SR[903] = {n:"Dofus 2 Convention",d:"",l:"fr",p:"0",t:0,c:"0",date:"1251324000000",rlng:[]};
SR[904] = {n:"Beta Dofus 2.0 FR",d:"",l:"fr",p:"0",t:0,c:"0",date:"1253829600000",rlng:[]};
SR[905] = {n:"Beta Dofus 2.0 JA",d:"",l:"ja",p:"0",t:0,c:"10",date:"1255039200000",rlng:[]};
SR[1001] = {n:"Shika",d:"Shika ist die hübsche Frau des berühmten Farle Ingalsse. Sie ist die Jugendfreundin König Allisters und berühmt für ihren Auftritt beim Sieg über Fu\'achid Fu\'Assap, einem furchtbaren und heimtückischen Dämon. Es heißt, sie sei unglaublich stark - sogar so sehr, dass sie sogar auf ihre Handschellen verzichten kann, wenn es darum geht, Störensfriede zu überwältigen und gefangenzunehmen.",l:"en",p:"0",t:0,c:"1",date:"1175724000000",rlng:["en"]};
SR[3001] = {n:"Nehra",d:"Nehra ist eine mächtige Zauberin, die in einer fernen Vergangenheit einmal das Dorf der ersten Siedler Amaknas vor der Vernichtung gerettet haben soll. Doch noch viele Jahrhunderte später berichteten Abenteurer immer wieder von wundersamen Rettungen aus höchster Not. Da die Zauberin nie spricht und sofort nach der erfolgreichen Rettung wieder verschwindet, wissen selbst die Weisen nur sehr wenig über dieses geheimnisvolle Wesen. Jedoch wird sie von zahlreichen Abenteurern heimlich als Schutzpatronin verehrt.",l:"de",p:"0",t:0,c:"3",date:"1184104800000",rlng:["de"]};
SR[3002] = {n:"Katar",d:"Katar war ein außergewöhnlicher Sacrieur-Krieger. Tapfer, stark wie ein MuWulf und  flink wie Moon. Drum wunderte es niemanden, dass sein Ruhm wuchs und wuchs... und an die Ohren eines Dämonen mit einer Schwäche für außergewöhnliche Krieger geriet. Der Dämon wirkte einen Fluch auf Katar. Seitdem irrt dieser durchs Land, auf der Suche nach einem Stärkeren, der ihn besiegen und so von seinem Fluch befreien könnte.",l:"de",p:"0",t:0,c:"3",date:"1259103600000",rlng:[]};
SR[4001] = {n:"Alma",d:"Alma ist Beschützerin aller erfahrenen Weltenbummler. Einer Legende nach soll sie eine neue Welt entdeckt und daraufhin eine geheimnisvolle Seekarte als Flaschenpost zurückgeschickt haben, welche den Weg dorthin beschreibt. Gerüchten nach soll noch keiner der Abenteurer, die sich in diese neue Welt gewagt haben, zurückgekommen sein. Möglicherweise sehen dort die Dinge besser aus... Andere behaupten, Alma habe ihnen geholfen, um ihnen den rechten Weg zu weisen, als sie sich in gefährlichen Gegenden verirrt hatten...",l:"es",p:"4",t:0,c:"4",date:"1184104800000",rlng:["es"]};
SR[4002] = {n:"Aguabrial",d:"Aguabrial, der Wasserdrache, wacht über eines der vier Elemente. Als die Welt noch jung war, gebar er den Türkis-Dofus. Doch wurde er von Djaul getäuscht, und verfolgt diesen nun mit seiner Rache. Auch wenn er äußerlich ruhig und gemäßigt erscheint, so bewahrheitet sich bei ihm die Volksweisheit: \"Stille Wasser gründen tief\".",l:"es",p:"2",t:0,c:"4",date:"1195772400000",rlng:["es"]};
SR[4003] = {n:"Buhorado",d:"Buhorado ist der verschollene Meister der „Firma“, der alle Eulen aus der Welt der Zwölf versammelt hat. Als belesene Buchhalter fungieren sie als Bankiers und als Wächter der Geschichte Ankamas. Buhurado war der Weiseste von ihnen, bis er vom Weg des Gäwinse-Spiels für  immer abkam.\nMan erzählt sich, dass sein Geist einige Jahrhunderte später zum letzten Mal in Erscheinung trat, aber dies wird von den Getreuen Allisters als Gerücht abgetan. Sie sehen in Buhurado ein Überbleibsel aus der „Ära des Paten“ und somit als einen Zweifler der königlichen Autorität.",l:"es",p:"2",t:0,c:"4",date:"1212357600000",rlng:["es"]};
SR[4004] = {n:"Schatten",d:"Schatten ist für mehrere von ihm angerichtete Massaker und seine legendäre Waffe berüchtigt. Diese Waffe nennt sich ein Peiniger. Sie wurde von seinem Adoptiv-Vater, dem Bastler Issering für ihn persönlich angefertigt und ermöglicht ihm erst, seine vollen Kräfte zu entfalten... Wenn Schatten diese Waffe trägt, verwandelt er sich nämlich in den gefürchteten Schatten-Ritter, dessen Namen die meisten Abenteurer nicht einmal auszusprechen wagen.",l:"es",p:"1",t:0,c:"4",date:"1224108000000",rlng:["es"]};
SR[4005] = {n:"Bolgrot",d:"Bolgrot ist ein geheimnisvoller Drache, dessen Schicksal die Welt der Zwölf erschüttert hat. Nachdem er von Aguabrial gezeugt wurde, verschwand er für die Dauer von ein paar Jahrhunderten, bis er schließlich Rykke Errel an den Türen von Amakna begegnete. Rykke kam ursprünglich, um Bolgrot zu bekämpfen, doch wurde eine feste Freundschaft daraus. Diese endete jedoch, als der wahnsinnig gewordene Bolgrot Rykkes Geliebte, Heléphine, tötete. In einem gigantischem Kampf brachten sich die Beiden gegenseitig um. In der Eingeweide Bolgrots fanden die Weisen Amaknas schließlich 6 Dracheneier seltsamer Farbe. So entstand der Mythos der Dofus.",l:"es",p:"0",t:0,c:"4",date:"1238709600000",rlng:[]};
SR[4006] = {n:"Nomekop",d:"Sowohl Freund, als auch Feind nennt ihn \"Den Unreifen\". Freunde hat er bloß zwei, nämlich Eratz und Edass. Feinde dafür umso mehr. Doch unreif wie er sein mag, dort wo Nomekop hintritt, da wächst lange Zeit kein Gras mehr!",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4007] = {n:"Edass",d:"Sein Spitzname lauter \"Der Unruhestifter\". Seltsam, denn eigentlich liebt er das Feiern...auf Kosten anderer. Der Legende nach soll er einen Dofus besitzen, entweder er, oder einer seiner beiden Freunde Nomekop und Eratz. Man könnte ihn ja mal höflich danach fragen...",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4008] = {n:"Eratz",d:"Eratz ist Teil des legendären Banditentrios von Cania. Wenn man einen von ihnen sieht, sind die beiden anderen, nämlich Nomekop und Edass niemals fern. Doch nur wenige sind dann noch da, um von der Begegnung zu erzählen.",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[6001] = {n:"Spiritia",d:"Saphira ist ein schillernder Drache, dessen Schuppen in allen Farben glänzen. Dieser Drache ist ein fleischgewordenes Symbol für den göttlichen Geist, der jedes Objekt und alle Kreaturen von Amakna erfüllt. Desweiteren repräsentiert er die Quadramentalbrise, wie sie in den Büchern des Alchimistenmeisters Hel Munster genannt wird.",l:"pt",p:"0",t:0,c:"6",date:"1206572400000",rlng:["en","pt"]};
SR[6002] = {n:"Helioboros",d:"Helioboros ist einer der drei Drachen, die von den Anhängern Osamodas besonders verehrt werden. Denn der Legende nach soll dieser große weiße Drache an der Erschaffung der Welt beteiligt gewesen sein und ihr das Licht gebracht haben! Anhänger Srams hingegen sind der Meinung, dass es Ouronigrid, der große schwarze Drache gewesen sei, welcher sich im Schwanz von Helioboros verbissen habe, woraufhin bei ihrem großen Kampf versehentlich die Welt entstanden ist... Was ist nun die Wahrheit? Ist das nicht egal? Es sind nun mal Legenden wie diese, die die Taschen von Magus X zum Klingen bringen...",l:"pt",p:"0",t:0,c:"6",date:"1253484000000",rlng:["en","pt"]};
SR[7001] = {n:"Dark Vlad",d:"Dark Vlad, dessen Name vortrefflich zutrifft, ist ein berühmt-berüchtigter Iopkrieger, dessen Name von Bonta bis Brâkmar Angst und Schrecken verbreitet. Er reitet auf einem geflügeltem Kleppripp-Reittier und trägt ein von Abenteurern heiß begehrtes Flammenschwert. Dark Vlad haust tief im Schattenwald, wo er tollkühne Abenteurer, die ihm zu nahe kommen, in kleine Stückchen zersäbelt. ",l:"nl",p:"0",t:0,c:"7",date:"1219788000000",rlng:["nl"]};
SR[9001] = {n:"Ereziah",d:"Ereziah ist ein Alchimist aus alten Zeiten und anerkannter Exorzist, der auch durch seine Freundschaft mit dem Wasserdrachen Aguabrial bekannt ist. Seine Zauberkenntnisse werden nur von seinem Scharfsinn übertroffen und durch seine Gabe ist er auf allen Erdteilen berühmt.\nEinst rettete er seinen Freund Aguabrial aus der Falle des Dämons Djaul;\r\n            nur wenige können sich rühmen, Djaul jemals überlistet zu haben.\nDie Legende will es, dass dieser einfache Sterbliche den mächtigen Drachen aus der Verzauberung von Djaul dem Grossen Planscher rettete: diese Begebenheit verursachte das Ausschlüpfen eines DOFUS und der Drache war geboren.",l:"it",p:"0",t:0,c:"9",date:"1212357600000",rlng:["it"]};
