SR = new Object();
SR[1] = {n:"Jiva",d:"Jiva ist die Beschützerin des Monats Javian. Sie ersetzte in dieser Position Solar, nachdem dieser von Djaul getötet wurde. Sie war zusammen mit Pouchecot und Ménalt Gründerin der Stadt Bonta, die sie erbauten, um die wachsende Macht von Brâkmar aufzuhalten.",l:"fr",p:"4",t:0,c:"0",date:"1093298400000",rlng:[]};
SR[2] = {n:"Rushu",d:"Rushu ist ein Dämonenlord, der davon träumt, auf die gleiche Stufe wie die Götter zu treten. Es ist ihm gar gelungen, Djaul, seinen Günstling, als Beschützer des Monats Descendre einzusetzen. Ganz besonders hasst er die Göttin Sacrieur, welcher er vorwirft, seinen rechtmäßigen Platz eingenommen zu haben.",l:"en",p:"2",t:0,c:"2",date:"1125525600000",rlng:[]};
SR[3] = {n:"Djaul",d:"Djaul ist ein Dämon, der treu zu Rushu hält. Doch vor allem ist er der Beschützer des Monats Descendre. Diese Stellung hat er inne, seit er den früheren Beschützer von Javian, Solar im Kampf niederstreckte. Ihn treibt ein gewaltiger Hass auf alle übrigen Monatsbeschützer an.",l:"fr",p:"4",t:0,c:"0",date:"1132527600000",rlng:[]};
SR[4] = {n:"Raval",d:"Raval, der Schreckliche, ist der Beschützer des Monats Septange. Niemand weiß, was er wirklich bezweckt. So half er beispielsweise beim Aufbau der dunklen Stadt Brâkmar, versetzte den Brâks allerdings dennoch bei der Schlacht des purpurnen Morgenröte den Todesschlag, so dass diese verloren. Die Halsabschneider schwören ihm in einem mysteriösen Kult die Treue.",l:"fr",p:"4",t:0,c:"0",date:"1140562800000",rlng:[]};
SR[5] = {n:"Hecate",d:"Hécate ist die Beschützerin des Monats Joullier. Sie ist eine Dämonin, die immer unabhängig bleibt. Einst rettete sie sogar Ulgrud, den Beschützer von Martalo, nachdem dieser gegen Djaul gekämpft hatte. Man könnte beinahe spekulieren, sie hege eine geheime Liebe zu Ulgrud.",l:"fr",p:"4",t:0,c:"0",date:"1145916000000",rlng:[]};
SR[6] = {n:"Summens",d:"Summens ist ein treuer Anbeter des Gottes Enutrof. Darüberhinaus ist er der Beschützer des Monats Juinssidor. Er besitzt einen gar erstaunlichen Stoffwechsel, denn alles, wass er isst, wandelt er wieder in wertvolle Edelsteine um.",l:"fr",p:"4",t:0,c:"0",date:"1149717600000",rlng:[]};
SR[7] = {n:"Menalt",d:"Menalt war ein mächtiger Zentaur-Krieger und der Meister des Ordens des Tapferen Herzens. Gleichzeitig war er auch der Beschützer des Monats Martalo. Doch all dies konnte ihn nicht retten. Er fiel bei einem Brâk-Angriff im Laufe der Schlacht der purpurnen Morgenröte.",l:"fr",p:"4",t:0,c:"0",date:"1156802400000",rlng:[]};
SR[8] = {n:"Rosal",d:"Rosal ist der Wächter aller Blumen, und Beschützer des Monats Maisial. Man sollte sich allerdings nicht von seinem sanftmütigen Wesen täuschen lassen. Als Telepath ist er in der Lage, den Geist aller Sterblichen zu sondieren: er kennt ihre intimsten Geheimnisse, und es ist ihm ein Leichtes, alle Art von Lügen auszudecken. Dabei zeigt er keine Gnade all denen gegenüber, die nicht reinen Geistes sind.",l:"en",p:"1",t:0,c:"2",date:"1159221600000",rlng:[]};
SR[9] = {n:"Maimane",d:"Maimane, der Ausgleichende, ist der Beschützer des Monats Octolliard. Der ewigen Schlachten und Kämpfe müde, beschloss er seine Emotionen zu versiegeln, indem er sie magisch im Boden einschloss. So verschwanden Liebe und Hass aus seinem Herzen, bis sie durch einen (glücklichen) Zufall wiedergefunden wurden.",l:"fr",p:"4",t:0,c:"0",date:"1159826400000",rlng:[]};
SR[10] = {n:"Silvosse",d:"Silvosse, der Meister der Ästlinge, ist der Beschützer des Monats Flovor. Wenn es darum geht, die Vegetation unter seiner Obhut zu schützen, dann kennt er keine Grenzen. So bemächtigte er sich zum Beispiel einst der Seele einer Gruppe schlechtberatener Holzfäller und sperrte sie in die gefällten Baumstämme. So wurde das Volk der Astaknyden erschaffen, sagt man.",l:"fr",p:"4",t:0,c:"0",date:"1165273200000",rlng:[]};
SR[11] = {n:"Brumaire",d:"Brumaire, der finstere Fürst der Finsternis, ist der Beschützer des Monats Novamaire. Bei der Schlacht der purpurnen Morgenröte stand er an Djauls Seite, doch seit eben dieser Niederlage wird er von Rachdurst geleitet und wartet nur eine Gelegenheit, Djaul herauszufordern, den er für einen inkompetente, arroganten Schwachkopf hält.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[12] = {n:"Pouchecot",d:"Pouchecot, der Fruchtige, ist der Beschützer des Monats Fraouctor. Er trug viel zur Gründung von Bonta bei. Mit seinem aufgeweckten Geist und als großer Kenner von allen Künsten, insbesondere der Musik, bringt er es sogar fertig, dass sich selbst Weich-Eich vor Lachen zu Boden biegt.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[13] = {n:"Silouate",d:"Silouate ist ein Minotoror, der dank seiner großen Weisheit zum Beschützer des Monats Aperirel wurde. Er ist derjenige, der die letzten Spuren des schwindenden Winters vertreibt. Als enger Freund von Summens wird auch ihm Ehre für die Entscheidung gezollt, die Dofus außer Reichweite der Habsucht der Abenteurer gebracht zu haben.",l:"fr",p:"4",t:0,c:"0",date:"1171321200000",rlng:[]};
SR[14] = {n:"Domen",d:"Domen ist eine der drei grauen Eminenzen von Brâkmar. Er ist seinem Herrn Brumaire treu ergeben und durch und durch verdorben. Seit der Niederlage bei der Schlacht der Morgenröte, ist er - wie sein Herr - von tiefer Bitterkeit erfüllt - und zwar so sehr, dass er üblicherweise in Gestalt eines wandelnden Geistes auftritt.",l:"fr",p:"4",t:0,c:"0",date:"1175724000000",rlng:[]};
SR[15] = {n:"Amayiro",d:"Amayiro ist ein Mitglied des Hohen Rates von Bonta. Angesichts der ständigen Kriege rief dieser alte kampferprobte Kriegsveteran die Miliz der Stadt ins Leben, um die Verteidigung und Sicherheit in Bonta zu stärken. Trotz seines hohen Alters leitet er auch heute noch die Miliz mit eiserner Faust.",l:"fr",p:"4",t:0,c:"0",date:"1179784800000",rlng:[]};
SR[16] = {n:"Rykke Errel",d:"Rykke Errel war ein junger Anhänger Iops und der einzige Krieger, der den Mut aufbrachte, dem fürchterlichen Drachen Bolgrot entgegenzutreten. Er besiegte ihn, verschonte ihn jedoch. So wurde der Drache sein Freund. Außer sich vor Wut und Eifersucht tötete die Bestie später Rykkes Geliebte, woraufhin Rykke ihn letztlich erschlug.",l:"fr",p:"4",t:0,c:"0",date:"1182808800000",rlng:[]};
SR[17] = {n:"Hyrkul",d:"Hyrkul ist ein treuer Diener von Djaul. Er ist nicht nur genauso grausam und böse wie sein verdorbener Lehnsherr, sondern auch ein mächtiger Krieger, der den Kampf liebt. Rushu persönlich hat ihn zum Dank für die geleisteten Dienste in die Reihen der Unsterblichen aufgenommen.",l:"fr",p:"4",t:0,c:"0",date:"1183413600000",rlng:[]};
SR[18] = {n:"Helsephine",d:"Helséphine war eine sanftmütige und schöne Magierin. Mit ihrer Schönheit gewann sie das Herz von Rykke Errel, dem berühmten Helden, doch ebenfalls von dessen Freund, dem Drachen Bolgrot. Letzterem gelang es nicht, die Liebe im Herzen der jungen Frau zu entfachen. In auflodernder Eifersucht spie er daher seine Flammen aus und ließ seine  Angebetete in ihnen zu Tode kommen. Rykke Errel brachte Bolgrot anschließend zur Strecke, um seine große Liebe zu rächen.",l:"fr",p:"4",t:0,c:"0",date:"1192485600000",rlng:[]};
SR[19] = {n:"Allister",d:"Allister ist der geschätzte König von Amakna. Als einfacher Hirte leistete er eine Ruhmestat bei der Ergreifung des gefürcheten Dämons Fu\'achid Fu\'Assaps. Bei dieser Gelegenheit gründete er auch die erste Gilde in der Geschichte der Welt der Zwölf. Nachdem er viele Jahre isoliert in seinem Schloss gelebt hat, greift er nun wieder aktiv in die Staatsgeschäfte ein.",l:"fr",p:"4",t:0,c:"0",date:"1196722800000",rlng:[]};
SR[20] = {n:"Otomaï",d:"Otomaï ist ein begabter Alchemist und der Erfinder des Trankes gegen die Myxomawose. Desweiteren hat dieser Erforscher der Lebenskräfte aller Kreaturen die Insel entdeckt, die nun seinen Namen trägt. Dort widmet er sich geheimen Forschungen, gefährliche Experimente an allen Tierarten der Welt der Zwölf durchzuführen...",l:"fr",p:"4",t:0,c:"0",date:"1201215600000",rlng:[]};
SR[21] = {n:"Lily",d:"Lily ist für ihre Navigationskünste bekannt, dank derer sie es in 80 Tagen um die ganze Welt schaffte. Auf ihren Expeditionen entwickelte sie eine wahre Vorliebe für die Wabbits - sofern sie in spießgerechten Häppchen gereicht werden. Seither unternimmt sie regelmäßig kulinarische Ausflüge auf die Wabbit-Insel, an denen sie diverse Abenteurer teilhaben lässt, deren Gaumen sie gerne verwöhnt, um sie anschließend um ein paar Kamas zu erleichtern. Denn Lily verfügt nicht nur über einen unfehlbaren Orientierungs-, sondern auch über einen ausgeprägten Geschäftssinn.",l:"fr",p:"2",t:0,c:"0",date:"1203030000000",rlng:[]};
SR[22] = {n:"Oto Mustam",d:"Oto Mustam ist der Chef der Miliz von Brâkmar. Er ist impulsif, grausam und gewalttätig. Er ist Djaul treu ergeben und hasst seine anderen Mitmenschen. Seine Treue gegenüber den Dämonen hat dazu geführt, dass er Rushu aufgefallen ist, der ihm folgenden Auftrag gegeben hat: er soll dafür Sorge tragen, dass eine bestimmte Welt der Zwölf noch viel grausamer und chaotischer ist, als alle anderen. Zu diesem Zweck wählt er tapfere Kämpfer, die später Teil der gewaltigen Dämonenarmee werden, mit welcher der letzte Kampf gegen die Götter durchgeführt werden soll.",l:"en",p:"0",t:1,c:"2",date:"1222120800000",rlng:[]};
SR[23] = {n:"Hel Münster",d:"Hel Münster wird von seinen Kollegen als der beste Magier von Amakna angesehen und unterrichtet Abenteurer in seinem Spezialfach, der Schmiedmagie, vorausgesetzt diese erweisen sich dessen würdig. Hel ist auch Autor des Bestsellers \"Magische Gegenstände für Dumme\", in der unter anderem seine Theorie  zum Erscheinen der Quadratbrise beschrieben wird.",l:"fr",p:"2",t:0,c:"0",date:"1205794800000",rlng:[]};
SR[24] = {n:"Danathor",d:"Danathor ist der Intendant von Bonta. Er wurde von Jiva höchstpersönlich in dieses Amt gehoben. Als treuer Gefolgsmann der Beschützerin des Monats Javian ist er zu allem bereit, um Brâkmar zu vernichten - koste es, was es wolle! Dieser machtversessene Herr ist der Feind von Amayiro und wartet nur darauf, sich einen  Platz ganz oben der Hierarchie der Welt der Zwölf zu erobern...",l:"fr",p:"2",t:0,c:"0",date:"1208469600000",rlng:[]};
SR[25] = {n:"Kuri",d:"Kuri ist eine der drei berühmten Liebespriesterinnen, die für jenes unzüchtige Fieber verantwortlich waren, das einst die Gelees von Amakna heimsuchte.\nSie ist die Linke Hand der berüchtigten Oma Pralinchen. Man kann man sie sowohl an ihrem legendären Bogen erkennen, als auch an ihrer aufgeblasenen Kopfbedeckung.",l:"fr",p:"1",t:0,c:"0",date:"1211839200000",rlng:[]};
SR[26] = {n:"Mylaise",d:"Bevor sie Liebespriesterin wurde, war Mylaise nur eine unscheinbare Ecaflip-Anhängerin unter vielen. Topfit und mit wohlgefittetem Top wurde sie beinahe als Kandidatin für die Dofus-Akademie ausgewählt. Doch Oma Pralinchen kam der Akademie zuvor und machte Mylaise zur Wächterin des\nHöllehmturmes.",l:"fr",p:"1",t:0,c:"0",date:"1223330400000",rlng:[]};
SR[27] = {n:"Goultard",d:"Auch wenn Goultard äußerlich einem Iop ähnelt, so ist nicht mehr viel an ihm menschlich... Einst besaß er neben seinen starken Muskeln auch ein gutes Herz, doch brachten ihn tragische Erlebnisse dazu, den Weg von Chaos und Zerstörung zu verfolgen. Doch auch heute noch ist und bleibt Goultard wohl einer der mächtigsten Krieger der Welt der Zwölf.",l:"fr",p:"0",t:0,c:"0",date:"1227135600000",rlng:[]};
SR[28] = {n:"Ulette",d:"Ulette ist ein betörend schönes Ecaflippchen. Mit ihren Verführungskünsten und ihrer subtilen Zuckerbrot-und-Peitschen-Methode hat sie bereits mehr als nur einen Abenteurer um seinen Verstand gebracht. Schließlich verlor sie jedoch den Ihren, nämlich als der von ihr verführte Ecaflipheld Dodge in einem Anfall trauriger Ungeschicklichkeit ihren Kopf von den Schultern trennte. Ähnliches wiederfuhr auch Vald, aber das ist eine Geschichte für ein andermal.",l:"fr",p:"0",t:0,c:"0",date:"1230505200000",rlng:[]};
SR[29] = {n:"Vil Smisse",d:"Vil Smisse hat bereits viel gesehen auf seinem Weg vom einfachen Räuber bis hin zu einem echten Symbol des Bösen. Als Chef des Clans der Halsabschneider liebt er es, geheimnisvoll und unerreichbar zu erscheinen!",l:"fr",p:"1",t:0,c:"0",date:"1234479600000",rlng:[]};
SR[30] = {n:"Many",d:"Many ist der geschickteste Xélor von Djaul und ein Meister, wenn es darum geht, Informationen aus jemandem herauszupressen. Die Unschuldigen, die unter seinen Zifferblättern ihre Schuld zugegeben haben, sind unzählig. Seine Arbeit macht ihm viel Spaß, was in diesem Job ein großes Plus ist.",l:"fr",p:"0",t:0,c:"0",date:"1236898800000",rlng:[]};
SR[31] = {n:"Solar",d:"Solar war ein legendärer Iop-Krieger und der frühere Beschützer des Monats Javian. Seine gewaltige Stärke folgte dem Stand der Sonne: sie nahm stets morgens zu, erreichte mittags ihren Höhepunkt und nahm im Laufe des Nachmittages immer weiter ab. Solar fiel am 31. Descendre im Jahr 11 bei Abenddämmerung im Kampf gegen Djaul und wurde am 12. Flovor des Jahres 12 durch Jiva ersetzt.",l:"en",p:"0",t:0,c:"2",date:"1214258400000",rlng:[]};
SR[32] = {n:"Crocoburio",d:"Crocoburio, Sohn von Crocabulia und Grougalorasalar, war der Anführer der Crocodylls. Als unübertroffener Kämpfer hat er sich in zahlreichen Schlachten ausgezeichnet, bis er schließlich während einer Schlacht gegen Bonta von den Rittern der Stadt getötet wurde. Übrig blieb nur das Crocobur, sein mythisches Schwert.",l:"fr",p:"0",t:0,c:"0",date:"1259017200000",rlng:[]};
SR[33] = {n:"Li Crounch",d:"Sadida Anhänger und von Beruf Maler, hat Li Crounch sein Leben damit zugebracht, die Weisungen seines Gottes mit unerbittlichster Strenge zu befolgen: Meditation und Liebe zur Natur. Der junge Künstler machte es sich zur Aufgabe, mindestens 20 Stunden von 24 zu schlafen und den Rest der Zeit damit zu verbringen, Blumen zu malen, auch wenn das nur wenige Leute glauben können. Er bleibt dennoch ein Vorbild für zahlreiche Sadidas.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[35] = {n:"Farle",d:"Farle Ingalsse, ein berühmter Bauer, ist für seine Geduld und seine Liebe zur Erde bekannt. Schon seit jeher bebaut er sorgfältig seine Felder im Herzen Amaknas, auch wenn Horden von Abenteurern über seine Getreideäcker treten. Farle hat es auch geschafft, die Abenteuerlust einer anderen berühmten Abenteurerin zu zügeln und sie für sich zu erobern, nämlich Shika Ingalsse.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[36] = {n:"Agrid",d:"Da wo bestimmte Holzfäller Amaknas wie Bruce Bulgour mit ihren tollkühnen Taten in die Legende eingegangen sind, sind andere bescheidener und anonymer geblieben, wie es zum Beispiel bei Agrid der Fall ist. Glücklicherweise sind weder Tüchtigkeit und Verdienst mit Ruhm verbunden und Agrid fehlt es weder am einen noch am anderen. Er gibt gerne die Mysterien der Hackkunst an all jene weiter, die danach fragen.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[37] = {n:"Bowisse",d:"Bowisse ist ein talentierter und respektierter Schuhmacher, ihm verdankt man übrigens die schönsten und originellsten Gürtel und Stiefel in der Welt der Zwölf. Seine Berühmtheit erlangte er vor allem durch seine einzigartige Fähigkeit  Kleider zu entwerfen, die sich perfekt dem Kunden anpassten, der sie bestellte. Zahlreiche Abenteurer haben einen Stiefel vertragen können und keiner hat sich je beklagt!",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[38] = {n:"Ogivol",d:"",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[39] = {n:"Lethalina",d:"",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[40] = {n:"Aermyne",d:"Aermyne genoss lange Zeit einen ausgezeichneten Ruf bei den Müttern Amaknas, denn niemand konnte so gut wickeln, baden, Fläschchen geben wie sie. Doch eines Tages hörte sie eine Stimme in ihrem Kopf und die Dinge änderten sich. Schluss mit Wäsche und Fläschchen, von nun an jagte Aermyne die Knirpse mit dem Wäscheklopfer hinaus. Keiner begriff warum und Aermyne ging auf Pandala ins Exil.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[41] = {n:"Zatoïshwan",d:"Zatoïshwan, ein eingefleischter Spieler (was für einen Pandawa eher selten ist) und auch noch blind, hatte einen Ruf, der sogar die größten Ecaflip Spieler erzittern ließ. Eines Tages wurde er vom Blitz getroffen und er ging daraus wie von der Göttin Pandawa erleuchtet hervor: plötzlich beherrschte er die alte Kunst des Pandawushu. Woraufhin er sich eine Zeitlang als Rächer betätigte...bevor er zum gesuchten berüchtigten Banditen wurde.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
