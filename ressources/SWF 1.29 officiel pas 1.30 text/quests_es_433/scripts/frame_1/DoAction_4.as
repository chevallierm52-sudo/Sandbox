Q.s[339] = {n:"Desplumar a Gobrosa",d:"Gobrador le tiene envidia a los píos de Gobrosa. ¡El único que puede hacer palpitar su corazoncito es él y nada más!",r:[3000,null,null,null,null,null]};
Q.s[337] = {n:"Llenarse la panza",d:"Bworcina acepta cambiar su esclava por su peso en cerveza bwork.",r:[12000,null,null,null,null,null]};
Q.s[338] = {n:"Conceder el pretendiente",d:"¿Acabarán Gobrosa y Gobrador uniéndose?",r:[null,3000,null,null,null,null]};
Q.s[336] = {n:"Encontrar la guarida del Bworkcina",d:"Buscar el lugar de detención de Gobrosa.",r:[1000,null,null,null,null,null]};
Q.s[354] = {n:"Luchar para la guardia",d:"El capitán te encargó una tarea sencilla pero útil.",r:[195,null,null,null,null,null]};
Q.s[345] = {n:"Relevo de la guardia",d:"Diskre te ha pedido que controles si los guardias están haciendo bien su trabajo.",r:[230,null,null,null,null,null]};
Q.s[362] = {n:"Volver a la vida",d:"Almae Terna te ha transformado en fantasma, utiliza el fénix para recuperar tus fuerzas.",r:[null,null,null,null,null,null]};
Q.s[363] = {n:"¡Osemos el osa!",d:"¡Este osa vanidoso se merece una buena paliza!",r:[500,null,[[8534,1]],null,null,null]};
Q.s[368] = {n:"Luchar para la guardia",d:"El capitán te encargó una tarea sencilla pero útil.",r:[195,null,null,null,null,null]};
Q.s[369] = {n:"Luchar para la guardia",d:"El capitán te encargó una tarea sencilla pero útil.",r:[195,null,null,null,null,null]};
Q.s[370] = {n:"Luchar para la guardia",d:"El capitán te encargó una tarea sencilla pero útil.",r:[195,null,null,null,null,null]};
Q.s[372] = {n:"Encontrar Aguado",d:"A pesar de su pésimo acento, has comprendido lo que quería Marylork.",r:[75,75,null,null,null,null]};
Q.s[373] = {n:"Noken chochea",d:"Noken cuenta su vida de antiguo aventurero.",r:[10,null,null,null,null,null]};
Q.s[385] = {n:"Encontrar la guarida de los Tymadores",d:"Yse Vewybad te dio indicios sobre la posición de los Pillos...Acércate al cementerio.",r:[9000,null,null,null,null,null]};
Q.s[384] = {n:"Encontrar al sram",d:"Yse Vewybad te habló de un sram importante en Amakna...¿Dónde se pueden encontrar los srams en Amakna?",r:[1000,null,null,null,null,null]};
Q.s[394] = {n:"Encontrar al pretendiente.",d:"Debes encontrar a un pretendiente para Allisteria, la hija del hermano del rey.",r:[15000,null,null,null,null,null]};
Q.s[395] = {n:"En busca de informaciones.",d:"Vis Smis quiere que reúnas informaciones sobre lo que se está preparando en el castillo. Debes buscar a alguien que te pueda informar.",r:[3000,null,null,null,null,null]};
Q.s[396] = {n:"Buscar las 4 patas al Miaumiau",d:"Ahora sabes que el rey quiere casar a su sobrina... ¿Pero con quien?",r:[12000,null,null,null,null,null]};
Q.s[402] = {n:"Falsa identidad",d:"Como puedes notarlos, Uba Teseo te ha transformado en Wabbit. Ahora no tienes más que ir al castillo para hacer fracasar la boda.",r:[50000,25000,null,null,null,null]};
Q.s[401] = {n:"Después de la receta, los ingredientes.",d:"Ahora que Uba tiene la fórmula, solamente le faltan los ingredientes.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"Haz el favor traerme una fórmula.",d:"Tienes que encontrar a los alquimistas esparcidos por Amakna.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit powa",d:"Encontrar una forma de transformarse en Wabbit.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"Empache",d:"Ya tienes el huevo de Tofu obeso pero el huevo solamente no acabará con el pwíncipe... Tienes que encontrar algo para cebarlo.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Un huevo nuevo",d:"Vil Smis te ha pedido un huevo de tofu obeso. Tendrás que buscar algún nido antes...",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"En busca de matones",d:"Vil Smis no podrá utilizar el blopicero envenenado. Por eso optó por un ataque frontal. Para eso quiere contratar asesinos, o sea que necesita dinero para ello.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"Un regalo envenenado",d:"Vil Smis decidió evitar una confrontación directa y ocuparse del asunto según la tradición de los Tymadores: A lo falso.",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Aguafiestas",d:"Los asesinos han fracasado en su intento de matar al príncipe... Vil Smis te pide ir a contratar a un Zollo para acabar con él.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"¡Muerte al tofu!",d:"Sabes donde el pwíncipe del Wey fue a cazar, bueno más o menos... Se encuentra al sur de Bonta. ¡Búscalo y encuéntralo!",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"A trabajar",d:"Vete a preguntarle al contramaestre lo que debes hacer.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Por favor, un favor.",d:"El intendente San Lavals pide tu ayuda para los últimos preparativos de la boda.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"1era etapa",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"Un disfraz para Esmeralda",d:"Esmeralda busca desesperadamente un set Koalak.",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Responder al interrogatorio",d:"El guardián del Puente de la Muerte exije que respondas correctamente a sus preguntas.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Para preparar el viaje",d:"El Capitán Guarrok necesita que le lleves varios objetos para poder llevarte en su barco.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"El Cofre Maldito del Flib",d:"El barco del Capitán Guarrok se ha encallado en la isla de los náufragos. Tienes que encontrar el Cofre Maldito del Flib y otros objetos para reparar el barco.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"¡No pasarás!",d:"El Caballero Negro y Rosa está firmemente decidido a no dejarte pasar. Quizas este sea un buen momento para hacer uso de la fuerza.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"Una pócima para el profesor",d:"El Profesor Fornasol necesita una pócima Búlbica para ponerse a trabajar.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Las máquinas de cría",d:"Polka Merer necesita unas máquinas de cría para sus criaturas.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"Cuestión de harinas",d:"Paulina Panela, la panadera, pretende cortar su harina de Javier el Panadero con otras harinas más baratas. ¡Ella tuvo la idea, así que a ti te toca encontrar las harinas!",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"En busca del hijo escondido",d:"El Doctor Niet a perdido a su hijo en un laboratorio infectado de horribles criaturas salvajes. ¡Encuéntralo y asegúrate de que sigue vivo!",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"Un Doctor sin su Morros",d:"El pobre Doctor Morros ha perdido a su mujer. Ayúdalo a encontrarla en la Oscura Jungla e intenta convencerla de que vuelva con su marido, para que éste pueda volver a su investigación.",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"Equipo mejorado",d:"Spit Faller está buscnado un casco  y unas alas de piloto mejorados. Necesitarás la ayuda de un sastre experimentado.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Dos dragopavos para Flip Flap",d:"Flip Flap quiere que le lleves un certificado de Dragopavo Pelirrojo y un certificado de Dragopavo Almendrado.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Safari en la Oscura Jungla",d:"A Cocodrail Dandi le gustaría que machacases algunas criaturas de la Oscura Jungla.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Safari de llanuras",d:"A Cocodrail Dandi le gustaría que machacases algunas criaturas de las Llanuras Herbosas.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Safari de playa",d:"A Cocodrail Dandi le gustaría que machacases algunas criaturas de la Playa de Coral.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Safari en el Árbol Hakam",d:"A Cocodrail Dandi le gustaría que machacases algunas criaturas del Árbol Hakam.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Safari en la Turbera sin fondo",d:"A Cocodrail Dandi le gustaría que machacases algunas criaturas de la Turbera sin fondo.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"Un ejemplo para los piratas",d:"Kito te ha pedio que des una lección ejemplar a los Piratas que le disparan en pleno vuelo.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"El Caballero Negro y Rosa",d:"A Peggy la Puerkaza le gustaría que te enfrentases con el caballero Negro y Rosa en su lugar.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"El cambio maldito",d:"Quizás Farle Ingals sea la única persona de Amakna capaz de conseguir que esta espada maldita vuelva a ser utilizable...",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"¡Corre, corre!",d:"Están a punto de robarle a Milone. Date prisa para poder evitarlo.",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Pescador de caña, paciencia y maña.",d:"No ha habido ningún problema durante el viaje. Los bandidos no han atacado... Amayiro está esperando tu informe.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"Trampa para zurcaráks.",d:"Amayiro quiere tender una emboscada a los bandidos, pero para que caigan en la trampa hace falta una joya de gran valor.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Escort Guerl.",d:"Tu misión es escoltar hasta Astrub a la tropa de mercaderes de Guerl.",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"El informe.",d:"Unos bandidos zurcaráks, que se parecían a aquellos que descubriste en el campamento, han atacado el convoy. Amayiro está esperando a que le lleves el informe para convencer al consejo de actuar.",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Al buen informador, unos Kamas bastan.",d:"En el templo Sram, Rigal Mano Ganchuda tiene la reputación de saberlo todo, pero toda información tiene su precio. Sólo falta saber a cuánto asciende lo que quieres saber.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"El taller está enregistrado quien lo desenregistrará...",d:"Tienes que encontrar las reservas de veneno de Brakmar y robar el registro de clientes del taller de alquimistas. Bishom Pot quizás pueda ayudarte.",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"Alquimia para tontos.",d:"Tienes que robar el registro de clientes en el taller de alquimistas de Brakmar y llevárselo a Rigal Mano Ganchuda.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Dos cómplices.",d:"Para penetrar en las reservas de veneno de Brakmar, necesitarás un sram o un espía cualificado.",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Atrápalos como puedas.",d:"Una cita entre un brakmariano y un bontariano corrupto va a tener lugar en la Torre de Bonta. Hay que capturar a los dos, si es posible.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"No hay salida para los traidores.",d:"Tienes que hacer la ronda con los milicianos para apostarlos en la Torre de Bonta.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"¡Bwork, qué peste!",d:"Puede que Etenipse Tik no sepa nada más o puede que se niegue a contártelo. En cualquier caso, los bworks magos deberían ser menos reacios a informarte sobre uno de los suyos.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Danathor, ¿qué nos tienes guardado aún?",d:"Danathor parece tener una nueva oferta que proponerte. Probablemente algún asunto sucio.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"La muñeca encantada.",d:"Tienes que encontrar cuatro sadidas lo suficientemente experimentadas en invocar Hinchables, para realizar el ritual de aguas encantadas de los lagos Koalaks.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Genialísimo.",d:"Si le quitas la maldición a Jean-Bworknouille, seguramente que para agradecértelo te contará lo que sabe. También ha sugerido que te informes en la biblioteca.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"En busca del secretario judicial triste.",d:"Aigurraf, el secretario judicial de la Orden del Ojo Atento, frecuenta las tabernas desde que desapareció su ratón. Hay que llevarlo a ver a Onidal.",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Salida de prisión.",d:"Tienes que salvar a un guerrero que Bonta ha capturado. Podrás encontrarlo en el sótano de la prisión de la milicia bontariana.",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"Enemigo Íntimo",d:"Encuentra y elimina a tu objetivo.",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Ganar el combate",d:"Sigue atacando para ganar el combate. Pasa el turno con el botón {ui,banner,btn_skipTurn::Pasar su turno} cuando quieras recuperar tus {ui,banner,lbl_pa,2::PA} y tus {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Terminar el combate",d:"Gana el combate contra el monstruo. Atención, ahora los turnos duran un tiempo limitado. El {ui,banner,tx_artwork,3::indicador de tiempo} marca cuanto tiempo has utilizado y cuanto te queda antes de que se termine el turno.",r:[null,null,null,null,null,null]};
Q.s[1042] = {n:"Desplazamiento por el mapa",d:"Bienvenido al tutorial guiado. Haz clic con el botón izquierdo y tu personaje irá donde le has indicado (si es posible). Si haces clic lejos de tu pérsonaje, correrá. Si no, irá andando.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Pasar el turno",d:"Cuando hayas acabado de actuar, haz clic con el botón izquierdo en el botón {ui,banner,btn_skipTurn::Pasar su turno} para acelerar el desarrollo del combate y recuperar tus {ui,banner,lbl_pa,2::PA} y tus {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Equipar un objeto",d:"Abre tu interfaz de {ui,banner,btn_character,1::características}. Mueve el {ui,storage,grid::Anillo de principiante} que acabas de ganar seleccionándolo con el botón izquierdo y, sin soltar el botón, arrastrándolo hasta el {ui,characterSheetUi,slot_2,2::lugar reservado para anillos} de la ficha de tu personaje.\nTambién puedes equipártelo haciendo rápidamente clic dos veces con el botón izquierdo en el {ui,storage,grid::anillo de principiante}.",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"Equiparse objetos",d:"Abre tu interfaz de {ui,banner,btn_character,1::características} y equipa a tu personaje con todos los objetos que has ganado.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Desplazarse durante el combate",d:"Tu perosnaje posee {ui,banner,lbl_pm,2::puntos de movimiento} (PM) para desplazarse. Desplazarse de una casilla a otra cuesta 1PM. Para hacer que tu personaje se desplace haz clic con el botón izquierdo en la casilla a la que desees moverlo. \nRecuperarás tus {ui,banner,lbl_pm,2::PM} al principio de tu siguiente turno.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Utilizar un hechizo",d:"Selecciona {ui,banner,gd_spellitemotes,0::un hechizo} y haz clic con el botón izquierdo en tu objetivo. Algunos hechizos se lanzan a los enemigos, otros a los aliados o incluso a tu personaje. Las casillas azules indican el alcance del hechizo. Para lanzar los hechizos necesitarás {ui,banner,lbl_pa,2::puntos de acción} (PA). Recuperarás los {ui,banner,lbl_pa,2::PA} en cada turno.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Elegir la casilla de partida",d:"Haz clic en una de las {cell,272::casillas azules} para elegir tu posición de partida. Luego, haz clic en {ui,banner,btn_ready::Listo} para comenzar el combate.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Cambiar de mapa",d:"Para cambiar de mapa (pantalla), haz clic en {cell,335::los bordes de la pantalla} cuando el cursor se transforme en una flecha.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Vencer al monstruo",d:"Para acabar la misión, ve a la {arrow,700,870,0,1::sala siguiente} y lanza un combate contra {monster,2781::el monstruo}.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Concluir el aprendizaje",d:"Para validar tu misión debes contarle tu victoria a {npc,1222::Mauricio, el guía} .",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Comenzar una misión",d:"Habla con {npc,1222::Mauricio, el guia} para empezar la misión (los PNJ que proponen misiones tienen un signo de exclamanción sobre la cabeza).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Hablar con un pnj",d:"Haz clic con el botón izquierdo en {npc,1222::Mauricio, el guía} y selecciona la acción \"hablar\" para conversar con él.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Lanzar un combate",d:"Haz clic con el botón izquierdo en el {cell,313::espantapájaros de Incarnam} para lanzar un combate.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"Una vida complicada",d:"Tendrías que haber seguido los consejos de Essel Dawa y haber desconfiado. Ahora parece que tu cabeza tiene precio. Desgraciadamente, la vida no siempre es tan fácil como parece...",r:[null,null,null,null,null,null]};
Q.s[1058] = {n:"¡Acabaremos con ello!",d:"Gracias a tu ayuda, Essel Dawa podrá erradicar el mal que afecta al mercado de bebidas pandáwicas... siempre que encuentre antes un antídoto.",r:[3000,null,[[10818,1]],null,null,null]};
Q.s[1056] = {n:"La vida fácil",d:"Acabas de llegar y ya te proponen un modo de ganarte la vida fácilmente y sin cansarte demasiado. ¡¿Qué más quieres?!",r:[null,null,null,null,null,null]};
Q.s[1091] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1054] = {n:"",d:"",r:[null,null,null,null,null,null]};
Q.s[996] = {n:"Ir al templo.",d:"Ve al templo de tu clase y aprovecha para luchar contra el dopeul que allí encontrarás.",r:[5000,null,null,null,null,null]};
Q.s[884] = {n:"¡Vuelve a alistarte! Decían...",d:"Snori Nairb te ha prometido compartir sus kamas y su experiencia contigo si te alistas en la milicia de Bonta",r:[null,null,null,null,null,null]};
Q.s[576] = {n:"¿Quién sabe dónde?",d:"Según Elviana Tirips, existe una medium que podría ayudarte a encontrar al espíritu de la luz. Como la medium está desaparecida, lo primero será encontrarla.",r:[null,null,null,null,null,null]};
Q.s[577] = {n:"Encontrar y convencer al Espíritu de Luz.",d:"Tienes que encontrar al espíritu de la luz ligado al martillo y convencerlo de que te siga hasta Bonta.",r:[280000,null,null,null,null,null]};
Q.s[966] = {n:"Un espíritu de pocas luces.",d:"Parece ser que Onidal vuelve a necesitar tu ayuda con el tema del Martillo de Luz y de su espíritu.",r:[null,null,null,null,null,null]};
Q.s[567] = {n:"Un descanso bien merecido.",d:"Has participado en el juicio a Vasta Detontirías y tu testimonio ha sido determinante. Ahora puedes volver a tus ocupaciones normales.",r:[264000,null,null,null,null,null]};
Q.s[562] = {n:"Un juez que a veces pierde el juicio.",d:"Satirev Novini ha roto su martillo y te ha pedido uno nuevo. Como es un poco testarudo, se ha negado a utilizar cualquier martillo que no sea un Martillo de Paliza.",r:[null,null,null,null,null,null]};
Q.s[563] = {n:"Conversación con Danathor.",d:"Danathor quiere hablarte antes de que empiece el juicio, parece que es urgente.",r:[null,null,null,null,null,null]};
Q.s[561] = {n:"Sigue el olor.",d:"Amayiro te ha pedido que encuentres al Sram que encuentres al Sram que ha amenazado a Otabaj. Sólo tienes una pista: a menudo va a las alcantarillas por la entrada situada al sudeste de la ciudad.",r:[null,null,null,null,null,null]};
Q.s[962] = {n:"Un interrogatorio felino.",d:"Tienes que encontrar un miaumiauligno para el interrogatorio de Kerenah antes de que se abra el proceso.",r:[null,null,null,null,null,null]};
Q.s[566] = {n:"Un proceso justo.",d:"Como has investigado sobre el asunto de la traición de Vasta Detontirías, ahora te toca testificar. Elige tu campo.",r:[null,null,null,null,null,null]};
Q.s[973] = {n:"Cazadora de pensamientos.",d:"Debes convencer a Baha Tracio de que te ayude a capturar un maripensón de Solar, para poder llevárselo a Danathor.",r:[304000,null,null,null,null,null]};
Q.s[972] = {n:"Un remedio contra la amnesia.",d:"Donfor Tuna padece amnesia. No podrás curarlo si no sigues las indicaciones de Surivitna, el chamán.",r:[null,null,null,null,null,null]};
Q.s[971] = {n:"Solar in memoriam",d:"Debes conseguir un pensamiento perdido del difunto Solar, el primer protector del mes de javian. Quizás debas pedirle ayuda a algunos alquimistas.",r:[null,null,null,null,null,null]};
Q.s[64] = {n:"Lo quiero todo y lo quiero ya",d:"Volverse el rey del mundo.",r:[500,1000,[[968,1],[948,5]],[11,10],[27,47],[453,3,437]]};
Q.s[65] = {n:"Ya no quiero nada",d:"Quiero menos xp y menos kamas.",r:[null,null,null,null,null,null]};
Q.s[766] = {n:"El ataque bontariano.",d:"Tienes que ir a la muralla este para vencer allí a los bontarianos.",r:[37000,null,null,null,null,null]};
Q.s[806] = {n:"Un personaje inquietante.",d:"Kaffra Kyper te ha dicho que Hyrkul el tendencioso te espera en la sala secreta de la torre de Brakmar.",r:[null,null,null,null,null,null]};
Q.s[809] = {n:"La hora perdida",d:"Hyrkul te ha pedido que le lleves una hora perdida. Amino, el maestro de clase xelor, podría ayudarte.",r:[null,null,null,null,null,null]};
Q.s[810] = {n:"El subterfugio de Hyrkul.",d:"Hyrkul necesita el rayo de Ulgrud y te ha pedido que le pongas una trampa a uno de sus descendientes en el santuario Hotomani.",r:[null,null,null,null,null,null]};
Q.s[807] = {n:"La máscara de Hyrkul.",d:"Por alguna oscura razón, Hyrkul quiere fabricarse una máscara y te ha encargado que le consigas los materiales.",r:[null,null,null,null,null,null]};
Q.s[811] = {n:"La asamblea de los protectores.",d:"Hyrkul y Kaffra Kyper quieren que representes a la Orden del Corazón Sangriento durante la asamblea de los protectores y que luego hagas un informe.",r:[1200000,null,null,null,null,null]};
Q.s[808] = {n:"Corazón de Chafer.",d:"Hyrkul necesita un corazón de chafer. Una bontariana sabrá indicarte donde podrás encontrarlo. Pregúntale a Sbab... sabe más que el noticiero.",r:[null,null,null,null,null,null]};
Q.s[84] = {n:"Muy bonita cobaya",d:"0",r:[null,null,null,null,null,null]};
Q.s[82] = {n:"Un remedio de Tabi",d:"0",r:[null,null,null,null,null,null]};
Q.s[86] = {n:"Estabilizar el paciente",d:"0",r:[null,null,null,null,null,null]};
Q.s[77] = {n:"Muy bonita cobaya",d:"0",r:[null,null,null,null,null,null]};
Q.s[83] = {n:"Estabilizar el paciente",d:"0",r:[null,null,null,null,null,null]};
Q.s[85] = {n:"Un remedio de Tabi",d:"0",r:[null,null,null,null,null,null]};
Q.s[970] = {n:"El tesoro del bosque.",d:"Hay un pensaceptor en una antigua guarida de Dardondakal. La entrada se esconde en la bosque de Cania pero hay que tener los recursos adecaudos para poder encontrarla.",r:[296000,null,null,null,null,null]};
Q.s[969] = {n:"Recuerdos, recuerdos...",d:"Danathor quiere que le consigas esquirlas de recuerdos de dragón. No sabes dónde hacerte con ellas, pero la adivinación debería poder ayudarte...",r:[null,null,null,null,null,null]};
Q.s[788] = {n:"El secreto de Terra Cógita.",d:"Terra Cógita sabe dónde están las estatuas de Sumens. Elviana te ha encargado que las recuperes antes de que los brakmarianos les echen el guante.",r:[60000,null,null,null,null,null]};
Q.s[546] = {n:"Por un complot más.",d:"Han acusado a Vasta Detontirías de traición, pero Amayiro lo cree inocente. Por eso te ha pedido que vayas a la prisión a pedirle a Vasta su versión, y que luego compruebes lo que ha dicho.",r:[240000,null,null,null,null,null]};
Q.s[559] = {n:"Interrogatorio en regla.",d:"Amayiro te ha pedido que interrogues al testigo que acusó de traición a Vasta Detontirías hasta que revele algo interesante. Seguramente podrás encontrarlo en la taberna Almenú.",r:[null,null,null,null,null,null]};
Q.s[560] = {n:"Reconstitución de los hechos.",d:"Hay que repetir los pasos de Vasta Detontirías el día que le arrestaron, e interrogar a los que se cruzaron en su camino.",r:[null,null,null,null,null,null]};
Q.s[475] = {n:"Asunto sucio.",d:"Aprovecha la ausencia de Xantrax para entrar discretamente en su casa y registrarla. Necesitarás la ayuda de un manitas competente.",r:[null,null,null,null,null,null]};
Q.s[924] = {n:"En la torre.",d:"Xantrax tiene cita con un brakmariano en la Torre de Bonta  después de la reunión de la gente importante. Date prisa para no llegar tarde.",r:[95000,null,null,null,null,null]};
Q.s[837] = {n:"Un chisme muy raro.",d:"Elviana Tirips desea que vayas a la Isla de Otomai para investigar sobre los Dofus ocre y esmeralda.",r:[null,null,null,null,null,null]};
Q.s[838] = {n:"Un capitán muy raro.",d:"Capitán Quuk tiene información importante sobre los dos Dofus más poderosos. Descubre lo que sabe.",r:[null,null,null,null,null,null]};
Q.s[845] = {n:"Tédeor y los tymadores.",d:"Al parecer Tédeor tiene algunos asuntos con los tymadores. Si quieres saber lo que se traen entre manos...",r:[null,null,null,null,null,null]};
Q.s[839] = {n:"El cofre de los Dofus.",d:"Breit Gnil puede teletransportar cerca de la isla de los náufragos a cualquiera que le dé una anillo Pasado de Xelor. En esa isla podrás encontrar los Dofus ocre y esmeralda.",r:[null,null,null,null,null,null]};
Q.s[846] = {n:"La asamblea de los protectores.",d:"Elviana Tirips te ha encargado que representes a la Orden del Espíritu de Salvación durante la asamblea de los protectores. Pero actúa con astucia.",r:[1200000,null,null,null,null,null]};
Q.s[844] = {n:"Investigación en el bosque de Cania.",d:"Ve a ver qué es lo que se está tramando en el bosque de Cania mientras esperas a que llegue el momento de tu encuentro con Tédeor y los tymadores.",r:[null,null,null,null,null,null]};
Q.s[843] = {n:"Otra misión para Bibi.",d:"Los tymadores se han aliado con los demonios de las horas para retroceder en el tiempo hasta la época de las guerras entre las ciudades. Elviana Tirips quiere saber por qué.",r:[null,null,null,null,null,null]};
Q.s[830] = {n:"La misión del protector.",d:"Ulgrud ha aceptado que salves en su lugar al descendiente de su primo, pero para ello te impone como condición que vayas acompañado de otros bontarianos.",r:[1200000,null,null,null,null,null]};
Q.s[829] = {n:"La asamblea de los protectores.",d:"Medah Larisa te ha encargado que representes a la Orden del Corazón Valiente durante la asamblea de los protectores y que actúes como es debido.",r:[null,null,null,null,null,null]};
Q.s[828] = {n:"La torre superinfernal que te cagas (uyuyuyuyuiii qué miedo) de Gisgul.",d:"Para evitar que la estupidez de los wabbits interfiera con sus planes. Jeryn te confía la creación de una gran Hada Artificiural.",r:[null,null,null,null,null,null]};
Q.s[827] = {n:"La torre infernal de Gisgul.",d:"Medah Larisa quiere hacer volar por los aires la torre de Gisgul y te ha encargado los preparativos y la demolición.",r:[null,null,null,null,null,null]};
Q.s[802] = {n:"Pío precavido vale por dos.",d:"Medah Larisa necesita semillas modificadas mágicamente para los píos de su criadero. Mirleen el Encadenador conoce la fórumla.",r:[600000,null,null,null,null,null]};
Q.s[801] = {n:"Guarda muebles.",d:"Medah Larisa se teme que vengan agentes brakmarianos a robar la estatua de Sumens de la Torre de Bonta. Te ha pedido que la protejas.",r:[null,null,null,null,null,null]};
Q.s[967] = {n:"Un futuro presente.",d:"Danathor te necesita. Se trata de cierto regalo mágico o algo por el estilo.",r:[null,null,null,null,null,null]};
Q.s[968] = {n:"Entrevista con un tymador.",d:"Tienes que hablar con un tymador para discutir sobre el precio de un fragmento de tiempo robado a los demonios de las horas.",r:[288000,null,null,null,null,null]};
Q.s[831] = {n:"Un poder incontrolable.",d:"Onidal te ha pedido que interrogues a los otros maestros de orden y al jefe de la milicia para poder comprobar si hay un cambio de comportamiento.",r:[null,null,null,null,null,null]};
Q.s[835] = {n:"La caza del tesoro.",d:"Encuentra la entrada del reino subterráneo, en la landa, allí donde la tierra y las llamas se funden en uno y donde la noche es eterna.... Pero no te embobes y ¡¡llévale el tesoro a Onidal!",r:[null,null,null,null,null,null]};
Q.s[834] = {n:"Tras las huellas de los Nungi bellos.",d:"Onidal quiere echarle manos al tesoro de los Nungi bellos para poder comprar un nuevo equipamiento y mantener al ejército bontariano.",r:[null,null,null,null,null,null]};
Q.s[833] = {n:"El informe.",d:"Has inspeccionado los alrededores del castillo de Amakna. Ya es hora de volver a Bonta para hacer el informe.",r:[null,null,null,null,null,null]};
Q.s[832] = {n:"Problemas en Amakna.",d:"Con el propósito de estimar el alcance de los daños, Onidal te ha pedido que vayas a Amakna y que interrogues a sus habitantes.",r:[null,null,null,null,null,null]};
Q.s[840] = {n:"La asamblea de los protectores.",d:"Onidal desea que representes a la Orden del Ojo Atento durante la asamblea de los defensores y que luego le hagas un informe.",r:[1200000,null,null,null,null,null]};
Q.s[557] = {n:"Alcohol, mujeres y.... más alcohol.",d:"Satirev aceptará el aplazamiento para tu investigación si antes le das un tonel de hidromiel para que se refresquen los prisioneros y una mujer de Astrub para refrescar su cuerpo.",r:[null,null,null,null,null,null]};
Q.s[551] = {n:"Obtener un aplazamiento.",d:"Al juez Satirev Novini no le gusta que las investigaciones se alarguen \"ad vitam aeternam\", pero Amayiro te envía a verlo para que obtengas un aplazamiento. Se pasa la mayor parte del tiempo en el edificio de la milicia.",r:[null,null,null,null,null,null]};
Q.s[554] = {n:"Un aplazamiento difícil.",d:"Has logrado obtener un aplazamiento. Amayiro se alegrará cuando se lo digas.",r:[248000,null,null,null,null,null]};
Q.s[534] = {n:"La elección",d:"Has encontrado a tiempo al espía. Pero ¿vas a seguir las órdenes y recuperar los documentos dejándolo ahí?",r:[205000,null,null,null,null,null]};
Q.s[144] = {n:"...o comillos de xelors.",d:"Parece que los xelors están interesados. Según Ant, sería para poner agujas a sus relojes de arena... Pero, tampoco es muy seguro.",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Encontrar al fuera de la ley",d:"Algunos pretenden haber visto a Qil Bil cerca de las llanuras de Sidimote. Se busca a Qil Bil por arrancamiento de miembros. Fue condenado a prisión en Astrub.",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"¡Vuelve a alistarte! Decían...",d:"Snori Nairb te ha prometido compartir sus kamas y su experiencia contigo si te alistas en la milicia de Brakmar.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"El que siembra biento, recoge artempestades",d:"Para comprobar su teoría sobre la aparición de flores carnívoras, Trapchet te pide sembrar semillas de rosas oscuras y recogerlas después...",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"La flora puede matar...",d:"Tres-Flores, un amigo de Trapchet vive en Amakna y conoce perfectamente la flora de su región. Hay que pedirle información acerca de las flores agresivas que se encuentran por esas tierras.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"La specia necia",d:"Erty Trapchet quiere estudiar las semillas de diente de león para compararlas con la specia...",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"El regador renegado",d:"Erty Trapchet se olvidó de regar sus plantas, tienes que ir a su casa para regarlas.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"No pisar el césped...",d:"Para sus investigaciones, Trapchet necesita estudiar la repartición geográfica de las flores en los alrededores de Astrub.",r:[6500,500,null,null,null,null]};
Q.s[60] = {n:"0",d:"0",r:[null,null,null,null,null,null]};
Q.s[56] = {n:"Pesquisa sobre una desaparición de una... casa.",d:"0",r:[null,null,null,null,null,null]};
Q.s[38] = {n:"Entrega para Erty Trapchett",d:"0",r:[null,null,null,null,null,null]};
Q.s[40] = {n:"Entrega para la mina",d:"0",r:[null,null,null,null,null,null]};
Q.s[39] = {n:"Entrega para Simbrazo Manco",d:"0",r:[null,null,null,null,null,null]};
Q.s[143] = {n:"Caza salvaje",d:"Oscuras criaturas arruinan los negocios de Ant Ydoto, parece que la solución consistiría en librarse de ellas... Por lo menos hasta que se sepa lo que hacen aquí...",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"¿Los huevos pueden nadar?",d:"Ya no hay agentes infecciosos en las plumas de los tofus enfermos. En cambio sus huevos pueden ser una pista para los aniripsas. ¡A por más kamas!",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"¡La sangre será derramada!",d:"Te surgen unas incontrolables ganas de saber más sobre ti mismo y decides ir a un sangriento lugar... A la carnicería.",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"Hay miaumiau encerrado...",d:"Tu amo ha oído que hace poco, un minero ha sido cambiado en minero oscuro. ¡Quiere estar seguro de ello!",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"¡Estúpidos Anutrofs!",d:"Los Anutrofs han descubierto algo y te van a necesitar.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Extracto de dizbi",d:"La flor tal cual no servirá ¡Necesitas hacer una infusión!",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Reparto exprés",d:"¡Tienes que llevarle la infusión a tu ama de gremio para que pueda hacerte tu bastón! Si además tienes tiempo de llevarle un poco de infusión a tu proveedor de flores... le hará mucha ilusión.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Flor de dizbi",d:"Para que tu ama de clase pueda hacerte un bastón digno de tu condición, debes encontrar flores de dizbi.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"¡Tenemos hambre!",d:"Los jalatós de Allisteria tienen hambre. ¡Vas a tener que darles de comer!",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Morcilla Cocida de Jalató",d:"Salvar la tradición de la buena Morcilla Cocida de Jalató.",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Lucha si eres una Feca",d:"El famoso Fallanster te ha pedido entrenar a su hija al combate.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"La vía del Agua",d:"La vía del agua consiste en resistir a... la absorción y a la inmersión (parcial y total) en agua a toda costa. No beberla nunca, lavarse únicamente en caso de necesidad. Encuentra al maestro de la vía del Agua: Sabe más de lo que parece.",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"El Zollo sabio",d:"Una vendedora de refrescos Pandawallana te aconseja ir a ver al Zollo sabio. Según ella, él detiene la verdad sobre Pandala y sus secretos.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"La estatua de la diosa",d:"Pandawelo ha aceptado el regalo de los anutrofs con mucho gusto. Como es un ferviente admirador de los buscadores de Dofus, te acoge con los brazo abiertos.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"El Pandawelo: Un pandawa simpático",d:"Los Anutrofs que están siendo curados en casa del Shaman te aconsejan ir a ver al Pandawelo. Está muy al tanto de las costumbre locales y también es un gran conocedor de las leyendas Pandawallanas.",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Libaciones para la diosa",d:"Gracias a ti, el Asistente del Shaman puede empezar su ritual de agradecimiento a la diosa. Estará listo en cuanto le hayas entregado una ofrenda pandawallana tradicional.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"Al servicio del rey",d:"Al rey le gusta montar, hay que encontrarle dragopavos.",r:[75000,null,null,null,null,null]};
