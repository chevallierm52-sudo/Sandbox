Q.s[704] = {n:"En ayuda de Lyeno.",d:"Tienes que salvar al coronel Lyeno: desapareció al este del Bosque de los Abráknidos.",r:[12800,null,null,null,null,null]};
Q.s[722] = {n:"Otra petición del cocinero.",d:"El cocinero de la milicia te pide que le ayudes de nuevo.",r:[31000,null,null,null,null,null]};
Q.s[1088] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
