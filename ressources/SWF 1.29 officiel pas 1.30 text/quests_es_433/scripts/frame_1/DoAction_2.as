Q.s[898] = {n:"La confirmación.",d:"Pandaulina Rubi ha aprovechado el combate para escaparse... debe estar en su casa. Tienes que convencerla de que le entregue la carta Xéphirex.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intimidación íntima.",d:"Debes saquear la casa de Pandaulina Rubi para así intimidarla. Necesitas 3 frascos de pasta Plas Plum, que se obtiene al mezclar 15 hocicos de jabalí, 5 frascos de zampávoros y 1 pluma de serpipluma.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"El cartero.",d:"Hay que encontrar el modo de darle la carta a Xéphirex. Va mucho por la Taberna del Pandawa Borracho pero se niega a hablar contigo.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"El relevo.",d:"Tienes que encontrar al guerrero Tink Verbal para perdirle que releve a Brank Thoof.",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"La tortura",d:"Usar la fuerza no te ha servido de nada... Así que aprovecha que Tugtora tiene hambre y encuentra la manera de envenenarla. Seguro que algún habitante de la isla sabe de qué se alimentan las tortugas",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Tortuga panzarriba",d:"Ya que preguntando no consigues ninguna información... tendrás que pasar a la acción.",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Transformación",d:"Poss\'Ybel quiere que le consigas algunos productos, fruto de tus cosechas.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Transformación",d:"Poss\'Ybel Nano quiere una mini pócima de curación hecha a base de una flor de lino y un poco de agua.",r:[50,null,null,null,null,null]};
Q.s[379] = {n:"Transformación",d:"Poss\'Ybel quiere que le consigas algunos productos acabados, fruto de tus cosechas.",r:[50,15,null,null,null,null]};
Q.s[380] = {n:"Transformación",d:"Poss\'Ybel quiere que le consigas algunos productos acabados, fruto de tus cosechas.",r:[50,15,null,null,null,null]};
Q.s[686] = {n:"Caza a los bebedores.",d:"Tienes que ir a todas las tabernas de Bonta y encontrar a los milicianos que no estén en su puesto de trabajo para pedirles su insignia.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Condiciones de intercambio",d:"Anta te escribió una lista de lo que quiere que le traigas a cambio de su collar.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"Asistente social",d:"Diskre quiere saber si los aldeanos han notado algo extraño o inhabitual estos últimos tiempos.",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Shaman connexion",d:"El Shaman es un Pandawa que sabe muchas cosas sobre el comportamiento de algunos... Aparentemente, no todo es rosa en Pandala...",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"¡A la salud de la diosa!",d:"Nuevo llegado a Pandala, el Asistente Shaman te pide honrar a tu diosa: una ofrenda espirituosa sería la bienvenida... Tu iniciación comienza.",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Encontrar un trabajillo",d:"Enin Postor tendrá sin duda algún trabajillo para ti.",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"Una receta para Kotorra",d:"Kotorra Nana espera la receta de las crepes de Astrub para preparar la llegada de sus nietos.",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"El baile de la cuerda.",d:"Baja con una cuerda hasta la guarida de los bandidos, ¡pero no vayas solo!",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"¡Qué monina!",d:"En tu encuentro con los bandidos te enteraste que Hersa Garra Oscura sabe más de lo que dice. Habrá que hablar con ella con mucho cuidadito para evitar que nos arañe la cara.",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"La guarida en la pradera.",d:"Amayiro te ha pedido que investigues en las llanuras de Cania para encontrar la guarida de los bandidos. Según la información que tienes, no debe estar lejos de la Feria del Trool, un poco hacia el oeste.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Pretty Nara.",d:"Nara te ha dado una larga lista de elementos que necesita para forjar el equipamiento de la milicia de Bonta. Tienes que llevárselos hasta la Mina de los Porcos.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Agencia inmobiliaria.",d:"Ya has visto los distintos lugares que Setag te indicó. Ahora sólo tienes que convencer a Nara para que se mude a uno de ellos.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"Prospección Inmobiliaria.",d:"Nara te ha pedido que le encuentres un lugar aislado para instalar su forja y su material.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Transporte de cajas.",d:"Tienes que conducir 4 cajas desde donde está Amayiro hasta el puesto avanzado de Bonta, al sur de la ciudad.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Hacer sus pruebas",d:"Como todavía no eres muy famoso por la zona, los autóctonos no saben todavía si pueden confiar en ti.",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"Arriba, abajo, al centro...",d:"Ya tienes la cerveza, si se la das a Almae recuperarás toda tu energía.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Almae quiere cerveza",d:"Almae Terna quiere cerveza ¿Y por qué no va a buscarla él mismo?",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"El amigo de los animalitos",d:"Tienes que descubir de dónde viene Tugtora. Lo mejor será preguntarle a un especialista en animales, así que empieza por hablar con Yokashi, el responsable de la petrera.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"El wabbit y la tortuga",d:"Según Yokashi, Tugtora tendría un enemigo mortal. Eliebwe Palp Atynte habría podido firmar un pacto con los demonios para tener más poder. Lo encontrarás en la Isla de los Wabbits Esqueletos.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Agenda de direcciones",d:"Agregar un jugador a tu lista de amigos.",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"El mejor enemigo del hombre...",d:"Ma\'Ster te pone a prueba. Debes vencer al monstruo escondido en su perrera.",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Juego Troll reglas avanzadas",d:"Raquixtico está asustado. Sabe que los bworks lo entregarán al trool para que haga una partida de juego trool reglas avanzadas con él. Deberá eliminar a este trool, una auténtica amenaza para la integridad física de Raquixtico.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"Peregrinación ensangrentada.",d:"Enfréntate con el dopeuls de cada uno de los 12 templos de clase.",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Eliminar las tortugas.",d:"Oto te ha pedido que mates 10 tortugas de la isla de Moon. Además quiere que le lleves la prueba de que lo has hecho... los ojos, por ejemplo.",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Vino para Oto.",d:"Debes llevar a Oto vino de zampávoro ¿Dónde podríamos conseguir eso?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"La entrevista.",d:"Una persona importante de Brakmar quiere verte. Está en el sótano de la torre de Brakmar.",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Pócimas energéticas.",d:"Oto Mustam necesita 3 pócimas pahoa reid.",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"La guarida al descubierto.",d:"Gracias al mensaje del jefe de los ladrones vas a poder encontrar su guarida. Estaría bien darse una vueltecita antes de volver a la milicia, ¿no?",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"La compra de equipamiento.",d:"Tienes que comprar el equipo que Oto te indicó en la lista y equiparlo antes de regresar para verle.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"¡32 dientes de oro!",d:"Debes proporcionarle a Mak una dentadura de oro. Podrías conseguirla de los chafers de élite, pero sin lugar a dudas, el herrero de Brakmar puede suministrarte lo que necesitas.",r:[28000,null,null,null,null,null]};
Q.s[487] = {n:"Penetrar en la biblioteca.",d:"Los espías de Bonta han fracasado en su intento de asesinato, así que tendrás que rematar el trabajo en su lugar. El objetivo es un estratega que vive en la biblioteca de Bonta. Pero, ¡ten cuidado con los perros guardianes!",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Asesinato.",d:"Ahora puedes entrar en la biblioteca para ocuparte del estratega.",r:[null,null,null,null,null,null]};
Q.s[750] = {n:"¿Humillar a Sbab?",d:"Oto te ha pedido que le lleves a Sbab 10 orejas de pekewabbit para asustarle. Pero hay muchas cosas que puedes hacer si eso no te apetece.",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Golpear a los bontarianos.",d:"Oto te ha pedido una cerveza de La Paliza Feliz. La taberna se encuentra en Bonta.",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Buscar los documentos.",d:"El espía no tenía los documentos secretos. La fauna de las landas de Sidimote se encargado de robárselos.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"La Revelación",d:"En el sótano del mercadillo de los alquimistas hay un armario. Sólo tienes que ponerte delante de él para acceder al pasadizo secreto, donde te espera el Mago de Zo.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"El Mago de Zo",d:"Amayiro te ha pedido que interrogues al Mago de Zo para saber cómo se utiliza el cuerno Mágico y cuáles son sus poderes.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"De vuelta a casa",d:"Ya es hora de volver a Bonta e informar a Amayiro.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"El conocimiento básico.",d:"Ve a aprender la técnica de captura de las almas. La llave de la mazmorra debería estar en el vientre de las criaturas de la región.",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Los cascos de chafer.",d:"Oto quiere 10 cascos de chafer que podemos encontrar en el Cementerio de los Torturados.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Presencia brakmariana",d:"Has atacado a un brakmariano que aún no tenía el cuerno Mágico. Si Zurcarák está de tu parte, quizás encuentres el cuerno Mágico antes que los brakmarianos.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"La decisión de Tugtora",d:"Tienes que convencer a Tugtora para que te cambie la bandana Remendada por el cuerno Mágico. Necesitarás llevar un mazorrasombrero y una Zampaburg para que aparezca.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Se abre la veda del lobo.",d:"Oto te ha pedido que te deshagas de un lobo que anda por la fachada de Brakmar.",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"Tan cerca del objetivo.",d:"Norb sabe donde se encuentra el herrero ermitaño. Sólo tienes que convencerle para que te diga dónde se esconde. Quizás Amayiro pueda ayudarte.",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Así forjaba... así, así...",d:"Tienes que encontrar un herrero competente que acepte hacer el equipamiento para Bonta.",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Historias de taberna",d:"Tus fuentes te han informado de que el tabernero de Sufokia podría saber algo sobre un poderoso cuerno.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"Si no te sirven bien, barra libre",d:"La información que el tabernero Ripata te ha revelado no te servirá de mucho. Seguro que sacas mucha más preguntando a los eruditos.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, ¿koko?",d:"Presientes que la próxima misión, que Oto Mustam te confiará, va a ser dura. Será mejor que prepares el terreno y te hagas con algunas nueces de kokoko.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Caparazones",d:"El tabernero Ripata quiere que le lleves caparazones de tortuga de Moon, uno de cada color. Aunque, quizás deberías optar por un método más rápido.",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Luchar con el lupus minimus",d:"Un combate que pondrá a prueba todas tus capacidades.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Una misión casi cumplida.",d:"El camino ya está libre, aunque los goblins no eran una verdadera amenaza. Al fin, Exoram te va a contar lo que sabe y Oto Mustam estará orgulloso de ti.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"Abracadabra, yo otra vez.",d:"Exoram no está muy tranquilo ya que ha oído ruidos sospechosos y risas socarronas más al norte. Si puedes confirmarle que el camino está libre, te dará la información sobre Xéphirex.",r:[null,null,null,null,null,null]};
Q.s[445] = {n:"Abracadabra, soy yo.",d:"Le has proporcionado a Oto Mustam información de gran utilidad. Ahora te pide que tomes el relevo de un miliciano y que vayas al Bosque de los Abráknidos, a buscar a un sram que conoce a Xéphirex.",r:[null,null,null,null,null,null]};
Q.s[891] = {n:"Una misión que está lejos de ser cumplida.",d:"Los indicios de lucha y restos de karne nos indican que Exoram ha luchado pero deben de haberle capturado o asesinado. Más vale que te pongas a cubierto cuando Oto Mustam se entere... ¡tiene muy malas pulgas cuando no le dan buenas noticias!",r:[65000,null,null,null,null,null]};
Q.s[444] = {n:"Los buenos bares de Bonta.",d:"Tienes que encontrar información sobre Xéphirex. Los taberneros de Bonta podrían darte algunas pistas.",r:[null,null,null,null,null,null]};
Q.s[737] = {n:"La recolección de veneno.",d:"Oto Mustam necesita 20 pods de veneno de scorbuto.",r:[4600,null,null,null,null,null]};
Q.s[485] = {n:"La cosecha de veneno.",d:"Los espías de Bonta necesitan veneno: un veneno raro que tienen los bwoks magos. Los espías están escondidos en el barrio suroeste de Bonta.",r:[null,null,null,null,null,null]};
Q.s[906] = {n:"El buen escondrijo.",d:"Les debes a los espías un escondrijo nuevo entre su actual ubicación y la biblioteca. Tendrás que neutralizar a sus ocupantes en caso de que presenten oposición.",r:[128000,null,null,null,null,null]};
Q.s[535] = {n:"Un pequeño fracaso",d:"Restos de un combate, dos armas por el suelo y un sram muerto. Conclusión: parece que no has llegado a tiempo.",r:[205000,null,null,null,null,null]};
Q.s[918] = {n:"Exoram, el sram.",d:"Has traído a Exoram al templo Sram. Esta vez, más le vale que te proporcione la información que te había prometido.",r:[70000,null,null,null,null,null]};
Q.s[892] = {n:"Un sram más tonto de lo normal.",d:"Exoram se ha vuelto a meter en líos. Si quieres la información sobre Xéphirex, vas a tener que ayudarle otra vez.",r:[null,null,null,null,null,null]};
Q.s[447] = {n:"Infiltrarse o perderse entre la multitud, ésa es la cuestión.",d:"De acuerdo con lo que has descubierto, Exoram debe estar prisionero en el campamento goblin... eso si no se lo han cargado ya.",r:[null,null,null,null,null,null]};
Q.s[448] = {n:"Tras las huellas del sram.",d:"Los goblins han soltado vivo a Exoram. Tienes que salir de nuevo en busca de indicios para echarle el guante.",r:[null,null,null,null,null,null]};
Q.s[493] = {n:"En la cueva de los porcos.",d:"Intenta que el herrero de la cueva de los porcos se una a la causa de Brakmar.",r:[152000,null,null,null,null,null]};
Q.s[759] = {n:"Lección de humildad.",d:"Oto te ha ordenado que le lleves 40 ojos de larvas azules.",r:[23000,null,null,null,null,null]};
Q.s[760] = {n:"¡Maldita larva dorada!",d:"Tienes que encontrar un modo de deshacerte de la larva dorada que te persigue.",r:[25000,null,null,null,null,null]};
Q.s[452] = {n:"Un fracaso... temporal.",d:"Xéphirex ha rechazado tu oferta... pero no todo está perdido. Seguro que una joya servirá para sobornarlo.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"El encuentro.",d:"El escondrijo donde Xéphirex se ha metido ha sido identificado, ahora tienes que encontrar la Taberna del Pandawa Borracho y hacerle una proposición. Estará allí a partir de las 16:00.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"Transmitir el mensaje.",d:"Oto quiere que le des un mensaje a Vil Smis. Le encontrarás en la guarida de los tymadores que está en el cementerio de Amakna.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"Un nuevo peligro que asusta.",d:"Varios guerreros brakmarianos han sido batidos y dados por muertos en el camino que lleva a Astrub. Tienes que ir a investigar, pero antes Oto Mustam quiere un alma de colmillo blando.",r:[140000,null,null,null,null,null]};
Q.s[747] = {n:"Recaudador de impuestos.",d:"Tienes que recaudar el nuevo impuesto de Oto y para ello tendrás que ir a todas las tabernas de Brakmar. Oto te ha dado carta blanca para que les des una buena ración de tortas a los taberneros que no quieran pagar.",r:[10700,null,null,null,null,null]};
Q.s[889] = {n:"Un carta X.",d:"Tienes que averiguar la identidad del famoso X. La carta hace referencia a un lugar donde tiene la costumbre de ir. Si encuentras ese lugar podrás averiguar más cosas.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Regreso a la torre.",d:"Has encontrado un pedazo de papel muy interesante. Tienes que enseñárselo a Oto.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"La torre del desorden.",d:"Encuentra en Bonta a un personaje importante al que puedas corromper. Oto te ha sugerido que lo busques en la torre.",r:[null,null,null,null,null,null]};
Q.s[792] = {n:"En busca del secretario judicial deprimido.",d:"Tabach, el secretario judicial de la Orden del Corazón Valiente, frecuenta las tabernas desde que perdió su gato. Hay que llevarlo a ver a Medah Larisa.",r:[null,null,null,null,null,null]};
