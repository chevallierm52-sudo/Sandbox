Q.s[365] = {n:"La llave entre los dientes",d:"Si quieres conseguir la llave de la Mazmorra tendrás que matar a un enorme jalató rabioso.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"¿Sadiqué?",d:"Danathor necesita aún que le ayudes a echarle el guante al grimorio del bwork mago de las cavernas, tan conocido por haber lanzado el embrujo de la grafiosis.",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Sadihumao.",d:"Tuh Flowa te ha indicado dónde se encuentra la entrada de la prisión vegetal. Estaba un poco aturdido, así que esperemos que no se haya olvidado de darte algún dato importante.",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"La llave y la ardilla.",d:"Tienes que encontrar en Brakmar una ardilla que ha robado una importante llave. Cuando lo consigas, llévale la llave a Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Llevar las cajas.",d:"Tienes que llevarle a Oto las cajas de armas blancas que se encuentran en la torre de Brakmar.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Getas para Milone.",d:"Como castigo por no haber impedido que los ladrones robasen la joya, Milone quiere que le consigas unas getas de fuegodala.",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Volver a deshuesar a Mak Gahan.",d:"El chafer Mak Gahan quiere la revancha.",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Regañan a Willem Lenglade.",d:"Willem Lenglade necesita que le den otra lección.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"El tiempo se agota.",d:"Debes encontrar un estratega y convencerle de que se una a las filas de Bonta.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Kaffra Kyper.",d:"Oto Mustam quiere conocer la opinión de Kaffra Kyper para preparar la ofensiva contra Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Regresar con Oto.",d:"La batalla se ha acabado. Oto Mustam está esperando tu informe.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Escaramuza.",d:"Un combate está teniendo lugar cerca de la Bahía de Cania, en el camino que hay entre Bonta y Brakmar. Tienes que unírte a los brakmarianos y ayudarles ¡a ganar!",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Entrenamiento con el martillo.",d:"Oto necesita 10 martillos de maderucha para entrenar a sus tropas.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"El cristal oscuro.",d:"Tienes que ir por el camino secreto que está en el taller de los alquimistas. Necesitarás una pócima de ráfaga, una de armonía y otra de kobalita.",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"El crimen nunca paga.",d:"Se ha enviado el mensaje a Captain Starky. Mientras esperas a que conteste, deberías ir a ver si Sabina está tranquila o no.",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"El rescate.",d:"Sabina está a buen recaudo: ahora ponte en contacto con Captain Starky para exigirle un cristal de Kay Daryn como rescate.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"De camino a la prisión.",d:"Tienes que llevar a Sabina hasta Oto Mustam. Presta mucha atención para que no se te escape a la primera de cambio.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"El rapto de Sabina.",d:"Tienes que raptar a Sabina y meterla en un lugar de donde no pueda escapar.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"El crimen va a pagar, palabra de brakmariano.",d:"Los bontarianos han intentado liberar a Sabina. ¡Eso no debe quedarse así! ¡Tienes que enseñarles quien manda aquí!",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Desafiar a Puja.",d:"Se supone que tienes que desafiar a Puja Mustam, el hijo de Oto, y hacer que pierdes. ¡Pero no vayas a llegar al punto de dejar que ese mocoso te mate!",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"Una nueva dentadura.",d:"Debes arrancarle los dientes a un jalató para hacer una dentadura. Tienes que conseguir todos los dientes necesarios para hacer una dentadura humana... en fin, más bien humanoide.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"La gran peladura.",d:"Tienes que pelar las patatas para la cena. La cocina se encuentra en el sótano del edificio de la milicia.",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"Vencer al zoth Manitú.",d:"Debes vencer al zoth Manitú y llevarle la prueba de tu victoria a Bob, el anutrof.",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Engatugtora",d:"Tienes que encontrar la manera de engatusar a Tugtora para conseguir el cuerno Mágico. Los habitantes de la Isla de Moon te ayudarán.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"Volver con Oto.",d:"Como el estratega se ha ido de la ciudad, puedes dejar que Oto Mustam piense que lo has matado.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Domador de bestias, y también de animales.",d:"Oto Mustam quiere conocer el secreto de la doma de colmillos blandos. Regresa a la biblioteca de Bonta para encontrar pistas.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"Picadillo de inútil.",d:"Oto Mustam está convenido de que intentas engañarle: tendrás que encontrar forzosamente la joya si no quieres acabar hecho picadillo.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"¡Victoria!",d:"Xéphirex ha aceptado las condiciones y está dispuesto a traicionar a Bonta si se le presenta una buena ocasión.  A Oto le va a dar una alegría esta noticia.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"La entrevista.",d:"Todo está dispuesto, sólo te queda encontrar a Xéphirex en la Taberna del Pandawa Borracho para entregarle la carta y establecer una fecha para que te dé su respuesta.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Venganza, juajaja.",d:"La guarida de los bandidos está repleta de trampas. Tendrás que encontrar un manitas de nivel 30 como mínimo para que te acompañe y desmonte las trampas que protegen el escondrijo.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"¡Informando!",d:"La batalla se ha acabado, Medah Larisa espera tu informe.",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Escaramuza.",d:"Un combate está teniendo lugar cerca de la Bahía de Cania, en el camino que está entre Bonta y Brakmar. ¡Tienes que ir y ayudar a Bonta a ganar!",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Oferta de trabajo.",d:"Oto Mustam quiere saber quién ha asesinado al tabernero de la Taberna del Gatokemao.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"La papilla de blops.",d:"Hay que darle a Oto papilla de blop triturado. Él te dará una receta.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Encontrar el testamento.",d:"Tienes que encontrar el testamento de Oto en la tumba de su padre, en el cementerio. La tumba se reconoce las flores que la adornan. Tienes que transformarte en espíritu para poder entrar.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"Pirata atracado.",d:"Gracias a Xéphirex sabes que el navío bontariano \"La Descemer\" transporta numerosos objetos mágicos en sus bodegas. Tienes que encontrarlo y apropiarte de la mercancía.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Liquidación total.",d:"Una sram debe dinero a Oto Mustam. Como ella no se lo ha devuelto, Oto ha decidido eliminarla para dar ejemplo. Probablemente la encontrarás en una sala de juego ilegal.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Equipa a los guerreros",d:"Oto teme que Bonta pueda atacar, por lo que te pide que equipes a algunos guerreros de Brakmar con el equipo especial.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Enchufe.",d:"Kosuke Ichazum tenía razón: Latem Odasep tiene el contrato para equipar a la milicia de Bonta por enchufe y no por su habilidad de herrero.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Forjar con los pies.",d:"Debes interrogar al proveedor de equipación de la milicia y poner a prueba al herrero que la fabrica.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"El pozo del loco.",d:"Tienes que encontrar la ubicación del pozo de almas mancilladas para poder utilizar las piedras a su máxima potencia.  El maestro de la Orden del Espíritu Insano, Divad Dleifrepok, podrá ayudarte.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Alquimia maléfica.",d:"Tienes que conseguir piedras mancilladeras. Sólo los mineros son capaces de fabricarlas a partir de creaciones en bruto de un alquimista loco.",r:[null,null,null,null,null,null]};
Q.s[903] = {n:"Siete almas o nada.",d:"Tienes que capturar las almas de los siete bandidos y llevarlas al pozo de almas mancilladas para someterlas. Necesitarás unos brakmarianos viles hasta el punto de poder elegir una especialidad.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Encuentra al espía",d:"Debes encontrar, lo más rápido posible, al espía herido en el camino que lleva a Bonta para recuperar los documentos. Seguramente esté más cerca de Bonta que de Brakmar.",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Ronda de las tabernas.",d:"El bandido al que pertenece esta espada probablemente haya pasado por una de las tabernas. Por consiguiente, los taberneros deben saber algo.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Una investigación importante.",d:"Pasa revista a los guardias de Brakmar y haz una lista de los guardias que no hacen descanso.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Domador de bestias, y también de animales.",d:"Oto Mustam quiere conocer el secreto de la doma de colmillos blandos. Regresa a la biblioteca de Bonta para encontrar pistas.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Hasta Brakmar.",d:"El estratega ha aceptado seguirte hasta Brakmar.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Otro informe.",d:"Tienes que encontrar a Trojen Tihpor en las murallas de Bonta y conseguir su informe.",r:[19000,null,null,null,null,null]};
