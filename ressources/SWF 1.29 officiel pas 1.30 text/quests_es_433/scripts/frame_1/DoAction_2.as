Q.s[956] = {n:"¿Orden o contraorden?",d:"Al no estar confirmado el plan de ataque actual, tienes que buscar a Kapi Ta\'han para averiguar si ha habido confirmación o cambios. Cuando sepas todos los detalles, informa a Amayiro.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Plan de ataque.",d:"Amayiro teme que los brakmarianos vayan a realizar un asalto inminente. Tienes que encontrar su plan de ataque para que Amayiro les pueda preparar un comité de bienvenida digno de su nombre.",r:[null,null,null,null,null,null]};
