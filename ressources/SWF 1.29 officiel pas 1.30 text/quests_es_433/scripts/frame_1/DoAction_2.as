Q.s[919] = {n:"Colgando de una cuerda.",d:"Ahora puedes fabricar llaves e inspeccionar la guarida de los bandidos para buscar pistas. Una cuerda de escalada no te vendrá mal para bajar hasta la guarida.",r:[80000,null,null,null,null,null]};
Q.s[916] = {n:"Minino, minino.",d:"Tienes que echarle mano a la llave de la guarida, por lo que necesitas echarle mano a un bandido que posea una. El ex-amante de Hersa te puede valer.",r:[null,null,null,null,null,null]};
Q.s[917] = {n:"Llave sin moleta.",d:"Tienes que hacer copias de la llave de la guarida para poder entrar en grupo y recuperar todos los documentos relacionados con la investigación.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Actividad ilícita.",d:"Algo turbio se está preparando en el barrio de los panaderos. Amayiro te ha pedido que vayas a investigar.",r:[17000,null,null,null,null,null]};
Q.s[689] = {n:"Entrenamiento con el bastón.",d:"Amayiro te ha pedido 20 bastones de maderucha para entrenar a sus tropas.",r:[4000,null,null,null,null,null]};
Q.s[718] = {n:"Una petición para Danathor.",d:"Danathor te ha enviado una carta para pedirte ayuda.",r:[11500,null,null,null,null,null]};
Q.s[719] = {n:"Larry Poller.",d:"Larry Poller te ha pedido ayuda. Podrás encontrarlo cerca de la torre de Bonta.",r:[11500,null,null,null,null,null]};
Q.s[1035] = {n:"Desvelar el secreto de la estatua",d:"Perfobland ha enterrado su secreto al pie de la estatua. Agáchate para recogerlo.",r:[null,null,null,null,null,null]};
Q.s[751] = {n:"Ayudar a Raaga.",d:"Encuentra a Raaga en las minas del norte y pídele el informe.",r:[13500,null,null,null,null,null]};
Q.s[738] = {n:"El informe del espía.",d:"Oto te ha pedido que encuentres al espía Finche Aticus en Bonta, y que le pidas el informe",r:[5200,null,null,null,null,null]};
Q.s[743] = {n:"En búsqueda de veneno mágico",d:"Tienes que encontrar en Brakmar a alguien que sepa preparar veneno mágico.",r:[8200,null,null,null,null,null]};
Q.s[335] = {n:"A trabajar",d:"Vete a preguntarle al contramaestre lo que debes hacer.",r:[250,250,null,null,null,null]};
