Q.s[409] = {n:"Una pequeña ayuda",d:"El pwíncipe del Wey te ha pedido un séquito digno de su estatura... A lo visto de sus proezas en combate y de su sentido del esteticismo, necesitarás por lo menos a cuatro personas para que le ayuden.",r:[45000,null,null,null,null,null]};
Q.s[693] = {n:"Llevar la pólvora.",d:"Debes llevarle 10 pods de pólvora de cañón a Amayiro. Podrás comprárselos a Mub Oreicifrita, en Bonta.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"La invocación desconocida.",d:"Amayiro te ha pedido que le preguntes a Zeurg (maestro de la clase osamodas) sobre la invocación desconocida que han usado en Brakmar.",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Encontrar el punto débil.",d:"Tienes que encontrar algo interesante en los engranajes de la gran puerta de Brakmar.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"Alguien robó en el nido del cuco.",d:"Amayiro quiere tender una emboscada a los brakmarianos para poner a prueba el nuevo material y la cohesión de los milicianos.",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Intercepción brutal.",d:"Tienes que interceptar el convoy de armas que va a pasar por el linde del bosque de los abráknidos para llegar hasta el pueblo de los salteadorillos. No te vendrían mal unos refuerzos.",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"El viejo joyero.",d:"Según el jefe de los ladrones, el joyero de Brakmar, Milone Corichel, tiene información interesante.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"El Informador.",d:"Amayiro sospecha que Brakmar es el origen de todos los problemas de Bonta. Bishom Pot, espía miliciano de Brakmar, puede que sepa algo.",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Subterráneo riguroso",d:"¡Únicamente ocho valientes serán capaces de llegar hasta el final de este subterráneo!",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Subterráneo misterioso",d:"Una baldosa encaramada encima de una montaña y una puerta secreta... Hará falta encontrar voluntarios para llegar hasta el final de este pasillo...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"El sótano de la Biblioteca",d:"Como en cualquier sótano de biblioteca, hay todo tipo de libros y de telas de araknas... Pero en esta, hay como una  atmósfera misteriosa...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Subterráneo tenebroso",d:"Una puerta secreta en la montaña abre paso a un subterráneo, pero es necesario encontrar cómo...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Subterráneo impenetrable",d:"¡Ojo con el dragohuevo! Vas a tener que atravesar su territorio para entrar en esta nueva cueva...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Subterráneo arriesgado",d:"¡Puede que este subterráneo que acabe con tu paciencia!",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Visita a la taberna.",d:"Ve a ver al tabernero Feubuk y recupera la carta de Amayiro... ¡y de paso una cerveza!",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"Operación patata caliente.",d:"Tienes que pelar 200 pods de patatas que luego tendrás que llevarle al cocinero de la milicia.",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"Un champo para Amayiro.",d:"Amayiro te ha pedido que le lleves un champo común que podrás obtener de los maestros boletus.",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Pinta Gono quiere leer la receta",d:"Ya se ha comprado todo el material para construir su cervecería. Solamente le falta la receta.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Encontrar la receta de la cerveza Bwork",d:"Pinta Gono está buscando la receta de la famosa cerveza Bwork. Cree que está en una sala extraña en territorio Bwork.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Asalto al castillo del Wey",d:"Tendrás que recuperar la bandana de Tugtora, los wobots la tienen escondida en la mazmorra del Wey Wabbit.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"Costura de alto riesgo",d:"Debes encontrar la manera de devolverle a la bandana Mokete su estado y su esplendor de antaño. Pide ayuda a un sastre.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Recuperación movidita",d:"Has encontrado al espía a tiempo, pero los brakmarianos no piensan darte los documentos. Sin embargo, tienes que llevárselos a Amayiro cueste lo que cueste.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"Bromitas entre enemigos",d:"Los brakmarianos tenían que llevarle los documentos a su superior. Sin embargo, has conseguido reemplazarlos por unos que has falsificado y, de esta manera, has hecho que tus enemigos sigan una pista falsa.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Carrera contrarreloj",d:"Un espía bontariano se está escapando de Brakmar por el este. Tienes que encontrarlo y escoltarlo. ¡El tiempo se acaba!",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Informe protegido.",d:"Un informe en el que se te acusa de muchas cosas está guardado en la Torre de las Órdenes de Bonta. Tienes que ir a por él y demostrar tu inocencia.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"Para alimentar, hacen falta alimentos.",d:"Sometido a la presión del consejo, Amayiro ha anulado la investigación y ahora tienes que hacer la faena de avituallamiento.",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Robo en la torre.",d:"Encuentra un cómplice para desviar la atención del guardia mientras que tú estás robando.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
