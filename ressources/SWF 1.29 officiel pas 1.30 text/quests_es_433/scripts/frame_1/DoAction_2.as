Q.s[680] = {n:"Interrogar a Doña.",d:"Tienes que ir a ver a Doña Claudia para preguntarle qué es lo que pasa.",r:[125,null,null,null,null,null]};
Q.s[1067] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
