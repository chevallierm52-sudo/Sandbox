Q.s[726] = {n:"Deshuesar a Mak.",d:"Vence al chafer Mak Gahan y llévale uno de sus huesos a Oto Mustam.",r:[50,null,null,null,null,null]};
Q.s[536] = {n:"Atrapa al espía",d:"Un espía bontariano se ha colado en la torre y ha robado unos documentos. Tendrás que utilizar un zaap para atraparlo al este del camino que lleva a Bonta, del lado de Brakmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Los Tymadores no andan muy lejos...",d:"Seguro que has adivinado dónde se esconden los Pillos. Sólo te queda por confirmar las informaciones.",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"La cripta mola",d:"Tendrás que visitar las cinco criptas del cementerio de Amakna.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"Infiltración secreta",d:"Tendrás que infiltrarte en casa de los Pillos y hablar con Vil Esmis.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"En territorio enemigo.",d:"Tienes que infiltrarte en el edificio de la milicia de Bonta para descubrir dónde guardan sus armas los enemigos.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"Una pedazo de caja.",d:"Debes burlar la vigilancia del guardián para robarle las llaves del almacén. Luego, tienes que robarle una caja de equipamiento y llevársela a Mulic Bere para que la examine.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"Las capas brakmarianas.",d:"Oto te ha pedido 5 capas brakmarianas. Él mismo te dirá cómo fabricarlas.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Aguacero",d:"Yueba Kántaros necesita agua para sus ninfitas.",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"En busca del cuerno",d:"El supuesto guardián del cuerno Mágico se encontraría en la selva profunda de la Isla de Moon. Según los rumores, tendrás que llevarle un mazorrasombrero y sacar una Zampaburg para que aparezca.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"La información del capitán.",d:"Tienes que encontrar un modo de ponerte en contacto con el capitán Tsog, para poder conseguir la información que debe transmitir. El capitán Alrok conoce la ubicación de la tumba de Tsog.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Encontrar al culpable.",d:"Encuentra al asesino de Rimaraf y llévale el formulario cumplimentado a Amayiro.",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Pruebas falsas.",d:"Engaña a Amayiro mostrándole pruebas falsas. Danathor podrá ayudarte a hacerlo.",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"La sangre de las ratas.",d:"Amayiro te ha pedido que aniquiles 4 ratas hyoactivas en las alcantarillas de Bonta.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Personas de confianza",d:"Amayiro necesita personas de confianza para que participen en la escenificación de los falsos poderes del cuerno Mágico.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"Una escenificación minuciosa",d:"Para terminar la escenificación, Amayiro necesita tierrapatas de la cabeza de los crujidores y grasa de gelatina real, cualquiera sirve.",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"Más colecta...",d:"Los ocra son los especialistas del flechazo... envenenado. Las araknas enfermas parecen tener en sus patas una sustancia que puede servir como veneno... Business is business...",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"La pala del apocalipsis",d:"Arucol pide una pala de maderucha para construirse un refugio anti-apocalipsis.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"Pan y tablas",d:"Para construir una cabaña indestructible, Arucol pide dos tablas de castaño y algunos panes para sobrevivir por lo menos durante 3 días tras el desastre.",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Pisto",d:"Tienes que echar los ingredientes necesarios en el caldero especial: un objeto de cada tipo y un alquimista, un panadero, un campesino, un carnicero y un pescadero.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"El arte de cocinar sin a penas cansarse",d:"Tienes que encontrar las recetas para los ingredientes de la lista que te dio Oto Mustam.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Nuestros amigos los animalitos",d:"Amayiro quiere saber más sobre Tugtora. Yokashi, el guardián de la petrera, seguramente posee información sobre esta tortuga.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Los zollos infolman",d:"Tugtora se unió a los zollos y los defendió en el pasado. Los zollos, que se encuentran al sur de la Isla de los Wabbits, ¿se acordarán aún de aquello?",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Colecta de calzones.",d:"Tienes que vencer a los milicianos de Bonta y... ¡conseguir sus calzones! Oto quiere 5.",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Madera de Carvayinio",d:"Consigue madera de Carvayinio: sacrificando la naturaleza, podrás aliarte con ella.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Ritual",d:"Encuentra a la persona que te ayudará a confeccionar tu bastón del novato.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Enseñar sus talentos",d:"Tus talentos se están desarrollando, pero no todos están convencidos.",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"Abrakadabra ¡un cuerno!",d:"El supuesto guardián del cuerno Mágico se encontraría en la profunda jungla de la Isla de Moon. Según los rumores, tendrás que llevarle un mazorrasombrero y sacar una Zampaburg para que aparezca.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"¿Baba para hacer una joya?",d:"Tienes que conseguir los materiales para hacer una joya: 5 lingotes de oro, 1 dosis de baba de jalató real y 1 nácar. El nácar podrás conseguirlo puliendo 10 piedras de nácar en bruto que encontrarás en los crustáceos y moluscos de la Isla de Otomai.",r:[80000,null,null,null,null,null]};
Q.s[1063] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1064] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
