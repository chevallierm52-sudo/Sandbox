Q.s[793] = {n:"En busca de la secretaria judicial.",d:"Ybaul, la secretaria judicial de la Orden del Espíritu de Salvación, va por las tabernas buscando a sus hermanos. Hay que llevarla a ver a Elviana Tirips.",r:[null,null,null,null,null,null]};
Q.s[795] = {n:"Hueso de corazón.",d:"Kaffra Kyper te ha pedido que le lleves 1 hueso de chafer para demostrarle tu valor.",r:[null,null,null,null,null,null]};
Q.s[797] = {n:"Mal de ojo.",d:"Alse Tocreto te ha pedido que le lleves 1 ojo de cuerbok para demostrarle tu valor.",r:[null,null,null,null,null,null]};
Q.s[210] = {n:"Nada es imposible para un corazón sangriento.",d:"Debes apropiarte de las estatuillas símbolo del bien y del mal de la humanidad para dárselas a Kaffra. Están escondidas en una mina abandonada cerca del templo anutrof.",r:[200000,null,null,null,null,null]};
Q.s[796] = {n:"Los pelos de la barba.",d:"Divad Dleifrepok te ha pedido que le lleves 1 manojo de pelos de la baraba de un bwork mago para demostrarle tu valor.",r:[null,null,null,null,null,null]};
Q.s[1071] = {n:"La fábrica de juguetes.",d:"Unas monstruosas criaturas han robado en el almacén de Papá Nowel. Tienes que recuperar las cajas de regalos que han robado, ya sea por las buenas o por las malas. Luego llévaselas a Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
