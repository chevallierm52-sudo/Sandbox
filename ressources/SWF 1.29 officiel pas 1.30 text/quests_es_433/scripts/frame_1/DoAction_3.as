Q.s[7] = {n:"Cocomida",d:"Pregúntales a las personas que encuentres qué come un miaumiau. Después tráele un poco de comida a este miaumiau.",r:[1220,null,null,null,null,null]};
Q.s[9] = {n:"¿Miaumiau, un héroe?",d:"Encuentra lo que convertirá a este pobre miaumiau en un héroe para su novia.",r:[3060,null,null,null,null,null]};
Q.s[6] = {n:"Leleche para un Miaumiau",d:"Traer leche para el pobre miaumiau.",r:[1220,null,null,null,null,null]};
Q.s[8] = {n:"Paseo Grato del Gato",d:"Pasear el miaumiau por la ciudad.",r:[1500,null,null,null,null,null]};
Q.s[13] = {n:"Anillo de regalo",d:"Shani te ha regalado un anillo que posee poderes ocultos. Para descubrirlos tendrás que matar a un abráknido.",r:[11000,1200,[[6793,1]],null,null,null]};
Q.s[12] = {n:"Picapica",d:"Shani no tiene suficientes espinas de champi champ para la prueba de mañana. Vete a por ellas.",r:[2600,250,null,null,null,null]};
Q.s[11] = {n:"Reciclaje de agua apestosa",d:"Traerle babas de jalató a Shani Sings.",r:[1700,200,null,null,null,null]};
Q.s[10] = {n:"¿Un amuleto velludo?",d:"Llévale patas de arakna a la joyera, son necesarias para fabricar el amuleto.",r:[1700,null,[[6773,1]],null,null,null]};
Q.s[24] = {n:"Ratero",d:"Encuentra una manera de hacerte con el informe del espía y llévaselo a Ztiv Oztin.",r:[1200,null,[[6784,1]],null,null,null]};
Q.s[22] = {n:"El espía biónico",d:"Encuentra a Ztiv Oztin y proponle tus servicios.",r:[1200,null,null,null,null,null]};
Q.s[20] = {n:"Discreción asegurada",d:"Encuentra a Ogivol Scarratero, podrás localizar la entrada de su guarida gracias a una trampilla escondida en el suelo del almacén de madera.",r:[600,null,null,null,null,null]};
Q.s[121] = {n:"Encontrar y escoltar al fuera de la ley",d:"Es posible que Noai Aludem se encuentre en el Noroeste de las llanuras de Cania, cerca del bosque de Litneg. Está condenado a ser encarcelado en Astrub por deterioración de Jalató doméstico y escándalo nocturno.",r:[null,84500,null,null,null,null]};
Q.s[26] = {n:"Se buscan piernas rápidas",d:"El panadero necesita entregar un pedido urgente a 4 personas. Vete a entregarles los pasteles lo más rápido posible.",r:[1000,null,null,null,null,null]};
Q.s[29] = {n:"En busca de un nuevo repartidor",d:"Encuentra a una persona a la vez fuerte y ágil para que ocupe el puesto de repartidor.",r:[2000,250,null,null,null,null]};
Q.s[28] = {n:"Un repartidor seductor",d:"Comprueba si el repartidor Luk Drif está realmente enfermo.",r:[2000,500,null,null,null,null]};
Q.s[30] = {n:"Una última entrega",d:"Entregar el pastel a Abuela",r:[5000,null,null,null,null,null]};
Q.s[103] = {n:"La casa de Yori Khas",d:"Yori Khas ha olvidado donde está su casa, aterrorizada, ya no se atreve a aventurarse sola en la ciudad.",r:[5750,250,null,null,null,null]};
Q.s[33] = {n:"El ramo de lino",d:"Debes conseguir flores de lino para la madre de Yori Khas. Solamente los alquimistas pueden recolectar esas flores.",r:[2000,200,null,null,null,null]};
Q.s[31] = {n:"Los bandidos mancos",d:"El campamento de los bandidos mancos se sitúa al norte del bosque de Astrub. El peluche lo tiene seguramente uno de los bandidos del grupo.",r:[2000,null,null,null,null,null]};
Q.s[37] = {n:"¡Tiembla, hombre oso!",d:"Según dice Abrazolargo hay que atacar al hombre oso entre varios para estar seguro de que utilice su manuscrito en combate. Después hay que traérselo para que lo autentifique.",r:[9000,2500,null,null,null,null]};
Q.s[35] = {n:"Informe osamodas",d:"Abrazolargo Sixgarras ha hablado del hombre oso, capaz de controlar criaturas muy poderosas. Antes de lanzarte tras él deberías hablar a Nokomas Seso de lo que has descubierto.",r:[3000,null,null,null,null,null]};
Q.s[34] = {n:"La bestia peluda",d:"El pastor Nokomas Seso tiene problemas con una bestia peluda, por eso busca a una persona capaz de conseguir más información sobre esta criatura...",r:[750,null,null,null,null,null]};
Q.s[36] = {n:"Siguiendo la pista del oso",d:"Siguiendo la pista del oso",r:[3000,null,null,null,null,null]};
Q.s[53] = {n:"Forro apestoso",d:"Alit te aconseja añadirle un forro a tu capa. Pero para eso le tienes que traer lana de jalató.",r:[3500,null,[[6801,1]],null,null,null]};
Q.s[54] = {n:"¡Todo eso para unas orejeras!",d:"Traer los materiales necesarios para la confección de una orejeras. Algunos serán difíciles de conseguir, así que puede que necesites ayuda.",r:[11000,500,[[6802,1]],null,null,null]};
Q.s[52] = {n:"Se necesita lana",d:"El sastre Alit necesita lana de jalatín blanco y negro. Si se la traes te hará probablemente algo a medida.",r:[2500,null,[[6800,1]],null,null,null]};
Q.s[49] = {n:"Se necesitan refuerzos",d:"Vete en busca de ayuda a junto de los Fecas y los Aniripsas.",r:[1200,null,null,null,null,null]};
Q.s[51] = {n:"Se necesita una pala",d:"Vuelve para hacer tu informe a Joe y para conseguir tu recompensa.",r:[1200,null,[[6786,1]],null,null,null]};
Q.s[45] = {n:"Se necesita mano de obra",d:"Encuentra a Howard el Siperonada y dale la carta de Joe Pierlivet.",r:[600,null,null,null,null,null]};
Q.s[55] = {n:"La sangre del Wabbit GM",d:"0",r:[null,null,null,null,null,null]};
Q.s[57] = {n:"Análisis de sangre",d:"0",r:[null,null,null,null,null,null]};
