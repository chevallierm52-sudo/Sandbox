Q.s[461] = {n:"Información sobre la Bagruta.",d:"El mercader de vino local ha desaparecido. Puede que el tabernero de la Bagruta tenga información al respecto.",r:[null,null,null,null,null,null]};
Q.s[462] = {n:"Investigación al este.",d:"Según el tabernero de la Bagruta, el mercader tiene la costumbre de volver a su casa, un poco más hacia el este.",r:[60000,null,null,null,null,null]};
Q.s[575] = {n:"En busca de un martillo.",d:"El libro revela el emplazamiento del Martillo de Luz. Está en una de las criptas del cementerio de Amakna. Tienes que llevárselo a Onidal.",r:[272000,null,null,null,null,null]};
Q.s[574] = {n:"Información sobre el martillo.",d:"En busca de un Martillo de Luz, Onidal te ha pedido que interrogues a los maestros de clase de los siguientes templos: Aniripsa, Feca, Ocra, Sacrógrito, Yopuka y Zurcarák.",r:[null,null,null,null,null,null]};
Q.s[584] = {n:"Al servicio de Onidal.",d:"Amayiro te ha informado de que Onidal necesita tus servicios. Podrás encontrarlo en la Torre de Bonta.",r:[null,null,null,null,null,null]};
Q.s[512] = {n:"Sufokia",d:"Corren rumores sobre la existencia de un cuerno con poderes mágicos. Los habitantes de Sufokia podrían saber algo sobre el tema.",r:[null,null,null,null,null,null]};
Q.s[513] = {n:"Caparazones de tortuga",d:"El tabernero Ripata quiere que le lleves caparazones de tortuga de Moon, uno de cada color. Quizás recibas una gran suma de kamas a cambio.",r:[null,null,null,null,null,null]};
Q.s[935] = {n:"Chikokoko",d:"Más vale prevenir que curar. Así que consigue una buena reserva de nueces de kokoko antes de volver con Amayiro.",r:[170000,null,null,null,null,null]};
Q.s[934] = {n:"Cuernos a la mar",d:"Según el tabernero Ripata, el cuerno se encontraría en una isla. Los eruditos te darán, sin duda, más información.",r:[null,null,null,null,null,null]};
Q.s[697] = {n:"Investigación en la feria.",d:"Hay que pedirle el formulario a Ture Inge que está en la milicia. Luego interroga al jefe de la feria del Trool para saber si es brakmariano o no.",r:[8200,null,null,null,null,null]};
Q.s[171] = {n:"Escapar es vivir",d:"Aparentemente, no eres el bienvenido en Airedala... Sabrás escapar de tu destino? Más te vale...",r:[10000,null,null,null,null,null]};
Q.s[169] = {n:"Cero Dofus",d:"El mensajero del Zollo sabio te envía al linde del pueblo de Airedala. En el camino, vas meditando estas últimas palabras: \"Más de un aventurero ha sido mal acogido al llegar a Airedala. Dicen que son los aliados de los Pandawas rebeldes los que sabotean todos los accesos a la isla...\"",r:[2000,null,null,null,null,null]};
