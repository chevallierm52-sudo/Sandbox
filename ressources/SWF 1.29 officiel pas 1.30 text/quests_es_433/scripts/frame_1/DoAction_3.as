Q.s[76] = {n:"La necesidad de saber servirse de ella",d:"Aprende a manipular tu nueva arma atacando algunos insectos.",r:[900,null,null,null,null,null]};
Q.s[67] = {n:"Cómo forjar una espada para  dummies",d:"Necesitas a un herrero para crear una espada.",r:[null,null,null,null,null,null]};
Q.s[68] = {n:"La utilidad de una buena empuñadura de espada",d:"Encuentra una empuñadura para que te forjen una espada.",r:[1200,null,null,null,null,null]};
Q.s[69] = {n:"La importancia de los acabados",d:"Llévale la espada recién forjada a tu amo.",r:[900,null,[[6780,1]],null,null,null]};
Q.s[63] = {n:"0",d:"Entregarle la espada a tu amo de gremio. Él le pondrá la marca de tu clase.",r:[1200,null,null,null,null,null]};
Q.s[61] = {n:"Un metal sospechoso",d:"Llevarle la bolsa de kamas sospechosos a una persona que pueda hacer algo interesante con ella.",r:[600,null,null,null,null,null]};
Q.s[62] = {n:"0",d:"Transformar tu metal sospechoso.",r:[1200,null,null,null,null,null]};
Q.s[72] = {n:"Ladrón de corazón",d:"Las piedrecillas vienen de las minas situadas al noreste del pueblo. Descubre allí el cofre de Luk.",r:[4000,null,null,null,null,null]};
Q.s[150] = {n:"La recompensa",d:"Vete a buscar tu recompensa a casa de Luk Drif.",r:[5000,null,[[1519,1]],null,null,null]};
Q.s[71] = {n:"En busca de las piedrecillas",d:"Examina las piedrecillas para compararlas a las que se encontraron en casa de Luk. Para eso, ve a los lugares sospechosos.",r:[1500,250,null,null,null,null]};
Q.s[70] = {n:"Cambio metaria por una cita.",d:"Luk tiene que resolver su problema de cofre y prepararse al mismo tiempo para su primera cita. Vete a buscarle dos rosas, una para cada chica.",r:[1500,500,null,null,null,null]};
Q.s[73] = {n:"¡Corre Forest!",d:"¿Te gustan los niños? Este lo vas a odiar...",r:[600,50,null,null,null,null]};
Q.s[75] = {n:"Ezte ez mi arco, ez el míoooo...",d:"Jo, qué ilusión fabricarse su primer arco.",r:[1200,null,[[6783,1]],null,null,null]};
Q.s[78] = {n:"Ocratástrofe",d:"Ahora vas a aprender a tirar al arco.",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Encontrar a la fuera de la ley",d:"Algunos pretenden haber visto a Tortacia Leukocitina cerca del pueblo de los Bandidos Mancos. Es buscada por punciones ilegales de hemoglobina. Condenada al encarcelamiento en Astrub.",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Encontrar al fuera de la ley",d:"Algunos pretenden haber visto a Nervus Brakdan cerca del bosque de los Abráknidos. Es buscado por robo de joyería. Condenado al encarcelamiento en Astrub.",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Encontrar al fuera de la ley",d:"Algunos pretenden haberlo visto cerca de las Landas de Sidimote. Se le busca por insumisión al orden cósmico. Brumen Tinctoria fue condenado a prisión en Astrub.",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Encontrar al fuera de la ley",d:"Peazo Beyota recorre la ciudad de Astrub en busca de suculentas bellotas.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Encontrar al fuera de la ley",d:"Se ha visto a Ogivol cerca de Brakmar. Se le busca por haber robado una cantidad increíble de cosas, sobre todo documentos secretos, y porque tiene pendiente una condena a prisión en Astrub.",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Escolta de Mezcla",d:"Tek Abir, el tabernero del pueblo, tiene que mezclar su cerveza con agua porque le han robado la suya. Encuentra al repartidor al sudeste bordeando el camino y escóltalo.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"¿El final de la cervagua?",d:"Acabar con el robo de cerveza.",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Conjunto de visión",d:"Conseguir diversos recursos para ayudar a Kukokwartzo a que pueda ver el futuro.",r:[600,null,null,null,null,null]};
Q.s[92] = {n:"¡El futuro es duro!",d:"Kukokwartzo te habla de tu lo que será tu futuro inmediato.",r:[1200,null,null,null,null,null]};
Q.s[91] = {n:"¡El futuro es la aventura!",d:"Kukokwartzo necesita una piel de larva azul para terminar su máquina.",r:[1200,null,null,null,null,null]};
Q.s[94] = {n:"Entrega",d:"Llévale a Clint Pot el remedio que has conseguido... para curar a los tofus o a los anutrofs... La verdad es que no estaba muy claro. No te olvides de redactar un informe para tu amo de gremio.",r:[1800,null,[[6785,1]],null,null,null]};
Q.s[93] = {n:"Constipositorio...",d:"Ayúdale a tu amo de gremio a que encuentre un remedio para curar a sus tofus.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"Primera sala",d:"Averiguar cómo utilizar los tres Dofus.",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Segunda sala",d:"Encontrar la llave.",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"¡Tac tic!",d:"...",r:[2500,20,null,null,null,null]};
Q.s[145] = {n:"...de tijeras",d:"¡Con las tijeras nuevas que has conseguido, Peluka se pondrá muy contenta!",r:[1750,null,null,null,null,null]};
Q.s[133] = {n:"Un buen par...",d:"Peluka Diolobalgo busca tijeras forjadas, te aconseja ir a ver el herrero del mercadillo para comprarle unas.",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Pelos, pelos y más pelos...",d:"Peluka quiere recuperar todos los tipos de cabellos de los habitantes de Astrub para hacer postizos.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"Una primera pista",d:"Los anutrofs que se marcharon en busca de husmeatós se han perdido seguramente en las profundidades de las galerías. La zona está plagada de miliratas de alcantarillas...",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"Uno tuyo vale más que dos pods de rata",d:"Acaba con esta rata de alcantarillas... Parece que está enferma, no debería ser demasiado complicado... Bueno, si sois varios, obviamente...",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"El principio de la fortuna",d:"Conseguir diez patas de arakna para Ant Ydoto o para ti... En cualquier caso, parece ser rentable.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Plumas enfermas",d:"Con diez plumas, se debería poder hacer un plumero. Aunque viendo la pinta de las plumas...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Recompensa merecida",d:"Volver a hablar con la abuela para enseñarle la cabeza de los raratones.",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"El sótano plagado",d:"Ir al sótano de la abuela y exterminar todo lo que tenga bigotes... ¡pero a la abuela no!",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Vencer al miliciano.",d:"Tienes que vencer al miliciano Tarche en la sala de al lado.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Dar el pan.",d:"Debes llevarle 20 panes de trigo completo a Amayiro.",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"Los dientes de jalató.",d:"Tienes que arrancarles tantos dientes a un jalató como los que hay en una dentadura humana. Cuando tengas todos los piños, llévaselos a Ned que está al suroeste de la ciudad.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"¡Marchando una ración de palos para el hermanillo!",d:"Tienes que vencer al miliciano Torcha y llevarle una prueba a Amayiro.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Encontrar al cuerbok.",d:"Tienes que encontrar al cuerbok que ha robado el collar de la hija del alcalde. Dale una buena paliza y recupera el collar. El cuerbok debe estar por la torre.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Se abre la veda del jabalí.",d:"Tienes que ir al sur de Bonta para encontrar al jabalí agresivo y vencerlo.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"La reparación de la katana.",d:"Tienes que pedirle a Kosuke el herrero que repare la hoja de Amayiro si quiere recibir el cheque.",r:[4600,null,null,null,null,null]};
Q.s[690] = {n:"Golpear al que no paga.",d:"El tabernero de La Paliza Feliz debe una gran cantidad de Kamas a Amayiro. Tienes que convencerle de que pague... tú verás qué medios de persuasión utilizas.",r:[null,null,null,null,null,null]};
Q.s[692] = {n:"Ponerse en contacto con el espía.",d:"Tienes que ir a Brakmar para encontrar a Bishom Pot y sacarle la información que Amayiro te ha pedido.",r:[5200,null,null,null,null,null]};
Q.s[694] = {n:"Reparar la brecha.",d:"Karne Dekanión necesita 4 piedras de crujidor de las llanuras para reparar la brecha de la muralla. Podrás encontrarlo a la entrada de Bonta.",r:[6400,null,null,null,null,null]};
Q.s[696] = {n:"Colección de cascos.",d:"Tienes que llevarle 15 cascos de chafer de élite a Amayiro.",r:[7600,null,null,null,null,null]};
Q.s[698] = {n:"Papilla para el tabi.",d:"Llévale papilla de flores de blop a Amayiro. Para conseguir la papilla, hay que machacar 4 flores de blops de diferentes colores en un triturador munster.",r:[8800,null,null,null,null,null]};
Q.s[700] = {n:"Más agilidad para Amayiro.",d:"Amayiro te ha pedido 20 anillos de agilidad.",r:[10000,null,null,null,null,null]};
Q.s[702] = {n:"Llevar las capas.",d:"Amariyo te ha pedido que le lleves 10 capas bontarianas al capitán Koda. Estas capas se confeccionan con una lana de jalató blanco, una pluma de cuerbok y un tinte mágico azul.",r:[11400,null,null,null,null,null]};
Q.s[705] = {n:"21 horas.",d:"Danathor te ha pedido que te encuentres con él a las 21 horas y que lleves todos los ingredientes que te indicó en la lista.",r:[13500,null,null,null,null,null]};
Q.s[708] = {n:"Carne para el cocinero.",d:"El cocinero de la milicia de Bonta, Orenicoc, necesita 10 muslos de tofu.",r:[13500,null,null,null,null,null]};
Q.s[707] = {n:"Asesinato fallido.",d:"Regresa con Amayiro.",r:[null,null,null,null,null,null]};
Q.s[712] = {n:"Llevar el veneno.",d:"Capitán Osarra, que está en la prisión de Bonta, necesita 30 pods de veneno de scorbuto.",r:[15600,null,null,null,null,null]};
Q.s[714] = {n:"Pelear... ¿para nada?",d:"Tienes que encontrar a Dike Tarak en el barrio del norte. Desafíalo y gánale.",r:[null,null,null,null,null,null]};
Q.s[713] = {n:"Pelear... para nada.",d:"Tienes que encontrar a Dike Tarak en el barrio del norte. Desafíalo, pero pierde.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Encontrar el punto débil.",d:"Amayiro te ha pedido que explores el Cementerio de los Torturados, situado al este de Brakmar para averiguar si hay algún punto débil en la defensa de la ciudad. Probablemente necesites material especial.",r:[19000,null,null,null,null,null]};
Q.s[717] = {n:"Trabajo para elegir.",d:"Tienes que llevarle a Amayiro: o 20 tablas de fresno, o 10 raíces de Abráknido.",r:[21000,null,null,null,null,null]};
Q.s[721] = {n:"Ofensiva en Brakmar.",d:"Amayiro te ha pedido que venzas a los guerreros brakmarianos y que consigas 10 de sus insignias.",r:[28000,null,null,null,null,null]};
Q.s[723] = {n:"Dar una lección.",d:"Un tal Willem Lenglade molesta a los habitantes de Bonta: tienes que ir a tranquilizarlo... por la fuerza.",r:[34000,null,null,null,null,null]};
Q.s[724] = {n:"En los calabozos de Brakmar.",d:"Amayiro te ha pedido que salves a Libah Yoson que está en la prisión de Brakmar y que luego lo lleves hasta la milicia bontariana.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"¡Pandrista a la vista!",d:"Busca a un vendedor ambulante: podrás pagarle la tasa sobre la Pandrista. No dudes en insistir mucho.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"¡Vaya, vaya, aquí es Pandala...!",d:"Al llegar a Pandala tendrás que pagar la tasa a la administración: debes pagar la tasa de la pandrista.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"Mi primera Shaman Party",d:"¡Vete a pedirle ayuda al Shaman ahora mismo!",r:[4700,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[170] = {n:"Un nuevo mensaje del sabio",d:"¡Un mensajero te trae un mensaje, habla con él!",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Pequeño entrenamiento con el escudo",d:"Para agradecerte la entrega, el forjador de escudos te ha regalado un pequeño escudo de entrenamiento. Vete a hablar con el Maestro del Dojo para un pequeño entrenamiento.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"Poner el acento sobre el viaje",d:"El Zollo sabio te pide ir al pueblo de Airedala... O de Tierradala, imposible averiguarlo por culpa de su acento. Cuando estés allí, habla con el maestro Pandawushu.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"En casa del forjador de escudos",d:"En Tierradala, nadie puede ir a llevarle los recursos a la forja de escudos. Aunque forjar escudos es indispensable para los guerreros Pandawas... ¡Menos mal que estás tú!",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Miaumiaufobia",d:"Poochan está buscando a su futuro marido, las únicas pistas de las que dispone es que tiene que estar por Pandala y le  asustan los miaumiaus. Lo más sencillo será transformarse en miaumiau y saltar a los brazos de todo el mundo ¿no?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Compromiso amistoso",d:"La tradición aquí quiere que el padre decida con quién su hijo o su hija se casará. Por eso tendrás que convencer al padre de cederte a su hijo. Haz lo que haga falta para conseguirlo.",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Conquista de las Dento",d:"Para liberar a Lanma de sus obligaciones tendrás que romper la promesa de matrimonio que tiene con una de las hijas del Dojo Dento.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"¿Recompensa?",d:"Poochan te está esperando.",r:[7000,null,null,null,null,null]};
Q.s[174] = {n:"Paseo por el Espacio y el Tiempo de Amakna",d:"¡Este Paseo por el Espacio y en el Tiempo de Amakna (P.E.T.A) podrá salvar el mundo!",r:[null,null,null,null,null,null]};
Q.s[173] = {n:"El Kuarzo de la última suerte",d:"Amino le propone a Henual que utilice el último recurso:...¡Kuarzo!",r:[null,null,null,null,null,null]};
Q.s[172] = {n:"Amino me importa",d:"Hay que transmitirle una carta a Amino al templo Xelor de la parte del vigilante Henual.",r:[null,null,null,null,null,null]};
Q.s[178] = {n:"Beber y deber",d:"Un comerciante ambulante te podrá seguramente vender una de esas bebidas fermentadas que hicieron la fama de la isla. ¡Sólo necesitas encontrar uno!",r:[null,null,null,null,null,null]};
Q.s[185] = {n:"Promoción al grado Rokwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Rokwa.",r:[30000,null,null,null,null,null]};
Q.s[184] = {n:"Promoción al grado Gokwa",d:"Hay que presentarse ante el maestro un sábado para pasar la evaluación del grado Gokwa.",r:[30000,null,null,null,null,null]};
Q.s[183] = {n:"Promoción al grado Yonkwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Yonkwa.",r:[20000,null,null,null,null,null]};
Q.s[180] = {n:"Promoción al grado Ikwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Ikwa.",r:[5000,null,null,null,null,null]};
Q.s[187] = {n:"Comienzo del entrenamiento",d:"Para empezar el entrenamiento, debes conseguir un certificado shamánico y un traje Pandawushuka.",r:[null,null,[[7313,1]],null,null,null]};
Q.s[182] = {n:"Promoción al grado Sankwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Sankwa.",r:[15000,null,null,null,null,null]};
Q.s[181] = {n:"Promoción al grado Nikwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Nikwa.",r:[10000,null,null,null,null,null]};
Q.s[191] = {n:"Yondanwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Yondanwa.",r:[60000,null,null,null,null,null]};
Q.s[190] = {n:"Sandanwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Sandanwa.",r:[50000,null,null,null,null,null]};
Q.s[186] = {n:"Shodanwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Shodanwa.",r:[30000,null,null,null,null,null]};
Q.s[189] = {n:"Nidanwa",d:"Hay que presentarse a un maestro un sábado para pasar la evaluación del grado Nidanwa.",r:[40000,null,null,null,null,null]};
Q.s[175] = {n:"Leyenda Zolla",d:"¡Por fin! ¡Has llegado a la meta! Pero no lo has visto todo todavía... El Zollo de la Isla de los Wabbits te va a revelar un gran secreto que ha estado muy bien guardado durante mucho tiempo...",r:[7500,null,null,null,null,null]};
Q.s[188] = {n:"En el templo de tu dios",d:"Siguiendo los consejos del Zollo sabio, vas preparando tu próxima expedición. Para eso tendrás que ir al templo de tu divinidad en Amakna.",r:[7500,null,null,null,null,null]};
Q.s[176] = {n:"¡Dark Vlad, uno que sí que tiene...!",d:"Purifica tu alma y lávate las orejas: el Zollo sabio te revela la verdad sobre el Dofus de Pandala.",r:[40000,null,null,null,null,null]};
Q.s[193] = {n:"El receptáculo de Dofus",d:"El Pandawelo ha aceptado el regalo de los Anutrofs con mucho gusto. Como es un ferviente admirador de los buscadores de Dofus, te aconseja ir a ver el receptáculo de Dofus.",r:[1500,null,null,null,null,null]};
Q.s[192] = {n:"Besos desde Astrub",d:"El shaman está demasiado ocupado como para dedicarte su tiempo. Entre los pandikazes, la enfermedad de los anutrofs de Astrub y todo lo demás... Te aconseja ir a hablar con Pyrita, un anutrof en cuarentena, si deseas ayudarle.",r:[1500,null,null,null,null,null]};
Q.s[194] = {n:"La vía del agua",d:"La vía del agua consiste en resistir a... la absorción y a la inmersión (parcial y total) en agua a toda costa. No beberla nunca, lavarse únicamente en caso de necesidad. Encuentra al maestro de la vía del agua: sabe más de lo que parece.",r:[10000,null,null,null,null,null]};
Q.s[207] = {n:"El Pandawelo",d:"Llevarle el Dofus falso al Pandawelo.",r:[2200,null,null,null,null,null]};
Q.s[195] = {n:"Escudero, palafrenero, un mismo combate.",d:"Los brakmarianos han destruido los desvanes bontarianos. Hay que encontrar un modo de alimentar a las monturas de la milicia. Ve al taller de los alquimistas y que Mirleen te dé una solución.",r:[50000,null,null,null,null,null]};
Q.s[196] = {n:"En la piel de un espía.",d:"Tras el incendio de los almacenes de comida que originaron los brakmarianos, Onidal quiere saber lo que los enemigos están tramando.",r:[50000,null,null,null,null,null]};
Q.s[197] = {n:"Levántate y anda... y empieza a largar.",d:"Elviana Tirips quiere interrogar a los renegados bontarianos pero para eso hace falta resucitarlos.",r:[50000,null,null,null,null,null]};
Q.s[782] = {n:"Agricultura de alto riesgo.",d:"Los planes de Bonta para incrementar la producción de cereales han llegado a los oídos de Kaffra. Necesita 20 semillas de scorbuto para que dicha producción sirva a los propósitos de Brakmar.",r:[50000,null,null,null,null,null]};
Q.s[200] = {n:"Brakmarianos ineptos.",d:"Al no poder contar con los inútiles de los agentes brakmarianos, Kaffra te ha pedido que vayas a Astrub y que convenzas al comerciante bontariano Ramón Santo de que abastezca Brakmar.",r:[null,null,null,null,null,null]};
Q.s[783] = {n:"Intoxicación alimenticia.",d:"Tras haber leído tu informe, Alse Tocreto te ha entregado 20 semillas de scorbuto modificadas para que las deposites en el taller de los alquimistas de Bonta. Tendrás que hacerlo por la noche cuando Mirleen el Encadenador esté dormido.",r:[50000,null,null,null,null,null]};
Q.s[198] = {n:"Inquietudes brakmarianas.",d:"Alse Tocreto se pregunta lo que trama Bonta en este momento. Te envía para que te pongas en contacto con el espía Atticus Finch.",r:[null,null,null,null,null,null]};
Q.s[787] = {n:"¡Te he dicho que te levantes y que andes!",d:"La maldición de Nas Orazal te ha enseñado cómo hacer que un alma se reencarne en contra de su voluntad. Para ello, tienes que crear una pócima especial y seguir los pasos de un ritual muy preciso.",r:[50000,null,null,null,null,null]};
Q.s[199] = {n:"Levántate y anda...",d:"Divad no consigue resucitar a Terra Bitya para poder interrogarla. Por lo que tu misión será improvisar un hechizo de resurrección con el que seas capaz de hacerlo.",r:[null,null,null,null,null,null]};
Q.s[201] = {n:"Encuentra al fugitivo",d:"Rok ha sido visto al norte de Pandala. \nTiene pendiente una pena de prisión en Astrub.",r:[null,6250,null,null,null,null]};
Q.s[202] = {n:"Encontrar al fuera de la ley",d:"Musha ha sido visto en la parte sur de Pandala. Ha sido codenado a prisión en Astrub.",r:[null,64000,null,null,null,null]};
Q.s[203] = {n:"Encontrar al fuera de la ley",d:"Marzwelo ha sido visto cerca de Airedala. Ha sido codenado a prisión en Astrub.",r:[null,25000,null,null,null,null]};
Q.s[206] = {n:"Encontrar al fuera de la ley",d:"Aermyn ha sido visto cerca de Tierradala. Está condenado al encarcelamiento en Astrub.",r:[null,16000,null,null,null,null]};
Q.s[785] = {n:"Interrogatorio sorpresa.",d:"Elviana Tirips quiere saber qué información han proporcionado los renegados bontarianos a los brakmarianos y mira por donde, ¡eres tú el encargado de hacer el interrogatorio!",r:[200000,null,null,null,null,null]};
Q.s[786] = {n:"Se abre la veda de caza al renegado",d:"Algunos renegados bontarianos se han refugiado en Brakmar. Tienes que encontrarlos, eliminarlos y traer sus cadáveres hasta Bonta.",r:[200000,null,null,null,null,null]};
Q.s[209] = {n:"El secreto de Terra Bitya.",d:"Terra Bitya ha resucitado. Ahora sólo te queda convencerla para que te diga su secreto... ¡ahí es ná!",r:[200000,null,null,null,null,null]};
Q.s[208] = {n:"El puente hacia Terra Bitya.",d:"Alse Tocreto quiere echarle mano a las estatuillas de Sumens. Te ha encargado capturar al guardián.",r:[200000,null,null,null,null,null]};
Q.s[214] = {n:"Hablar con Bajofrente, el jefe mercenario de Astrub",d:"Bajofrente conoce las leyes relativas a los traficantes de Dofawa.",r:[1000,45,[[7929,1]],null,null,null]};
Q.s[213] = {n:"Hablar con el Mago Zo",d:"El Mago Zo debería poder analizar los huevos de tofu y el Dofus.",r:[1000,null,null,null,null,null]};
Q.s[212] = {n:"Huevos de tofu para Nowa",d:"Llevarle a Nowa: 2 huevos de tofu.",r:[1000,5,null,null,null,null]};
Q.s[217] = {n:"Conseguir una pluma de pío violeta para Acidrik",d:"La necesita para deshacer el hechizo de plagio que Herdegriz le echó a su libro.",r:[1500,100,[[7930,1]],null,null,null]};
Q.s[216] = {n:"Hacerse con el libro falso de Acidrik",d:"Este libro se llama \"El Tempo de los Dragones\" y no \"El Tiempo de los Dragones\".",r:[1000,200,null,null,null,null]};
Q.s[215] = {n:"Llevarle una cerveza a Acidrik",d:"Es capaz de ver tu futuro en la espuma de una buena cerveza.",r:[500,null,null,null,null,null]};
Q.s[219] = {n:"Ir allí donde el infinito y la nada se unen",d:"Aquí encontrarás una respuesta acerca del alma de Menalt.",r:[1500,50,[[7934,1]],null,null,null]};
Q.s[234] = {n:"Símbolo y simbolismo.",d:"Vuelve a ver a Nistracolamus para descubrir el significado de este famoso símbolo.",r:[1000,null,null,null,null,null]};
Q.s[218] = {n:"Descubrir la estatua del dios Xelor",d:"Debes memorizar el símbolo grabado en el martillo del dios.",r:[500,null,null,null,null,null]};
Q.s[220] = {n:"La cueva del Trankitronko",d:"Cuentan que el Trankitronko vive en esta cueva desde hace décadas. El ganadero que en ella entró nunca ha vuelto a salir...",r:[null,null,null,null,null,null]};
Q.s[221] = {n:"Un vistazo a los reclusos",d:"Los prisioneros de Astrub parecen estar muy agitados. Un mercenario te pide que le ayudes a vigilarlos.",r:[1000,null,[[133,1]],null,null,null]};
Q.s[233] = {n:"Una buena paliza a los reclusos",d:"Has sometido a los prisioneros de Astrub. Coméntaselo a Edgg Komb.",r:[1000,50,null,null,null,null]};
Q.s[222] = {n:"Visita al castillo de Allister",d:"Degui Ketatriste te propone visitar los nuevos aposentos del castillo y de su puerto.",r:[7000,50,null,null,null,null]};
Q.s[224] = {n:"Tablas para la estructura",d:"Tráele tablas de fresno a Kartier Tremai para acabar la construcción del tejado del castillo de Allister.",r:[3000,876,null,null,null,null]};
Q.s[227] = {n:"Carne de larva",d:"Tráele cachos de carne de larva a Kartier Tremai para que pueda alimentar a sus obreros.",r:[10000,1012,null,null,null,null]};
Q.s[226] = {n:"Trigo para los obrero",d:"Tráele trigo a Kartier Tremai para que pueda alimentar a sus obreros.",r:[3500,599,null,null,null,null]};
Q.s[225] = {n:"Piedrecillas para tapar los agujeros",d:"Tráele silex a Kartier Tremai para acabar la construcción de las paredes del castillo de Allister.",r:[3500,1022,null,null,null,null]};
Q.s[232] = {n:"Kartier Tremai prefiere brindar con un amigo",d:"Necesita cerveza y a un amigo para pasar una noche divertida.",r:[7500,3000,null,null,null,null]};
Q.s[228] = {n:"Una bonita mesa",d:"Kartier Tremai quiere impresionar a su futura novia con una bonita mesa llena de manjares.",r:[4000,4000,null,null,null,null]};
Q.s[230] = {n:"Una alianza para Monabella",d:"Kartier Tremai quiere invitar a Monabella a su cena para proponerle un noviazgo.",r:[2500,null,null,null,null,null]};
Q.s[229] = {n:"Un anillo en el desierto",d:"Kartier Tremai quiere un anillo de noviazgo.",r:[8500,3000,null,null,null,null]};
Q.s[231] = {n:"Kartier Tremai se consuela con Verrumacha",d:"Kartier invita a Verrumacha para compartir su cena.",r:[2500,null,null,null,null,null]};
Q.s[237] = {n:"Los dientes largos de la corrupción",d:"El tiburón le da kamas a Verrumacha.",r:[10500,null,null,null,null,null]};
Q.s[235] = {n:"La estela",d:"Verrumacha busca un tiburón.",r:[2100,null,null,null,null,null]};
Q.s[238] = {n:"Es la leche...",d:"A Verrumacha le apetece un poco de leche.",r:[12600,null,[[992,8],[989,8],[991,4]],null,null,null]};
Q.s[239] = {n:"La sonrisa del tiburón",d:"Escualo está contento de cómo transcurren las cosas.",r:[4800,null,null,null,null,null]};
Q.s[236] = {n:"El verdadero tiburón",d:"Verrumacha quiere que eche al \"tirubón\" del puerto.",r:[null,null,null,null,null,null]};
Q.s[242] = {n:"Una pócima de lame botas para un buen negocio",d:"Haraquiri querrá tal vez un poco de pócima para sus negocios con Allister.",r:[16500,1000,null,null,null,null]};
Q.s[240] = {n:"Los ingredientes de la pócima de lamebotas",d:"Cuerno del Jalatranki, Pétalo de Rosa Demoníaca, Kralamar vaciado y Semilla de Adormidera de son necesarios para realizar una buena pócima de lame botas.",r:[6000,6000,null,null,null,null]};
Q.s[241] = {n:"Una pócima de lame botas para una pesada",d:"Hay que entregarle la pócima a Monabella.",r:[7500,689,null,null,null,null]};
Q.s[243] = {n:"Fiesta de la espuma",d:"Eloko Osopeloso necesita beber cerveza para enfrentarse al tiburón.",r:[7000,30,null,null,null,null]};
Q.s[244] = {n:"Agua en el lúpulo",d:"A Eloko Osopeloso le duele la cabeza de tanto mezclar cervezas.",r:[2000,40,null,null,null,null]};
Q.s[245] = {n:"Un poco de cerveza",d:"Al docker le gustaría beberse algo para darse ánimos.",r:[1000,30,null,null,null,null]};
Q.s[249] = {n:"Un miaumiau para una plaplasta",d:"Monabella quiere un miaumiau blanco... Parece que quiere llevarse a un zoológico con ella para sus vacaciones.",r:[150000,5000,null,null,null,null]};
Q.s[248] = {n:"Montura y aceite para las vacaciones",d:"Monabella necesita un dragopavo y aceite de girasol para marcharse y descansar al sol en su futura casa de paja.",r:[140000,5000,null,null,null,null]};
Q.s[246] = {n:"Prisión y agencia inmobiliaria",d:"A Monabella le gustaría recuperar el antigua escondite de un prisionero para amueblarlo a su gusto.",r:[20000,null,null,null,null,null]};
Q.s[247] = {n:"Casa de paja",d:"Monabella quiere una casa aislada, lejos de la corte.",r:[50000,null,null,null,null,null]};
Q.s[250] = {n:"Tráfico de patatas",d:"Tienes que llevar sacos de patatas a la prisión del puerto.",r:[2000,null,null,null,null,null]};
Q.s[252] = {n:"Pobre patata",d:"Guemado Elwapo quiere agradecer a Rocco Fidelio por sus patatas.",r:[2500,1200,null,null,null,null]};
Q.s[251] = {n:"Una pala de patatas",d:"Guemado Elwapo quiere cultivar patatas él mismo por amor al arte.",r:[3000,null,[[538,12]],null,null,null]};
Q.s[253] = {n:"Bistés de Dragopavo",d:"Haraquiri, el carnicero oficial de Allister necesita carne fresca.",r:[5000,2500,[[10384,15]],null,null,null]};
Q.s[256] = {n:"Visitar la biblioteca",d:"Visitar la biblioteca",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[258] = {n:"Visitar la biblioteca",d:"Visitar la última biblioteca.",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[261] = {n:"Monturas para los animales",d:"El miliciano lo ha dicho claro, necesita dragopavos, ¡y rápido!",r:[75000,null,null,null,null,null]};
Q.s[262] = {n:"Cartografiar las tierras montañosas de los koalaks",d:"El cartógrafo Patalenta se está haciendo mayor para estos lejanos viajes.",r:[12000,50,[[7934,1]],null,null,null]};
Q.s[263] = {n:"Una cosecha fácil",d:"Hay orquídeas en las montañas de los koalaks. Hay que traerle un buen ramo a Maskara.",r:[7500,4000,null,null,null,null]};
Q.s[264] = {n:"Una lista cargada",d:"Koka Dekolak necesita varias materias primas muy específicas.",r:[30000,null,[[989,10],[281,2]],null,null,null]};
Q.s[265] = {n:"Una entrega alambicada",d:"Koka Dekolak necesita otra vez recursos muy específicos. Se encuentran en las tierras de los koalaks.",r:[120000,6000,[[283,10],[548,5],[580,10]],null,null,null]};
Q.s[266] = {n:"Un último recado para Koka",d:"Koka necesita otra vez que lo ayudes para una cosecha.",r:[350000,11000,[[539,30],[991,10],[548,5],[6964,5],[6965,5]],null,null,null]};
Q.s[267] = {n:"La llave de la mazmorra",d:"Enseñarle a Jalateater que estás decidido en ganar la llave de la Mazmorra de los Jalatós.",r:[7500,200,[[1568,1]],null,null,null]};
Q.s[268] = {n:"La vuelta al mundo",d:"Mega, el guerrero, te habló de una reliquia con fabulosos poderes. Primero debes demostrarle tu valor antes de seguir adelante.",r:[5000,null,null,null,null,null]};
Q.s[281] = {n:"Ir a ver al maestro",d:"Mega va a ponerte a prueba y para ello te envía a que vayas a ver a un enigmático personaje: El Amo de las llaves.",r:[10000,null,null,null,null,null]};
Q.s[271] = {n:"Continuar la aventura",d:"Debes seguir demostrando tu empeño.",r:[30000,null,null,null,null,null]};
Q.s[280] = {n:"Pasar a la etapa siguiente",d:"El Amo de las llaves te ha pedido ir a visitar al primero de sus amigos.",r:[null,null,null,null,null,null]};
Q.s[270] = {n:"Continuar la aventura",d:"Debes seguir demostrando tu empeño.",r:[30000,null,null,null,null,null]};
Q.s[269] = {n:"Luchar en la primera mazmorra",d:"Aquí empieza tu búsqueda de la reliquia de los Jug\'Onh. Enfréntate a los monstruos de la Mazmorra de los Campos.",r:[15000,null,null,null,null,null]};
Q.s[272] = {n:"Continuar la aventura",d:"Debes seguir demostrando tu empeño.",r:[40000,null,null,null,null,null]};
Q.s[273] = {n:"Para el título",d:"Pat será el árbitro para esta parte de la misión.",r:[45000,null,null,null,null,null]};
Q.s[279] = {n:"Pasar a la siguiente etapa",d:"Pat Adekabra te ha dirigido hacia la siguiente persona que puede ayudarte a demostrar tu valor.",r:[null,null,null,null,null,null]};
Q.s[278] = {n:"Para el título",d:"Pat no te pierde de vista.",r:[75000,null,null,null,null,null]};
Q.s[276] = {n:"Para el título",d:"Pat te está observando desde cerca.",r:[55000,null,null,null,null,null]};
Q.s[275] = {n:"Para el título",d:"Pat va a juzgar tus capacidades.",r:[45000,null,null,null,null,null]};
Q.s[277] = {n:"Para el título",d:"Pat no te quita el ojo de encima.",r:[65000,null,null,null,null,null]};
Q.s[274] = {n:"Para el título",d:"Pat será el árbitro para este asalto.",r:[45000,null,null,null,null,null]};
Q.s[288] = {n:"Una etapa sencilla",d:"A pesar de la dureza de los combates que has tenido que realizar, no eran más que una simple etapa.",r:[null,null,null,null,null,null]};
Q.s[283] = {n:"No tardar",d:"Chrisis no está mucho mejor, es preferible apurarse antes de que su estado empeore.",r:[135000,null,null,null,null,null]};
Q.s[284] = {n:"Rápido rápido rápido",d:"A pesar de que le llegue al alma, Chrisis te permite ir más adelante en tu caza de reliquias.",r:[145000,null,null,null,null,null]};
Q.s[287] = {n:"¿La ultima batalla?",d:"Si lo has entendido bien, ésta es tu última batalla antes de la victoria final.",r:[175000,null,null,null,null,null]};
Q.s[282] = {n:"Ir a otro sitio",d:"Chrisis anda ligeramente estresado. Será mejor hacer lo que pide cuanto antes.",r:[125000,null,null,null,null,null]};
Q.s[285] = {n:"Un verdadero desafío",d:"Chrisis te manda a sitios cada vez más peligrosos.",r:[155000,null,null,null,null,null]};
Q.s[286] = {n:"Otro más",d:"Sientes que tu búsqueda avanza... lentamente.",r:[165000,null,null,null,null,null]};
Q.s[296] = {n:"La última llave",d:"Kal te ha entregado la última llave. La meta está cerca...",r:[450000,null,null,null,null,null]};
Q.s[297] = {n:"¿Consagración?",d:"Kal ya no tiene nada para ti. Vuelve a hablar con el Amo de las llaves.",r:[null,null,null,null,null,null]};
Q.s[289] = {n:"Un mensaje muy claro",d:"Kal, una especie de máquina, te ayuda a cumplir tu misión. Por lo menos con él los objetivos son claros.",r:[250000,null,null,null,null,null]};
Q.s[291] = {n:"Problema mecánico",d:"Kal no ha resuelto sus problemas pero eso no te impide continuar tu misión.",r:[350000,null,null,null,null,null]};
Q.s[295] = {n:"Falta un tornillo",d:"Kal se queda bloqueado pero te da las llaves.",r:[400000,null,null,null,null,null]};
Q.s[290] = {n:"¿Problemas?",d:"Kal no ha conseguido transmitirte todo su mensaje pero con la llave puedes adivinar fácilmente lo que tienes que hacer.",r:[300000,null,null,null,null,null]};
Q.s[299] = {n:"El amo semental",d:"El amo cree que eres una verdadera máquina de matar, otra prueba.",r:[725000,null,null,null,null,null]};
Q.s[298] = {n:"El amo de las cintas",d:"El amo ha decidido imponerte más pruebas todavía. Esto se está convirtiendo en un aburrimiento.",r:[500000,null,null,null,null,null]};
Q.s[301] = {n:"El Amo despega",d:"Ya está, el amo de las llaves te entregó tu última prueba.",r:[875000,null,null,null,null,null]};
Q.s[300] = {n:"El amo de las normas",d:"Parece que no puedes librarte de esta interminable lista de masacres. ¡Qué le vamos a hacer!",r:[800000,null,null,null,null,null]};
Q.s[307] = {n:"El amo del juego",d:"Otro territorio hostil que tienes que atravesar.",r:[650000,null,null,null,null,null]};
Q.s[306] = {n:"El amo peligroso",d:"Esta vez, el amo te envía hacia el interior de las tierras en conflicto.",r:[575000,null,null,null,null,null]};
Q.s[302] = {n:"¡Por fin!",d:"Ya está, ¡has terminado! Ahora Mega tiene que cumplir su promesa. ¡La última reliquia de su familia es tuya!",r:[1000000,null,null,null,null,null]};
Q.s[315] = {n:"Servicio exprés",d:"La filtunga de Pol ya debe estar lista.",r:[null,null,null,null,null,null]};
Q.s[312] = {n:"¡Manos a la masa!",d:"La receta de la filtunga está entre tus manos. Ya no queda más que reunir todos los ingredientes para que Pol prepare la famosa receta.",r:[115000,5000,null,null,null,null]};
Q.s[311] = {n:"Un plato único",d:"La cruel Pandep amenaza con devorar a los niños El si no consigue nada mejor que comer.",r:[75000,null,null,null,null,null]};
Q.s[313] = {n:"Los ingredientes",d:"Argui Ñaño, el cocinero, va a realizar la receta si le traes todos los ingredientes.",r:[115000,null,null,null,null,null]};
Q.s[316] = {n:"La liberación",d:"Pol ha terminado la filtunga, Pandep podrá darse por satisfecha.",r:[120000,null,null,null,null,null]};
Q.s[310] = {n:"La pequeña choza en el bosque",d:"El joven Jorg ha hablado de una choza secreta en el bosque de los dragopavos.",r:[25000,null,null,null,null,null]};
Q.s[309] = {n:"La vuelta al pueblo",d:"Seguro que los aldeanos han visto a los niños El. Pregunta a unos cuantos habitantes si los han visto.",r:[35000,null,null,null,null,null]};
Q.s[308] = {n:"Una madre desconsolada",d:"Doña El está muy nerviosa. Anda buscando a sus hijos por el pueblo de Amakna.",r:[null,null,null,null,null,null]};
Q.s[314] = {n:"Comida rápida",d:"Pol ya tiene todo lo que necesita para preparar una filtunga. Ahora no más te queda esperar.",r:[15000,null,null,null,null,null]};
Q.s[321] = {n:"Matar bworks",d:"Gobatchef quiere que los bworks sean masacrados antes de que masacren a los goblins.",r:[20000,1000,null,null,null,null]};
Q.s[322] = {n:"Krazybwork quiere volver a ser idiota",d:"Krazybwork ha comido demasiados Goblines durante la batalla de Bworkdrift. Se convirtió en un ser inteligente y su deseo es volver a ser idiota. ¡Lo mejor sería darle un buen porrazo en toda la cabeza!",r:[null,500,[[8527,1]],null,null,null]};
Q.s[323] = {n:"Bworkidio el Paxifista",d:"¿Habrá pelea o no?",r:[15000,null,null,null,null,null]};
Q.s[325] = {n:"Recórtese siguiendo los puntos",d:"Bworknroll necesita llenar su criatura con cachos de órganos frescos (y jugosos).",r:[150000,null,null,null,null,null]};
Q.s[326] = {n:"No olvidar lo esencial: ¡el almejillón!",d:"Bworknroll necesita un almejillón recién salido del agua para acabar su criatura de ensueño.",r:[230000,5000,null,null,null,null]};
Q.s[324] = {n:"Un escalpelo útil",d:"Bworknroll necesita cachos de carne para fabricar su pareja ideal.",r:[120000,null,null,null,null,null]};
Q.s[375] = {n:"Qué dientes más grandes tienes.",d:"Un mediulubo te hace una propuesta tentadora.",r:[null,null,null,null,null,null]};
Q.s[376] = {n:"Inscripción",d:"Si Bworknroll acepta el pago, Peque podrá ser mago.",r:[null,null,null,null,null,null]};
Q.s[328] = {n:"Mimar al Peque",d:"Al padre de Peque le gustaría que se hiciera mago. Para que fuera posible, tendría que llevarlo a casa del Bwork Mago más poderoso sin olvidar la comida.",r:[null,null,null,null,null,null]};
Q.s[374] = {n:"Le han dado una beca a Peque",d:"Bworknroll aceptó enseñarle la magia al Peque. Darle la noticia a su padre.",r:[null,null,null,null,null,null]};
Q.s[330] = {n:"Pieles verdes",d:"Bworkespín quiere pieles de goblins para sus hembras.",r:[45000,30000,null,null,null,null]};
Q.s[331] = {n:"Una varita y un set",d:"Jefe Bworkesta necesita demostrarle su virilidad a su novia, para ello va a pedirles regalos a los visitantes que pasan por su bonito pueblo. \nCon un set de prespic, piensa que podrá protegerse contra los golpes de rodillo de su amor, bworkita...",r:[45000,35000,null,null,null,null]};
Q.s[340] = {n:"Más negociaciones",d:"Gobrosa prefiere ser una esclava y criar píos. Tendrás que explicarle esta triste realidad a su pretendiente...",r:[20000,null,null,null,null,null]};
