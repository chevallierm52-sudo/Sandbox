Q.s[800] = {n:"Robo en el corazón de Bakmar.",d:"Los brakmarianos se han hecho con la segunda estatua de Sumens. Encuétrala y recupérala.",r:[600000,null,null,null,null,null]};
Q.s[798] = {n:"El secuestro de Dike Tarak.",d:"Onidal te ha pedido que encuentres a DikeTarak, el sobrino de Amayiro, al que han secuestrado durante una excursión con su clase a las llanuras de Cania.",r:[null,null,null,null,null,null]};
Q.s[799] = {n:"Zona 51",d:"Algo te dice que el objeto extraño que has encontrado en el campamento está relaccionado con el rapto de Dike Tarak. Sólo te falta encontrar de qué modo.",r:[null,null,null,null,null,null]};
