Q.s[334] = {n:"Alas en kit",d:"Gobriel está harto de que los demás goblins le tiren piedras por culpa del color de su piel. Le gustaría convertirse en ángel.",r:[30000,null,null,null,null,null]};
Q.s[351] = {n:"El hilo de la historia",d:"Para conseguir información acerca de la espada de Yopuka puedes ir a ver a Yueba en el templo.",r:[75,null,null,null,null,null]};
Q.s[348] = {n:"Bienvenido/a",d:"¡Bienvenido/a!",r:[null,null,null,null,null,null]};
Q.s[349] = {n:"Pío",d:"¡Pío, pío, pío, pío, pío!",r:[250,null,[[6897,2],[8537,1]],null,null,null]};
Q.s[346] = {n:"Arietta Frasca",d:"Busca a Arietta Frasca.",r:[25,null,null,null,null,null]};
Q.s[332] = {n:"Esquila matinal",d:"Yanclod es un tipo genial, ha comprendido que con la lana se podía hacer... lana.",r:[120,150,null,null,null,null]};
Q.s[344] = {n:"Otro recado",d:"Esta vez tienes que llevarle un objeto a un xelor encargado de los zaaps.",r:[150,null,null,null,null,null]};
Q.s[416] = {n:"Bunny suit",d:"El pwíncipe del Wey te ha pedido reemplazarlo para descubrir a los asesinos. Pero antes tendrás que encontrar a alguien que te pueda transformar en Wabbit.",r:[15000,null,null,null,null,null]};
Q.s[415] = {n:"¡Asesino!",d:"El pwíncipe del Wey está siendo atacado, ¡Protégelo!",r:[5000,null,null,null,null,null]};
Q.s[417] = {n:"Compras",d:"Ahora que la fórmula está completa necesitas los ingredientes.",r:[120000,null,null,null,null,null]};
Q.s[390] = {n:"Dilema, dilema...",d:"Ahora sabes que Ys Vewybad está armando un complot contra el Rey. Vas a tener que elegir un bando.",r:[2000,null,null,null,null,null]};
Q.s[254] = {n:"Una buena comida",d:"Lorkos te regalará una llave del laberinto si le llevas comida para que pueda preparar una buena cena.",r:[null,null,null,null,null,null]};
Q.s[542] = {n:"Desaparición",d:"Ya puedes terminar tu investigación y llevarle tu informe a Oto Mustam.",r:[226000,null,null,null,null,null]};
Q.s[539] = {n:"El lado oscuro del wabbit",d:"Tendrás que negociar con Tugtora. Ofrécele un rascador para la espalda Spentox a cambio de que te diga dónde se encuentra el cuerno Mágico. Pero, ¿quién te espera en la selva profunda de Moon?",r:[null,null,null,null,null,null]};
Q.s[540] = {n:"El cuerno está enterrado, ¿quién lo desenterrará?...",d:"Tugtora te ha confesado que el cuerno Mágico está enterrado al noreste de la isla, cerca de una estatua de fénix.",r:[null,null,null,null,null,null]};
Q.s[541] = {n:"El aguafiestas",d:"Tus excavaciones se han visto interrumpidas por la llegada de un sadida. Te toca enseñarle lo que les ocurre a los que se oponen a Brakmar.",r:[null,null,null,null,null,null]};
Q.s[260] = {n:"Caballería ligera",d:"Entregar algunas monturas nuevas para la milicia.",r:[75000,null,null,null,null,null]};
Q.s[821] = {n:"El documento falso de Maimane.",d:"Tienes que ir a la  Taberna del Chatarrero, situada en Bonta, para recuperar un documento falso que tiene Motás Fegael",r:[null,null,null,null,null,null]};
Q.s[819] = {n:"Encontrar a Maimane.",d:"Tienes que localizar a Maimane. La joven Xela Dikk que se encuentra en Amakna puede informarte, pero para ello tendrás que ser muuy muuuy muuuuuy amable.",r:[null,null,null,null,null,null]};
Q.s[825] = {n:"El encuentro con Maimane.",d:"Tienes que engañar a Maimane y decirle que Djaul le presenta sus más sinceras excusas.",r:[null,null,null,null,null,null]};
Q.s[823] = {n:"Informe de un espía.",d:"Divad necesita que un miembro de la Orden del Ojo Putrefacto redacte un informe falso. Tienes que pedirle a Alse Tocreto que colabore.",r:[null,null,null,null,null,null]};
Q.s[820] = {n:"Informe sobre la cita.",d:"Divad necesita que un espía brakmariano le redacte un informe falso. Alse Tocreto podrá proporcionarte uno",r:[null,null,null,null,null,null]};
Q.s[826] = {n:"La asamblea de los defensores.",d:"Divad Dleifrepok desea que representes a la Orden del Espíritu Insano durante la asamblea de los defensores y que luego le redactes un informe.",r:[1200000,null,null,null,null,null]};
Q.s[822] = {n:"Falso testimonio.",d:"Debes ponerte en contacto con Mik Vackey, uno de los milicianos de Amakna, para sobornarle a cambio de la información.",r:[null,null,null,null,null,null]};
Q.s[824] = {n:"La confesión del espía bontariano.",d:"Divad necesita el testimonio de un espía bontariano. El servicio de contra-espionaje de Alse Tocreto podría resultarte útil.",r:[null,null,null,null,null,null]};
Q.s[914] = {n:"Spentox, no rasca, hace cosquillas",d:"Mulic Bere te ha dejado entrar en su forja especial para que puedas fabricar un rascador para la espalda Spentox.",r:[198000,null,null,null,null,null]};
Q.s[532] = {n:"La forja de lujo",d:"Hay que fabricarle a Tugtora un rascador para la espalda que pueda utilizar. El mejor forjador de Brakmar, Mulic Bere, te ayudará a crear este particular objeto.",r:[null,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[813] = {n:"Problemas en Amakna.",d:"Con el propósito de estimar el alcance de los daños, Alse te ha pedido que vayas a Amakna y que interrogues a sus habitantes.",r:[null,null,null,null,null,null]};
Q.s[842] = {n:"Trama retorcida.",d:"Como Domen ha eliminado a la alidada de Oto Mustam antes de que hablase, puedes retomar la misión en la torre de Gisgul",r:[null,null,null,null,null,null]};
Q.s[815] = {n:"Domen el liante",d:"Domen necesita la llave del santuario Hotomani pero no te ha dicho para qué. Fidji Merlín tiene los planos de la llave.",r:[null,null,null,null,null,null]};
Q.s[841] = {n:"Un castigo bien merecido.",d:"Domen te ha castigado por desvelar su plan a los partidarios de Oto Mustam... y para castigarte y tocarte las narices nada mejor que una misión sin interés alguno.",r:[null,null,null,null,null,null]};
Q.s[812] = {n:"Un poder incontrolable.",d:"Alse te ha pedido que interrogues a los otros maestros de orden y al jefe de la milicia para poder comprobar si hay un cambio de comportamiento.",r:[null,null,null,null,null,null]};
Q.s[818] = {n:"La asamblea de los Protectores.",d:"Alse Tocreto desea que representes a la Orden del Ojo Pútrido durante la asamblea de los protectores y que luego le redactes un informe.",r:[1200000,null,null,null,null,null]};
Q.s[817] = {n:"Trama retorcida.",d:"Disfrazado de bontariano debes ir a la torre de Gisgul a darle las instrucciones a un wabbit obrero. Domen te ha pedido que seas discreto.",r:[null,null,null,null,null,null]};
Q.s[816] = {n:"Una curiosa idea.",d:"Domen te ha pedido que te busques un atuendo de miliciano bontariano.",r:[null,null,null,null,null,null]};
Q.s[814] = {n:"El informe.",d:"Has inspeccionado los alrededores del castillo de Amakna. Ya es hora de volver a Bonta para hacer el informe.",r:[null,null,null,null,null,null]};
Q.s[746] = {n:"El pobre de Oto.",d:"A Oto no le queda ni un céntimo. ¿Qué se podría hacer para remediar la situación?",r:[10000,null,null,null,null,null]};
Q.s[748] = {n:"Robar el pulmón.",d:"Oto quiere que robes el pulmón de la llanura a Azra Lazarus, la joyera. Al parecer ella dispone de un escolta, pero quizás puedas evitar el combate...",r:[11400,null,null,null,null,null]};
Q.s[758] = {n:"Encontrar un bontariano deshonesto.",d:"Tienes que encontrar un bontariano culpable de asesinato. Para eso, tienes que conseguir que Fryda te dé un bastón husmeador. Luego sólo tendrás que probarlo con los bontarianos hasta que encuentres uno que te convenga.",r:[21000,null,null,null,null,null]};
