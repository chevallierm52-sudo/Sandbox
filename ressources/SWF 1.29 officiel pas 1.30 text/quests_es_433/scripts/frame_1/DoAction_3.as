Q.s[975] = {n:"La forja del Resplandor del Alba.",d:"Danathor quiere que vayas al Islote Estitch para forjar el Resplandor del Alba. Sigue sus instrucciones al pie de la letra.",r:[312000,null,null,null,null,null]};
