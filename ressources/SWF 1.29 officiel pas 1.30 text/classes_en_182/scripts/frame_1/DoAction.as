G[7] = {sn:"Eniripsa",ln:"Eniripsa\'s Hands",ep:1,d:"Eniripsas are Healers with the power to ease your pain with a single Word. Their potent utterances can either heal their allies or hurt their enemies... Some of them even became word hunters, wandering the earth in search of obscure verbs and forgotten languages!",sd:"As healers, they use their spells to cure their allies.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
