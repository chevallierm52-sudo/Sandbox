SCR[478] = "mit dem Wa Pwinzen";
SCR[479] = "So jemand einen Einspruch gegen diese Hochzeit erheben will, möge er jetzt sprechen oder für immer schweigen!";
SCR[480] = "Bob Lenald";
SCR[481] = "Ich erhebe Einspruch! Diese Hochzeit ist eine Untat! Der Prinz ist ein Wabbit!";
SCR[482] = "Ich fordere dich heraus, Kawottenprinz!";
SCR[483] = "Mein Held... Wo ist mein Held?";
SCR[484] = "Ich werde die Vorbereitungen treffen. Bis gleich!";
SCR[485] = "Ah, da kommt sie ja!";
SCR[486] = "Ich habe die Hilfe deines neuen Freundes in Anspruch genommen, damit er dir die Grundlagen des Kampfes beibringt. Heutzutage ist das sicherer...";
SCR[487] = "... und ich möchte, dass du wenigstens in der Lage bist, dich zu verteidigen.";
SCR[488] = "Nun gut, mein junger Freund. Gebt meiner Tochter ein Zeichen, wenn ihr soweit seid.";
SCR[489] = "Das wird mir meinen Fresssack auch nicht zurückbringen!";
SCR[490] = "Würdet ihr das wirklich tun? Das ist sehr freundlich!";
SCR[491] = "Eines meiner Fresssäckchen hat sich im Untergrund verlaufen. Bringt es mir zurück, dann sind wir quitt!";
SCR[492] = "Gib mir dein Bier, sonst...";
SCR[493] = "Ah... Ich habe von diesem Duell Wind bekommen. Es kommt nicht in Frage, dass ihr gegen Arkana kämpft!";
SCR[494] = "ICH WERDE DIESE HOCHZEIT UNTERBINDEN UND ZWAR IN DEM AUGENBLICK, WO ICH DIR DEN HALS UMDREHE!";
SCR[495] = "Mörder";
