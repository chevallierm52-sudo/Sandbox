SCR[497] = "Was?!?";
SCR[498] = "So, nun beherrschst du die Kunst!";
SCR[499] = "Du wirst Arkana niemals bekommen!";
SCR[500] = "Gehen wir, Juppi?";
SCR[501] = "Komm mit, ich bringe dich zu BworknRoll.";
