Q.s[1019] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[608] = {n:"Intérprete? Interprete!",d:"Para se comunicar com os Wabbits e dizer a eles que construam e não cavem, As\'Ruoy\'Dnim precisa de um intérprete.",r:[null,null,null,null,null,null]};
Q.s[607] = {n:"Cenowawas em Crescimento",d:"Wabbits devem cultivar Cawwots para continuar seu \"trabalho\" no templo. Eles vão precisar de 10 Cawwots, 2 unidades de Fertilizante, 50 unidades de Água e um Amuleto de Lou Ptiote. ",r:[null,null,null,null,null,null]};
Q.s[534] = {n:"A Escolha",d:"Você encontrou o espião a tempo. Mas você vai seguir as ordens, pegar os documentos e deixar ele ali?",r:[205000,null,null,null,null,null]};
Q.s[144] = {n:"... Ou dentes de Xelors.",d:"Os Xelors parecem estar interessados. De acordo com Ant, eles vão gostar de colocar as mãos em uma ampulheta... Bem, o Ant não parecia ter muita certeza disso.",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Encontre o fora-da-lei",d:"Qil Bil foi visto perto das planícies Sidimote e é procurado por remover membros humanos. Sentenciado à prisão em Astrub.",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"Realistar-se, disse ele.",d:"Snori Nairb prometeu dividir seus Kamas e sua experiência com você se você realistar-se na milícia de Brakmar.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"Quem semeia vento colhe tempestade",d:"Para testar sua teoria sobre o surgimento de flores carnívoras, Trapchet pediu alguns grãos de rosa obscura para semear e ver os resultados.",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"O bom, o mau e a flora.",d:"Três-flores, um amigo de Trapchet que vive em Amakna, conhece a flora da área como ninguém. Você deve pedir a ele algumas informações sobre as flores agressivas que estão por aqui.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"Sementes de Epyss",d:"Erty Trapchet gostaria de estudar algumas sementes de dandélio para compará-las com algumas Epyss...",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"O irrigador",d:"Erty Trapchet esqueceu de cuidar de suas plantas. Você precisa regá-las.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"Que bagunça de ervas daninhas!",d:"Para sua pesquisa, Trapchet precisa estudar a distribuição geográfica das flores em Astrub.",r:[6500,500,null,null,null,null]};
Q.s[60] = {n:"Maldição, como é óbvio!",d:".",r:[null,null,null,null,null,null]};
Q.s[56] = {n:"Investigação sobre um desaparecimento... De casa",d:"",r:[null,null,null,null,null,null]};
Q.s[38] = {n:"Entrega de Erty Trapchett",d:"",r:[null,null,null,null,null,null]};
Q.s[40] = {n:"Entrega da Mina",d:"",r:[null,null,null,null,null,null]};
Q.s[39] = {n:"Entrega de Noam Wanarm",d:"",r:[null,null,null,null,null,null]};
Q.s[143] = {n:"Caça selvagem",d:"Algumas criaturas das sombras estão arruinando os negócios de Ant Emicheun. A resposta é se livrar delas... Pelo menos até que ele possa entender o que elas estão fazendo aqui...",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"Os ovos são capazes de nadar?",d:"Sem mais agentes infecciosos nas penas do Tofus doente. Por outro lado, seus ovos provavelmente serão utéis para Eniripsa. Alguns kamas a mais para ganhar!",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"Confusões no ar!",d:"De repente, você sente a necessidade de aprender mais sobre si mesmo e decide ir a um local debulhado de sangue... O açougue.",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"Sangue a vista!",d:"Seu mestre ouviu que recentemente, um operário que trabalhava nas minas transformou-se em um mineirador das sombras. Ele quer saber o que realmente aconteceu!",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"Enutrofs Estúpidos!",d:"Enutrofs fizeram uma descoberta e precisarão de sua ajuda.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Essência de Dizbi",d:"A flor não poderá ser usada da forma como está: você precisa usá-la para fazer um chá!",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Entrega Expressa",d:"Traga o chá para o líder de sua guilda, assim ele poderá fazer seu cajado. Se você tiver algum tempo disponível, traga um pouco da infusão para o fornecedor de flores também: ele ficará satisfeito.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Flor de Dizbi",d:"Você deve encontrar algumas flores de Dizbi se deseja que seu mestre faça um cajado valioso.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"Estamos famintos!",d:"Os Gobballs de Allisteria estão famintos. Eles precisam ser alimentados... todos eles!",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Pudim Gobball Preto",d:"Salve a tradição do bom Pudim Preto de Gobball.",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Lute se você é um Feca",d:"O famoso Fallenster pediu para que você treinasse a filha dele. Só assim ela poderá tornar-se uma lutadora.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"É proibido vender água para pessoas com idade abaixo de...",d:"O caminho da água consiste em resistir a qualquer forma a absorção de água ou submersão (parcial ou total), sem beber ou se lavar (exceto em extrema necessidade). Encontre o mestre do caminho da água: ele sabe mais do que parece.",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"Lenald, o Sábio",d:"Uma vendedora Pandawaiian de refrigerante aconselha que você fale com Lenald, o Sábio. De acordo com ela, ele é o único que sabe a verdade sobre Pandala e seus mistérios.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"A Estátua da Deusa",d:"O Grandapan aceitou com prazer o presente dos Enutrofs. Como um admirador ardente dos caçadores de Dofus, ele deu calorosas saudações.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"O Grandapan: A Pandawa simpático",d:"De acordo com o conselho do Xamã, O Enutrof tem a cura. Ele é realmente sábio sobre o folclore local e as lendas Pandawaiians.",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Libação da Deusa",d:"Obrigado por sua ajuda. O assistente do Xamã pode começar o ritual de agradecimento à deusa. Ele estará pronto assim que você fizer a tradicional oferenda padawaiian.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"A serviço do rei",d:"O rei gosta de cavalgar. Você deve encontrar dragossauros para ele.",r:[75000,null,null,null,null,null]};
