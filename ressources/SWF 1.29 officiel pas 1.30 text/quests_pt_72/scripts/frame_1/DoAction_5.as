Q.s[557] = {n:"Refresco, Mulheres, Energético....",d:"Em troca por seu favor garantindo mais tempo, o juiz Satirev Onivin te pediu algumas bebidas de Astrub para refrescar seus prisioneiros e uma mulher de Astrub para refrescar seu corpo.",r:[null,null,null,null,null,null]};
Q.s[551] = {n:"Negociando mais vezes",d:"O juiz Satirev Onivin não gosta de investigações que duram uma eternidade. Amayiro te enviou para vê-lo e negociar mais tempo. Ele passa a maior parte do seu tempo na milícia.",r:[null,null,null,null,null,null]};
Q.s[554] = {n:"O Sufoco em Conseguir Mais Tempo",d:"Você conseguiu mais tempo. Amayiro vai ficar contente ao saber disso.",r:[248000,null,null,null,null,null]};
Q.s[593] = {n:"Agente que foi Infiltrado",d:"Divad pediu que você derrotasse um dos agentes de Domen no Cemitério dos Heróis, em troca pela ajuda.",r:[null,null,null,null,null,null]};
Q.s[590] = {n:"Começo e Fim de um Plano",d:"Você deve encontrar alguém em Brakmar capaz de fazer uma roupa de Dreggon... Ou capaz de mudar os planos de As\'Ruoy\'Dnim.",r:[null,null,null,null,null,null]};
Q.s[594] = {n:"Uma Fantasia Confiável",d:"Engane o guarda de Dreggon na casa dos símbolos, a caminho do centro da Vila de Dreggon, e pegue um símbolo para As\'Ruoy\'Dnim.",r:[null,null,null,null,null,null]};
Q.s[591] = {n:"Outro Plano",d:"O sapateiro te contou que o plano de As\'Ruoy\'Dnim seria uma completa falha (que surpresa!)... Agora você deve encontrar alguém que te ajude na missão que te deram.",r:[null,null,null,null,null,null]};
Q.s[1018] = {n:"null",d:"",r:[430000,null,null,null,null,null]};
