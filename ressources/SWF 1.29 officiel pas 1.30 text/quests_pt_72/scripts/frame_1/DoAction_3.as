Q.s[898] = {n:"A confirmação",d:"Pandalida escapou enquanto nós lutávamos. Acho que ela foi se esconder na sua casa. Vou DEVE convencê-la a entregar a carta à Xephires.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intimidação Íntima",d:"Vasculhar a casa de Pandalida lhe dá mal-estar. Você precisará de 3 pastas Tra Khben, que é feita da mistura de 15 Focinhos de Javali, 5 Potes de Greedovore e 1 Penas de Quetsnakiatl.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"Mensageiro",d:"Você deverá encontrar uma maneira de entregar a carta para Xephires. Ele frequenta a Taverna do Pandawa Eufórico, mas se recusa a falar com você.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"Assumindo o Controle",d:"Você deverá encontrar o guerreiro Tink Berval e peça a ele que vá e chame o guerreiro Brank Thoof",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"Um Prato Melhor Servido Frio",d:"Já que Elturt é um esfomeado, e suas táticas brutas não estão funcionando, você deve encontrar um modo de envenená-lo. Algum morador da ilha deve saber qual é a comida favorita da tartaruga.",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Virando uma Tartaruga de cabeça para baixo.",d:"Como perguntar não parece estar funcionando, você deve agir um pouco diferente para conseguir essa informação.",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Transformação",d:"Poss\'Ybel quer que você abasteça-o com alguns produtos feitos de sua própria colheita.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Transformação",d:"Poss\'Ybel quer uma mini-poção de cura feita de uma flor Flax e um pouco de água.",r:[50,null,null,null,null,null]};
Q.s[379] = {n:"Transformação",d:"Poss\'Ybel quer que você abasteça-o com alguns produtos feitos de sua própria colheita.",r:[50,15,null,null,null,null]};
Q.s[380] = {n:"Transformação",d:"Poss\'Ybel quer que você abasteça-o com alguns produtos feitos de sua própria colheita.",r:[50,15,null,null,null,null]};
Q.s[686] = {n:"Rastreie os Eufóricos",d:"Você deverá rastrear pela Taverna de Bonta e encontrar o miliciano que está trabalhando e pedir pelos crachás.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Termos de troca",d:"Telma fez uma lista de todas as coisas que ela pediu para seu colar mágico.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"Sou um trabalhador social",d:"Qwizitor quer saber se os moradores da vila notaram coisas estranhas ou incomuns.",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Conexão Xamã",d:"O Xamã é um Pandawa que sabe muito sobre os planos de alguns povos... Parece não ser um caminho de rosas em Pandala!",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"Vida longa à Deusa!",d:"Recém-chegado a Pandala, o assistente Xamã deseja que você tenha mérito de sua deusa: uma oferenda espiritual de fato deve ser bom para você... Sua iniciação pode começar.",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Encontre um trabalho",d:"Postor Nhin provavelmente tem algo para você fazer.",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"Uma receita para Babblera",d:"Babblera está esperando pela receita de panqueca de Astrub, assim ela pode se organizar para receber bem as crianças.",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"Risco Total",d:"Entre no esconderijo dos bandidos utilizando uma corda. Lembre-se: não vá sozinho!",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"Retorno à Amayiro",d:"Você encontrou o sentinela dos bandidos, isso significa que o esconderijo não está longe. Amayiro ficará interessado neste pedaço de informação.",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"Encontre o Esconderijo",d:"Amayiro pediu a você que investigue as Planícies de Cania e encontre o esconderijo dos Bandidos. Ele disse que deve ser perto da feira.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Linda Nara",d:"Nara deu uma longa lista de materiais de que ele precisa para fazer o equipamento para Bonta. Você deve trazê-los para ele dentro da Mina de Porco.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Estado Real",d:"Você visitou todos os lugares como Setag pediu. Agora, você deve convencer Nara a se mudar para um deles.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"Caçada Interna",d:"Amayiro pediu que você encontrasse o ferreiro que pode ajudar Bonta. Aparentemente, ele está em uma mina ou caverna perto da Oficina de Norb.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Transporte de Caixas",d:"Você deve carregar 4 caixas de Amayiro para o posto avançado de Bonta.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Entre prove",d:"Como você é novo na área, o povo local precisa ter certeza que pode confiar em você.",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"Licença quatro",d:"Você conseguiu o energético. Enquanto dá a Brett, você deve recuperar toda a sua força.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Traga o energético",d:"Brett quer energético. Por quê ele mesmo não pega?  ",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"O encontro",d:"Você precisa descobrir mais sobre Elturt. Um especialista em animais deve ser capaz de ajudá-lo. Oshimo, o dono do Canil, pode ser uma boa pessoa pra isso.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"O Wabbit e a Tartaruga",d:"De acordo com Oshimo, Elturt tem um arqui-inimigo. Herr Palp Itane assinou um contrato com alguns demônios para aumentar seus poderes. Ele vive na Ilha dos Wabbits Esqueletos.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Caderneta de endereço",d:"Adicionar um jogador à lista de amigos.",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"Que bicho é este?",d:"Onmast\'her te desafiou a derrotar o monstro escondido em sua morada.",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Jogo de Trool",d:"Raxitik está aterrorizado. Ele sabe que Bworks o levarão para o Troll brincar em seu joguinho. Você deve matar este Troll que ameaça a integridade física de Raxitik.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"Peregrinação Vermelha",d:"Confronte o Dopple no templo de cada raça.",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Aniquilando Tartarugas",d:"Oto pediu que você derrote 10 tartarugas da Ilha da Lua. Traga os olhos delas como prova.",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Suco para Oto",d:"Você precisa trazer suco para Oto Greedovore. Mas onde você irá encontrar?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"Entrevista",d:"Uma celebridade Brakmariana perguntou de você. Vá e a encontre no porão da torre de Brakmar.",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Energizando Poções",d:"Oto Mustam precisa de três Poções Pahoa Raid",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"Resgate",d:"A mensagem do chefe dos ladinos o ajudou a encontrar seu esconderijo. Porque você não vai verificar antes de voltar para a milícia?",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"Compre o equipamento",d:"Você deve comprar e equipar o equipamento que Oto lhe pediu para pegar antes de visitá-lo novamente.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"32 Dentes de Ouro",d:"Traga para Mak uma dentadura dourada. Você encontrará alguns nos Chafers de Elite, mas o ferreiro de Brakmar também pode lhe fornecer algumas.",r:[28000,null,null,null,null,null]};
Q.s[487] = {n:"Entrar na biblioteca",d:"Os espiões falharam na missão. Você deve fazer isso para eles. O alvo é o estrategista que mora na biblioteca de Bonta.",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Infiltrador",d:"Agora, você pode entrar na biblioteca para cuidar do estrategista.",r:[null,null,null,null,null,null]};
Q.s[750] = {n:"Assustando Sbab",d:"Oto pediu que você mostrasse a Sbab 10 orelhas de Tiwabbits para assustá-la. Mas talvez exista uma maneira de não ter que fazer isto caso não queira...",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Arrasando com os Bontarianos",d:"Oto perguntou pediu um energético na Taverna Kikim... Em Bonta!",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Encontre os documentos",d:"O espião não tinha os documentos confidenciais com ele. A fauna de Sidimote provavelmente deu uma mãozinha a eles.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"A Revelação",d:"Embaixo do mercado de alquimia existe um armário. Você precisa ficar em frente a ele para abrir a passagem secreta. Magus Ax está esperando por você lá.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"Magus Ax",d:"Magus Ax pode ser encontrado na Oficina dos Alquimistas em Astrub. Ele deve saber mais sobre o chifre mágico.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"Retornar ao Batente",d:"É hora de voltar a Bonta e avaliar a situação com Amayiro.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"Conhecimento comum",d:"Vá e aprenda como capturar almas. A chave do Calabouço deve estar com as criaturas da região.",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Capacetes de Chafer",d:"Oto quer 10 Capacetes de Chafer que pode ser encontrado no Cemitério dos Atormentados.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Presença Brakmariana",d:"Você foi atacado por um Brakmariano que já estava lá, mas que não possuia o Chifre. Se Ecaflip estiver ao seu lado, você deverá ser capaz de encontrar o Chifre de Fogornleg antes dos Brakmarianos.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"A Decisão de Elturt",d:"Convença Elturt a trocar o Chifre de Fogornleg pela Bandana Remendada. Você irá precisar de um Chapéuemboscada e uma garrafa de Greedoburg para fazer ele aparecer.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Caça ao Lobo",d:"Oto pediu que você livre Brakmar do lobo que está à espreita",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"Localização Localizada",d:"Amayiro está interessado no que Norb contou a você.",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Oficinas",d:"Você deve encontrar um ferreiro habilidoso que aceitará fazer o equipamento para Bonta. Amayiro sugere que você procure nas Oficinas (tanto nas de ferreiros, como nas de mineradores).",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Outro Hospedeiro",d:"De acordo com Oto, o hospedeiro em Sufokia tem informações sobre um poderoso chifre mágico.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"Se você quer algo bem feito...",d:"A informação que o hospedeiro de Ripate revelou a você não é tão útil do jeito que estão as coisas. Uma pequena conversa com alguem mais instruído poderia ser mais frutífera.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, koko?",d:"Você tem uma idéia vaga do que Oto Mustam possa ter planejado para sua próxima missão, e assim, pode ser melhor você abrir caminho recolhendo algumas Kokonozes.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Conchas",d:"Ripate, o hospedeiro, quer que você traga Cascos de targaturas da Lua - uma de cada cor. Mas talvez você possa fazer algo mais simples e rápido...",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Derrote o lupus minimus.",d:"Uma batalha que colocará todas as suas novas habilidades em teste.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Missão Inacabada",d:"O caminho está livre agora, embora os goblins fossem inofensivos também. Exoram finalmente será capaz de  contar o que realmente faz Oto Mustam feliz.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"O Informante",d:"Exoram se sente inseguro. Disse ter ouvido algo esquisito, como risadas demoníacas vindas do norte. Se você consegir afirmar a ele de que a estrada está ok, ele lhe uma preciosa informação sobre Xephires.",r:[null,null,null,null,null,null]};
Q.s[445] = {n:"Sem Resultados",d:"Você conseguiu interessantes informações para Oto Mustam. Ele pediu que você domine um miliciano. Vá a Floresta Treechnid e procure por um Sram que conheça Xephires.",r:[null,null,null,null,null,null]};
Q.s[891] = {n:"Missão longe de ser acabada",d:"As marcas da luta e destroços de Karnes indicam que Exoram foi capturado -  e que se engajou na luta. Oto Mustam não se alegrará ao descobrir.",r:[65000,null,null,null,null,null]};
Q.s[444] = {n:"Informação",d:"Você deve encontrar informações sobre Xephires. Hospedeiros Bontarianos talvez possam te ajudar.",r:[null,null,null,null,null,null]};
