Q.s[7] = {n:"Um pouco de comida",d:"Se você encontrar algumas pessoas pelo caminho, pergunte a elas o que um Miau de tamanho médio gosta de comer. Quando descobrir, traga um pouco de comida para ele.",r:[1220,null,null,null,null,null]};
Q.s[9] = {n:"O Miau é um herói?",d:"Este frágil Miau precisa ser visto como um verdadeiro herói por seu companheiro. Descubra uma maneira de fazer isso.",r:[3060,null,null,null,null,null]};
Q.s[6] = {n:"Um pouco de leite para o Miau",d:"Traga um pouco de leileite para o Miau miserável.",r:[1220,null,null,null,null,null]};
Q.s[8] = {n:"Um passeio com o Miau",d:"Leve o Miau para dar uma caminhada pela cidade",r:[1500,null,null,null,null,null]};
Q.s[13] = {n:"Anel entregue",d:"Shani deu a você um anel que tem poderes latentes. Para ativá-los, você precisa derrotar um Treechnid.",r:[11000,1200,[[6793,1]],null,null,null]};
Q.s[12] = {n:"Um pouco de coisas espinhosas",d:"Shani vai precisar de espinhos de cogu cogu para seu teste de amanhã, mas ele não tem a quantidade suficiente.  Vá e consiga mais alguns.",r:[2600,250,null,null,null,null]};
Q.s[11] = {n:"Tratando a água suja",d:"Traga um pouco de saliva de Gobball para Shani Sing",r:[1700,200,null,null,null,null]};
Q.s[10] = {n:"Um amuleto peludo?",d:"Traga algumas patas de Aracne para a joalheira, que precisa delas para fazer amuletos.",r:[1700,null,[[6773,1]],null,null,null]};
Q.s[24] = {n:"Batedor de carteira",d:"Encontre um meio de obter o relatório de espionagem e leve-o para Ztiv Oztin.",r:[1200,null,[[6784,1]],null,null,null]};
Q.s[22] = {n:"O espião que vale seis kamas",d:"Encontre Ztiv Oztin e ofereça seus serviços a ele...",r:[1200,null,null,null,null,null]};
Q.s[20] = {n:"Discrição assegurada",d:"Encontre Ogivol Scarlacin. Para achar o caminho que leva a sua caverna, procure um alçapão secreto no chão do depósito de madeiras.",r:[600,null,null,null,null,null]};
Q.s[121] = {n:"Encontre e escolte o fora-da-lei",d:"Nomarow Transplante pode estar a noroeste das Planícies de Cania, perto da floresta Eltneg. Ele foi sentenciado à prisão em Astrub por machucar Gobballs domésticos e chutá-los.",r:[null,84500,null,null,null,null]};
Q.s[26] = {n:"Precisa-se de pernas rápidas!",d:"O padeiro tem quatro entregas urgentes para serem feitas. Vá e entregue os bolos nos locais corretos o mais rápido possível.",r:[1000,null,null,null,null,null]};
Q.s[29] = {n:"Procurando por um novo entregador",d:"Encontre alguém ágil e forte para ocupar o posto de novo entregador.",r:[2000,250,null,null,null,null]};
Q.s[28] = {n:"Um entregador mulherengo",d:"Verifique se o entregador Louc Drif está mesmo doente.",r:[2000,500,null,null,null,null]};
Q.s[30] = {n:"A última entrega",d:"Entregue o bolo para a vovó.",r:[5000,null,null,null,null,null]};
Q.s[103] = {n:"Casa do bebê",d:"Kry Babby esqueceu onde fica sua casa e está morrendo de medo de aventurar-se sozinha pela cidade.",r:[5750,250,null,null,null,null]};
Q.s[33] = {n:"O buquê de linho",d:"Você tem de coletar flores de linho para a mãe do Kry Bebê. Apenas alquimistas podem coletar estas flores...",r:[2000,200,null,null,null,null]};
Q.s[31] = {n:"Bandidos manetas",d:"O acampamento dos bandidos manetas fica ao norte da floresta de Astrub. O brinquedo de pelúcia provavelmente está com um dos bandidos...",r:[2000,null,null,null,null,null]};
Q.s[37] = {n:"Em guarda Homem Urso!",d:"De acordo de Abrazelon, o Homem Urso só usará seu pergaminho se várias pessoas vierem atacá-lo. Você terá que trazer esse manuscrito para que ele possa autenticá-lo.",r:[9000,2500,null,null,null,null]};
Q.s[35] = {n:"Relatório de Osamodas",d:"Abrazelon Sixgriffe falou sobre o Homem Urso, que é capaz de controlar criaturas muito poderosas. Antes que você saia em sua perseguição, informe Don Eaddat sobre sua descoberta...",r:[3000,null,null,null,null,null]};
Q.s[34] = {n:"A fera peluda",d:"Don Eaddat, o pastor, tem problemas com uma fera peluda. Ele procura por alguém que possa dar-lhe mais informações a respeito dessa criatura..",r:[750,null,null,null,null,null]};
Q.s[36] = {n:"Na pista do Urso",d:"Você tem que seguir as pegadas do uso para encontrar o seu  esconderijo...",r:[3000,null,null,null,null,null]};
Q.s[53] = {n:"Forro Fedorento",d:"Alit recomenda que você adicione forro à sua capa. Mas para isso, você tem de trazer um pouco de lã de Gobball.",r:[3500,null,[[6801,1]],null,null,null]};
Q.s[54] = {n:"Toda esta confusão por um protetor de ouvido!",d:"Traga os materiais necessários para fazer um protetor de ouvido. Como alguns deles serão difíceis de conseguir, provavelmente você terá de pedir ajuda para alguém.",r:[11000,500,[[6802,1]],null,null,null]};
Q.s[52] = {n:"Necessidade de Lã",d:"Alit, o alfaiate, precisa de mais lã branca e preta de Gobbly. Se você trouxe algumar, ele provavelmente costurará algo para você.",r:[2500,null,[[6800,1]],null,null,null]};
Q.s[49] = {n:"Precisa de reforço",d:"Vá e consiga ajuda do Fecas e Eniripsa.",r:[1200,null,null,null,null,null]};
Q.s[51] = {n:"Precisa de uma pá",d:"Entregue seu relatório a Joe para obter a recompensa.",r:[1200,null,[[6786,1]],null,null,null]};
Q.s[45] = {n:"Precisa de um trabalho",d:"Encontre Howard, o Simmasnão, e dê a ele a carta de Joe Stonefiddler.",r:[600,null,null,null,null,null]};
