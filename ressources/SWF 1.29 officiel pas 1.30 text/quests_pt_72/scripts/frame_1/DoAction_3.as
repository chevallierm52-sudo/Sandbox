Q.s[651] = {n:"Investigação sobre o Problemático",d:"Oto pediu que você volte para a caverna onde você deixou o item para encontrar a prova sobre o intruso que interviu.",r:[338000,null,null,null,null,null]};
Q.s[583] = {n:"Procurando o Castelo",d:"As\'Ruoy\'Dnim ordenou que você procure infomações sobre suas correntes, no castelo de Amakna.",r:[null,null,null,null,null,null]};
Q.s[582] = {n:"A Torre de Gisgoul",d:"Vá para a Torre de Gisgoul, coloque um Estômago de Gobball no altar, e vá para o ponto suldeste da sala (entre os dois pilares) para encontrar a pessoa que quer falar com você.",r:[null,null,null,null,null,null]};
Q.s[601] = {n:"Sequestro",d:"Fallanster está fora. Sua missão é sequestrar Allisteria. Ela está cuidando dos Gobballs perto de Astrub.",r:[null,null,null,null,null,null]};
Q.s[602] = {n:"Sequestro Frustrado",d:"Allisteria escapou e avisou os guardas durante a luta. Hora de fugir!",r:[410000,null,null,null,null,null]};
Q.s[595] = {n:"Investigando Fallanster",d:"As\'Ruoy\'Dnim te enviou para Astrub para descobrir informações sobre Fallanster. Como de costumo, ele não contou mais sobre isso. Quem poderia dar mais informações?",r:[null,null,null,null,null,null]};
Q.s[677] = {n:"Persuadindo Flinche",d:"Finche Aticus não tem mandado seus relatórios há algum tempo. Oto pede que você o encontre e descubra o que está acontecendo em Bonta.",r:[null,null,null,null,null,null]};
Q.s[780] = {n:"null",d:"",r:[500000,250000,null,null,null,null]};
Q.s[586] = {n:"Encontre força de trabalho",d:"Você deve encontrar a mão-de-obra para a construção do templo. Uma cria inocênte deve dar conta.",r:[420000,null,null,null,null,null]};
Q.s[585] = {n:"Material para o Templo",d:"As\'Ruoy\'Dnim mandou você trazer 50 unidades de Ferro, 10 unidades de Carvão, 10 Pedras de Crackler e 20 unidades de Alumínio para construir seu templo.",r:[null,null,null,null,null,null]};
Q.s[657] = {n:"Capturando Territórios",d:"Você deve capturar os territórios listados na nota que você deu para Oto.",r:[240000,null,null,null,null,null]};
Q.s[649] = {n:"Confronto",d:"Oto Mustam te desafiou! Obviamente, era só uma piada!",r:[null,null,null,null,null,null]};
Q.s[737] = {n:"Juntando o Veneno",d:"Oto Mustam precisa de 20 pods de veneno de escorpião.",r:[4600,null,null,null,null,null]};
Q.s[485] = {n:"Coletando Veneno",d:"Espiões em Bonta precisam de um especial e raro veneno que apenas o Mago Bwork possui.",r:[null,null,null,null,null,null]};
Q.s[906] = {n:"Onde o Sol não brilha",d:"Encontre outro esconderijo para os espiões entre seu atual esconderijo e a biblioteca. ",r:[128000,null,null,null,null,null]};
Q.s[535] = {n:"Pequena Falha",d:"Vestígios de uma luta recente, suas armas no chão, um Sram derrotado... Evidências parecem te dizer que você não chegou a tempo.",r:[205000,null,null,null,null,null]};
Q.s[918] = {n:"Exoram, o Sram",d:"Você trouxe Exoram para o templo Sram. Desta vez seria melhor você dizer a eles que fará o que prometeu.",r:[70000,null,null,null,null,null]};
Q.s[892] = {n:"Alguns Srams devem ter isto",d:"Exoram se meteu em encrencas novamente. Se você estiver procurando informações de Xephires, você terá que ajudá-lo novamente.",r:[null,null,null,null,null,null]};
Q.s[447] = {n:"Gratidão",d:"Desde que você descobriu que Exoram foi feito pisioneiro pelos Goblins e está em seu acampamento. Ao menos que já o tenham infiltado.",r:[null,null,null,null,null,null]};
Q.s[448] = {n:"Desaparecido!",d:"Parece que Exoram foi libertado pelos Goblins. Você deverá ir e procurá-lo.",r:[null,null,null,null,null,null]};
Q.s[493] = {n:"Na Caverna dos Porcos",d:"Oto quer expulsar o ferreiro da Caverna de Porcos para a causa Brakmariana",r:[152000,null,null,null,null,null]};
Q.s[759] = {n:"Aprenda a Humildade",d:"Oto lhe pediu para trazer 40 olhos de Larva Azul.",r:[23000,null,null,null,null,null]};
Q.s[760] = {n:"Livrando-se da Larva Dourada",d:"Você precisa encontrar uma maneira de se livrar desta Larva Dourada pegajosa que está sempre seguindo você.",r:[25000,null,null,null,null,null]};
Q.s[452] = {n:"Temporariamente... falha",d:"Xephires rejeitou sua oferta, mas nem tudo está perdido. Você poderá fazer o que quiser com a jóia. Vá ver o joalheiro Milone, ele poderá te ajudar.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"Encontro",d:"Agora que você descobriu onde está Xephires, vá até a Taverna do Pandawa Eufórico e faça uma oferta. Ele estará lá às 4 horas da tarde.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"Uma Mensagem a ser Passada",d:"Oto quer que você envie a mensagem para Vil Smisse, no esconderijo dos Ladinos - o qual fica no Cemitério de Bonta.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"Novo Perigo",d:"Vários guerreiros Brakmarianos foram derrotados, e seus corpos foram deixados na estrada para Astrub. Você deve investigar.",r:[140000,null,null,null,null,null]};
Q.s[747] = {n:"Colete o Imposto",d:"Você deverá ir e coletar a nova taxa de Oto em todas as Taverna Brakmarianas. Você tem passe livre para fazê-los pagá-lo da maneira que achar melhor.",r:[10700,null,null,null,null,null]};
Q.s[889] = {n:"Uma Carta X",d:"Descubra a identidade deste famoso X. A carta se refere ao lugar onde ele costumava estar. Se você encontrar este lugar, certamente conseguirá mais informações.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Retorno à Oto",d:"Você encontrou um pedaço de papel interessante e deve voltar e mostrá-lo a Oto.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"Busca na Torre",d:"Você deve encontrar em Bonta uma pessoa muito importante que é conhecida por ser corrupta. Oto sugere que você procure na Torre.",r:[null,null,null,null,null,null]};
Q.s[792] = {n:"Em busca do Clérigo azul",d:"Tabach, Clérigo da Ordem do Coração Valente, está procurando nas tavernas desde que seu gato desapareceu. Leve-o devolta a Jerhyn Gholein",r:[null,null,null,null,null,null]};
Q.s[793] = {n:"Em busca do Clérigo",d:"Ybaul, Clériga da Ordem do Espírito Salvador, está procurando nas tavernas desde que seus irmãos desapareceram. Leve-a devolta a Jerhyn Gholein",r:[null,null,null,null,null,null]};
