Q.s[503] = {n:"Prata, Lenha e Ferramentas",d:"Na mina do território de Porco, Nara, a ferreira, precisa de 20 unidades de Prata, 20 unidades de Madeira de Ébano e uma ferramenta que pode ser encontrada na Oficina de Norb.",r:[140000,null,null,null,null,null]};
