Q.s[365] = {n:"Chave entre os dentes",d:"Se você quiser a chave do calabouço, deve derrotar um grande Gobball agressivo.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"O Grimório Grafiose",d:"Danathor precisa que você encontre o grimório do Mago Bwork. Ele pode conter a Maldição Grafiose",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Sadidisti",d:"Touh Flowa mostrou a você onde fica a entrada para a prisão de vegetal. Ele parecia estar com a cabeça nas nuvens. É melhor que não tenha deixado nada de fora!",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"Uma chave em um Esquilo",d:"Você deverá encontrar o esquilo em Brakmar que roubou uma chave muito importante. Traga a chave de volta para Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Tragam as Caixas",d:"Você deverá trazer as caixas de ferramentas de Oto, na Torre de Brakmar.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Getas para Milone",d:"Desde a vez que você não conseguiu impedir o roubo à casa de Milone, ele pediu que o levasse à Feudala Getas",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Desossando Mak, de novo",d:"O Chafer Mak Gahan quer a sua revanche",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Lengland está em sua nova sessão",d:"William Lengland precisa aprender outra lição.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"Um esforço refrescante",d:"Você deve encontrar um estrategista e convencê-lo a juntar forças com Bonta.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Guardião Kaffra",d:"Oto quer a opinião do Guardião da Kaffra sobre o seu plano de ataque contra Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Retorno à Oto",d:"A luta acabou. Oto está esperando pelo seu relatório.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Skirmich",d:"Uma luta está começando perto a Baia de Cania, e é certo que será entre Brakmar e Bonta. Você deverá se juntar a Brakmar para que saiam vencedores.",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Prática de Martelo",d:"Oto precisa de 10 Martelos Bonsai para treinar sua tropa.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"O Cristal das Trevas",d:"Você precisará perguntar o caminho secreto da oficina de alquimistas para os Mestres desta profissão. Você também precisará de uma Poção de Vento, Harmonia e Kobalite..",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"O crime não compensa",d:"A mensagem foi enviada ao Capitão Starky. Vá ver se Sabine está calma enquanto você espera por uma resposta",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"O refém",d:"Sabine está bem guardada, então você deve entrar em contato com o Capitão Starky para conseguir pegar Kain Dharyn como refém.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"Bom comportamento",d:"Traga Sabine antes que Oto Mustam a force. Você deverá se certificar que ela não terá nenhuma oportunidade de escapar.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"Capturando Sabine",d:"Você deve capturar Sabine e colocá-la onde ela não possa fugir.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"O crime de Brakmar compensa",d:"Os Bontarianos tentaram salvar Sabine. Você não pode deixar isso acontecer. Mostre a eles quem é que manda.",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Desafio Puja",d:"Você precisa perder o desafio lançado contra Puja Mustam, o filho de Oto. Você realmente vai deixar aquele pentelho te derrotar?",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"Dentadura Nova",d:"Você deve conseguir dentes de Gobball - o quanto conseguir para fazer uma dentadura como a de humanos.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"A Grande Descascada",d:"Você precisa descascar batatas para o jantar. A cozinha é descendo a escada na milícia.",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"null",d:"",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Encontre a Tartaruga",d:"Você deve encontrar um meio de bajular Elturt e tirar o Chifre de Fogornleg de suas mãos. Os habitantes da Ilha da Lua devem ser capazes de ajudar.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"A Volta de Oto ",d:"O estrategista deixou a cidade, e você pode facilmente fazer que Oto acredite que você o matou.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Domesticando a fera e o animal também",d:"Oto Mustam quer encontrar o segredo para domesticar um Lupis Albino. Volte para a biblioteca de Bonta e encontre algumas pistas.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"Punhalada nas entranhas",d:"Oto Mustam foi convencido de que você estava planejando enganá-lo. Encontre a jóia verdadeira o mais rápido possível para que sua dignidade esteja garantida pelo resto de sua vida.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"Vitória!",d:"Xephires aceitou a condição e está pronto para trair Bonta no momento oportuno. Oto ficará satisfeito em ouvir a notícia.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"Entrevista",d:"Está tudo pronto. Você apenas deverá encontrar Xephires na Taverna do Pandawa Eufórico, dar a ele a carta e fazer apontamentos em sua resposta.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Vingança, mwahahaha.",d:"No esconderijo dos bandidos tem uma armadilha. Você precisará de um chaveiro de no mínimo nível 30 para desativá-la.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"De volta a Jerhyn Gholein",d:"A luta terminou. Jerhyn Gholein está esperando pelo seu depoimento",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Batalha",d:"Uma luta está acontecendo perto da Baia de Cania, entre Bonta e Brakmar. Você deve se juntar e ajudar Bonta a vencer.",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Proposta de Emprego",d:"Oto Mustam quer saber quem derrotou o dono da Taverna Gato Chamuscado.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"Polpa de Blop",d:"Você deverá trazer Polpa de Blop para Oto. Ele lhe dará a receita.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Encontre o Testamento",d:"Você deverá encontrar o testamento do pai de Oto na tumba - o qual você poderá reconhecer pelas flores ao redor. Você deve estar em espírito - literalmente - para entrar neste cemitério.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"Emboscada",d:"Xephires lhe contou que o navio Bontariano \"A Panta Maria\" está carregando com muitos objetos mágicos em seus armazéns. Vá encontrá-lo e tire-o desse mercado.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Cancelamento total",d:"Há uma Sram que deve dinheiro a Oto Mustam. Ela não o pagou, então Oto decidiu que ela merece uma punição. Provavelmente ela está jogando em algum lugarl irregular.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Equipando os Guerreiros",d:"Oto teme um ataque de Bonta e pediu que equipasse alguns de seus soldados com equipamentos específicos.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Coleguismo",d:"Kozuke Ichazum estava certo. Latem As conseguiu o contrato para equipar sua milícia por meio de indicações e não por suas habilidades como ferreiro.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Traga as Espadas",d:"Encontrar e testar o fornecedor de equipamentos da milícia.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"Poço Corrompido",d:"Você precisa descobrir onde o Poço das Almas Corrompidas está localizado para revelar todo o poder das Pedras Corrompidas. Divad Dleifrepok, o mestre da Ordem da Mente Insana poderá ajudá-lo.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Alquimia Cruel",d:"Você precisará pegar algumas Pedras Corrompidas. Os Mineiros são os únicos que podem fazê-las usando-as em seu estado bruto à partir das selvagens criações dos antigos alquimistas.",r:[null,null,null,null,null,null]};
Q.s[903] = {n:"Seta almas ou nenhuma",d:"Você deverá capturar a alma de sete bandidos e levá-las  ao Poço das Pedras das Almas Corrompidas. Você precisará de alguns Brakmarianos que sejam maus o suficiente para ajudá-lo.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Encontre o Espião",d:"Você deve encontrar rapidamente o espião ferido na estrada para Bonta e pegar os documentos. O espião deve estar mais próximo de Bonta do que de Brakmar. ",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Espionagem na Pousada",d:"O Bandido, dono desta espada, provavelmente estava em uma das Tavernas. Portanto, os hospedeiros devem saber de alguma coisa.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Importante Investigação",d:"Verifique as atividades dos guardas Brakmarianos e faça um relatório sobre aquleles que não fazem pausa.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Domesticando a fera e o animal também",d:"Oto Mustam quer encontrar o segredo para domesticar um Lupis Albino. Volte para a biblioteca de Bonta e encontre algumas pistas.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Até Brakmar",d:"O estrategista concorda em acompanhar você até Brakmar.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Outro Relatório",d:"Você precisa encontrar Trojen Tihpor e pedir pelo seu relatório. Ele está nas muralhas de Bonta.",r:[19000,null,null,null,null,null]};
