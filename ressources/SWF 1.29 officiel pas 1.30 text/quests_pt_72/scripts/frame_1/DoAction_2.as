Q.s[917] = {n:"Não quebre o molde",d:"Faça cópias da chave do esconderijo dos bandidos, mas não esqueça de ir em grupo. Pegue qualquer documento relacionado a investigação.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Atividades Ilegais",d:"Coisas estranhas estão acontecendo no Distrito dos Padeiros. Amayiro pediu que investigue.",r:[17000,null,null,null,null,null]};
