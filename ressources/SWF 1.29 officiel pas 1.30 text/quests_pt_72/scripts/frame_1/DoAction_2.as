Q.s[693] = {n:"Tragam o Pólvora",d:"Você deverá trazer 10 pods de pólvora para Amayiro. Você poderá comprá-la de Moob Tsinhcetoryp em Bonta.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"Invocação Desconhecida",d:"Amayiro pediu a você que encontre Zeurg (mestre da raça Osamodas) e falou para ele sobre uma invocação desconhecida usada em Brakmar",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Encontre uma Fenda",d:"Você precisa encontrar a uma fenda útil no mecanismo dos portões que dão em Brakmar.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"Encontre o Comandante do Ataque",d:"O comandante está esperando por você para iniciar o ataque. Ele se encontra próximo da entrada do Cemitério dos Torturados.",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Paranoia Justificada",d:"O comboio de armas passará pela borda da Floresta Treechnid até a Vila dos Diabinhos. Encontre-o!",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"Milone, o joalheiro",d:"De acordo com Bishom Pot, Milone Corichel - o joalheiro de Brakmar  - sabe de alguma coisa.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"O retorno de Bishom Pot",d:"Amayiro suspeita que Brakmar é a origem de todos os seus problemas. Com um miliciano espião em Brakmar, Bishom Pot deve ter aprendido algo por lá.",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Subterrâneo rigoroso",d:"Apenas oito bravos aventureiros conseguirão chegar ao fim desta passagem subterrânea!",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Subterrâneo misterioso",d:"Uma placa no alto da montanha e uma porta escondida... Nós precisaremos de alguns voluntários para chegarmos ao fim desta galeira...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"O porão da biblioteca",d:"Como em todo porão de biblioteca, este aqui é repleto de todos os tipos de livros e teias de aranha... Entretanto, neste porão há algo diferente: uma atmosfera misteriosa e ao mesmo tempo muito especial toma conta do lugar...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Subterrâneo tenebroso",d:"Uma passagem secreta na montanha dá acesso a uma passagem subterrânea. Mas você ainda terá de descobrir como...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Subterrâneo impenetrável",d:"Cuidado com o Dragonete! Para chegar a esta nova caverna, você terá de cruzar o território deles...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Subterrâneo arriscado",d:"Esta passagem pode te deixar louco!",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Visita ao Hospedeiro",d:"Você deverá trazer de volta para Amayiro o mapa e o energético para a Taverna de Feubuk.",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"Batata Quente",d:"Você deverá descascar 200 pods de batatas e trazê-las para o cozinheiro da milícia",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"Fedorat para Amayiro",d:"Amayiro pediu a você que traga a ele um chapéu Fedorat Padrão. Você poderá encontrá-lo com o Mestre Fungi",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Pinta Gone quer ler a receita",d:"Ele já comprou todos os equipamentos para fermentar o energético. \nSó a receita está perdida.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Encontre a receita de energético de Bwork",d:"Pinta Gone está procurando pela receita do famoso energético de Bwork. Ele acredita que está em uma estranha sala no território Bwork.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Colhendo Alface",d:"Você deve ir e recolher a bandana de tartaruga guardada pelos Wobots, no Calabouço de Wabit.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"Moda de Alto Risco",d:"Você deve encontrar um modo de trazer a bandana de volta a sua glória. Um alfaiate deve conseguir ajudá-lo.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Recuperação Árdua",d:"Você encontrou o espião a tempo, mas os Brakmarianos não estão felizes com você por ter conseguido os documentos. Leve-os para Amayiro o quanto antes.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"Uma Pequena Brincadeira entre Inimigos",d:"Os Brakmarianos devem levar os documentos para o superior deles. Você escreveu alguns documentos falsos para substituir eles e enviou aos seus inimigos.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Corrida contra o Tempo",d:"Um espião Bontariano está escapando de Brakmar em direção ao Leste. Você deve encontrá-lo e escoltá-lo. Rápido, seu tempo é curto!",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Reporte Indecente",d:"Alguém escreveu um reporte te criticando pesadamente. Este reporte está na Torre de Ordens de Bonta. Você deverá colocar suas mãos nele assim que possível para provar a sua inocência.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"Você precisa de suprimentos para viver",d:"Soba a pressão do conselho, Amaryio o privou de sua investigação. Os suprimentos estão à seu cargo agora.",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Indiferença elevada",d:"Encontre um cúmplice para distrair os guardas enquanto você subtrai os documentos.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"Fábrica de brinquedos.",d:"Criaturas abomináveis invadiram a fábrica do Papai Nowel. Você deve recuperar as caixas de presentes que eles roubaram, com ou sem o consenso deles, e entregá-las a Harry Kwismas.",r:[null,1000,[[10920,1]],null,null,null]};
