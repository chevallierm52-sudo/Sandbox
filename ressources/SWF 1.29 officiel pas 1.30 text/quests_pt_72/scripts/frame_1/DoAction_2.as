Q.s[956] = {n:"Ordem ou Contraordem?",d:"O plano atual não foi confirmado. Note qualquer confirmação ou mudança nos planos por Kapp Tenn e, então, informe Amayiro.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Plano de Ataque",d:"Amayiro está preocupado. Os Brakmarianos podem atacar em breve. Você deve encontrar o plano de ataque deles, assim como Amayiro pode preparar uma festa de boas-vindas...",r:[null,null,null,null,null,null]};
Q.s[358] = {n:"Treinamento",d:"Você deve fazer o espantalho animado perder toda a palha.",r:[25,null,null,null,null,null]};
Q.s[755] = {n:"Madeira para Oto",d:"Oto quer 10 Cascas de Treechnid para usar como lenha.",r:[16300,null,null,null,null,null]};
Q.s[946] = {n:"Alistar-se, disse ele.",d:"Snori Nairb colocou você na milícia Brakmariana, mas ele fez isso de maneira não oficial. Para tornar isso oficial, você vai precisar falar com Oto Mustam.",r:[null,null,null,null,null,null]};
Q.s[945] = {n:"Alistar-se, disse ele.",d:"Snori Nairb colocou você na milícia Bontariana, mas ele fez isso de maneira não oficial. Para tornar isso oficial, você vai precisar falar com Amayiro.",r:[null,null,null,null,null,null]};
Q.s[752] = {n:"Encontre o espião",d:"Um espião conseguiu escapar de Brakmar com documentos confidenciais. Um dos guardas ao norte deve tê-lo visto.",r:[14200,null,null,null,null,null]};
