Q.s[726] = {n:"Desossando Mak",d:"Derrote Mak Gahan e traga seus osso para Oto Mustam.",r:[50,null,null,null,null,null]};
Q.s[536] = {n:"Capturando o Espião",d:"Um espião Bontariano infiltrou-se na Torre e roubou os documentos. Use um Zaap e intercepte-o. Ele deve estar na estrada Leste, que leva à Bonta. Mas ainda está perto de Brakmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Tudo está bem para os Ladinos",d:"Agora que você sabe exatamente onde está o esconderijo dos Ladinos, você apenas tem de conferir a informação.",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"Contos da cripta",d:"Você deve visitar as cinco criptas no cemitério de Amakna.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"Por alguns poucos Ladinos...",d:"Você precisa infiltra-se nos Ladinos e falar com Vil Smisse.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"No território inimigo",d:"Infiltre-se na milícia Bontariana e descubra onde seus inimigos estão estocando armas.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"Meu adorário armário",d:"Distraia o guarda e pegue a chave do depósito. Então, pegue o equipamento e leve até Mulic Bere.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"Mantos de Brakmar",d:"Oto pediu a você 5 Mantos de Brakmar. Ele poderá te ensinar como fazê-las.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Histórias aquáticas",d:"Danaida precisa de água para seu ninfetas.",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"Pesquisa sobre um Chifre",d:"O tão falado guardião do chifre de Fogornleg vive na densa selva da Ilha da Lua.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"Informação sobre o Capitão",d:"Você deve encontrar um meio de comunicar ao falecido capitão Tsog a fim de conseguir as informações que ele deseja transmitir. O capitão Alrok sabe onde dizer onde está o túmulo de Tsog.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Encontre o Acusado",d:"Encontre o infiltrador Rimaraf e traga seu formulário preenchido para Amayiro",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Falsa Evidência",d:"Encontre uma maneira de enganar Amayiro mostrando uma prova falsa. Danahor será capaz de ajudá-lo",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"Sangue de Rato",d:"Amayiro pediu que você derrote 4 Rato Hioativos nos esgotos de Bonta.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Pessoas de Confiança",d:"Amayiro precisa de pessoas confiáveis para participar da apresentação que mostrará os falsos poderes do Chifre de Fogornleg.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"Uma Performance Meticulosa",d:"Amayiro pediu sua ajuda para completar sua apresentação. Ele precisa de Miteters que podem ser encontrados nos Cracklers e Gordura de Geléias Reais (Não importando o tipo de Geléia Real).",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"Mais coleção..",d:"Os Cras retiraram suas flechas do jogo. Parece que as pernas de uma Arachnee doente foram usadas para fazer veneno... Bom, negócio é negócio...",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"O chamado do lunático",d:"Eliof pediu uma pá para poder construir um abrigo anti-apocalipse.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"Os pães estão na mesa",d:"Para construir o abrigo indestrutível, o Eliof pediu duas tábuas de castanheira e alguns pães de forma... Isso deve ser o suficiente para mantê-lo vivo por pelo menos três dias após o apocalipse!",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Mestre-Cuca",d:"Você deve combinar os ingredientes necessários no caldeirão primordial: um item de cada tipo, e um alquimista, um padeiro, um fazendeiro, um açougueiro e um peixeiro.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"Procurando a Salada",d:"Você eve trazer 10 folhas de saladas para Oto e tempere-as com pólem.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Animais são Nossos Amigos Tambem",d:"Amayiro quer saber mais sobre Elturt. Oshimo, o guardião do Canil, com certeza deve saber mais sobre a tartaruga.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Todos amam Lenald",d:"Elturt já se esbarrou com os Lenalds no passado. Os Lenalds, ao sul da ilha Wabbit, podem ainda se lembrar dele.",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Coleção de Roupas de Baixo",d:"Você precisa derrotar homens da milícia Bontariana e... Pegar suas roupas de baixo. Oto precisa de 5 delas.",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Madeira Hurry",d:"Consiga Hurry Wood. Sacrificando a natureza, você terá a oportunidade de criar um laço com ela.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Ritual",d:"Encontre a pessoa que ajudará você a criar seu cajado de iniciante.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Mostre suas habilidades",d:"Você está melhorando suas habilidades, mas precisa melhorar ainda mais para convencer a todos.",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"De Volta à Lua",d:"O tão falado guardião do Chifre de Fogornleg está nos confins da selva da Ilha da Lua. De acordo com os rumores, você deve estar carregando um Chapéuemboscada e um pouco de Greedoburg parece ele aparecer.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"Kanigers e Safira",d:"Você deverá recolher certos ingredientes para fazer esta jóia, incluindo 5 Lingotes de Ouro, 1 Língua de Gobball Real e 1 Madre Pérola. Você poderá conseguir a Madre Pérola polindo 10 Madres Pérolas brutas que podem ser encontradas perto da Ilha de Otomai.",r:[80000,null,null,null,null,null]};
