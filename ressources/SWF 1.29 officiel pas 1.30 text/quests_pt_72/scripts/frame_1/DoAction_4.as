Q.s[402] = {n:"Identidade falsa",d:"Como você pode ver, Uba Tesse te transformou em Wabbit. Você só tem de ir ao castelo e arruinar este casamento.",r:[50000,25000,null,null,null,null]};
Q.s[401] = {n:"Após a receita, consiga os ingredientes!",d:"Agora que Uba tem a fórmula, ele só precisa dos ingredientes.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"Uma fórmula!",d:"Você precisa encontrar alquimistas dispersos em Amakna.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit Powa.",d:"Encontre um meio de se transformar em Wabbit.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"Alimentação forçada",d:"Você tem o ovo de tofu obeso, mas um ovo não fará mal ao plíncipe... Você precisa encontrar algo para alimentar o jovem pássaro que está para nascer.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Implorando por um ovo",d:"Vil Smisse pediu para você trazer um ovo de tofu obeso. Tudo que você precisa fazer é encontrar o ninho...",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"Infiltrador de aluguel",d:"Vil Smisse não será capaz de usar o blop gateau envenenado. Ele então recorrerá ao ataque direto. Para isso, ele quer contratar infiltradores e precisa de dinheiro.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"Um cálice envenenado",d:"Vil Smisse escolheu seguir o caminho dos Ladinos: a dissimulação.",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Infiltrador substituto",d:"Os infiltrador não conseguiram matar o príncipe... Vil Smisse pediu para você ir e contratar um Lenald para fazer o trabalho.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"Morte ao Tofu!",d:"Você sabe onde plíncipe de Wa queria caçar. Bem... Em algum lugar ao sul de Bonta. Resta encontrar o plíncipe.",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"Dê toda a atenção ao trabalho",d:"Pergunte ao contramestre o que você precisa fazer.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Servindo ou fazendo um favor?",d:"O secretário San Lavalss pediu para você ajudá-lo a preparar o casamento.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"1º passo",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"Um Traje para Emeralda",d:"Emeralda esta procurando desesperadamente um conjunto de Koalak",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Responda o Questionário",d:"O Guardião da Ponte da Morte deseja que você responda corretamente suas perguntas.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Preparar para sua Viagem",d:"O Capitão Haddock\'n\'roll pediu para você trazer vários itens, assim você pode subir a bordo do barco dele.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"Caixinha Amaldiçoada de Flib",d:"O Capitão Haddock\'n\'roll foi para a praia na Ilha dos Náufragos. Você deve encontrar o Baú Amaldiçoado de Flib e pegar alguns itens para consertar o barco.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"Você não conseguirá passar!",d:"O Cavaleiro Preto e Rosa não deixará você passar. Pode ser uma boa hora para usar a força e conseguir o que deseja.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"Uma Poção para um Professor",d:"O professor Kalkulus precisa de uma Poção Bulbish para começar de novo a trabalhar.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Máquinas de Criação",d:"Polka Merer precisa de maquinas de criação para suas criaturas.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"Uma História de Farinha",d:"Stella Stukup, a padeira, quer adicionar outras farinhas mais baratas que as de Xavier, o padeiro. Ele teve a idéia, cabe a você encontrar as farinhas!",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"Procurando o Filho Escondido",d:"O Doutor Nauh perdeu seu filho em um laboratório cheio de terríveis criaturas selvagens. Você deve encontrá-lo e garantir que permaneça vivo!",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"O Doutor está se sentindo Impertinente",d:"O pobre Doutor Impertinente perdeu sua esposa. Ajude-o a encontrá-la na Selva Negra e tente convencê-la a voltar para o seu marido, assim ele pode voltar às pesquisas.",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"Equipamento Melhorado",d:"Speet Fyer está procurando um capacete de piloto melhorado e uma capa. Somente um alfaiate experiente poderá te ajudar.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Dois Dragossauros para Flip Flap",d:"Flip Flap gostaria que trouxesse para ela um certificado de Dragossauro Gengibre e um de Dragossauro Amêndoa.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Caça na Selva Negra",d:"Crocodyl Dandy gostaria que você caçasse algumas criaturas da Selva Negra.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Caça na Planície",d:"Crocodyl Dandy gostaria que você caçasse várias criaturas das Planícies.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Caça na Praia",d:"Crocodyl Dandy gostaria que você matasse algumas criaturas na Praia de Coral.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Caça na Árvore de Keeholo",d:"Crocodyl Dandy gostaria que você caçasse algumas criaturas da Árvore de Keeholo.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Caça à Turfeira Sem Fundo",d:"Crocodyl Dandy gostaria que você caçasse algumas criaturas da Turfeira Sem Fundo.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"Um Exemplo para os Piratas",d:"Kito pediu para você mostrar aos Piratas o que você pode fazer. Isto servirá de exemplo para os outros que quiserem jogar bolas de canhão.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"O Cavaleiro Preto e Rosa",d:"Senhorita Porca Imunda gostaria que você confrontasse o terrível Cavaleiro Preto e Rosa.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"A Troca Amaldiçoada",d:"Farle Ingalsse é provavelmente a única pessoa em Amakna capaz de consertar sua espada amaldiçoada...",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"Rápido! Rápido!",d:"A casa de Milone está a ponto de desabar. Corra e impeça isto!",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Isca Ruim?",d:"A jornada foi tranquila. Os bandidos não atacaram. Amayiro espera pelo seu reporte.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"EcaTrapaça",d:"Amayiro precisa da jóia modificada para seu plano funcionar.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Escolta",d:"Sua missão, se aceitá-la, será escoltar o grupo de mercadores de Astrub.",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"Mãos, Bliks!",d:"O comboio foi atacado por ladinos Ecaflips que se parecem em muito com aqueles do acampamento que você descobriu. Amayiro está esperando sua mensagem para convencer o conselho de um ataque.",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Rigal, o Ladino",d:"No Templo Sram, Rigal Hookhand é bem informado e deve saber de algo. Informação tem um preço. Você apenas precisa descobrir qual é o seu preço.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"Suspeitas Confirmadas",d:"Você precisa encontrar depósito de veneno de Brakmar e roubar a lista de clientes da Oficina de Alquimia. Bishom Pot talvez possa ajudá-lo.",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"Alquimia para Iniciantes",d:"Você precisa adquirir o registro de clientes da oficina de alquimia em Brakmar e trazê-lo para Rigal Hookhand.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Despedida",d:"Você precisará da ajuda de um Sram ou algum bom espião para conseguir adentrar as reservas de veneno de Brakmar.",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Encontro na Torre",d:"Um encontro entre um Brakmariano e um Bontariano subornado está preste a acontecer na Torre de Bonta. Você deve capturar ambos assim que possível.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"Droga!",d:"Você deverá encontrar alguns milicianos para o posto da Torre de Bonta.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"Bwork, que fedor!",d:"Mesmo Epuop Tik não sabe mais, ou ele não quer dizer mais. Qualquer que seja o caso, o Mago Bwork deve ser um pouco menos relutante em vender uma de suas.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Duvidando de Danathor",d:"Danathor parece ter uma nova oferta para propor a você. Mas, provavelmente, trata-se de uma proposta ilegal.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"A boneca encantada",d:"Você deve encontrar quatro Sadidas que são experientes o suficiente para invocar infláveis para um ritual envolvendo as águas encantadas dos lagos de Koalak.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Selvagem",d:"Se você remover a maldição.........., ele definitivamente vai contar tudo que sabe, como agradecimento. Ele também sugere que você vá para a biblioteca para descobrir mais pistas.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"Em busca do Clérigo desamparado",d:"Aigurraf, Clérigo da Ordem do Olho Observador, está procurando nas tavernas desde que seu rato desapareceu. Leve-o devolta a Jerhyn Gholein",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Fuga da Prisão",d:"Você precisa libertar um guerreiro que foi feito prisioneiro de Bonta.",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"Seu inimigo",d:"Encontre e derrote seu oponente.",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Vencendo a batalha.",d:"Continue a atacar o seu alvo para vencer a batalha. Passe seu turno usando o botão {ui,banner,btn_skipTurn::terminar turno} quando você quiser recuperar seu {ui,banner,lbl_pa,2::PA} e seu {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Terminando a batalha.",d:"Derrote o monstro. Tenha cuidado, agora os turnos possuem uma duração limitada. A {ui,banner,tx_artwork,3::barra de tempo restante} mostra o quanto de tempo você tem antes do turno terminar.",r:[null,null,null,null,null,null]};
Q.s[1042] = {n:"Posicionando-se no mapa.",d:"Bem-vindo ao tutorial. Clique em volta do seu personagem para posicioná-lo.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Passando seu turno.",d:"Quando tiver terminado suas ações, clique no botão {ui,banner,btn_skipTurn::Finalizar Turno} para acelerar a batalha.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Equipando um item.",d:"Abra seu menu de {ui,banner,btn_character,1::características}.Arraste o {ui,storage,grid::Anel de Novato} que você acabou de receber para o {ui,characterSheetUi,slot_2,2::espaço de anel} na tela de seu personagem.",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"Equipando seus itens.",d:"Abra a interface de {ui,banner,btn_character,1::características} e equipe seu personagem com os itens que ganhou.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Posicionando-se no mapa durante uma batalha.",d:"Seu personagem utiliza {ui,banner,lbl_pm,2::Pontos de Movimento} (PM) para se mover. Mover 1 célula custa 1 PM. Movimente seu personagem selecionando e clicando em uma célula.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Utilizando um feitiço.",d:"Escolha {ui,banner,gd_spellitemotes,0::um feitiço} e seu alvo. Alguns feitiços são conjurados em inimigos, e alguns em aliados ou em seu personagem. O alcance de um feitiço é mostrado pelas células azuis. Feitiços precisam de {ui,banner,lbl_pa,2::pontos de ação} (PA) para serem conjurados. Você recebe esses pontos de volta no início de cada turno.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Escolhendo sua posição inicial.",d:"Clique em uma das células azuis para escolher sua posição inicial e clique no {ui,banner,btn_skipTurn::Botão de Início} para começar a batalha.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Trocando de mapa.",d:"Para trocar de mapas, mova o cursor ao {cell,335::canto da tela}e clique quando ele se tornar uma seta.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Terminando uma missão.",d:"Para finalizar sua missão, você precisa ir até a próxima sala, derrotar a criatura que encontrar, e falar com {npc,1222::Maurice, o Guia}.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Terminando seu treinamento.",d:"Vá e conte a {npc,1222::Maurice, o Guia} sobre sua vitória.",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Começando uma missão.",d:"Fale com {npc,1222::Maurice, o Guia} para começar uma missão (NPC com missões para serem feitas irão aparecer com um ponto de exclamação acima de suas cabeças).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Falando com um NPC.",d:"Clique em {npc,1222::Ganymede Yalpot} para falar com ele.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Entrando em batalha.",d:"Clique no {cell,313::Espantalho de Incarnam} para começar a batalha.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"Uma vida complicada",d:"Você deveria ter seguido o conselho de Salt Dawa e tomado cuidado. Agora parece que sua vida corre risco. Bem, a vida não é tão simples quanto imaginamos.",r:[null,null,null,null,null,null]};
