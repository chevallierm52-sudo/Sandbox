Q.s[67] = {n:"Como forjar uma espada\' para iniciantes",d:"Você precisa de um ferreiro para criar uma espada.",r:[null,null,null,null,null,null]};
Q.s[68] = {n:"A utilidade de um bom cabo",d:"Encontre um cabo para que sua espada seja forjada.",r:[1200,null,null,null,null,null]};
Q.s[69] = {n:"A importância dos toques finais",d:"Traga a espada recém forjada para seu mestre.",r:[900,null,[[6780,1]],null,null,null]};
Q.s[63] = {n:"...dúvida!",d:"Traga a espada de volta ao líder de sua guilda. Ele irá gravar a marca de sua classe nela.",r:[1200,null,null,null,null,null]};
Q.s[61] = {n:"Um metal dúbio",d:"Traga a sacola cheia de kamas duvidosos para alguém que seja capaz de fazer algo de interessante com ela.",r:[600,null,null,null,null,null]};
Q.s[62] = {n:"Refinamento dúbio",d:"Transforme seu metal duvidoso.",r:[1200,null,null,null,null,null]};
Q.s[72] = {n:"Ladrão de Coração",d:"As pequenas rochas estão nas proximidades das minas, a nordeste da vila. Encontre o baú de Looc lá.",r:[4000,null,null,null,null,null]};
Q.s[150] = {n:"A recompensa",d:"Volte para a casa de Drif e obtenha sua recompensa.",r:[5000,null,[[1519,1]],null,null,null]};
Q.s[71] = {n:"Procurando pedras pequenas",d:"Para encontrar a casa de Looc, observe cuidadosamente duas pequenas pedras. Para fazer isso, você terá que checar todos os locais suspeitos.",r:[1500,250,null,null,null,null]};
Q.s[70] = {n:"Troca de metaria para um encontro",d:"Looc precisa resolver o problema de seu baú e, ao mesmo tempo, tem que se preparar para o seu primeiro encontro. Vá e consiga duas rosas, uma para cada garota.",r:[1500,500,null,null,null,null]};
Q.s[73] = {n:"Corra Forest!D26",d:"Você acha que gosta de crianças? Isso é porque você ainda não conheceu essa aqui!",r:[600,50,null,null,null,null]};
Q.s[75] = {n:"Ah-Arco-Cra-Dabble",d:"Haa..  Seu primeiro arco, que legal!",r:[1200,null,[[6783,1]],null,null,null]};
Q.s[78] = {n:"Cratastrofe",d:"Agora você aprenderá como utilizar seu arco.",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Encontre o fora-da-lei",d:"Frakacia Leukocytin foi vista perto da vila dos Bandidos Manetas.  Procurada por roubar hemoglobina, ela foi sentenciada à prisão em Astrub.",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Encontre o fora-da-lei",d:"Nervoes Brakdown foi visto perto da floresta de Treechnids. Procurado por roubar à joalheria. Sentenciado à prisão em Astrub.",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Encontre o fora-da-lei",d:"Sentenciado à prisão em Astrub, Brumen Tinctorias foi visto perto do Pântano de Sidimote. Ele é procurado por ser insubordinado à ordem cósmica",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Encontre o fora-da-lei",d:"Akornadikt está perambulando pela cidade em busca de bolotas suculentas que ele possa morder com gosto.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Encontre o fora-da-lei",d:"Ogivol foi visto perto de Brakmar. Procurado por roubar um monte de coisas, como documentos secretos. Ele foi sentenciado à prisão em Astrub.",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Escolta da Mistura",d:"Tek Abir, o estalajeiro da vila, tem perdido uma parte de seu lucro por conta dos ladrões. Para evitá-los, Tek Abir costuma colocar água em seus energéticos. Vá pela estrada, encontre o entregador a sudoeste e escolte-o.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"Opressão levou a um fim?",d:"Coloque um fim no roubo de energéticos.",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Kit de visão",d:"Para ajudar Montrakwartz a prever o futuro, você terá que conseguir vários recursos.",r:[600,null,null,null,null,null]};
Q.s[92] = {n:"Futuro é sério!",d:"Montrakwartz está contando mais sobre seu futuro próximo.",r:[1200,null,null,null,null,null]};
Q.s[91] = {n:"Futuro é aventura!",d:"Montrakwartz precisa de uma pele de larva azul para completar sua máquina.",r:[1200,null,null,null,null,null]};
Q.s[94] = {n:"Entrega",d:"Traga para Clint Pot o remédio que você conseguiu. Não tenho certeza se o medicamento é para Tofus ou para os próprios Enutrofs. Não esqueça de fazer um relatório para seu mestre de guilda.",r:[1800,null,[[6785,1]],null,null,null]};
Q.s[93] = {n:"Subourbe...",d:"Ajude o líder de sua guilda a encontrar uma cura para o Tofu.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"Primeira sala",d:"Descubra como usar seus três Dofus",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Segunda sala",d:"Encontre a chave",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"Tac Tic!",d:"...",r:[2500,20,null,null,null,null]};
Q.s[145] = {n:"...de tesoura",d:"Raih ficará alegre em ver a qualidade da nova tesoura que você conseguiu.",r:[1750,null,null,null,null,null]};
Q.s[133] = {n:"Um belo par...",d:"Raih Resserd está em busca de uma tesoura forjada. Ela aconselha que você vá ao mercado encontrar o ferreiro,assim você poderá comprar uma.",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Cabelo... mais e mais cabelo",d:"Raih Resserd está tentando reunir todos os tipos de cabelo existentes entre os habitantes de Astrub.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"O começo de uma busca",d:"Os Enutrofs, que foram em busca de sniffallrats, provavelmente se perderam nas passagens subterrâneas. O local é infestado com miliratos dos esgotos....",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"Um pássaro na mão é melhor do que dois ratos na moita",d:"Livre-se deste Rato de esgoto... Ele parece doente, então não será tão difícil...",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"O começo de riqueza",d:"Colete dez pernas de aracne para Ant Emicheun. Ou para você mesmo... Como preferir. De qualquer forma você terá lucro.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Penas doentes",d:"Com 20 penas, alguém deve ser capaz de fazer um espanador. Bem, dado o tamanho das penas...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Recompensa merecida",d:"Fale novamente com a vovó e mostre a cabeça dos camundongos",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"O porão infestado",d:"Vá até o celeiro da vovó e dê um jeito na ameaça.",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Derrote o Guarda da Milícia",d:"Derrote o miliciano Tarche na sala próxima a esta aqui.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Entregue Pães",d:"Você deverá trazer 20 pães integrais",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"Dentes de Gobball",d:"Você deve retirar Dentes de Gobball - o quanto você  precisar para fazer uma dentadura humana, e traga-a para Ned, ao sudoeste da cidade.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"Sapato de Bro",d:"Você precisará derrotar Torche e trazer a prova que isso aconteceu.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Encontre o Corvo",d:"Você deverá encontrar o corvo que roubou o colar da filha do Prefeito, derrote-o e pegue o colar. O corvo costuma estar perto da torre.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Caça ao Javali",d:"Você precisa encontrar o javali agressivo no sul de Bonta e derrotá-lo.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"Conserte a Katana",d:"Você deverá pedir ao ferreiro Kosuke que conserte a lâmina de Amayiro em troca de um cheque.",r:[4600,null,null,null,null,null]};
Q.s[690] = {n:"Expulse os Devedores",d:"O hospedeiro da Taverna Kikim deve muito dinheiro à Amayiro. Você deve convencê-lo - não importa como - a pagá-lo.",r:[null,null,null,null,null,null]};
Q.s[692] = {n:"Comunicando-se com um Espião",d:"Você deve encontrar Bishom Pot em Brakmar e extrair a informação que Amayiro pediu a ele.",r:[5200,null,null,null,null,null]};
Q.s[694] = {n:"Feche as Lacunas",d:"Shere Hacanon, na entrada de Bonta disse que precisa de 4 blocos de rochas de Crackler das Planícies para fechar o buraco nas paredes.",r:[6400,null,null,null,null,null]};
Q.s[696] = {n:"Coleção de Capacetes",d:"Você deverá trazer 15 Capacetes de Chafer de Elite para Amayiro",r:[7600,null,null,null,null,null]};
Q.s[698] = {n:"Polpa para Tabi",d:"Traga uma Polpa de flor de Blop para Amayiro. Para fazê-la, você precisará usar 4 tipos diferentes de Flores Blops e de um Triturador Monstro.",r:[8800,null,null,null,null,null]};
Q.s[700] = {n:"Agilidade para Amayiro",d:"Amayiro pediu a você que traga 20 anéis de agilidade",r:[10000,null,null,null,null,null]};
Q.s[702] = {n:"Tragam as Capas",d:"Amayiro pediu que trouxesse 10 capas Bontarianas para o Capitão Koda, na porta ao lado. Elas são feitas com uma tinta azul mágica, penas de corvo e lã de Gobbly.",r:[11400,null,null,null,null,null]};
Q.s[705] = {n:"21 horas",d:"Danathor lhe pediu para encontá-lo às 9h da noite com todos os ingredientes pedidos na lista.",r:[13500,null,null,null,null,null]};
Q.s[708] = {n:"Carne para a Cozinha",d:"O cozinheiro da milícia de Bonta, Kooc Fehc, precisa de 10 pernas de Tofu.",r:[13500,null,null,null,null,null]};
Q.s[707] = {n:"Infiltrador Recusado",d:"Volte para Amayiro",r:[null,null,null,null,null,null]};
Q.s[712] = {n:"Traga Veneno",d:"Na prisão de Bonta, o Capitão Essacarf precisa de 30 pods de veneno de escorpião.",r:[15600,null,null,null,null,null]};
Q.s[714] = {n:"Lute... por uma piada?",d:"Você deverá encontrar Dike Tarak pela vizinhança, desafiá-lo e derrotá-lo.",r:[null,null,null,null,null,null]};
Q.s[713] = {n:"Lute... por uma piada",d:"Você deverá encontrar Dike Tarak na região norte do bairro, desafiá-lo e perder.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Encontre um Defeito",d:"Amayiro pediu que explore o Cemitério dos Atormentados, ao leste de Brakmar, e veja se há alguma falha em sua tática de defesa. Você certamente precisará de um material mais específico.",r:[19000,null,null,null,null,null]};
Q.s[717] = {n:"Profissão à sua escolha",d:"Você deve trazer para Amayiro também 20 Tábuas de Freixo ou 10 raízes de Treechnid.",r:[21000,null,null,null,null,null]};
Q.s[721] = {n:"Ataque-surpresa em Brakmar",d:"Amayiro pediu a você que derrote guerreiros Brakmarianos e pegue seus crachás.",r:[28000,null,null,null,null,null]};
Q.s[723] = {n:"Uma lição a Ensinar",d:"William Lengland tem perturbado os habitantes de Bonta. Você deverá acalmá-lo usando um pouco da força.",r:[34000,null,null,null,null,null]};
Q.s[724] = {n:"Na Prisão de Brakmar",d:"Amayiro pediu que você solte Atall Tramston da prisão de Brakmar e traga também para ele um miliciano de Bonta.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"Dinheiro Pandrista!",d:"Encontre um mercador ambulante para conseguir pagar a taxa Pandrista. Não hesite em insistir bastante.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"Deixe o sol brilhar em Pandala!",d:"Assim que chegar em Pandala, você deve colocar seus papéis em ordem com a administração. Além disso, você terá que pagar a taxa Pandrista.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"Minha primeira festa Xamã!",d:"Pedido de ajuda para o Xamã! Rápido!",r:[4700,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[170] = {n:"Uma mensagem de sabedoria",d:"Um mensageiro está querendo dizer alguma coisa! Fale com ele!",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Treinamento para manusear escudos para iniciantes",d:"Como forma de agradecimento pela entrega, o ferreiro de escudo oferece um presente a você: um pequeno escudo de treinamento. Fale com o mestre do Dojo.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"Acentuação diferente",d:"Lenald, o Sábio, pediu para que você vá a vila de Aerdala... Ou talvez Terrdala;\r\n            de fato, é impossível compreender esta pronúncia! Quando chegar lá, fale com o mestre Pandawushu.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"Pelo ferreiro de escudo",d:"Em Terrdala, não há ninguém disponível para trazer as matérias-primas até a oficina do ferreiro de escudo. Felizmente você está aqui para fazer este trabalho, já que esse tipo de a forja é essencial para os guerreiros de Pandawa.",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Quem está com medo do Miau",d:"Poochan está a procura de seu futuro marido, mas as únicas pistas que ela possui são as informações de que ele deixou Pandala e teme Miau. O meio mais fácil seria transformá-la em um Miau para que ela pudesse saltar em todo mundo, não acha?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Acordo informal",d:"Aqui, a tradição diz que é o pai quem deve decidir com quem o seu filho ou filha deverá se casar. Você precisa persuadí-lo para que ele deixe seu filho seguir em frente. Faça o melhor possível para convencê-lo.",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Conquista de Dento",d:"Para libertar Lanman de seus deveres, você precisa quebrar a promessa de casamento que ele fez à garota de Dojo Dento.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"Recompensa ?",d:"Poochan o aguarda",r:[7000,null,null,null,null,null]};
Q.s[174] = {n:"Um pequeno passeio...",d:"Este passeio pelo no tempo e espaço de Amakna ajudará a salvar o mundo.",r:[null,null,null,null,null,null]};
Q.s[173] = {n:"Um Kouartz e ficará bem",d:"Como último recurso, Amine propôs a Henual.. alguns Kouartz",r:[null,null,null,null,null,null]};
Q.s[172] = {n:"SMS de Henual",d:"Uma carta de (o sentinela, guarda, supervisor) Henual deve ser transmitida para Amine no templo Xelor",r:[null,null,null,null,null,null]};
Q.s[178] = {n:"Refrigerantes...",d:"Um vendedor ambulante deve ser capaz de fornecer uma destas bebidas fermentadas que são famosas em Pandala. Você só precisa encontrar um!",r:[null,null,null,null,null,null]};
Q.s[185] = {n:"Passagem de nível: Rokwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Rokwa.",r:[30000,null,null,null,null,null]};
Q.s[184] = {n:"Passagem de nível: Gokwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Gonkwa.",r:[30000,null,null,null,null,null]};
Q.s[183] = {n:"Passagem de nível: Yonkwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Yonkwa.",r:[20000,null,null,null,null,null]};
Q.s[180] = {n:"Passagem de nível: Ikwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Ikwa.",r:[5000,null,null,null,null,null]};
Q.s[187] = {n:"Treinamento: o básico",d:"Antes de começar o treinamento, você precisa conseguir um certificado xamanístico e um traje Pandawushuka.",r:[null,null,[[7313,1]],null,null,null]};
Q.s[182] = {n:"Passagem de nível: Sankwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Sankwa.",r:[15000,null,null,null,null,null]};
Q.s[181] = {n:"Passagem de nível: Nikwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Nikwa.",r:[10000,null,null,null,null,null]};
Q.s[191] = {n:"Yondanwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Yondanwa.",r:[60000,null,null,null,null,null]};
Q.s[190] = {n:"Sandanwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Sandanwa.",r:[50000,null,null,null,null,null]};
Q.s[186] = {n:"Shodanwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Shodanwa.",r:[30000,null,null,null,null,null]};
Q.s[189] = {n:"Nidanwa",d:"Você tem de aparecer no sábado para passar na avaliação de nível do grande Nidanwa.",r:[40000,null,null,null,null,null]};
Q.s[175] = {n:"Lenda Lenald",d:"Finalmente! Você está quase lá! Mais surpresas ainda lhe aguardam.. O Lendal da Ilha de Wabbit revelará alguma coisa que foi mantida em segredo até hoje...",r:[7500,null,null,null,null,null]};
Q.s[188] = {n:"No templo de seu Deus",d:"Após os conselhos de Lenald, o Sábio, você planeja sua próxima expedição. Você terá de ir ao templo de seu Deus em Amakna.",r:[7500,null,null,null,null,null]};
Q.s[176] = {n:"Dark Vlad, um verdadeiro homem!",d:"Purifique sua alma e lave suas orelhas: Lenald, o Sábio, vai dizer a você a verdade sobre os Dofus de Pandala.",r:[40000,null,null,null,null,null]};
Q.s[193] = {n:"Receptáculo auxiliar de Dofus",d:"O Grandapan aceitou com prazer o presente dos Enutrofs. Como um grande admirador dos caçadores de Dofus, ele lhe dá uma calorosa recepção. Para satisfazer sua curiosidade de explorador, ele pegou o Receptáculo auxiliar de Dofus.",r:[1500,null,null,null,null,null]};
Q.s[192] = {n:"Beijo de Astrub",d:"O Xamã está muito ocupado e não tem tempo de atendê-lo. Os Pandikazes e a doença dos Enutrofs são apenas dois dos milhares de problemas que precisam ser resolvidos... Se você quer ajudá-lo, fale com Pyrite, o Enutrof em quarentena.",r:[1500,null,null,null,null,null]};
Q.s[194] = {n:"Água para beber com moderação",d:"O caminho da água consiste em resistir a qualquer forma de absorção ou submersão em água (parcial ou total), a ficar sem beber ou se lavar (exceto em extrema necessidade). Encontre o mestre do caminho da água: ele sabe mais do que parece.",r:[10000,null,null,null,null,null]};
Q.s[207] = {n:"O Grandapan",d:"Traga o Dofus falso para Grandapan.",r:[2200,null,null,null,null,null]};
Q.s[195] = {n:"Escudos de Terrdala",d:"Estes escudos são uma das especilidade de Pandala. Bonta está prestando atenção neste equipamento que poderia ser útil contra as forças de Brakmar.",r:[50000,null,null,null,null,null]};
Q.s[196] = {n:"No encalço do espião",d:"Depois do fogo nos porões de Brakmar, Ebru Of El quer saber o que seus inimigos estão planejando.",r:[50000,null,null,null,null,null]};
Q.s[197] = {n:"Pedras de Alma",d:"Uma pedra da alma contém um grupo de criaturas, disponível para ser invocado novamente... Mas primeiro, é melhor saber como fazer tudo isso!",r:[50000,null,null,null,null,null]};
Q.s[782] = {n:"Agricultura de Alto-risco",d:"Kaffra tem planos para aumentar a produção de cereal em Bonta. Ele precisa de 20 sementes de escorpião para fazer esta mesma produção em Brakmar.",r:[50000,null,null,null,null,null]};
Q.s[200] = {n:"Brakmarianos sem esperança",d:"Sabendo que os agentes Brakmarianos se tornaram inúteis, Kaffra pediu que você vá a Astrub e convença o mercador Bontariano Raymon Santho a abastecer Brakmar.",r:[null,null,null,null,null,null]};
Q.s[783] = {n:"Envenenando a Comida",d:"Shush te confiou 20 sementes de escorpião modificadas ao deixar a oficina de Alquimia em Bonta. Você deve realizar a sua missão na noite que Merlinmagus Ambrosius tiver adormecido.",r:[50000,null,null,null,null,null]};
Q.s[198] = {n:"Preocupações Brakmarianas",d:"Shush quer saber o que acontece em Bonta. Ele o enviou para que entre em contato com o espião Finche Aticus.",r:[null,null,null,null,null,null]};
Q.s[787] = {n:"Eu disse: Levante-se e Ande",d:"A Maldiçao de Erazar t ensinou como forçar uma alma ressuscitar contra a sua vontade. Para fazer isso, você deverá criar uma poção específica e seguir um ritual muito específico.",r:[50000,null,null,null,null,null]};
Q.s[199] = {n:"Levante-se e Ande",d:"Divad não pode ressuscitar Terra Tibya para questioná-la. Confiaram à você a missão de improvisar um feitiço de ressurreição que funcione.",r:[null,null,null,null,null,null]};
Q.s[201] = {n:"Encontre o fora-da-lei",d:"Rok foi visto ao norte de Pandala.\nEle foi sentenciado à prisão em Astrub.",r:[null,6250,null,null,null,null]};
Q.s[202] = {n:"Encontre o fora-da-lei",d:"Musha foi visto ao sul de Pandala.\nEle foi sentenciado à prisão em Astrub.",r:[null,64000,null,null,null,null]};
Q.s[203] = {n:"Encontre o fora-da-lei",d:"Marzwel foi visto perto de Aerdala.\nEle foi sentenciado à prisão em Astrub.",r:[null,25000,null,null,null,null]};
