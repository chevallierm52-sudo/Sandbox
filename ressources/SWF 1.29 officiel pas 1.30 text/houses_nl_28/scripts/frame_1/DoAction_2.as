H.h[874] = {n:"Luxe Fokker\'s Huis",d:"Dit luxueuse huis heeft meer weg van een paleis dan een huis. Het is perfect om je vrienden jaloers mee te maken als je een feest organiseerd in een van de talloze kamers van dit echte monument."};
