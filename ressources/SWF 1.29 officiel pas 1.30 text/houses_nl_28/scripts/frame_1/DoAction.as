H.h[66] = {n:"Kleine rieten hut",d:"Dit kleine huis met rieten dak staat vlakbij de rivier en is perfect voor sportvissers. Het heeft één verdieping, maar om daar te komen, staat er gratis een ladder tot je beschikking, want de trap is niet standaard inbegrepen bij dit type huis."};
H.h[67] = {n:"Kleine rieten hut",d:"Dit kleine huis met rieten dak staat vlakbij de rivier en is perfect voor sportvissers. Het heeft één verdieping, maar de trap is niet inbegrepen. Daarom wordt er gratis een ladder aangeboden."};
H.h[68] = {n:"Klein Huis",d:"Dit kleine huis heeft één onbewoonbare verdieping, omdat de zolder niet meer toegankelijk is sinds de komst van een rattenfamilie."};
H.h[69] = {n:"Huis met twee etages",d:"Dit huis met twee verdiepingen zal goed in de smaak vallen bij degenen die graag grote feesten organiseren. Maar niet bij degenen die niet van traplopen houden."};
H.h[70] = {n:"Huis met één etage",d:"Dit huis ligt dicht bij de rivier en het dorp en dat compenseert het feit dat het maar één verdieping heeft. Maar let op, als het water van de rivier hoog staat, staat de begane grond vaak onder water."};
H.h[74] = {n:"Huis bij de Winkel",d:"Dit kleine huis heeft één verdieping, maar het grote voordeel is dat het naast de winkel van Séline en Charlotte staat, een paar stappen van het dorpscentrum dus. Stelletjes die op hun privacy gesteld zijn, gaan voor dit huis met z\'n twee aparte bedden op de bovenverdieping."};
H.h[75] = {n:"Hut bij de Fontein",d:"Deze hut bestaat niet meer dan uit één verdieping en ligt bij de Fontein van het Plein en is het ideale huis voor degenen die met hun bezittingen willen pronken."};
H.h[76] = {n:"Gebouw bij de Bron",d:"Dit gebouw heeft zelfs twee verdiepingen en was van een rijke notaris die onder vreemde omstandigheden verdween en z\'n huis achterliet."};
H.h[77] = {n:"Gebouw bij de Herberg",d:"Dit gebouw bestaat uit één enkele verdieping en wordt bijzonder gewaardeerd door bierdrinkers die vaak niet meer de weg naar huis weten als ze te lang in de Herberg geweest zijn. Jawel, dit gebouw is maar een paar stappen verwijderd van de Herberg."};
H.h[78] = {n:"Groot Herenhuis",d:"Dit herenhuis heeft drie kamers en één verdieping en is duidelijk bedoeld voor de rijkste personen in Amakna. Het is groot genoeg om met meerdere families in te wonen, als ze er tenminste van houden om in een gemeenschap te leven, zoals mieren bijvoorbeeld."};
H.h[79] = {n:"Gebouw van de Bakkerij",d:"Dit gebouw heeft één verdieping en was een bakkerij waar een beroemde bakster haar broden verkocht. Heden ten dage is dit gebouw in ere hersteld en doet niet onder voor andere huizen."};
H.h[80] = {n:"Hut van de Bakker",d:"Deze hut bestaat uit één verdieping en was van een bekende bakkersvrouw waarvan de naam nog steeds onbekend is. Deze hut is verre van het ideale huis voor elke zichzelf respecterende bakker."};
H.h[81] = {n:"Huis bij de Xelor Tempel",d:"Dit kleine huis met één kamer heeft het voordeel dat het naast de Xelor Tempel en de Bakkerij staat."};
H.h[82] = {n:"Hut bij de Xelor Tempel",d:"Deze hut met één verdieping ligt precies tegenover de Xelor Tempel en daardoor een voor de hand liggende keus voor Xelors."};
H.h[83] = {n:"Hut van de Kleermaker",d:"Deze hut met één verdieping was van de populairste Kleermaker van Amakna: Elvis Trosse. Zijn specialisatie was blauwe broeken."};
H.h[84] = {n:"Huisje van de Bowisse",d:"Bowisse, de schoenmaker, heeft dit prachtige kleine huis zelf gebouwd en is een van de meest geliefde gebouwen van Amakna. Na de Bakkerij van Xavier is dit een van de meest bezochte plekken."};
H.h[85] = {n:"Hut Veelvraten",d:"Deze charmante hut heeft één verdieping en wordt vaak omringd door hongerige Veelvraten, maar omdat hij bij een Kanojedo Tempel ligt, is hij waardevol voor beginnende avonturiers."};
H.h[87] = {n:"Hut bij de Cra-Winkel",d:"Deze hut bevat één verdieping en was van Edridge Valling voordat ze verhuisde naar de zolder van haar winkel. Op de muren zie je nog waar de pijlen doorheen gegaan zijn, maar dat geeft het juist een zekere charme."};
H.h[88] = {n:"Huis bij de Cra-Winkel",d:"Dit kleine huis heeft maar één kamer en is erg duur, omdat het naast de winkel van Edridge Valling staat. Want vele hovelingen hebben dit huis gekocht om met haar in contact te komen."};
H.h[89] = {n:"Chalet bij de Gieterij",d:"Dit houten huis met één verdieping staat naast de gieterij en is perfect geschikt voor gesmolten metaal amateurs. Maar let op, dit gebied wordt geplaagd door Veelvraten."};
H.h[90] = {n:"Zeemanshut",d:"Deze hut heeft maar één kamer en ligt beschermd tegen harde wind en pakt de eerste zonnestralen. En het gevoel van de zonnestralen op je huid \'s morgens vroeg is onbetaalbaar."};
H.h[91] = {n:"Visserskrot",d:"Dit gebouwtje met één kamer is een historisch gebouw. Hier schreef de beroemde Bijl Smid minstreel Jony Lenon z\'n meeste liederen."};
H.h[92] = {n:"Visserswoning",d:"Deze woning heeft maar één enkele kamer en heeft niets bijzonders, behalve dat hier de beroemde Bowisse het grootste deel van z\'n jeugdjaren heeft doorgebracht."};
H.h[93] = {n:"Kleine Visserswoning",d:"De gevel van dit kleine vissershuisje met slechts één kamer zou opgeknapt moeten worden, maar heeft juist hierdoor ook wel charme."};
H.h[94] = {n:"Vissershut",d:"Deze vissershut heeft één verdieping en werd lange tijd geleden gebruikt als magazijn voor krabben."};
H.h[95] = {n:"Huis met Rompvormig Dak",d:"Dit oude gebouw heeft één verdieping. Kapitein Iglout woonde hier voordat hij een plaatselijk onderkomen kreeg in de gevangenis."};
H.h[96] = {n:"Kleine hut bij de Haven",d:"Deze kleine hut heeft één kamer vlakbij de zee. Je kunt de hele dag het ontspannende geluid van de branding horen."};
H.h[97] = {n:"Groot Huis met Rompvormig Dak aan de Haven",d:"Dit grote huis met rompvormig dak heeft drie kamers en is eigenlijk een Herenhuis. Het ligt dicht bij het water en je kunt bovendien je vuilnis direct in zee storten zodat je niet hoeft te onthouden wanneer het vuilnis opgehaald wordt. Eigenlijk puur gemak dus."};
H.h[109] = {n:"Spoorbaanhuis",d:"Dit kleine huis heeft slechts één kamer. Het was van een oude stationschef, Hamm Trakk, die het huis verliet toen de spoorweg opgeheven werd."};
H.h[110] = {n:"Klein Huis bij de Spoorbaan",d:"Dit kleine huis heeft één kamer en was van een oude mijnwerker die in z\'n kleine ertswagentje naar z\'n werk ging."};
H.h[111] = {n:"Gebouw van de Veelvraten",d:"Dit huis met rieten dak heeft een opvallend mooie ingerichte verdieping. De vorige bewoner had de gewoonte om de Veelvraten vet te mesten die langs kwamen. Na enkele maanden waren de Veelvraten dik genoeg en hij sneed hun hals af met oude roestige dolken. Een of ander vreemd ritueel."};
H.h[112] = {n:"Klein Huis van de Veelvraten",d:"Dit huisje met één kamer is zeer gewild. De aanwezigheid van veel wilde Veelvraten is interessant voor degenen die daarvan houden."};
H.h[113] = {n:"Paddestoelhuis",d:"Dit kleine huis heeft slechts één kamer en was van een oude Alchemist die veel paddestoelen gebruikte voor zijn drankjes, waarvan het effect vaak onderschat werd. Let op, de paddestoelen die er groeien zijn gevaarlijk en zelfs agressief."};
H.h[114] = {n:"Klein Huis bij het Plein",d:"Dit kleine zeemanshuisje staat in een toeristische omgeving, wat een probleem kan zijn voor degenen die rust willen. Maar voor degenen die niet veel vrienden hebben, is het een prima keus."};
H.h[115] = {n:"Klein Huis bij het Plein",d:"Dit kleine zeemanshuisje met één bescheiden kamer is prima geschikt voor niet materialistische personen die niet om comfort geven en die snel tevreden zijn."};
H.h[116] = {n:"Klein Huis bij het Plein",d:"Dit zeemanshuis heeft maar één kamer en men zegt dat dit huis de vruchtbaarheid verhoogd van paren die hier wonen. Het kleine eenpersoonsbed zou hier van alles mee te maken hebben."};
H.h[117] = {n:"Klein Huis bij het Plein",d:"Dit kleine vissershuisje staat op een mooie plek vlak naast de fontein bij de haven. Helaas heeft het maar één kamer, maar de prijs is daardoor betaalbaar voor dit type huis."};
H.h[118] = {n:"Huis met Rompvormig Dak bij het Plein",d:"Dit huis met rompvormig dak heeft één verdieping en ligt bij het plein bij de haven tegenover de fontein. Daardoor is het interessant voor handelaars, want ze hoeven niet ver om hun spullen op de veiling bij de haven te verkopen."};
H.h[119] = {n:"Huis met Rompvormig Dak bij de Haven",d:"Dit huis met rompvormig dak heeft één verdieping met uitzicht op de vuurtoren. Echt iets voor de romantici van Amakna, die ervan houden om speciale schaduwfiguren te maken met het vuurtorenlicht... en god weet dat er velen zijn."};
H.h[120] = {n:"Klein Huis bij de Haven",d:"Dit kleine huis heeft één kamer en is zo charmant dat slechts weinige toeristen het niet wilden kopn. Het zeezicht vanaf het toilet geeft waarschijnlijk voor velen de doorslag."};
H.h[122] = {n:"Huis van de Kanojedo Bewaker",d:"Eén kamer van dit huis is onbewoonbaar (de zolder is niet toegankelijk door een invasie van termieten die de dakpannen wegvreten). Het huis ligt naast de Kanojedo Tempel en wordt over het algemeen toegewezen aan bewakers van de tempel."};
H.h[123] = {n:"Klein Huis bij de Brug",d:"Dit huis met maar één grote kamer staat op een eiland, ver weg van alle beschaving, in de buurt van een brug en een gieterij. De kosten voor belasting zijn niet inbegrepen."};
H.h[124] = {n:"Huis Tuinman",d:"Dit kleine huis met één kamr heeft een leuke kleine moestuin en staat vlak bij de kust. Dit is het droomhuis voor elke boer met wat geld, die van een rustige vakantie wil genieten."};
H.h[125] = {n:"Hut bij Meer",d:"Deze hut met rieten dak heeft één verdieping en een klein buitenhuis, dat apart te koop is. Hierdoor heb je een onderkomen voor je bewaker of je bedienden."};
H.h[126] = {n:"Klein Huis bij het Meer",d:"Dit huisje met één kamer staat vlakbij het meer en de kust. Heerlijk voor sportvissers die in zoet en zout water willen vissen."};
H.h[127] = {n:"Klein Huis bij het Meer",d:"Dit kleine bescheiden huis heeft één kamer, maar die is behoorlijkgroot en fraai ingericht. Doordat het dichtbij het meer ligt, is het bijzonder geschikt voor zoetwatervissers en zwemmers."};
H.h[128] = {n:"Hut met pad",d:"Dit huisje heeft twee grote kamers, en blijkbaar groot genoeg om belangrijke spellen te organizeren van Tragic The Gardening. De eigenaar is verantwoordelijk voor het onderhoud van de bomen op het pad."};
H.h[129] = {n:"Huis van de MAX-LoL",d:"Dit kleine huis heeft geen enkele verdieping, maar heeft het voordeel dat het op een klein eiland ligt. Daardoor biedt het meer bescherming tegen aanvallen van de Gladjanussen bijvoorbeeld."};
H.h[130] = {n:"Huis met Oud Rompvormig dak",d:"Dit huis heeft één verdieping en een rompvormig dak. Altijd handig als het water van de rivier stijgt of ingeval van erge overstromingen."};
H.h[131] = {n:"Klein Zeemanshuisje",d:"Dit kleine huis heeft één verdieping. Het staat vlak bij de haven en bij een modderige zee-arm. Aantrekkelijk voor krabtelers die van buren houden."};
H.h[132] = {n:"Klein Vissershuis",d:"Dit kleine vissershuis heeft maar één kamer en toen de zee zich in de loop der tijd terugtrok, werd dit huis een stuk minder interessant. Maar minder rijken nemen het zoals het is en kunnen in de tussentijd sparen."};
H.h[133] = {n:"Huis met Rompvormig dak",d:"Dit zeer originele huis heeft een rompvormig dak. Hierdoor hoeft de eigenaar niet elke keer na een storm de dakpannen te vervangen. Dit huis heeft twee fraai ingerichte verdiepingen."};
H.h[134] = {n:"Klein Huis bij de Rivier",d:"Dit kleine huis heeft een bescheiden kamer en is vooral ontworpen voor een eenpersoonshuishouden of voor kleine medebewoners."};
H.h[135] = {n:"Klein Vissershuis",d:"Dit kleine vissershuisje met één kamer is zeer geliefd bij sportvissers, die van daaruit direct kunnen vissen."};
H.h[136] = {n:"Huis van de Veelvraten",d:"Dit huis heeft een giga grote verdieping. Groot genoeg om feesten en partijen te geven. Als je dit huis koopt, krijg je er een hooiwagen bij. Maar let op, de vorige eigenaar hield hier Veelvraten en heeft deze rond het huis losgelaten."};
H.h[137] = {n:"Hut bij de Wilde Kersenboom",d:"Dit huis heeft één verdieping en een prachtige eikenhouten trap. Het rieten dak en de Vogelkers die vlak voor de deur staat, geven dit huis een rustiek karakter. Voor degenen die zich willen onderscheiden van anderen, is dit huis bijzonder geschikt."};
H.h[138] = {n:"Klein Huis bij de Wilde Kersenboom",d:"Dit huis heeft slechts één kamer, maar die is wel groot. In de zomer kunnen de eigenaars van deze woning van de schaduw van de prachtige Vogelkers genieten."};
H.h[139] = {n:"Huis Houtzagerij",d:"Dit kleine huis heeft zelfs een verdieping. Het ligt vlak naast de houtzagerij en is het ideale huis voor de eigenaar hiervan."};
H.h[140] = {n:"Hut van de Houtzagerij",d:"Dit kleine huis heeft een klassieke verdieping, maar staat naast de houtzagerij. Perfect voor houthakkers die niet te veel tijd willen verliezen om naar hun werk te gaan."};
H.h[141] = {n:"Huis van Aria Knofob",d:"NPC Huis"};
H.h[142] = {n:"Berghuis",d:"Dit huis heeft slechts één kamer, maar die is behoorlijk groot en fraai ingericht."};
H.h[143] = {n:"Groot Huis met Rompvormig Dak aan de Haven",d:"Dit grote huis met rompvormig dak heeft twee woonlagen en is feitelijk een Herenhuis. Het ligt vlakbij de haven en is de ideale woning voor degenen die van reizen houden. Daarentegen heeft het een naargeestige zolder vol met spinnenwebben."};
H.h[144] = {n:"Sufokia huis",d:"Statige woning, zeezicht en zeer gerieflijk van binnen. Dit huis zal u weten verleiden door de rijke meubilering."};
H.h[145] = {n:"Groot Sufokia huis",d:"Een afgelegen huis, waarvan de architectuur u versteld doet staan door zijn helderheid en zijn comfort. De verdieping heeft prachtige een binnentuin, heel bijzonder om je te ontspannen bij het kalmerende geluid van de oceaan."};
