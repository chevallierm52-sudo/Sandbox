G = new Object();
G[1] = {sn:"Feca",ln:"Lo scudo Feca",ep:1,d:"I Feca sono dei Protettori leali. Sono molto apprezzati dai gruppi di avventurieri per i loro poteri protettivi, ma anche perché sanno servirsi del bastone come nessun altro. Tutti i Feca sono fieri di essere difensori fuori dal comune ai quali i Saggi hanno conferito gli oggetti più preziosi, dandogli piena fiducia.",sd:"Una classe di protettori. Le loro armature riducono i danni inflitti agli alleati.",s:[3,17,6,4,2,1,9,18,20,14,19,5,16,8,12,11,10,7,15,13,1901],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[2] = {sn:"Osamodas",ln:"La frusta di Osamodas",ep:1,d:"Gli Osamodas sono Invocatori nati! Hanno il potere di invocare creature e sono dei notevoli ammaestratori. Circola la diceria che taglino i loro vestiti nella pelle dei loro nemici, ma prova a chiederglielo....e scoprirai come finiranno i tuoi giorni, se da stivale o sotto forma di berretto foderato di pelliccia.",sd:"Una classe di invocatori. Usano le invocazioni per combattere a distanza.",s:[23,34,21,26,22,35,28,37,30,27,24,33,25,38,36,32,29,39,40,31,1902],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[3] = {sn:"Anutrof",ln:"Le dita di Anutrof",ep:1,d:"Gli Anutrof sono degli incalliti Cacciatori di tesori! Si interessano a qualsiasi prodotto, oggetto o creatura da cui potranno ricavare dei kama. La prima cosa che fa un Anutrof quando incontra un altro avventuriero è squadrarlo. È vero: agli occhi di un Anutrof, un avventuriero non è altro che una creatura carica di cibo, e ricca di oggetti... da rivendere!",sd:"Una classe di cacciatori di tesori. Sanno annullare gli incantesimi e rallentare gli spostamenti dei nemici.",s:[51,41,43,49,42,47,48,45,53,46,52,44,50,54,55,56,58,59,57,60,1903],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[150,3],[230,4],[330,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[60,3],[100,4],[150,5]]};
G[4] = {sn:"Etram",ln:"L\'ombra di Etram",ep:1,d:"Gli Etram sono Assassini che amano le borse, preferibilmente rigonfie. Sollevare i drappi di una tunica, tastare il fondo di una tasca, dare prova di destrezza, impadronirsi di gioielli a lungo bramati, piazzare trappole, tendere agguati mortali: questa è la vita di un discepolo di Etram!",sd:"Una classe di Ladrurbi. Grazie all\'invisibilità e alle loro trappole, attaccano i nemici alle spalle.",s:[65,72,61,66,68,63,74,64,79,78,71,62,69,77,73,67,70,75,76,80,1904],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[100,2],[200,3],[300,4],[400,5]],b15:[[0,2],[50,3],[150,4],[250,5]]};
G[5] = {sn:"Xelor",ln:"La clessidra di Xelor",ep:1,d:"Gli Xelor sono Maghi che dominano il tempo e tutti i meccanismi che segnano l\'ora - carillon, orologi e pendoli - sono in loro balia e obbediscono ad ogni loro cenno. Gli Xelor possono quindi giocare con il tempo per rallentare un nemico o teletrasportarsi dove meglio credono.",sd:"Una classe di maghi. Usano i loro incantesimi per rallentare i nemici e impedirgli di giocare.",s:[81,83,82,84,100,92,88,93,85,96,98,86,89,90,87,94,99,95,91,97,1905],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[6] = {sn:"Ecaflip",ln:"La moneta di Ecaflip",ep:1,d:"Gli Ecaflip sono Guerrieri giocatori che si cacciano in posti in cui si può guadagnare molto, ma perdere molto... Un Ecaflip a suo agio gioca senza sosta, per tutto e per niente. Ma attenzione, prende il gioco molto sul serio e arriva perfino a puntare la sua vita su un lancio di dadi pur di vincere un combattimento...",sd:"Una classe di guerrieri giocatori. I loro attacchi si basano principalmente sulla casualità.",s:[102,103,105,109,113,111,104,119,101,107,116,106,117,108,115,118,110,112,114,120,1906],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[7] = {sn:"Aniripsa",ln:"Le mani di Aniripsa",ep:1,d:"Gli Aniripsa sono Guaritori che utilizzano una semplice Parola, soprattutto per curare i loro alleati, ma talvolta anche per ferire i loro nemici. Tra loro, alcuni sono perfino diventati cacciatori di parole, misuratori del verbo, oppure esploratori delle lingue dimenticate.",sd:"Una classe di guaritori. Usano i loro incantesimi per curare gli alleati.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[8] = {sn:"Yop",ln:"Il cuore di Yop",ep:1,d:"Gli Yop sono dei Guerrieri risoluti e senza paura! Una cosa è sicura: sanno fare parlare le armi. D\'altronde, versare sangue almeno una volta al giorno è per loro segno di buona salute. Il temperamento impetuoso fa degli Yop i paladini dell\'estremo, capaci di tutto nel bene e nel male!",sd:"Una classe di guerrieri. I loro incantesimi offensivi gli permettono di causare enormi danni.",s:[142,143,141,144,145,146,147,148,154,150,151,155,152,153,149,156,157,158,160,159,1908],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[9] = {sn:"Ocra",ln:"La portata di Ocra",ep:1,d:"Gli Ocra sono Arcieri tanto orgogliosi quanto precisi! Sono preziosi alleati contro gli adepti della rissa libera. Sono abili nel far danni! Restano a distanza e scoccano le loro frecce piumate nelle più piccole aperture lasciate incustodite.",sd:"Una classe di arcieri. Sono specializzati negli attacchi a distanza.",s:[169,164,161,163,165,172,167,168,162,170,171,166,173,174,176,175,178,177,179,180,1909],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[50,2],[150,3],[250,4],[350,5]]};
G[10] = {sn:"Sadida",ln:"Il sandalo di Sadida",ep:1,d:"I Sadida sono degli Invocatori che fabbricano unguenti e veleni pericolosissimi! Addomesticare i Rovi per farne armi terrificanti, confezionare bambole da guerra e per curare, ecco ciò che soddisfa ogni discepolo di Sadida degno di questo nome!",sd:"Una classe di stregoni. Usano bambole per combattere e ammaliare i nemici.",s:[193,183,200,198,195,182,192,197,189,181,199,191,186,196,190,194,185,184,188,187,1910],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[250,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[11] = {sn:"Sàcrido",ln:"Il sangue di Sàcrido",ep:1,d:"I Sàcridi sono Berserker le cui forze si moltiplicano quando vengono colpiti! Dato che non temono né colpi né ferite, si trovano spesso in prima linea e per tale caratteristica sono assai apprezzati dai gruppi di avventurieri! Il Sàcrido è veramente il compagno ideale per le tue lunghe serate di guerra...",sd:"Una classe di protettori. Hanno molta resistenza e incassano i colpi al posto degli alleati.",s:[431,432,434,444,449,436,437,439,433,443,440,442,441,445,438,446,447,448,435,450,1911],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,3],[100,4],[150,5]],b11:[[0,1,2]],b12:[[0,3]],b13:[[0,3],[100,4],[150,5]],b14:[[0,3],[100,4],[150,5]],b15:[[0,3],[100,4],[150,5]]};
G[12] = {sn:"Pandawa",ln:"La pinta di Pandawa",ep:18,d:"I Pandawa sono Guerrieri portatori che sanno fare cose incredibili con il proprio corpo... ma anche con il corpo degli altri! Infatti, il Pandawa può sollevare i suoi alleati per proteggerli. Quanto ai suoi nemici, li può spedire gambe all\'aria per ferirli!",sd:"Una classe di guerrieri portatori. La birra li rende più forti, possono sollevare gli alleati.",s:[686,692,687,689,690,691,688,693,694,695,696,697,698,699,700,701,702,703,704,705,1912],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[200,3]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[50,2],[200,3]],b14:[[0,1],[50,2],[200,3]],b15:[[0,1],[50,2],[200,3]]};
