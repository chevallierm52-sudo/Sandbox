I.u[9808] = {n:"Regalo: Fab\'huritu de Rushu",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9809] = {n:"Transformación fantasma de Fab\'huritu de Rushu",t:27,d:"Has sido transformado en fantasma para poder penetrar en el santuario de las mascotas.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
