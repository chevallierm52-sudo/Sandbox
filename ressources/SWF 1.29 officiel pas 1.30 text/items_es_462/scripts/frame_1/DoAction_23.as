I.u[10220] = {n:"Instrucciones de uso de la pala Heliktrochok",t:24,d:"Este libro, traducido en 198 lenguas y dialectos, explica cuándo y cómo utilizar la pala Heliktrochok. Las páginas en bwork y en dialecto yopuka son las que más ilustraciones contienen.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10221] = {n:"Agua transmutada",t:15,d:"Esta agua, transmutada con destreza por Nibe Lula, es una cuidada mezcla de agua sagrada y de agua de luna. El resultado es, simplemente... sorprendente.",ep:0,g:769,l:1,wd:false,fm:true,w:1,p:1};
I.u[10223] = {n:"Pala Heliktrochok",t:8,d:"Esta pala está principalemnte destinada a su uso médico, aunque algunos salvajes, como el anutrof Resat, la utilizan para lo que ellos llaman «autodefensa».",ep:0,g:10,l:40,wd:false,fm:true,w:25,an:16,tw:true,e:[15,4,1,1,50,50,false,false],p:1000};
I.u[10224] = {n:"Pensamiento perdido",t:24,d:"Esta crisálida encierra un pensamiento perdido de Solar. Pronto dará nacimiento a un magnífico maripensón dorado, salvo si antes alguien la vende o la destruye.",ep:0,g:765,l:1,wd:false,fm:true,w:0,p:1};
I.u[10227] = {n:"Gema espiritual de Mob Lasponja",t:85,d:"Esta gema, que te ha sido entregada como recompensa por tus victorias, tiene cautiva el alma de un monstruo. Conservar en un lugar seco y no expuesto a la luz. Agitar antes de usar.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
