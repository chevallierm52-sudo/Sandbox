I.u[10168] = {n:"Chispotas",t:11,d:"Ponx sacaba brillo a sus botas cada mañana antes de partir a lomos de su dragopavo en busca de viudas y huérfanos a los que salvar, sobre todo viudas... Todo un seductor este Ponx.",ep:0,g:141,l:42,wd:true,fm:true,w:10,s:138,p:4850};
I.u[10169] = {n:"Chisprotección",t:82,d:"Ponx, montado en su dragopavo, lucía este escudo con orgullo mientras velaba por la seguridad de las calles de Bonta.",ep:0,g:41,l:1,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10170] = {n:"Chispocasco",t:16,d:"Este casco te servirá para protegerte de una forma muy eficaz de las caídas de dragopavos o para pasar por un idiota sin serlo.",ep:0,g:246,l:40,wd:true,fm:true,w:10,s:138,p:4400};
I.u[10171] = {n:"Mitón de Chisp",t:9,d:"Este mitón es perfecto para repartir unas buenas tortas.",ep:0,g:173,l:44,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10172] = {n:"Collechuga",t:1,d:"Este amuleto puede alimentar a una babosa vorpal durante dos días o, incluso más, si lo acompañas de puré de tu cabeza.",ep:0,g:148,l:42,wd:true,fm:true,w:10,s:137,p:4900};
I.u[10173] = {n:"Babotas",t:11,d:"La suela de estas botas está cubierta de una baba pegajosa y su interior está lleno de una baba escurridiza. O era al contrario...",ep:0,g:142,l:39,wd:true,fm:true,w:10,s:137,p:4105};
I.u[10174] = {n:"Babcapa",t:17,d:"De los poros de esta capa sale una especie de baba pegajosa. Toma un poco de impulso, acuéstate sobre tu espalda y comienza a deslizarte.",ep:0,g:169,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10175] = {n:"Baborrito",t:16,d:"Con este gorrito pegajoso y baboso tendrás siempre el pelo engominado. Además, tiene dos antenas con ojos que puedes conectarte al cerebro a través de unas terminaciones nerviosas que deben introducirce en las orejas.",ep:0,g:247,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10176] = {n:"Libro viejo y usado",t:24,d:"Las tapas de este libro están tan usadas y rugosas como la piel de un anutrof centenario. Si le echas un vistazo rápido a su contenido, te darás cuenta que está destinado a los yopukas. Cierto, hay muy poco texto y muchas imágenes, ya que como todo el mundo sabe el yopuka medio es inculto, algo parecido a las almas recién llegadas a Astrub.",ep:0,g:763,l:1,wd:false,fm:true,w:0,p:1};
I.u[10177] = {n:"Corteza oscura de abráknido oscuro",t:24,d:"Más oscura que la corteza de abráknido oscuro común, esta corteza le debe su brillo a las sustancias que expulsa el organismo del abráknido oscuro y cuyo consumo es poco recomendable. Son estas mismas sustancias las que le confieren sus misteriosos poderes.",ep:0,g:231,l:1,wd:false,fm:true,w:0,p:1};
I.u[10178] = {n:"Corteza oscura esculpida",t:24,d:"Para no estropearla, has guardado la corteza oscura esculpida en esta caja",ep:0,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[10179] = {n:"Calzoncillo ceñidos de cuero de San Grampiro",t:24,d:"Para protegerse de los golpes críticos en los lugares más... críticos, San Grampiro utiliza su calzoncillo de cuero cada vez que sale de caza. Este calzoncillo le protege igualmente aquellos lugares críticos del sol.",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10180] = {n:"Amuleto Solar",t:1,d:"Se supone que este amuleto sirve de llave para entrar en una misteriosa ciudad olvidada.",ep:0,g:149,l:42,wd:true,fm:true,w:10,s:136,p:4800};
I.u[10181] = {n:"Anillo Solar",t:9,d:"Este anillo se encontró en una misteriosa ciudad de la que nadie sospechaba realmente que existía hasta que alguien empezó a sospecharlo.",ep:0,g:174,l:41,wd:true,fm:true,w:10,s:136,p:4600};
I.u[10182] = {n:"Escudo solar",t:82,d:"Este escudo absorbe los rayos de sol y los reenvía directamente a la cara de tus adversarios. A falta de deslumbrarlos con tu inteligencia, podrás cegarlos temporalmente gracias a este escudo.",ep:0,g:42,l:1,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10183] = {n:"Máscara Solar",t:16,d:"Esta máscara captará los rayos de sol y los concentrará en tu cara para que puedas estar bronceado todo el año, incluso si vives en el norte de Amakna.",ep:0,g:248,l:42,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10184] = {n:"Máscara de Noke",t:16,d:"A Noke le gustaba mucho ponerse esta máscara y esconderse en el bosque para asustar a los paseantes. Murio de un susto, hace mucho tiempo, al ver su reflejo en un charco de agua.",ep:0,g:249,l:42,wd:true,fm:true,w:10,s:135,p:4700};
I.u[10185] = {n:"Capa de Noke",t:17,d:"Noke siempre soñó con ser un lobo malvado. Para su desgracia, incluso con esta capa, sólo consiguió parecerse a un malo de poca monta.",ep:0,g:170,l:41,wd:true,fm:true,w:10,s:135,p:4600};
I.u[10186] = {n:"Collar de Noke",t:1,d:"Este amuleto hecho con dientes de jabalí asustará a los jabalíes, y mejor todavía ¡A tu suegra también!",ep:0,g:150,l:41,wd:true,fm:true,w:10,s:135,p:4525};
I.u[10187] = {n:"Dagas de Noke",t:5,d:"Estas dagas sirvieron en su día a despedazar a un jabalí belicoso que quería ser un ciervo.",ep:0,g:76,l:41,wd:true,fm:true,w:10,an:13,tw:true,e:[12,3,1,1,30,45,false,false],c:"CS>50&CW>50&CV>80",s:135,p:4000};
I.u[10188] = {n:"Casco del extraterrestre",t:16,d:"Este casco te transformará en un autentico wobot del protocolo ya que tiene integrado un dispositivo único con el que podrás traducir en un abrir y cerrar de ojos las conversaciones de repollos. Además, está muy bien insonorizado.",ep:0,g:250,l:43,wd:true,fm:true,w:10,s:133,p:5075};
I.u[10189] = {n:"Oxanillo",t:9,d:"Este anillo pertenecia a un fabricante de zancos llamado Raimundo (pero sus amigos lo llamaban \"Mundo\"): lo ganó tras haber hecho un largo viaje trotando. Desde entonces, sus amigos lo llamaron \"El Trota-mundo\".",ep:0,g:175,l:37,wd:true,fm:true,w:10,s:133,p:3875};
I.u[10190] = {n:"Botines del extraterestre",t:11,d:"Si te decides a cultivar coles, estos botines te serán de gran utilidad ya que están diseñados para no aplastarlos. Se desaconseja su uso para bailar la salsa: no evita los pisotones en los pies de la pareja de baile.",ep:0,g:143,l:38,wd:true,fm:true,w:10,s:133,p:3925};
I.u[10191] = {n:"Cinturoxo",t:10,d:"Con este cinturón podrás retener los gases que da la sopa de col.",ep:0,g:158,l:37,wd:true,fm:true,w:10,s:133,p:373};
I.u[10192] = {n:"Regalo: Capa de Tor Nyquete",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10193] = {n:"Regalo: Máscara de Tor Nyquete",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10194] = {n:"Regalo: Cinturón de Tor Nyquete",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10195] = {n:"Regalo: Botas de Tor Nyquete",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10196] = {n:"Emplazamiento de la losa Zurcarák",t:24,d:"Según Grizmoh, la losa de Zurcarák se encuentra en la Isla del Minotauroro.\nSólo un zurcarák equipado con una Suerte de Zurcarák y que posea una pieza del tesoro del Badulo podrá activar el mecanismo que da acceso a la cueva al colocarse en la losa.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10197] = {n:"Emplazamiento de la losa Xelor",t:24,d:"Chronokwartz ha puesto la losa de Xelor en alguna parte en Fuegodala.\nSólo un xelor equipado con un Pasado de Xelor y que posea polvo temporal podrá activar el mecanismo que da acceso a la cueva al colocarse en la losa.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10198] = {n:"Emplazamiento de la losa Anutrof",t:24,d:"Según Palana, su marido Orava ha enterrado la losa de Anutrof al noreste de su casa, al pie de la estatua de un dragopavo.\nSólo un anutrof equipado con un Recuerdo de Anutrof y que tenga un diente de oro de crujidor podrá activar el mecanismo que da acceso a la cueva al colocarse en la losa.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10199] = {n:"Anotaciones sobre la visión de Nosilla Budois",t:24,d:"Según Nosilla Budois, el espíritu de la luz parece haber atravesado el bosque de Amakna y las montañas para instalarse en lo que parece ser el Cementerio de los Torturados. Nosilla también habló de una ciudad con una casa de alquimistas, de un aniripsa que estaba de pie junto a una sadida que fabricaba una muñeca. Has anotado su descripción.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10200] = {n:"Espíritu de la luz",t:32,d:"Este espíritu de la luz no es muy luminoso. Se podría decir que el hecho de que lo hayan sacado de su martillo ha ensombrecido su resplandor. Cuanto antes lo lleves hasta Onidal, mejor.",ep:0,g:26,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10201] = {n:"Jabalí de las llanuras",t:32,d:"Al parecer este jabalí de las llanuras tiene demasiada grasa o está muy enfermo, o quizás las dos cosas. En cualquier caso, no quiere seguirte, así que vas a tener que arrastrarlo todo el tiempo. Esto te va a llevar tu tiempo. Además, me da que en la que te descuides, se te escapa.",ep:0,g:27,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10202] = {n:"Fragmento de tiempo robado",t:24,d:"Los demonios de las horas han robado este fragmento de tiempo del Reloj Divino de Xelor. Más te vale no alardear de que tienes este objeto si quieres evitar ira del dios.",ep:0,g:801,l:1,wd:false,fm:true,w:0,p:1};
I.u[10203] = {n:"Órdenes de misión rotas",t:24,d:"Este pedazo de papel roto indica el final de una lista de órdenes de misión: «... y llévalo a los calabozos de Brakmar para el interrogatorio».\nParece que el papel no es muy viejo, así que no lleva mucho tiempo perdido.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10204] = {n:"Lista para llegar a la guarida de Dardondakal",t:24,d:"Para acceder a la guarida de Dardondakal que está escondida en el bosque de Cania, necesitas: 10 cáscaras de dragohuevo blanco, 5 huevos de dragohuevo blanco y 1 piel de dragohuevo guerrero.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10205] = {n:"Pensaceptor",t:24,d:"¿Quién habría creído que un pensaceptor que un día perteneció a un dragón pudiera tener un aspecto tan común? Seguro que tú no.",ep:0,g:46,l:1,wd:false,fm:true,w:0,p:1};
I.u[10206] = {n:"Agua sagrada",t:24,d:"Esta agua proviene de una fuente subterránea de Akwadala. Los vapores de alcohol que desprende confirman su naturaleza sagrada.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[10207] = {n:"Llavero",t:24,d:"Con las llaves de este llavero podrás entrar gratuitamente en cada una de las mazmorras del Mundo de los 12. ¡Pero sólo una vez a la semana!",ep:0,g:774,l:1,wd:false,fm:true,w:0,p:0};
I.u[10208] = {n:"Elixir pandawa",t:12,d:"Un buen trago y te teletransportarás al templo de tu clase. Efectos secundarios conocidos: cólicos, aparición de suegra, pérdida del pelo, aliento de chacal, cordones sueltos y muchos semáforos en rojo.",ep:0,g:153,l:1,wd:true,fm:true,w:1,c:"PG=12",u:true,p:0};
