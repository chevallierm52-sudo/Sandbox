I.u[9760] = {n:"Fragmento de fuerza mayor",t:115,d:"Este fragmento de alma proviene de uno de los Fab\'huritus de Rushu. Si dispones de un arma Fab\'hurista, podrás utilizar este fragmento para hacerla más potente. Si tu arma sobrepasa su potencia máxima, se retirarán todas las runas y se colocarán en tu inventario.\n(Haz doble clic para colocar este fragmento de alma en un arma Fab\'hurista equipada).",ep:0,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9785] = {n:"Fab\'huritu de Rushu",t:18,d:"Este demonio menor te acompañará durante todos tus viajes: del Zaap de Astrub al cementerio, y hasta del cementerio al Zaap de Astrub.Esta criatura le tiene un odio visceral hacia los Stropajos (es una turbia historia que oculta algún sucio trapicheo) así que cuando mates Stropajos él se alimentará con sus restos.",ep:0,g:52,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9786] = {n:"Fantasma de Fab\'huritu de Rushu",t:90,d:"Este fantasma aún está en el mundo de los vivos, y sólo cuenta contigo para que encuentres el modo de resucitarlo, o... también puedes abandonarlo como hacen los cobardes.",ep:0,g:49,l:1,wd:true,fm:true,w:1,p:1};
