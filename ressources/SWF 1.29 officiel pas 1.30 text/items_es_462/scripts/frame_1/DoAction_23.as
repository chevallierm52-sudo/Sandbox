I.u[9911] = {n:"Camuflaje inmovil.",t:31,d:"Si no te mueves, puede que nadie te vea.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[9912] = {n:"Pandawa attitude",t:31,d:"Tienes la Pandawa attitude, al menos hasta que vuelvas a entrar en combate.",ep:0,g:23,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[9913] = {n:"Mechón de pelo de Pandawalp",t:24,d:"Después de haberle derrotado al Pandawalp, le arrancaste este mechón de pelos de su trasero. Mirándolo con atención, parece que no sólo haya pelos... Mas vale no intentar averiguar más.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[9916] = {n:"Pergamino del hechizo especial Lazo Espiritual",t:75,d:"(Doble clic para aprender el hechizo) \nEste pergamino te permite aprender el hechizo Lazo Espiritual... Sólo para Osamodas.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"PG=2",u:true,p:10000};
I.u[9917] = {n:"Pergamino de Recompensa",t:24,d:"Este pergamino indica el objetivo.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9919] = {n:"Anillo de buho",t:9,d:"Para tomar la apariencia de búho.",ep:0,g:7,l:1,wd:false,fm:false,w:0,p:0};
I.u[9920] = {n:"Pergamino de recompensa completado.",t:24,d:"Este pergamino indica que el objetivo ha sido eliminado.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9921] = {n:"Brazalete taktikonik",t:9,d:"Este brazalete brilla, pero sólo en las noches de taberna.",ep:0,g:168,l:45,wd:true,fm:true,w:10,s:132,p:5525};
I.u[9922] = {n:"Cinturón taktikonik",t:10,d:"Este cinturón esta dotado de un mecanismo magnético tan increiblemente potente que hace que, a pesar de no tener hebilla, no se te caiga el cinturón. Importante: no te aconsejamos que lo utilices con unos calzoncillos de plomo.",ep:0,g:154,l:38,wd:true,fm:true,w:10,s:132,p:4050};
I.u[9923] = {n:"Zapatillas taktikonik",t:11,d:"Si tienes los músculos más duros que el acero y quieres bailar como un robot, necesitas un par de zapatillas como estas. Los cordones se venden por separado.",ep:0,g:135,l:40,wd:true,fm:true,w:10,s:132,p:4300};
I.u[9924] = {n:"Cuernos de Grandaiser",t:16,d:"Cuenta la leyenda que estos cuernos pueden usarse de pararrayos, ya que son capaces de concentrar el rayo durante varias horas y luego proyectar relámpagos contra los imprudentes que se acerquen demasiado. Otra leyenda cuenta que sólo sirve para que parezcas un idiota. Lo que sí es cierto es que sólo Grandaiser sabe llevar estos cuernos con elegancia.",ep:0,g:239,l:42,wd:true,fm:true,w:10,s:139,p:4825};
I.u[9925] = {n:"Puño Rotante",t:9,d:"Este anillo se parece más a un guante o a una manopla que a una alianza, pero que más da, lo cierto es que nadie volverá a estrecharte la mano como antes.",ep:0,g:169,l:44,wd:true,fm:true,w:10,s:139,p:4400};
I.u[9926] = {n:"Hachilla Doble",t:19,d:"Con esta hacha, compuesta de dos cuchillas, podrás cortar dos cabezas simultáneamente o, lo que es lo mismo, decapitar un octavo de hydra de dieciséis cabezas.",ep:0,g:57,l:39,wd:true,fm:true,w:10,an:17,e:[3,5,1,1,20,50,false,false],c:"CC>60&CV>50&CW>30",s:139,p:3900};
I.u[9927] = {n:"Robotas",t:11,d:"Grandaiser llevaba estas botas cuando, desde lo alto del monte Jifu, divisó unos objetos no identificados atravesando el cielo.",ep:0,g:136,l:42,wd:true,fm:true,w:10,s:139,p:4805};
I.u[9928] = {n:"Botas de Tor Nyquete",t:11,d:"Necesitarás 12 horas para atar estas botas, y otras 16 para desatarlas. Si quieres quitártelas una vez al día, cada vez irás más retrasado... a no ser que empieces hoy para compensar el retraso de mañana.",ep:0,g:137,l:42,wd:true,fm:true,w:10,s:131,p:4750};
I.u[9929] = {n:"Cinturón de Tor Nyquete",t:10,d:"El talón de Aquiles de algunos luchadores se encuentra en la zona del ombligo. Con este cinto en tus caderas puede que parezcas más jactancioso, pero también estarás mejor protegido.",ep:0,g:155,l:41,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9930] = {n:"Máscara de Tor Nyquete",t:16,d:"Con esta máscara, de lejos te parecerás a una larva mutante del espacio... pero de cerca serás igualito que un temible luchador, así que evita los combates a distancia.",ep:0,g:240,l:38,wd:true,fm:true,w:10,s:131,p:4000};
I.u[9931] = {n:"Peluca galaktiko taktikonik",t:16,d:"Nuca despejada y cresta de gallo: esta peluca te irá que ni pintada, además tras un duelo de taktikonik, nadie verá que te has despeinado.... ¡Forma parte de tu estilazo!",ep:0,g:241,l:39,wd:true,fm:true,w:10,s:132,p:4255};
I.u[9932] = {n:"Manojo de pelos del tabernero de la Bagruta",t:24,d:"Este manojo de pelos pegajoso se lo han arrancado de las axilas al tabernero de la Bagruta. El olor que desprende te da ganas de salir corriendo gritando ¡sálvese quien pueda! Te dejará trastornado.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[9933] = {n:"Capa de Tor Nyquete",t:17,d:"Los pelos de tufo con los que hemos cubierto el cuello de esta capa te protegerán cuando el público te tire sillas ... Tus combates son tan lamentables que más vale prevenir....",ep:0,g:167,l:42,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9934] = {n:"Llave del cercado",t:24,d:"Los goblins poseen equipos rudimentarios, reciclan muchas cosas y este hueso no va a ser la excepción. ¿Quién habría dicho que con un simple hueso se podría abrir el cercado? Desde luego, ¡tú no!",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9935] = {n:"Cuerda de escalada",t:15,d:"Esta sólida cuerda, está muy de moda entre los futuros alpinistas, sirve para subir y bajar. No obstante, existe una vieja tradición que consiste en hacer un nudo corredizo y pasarlo alrededor del cuello del jefe de la ciudad para hacerle entender que sus decisiones no gustan a todos.",ep:0,g:170,l:1,wd:false,fm:true,w:5,p:1};
I.u[9936] = {n:"Darth Casco",t:16,d:"Este casco es perfecto si lo que quieres es parecerte a un malo malísimo...a pesar de los granos y tu cara de angelito.",ep:0,g:242,l:37,wd:true,fm:true,w:10,s:117,p:3825};
I.u[9937] = {n:"Charlombín",t:16,d:"Este sombrero viene con un bigote postizo que no crece....¡Lo que te vas a ahorrar en el barbero!",ep:0,g:243,l:37,wd:true,fm:true,w:10,s:116,p:3700};
I.u[9938] = {n:"Delú",t:6,d:"La hoja de este sable fue templada durante 18 meses en un conentrado de luciérnagas.¡Es de vergüenza hacer eso con las pobres!...pero bueno, ¡es que así brilla en la oscuridad!",ep:0,g:91,l:38,wd:true,fm:true,w:10,an:14,tw:true,e:[5,4,1,1,50,50,false,false],c:"CV>30&CS>20&CW>20",s:117,p:3800};
I.u[9939] = {n:"Charbastón",t:4,d:"Esta vara flexible de bambú perteneció a un ilustre vagabundo con muy buenos modales.",ep:0,g:88,l:37,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"CC>25",s:116,p:3700};
I.u[9940] = {n:"Nácar en bruto",t:51,d:"Bien pulida, esta piedra puede proporcionarte un excelente nácar.",ep:0,g:10,l:20,wd:true,fm:true,w:1,p:10};
I.u[9941] = {n:"Nácar",t:50,d:"Compuesto de cristales de aragonita y de conquiolina, el nácar era completamente desconocido hasta el descubrimiento de la Isla de Otomai y de los crustorales. Es un elemento esencial en alquimia y joyería, aunque las recetas que contienen nácar son sumamente secretas.",ep:0,g:4,l:50,wd:true,fm:true,w:10,p:5000};
I.u[9942] = {n:"Anillo de la Muerte",t:9,d:"Este anillo, también conocido como \"Anillo negro\", no se ha terminado de construir...¡pero qué más da! Su potencia es tal que podría destruir hasta una luna.",ep:0,g:170,l:36,wd:true,fm:true,w:10,s:117,p:3600};
I.u[9943] = {n:"Charlzado",t:11,d:"Estos magníficos zapatos están pintados con un barniz a base de.... Bueno, nadie lo sabe a ciencia cierta, pero....¡qué bonitos son y cuánto brillan!",ep:0,g:138,l:43,wd:true,fm:true,w:10,s:116,p:4975};
I.u[9944] = {n:"La Charbata",t:1,d:"Doble función: amuleto y corbata. Con este objeto, tus allegados podrán llevarte atado fácilmente ¡Y a ti te gustará!",ep:0,g:145,l:43,wd:true,fm:true,w:10,s:116,p:5000};
I.u[9945] = {n:"Saco de Boba el Féttido",t:81,d:"Boba siempre ha olido muy mal, hasta llegó ha hacerse una armadura con tubo de escape para ocultar sus olores. Fue cazarecompensas durante varios años pero su carrera termino tristemente en el estómago de una criatura monstruosa.",ep:0,g:33,l:38,wd:true,fm:true,w:10,s:117,p:4050};
I.u[9946] = {n:"Cristal de Kay Daryn.",t:24,d:"Kay Daryn era un celebre cazatesoros conocido en toda en Amakna. Uno de sus descubrimientos fueron unos cristales preciosos con propiedades sorprendentes, como la capacidad de bizquear del revés sin utilizar las manos. Kay nunca dijo dónde se encontraba el yacimiento y aún hoy hay muchos anutrofs que lo buscan.",ep:0,g:744,l:1,wd:false,fm:true,w:0,p:1};
I.u[9947] = {n:"Cristal de Kay Daryn encantado",t:24,d:"Este cristal de Kay Daryn ha sido encantado y ahora puede decuplicar la codicia de aquellos que lo miran.",ep:0,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9948] = {n:"Tibia del jefe de los ladrones",t:24,d:"Con una tibia de menos, al jefe de los ladrones le va a costar andar. Peor para él, ¡eso es para que aprenda!",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9949] = {n:"Pasta Plas Plum",t:110,d:"Esta pasta la inventó el célebre Plas Plum, un geólogo especialista del ecosistema y de la siega, que sufría de artrosis precoz en la espalda. La pasta tiene como propiedades estirar y endurecer cualquier sustancia orgánica con la que entre en contacto: gracias a esto, Plas Plum se podía erguir. Tras la muerte de su creador, se descubrió otro uso muy útil, sobre todo, para los anutrofs. El único inconveniente es su olor... esto explica el mal aliento de ciertas anutrofas.",ep:0,g:42,l:1,wd:false,fm:true,w:1,p:1};
I.u[9950] = {n:"Piedra macilladera azul impura",t:51,d:"Bien pulida, podrás utilizar esta piedra al máximo de su potencia.",ep:0,g:151,l:1,wd:false,fm:true,w:5,p:1};
I.u[9951] = {n:"Piedra macilladera amarilla impura",t:51,d:"Bien pulida, podrás utilizar esta piedra al máximo de su potencia.",ep:0,g:145,l:1,wd:false,fm:true,w:5,p:1};
I.u[9952] = {n:"Piedra macilladera verde impura",t:51,d:"Bien pulida, podrás utilizar esta piedra al máximo de su potencia.",ep:0,g:76,l:1,wd:false,fm:true,w:5,p:1};
I.u[9953] = {n:"Piedra macilladera azul",t:50,d:"Esta piedra es capaz de manchar un alma que no tenga una gran voluntad... cosa que puede ser bastante eficaz para transformar tofus en tofus maléficos. Combinada con otras piedras macilladeras, podría incluso proporcionar un control total de las almas mancilladas.",ep:0,g:460,l:50,wd:false,fm:true,w:10,p:100};
I.u[9954] = {n:"Piedra macilladera amarilla",t:50,d:"Esta piedra es capaz de manchar un alma que no tenga una gran voluntad... cosa que puede ser bastante eficaz para transformar tofus en tofus maléficos. Combinada con otras piedras macilladeras, podría incluso proporcionar un control total de las almas mancilladas.",ep:0,g:463,l:50,wd:false,fm:true,w:10,p:100};
I.u[9955] = {n:"Piedra macilladera verde",t:50,d:"Esta piedra es capaz de manchar un alma que no tenga una gran voluntad... cosa que puede ser bastante eficaz para transformar tofus en tofus maléficos. Combinada con otras piedras macilladeras, podría incluso proporcionar un control total de las almas mancilladas.",ep:0,g:461,l:50,wd:false,fm:true,w:10,p:100};
I.u[9956] = {n:"Piedra de almas mancilladas",t:24,d:"Esta piedra proviene del pozo de las almas mancilladas. Gracias a ella, es posible controlar las almas de las criaturas que tiene atrapadas.",ep:0,g:462,l:1,wd:false,fm:true,w:0,p:1};
I.u[9958] = {n:"Caja de equipo bontariano",t:24,d:"Esta caja encierra el set del perfecto miliciano. Si el contenido de esta caja tiene la misma calidad que el continente, no debería sorprenderte que la milicia a Bonta sea derrotada en menos de un día.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9959] = {n:"Informe de peritaje",t:24,d:"Ya te lo esperabas, este informe de peritaje confirma la mala calidad del equipamiento de los milicianos bontarianos. Esta noticia va alegrarle el día a Oto Mustam.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9960] = {n:"Llaves del almacén",t:24,d:"Este tarro contiene los restos de lo que Neke Nieh tenía en el vientre. Lo bueno es que también contiene las llaves del almacén. Sólo tienes que meter la mano para recuperarlas y lo mejor para el postre, te chuparás los dedos.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9961] = {n:"Martillo Martel",t:7,d:"Este martillo de baja calidad fue creado para engañar a los herreros haciéndoles creer que tenían entre las manos un martillo de excelente calidad. Se desaconseja su uso incluso cuando no vayas a hacer nada.",ep:0,g:2,l:1,wd:true,fm:false,w:5,an:15,e:[5,4,1,1,60,20,false,false],p:10};
I.u[9962] = {n:"Caja de minerales",t:24,d:"Has robado esta caja de minerales para que Latem Odasep no pueda utilizarla para forjar los nuevos equipos destinados a la milicia de Bonta.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9963] = {n:"Martillo de herrero",t:24,d:"Le has robado este martillo a Latem Odasep y lo has reemplazado por el martillo de Martel. Latem Odasep es tan incompetente que no debería darse cuenta.",ep:0,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9964] = {n:"Regalo: Dragopavo Krameleón",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9965] = {n:"Método de Cría Canina",t:24,d:"Este método, desarrollado por el famoso adiestrador de miaumiaus Cángel Risto, explica cómo domar a un colmillo blando para que sea el mejor amigo del hombre, pero no de la mujer.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9966] = {n:"Botín del convoy",t:24,d:"Has obtenido este botín al atacar el convoy bontariano.  Aplastator el Aminal que se encuentra en el edificio de la milicia de Brakmar sabrá recompensarte por tus esfuerzos. Con un poco de suerte, te dejará que te marches de una sola pieza.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9967] = {n:"Cómo preparar Zampaburg",t:24,d:"Laura Soho, camarera de la taberna de Amakna, te escribió en este trozo de papel cómo preparar una buena botella de Zampaburg, con ayuda de un alquimista.\n- 5 frascos de Pandaburg\n- 1 zamparrón\n- 10 hojas de enchalada",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9968] = {n:"Botella de Zampaburg",t:79,d:"Esta mezcla superpotente de alcohol quema en la garganta y en el esófago, explota en el estómago, al mismo tiempo que hierve en el cerebro. ¡Sin duda es una bebida para los verdaderos pandawas! En la botella aparece el siguiente aviso en letra muy pequeña: el abuso de alcohol es peligroso para la salud. Consumir con moderación salvo en caso de sacrificio en honor a la diosa.",ep:0,g:177,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[9969] = {n:"Enchalada de pescado envenenada",t:15,d:"Como dice el refrán: «Lo que tiene mal olor, perfumado huele peor». Así es, el aroma que desprende esta enchalada de pescado esconde un potente veneno que te hará vomitar al primer bocado. Ideal para animar una boda un poco sosa o para gastarle una broma a tu jefe de gremio preferido.",ep:0,g:80,l:1,wd:false,fm:true,w:1,p:1};
I.u[9970] = {n:"Receta de la enchalada de pescado",t:24,d:"Propanzón Crizoe escribió en la arena la receta de la enchalada de pescado que pudiste copiar en un trozo de papel\n - 1 pescadero (incluirlo en el plato es opcional)\n - 2 lubinas mericanas\n - 3 barras de cangrejo ***\n - 2 limones\n - 4 hojas de enchalada\n - 1 blopicero envenenado (toque personal)",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9971] = {n:"Llaves de Mulic Bere",t:24,d:"Estas llaves, que pertenecen a Mulic Bere, abren la puerta de su forja especial dónde fabrica objetos poco habituales para gente normal y corriente como tú.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9972] = {n:"Martillo de forjador de rascador",t:7,d:"Este martillo está destinado a un uso concreto en la forja, sería un poco difícil utilizarlo para otra cosa. Sólo alguien que estuviera desesperado podría usarlo para forjar armas.",ep:0,g:2,l:1,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,50,false,false],c:"PJ>20,49",p:150};
I.u[9973] = {n:"Cabeza del rascador",t:15,d:"La cabeza del rascador cuenta con varias articulaciones que facilitan su uso. Los múltiples pinchos de su extremo  ilustran a la perfección el antiguo dicho que dice: «Si te pica, ráscate».",ep:0,g:716,l:1,wd:false,fm:true,w:1,p:1};
I.u[9974] = {n:"Talladora de mangos",t:5,d:"Si utilizas esta talladora para luchar, no tendrás suerte en el combate. Sin embargo, si la utilizas para esculpir mangos, dejarás a los escultores en el paro, provocando así el enfado de unos cuantos.",ep:0,g:17,l:1,wd:true,fm:true,w:5,e:[5,4,1,1,50,50,false,false],c:"PJ>19,49",p:150};
I.u[9975] = {n:"Mango de rascador",t:15,d:"El mango solo no te servirá para nada, aunque si le añades una cabeza de rascador... seguirá sin servirte para nada. Como verás, sólo una mente retorcida sabría qué hacer con él.",ep:0,g:52,l:1,wd:false,fm:true,w:5,p:1};
I.u[9976] = {n:"Rascador para la espalda inacabado",t:15,d:"Este rascador para la espalda es casi perfecto, pero no está terminado. Sólo un herrero talentoso podrá acabarlo. Desgraciadamente, no conoces ninguno.",ep:0,g:52,l:1,wd:false,fm:true,w:10,p:1};
I.u[9977] = {n:"Rascador para la espalda Spentox",t:24,d:"Este rascador para la espalda cubierto de púas se adapta a la forma de tu cuerpo y llega a lugares hasta ahora inaccesibles. ¡Atención! Sólo apto para osamodas.",ep:0,g:745,l:1,wd:false,fm:true,w:0,p:1};
I.u[9978] = {n:"Ejército de garrapatas de jabalí de las llanuras",t:24,d:"Las garrapatas de jabalí de las llanuras, más gordas que las de jalató, pueden absober hasta cien veces su peso en sangre. Los vampiros y Dark Vlad en persona palidecen de envidia al oir hablar de ellas.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9979] = {n:"Filtro de longevidad",t:12,d:"El alquimista Nileza creó esta pócima con la esperanza de conseguir la inmortalidad. Desgraciadamente, no llegó a probarla, porque murió envenenado al confundirla con la sangre de unikornio.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[9980] = {n:"Plato de fribamga",t:49,d:"Este plato ilustra a la perfección la expresión favorita del caballero Kacadoro «Si no está frito, no está rico».",ep:0,g:82,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9981] = {n:"Harina terrada",t:52,d:"Esta es la harina con la que Javier, el panadero, hizo el pan para los diferentes funerales del famoso trovador Badiz Mustabante.",ep:0,g:7,l:1,wd:false,fm:true,w:1,p:1};
I.u[9982] = {n:"Ensalada misela",t:69,d:"El nombre de esta ensalada rinde homenaje al día de su creación. En efecto, se sirvió por primera vez durante la ceremonia de investidura del caballero Kacadoro. No apta para señoritas.",ep:0,g:129,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9983] = {n:"Hogazas querosas",t:33,d:"Este pan, que se sirvió en los funerales del famoso trovador Badiz Mustabante, tiene un sabor y un olor tan asquerosos que resucitarían a un muerto o matarían a un vivo. Tal vez, de esta manera se puedan explicar las numerosas resurrecciones del trovador Badiz Mustabante.",ep:0,g:13,l:1,wd:false,fm:true,w:2,u:true,ut:true,p:1};
I.u[9984] = {n:"Lista de ingredientes de antaño",t:24,d:"Esta es la lista que dio Oto Mustam:\n- 1 hogaza querosa\n- 1 ensalada misela\n- 1 plato de fribamga\n- 1 filtro de longevidad",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9985] = {n:"Receta de las hogazas querosas",t:24,d:"- 2 sacos de harina terrada\n - 5 cubos de agua\n - 2 medidas de levadura de panadero",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9986] = {n:"Receta de la harina terrada",t:24,d:"- 1 medida de harina de Javier, el panadero \n - 1 medidas de pólvora de aniripsa \n-  4 cebollas",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9987] = {n:"Receta de la ensalada misela",t:24,d:"- 5 ensaladas de hocico ***\n - 20 porciones de polen de blop\n - 10 brotes de abráknido",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9988] = {n:"Receta del plato de fribamga",t:24,d:"- 10 buñuelos de bamga *** \n- 5 limones \n- 10 hojas de enchalada",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9989] = {n:"Receta del filtro de longevidad",t:24,d:"- 2 dosis de sangre de urikornio\n - 10 pócimas de envejecimiento\n - 2 pócimas de firma",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9990] = {n:"Broche de Guerl",t:24,d:"Guerl te prometió que a su regreso a Bonta te agradecería personalmente tu ayuda por haber defendido su convoy de mercancías. Y como muestra de gratitud te ha dado este broche.",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9993] = {n:"Sabina",t:32,d:"Tienes que llevar a Sabina al edificio de la milicia de Brakmar.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9995] = {n:"Pergamino ligado de Mercenario",t:87,d:"Este pergamino te permite localizar tu objetivo para poder cazarlo.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps=3",u:true,p:1};
I.u[9996] = {n:"Lote de cien pergaminos para mercenarios",t:87,d:"Con este lote se puede \"marcar\" a <b>un único objetivo</b> para que un mercenario pueda perseguirlo varias veces.",ep:0,g:3,l:10,wd:false,fm:true,w:100,ut:true,p:3500};
I.u[9997] = {n:"Llave de la guarida de los bandidos",t:24,d:"Con esta llave podrás abrir la puerta de la guarida de los bandidos. Gracias a Grimpill, sabes que un mecanismo cierra automáticamente la puerta cuando entra una persona, por esa razón todas las personas a las que los bandidos han habilitado tienen una llave.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9999] = {n:"Copia de la llave de la guarida de los bandidos",t:84,d:"Esta copia de la llave de la guarida de los zurcarák parece que se fuera a partir. Apostaría a que si intentas utilizarla se partirá. Pero dado que la inscripción \"Usar con precaución\" no está escrita en la caja, tienes toda la razón en decir que es ¡una falsificación!",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10000] = {n:"Manojo de pelos de Grimpill",t:24,d:"Cuando agarras este manojo de pelos con la mano, te da la impresión de que se mueve. Y si te fijas más de cerca, te das cuenta de que es verdad. No es un manojo de pelos sino un manojo de pulgas y garrapatas gigantescas. En resumen, tienes en la palma de la mano un verdadero ecosistema.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[10001] = {n:"Lote de diez pergaminos para mercenarios",t:87,d:"Con este lote se puede \"marcar\" a <b>un único objetivo</b> para que un mercenario pueda perseguirlo varias veces.",ep:0,g:3,l:10,wd:false,fm:true,w:10,ut:true,p:500};
I.u[10002] = {n:"Pergamino virgen para mercenarios",t:87,d:"Con este pergamino se puede \"marcar\" a un objetivo para que un mercenario pueda perseguirlo.",ep:0,g:1,l:10,wd:false,fm:false,w:1,ut:true,p:100};
I.u[10003] = {n:"Mermelada bollera",t:110,d:"Sólo Liroye Merlín conoce la receta de la mermelada bollera artificial. Cuando la mezclas con hierba húmeda, la mermelada se endurece y toma la forma del objeto que metas dentro... por eso la mermelada bollera va genial para hacer moldes.",ep:0,g:47,l:1,wd:false,fm:true,w:0,p:1};
I.u[10004] = {n:"El arte de saber usar la mermelada bollera",t:24,d:"Este documento lo redacto Liroy Merlín y explica los mil y un usos de la mermelada bollera. La parte que más te interesa es la que explica cómo hacer llaves baratas:\n-1 mermelada bollera\n-1 hierba loca\n-1 bakelitita",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10005] = {n:"Documentos confidenciales",t:24,d:"Lista de documentos confidenciales bontarianos. ¿Cómo habrán llegado tales documentos a una guarida de bandidos?",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10006] = {n:"Informe sospechoso",t:24,d:"Este informe arroja dudas sobre ti. Sus documentos cuestionan tu lealtad hacia Bonta y te implican en innumerables asuntos sucios. Solamente un experto te dirá si son auténticos o no.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10007] = {n:"Frasco de veneno brakmariano",t:24,d:"En este frasco de veneno brakmariano preparado a la antigua se puede leer \"Conservar en un lugar fresco y seco y consumir lentamente tras su apertura\", seguido de \"No ingerir salvo en caso de ser la víctima o bontariano\". Decididamente, los brakmarianos no bromean con el veneno.",ep:0,g:39,l:1,wd:false,fm:true,w:0,p:1};
I.u[10008] = {n:"Registro de clientes",t:24,d:"Este registro contiene la lista de todos los clientes del taller de alquimistas de Brakmar de estas dos últimas semanas. El problema es que todo está escrito en brakmariano y de ahí que no entiendas nada.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10009] = {n:"Xéphirex",t:32,d:"Tienes que llevar al traidor de Xéphirex hasta Amayiro: le tiene que rendir cuentas.",ep:0,g:24,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10010] = {n:"Llave de la salla de juego",t:24,d:"Esta es la llave de la sala de juego de la taberna Gatokemao.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[10011] = {n:"Corazón de Trempa",t:24,d:"Este es el corazón aún palpitante de Trempa. ¿Aún te atormenta que un discípulo del dios Sram no haya opuesto resistencia alguna cuando has procedido a quitarle la vida? ¡No te preocupes! El resultado habría sido el mismo... Además, no te dará tanta pena cuando se lo entregues a tu querido jefe.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10012] = {n:"Corazón de Trempa",t:24,d:"Este es el corazón aún palpitante de Trempa. ¿Aún te atormenta que un discípulo del dios Sram no haya opuesto resistencia alguna cuando has procedido a quitarle la vida? ¡No te preocupes! El resultado habría sido el mismo... Además, no te dará tanta pena cuando se lo entregues a tu querido jefe.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10013] = {n:"Corazón de Trempa",t:24,d:"Este es el corazón aún palpitante de Trempa. ¿Aún te atormenta que un discípulo del dios Sram no haya opuesto resistencia alguna cuando has procedido a quitarle la vida? ¡No te preocupes! El resultado habría sido el mismo... Además, no te dará tanta pena cuando se lo entregues a tu querido jefe.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10014] = {n:"Cheque de Trempa",t:24,d:"Este es el cheque que preparó Trempa para Oto Mustam. Es una pena que no sean kamas contantes y sonantes, porque los podrías haber cogido disimuladamente.",ep:0,g:54,l:1,wd:false,fm:true,w:0,p:1};
I.u[10015] = {n:"Lista de la compra de Oto Mustam",t:24,d:"Lamentablemente, has suspendido el examen de maldad y Oto Mustam te lo ha hecho pagar obligándote a buscar los siguientes objetos: \n- 1 saco de bronce\n- 1 saco de malta\n- 1 saco flores de cáñamo",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10016] = {n:"Hacha Lense",t:24,d:"Esta hacha tiene un aspecto rudimentario y parece pertenecer a otra época. Tiene una calidad tan mediocre que no creo que puedas cortar un tronkónido con ella.",ep:0,g:746,l:1,wd:false,fm:true,w:0,p:1};
I.u[10017] = {n:"Katana de Nara",t:24,d:"Esta es la katana que Nara forjó para demostrar su pericia. La calidad de esta katana es incomparablemente superior a la del hacha Lense forjada por Latem Odasep.",ep:0,g:53,l:1,wd:false,fm:true,w:0,p:1};
I.u[10018] = {n:"Esquema de la pinza para la ropa",t:15,d:"Este esquema está tan claro que hasta un niño yopuka podría comprenderlo. Quizás, porque un yopuka siempre será un yopuka. En las manos de un manitas, este esquema servirá hasta para fabricar objetos. Y bueno, si el manitas es un yopuka, es que de verdad existen los milagros.\nNecesitarás este esquema, 10 tablas de madera de kalipto y 10 aluminitas.",ep:0,g:767,l:1,wd:false,fm:true,w:1,p:1};
I.u[10019] = {n:"Cubo de pinzas para la ropa",t:15,d:"Este cubo tiene suficientes pinzas para la ropa como para tender todos los calzoncillos de todos los milicianos de Amakna en las murallas. También podemos utilizarlas para secar las pieles y los cueros de los monstruos o de los suegros acabaditos de matar... ¡Te vendrá de perlas!",ep:0,g:768,l:1,wd:false,fm:true,w:10,p:1};
I.u[10020] = {n:"Muñeca maltratada",t:24,d:"Te cuesta creer que esta muñeca fea y maloliente fuera antes un bwork mago. Pues piensa que un bwork mago es feo y maloliente... ahora las cosas parecen tener más sentido, ¿no?",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10021] = {n:"Muñeca remendada",t:24,d:"Te preguntas si la muñeca estaba mejor antes o después de que Maskara le echase el remiendo... Una cosa está clara, sólo un dios podía hacer que la muñeca fuera más bonita que el modelo original.  Ahora comprendemos por qué el bwork mago se encerró en una caverna y por qué tenía mal carácter.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10022] = {n:"Muñeca encantada",t:24,d:"Qué encanto recibir esta muñeca encantada de manos del encantador que la ha encantado en los lagos encantados. Si aún estuviese vivo, el trovador Badiz Mustabante para dártela te habría cantado encantado una cancioncilla.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10023] = {n:"Registro de rondas",t:24,d:"Este registro no habla de mamás bworks sino del recorrido que hacen las patrullas brakmarianas. Así que si quieres tenderles una emboscada tienes para elegir...",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10024] = {n:"Viejo grimorio bwork",t:24,d:"Es el viejo grimorio de un bwork mago de las cavernas, lo que significa que las ilustraciones que contiene son difícilmente compresibles para un bwork mago de las cavernas normal y mucho menos para un bwork mago moderno. Esperemos que Danathor le encuentre alguna utilidad. Sería una pena tomarse tanto trabajo para nada, ¿no?",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10025] = {n:"Fiebre de Zampaburg",t:30,d:"Quedaste avisado: el abuso de Zampaburg es peligroso para la salud.",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10026] = {n:"Receta de la enchalada de pescado",t:24,d:"Propanzón Crizoe escribió en la arena la receta de la enchalada de pescado que pudiste copiar en un trozo de papel\n- 1 pescadero (opcional)\n- 2 lubinas mericanas\n- 3 barras de cangrejo ***\n- 2 limones\n- 4 hojas de enchalada\n- 2 Vergelys (toque personal)",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10028] = {n:"Receta del tejido remendón",t:24,d:"El sastre Sosh elaboró esta receta para remendar las prendas mágicas. Los sastres con experiencia pordrán utilizarla para crear tejidos a prueba del tiempo y las intemperies. \n- 5 pelos de barba de bwork mago \n- 5 pelos de black pekewabbit \n- 3 pelos de barba del Awuelito wabbit \n- 3 pelos del minilubo \n- 1 hilo de seda",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10029] = {n:"Receta del tinte naranja sanguina",t:24,d:"El famoso alquimista Uba Teseo elaboró esta receta. Nadie ha podido usarla aún, porque Uba Teseo se la olvidó en casa de su amigo Sosh, quién amablemente te la regaló.\n- 1 dosis de tinte mágico rojizo\n- 1 dosis de tinte mágico naranja\n- 10 dosis de sangre de jalató\n- 5 sardinas brillantes",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10030] = {n:"Tejido remendón",t:55,d:"Este tejido sintético que inventó el sastre Sosh permite remendar las prendas mágicas sin alterar sus poderes. Por eso, es tan apreciado entre los sastres con experiencia.",ep:0,g:434,l:1,wd:false,fm:true,w:1,p:1};
I.u[10031] = {n:"Tinte naranja sanguina",t:70,d:"Este tinte mágico que inventó Uba Teseo es extremadamente agresivo, como si algo lo empujara a hacer el mal. ¿Por qué será tan malvado?",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
I.u[10032] = {n:"Bandana remendada",t:24,d:"Esta bandana está ahora en mejor estado que cuando la descubrieron. El hecho de que huela más a pescado que a zanahowia, hace que se parezca más a lo que fue antaño. Tugtora debería estar agradecido por recuperarla en tan buen estado.",ep:0,g:749,l:1,wd:false,fm:true,w:0,p:1};
I.u[10033] = {n:"Orden de misión",t:24,d:"Esta orden de misión firmada por Kaffra Kyper indica a los brakmarianos que deben devolver los documentos a Seci Ves, de guardia junto a la Torre de las Órdenes de Brakmar.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10034] = {n:"Lista del Mago de Zo",t:24,d:"Lista de objetos que hay que llevarle para el ritual de la revelación:\n - 5 pócimas de llovizna\n - 10 cubos de agua\n - 10 semillas de pandoja\n - 4 medidas de polvos mágicos\n - 2 trocos de madera de carpe\n - 4 pócimas de corriente de aire\n - 2 personas de confianza\n - NADA de echarse azufre encima",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10035] = {n:"Resultado de la revelación",t:24,d:"El Mago de Zo escribió en este pergamino el resultado del ritual de la revelación. Para utilizar el cuerno mágico, sólo hay que meter la mano dentro y sacar unas cuantas patatas fritas.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10036] = {n:"Hada Lanzadora de Garra Juguetona",t:74,d:"Cuando Mylesa vivía en la Torre Ente pidió a un famoso artesano un gran número de hadas artificiales para animar sus fiestas. Aún hoy da algnuas cuando no se pone en plan... aguafiestas.",ep:0,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10042] = {n:"Hada Lanzadora de Lengua Raspadora",t:74,d:"Cuando Mylesa vivía en la Torre Ente pidió a un famoso artesano un gran número de hadas artificiales para animar sus fiestas. Aún hoy da algnuas cuando no se pone en plan... aguafiestas.",ep:0,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10043] = {n:"Más Bonita que Ninguna",t:30,d:"Una loción de belleza muy potente te ha dado esta apariencia... ¡ya estas lista para robarle el corazón a todos los Miaumiaus! ¡Miauuu!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10044] = {n:"Loción de Belleza de Mylesa",t:12,d:"Mylesa se unta todos los días esta loción en el cuerpo para seguir joven y bella... ¡Pruébala y verás!\nAunque, con el mínimo esfuerzo que realices en combate desaparecerán sus efectos y volverás a tener un aspecto demacrado....La loción no hace a la Sacerdotisa del Amor.",ep:0,g:40,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10052] = {n:"Pócima de olvido: \"Lazo Espiritual\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo elemental \"Lazo Espiritual\"",ep:0,g:31,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[10054] = {n:"Anillo de Vampyro",t:9,d:"Este anillo ha pasado tres años metido en excrementos de murciélago... ¡pero anda que no es mágico!",ep:0,g:171,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4703};
I.u[10055] = {n:"Amuleto de Vampyro",t:1,d:"Este amuleto previene a los vampyros, que se dispongan a morderte en el cuello, de que es inútil que intenten chuparte la sangre ya que tú eres otro vampyro.",ep:0,g:146,l:45,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:5500};
I.u[10056] = {n:"Cinturón de Vampyro",t:10,d:"El eslogan de este cinturón dice \"¡Y además brilla por la noche!\"...mmm sí, vale ¿además de qué?",ep:0,g:156,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4805};
I.u[10057] = {n:"Runa de caza",t:78,d:"Acuérdate de lo que decía el rayante Crusy: \"El cazador tiene un arco, ve algo que se mueve y ¡dispara! Porque si hay que disparar se dispara, pero... pero disparar pa ná ¡es tontería!\" Gracias a esta runa, podrás comprobar el dicho con cualquiera de tus armas.",ep:0,g:60,l:10,wd:false,fm:true,w:1,p:10};
I.u[10058] = {n:"Capa de Vampyro",t:17,d:"Bram tenía razón... hay que desconfiar de las personas con dientes largos, sobre todo cuando llevan una capa de vampyro.",ep:0,g:168,l:41,wd:true,fm:true,w:5,c:"PO!10119",s:130,p:4550};
I.u[10061] = {n:"Botas de Vampyro",t:11,d:"Se dice que la misma Elizabeth Byctora utilizó una vez estas botas. ¡Aunque a ti que más te da!",ep:0,g:139,l:41,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4550};
I.u[10063] = {n:"Más Bonita que Ninguna",t:31,d:"Una loción de belleza muy potente te ha dado esta apariencia... ¡ya estas lista para robarle el corazón a todos los Miaumiaus! ¡Miauuu!",ep:0,g:13,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10065] = {n:"Loción Laérol",t:24,d:"Esta loción la inventó hace ya siglos el alquimista anutrof Laérol. Su objetivo era luchar contra la caída del pelo. Desgraciadamente, esta loción no servía de nada contra las avalanchas de piedras y por eso murio aplastado pour las piedras de una partida de petanca entre crujidores.",ep:0,g:752,l:1,wd:false,fm:true,w:0,p:1};
I.u[10069] = {n:"Tonel de hidramiel",t:24,d:"Este tonel contiene un alcohol tan fuerte y potente a base de veneno de coolebra y de miel de oreja de maxilubo. Un solo trago puede provocar lesiones cerebrales graves. Es la bebida preferida de los yopukas... claro que ellos pueden consumirla sin correr riesgos.",ep:0,g:165,l:1,wd:false,fm:true,w:0,p:1};
I.u[10070] = {n:"Tonel de bombú",t:15,d:"Los aros de este tonel de madera de bombú están hechos de ebonita. Esta aleación se vuelve venenosa con el tiempo. Los toneles de bombú se utilizan sobre todo para la fermentación y conservación de distintos alcoholes, a los que les aporta un sabor bastante particular y unos efectos secundarios igualmente particulares.",ep:0,g:165,l:1,wd:false,fm:true,w:5,p:1};
I.u[10071] = {n:"Plano de acceso a la cueva de Argui Ñaño",t:24,d:"Este plano indica cómo se accede a la cueva de Argui Ñaño que está situada al sur del zaap del pueblo de Amakna. Hacen falta dos personas para despejar la entrada: una persona equipada con una pala Patarta y un minero equipado con su pico y que sea capaz de extraer plata. También será necesario un tonel de bombú para transportar la hidramiel. Los manitas saben fabricarlos.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10072] = {n:"Pluma de trasero",t:24,d:"Esta pluma embebida de los efluvios alcoholizados se la han arrancado del trasero a un borracho perdido. Ahora tiene plena consciencia de que el alcohol es perjudicial para la salud.",ep:0,g:754,l:1,wd:false,fm:true,w:0,p:1};
I.u[10073] = {n:"Escudo HispáÑico",t:82,d:"Ésta es una de las raras réplicas que Sir-Dal mandó hacer del escudo mágico de su tatarabuelo, el mítico Dal-Uk-Wet, unificador de los reinos de HispaÑia. Con estos escudos, Sir-Dal quiso recompensar el valor y el coraje de los mejores guerreros de HispaÑia.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[10074] = {n:"Carta del jefe de los ladrones",t:24,d:"La encontraron tras un combate contra los ladrones de casa de Milone.\nMilone Corichel, el joyero, acaba de crear una joya de gran valor. Róbala cueste lo que cueste.\nAfortunadamente, Milone les dio una falsa, y no ha sido gracias a tu ayuda.\nPor otro lado, al dorso del mensaje se especifica la ubicación de su guarida. Hay que tomarse la revancha, pero mejor será ir acompañado.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10075] = {n:"Papilla asquerosa",t:24,d:"Esta asquerosa papilla ha aparecido, como por arte de magia, en tu bolsillo.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[10076] = {n:"Escudo HispáÑico Único",t:82,d:"Éste es el escudo mágico del mítico Dal-Uk-Wet, el unificador de los reinos de HispaÑia. Con él podía concentrar y canalizar todo su poder (para mayor desgracia de sus adversarios). Años más tarde, Sir-Dal, su tataranieto, mandó realizar varias réplicas de este escudo para los mejores guerreros de HispaÑia, pero éste es el original, ¡el único!",ep:0,g:40,l:1,wd:false,fm:true,w:30,c:"PP>9",p:63200};
I.u[10077] = {n:"Terra Cógita",t:32,d:"Tienes que escoltar a Terra Cógita a varios sitios antes de lleverle hasta Medah Larisa.",ep:0,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10078] = {n:"Ani N\'Hubb",t:32,d:"Tienes que escoltar y proteger a Ani N\'Hubb. Desde que te acompaña, se podría decir que el destino está en contra tuya.",ep:0,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10079] = {n:"Pan trémulo",t:33,d:"A los yopukas les encanta este pan que te vuelve valiente y temerario al mismo tiempo... y que por esa misma razón ha provocado la muerte de más de un aventurero. Xavier el panadero dejo de hornearlos cuando una compañía de trovadores atacó a un grupo de lubos rabiosos despues de comerse uno.",ep:0,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[10080] = {n:"Mensaje de los renegados",t:24,d:"Este mensaje da cita los renegados que estén cerca de la Mazmorra de los Escarahojas. Tendrías que ir para avreiguar más infomación.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10081] = {n:"Mensaje del jefe de los renegados",t:24,d:"En este mensaje, el jefe de los renegados les pide que se unan a él al sur del territorio de los bandidos. La ocasión la pintan calva para eliminar a ese traidor.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10082] = {n:"Cóctel mohitov",t:24,d:"¿Qué obtenemos al exprimir un pétalo mohito? Savia alcoholizada a base de muchos cócteles distintos con los que los discípulos de Otomai se deleitan en las fiestas de verano. De hecho, este cóctel explosivo será la bomba de la fiesta, figurada y literalmente.",ep:0,g:762,l:1,wd:false,fm:true,w:0,p:1};
I.u[10083] = {n:"Enchalada de pescado",t:49,d:"Como dice el refrán: «Lo que tiene mal olor, perfumado huele peor». Así es, el aroma que desprende esta enchalada de pescado esconde un fuerte olor a pies. No consumir en presencia de puerkazo en celo, a no ser que seas una bonita cerda.",ep:0,g:80,l:1,wd:false,fm:true,w:3,u:true,ut:true,p:1};
I.u[10084] = {n:"Silbato de llamada",t:24,d:"Este silbato fue concebido por Cángel Risto y permite llamar a los colmillos blandos domesticados. Pero por otra parte no te dejará que te hagas pasar por el dueño de un colmillo blando que no te pertenezca. También funciona muy bien con los colmillos blandos salvajes.",ep:0,g:755,l:1,wd:false,fm:true,w:0,p:1};
I.u[10085] = {n:"Orden de ejecución",t:87,d:"Las órdenes están más claras que el agua, todo lo contrario que los calzoncillo del minotot. Encuentra y vence al objetivo.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:0};
I.u[10086] = {n:"Canino de bandido de las llanuras",t:24,d:"El combate contra los bandidos de las llanuras fue tan violento que uno de ellos perdió un canino.",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:1};
I.u[10087] = {n:"Cita de Xantrax",t:24,d:"Este papel escrito por un brakmariano te da cita con Xantrax en la Torre de Bonta al final de su próxima reunión. Eso quiere decir que igual ya es la hora de la cita, ¿no?",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10088] = {n:"Pañuelo usado",t:24,d:"Has recuperado este pañuelo en tu combate contra Xéphirex. Un recuerdo útil y agradable, sobre todo si tienes la nariz atascada o si eres alérgico a los pelos de miaumiau.",ep:0,g:756,l:1,wd:false,fm:true,w:0,p:1};
I.u[10089] = {n:"Caja de mercancías",t:24,d:"Xéphirex te ha pedido entregar esta caja de mercancías al  consejero Boyowa, en casa de Pandawelo, en señal de buena fe. No sabes lo que hay en su interior pero seguramente son objetos de valor.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10090] = {n:"Lista de suministros de Nara",t:24,d:"Nara te ha hecho la lista de lo que necesita para su nuevo taller de herrero: 20 maderas de roble, 1 petaca de azufre, 30 hierros, 1 kuarzo, 5 bakelititas y 10 cueros de jabalí de las llanuras.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10091] = {n:"Notas sobre la maldición de Nas Orazal",t:24,d:"La maldición de Nas Orazal sirve para resucitar un alma en contra de su voluntad. Hace falta 1 dosis de sangre de fénix, 5 medidad de polvos mágicos y 1 amuleto de Lear que podrás encontrar en los cadáveres de los abraknos y de los abraknos oscuros.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10092] = {n:"Orden de anulación",t:24,d:"Esta carta, fechada hace sólo algunas horas, indica que el asalto contra Bonta ha sido anulado debido a las mejoras del equipamiento que han recibido sus milicianos y también gracias a la captura de Xéphirex.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10102] = {n:"Máscara de Vampyro",t:16,d:"Esta máscara te protegerá de los rayos del sol.",ep:0,g:244,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4725};
I.u[10103] = {n:"Carta para Fidji Merlín",t:24,d:"Onidal te ha confiado esta carta para que se la entregues a Fidji Merlín. Al parecer, tendrás que seguir las instrucciones de la manitas de Brakmar.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[10104] = {n:"Pesebre trucado",t:24,d:"Este comedero ha sido trucado para esconder las berenjenas. Más te vale no atravesar Brakmar a lomos de una montura que se haya saciado en este comedero. Ciertamente, las flatulencias que provocan estas berenjenas podrían provocar un incidente explosivo.",ep:0,g:759,l:1,wd:false,fm:true,w:0,p:1};
I.u[10105] = {n:"Pata cubierta de pelos",t:24,d:"Esta pata de arakna cubierta de pelos de arakna y de miaumiau es un arma temible para enfrentarse a Alse Tocreto.",ep:0,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[10106] = {n:"Vampyrilla",t:18,d:"A esta terrible criatura le encanta chupar la sangre a tus amigos, pero tampoco le hace ascos a tus tobillos si los tienes bien regordetes. Sin embargo nada de esto es suficiente para ella, ya que lo que más le gusta es que a dos os enfrentéis a esqueletos y que luego os repartáis los cadáveres. Ya te habíamos avisado de que era terrible.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10107] = {n:"Murciego",t:18,d:"Esta mascota ha tenido una infancia muy dificil ... las otras mascotas le llamaban de todo..murcuatroojos, murmiope, murcegatón... Eso explica su comportamiento. Se ha vuelto loco y sólo tiene una obsesión en la vida: matar a todos los Stropajos que pasen por su lado para alimentarse de sus cadáveres.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10108] = {n:"Fantasma de Vampyrilla",t:90,d:"Este fantasma aún está en el mundo de los vivos, y sólo cuenta contigo para que encuentres el modo de resucitarlo, o... también puedes abandonarlo como hacen los cobardes.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10109] = {n:"Fantasma de Murciego",t:90,d:"Este fantasma aún está en el mundo de los vivos, y sólo cuenta contigo para que encuentres el modo de resucitarlo, o... también puedes abandonarlo como hacen los cobardes.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10118] = {n:"Colmillo blando domado",t:32,d:"Este colmillo blando ha sido adiestrado con el Método de Cría Canina que fue escrito por el famoso adiestrador de miaumiaus Cángel Risto.",ep:0,g:23,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10119] = {n:"Ghulificado",t:30,d:"Te sentirás algo diferente...",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,c:"POX10055&POX10054&POX10056&POX10061&POX10058&POX10102",p:0};
I.u[10120] = {n:"Descripción de un desconocido",t:24,d:"Otabaj te ha dado por escrito la descripción de un desconocido que se entretuvo con Vasta Detontirías. Lo que resulta extraño es que no corresponde con la descripción que te dio oralmente. Aquí hay algo que huele muy mal.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10121] = {n:"Piedrecilla",t:51,d:"Con esta piedrecilla podrás activar la magia de las baldosas para alcanzar al espíritu del agua. Su uso es muy sencillo: sólo tienes que depositarla sobre una baldosa y la mágia hará su trabajo. Simple y eficaz. Hasta un yopuka podría hacerlo, eso si no se encuentra antes con un enemigo a quien tirarle la piedrecilla.",ep:0,g:267,l:1,wd:false,fm:true,w:1,p:1};
I.u[10122] = {n:"La lista de Norb",t:24,d:"Norb te ha hecho la lista de recursos que tienes que llevar a Nara. Te hacen falta 2 bakelititas, 10 manganeso, 20 bauxitas, 15 dolomitas y 20  madera de olivioleta.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10123] = {n:"Kerenah",t:32,d:"Debes escoltar a este sram hasta Amayiro y debes hacerlo rápido, ya que la peste que desprende va a atraer a todos los miaumiaus de los alrededores.",ep:0,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10124] = {n:"Miaumiauligno",t:32,d:"Debes llevarle este miaumiau a Risto Cángel, el domador de miaumiaus. Es muy importante que no mires a esta terrible criatura a los ojos, podrías sucumbir a su encanto y volverte tan bobo como algún que otro aniripsa.",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10125] = {n:"Arco del Bandido Arquero",t:2,d:"Este arco perteneció a un viejo Bandido Arquero que lo utilizaba para alcanzar a sus victimas a una gran distancia: así no se manchaba. Está impregnado de una magia tan poderosa que corres el riesgo de transformarte en Bandido Arquero si te lo equipas...",ep:0,g:67,l:30,wd:true,fm:false,w:10,an:10,tw:true,e:[2,6,3,5,40,40,false,true],p:3000};
I.u[10126] = {n:"Espada del Bandido espadachín",t:6,d:"Esta espada perteneció a un viejo Bandido espadachín al que no le gustaba nada correr para alcanzar a sus adversarios. Su procedimiento era bien sencillo: primero le cortaba las piernas y luego les preguntaba lo que quería saber. Está impregnada de una magia tan poderosa que corres el riesgo de transformarte en Bandido espadachín si te lo equipas...",ep:0,g:92,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,40,40,false,false],p:3000};
I.u[10127] = {n:"Bastón del Bandido Pendenciero",t:4,d:"Este bastón pertenció a un viejo Bandido Pendenciero que al estar siempre borracho, era incapaz de hurgar en los bolsillos de sus victimas sin desplomarse: este bastón le permitía mantenerse de pie el tiempo que le llevaba hacer su trabajo. Está impregnado de una magia tan poderosa que corres el riesgo de transformarte en Bandido Pendenciero si se te ocurre equiparte con ella.",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:12,e:[5,6,1,1,40,40,false,false],p:3000};
I.u[10131] = {n:"Regalo: Vampyrilla",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está deseando tirársete al cuello. ¡No pierdas ni un segundo más y ábrelo rápidamente! Hay una super mascota.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10132] = {n:"Regalo: Murciego",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está deseando tirársete al cuello. ¡No pierdas ni un segundo más y ábrelo rápidamente! Hay una super mascota.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10133] = {n:"Varita del Bandido Hechicero",t:3,d:"Esta varita perteneció a un viejo Bandido Hechicero, quien la usaba para reducir a cenizas a los enemigos que quería \"ahumar\". Está impregnada de una magia tan poderosa que corres el riesgo de transformarte en Bandido Hechicero si te lo equipas...",ep:0,g:72,l:30,wd:true,fm:false,w:10,an:11,tw:true,e:[2,5,2,4,40,40,false,true],p:3000};
I.u[10134] = {n:"Certificado de admisión en la petrera: vampyrilla",t:77,d:"Este certificado describe las características de la vampyrilla que has dejado en la petrera.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10135] = {n:"Certificado de admisión en la petrera: murciego",t:77,d:"Este certificado describe las características del murciego que has dejado en la petrera.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
