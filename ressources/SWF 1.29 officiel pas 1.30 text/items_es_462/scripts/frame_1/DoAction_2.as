I.u[836] = {n:"Abranillo",t:9,d:"Este anillo fue forjado en la corteza de abráknido. Posee grandes poderes e implica por lo tanto grandes responsabilidades. Sin embargo, a pesar de su valor, existen rumores que cuentan que está maldito.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:100};
I.u[837] = {n:"Botas de Kluh",t:11,d:"Estas botas aumentan la fuerza del que las lleva pero pueden hacer que se vuelva un poco idiota al cabo de un cierto tiempo e incluso pueden transformarlo en Yopuka si las utiliza demasiado a menudo y de forma prolongada.",ep:1,g:3,l:8,wd:true,fm:true,w:1,p:400};
I.u[838] = {n:"Sangre de Oni",t:15,d:"Este frasco de sangre de Oni es muy rebuscado por los alquimistas experimentados que desean proporcionar a algunas armas, propiedades especialmente espantosas.",ep:4,g:662,l:75,wd:true,fm:true,w:1,p:100};
I.u[840] = {n:"Pelos de minotauroro",t:54,d:"Estos pelos huelen muy mal, pero son de una resistencia a toda prueba, llevar sobre sí una tela hecha con pelos de minotauroro hará de ti una persona temida por tus adversarios y apreciada por las moscas.",ep:2,g:201,l:125,wd:true,fm:true,w:1,p:100};
I.u[841] = {n:"Anillo de Satisfacción",t:9,d:"Este anillo permitirá aumentar los PA de tu héroe, en contrapartida de su fuerza e inteligencia.",ep:1,g:12,l:8,wd:true,fm:true,w:1,p:10};
I.u[842] = {n:"Cáscara de dragohuevo dorado",t:111,d:"Esta cáscara es casi irrompible, sin embargo, puliéndola durante generaciones, los mejores Joyeros pueden utilizar sus propiedades mágicas para hacer amuletos con poderes excepcionales.",ep:11,g:202,l:64,wd:true,fm:true,w:5,p:1};
I.u[843] = {n:"Cáscara de dragohuevo negro",t:111,d:"Esta cáscara es casi irrompible, sin embargo, puliéndola durante generaciones, los mejores Joyeros pueden utilizar sus propiedades mágicas para hacer amuletos con poderes excepcionales.",ep:11,g:203,l:64,wd:true,fm:true,w:5,p:150};
I.u[844] = {n:"Huevo de dragohuevo de zafiro",t:105,d:"Este extraño huevo dará nacimiento a un hermoso Dragohuevito una vez que este haya sido empollado por una Hembra Dragohuevo de Zafiro. Mientras tanto, procura no llevarlo en uno de tus calentitos bolsillos, nunca se sabe lo que podría ocurrir...",ep:11,g:204,l:74,wd:true,fm:true,w:20,p:100};
I.u[845] = {n:"Huevo de dragohuevo dorado",t:105,d:"Este extraño huevo dará nacimiento a un hermoso Dragohuevito una vez que este haya sido empollado por una Hembra Dragohuevo Dorado. Mientras tanto, procura no llevarlo en uno de tus calentitos bolsillos, nunca se sabe lo que podría ocurrir...",ep:11,g:205,l:74,wd:true,fm:true,w:20,p:100};
I.u[846] = {n:"Huevo de dragohuevo negro",t:105,d:"Este extraño huevo dará nacimiento a un hermoso Dragohuevito una vez que este haya sido empollado por una Hembra Dragohuevo Negro. Mientras tanto, procura no llevarlo en uno de tus calentitos bolsillos, nunca se sabe lo que podría ocurrir...",ep:11,g:206,l:74,wd:true,fm:true,w:20,p:100};
I.u[847] = {n:"Huevo de dragohuevo blanco",t:105,d:"Este extraño huevo dará nacimiento a un hermoso Dragohuevito una vez que este haya sido empollado por una Hembra Dragón Negro. Mientras tanto, procura no llevarlo en uno de tus calentitos bolsillos, nunca se sabe lo que podría ocurrir...",ep:10,g:38,l:74,wd:true,fm:true,w:1,p:100};
I.u[848] = {n:"Viejo Hueso de Dragohuevo",t:47,d:"Este viejo hueso es mágico, correctamente utilizado, debería permitirte hacer objetos muy poderosos.",ep:11,g:15,l:70,wd:true,fm:true,w:20,p:100};
I.u[849] = {n:"Anillo Forcesco",t:9,d:"Este pequeño anillo procura Fuerza a su portador.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[850] = {n:"Anillo Agilesco",t:9,d:"Curiosamente, los coleccionistas Amaknienses se disputan este anillo a pesar de que no valga un churro.",ep:1,g:1,l:1,wd:true,fm:true,w:1,p:50};
I.u[851] = {n:"Anillo Vitalesco",t:9,d:"Este pequeño anillo aumenta la vida de su portador.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[852] = {n:"Pequeño Anillo Mágico",t:9,d:"Este pequeño anillo aumenta la inteligencia de su portador.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[853] = {n:"Pequeño Anillo del Afortunado",t:9,d:"Este pequeño anillo aumenta la suerte de su portador.",ep:1,g:42,l:1,wd:true,fm:true,w:1,p:50};
I.u[854] = {n:"Amuleto del Osito",t:1,d:"Este amuleto aumenta la fuerza de su portador.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[855] = {n:"Amuleto del Lobezno",t:1,d:"Este amuleto aumenta la vida de su portador.",ep:0,g:6,l:1,wd:true,fm:true,w:1,p:50};
I.u[856] = {n:"Ranilla",t:1,d:"Este amuleto aumenta la agilidad de su portador.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[859] = {n:"Cinturón de Agilidad",t:10,d:"Este modesto cinturón aumenta la agilidad de quien lo lleve puesto.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:50};
I.u[860] = {n:"Cinturón de Suerte",t:10,d:"Este modesto cinturón aumenta la suerte de quien lo lleve puesto.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[861] = {n:"Pequeñas Botas de Fuerza",t:11,d:"Esta botas aumentan la fuerza del que las lleva en detrimento de su agilidad, lo cual tiende a diferenciarlo de un Tofu sin que sea tampoco menos idiota.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[862] = {n:"Sandalias de Inteligencia",t:11,d:"Estas botas permiten aumentar la inteligencia del que las lleva al mismo tiempo que le confiere un estilo muy a la moda gracias a su suela de madera de nogal que ofrece una adherencia increíble.",ep:1,g:4,l:8,wd:true,fm:true,w:1,p:400};
I.u[863] = {n:"Botas Agilescas",t:11,d:"Estas botas permiten aumentar la agilidad del que las lleva. De esta manera podrá imitar a un Tofu cuando le entren ganas de hacer el imbécil.",ep:1,g:5,l:8,wd:true,fm:true,w:1,p:400};
I.u[864] = {n:"Botas de Suerte",t:11,d:"Estas botas aumentan la suerte del que las lleva para ayudarle a encontrar objetos muy poderosos, como por ejemplo la baba de Jalató.",ep:1,g:1,l:8,wd:true,fm:true,w:1,p:100};
I.u[867] = {n:"Dragolira",t:1,d:"Este espléndido amuleto confeccionado a partir de restos de Dragohuevo, es lo suficientemente impresionante como para alejar a la mayoría de los enemigos normalmente constituidos.",ep:11,g:9,l:32,wd:true,fm:true,w:2,p:4700};
I.u[878] = {n:"Pergamino de panadero",t:13,d:"(Haz doble clic para utilizarlo) \nEste pergamino permite ganar puntos de experiencia en el oficio de panadero.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[879] = {n:"Pergamino de zapatero",t:13,d:"(Haz doble clic para utilizarlo) \nEste pergamino permite ganar puntos de experiencia en el oficio de zapatero.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[880] = {n:"Lana de jalató real",t:57,d:"Esta lana es real, es suave y ligera, pero tiende a picar las pieles sensibles. Esta lana está en cambio muy gastada y por consiguiente, es muy frágil, dada la edad del jalató real.",ep:1,g:207,l:35,wd:true,fm:true,w:1,p:4000};
I.u[881] = {n:"Lana de jalatín blanco",t:57,d:"Esta lana es extremadamente suave, ya que procede del plumón de un jalató. Sin embargo ten cuidado si la llevas contigo, por que está todavía impregnada de un olor que podría incitar a la madre del jalató a lamerte.",ep:1,g:208,l:2,wd:true,fm:true,w:1,p:1};
I.u[882] = {n:"Lana del jefe de guerra del jalató",t:57,d:"Esta lana huele muy mal, pero perteneció a un Jefe de Guerra Jalató, lo cual le confiere un gran valor sentimental para los belicosos.",ep:1,g:209,l:19,wd:true,fm:true,w:1,p:1};
I.u[883] = {n:"Cuero de jalatín blanco",t:56,d:"Este cuero muy liso está especialmente adaptado para la elaboración de ropa interior de cuero, el Calzoncillo de Cuero del Chafer llega a ser un sorprendente ejemplo.",ep:1,g:534,l:2,wd:true,fm:true,w:1,p:1};
I.u[884] = {n:"Cuero de jalatín negro",t:56,d:"Este cuero reluciente es muy apreciado por los Zapateros y sastres, para la elaboración de pequeñas botas o sombreros.",ep:1,g:16,l:2,wd:true,fm:true,w:1,p:1};
I.u[885] = {n:"Lana de jalatín negro",t:57,d:"Esta lana áspera no es muy utilizada por los sastres, es en cambio muy apreciada por los anutrofs, que la usan para ocultar su incipiente calvicie.",ep:1,g:210,l:2,wd:true,fm:true,w:1,p:1};
I.u[886] = {n:"Cuero de Jalató Real",t:56,d:"Este cuero es real, tiene una flexibilidad extraordinaria y las grietas que lleva son los testigos de la larga vida del Jalató Real. No existe mejor cuero en toda la provincia de Amakna.",ep:1,g:535,l:35,wd:true,fm:true,w:1,p:4000};
I.u[887] = {n:"Cuero del jefe de guerra jalató",t:56,d:"\"Este cuero conoce cada guerra, cada herida, cada ser\" tales eran las palabras del famoso Trovador Badiz Mustabante, exactamente antes de morir asfixiado por el olor de un Jefe de Guerra Jalató.",ep:1,g:534,l:19,wd:true,fm:true,w:1,p:1};
I.u[888] = {n:"Grandes Botas de Concentración",t:11,d:"Estas botas son tan cómodas que permiten que el héroe que las lleve aumente su capacidad para concentrarse.",ep:1,g:6,l:26,wd:true,fm:true,w:15,p:1950};
I.u[889] = {n:"Poderosas Botas de Concentración",t:11,d:"Estas botas son tan cómodas que permiten que el héroe que las lleve aumente su capacidad para concentrarse.",ep:1,g:6,l:27,wd:true,fm:true,w:15,p:2200};
I.u[890] = {n:"Botas del jalató",t:11,d:"Estas botas están hechas con cuero de Jalató, permiten que los ganaderos puedan acercarse más fácilmente a los Jalatós para matarlos gracias al olor que desprenden.",ep:1,g:3,l:1,wd:true,fm:true,w:3,p:150};
I.u[891] = {n:"Botas del Gran Jalató",t:11,d:"Estas botas están hechas con cuero de Jalató, permiten que los ganaderos puedan acercarse más fácilmente a los Jalatós para matarlos gracias al olor que desprenden.",ep:1,g:3,l:2,wd:true,fm:true,w:4,p:200};
I.u[892] = {n:"Botas del Poderoso Jalató",t:11,d:"Estas botas están hechas con cuero de Jalató, permiten que los ganaderos puedan acercarse más fácilmente a los Jalatós para matarlos gracias al olor que desprenden.",ep:1,g:3,l:4,wd:true,fm:true,w:5,p:250};
I.u[893] = {n:"Pequeñas Dagas Silvestres",t:5,d:"Estas dagas fueron especialmente diseñadas para cortar raíces o pequeños brotes, ahora se usan para otros propósitos y se volvieron unas armas casi letales.",ep:1,g:6,l:20,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>20&CI>5",p:1300};
I.u[894] = {n:"Dagas Silvestres",t:5,d:"Estas dagas fueron especialmente diseñadas para cortar raíces o pequeños brotes, ahora se usan para otros propósitos y se volvieron unas armas casi letales.",ep:1,g:6,l:23,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>23&CI>5",p:1600};
