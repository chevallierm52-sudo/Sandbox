I.u[818] = {n:"Llave de Roca de Ded Asolas",t:12,d:"Esta pequeña llave de roca te abrirá la cueva de Ded Asolas. Pero antes tendrás que encontrarla...",ep:4,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[819] = {n:"Espada Sagrada",t:6,d:"Esta es una espada santa que se entrega a los jóvenes guerreros durante su formación.",ep:1,g:1,l:15,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>30&CV>3",p:800};
