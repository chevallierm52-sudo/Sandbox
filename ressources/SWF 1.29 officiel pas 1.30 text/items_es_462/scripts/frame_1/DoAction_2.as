I.u[901] = {n:"Cuero del cochinillo",t:56,d:"Este cuero muy liso se vuelve casi anaranjado con los años, pero huele también cada vez peor a lo largo del tiempo, un poco como los callos cuando se ponen a hervir...",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Pequeñas Botas de Klim",t:11,d:"La agilidad que confieren estas botas permitía a Klim el zapatero montar fácilmente sobre el lomo de cualquier jalató. Se murió al confundir un jalató con una gelatina, tras una noche demasiado alcoholizada en la taberna.",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Botas de Klim",t:11,d:"La agilidad que confieren estas botas permitía a Klim el zapatero montar fácilmente sobre el lomo de cualquier jalató. Se murió al confundir un jalató con una gelatina, tras una noche demasiado alcoholizada en la taberna.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Grandes Botas de Klim",t:11,d:"La agilidad que confieren estas botas permitía a Klim el zapatero montar fácilmente sobre el lomo de cualquier jalató. Se murió al confundir un jalató con una gelatina, tras una noche demasiado alcoholizada en la taberna.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Superpoderosas Botas de Klim",t:11,d:"Cuenta la leyenda que estas botas han sido intercambiadas por otras botas, defectuosas pero superpoderosas, que habían sido fabricadas por un torpe zapatero que no había dormido lo suficiente.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Pequeñas Botas de Persecución",t:11,d:"Hogmeiser podía con estas botas perseguir a los únicos seres vivientes que no soportaba, los niños. Afortunadamente para ellos, estas botas eran tan pesadas que no conseguía patearles el trasero.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Botas de Persecución",t:11,d:"Estas botas permitían a Hogmeiser perseguir a los únicos seres vivientes que no soportaba, los niños. Afortunadamente para ellos, estas botas eran tan pesadas que no conseguía patearles el trasero.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Botas de Superpersecución",t:11,d:"Estas botas permitían a Hogmeiser perseguir a los únicos seres vivientes que no soportaba, los niños. Afortunadamente para ellos, estas botas eran tan pesadas que no conseguía patearles el trasero.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Poderosas Botas de Persecución",t:11,d:"Estas botas permitían a Hogmeiser perseguir a los únicos seres vivientes que no soportaba, los niños. Afortunadamente para ellos, estas botas eran tan pesadas que no conseguía patearles el trasero.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Botas de Hogmeiser",t:11,d:"Estas botas pertenecieron durante años a Hogmeiser, antes de que las perdiese en una apuesta estúpida con Grizmoh Guay. Moraleja: Nunca juegues con un Zurcarák.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Botas Usadas de Hogmeiser",t:11,d:"Estas botas han pertenecido durante años a Hogmeiser, están tan usadas que son más que nada un estorbo. Un buenísimo Zapatero debería poder repararlas con un poco de suerte.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Botas Doradas de Hogmeiser",t:11,d:"Estas magníficas botas de Hogmeiser están revestidas con una capa fina de piedras preciosas para que resistan a determinados ataques mágicos. Estas botas son las que Brus Bulguro utilizó para aplastar la cabeza del Rey de los Abráknidos hace mucho tiempo, para animar la apertura de la Feria del Trool.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[913] = {n:"Gorro del Aprendiz Panadero",t:16,d:"Este gorro demostrará a todo el mundo que eres un aprendiz Panadero.",ep:0,g:258,l:1,wd:false,fm:true,w:1,p:10000};
I.u[914] = {n:"Gorro del Panadero",t:16,d:"Este gorro demostrará a todo el mundo que eres un Panadero.",ep:0,g:257,l:1,wd:false,fm:true,w:1,p:10000};
