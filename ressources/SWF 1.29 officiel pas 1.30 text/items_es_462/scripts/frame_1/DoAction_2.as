I.u[825] = {n:"Hoja del Bwork",t:6,d:"Esta espada aparentemente rudimentaria es muy apreciada por los bworks más estúpidos que no saben servirse de un arco o de un bastón, incluso algunos confunden el filo con el mango lo cual provoca la risa de sus adversarios.",ep:1,g:13,l:23,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>46&CA>8",p:1600};
