I.u[897] = {n:"Pequeñas Dagas Afiladas",t:5,d:"Estas dagas aparentemente modestas son sin embargo muy peligrosas. Además son fáciles de esconder las vuelve ideales para los asesinos.",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
I.u[898] = {n:"Dagas Afiladas",t:5,d:"Estas dagas aparentemente modestas son sin embargo muy peligrosas. Además son fáciles de esconder las vuelve ideales para los asesinos.",ep:7,g:10,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>33&CW>5",p:3100};
