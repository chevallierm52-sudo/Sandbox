I.u[9523] = {n:"Super recompensa de misión mercenaria",t:14,d:"Este super pergamino certifica que te mereces una super recompensa honorífica por tu dedicación en todas tus misiones con los mercenarios.",ep:0,g:6,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[9524] = {n:"Regalo: Escudo Atigrado",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9525] = {n:"Regalo: de San Valentón",t:89,d:"Este Regalo: contiene un kit de supervivencia para las operaciones amorosas más peligrosas.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9526] = {n:"Nota sobre las amenazas",t:24,d:"Para acordarte, has escrito en este pedazo de papel que no debes amenazar a un astrubiense cuando los mercenarios encargados de la seguridad de la ciudad anden cerca.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9527] = {n:"Polvos de uñas encarnadas",t:24,d:"Polvos de uñas encarnadas que en otro tiempo estaban en los pies de un anutrof. Mira que ha pasado ya tiempo... Pero aún apesta. Todo indica que te han dado miaumiau por wabbit.",ep:1,g:37,l:1,wd:false,fm:true,w:0,p:1};
I.u[9528] = {n:"Amuleto de Lear",t:24,d:"Este potente amuleto perteneció a Lear, un jefe de culto hoy desaparecido. Él estaba en contacto con criaturas extradimensionales y podía clonar las almas... o algo así. Tenía la facultad de autoresucitarse... un poder bastante práctico cuando no hay ningún cura cerca.",ep:9,g:48,l:1,wd:false,fm:true,w:0,p:1};
I.u[9529] = {n:"Pócima de Resurrección Forzosa",t:24,d:"A veces ocurre que un alma no puede o no quiere reencarnarse. En esos casos, utiliza esta poción: sirve para devolver, en contra su voluntad, las almas a su cuerpo de origen.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9530] = {n:"Caña para pischis embrujada",t:24,d:"Con un poco de suerte, con esta caña de pischis podrás pescar un pischis que tenga una lengua artija.",ep:0,g:739,l:1,wd:false,fm:true,w:0,p:1};
I.u[9531] = {n:"Lengua artija",t:24,d:"Este extraño órgano se utiliza con el método de la lengua artija.\nEste método engañoso consiste en hacer que la víctima se trague una lengua artija para que no pueda dejar de hablar ni gesticular por todos lados como si estuviese bailando la pektonita para hacer así que la víctima se canse rápidamente. Aún más interesante es el segundo efecto que produce: cuando la víctima está cansada creerá que la primera persona que vea es su mejor amiga, por lo que la hace más propensa a desvelar información.",ep:1,g:740,l:1,wd:false,fm:true,w:0,p:1};
I.u[9532] = {n:"Estatua de Sumens",t:24,d:"Esta es una de las dos estatuas que Maimane le ofreció a Sumens y que representan el bien y el mal de la humanidad. Debe su apariencia a un encantamiento de Sumens que la quería proteger de los aventureros codiciosos.\nPero aún quedan muchas preguntas por responder: ¿Esta estatua representa el bien o el mal? Y sobre todo, ¿por qué eligió una apariencia tan ridícula?",ep:14,g:738,l:1,wd:false,fm:true,w:0,p:1};
I.u[9533] = {n:"Piedra de alma seductora",t:24,d:"Embrujada por el maestro de la Orden del Ojo Putrefacto en persona, esta piedra de alma tiene la facultad de engatusar las almas que se dejan capturar sin ofrecer resistencia.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9534] = {n:"Piedra de alma de Terra Bitya",t:24,d:"Esta piedra de alma contiene el alma del anutrof Terra Bitya. Más te vale cuidarla bien si no quieres que tu alma vaya a hacer compañía a la del anutrof.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9535] = {n:"Poción de Transgénesis",t:24,d:"Si se utiliza bien, esta poción puede acelerar el crecimiento de los cereales al modificar sus genes. Evidentemente, ingerir estos cereales podría ocasionar algunos efectos secundarios, ¡¡pero tu no digas ni mú!! Los consumidores no pueden enterarse. \nNecesitas la ayuda de dos campesinos y dos alquimistas.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9536] = {n:"Pergamino de Transgénesis",t:24,d:"Este pergamino te ayuda a activar los efectos de la poción Transgénesis cuando ya hemos rociado con ella los cereales.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9537] = {n:"La Bendición de Nas Orazal",t:24,d:"Este libro, además de muchas historias locas de muertos que se levantan de sus tumbas y de fantasmas que hablan, explica el ritual para forzar a un alma a volver a su cuerpo.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9538] = {n:"Pócima de firma: memoria.",t:24,d:"Con esta pócima podrás acordarte de un recuerdo que la memoria pueda haber olvidado por descuido.",ep:0,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[9539] = {n:"Insignia del jefe de los renegados",t:24,d:"Le has robado esta insignia a un renegado bontariano que no la merecía.",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9540] = {n:"Capa del Padrino",t:17,d:"Esta capa te protegerá el cuello de la escarcha, aunque te deje el culo al aire.",ep:0,g:163,l:48,wd:true,fm:true,w:10,s:126,p:6200};
I.u[9541] = {n:"Sombrero Borsalino del Padrino",t:16,d:"El corte con clase de este sombrero de fieltro permite afirmarte en tu rol de padrino. ¿Te vas a privar de esto?",ep:0,g:234,l:43,wd:true,fm:true,w:10,s:126,p:5100};
I.u[9542] = {n:"Zapatos lacados del Padrino",t:11,d:"Estos zapatos brillan más que las luces de discoteca, incluso cando estén totalmente desgastados. También son muy útiles para cegar a tus adversarios cuando les pongas tu pie en sus narices.",ep:0,g:130,l:40,wd:true,fm:true,w:10,s:126,p:4450};
I.u[9543] = {n:"Anillote Gordo del Padrino",t:9,d:"Este pesado anillo le añadirá algo de inercia a tus guantazos, y un poco más de brillo a tus caricias.",ep:0,g:166,l:40,wd:true,fm:true,w:10,s:126,p:0};
I.u[9544] = {n:"Atormentador de Tinieblas",t:114,d:"El famoso Héroe Manitas Sinserrín confeccionó esta terrible arma mágica.Canaliza la energía mágica del que la use, y luego la transforma en poderosas descargas. Pero eso no es todo, porque esta arma mágica también cambiara la apariencia de quien la use, permiténdole usar nuevos hechizos. Su dueño se volverá otra persona y el Atormentador será su único amigo, hasta que decida dejar de utilizarlo.",ep:0,g:1,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
I.u[9545] = {n:"Atormentador de Llamas",t:114,d:"El famoso Héroe Manitas Sinserrín confeccionó esta terrible arma mágica.Canaliza la energía mágica del que la use, y luego la transforma en poderosas descargas. Pero eso no es todo, porque esta arma mágica también cambiara la apariencia de quien la use, permiténdole usar nuevos hechizos. Su dueño se volverá otra persona y el Atormentador será su único amigo, hasta que decida dejar de utilizarlo.",ep:0,g:2,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
I.u[9546] = {n:"Atormentador de Hoja",t:114,d:"El famoso Héroe Manitas Sinserrín confeccionó esta terrible arma mágica. Canaliza la energía mágica del que la use, y luego la transforma en poderosas descargas. Pero eso no es todo, porque esta arma mágica también cambiará la apariencia de quien la use, permiténdole usar nuevos hechizos. Su dueño se volverá otra persona y el Atormentador será su único amigo, hasta que decida dejar de utilizarlo.",ep:0,g:3,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
