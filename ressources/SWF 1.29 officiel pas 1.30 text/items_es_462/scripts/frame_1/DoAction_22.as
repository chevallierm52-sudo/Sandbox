I.u[9652] = {n:"Cinta para el pelo del Director Kuno",t:16,d:"Esta es la cinta de pelo ideal para secar tu frente cuando la emoción de una bella competición te embriague.",ep:0,g:236,l:48,wd:true,fm:true,w:10,s:129,p:6175};
I.u[9653] = {n:"Gorrump",t:16,d:"Las alitas de este gorra protegerán tus lindas orejitas de las palabrotas... pero sólo de las que tu digas.",ep:0,g:237,l:42,wd:true,fm:true,w:10,s:140,p:4825};
I.u[9654] = {n:"Capa del Director Kuno",t:17,d:"Ésta es la capa perfecta para esconder bajo ella las curvas de tu trasero, ¡o las de tu joroba!",ep:0,g:165,l:48,wd:true,fm:true,w:10,s:129,p:6105};
I.u[9655] = {n:"Sandalias del Director Kuno",t:11,d:"Unas sandalias con suela reforzada. Ideal para aguantar los balies y pisotones del Direktor Kuno",ep:0,g:132,l:49,wd:true,fm:true,w:10,s:129,p:6475};
I.u[9656] = {n:"Slumptines",t:11,d:"Con las ruedas de estos patines podrás bajar las escaleras sin ningún esfuerzo... eso sí, es muy probable que te partas algún hueso que otro. ¡Tú mismo!",ep:0,g:133,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9657] = {n:"Kakapinxo",t:4,d:"¿Quién le ha dado un nombre tan ridículo a este palo? A saber,... pero ahora tendrás que llamarlo así y tendras que poner pinta de tonto cuando te pregunten por el nombre de tu bastón.",ep:0,g:82,l:42,wd:true,fm:true,w:10,an:12,e:[1,3,1,1,10,40,false,false],c:"CV>60&CW>30",s:140,p:4200};
I.u[9658] = {n:"Amuleto del Director Kuno",t:1,d:"Este amuleto no es nada más que un surtido de flores atadas en torno a un hilo. Se supone que desprende un perfume mágico capáz de trasnformar a un chico en chica o incluso a su padre en panda.",ep:0,g:144,l:47,wd:true,fm:true,w:10,s:129,p:6000};
I.u[9659] = {n:"Collar Slump",t:1,d:"Elara tuvo este amuleto colgado al cuello toda su infancia. Aún nadie ha descubierto lo que guarda en su interior.",ep:0,g:143,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9660] = {n:"Capa de Sliat",t:17,d:"¿Qué siempre soñaste con tener dos colas? ¡Deseo concedido!",ep:0,g:166,l:47,wd:true,fm:true,w:10,s:128,p:5825};
I.u[9661] = {n:"Fantasma Miaumiau Angora",t:90,d:"Este fantasma no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[9662] = {n:"Anillo Sliat",t:9,d:"Este es el anillo preferido de la extraña raza de prespics azules quienes,  por alguna misteriosa razón, no pueden impedirse coleccionarlos hasta la saciedad.",ep:0,g:167,l:43,wd:true,fm:true,w:10,s:128,p:5100};
I.u[9663] = {n:"Orejillas de Sliat",t:16,d:"Estas orejillas pelirrojas son mucho más aerodinámicas de lo que pueda parecer a simple vista.",ep:0,g:238,l:49,wd:true,fm:true,w:10,s:128,p:6375};
