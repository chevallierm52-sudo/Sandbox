I.u[9557] = {n:"Llave del cofre",t:24,d:"Esta llave abre el cofre que, según Terra Bitya, contiene las estatuillas de Sumens.",ep:1,g:3,l:1,wd:false,fm:true,w:0,p:1};
I.u[9558] = {n:"Pócima de visiondaje",t:14,d:"Con esta pócima podrás ver a todos los personajes invisibles que estén a tu alrededor.",ep:0,g:73,l:1,wd:false,fm:true,w:1,c:"Pg>23,3",u:true,p:1};
I.u[9562] = {n:"Objeto extraño",t:24,d:"Este extraño objeto es verdaderamente extraño, pero lo más extraño es la extraña sensación que tienes de que sirve para acceder a un extraño lugar en los alrededores. ¿A que es extraño?",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9563] = {n:"Pelos de brakamriano",t:24,d:"Este manojo de pelo se lo han arrancado a una criatura desconocida que lucía la insignia de Brakmar. Ésta es la prueba irrefutable de que TÚ lo has visto.",ep:0,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[9564] = {n:"Insignia de un psicópata",t:24,d:"Has recuperado esta insignia del cadáver aún trémulo de un psicópata brakmariano. ¿No te da vergüenza abusar de los muertos?",ep:0,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9566] = {n:"Pararrayo cósmico",t:82,d:"Gladis Ney vivía en la miseria, rodeado de ratones, hasta que un día la cabeza de uno de ellos le sirvió de inspiración para forjar este escudo.  \nSupuestamente “mágico”, se dice que el escudo tenía el poder de proteger a los “HispaÑianos” de los efectos devastadores del rayo cósmico. ¡Se vendió como rosquillas! \nSin aventurarse mucho en las auténticas propiedades del escudo, lo que sí que hay que reconocerle es que tiene un aspecto bastante premonitorio.",ep:0,g:34,l:1,wd:false,fm:true,w:1,p:5000};
I.u[9567] = {n:"Gorro del Black Wab",t:16,d:"Con este gorro te será más facil metamorfosearte en vengador enmascarado, e incluso quizás en mascador envengarado. Como tú prefieras.",ep:0,g:235,l:49,wd:true,fm:true,w:10,s:127,p:6325};
I.u[9569] = {n:"Capa del Black Wab",t:17,d:"El pequeño pompón que pende a los pies de esta capa es muy eficaz para recojer el polvo de casa. Además, su pequeño tamaño te permitirá pasarlo hasta debajo de los muebles. Pero no te olvides de quitarlo cuando salgas a trabajar al campo.",ep:0,g:164,l:46,wd:true,fm:true,w:10,s:127,p:5600};
I.u[9570] = {n:"Semillas de sésamobolizante",t:58,d:"Esta semilla que ha sido modificada mágicamente hace que los músculos se desarrollen de una forma espectacular. Pero la parte negativa es que reduce de forma también espectacular la masa cerebral. Ahora todo empieza a encajar: es uno de los ingredientes esenciales de la alimentación de los yopukas.",ep:0,g:3,l:1,wd:false,fm:true,w:1,p:1};
I.u[9573] = {n:"Receta de las semillas de sésamobolizante",t:24,d:"Esta receta sólo la conocen unos cuantos alquimistas en todo el mundo. Mirleen ha aceptado dártela porque ya está cansado de que le molesten continuamente. \n7 semillas de sésamo \n5 setas \n1 Lucio rebosante \nPreparar previamente el lucio rebosante. Necesitarás que un pescadero mezcle 2 lucios destripados, 7 semillas de scorbuto, 2 mojos de mediulubo, 1 trozo de carne de cocodrail conservada y 2  trozos de vísceras de kitsu.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9575] = {n:"Cinturón del Black Wab",t:10,d:"Este cinto puede vestirse de los dos lados, según lo que prefieras mostrar o esconder...",ep:0,g:153,l:46,wd:true,fm:true,w:10,s:127,p:5600};
I.u[9576] = {n:"Botines del Black Wab",t:11,d:"Estos botines de piel de nalgas de Black Wabbit, te permitirán sentir que, a cada paso, les estarás pateando el culo a esas temibles criaturas. A veces, los mayores placeres de la vida son los más simples.",ep:0,g:131,l:47,wd:true,fm:true,w:10,s:127,p:5850};
I.u[9577] = {n:"Maldición de Assán Trapick",t:30,d:"No se qué te pasa, que pareces un viejo verde.",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9578] = {n:"Regalo: Gorro del Black Wab",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
