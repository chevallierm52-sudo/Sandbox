I.u[9153] = {n:"Amublop Guinda Real",t:1,d:"Este amuleto es mucho más caro de fabricar que un Amublop Guinda normal. Mira el lado bueno de la cosa, también lo puedes vender más caro ¡Sobre todo si consigues timar a un habitante de Astrub!",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
