I.u[9166] = {n:"Bloptas Multicolor Reales",t:11,d:"Con o sin relleno, estas botas seguirán siendo raras. Así que es inutil que intentes rellenarlas con algo que no sean tus pies.",ep:5,g:125,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9167] = {n:"Blopinturón Guinda",t:10,d:"Detrás de este nombre estúpido se esconde un cinturón muy original, del que no se conocen los defectos, y tampoco las virtudes. Lo que sí se sabe es que se le ha reconocido como \"de utilidad pública\" gracias a su extraordinaria protección de los michelines.",ep:5,g:136,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9168] = {n:"Blopinturón Reineta",t:10,d:"Detrás de este nombre estúpido se esconde un cinturón muy original, del que no se conocen los defectos, y tampoco las virtudes. Lo que sí se sabe es que se le ha reconocido como \"de utilidad pública\" gracias a su extraordinaria protección de los michelines.",ep:5,g:137,l:50,wd:true,fm:true,w:10,s:99,p:1000};
