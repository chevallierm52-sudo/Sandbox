I.u[9594] = {n:"Boluto del Padrino",t:18,d:"Este boluto parece bastante normal... Pero si lo miras con atención, te dará la sensación de que su lana oscurece en distintos sitios... Dale tiempo ¡Y puede que te dé una sorpresa!",ep:0,g:46,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9595] = {n:"Fantasma de Boluto del Padrino",t:90,d:"Este pequeño Boluto aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o decidir abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[9596] = {n:"Regalo: Boluto del Padrino",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9597] = {n:"Transformación fantasma Boluto del Padrino",t:27,d:"Has sido transformado en fantasma para poder penetrar en el santuario de las mascotas.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9598] = {n:"Certificado de admisión en la petrera: boluto del padrino",t:77,d:"Este certificado describe las características del boluto del padrino que has dejado en la petrera.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[9616] = {n:"Fantasma Cochino Jabato",t:90,d:"Este fantasma no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:40,l:1,wd:true,fm:true,w:1,p:1};
I.u[9617] = {n:"Miaumiau Angora",t:18,d:"Esta bola de pelos resiste mejor al frío que el Miaumiau común. Además su pelo es mas suave y sedoso, pero parece que su caracter es mucho más arisco. Esta criatura sólo come carne y pescado.",ep:0,g:50,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9618] = {n:"Regalo: Anillote Gordo del Padrino",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9619] = {n:"Pekewabbit hambriento",t:18,d:"Esta criatura es un tanto estúpida, el único modo de hacerla avanzar es atarle a la espalda un bastón del que cuelgue una zanahowia.\nAfortunadamente, esta mascota ha sido bien amaestrada y no intentará morderte;\r\n            de hecho, este devorador de almas sólo se alimenta de los restos de otros Wabbits",ep:0,g:51,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9620] = {n:"Miniminotot",t:18,d:"Esta criatura es un Minimino criado personalmente por el mismísimo Minotot. Éste le ha transmitido su horrible caracter y también algo de su olor corporal, de tanto llevarlo debajo del brazo. Este devorador de almas comerá los despojos de las criaturas de la Isla del Minotauroro.",ep:0,g:49,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9621] = {n:"Regalo: de Otros Mundos",t:89,d:"Esta mochila no estaba aquí hace un minuto... ¿Qué habrá dentro?  (HAZ DOBLE CLIC PARA UTILIZARLO)",ep:0,g:32,l:1,wd:false,fm:false,w:1,u:true,p:0};
I.u[9622] = {n:"Brote de la rosa de los tiempos",t:36,d:"La existencia de esta planta es tan misteriosa e inverosímil como su nombre. A la vez aquí y allá, pero no ahora;\r\n            por suerte no está en otra parte, porque entonces nada tendría sentido. Tendrás que llevarla al templo de Xelor (coordenadas 3,1), sólo unos iluminados como ellos podrán descifrar y entender alguno de sus misterios.",ep:0,g:638,l:1,wd:false,fm:false,w:1,p:0};
I.u[9623] = {n:"Cocodrail",t:18,d:"No te confies, tarde o temprano los puntiagudos dientes de esta criatura acabarán clavados en tu trasero. Esta mascota sólo come carne y pescado.",ep:0,g:47,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9624] = {n:"Dragún negro",t:18,d:"Coge un dragún rosa, tíñelo de negro, decóralo con polvo de oro, mételo en un baño de aceite y por último en un baño de agua. Obtendrás un falso dragún negro. Este devorador de almas sólo come los despojos de los dragohuevos.",ep:0,g:48,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9625] = {n:"Shigekax almendra",t:28,d:"Vuelve a disfrutar el sabor de las golosinas de antaño... con este caramelo de almendra preparado de forma tradicional. Humm... Este Shigekax sabe aun mejor si lo dejas desacerse bajo la lengua.",ep:0,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
