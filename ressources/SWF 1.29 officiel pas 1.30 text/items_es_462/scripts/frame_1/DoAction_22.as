I.u[9361] = {n:"Regalo: Anillo Objevivo",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9362] = {n:"Regalo: Capa Objeviva",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9363] = {n:"Regalo: Sombrero Objevivo",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9366] = {n:"Tutú rosa",t:10,d:"Este tutú rosa le quedará perfecto a tu hija pequeña para la representación teatral de fin de año. 100% mezcla de algodón ancestral y gomaespuma de Mob lasponja, lo que le garantiza suavidad y confort. Con el toque elegante de la faldita, este puede ser el primer tutú de una futura bailarina famosa.",ep:22,g:148,l:49,wd:true,fm:true,w:5,p:300};
I.u[9379] = {n:"Cajita de bombones y chocolates",t:42,d:"Puedes regalar este paquetín de bombones a la persona que ocupa tu corazón. Si éste está libre, siempre te los puedes comer tú mismo.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9380] = {n:"Hada-cohete invocadora de corazones",t:74,d:"Esta original hada-cohete te permitirá distribuir un poco de amor en este mundo de salvajes, y un poco de celo en este mundo de amor.",ep:1,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[9381] = {n:"Flor de bloponcio",t:35,d:"El bloponcio tiene un apetito tal que sería capaz de comerse sus propias flores. Por suerte, siempre encuentra algún aventurero imprudente que pasa cerca de sus fauces.",ep:5,g:7,l:50,wd:true,fm:true,w:1,p:1};
I.u[9382] = {n:"Flor de blopiseta",t:35,d:"Esta flor acaba de ser arrancada de la cabeza de una blopiseta. Viendo el aspecto ridículo que tenía con ella encima, no creo que vaya a venir quejándose.",ep:5,g:8,l:40,wd:true,fm:true,w:1,p:1};
I.u[9383] = {n:"Raíz de tronkoblop",t:98,d:"El tronkoblop tiene unas largas raíces que buscan por el suelo todo lo que pueden tirar los aventureros.",ep:5,g:1,l:40,wd:true,fm:true,w:1,p:1};
I.u[9384] = {n:"Flor de blop guinda real",t:35,d:"Si ésta no fuese una flor real, seguro que ya la habrías tirado.",ep:5,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[9385] = {n:"Flor de blop coco real",t:35,d:"Si ésta no fuese una flor real, seguro que ya la habrías tirado.",ep:5,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[9386] = {n:"Flor de blop índigo real",t:35,d:"Si ésta no fuese una flor real, seguro que ya la habrías tirado.",ep:5,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[9387] = {n:"Flor  de blop reineta real",t:35,d:"Si ésta no fuese una flor real, seguro que ya la habrías tirado.",ep:5,g:10,l:100,wd:true,fm:true,w:1,p:1};
I.u[9388] = {n:"Hoja de blop real",t:36,d:"Una vez seca, si se enrolla y se fuma, esta hoja puede provocar alucinaciones y ganas de ir al baño en las personas más débiles. En cualquier caso, su consumo excesivo es mortal.",ep:5,g:13,l:100,wd:true,fm:true,w:1,p:1};
I.u[9389] = {n:"Hoja de blop multicolor real",t:36,d:"Esta hoja se alimenta de la matiera gris del cerebro del blop multicolor real. Por suerte no es muy glotona...",ep:5,g:14,l:150,wd:true,fm:true,w:1,p:1};
I.u[9391] = {n:"Flor de blop multicolor real",t:35,d:"Esta flor se escondía en el interior de la cavidad craneal de un blop multicolor real. Allí puesta, le servía para tapar los agujeros de su memoria.",ep:5,g:13,l:150,wd:true,fm:true,w:1,p:1};
I.u[9394] = {n:"Blopisetombrero",t:16,d:"Este sombrero no sólo te dará clase y estilo fúngico, también te proporcionará un olor a sotobosque con el que te quedarás sin amigos.",ep:22,g:222,l:152,wd:true,fm:true,w:15,p:45782};
I.u[9395] = {n:"Bloprona Real",t:16,d:"Esta corona cubrió la cabeza de la mismísima Kuri durante vario años, hasta que ésta decidió estar más a la moda.",ep:22,g:223,l:161,wd:true,fm:true,w:10,p:47750};
I.u[9396] = {n:"El sello de los Dewuan",t:9,d:"En la antigua lengua Zolla, se llamam \"Dewuan Ling\". \nSe cuenta que Sauwon, el wabbit oscuro, lo forjó en la lava de un volcán escondido bajo Pandala Fuego.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PX=3|PX=5",p:1};
I.u[9401] = {n:"Piel de bworker",t:59,d:"Esta piel ha vivido todas las guerras sin siquiera sufrir un rasguño, ni siquiera se le nota el paso del tiempo ¡y vas tú y la arrancas! ... y además estarás orgulloso.",ep:14,g:9,l:400,wd:true,fm:true,w:10,p:1};
I.u[9402] = {n:"Zapatillánganos",t:11,d:"Las alitas que llevan estas zapatillas permiten aerear los pies malolientes. Cuidado, estas zapatillas no han sido homologadas para jugar al Jálabol, la Jalabola podría enfadarse si le pinchas el trasero.",ep:1,g:128,l:34,wd:true,fm:true,w:5,s:112,p:3200};
I.u[9403] = {n:"Mazaguijón",t:7,d:"Las alitas que tiene esta maza te permiten sentirla más ligera y facil de manejar. A veces hasta saldrá volando ella sola y te golpeará mientras duermes, sólo para reirse un poco de ti.",ep:1,g:68,l:27,wd:true,fm:true,w:12,an:15,e:[10,4,1,1,45,50,false,false],c:"CI>17&CC>5",s:112,p:2100};
I.u[9404] = {n:"Capa Kacebzz",t:17,d:"El aguijón que pende de esta capa es tan peligroso como tranquilizador. Cuidado, porque te lo puedes clavar al sentarte;\r\n            pero descansa, porque ya nadie intentará \"patearte el trasero\".",ep:1,g:155,l:33,wd:true,fm:true,w:5,s:112,p:3000};
I.u[9405] = {n:"Caskabeja",t:16,d:"¡Cuidado! Si te pones este casco, te arriesgas a recibir centenares de golpes de Mata-Moskitos en las antenas.",ep:1,g:224,l:37,wd:true,fm:true,w:9,s:112,p:3825};
I.u[9406] = {n:"Gochobits",t:16,d:"Estas orejas, aun frescas, de Puerkazo son muy útiles par ligar con las Puerkazas que se te crucen. No te rías, podría serte muy útil, A veces uno se siente muy solo en la inmensidad del campo de Amakna.",ep:1,g:225,l:36,wd:true,fm:true,w:2,s:113,p:3600};
I.u[9407] = {n:"Capa-corchos",t:17,d:"Algunos la llaman \"Saca-capa\" y sienten un odio feroz contra todos aquellos que la llaman de otro modo... Pero, la llames como la llames, esta capa no te será de ninguna utilidad para descorchar botellas.",ep:1,g:156,l:37,wd:true,fm:true,w:3,s:113,p:3800};
I.u[9408] = {n:"Jamonillo",t:9,d:"Con este anillo puesto en el dedo, podrás ser un auténtico Puerkazo, lo que no debería disgustar a tus amigos más cercanos.",ep:1,g:162,l:40,wd:true,fm:true,w:3,s:113,p:500};
I.u[9409] = {n:"Cinturón Tocinero",t:10,d:"Tu colita enroscada va a dar envidia a más de uno de tus amigos...",ep:1,g:149,l:39,wd:true,fm:true,w:1,s:113,p:4225};
I.u[9410] = {n:"Sombrero del Bosque del Este",t:16,d:"Menos de moda que el Clint, pero mucho más refinado, este sombrero te permitirá expresar tu coquetería sin límites.",ep:1,g:226,l:40,wd:true,fm:true,w:25,s:114,p:1000};
I.u[9411] = {n:"Capa del Bosque del Este",t:17,d:"Esta capa te portegerá de las insolaciones más graves. Atención, no a todos los aventureros les podrá llegar a las nalgas.",ep:1,g:157,l:36,wd:true,fm:true,w:10,s:114,p:6500};
I.u[9412] = {n:"Cinturón del Bosque del Este",t:10,d:"La honda que va atada con este cinto está muy bien atada. Tan bien atada que no la podrás desatar. Sólo sirve para impresionar a los forajidos que se crucen en tu camino.",ep:1,g:150,l:32,wd:true,fm:true,w:10,s:114,p:3000};
I.u[9413] = {n:"Botas del Bosque del Este",t:11,d:"Las espuelas que llevan estas botas, te permitirán estimular el cuero de tu Dragopavo. Tanto para que corra más rápido, como para trocearlos mejor si un día decides comértelo.",ep:1,g:129,l:30,wd:true,fm:true,w:10,s:114,p:2700};
I.u[9414] = {n:"Limogorro",t:16,d:"Este enorme limón vaciado recubrira perfectamente tu cabeza y la miníscula pepita que llevas adentro.",ep:1,g:227,l:30,wd:true,fm:true,w:9,s:115,p:2600};
I.u[9415] = {n:"Capa Gria",t:17,d:"Esta capa se ha confeccionado con multitud de hebras sacadas de las ralladuras de los cítricos más variados. Es tan bonita como refrescante;\r\n            pero no te molestes, ¡No brilla en la oscuridad!",ep:1,g:158,l:30,wd:true,fm:true,w:8,s:115,p:2525};
I.u[9416] = {n:"Anillo Ralladuro",t:9,d:"Si beber agua no te sabe a nada, mete el dedo con este anillo en tu vaso y remuévelo frenéticamente hasta que se suelte. Ahora tienes un delicioso cóctel de limón y naranja de sangre, también tienes un dedo menos... ¡Pero te siguen quedando nueve!",ep:1,g:163,l:20,wd:true,fm:true,w:4,s:115,p:1300};
I.u[9417] = {n:"Pajastón",t:4,d:"Si alguna vez soñaste con beber la sangre de tus enemigos mientras los golpeabas fuertemente, este bastón es lo que estabas esperando.",ep:1,g:81,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",s:115,p:2900};
I.u[9418] = {n:"Tocado Cristalino",t:16,d:"El próximo al que se le ocurra peinarte se va a llevar una sorpresa... ¡Y lo mismo se queda sin peine!",ep:1,g:228,l:22,wd:false,fm:true,w:12,s:125,p:1525};
I.u[9451] = {n:"Capa Cristalina",t:17,d:"Este impreionante pedazo de cristal puede servir de capa rígida. Quizás no te haga más fuerte, pero al menos podrás estar seguro de que el próximo monstruo que quiera devorarte se va a ahogar con ella.",ep:1,g:159,l:21,wd:false,fm:true,w:10,s:125,p:1400};
I.u[9452] = {n:"Anillo Cristalino",t:9,d:"Tu dedo nunca habrá brillado tanto como con este anillo puesto.",ep:1,g:164,l:30,wd:false,fm:true,w:4,s:125,p:2600};
I.u[9453] = {n:"Cinto Cristalino",t:10,d:"¿Quieres esconder tus michelines? Nada mejor que el ¡¡Cinto Cristalino!! No sólo rompera tu silueta con sus reflejos, sino que además tus amigos dejarán de pellizcarte (para no cortarse los dedos).",ep:1,g:151,l:48,wd:false,fm:true,w:30,s:125,p:6075};
I.u[9454] = {n:"Pompamuleto",t:1,d:"Este amuleto podría servir de babero para los más jóvenes y los más viejos.",ep:1,g:140,l:27,wd:false,fm:true,w:5,s:124,p:2200};
I.u[9455] = {n:"Pompanillo",t:9,d:"Este anillo te lo puedes poner en los dedos de los piés... si es que tienes ciertos olores que esconder",ep:1,g:165,l:30,wd:false,fm:true,w:4,s:124,p:2600};
I.u[9456] = {n:"Capompón",t:17,d:"Si te parece que tu trasero nunca ha recibido toda la atención que se merece, aun estás a tiempo de ponerte esta larga capa que centrará en el todas las miradas.",ep:1,g:160,l:33,wd:false,fm:true,w:5,s:124,p:3075};
I.u[9457] = {n:"Pompombrero",t:16,d:"Este sombrero desprende un olor tan fuerte a Rosa Demoníaca que hará que todos los piojos que poblaban tu cabeza salgan corriendo, y también todos los parásitos que se hacen pasar por amigos.",ep:1,g:229,l:33,wd:false,fm:true,w:5,s:124,p:3000};
I.u[9459] = {n:"Lista de regalos de Chanta Klaus",t:24,d:"Chanta Klaus siempre cuida con mucho cariño las listas de regalos que le dan los niños que devora. \n¿Todavía no habías escrito la tuya? Aquí tienes una",ep:1,g:41,l:1,wd:false,fm:true,w:0,p:0};
I.u[9460] = {n:"Pikapiña",t:24,d:"Aquí tienes un pikabeto que no crecerá nunca",ep:1,g:123,l:1,wd:false,fm:true,w:0,p:0};
I.u[9461] = {n:"El Kim",t:16,d:"Se dice que el Kimbo lleva esta peluca porque le recuerda a un joven y bronceado efebo que un día conoció en su isla y cuya sonrisa le encandiló. Así todo, se la pone bajo su coco ya que la encuentra ridícula.",ep:22,g:230,l:196,wd:true,fm:true,w:10,p:60000};
I.u[9463] = {n:"Amunito",t:1,d:"Este amuleto tiene tal poder que mataría a un moskito a 30 pasos de distancia, si tan sólo su olor no alejase a los moskitos a más de un kilómetro a la redonda.",ep:23,g:141,l:189,wd:true,fm:true,w:10,s:107,p:58000};
I.u[9464] = {n:"Kralamansion",t:1,d:"Este horrible amuleto vivió muchos años escondido en una mansión perdida en lo alto de una colina. Antaño quería conquistar el mundo, pero ahora se tendrá que conformar con tu cuello... ¡El pobre!",ep:22,g:142,l:194,wd:true,fm:true,w:30,s:97,p:58411};
I.u[9468] = {n:"Pala Emélaka",t:8,d:"Esta pala es muy peligrosa, te robará tu vitalidad, tu juventud, el agua de tu cuerpo y hasta tus preciosos gatrools.",ep:22,g:51,l:191,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,35,50,false,false],c:"CC>450",p:58401};
I.u[9469] = {n:"Espada Bama",t:6,d:"Esta espada, construida con fragmentos de micosis, será perfecta para parasitar los intestinos de tus enemigos.",ep:23,g:85,l:184,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,50,50,false,false],c:"CC>300&CA>300",p:58456};
I.u[9471] = {n:"Sombrero de San Valentón",t:16,d:"Valentines, Valentinas, este sombrero está especialmente diseñado para vosotros que buscáis vuestro medio pomelo. Efectivamente, ningún aventurero casado podrá ponerse nunca este gorro en la cabeza;\r\n            así podréis reconocer de un vistazo a los aventureros o aventureras cuyo corazón aún no haya sido conquistado.",ep:1,g:231,l:1,wd:false,fm:true,w:1,c:"PR=0",p:1};
I.u[9472] = {n:"Shigekax fruta de la pasión",t:42,d:"Famoso por sus virtudes afrodisíacas, este caramelo suave y dulce es el regalo ideal para los seres queridos.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9473] = {n:"Globo corazoncito",t:94,d:"La leyenda cuenta que Rodrigo, harto de que le preguntaran constatemente si tenía un corazón grande, se dedido a hinchar el corazón de todos los pasantes. En su honor, el mago Don Chahin creó la receta del gobo de corazoncito. Hay que soplar en un corazón de jalató con sonroseo que acabe de ser arrancado y aún esté palpitante. Luego haz un agujero en el ventrículo izquierdo y espolvorealo con amor liofilizado. Y ya está. ¡Qué romántico!",ep:0,g:14,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9474] = {n:"Sublime piedra de alma azarosa",t:83,d:"Esta runa te da un poquito de suerte para capturar almas cuya potencia es simplemente increible.",ep:0,g:17,l:1,wd:false,fm:true,w:1,tw:true,p:23000};
I.u[9475] = {n:"Sublime piedra de alma",t:83,d:"Esta runa te da suerte para capturar almas cuya potencia es simplemente increible.",ep:0,g:16,l:1,wd:false,fm:true,w:1,tw:true,p:50000};
I.u[9476] = {n:"Sublime piedra de alma feliz",t:83,d:"Esta runa te ofrece una gran posibilidad de capturar almas cuya potencia es simplemente increíble.",ep:0,g:18,l:1,wd:false,fm:true,w:1,tw:true,p:75000};
I.u[9479] = {n:"Poshopeinado",t:16,d:"Con el clavo de este peinado se te puede abrir una vía de escape para los humos que se te suban, antes de que te explote la cabeza.",ep:1,g:232,l:45,wd:true,fm:true,w:23,s:123,p:1000};
I.u[9480] = {n:"Poshocapa",t:17,d:"Con la bonita diana que decora esta capa, los enemigos no tendrán escusa si fallan cuando te golpean.",ep:1,g:161,l:33,wd:true,fm:true,w:10,s:123,p:3000};
I.u[9481] = {n:"Poshoscudo",t:82,d:"El clavo que atraviesa este escudo puede serte útil en el cuerpo a cuerpo... si lo que quieres es pinchar a tu rival hasta que se raje.",ep:1,g:36,l:1,wd:true,fm:true,w:1,s:123,p:1};
I.u[9482] = {n:"Cigarrescudo",t:82,d:"Si tus amigos huyen corriendo al ver tu cara de feo, ahora tienes el ¡¡Cigarrescudo!! ¡Escóndete detrás de él y seguirás siendo igual de feo! Pero al menos ¡Parecerás más simpático!.",ep:1,g:37,l:1,wd:true,fm:true,w:1,s:122,p:1};
I.u[9483] = {n:"Escudo Boh-Bihna",t:82,d:"Este escudo perteneció al célebre sádida Boh. A pesar de que los Bihna eran una familia que ilustró los mejores manuscritos, Boh quería ser guerrero. Se inventó este escudo en el que guardaba muchas imágenes y, si su padre venía, podía sacarlas muy rápido para impresionarle.",ep:1,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[9484] = {n:"Escudo Atigrado",t:82,d:"Este escudo no cubre totalmente a su dueño, pero te protegerá contra los fantasmas.",ep:1,g:39,l:1,wd:true,fm:true,w:1,p:1};
I.u[9485] = {n:"Cigacapa",t:17,d:"Las bolitas que adornan esta capa sirven para bolear a los enemigos... Pero antes tienes que aprender a hacer la peonza.",ep:1,g:162,l:30,wd:true,fm:true,w:10,s:122,p:2500};
I.u[9486] = {n:"Cigacofia",t:16,d:"Aunque no te pongas esta cofia, seguirás pareciendo un bufón. Pero si te la pones, al menos tendrás una buena escusa.",ep:1,g:233,l:33,wd:true,fm:true,w:10,s:122,p:3075};
I.u[9487] = {n:"Certificado de cambio de alineación",t:24,d:"Morry Gann te dio este certificado. Contiene varias informaciones que te conciernen, entre ellas tu cambio de alineación.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9488] = {n:"Registro de Bonta",t:24,d:"Este registro pertenece a Morry Gann y contiene muchos documentos de cómo llegar a ser bontariano. Tendrás que cumplimentar una página.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9489] = {n:"Registro de Brakmar",t:24,d:"Este registro pertenece a Morry Gann y contiene muchos documentos de cómo llegar a ser brakmariano. Tendrás que cumplimentar una página.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9490] = {n:"Certificado de órdenes número 5",t:24,d:"Este certificado asegura que perteneces a una orden en concreto. Para cambiar de orden, tendrás que esperar siete días a partir de la fecha de entrega de este certificado. Tienes derecho a cambiar de opinión, pero no te pases.",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9491] = {n:"Maldición del sonroseo agudo",t:30,d:"¡Acabas de atrapar el sonroseo agudo! Ahora lo verás todo de color de rosa, y además serás feliz.",ep:1,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9492] = {n:"Regalo: Zapatillánganos",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9493] = {n:"Regalo: Mazaguijón",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9494] = {n:"Regalo: Capa Kacebzz",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
