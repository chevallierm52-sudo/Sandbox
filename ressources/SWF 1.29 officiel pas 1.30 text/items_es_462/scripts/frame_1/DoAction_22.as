I.u[9157] = {n:"Amublop Multicolor Real",t:1,d:"Sin aditivos ni colorantes, este amuleto sería transparente. Puedes estar tranquilo, nadie te va a pedir que te lo comas.",ep:5,g:136,l:90,wd:true,fm:true,w:10,s:106,p:21000};
I.u[9158] = {n:"Bloptas Guinda",t:11,d:"No te quejes porque el nombre de estas botas sea impronunciable, esta particularidad ¡Puede salvarte la vida! Imagínate que un asalta caminos te detiene diciéndote: \"Dame tus Blotaps. No, tus Blotpas. No, tus Plobtas. No, tus...\"  Tendrás todo el tiempo necesario para salir por piernas.",ep:5,g:117,l:50,wd:true,fm:true,w:10,s:98,p:1000};
