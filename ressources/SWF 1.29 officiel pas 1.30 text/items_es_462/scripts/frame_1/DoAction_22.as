I.u[9718] = {n:"Gargantuesca piedra de alma perfecta",t:83,d:"Única en su especie, esta piedra fue concebida con un único objetivo: capturar el alma del kralamar. Esto se nota en su aspecto... y también en su olor.",ep:0,g:24,l:1,wd:false,fm:true,w:1,tw:true,c:"Qa=439",p:0};
