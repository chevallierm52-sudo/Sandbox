I.u[9627] = {n:"Bastón del aprendiz peregrino",t:4,d:"A veces, los dioses escogen a ciertas personas para que ayuden al prójimo en toda circunstancia. Éste es el bastón que identifica a los elegidos de esa noble empresa.",ep:0,g:1,l:1,wd:false,fm:true,w:0,an:12,tw:true,e:[0,42,1,1,42,42,false,true],c:"PL<6",p:0};
