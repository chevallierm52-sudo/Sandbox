I.u[1543] = {n:"Fragmento del pedestal de la Cocobur",t:24,d:"Este es un fragmento del Pedestal donde la tristemente célebre espada de Cocoburio, la Cocobur, ha dormido y seguirá tal vez durmiendo durante siglos, impregnando poco a poco la piedra con su poderosa magia.",ep:1,g:28,l:1,wd:true,fm:true,w:0,p:1};
