I.u[1403] = {n:"Martillo Haimito",t:7,d:"Este martillo perteneció a Haimito, un joven discípulo de Osamodas que se pasaba el tiempo contando chistes estúpidos. Su martillo, no te volverá más inteligente que Haimito pero a veces puede apaciguar tensiones.",ep:1,g:3,l:23,wd:true,fm:true,w:20,an:15,e:[4,4,1,1,30,30,false,true],c:"CA>20",p:1700};
I.u[1404] = {n:"Martillo Bestial",t:7,d:"¿Te gustan los animales? A Besti también. Incluso les había dedicado su vida. Este martillo cuenta un poco su historia: una gran comunión con los animales, tan ágil como un jalató cojo con sólo 2 dedos en cada pata.",ep:5,g:15,l:35,wd:true,fm:true,w:35,an:15,e:[6,4,1,1,30,30,false,true],c:"CI>80&CW>30",p:3400};
I.u[1405] = {n:"Pócima Agua de Hada",t:12,d:"Esta pócima consigue reproducir los mismos poderes de curación que tiene la sangre de Aniripsa. Ahora ya no necesitas desangrarlas a todas.",ep:3,g:41,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1406] = {n:"Sangre de urikornio",t:12,d:"Esta pócima reproduce con fidelidad los efectos de las sangre del urikornio, excepto el rollo ese de la inmortalidad. \"Bébetela y todos tus males serán curados\" decía el eslogan.",ep:3,g:40,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
