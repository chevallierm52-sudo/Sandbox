I.u[1399] = {n:"Maza Clavito",t:7,d:"Como el amuleto del mismo nombre, la Maza Clavito tiene la particularidad de transformar tu energía vital en potencia. Consúmase con moderación...",ep:1,g:12,l:15,wd:true,fm:true,w:15,an:15,e:[5,5,1,1,40,40,false,true],p:1500};
