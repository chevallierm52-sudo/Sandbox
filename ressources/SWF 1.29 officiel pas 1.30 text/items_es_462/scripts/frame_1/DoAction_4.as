I.u[1426] = {n:"Pala Patarta",t:8,d:"Patarta fue el creador de esta pala, era un discípulo de Yopuka. Un nombre predestinado para un Yopuka ¿Verdad?",ep:3,g:8,l:24,wd:true,fm:true,w:24,an:16,e:[5,5,1,1,50,50,false,true],p:1800};
I.u[1427] = {n:"Pala Zebuth",t:8,d:"Los Sacerdotes Kaníbolas de la isla de Moon utilizan esta pala para invocar a Zébuth, una de sus divinidades a menudo representada bajo una forma vacuna. Sólo los viles personajes pueden utilizar esta arma.",ep:1,g:40,l:55,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,50,20,false,true],c:"Ps=2&CC>50",p:8000};
I.u[1428] = {n:"Inmortal",t:36,d:"Esta extraña plantita crece en los sitios áridos, y desprende un olor a curry a los alrededores. Muy resistente, no parece sufrir los asaltos del tiempo... Si tan sólo se pudiera decir lo mismo de todas las mujeres...",ep:2,g:54,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1429] = {n:"Palita Frutera",t:8,d:"Esta pala era utilizada por los anutrofs para recoger frutas en los árboles, pero también puede resultar un arma de combate temible. Como diría su creador, el viejo Joudi: \"Ezta ez mi pala, hay muzas como ezta, pero ezta ez la mía y ez la máz bonita\".",ep:1,g:19,l:30,wd:true,fm:true,w:15,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>10&CI>10",p:1500};
I.u[1430] = {n:"Pala Frutera",t:8,d:"Esta pala era utilizada por los Anutrofs para recoger frutas en los árboles, pero también puede resultar un arma de combate temible. Como diría su creador, el viejo Joudi: \"Ezta ez mi pala, eczizten muzas como ezta, pero ezta ez la mía y ez la máz bonita\".",ep:1,g:19,l:45,wd:true,fm:true,w:23,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>15&CI>15",p:2300};
I.u[1431] = {n:"Gran Pala Frutera",t:8,d:"Esta pala era utilizada por los Anutrofs para recoger frutas en los árboles, pero también puede resultar un arma de combate temible. Como diría su creador, el viejo Joudi: \"Ezta ez mi pala, eczizten muzas como ezta, pero ezta ez la mía y ez la máz bonita\".",ep:1,g:19,l:60,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>25&CI>25",p:3000};
I.u[1432] = {n:"Pala de Kolokón",t:8,d:"Kolokón era un jardinero discípulo de Anutrof, tenía cierta tendencia en abusar demasiado de las plantas. Esta arma lo demuestra: es tan poderosa que te puede dar mareos y engañar tu sentido de la percepción.",ep:1,g:17,l:21,wd:true,fm:true,w:21,an:16,e:[2,4,1,1,50,50,false,true],c:"CC>27&CW<100&CS>10",p:2100};
I.u[1433] = {n:"Pala Defensiva",t:8,d:"Esta pala fue el arma de defensa personal de un pequeño grupo de Anutrofitas. Estas damas, una vez el instrumento de potencia entre sus manos, cambiaron completamente e intentaron conquistar el mundo.",ep:7,g:4,l:60,wd:true,fm:true,w:30,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>60&CS>30&CA>10",p:6500};
