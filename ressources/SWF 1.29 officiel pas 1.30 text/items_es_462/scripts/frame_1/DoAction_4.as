I.u[1383] = {n:"Martillo Konda",t:7,d:"Este martillo ha sido forjado durante años y años, por decenas de herreros. Al final, llega a ser una espléndida arma, pero que heredó desgraciadamente de una determinada idea de la velocidad por parte de sus creadores.",ep:1,g:5,l:55,wd:true,fm:true,w:20,an:15,tw:true,e:[8,4,1,1,50,50,false,false],p:8000};
