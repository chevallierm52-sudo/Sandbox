I.u[1511] = {n:"Nueve Colas",t:6,d:"Cuenta la leyenda que un zurcarák utilizó, durante el dantesco combate que lo elevó al rango de dios, una arma hecha con sus propias colas, cada una correspondía a una de sus vidas.",ep:13,g:19,l:80,wd:true,fm:true,w:20,an:14,e:[9,9,1,1,20,20,false,false],c:"CS>99&CA>99&CV>99",p:20000};
I.u[1512] = {n:"La Leyenda del Cocoburio",t:25,d:"Este libro describe la historia del tristemente célebre Cocoburio.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1514] = {n:"Pócima de olvido: \"Contragolpe\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo de Zurcarák: \"Contragolpe\".",ep:2,g:27,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1515] = {n:"Huevo de bwak de fuego",t:72,d:"Este huevo puesto por un kwak de llama está a punto de abrirse... Aunque sean muy agresivos desde su nacimiento, los bwaks nunca atacan a sus padres.",ep:1,g:59,l:1,wd:true,fm:true,w:1,u:true,p:100};
