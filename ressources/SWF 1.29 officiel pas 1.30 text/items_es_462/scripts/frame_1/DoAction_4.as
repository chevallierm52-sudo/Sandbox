I.u[1342] = {n:"Pócima de Ráfaga",t:26,d:"Esta pócima silbante se utiliza generalmente para hechizar correctamente todas las clases de objetos gracias a la magia de aire que lleva atrapada.",ep:9,g:3,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1343] = {n:"Pócima de Flameación",t:26,d:"Esta pócima crepitante se utiliza generalmente para hechizar correctamente todas las clases de objetos gracias a la magia de fuego que lleva atrapada.",ep:9,g:1,l:25,wd:true,fm:true,w:1,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1344] = {n:"Verbena",t:36,d:"Esta planta especial permite hacer que cualquier persona se duerma mucho más fácilmente. Eso debe probablemente ser el emblema del Sadida.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1345] = {n:"Pócima de Incendio",t:26,d:"Esta pócima fulminante se utiliza generalmente para hechizar poderosamente un poco todas las clases de objetos gracias a la potente magia de fuego que lleva atrapada.",ep:4,g:1,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1346] = {n:"Pócima de Tsunami",t:26,d:"Esta pócima inundadora se utiliza generalmente para hechizar poderosamente un poco todas las clases de objetos gracias a la potente magia de agua que lleva atrapada.",ep:4,g:2,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1347] = {n:"Pócima de Huracán",t:26,d:"Esta pócima ululadora se utiliza generalmente para hechizar poderosamente un poco todas las clases de objetos gracias a la potente magia de aire que lleva atrapada.",ep:4,g:3,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1348] = {n:"Pócima de Seísmo",t:26,d:"Esta pócima tragadora se utiliza generalmente para hechizar poderosamente un poco todas las clases de objetos gracias a la potente magia de tierra que lleva atrapada.",ep:4,g:4,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1350] = {n:"Arco Hólico",t:2,d:"Este arco ha sido creado por un mago que le tenía un cariño muy especial a su botella. Para acabar con su dependencia sentimental, inventó este arco especializado en el agua.",ep:3,g:4,l:15,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,3,6,30,50,false,true],p:250};
I.u[1351] = {n:"Arco de Charra",t:2,d:"\"Con semejante arco, te largas o te mato\" dice el refrán. Los más sabios evitarán esta arma, pues dicen que atrae el mal de ojo...",ep:1,g:51,l:30,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,10,10,false,true],c:"CC>30",p:1600};
I.u[1352] = {n:"Arco de Boo",t:2,d:"Este arco saca su poder tanto de la tierra como del agua. Pobre del que no domine el uno ni el otro.",ep:2,g:6,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],p:5000};
I.u[1353] = {n:"Arco de Madero",t:2,d:"Antiguamente, este arco era el símbolo de la lucha del bien contra el mal. Hoy en día todavía se puede sentir, al tocarlo, una agradable sensación de poder y de superioridad social... Aunque será mejor no enseñarlo si te paseas solo por los bajos fondos de la ciudad de Bonta.",ep:12,g:10,l:41,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"Ps=1&Pa>10&CI>30&CW>30",p:200};
I.u[1354] = {n:"El Arco Hips",t:2,d:"Hips era un ocra maldito: no conseguía librarse de su hipo. Sin embargo un día acabó echando su arco al fuego para reemplazarlo por una espada y su mal desapareció misteriosamente.",ep:13,g:11,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,6,40,40,false,true],p:1000};
I.u[1355] = {n:"Arco Desade",t:2,d:"El creador de este arco, un noble llamado Desade, nunca supo muy bien cómo manipularlo. Al igual que podía infligir tremendos daños a sus enemigos, también podía herirse él mismo.",ep:14,g:12,l:40,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,7,30,50,false,true],p:4000};
I.u[1356] = {n:"Bio Varita",t:3,d:"El panadero Raguiñano fue famoso por haber sido el primer Aniripsa en hacer su pan con  levadura biológica. Como su invento no tuvo ningún éxito, ha tenido que vender su panadería y empezar una nueva vida como actor de teatro ambulante. Qué triste.",ep:1,g:13,l:11,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,30,50,false,true],p:1000};
I.u[1357] = {n:"Varidaga",t:3,d:"un escultor un poco bromista quiso hacer pasar sus varillas por dagas. Su estratagema no tuvo ningún éxito pero sus dagas sí que lo tuvieron...",ep:7,g:17,l:35,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,40,40,false,true],c:"CI>25",p:3500};
I.u[1359] = {n:"El Tizón Zippón",t:3,d:"Los orígenes de esta varita siguen siendo muy oscuros. Sin embargo, es muy apreciada por los aventureros ya que con ella pueden encender hogueras, quemarse las sanguijuelas, los pelos del pecho y además es muy útil para encontrar su camino en las noches muy oscuras... Por cierto, por mucho que sople el viento, no se apaga nunca.",ep:9,g:12,l:59,wd:true,fm:true,w:10,an:11,e:[7,3,2,3,30,50,false,true],c:"CI>70&CS>30",p:5000};
I.u[1360] = {n:"La Hyldegard",t:3,d:"Esta varita ha sido creada, hace muchísimos años en las llamas de la forja del Muro Doro. Esta arma requiere tener agua a tu alcance para poder dominar su fuego interior...",ep:13,g:8,l:48,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],p:4800};
I.u[1361] = {n:"Varita Prismática",t:3,d:"La Varita Prismática tiene el extraño poder de conferir una vista agudísima al que la posea. Luego le tocará a esta persona ser lo suficientemente rápida para poder escapar del peligro que se acerque.",ep:1,g:15,l:43,wd:true,fm:true,w:10,an:11,e:[4,5,2,2,40,40,false,true],c:"CA>80",p:4000};
I.u[1362] = {n:"Estaca Vampírica",t:3,d:"La Estaca Vampírica es en realidad la varita de un vampiro que se retiró desde hace tiempo de la vida social y de la carnicería. Sin embargo, este extraño cacho de madera ha conservado algunas de las ventajas de su antiguo amo...",ep:7,g:14,l:65,wd:true,fm:true,w:10,an:11,e:[5,6,2,3,50,20,false,true],c:"CA>30&CW<60",p:4000};
I.u[1363] = {n:"Bastón Tontolonero",t:4,d:"Además de su insoportable nombre, este bastón tiene muchas más formas de hacer que su dueño se vuelva loco de ira.",ep:1,g:5,l:40,wd:true,fm:true,w:10,an:12,e:[5,5,1,1,5,5,false,true],c:"CI<100",p:5000};
I.u[1364] = {n:"Bastón del Olvido",t:4,d:"Este bastón hace que su dueño olvide todos sus problemas y sus pensamientos negativos. Desfortunadamente, también pierde a veces una parte de su memoria y provoca problemas de concentración cada vez más frecuentes. Reservado para los más sabios...",ep:13,g:11,l:30,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,true],c:"CW>50",p:3000};
I.u[1365] = {n:"Bastón Torrón",t:4,d:"Torrón era un temible guerrero con su bastón. Incluso algunos decían que era inmortal... hasta el día en que se murió asfixiado. Se había olvidado de respirar.",ep:1,g:68,l:20,wd:true,fm:true,w:15,an:12,e:[8,5,1,1,50,40,false,true],p:2000};
I.u[1366] = {n:"Bastón de Jalatero",t:4,d:"Se trata aquí de un bastón muy utilizado por los jalateros durante la trashumancia. Pues a los bworks les encanta saborear los rebaños de jalatós cortados en finas lonchas para el aperitivo (el plato fuerte llegaba a ser el propio jalatero).",ep:9,g:9,l:12,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,true],p:1200};
I.u[1367] = {n:"Bastón de Dina Mita",t:4,d:"Este bastón perteneció a la elegante y bella Dina Mita. Esta era sobre todo famosa por sus curvas encantadoras y su carácter... explosivo. Vamos, que era una auténtica bomba.",ep:13,g:6,l:40,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,30,50,false,true],c:"CI>50&CA>40",p:4000};
I.u[1368] = {n:"Bastón Extintor",t:4,d:"Este bastón perteneció a uno de los valientes bomberos de Amakna que combatieron el fuego de un Dragonito en mal de sensaciones fuertes. Necesitarás valor y fuerza para poder usar este bastón.",ep:1,g:18,l:29,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,true],c:"CC>10",p:2500};
I.u[1369] = {n:"Los Cuchillos Jinsu",t:5,d:"Se supone que estos cuchillos eran de cocina y eran para un lujoso restaurante, pero cuando el chef se percató del aspecto más bien extraño que tenían, los vendió a un lanzador de cuchillos ambulante.",ep:1,g:13,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>55&CC>5",p:3000};
I.u[1370] = {n:"Ergot Mina",t:5,d:"La empuñadura de esta arma está grasienta y resbala mucho, pero tiene una pinta muy chula.",ep:1,g:14,l:20,wd:true,fm:true,w:10,an:13,e:[8,3,1,1,50,50,false,true],p:2000};
I.u[1371] = {n:"Dagas de Kaka",t:5,d:"Kaka era un jalatero del norte de Amakna que un día encontró en medio del estiércol de sus jalatós, un par de dagas ligeramente manchadas. Quien las use que tenga mucho cuidado: el mango resbala por lo cual es muy fácil fallar su ataque con ellas.",ep:1,g:10,l:40,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>40",p:4000};
I.u[1372] = {n:"Dagas Olina",t:5,d:"Olina era una legendaria discípula de Sram que se pasó la vida entera buscando una nueva fuente de riqueza que según ella revolucionaría los métodos de producción. Estas dagas han sido encontradas junto a su cadáver... la pobre se había caído dentro de un pozo de barro negro y viscoso. Los del pueblo taparon el agujero al día siguiente para evitar que se repitieran otros accidentes tan estúpidos como este.",ep:9,g:19,l:44,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5300};
I.u[1373] = {n:"La Afeitadora Infernal",t:5,d:"Nosa Afeyta era una vieja discípula Anutrof que tenía barba, como todos los discípulos de Anutrof dignos de su condición. Cuando el señor Afeyta le regaló este cuchillo para su cumpleaños, ella prefirió utilizarlo para luchar...",ep:1,g:17,l:30,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1374] = {n:"Daga Ligra Fía",t:5,d:"Ligra Fía era un escriba que vivió hace muchos siglos. Tenía la particularidad de grabar sus cuadernos de piedra con esta daga en vez de utilizar un buril. De este ilustre personaje sólo nos ha quedado esta hermosa daga, cuya resistencia a los choques es impresionante.",ep:1,g:12,l:30,wd:true,fm:true,w:13,an:13,e:[10,3,1,1,30,50,false,false],c:"CS>50",p:3000};
I.u[1375] = {n:"Hacha Al-Terófilo",t:19,d:"Al-Terófilo era un discípulo Yopuka capaz de levantar pesos impresionantes. Pero desafortunadamente para él, igual que para todos los Yopukas demasiado musculosos, la inteligencia no era su fuerte.",ep:1,g:14,l:15,wd:true,fm:true,w:25,an:17,e:[10,5,1,1,50,50,false,true],c:"CS>70&CI<10",p:800};
I.u[1376] = {n:"Hacha Kador",t:19,d:"Esta hacha, a veces difícil de manejar, es perfecta para acabar con los Trools: las runas mágicas que leva grabadas permiten quemar a los enemigos.",ep:7,g:15,l:35,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,50,false,true],c:"CS>50",p:3000};
I.u[1377] = {n:"Hacha Mahn",t:19,d:"Mahn era un sacerdote que no vacilaba en usar las armas para que progresara la fe en Amakna. Su arma predilecta era un hacha sobre la cual dibujó numerosas rayas cuya significación se ha perdido para siempre...",ep:1,g:16,l:22,wd:true,fm:true,w:22,an:17,e:[10,5,1,1,50,50,false,true],c:"CW>30",p:2200};
I.u[1378] = {n:"La Rike Glesias",t:19,d:"Esta hacha de combate, reservada para los jóvenes guerreros, tiene la particularidad;\r\n            como su nombre lo indica;\r\n            de producir un sonido estridente y particularmente desagradable cuando choca contra otra arma.",ep:1,g:17,l:28,wd:true,fm:true,w:22,an:17,e:[8,5,1,1,40,40,false,true],c:"CA>30",p:2300};
I.u[1379] = {n:"El Skrunnchhh",t:7,d:"Según cuenta la leyenda, el nombre de este martillo viene del sonido que produce cuando se estrella sobre un cráneo enemigo. Desgraciadamente, ningún enemigo está en vida para poder confirmar este rumor.",ep:7,g:9,l:35,wd:true,fm:true,w:35,an:15,e:[8,5,1,1,30,40,false,true],c:"CS>50&CA>20",p:35000};
