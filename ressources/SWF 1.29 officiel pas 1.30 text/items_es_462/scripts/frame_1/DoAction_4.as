I.u[1619] = {n:"El Abramú",t:1,d:"El Abramú es un amuleto muy elegante. Si tienes la intención de ponértelo, te aconsejamos llevarlo desnudo para poner en valor esta preciosa joya. Ya verás, las mujeres no te resistirán.",ep:9,g:16,l:46,wd:true,fm:true,w:2,p:5700};
I.u[1620] = {n:"Abrarco",t:2,d:"Este arco parece estar vivo todavía y casi puede lanzar flechas sin la ayuda de nadie, como una persona mayor. Hubiese podido ser el arco ideal para las personas que no tienen brazos, pero desafortunadamente, siempre habrá que armar el arco poniendo la flecha en el buen sentido.",ep:9,g:24,l:39,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,50,30,false,true],p:4200};
I.u[1621] = {n:"Botas de Dominación",t:11,d:"Las botas de Dominación aumentan la agilidad y la inteligencia de quien las lleve puestas pero en detrimento de la fuerza y de la suerte. A pesar de lo que se podría pensar, no permiten dominar a tu adversario.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1622] = {n:"Botas de Potencia",t:11,d:"Las botas de potencia aumentan la fuerza y la suerte de quien las lleve puestas pero en detrimento de la inteligencia y de la agilidad. A pesar de lo que se podría pensar, no confieren un poder infinito al que las lleva puestas.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1623] = {n:"Botas de Anticipación",t:11,d:"Las botas de Anticipación aumentan la fuerza y la agilidad de quien las lleve puestas pero en detrimento de la inteligencia y de la suerte. A pesar de lo que se podría pensar, no permiten prever las acciones de tus adversarios.",ep:4,g:15,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1624] = {n:"Botas de Nexus",t:11,d:"Estas botas han pertenecido a Nexus, un gran caballero que ha sido petrificado para siempre.",ep:3,g:16,l:17,wd:true,fm:true,w:5,p:1000};
