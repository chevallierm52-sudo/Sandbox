I.u[1557] = {n:"Runa Ga Pa",t:78,d:"Esta runa es tan poderosa que los Dioses deberían hacerla desaparecer. Tiene el poder de volver un arma tan fácil de utilizar que uno puede manejarla al mismo tiempo que saborea un café.",ep:1,g:55,l:50,wd:true,fm:true,w:1,p:10};
I.u[1558] = {n:"Runa Ga Pme",t:78,d:"Esta runa es tan poderosa que debería ser desterrada por Dioses. Tiene el poder de volver un arma tan ligera y fácil de guardar que uno puede utilizarla e ir a tomarse una birra a la Taberna justo después.",ep:1,g:56,l:50,wd:true,fm:true,w:1,p:10};
I.u[1559] = {n:"Abranillo Blando",t:9,d:"Este anillo era en un principio una excrecencia del Roble Blando que se arrancó durante una tempestad. Ahora es tuyo, pero procura no acercarlo demasiado a su maestro, pues podría volverse contra ti.",ep:9,g:11,l:46,wd:true,fm:true,w:3,p:7775};
