I.u[1393] = {n:"El Matrónomo",t:7,d:"Este martillo se fabricó a partir de un reloj, el famoso reloj tragado por el Cocodrail que había devorado la mano del Capitán Garfeo. Aunque se pudo recuperar el reloj, no se sabe lo que ha ocurrido con la mano...",ep:5,g:21,l:54,wd:true,fm:true,w:20,an:15,e:[8,6,1,1,40,40,false,true],c:"CI>62&CW>22",p:9700};
