I.u[2626] = {n:"Muñeca Bodú Jav",t:15,d:"Una fuerza se desprende de esta muñeca pero tienes la extraña sensación de que está llamando a alguien.",ep:12,g:611,l:51,wd:true,fm:true,w:2,p:1};
I.u[2627] = {n:"Muñeca Bodú Cerbat",t:15,d:"Una fuerza se desprende de esta muñeca pero tienes la extraña sensación de que está llamando a alguien.",ep:12,g:612,l:51,wd:true,fm:true,w:2,p:1};
I.u[2628] = {n:"Muñeca Bodú Arquero",t:15,d:"Una fuerza se desprende de esta muñeca pero tienes la extraña sensación de que está llamando a alguien.",ep:12,g:613,l:51,wd:true,fm:true,w:2,p:1};
I.u[2629] = {n:"Caracapa Minotoris",t:17,d:"Esta capa real constituye también una increíble protección. Fue este modelo el que le hizo cobrar fama a una célebre sastre justo antes de que se muriera, víctima de su triunfo... fue aplastada por la muchedumbre que venía para aclamarla.",ep:13,g:55,l:121,wd:true,fm:true,w:10,p:38500};
I.u[2630] = {n:"Frasco de Zampávoro",t:15,d:"Básicamente, el zampávoro no es muy generoso. Ahora que tienes este frasco llenito puedes considerarte afortunado. Ahora solamente queda encontrarle alguna utilidad.",ep:12,g:614,l:44,wd:true,fm:true,w:1,p:1};
I.u[2631] = {n:"Estómago del Zampávoro",t:15,d:"Este es el estómago más resistente que puedas encontrar. Increíblemente flexible, incluso podrías esconderte dentro si lo desearas.",ep:12,g:615,l:44,wd:true,fm:true,w:1,p:1};
I.u[2632] = {n:"Zampa Ron",t:15,d:"Esta botella ha sido abandonada dentro de un zampávoro. ¡Vaya despilfarro! En cambio, parece que ha envejecido muy bien, desarrollando su aroma. Si los campesinos lo supieran, existirían almacenes llenos de Zampávoros.",ep:12,g:177,l:44,wd:true,fm:true,w:1,p:1};
I.u[2633] = {n:"Ron Mazorral",t:15,d:"Vaya trampa. El Mazorral es tan falso que ha llenado una botella de Ron con... pues eso, con ron. Pero su olor se puede detectar desde diez mil leguas: La Kosakepega secada.",ep:12,g:177,l:24,wd:true,fm:true,w:1,p:1};
I.u[2634] = {n:"Lanza rota",t:15,d:"Sin su lanza, el Mazorral no hará tanto el listillo. Ahora te toca saber lo que piensas hacer con ella.",ep:12,g:616,l:24,wd:true,fm:true,w:2,p:1};
I.u[2635] = {n:"Pan Bumbo",t:33,d:"Esta receta ha sido elaborada por un rival de Javier el Panadero, un tal Paco alias \"Cocopredator\". Su nombre era tan estúpido que sus clientes no paraban de burlarse de él. Pero se vengaba amasando el pan con los pies.",ep:1,g:13,l:80,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2636] = {n:"Pan Hasonik",t:33,d:"Este pan lleva dentro varias tiras de carne que tienen el sabor y la apariencia de ser de primera calidad, pero ojo, no es eso. Si lo miras desde más cerca, podrás oler un ligero olor a tofu.",ep:1,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2637] = {n:"La Garra",t:6,d:"Esta hoja encorvada hecha con huesos, cartílagos y cuerno corta tanto como una garra de Zurcarák. Sin embargo, es más gruesa y está más limpia.",ep:13,g:33,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[2638] = {n:"La Garra Afilada",t:6,d:"Cien por cien natural, esta espada es como una sexta garra de la mano de un zurcarák. Por cierto, ¡ten mucho cuidado con no rascarte el hocico con esta garra!",ep:14,g:34,l:68,wd:true,fm:true,w:12,an:14,e:[12,4,1,1,30,50,false,false],c:"CV>30&CA>30&CS>30",p:6800};
I.u[2639] = {n:"Falsa Garra de Ceangal",t:6,d:"Una herrera zurcarák tuvo la idea de forjar esta espada tras sus múltiples fracasos intentando adquirir la técnica ancestral del mismo nombre. Decía que por lo menos esta garra saltaría a la vista de los demás.",ep:14,g:35,l:95,wd:true,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[2640] = {n:"Bastón Carnívoro",t:4,d:"Esculpido de manera extraña, este bastón no es de la comarca. Huele a antiguos lugares húmedos y oscuros de Brakmar.",ep:1,g:24,l:30,wd:true,fm:true,w:56,an:12,e:[3,5,1,1,20,50,false,false],s:7,p:1000};
I.u[2641] = {n:"Toady",t:16,d:"Rojo, blanco y suntuosamente chulo, este sombrero te permitirá causar impresión durante las fiestas organizadas por tus amigos.",ep:1,g:51,l:30,wd:true,fm:true,w:10,s:7,p:2700};
I.u[2642] = {n:"Mandíbula de Rib",t:47,d:"Es sabido que el Rib es más bien delgaducho, por lo cual si le llega a faltar la mandíbula se volvería tan ofensivo como un ejército de garrapatas en hibernación.",ep:3,g:617,l:33,wd:true,fm:true,w:1,p:1};
I.u[2643] = {n:"Colmillo de dragocerdo",t:47,d:"Este colmillo pertenece a uno de los más famosos depredadores de las montañas de Amakna: el Dragocerdo. Algunos cazadores estarían dispuestos a vender a toda su familia para poseer lo que tienes entre las manos. Será la ocasión ideal para comprarte una familia por poco dinero...",ep:2,g:618,l:70,wd:true,fm:true,w:1,p:1};
I.u[2644] = {n:"Cola de dragocerdo",t:65,d:"Este enorme cacho de cola de dragocerdo es un verdadero manjar. Sofríelo en una sartén con unas cuantas semillas de sésamo y tus invitados ya no se marcharán de tu casa. ¿A que es genial? ¿No? Bueno...",ep:2,g:619,l:70,wd:true,fm:true,w:1,p:1};
I.u[2645] = {n:"Hocico de dragocerdo",t:15,d:"Pues parece que el dragocerdo no ha visto llegar el golpe con suficiente antelación... Una pena para él.",ep:2,g:620,l:70,wd:true,fm:true,w:1,p:1};
I.u[2646] = {n:"Calzoncillo de cuero del cochinillo",t:56,d:"Este calzoncillo muy ancho le queda genial al cochinillo, las costuras son elásticas y están reforzadas para mayor eficacia durante los combates cuerpo a cuerpo. Como la tradición lo exige, jamás se ha de lavar so pena de perder sus propiedades muy temidas hoy en día.",ep:1,g:621,l:20,wd:true,fm:true,w:1,p:1};
I.u[2647] = {n:"Oreja de cochinillo",t:106,d:"El cochinillo se suele cazar generalmente para su marfil y no para sus orejas. Pero bueno, a falta de marfil...",ep:1,g:623,l:20,wd:true,fm:true,w:1,p:1};
I.u[2648] = {n:"Garras de kwak",t:15,d:"El kwak no es en absoluto un carroñero, sin embargo lleva debajo de sus garras una grasilla que será mejor no describir...",ep:1,g:624,l:30,wd:true,fm:true,w:1,p:1};
I.u[2649] = {n:"Gusano de tierra",t:15,d:"Este Gusano es el plato favorito de los Kwak salvajes. Resulta extraño que haya permanecido con vida tras ser sacado del Estomago del Kwak.",ep:5,g:625,l:30,wd:true,fm:true,w:1,p:1};
I.u[2650] = {n:"Gusano de Agua",t:15,d:"Este Gusano es la comida preferida de los Kwaks salvajes. Lo más extraño es que sigue vivo incluso después de haber sido extirpado del estómago del Kwak.",ep:1,g:626,l:30,wd:true,fm:true,w:1,p:1};
I.u[2651] = {n:"Gusano de fuego",t:15,d:"Este Gusano es el plato favorito de los Kwak salvajes. Resulta extraño que haya permanecido con vida tras ser sacado del Estomago del Kwak.",ep:5,g:627,l:30,wd:true,fm:true,w:1,p:1};
I.u[2652] = {n:"Gusano de aire",t:15,d:"Este Gusano es el plato favorito de los Kwak salvajes. Resulta extraño que haya permanecido con vida tras ser sacado del Estomago del Kwak.",ep:5,g:628,l:30,wd:true,fm:true,w:1,p:1};
I.u[2653] = {n:"Arakna Mayor Muerta",t:15,d:"Hiciste bien en recogerla, está intacta. Muerta pero intacta.",ep:1,g:629,l:43,wd:true,fm:true,w:10,p:1};
I.u[2654] = {n:"Huevo de arakna mayor",t:105,d:"El problema que plantean las Araknas es que te puedes encontrar con varias generaciones en unos días por culpa del calor. Si llega una ola de calor, no te pasees mucho por el bosque de los Abráknidos.",ep:1,g:630,l:43,wd:true,fm:true,w:1,p:1};
I.u[2655] = {n:"Cinturón Cuerbakial",t:10,d:"Este cinturón ha sido creado con los restos cosidos del Maestro Cuerbok. Si lo llevas puesto, deberías sentirte respetado. Incluso Le Chuko ha aceptado prestar su hebilla para la ocasión.",ep:13,g:56,l:120,wd:true,fm:true,w:10,p:36938};
I.u[2656] = {n:"Hilo resistente",t:15,d:"Si los zapateros y los sastres conociesen la existencia de este hilo resistente, se habrían inventado la Semana del hilo resistente, la Feria del hilo resistente e incluso el día festivo de \"San Hilo Resistente\".",ep:1,g:631,l:43,wd:true,fm:true,w:1,p:1};
I.u[2659] = {n:"Pétalo de girasol salvaje",t:35,d:"Este pétalo se mueve. Sí, se mueve en función del sol. Si lo metes en tu bolsillo derecho por la mañana, acabará en tu bolsillo izquierdo por la tarde.",ep:1,g:632,l:12,wd:true,fm:true,w:1,p:1};
I.u[2661] = {n:"Hoja de girasol salvaje",t:36,d:"Esta parte del Girasol no es solamente la Hoja de la planta sino que también la planta de sus pies. Que no te extrañe si huele a quesito...",ep:1,g:633,l:12,wd:true,fm:true,w:1,p:1};
I.u[2662] = {n:"Baba de rosa demoníaca",t:15,d:"Una Rosa Rabiosa tiene la mala costumbre de babear sobre cualquiera que se atreva a acercarse. Pero parece ser que eso es un signo de afecto. Una Rosa Demoníaca y rabiosa... Vaya, lo habremos visto todo.",ep:1,g:634,l:8,wd:true,fm:true,w:1,p:1};
I.u[2663] = {n:"Abono",t:15,d:"Todas las flores bonitas necesitan abono. Las Anutrofitas más viejas podrán prescindir de él.",ep:1,g:635,l:8,wd:true,fm:true,w:1,p:1};
I.u[2664] = {n:"Hueso de cocodrail",t:47,d:"Este hueso verdoso y extraño procede de una pata de Crocodail. Seguro que este último dejó derramar alguna que otra lágrima al enterarse de que se quedó sin una pata.",ep:4,g:636,l:36,wd:true,fm:true,w:2,p:100};
I.u[2665] = {n:"Hierba loca",t:36,d:"Este tipo de hierba se suele plantar en los cercados para Jalatós. Esta hierba está loca ya que de vez en cuando se escapa del cercado gritando...",ep:1,g:637,l:9,wd:true,fm:true,w:1,p:1};
I.u[2666] = {n:"Pezuña de Minotauroro",t:47,d:"Seguro que aplastó unos cuantos aventureros con esta pezuña... Pero ahora se chuleará mucho menos con una sóla pata, ¡Aunque eso le dé también una herida de guerra más importante que mostrar!",ep:2,g:800,l:125,wd:true,fm:true,w:1,p:1};
I.u[2667] = {n:"Cola del minotauroro",t:65,d:"Conseguir ver una cola de Minotauroro sin el Minotauroro que va delante puede ser algo extraordinario. El pobre idiota debe andar buscándola como un loco... A menos que todavía no se haya dado cuenta ¡Lo que tampoco es imposible!",ep:2,g:640,l:125,wd:true,fm:true,w:1,p:1};
I.u[2669] = {n:"Murciélago",t:15,d:"A veces los vampiros se transforman en Murciélagos para huir más rápido. Suele entonces emitir una pequeña carcajada parecida a esto: \"nipa ñipo nipa nipa\". Esto puede ahuyentar a un ejército de... Garrapatas.",ep:3,g:641,l:21,wd:true,fm:true,w:1,p:1};
I.u[2673] = {n:"Huevo podrido",t:105,d:"Esto es una auténtica vergüenza. ¿Cómo puede un Tofu poner un huevo totalmente descompuesto? Hay que ser muy maligno para tener este tipo de ideas.",ep:1,g:642,l:3,wd:true,fm:true,w:1,p:1};
I.u[2674] = {n:"Calabacita",t:46,d:"La calabacita es exquisita al llegar esta temporada. Su tamaño no es excesivamente reducido como para tener un sabor agradable, ni excesivamente importante como para transformarse en Calabazwa, de sabor exquisito y devuelta por Houj el seco.",ep:4,g:643,l:15,wd:true,fm:true,w:1,p:1};
I.u[2675] = {n:"Pluma de tofu maléfico",t:53,d:"El tofu maléfico ya no tiene muchas plumas, acabará por constiparse. Por eso no te extrañes si lo oyes estornudar durante la noche.",ep:1,g:644,l:3,wd:true,fm:true,w:1,p:1};
I.u[2676] = {n:"Nujo muerto",t:15,d:"Tuviste razón de quedarte con él. Está intacto. Muerto, pero intacto.",ep:4,g:645,l:274,wd:true,fm:true,w:10,p:1};
I.u[2677] = {n:"Cinturón Le Chukoso",t:10,d:"Este cinturón ha sido creado con los objetos más poderosos de Le Chuko, principalmente con su calzón. Con él podrás impresionar a todas las filibusteras del bar de los piratas.",ep:12,g:41,l:98,wd:true,fm:true,w:10,p:25000};
I.u[2678] = {n:"Cinturón Kokoketo",t:10,d:"Este cinturón casi se parece a un taparrabo. Te vendrá muy bien si te quieres esconder entre los Kokokos de la isla de Moon, o sencillamente si deseas ligar con un Kokoko.",ep:12,g:40,l:42,wd:true,fm:true,w:10,p:4800};
I.u[2681] = {n:"Cinturón tortuga amarilla",t:10,d:"Este pequeño cinturón es ideal para poner tus partes sensibles a salvo de los golpes críticos. Sin embargo, asegúrate bien de que el zapatero haya desalojado al dueño del caparazón antes de probártelo.",ep:7,g:43,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2683] = {n:"Cinturón tortuga azul",t:10,d:"Este pequeño cinturón es ideal para poner tus partes sensibles a salvo de los golpes críticos. Sin embargo, asegúrate bien de que el zapatero haya desalojado al dueño del caparazón antes de probártelo.",ep:7,g:44,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2685] = {n:"Cinturón tortuga verde",t:10,d:"Este pequeño cinturón es ideal para poner tus partes sensibles a salvo de los golpes críticos. Sin embargo, asegúrate bien de que el zapatero haya desalojado al dueño del caparazón antes de probártelo.",ep:7,g:42,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2687] = {n:"Cinturón tortuga roja",t:10,d:"Este pequeño cinturón es ideal para poner tus partes sensibles a salvo de los golpes críticos. Sin embargo, asegúrate bien de que el zapatero haya desalojado al propietario del caparazón antes de probártelo.",ep:7,g:45,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2688] = {n:"Cinturón Pegajoso",t:10,d:"Lo menos que se pueda decir es que un vez que te lo hayas puesto, no te arriesgas a perder este cinturón. Es ideal para los despistados y para las víctimas de robos recurrentes.",ep:12,g:46,l:50,wd:true,fm:true,w:10,p:6600};
I.u[2689] = {n:"Cinturón Pekabeza",t:10,d:"Al zapatero que ha creado este cinturón con restos de Dragopavo debió de faltarle imaginación para darle un nombre tan estúpido.",ep:2,g:47,l:29,wd:true,fm:true,w:10,p:2400};
I.u[2710] = {n:"Cinturón Pekabeza Salvaje",t:10,d:"Lleva refuerzos de hierro, pues se trata de una versión mejorada del clásico Cinturón Pekabeza, ha sido especialmente diseñada para cazar los Dragopavos Salvajes en las comarcas salvajes.",ep:2,g:48,l:32,wd:true,fm:true,w:10,p:3000};
