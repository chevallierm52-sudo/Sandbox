I.u[2998] = {n:"Lana del minotauroro",t:57,d:"Esta lana excepcional ha vivido mucho, como el encuentro con Vald. Los pelos que la componen son tan duros que protegen incluso de los golpes con más mala leche.",ep:2,g:654,l:125,wd:true,fm:true,w:30,p:12500};
I.u[2999] = {n:"Cuero de minotauroro",t:56,d:"Este cuero es tan resistente como la fortaleza de Brakmar. Sus propiedades intrínsecas, prácticamente desconocidas, hacen que sea fácil trabajarlo para fabricar los objetos más prestigiosos.",ep:2,g:655,l:125,wd:true,fm:true,w:30,p:12500};
I.u[3000] = {n:"Casco roto de Bwork",t:15,d:"En la tribu Bwork, los Bworks Magos son los que se ocupan de la forja. Un trabajo muy meticuloso, el casco se entrega desde el nacimiento para protegerse lo más rápido posible de las caídas o de los martillazos.",ep:4,g:646,l:43,wd:true,fm:true,w:10,p:1};
I.u[3001] = {n:"Hombrera de Bwork",t:15,d:"La Hombrera es un elemento de gran importancia en la educación de los Bwork, aunque para ellos este término no parece ser el más apropiado. Más bien tendrá que ver con entrenarse.",ep:4,g:647,l:43,wd:true,fm:true,w:10,p:1};
I.u[3002] = {n:"Bota Agujereada del Bwork",t:15,d:"Esta bota no se puede utilizar en ese estado. Cuando algún zapatero experimentado te la haya reparado, tal vez puedas encontrarle otra utilidad. Mientras tanto, su olor puede servirte para rechazar las propuestas de gente demasiado atrevida.",ep:4,g:648,l:43,wd:true,fm:true,w:10,p:1};
