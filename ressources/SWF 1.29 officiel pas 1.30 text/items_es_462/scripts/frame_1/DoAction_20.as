I.u[8557] = {n:"Pluma de Batofu",t:53,d:"Esta pluma ha sido arrancada de las axilas del Batofu. Desprende un olor a vómito de rata muerta.",ep:3,g:120,l:20,wd:true,fm:true,w:1,p:10};
I.u[8558] = {n:"Sombrero del Cunejo",t:16,d:"Si piensas dialogar con los Wabbits este es el sombrero que necesitas. Si quieres ligar, regala este sombrero a tus rivales.",ep:1,g:170,l:6,wd:true,fm:true,w:10,p:12000};
I.u[8559] = {n:"El HmmMmmMmmm",t:16,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:2,g:171,l:42,wd:true,fm:true,w:1,p:420};
I.u[8561] = {n:"Bebé Pandawa",t:18,d:"A este entrañable bebé Pandawa le encantará seguirte a todos sitios para descubrir el mundo con sus ojazos redonditos. Esta mascota domesticada solamente come arroz.",ep:3,g:42,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8563] = {n:"Peke Gobleche",t:32,d:"Peke tiene que conocer a su futuro profesor de magia.",ep:1,g:18,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[8564] = {n:"Certificado de admisión en la petrera: bebé pandawa",t:77,d:"Este certificado describe las características del bebé pandawa que has dejado en la petrera.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8565] = {n:"Fantasma Bebé Pandawa",t:90,d:"Este fantasma no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[8566] = {n:"Transformación Walk",t:27,d:"Te has transformado en fantasma para poder penetrar en el santuario de las mascotas.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8567] = {n:"Transformación fantasma Bebé Pandawa",t:27,d:"Te has transformado en fantasma para poder penetrar en el santuario de las mascotas.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8568] = {n:"Regalo: Bebé Pandawa",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8569] = {n:"Doro le Black",t:16,d:"Este gorro perteneció a una pequeña xelor a la que le gustaba alterar el tiempo. Se dice que llegó a robarles varios días a los habitantes de Amakna. Éstos se enfadaron tanto que sólo consiguió calmarlos repartiendo caramelos y chocolates.",ep:22,g:172,l:129,wd:true,fm:true,w:10,p:42512};
I.u[8570] = {n:"Pelo de rata bontariana",t:54,d:"Este pelo pertenecía a una rata de alcantarillas de Bonta, son las únicas que tienen mechones de pelos del mismo color que las murallas de su ciudad.",ep:2,g:672,l:40,wd:true,fm:true,w:1,p:10};
I.u[8571] = {n:"Pelo de rata brakmariana",t:54,d:"Este pelo pertenecía a una rata de alcantarillas de Brakmar, son las únicas que tienen mechones de pelos del mismo color que las murallas de su ciudad.",ep:2,g:673,l:40,wd:true,fm:true,w:1,p:10};
I.u[8572] = {n:"Pócima de olvido: \"Domesticación de montura\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo: \"Domesticación de montura\".",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8573] = {n:"Pócima de olvido: \"Bumerán pérfido\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo: \"Bumerán pérfido\".",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8574] = {n:"Dofus vinagreta",t:23,d:"Con ensalada o con mejillones, este Dofus siempre está bueno.",ep:0,g:13,l:1,wd:false,fm:true,w:1,p:1};
I.u[8575] = {n:"El Rambotón",t:4,d:"Un famoso guerrero feca que vivía en la selva de Pandala decía muy a menudo \"Para ganar la guerra, hay que ser la guerra\".",ep:1,g:71,l:200,wd:false,fm:true,w:20,an:12,tw:true,e:[7,3,1,2,42,42,false,true],c:"PN~xxramboplxx",p:100000};
I.u[8576] = {n:"Pergamino de recomendación de Ys Vewybad",t:24,d:"Ys Vawybad te ha entregado este pergamino a cambio de tus servicios.",ep:2,g:26,l:20,wd:false,fm:true,w:0,p:1};
I.u[8588] = {n:"Emblema de Tymador",t:24,d:"Este emblema que te dio un tymador será tal vez la llave para entrar en su guarida.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[8590] = {n:"Contrato entre Vil Smis y Ys Vewybad",t:24,d:"Este contrato demuestra la felonía de Ys Vewybad. Tienes que llevárselo al interesado.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[8593] = {n:"Pócima de transformación en Wey Wabbit",t:27,d:"Uba Teseo te ha entregado esta pócima. Te transformará en wabbit y debería permitirte hacerte pasar por el pretendiente de Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8594] = {n:"Pócima de twansfowmación en Wey Wabbit",t:27,d:"Uba Teseo te ha entregado esta pócima. Te transformará en wabbit y debería permitirte hacerte pasar por el pretendiente de Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8595] = {n:"Huevo de tofu obeso",t:24,d:"Este huevo lleva un tofu obeso en su interior, tal vez sea el futuro vencedor del pwíncipe de Wey.",ep:1,g:122,l:1,wd:true,fm:false,w:0,p:1};
I.u[8596] = {n:"Garra púrpura",t:6,d:"Esta aguda espada tomó su elegante color después de haber cortar un millar de bworks en rebanadas. Antes su hoja era violeta oscuro.",ep:22,g:72,l:145,wd:true,fm:true,w:15,an:14,tw:true,e:[8,6,1,1,45,100,false,false],c:"CS>350&CV>400",p:52000};
I.u[8597] = {n:"Pócima de Cebadura",t:24,d:"Esta pócima le permitirá a Vil Smis cebar al tofu obeso que le has traído.",ep:3,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[8598] = {n:"Emment Daga",t:5,d:"Estas dagas, llenas de agujeros, emiten un bonito silvido cuando se agitan en el aire. Los agujeros también son muy útiles pues arrastran las víesceras de tus enemigos hacia fuera cuando los cortas profundamente.",ep:22,g:61,l:67,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CA>100",p:10654};
I.u[8599] = {n:"Garritas",t:5,d:"Estas dagas fueron forjadas por una Zurcarák maníaca de la manicura. Pensaba que las espadas no iban a juego con su uñas cuidadosamente pintadas.",ep:22,g:62,l:69,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,30,false,true],c:"CA>100&CS>100",p:11254};
I.u[8600] = {n:"La Pereza de subir las escaleras",t:30,d:"Te acaba de dar un bajón de tanto gritar y ya no te sientes capaz de subir tantos escalones durante por lo menos 6 minutos...",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8603] = {n:"Librea de criado del Príncipe Wabbit",t:24,d:"Con esto, el criado del príncipe Wabbit estará vestido a la última moda.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8604] = {n:"Espadúnculo",t:6,d:"Esta espada brillante resulta ideal para cortar flores, aunque se defiendan. De hecho, hasta resulta ideal para cortar árboles.",ep:22,g:73,l:100,wd:true,fm:true,w:10,an:14,e:[15,8,1,1,40,50,false,false],c:"CS>250&CI<1",p:25654};
I.u[8605] = {n:"Espada Protectora",t:6,d:"La hoja de esta espada está lubrificada para resbalar mejor en su funda. Sin embargo, no podrás limpiarla y tendrás que tirarla después de cada uso, sobre todo si está recubierta de sangre. ¡No olvides que se trata de proteger tu salud!",ep:22,g:74,l:73,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,40,50,false,true],c:"CS>80&CI>80&CA>80",p:14000};
I.u[8606] = {n:"Vestido de Novia",t:24,d:"El vestido de Novia está muy bien empaquetada. Ya no tienes más que ir a llevársela al intendente San Lavalss.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8607] = {n:"El Bastón Claveado",t:4,d:"Es un gran bastón, llenito de clavos. No busques más, es la simplicidad personificada (o \"cosificada\"), y sin embargo es endomniadamente eficaz a la hora de desdentar a tus rivales.",ep:22,g:72,l:107,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,50,false,true],c:"CA>150&CI>150",p:29856};
I.u[8608] = {n:"El Bastón de Fraye",t:4,d:"Se cuenta que un discípulo de Sadida llamado Fraye utilizó este bastón para defender a su mujer y su hijo frente a un rebaño de jalatós rabiosos. Es una pena que, en medio del clamor de la batalla, confundiese a su familia con los monstruos.",ep:22,g:73,l:85,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,35,40,false,true],c:"CW>150&CV>200",p:20000};
I.u[8609] = {n:"Geish\'Arco",t:2,d:"Este arco es ligero, fino, elegante y huele a flor de cerezo. También es mortal si uno sabe utilizarlo.",ep:22,g:56,l:81,wd:true,fm:true,w:15,an:10,tw:true,e:[5,4,3,7,30,50,false,true],c:"CA>200",p:16900};
I.u[8610] = {n:"El Arco Astral",t:2,d:"Si mantienes este arco bien alto por encima de tu cabeza y gritas con fuerza la palabra \"¡Pampiluliu!\", no te quepa duda, estarás ridículo.",ep:22,g:57,l:79,wd:true,fm:true,w:10,an:10,tw:true,e:[7,5,4,7,30,50,false,true],c:"CI>150&CC>150",p:15320};
I.u[8611] = {n:"Vagdita Café",t:3,d:"Est varita es famosa por haber sido fabricada en el famosísimo Vagdá Café, pero no pienses que podrás tomarte una tazita cuando te pegue el sueño.",ep:22,g:61,l:72,wd:true,fm:true,w:15,an:11,e:[5,3,2,4,15,50,false,true],c:"CI>100&CC>100",p:16500};
I.u[8612] = {n:"El Bidyiz",t:3,d:"El Bidyiz te garantiza que seguirás con vida, quizás porque la mayoría de los enemigos no podrá dejar de bailar cuando vea todos los birllantes espejos de la bola que lo adorna.",ep:22,g:62,l:79,wd:true,fm:true,w:10,an:11,tw:true,e:[10,4,2,5,40,50,false,true],c:"CA>150",p:18000};
I.u[8613] = {n:"Pala Minsterio",t:8,d:"Obra de arte de la forjamagia, con esta pala te costará mucho cavar hoyos, salvo en la cabeza de tus enemigos.",ep:22,g:46,l:70,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,30,50,false,false],c:"CC>100",p:13540};
I.u[8614] = {n:"R.I.Pala",t:8,d:"Esta magnífica pala dos-en-uno además de ayudarte a cavar una tumba, también te evitará tener que buscar la cruz. Pero no pierdas más de un compañero cada vez, o te tocará cavar las otras tumbas con las manos.",ep:22,g:47,l:66,wd:true,fm:true,w:1,an:16,tw:true,e:[5,4,1,1,20,30,false,false],c:"CI>100&CC>50",p:1};
I.u[8615] = {n:"Martillo Rojo",t:7,d:"Este martillo hace migas de los craneos enemigos tan facilmente que a acabado adquiriendo un bonito color rojo tomate.",ep:22,g:61,l:83,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100&CV>100",p:17560};
I.u[8616] = {n:"Mart\'IT\'llo",t:7,d:"Este martillo se creó en tiempos del Rey Stephen, que aterrorizó a sus millones de leales súbditos",ep:22,g:62,l:178,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,40,50,false,true],c:"CI>350&CW>180",p:10000};
I.u[8617] = {n:"Bast Hacha",t:19,d:"Para cuando tengas que decir \"Te quiero\", o para decir ¡Basta Ya!",ep:22,g:45,l:62,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,20,30,false,false],c:"CV>150",p:10200};
I.u[8618] = {n:"Hacha Charear",t:19,d:"Esta extraña hacha se forjó con esta forma para facilitar la decapitación de bworks. La facilidad con la que puede decapitar a los habitantes de Astrub indica que existe una relación entre estas dos razas. Aunque nadie la haya encontrado aún.",ep:22,g:46,l:80,wd:true,fm:true,w:10,an:17,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>120&CA>60",p:16700};
I.u[8619] = {n:"Casco Moasdicho",t:16,d:"Cierto es que con este tocado todos los Yopukas parecen más fieros, pero también hay que decir que este casco reduce bastante el campo de visión y es aún peor para los oídos. Así que el Casco Moasdicho sólo es recomendable para aquellos que suelen pegar primero y hablar después... es decir, para los Yopukas.",ep:22,g:175,l:40,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8620] = {n:"Vagria",t:28,d:"Gracias a esta píldora mágica podrás usar tu porra con más fuerza y durante más tiempo... Es increíble como la magia no conoce límites...",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8621] = {n:"Zanahowia maldita",t:94,d:"Esta apetecible zanahowia pawece nowmal pero huele a maleficio. ¿Cwees que podwás wesistiw a la tentación de mowdewla?",ep:8,g:6,l:21,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[8624] = {n:"Globo azul mágico",t:94,d:"Nada que ver con las imitaciones que se pueden encontrar en la feria del Trool. Este globo por lo menos sabe volar con gracia y elegancia. En realidad es una larva azul hinchada por un trool. Otra receta del gran mago Hava Niyao.",ep:1,g:7,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8625] = {n:"Globo verde mágico",t:94,d:"Este globo verde es en realidad una larva verde que se ha comido un champiñón Luzdji. Fíjate, los ojos de la larva se salieron disparados durante el proceso de digestión. Seguro que algún bwork se los ha comido, pues al bwork le encanta este tipo de golosinas. Este globo ha inspirado las famosas recetas del gran mago Hava Niyao.",ep:1,g:8,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8626] = {n:"Ivillinik Milditik",t:94,d:"Istik ipiticiblik ivillinik tinik ink ispictik nirmilik prik disprindik milificik. ¿Cris kik pidris risistir ik lik tintincinik dik picitirlik?",ep:6,g:9,l:21,wd:false,fm:true,w:1,u:true,ut:true,p:100};
I.u[8627] = {n:"Flauta de Sarr Ys",t:3,d:"Colega y amigo del célebre Guy-guy (pariente cercano del Roble Blando), Sarr Ys es un trovador cuyas notas encantadoras han dejado huella en la memoria de Amakna. Una lástima que este brillante artista haya fallecido trágicamente en un accidente de Kuak kuak durante un fiestorro veraniego...",ep:1,g:63,l:1,wd:false,fm:true,w:10,an:11,e:[10,6,2,3,100,30,false,true],p:1};
I.u[8628] = {n:"Sombrero del Tahúr",t:16,d:"Este sombrero da a los zurcarák una gran seguridad y autoconfianza. Gracias a él, se creen capaces realizar los mayores logros. Así que no te olvides de quitártelo de vez en cuando ¡O acabará por meterte en situaciones de las que no podrás salir fácilmente!",ep:22,g:185,l:40,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8629] = {n:"Multricornio",t:16,d:"Con este sombrero, a menudo los enemigos se quedan mudos como tumbas. No nos atrevemos a preguntar a qué se supone que se parece este sombrero, pero no pasa nada, a los Srams les encanta.",ep:22,g:179,l:40,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8630] = {n:"Diapa Sombrero",t:16,d:"Puede que este sombrero se asemeje al Sulik, o incluso al Piruk, pero el Diapa Sombrero es indiscutiblemente un sombrero Xelor. Posée un mecanismo interior con el que nunca perderás el ritmo de batalla. Algunos Xelor no se la quitan ni para dormir, pues dicen que su mecanismo les suena como una nana, pero también se dice que hace roncar tan fuerte que los sapos te tendrán envidia.",ep:22,g:177,l:40,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8631] = {n:"Gorro del Maestro Piezo",t:16,d:"El Maestro Piezo fue un gran Aniripsa especialista en la cura de esguinces y dislocaciones de articulaciones. (Su propio padre era un poco patoso, así que aprendió de muy niño a tener que curar estas lesiones). Su sabiduría llegó a ser tan grande que se retiró a Bonta y se dedicó a enseñar a los demás. Usaba este sombrero para que los demás pudiesen verlo a pesar de su tamaño, pues nadie se habría puesto un gorro tan ridículo sin un motivo válido.",ep:22,g:184,l:40,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8632] = {n:"Gorra Bano",t:16,d:"Con este nombre podríamos esperar un bonito artículo blanco y rechoncho, pero esta gorra más bien parece una máscara... Entonces ¿Por qué sus creadores la han llamado así? Personalmente me importa un rábano, pero seguramente lo hiciesen para dar de qué hablar a las malas lenguas.",ep:22,g:178,l:40,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8633] = {n:"Sombrervido",t:16,d:"Con las puntas de acero que salen de este sombrero no sólo podrás herir más facilmente al adversario, también triplicarás tu suerte para recibir un rayo que te hierva el cerebro en plena tormenta. En efecto, a los sacrógrito les gusta tanto hacer sufrir a los otros como a ellos mismos. Un buen olor a carne churruscada, ¿qué puede haber mejor para empezar el día?",ep:22,g:180,l:40,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8634] = {n:"Capucha Apino",t:16,d:"Gracias a este sombrero te parecerás a una auténtica bestia cornuda. Nadie podrá evitar admirar el magnífico par de cuernos que decora tu cabeza. Además su amplia capucha te permitirá mantener frescos alimentos como la paja para jalatós o el pan para tofus.",ep:22,g:181,l:40,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8635] = {n:"Casco Locado",t:16,d:"Este casco ayuda a los Pandawas a mantenerse erguidos cuando están ébrios, lo que suele ser bastante a menudo. En esos momentos suelen sentirse tan ligeros como si andasen sobre nubes de algodón, pero este casco les ejerce una presión estratégica sobre el centro neurálgico del equilibrio forzándo a la verticalidad pero limitando la rectitud, así les costará más despegar.",ep:22,g:176,l:40,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8636] = {n:"Gorro del príncipe Robin",t:16,d:"Robin Gorro era un famoso ocra que vivía en los bosques de Shirvud, lo que explica el color verde de su gorro (para fundirse en el paisaje) pero no su pluma. Robin se creía un justiciero, y por eso se pasaba el tiempo robando kamas a los más ricos por repartirlos entre... ¡Él solo!",ep:22,g:186,l:40,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8637] = {n:"Sombrerillo del Lazarillo",t:16,d:"Con este gorro puesto, un Feca aumentará tanto su suerte como la de sus aliados. Si formas parte de un grupo guiado por un Feca con el Lazarillo, puedes estar seguro de llegar a tu destino y casi sin ningún percance. Desgraciadamente, este sombrero hace que el Feca se pare en seco cuando vé una luz roja, hasta que esta pase a verde.",ep:22,g:182,l:40,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8638] = {n:"Alfue Gorro",t:16,d:"Este sombrero te servirá tanto para  protegerte de la intemperie como de accecsorio de cocina, para poder hacer refritos y sofritos. A pesar de su nombre, el Alfue Gorro no te calentará la cabeza, pues genera una corriente de aire que, además de refrescarte, te ayudará a mantener la temperatura de cocción ideal. Sólo tendrás que remover suavemente, pero con los brazos de un Anutrof no será un problema.",ep:22,g:183,l:40,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8639] = {n:"Capa Yaso",t:17,d:"Yaso era un yopuka que solía hacer chistes al enemigo para, según él, desconcentrarlo. La verdad es que sus chistes no eran muy buenos, por eso un día el Bwroker lo partió en cuatro pedazos. De ahí el dibujo de esta capa.",ep:22,g:131,l:80,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8640] = {n:"Capa Gar",t:17,d:"Su tejido suave y resistente hace que los zurcarák se sientan como ases pase lo que pase. Cuando más tarde ganan su partida, no es raro oírles reclamar su recompensa gritando: \"Te toCa paGar\".",ep:22,g:133,l:80,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8641] = {n:"Capa Migodel Oajeno",t:17,d:"Migodel Oajeno no era un buen guerrero, así que se pueso a hablar con la gente para ayudarlos a resolver sus problemas. Tras años con este trabajo escribió un pergamino en el que decía que el carácter engañino y desconfiado de los Sram se explicaba por una infancia dura y con poco cariño. Puede que tú te preguntes si eso justifica a TODOS los Sram, pero ellos le hicieron esta capa en homenaje.",ep:22,g:140,l:80,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8642] = {n:"Capa Tic-tac",t:17,d:"El oscuro color de esta capa hace que case con cualquier cosa que te quieras poner y su diseño de agujas nunca pasará de moda. Además su amplio tamaño podrá cubrirte la cabeza hasta la nariz.",ep:22,g:141,l:80,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8643] = {n:"Capa Labrita",t:17,d:"La Capa Labrita ha de colocarse delicadamente sobre los hombros para que pueda silvarte al oido todas esas palabritas que el clamor del combate te puede hacer olvidar. Debido a sus virtudes terapéuticas, también los pandawa querrían tener una capa así, pues entre jarrita y jarrita ellos también olvidan las palabritas.",ep:22,g:134,l:80,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8644] = {n:"Capitón",t:17,d:"¿Que por qué la han llamado así si no tiene ni la forma ni el color de una pitón? Pues porque no todas las sádidas tienen un cuerpo perfecto, algunas tienen piel de serpiente, entonces la esconden bajo esta capa. Los sádidas hombre, por su parte prefieren usarla para esconder sus \"reservas naturales de grasa\".",ep:22,g:139,l:80,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8645] = {n:"Cap\'Ytal",t:17,d:"Esta capa cumple un rol capital en la prestancia de los sacrógritos. Las usan a modo de venda para aseptizarse las heridas, a modo de bayeta para limpiar la sangre y hasta a modo de alfombra para no coger frío en los pies al bajar de la cama. ¡No os podéis imaginar hasta que punto les da miedo a estos personajes pisar el suelo frío!",ep:22,g:138,l:80,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8646] = {n:"Capa Lina",t:17,d:"Las Osamodas más coquetas usan esta suave capa, atándosela a modo de pañuelo para cubrirse la cabeza de un modo elegante. Los Osamodas macho, por su parte, sólo la usan como una capa de viaje. Gracias al diseño de esta capa, sus portadores son percibidos como gente honesta que sabe reirse de sí misma;\r\n            de hecho tienen la risa cosida en la ropa.",ep:22,g:137,l:80,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8647] = {n:"Capa Weira",t:17,d:"Los pandawas usan esta capa como accesorio para un baile. La dejan en el suelo, en el centro de un coro de bailarines bebidos. Luego improvisan una coreografía en la que los pies no pueden pisar fuera de la capa. Además, esta capa también te puede proteger del frío y de la lluvia.",ep:22,g:142,l:80,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8648] = {n:"Capulko",t:17,d:"Esta capa debe su nombre a un ocra con tan pésimo sentido de la orientación que era capaz de perderse en su propia casa, ¡Y eso que vivía en una cabaña! El origen de su problema era una malformación cerebral que perturbaba sus funciones visuales: todo lo que veía se le aparecía como una enorme playa soleada, bañada por aguas cristalinas y rodeada de cocoteros.",ep:22,g:132,l:80,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8649] = {n:"Capa Docia",t:17,d:"Los colores cálidos y reconfortantes de esta capa pueden transportarte en un viaje imaginario hasta un territorio soleado, lleno de cañones labrados por siglos de erosión, con mágicas chimeneas, y arte rupestre labrado en la roca y los barrancos. Extremadamente útil para olvidar el frío gris de los días de lluvia.",ep:22,g:136,l:80,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8650] = {n:"S\'capa Toria",t:17,d:"Los anutrofs han cogido la costumbre de dibujar un mapa en su capa. ¿A dónde lleva? Pues a un lugar de \"evacuación\" pues a veces es dificil encontrar el camino al baño dentro de la mina, y esto puede ser muy problemático cuando se sufre de incontinencia.",ep:22,g:135,l:80,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8651] = {n:"Correa Litichow",t:10,d:"Esta es la mejor Corra con la que jamás podrás atar la túnica de un Yopuka. Su particularidad consiste en alterar tu visión para que veas las cosas con la realidad de la vida misma. ¿Qué cuál es la difenercia con no llevarla? Pues que te garantizamos que lo ves es real, no como en el teatro.",ep:22,g:116,l:130,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8652] = {n:"Cintourón Baraja",t:10,d:"El Caza Ratones era un zurcarák famoso por su habilidad en la caza. Era tan diestro con sus garrras como desafortunado en el juego. Un día empezo a tener mejor suerte al poker, pero cuando sacó una mano con cinco ases, entonces todos se dieron cuenta de que su cinto no sólo era un adorno. Desde aquél día poco más se sabe de él...",ep:22,g:117,l:130,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8653] = {n:"Cinto Hreru",t:10,d:"Hay quien huye de los sram por su reputación de falsos y violentos. Pero los que los conocen bien saben apreciar su coraje. Tal es el caso del famoso Hreru que, con la sola ayuda de su cinto, consiguió estrangular a dos minotauroros ¡A la vez!",ep:22,g:118,l:130,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8654] = {n:"Cinto O\'rario",t:10,d:"El constante Tic-Tac del mecanismo de relojería del Cinto O\'rario impide que los Xelor se duerman cuando los combates se hacen eternos. Así que no olvides quitarte este cinto antes de irte a dormir.",ep:22,g:119,l:130,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8655] = {n:"Cinturronchón",t:10,d:"Gracias a su exclusivo diseño, este cinto permite llevar al campo de batalla todo el equipo necesario para curar los arañazos, zorrostrones, ronchones, moratones, rozaduras, ampoyas, picazones de garganta, dolores de cabeza, congestión nasal, caspa, uñeros, otitis y demás molestias leves que los aliados puedan sentir. Para todo lo demás será mejor que conozcas unos buenos hechizos. ¡Y no te olvides de comer!",ep:22,g:120,l:130,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8656] = {n:"Cintelación",t:10,d:"Las razones que llevaron a los conceptores de este accesorio a poner una cabeza de muñeca cerca de la entrepierna son un misterio que aún no se ha resuelto. Y no precisamente por falta de teorías.",ep:22,g:121,l:130,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8657] = {n:"Cinto Orturator",t:10,d:"La extinta tribu de los Orturator fue la primera en rendir culto a la diosa Sacrógrito. Fueron universalmente conocidos por la profusión de sanger de sus rituales religiosos. Al igual que la tribu que le da nombre, el Cinto Orturator está sediento de sangre.",ep:22,g:122,l:130,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8658] = {n:"Cinto\'Rbodyezel",t:10,d:"Los osamodas tienen la reputación de ser un poco impulsivos. No tardan nada en arrancar cuando se trata de una pelea. Este cinto, con sus numerosas hebillas, les sirve para refrenar estos impulsos: \"Antes de que montes en cólera y de que se te inyecten los ojos en sangre, toca todos los picos del cinto\'rbodyezel\".",ep:22,g:123,l:130,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8659] = {n:"Pandinturón",t:10,d:"El cinturón oficial de la isla de Pandawa... si creemos lo que pone en la caja. En realidad este cinturón tan chulo fue diseñado para vendéselo a los turistas, pero los propios Pandawas lo encontraron tan simpático que lo adoptaron como propio. Supongo que esto no te interesa, pero esa es su historia.",ep:22,g:124,l:130,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8660] = {n:"Cincha diana",t:10,d:"Este cinturón sirve para dos cosas: para que no se caiga la ropa de los ocras (algo que puedría herir la sensibilidad de más de un alma candida) y también puede usarse para entrenar y mejorar el manejo del arco. Advertencia: no olvides quitarte el cinturón para los entrenamientos.",ep:22,g:125,l:130,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8661] = {n:"La Merendera",t:10,d:"\"Feca precavido vale por dos\" eso es lo que piensan todos los Fecas, pero especialmente los que llevan este cinto;\r\n            pues en su bolsita guardan la merienda para nunca morir de hambre. Quizás no sea una merienda cuantiosa, pero el Cinturón Deceguritá pega la bolsita al cuerpo de modo que sea imposible robarla, ni que se caiga ella sola.",ep:22,g:126,l:130,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8662] = {n:"Cinto Rhente",t:10,d:"Cinto Rhente es un accesorio de moda, muy útil para el macho Anutrof. Garcias al mapa que lleva cosido, podrá esconder los \"accidentes\" que encuentre a la hora de ir al baño.",ep:22,g:127,l:130,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8663] = {n:"Botas altante",t:11,d:"Con estas botas puestas, los yopukas siempre estarán en primera línea de combate. Su suavidad y la facilidad con la que se hacen a tu pie garantizan un confort que hará que te olvides de las ampoyas y los juanetes. Sin embargo no podrán hacer nada contra los golpes que recibas durante el combate.",ep:22,g:100,l:100,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8664] = {n:"Zapatillas con pelos",t:11,d:"Dicen que los sadidas nunca se sienten solos porque pueden invocar montones de muñecas para hacerles compañía. ¡Ahora tú tampoco te sentirás solo gracias a estas zapatillas! Cuando uno se las pone se siente realmente bien, aunque sea un poco vergonzoso salir con ellas a la calle.",ep:22,g:105,l:100,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8665] = {n:"Botas Idermista",t:11,d:"Estas botas podrían haberse clasificado como un arma de lo duras que resultan cuando se espetan en los lomos de los jalatós. Misteriosamente, sólo provocan daños internos y no alteran el aspecto exterior, lo que resulta muy práctico para esos sádicos a los que les gusta coleccionar animales muertos y exponerlos en sus salones.",ep:22,g:102,l:100,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8666] = {n:"Zapato M\'prano",t:11,d:"Xelor enseño a sus discípulos la utilidad de madrugar para disponer de más tiempo a lo largo del día. Los Zapato M\'prano se crearon con esa idea, pues su interior es tan confortable que no los cambiarás por ninguna zapatilla de andar por casa. Desgraciadamente no podrás dormir con ellos puestas, salvo si sabes dormir de pie.",ep:22,g:103,l:100,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8667] = {n:"Botas Epsia",t:11,d:"Gracias a estas botas bajas, siempre estarás protegido de las toxinas y bacterias que habitan el suelo. ¡Nunca se tiene suficiente cuidado! Algunos observadores dicen  que más que a botas se parecen a pantuflas, pero los Aniripsas las llaman así ¿Será que a causa de su tamaño ven las cosas desde otro ángulo?",ep:22,g:104,l:100,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8668] = {n:"Botas Nicas",t:11,d:"Es famoso el amor que los Sadidas sienten por las plantas y si estas botas son sus preferidas, es porque tienen un sistema de reconocimiento floral integrado que evitará las especies vegetales más raras al caminar. Aunque no evitarán los variados excrementos que se puedan cruzar en su camino, y seguirán teniendo que mirar por dónde ponen los pies",ep:22,g:101,l:100,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8669] = {n:"Chancla Vada",t:11,d:"A los Sacrógrito les gusta llevar clavos en los piés, esto les recuerda las espinitas que se tienen que sacar. Además el dolor les ayuda a encontrar la rabia para hacer polvo a sus enemigos. Y los rastros de sangre que van dejando por el camino les permiten no perderse, siempre podrán dar media vuelta y volver a casa (lo que sería más dificil si tuviesen otros zapatos)",ep:22,g:106,l:100,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8670] = {n:"Botaz Mania",t:11,d:"Con estas botas, los Osamodas son capazes de recorrer largas distancia e ir hasta los más recónditos rincones del Mundo. A parte de esto, no se sabe muy bien para qué sirven. Algunos dicen que hacen un florero muy original para presentar las flores del campo, otros piensan que pueden servir de nido para tofus, pero nada de eso resulta muy convincente. En realidad las Botaz Mania son, basicamente, un par de botas.",ep:22,g:107,l:100,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8671] = {n:"Reliquia del Coralador Magistral",t:24,d:"Esta impresionante reliquia te permitirá tal vez olvidar todos tus problemas.",ep:22,g:152,l:1,wd:true,fm:true,w:0,p:1};
I.u[8672] = {n:"Reliquia de Gurlo",t:24,d:"Esta impresionante reliquia te hará olvidar todos tus problemas.",ep:22,g:153,l:31,wd:true,fm:true,w:0,p:1};
I.u[8673] = {n:"Reliquia del Rasgabola Mayor",t:24,d:"Esta impresionante reliquia te hará olvidar todos tus problemas.",ep:22,g:154,l:61,wd:true,fm:true,w:0,p:1};
I.u[8674] = {n:"Reliquia del Tynril",t:24,d:"Esta impresionante reliquia te hará olvidar todos tus problemas.",ep:22,g:155,l:101,wd:true,fm:true,w:0,p:1};
I.u[8675] = {n:"Reliquia del Kimbo",t:24,d:"Esta impresionante reliquia te hará olvidar todos tus problemas.",ep:22,g:156,l:141,wd:true,fm:true,w:0,p:1};
I.u[8676] = {n:"Espada Gasificadora",t:6,d:"Vlad se había enamorado de esta magnífica espada. Ha participado a la carrera de Dragokart más terrible que hubo para poder comprarla. Desafortunadamente, no sabía que esta espada llevaba una terrible maldición...",ep:1,g:75,l:95,wd:true,fm:true,w:1,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8677] = {n:"Ross",t:18,d:"Este magnífico Conejillo es la mascota preferida del famoso Maestro Negro Jack. No es lo que parece, puede ser un temible adversario en combate. Esta mascota solamente come Zanahowias y plantas.",ep:3,g:44,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8678] = {n:"Sombrero de Nodoymas",t:16,d:"Pierre Nodoymas era un patinador artístico que un día, al caerse sobre el trasero tuvo una revelación que cambiaría radicalmente su vida: ¡su destino era convertirse en el mejor conductor de Dragokart de su generación! Hay que ver lo que una pequeña caída puede provocar en ciertas mentes perversas...",ep:1,g:187,l:36,wd:true,fm:true,w:20,p:3550};
I.u[8679] = {n:"Fantasma Ross",t:90,d:"Este fantasma no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:46,l:1,wd:true,fm:true,w:1,p:1};
I.u[8680] = {n:"Escama pegajosa",t:59,d:"Esta escama pegajosa y resbaladiza le permitía a su dueño zafarse y no dejarse atrapar fácilmente por los aventureros que han decidido pescar con los dientes. \nDesafortunadamente, no le protegió contra un golpe de espada oxidada bien dado.",ep:1,g:626,l:10,wd:true,fm:true,w:1,p:1};
I.u[8681] = {n:"Piel de Raúl Mops",t:59,d:"Lo que le pierde al Raúl Mops es que le encanta bañarse en el agua, en el vino o incluso en vinagre. Pero ante todo adora meterse dentro de tarros de vidrio y enrollarse con una cebolla. Otra criatura con misteriosas costumbres...",ep:1,g:627,l:40,wd:true,fm:true,w:1,p:1};
I.u[8682] = {n:"Piel de Mob Lasponja",t:59,d:"Esta piel puede ser utilizada por los dos lados, el primero es suave y permite lavar las superficies frágiles, el otro es mucho más rugoso y permite por ejemplo limpiar las partes de su anatomía inaccesibles hasta entonces.",ep:1,g:628,l:10,wd:true,fm:true,w:1,p:1};
I.u[8683] = {n:"Regalo: Walk",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8684] = {n:"Certificado de admisión en la petrera: Ross",t:77,d:"Este certificado describe las características de Ross, al que has dejado en la petrera.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8685] = {n:"Certificado de admisión en la petrera: Bilby",t:77,d:"Este certificado describe las características de Bilby, al que has dejado en la petrera.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8686] = {n:"Regalo: Ross",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8687] = {n:"Regalo: Bilby",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8688] = {n:"Transformación fantasma Ross",t:27,d:"Te has transformado en fantasma para poder entrar en el santuario de las mascotas.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Venda Pandawushu",t:24,d:"Le has cogido esta venda al discípulo Pandawushu como símbolo de tu victoria.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Fórmula de pócima de transformación",t:24,d:"Este documento contiene las teorías de varios alquimistas sobre la posibilidad de transformarse en Wabbit. Realmente los alquimistas se aburren mucho...",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Feanor",t:18,d:"Gracias a esta mascota, cualquier persona del sexo opuesto intentará ligarte. Un consejo: ándate con pies de plomos. Te darás rápidamente cuenta de que en realidad esa persona está hipnotizada por Feanor. Y no creas que podrás aprovecharte de la situación, ahora tu pretendiente come pischi crudo frotándose contra tus piernas... No es un comportamiento muy \"glamur\". Esta mascota solamente come pescado.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Pimiento relleno",t:42,d:"Este pimiento relleno está cubierto con caramelo rojo derretido y superpoderoso. Esta mezcla explosiva entre la confitería y el pimiento le permitió al dragopavo Brezo Rubio ganar una de las más famosas carreras de Dragokart. Lo puedes usar como supositorio para correr más rápido o como dragea si te huele mal el aliento.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"Penispada",t:6,d:"Como decía Brice: \"El tamaño no es lo que importa, sólo lo bien que la usas cuenta\".",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
I.u[8699] = {n:"Tocado del Tynril",t:16,d:"Con este tocado en la cabeza, siempre estarás greñudo, por muy bien que te peines. No hay que olvidar que la corteza del cabellera del Tynril se riza cuando el tiempo es húmedo, lo que convierte a este animal en el higrómetro natural más exacto que existe. Sin embargo, huye del fuego, así que ten cuidado si no quieres convertirte en la increible antorcha humana.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Cáscara Esmeralda",t:16,d:"Parece que este casco era antes un Dofus Esmeralda que se ha roto. El Dofus todavía no está del todo vacío, podrás aprovechar para hacerte un champú a base de huevo.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Espada Jikote",t:6,d:"Esta lujosa espada perteneció a un gran ladrón, famoso porque le atrapaban cada vez que cometía un delito.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
