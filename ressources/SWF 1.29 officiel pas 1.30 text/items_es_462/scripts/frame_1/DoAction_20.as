I.u[8255] = {n:"Pala de Esponja",t:8,d:"Esta arma terriblemente potente contra las motas de tierra ha marcado a más de un aventurero novato. Después de mojarla se ablanda y se puede enrollar, muy práctico para guardarla en tu mochila.",ep:1,g:44,l:10,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,true],s:63,p:500};
I.u[8256] = {n:"Botas de Esponja",t:11,d:"Con estas botas, un Aniripsa puede caminar sobre el agua lo cual no le sirve para nada ya que puede volar pero eso impresiona a una cantidad de gente increíble. Los demás podrán utilizar estas botas para rascarse los pies al mismo tiempo que se camina o sencillamente para limpiarlos.",ep:1,g:84,l:11,wd:true,fm:true,w:5,s:63,p:525};
I.u[8257] = {n:"Cinturón de Esponja",t:10,d:"Este cinturón le permitía a Vlad tomarse un baño sin peligro ya que ningún Yopuka sabe nadar.",ep:1,g:102,l:10,wd:true,fm:true,w:5,s:63,p:500};
I.u[8258] = {n:"Capa de Esponja",t:17,d:"Esta capa es ideal para el camuflaje en medio natural, pero solamente si no hay nadie que te pueda ver.",ep:1,g:109,l:10,wd:true,fm:true,w:1,s:63,p:505};
I.u[8259] = {n:"Sombrero de Esponja",t:16,d:"En el folleto explicativo podemos leer: \"Regala este sombrero a tu marido, atorníllalo en su cabeza, agárralo por los pies y arrástralo hasta la cocina. El suelo se quedará limpio y reluciente\". Para parejas modernas que se reparten las tareas domésticas sin ningún complejo.",ep:1,g:143,l:11,wd:true,fm:true,w:10,s:63,p:525};
I.u[8260] = {n:"Pañuelo kalipto",t:16,d:"¡Con este pañuelo, los yopukas se lucirán!",ep:20,g:124,l:133,wd:true,fm:true,w:10,p:43500};
I.u[8262] = {n:"El Amaxilubeto",t:1,d:"El Amaxilubeto encierra una extraña sustancia que brota de las entrañas del maxilubo. Muchos dicen que se trata de la esencia del monstruo, otros piensan que devoró un Kirbola caducado.",ep:20,g:107,l:143,wd:true,fm:true,w:1,s:55,p:44850};
I.u[8263] = {n:"Anillo del maxilubo",t:9,d:"Cuidado, este anillo hará que tu dedo tenga un olor apestoso. Un olor que podría encubrir otro. Tal vez sea cosa buena para tu dedo y para tu entorno...",ep:20,g:113,l:126,wd:true,fm:true,w:10,s:55,p:40190};
I.u[8264] = {n:"Botas del maxilubo",t:11,d:"Estas botas todavía llevan en su esencia una parte del voraz apetito del Maxilubo. Si tus pies huelen a Kesitufo, puede que muerdan.",ep:18,g:85,l:131,wd:true,fm:true,w:20,s:55,p:42840};
I.u[8265] = {n:"Capa del Maxilubo",t:17,d:"El maxilubo tiene una bonita cola tan grande que le arrastra por el suelo. Algunos aventureros envidiosos se la arrancaron y la llevan puesta... Creen que eso incrementará su virilidad.",ep:20,g:110,l:139,wd:true,fm:true,w:10,s:55,p:44500};
I.u[8266] = {n:"Cinturón del Maxilubo",t:10,d:"Este cinturón colorado tiene un magnífico mechón violáceo por delante, también se puede llevar del revés para disfrazarte en Wabbit.",ep:20,g:103,l:125,wd:true,fm:true,w:1,s:55,p:1};
I.u[8267] = {n:"Casco del Maxilubo",t:16,d:"Al descuartizar el maxilubo unos cazadores se dieron cuenta de que solamente tiene un grueso cuerno que le atraviesa el cráneo de parte a parte. No es una molestia para los Yopukas, ellos lo lucen con entusiasmo y sin disimulo alguno.",ep:4,g:144,l:141,wd:true,fm:true,w:10,s:55,p:44600};
I.u[8268] = {n:"Collar del Minotauroro",t:1,d:"Este collar le permitía al Minotauroro protegerse contra las pulgas, las garrapatas o incluso contra los piojos. Te vendrá como anillo al dedo.",ep:18,g:112,l:111,wd:true,fm:true,w:1,s:54,p:31260};
I.u[8269] = {n:"Anillo del Minotauroro",t:9,d:"A pesar de lo que cuentan algunos aventureros, este anillo nunca ha sido llevado por el Minotauroro, por la sencilla razón que le resultaría imposible ponerse el anillo en la pezuña.",ep:21,g:117,l:105,wd:true,fm:true,w:1,s:54,p:28010};
I.u[8270] = {n:"Pulsera del Minotot",t:9,d:"Esta pulsera permite proteger la totalidad del brazo de un Aniripsa, pero triplica su peso.",ep:21,g:116,l:151,wd:true,fm:true,w:10,s:57,p:45425};
I.u[8271] = {n:"Anillo del Dragocerdo",t:9,d:"Este anillo de cuero y de marfil permite estimular más fácilmente a tus compañeros.",ep:18,g:115,l:108,wd:true,fm:true,w:1,s:58,p:29600};
I.u[8272] = {n:"Collar del Minotot",t:1,d:"Este collar permitía a los Minotot proteger sus cervicales y evitar la muerte por culpa de un golpe estúpido de Wabbit.",ep:21,g:111,l:158,wd:true,fm:true,w:20,s:57,p:47800};
I.u[8273] = {n:"Collar del dragocerdo",t:1,d:"Este collar tiene una pequeña argolla que permitía atar una cuerda al cuello del Dragocerdo cuando su dueño quería sacarlo a pasear por la noche.",ep:21,g:110,l:100,wd:true,fm:true,w:1,s:58,p:25470};
I.u[8274] = {n:"Hacha del Minotauroro",t:19,d:"Esta hacha permitió cortarle la cabeza a uno de los más peligrosos minotauroros que la provincia de Amakna ha conocido. Lo más increíble en esta historia es que parece que te importa tres pepinos...",ep:21,g:44,l:109,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,40,50,false,true],s:54,p:30110};
I.u[8275] = {n:"Cetro del Minotot",t:4,d:"Este cetro, adornado en su extremidad con una cabeza de serpientita de joyas, te permitirá espantar a los jóvenes aventureros y provocar su huida a base de patadas en sus pequeñas nalgas rosas.",ep:21,g:67,l:151,wd:true,fm:true,w:50,an:12,tw:true,e:[5,4,1,1,40,50,false,false],s:57,p:46200};
I.u[8276] = {n:"Botas del Minotauroro",t:11,d:"Es evidente, estas terribles botas de cuero y con pelo del Minotauroro no te permitirán ganar la legendaria carrera de la bahía de Amakna, pues son demasiado pesadas. \nSin embargo, deberían permitirte aplastar fácilmente los pies de los demás concursantes en la línea de salida.",ep:21,g:89,l:113,wd:true,fm:true,w:40,s:54,p:32290};
I.u[8277] = {n:"Sandalias del minotot",t:11,d:"Con estas increíbles sandalias, podrás bañarte en aguas de las más peligrosas, sin que tus pies sufran daños. Pero sé cauto, tienen fama de rayar el fondo de las bañeras.",ep:21,g:88,l:163,wd:true,fm:true,w:20,s:57,p:48400};
I.u[8278] = {n:"Zapatillas del dragocerdo",t:11,d:"Con un buen par de zapatillas te sentirás enseguida más fuerte, más poderoso y más atractivo... Lo que hace un par de zapatillas...",ep:20,g:87,l:93,wd:true,fm:true,w:5,s:58,p:22800};
I.u[8279] = {n:"Capa del Minotauroro",t:17,d:"Coge un Minotauroro, átalo muy fuerte, coge un cepillo gigante y pélale (de un solo golpe) la espalda. Ya está, ya tienes en tus manos una capa del Minotauroro.",ep:21,g:117,l:109,wd:true,fm:true,w:10,s:54,p:30500};
I.u[8280] = {n:"Capa del Minotot",t:17,d:"Para salir de marcha o para seducir en la fiesta de disfraces de Capitán Chafer. Ésta es la capa que necesitas.",ep:21,g:116,l:156,wd:true,fm:true,w:40,s:57,p:48850};
I.u[8281] = {n:"Capa del Dragocerdo",t:17,d:"Esta capa no hará de ti un cochinillo pero te permitirá tal vez disfrazarte durante una noche, para seducir a una bonita cerda.",ep:20,g:118,l:103,wd:true,fm:true,w:10,s:58,p:27500};
I.u[8282] = {n:"Cinturón del Minotauroro",t:10,d:"Este cinturón es tan flexible que puede servir para flagelar las nalgas de los niños demasiado traviesos. Con un poco de suerte, las piezas de metal permitirán arrancar algunos cachos de piel y los terribles gamberros acabarán asimilando sus lecciones definitivamente.",ep:21,g:106,l:111,wd:true,fm:true,w:1,s:54,p:1};
I.u[8283] = {n:"Cinturón del Minotot",t:10,d:"Este cinturón rígido le permitía al Minotot apretar su impresionante barriga para evitar que cualquier corriente de aire provocara su caída.",ep:21,g:105,l:149,wd:true,fm:true,w:30,s:57,p:49950};
I.u[8284] = {n:"Sombrero del minotot",t:16,d:"Este sombrero se va transmitiendo de generación en generación en la familia del Minotot. Eso explica en parte su olor a caspa en descomposición.",ep:21,g:151,l:157,wd:true,fm:true,w:20,s:57,p:47652};
I.u[8285] = {n:"Casco del dragocerdo",t:16,d:"Con este enorme cráneo, te parecerás a un Grizbola de pelos duros, pero sin pelos. Esto dejará sin habla a tus admiradoras.",ep:20,g:150,l:98,wd:true,fm:true,w:10,s:58,p:24500};
I.u[8286] = {n:"Capa de Dragohuevo",t:17,d:"Esta capa cubierta con escamas te protegerá según cuenta la leyenda, contra los rayos, las alubias y sobre todo las mujeres fatales.",ep:11,g:115,l:127,wd:true,fm:true,w:10,s:56,p:41000};
I.u[8287] = {n:"Casco Dragohuevo",t:16,d:"Este casco absolutamente terrorífico y cuyo tamaño es desproporcionado haría pasar a un pequeño querubín como tú por un despiadado guerrero llegado del más allá. Si lo clavas a una pared, podrás usarlo como si fuera un colgador para la ropa.",ep:11,g:149,l:128,wd:true,fm:true,w:10,s:56,p:41500};
I.u[8288] = {n:"Cinturón del Dragohuevo",t:10,d:"Los espíritus más traviesos de Amakna cuentan que este cinturón podía utilizarse como una prótesis. Nadie sabe por qué y menos mal que no es para nada cierto, se trata de un banal cinturón de Dragohuevo.",ep:20,g:104,l:124,wd:true,fm:true,w:1,s:56,p:1};
I.u[8289] = {n:"Anillo del Dragohuevo",t:9,d:"Este anillo directamente tallado en una escama gigante de Dragohuevo protegerá una pequeña parte de tus falanges. Seguramente la más importante.",ep:20,g:114,l:128,wd:true,fm:true,w:10,s:56,p:41468};
I.u[8290] = {n:"Amuleto del Dragohuevo",t:1,d:"Confeccionado a base de escamas de Dragohuevos, este amuleto protegerá eficazmente tu nuez de Adán o tus amígdalas. Estas ventajas se notarán mucho en el campo de batalla.",ep:11,g:108,l:124,wd:true,fm:true,w:1,s:56,p:38930};
I.u[8291] = {n:"Botas del Dragohuevo",t:11,d:"Estas botas son perfectas para matar la Jalabola durante una partida de Jálabol o para que tus enemigos sufran un poco más cuando les patees el trasero.",ep:20,g:86,l:129,wd:true,fm:true,w:20,s:56,p:41500};
I.u[8292] = {n:"Espada del dragohuevo",t:6,d:"Afilada como una hoja de afeitar, con esta espada podrás incluso afeitarte las axilas (bueno, si tienes el brazo bastante largo...).",ep:11,g:68,l:127,wd:true,fm:true,w:30,an:14,e:[8,5,1,1,40,50,false,true],c:"CS>200&CA>200",p:41025};
I.u[8293] = {n:"Hacha del Dragohuevo",t:19,d:"Esta hacha corta cabezas como si fueran mantequilla.",ep:20,g:43,l:126,wd:true,fm:true,w:20,an:17,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>180&CW>80",p:40854};
I.u[8294] = {n:"Martillo del dragohuevo",t:7,d:"Es más pesado que el cráneo vacío de un Kroker pero más frágil que un fémur de Kirbola de las cuevas. Sin embargo este martillo no deja de ser un arma que hace pupa.",ep:20,g:59,l:123,wd:true,fm:true,w:30,an:15,e:[10,5,1,1,45,50,false,true],c:"CI>200&CC>100",p:38542};
I.u[8295] = {n:"Arco del Dragohuevo",t:2,d:"Este arco es tan potente que permite enviar huevos podridos de Dragohuevos por encima de las murallas de Brakmar. ¡Vaya despilfarro!",ep:20,g:55,l:122,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,8,40,50,false,true],c:"CS>300&CV>250",p:38015};
I.u[8296] = {n:"Varita de Dragohuevo",t:3,d:"Esta varita parece más eficaz cuando es utilizada como una porra o como un aplasta moskitos.",ep:21,g:60,l:124,wd:true,fm:true,w:10,an:11,e:[5,3,2,5,30,30,false,true],c:"CI>100&CA>200",p:37884};
I.u[8297] = {n:"Bastón del Dragohuevo",t:4,d:"Este bastón lleva en su extremidad una punta cuyo origen es totalmente desconocido. En cambio, los aventureros experimentados saben donde meterla...",ep:20,g:66,l:124,wd:true,fm:true,w:30,an:12,tw:true,e:[5,5,1,1,30,50,false,true],c:"CS>300&CA>150&CV>300",p:39800};
I.u[8298] = {n:"Espiga de Shika",t:1,d:"Shika le ayudaba a Farle durante las cosechas recuperando las espigas mágicas que iban cayendo bajo los golpes de su guadaña. A lo largo de las cosechas tomó la costumbre de colgárselas al cuello. A pesar de estar privadas de sus raíces y del resto de sus tallos, estas espigas mágicas siguen madurando cada año en la misma época.",ep:18,g:113,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8299] = {n:"Pulsera Mágica de Shika",t:9,d:"Esta pulsera cubría los brazos de Shika, protegiéndola contra las quemaduras de sol y los picotazos de los Cuerboks atraídos por su belleza resplandeciente. Todavía lleva impregnado su suave sudor.",ep:21,g:118,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8300] = {n:"Bastón de Shika",t:4,d:"Este bastón tallado a la medida, le permitía a Shika crear las muelas de paja más altas de toda Amakna. Cuenta la leyenda que su tamaño era tan grande que los marineros las usaban para saber si se estaban acercando a la costa de Amakna.",ep:20,g:69,l:80,wd:true,fm:true,w:10,an:12,e:[10,5,1,1,45,45,false,false],s:53,p:16500};
I.u[8301] = {n:"Zuecos de Shika",t:11,d:"Estos zuecos fueron diseñados para que Shika no pisara sus sembrados cuando iba sembrando por las llanuras de Snossios. Ella le añadió los tacones de aguja para poder correr cada mañana comodamente por las praderas sin mojarse con el rocío y para no dañar sus frágiles tobillos.",ep:21,g:91,l:80,wd:true,fm:true,w:10,s:53,p:16600};
I.u[8302] = {n:"Capa de Shika",t:17,d:"Esta capa confeccionada con cereales mágicas tejidas entre sí lleva flores cosidas encima. Está animada con una magia tan potente, que Shika la utilizaba para protegerse contra los rayos, las noches de tormenta.",ep:20,g:120,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8303] = {n:"Shikaturón",t:10,d:"Este cinturón de cuero protegía los muslos de Shika cuando atravesaba corriendo los campos de trigo en busca de los jalatós de su rebaño que se habían perdido. Está cubierto de polen de cereales mágicos. Se cuenta que brillaba con la luz de la luna y gracias a él, Farle no le seccionaba las piernas a su propia esposa cuando segaba campos enteros de cereales por la noche.",ep:21,g:107,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8304] = {n:"Shikasombrero",t:16,d:"Está cubierta por una multitud de flores. Este sombrero le lucía mucho a Shika cuando se iba por la mañana a labrar las colinas de Koln.",ep:20,g:156,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8305] = {n:"Reliquia del Mominotauro",t:24,d:"Esta extraña reliquia es indispensable para poder conocer al Minotauroro.",ep:21,g:119,l:1,wd:false,fm:true,w:0,p:1};
I.u[8306] = {n:"Reliquia del Deminobola",t:24,d:"Esta extraña reliquia es indispensable para poder conocer al Minotauroro.",ep:21,g:120,l:1,wd:false,fm:true,w:0,p:1};
I.u[8307] = {n:"Llave de la sala del Minotot",t:84,d:"Esta llave fabricada con diversos recursos te permitirá conocer al increíble Minotot. Será un momento que te marcará de por vida cuando el Minotot te haya dado unas cuantas patadas en la cocorota.",ep:13,g:15,l:1,wd:true,fm:true,w:1,p:10};
I.u[8308] = {n:"Caparazón de escarato",t:107,d:"Este pequeño caparazón reluciente es muy práctico para crear bonitas joyas por poco dinero, que venderás por una fortuna en cuanto hayas convencido a un Astrubiense de que es una poderosa reliquia que permite volar por los aires de forma totalmente invisible...",ep:21,g:735,l:1,wd:true,fm:true,w:1,p:10};
I.u[8309] = {n:"Pluma de Serpipluma",t:53,d:"Esta pluma está recubierta de polvo de piedra mágica, lo que explica que una sola pluma de Serpipluma pese más del triple que una pluma de tofu. Todo es cuestión de lógica.",ep:21,g:4,l:1,wd:true,fm:true,w:10,p:1};
I.u[8310] = {n:"Gelatina descongelada",t:110,d:"Este tarro de gelatina contiene una sustancia que huele a muerto y que sabe a vómito. Sin embargo, todas las noches sueñas secretamente con poder untarte con esta sustancia. Realmente deberías consultar a un curandero...",ep:21,g:736,l:1,wd:true,fm:true,w:1,p:1};
I.u[8311] = {n:"Pelo de minovillo",t:54,d:"Este pelo parece recubierto de una especie de gomina hecha a base de musgo de tufo de pelo raso y de grasa de kirbola de las cavernas. Casi da ganas de comérselo.",ep:21,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[8312] = {n:"Piel de minoskito",t:59,d:"Esta piel curtida por la arena fina y la sal del mar es tan fina como un viejo calcetín deesgastado por la arena fina y la sal del mar. De ahí a decir que el Minoskito parece un viejo calcetín sólo hay un paso que no darás.",ep:21,g:604,l:1,wd:true,fm:true,w:1,p:1};
I.u[8313] = {n:"Fémur del minotauroro",t:47,d:"Este hueso es tán resistente que con él podrías romper ladrillos empilados de diez en diez. Muy práctico para destruir la casa del vecino, pero totalmente inutil para las personas sin probleas de orden mental.",ep:2,g:644,l:1,wd:true,fm:true,w:1,p:1};
I.u[8314] = {n:"Piel de Krameleón",t:59,d:"Esta piel quemada protege eficazmente las pieles sensibles de los rayos del sol. Para ello tiene que estar muy pegadita al cuerpo.",ep:21,g:603,l:1,wd:true,fm:true,w:1,p:1};
I.u[8315] = {n:"Piel de mandrina",t:59,d:"Esta piel manchada es mundialmente conocida porque se dice que está cubierta de un veneno capaz de transformar a cualquiera en un karabola desecado. Intrigante y tentador a la vez.",ep:21,g:602,l:1,wd:true,fm:true,w:1,p:1};
I.u[8316] = {n:"El Pekefux: Criarlo bien",t:25,d:"Este libro escrito por Yokashi Temato Konkatana explica cómo criar a los Pekefux.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8317] = {n:"El Escarador: Criarlo bien",t:25,d:"Este libro escrito por Yokashi Temato Konkatana explica cómo criar a los Escaradores.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8318] = {n:"Abra Kadabra: Criarlo bien",t:25,d:"Este libro escrito por Yokashi Temato Konkatana explica cómo criar Abra Kadabras.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8319] = {n:"Boluto: Criarlo bien",t:25,d:"Este libro escrito por Yokashi Temato Konkatana explica cómo criar a los Bolutos.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8320] = {n:"Llave del antro del Dragocerdo",t:84,d:"Después de haberte perdido en el laberinto del Dragocerdo, te has dado cuenta de que te olvidaste traer contigo las llaves del antro del Dragocerdo. Menos mal, tus amigos los Porcos tenían un doble de las llaves en sus bolsillos.",ep:15,g:16,l:1,wd:true,fm:true,w:1,p:100};
I.u[8321] = {n:"Pelos del Deminobola",t:54,d:"No insistas, estos pelos no son comestibles.",ep:21,g:664,l:100,wd:true,fm:true,w:1,p:10};
I.u[8322] = {n:"Pelo de mominotauro",t:54,d:"Bajo sus vendas, el mominotauro oculta un pelaje tan suave que sería la envidia de las princesas más coquetas, si tan sólo éstas se acercasen lo suficiente a los mominotauros.",ep:21,g:663,l:100,wd:true,fm:true,w:1,p:10};
I.u[8323] = {n:"Cuero del Deminobola",t:56,d:"Rugoso y crujiente, este cuero te recordará las mejillas de tu Dulcinea.",ep:21,g:657,l:100,wd:true,fm:true,w:1,p:10};
I.u[8324] = {n:"Cuero de mominotauro",t:56,d:"Si el mominotauro siempre va envuelto en vendajes no es sino por su piel frágil. Estos vendajes son mucho más eficaces que cualquier crema o poción aniripsa.",ep:21,g:656,l:100,wd:true,fm:true,w:1,p:10};
I.u[8325] = {n:"Sombrero del mominotauro",t:16,d:"Si quieres que el paso de los años no altere tu piel de bebé, te aconsejamos este sombrero. Pero ojo, es totalmente ineficaz contra las pérdidas de memoria.",ep:0,g:157,l:110,wd:false,fm:true,w:10,s:59,p:100};
I.u[8326] = {n:"Venda del mominotauro",t:15,d:"Enrolladas en los cuernos, pero sobre todo en las partes íntimas del Mominotauro, estas vendas se han impregnado durante muchos años con la magia del Mominotauro. Terroríficas y malolientes a la vez, estas vendas sería el orgullo de la colección de lo más famosos arqueólogos.",ep:21,g:734,l:100,wd:true,fm:true,w:1,p:10};
I.u[8327] = {n:"Cuerno del Deminobola",t:47,d:"Este impresionante cuerno parece no servir para nada, pero si la miras con cuidado y más de cerca, verás que, efectivamente, sirve para tan poca cosa como un ejército de pulgas.",ep:21,g:643,l:100,wd:true,fm:true,w:1,p:10};
I.u[8328] = {n:"Cuerno de mominotauro",t:47,d:"Envuelta en sus vendas mágicas, este cuerno se, evidentemente, muy caro, muy precioso, apestoso y maldito. Un poco como todas las momias.",ep:21,g:642,l:100,wd:true,fm:true,w:1,p:10};
I.u[8330] = {n:"Sombrero de Dragohuevo volador",t:16,d:"Este pequeño sombrero permite al dragohuevo volador arrojarse sobre sus enemigos sin tener que sufrir chichones en el cráneo. Utilizado desde tiempos remotos en las obras públicas de Amakna, este sombrero aumentó su fama a raíz de la invasión de Astrub por la famosa tropa de mediulubos desbocados de la montaña de Krup. Esta historia no tiene lógica, ¿y qué?",ep:13,g:152,l:72,wd:true,fm:true,w:10,p:16000};
I.u[8331] = {n:"Sombrero de la Dragosa",t:16,d:"Con este sombrero puesto en la cabeza podrás, sin dificultad, disfrazarte y seducir a algún Astrubiense inocentón. Luego lo podrás estafar proponiéndole una loca noche de amor detrás de un enorme olmo por tan sólo 100 kamas.",ep:18,g:153,l:95,wd:true,fm:true,w:10,p:23000};
I.u[8333] = {n:"Capa de Chanta Klaus",t:17,d:"Esta misteriosa capa aparece cuando llega el frío y permite hacerte pasar por un viejito generoso.",ep:1,g:119,l:19,wd:true,fm:true,w:10,p:1205};
I.u[8334] = {n:"Sombrero de Chanta Klaus",t:16,d:"Este sombrero te permitirá ocultar las cicatrices que tienes en la cocorota. Por fin ya no espantarás a los niños...",ep:1,g:155,l:22,wd:true,fm:true,w:10,p:1478};
I.u[8335] = {n:"Pequeño Regalo de Nawidad.",t:89,d:"El equipo Ankama te desea unas felices y agradables fiestas. Este regalo te colmará de felicidad.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8336] = {n:"Regalito de Nawidad",t:89,d:"El equipo Ankama te desea unas felices y agradables fiestas. Este regalo te colmará de felicidad.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8337] = {n:"Regalo: de Nawidad",t:89,d:"El equipo Ankama te desea unas felices fiestas. Este Regalo: te colmará de felicidad.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8338] = {n:"Espada de Nawidad",t:6,d:"Esta extraña espada no te volverá invencible, pero tal vez consigas utilizarla para matar bolas de nieve...",ep:1,g:69,l:1,wd:false,fm:true,w:1,an:14,e:[1,1,1,1,2,2,false,true],p:1};
I.u[8339] = {n:"Gran Regalo de Nawidad",t:89,d:"El equipo Ankama te desea unas felices y agradables fiestas. Este regalo te colmará de felicidad.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8340] = {n:"Increíble regalo de Nawidad",t:89,d:"El equipo Ankama te desea unas felices y agradables fiestas. Este regalo te colmará de felicidad.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8341] = {n:"Botapiñas",t:11,d:"Estas botas huelen a zumo de piña macerada en substrato de calcetín agujereado. La ventaja es que nadie te pedirá que te los quites cuando vayas a casa de un amigo.",ep:1,g:90,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8342] = {n:"Llave del Santuario de los Dragohuevos",t:84,d:"Esta llave hecha con cáscaras de Dragohuevo te permitirá acceder al terrible Santuario de los Dragohuevos, famoso por la escasa locuacidad de sus habitantes.",ep:10,g:18,l:1,wd:true,fm:true,w:1,p:100};
I.u[8343] = {n:"Llave de la Mazmorra de los Dragohuevos",t:84,d:"Puede que al entrar en el Santuario de los Dragohuevos pensaras que sería el final de tus sufrimientos... Pues lamentablemente te has equivocado. Esta llave será tal vez la causa de tu muerte.",ep:10,g:17,l:1,wd:true,fm:true,w:1,p:100};
I.u[8344] = {n:"Cuerno de dragoss negro",t:47,d:"Es menos puntiagudo que una aguja de Xelor pero más resistente. Este cuerno les permite a los Dragoss dar cornadas al trasero de sus adversarios.",ep:11,g:648,l:50,wd:true,fm:true,w:1,p:10};
I.u[8345] = {n:"Cuerno de dragoss de zafiro",t:47,d:"Es menos puntiagudo que una aguja de Xelor pero más resistente. Este cuerno les permite a los Dragoss dar cornadas al trasero de sus adversarios.",ep:11,g:647,l:50,wd:true,fm:true,w:1,p:10};
I.u[8346] = {n:"Cuerno de dragoss blanco",t:47,d:"Es menos puntiagudo que una aguja de Xelor pero más resistente. Este cuerno les permite a los Dragoss dar cornadas al trasero de sus adversarios.",ep:11,g:646,l:50,wd:true,fm:true,w:1,p:10};
I.u[8347] = {n:"Cuerno de dragoss dorado",t:47,d:"Es menos puntiagudo que una aguja de Xelor pero más resistente. Este cuerno les permite a los Dragoss dar cornadas al trasero de sus adversarios.",ep:11,g:645,l:50,wd:true,fm:true,w:1,p:10};
I.u[8348] = {n:"Cáscara de dragoss negro",t:111,d:"Esta cáscara puede servir para proteger tus pertenencias más valiosas.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Cáscara de dragoss de zafiro",t:111,d:"Esta cáscara puede servir para proteger tus pertenencias más valiosas.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
I.u[8350] = {n:"Cáscara de dragoss blanco",t:111,d:"Esta cáscara puede servir para proteger tus pertenencias más valiosas.",ep:11,g:740,l:50,wd:true,fm:true,w:1,p:10};
I.u[8351] = {n:"Cáscara de dragoss dorado",t:111,d:"Esta cáscara puede servir para proteger tus pertenencias más valiosas.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Escama de dragoss negro",t:59,d:"Esta escama de dragoss podría servir para confeccionar unas bonitas botinas o prendas interiores de combate.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Escama de dragoss zafiro",t:59,d:"Esta escama de dragoss podría servir para confeccionar unas bonitas botinas o prendas interiores de combate.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"Escama de dragoss blanco",t:59,d:"Esta escama de dragoss podría servir para confeccionar unas bonitas botinas o prendas interiores de combate.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Escama de dragoss dorado",t:59,d:"Esta escama de dragoss podría servir para confeccionar unas bonitas botinas o prendas interiores de combate.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Piel de dragosa",t:59,d:"Lisa y perfumada con la sangre de jóvenes aventureros, esta piel hace que las Dragosas sean irresistibles. Si la utilizas para hacer botas o cinturones, esta piel tiene la ventaja de poderse lavar a máquina a cualquier temperatura.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Cuerno de Dragosa",t:47,d:"La Dragosa dispone de dos pequeños cuernos detrás del cráneo que le permite captar más fácilmente las ondas amorosas emitidas por los demás Dragohuevos durante la época de los amores que por cierto nunca termina para los Dragohuevos.",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Protección de la Dragosa",t:111,d:"Este par de cáscaras de Dragohuevo le permite a la Dragosa protegerse de sus propios Rayos Amorosos. Esta protección también la pueden utilizar los machos, si la llevan por debajo de la cintura.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Ala de dragohuevo volador",t:104,d:"Aunque estropeada, desgarrada y quemada, esta ala le permite al Dragohuevo Volador moverse libremente por los aires, igual que un joven moskito despreocupado.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Piel de Dragohuevo Volador",t:59,d:"Esta piel oscura está recubierta por una multitud de pequeñas escamas que supuestamente, mejoran el aerodinamismo del Dragohuevo Volador. En realidad, solamente les sirve para impresionar a los transeúntes más curiosos.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Cuerno de Dragohuevo Volador",t:47,d:"Este cuerno es como el punto de mira del Dragohuevo Volador. Le permite no fallar sus ataques, cuando no está totalmente ebrio.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Piel de Dragohuevo Guerrero",t:59,d:"Es lo suficientemente sólida como para resistir a los golpes de su propia espada. La piel del Dragohuevo Guerrero tiene fama sobre todo por ser comestible, después de haberla hervido durante varios años...",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Cuerno de Dragohuevo Guerrero",t:47,d:"El Dragohuevo Guerrero tiene tres cuernos distintos, dos detrás de la cabeza y uno encima del hocico. \nEn general, después de un ataque, un cuerno acaba hundido en el trasero de sus víctimas y las dos restantes en las narices de los imprudentes. Sin embargo a veces, el Dragohuevo Guerrero confunde el trasero y la nariz de sus víctimas, lo cual puede resultar todavía más problemático.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Correa de cuero del Dragohuevo Guerrero",t:15,d:"Esta correa de cuero le permite al Dragohuevo Guerrero colgar su hombrera o también te podrá servir para hacerte unos tirantes.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Cuerno roto de Crocabulia",t:47,d:"Crocabulia ha roto su propio cuerno durante un terrible combate en el cual intentaba proteger el huevo del que nació, 15 años más tarde, el Cocoburio.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Capa del Capón Turcito Rojo",t:17,d:"Esta capa pertenecía a un famoso Capón, un viejo ave con largas plumas al que le gustaba pasearse por el Zaap de Bonta delante de un corral lleno de inocentes gallinas y de pollas inmaduras.",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Piel de Crocabulia",t:59,d:"Esta piel roja te permitirá tal vez confeccionar la capa del Tacirupeco Rojo, si no temes que tus aliados se burlen de ti.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Diente de Crocabulia",t:47,d:"Un aguerrido aventurero le arrancó esta enorme diente al crocabulia \"in extremis\", justo antes de que cerrase sus fauces para siempre.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Fragmento de cáscara de Terrakubiack el Guerrero",t:111,d:"Este fragmento de cáscara pertenecía a Terrakubiack el guerrero, con él deberías conseguir fabricar una llave para el santuario de los Dragohuevos.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Fragmento de cáscara de Ignelicrobur el Guerrero",t:111,d:"Este fragmento de cáscara pertenecía a Ignelicrobur el guerrero, con él deberías conseguir fabricar una llave para el santuario de los Dragohuevos.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Fragmento de cáscara de Aerohuctor el Guerrero",t:111,d:"Este fragmento de cáscara pertenecía a Aerohuctor el guerrero, con él deberías conseguir fabricar una llave para el santuario de los Dragohuevos.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Fragmento de Aquabralak el Guerrero",t:111,d:"Este fragmento de cáscara pertenecía a Aquabralak el guerrero, con él deberías conseguir fabricar una llave para el santuario de los Dragohuevos.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Piedra de Ignirkocropos el Hambriento",t:51,d:"Si se combina esta piedra con tres otras liberará una onda mágica lo suficientemente potente como para activar y abrir una puerta mágica.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Piedra de Acualikros el Despiadado",t:51,d:"Si se combina esta piedra con tres otras liberará una onda mágica lo suficientemente potente como para activar y abrir una puerta mágica.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Piedra de Terraburkal el Pérfido",t:51,d:"Si se combina esta piedra con tres otras liberará una onda mágica lo suficientemente potente como para activar y abrir una puerta mágica.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Piedra de Aerotrugobur el Malvado",t:51,d:"Si se combina esta piedra con tres otras liberará una onda mágica lo suficientemente potente como para activar y abrir una puerta mágica.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Runa de Manitas",t:88,d:"Esta piedra mágica les permite a los Manitas comunicarles su posición a sus clientes.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Fragmento mágico",t:88,d:"Este fragmento mágico contiene una parte de la magia encerrada en un objeto. Con un poco de suerte, podrás recuperar unas cuantas runas mágicas.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Runa Vida",t:78,d:"Esta pequeña runa tiene el poder de volver más resistente.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Tejido del Peki",t:55,d:"Este tejido cubría las nalgas peludas del Peki antes de que decidieras quitársela.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Cola mágica del Peki",t:65,d:"Esta cola es tan mágica que todavía se mueve, incluso tras haber sido cortada y disecada. Si buscas bien, puede que le encuentres alguna utilidad que no sea puramente decorativa.",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Piel de Moon",t:59,d:"Sin su pequeña piel suave, el pobre Moonito prefirió huir como un cobarde hacia la selva gritando de dolor. Una escena divertida que no te olvidarás de contar a tus hijos por la noche para ayudarles a conciliar el sueño.",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Tejido mágico de Moon",t:55,d:"Este tejido se parece a un tejido mágico y te cuesta bastante aceptarlo. Sin embargo algún día tendrás que reconocerlo ya que eres demasiado tonto como para saber lo que es mágico y lo que no lo es. No sigas tu instinto de asesino de Astrubienses, confía en lo que pone en las descripciones.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Piel de Shin Larva",t:59,d:"Esta piel de Shin Larva es aún más pegajosa de que lo pensabas. Te recuerda la última princesa que liberaste.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Diente de Shin Larva",t:47,d:"Quién se hubiese creido que una Shin Larva pudiera tener la boca llena de dientes. Esto se explica por el mero hecho de que Shin Larva luce un sólo diente.",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Pluma vibrante del Tofu Real",t:53,d:"Es más real que la pluma del Tofu Real, más vibrante que la pluma de un Kirbola Vibrante de las minas de Kruup. Con esta pluma podrás hacer cosquillas a quien quieras en donde quieras. En el manual de uso explican que se lava con agua tibia y jabón.",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Piel de Bworka",t:59,d:"Bworka te dejó que le arrancaras un pedazo de piel a cambio de su mansedumbre. Pero se le olvidó decirte que avisó a su hermano mayor, Bworkero, para que se deleitará arrancándote tu propia piel.",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Pelos de Bworka",t:54,d:"Las hembras de bwork tienen la piel lisa, salvo bajo las axilas. Así aprovechan para aliñar los bizcochos a los que dan forma con sus axilas.",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Piel de Cerdo de Farle",t:59,d:"Farle era el mayor criador de cerdos y tal vez incluso de cerdas. Bueno, eso lo solían decir aquellas malas lenguas que le tenían envida por tener a Shika como esposa. Lo cierto es que él fue el autor de la denominación \"Cerdos de Farle\" ya que los creó a su imagen.",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"Piel de Don Dórgano",t:59,d:"El Don Dórgano ha sido una vez más muy generoso contigo, a pesar de su terrible carácter. Te ha regalado su piel antes de marcharse gruñendo como un Puerkazo. ¡Qué cara tiene!",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"Piel de Don Dessangre",t:59,d:"El Don Dessangre que has conseguido pelar con un raspador de queso para conseguir esta piel muy fina se acordará de ello toda su vida. Podemos suponer que te guardará rencor durante mucho tiempo. Ya no cuentes con él para que  te indique tu camino la próxima vez que te pierdas en su laberinto.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Pelo de dragocerdo",t:54,d:"Por más que le des vueltas, no consigues encontrar la parte del cuerpo del dragocerdo donde estaba plantado este pelo. Buscando con más empeño, la anatomía del dragocerdo te  revelará numerosas sorpresas...",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Mega piedra del Crujidor Legendario",t:51,d:"Esta enorme piedra se parece a una piedra del Crujidor Legendario, pero las apariencias engañan, su poder es todavía más demoledor.",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Mojo del mediulubo",t:15,d:"Este pequeño frasco contiene toda la virilidad del mediulubo. Ojo, su contenido no es comestible.",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Pelo del Wey Wabbit",t:54,d:"El Wey Wabbit es en general bastante tacaño y no suele compartir sus pelos con nadie. Excepcionalmente, para recompensar tu valentía (o comprar tu clemencia) decidió darte una parte de su cuerpo. Todo un detalle.",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Paño del Wey Wabbit",t:55,d:"Nadie sabe realmente de donde ha sacado el Wey Wabbit este paño y parece que nadie lo quiere saber. El origen de este paño sigue siendo uno de los mayores misterios de toda Amakna.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Pelo de Maestro Pandora",t:54,d:"Una vez más, el Maestro Pandora ha querido hacerse el listillo y no olvidará esta lección tan pronto. Hubiera tenido que quedarse dentro de su caja.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Tejido de Maestro Pandora",t:55,d:"Este tejido protegía la nuca y el trasero del Maestro Pandora. Pero esta vez no le sirvió de mucho.",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Piel de Maestro Pandora",t:59,d:"Está gastada por tantos ataques mágicos y además el viento de Pandala acabó secándola por completo. Esta piel es de mala calidad, sin embargo parece que tiene un valor sentimental particular para ti a pesar de que su dueño casi te quite la vida varias veces sin el menor remordimiento. Esa es toda la diferencia entre un verdadero monstruo y un cobarde como tú.",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Piedra del trankitronko",t:51,d:"Aunque el Trankitronko sea muy generoso, no te ha dado su gran piedra con muchas ganas, y es fácil entenderlo cuando se sabe lo que vas a hacer de ella.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
I.u[8403] = {n:"Trenza del Trankitronko",t:15,d:"El Trankitronko se hizo este tranza él mismo, hace varios siglos. Con el paso del tiempo se ha vuelto más dura que una roca. Aún así todavía está repleta de un líquido biscoso y nauseabundo que, de vez en cuando, atrae a los Moskitos. Lo más sorprendente de todo, es que la trenza le quedaba muy bien al Trankitronko. ¡Sólo a tí se te podía ocurrir el robársela!",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Piel de Skonk",t:59,d:"Parece que este pedazo de piel proviene de los talones del Skonk, eso explicaría ese agradable matiz amarillento. Aunque no puedas hacerte ropa de moda, con esta vieja piel podrás hacerte ropa \"de otra época\", unos aires antiguos que impresionarán a los más jóvenes.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Pelo de Skonk",t:54,d:"A parte tuya, ¿Quién hubiera podido imaginar que Skonk no se depilaba el cuerpo entero desde su más tierna infancia?",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Lana del minotot",t:57,d:"Esta lana particularmente fina, hace que el minotot no tenga tirabuzones en su cuerpo. Nadie sabe con certeza para que le sirve, pero tú puedes usarla para hacerte implantes capilares y así alardear con tu nueva mata de pelo en el pecho. ¡Hasta los sueños de infancia pueden volverse realidad!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Cuero del Minotot",t:56,d:"A penas más raro que el cuero de Jalató, este cuero es ideal para las creaciones que requieren costuras flexibles, como las máscaras de cuero por ejemplo.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Pezuña de Minotot",t:47,d:"Esta pezuña ha machacado a muchos aventureros y también a algunas mierdecillas perdidas en el Laberinto del Minotauroro. También hay que admitir que no es fácil distinguir entre los ambos del primer vistazo... ¡Pobre Minotot!",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
I.u[8409] = {n:"Cuerno del Minotot",t:47,d:"De lejos, este cuerno parece un cuerno de jalató gigante y extremadamente mágico. Sorprendentemente, de cerca se parece a un cuerno de Minotot.",ep:21,g:655,l:400,wd:true,fm:true,w:1,p:10};
I.u[8410] = {n:"Fémur del minotot",t:47,d:"Este imponente hueso ha conseguido soportar la sobrecarga ponderal del minotot durante varios siglos. ¡Tiene mérito!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8411] = {n:"Amuleto del Mominotauro",t:1,d:"Este amuleto maldito cubierto con vendas quizás te permita  sobrevivir a la maldición de El Laberinto del Minotauroro. Pero no te fíes demasiado, puede que se trate de una vulgar imitación para impresionar a los turistas.",ep:0,g:114,l:111,wd:false,fm:true,w:5,s:59,p:31300};
I.u[8412] = {n:"Anillo del Mominotauro",t:9,d:"Este anillo, confeccionado a base de pequeñas vendas del Mominotauro enrolladas entre sí, huele muy mal y es bastante feo, pero resultará ser un excelente apósito cuando te pilles un dedo en una de las puertas de El Laberinto del Minotauroro.",ep:0,g:119,l:111,wd:false,fm:true,w:10,s:59,p:31525};
I.u[8413] = {n:"Martillo del Mominotauro",t:7,d:"El bloque de piedra que se encuentra a la extremidad de este martillo está enrollado en las vendas del Mominotauro para absorber los fluidos que saldrán de las criaturas que aplastarás, o sencillamente para hacerles menos daño y no matarlos tan rápido.",ep:0,g:60,l:112,wd:false,fm:true,w:10,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>100&CI>200&CW>150",s:59,p:100};
I.u[8414] = {n:"Dagas de Dragohuevo",t:5,d:"Estas dagas son ideales para recortar la parte de arriba de un huevo de Dragohuevo cocido (el huevo, no el dragohuevo). También son muy ligeras, lo cual permite correr muy deprisa cuando la manada de Dragohuevos se da cuenta de lo que acabas de hacer...",ep:20,g:58,l:128,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CS>150&CI>150&CA>100",p:39854};
I.u[8415] = {n:"Botas del Mominotauro",t:11,d:"Rellenas y decoradas con vendas de Mominotauro, estas botas son al mismo tiempo muy confortables y muy calientes. Tal vez te recuerden a alguien.",ep:0,g:92,l:110,wd:false,fm:true,w:10,s:59,p:31255};
I.u[8416] = {n:"Capa del Mominotauro",t:17,d:"Confeccionada a partir de vendas del Mominotauro trenzadas entre sí, esta capa te proporcionará un estilo vestimentario muy de moda... en el más allá. Tus enemigos se morirán de envidia.",ep:0,g:122,l:111,wd:false,fm:true,w:10,s:59,p:31780};
I.u[8417] = {n:"Pala para Pasteles",t:8,d:"Esta pequeña pala ha sido regalada a un joven Anutrof, le gustó tanto que la siguió usando hasta la muerte.",ep:20,g:43,l:131,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CC>250&CA>100",p:42514};
I.u[8418] = {n:"Cinturón del Mominotauro",t:10,d:"Esta gruesa venda de Mominotauro posee un valor extraordinario a pesar de que se desconozca su origen. Pero qué más da, la podrás vender a buen precio y su maldición acelerará la putrefacción de las caderas de los amigos a los que regales este cinturón... ¡No tiene precio!",ep:0,g:108,l:112,wd:false,fm:true,w:10,s:59,p:32255};
I.u[8419] = {n:"Pala Moh",t:8,d:"Fue con esta pala que el capitán Machab destripó a Grobill Dick, el gran Kralamar Blanco.",ep:20,g:42,l:115,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>200",p:33653};
I.u[8420] = {n:"Pala dragohuevo",t:8,d:"A los Dragohuevos les encanta excavar subterráneos. La comunidad Anutrof ha estudiado durante mucho tiempo este enigma, al final del estudio sacaron esta conclusión: Es menos importante saber de donde viene que golpear con ella.",ep:20,g:45,l:127,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,40,40,false,true],c:"CC>200&CS>100",p:42154};
I.u[8421] = {n:"Certificado de admisión en la petrera: cuerbokito feo",t:77,d:"Este certificado describe las características del cuerbokito feo que has dejado en la petrera.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8423] = {n:"Regalo: de compensación",t:89,d:"A utiliser pour un nouveau cadeau (ne pas traduire).",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8424] = {n:"Regalo: de compensación del ganadero",t:89,d:"Este Regalo: destinado a los ganaderos contiene todo lo necesario para llenar un cercado con excelentes máquinas de ganadería. (Atención, los objetos contenidos en este Regalo: son muy pesados, puede que estés en sobrecarga cuando lo abras).",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8425] = {n:"Bolsa de 10.000 kamas",t:100,d:"Esta bolsa es muy pesada, seguro que contiene una verdadera fortuna. Los mercaderes se harán un placer cambiándotela por su valor en kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:100000};
I.u[8428] = {n:"Pócima de invisibilidad nebulosa",t:12,d:"Con esta pócima podrás evaporarte para volver al último registro... y todo sin dejar rastro.",ep:0,g:26,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,ut:true,p:1};
I.u[8430] = {n:"Globo amarillo mágico",t:94,d:"Aunque se puedan encontrar imitaciones en la feria del Trool, este globo sabe por lo menos volar con gracia y facilidad. Ha sido confeccionado a mano como antiguamente, en verdadero pelo de Tofu según la receta tradicional del gran mago Vahy Né.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8431] = {n:"Atomizador fumífero ciclónico",t:12,d:"Esta pócima fumífera crea un torbellino de humo que te servirá de pantalla para ocultar estilosmanete todas tus acciones.",ep:0,g:29,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,p:1};
I.u[8435] = {n:"Globo rojo mágico",t:94,d:"Aunque se puedan encontrar imitaciones en la feria del Trool, este globo sabe por lo menos volar con gracia y facilidad. Ha sido confeccionado a mano como antiguamente, en verdadero párpado de Gelatina de Fresa según la receta tradicional del gran mago Vahy Né.",ep:1,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8436] = {n:"Llave de la Mazmorra del Roble Blando",t:84,d:"Esta llave te permitirá acceder a las partes más íntimas de la anatomía del Roble Blando aunque tampoco sepas a donde te diriges... Extraño y excitante a la vez, este viaje hacia el infinito y más allá no te dejará indiferente.",ep:1,g:236,l:1,wd:true,fm:true,w:1,p:100};
I.u[8437] = {n:"Llave de la Mazmorra Enarenada",t:84,d:"Esta llave confeccionada a base de detritus marinos y caparazones de crustáceos te permitirá acceder a la playa donde se encuentra la arena más fina de toda la costa del Mar Rano.",ep:1,g:237,l:1,wd:true,fm:true,w:1,p:100};
I.u[8438] = {n:"Llave de la Mazmorra de las Ratas de Brakmar",t:84,d:"Esta llave te permitirá acceder a la mazmorra de las Ratas que se encuentra en Brakmar. No hará falta disfrazarte, pasarás desapercibido, aunque no seas Brakmariano.",ep:1,g:238,l:1,wd:true,fm:true,w:1,p:100};
I.u[8439] = {n:"Llave de la Mazmorra de las Ratas de Bonta",t:84,d:"Esta llave te permitirá acceder a la mazmorra de las Ratas que se encuentra en Bonta. No hará falta disfrazarte, pasarás desapercibido, aunque no seas Bontariano.",ep:1,g:239,l:1,wd:true,fm:true,w:1,p:100};
I.u[8441] = {n:"Billreola",t:16,d:"Bill quería una aureola. Se puso a gritar su capricho tan fuerte que se la dieron. Un verdadero diablillo...",ep:22,g:159,l:100,wd:true,fm:true,w:1,p:25540};
I.u[8442] = {n:"Máscara de la Rata Negra",t:16,d:"Esta máscara le sirvió a Brus Bulguro cuando infiltró discretamente una guarida de ratas de Alcantarillas para cortar un enorme olmo, empezando por las raíces. De todas formas acabó masacrando a todas las ratas de la guarida porque en realidad no fue tan discreto... lo delataron sus enormes zuecos de madera.",ep:2,g:158,l:102,wd:true,fm:true,w:1,s:68,p:17222};
I.u[8443] = {n:"Capa de la Rata Negra",t:17,d:"Esta capa se puede confeccionar con cualquier tipo de pelo a condición de que esté lo más sucio posible. Están trenzados entre sí y se pegan mediante secreciones diversas. El olor viene de serie.",ep:13,g:123,l:105,wd:true,fm:true,w:5,s:68,p:18356};
I.u[8444] = {n:"Dagas de la Rata Negra",t:5,d:"Aunque estén un poco estropeadas, están afiladísimas. Permiten cortar los miembros de tus adversarios con una desconcertante facilidad y al mismo tiempo les arrancarás una impresionante cantidad de cachos de carne. Una pena que no estén oxidadas, calentadas al rojo vivo y envenenadas...",ep:8,g:59,l:108,wd:true,fm:true,w:5,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CW>100&CV>300",s:68,p:19358};
I.u[8445] = {n:"Collar de la Rata Negra",t:1,d:"La rata que poseía este collar quería convertirse en el jefe de su clan. Ha sido devorado por un Zollo rabioso.",ep:18,g:115,l:103,wd:true,fm:true,w:5,s:68,p:17650};
I.u[8446] = {n:"Botas de la Rata Negra",t:11,d:"Ten cuidado al ponerte estas botas, puede que lleven dentro uno o dos pies de su dueño anterior.",ep:13,g:93,l:101,wd:true,fm:true,w:10,s:68,p:18700};
I.u[8447] = {n:"Cinturón de la Rata Negra",t:10,d:"Contrariamente a su primo blanco bontariano, a la Rata Negra le gusta ser discreta. Por eso lleva este cinturón de tela. También le gusta llevar una gran cantidad de armas que van haciendo un ruido espantoso al chocar entre sí al ritmo de sus pasos.",ep:13,g:109,l:101,wd:true,fm:true,w:5,s:68,p:18934};
I.u[8448] = {n:"Anillo de la Rata Negra",t:9,d:"Pon este anillo del derecho si le estrechas la mano a un amigo o ponlo del revés si es un enemigo. En cualquier caso, procura no aplaudir cuando lo tengas puesto...",ep:20,g:120,l:98,wd:true,fm:true,w:5,s:68,p:16980};
I.u[8449] = {n:"Transformación de la Mazmorra Abráknida",t:27,d:"Un Abráknido te ha mordido y te ha transmitido una extraña maldición.",ep:9,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8450] = {n:"Espada de la Rata Blanca",t:6,d:"Esta arma es el símbolo de la rata blanca. Es famosa por ser capaz de cortar tanto a enemigos como a aliados con la misma facilidad.",ep:16,g:71,l:109,wd:true,fm:true,w:10,an:14,tw:true,e:[5,5,1,1,40,50,false,false],c:"CA>150&CS>100",s:67,p:17542};
I.u[8451] = {n:"Sombrero de la rata blanca",t:16,d:"Con este sombrero, la Rata Blanca se parece a una verdadera Rata Blanca de Bonta. Sin él, se parece a una verdadera Rata Blanca de Bonta... pero sin sombrero.",ep:13,g:160,l:105,wd:true,fm:true,w:10,s:67,p:18451};
I.u[8452] = {n:"Capa de la Rata Blanca",t:17,d:"Esta capa es la prenda que identifica una rata blanca de la red de alcantarillas de Bonta. Antes de entregársela tiene que pasar un examen largo y difícil y la lleva puesta con orgullo hasta su muerte, o sea poco tiempo.",ep:14,g:124,l:102,wd:true,fm:true,w:5,s:67,p:17025};
I.u[8453] = {n:"Collar de Rata Blanca",t:1,d:"Si lo llevas de collar, te protegerá contra las emanaciones tóxicas de las alcantarillas. En cambio, si lo usas como un cinturón, serán tus aliados los que estarán a salvo de tus propias emanaciones tóxicas.",ep:18,g:116,l:103,wd:true,fm:true,w:5,s:67,p:18900};
I.u[8454] = {n:"Guante de la Rata Blanca",t:9,d:"Este guante pertenecía a Mari Té, cocinera del palacio de Bonta. Lo utilizaba para aturdir a los jalatós que no querían dejarse degollar, a las plantas salvajes que no querían ir a la ensalada y a los clientes que no querían comerse su comida.",ep:18,g:121,l:101,wd:true,fm:true,w:5,s:67,p:17150};
I.u[8455] = {n:"Cinturón de la Rata Blanca",t:10,d:"A pesar de lo que piensa su primo brakmariano, la Rata Negra, a la Rata Blanca también le gusta ser discreta. Las costuras metálicas de este cinturón se han reforzado con alquitrán y no hacen ruido, excepto cuando su portador se cae. Eso ocurre a menudo ya que este cinto pesa varias toneladas.",ep:16,g:110,l:102,wd:true,fm:true,w:150,s:67,p:18850};
I.u[8456] = {n:"Botas de la Rata Blanca",t:11,d:"Con estas botas, tu equilibrio será perfecto, incluso cuando sople muy fuerte el viento, no te moverás en absoluto.",ep:3,g:94,l:99,wd:true,fm:true,w:10,s:67,p:17650};
I.u[8457] = {n:"Máscara ceremonial del Amo de las Ratas",t:16,d:"Esta máscara no es un dora... de hecho ¡No tiene nada que ver con esos sombreros de la Isla de Moon! Así que no vale la pena que extiendas rumores absurdos sobre la falta de inspiración o la vagancia de su creador. Sin embargo, parece que la han fabricado con sangre y oro, y eso la hace muy bonita.",ep:13,g:173,l:133,wd:true,fm:true,w:10,s:64,p:43300};
I.u[8458] = {n:"Capa ceremonial del Amo de las Ratas.",t:17,d:"Esta capa colorada hace de ti un blanco ideal. Solamente los aventureros más vivos y ágiles han podido llevar esta capa más de un minuto.",ep:14,g:125,l:130,wd:true,fm:true,w:10,s:64,p:42030};
I.u[8459] = {n:"Collar ceremonial del Amo de las Ratas",t:1,d:"Para evitar que alguien se lo robe, este collar se lo ponen al heredero del Amo de las Ratas desde su nacimiento. De esta forma, cuando llega a la edad adulta, la única manera de quitárselo consiste en cortarle la cabeza. Ningún antirrobo es infalible...",ep:18,g:117,l:134,wd:true,fm:true,w:5,s:64,p:45842};
I.u[8460] = {n:"Anillo ceremonial del Amo de las Ratas",t:9,d:"Este anillo ha sido diseñado en una época en la cual el Amo de las Ratas se había mutilado y ya no le quedaba ni un dedo. Los desafortunados Amos que siguieron todavía los tenían todos.",ep:20,g:122,l:131,wd:true,fm:true,w:5,s:64,p:42542};
I.u[8461] = {n:"Cinturón ceremonial del Amo de las Ratas",t:10,d:"Los dibujos de este cinturón dan la impresión de que se te está quemando la zona púbica. La ilusión es tan realista que la mayoría de los que se ponen el cinturón salen corriendo y gritando... Lo que corresponde exactamente con el ritual de la ceremonia.",ep:16,g:111,l:133,wd:true,fm:true,w:10,s:64,p:43358};
I.u[8462] = {n:"Botas Ceremoniales del Amo de las Ratas",t:11,d:"El primer Amo de las Ratas se murió pisando sin querer un charco de lava en fusión. Estas botas han pertenecido a los Amos siguiente que se las ponían en homenaje a su predecesor. Obviamente, son totalmente ignífugas.",ep:13,g:95,l:134,wd:true,fm:true,w:10,s:64,p:43541};
I.u[8463] = {n:"Abracaska Ancestral",t:16,d:"Las setas que decoran este casco esparcen una suave fragancia euforizante que da ganas de echar raíces. También saben muy bien pero puede que te entierren definitivamente.",ep:9,g:174,l:114,wd:true,fm:true,w:10,s:65,p:33150};
I.u[8464] = {n:"Abrakapa Ancestral",t:17,d:"En verano, al abráknido ancestral le encanta ponerse moreno al sol, pero su madera lo tolera mal ya que está acostumbrada a los bosques oscuros. Esta capa ha sido confeccionada con las virutas de su corteza.",ep:18,g:126,l:114,wd:true,fm:true,w:5,s:65,p:33524};
I.u[8465] = {n:"Torque Ancestral",t:1,d:"Puesto alrededor del cuello, este torque pone tu barba en valor. Si no tienes barba peor para ti.",ep:20,g:118,l:110,wd:true,fm:true,w:10,s:65,p:31542};
I.u[8466] = {n:"Anillo Ancestral",t:9,d:"Las noches en las que hayas bebido demasiado, puede que notes que el moskito engastado en este anillo te haya guiñado el ojo. Pero procura no comentárselo a tus amigos, no ha sido real.",ep:9,g:123,l:113,wd:true,fm:true,w:5,s:65,p:33241};
I.u[8467] = {n:"Protege Tibia Ancestral",t:11,d:"Con estos protege tibia en madera maciza, tus piernas estarán a salvo. En cambio, si te los pones no podrás llevar botas. También puedes usarlos durante las competiciones de Jálabol aunque no sean muy adecuadas para los tiros a puerta...",ep:20,g:96,l:110,wd:false,fm:true,w:10,s:65,p:31524};
I.u[8468] = {n:"Abratura Ancestral",t:10,d:"Se supone que este cinturón proporcionaba la virilidad ancestral. Sea eso cierto o no, el efecto ha vencido.",ep:9,g:112,l:111,wd:true,fm:true,w:10,s:65,p:32101};
I.u[8469] = {n:"Talismán del Roble Blando",t:1,d:"Esta pieza de madera ha sido extraída del propio corazón del roble blando. Encierra un gran poder, como el de enfadar al Roble Blando...",ep:20,g:119,l:138,wd:true,fm:true,w:10,s:66,p:44521};
I.u[8470] = {n:"Anillo del Roble Blando",t:9,d:"Este anillo es un excremento del Roble Blando, de madera, pero el olor es el mismo.",ep:9,g:124,l:139,wd:true,fm:true,w:5,s:66,p:43014};
I.u[8471] = {n:"Chanclas de domingo del Roble Blando",t:11,d:"Cada domingo, el Roble Blando duerme la siesta. Y cuando se despierta, le gusta que un obediente tronkónido le traiga sus chanclas sin que tenga que pedírselo. Lástima que no tenga pies... de hecho, por eso están nuevas.",ep:20,g:97,l:136,wd:true,fm:true,w:5,s:66,p:43521};
I.u[8472] = {n:"Capa gastada del Roble Blando",t:17,d:"Hace más de 200 años, el Roble Blando atrapó en sus ramas un tejido cualquiera. El árbol ha crecido alrededor de él, comunicándole su magia. Ahora no se puede separar del cacho de madera en el que está atrapado lo cual hace que sea poco práctica pero su poder no se puede negar.",ep:18,g:127,l:142,wd:true,fm:true,w:10,s:66,p:44578};
I.u[8473] = {n:"Tanga otoñal del roble blando",t:10,d:"En otoño, el roble blando se pone su tanga para proteger sus preciosas bellotitas. En verano, las deja al aire libre.",ep:9,g:113,l:141,wd:true,fm:true,w:10,s:66,p:44514};
I.u[8474] = {n:"Sombrero del roble blando",t:16,d:"Ya puedes ponerte este sombrero como te plazca, siempre tendrás la impresión de que no está derecho.",ep:9,g:166,l:145,wd:true,fm:true,w:10,s:66,p:45241};
I.u[8475] = {n:"Llave de la Guarida del Peki Lobo",t:84,d:"Esta llave se transforma las noches de luna llena en una terrible llave con vida que va abriendo las casas cuyos dueños tienen hábitos inconfesables. Incluso algunos aventureros se lo creen.",ep:1,g:240,l:1,wd:true,fm:true,w:1,p:100};
I.u[8476] = {n:"Primera llave de la Mazmorra de Sfinter",t:24,d:"Esta llave no será suficiente para penetrar en la mazmorra de Sfinter, ¡Necesitas la otra llave!",ep:1,g:502,l:1,wd:false,fm:true,w:0,p:100};
I.u[8477] = {n:"Segunda llave de la Mazmorra de Sfinter",t:24,d:"Esta llave no será suficiente para penetrar en la mazmorra de Sfinter, ¡Necesitas la otra llave!",ep:1,g:503,l:1,wd:false,fm:true,w:0,p:100};
I.u[8478] = {n:"Pócima de Lame Botas",t:12,d:"Esta pócima totalmente ilegal es temida por los más grandes. Un pequeño trago y el bebedor tendrá la obsesión de lamer las botas que estén a su alcance. Unos rumores cuentan que existe una variante todavía más humillante. El desafortunado bebedor tendrá entonces un aliento tan apestoso que echará para atrás a los más osados...",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:10};
I.u[8480] = {n:"Pócima de lame botas",t:24,d:"Esta pócima totalmente ilegal es temida por los más grandes. Un pequeño trago y el bebedor tendrá la obsesión de lamer las botas que estén a su alcance. Unos rumores cuentan que existe una variante todavía más humillante. La única pista de la que disponemos acerca de este lugar es el mal aliento de los desafortunados bebedores...",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:10};
I.u[8481] = {n:"Pelo de rata de las alcantarillas",t:54,d:"Este pelo está sucio y huele mal, pasó por las alcantarillas más insalubres de la comarca. Sin embargo, todavía brilla.",ep:2,g:670,l:42,wd:true,fm:true,w:1,p:10};
I.u[8482] = {n:"Piel de Rata de las Alcantarillas",t:59,d:"Esta piel está cubierta por una multitud de pequeñas cicatrices que son representativas de la dura infancia que ha tenido la Rata de las Alcantarillas. ¡Ya podías apiadarte un poco de él!",ep:2,g:621,l:42,wd:true,fm:true,w:1,p:10};
I.u[8483] = {n:"Piel de Chamán de Alcantarillas",t:59,d:"Si la lavas, podrás hacer con esta magnífica piel una preciosa alfombra.",ep:2,g:622,l:40,wd:true,fm:true,w:1,p:10};
I.u[8484] = {n:"Pelo de chamán de alcantarillas",t:54,d:"Antiguamente se usaba para hacer bigotes postizos, este tipo de pelo también puede usarse para hacer pelos de axilas postizos.",ep:2,g:671,l:40,wd:true,fm:true,w:1,p:10};
I.u[8485] = {n:"Tejido de la rata negra",t:55,d:"Enrrollado en un lámina de madera tierna, este tejido podrá servir de esponja. Muy útil para limpiarse el trasero.",ep:2,g:725,l:100,wd:true,fm:true,w:1,p:10};
I.u[8486] = {n:"Tejido de la rata blanca",t:55,d:"Este tejido es tan grasiendo como el pelo del Wabbit empapado en grasa de blop. Protege muy bien contra el frío, sobre todo si le prendes fuego.",ep:2,g:726,l:100,wd:true,fm:true,w:1,p:10};
I.u[8487] = {n:"Tejido de Sfinter Cell",t:55,d:"Este tejido parece estar untado con un producto químico extraño cuyos efectos secundarios se desconocen. Será mejor que no guardes este tejido demasiado tiempo, puede que te crezcan cosas raras por todo el cuerpo...",ep:2,g:727,l:200,wd:true,fm:true,w:10,p:100};
I.u[8488] = {n:"Cubitus de la Rata Negra",t:47,d:"Este hueso se puede vaciar, perforar y tallar para servir después como un instrumento de música o como si no tienes buen oído.",ep:2,g:658,l:100,wd:true,fm:true,w:10,p:10};
I.u[8489] = {n:"Diente de rata blanca",t:47,d:"Este diente es en realidad un horrible colmillo que le permitía a la rata blanca transmitir una multitud de enfermedades a las personas que mordía. Aunque no consiguiera matarlas en el acto por lo menos sabía que se morirían tarde o temprano...",ep:2,g:659,l:100,wd:true,fm:true,w:10,p:10};
I.u[8490] = {n:"Fémur de Sfinter Cell",t:47,d:"Sfinter no solía ser muy cuidadoso con los huesos, él los partía en dos, en tres y en cuatro... Incluso a veces en cinco, cuando era necesario despertar a los espectadores que se habían dormido delante de un combate aburrido.",ep:2,g:657,l:200,wd:true,fm:true,w:10,p:10};
I.u[8491] = {n:"Piel de Rata Negra",t:59,d:"Rata Negra era famosa por su mal aliento pero también por la rugosidad de la piel de sus nalgas. Resulta muy práctico para no resbalar sobre la tapa de los servicios. Una pena que la rata negra nunca los usara... Ella hacía sus necesidades directamente en las cloacas de la ciudad...",ep:2,g:623,l:100,wd:true,fm:true,w:1,p:10};
I.u[8492] = {n:"Piel de Rata Blanca",t:59,d:"Rata Blanca solía aburrirse en los lugares más recónditos de su cloaca esperando a que alguien viniera a levantarle los ánimos. Parece ser que se aprovecha de la inocencia de quienes vienen a verla para descuartizarlos vivos y asarlos después de haberlos rellenado con castañas de cajú. Pobres castañas...",ep:2,g:624,l:100,wd:true,fm:true,w:1,p:10};
I.u[8493] = {n:"Piel de Sfinter Cell",t:59,d:"¿Quién te iba a decir que un día tendrías este cacho de piel entre tus manos? Desde luego Sfinter no... Su exceso de confianza ha causado su pérdida.",ep:2,g:625,l:200,wd:true,fm:true,w:10,p:100};
I.u[8494] = {n:"Corteza de abráknido ancestral",t:96,d:"Esta corteza se despegó del Abráknido Ancestral, sin que tuvieses que arrancarla a mordiscos.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[8495] = {n:"Yema del abráknido ancestral",t:108,d:"Antaño, una criatura hambrienta desecó esta yema al sacarle toda la savia. Si la metes en agua, verás como retoma su forma inicial, se hincha y luego, si esperas mucho, se acaba pudriendo.",ep:9,g:755,l:200,wd:true,fm:true,w:1,p:10};
I.u[8496] = {n:"Raíz de abráknido ancestral",t:98,d:"Aunque la arranquen a su dueño, esta raíz puede latigarte el trasero o hacerte un esguince de tobillo. Jodito bicho.",ep:9,g:668,l:200,wd:true,fm:true,w:1,p:10};
I.u[8497] = {n:"La receta de la filtunga",t:24,d:"Este libro encierra los secretos de la filtunga, el plato mítico ideado por Mus Buf.",ep:16,g:95,l:1,wd:true,fm:true,w:0,u:true,p:10};
I.u[8498] = {n:"Carne de kanugro",t:63,d:"Esta carne es tan tierna como el cerebro de un Dolo.",ep:13,g:375,l:80,wd:true,fm:true,w:1,p:1};
I.u[8499] = {n:"Carne de koalak",t:63,d:"La carne de koalak suele ser bastante dura, pero basta con golpearla con un tronco de Kalipto. Igual que a los niños indisciplinados.",ep:20,g:376,l:60,wd:true,fm:true,w:1,p:1};
I.u[8500] = {n:"Carne de crocodail",t:63,d:"Esta carne insulsa puede conservarse en el fango varios años seguidos, antes de acabar pudriendose y de que aparezca un sabor apetecible.",ep:4,g:377,l:70,wd:true,fm:true,w:1,p:1};
I.u[8501] = {n:"Carne de kanugro conservada",t:64,d:"Esta carne de Kanugro ahora se puede conservar durante varios días antes de ser utilizada para la preparación de un plato.",ep:13,g:387,l:80,wd:true,fm:true,w:1,p:10};
I.u[8502] = {n:"Carne de koalak conservada",t:64,d:"Esta carne de koalak ahora se puede conservar durante varios días antes de ser utilizada para la preparación de un plato.",ep:20,g:388,l:120,wd:true,fm:true,w:1,p:10};
I.u[8503] = {n:"Carne de cocodrail conservada",t:64,d:"Esta carne de cocodrail ahora se puede conservar durante varios días antes de ser utilizada para la preparación de un plato.",ep:4,g:389,l:70,wd:true,fm:true,w:1,p:10};
I.u[8504] = {n:"Entrecot de kanugro",t:69,d:"Frío o caliente, este entrecot colmará los apetitos más voraces.",ep:13,g:132,l:80,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8505] = {n:"Filete de koalak",t:69,d:"Este cacho de carne llenará incluso los estómagos sin fondo.",ep:20,g:133,l:120,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8506] = {n:"Entrecot de cocodrail",t:69,d:"Este imponente cacho de carne debe de ser muy difícil de digerir. Aunque la gula siempre prevalece sobre la razón.",ep:4,g:134,l:70,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8507] = {n:"Plato de filtunga",t:69,d:"La filtunga es un plato único. Gracias a los ingredientes que la componen conserva su sabor... Único. Se sirve tibio.",ep:1,g:136,l:100,wd:true,fm:true,w:1,c:"Cv<100",u:true,ut:true,p:1};
I.u[8508] = {n:"Plato de filtunga",t:24,d:"Este plato es para la bruja Pandep.",ep:1,g:120,l:1,wd:true,fm:true,w:0,p:1};
I.u[8509] = {n:"La receta de la cerveza Bwork",t:25,d:"El gran mago Bworknroll te revela aquí la receta sagrada de la cerveza Bwork. No calla ningún secreto de fabricación. Incluso te explica cuál es la mejor manera para saborearla. Los novatos se chuparán los dedos, en cambio los más experimentados no serán capaces de beber este asqueroso brebaje.",ep:1,g:130,l:10,wd:false,fm:true,w:5,u:true,p:500};
I.u[8511] = {n:"Ballesta superpoderosamente tenebrosa de la muerte que te mata bien muerto",t:102,d:"...",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:10,tw:true,e:[20,7,4,12,50,30,true,true],p:1};
I.u[8513] = {n:"Escalpelo de Bworknroll",t:5,d:"Para colectar \"cachos\" de criatura no hay nada mejor que el escalpelo de Bworknroll ya que preserva la vitalidad de los miembros arrancados. Hay que utilizarlo en combate para recuperar las partes deseadas.",ep:1,g:60,l:40,wd:true,fm:true,w:10,an:13,e:[10,4,1,1,30,50,false,false],c:"Qa=166",p:100};
I.u[8514] = {n:"Sesos de Vampiro",t:15,d:"Están siempre llenos de glóbulos frescos. Los sesos de un vampiro aspira todos los glóbulos rojos disponibles. Por eso los vampiros tienen siempre una tez muy pálida. A la inversa, en el organismo Yopuka, lo que atrae su sangre son los pies y por eso son más hábiles saltando que pensando...",ep:3,g:492,l:20,wd:true,fm:true,w:2,u:true,p:10};
I.u[8515] = {n:"Hueso de Trool",t:47,d:"A tenor de la solidez y del peso de un hueso de un trool, se entiende mejor por qué duelen tanto sus bofetadas.",ep:4,g:640,l:5,wd:true,fm:true,w:50,p:50};
I.u[8516] = {n:"Corazón de Bworkcelana",t:15,d:"Esta despiadada  Bworka que tiró a su hijo Krazybwork en un pozo fue maldita por Bworknroll al que negó su amor. Encerrada en su sótano, se nutre a diario de su propio corazón. Todas las noches le vuelve a crecer y a batir como nuevo.",ep:4,g:518,l:33,wd:true,fm:true,w:33,p:33};
I.u[8517] = {n:"Almejillón",t:15,d:"Este Almejillón fresquito le es muy útil a los Bworks cuando se marchan de rapiña lejos de sus esposas...",ep:3,g:756,l:1,wd:true,fm:true,w:3,p:21};
I.u[8518] = {n:"Almejillones con patatas fritas",t:69,d:"En las entrañas del Mar Rano, los Almejillones cosechan algas que revuelven bajo sus axilas. En cuanto la materia coge la forma de patatas fritas, se suben a la playa para dorarla al sol antes de ingerirlas.",ep:3,g:135,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:30};
I.u[8519] = {n:"Gatrool",t:69,d:"Esta torta tradicional, rellena con kagrarrutas de trool, es una antigua receta bwork. Los únicos que tienen derecho a comérsela son los bwork que hayan derrotado a un trool con sus propias manos. El que haya logrado sobrevivir a ese combate, seguro que se tragará cualquier cosa.",ep:1,g:136,l:5,wd:true,fm:true,w:20,u:true,p:200};
I.u[8520] = {n:"Gratrool",t:60,d:"Esta grasa espesa y nutritiva permite cocer gran parte de los alimentos en ollas desgastadas sin colgar el plato. Algunos aficionados osamodas la utilizan para dejar Tofus en lugares en los que la moral yopuka prohíbe su presencia.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[8521] = {n:"La capa colorada",t:17,d:"La capa colorada es el artefacto favorido de los megalómanos. Al cubrir sus hombros débiles, tienen la impresión de ser Superman o un algún mago superdotado hasta que se les venga encima un Minotauroro.",ep:1,g:128,l:9,wd:false,fm:true,w:1,p:200};
I.u[8522] = {n:"Lanzador de efecto mágico",t:74,d:"Este sorprendente objeto encierra un concentrado de magia oscura más bien inestable. Nadie puede saber lo que encierra pero se desaconseja esperar demasiado para utilizarlo.",ep:1,g:31,l:1,wd:false,fm:true,w:0,ut:true,p:1};
I.u[8523] = {n:"La reliquia de los Jug\'Onh",t:24,d:"Este objeto familiar lleva un fluido mágico muy poderoso. Todos los guerreros del clan la han utilizado y algunos incluso ¡varias veces! Sin embargo se dice que una maldición se abatirá sobre aquel que ose darle la vuelta. Esta reliquia no ha perdido su poder a pesar de su antigüedad. Existen muy pocos artefactos con tanto poder como éste, puede incluso que haya estado en contacto con un Dofus...",ep:1,g:714,l:200,wd:true,fm:true,w:0,p:1};
I.u[8524] = {n:"Fantasma Walk",t:90,d:"Este fantasma no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:45,l:1,wd:true,fm:true,w:1,p:1};
I.u[8525] = {n:"Huevo de pío",t:69,d:"Los huevos de píos son un bálsamo para el paladar de los adictos a las chucherías. Son sin embargo muy rápidos en eclosionar cuando están al lado de una fuente de calor. Con lo cual, más vale guardarlos en tu bolsillo ou en tu boca ya que al cabo de algunos minutos un mini pío puede salir de su cáscara. Un pío hambriento entre tus dientes o hurgando por tu ropa puede hacerle cosquillas a tu paladar o a otras partes más íntimas de tu anatomía.",ep:4,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[8526] = {n:"Certificado de admisión en la petrera: koalak sanguíneo",t:77,d:"Este certificado describe las características del koalak sanguíneo que has dejado en la petrera.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8527] = {n:"Gobtroter",t:11,d:"Estas botas hechas con pieles de goblines han sido creadas para Planbworksekio para cargar velozmente contra el enemigo (al ser posible cuando está de espaldas). Al tener estas botas puestas ha salvado a más de un colega Bwork en apuros.",ep:4,g:98,l:14,wd:true,fm:true,w:20,p:400};
I.u[8528] = {n:"La receta de las crepes",t:25,d:"Gracias a Argui Ñaño sabrás por fin como preparar tus crepes para darles de comer a tus hijitos y poder enviarlos rápidamente a dormir la siesta. El secreto de esta receta alimenticia y soporífica: ¡Polvos mágicos, claro!",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[8529] = {n:"El martillo para Zaap",t:24,d:"¡No hay nada como un buen martillazo para reparar un Zaap averiado!",ep:1,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[8530] = {n:"Simbreria",t:16,d:"Este gorrito ártico, además de mantenerte calientes las orejas, absorverá todos los vapores alcohólicos que se escapen de tu cabeza. ¿Qué más podrías pedirle?",ep:22,g:167,l:151,wd:true,fm:true,w:10,p:46280};
I.u[8531] = {n:"Cunejosombrero",t:16,d:"¿Quién se atrevería a llevar un sombrero tan ridículo? Nadie excepto tú.",ep:1,g:168,l:33,wd:true,fm:true,w:6,p:3000};
I.u[8532] = {n:"Capa del Cunejo Hastiado",t:17,d:"Poniéndote esta capa podrás por fin demostrar a las personas a las que das la espalda que estás harto de su estupidez.",ep:1,g:129,l:14,wd:true,fm:true,w:1,p:775};
I.u[8533] = {n:"El Flud",t:16,d:"El Flud no es realmente un sombrero sino un parásito que se desarrolla sobre el cráneo de las personas demasiado locuaces, excesivamente ruidosas o sencillamente que son verbalmente agresivas. Su aspecto repelente espanta a la gente por lo cual su portador suele ponerse a gritar aún más fuerte para que lo oigan... intento fallido obviamente ya que de todas formas no tiene nada que decir.",ep:1,g:169,l:1,wd:true,fm:true,w:1,s:69,p:100};
I.u[8534] = {n:"La Capa Slok",t:17,d:"Esta capa forrada absorbe todos los ruidos de los alrededores. Eso obliga su portador a gritar todo el tiempo.",ep:1,g:130,l:1,wd:true,fm:true,w:10,s:69,p:100};
I.u[8535] = {n:"Los Okupas",t:11,d:"Estas getas son tan ligeras que el que las lleva puestas se pone a correr y saltar por todos sitios cuando empieza un combate. Los aventureros experimentados odian estas getas porque quienes las llevan puestas se cuelan en los combates a los que no les han invitado.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8536] = {n:"La Spamita",t:10,d:"Este cinturón se lleva tan apretado que no dejarás de tartamudear, temblar y hacer estupideces cuando lo lleves puesto...",ep:1,g:114,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8537] = {n:"El Masano",t:9,d:"Este anillito no sirve para nada, pero ya que tiene un color muy chillón podrás hacerle ver a la gente que existes.",ep:1,g:125,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8538] = {n:"El S\'Mesmo",t:1,d:"Tras varias noches de dura labor para realizar este amuleto, el mejor joyero de Astrub, famoso por haber sido criado por los bworks, exclamó delante de la muchedumbre boquiabierta: \"Es 1 amu de pm\". Incluso el ilustre Champo Nión nunca consiguió descifrar lo que este joyero quiso decir.",ep:1,g:120,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8539] = {n:"Hacha del aprendiz leñador",t:19,d:"Aunque no sepas manejar un hacha a la perfección no te preocupes, pues ésta está tan gastada que no cortarías ni mantequilla con ella. Pero bueno, si realmente golpeas con todas tus fuerzas puede que consigas cortar algún arbolito.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:0};
I.u[8540] = {n:"Guadaña del aprendiz campesino",t:22,d:"La calidad de esta guadaña es bastante mediocre pero no te puedes quejar ya que ha sido un regalo. Además, con ella se puede segar perfectamente el trigo... ¿Qué más se le puede pedir?",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[8541] = {n:"Caña de aprendiz de pescador",t:20,d:"Bueno, esta caña ha tenido días mejores. Su tanza ya no es muy resistente y el anzuelo está algo oxidado. Vamos, es perfecta para ir a pescar gobios.",ep:1,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,1,100,100,false,false],p:1};
I.u[8542] = {n:"Guantes del aprendiz alquimista",t:20,d:"Este par de guantes son de una calidad indiscutible. Casi no tienen agujeros, el olor a sudor de su antiguo dueño es apenas perceptible, los dedos son demasiado cortos, se te caen fácilmente... No cabe duda: estos guantes son una birria.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:1};
I.u[8543] = {n:"Cerveza de Incarnam",t:79,d:"Esta cerveza que ha sido fabricada por los dioses es una mezcla de éter, de alma y de lúpulo. Repone las almas jóvenes que se encarnaron en Incarnam. Para las demás, será una gaseosa que solamente sirve para entrenarse antes de los concursos de eructos.",ep:1,g:4,l:1,wd:true,fm:true,w:1,c:"PL<16",u:true,ut:true,p:1};
I.u[8544] = {n:"Certificado de admisión en la petrera: walk",t:77,d:"Este certificado describe las características del walk que has dejado en la petrera.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8545] = {n:"Llave de la Mazmorra de Incarnam",t:84,d:"Esta llave permite entrar en la mazmorra de Incarnam donde vive el terrible minilubo albino.",ep:1,g:19,l:1,wd:true,fm:true,w:1,p:10};
I.u[8546] = {n:"Piel del minilubo albino",t:59,d:"Sus ligeros ricitos hacen de esta piel una bonita alfombra para poner a los pies de la cama. Sin duda debe de existir alguien en Incarnam que esté dispuesto a darte un maravilloso objeto a cambio de esta piel. No más te queda encontrarlo...",ep:1,g:3,l:1,wd:true,fm:true,w:10,p:1};
I.u[8547] = {n:"...",t:31,d:"Lis ivillinis milditis sink milis prirk lik silidik.",ep:1,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8548] = {n:"Twansfowmación en wabbit",t:31,d:"Las zanahowias malditas wesultan tewibles pawa la salud.",ep:8,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
