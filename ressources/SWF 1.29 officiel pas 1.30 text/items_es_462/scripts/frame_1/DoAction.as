I.u[259] = {n:"Imponente cinturón Forcesco",t:10,d:"Este cinturón te hará más fuerte.",ep:1,g:11,l:8,wd:true,fm:true,w:12,p:400};
I.u[260] = {n:"Pequeño Cinturón Agilesco",t:10,d:"Este cinturón aumenta la agilidad de quien lo lleve puesto.",ep:1,g:8,l:1,wd:true,fm:true,w:6,p:100};
I.u[261] = {n:"Cinturón Agilesco",t:10,d:"Este cinturón aumenta la agilidad de quien lo lleve puesto.",ep:1,g:8,l:3,wd:true,fm:true,w:10,p:200};
