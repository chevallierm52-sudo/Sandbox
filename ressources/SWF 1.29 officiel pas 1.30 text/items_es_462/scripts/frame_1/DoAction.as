I.u[267] = {n:"Potente Arco Desconcertante",t:2,d:"El Arco Desconcertante es un objeto básico, pero no se debe despreciar su utilidad.",ep:1,g:3,l:19,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>19&CS>9",p:1200};
I.u[270] = {n:"Javiador",t:2,d:"El Javiador es un arco eficaz. Pertenecía al gran Javier el Panadero. Entre dos hornadas, se marchaba a repartir tortas entre los monstruos que rodeaban su panadería.",ep:7,g:5,l:60,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,9,30,100,false,true],c:"CA>60&CV>15",p:9050};
I.u[271] = {n:"El Martillo del Chafer",t:7,d:"Esta es una bonita arma. Extraña y fascinante te permitirá luchar en cuerpo a cuerpo como lo haría el mejor de los Chafers.",ep:1,g:9,l:21,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,40,30,false,false],c:"CS>10&CI>11",p:1350};
I.u[272] = {n:"Nomoon",t:2,d:"Este arco es suficientemente potente como para enviar una flecha sobre la luna.",ep:7,g:9,l:28,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,12,30,50,false,true],c:"CA>28&CV>5",p:2350};
I.u[273] = {n:"La Cuerda de Yamato",t:2,d:"La Cuerda de Yamato hizo vibrar a más de un corazón de monstruo. Es un arma refinada capaz de dirigir su flecha en los más recónditos lugares.",ep:7,g:10,l:33,wd:true,fm:true,w:18,an:10,tw:true,e:[10,4,2,7,30,50,false,false],c:"CA>33&CS>10",p:3000};
I.u[274] = {n:"Pieza del puzle de la Garra",t:51,d:"Una pieza muy rara del tesoro de Dodge, uno de los más grandes zurcaráks de Amakna.",ep:1,g:267,l:12,wd:true,fm:true,w:1,p:100};
I.u[276] = {n:"Pieza del tesoro del Badulo",t:15,d:"Una pieza muy rara del tesoro escondido por el célebre Dodge, uno de los mayores guerreros de Amakna.",ep:1,g:268,l:12,wd:true,fm:true,w:1,p:100};
I.u[278] = {n:"Anillo de las Rocosas",t:9,d:"Este anillo está engastado con una piedra rara. Las distintas piedras que componen su nombre son imprescindibles para su creación.",ep:1,g:4,l:15,wd:true,fm:true,w:4,p:800};
I.u[279] = {n:"La Lágrima del Jalató",t:1,d:"Según un ilustre aventurero, este amuleto contiene una lágrima de Jalató. Su olor y sus propiedades son semejantes a las que producen las decocciones del cuero de un Jalató.",ep:1,g:7,l:2,wd:true,fm:true,w:5,p:200};
I.u[280] = {n:"Collar del Arco Iris",t:1,d:"Este collar es muy rebuscado por los coleccionistas, conseguirás venderlo por un buen precio.",ep:1,g:11,l:6,wd:true,fm:true,w:6,p:300};
I.u[281] = {n:"Manzana",t:42,d:"Esta manzana restaura algunos puntos de vida perdidos, pero ojo, si la utilizas cuando has alcanzado el máximo de PDV la perderás para siempre...",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[282] = {n:"Frasco de cuidados superiores",t:12,d:"Este frasco te permite reponer algunos puntos de vida perdidos en combate.",ep:1,g:39,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[283] = {n:"Frasco de cuidados",t:12,d:"Este frasco te permite reponer algunos puntos de vida perdidos en combate.",ep:1,g:3,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[284] = {n:"Sal",t:48,d:"La sal es un mineral, molido te permite darle gusto a tus panes.",ep:2,g:260,l:1,wd:true,fm:true,w:1,p:10};
I.u[285] = {n:"Harina de trigo",t:52,d:"La harina se consigue aplastando granos de trigo, es muy útil para hacer pan, crepes, gofres y deliciosas tartas, pero sobre todo para enharinar a tus enemigos de infancia.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[286] = {n:"Levadura del panadero",t:48,d:"Es un ingrediente indispensable para la fermentación del pan.",ep:1,g:137,l:1,wd:true,fm:true,w:1,p:1};
I.u[287] = {n:"Semillas de sésamo",t:58,d:"Esta semilla extremadamente rica en proteínas permite realizar deliciosos panes, pero el cultivo del sésamo es delicado bajo el clima dofusiano, por eso es una semilla rara y costosa.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[288] = {n:"Semilla de girasol salvaje",t:58,d:"Esta semilla rica en proteínas permite dar un sabor muy particular a los panes. La única manera de conseguir algunas es matando a un girasol salvaje ¡O comprándolo!",ep:1,g:6,l:12,wd:true,fm:true,w:1,p:10};
I.u[289] = {n:"Trigo",t:34,d:"El Trigo es desde los albores de la amaknidad un ingrediente indispensable para la alimentación de los habitantes de Amakna y de los Tofus.",ep:1,g:9,l:1,wd:true,fm:true,w:2,p:0};
I.u[290] = {n:"Seta",t:15,d:"Con o sin crema, las setas son siempre igual de sabrosas. La manera más sencilla para conseguir algunas consiste en matar a un Champi-Champ.",ep:1,g:1,l:5,wd:true,fm:true,w:1,p:10};
I.u[291] = {n:"Pelos de mediulubo",t:54,d:"Estos pelos no son como los demás pelos, disponen de propiedades particulares que los vuelven muy apreciados por los alquimistas.",ep:1,g:8,l:70,wd:true,fm:true,w:1,p:1};
I.u[292] = {n:"Testículos del mediulubo",t:15,d:"Estos enormes testículos están recubiertos con un extraño vello especialmente suave y caliente. Es casi imposible recuperarlos intactos después de un combate con un mediulubo, esto explica en parte su precio escandaloso.",ep:1,g:10,l:70,wd:true,fm:true,w:20,p:50};
I.u[293] = {n:"Palita del crujidor",t:8,d:"Lo único que puede ser tan sólido como un crujidor, es un crujidor. Esa es la razón por la cual esta pala, diseñada para cazar crujidores, está hecha con piedra de crujidor.",ep:1,g:7,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1200};
I.u[294] = {n:"Pala del crujidor",t:8,d:"Lo único que puede ser tan sólido como un Crujidor, es un Crujidor. Esa es la razón por la cual esta pala, diseñada para cazar Crujidores, está hecha con piedra de Crujidor.",ep:1,g:7,l:23,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>8&CC>15",p:1600};
I.u[295] = {n:"Gran Pala del Crujidor",t:8,d:"Lo único que puede ser tan sólido como un Crujidor, es un Crujidor. Esa es la razón por la cual esta pala, diseñada para cazar Crujidores, está hecha con piedra de Crujidor.",ep:1,g:7,l:26,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>11&CC>15",p:2000};
I.u[296] = {n:"Potente Pala del Crujidor",t:8,d:"Lo único que puede ser tan sólido como un Crujidor, es un Crujidor. Esa es la razón por la cual esta pala, diseñada para cazar Crujidores, está hecha con piedra de Crujidor.",ep:1,g:7,l:29,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>14&CC>15",p:2400};
I.u[297] = {n:"Botas del pequeño jalató",t:11,d:"Estas botas están hechas con cuero de Jalató, permiten que los ganaderos puedan acercarse más facilmente a los Jalatós para matarlos gracias al olor que desprenden.",ep:1,g:3,l:1,wd:true,fm:true,w:2,p:100};
I.u[298] = {n:"Sandalias Tofuescas",t:11,d:"Estas sandalias están hechas con plumas de tofu cocido y la suela es de pico de tofu inalterable. Por motivos todavía inexplicados, hacen que su portador se vuelva un poco tonto... como un tofu.",ep:1,g:4,l:1,wd:true,fm:true,w:7,p:100};
I.u[299] = {n:"Botas de Fayt",t:11,d:"La mejor defensa es el ataque, estas botas anti agresión te permitirá acabar con un grupo de agresores sin ninguna dificultad.",ep:1,g:8,l:24,wd:true,fm:true,w:30,p:1800};
I.u[300] = {n:"Semilla de adormidera",t:58,d:"Esta semilla procura virtudes alucinógenas a los panes que los aventureros adoran comerse para relajarse después de un combate difícil.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:1};
I.u[301] = {n:"Pluma de tofu",t:53,d:"Las plumas de tofu se utilizan mucho en costura para los distintos forros. Y sobre todo, no te olvides de que un kilo de plumas de Tofu pesa tanto como un kilo de plomo.",ep:1,g:14,l:4,wd:true,fm:true,w:1,p:10};
I.u[302] = {n:"Calabaza",t:68,d:"Las calabazas que crecen en los campos, son una pizca más grandes que los testículos de mediulubo, en cambio tienen mejor gusto.",ep:4,g:12,l:15,wd:true,fm:true,w:5,p:10};
I.u[303] = {n:"Madera de fresno",t:38,d:"La Madera de Fresno no es una madera de calidad, pero es abundante y crece relativamente rápido. Sin embargo, ten cuidado, no lo almacenes cerca de una fuente de calor ya que es inflamable.",ep:1,g:17,l:1,wd:true,fm:true,w:5,p:0};
I.u[304] = {n:"Cuero de jalató",t:56,d:"Este cuero muy resistente constituye el principal recurso de los curtidores que hacen botas, cinturones e incluso trallas de látigo. Su único inconveniente es que huele a sudor de Jalató en celo... lo cual no favorece mucho los encuentros.",ep:1,g:16,l:9,wd:true,fm:true,w:2,p:1};
I.u[305] = {n:"Diente de wabbit",t:47,d:"Estropeados de tanto roer zanahowias, los dientes de Wabbit son a pesar de todo muy útiles para la elaboración de pócimas gracias a sus propiedades que revigorizan.",ep:8,g:13,l:20,wd:true,fm:true,w:1,p:1};
I.u[306] = {n:"Flor del diente de león diabólico",t:35,d:"Correctamente hervida y secada, esta flor pierde sus propiedades tóxicas y puede consumirse en tisana, pero se utiliza sobre todo la flor para divertir a los jóvenes románticos. Pues ¿Quién no ha soplado nunca sobre una flor de diente de león diabólico para enviar al cuello del ser amado, estas espléndidas semillas, suaves como la caricia de una rayo de sol sobre las hojas de un carpe aún impregnadas de rocío? Quizá los yopukas, que en vez de soplar, tienden a aspirar las semillas y asfixiarse lamentablemente entre atroces convulsiones.",ep:1,g:18,l:5,wd:true,fm:true,w:1,p:10};
I.u[307] = {n:"Ala de moskito",t:104,d:"Estas alas muy finas tienen la particularidad de favorecer la reflexión de las personas que se atreven a masticarlas. Su gusto es bastante cercano al de los huevos podridos de Kwak, por eso se utilizan esencialmente para las pócimas de sabiduría.",ep:1,g:19,l:2,wd:true,fm:true,w:1,p:1};
I.u[308] = {n:"Cáscara de dragohuevo blanco",t:111,d:"Esta cáscara es casi irrompible, sin embargo, si se pule durante generaciones, los mejores Joyeros podrán utilizar sus propiedades mágicas para hacer amuletos con poderes excepcionales.",ep:11,g:21,l:64,wd:true,fm:true,w:5,p:1};
I.u[309] = {n:"Pétalo de rosa demoníaca",t:35,d:"Estos pétalos tienen propiedades afrodisíacas muy potentes, por eso es el regalo ideal para conquistar al ser amado. Procura no consumirlos en infusión, pues este tipo de preparación acabaría produciendo los efectos contrarios.",ep:1,g:20,l:6,wd:true,fm:true,w:1,p:10};
I.u[310] = {n:"Hueso de chafer",t:47,d:"Este hueso es casi irrompible, pero al contacto del agua, se vuelve muy suave, esto facilita su utilización por los alquimistas.",ep:1,g:15,l:34,wd:true,fm:true,w:5,p:1};
I.u[311] = {n:"Agua",t:15,d:"El agua es útil para muchas cosas, y cuanto más turbia es, más sabor le da a la cerveza (y no digas nunca cerveza, de tu agua no beberé...).",ep:1,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[312] = {n:"Hierro",t:39,d:"El hierro es muy útil para los herreros y para los que utilizan metal, algunos incluso lo usan para planchar.",ep:1,g:24,l:1,wd:true,fm:true,w:5,p:0};
I.u[313] = {n:"Oro",t:39,d:"El oro es un metal raro y precioso, sus calidades intrínsecas hacen de él un metal idóneo para la fabricación de armas u objetos especialmente potentes y de estética refinada.",ep:1,g:22,l:80,wd:true,fm:true,w:5,p:0};
I.u[315] = {n:"Diamante",t:50,d:"Todos los joyeros de Amakna adoran esta piedra que requiere una excelente destreza para ser tallada. Es a menudo necesario aventurarse dentro de peligrosas minas para encontrarlas, pero afortunadamente, los diamantes son eternos.",ep:1,g:25,l:50,wd:true,fm:true,w:10,p:5000};
I.u[316] = {n:"Esmeralda",t:50,d:"Con su verde intenso, esta espléndida piedra preciosa puede fácilmente transformar a una bruja en princesa, sin que sea necesaria utilizar ningún tipo de magia oculta.",ep:1,g:23,l:50,wd:true,fm:true,w:10,p:5000};
I.u[317] = {n:"Bastón del Pequeño Tabi",t:4,d:"Los ganaderos de Amakna utilizaban este bastón cuando querían controlar más fácilmente a sus rebaños de Tabis, este bastón es tan ligero que permite correr detrás de los Tabis que se quieren escapar sin ni siquiera cansarse.",ep:7,g:6,l:30,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:2650};
I.u[318] = {n:"Bastón del Tabi",t:4,d:"Los ganaderos de Amakna utilizaban este bastón cuando querían controlar más fácilmente a sus rebaños de Tabis, este bastón es tan ligero que permite correr detrás de los Tabis que se quieren escapar sin ni siquiera cansarse.",ep:7,g:6,l:34,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:3200};
I.u[319] = {n:"Bastón del Gran Tabi",t:4,d:"Los ganaderos de Amakna utilizaban este bastón cuando querían controlar más fácilmente a sus rebaños de Tabis, este bastón es tan ligero que permite correr detrás de los Tabis que se quieren escapar sin ni siquiera cansarse.",ep:7,g:6,l:37,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>25",p:3750};
I.u[320] = {n:"Bastón del Poderoso Tabi",t:4,d:"Los ganaderos de Amakna utilizaban este bastón cuando querían controlar más fácilmente a sus rebaños de Tabis. Es tan ligero que permite correr detrás de los Tabis que se quieren escapar sin cansarse en absoluto.",ep:7,g:6,l:40,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>30",p:4300};
I.u[323] = {n:"Amuleto del Kam Asutra",t:1,d:"Este amuleto proporciona facultades muy particulares a su portador, pues este se verá como transportado por un aura misteriosa que irá recorriendo su cuerpo, lo cual generalmente acaba aumentando sus capacidades físicas.",ep:1,g:4,l:43,wd:true,fm:true,w:5,p:5000};
I.u[324] = {n:"Amuleto de Kroketa",t:1,d:"Este amuleto tiene la facultad de volverse rosa los días en que su portador esté de humor vivaracha. Dicen que aumenta también tus posibilidades de encontrar buenos objetos.",ep:1,g:7,l:6,wd:true,fm:true,w:5,p:300};
I.u[325] = {n:"Amuleto del Sram",t:1,d:"Este amuleto confeccionado por uno de los más grandes joyeros Sram a partir de pequeñas calaveras talladas en el hueso, es único. Permite que su portador se escape más fácilmente de situaciones peligrosas.",ep:1,g:3,l:2,wd:true,fm:true,w:5,p:200};
I.u[326] = {n:"Amuleto Demetarana",t:1,d:"Este amuleto proviene de las regiones nórdicas, le confiere a su portador la capacidad de invocar criaturas más fácilmente.",ep:1,g:2,l:33,wd:true,fm:true,w:4,p:3000};
I.u[327] = {n:"Hoja del Cabalgador de Karne",t:6,d:"Esta hoja forjada en su origen para los Cabalgadores de Karne era en realidad demasiado pesada para estos frágiles goblins. Sin embargo, resulta muy ligera para un indivíduo normal, lo cual le permite golpear con mucha rapidez.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,50,20,false,false],c:"CS>32",p:900};
I.u[328] = {n:"Korta-Kotas",t:6,d:"Esta hoja doble con una forma muy extraña servía en su origen como machete para poder avanzar en los bosques densos. Los leñadores se dieron rápidamente cuenta de que constituía un arma genial para romper las armaduras de sus adversarios.",ep:1,g:4,l:18,wd:true,fm:true,w:28,an:14,e:[6,5,1,1,20,60,false,false],c:"CS>36",p:1050};
I.u[329] = {n:"Arco de Triunfo",t:2,d:"Como lo indica su nombre, este arco permite ganar fácilmente un combate. Incluso un gran arquitecto Ocra sin imaginación utilizó este nombre para una de sus horribles construcciones.",ep:7,g:11,l:30,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,10,30,50,false,true],c:"CA>30&CC>5&CS>10",p:1950};
I.u[331] = {n:"Arco Yris",t:2,d:"Este arco es el más buscado de toda Amakna, algunos cuentan que donde caen sus flechas se puede hallar un tesoro. Cosa extraña, parece que sólo es eficaz cuando la lluvia se mezcla a los rayos del sol.",ep:7,g:16,l:22,wd:true,fm:true,w:19,an:10,tw:true,e:[10,5,2,11,30,50,false,true],c:"CA>22&CC>15",p:1500};
I.u[332] = {n:"Arco de Juana",t:2,d:"Juana estaba un poco loca, oía Tabis eructar dentro de su cabeza. Para evitar que se lastimara con su arco, se lo quitaron y decidieron quemarla viva para calentar el ambiente el día de la inauguración de la taberna.",ep:7,g:15,l:30,wd:true,fm:true,w:23,an:10,tw:true,e:[10,4,2,9,30,50,false,true],c:"CS>10&CA>30",p:2550};
I.u[333] = {n:"Varita Depan",t:3,d:"En su origen era comestible pero con el paso del tiempo se convirtió en una temible arma, pues Javier el Panadero la olvidó en su horno durante 234 años cuando se había marchado a repartir tortas a los monstruos que se encontraban alrededor de su panadería.",ep:3,g:9,l:50,wd:true,fm:true,w:1,an:11,e:[5,3,3,5,50,50,false,true],c:"CW>40&CI>100",p:6650};
I.u[334] = {n:"Varita de Liriel",t:3,d:"Esta varita pertenecía a la aniripsa Liriel que se murió de una sobredosis de fresas en una lenta y horrible agonía durante la cual perdió sus alas gritando como una desesperada. Los coleccionistas estarían dispuestos a matar para conseguir esta varita maldita.",ep:7,g:5,l:20,wd:true,fm:true,w:13,an:11,e:[5,5,2,3,50,50,false,true],c:"CI>40",p:1300};
I.u[335] = {n:"Bastón del Bwork Mago",t:4,d:"Sin su bastón, los Bwork Magos son tan inofensivos como los Tofus sin sus Picos. Esto te dará una visión más clara del poder que encierra este bastón.",ep:7,g:1,l:58,wd:true,fm:true,w:28,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>58&CA>20",p:8900};
I.u[336] = {n:"Bastón del Awelito Wabbit",t:4,d:"Este bastón tiene la facultad de hacer levitar las Zanahowias. Uno puede preguntarse para qué demonios le sirve hacer eso durante un combate.",ep:8,g:1,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",p:2900};
I.u[337] = {n:"Arco del Bwork Arquero",t:2,d:"Este es un arco de uso muy sencillo, ha sido diseñado para adaptarse a la inteligencia de un Bwork Arquero, por lo cual incluso un Tofu podría utilizarlo. En cambio, es necesario tener la fuerza de un Crujidor para tensarlo.",ep:7,g:4,l:20,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>20&CA>20",p:1300};
I.u[338] = {n:"Hoja del Pequeño Bwork",t:6,d:"Esta espada aparentemente rudimentaria es muy apreciada por los Bworks más estúpidos que no saben servirse de un arco o de un bastón, incluso algunos confunden el filo con el mango lo cual provoca la risa de sus adversarios.",ep:1,g:13,l:21,wd:true,fm:true,w:30,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>42",p:1400};
I.u[339] = {n:"Cuchilla del chafer",t:6,d:"Esta cuchilla pertenecía a Metzger, el carnicero. Ha sido forjada para poder cortar huesos. Sin embargo un chafer consiguió robarle esta herramienta que actualmente se ha vuelto famosa por haber sido la causa de numerosas amputaciones.",ep:1,g:5,l:27,wd:true,fm:true,w:20,an:14,e:[20,6,1,1,15,60,false,false],c:"CS>54&CC>10",p:2100};
I.u[340] = {n:"Limpiadoras",t:5,d:"Estas dagas permiten, según cuenta la leyenda, robar cualquier cosa a cualquier persona o al revés, pero ya nadie recuerda muy bien la leyenda.",ep:1,g:9,l:12,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>12",p:600};
I.u[341] = {n:"Las dagas chifladas",t:5,d:"Estas dagas legendarias constituyen verdaderas piezas de colección para cualquier sram que se respete, son tan veneradas que algunos srams se niegan a robarlas.",ep:7,g:10,l:46,wd:true,fm:true,w:10,an:13,e:[10,2,1,1,30,50,false,false],c:"CA>46",p:5600};
I.u[342] = {n:"Martillo Picador",t:7,d:"Este martillo muy particular se hizo con picos de Kwaks, esto explica por qué pincha mucho cuando uno es golpeado con él.",ep:5,g:12,l:18,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>12&CS>6",p:1100};
I.u[345] = {n:"Pequeña Pala Apaleadora",t:8,d:"Después de una noche demasiado alcoholizada en la taberna que acabó con una pelea general, un Anutrof se dio cuenta de que esta pala, en su origen diseñada para los grandes trabajos de construcción, era una excelente arma.",ep:1,g:8,l:25,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>5&CC>20",p:1900};
I.u[346] = {n:"Anillo Vizna",t:9,d:"Algunas leyendas cuentan que este anillo protege de las intemperies al que lo lleve puesto. Pero eso todavía no ha sido demostrado ya que en Amakna nunca llueve.",ep:1,g:34,l:17,wd:true,fm:true,w:4,p:1000};
I.u[347] = {n:"Rhizoma dorado",t:8,d:"Esta pala de jardinero es especialmente eficaz para cortar los rhizomas, o las malas hierbas. Es una excelente arma también cuando se trata de cortar otra cosa que los rhizomas.",ep:1,g:10,l:40,wd:true,fm:true,w:30,an:16,e:[10,4,1,1,50,50,false,false],c:"CS>10&CC>30",p:4400};
I.u[348] = {n:"Botas de Rap y Dhez",t:11,d:"Estas botas pertenecieron a Rap y a Dhez, el primero tenía por costumbre hablar a una velocidad insuperable para proferir insultos salvajes sin que nadie le entendiese. En cambio Dhez, se pasaba las tardes escuchando música Chill Out para relajarse tras una dura jornada laboral. Parece que ambos rasgos dejaron huella sobre estas botas que te proporcionarán velocidad y calma a la hora de luchar contra un rival.",ep:2,g:5,l:53,wd:true,fm:true,w:20,p:6700};
I.u[350] = {n:"Plata",t:39,d:"La plata es un metal brillante muy apreciado por los joyeros, pese a lo que puedan decir algunos, la plata no tiene ningún efecto particular sobre los vampiros.",ep:1,g:28,l:60,wd:true,fm:true,w:5,p:0};
I.u[351] = {n:"Cerveza de Amakna",t:37,d:"Esta cerveza te permitirá restaurar tus puntos de vida. Y como dice el brillante refrán paterno: \"Más vale cerveza en el cuerpo que tener el cuerpo en la cerveza\"",ep:2,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[352] = {n:"Espadita Sagrada",t:6,d:"Esta es una espada santa que se entrega a los jóvenes guerreros durante su formación.",ep:1,g:1,l:13,wd:true,fm:true,w:30,e:[5,4,1,1,50,50,false,false],c:"CS>26&CV>5",p:700};
I.u[353] = {n:"Espada del Pequeño Caballero",t:6,d:"La Espada del Pequeño Caballero es una espada sólida y eficaz, si la usas de forma adecuada podrás causar enormes daños a tus adversarios.",ep:7,g:9,l:21,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>42",p:1400};
I.u[354] = {n:"La Klebik",t:6,d:"Este tipo de espada fue forjada para los guardias de un comerciante rico y famoso. Aunque su función inicial consistía en asustar a los ladrones, no deja de ser una arma temible para rematar a los ladrones o a los clientes honrados pero un poco pelmas.",ep:1,g:11,l:25,wd:true,fm:true,w:20,e:[12,4,1,1,30,60,false,false],c:"CS>50&CW>5",p:1850};
I.u[355] = {n:"Anillo de Valor",t:9,d:"Este anillo proporciona fuerza y valentía.",ep:1,g:7,l:12,wd:true,fm:true,w:4,p:600};
I.u[356] = {n:"Cinturón de Resistencia",t:10,d:"Este cinturón vuelve más resistente a quien lo lleve puesto.",ep:1,g:3,l:27,wd:true,fm:true,w:16,p:2200};
I.u[357] = {n:"La Cola",t:6,d:"Esta espada simboliza la parte del cuerpo de la que los Zurcaráks están más orgullosos. También resume perfectamente la filosofía de los jugadores.",ep:1,g:18,l:13,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>26&CA>10",p:650};
I.u[358] = {n:"La Cola Infernal",t:6,d:"La Cola Infernal es verdaderamente infernal... Con ella harás que tus adversarios o que tus compañeros se vuelvan completamente locos, o que tus compañeros se conviertan en adversarios si no sabes usarla. En cambio, nunca se dará el caso contrario.",ep:1,g:18,l:21,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>42&CA>10",p:1400};
I.u[359] = {n:"El Zurcalizador",t:9,d:"Este anillo le fue regalado hace mucho tiempo a Isidoro-es-genial por el rey Alister, que reconoció la agilidad inigualable de este zurcarák.",ep:1,g:35,l:29,wd:true,fm:true,w:3,p:2400};
I.u[360] = {n:"Orejas del pekewabbit",t:106,d:"Estas pequeñas orejas cubiertas con pelos marrones huelen a mediulubo muerto en cuanto se cuecen. En cambio son muy apreciadas cuando están rellenadas con gelatina real.",ep:8,g:30,l:11,wd:true,fm:true,w:1,p:10};
I.u[361] = {n:"Zanahowia",t:68,d:"Es la única comida del Pekewabbit hambriento, lo cual puede explicar su impenitente estupidez.",ep:2,g:31,l:20,wd:true,fm:true,w:1,p:2};
I.u[362] = {n:"Piel de larva azul",t:59,d:"Esta piel muy lisa constituye un excelente ingrediente para las pócimas mágicas.",ep:1,g:32,l:2,wd:true,fm:true,w:1,p:2};
I.u[363] = {n:"Piel de larva naranja",t:59,d:"Esta piel muy lisa constituye un excelente ingrediente para las pócimas mágicas.",ep:1,g:33,l:9,wd:true,fm:true,w:1,p:2};
I.u[364] = {n:"Piel de larva verde",t:59,d:"Esta piel muy lisa constituye un excelente ingrediente para las pócimas mágicas.",ep:1,g:34,l:7,wd:true,fm:true,w:1,p:100};
I.u[365] = {n:"Pata de arakna",t:103,d:"Una pata muy fina, pero muy velluda. Muy valorada por los alquimistas por sus propiedades euforizantes, esta pequeña debilidad causará su pérdida.",ep:1,g:35,l:2,wd:true,fm:true,w:1,p:10};
I.u[366] = {n:"Pico del tofu",t:47,d:"Este ridículo pequeño pico de tofu, aparentemente muy normal, está sin embargo muy afilado. Los arqueros de Amakna los utilizan desde hace siglos para hacer las puntas de sus flechas.",ep:1,g:37,l:4,wd:true,fm:true,w:1,p:2};
I.u[367] = {n:"Huevo de tofu",t:105,d:"Este huevo tiene la particularidad de oler a huevo podrido incluso cuando no está podrido, imagínate entonces un momento a lo que huele cuando realmente está podrido... Nadie sabe en cambio, quienes del tofu o del huevo de tofu llegó el primero en Amakna.",ep:1,g:38,l:4,wd:true,fm:true,w:1,p:1};
