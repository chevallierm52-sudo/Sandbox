I.u[255] = {n:"Imponente cinturón Vitalesco",t:10,d:"Este cinturón aumenta la vida del que lo lleve puesto, garantizandote una mayor seguridad en pleno combate.",ep:1,g:9,l:8,wd:true,fm:true,w:9,p:400};
