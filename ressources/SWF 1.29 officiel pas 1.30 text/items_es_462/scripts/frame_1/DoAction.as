I.u[250] = {n:"Ares",t:8,d:"Medio hacha, medio pala, Ares fue una de las siete armas utilizadas por el Demonio Kajlir para acabar con la ACDP (la cofradía de los Anutrofs Coleccionistas de Dofus Púrpura.",ep:9,g:9,l:72,wd:true,fm:true,w:50,an:16,e:[10,4,1,1,50,50,false,false],c:"CC>200",p:14000};
I.u[251] = {n:"Barba Gris",t:8,d:"Barba Gris era el arma favorita del demonio enano Tehle Fónika, que aterrorizó a numerosos campesinos atacándoles a cobro revertido y gritando \"¡Si te mueves, te cuelgo!\".",ep:1,g:11,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1250};
