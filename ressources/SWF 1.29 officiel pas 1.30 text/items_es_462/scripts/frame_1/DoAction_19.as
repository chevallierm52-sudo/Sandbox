I.u[7999] = {n:"Capapiña",t:17,d:"Algunos aventureros cuentan que esta capa es tan rugosa como la piel de un Cocodrail y otros incluso dicen que es todavía más rugosa que la piel de las nalgas de una hembra Bwork. Sea lo que sea, ten mucho cuidado en llevarla puesta del derecho si no quieres tú también acabar con las nalgas arrugadas...",ep:1,g:94,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8000] = {n:"Bworky",t:18,d:"Esta pequeña criatura es un Bwork que se ha quedado encerrado vivo dentro de un frasco de vidrio durante varias décadas. Por eso ha tomado la forma del frasco, y seguirá siendo enano toda su vida. Su buen humor legendario lo convierten en el compañero ideal para los asaltos a mazmorras perdidos de antemano, o para pasar noches mundanas infernales.",ep:3,g:31,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8001] = {n:"Vendita del guerrero koalak",t:15,d:"Esta vendita va normalmente enrollada alrededor de los brazos del guerrero koalak y le permite sonarse los mocos sin tener que usar pañuelos. Cuando ha sido ya muy utilizada, se cuelgan al techo de las casas para que los Moskitos se peguen sobre ellas.",ep:20,g:719,l:70,wd:true,fm:true,w:5,p:100};
I.u[8002] = {n:"Tela de Dok Alako",t:55,d:"Esta tela parece estar impregnada con una magia ancestral difícilmente previsible y dominable. Otro punto en común con tu dulcinea.",ep:20,g:720,l:40,wd:true,fm:true,w:5,p:1};
I.u[8003] = {n:"Amuleto del koalak",t:1,d:"Este amuleto no se parece a ningún otro amuleto, sencillamente porque ningún amuleto tiene parecido.",ep:20,g:94,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8004] = {n:"Anillo del koalak",t:9,d:"Los Koalaks más temerarios llevan puesto este maravilloso anillo. Él demuestra la valentía y la sangre fría que ha tenido que demostrar su portador para robárselo a los aventureros que salen del banco de Astrub.",ep:20,g:99,l:53,wd:true,fm:true,w:10,s:46,p:7375};
I.u[8005] = {n:"Arco del koalak",t:2,d:"Este sorprendente arco permite robarle vida a tus adversarios, incluso a veces puede arrebatársela toda. Lo cual resulta ser muy impresionante.",ep:20,g:52,l:61,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,4,50,50,false,true],s:46,p:9775};
I.u[8006] = {n:"Botas del koalak",t:11,d:"Estas botas son en realidad unos pies de koalaks que han sido arrancados a sus propietarios de forma salvaje, vaciados de su contenido y forrados con pelos de koalaks. A la vez terroríficas y chulas, estas botas harán que te transformes en el terror de Astrub.",ep:20,g:71,l:60,wd:true,fm:true,w:10,s:46,p:9600};
I.u[8007] = {n:"Capa del Koalak",t:17,d:"Esta capa te protegerá contra la mayoría de los ataques, pero no contra el ridículo.",ep:20,g:95,l:61,wd:true,fm:true,w:10,s:46,p:9675};
I.u[8008] = {n:"Cinturón del koalak",t:10,d:"Este cinturón hecho con hojas de Kalipto desprende un delicioso olor capaz de encubrir otros. También es ideal para disimular tus michelines.",ep:20,g:87,l:60,wd:true,fm:true,w:10,s:46,p:9508};
I.u[8009] = {n:"Sombrero del koalak",t:16,d:"Este sombrero está adornado con enormes orejas de Koalak que permiten ampliar los sonidos emitidos por las criaturas que te rodean. Ojo, puede destruir tus tímpanos si sus amigos son aficionados a los vientos de pánico.",ep:20,g:125,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8010] = {n:"Desmontador",t:93,d:"Permite recuperar un equipo instalado en un cercado.",ep:1,g:96,l:1,wd:false,fm:true,w:10,ut:true,p:1};
I.u[8011] = {n:"Los Profetas, los cultos, la Fe",t:25,d:"Algunas buenas historias sobre los cultos que seducirán al místico empedernido.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8012] = {n:"Polvo de resurrección",t:48,d:"Este polvo permite resucitar a una mascota fantasma, a condición de saber cómo se alimentan los fantasmas de mascotas.",ep:20,g:51,l:1,wd:true,fm:true,w:1,p:100};
I.u[8013] = {n:"Transformación fantasma Miaumiau",t:27,d:"Has sido transformado en fantasma para poder penetrar en el santuario de las mascotas.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8016] = {n:"Fantasma de Koalak Sanguíneo",t:90,d:"Este Koalak aún no ha dejado el mundo de los vivos, tendrás que encontrar la forma de resucitarlo o decidir abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:43,l:1,wd:true,fm:true,w:1,p:1};
I.u[8017] = {n:"Fantasma del Bworky",t:90,d:"Este Bworky aún no ha dejado el mundo de los vivos, te toca encontrar alguna manera de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:31,l:1,wd:true,fm:true,w:1,p:1};
