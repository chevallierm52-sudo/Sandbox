I.u[7877] = {n:"Piedra de jade",t:51,d:"Esta piedra nunca perteneció a Jade, igual que la piedra de ágata nunca perteneció a Ágata.",ep:1,g:458,l:1,wd:true,fm:true,w:1,p:1};
I.u[7879] = {n:"La llegada de Hyrkul",t:25,d:"Los Anales colosales, inmorales y no banales de Domen son estremecedores. Léase respetando las dosis prescritas. Efectos secundarios: sudores fríos e incontinencia nocturna.",ep:16,g:19,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[7880] = {n:"Amuleto del jalatranki",t:1,d:"Este amuleto era antiguamente llevado por todos los aventureros que preferían reivindicar el amor y no la guerra. Cada cual tiene sus gustos...",ep:20,g:93,l:20,wd:true,fm:true,w:5,s:43,p:1300};
I.u[7881] = {n:"Anillo del jalatranki",t:9,d:"Tus hijos se merecen que le des fuerte con este anillo para que sufran todavía más.",ep:20,g:98,l:38,wd:true,fm:true,w:5,s:43,p:4000};
I.u[7882] = {n:"Martillito del jalatranki",t:7,d:"Este martillo es ideal para dejar una huella de tus valores pacifistas sobre el cráneo de tus adversarios.",ep:20,g:54,l:41,wd:true,fm:true,w:10,an:15,e:[5,5,1,1,40,40,false,false],s:43,p:4520};
I.u[7883] = {n:"Botas del jalatranki",t:11,d:"Forradas con lana de jalatranki, estas botas son realmente encantadoras. Ligeras, calurosas durante las épocas de gran frío y aireadas durante las temporadas estivales, permitirán satisfacer al aventurero que piense haberlo visto todo.",ep:20,g:66,l:38,wd:true,fm:true,w:15,s:43,p:3925};
I.u[7884] = {n:"Capa del jalatranki",t:17,d:"Si te gusta tomarte la vida con tranquilidad, esta capa es la tuya. Es tan gruesa y cómoda que puedes usarla como cama improvisada si te cansas demasiado. Además su olor a Kalipto ahumado le permite ahuyentar a los insectos, a las criaturas indeseables o incluso a las suegras...",ep:20,g:93,l:55,wd:true,fm:true,w:15,s:43,p:8030};
I.u[7885] = {n:"Cinturón del jalatranki",t:10,d:"Cuando lleves este cinturón, tus rivales pensarán que eres un aventurero pacifista y de esta manera podrás darles un susto más grande clavándoles tu espada en la espalda.",ep:20,g:84,l:37,wd:true,fm:true,w:10,s:43,p:3800};
I.u[7886] = {n:"Sombrero del jalatranki",t:16,d:"Con esta cofia sobre la cabeza, no parecerás más inteligente que antes, eso dátelo por seguro. En cambio, tendrás un aspecto mucho más \"tranki\" y al final eso es lo que cuenta.",ep:20,g:119,l:47,wd:true,fm:true,w:15,s:43,p:6000};
I.u[7887] = {n:"Sombrero del trankitronko",t:16,d:"Este sombrero perteneció al famoso trankitronko, conocido por la fragilidad de sus pies y por su legendario buen humor.",ep:20,g:122,l:82,wd:true,fm:true,w:10,s:44,p:18375};
I.u[7888] = {n:"Bolso del Trankitronko",t:81,d:"Este bolso le permite al Trankitronko conservar al fresco sus hojas de Kalipto o asfixiar los Koalaks demasiado atrevidos.",ep:20,g:2,l:69,wd:false,fm:true,w:10,s:44,p:12278};
I.u[7889] = {n:"Botas del Trankitronko",t:11,d:"Estas botas pertenecieron al Trankitronko, y aunque no se vea... se puede oler. Estas botas son tan confortables que casi te harán olvidar tu miserable vida.",ep:20,g:69,l:73,wd:true,fm:true,w:10,s:44,p:13775};
I.u[7890] = {n:"Bastón del Trankitronko",t:4,d:"Este bastón es en realidad un hueso vaciado de uno de los antepasados del Trankitronko. Lleva agujeros en sus dos extremidades y puede servir como pipa de Kalipto, pero también como flauta para los pastores. Eso es tecnología punta.",ep:20,g:62,l:75,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,20,50,false,false],s:44,p:14675};
I.u[7891] = {n:"Mini Wey",t:18,d:"Este pequeño Wabbit es en realidad uno de los hijos ocultos del tristemente célebre Wey Wabbit. Tal vez algún día se haga con el trono.",ep:3,g:28,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7892] = {n:"Willy el Plasta",t:18,d:"Willy el Plasta es realmente una vil criatura. Parece ser que su infancia fue especialmente difícil. Desde se venga comiendo todos los peluches con los que llega a cruzarse.",ep:3,g:29,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7893] = {n:"Fantasma de Mini Wey",t:90,d:"Este pequeño Mini Wey aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o decidir abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:18,l:1,wd:true,fm:true,w:1,p:1};
I.u[7894] = {n:"Fantasma de Willy el Plasta",t:90,d:"Este pequeño Willy el Plasta aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o decidir abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:17,l:1,wd:true,fm:true,w:1,p:1};
I.u[7895] = {n:"Certificado de admisión en la petrera: Mini Wey",t:77,d:"Este certificado describe las características del Mini Wey, al que has dejado en la petrera.",ep:3,g:34,l:1,wd:false,fm:true,w:1,p:100};
I.u[7896] = {n:"Certificado de admisión en la petrera: Willy el plasta",t:77,d:"Este certificado describe las características de Willy el plasta, al que has dejado en la petrera.",ep:3,g:29,l:1,wd:false,fm:true,w:1,p:100};
I.u[7897] = {n:"Regalo: Mini Wey",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.\n(¡OJO! Este Regalo: contiene objetos muy pesados. Si lo abres ahora, puede que no puedas moverte debido al exceso de peso. Si quieres ver lo que contiene, deshazte de algunos objetos pesados de tu inventario o pide ayuda a algún amigo.)",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7898] = {n:"Regalo: Willy el Plasta",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.\n(¡OJO! Este Regalo: contiene objetos muy pesados. Si lo abres ahora, puede que no puedas moverte debido al exceso de peso. Si quieres ver lo que contiene, deshazte de algunos objetos pesados de tu inventario o pide ayuda a algún amigo.)",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7899] = {n:"El Mini Wey: Criarlo bien",t:25,d:"Este libro escrito por Yokashi Temato Konkatana explica cómo criar a un Mini Wey.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7900] = {n:"Willy el Plasta: Criarlo bien",t:25,d:"Este libro escrito por Yokashi Temato Konkatana explica cómo criar a un Willy el Plasta.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7902] = {n:"Cinturón de una Mujer de Oro",t:10,d:"Cuenta una vieja leyenda en el famoso libro de magia \"Toda la verdad sobre las mujeres\" que este cinturón perteneció a una mujer de oro, más interesada por la riqueza que por el poder. En la versión no censurada del libro, se cuenta también que esta era famosa por su pronunciado gusto por los chistes verdes. Al final no era tan diferente de las demás mujeres...",ep:2,g:86,l:71,wd:true,fm:true,w:5,p:13300};
I.u[7903] = {n:"Hoja de kalipto",t:36,d:"Si se introducen con cuidado, estas hojas podrán desatascar cualquier nariz. Algunas leyendas tribales cuentan que esta técnica funciona con otros orificios.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7904] = {n:"Flor de kalipto",t:35,d:"Tras quemarse, esta flor desprende un espeso humo con virtudes alucinógenas. Si se mastica, vuelve impotente. En infusión puede producir importantes efectos laxativos. La mejor solución consiste en no tocarla jamás.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7905] = {n:"Lana del jalatranki",t:57,d:"Esta lana se parece mucho a la lana del jalató y sin embargo no lo es ya que no huele mal.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7906] = {n:"Cuerno de jalatranki",t:47,d:"Una vieja leyenda cuenta que la pólvora extraída de estos cuernos tiene virtudes afrodisíacas. Esta misma leyenda precisa que también puede tener sorprendentes efectos secundarios. Una buena razón para probarla.",ep:20,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[7907] = {n:"Cuero del jalatranki",t:56,d:"Este cuero multicolor permite confeccionar ropa interior de cuero multicolor. El más extravagante de los Chafers se volverá loco de envidia.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7908] = {n:"Llave de la Mazmorra del Trankitronko",t:84,d:"Esta llave esculpida en hueso te permitirá acceder a la mazmorra del Trankitronko sin tener que presentar ninguna invitación",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[7911] = {n:"Koalak sanguíneo",t:18,d:"Este pequeño koalak tiene un aspecto inofensivo, pero las mata callando. Durante su tierna infancia ha sido martirizado, pues recibió numerosos bumeranes en los dientes o incluso en las nalgas. Desde entonces, odia los bumeranes y los devora sin ni siquiera masticarlos.",ep:3,g:30,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:46,p:1};
I.u[7913] = {n:"El Divisor (MJ)",t:9,d:"Este misterioso objeto, olvidado por todos, pertenecía a un gran mago... según parece, permitía hablar con ciertos animales...",ep:1,g:22,l:1,wd:false,fm:true,w:1,p:1};
I.u[7917] = {n:"Regalo: de Compensación",t:89,d:"Para excusarnos por los problemas de desconexión que has tenido, el equipo de Ankama te hace este regalo. Dentro descubrirás:                                                          - 5 Caramelos de Compensación del Sabio\n- 5 Caramelos de Compensación del Afortunado\n- 10 Caramelos de Compensación Energéticos\n- 10 Polvos de Aniripsas",ep:1,g:32,l:1,wd:true,fm:true,w:1,c:"PO!7801&PO!7800",u:true,p:1};
I.u[7918] = {n:"Llave de la Mazmorra de los Tofus",t:84,d:"Esta llave fabricada con una pluma de Tofu es capaz de hacer cosquillitas en el interior de ciertas cerraduras... Opcionalmente, con ella podrás acceder al Tofullinero de Farle Ingals.",ep:1,g:6,l:1,wd:true,fm:true,w:1,p:100};
I.u[7919] = {n:"Ficha del Master de Juego",t:15,d:"Esta magnífica ficha se podrá sin duda cambiar en la Feria del Trool por preciosos regalos.",ep:1,g:737,l:1,wd:true,fm:true,w:1,p:100};
I.u[7920] = {n:"Varita del Torneo (MJ)",t:3,d:"Esta modesta varita permite a los Masters de Juego teleportar a los aventureros en una zona reservada para los torneos.",ep:1,g:8,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],u:true,p:100};
I.u[7921] = {n:"Corona del Tofu Real",t:16,d:"Esta corona es bastante difícil de atrapar, resbala entre los dedos. No hay duda, se trata de la Corona de Tofu Real. En cambio, no parece poder ajustarse a tu cabecita ¡Sin hablar de la de un Yopuka!",ep:13,g:154,l:128,wd:true,fm:true,w:10,p:42625};
I.u[7922] = {n:"Peluche del dopeul sacrógrito",t:61,d:"Este peluche se ha hecho para los jóvenes sacrógritos. Es perfecto para limpiarse la sangre. Es fácil de lavar, sea cual sea la temperatura del agua.",ep:0,g:1,l:1,wd:true,fm:true,w:10,p:1};
I.u[7923] = {n:"Peluche del dopeul pandawa",t:61,d:"Este peluche huele a alcohol y a pelo de pandawa mojado... Igual que mamá.",ep:1,g:2,l:1,wd:true,fm:true,w:10,p:1};
I.u[7924] = {n:"Llave del Laberinto del Minotauroro",t:84,d:"Esta magnífica llave te permitirá entrar en el laberinto del Minotauroro, pero no te servirá para salir de él...",ep:13,g:7,l:1,wd:true,fm:true,w:1,p:100};
I.u[7925] = {n:"Madera de kalipto",t:38,d:"Esta madera perfumada permite construir casas que huelen bien, aunque sus propietarios huelan mal. Desgraciadamente, esta madera no es bastante flexible para la elaboración de la ropa interior.",ep:20,g:1,l:50,wd:true,fm:true,w:2,p:0};
I.u[7926] = {n:"Llave de la Mazmorra del Maestro Cuerbok",t:84,d:"Esta llave te permitirá conocer al Maestro Cuerbok en persona. Es muy probable que éste te invite a comer queso con él...",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[7927] = {n:"Llave de la Mazmorra de los Crujidores",t:84,d:"Esta llave es casi irrompible, pero está muy gastada ya que abrió muchas puertas. Parece que ha sido fabricada con las partes íntimas de un Crujidor. Sencillamente aterrador.",ep:1,g:9,l:1,wd:true,fm:true,w:1,p:100};
I.u[7928] = {n:"Llave de la Mazmorra de las Mascotas",t:84,d:"Esta llave te permitirá entrar en el santuario de las mascotas muertas de hambre, de cansancio, toturadas, devoradas, cosquilleadas hasta la muerte, intoxicadas por Dragoleche, asfixiadas en un cofre o sencillamente abandonadas en la cuneta de un pedregoso camino.",ep:1,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[7929] = {n:"Manual del Mercenario de Astrub",t:25,d:"El Manual del Mercenario de Astrub, escrito por el famoso Bajovientre, jefe mercenario de Astrub es la biblia de todos aquellos que afeccionan respetar la ley o eludirla.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7930] = {n:"Hacerse amigos y guardarlos",t:25,d:"Normas y consejos para hacerse buenos y leales amigos por Acidrik Rasgapanza",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7931] = {n:"El tiempo de los dragones - Fragmentos Encontrados III",t:25,d:"Tomo III de los Fragmentos de la Historia del Mundo, encontrados por el Erudito Acidrik Rasgapanza y reescritos por él mismo.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:50};
I.u[7932] = {n:"Pergamino Miss Astrub",t:25,d:"La exuberante Miss Astrub de este año nos desvela las encantos con los que sedujo al jurado.",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[7933] = {n:"Pergamino de los Mangadores de Amígdala.",t:25,d:"Estos bailadores profesionales animan las noches más destacadas de la comarca.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:69};
I.u[7934] = {n:"Viajar Sin Perder el Norte",t:25,d:"Arpagnagrobis ha escrito este libro para todos los aventureros que no saben utilizar ni la brújula ni los zaaps.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7935] = {n:"Broche Zafiro",t:24,d:"Esta joya permaneció colgada durante meses en una cabellera gruesa. Una inscripción explica que puede servir como llave si se reúnen otros broches...",ep:20,g:109,l:1,wd:true,fm:true,w:0,p:100};
