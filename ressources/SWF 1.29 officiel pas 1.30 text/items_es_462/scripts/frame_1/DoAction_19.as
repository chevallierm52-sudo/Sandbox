I.u[8249] = {n:"Pluma del Bebedor",t:53,d:"Esta pluma usada e impregnada de alcohol es altamente inflamable. Muy práctica para cocinar un Bebedor asado.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[8250] = {n:"Pelo de Zorrowapo",t:54,d:"El Zorrowapo adora disfrazarse de Cuerbok, nadie sabe en realidad por qué, aunque las mentes malpensadas tienen su propia opinión sobre la cuestión...",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[8251] = {n:"Pelo de Peki",t:54,d:"¿Quién hubiera creído que el Peki te regalaría un mechón de su pelo? Nadie excepto Moki Toh, el famoso tonto del pueblo de Amakna...",ep:18,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[8252] = {n:"Pluma de cuerbok domesticado",t:53,d:"Esta pluma muy grasienta es la de un cuerbok domesticado, que pasó la mayor parte de su existencia encerrado y cebado hasta que ocupó la totalidad del espacio de su jaula.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[8253] = {n:"Amuleto de Esponja",t:1,d:"A menudo se confunde este amuleto con uno de esos juguetes que hay en las bolsas sorpresa que ganas en el puesto de tiro de las ferias.",ep:1,g:106,l:11,wd:true,fm:true,w:2,s:63,p:525};
I.u[8254] = {n:"Anillo de Esponja",t:9,d:"Como una alianza, este anillo permite comunicarle dos mensajes al ser amando: \"Te quiero\" y \"Vete a lavar la vajilla\". Ideal para no perder el tiempo repitiendo cada noche la misma cosa.",ep:1,g:112,l:10,wd:true,fm:true,w:2,s:63,p:500};
