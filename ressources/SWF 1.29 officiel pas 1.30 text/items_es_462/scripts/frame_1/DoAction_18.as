I.u[7439] = {n:"Recompensa de misión mercenaria",t:14,d:"Este pergamino certifica que mereces una recompensa honorífica por tu implicación en las misiones de los mercenarios.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"Ps=3&Pa>79",u:true,ut:true,p:1};
I.u[7440] = {n:"Sanción de mercenario",t:14,d:"Este pergamino certifica que mereces una sanción por no haber observado las reglas del clan de los mercenarios.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"Ps=3&Pa>79",u:true,ut:true,p:1};
