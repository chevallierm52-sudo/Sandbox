I.u[7431] = {n:"Pócima de pueblo de los Dopeuls",t:12,d:"Esta pócima te permite teleportarte en el pueblo de los dopeuls, si éste último te pertenece.",ep:0,g:19,l:1,wd:false,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:1};
I.u[7432] = {n:"Pócima de pueblo los Kwaks de Tierra",t:12,d:"Esta pócima te permite teleportarte en el pueblo de los kwaks de tierra, si éste último te pertenece.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7433] = {n:"Runa Gri",t:78,d:"Esta runa permite volver tus ataques todavía más sorprendentes.",ep:1,g:14,l:20,wd:true,fm:true,w:1,p:10};
