I.u[7493] = {n:"Engastador del Joyeromago",t:5,d:"Este engastador permite volver las joyas que has creado más brillantes.",ep:2,g:52,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=63",p:1000};
I.u[7494] = {n:"Aguja del Sastremago",t:20,d:"Esta aguja mágica te permitirá mejorar considerablemente la calidad de tus creaciones.",ep:9,g:23,l:1,wd:false,fm:true,w:1,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=64",p:1000};
I.u[7495] = {n:"Corta cueros de zapateromago",t:5,d:"Este Corta Cueros mágico permite recortar mejor el cuero y rascar las pieles. Es la herramienta idónea para mejorar las viejas botas y los cinturones.",ep:2,g:53,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=62",p:1000};
I.u[7496] = {n:"Pócima de Resurrección de las Masas",t:14,d:"Esta pócima permite resucitar a todos los aliados presentes a tu alrededor.",ep:0,g:60,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7497] = {n:"Pócima de Liberación de las Masas",t:14,d:"Esta pócima permite liberar las almas de tus enemigos para enviarlas directamente a su cementerio, sin dejarles la posibilidad de ser resucitados.",ep:0,g:59,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7498] = {n:"Pequeña pócima de Curación de Masas",t:14,d:"Esta pócima permite curar a todos los aliados presentes en el mapa.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"Pg>23,2",u:true,p:10};
I.u[7499] = {n:"Pócima de pueblo los Kwaks de Hielo",t:12,d:"Esta pócima te permite teleportarte en el pueblo de los kwaks de hielo, si éste último te pertenece.",ep:0,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7500] = {n:"Pócima del pueblo de los Kwaks de Fuego",t:12,d:"Esta pócima te permite teleportarte en el pueblo de los kwaks de fuego, si éste último te pertenece.",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7501] = {n:"Pócima del pueblo de los Kwaks de Viento",t:12,d:"Esta pócima te permite teleportarte en el pueblo de los kwaks de viento, si éste último te pertenece.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7502] = {n:"Pócima de Unión",t:12,d:"Esta pócima permite crear un punto de encuentro para que los aventureros de tu alineación se unan a ti, por ejemplo, para organizar un ataque o una defensa de pueblo. Esta pócima mágica permite guardar también la posición de los que llegan para permitirles volver rápidamente a su ubicación inicial.",ep:0,g:21,l:1,wd:false,fm:true,w:1,p:1};
I.u[7504] = {n:"Runa de Vuelta Atrás",t:88,d:"Esta runa permite volver rápidamente al lugar de su último punto de reaparición.",ep:1,g:46,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7505] = {n:"Pócima de olvido de oficio: Sastremago",t:44,d:"Esta pócima te hará olvidar el oficio de Sastremago.",ep:9,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7506] = {n:"Pócima de olvido de oficio: Joyeromago",t:44,d:"Esta pócima te hará olvidar el oficio de joyeromago.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7507] = {n:"Pócima de olvido de oficio: Zapateromago",t:44,d:"Esta pócima te hará olvidar el oficio de Zapateromago.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7508] = {n:"Runa de Firma",t:50,d:"Esta runa permite que los artesanos más hábiles puedan firmar sus creaciones. \n(hay que utilizarla durante la fabricación del objeto, junto con todos los ingredientes)",ep:18,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[7509] = {n:"Trozo de la llave de la Mazmorra Cerda",t:84,d:"Si este hocico no te suena no intentes hacer nada con él o recibirás una bofetada mortal, sobre todo si eres distraído.",ep:13,g:1,l:1,wd:true,fm:true,w:1,p:100};
I.u[7510] = {n:"Segunda parte de la llave del Laberinto del Dragocerdo",t:84,d:"Este cacho puede formar parte de la llave que abre el cofre del tesoro con el que siempre has soñado... o puede simplemente que sea la llave de tu propia tumba.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[7511] = {n:"Llave de la Mazmorra Cerda",t:84,d:"Si piensas encontrar muchas cerdas con esta llave te equivocas. Te permitirá abrir el antro del Dragocerdo. Ten cuidado, se destruirá después de haber sido utilizada.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:100};
I.u[7512] = {n:"Espíritu de cerdo",t:24,d:"Este trofeo demuestra tu amor por los cerdos. Pero no te olvides de ducharte cuando vuelvas a junto de tu mujer si no quieres dormir en la granja de los jalatós.",ep:1,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[7513] = {n:"Sandalia Titud",t:11,d:"Titud era un humilde zapatero anutrof, todavía más pequeño que un xelor. Dicen que ha creado estas sandalias para conseguir por fin besar a su dulcinea, una aniripsa lisiada sin piernas, pero eso no siendo suficiente, ha tenido que conformarse con no besarla de pie.",ep:20,g:67,l:122,wd:true,fm:true,w:10,p:37800};
I.u[7514] = {n:"Botas Focas",t:11,d:"Con un bonito balón rojo y amarillo en su punta... póntelas y verás como flipan los delfines...",ep:20,g:70,l:123,wd:true,fm:true,w:10,p:37850};
I.u[7515] = {n:"Capa Itanflam",t:17,d:"Esta capa no es de tu galaxia y sin embargo hace juego con tus medias en lana de Jalatín.",ep:20,g:92,l:148,wd:true,fm:true,w:10,p:47925};
I.u[7516] = {n:"Sombrero del Bimd\'Ulo",t:16,d:"El primero en descubrir este terrible sombrero fue un viejo Anutrof, amargado y carcomido por años de mala suerte. La encontró en el fondo de una alcoba en las cuevas de Bimd\'Ulo. Más tarde, el Anutrof se exilió lejos de las tierras de Amakna para intentar escapar del aburrimiento y descubrir nuevos horizontes.",ep:20,g:121,l:110,wd:true,fm:true,w:10,p:31675};
I.u[7517] = {n:"Cerveza del Ripata",t:37,d:"Esta cerveza está tan ácida que la jarra con la que la sirven tiene una esperanza de vida comparable a la del Moskito.",ep:7,g:4,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7518] = {n:"Fotasma",t:18,d:"Esta sorprendente criatura viene del más allá y no tiene pensado volver, excepto si por desgracia, vas tú con ella...",ep:3,g:13,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7519] = {n:"Dragún rosa",t:18,d:"Este pequeño dragón tiene la piel tan rosada como las nalgas de una hembra Bwork. Es un buen método para satisfacer tus fantasías gratuitamente y sin riesgos, o simplemente para recordarte los viejos tiempos. Afortunadamente para él, este dragón no es solamente el objeto de tus fantasías, sino que sobre todo es una criatura muy poderosa y sabia. Pero ten cuidado, es tan voraz como un Chafer perverso las noches de luna llena, y sólo se alimenta con otras mascotas.",ep:3,g:14,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7520] = {n:"Crum",t:18,d:"Esta criatura es un antiguo soldadito de plomo jubilado que volvió a la vida. Te seguirá por todas partes y lo hará todo para defenderte arriesgando incluso su propia vida, eso sí, si lo alimentas con frecuencia.",ep:3,g:15,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7521] = {n:"Regalo: Fotasma",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7522] = {n:"Minimino",t:18,d:"Este bebé Minotauroro está domesticado y lavado. Puedes acercarte a él y acariciarlo, sin correr el riesgo de perder una mano. Sin embargo, sé prudente, la naturaleza puede a veces volver al estado salvaje y podría ser que el instinto destructivo de esta criatura vuelva a dominarlo en el momento menos esperado. Para evitar malas sorpresas, edúcalo como si fuese tu propio hijo, a golpe de maza.",ep:3,g:21,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7523] = {n:"Miaumiau Pelirrojo",t:18,d:"Esta entrañable criatura es capaz de robar el corazón de cualquier felino, incluso el de los más experimentados. \n(ESTA MASCOTA LEGENDARIA NO NECESITA ALIMENTARSE)",ep:1,g:40,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7524] = {n:"Miaumiau Atigrado",t:18,d:"Esta sorprendente criatura es el resultado del cruce entre un Miaumiau blanco y un Miaumiau negro.",ep:3,g:41,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7525] = {n:"Regalo: Dragún Rosa",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7526] = {n:"Regalo: Crum",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.\n(¡OJO! Este Regalo: contiene objetos muy pesados. Si lo abres ahora, puede que no puedas moverte debido al exceso de peso. Si quieres ver lo que contiene, deshazte de algunos objetos pesados de tu inventario o pide ayuda a algún amigo.)",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
