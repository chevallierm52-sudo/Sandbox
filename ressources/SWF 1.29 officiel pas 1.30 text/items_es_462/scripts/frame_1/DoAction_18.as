I.u[7363] = {n:"Nacimiento de Bolgrot - Fragmentos Encontrados VI bis",t:25,d:"Tomo VI adicional de los Fragmentos de la Historia del Mundo encontrados por el erudito Acidrik Rasgapanza y reescritos por él mismo.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
