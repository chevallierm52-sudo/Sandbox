I.u[7714] = {n:"Tortuga",t:18,d:"Dicen que un Experto en Artes Marciales ha criado esta tortuga que se parece a una rata de alcantarillas. Si la alimentas con pescado se volverá buena y te ayudará a curar a los aventureros heridos. Si le das carne, se volverá más agresiva y te ayudará a luchar contra tus adversarios.",ep:2,g:17,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:9,p:1};
I.u[7721] = {n:"Fantasma del Cuerbokito Feo",t:90,d:"Este Cuerbokito Feo aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:38,l:1,wd:true,fm:true,w:1,p:1};
