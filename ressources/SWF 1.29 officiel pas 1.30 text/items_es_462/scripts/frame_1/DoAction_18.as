I.u[7805] = {n:"Los Dragopavos: Criarlos bien",t:25,d:"Este imponente libro te explicará cómo capturar, criar y montar los Dragopavos. Lo escribió Gylygil en persona. Una garantía de calidad.",ep:16,g:19,l:1,wd:false,fm:true,w:1,u:true,p:500};
I.u[7806] = {n:"Certificado de Montura",t:97,d:"Este certificado te permite ir a por tu montura en un establo. Ojo, este certificado sólo es válido durante 20 días, cuando este período haya transcurrido, tu montura se soltará en la naturaleza, tu certificado ya no será válido y no podrás recuperar tu montura. Piensa en dejar tu montura en algún establo si vas a estar ausente durante mucho tiempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
