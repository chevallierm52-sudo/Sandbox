I.u[7753] = {n:"Varita Termal",t:3,d:"Esta varita sale directamente de las profundidades más calientes de las entrañas de la tierra. Ten cuidado al manipularla. ¿Acaso no te han dicho que no se jugaba con el fuego?",ep:1,g:131,l:229,wd:false,fm:true,w:15,an:11,e:[10,2,5,5,20,60,false,false],c:"CI>1000&CA>250",p:57000};
I.u[7754] = {n:"Dofus Ocre",t:23,d:"Ha sido puesto por Terrakurial, el Dragón de la Tierra. Este Dofus encierra grandes poderes por lo cual no debe dejarse entre las manos de cualquiera...",ep:1,g:12,l:6,wd:true,fm:true,w:10,p:50000};
