I.u[7366] = {n:"Dioses y Demonios",t:25,d:"Algunas consideraciones metafísicas de Acidrik Rasgapanza.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7367] = {n:"Ángeles y Demonios",t:25,d:"Obra que recibió una muy buena acogida por millones de lectores, Acidrik Rasgapanza vuelve de nuevo con otras tantas consideraciones metafísicas.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7368] = {n:"Varita Strella",t:3,d:"El escultor de esta varita quería destruir con ella las estrellas fugaces que le impedían dormir por la noche. Cuenta la leyenda que una noche, al salir de la taberna completamente borracho, quiso probar su varita pero confundió la luna con una estrella fugaz. Como la varita era muy poderosa partió la luna en dos y sus dos cachos se cayeron en pleno Mar Rano, creando de esta manera la Isla de Moon tal como la conocemos hoy. Otra ridícula historia que puedes contar a tus amigos las noches de borrachera.",ep:19,g:55,l:126,wd:true,fm:true,w:15,an:11,e:[5,4,2,4,50,50,false,true],c:"CS>100&CV>150&CI>300",p:39355};
I.u[7369] = {n:"Ámbar de bambuto",t:50,d:"Este ámbar va colgado generalmente en la cima del bambuto, es una joya pero también le otorga más inercia cuando el bambuto decide caerte encima para haciéndote más daño. Qué ingeniosa criatura.",ep:18,g:2,l:40,wd:true,fm:true,w:2,p:100};
I.u[7370] = {n:"Ámbar de bambuto sagrado",t:50,d:"Este ámbar constituye la única riqueza del bambuto sagrado, tal vez sea por eso que está tan amargado y es tan malo con los turistas que visitan la isla de Pandala.",ep:18,g:1,l:120,wd:true,fm:true,w:2,p:100};
I.u[7371] = {n:"El tiempo de los Dofus - Fragmentos Encontrados IV",t:25,d:"Tomo IV de los Fragmentos de la Historia del Mundo, encontrados por el Erudito Acidrik Rasgapanza y reescritos por él mismo.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
