I.u[7379] = {n:"Tejido de fantasma Pandikaze",t:55,d:"A pesar de los golpes que le has tenido que dar a ese pobre fantasma Pandikaze para arrancárselo, este montón de pelos está casi intacto.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7380] = {n:"Tejido de fantasma Maho Firefux",t:55,d:"Este mágico tejido rosa rezuma una magia superpoderosa. Aunque no podemos decir lo mismo de ti.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7381] = {n:"Tejido de fantasma Soryo Firefux",t:55,d:"Este tejido de tamaño medio es perfecto para tapar los huecos de debajo de las puertas, cuando se acerca el frío invierno.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7382] = {n:"Tejido de fantasma leopardo",t:55,d:"Este tejido no es tan suave al tacto como la música del leopardo lo es al oído, pero puede resultarte muy útil. ¿Para qué? Ésa es la cuestión.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7383] = {n:"Tejido de fantasma Yokai Firefux",t:55,d:"Este tejido proviene de las partes más sensibles (y también las que peor huelen) del fantasma Yokai Firefux. Muchos aventureros piensan que se trata de sus bigotes, pero se equivocan.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7384] = {n:"Tejido de fantasma Pandulo",t:55,d:"Al contrario de lo que pueda parecer, este tejido no es comestible. Los últimos que intentaron cocinarla se transformaron en Tanukui San. Lo que fue una bendición para algunos de ellos.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7385] = {n:"Tejido de fantasma Tanukui San",t:55,d:"Este tejido proviene directamente de las axilas del fantasma Tanukui San, que son tan famosas por su suavidad como por su olor, bastante cercano al de la carne de cuerbok putrefacta.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7386] = {n:"Testículos del Tanukui San",t:15,d:"Estos enormes testículos están recubiertos por una pelusilla muy suave que protege de maravilla contra los ataques mágicos pero también contra los golpes de zancos que se da el Tanukui San cuando no va con cuidado o cuando entra en trance al invocar a una hembra Tanuki Chan. En cualquier caso, lo que tienes entre las manos tiene un gran valor semental.",ep:1,g:2,l:120,wd:true,fm:true,w:200,p:10};
I.u[7387] = {n:"El Clan de los Mercenarios",t:25,d:"Todo lo que siempre quiso saber sobre los mercenarios pero jamás se atrevió a preguntar. Una excepcional obra escrita por el fundador y gran maestro del clan.",ep:1,g:19,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7388] = {n:"Pócima de olvido de Maestría: Hachas",t:45,d:"Esta pócima te permitirá olvidar un poco tu dominio de las Hachas.",ep:3,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7389] = {n:"Pócima de olvido: \"Furia\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo de Sacrógrito: \"Furia\".",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7390] = {n:"Pócima de olvido: \"Espada Voladora\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo de Sacrógrito: \"Espada Voladora\".",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7391] = {n:"Pócima de olvido: \"Coagulación\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo de Sacrógrito: \"Coagulación\".",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7392] = {n:"Pócima de olvido: \"Locura Sanguinaria\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo de Sacrógrito: \"Locura Sanguinaria\".",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7393] = {n:"Tejido de fantasma Pandora",t:55,d:"Este tejido todavía contiene el sudor de Pandora, lo que aumenta su valor de una manera inestimable.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7394] = {n:"Pócima de olvido: \"Feliación\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo especial \"Feliación\".",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7395] = {n:"Pócima de olvido: \"Captura de Almas\"",t:43,d:"Esta pócima permite olvidar un nivel del hechizo especial \"Captura de Almas\".",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7396] = {n:"Prosperidad",t:29,d:"Esta bendición permite ganar resistencia al Agua para los siguientes combates.",ep:18,g:10,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7397] = {n:"Perspicacia",t:29,d:"Esta bendición permite ganar resistencia al Fuego para los siguientes combates.",ep:18,g:9,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7398] = {n:"Elasticidad",t:29,d:"Esta bendición permite ganar resistencia al Aire para los siguientes combates.",ep:18,g:8,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7399] = {n:"Dureza",t:29,d:"Esta bendición permite ganar resistencia a la Tierra para los siguientes combates.",ep:18,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7400] = {n:"Pergamino ligado",t:87,d:"Este pergamino te permite localizar a tu blanco para cazarlo mejor.",ep:1,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:1};
I.u[7401] = {n:"Pergamino virgen",t:87,d:"Este pergamino permite \"marcar\" un blanco para poder cazarlo mejor después.",ep:16,g:1,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,ut:true,p:100};
I.u[7402] = {n:"Lote de diez pergaminos vírgenes",t:87,d:"Este lote permite \'marcar\' <b>un sólo blanco</b> para poder después cazarlo varias veces.",ep:16,g:3,l:10,wd:false,fm:true,w:10,c:"Ps!0&PP>0",u:true,ut:true,p:500};
I.u[7403] = {n:"Hueso de fantasma Leopardo",t:47,d:"Antaño, los Salteadorillos usaban este huesecillo para decorar sus narices. Era un modo elegante de ensalzar una nariz ganchuda.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7404] = {n:"Hueso de fantasma Maho Firefux",t:47,d:"Este hueso todavía contiene una magia digamos... ¡Artesanal! Así que no te extrañe si un día cobra vida e intenta encontrar los otros restos de su dueño.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7405] = {n:"Hueso de fantasma Pandikaze",t:47,d:"Este hueso es todo lo que queda del fantasma que acabas de exterminar. No tienes suerte, parece que no hay magia alguna que lo habite.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7406] = {n:"Hueso de fantasma Pandora",t:47,d:"Aunque te pueda parecer que sí, este hueso no sale de la caja de Pandora. ¡Ni siquiera de la caja torácica de Pandora!",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7407] = {n:"Hueso de fantasma Pandulo",t:47,d:"Este hueso, correctamente tallado, puede servir de manecilla de un reloj gigante. Vamos, totalmente imprescindible.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7408] = {n:"Hueso de fantasma Soryo Firefux",t:47,d:"La primera vez que Soryo Firefux se rompió un hueso, se intentó vengar en el primero que cruzara su camino. Al mismo tiempo, el trovador Badiz Mustabante se paseaba cantando por el bosque y se cruzó con Soryo Firefux. Nadie conoce el final de la historia, pero todo el mundo pudo comprobar que, a partir de aquel día, la voz del trovador fue mucho más aguda.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7410] = {n:"Hueso de fantasma Tanukui San",t:47,d:"A fuerza de soportar el peso inconmensurable de sus enormes testículos, los huesos del Tanukui San acabaron por volverse increíblemente resistentes.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7411] = {n:"Hueso de fantasma Yokai Firefux",t:47,d:"Este hueso habría podido servir  para abrir el cráneo a los aventureros insolentes, o incluso como martillo para plantar Anutrofs en el suelo como si fueran espárragos. Pero, desde que está entre tus manos, parece que su destino sea diferente...",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7412] = {n:"Lote de cien pergaminos vírgenes",t:87,d:"Este lote permite \'marcar\' <b>un sólo blanco</b> para poder después cazarlo varias veces.",ep:16,g:3,l:10,wd:false,fm:true,w:100,c:"Ps!0&PP>0",u:true,ut:true,p:3500};
I.u[7413] = {n:"Pergamino \"Señalar con el dedo\"",t:25,d:"(Doble clic para aprender este emote) \nEste pergamino te permite aprender la actitud \"Señalar con el dedo\", para indicar una dirección o para denunciar abiertamente a los tramposos.",ep:18,g:9,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7414] = {n:"Pequeño Miaumiau Blanco",t:18,d:"Esta pequeña bola de pelos araña, muerde y pellizca incluso la mano del que le da de comer. Por eso es una terrible criatura, pero no deja de ser irresistiblemente entrañable y fascinante. Cualquier semblante con personas del género femenino no sería puro azar. Ojo, esta criatura además de tener un carácter irascible es muy complicada a nivel alimentario, puesto que sólo come carne de criaturas que se han cazado.",ep:3,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7415] = {n:"Pequeño Wauwau Negro",t:18,d:"Esta extraña pequeña criatura sólo se alimenta con pescados recién pescados. Pero no te preocupes, su compañía agradable compensa ampliamente su aliento de pescado deshidratado.",ep:3,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7417] = {n:"Certificado de admisión en la petrera: peki peki",t:77,d:"Este certificado describe las características del peki peki que has dejado en la petrera.",ep:3,g:26,l:1,wd:false,fm:true,w:1,p:100};
I.u[7418] = {n:"Certificado de admisión en la petrera: pequeño miaumiau blanco",t:77,d:"Este certificado describe las características del pequeño miaumiau que has dejado en la petrera.",ep:3,g:27,l:1,wd:false,fm:true,w:1,p:100};
I.u[7419] = {n:"Certificado de admisión en la petrera: pequeño wauwau negro",t:77,d:"Este certificado describe las características del pequeño wauwau que has dejado en la petrera.",ep:3,g:28,l:1,wd:false,fm:true,w:1,p:100};
I.u[7420] = {n:"Certificado de admisión en la petrera: nomoon",t:77,d:"Este certificado describe las características del nomoon que has dejado en la petrera.",ep:3,g:35,l:1,wd:false,fm:true,w:1,p:100};
I.u[7421] = {n:"Pócima de olvido de oficio: Forjador de Escudos",t:44,d:"Esta pócima te hará olvidar el oficio de Forjador de Escudos.",ep:18,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7422] = {n:"Mascarapiña",t:16,d:"Esta máscara en forma de fruta exótica es una verdadera pieza de colección. No sirve para nada, excepto para volverte original y apetitoso. Algo es algo.",ep:1,g:117,l:1,wd:true,fm:true,w:1,s:74,p:10};
I.u[7423] = {n:"Huevo de larva dorado",t:12,d:"Aunque pueda parecer extraño, las Larvas Doradas no son las que ponen estos huevos. Las que los ponen son larvas de lo más común, de color verde, naranja o azul. La naturaleza no dejará nunca de sorprendernos.",ep:1,g:715,l:10,wd:true,fm:true,w:1,u:true,p:1};
I.u[7425] = {n:"Pequeña larva dorada",t:32,d:"Esta larva acaba de nacer de un huevo. Su primera mirada que se posó sobre ti, te considera como su propia madre.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
