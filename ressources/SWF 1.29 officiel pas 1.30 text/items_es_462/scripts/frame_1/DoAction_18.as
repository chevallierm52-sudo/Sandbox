I.u[7552] = {n:"Capapavo",t:17,d:"A veces, cuando un guerrero y un dragopavo contraen matrimonio, pueden producirse cosas muy extrañas. Esta capa es la prueba viviente ya se trata de una capa a la que se cosieron unas alas de dragopavo. El dragopavo que se sacrificó para poder hacerla se la regaló al célebre trovador Lonne Jenon el día de su unión. Incluso Badiz Mustabante le dedicó una canción.",ep:2,g:90,l:50,wd:true,fm:true,w:5,s:42,p:25000};
I.u[7553] = {n:"Sombropavo",t:16,d:"Tú que has soñado siempre con poder parecerte a un Dragopavo, este es el momento de realizarte. No obstante, si quieres conservar una buena salud, te aconsejamos que evites pasearte por las calles de Amakna durante las Navidades.",ep:2,g:118,l:50,wd:true,fm:true,w:10,s:42,p:15000};
I.u[7554] = {n:"Botopavos",t:11,d:"Tus amigos te envidiarán un montón, porque con estas botas podrás ser el amo del gallinero.",ep:2,g:65,l:50,wd:true,fm:true,w:3,s:42,p:5000};
I.u[7555] = {n:"Anillopavo",t:9,d:"Con este anillo, tus amigas dirán refiriéndose a ti: \"Vaya auténtica pava\".",ep:2,g:97,l:50,wd:true,fm:true,w:1,s:42,p:1000};
I.u[7556] = {n:"Regalo: Pavuesco",t:89,d:"Este Regalo: contiene una parte de un famoso disfraz. Tus amigas dragopavas se volverán locas de envidia.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7557] = {n:"Llave de la Mazmorra Abráknida",t:84,d:"Esta llave hecha con corteza de Abráknido podría dar raíces si la dejas en un lugar caliente y húmedo, como un calzoncillo de Bwork, por ejemplo.",ep:1,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[7558] = {n:"Pelos dekul de Bworky",t:24,d:"Estos pelos no permanecerán mucho tiempo en tu mochila... En cualquier caso, es todo lo que se puede desearte.",ep:14,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[7559] = {n:"Goldotura",t:10,d:"Dicen que cuando su primer propietario se ponía este cinturón, daba vueltas sobre sí mismo. Esto confirma que hay que estar un poco majara para ponerse una cosa parecida.",ep:22,g:85,l:164,wd:true,fm:true,w:0,p:48200};
I.u[7560] = {n:"Runa Re Per Agua",t:78,d:"Esta runa permite absorber los daños elementales de tipo Agua.",ep:1,g:31,l:10,wd:true,fm:true,w:1,p:10};
