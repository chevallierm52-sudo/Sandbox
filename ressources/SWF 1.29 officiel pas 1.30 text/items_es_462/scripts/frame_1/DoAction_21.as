I.u[8966] = {n:"Pata de Zurcarák Perfecta",t:6,d:"Esta espada constituye la encarnación de la suerte del dios Zurcarák. Tienes entre tus manos la versión más depurada de la Pata de Zurcarák. Qué suerte has tenido, seguro que lo pagarás siendo soltero toda tu vida.",ep:1,g:81,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
