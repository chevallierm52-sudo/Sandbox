I.u[9126] = {n:"Blopanillo Guinda Real",t:9,d:"Antaño, Kroula intentó ponerse este anillo en el dedo gordo del pié. Pensaba que así, sus enemigos se dignarían lamerle los piés con la esperanza de recuperar un poco de jugo de Blop Real.",ep:5,g:153,l:80,wd:true,fm:true,w:10,s:102,p:15000};
