I.u[8912] = {n:"Regalo: Genialísimo Sombrero de Turtoga",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8913] = {n:"Pócima Búlbica",t:12,d:"Esta pócima está compuesta de extractos de bulbos macerados en puré de Kloug. Los alquimistas más audaces utilizan harina de arroz en lugar de puré de Kloug dada su rareza hoy en día. Aunque te cueste creerlo, te acostumbrarás a su sabor.",ep:22,g:23,l:110,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[8914] = {n:"Ficha descriptiva de un manitas",t:24,d:"Esta ficha contiene todos los datos necesarios para encontrar al manitas que está descrito en ella.",ep:0,g:176,l:1,wd:false,fm:true,w:0,c:"PJ>65,50",p:1};
I.u[8915] = {n:"Ficha de manitas en blanco",t:80,d:"Esta ficha está hecha para rellenar en ella todos los datos necesarios para encontrar a un manitas.",ep:0,g:6,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[8916] = {n:"Ámbar del Tynril",t:50,d:"Este ámbar no es un ámbar cualquiera. Si lo agitas verticalmente con los ojos cerrados mientras bailas un tango rápido de Capitán Chafer, podrás sentirlo brillar y vibrar, como si una misteriosa alma lo habitase. También puede que parezcas un loco, pero un loco danzarín brillante y vibrante.",ep:22,g:1,l:100,wd:true,fm:true,w:10,p:1};
I.u[8917] = {n:"Llave de la Gruta Grut\'Hesqua",t:84,d:"Esta extraña llave te permitirá entrar de una pieza en la Gruta Grut\'Hesqua",ep:22,g:244,l:1,wd:true,fm:true,w:1,p:1};
I.u[8918] = {n:"Casco mejorado",t:16,d:"Este casco mejorado permite, en teoría, cabalgar los escarahojas más rápidos sin perder el peluquín. Sencillamente inestimable.",ep:22,g:25,l:1,wd:true,fm:true,w:10,p:1};
I.u[8919] = {n:"Alas de madera mejoradas",t:17,d:"Estas alas de madera mejoradas son más ligeras gracias al tejido que las recubre y a un relleno de plumas de pío. Aunque el esqueleto sigue siendo de madera, así que ten cuidado de no quedar aplastado bajo ellas.",ep:22,g:22,l:30,wd:true,fm:true,w:10,p:2633};
I.u[8922] = {n:"Bolsa de kamas",t:24,d:"Esta bolsa contiene una importante cantidad de kamas. Seguro que puede servir para un soborno.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8923] = {n:"Saco de patatas",t:24,d:"Un saco de patatas... Realmente uno tiene que aburrirse mucho para pasearse con este trasto.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8924] = {n:"Arco de Lafrontera",t:2,d:"Esta es la historia del joven Lafrontera, se entrenó tanto en el uso del arco que llegó a defender su pueblo él sólo. Desde entonces se dice \"ten cuidado al cruzar Lafrontera\".",ep:22,g:59,l:151,wd:true,fm:true,w:10,an:10,e:[10,3,2,7,30,50,false,true],c:"CA>200",p:46105};
I.u[8925] = {n:"Arco Léptico",t:2,d:"Este extraño arco fue esculpido por un Sádida durante una fase de sonambulismo creativo. De alla se desprende un sueño repentino que afecta tanto al arquero como al objetivo.",ep:22,g:60,l:185,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,3,8,30,50,false,true],c:"CA>300&CI>300",p:51125};
I.u[8926] = {n:"Daga Duh",t:5,d:"Estas dagas son ideales para cortar piñas o moler café. Hay quien las utiliza para trozear las manzanas y peras de la macedonia.",ep:22,g:65,l:175,wd:true,fm:true,w:10,an:13,tw:true,e:[7,3,1,1,30,30,false,false],c:"CA>250&CC>250&CS>150",p:49775};
I.u[8927] = {n:"Dagas de Unakabra",t:5,d:"Kabra era un Sram completamente chalado, él robaba a los pobres para dárselo a los ricos. Desde entoces se estila en los pueblos la expresión \"Estar loco como Unakabra\".",ep:22,g:66,l:171,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>350&CA>200",p:49280};
I.u[8928] = {n:"Dagas Roink",t:5,d:"Roink es mejor bebedor que guerrero, y no mejora con la edad. Aún así más te vale no parecerte a un tapón de botella cuando saque sus dagas.",ep:22,g:67,l:158,wd:true,fm:true,w:10,an:13,e:[15,2,1,1,30,50,false,false],c:"CA>300",p:47275};
I.u[8929] = {n:"Kriss Tobal",t:5,d:"No te confundas con el famoso bastón de nombre similar, estas dagas pueden provocar carnicerías mucho más violentas.",ep:22,g:68,l:149,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CI>250&CC>250",p:45875};
I.u[8930] = {n:"Fucsia",t:6,d:"Más de un guerrero muy macho se negó a usar esta espada por su color, la mayoría de ellos murió bajo su filo.",ep:22,g:78,l:163,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,30,50,false,false],c:"CA>300&CI>300",p:48245};
I.u[8931] = {n:"Az\'teqka",t:6,d:"Esta espada perteneció un viejo Anutrof megalómano. Está hecha en oro macizo, como el ego de su antiguo dueño.",ep:22,g:79,l:186,wd:true,fm:true,w:10,an:14,tw:true,e:[7,5,1,1,45,50,false,false],c:"CA>200&CC>200&CS>200",p:51275};
I.u[8932] = {n:"Kukri Kura",t:6,d:"¡Sonríe al pajarito...! Ya está, ya te han cortado en dos.",ep:22,g:80,l:179,wd:true,fm:true,w:10,an:14,e:[7,4,1,1,40,50,false,false],c:"CS>300&CA>150",p:50330};
I.u[8933] = {n:"Hacha Sudor Rancio",t:19,d:"Urak\'han era un viejo Pandawa de piel tan suave que lo apodaron \"Dulce Cutis\". Aunque también tenía otro apodo que se ganó gracias a su olor corporal, que acabó pasando a su hacha.",ep:22,g:49,l:162,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,50,50,false,false],c:"CW>250&CS>300",p:47900};
I.u[8934] = {n:"Hacha Parrada",t:19,d:"Con el enfado que se cogió cuando una ardilla pilla le robó un grano de arroz de su plato durante sus vacaciones en la Isla de Pandala, Brus Bulguro usó esta hacha para cortar cada bambú en el que se refugiase el ladrón. Los pandawas del lugar tuvieron que utilizar más de la mitad de la reserva de alcohol de bambú del pueblo para poder calmarlo... ¡Este Brus..!",ep:22,g:50,l:158,wd:true,fm:true,w:10,an:17,e:[7,5,1,1,50,50,false,false],c:"CC>150&CA>150&CI>150",p:47542};
I.u[8935] = {n:"La Pala de Mel",t:8,d:"Incluso cuando sólo era un joven Yopuka, Mel ya soñaba con capturar dragones. Jugaba a combatir las piedras del jardín de su madre con una pala a guisa de espada. Los cantos aprendieron a temer a este utensilio.",ep:22,g:48,l:176,wd:true,fm:true,w:10,an:16,e:[7,4,1,1,35,50,false,false],c:"CC>250&CI>250",p:49985};
I.u[8936] = {n:"Pala Shattkitou",t:8,d:"Esta pala salvaje no está domesticada. Intentará morder a su dueño cada vez que este la use. Además hará ruidos raros cuando este contenta y sólo se calmará si le das unas piedrecillas.",ep:22,g:49,l:137,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>150&CA>200",p:43945};
I.u[8937] = {n:"Pala Garbosa",t:8,d:"Un Anutrof se hizo pirata después de comprobar que se recojen más tesoros de un cadaver fresco que de una tumba mohosa. Su pala, roja como la sangre, era el símbolo con el que hacía temblar a la tripulación de los navíos de todos los mares.",ep:22,g:50,l:156,wd:true,fm:true,w:10,an:16,e:[7,5,1,1,20,50,false,false],c:"CS>250&CI>250",p:49455};
