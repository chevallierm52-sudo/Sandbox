I.u[8985] = {n:"EPEO para Dragún y Pekefux",t:116,d:"Utilizando este potente comprimido aumentarás las capacidades de tu Dragún o de tu Pekefux de forma definitiva. Ojo, tu mascota solamente puede asimilar una dósis... si le das más, puede que eso provoque resultados muy decepcionantes.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"PO=7519|PO=8155",u:true,p:1};
I.u[8986] = {n:"EPEO para Boluto y Fotasma",t:116,d:"Utilizando este potente comprimido aumentarás las capacidades de tu Boluto o de tu Fotasma de forma definitiva. Ojo, tu mascota solamente puede asimilar una dósis... si le das más, puede que eso provoque resultados muy decepcionantes.",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"PO=8151|PO=7518",u:true,p:1};
I.u[8987] = {n:"EPEO para El Escarador y Crum",t:116,d:"Utilizando este potente comprimido aumentarás las capacidades de tu Escarador o de tu Crum de forma definitiva. Ojo, tu mascota solamente puede asimilar una dósis... si le das más, puede que eso provoque resultados muy decepcionantes.",ep:1,g:10,l:1,wd:true,fm:true,w:1,c:"PO=8154|PO=7520",u:true,p:1};
I.u[8988] = {n:"EPEO para Abra Kadabra y Minimino",t:116,d:"Utilizando este potente comprimido aumentarás las capacidades de tu Abra Kadabra o de tu Minimino de forma definitiva. Ojo, tu mascota solamente puede asimilar una dósis... si le das más, puede que eso provoque resultados muy decepcionantes.",ep:1,g:11,l:1,wd:true,fm:true,w:1,c:"PO=8153|PO=7522",u:true,p:1};
I.u[8989] = {n:"Casco de Tufo Aéreo",t:16,d:"Con este casco en la cabeza puedes elevarte por los aires, sólo necesitarás girar sobre ti mismo a la velocidad del rayo. Para aterrizar, más te vale haber consultado antes, al menos, el libro de instrucciones.",ep:22,g:209,l:154,wd:true,fm:true,w:10,p:44350};
I.u[8990] = {n:"Prisma de conquista",t:112,d:"Este objeto mágico de piedra brilla cuando se coloca en una zona determinada. Permite marcar tu territorio sin tener que malgastar tu orina. Utilícese sin moderación si tienes un alma de conquistador. Atención, solamente puedes colocar un prisma de conquista si muestras claramente tu grado (modo jugador contra jugador) y si te encuentras en una zona que no contiene ningún prisma. La zona en la que quieres colocar un prisma también tiene que estar pegada a una zona aliada desde por lo menos cinco minutos.",ep:4,g:1,l:1,wd:true,fm:true,w:10,c:"PL>9&PP>2",u:true,p:1};
I.u[8991] = {n:"Anilamar",t:9,d:"Este anillo te chupará el dedo sin parar, además es pegajoso, húmedo y frio. Si puedes soportar todo esto, podrás disfrutar de su inmenso poder.",ep:22,g:145,l:189,wd:true,fm:true,w:10,s:97,p:55000};
I.u[8992] = {n:"Hoz Maldita del Gran Desangrador Guerrero",t:22,d:"Esta hoja siega a los enemigos como trigo, pero también aumenta la envidia de tus aliados. Ése es el destino de los poderosos.",ep:22,g:3,l:200,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,100,50,false,false],p:58000};
I.u[8993] = {n:"Espada Maldita del Gran Desangrador Guerrero",t:6,d:"De esta espada legendaria se desprende un inmenso poder, las masacres que predice son de las que aparecen en los libros de historia. Su manejo es, a pesar de todo, bastante aleatorio... quizás exista alguien capaz de corregir esto.",ep:20,g:83,l:200,wd:true,fm:true,w:10,an:14,tw:true,e:[10,5,1,1,100,2,false,false],p:58000};
I.u[8994] = {n:"Tejido coralino",t:55,d:"Este tejido húmedo se quedó largo tiempo en el mar hasta que el coral empezó a recubrirlo. Una pena que se volviese tan tieso, porque sería un magnífico pañuelo.",ep:22,g:728,l:150,wd:true,fm:true,w:1,p:100};
I.u[8995] = {n:"Tejido de Gurlo el Terrible",t:55,d:"Antaño usado para curar las heridas de Gurlo el Terrible, este tejido todavía está impregnado de un líquido de extraño olor. Aunque lo más extraño es que parece abrirte el apetito.",ep:22,g:729,l:150,wd:true,fm:true,w:1,p:100};
I.u[8996] = {n:"Piel del Rasgabola Mayor",t:59,d:"Esta piel es mas suave incluso que la que se puede encontrar en las nalgas de la hembra del Kilibris.",ep:22,g:48,l:250,wd:true,fm:true,w:1,p:100};
I.u[8997] = {n:"Piel lacerada del Tynril",t:59,d:"Esta piel seguramente recubría una parte sensible del Tynril, ¡Pobrecito!",ep:22,g:629,l:400,wd:true,fm:true,w:1,p:100};
I.u[8998] = {n:"Piedra preciosa del Kimbo",t:50,d:"Durante años, el Kimbo chupó esta piedra preciosa para desgastarla y poder metérsela más facilmente en la nariz.\nA veces la naturaleza es dificil de entender.",ep:22,g:109,l:900,wd:true,fm:true,w:1,p:100};
I.u[9000] = {n:"Escudo Pandala",t:82,d:"...",ep:0,g:10,l:1,wd:false,fm:true,w:10,c:"PP>5",p:1};
I.u[9001] = {n:"Escudo de Sidimote",t:82,d:"Este escudo debería refrescar la memoria de tus adversarios y recordarles que te criaste en las Landas de Sidimote. Puede que baste para asustarles.",ep:18,g:8,l:1,wd:true,fm:true,w:10,c:"PP>4",p:15650};
I.u[9002] = {n:"Ftalmo",t:82,d:"Varios ojos adornan este escudo para que su dueño pueda echarle uno a su rival sin tener que alzar la mirada.",ep:18,g:5,l:1,wd:true,fm:true,w:10,c:"PP>4",p:33000};
I.u[9003] = {n:"Escudo Taberna",t:82,d:"Seguro que el tabernero de la cervecería Feubuk de Bonta se aburría como una ostra cuando tuvo la idea de equipar a los gorilas de su local con estos escudos publicitarios...",ep:18,g:6,l:1,wd:true,fm:true,w:10,c:"PP>3",p:16200};
I.u[9004] = {n:"Escudo Akwadala",t:82,d:"Este escudo, proveniente del pueblo de Akwadala, te será muy útil para poder parar golpes de todo tipo.",ep:14,g:31,l:1,wd:true,fm:true,w:2,c:"PP>2",s:34,p:5350};
I.u[9005] = {n:"Escudo Ventiloso",t:82,d:"Cuando tus aliados empiecen a sentir flatos o incluso cuando quieras disipar los efectos de un Viento de Pánico, este escudo podrá salvarte la vida. Sólo basta con agitarlo con vigor en todos los sentidos, un poco como si quisieras calmar a un recién nacido demasiado ruidoso.",ep:18,g:11,l:1,wd:true,fm:true,w:10,c:"PP>8",p:54450};
I.u[9006] = {n:"Escudo del sadida",t:82,d:"Este escudo hacía las veces en un principio de taburete para los sadidas que lo utilizaban cuando tenían que tomarse un descanso. Una vez que hayas flexionado las piernas, te protegerá contra muchos ataques pero no estarás a salvo de las carcajadas de tus rivales.",ep:18,g:12,l:1,wd:true,fm:true,w:10,c:"PP>6",p:18700};
I.u[9007] = {n:"Escudo Slip",t:82,d:"Esta sorprendente creación está recubierta con un Slip de Cuero del Chafer lancero, hervido, limpiado y aflojado para moldearse a las formas del escudo, las cuales no se parecen en nada a las del Chafer que son mucho más ventajosas y atractivas...",ep:18,g:13,l:1,wd:true,fm:true,w:10,c:"PP>5",p:26700};
I.u[9008] = {n:"Escudo Rano",t:82,d:"Este espléndido escudo alberga una muestra de agua del Mar Rano, lo cual además de tener dotes de talismán, podrá servirte como botijo durante tus misiones, si soportas el olor que desprende.",ep:18,g:16,l:1,wd:true,fm:true,w:10,c:"PP>7",p:32450};
I.u[9009] = {n:"Escudo Abráknido",t:82,d:"Si te escondes detrás de este escudo, los aventureros más cándidos pensarán que eres un Abráknido y se marcharán corriendo a toda pastilla. Los demás te agredirán con motivo de recuperar un poco de ámbar.",ep:18,g:19,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5950};
I.u[9010] = {n:"Escudo Pandawa",t:82,d:"Idóneo para andar con discreción por Pandala y para llamar la atención en los demás sitios. La mayor ventaja de dicho escudo radica en sus pelos de Pandawas, famosos por ser totalmente hipoalergénicos. Podrás entonces guardar este escudo en tu calzoncillo de cuero sin temer posibles reacciones cutáneas.",ep:18,g:22,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5600};
I.u[9011] = {n:"Esfera de Fuego",t:82,d:"Este original escudo te protegerá del elemento Fuego y además, dará la hora a tus rivales. Muy útil para que puedan cronometrar su derrota.",ep:18,g:24,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9012] = {n:"Esfera de Aire",t:82,d:"Este original escudo te protegerá del elemento Aire y además, dará la hora a tus rivales. Muy útil para que puedan cronometrar su derrota.",ep:18,g:26,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9013] = {n:"Esfera de Tierra",t:82,d:"Este original escudo te protegerá del elemento Tierra y además, dará la hora a tus rivales. Muy útil para que puedan cronometrar su derrota.",ep:18,g:27,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9014] = {n:"Esfera de Agua",t:82,d:"Este original escudo te protegerá del elemento Agua y además, dará la hora a tus rivales. Muy útil para que puedan cronometrar su derrota.",ep:18,g:25,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9015] = {n:"Escudo del Leñador",t:82,d:"Los leñadores lo utilizaron en un principio para protegerse de los árboles que se derrumbaban tras ser talados. Rápidamente se utilizó para otros fines y ahora sirve para que puedas protegerte de los aventureros que tienen como costumbre caerte encima sin aviso previo.",ep:18,g:4,l:1,wd:true,fm:true,w:10,c:"PP>1",p:1200};
I.u[9016] = {n:"Escudo del Monte Puaj",t:82,d:"Pese a ser verdoso y apestoso, este escudo no deja de ser una protección idónea a la hora de enfrentarte a las criaturas del Monte Puaj.",ep:18,g:1,l:1,wd:true,fm:true,w:20,c:"PP>2",p:5400};
I.u[9017] = {n:"Escudo de los Salteadorillos",t:82,d:"Si siempre has soñado con ser un verdadero Salteadorillo, este es el escudo que necesitas. Ha sido transmitido de una generación a otra y te permitirá despojar a los jóvenes aventureros de Astrub sin recibir la más mínima hostia.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"PP>6",p:30700};
I.u[9018] = {n:"El Corazón Partido",t:82,d:"\"Clavitos para este Corazón partido...\" Dice una vieja canción de gesta, que quien encuentre cuatro de estos escudos ya no tendrá frío por las noches y que incluso el invierno se volverá primavera y que ni siquiera las malditas hechiceras podrán hacer que mueras en su veneno. Ya lo ves, lo que hay que oír...",ep:18,g:7,l:1,wd:true,fm:true,w:10,c:"PP>3",p:13000};
I.u[9019] = {n:"Escudo del Báwbawo",t:82,d:"No todos los Wabbits son criaturillas inofensivas. En realidad, todos los Wabbits son infames criaturas, incluso algunos tienen costumbres muy salvajes y aplastan las Zanahowias con este enorme escudo para hacer zumo.",ep:18,g:2,l:1,wd:true,fm:true,w:15,c:"PP>3",p:10500};
I.u[9020] = {n:"Derma Thólobo",t:82,d:"No conseguirás despegarte de este escudo hecho con piel de lobo de lo bueno que es. Pero no te olvides de curar sus verrugas y sus forúnculos de vez en cuando para que no se desgaste.",ep:18,g:3,l:1,wd:true,fm:true,w:10,c:"PP>2",p:2200};
I.u[9021] = {n:"Escudo del Capitán Amakna",t:82,d:"Un joven aventurero quiso alistarse en la milicia de Bonta para defender a los oprimidos. Como era de complexión más bien débil al final le dieron de baja, a pesar de todo, un alquimista de Amakna contactó con él para utilizarlo como cobaya y poder probar una de sus nuevas pócimas mágicas. El efecto fue inmediato, el joven aventurero se convirtió rápidamente en un auténtico guerrero dotado de una fuerza extraordinaria, pero también de una estupidez sin límites. Pues, se había convertido en Yopuka. Encargó forjar este escudo que tenía fama de ser indestructible y se le dio el mote de Capitán Amakna (en memoria al ilustre Capitán Chafer que desapareció en misteriosas circunstancias).",ep:18,g:14,l:1,wd:true,fm:true,w:30,c:"PP>9",p:63200};
I.u[9022] = {n:"Klum",t:82,d:"Este enorme escudo permitió antaño que el ilustre aventurero Klum sobreviviera tras haber sido aplastado bajo el peso de un Crujidor que se había enamorado de él. La historia no dice si sobrevivió a los efectos secundarios de su apasionada relación con el Crujidor.",ep:18,g:15,l:1,wd:true,fm:true,w:10,c:"PP>4",p:22100};
I.u[9023] = {n:"Escudo Cometa",t:82,d:"Aunque parezca extraño, dicen que este escudo de madera y de pelos, permite que los aventureros más ligeros puedan elevarse en los aires un momentito para impresionar a sus adversarios antes de caer de nuevo y estrellarse como un estúpido en el suelo.",ep:18,g:17,l:1,wd:true,fm:true,w:1,c:"PP>0",p:1200};
I.u[9024] = {n:"Escudo de Le Chuko",t:82,d:"Le Chuko utilizaba este escudo para protegerse de los besugos que a menudo le enviaban. Dicen las historias más extravagantes que algunos besugos tenían forma humana.",ep:18,g:18,l:1,wd:true,fm:true,w:10,c:"PP>6",p:36850};
I.u[9025] = {n:"Escudo del Jalató",t:82,d:"Bastante inútil pero impresionante por el olor que desprende. Este escudo será el compañero de muchos jóvenes aventureros.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PP>0",p:400};
I.u[9026] = {n:"Escudo de Bowis",t:82,d:"Este escudo rinde homenaje a la capa del Bowis, la cual también es a su vez un homenaje a una famosa reliquia hecha con tres fragmentos triangulares. Vamos, otro cuento para no dormir...",ep:18,g:21,l:1,wd:true,fm:true,w:10,c:"PP>3",p:10150};
I.u[9027] = {n:"Escudo del Crujidor",t:82,d:"Este escudo de piedra es en definitiva una cabeza de crujidor que un Minotauroro aplastó con el pie. Es una manera muy efectiva para combinar cabezazos con el olor a pies...",ep:5,g:23,l:1,wd:true,fm:true,w:10,c:"PP>2",p:6300};
I.u[9028] = {n:"Escudo Tierradala",t:82,d:"Este escudo, proveniente del pueblo de Tierradala, te será muy útil para poder parar golpes de todo tipo.",ep:18,g:32,l:1,wd:true,fm:true,w:10,c:"PP>3",s:36,p:14100};
I.u[9029] = {n:"Escudo Fuegodala",t:82,d:"Este escudo, oriundo del pueblo de Fuegodala, será muy valioso a la hora de parar todo tipo de golpes.",ep:18,g:33,l:1,wd:true,fm:true,w:15,c:"PP>5",s:37,p:27100};
I.u[9030] = {n:"Escudo Airedala",t:82,d:"Este escudo oriundo del pueblo de Airedala será de gran valía a la hora de parar todo tipo de golpes.",ep:18,g:30,l:1,wd:true,fm:true,w:10,c:"PP>4",s:35,p:11600};
I.u[9031] = {n:"Anillote del Maestro Jambo",t:9,d:"El Maestro Jambo fue muy poderoso, y tenía todas las mujeres que quería. Pero no tenía ningún mérito ya que sacaba todo su poder de su anillote. Un día atravesó la calle sin mirar y PAF el Jambo. Desde entonces su anillo pasa de manos en manos de la gente poco escrupulosa.",ep:0,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[9035] = {n:"Pócima de cercado de Gremio",t:12,d:"Esta pócima te permite volver a tu cercado de gremio.",ep:5,g:25,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[9036] = {n:"Pócima del pueblo de los Zoths",t:12,d:"Con esta pócima podrás teletransportarte al pueblo de los zoths, si éste último te pertenece.",ep:0,g:24,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9037] = {n:"Pócima de Descubrimiento",t:14,d:"Esta pócima permite desvelar a los personajes invisibles que se encuentren cerca de ti.",ep:0,g:0,l:1,wd:true,fm:true,w:1,p:10};
I.u[9038] = {n:"Pócima de Agresión pequeña",t:14,d:"Esta pócima te permite entrar en un estado de rabia tan grande que atacarás automáticamente a los enemigos que se te acerquen demasiado.",ep:0,g:32,l:1,wd:true,fm:true,w:1,c:"Pg=21",u:true,p:10};
I.u[9039] = {n:"Pócima Recordatoria de Prismas",t:12,d:"Con esta pócima podras teletransportarte al prisma aliado más cercano.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9040] = {n:"Pócima de Agresión mediana",t:14,d:"Esta pócima te permite entrar en un estado de rabia tan grande que atacarás automáticamente a los enemigos que se te acerquen demasiado.",ep:0,g:33,l:1,wd:true,fm:true,w:1,c:"Pg>21,1",u:true,p:10};
I.u[9041] = {n:"Pócima de Agresión grande",t:14,d:"Esta pócima te permite entrar en un estado de rabia tan grande que atacarás automáticamente a los enemigos que se te acerquen demasiado.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Pg>21,2",u:true,p:10};
I.u[9042] = {n:"Poderosa Pócima de Agresión",t:14,d:"Esta pócima te permite entrar en un estado de rabia tan grande que atacarás automáticamente a los enemigos que se te acerquen demasiado.",ep:0,g:36,l:1,wd:false,fm:true,w:1,c:"Pg>21,3",u:true,p:10};
I.u[9043] = {n:"Megapócima de agresión",t:14,d:"Esta pócima te permite entrar en un estado de rabia tan grande que atacarás automáticamente a los enemigos que se te acerquen demasiado.",ep:0,g:35,l:1,wd:false,fm:true,w:1,c:"Pg>21,4",u:true,p:10};
I.u[9044] = {n:"Pócima de disfraz de yopuka",t:14,d:"Con esta pócima podrás tomar la apariencia que quieras, ni siquiera tu madre te reconocerá.",ep:0,g:43,l:1,wd:false,fm:true,w:1,c:"Pg>10,3",u:true,p:10};
