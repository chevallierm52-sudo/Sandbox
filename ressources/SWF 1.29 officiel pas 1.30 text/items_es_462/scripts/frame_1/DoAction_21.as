I.u[8702] = {n:"",t:4,d:"",ep:0,g:74,l:1,wd:false,fm:true,w:1,an:12,tw:true,e:[0,0,1,1,0,0,false,false],p:1};
I.u[8704] = {n:"El Nahits",t:16,d:"Si agitas los dos cascabeles rápida y harmoniosamente, quizás consigas hacer música.",ep:22,g:190,l:160,wd:true,fm:true,w:10,p:47625};
I.u[8706] = {n:"Fantasma Feanor",t:90,d:"Este fantasma no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:48,l:1,wd:true,fm:true,w:1,p:1};
I.u[8707] = {n:"Certificado de admisión en la petrera: Feanor",t:77,d:"Este certificado describe las características de Feanor, al que has dejado en la petrera.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8708] = {n:"Certificado de admisión en la petrera: tortuga",t:77,d:"Este certificado describe las características de la tortuga que has dejado en la petrera.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Transformación fantasma Feanor",t:27,d:"Te has transformado en fantasma para poder entrar en el santuario de las mascotas.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Regalo: Feanor",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Cacho de Goldemort",t:110,d:"¡Enhorabuena! Has conseguido quitarle a Goldemort un cacho de su substancia. Los buitres están orgullosos de ti.",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Chancletas Bernáculo",t:11,d:"Se cuenta que, en algunas comarcas, los Pandawa lanzan este calzado a la cara de un rival para retarlo. Aunque te parezca gracioso, no es más absurdo que golpearlo con un par de guantes. La ventaja de las Chancletas Bernáculo es que añaden una conmoción olfativa al golpe. Los Pandawas no son precisamente famosos por la higiene de sus pies...",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Divin Anillo",t:9,d:"Este anillo ha sido honorado por la diosa Ocra. Todo aquél que lo lleve será considerado como el más rápido de los disparadores y su celeridad a la hora de desenfundar sus flechas será objeto de cantares legendarios.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Anillo del Craps",t:9,d:"La labia de los Zurcarák es legendaria, pueden contarte cualquier historia con tal de que vayas a jugar con ellos. Este anillo se fabricó en memoria de esta afición al juego, pero actualmente se usa más a menudo como recambio para el Craps. Recuerda que necesitarás otro (dado o anillo) para poder jugar.",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Col Anillo",t:9,d:"Las Osamodas se vuelven locas por este anillo, pues dicen que su cola les confiere un andar aún más elegante y felino. Hay que decir que, de tanto tratar con fieras, no es raro que acaben convirtiéndose en auténticas tigresas. Aunque a algunas se les compare más bien con lobas dado su gran apetito.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Pulserriña",t:9,d:"Las malas lenguas pretenden que la Pulserriña es el complemento de moda  más inutil que jamás se haya creado. Vale, las alitas de adorno son muy poco prácticas a la hora de buscar un pañuelo en tu bolsillo, pero como los yopukas no tienen bolsillos y no usan pañuelos pues no hay problema. Además te permiten arañar un pedazo de carne del enemigo cada vez que le asestes un puñetazo... así dicho, parece una joya de sacrógrito.",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Anillo Vedor",t:9,d:"Los Feca suelen usar los mini escudos de este anillo para pillar en ellos sus notas y que haceres. A este anillo también se lo conoce con el nombre de \"escudo anti olvidos\" pues en muchas ocasiones los fecas guardan en él las ideas que les llueven en la cabeza en los momentos más inesperados.",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Anillo Stálgico",t:9,d:"Con este objeto, los Anutrofs pueden en cualquier momento recordar momentos felices. Al retirar la pala que está clavada en él, emite un suave perfume. Obviamente, hay que meter dentro el olor que uno quiere conservar lo cual no siempre resulta fácil.",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Alianza Guero",t:9,d:"Este anillo lo dio Aniripsa a sus fieles como símbolo de una unión espiritual alcanzada al completar un rito de iniciación de clase. Los aniripsas lo usan como brazalete, recubierto de paños, para limpiar las heridas de sus aliados.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Anillo chistoso",t:9,d:"Este anillo está muy de moda entre los pandas chistosos, sobre todo entre los que lo son después de la tercera cerveza. A veces los chistes pueden pasar a ser insultos, pero no suele pasar nada porque, como dice el famoso proverbio Pandawa: \"Vientre chispado, sordo se ha quedado\".",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Avernillo",t:9,d:"Tradicionalmente, este anillo se entregaba como recompensa a los niños Sram al final de un rito iniciático en el que se afirmaban como adoradores del dios Sram. Las otras clases abandonaron este tipo de costumbres pues los jóvenes se agitaban mucho llegando a ser infernales.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Puntu Alianza",t:9,d:"\"¿Eres de los que no soporta llegar tarde a un combate? ¿Tampoco te gusta esperar al turno de los demás? ¿No soportas a los que se marchan a vigilar la pizza del horno y no vuelven para su turno? Entonces, ¡Usa tu Puntu Alianza! Para que todo funcione como un reloj\" Esto es lo que dice el anuncio, pero puedes no creerlo.",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Anillo Peludo",t:9,d:"¿Peludos? ¡¿Los Sadida?! ¡Nooooo! Les sobran tantos pelos que uno de ellos tuvo la genial ocurrencia de poner unos cuantos en este anillo, lo que tuvo como resultado aumentar sus efectos benéficos. Así que ni se te ocurra cortarlos.",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"Hospit Anillo",t:9,d:"Si alguna vez descubres a un jugador que no es un Sacrógrito intentando ponerse el Hospit Anillo, llévatelo corriendo a cuidados intensivos. Esta joya es extremadamente agresiva y, en general, la gente suele perder su sangre fría ante el baño de hemoglobina que provoca una vez puesta.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Zapatos Ginkel-Hy",t:11,d:"Estos zapatos consiguen que su portador baile como un profesional por mucho que llueve o truene, a pesar de los callos y ampolas que esto pueda causar. Se mueven sólos al ritmo de la música, y hacen \"bip-bip\" si sienten cerca un mineral precioso. Por eso a muchos Anutrof se les llama \"Beat-Machine\".",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Botas de Úveta",t:11,d:"Cuando los Fecas se sienten contrariados y no quieren seguir con la conversación, entonces hablan de sus botas de Úveta, y de cómo con ellas pueden subir cerros como quien anda por un camino. Además, el confort de estas botas les hace no poner pies en polvorosa durante los combates.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Botas Delappioh",t:11,d:"Las muchas correas que rodean estas botas altas, pueden servir de cuerda de recambio para tu arco. Las jóvenes Ocra también las usan para atar los manojos de verduras que van a cocinar... Esperemos que no les huelan los pies.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Coral desgastado",t:51,d:"El Coral desgastado se cae del Coralador cuando el tiempo es suficientemente seco. El coral es tan bonito que muchos lo usan para hacerse joyas. Otros lo comen, pero suele ser porque lo confunden con varitas de cangrejo.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Coxis del Coralador",t:47,d:"Situado en un lugar estratégico, este hueso permite al Coralador instalarse dignamente. Ahora que está muerto, puedes usar este hueso para asentar tu autoridad entre sus congéneres.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Coral Magistral",t:51,d:"La única diferencia entre el Coral desgastado y el Coral Magistral reside en el tamaño y en el uso que se le puede dar. Por desgracia una amalgama de corales usados nunca remplazará a un único Coral Magistral.",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Coral Kuraçao",t:51,d:"El increíble color de este coral viene dado por la alimentación poco equilibrada del Crustoral. ¡Otro más al que se le olvida comer sus 5 frutas o verduras al día!",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Coral Malibut",t:51,d:"El increíble color de este coral viene dado por la alimentación poco equilibrada del Crustoral. ¡Otro más al que se le olvida comer sus 5 frutas o verduras al día!",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Coral Passaoh",t:51,d:"El increíble color de este coral viene dado por la alimentación poco equilibrada del Crustoral. ¡Otro más al que se le olvida comer sus 5 frutas o verduras al día!",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Coral Mohito",t:51,d:"El increíble color de este coral viene dado por la alimentación poco equilibrada del Crustoral. ¡Otro más al que se le olvida comer sus 5 frutas o verduras al día!",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Corazón pulío",t:51,d:"Lo único que diferencia un corazón de Crujidor del de un Crujidor pulío es la delicadeza con la que se puede aplastar bajo el peso de los dedos de tus pies cuando menos te lo esperas.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Bola pulida",t:51,d:"¿De qué parte de la anatomía del crujibola puede venir esta bolita? Y lo que aún es más intrigante ¿Por qué se encuentran muy a menudo por pares?",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Coxis Magistral",t:47,d:"El Coralador te regala un hueso de su posterior. El Coralador Magistral te permitirá conseguir otra parte de su anatomía, pero a más o menos de la misma zona del cuerpo.",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Húmero del Sparo",t:47,d:"Aunque se llame Húmero, no hay nada que nos permita asegurar que este hueso viene del brazo del Sparo, ya que todo su esqueleto fue reducido a migas por la espadas que atravesaron el tonel.",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Encía con Raices del Flib",t:47,d:"Yo no habría recogido un objeto de una procedencia tan insalubre como la boca del Flib. Pero bueno, ¡El aventurero eres tú!",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Pico del Kido",t:47,d:"El pico del Kido es tan fragil que los discípulos de Otomai lo usan para fabricar flechas de punta blanda, así pueden practicar causando los mínimos daños.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Pinza de Crustoral",t:47,d:"¡Nunca le des la mano a una pinza de Crustoral! Puedes quedarte sin ella sólo por intentar ser bien educado.",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Pétalo Kuraçao",t:35,d:"El color de este pétalo es testimonio de su dudosa procedencia. El abuso del alcohol de los discípulos de Otomai es visible incluso en sus creaciones.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Pétalo Malibut",t:35,d:"El color de este pétalo es testimonio de su dudosa procedencia. El abuso del alcohol de los discípulos de Otomai es visible incluso en sus creaciones.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8747] = {n:"Pétalo Passaoh",t:35,d:"El color de este pétalo es testimonio de su dudosa procedencia. El abuso del alcohol de los discípulos de Otomai es visible incluso en sus creaciones.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Pétalo Mohito",t:35,d:"El color de este pétalo es testimonio de su dudosa procedencia. El abuso del alcohol de los discípulos de Otomai es visible incluso en sus creaciones.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Bulbo de Kuraçao",t:36,d:"La Palmiflor no nace de una semilla, sino de un bulbo que se se pone en remojo en alcohol. ¿Por qué? Pues imagínatelo.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Bulbo de Malibut",t:36,d:"La Palmiflor no nace de una semilla, sino de un bulbo que se se pone en remojo en alcohol. ¿Por qué? Pues imagínatelo.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Bulbo de Passaoh",t:36,d:"La Palmiflor no nace de una semilla, sino de un bulbo que se se pone en remojo en alcohol. ¿Por qué? Pues imagínatelo.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Bulbo de mohito",t:36,d:"La Palmiflor no nace de una semilla, sino de un bulbo que se se pone en remojo en alcohol. ¿Por qué? Pues imagínatelo.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Crines floridas",t:36,d:"Cruce imposible entre pelos y pétalos de flores, estas crines son doblemente alérgicas. Por favor, si eres sensible a estos elementos mantente alejado de ellas, so pena de perder tu cerebro por la nariz al estornundar.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Casi-barba de Barbrusa",t:54,d:"El olor a arena caliente, cremas solares, y cerveza barata de este minúsculo mechon de pelos te recordará a las vacaciones. Es una pena que también apeste a pólvora.",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Mechón pelirojo del Flib",t:54,d:"Nunca se supo si el color de esta pelambrera era natural o provocado por un fuejo silvestre incontrolado.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Pelusilla del Kilibris",t:54,d:"Debido a su ligereza, la pelusilla del Kilibris es un material muy preciado para la confección de colchones. Por eso, y en la espera de una especie de colchones que se pueda cazar en un safari, los fabricantes de colchones practican activamente la caza del Kilibris.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Camiseta de Barbrusa",t:15,d:"¿Buscas un sistema para ahuyentar a los insectos? ¡Pues ponte la camiseta de Barbrusa! Aunque también tendrás que renunciar a cualquier compañía femenina.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Pedazo del Calzón de Gurlo",t:15,d:"Nunca se ha conseguido encontrar un calzón de Gurlo intacto. Es que de tanto jugar con la pólvora, al final siempre se quema.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Cofre maldito del Flib",t:15,d:"Este cofre a cogido la forma de Flib. ¿O es del revés? Bueno,lo que importa es que se trata de un cofre maldito.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Fular del Sparo",t:15,d:"Indispensable tanto en verano como en invierno, este Fular te dará un look original, aunque quizás un poco pasado de moda. Gracias a su vistoso color, excitarás a todos los jalatós machos. Si eso es lo que quieres...",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Pólvora explosiva de Gurlo",t:48,d:"Como no puede coserse un cañón, Gurlo siempre lleva el suyo debajo del brazo. Pero no puede disparar muy rápido, ya que tiene que esperar a que seque la pólvora.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Fragmento de cerebro pulío",t:50,d:"Este pedazo de cerebro está tan pulío, que te costaría encontrar una sólo neurona dentro. Por eso no es raro que los Crujidores quieran aplanarte, es que te confunden con su encefalograma.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Bigote de Mufafah",t:15,d:"El bigote de Mufafah, más poblado que el de los Peces Gatito, te puede servir para hacer pinceles para Marylork, el pintor.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Ceja del Rasgabola mayor",t:15,d:"Para mostrar que él es el Jefe, el Rasgabola mayor siempre anda frunciendo el ceño. Incluso después de su muerte sus cejas siguen fruncidas.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Bastón del Kilibris",t:15,d:"Con este bastón podrás llegar a todos los lugares que antes te parecían inaccesibles... y rascarte libremente (o qué estabas pensando).",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Pluma del trasero del Kido",t:53,d:"Este recurso sirvió para crear uno de los enigmas más grandes de Otomai: ¿Qué pesa más, cien pods de plumas de Kido o cien pods de Piruta?",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Ala del tufo de las llanuras",t:104,d:"El tufo de las llanuras no se ha hecho famoso por sus proezas aéreas, pero viendo sus alas tampoco resulta tan raro.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Oreja rasgada de Pumbaa",t:106,d:"Su juntas esta oreja a la tuya no oirás el ruido del mar, pero quizás aún resuene el delicado galopar del jabalí de las llanuras.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Coco del tufo de las llanuras",t:111,d:"En este coco de Tufo no hay leche, sino un curioso zumo de cerebro que, a veces, incluso tiene una neurona o dos flotando en la superficie.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Corteza de Tynril",t:96,d:"Esta corteza tiene una peculiar forma curvada, como si se hubiese conseguido con un rallador.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Corteza de Floribundo",t:96,d:"Esta corteza está curvada como si se hubiese obtenido con un rallador.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Corteza de Esquejika",t:96,d:"Esta corteza tiene un peculiar forma curvada, como si se hubiese conseguido con un rallador.",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Corteza de Nierba",t:96,d:"Esta corteza tiene una peculiar forma curvada, como si se hubiese conseguido con un rallador.",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Corteza de Diente Pe-león",t:96,d:"Esta corteza tiene un peculiar forma curvada, como si se hubiese conseguido con un rallador.",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Corteza de Marguerrita",t:96,d:"Esta corteza tiene un peculiar forma curvada, como si se hubiese conseguido con un rallador.",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Coco del Tufo oscuro",t:111,d:"En este coco de Tufo no hay leche, sino un curioso zumo de cerebro que, a veces, incluso tiene una neurona o dos flotando en la superficie.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Pistilo del Tynril",t:36,d:"Las flores corresponden a los órganos sexuales de las plantas. Los pistilos forman parte de las flores, así que deduce lo que quieras.",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Estambre de Floribundo",t:36,d:"El estambre es el órgano masculino de la reproducción sexual en el reino vegetal. Eso es, el Floribundio es un macho aunque te parezca lo contrario.",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Carpelo de Esquejika",t:36,d:"Las flores corresponden a los órganos sexuales de las plantas. Los pistilos forman parte de las flores y el carpelo es una parte de un pistilo. Entiéndelo como quieras.",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Sépalo de Nierba",t:36,d:"Esta parte del cuerpo de Nierba siempre está verde. ¿Será debido a un exceso de clorofila o más bien a otra cosa?",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Caliz del Diente Pe-león",t:36,d:"No creas que podrás beber algo en este caliz, a pesar de que tenga forma de copa, pues también tiene el fondo lleno de agujeros.",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Bractea de la Marguerrita",t:36,d:"La Bractea de la Marguerrita corresponde a una zona que la moral me impide nombrar aquí.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Amígdalas del Tufo Oscuro",t:15,d:"Cuando le quitan las amígdalas, el Tufo Oscuro se vuelve mucho mas docil y tranquilo. Normal, ya que la operación suele llevarlo a la muerte.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Talón de aquiles del Abrajidor oscuro",t:15,d:"Para derrotar a un Abrajidor oscuro no basta con dispararle una flecha al talón, pero no pierdes nada por intentar.",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Grano del Abrajidor oscuro",t:58,d:"Con mucha paciencia, mucho tiempo y algo de agua y de abono, quizás consigas tener un Abrajidor en tu jardín con el que combatir para entrenarte. Aunque siempre será más facil diezmarlos en la Isla de Otomai.",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Trenza del Pohoyo",t:15,d:"Este matojo de pelos, áspero y espeso, puede servir de paño de cocina si no tienes una calvicie que ocultar. Pero antes tendrás que lavarla muchas veces.",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Cloaca del Pohoyo",t:15,d:"No, no es asqueroso, ¡Sólo es la naturaleza!",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Trasero del tufo aéreo",t:15,d:"Con este trasero podrás crear objetos que te eviten llevar el culo al aire.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Calcetín del Kimbo",t:15,d:"Sí, el Kimbo lleva calcetines, pero no se los pone en los pies. Prefiere hacerlos una bola y ponerlos en un lugar estratégico.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Relleno de Mopet",t:15,d:"Como la naturaleza no ha sido muy generosa con la Mopet, ésta usa relleno para compensar. También lo usa, en determinadas ocasiones, para mejorar la estabilidad de su cama.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Tejido de Mopet",t:55,d:"La textura de este tejido puede parecerte rara, pero puede vestir a cualquier monstruo en menos que canta un gallo.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Coco del Tufo aéreo",t:111,d:"En este coco de Tufo no hay leche, sino un curioso zumo de cerebro que, a veces, incluso tiene una neurona o dos flotando en la superficie.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Cáscara del kasrakol",t:111,d:"Redonda y reluciente, esta cáscara ha sido lustrada con baba durante varios siglos. A cada cual su rollo.",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Peluca del Kimbo",t:54,d:"Para esconder su creciente alopecia, el Kimbo se pone esta ridícula peluca. Por suerte, la nuez de coco la tapa casi por completo.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Nudo del Abrajidor claro",t:38,d:"Si algún leñador te dice que va a \"anudar amistad con algún Abrajidor\" ya sabes que recurso pretende recolectar. Ahora también sabes por qué el Abrajidor es un solitario.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Tocón del Abrajidor claro",t:38,d:"Un tocón distinto de cualquier otro tocón ¡Y además puede girar como una peonza!",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Cola emplumada del Rasgabola Mayor",t:65,d:"Las plumas del Rasgabola se pegan una a una, año tras año, en su apéndice colacal. Cuantas más plumas, más viejo es el rasgabola.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Pelo del sobaco de Pumbaa",t:54,d:"A pesar de afeitárselos cotidianamente, a Pumbaa le vuelven a salir unos pelos fuertes, espesos y con un constante edor rancio. ¡Y no es por culpa del sudor!",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Tejido Zoth",t:55,d:"Hecho de un material cómodo y resistente a la vez, este tejido se adapta perfectamente a los Zoths permitiéndoles esconder lo esencial.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Tejido de Stropajo",t:55,d:"Este tejido tiene más agujeros que un gruyer, sin embargo es capaz de absorber un máximo de desperdicios para devolverlos en el momento menos oportuno.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Tibia del Guerrero Zoth",t:47,d:"Como todos los huesos del Guerrero Zoth, esta tibia a sufrido múltiples fracturas. Poco a poco se soldó volviéndose más resistente. Sí pudiera hablar, ahora podria decir aquello de: \"lo que no me mata, me hace más fuerte\".",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Rótula del Discípulo Zoth",t:47,d:"De tanto dar rodillazos, la rótula de Discípulo Zoth se ha vuelto muy resistente y ha ganado en volumen. De seguir así, se podrán hacer bolas de petanca con ella.",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Bragueta del Maestro Zoth",t:15,d:"La bragueta del maestro Zoth se concibió especialmente para no despedazar las carnes. Los aventureros que ya hayan sido traumatizados por una bragueta lo entenderán.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Pañuelo de la chavala Zoth",t:15,d:"No creas que la Chavala Zoth usa este pañuelo para llorar en las despedidas, en realidad lo usa para limpiar la sangre que sus enemigos dejan en ella.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Heráldica del Sargento Zoth",t:15,d:"Se la regaló su madre, que la había bordado especialmente para dársela en su 5º cumpleaños. Con el tiempo pasó a ser una insignia militar.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Zumo de Stropajo",t:15,d:"Al menos que estés totalmente borracho, no es posible confundir el zumo de Stropajo con cualquier líquido potable. El olor nauseabundo disuadiría incluso a un ciego.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
I.u[8808] = {n:"Tejido del Rey Stropajo",t:55,d:"Este tejido tiene más agujeros que un queso suizo, pero aún así tiene un increíble poder para absorber la suciedad. ¡Por donde pase este tejido, la suciedad se habrá ido!",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"Calzones del revés del Rey Stropajo",t:15,d:"Desde que el Rey Stropajo Dagoberto lo puso de moda, todos sus descendientes se han puesto siempre los calzones del revés... mientras no les dé vueltas al estómago.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Barro seco del Barrostropajo",t:15,d:"Este barro, gracias a su composición a partir de vegetales en descomposición, tiene una sorprendente capacidad de absorción. Las mamás bworks lo usan bastante a menudo: como mínimo una semana cada cuatro.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Papada del Lodostropajo",t:15,d:"El lodostropajo se da muchos baños de lodo para ver si adelgaza, pero lo único que consigue es esta papada que harmoniza su silueta.",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Tinta de kralamar gigante",t:15,d:"Viscosa y concentrada, la tinta del kralamar puede servir para escribir como para pintar las paredes del cuarto de un depresivo.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Ventosa del kralamar gigante",t:15,d:"Viendo la talla de esta ventosa, no hay duda de que debe adherir muy bien y cuando se despega, el ruido que produce es fortísimo.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Bolsa de 5.000 Kamas",t:100,d:"Esta bolsa muy pesada seguro que contiene una verdadera fortuna.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Bolsa de 1.000 Kamas",t:100,d:"Esta bolsa muy pesada seguro que contiene una verdadera fortuna. Algún mercader te la cambiará sin problema por su valor en kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Regalo: Espada Gasificadora",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Quizás, esta vez, los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Regalo: Sombrero Satano",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"Soberana capa del Rey Stropajo",t:17,d:"Esta capa está hecha con tejido del propio Rey Stropajo, un tejido micro perforado que permite una mejor evacuación del sudor en caso de ejercicio intenso, como las peleas de la turbera. Esta capa deja salir la humedad conservando el calor para garantizarte el mayor confort. \nUna pena que, como el calor, su olor a podrido no se vaya con la humedad.",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Capa de Stropajo",t:17,d:"Aunque sea menos eficaz que la Soberana Capa del Rey Stropajo, esta capa presenta las mismas ventajas de evacuación del sudor. Con ella podrás enfrentarte a todos los enemigos... si consigues pelear en apnea, ya que su olor (realmente insoportable) podrá conseguir que te desmayes.",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Máscara del Sargento Zoth",t:16,d:"Gracias a esta máscara, no tendrás miedo al ver al enemigo. A decir verdad no podrás ver al enemigo, asi que...",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Gorro del Discípulo Zoth",t:16,d:"De lejos, este Gorro parece una pantalla de lámpara a la que se le han hecho dos agujero. De cerca, parece que la primera impresión se confirma.",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Máscara del Abrajidor claro",t:16,d:"Esta máscara no te permitirá ni prevenir ni curar la resaca, pero al menos podrás disimularla de un modo elegante.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Máscara del Abrajidor oscuro",t:16,d:"Esta máscara no te permitirá ni prevenir ni curar la resaca, pero al menos podrás disimularla de un modo elegante. El matiz oscuro indica, además, que poco le falta a tu humor para ser negro;\r\n            así que más vale que no te busquen las cosquillas.",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Kascorakol",t:16,d:"Vale que cuando te lo pongas parecerás un Kasrakol, ¡pero no es una razón para que babees así! Por muy bien que te proteja de los golpes en la cabeza, seguirás pudiendo desplazarte sin arrastrarte.",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Maza del Coralador Magistral",t:7,d:"Más grande, más fuerte, más poderosa, esta maza se abatirá con mucho más ruido sobre sus enemigos. Curiosamente, es más ligera y mas manejable... No es por nada que el Coralador a partir del que se fabricó era magistral.",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Martillo de la Chavala Zoth",t:7,d:"A pesar de su escaso tamaño, la Chavala Zoth es capaz de levantar este enorme martillo. Es un modo muy eficaz de hacer ejercico: para ganar fuerza no necesitará cargar peso en muñecas o tobillos. Llevar esta martillo es más que suficiente.",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Hacha del Guerrero Zoth",t:19,d:"El guerrero Zoth se acostumbro a llevar dos hachas porque le resultaba imposible tocar el flanco izquierdo de sus enemigos con su hacha derecha. ¿Un auténtico problema genético o más bien torpeza hereditara? Resulta difícil saber cual es la verdad, pero lo que es seguro es que dos hachas resultan muy prácticas para hacer rodajas al enemigo.",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Peluca de pohoyo",t:16,d:"Un pohoyo es un pajarraco poco hábil que tiene tanta viveza como un pato mareado y tanta inteligencia como un Tofu alelado. Vamos, que lo tenía mal para sobrevivir. Sin embargo hay quien adora su curiosa cabellera, que se parece a una fregona trenzada por un ama de casa teutona. Definitivamente, la naturaleza humana es bastante extraña.",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Sombrero de Barbrusa",t:16,d:"Este sombrero era lo suficientemente largo como para disimular la cabeza y la barba ridículamente pequeña del capitán Barbrusa, pero no podrá cubrir la cabeza de más de un cabezón.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8830] = {n:"Peluca no muy linda del flib",t:16,d:"Si siempre has soñado con tener una melena con volumen, está peluca es para ti. Además de estar a la última en la disco, también podrás amortiguar los golpes que encajes con la cabeza.",ep:0,g:198,l:1,wd:false,fm:true,w:1,p:1};
I.u[8832] = {n:"Baba del kasrakol",t:15,d:"La baba del Kasrakol no puede alcanzar el plumage del Tufo Aéreo, pero puede mantenerte pegado al suelo.",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Maza del Coralador",t:7,d:"El color de este martillo se debe a los trozos de Coralador que lo componen. Contrariamente a lo que indican las apariencias, este martillo no servía para apachurrar yopukas enemigos, sino que se trata de un artefacto ornamental dejado por una civilización extinta que lo usaba a modo de llamador para que las personas con problemas de sordera pudiesen oír si había alguien a la puerta.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Rama del abrajidor oscuro",t:3,d:"Con esta rama, el abrajidor se rascaba ciertas partes del cuerpo difícilmente accesibles. Puedes estar tranquilo, el color oscuro es el propio de la madera, no es fruto de ningún resto depositado en las cavidades inaccesibles del abrajidor.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Rama del abrajidor claro",t:3,d:"Con esta rama, el abrajidor se rascaba ciertas partes del cuerpo difícilmente accesibles. Esto explica ese extraño olor que tiene.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Tallo del Esquejika",t:4,d:"Los Esquejikas utilizan estos tallos para limpiarse las orejas. Los escultores de bastones prefieren usarlos como armas. Como puedes ver, sobre gustos no hay nada escrito.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Bastón del Maestro Zoth",t:4,d:"El maestro Zoth puede vencer a cualquiera con su bastón. ¡Ningún enemigo le asusta! Lo que no es tan raro cuando sabes que con su tocado no puede ver nada. Esta técninca, que resulta tan útil en el combate, puede ser más problemática cuando se trata de pasar a la mesa. De hecho el Maestro Zoth nunca a podido aprender a comer sin mancharse.",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Rizoma del Tynril",t:4,d:"Como la mala hierba, el Tynril puede reproducirse hasta el infinito gracias a un simple rizoma;\r\n            por eso ciertos escultores crearon un batón a base de Tynril: pretendían que se reproduciese facilemnte y así obtener grandes beneficios con el mínimo coste. Se equivocaron.",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Máscara Bodú Thierry",t:16,d:"Esta máscara Bodú sirve, básicamente, para cubrir la cara de los kaníbolas a los que le gusta disparar con honda (como a Thierry), pero que se ponen enfermos cada vez que fallan su objetivo. El color verdoso de esta máscara nos recordará que acaban de fallar su tiro... otra vez.",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Máscara Bodú Jav",t:16,d:"Los Kaníbolas Jav suelen estar bastante apenados, por eso pintan su máscara de un azul moroso. ¿Será por penas del corazón o por otras razones? Una respuesta dificil de encontrar, pero no estaría mal que se contentasen con llevar la máscara y que se dejasen de cantar su melancolía.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Máscara Bodú Cerbat",t:16,d:"Algunos Kaníbolas son auténticos devoradores de la prensa amarilla, la leen tanto que hasta sus propias máscaras se volvieron de este color. ¿Habría ocurrido lo mismo si leyesen prensa rosa?",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Máscara Bodú Arquero",t:16,d:"Como los Kaníbolas Arqueros simpre se quedan en la retaguardia, son los últimos en llegar a todas partes. Los demás Kaníbolas empezaron a llamarlos \"los farolillos rojos\", y así pintaron sus máscaras.",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Sombrero de Crocodail Dandi",t:16,d:"Con este sombrero en la cabeza, crocodail piensa estar a la última. Pero por muy Dandi que sea, sabe muy poco de moda. Así todo, evita hablarle de su aspecto ridículo porque es muy susceptible...",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"Soberana capucha del Rey Stropajo",t:16,d:"Tocado real, esta capucha posée las mismas virtudes que la Capa del Rey Stropajo. Su micro-perforado contribuye a mejorar la evacuación del sudor para mantener la cabeza fría. Desgraciadamente, también posée los defectos de la capa: su olor nauseabundo es tan espeso que casi se podría cortar con un cuchillo.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Capucha de Stropajo",t:16,d:"Menos eficaz que el tocado real, esta capucha permite, aún así, una  muy buena evacuación del sudor. Quizás demasiado buena, puesto que llevarla es un poco como no llevar nada.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Sombrero de la Chavala Zoth",t:16,d:"El Sombrero de la Chavala Zoth tiene la peculiaridad de hacerle ver doble. Así que cuando vé a alguien de la tribu se dice que ve Zothble.",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Casco del Guerrero Zoth",t:16,d:"Este casco tiene las mismas ventajas que los otros sombreros Zoth: protege de la insolación incluso en pleno verano, amortigua los golpes en la cabeza, e impide ser consciente del peligro que no se avecina de frente reduciendo el campo de visión a una estrecha franja frontal. Vamos, que es el casco ideal para los guerreros.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Tocado del Maestro Zoth",t:16,d:"El tocado del Maestro Zoth tiene la ventaja de reducir el campo de visión todavía más que los otros sombreros Zoth. Gracias a esta característica te permite dominar la famosa técnica de combate llamada \"de la garduña\". Grosso modo, basta con golpear con todas tus fuerzas en cualquier sitio. Al ser totalmente imprevisible, esta técnica te garantiza la victorio sobre el enemigo (o al menos lo sorprenderás tanto que conseguirás atizarle algunos golpes bien dados).",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Raíz de Diente Pe-león",t:4,d:"Este bastón te hará parecer un guerrero más fiero. Para ser un guerrero más fiero necesitarás algo más...",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Raíz de floribundo",t:4,d:"Si eres uno de esos supersitciosos que siempre andan buscando madera que tocar, ¡Aquí tienes la raíz del floribundo!\nSi no eres supersticioso, la raíz de floribundo también te ayudará a ganar combates perfumando la victoria de un agradable perfume floral.",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"x",t:24,d:"x",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"x",t:16,d:"x",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"Escudo Fi\'Squal",t:82,d:"Cierto es que este escudo puede protejerte de un modo que ningún otro lo hará nunca, pero no sueñes, no va a durar para siempre.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Cinturón Rasgabolario del Rasgabola",t:10,d:"Cuando al Rasgabola le tocan las bolas, se pone el Cinturón Rasgabolario para bolear a todos los boludos que se le acerquen.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Botas Stropajo",t:11,d:"Estas botas hacen un extraño ruido de succión con cada paso que das, lo que resulta bastante parecido al canto de apareamiento de las Trools en celo. ¡Así que ten cuidado, no sea que un trool con problemas oculares te vaya a confundir con su amada!",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"Soberano sello del Rey Stropajo",t:9,d:"Este sello designa a su propietario como soberano incontestable de la Turbera abismal de la Isla de Otomai. No hay reino más bucólico que éste.",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Alianza de Coral",t:9,d:"Este anillo se arrancó del dedo aun caliente de un joven Coralador frescamente machacado. Su madre lo esperaba para cenar, hasta que se dio cuenta de que alguien había transformado a su hijo en una piedra sepulcral. Hasta los coraladores tienen un corazón, que no es precisamente de piedra.",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Sandalias Circulares del Kimbo",t:11,d:"Tan sólo el Kimbo, con sus extraños pies, puede sentirse cómodo con estas sandalias. Sin embargo no es el único que podrá aprovechar su poder. Así todo, ten cuidado de no ponértelas del revés.",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Cinturón Túfico de Cosmic Ario",t:10,d:"Cosmic Ario estaba convencido de poder volar garcias a este cinto equipado de un par de alas de tufo. A pesar de que los Tufos no sepan volar, se lanzaba de lo alto del árbol Hakan aplastándose contra el suelo: por aquel entonces fue cuando lo apodaron \"Kotoplof\".",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothuleto",t:1,d:"Este amuleto es un vulgar cacho de madera con un pedazo de tela hecha jirones, pero los Zoths están convecidos de su poder. ¡Pobres locos!",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Kasr\'Arkol",t:2,d:"La cuerda de este arco se hizo con baba de Kasrakol semi seca, su elasticidad sin par, su textura pegajosa y su viscosidad te recordarán... bueno, no sé qué te recordarán, pero seguro que no es nada agradable.",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Anillo Kasrakol",t:9,d:"Esculpido en el caparazón de un Kasrakol, este anillo resiste a cualquier cosa, y casi también a cualquier persona.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Poderosa Capa Fulgurante",t:17,d:"Tejida con tejidos Zoths, esta capa alberga un extraordinario poder de origen desconocido.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Capa del Mopet",t:17,d:"Cuando te pongas esta capa, te entrarán una teribles ganas de vinagreta.",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Pohoyacha",t:19,d:"El que un pico de Pohoyo adorne esta arma no sirve más que para molestar a quien tenga que usarla. Por suerte es un arma muy poderosa.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Botines de madera de  Abrajidor",t:11,d:"Estas botas son tan pesadas que se podrían clasificar como armas, del daño que hacen las patadas con ellas puestas.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Cinturón oscuro de Abrajidor",t:10,d:"Tallado en madera de Abrajidor oscuro, este cinturón es muy poco flexible y por consiguiente bastante incómodo, pero al menos te protegerá bien.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Cinturón claro de Abrajidor",t:10,d:"Tallado en madera de Abrajidor claro, este cinturón es muy poco flexible y por consiguiente bastante incómodo, pero al menos te protegerá bien.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Palmanillo",t:9,d:"Esta no es una joya muy valiosa, pero tiene el tamaño ideal para medir la cantidad de murgal necesaria par un buen belgrut con glaviuz.",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Krustacinto",t:10,d:"¡Por fín tienes una buena excusa para ir oliendo a mar!",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Stropamuleto",t:1,d:"Esta joya intentará robarte algo de tu plato mientras comas... así que no la dejes colgar demasiado bajo.",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Velo de tinta",t:17,d:"Esta extraña capa parece estar hecha de tinta china, pero curiosamente se comporta como una tela y no gotea. Eso sí, mancha;\r\n            así que olvidaté de volver a tener limpias las posaderas.",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Kralanillo",t:9,d:"Una vez que te lo hayas puesto, no podrás quitartelo. Eso si que son ventosas eficaces.",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kidortillo",t:7,d:"Este martillo no es práctico, ni bonito, ni ergonímico, ni poderoso, ni lo suficientemente pesado, ni está bien equilibrado. Es demasiado ligero, demasiado fragil, Brilla mucho y huele mal. \n¡Pero es un martillo de colorines! Por fin un poco de color en este mundo de brutos.",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
I.u[8879] = {n:"Anillo Pulío",t:9,d:"Desgraciadamente, este anillo sólo está pulío por fuera. Se pone metiendo el dedo por un agujero relleno de afilados trocitos de roca. Ideal para los Sacrógrito.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Amufafah",t:1,d:"Este collar puede dar unas irrefrenables ganas de reir a quien lo lleve puesto, pues las plumas que lo adoran pueden hacer cosquillas en los pezoncillos.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Hanillo Solo",t:9,d:"Solo era un simpático debilucho, como solía decir el mismo, con una capacidad asombrosa para meterse en lios. Murió colgado en la plaza pública después de haberle robado la ropa interior a la mujer del jefe del pueblo.",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Pócima de Hogar de Gremio",t:12,d:"Esta pócima te permite volver a la casa de tu gremio.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Fantasma Miaumiau Atigrado",t:90,d:"Este Miaumiau Atigrado no ha dejado todavía el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Transformación fantasma Miaumiau Atigrado",t:27,d:"Has sido transformado en fantasma para poder penetrar en el santuario de las mascotas.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8887] = {n:"Certificado de admisión en la petrera: miaumiau atigrado",t:77,d:"Este certificado describe las características del miaumiau atigrado que has dejado en la petrera.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8888] = {n:"Certificado de admisión en la petrera: ardilla pilla",t:77,d:"Este certificado describe las características de la ardilla pilla que has dejado en la petrera.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8889] = {n:"Certificado de admisión en la petrera: leopardo",t:77,d:"Este certificado describe las características del leopardo que has dejado en la petrera.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8890] = {n:"Regalo: Miaumiau Atigrado",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8891] = {n:"Regalo: Ardilla Pilla",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8892] = {n:"Regalo: Leopardo",t:89,d:"Si acercas la oreja o si sacudes fuertemente la caja, oirás extraños ruidos que te indicarán la presencia de una criatura que está aún vivita y coleando. ¡No pierdas ni un segundo más y ábrelo rápidamente! Contiene una magnífica mascota, un libro que te explica cómo criarla y polvos de aniripsa para curarla.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
