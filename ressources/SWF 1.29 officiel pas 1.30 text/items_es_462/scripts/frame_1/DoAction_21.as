I.u[9122] = {n:"Blopanillo Guinda",t:9,d:"En cuanto te lo pongas en el dedo, ya no podrás quitártelo de encima. Si lo piensas bien, seguro que te recuerda a alguien...",ep:5,g:149,l:50,wd:true,fm:true,w:10,s:98,p:4000};
