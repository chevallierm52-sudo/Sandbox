I.u[2197] = {n:"La Fuerza del Divorcio",t:14,d:"Estos anillos permiten romper los lazos sagrados del matrimonio.",ep:1,g:13,l:1,wd:true,fm:true,w:0,ut:true,p:1};
I.u[2198] = {n:"Pergamino de Conocimiento",t:14,d:"Este pergamino te permite mejorar tu Inteligencia, eso te puede servir para mantener la calma frente a dos Bworks.",ep:1,g:7,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2199] = {n:"Pergamino de Estupidez",t:14,d:"Este pergamino te permite reducir la Inteligencia de un determinado blanco, eso te puede servir cuando tu enemigo se pone nervioso cuando se acercan dos Bworks.",ep:1,g:8,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2200] = {n:"Amenaza de Satirev Refibrom",t:24,d:"El gran juez de Brâkmar ya no quiere verte. Parece que no te lleva en absoluto en su corazón... bueno, la verdad es que tampoco tiene.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2201] = {n:"Serenidad",t:29,d:"Esta bendición permite ganar Sabiduría para los siguientes combates.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2202] = {n:"Senilidad",t:30,d:"Esta maldición te quita Sabiduría para el próximo combate.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2203] = {n:"Pergamino de Moderación",t:14,d:"Este pergamino te permite mejorar tu Sabiduría, eso te puede servir para llegar más rápido a la rodilla de Dark Vlad.",ep:1,g:9,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2204] = {n:"Pergamino de Senilidad",t:14,d:"Este pergamino te permite reducir la Sabiduría de un determinado blanco, eso te puede servir cuando tu enemigo intenta llegar más rápido que tú a la rodilla de Dark Vlad.",ep:1,g:10,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2205] = {n:"Cambio de orden",t:24,d:"Este papel indica que ya has realizado un cambio de orden.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2206] = {n:"Casualidad",t:29,d:"Esta bendición permite ganar Suerte para los siguientes combates.",ep:18,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2207] = {n:"Registro de detención",t:24,d:"En este papel están indicados los crímenes que has cometido, así como la fecha en la que has sido encarcelado...",ep:2,g:73,l:1,wd:true,fm:true,w:0,p:1};
I.u[2208] = {n:"Negra",t:30,d:"Esta maldición te quita Suerte para el próximo combate.",ep:1,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2209] = {n:"Pergamino de la Suerte",t:14,d:"Este pergamino te permite mejorar tu Suerte, eso te puede servir para encontrar más fácilmente algún tofu perdido.",ep:1,g:11,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2210] = {n:"Pergamino de la Negra",t:14,d:"Este pergamino te permite reducir la suerte de un determinado blanco, eso te puede servir cuando un adversario quiera volverse rico a tus despensas.",ep:1,g:12,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2211] = {n:"Traje yopuquesco",t:14,d:"Gracias a este disfraz vas a brillar en los bailes mundanos. El único problema es que te dirán a menudo que eres listo como un yopuka.",ep:1,g:14,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2212] = {n:"Traje xeloresco",t:14,d:"Con este sombrero y los utensilios que le acompañan, la semejanza engañará a cualquiera. Eres un xelor, de eso no cabe duda.",ep:1,g:15,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2213] = {n:"Traje sadidesco",t:14,d:"No hace falta gran cosa para parecerse a un sadida: una alfombrilla, tener la mirada nublada y la cabeza atrancada en el recto. Efecto garantizado.",ep:1,g:16,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2214] = {n:"Yopuka Attitude",t:31,d:"Tienes la Yopuka attitude hasta que empieces un combate.",ep:1,g:4,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2215] = {n:"Xelor Attitude",t:31,d:"Tienes la Xelor attitude hasta que empieces un combate.",ep:1,g:5,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2216] = {n:"Sadida Attitude",t:31,d:"Tienes la Sadida attitude hasta que empieces un combate.",ep:1,g:6,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2217] = {n:"Traje fequesco",t:14,d:"Este pelucón sale de un viejo armario, eso se nota en el aspecto un tanto \"retro\" de esta cofia. En cambio, es increíble cómo te pareces a un Feca poniéndotelo en la cabeza (porque tú lo velas).",ep:1,g:17,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2218] = {n:"Feca Attitude",t:31,d:"Tienes la Feca attitude hasta que empieces un combate.",ep:1,g:7,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2219] = {n:"Traje aniripesco",t:14,d:"Estas alas de aniripsa no te permitirán volar. O sea que no te hagas el fanfarrón delante de tus amigos con esta indumentaria, puede que hagas el ridículo al momento de aterrizar.",ep:1,g:18,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2220] = {n:"Aniripsa Attitude",t:31,d:"Tienes las Aniripsa attitude hasta que empieces un combate.",ep:1,g:8,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2221] = {n:"Traje anutrofesco",t:14,d:"Esta falsa barba te hace parecer a un Anutrof pero también te pega su haliento resacoso dominical. Todas caerán...",ep:1,g:19,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2222] = {n:"Anutrof Attitude",t:31,d:"Tienes la Anutrof attitude hasta que empieces un combate.",ep:1,g:9,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2223] = {n:"Traje sacrigriesco",t:14,d:"Un poco de sangre de tofu y unas cuantas falsas cicatrices, una mirada de pirata psicótica y hecho está. Podrás participar en las reuniones de los sacrógritos haciéndote pasar por uno de ellos sin levantar sospechas.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2224] = {n:"Sacrógrito Attitude",t:31,d:"Tienes la Sacrógrito attitude hasta que empieces un combate.",ep:1,g:10,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2225] = {n:"Traje sramesco",t:14,d:"Un kwan, una capa puesta sobre la cabeza y la ilusión es perfecta. Si te pones este traje, te parecerás a un horrible y abyecto personaje que sale de un  cementerio: En dos palabras: Un sram.",ep:1,g:21,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2226] = {n:"Sram Attitude",t:31,d:"Tienes la Sram attitude hasta que empieces un combate.",ep:1,g:11,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2227] = {n:"Traje osamodesco",t:14,d:"Tras equiparte con esta cola y estos cuernos, este traje te vendrá como anillo al dedo para invitarte a las famosas fiestas VIP (Violencias, Insultos y Porrazos) que organizan los osamodas a escondidas.",ep:1,g:22,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2228] = {n:"Osamodas Attitude",t:31,d:"Tienes la Osamodas attitude hasta que empieces un combate.",ep:1,g:12,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2229] = {n:"Traje zurcaresco",t:14,d:"Aquí tienes una orejas de pelo de wabbit muy suave, una cola atigrada y una caja llena de pulgas. No hay duda, cuando les pasarás estos bichejos a tus vecinos, nadie podrá dudar sobre tus talentos de transformista.",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2230] = {n:"Zurcarák Attitude",t:31,d:"Tienes la Zurcarák attitude hasta que empieces un combate.",ep:1,g:13,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2231] = {n:"Traje ocraesco",t:14,d:"Ya lo habrás notado, el ocra se pasea con su carcaj. No te extrañes si, llevando tú uno, te toman por uno de los suyos. Pero no es más que un farol, qué bueno resulta engañarlos a todos.",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2232] = {n:"Ocra Attitude",t:31,d:"Tienes la Ocra attitude hasta que empieces un combate.",ep:1,g:14,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2233] = {n:"La Mordisca",t:10,d:"Este cinturón fue creado por el Zollo Tsar. Tuvo la fabulosa idea de recoger todos los dientes que se podían encontrar en un campo de batalla Wabbit. Desde aquel día, ese gesto se ha convertido en una costumbre.",ep:8,g:20,l:28,wd:true,fm:true,w:20,c:"CS<40&CI>80",p:2400};
I.u[2234] = {n:"Bonta Attitude",t:31,d:"Tienes la Bonta attitude hasta que empieces un combate.",ep:1,g:15,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2235] = {n:"Brakmar Attitude",t:31,d:"Tienes la Brakmar attitude hasta que empieces un combate.",ep:1,g:16,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2236] = {n:"Disfraz bontesco",t:14,d:"Con esta pinta, muchos viajeros te saludarán y te preguntarán el camino que deben tomar.",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2237] = {n:"Traje brakmaresco",t:14,d:"Con esta indumentaria, todos te temerán.",ep:1,g:26,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2239] = {n:"Pólvora de Aniripsa",t:48,d:"Esta pólvora es producida en pequeñas cantidades por las alas de los aniripsas. Parece tener virtudes curativas cuando se echan sobre las mascotas.",ep:3,g:260,l:1,wd:true,fm:true,w:1,p:1000};
I.u[2240] = {n:"Hadita Artificial Roja",t:74,d:"Ideal para festejar bodas, perfecto para poner ambiente en las fiestas de las Bragas Rotas.",ep:16,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:350};
I.u[2241] = {n:"Gelatina menta real",t:110,d:"La gelatina real ha despojado a más de un aventurero demasiado atrevido, pero acabó aniquilada. Ojo, no te la comas como si fuese una simple Jalea Menta.",ep:7,g:408,l:100,wd:true,fm:true,w:1,p:100};
I.u[2242] = {n:"Gelatina fresa real",t:110,d:"Un concentrado de gelatina de fresa real puede transformar cualquier tabi pacifista en máquina de guerra sedienta de sangre. Cuidado, no lo sirvas como aperitivo a tus amigos.",ep:7,g:409,l:150,wd:true,fm:true,w:1,p:100};
I.u[2245] = {n:"Pinza de scorbuto",t:47,d:"Antiguamente se usaba para rascarse el trasero, también resulta ser un colgador de capas muy práctico si se clava en una pared. También puedes clavártela en el trasero aunque sea un poco más doloroso...",ep:14,g:411,l:36,wd:true,fm:true,w:1,p:1};
I.u[2246] = {n:"Corona rota del Tofu Real",t:15,d:"Esta corona se rompió tras sufrir potentes ataques mágicos o por el último cabezazo que el Tofu Real intentó darte.",ep:3,g:412,l:100,wd:true,fm:true,w:10,p:250};
I.u[2247] = {n:"Pluma de Tofu Real",t:53,d:"Sólo los Yopukas serían incapaces de darse cuenta de que esta pluma viene de la grupa de un Tofu Real. Y eso que se nota mucho ya que la pluma es más gruesa.",ep:3,g:413,l:100,wd:true,fm:true,w:11,p:250};
I.u[2248] = {n:"Pelo de Uginak",t:54,d:"Este pelo da calor, ya ves que tu mano se ha puesto a sudar desde que lo observas. A no ser que sea por miedo a las represalias del próximo uginak que te vea con ese pelo en el bolsillo... ¡Esperemos que no se ponga rabioso!",ep:14,g:414,l:51,wd:true,fm:true,w:1,p:1};
I.u[2249] = {n:"Hoja de Tronkónido",t:36,d:"Esta hoja seguro que le da la fuerza necesaria al tronkónido para que pueda luchar. Ahora bien, será mejor saber como se utiliza. Lo primero que a uno se le ocurre es picarla e incorporarla a un plato de alubias. Una delicia.",ep:2,g:415,l:35,wd:true,fm:true,w:1,p:1};
I.u[2250] = {n:"Madera de tronkónido",t:38,d:"Este cacho de madera suena hueco. La savia verde que de él se escapa indica que esta parte era la nariz del Tronkónido.",ep:9,g:416,l:35,wd:true,fm:true,w:1,p:100};
I.u[2251] = {n:"Mega piedra del crujidor",t:51,d:"¡No te tiro la megapiedra ni escondo la mano!",ep:5,g:417,l:45,wd:true,fm:true,w:15,p:150};
I.u[2252] = {n:"Diente de oro del crujidor",t:47,d:"Acabas de romperle los dientes descaradamente a un crujidor que pasaba por ahí. Que lástima que tuviera sólo uno, una dentadura hubiera cubierto de sobra los gastos de Zaap durante un mes.",ep:5,g:418,l:31,wd:true,fm:true,w:5,p:1};
I.u[2253] = {n:"Flor de zampávoro",t:35,d:"Esta flor facilita el tránsito intestinal. Se recomienda consumirla después de haber pasado unos días en casa de su cocinero preferido.",ep:12,g:420,l:42,wd:true,fm:true,w:1,p:100};
I.u[2254] = {n:"Hoja de mazorral",t:36,d:"La hoja de Mazorral tiene un sabor muy particular, entre la avellana y la enchalada poco fresca. En cualquier caso tus platos tendrán un pequeño perfume a mazorraleza si realmente deseas probarlos.",ep:2,g:421,l:22,wd:true,fm:true,w:1,p:1};
I.u[2255] = {n:"Informe del espía",t:24,d:"Ninguna actividad peligrosa en estos momentos. La organización de los milicianos se ve afectada por el asesinato de uno de los suyos. Parece que fue un bontariano el que se ocupó del crimen.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2256] = {n:"Carcasa de rata de alcantarillas",t:24,d:"Esta rata ya no es más que carne fría. Una menos que se pasea por la entrada de las alcantarillas.",ep:2,g:121,l:1,wd:true,fm:true,w:0,p:1};
I.u[2257] = {n:"Cacho de pared de alcantarilla",t:24,d:"Este cacho de pared de alcantarilla ha sido encontrado dentro del estómago de un chisme.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2259] = {n:"Diente de Karne",t:47,d:"Tienes en tus manos al juego más antiguo de la comarca de Amakna. No hay reglas más sencillas:tira un Diente y trata de recogerlo con la misma mano, procurando al mismo tiempo recuperar otro diente de Karne en el suelo.",ep:4,g:13,l:16,wd:true,fm:true,w:1,p:20};
I.u[2260] = {n:"Tarjeta de visita de un brakmariano",t:24,d:"Alguien ha metido esta tarjeta de visita dentro de tu equipo. Parece que ha sido un brakmariano. Esta tarjeta te anuncia que los Guerreros están interesados por tu talento de asesino y te proponen unirte a la loca aventura brakmariana.",ep:2,g:72,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2261] = {n:"Espíritu husmeador",t:30,d:"Un espíritu husmeador te ha endemoniado. Se nutre con tu olor y con tu vitalidad.",ep:1,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2262] = {n:"Descripción del asesino",t:24,d:"Has encontrado a un Bontariano que apestaba a sangre. Todas las informaciones que has podido juntar sobre este personaje están escritas sobre esta hoja de papel.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2263] = {n:"Bastón Husmeador de Sangre",t:80,d:"Este bastón está poseído por un espíritu husmeador. Se puede liberar este espíritu que saldrá entonces disparado en línea recta hasta cruzarse con un objeto que tenga el olor que le gusta. Atormentará entonces a cualquier persona durante un tiempo antes de volver al mundo de los espíritus.",ep:16,g:25,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[2264] = {n:"Piel de goblin",t:59,d:"Un Goblin suele ser burlón y travieso, pero lo haces pedazos, seguro que no se atreverá tanto.",ep:4,g:422,l:16,wd:true,fm:true,w:1,p:1};
I.u[2265] = {n:"Descripción de un Bontariano",t:24,d:"Has liberado a un espíritu husmeador pero no se ha pegado sobre la persona correcta. Has anotado algunas informaciones de la persona sobre este cacho de papel para poder recordarlas.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2266] = {n:"Leche del Cochinillo",t:15,d:"Esta leche es la de un Cochinillo. Nunca se sabe... Puede que pensaras haberlo sacado de un tofu, de eso nada.",ep:1,g:423,l:18,wd:true,fm:true,w:1,p:1};
I.u[2267] = {n:"Dragoleche",t:15,d:"Esta dragoleche es un alimento muy difícil de conseguir ya que nadie ha conseguido todavía ordeñar a un Dragocerdo. Podemos imaginar fácilmente que por lo menos 7 personas son necesarias para sujetar al bicho mientras que la octava lo ordeña muy rápidamente.",ep:2,g:424,l:70,wd:true,fm:true,w:2,p:1};
I.u[2268] = {n:"Cabellera de Bwork Arquero",t:15,d:"Aquí tienes una cabellera que podría estar de moda entre los Anutrofs:el piostizo. Una pizca de producto antipiojo y estarás listo para participar en el concurso del Anutrof con más caché.",ep:4,g:425,l:24,wd:true,fm:true,w:1,p:1};
I.u[2269] = {n:"Ojo de larva azul",t:24,d:"Acabas de recuperar este ojo intacto. Bien preparados, los ojos revueltos son ideales para un desayuno equilibrado. Este ojo de larva le demostrará a Oto que realmente has matado a una larva azul.",ep:1,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2270] = {n:"Racimo de huevos de larva",t:24,d:"Este racimo de huevos se parece a un enorme racimo de uvas. Pero será mejor que no te lo comas...",ep:1,g:83,l:1,wd:true,fm:true,w:0,p:1};
I.u[2271] = {n:"Cuero lila de bwork",t:56,d:"Abundan los misterios acerca de esta artesanía Bwork. Algunos aventureros creen que la tinta violácea procedería de los Goblines, pero se desconoce el origen del cuero. Qué raro.",ep:4,g:426,l:31,wd:true,fm:true,w:1,p:1};
I.u[2272] = {n:"Larva dorada",t:32,d:"Esta larva acaba de nacer de un huevo. Su primera mirada que se posó sobre ti, te considera como su propia madre.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[2273] = {n:"Tejido púrpura",t:55,d:"Ligero y suave, esas son las principales características de este extraño Tejido Púrpura. En su interior verás una etiqueta en la que pone \"made in talla one\"",ep:2,g:427,l:23,wd:true,fm:true,w:1,p:1};
I.u[2274] = {n:"Vela del minero oscuro",t:15,d:"Fíjate en los anutrofs. Cuando las minas son oscuras ya no lo ves. El minero oscuro, cuando está en la oscuridad, tampoco lo ves ya que ahora tienes su vela.",ep:1,g:428,l:24,wd:true,fm:true,w:10,p:10000};
I.u[2275] = {n:"Cuero de puerkazo",t:56,d:"El Puerkazo estuvo a punto de desaparecer de la cadena alimentaria. Pues hizo falta aparear Jabalíes con Cochinillos para volver a encontrar las Llanuras de Cania llenas de Puerkazos. Desde entonces, el Puerkazo odia al mundo entero...",ep:2,g:429,l:40,wd:true,fm:true,w:10,p:1};
I.u[2277] = {n:"Mortaja",t:55,d:"Para obtener más credibilidad, los fantasmas se visten con una mortaja que les permite aterrorizar a los aventureros perdidos.",ep:14,g:430,l:65,wd:true,fm:true,w:1,p:1000};
I.u[2278] = {n:"Tejido invisible",t:55,d:"Este tejido perteneció a Harry Toper, cazador de topos. Se enrollaba en él para matar a los topos que destrozaban su jardín. El carismático Capitán Chafer se apoderó más tarde de este tejido, antes de desaparecer en circunstancias un tanto extrañas...",ep:1,g:431,l:23,wd:true,fm:true,w:1,p:1};
I.u[2279] = {n:"Diente puntiagudo",t:47,d:"Este diente pertenecía a un Vampiro, no cabe duda. Eso se puede comprobar mirándolo desde muy cerca, verás que no existe diente más puntiagudo.",ep:3,g:432,l:15,wd:true,fm:true,w:1,p:1};
I.u[2280] = {n:"Pajita Vampiresca",t:15,d:"Nunca te fíes de un Vampiro con una pajita en la mano, podría chuparte la sangre hasta la última gota.",ep:3,g:433,l:22,wd:true,fm:true,w:1,p:1};
I.u[2281] = {n:"Tejido sanguíneo",t:55,d:"Parece que este tejido está vivo, los Vampiros lo utilizan a menudo para disfrazarse durante los carnavales...",ep:3,g:434,l:15,wd:true,fm:true,w:1,p:1};
I.u[2282] = {n:"Mechón de pelo canoso",t:15,d:"Aquí tienes la prueba que los monstruos también envejecen.",ep:1,g:435,l:24,wd:true,fm:true,w:1,p:1};
I.u[2283] = {n:"Ojo de kwoan",t:109,d:"Este ojo de kwoan tiene efectos hipnóticos sorprendentes, así que no le saques el ojo de encima cuando lo estés manipulando.",ep:3,g:436,l:8,wd:true,fm:true,w:1,p:1};
I.u[2284] = {n:"Nota de Harry Stóteles",t:24,d:"La entrada de la legendaria gruta de las larvas doradas se encuentra un poco al Oeste de Amakna. Los poderes latentes de la larva dorada te permitirán entrar. Cuidado, si tu pequeña larva recibe daños se precipitará en los brazos de su padre.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2285] = {n:"Tejido oscuro",t:55,d:"La particularidad de este Tejido es que irrita la piel si lo tocas. Será porque algún Uginak se ha sonado los mocos con él durante muchos años...",ep:3,g:437,l:50,wd:true,fm:true,w:1,p:1};
I.u[2286] = {n:"Vendas",t:15,d:"Estas vendas son toda una revolución: triple espesor, perfumadas con lavanda, ultra resistentes. Un verdadero producto de calidad.",ep:2,g:438,l:51,wd:true,fm:true,w:1,p:1};
I.u[2287] = {n:"Cuero negro",t:56,d:"Este cuero ya ha sido tratado, su proveniencia no es muy segura pero el color demuestra que sin duda se ha utilizado un tinte especial.",ep:1,g:439,l:74,wd:true,fm:true,w:1,p:1};
I.u[2288] = {n:"Pata de wabbit",t:103,d:"Muchos turistas van a la isla de Wabbits ante todo para hacerse con una Pata de Wabbit que hace las veces de talismán. Por desgracia, su efecto no es más que un espejismo, pero mejor callarse,la buena marcha del turismo podría acabar pagándolo.",ep:8,g:440,l:18,wd:true,fm:true,w:1,p:1};
I.u[2290] = {n:"Caparazón de escarahoja blanco",t:107,d:"No hace falta gran cosa para conseguir una bonita pantalla para lámpara. Aunque este caparazón ha de tener otra utilidad. Vamos, esperemos que sí la tenga...",ep:3,g:441,l:32,wd:true,fm:true,w:1,p:1};
I.u[2291] = {n:"Caparazón de escarahoja azul",t:107,d:"No hace falta gran cosa para conseguir una bonita pantalla para lámpara. Aunque este caparazón ha de tener otra utilidad. Vamos, esperemos que sí la tenga...",ep:3,g:442,l:32,wd:true,fm:true,w:1,p:1};
I.u[2292] = {n:"Caparazón de escarahoja rojo",t:107,d:"No hace falta gran cosa para conseguir una bonita pantalla para lámpara. Aunque este caparazón ha de tener otra utilidad. Vamos, esperemos que sí la tenga...",ep:3,g:443,l:32,wd:true,fm:true,w:1,p:1};
I.u[2293] = {n:"Caparazón de escarahoja verde",t:107,d:"No hace falta gran cosa para conseguir una bonita pantalla para lámpara. Aunque este caparazón ha de tener otra utilidad. Vamos, esperemos que sí la tenga...",ep:3,g:444,l:32,wd:true,fm:true,w:1,p:1};
I.u[2294] = {n:"Vísceras de escarahoja",t:15,d:"A simple vista, estas vísceras no tienen un aspecto muy apetitoso. Sin embargo, picadas con especias secadas al sol y con un poco de menta salvaje y estofadas en un viejo calderón oxidado, estas vísceras colmarán de felicidad al más gourmet de los chafers.",ep:3,g:445,l:32,wd:true,fm:true,w:1,p:1};
I.u[2295] = {n:"Fragmento de Espada Reptiliana",t:15,d:"Con este fragmento de Espada colgado en tu chimenea, podrás impresionar a tus invitados contándoles que eres domador de Cocodrails, como el excéntrico Mikul, más famoso bajo el mote de Cocodrail Dandi.",ep:4,g:446,l:69,wd:true,fm:true,w:10,p:1};
I.u[2296] = {n:"Escudo Reptiliano",t:15,d:"¿Para qué demonios puede servirte este magnífico escudo adornado con piedras preciosa? Mientras que te lo piensas, podrá servir de bandeja para traerles el té a tus amigos.",ep:4,g:447,l:69,wd:true,fm:true,w:15,p:1};
I.u[2297] = {n:"Flecha de ballesta",t:15,d:"Esta flecha puede servir para confeccionar un arma recortada pero muy cortante. También la puedes usar como palillo, tú verás.",ep:1,g:125,l:34,wd:true,fm:true,w:1,p:1};
I.u[2299] = {n:"Hombrera de Dark Vlad",t:15,d:"Esta Hombrera parece haber sufrido más de una herida. Aunque parezca débil, más vale no golpear a Dark Vlad en el hombro si quieres quedarte con tu arma.",ep:2,g:449,l:120,wd:true,fm:true,w:5,p:80};
I.u[2300] = {n:"Fragmento de hueso",t:47,d:"Este fragmento de hueso procede de un resto de chafer que data del neolítico o de un almuerzo de un mediulubo. Pero existen grandes probabilidades de que su origen sea de distinta naturaleza.",ep:9,g:450,l:43,wd:true,fm:true,w:1,p:1};
I.u[2301] = {n:"Mostacho de Kólerat",t:15,d:"Poco resistente, el mostacho podrá servirte para hacer el gandul delante de tus amigos. Gracias a él podrás disfrazarte en Sava Torh Balí, uno de los mayores pintores Brakmarianos.",ep:2,g:451,l:9,wd:true,fm:true,w:1,p:1};
I.u[2302] = {n:"Lengua de cangrejo",t:15,d:"Los sabios de Amakna aún siguen preguntándose para qué le sirve esta lengua al cangrejo. Se llevarían un buen disgusto si lo supieran.",ep:1,g:452,l:4,wd:true,fm:true,w:1,p:1};
I.u[2303] = {n:"Caparazón de cangrejo",t:107,d:"Correctamente vaciado, este caparazón de cangrejo puede contener diversos objetos. No obstante, los objetos en cuestión conservarán eternamente un olor a cangrejo más o menos desestabilizante.",ep:1,g:453,l:4,wd:true,fm:true,w:2,p:1};
I.u[2304] = {n:"Fragmento de piedra pulida",t:51,d:"Este fragmento procede de la parte izquierda del trasero de un Crujidor de las Llanuras. De lo mejorcito que hay para machacar a una Arakna, sin hablar del Crujidor en persona.",ep:5,g:454,l:45,wd:true,fm:true,w:5,p:1};
I.u[2305] = {n:"Fragmento de piedra afilada",t:51,d:"Este fragmento procede del omóplato derecho de un Crujidor de las Llanuras. A no ser que se trate de una parte del pubis. En todo caso, no coloques esta piedra en cualquier lugar.",ep:5,g:455,l:45,wd:true,fm:true,w:5,p:1};
I.u[2306] = {n:"Corazón de Crujidor",t:51,d:"Corazón de piedra, fíjate en el amor que siento por ti. Si te empeñas en seguir así, te dejo por tierra, no quiero que sigas agobiándome.",ep:5,g:456,l:45,wd:true,fm:true,w:5,p:1};
I.u[2307] = {n:"Escudo del Chafer Lancero",t:24,d:"...",ep:2,g:75,l:1,wd:true,fm:true,w:0,p:1};
I.u[2308] = {n:"Insignia Brakmariana",t:24,d:"Esta insignia permite identificar al guerrero cuando fallece en el campo de batalla. Parece ser que algunos Bontarianos las coleccionan.",ep:2,g:76,l:1,wd:true,fm:true,w:0,p:1};
I.u[2309] = {n:"Vela roja",t:24,d:"No es una vela del montón...",ep:1,g:77,l:1,wd:true,fm:true,w:0,p:1};
I.u[2310] = {n:"Vela verde",t:24,d:"...",ep:2,g:78,l:1,wd:true,fm:true,w:0,p:1};
I.u[2311] = {n:"Vela azul",t:24,d:"...",ep:2,g:79,l:1,wd:true,fm:true,w:0,p:1};
I.u[2312] = {n:"Polvo de sangre",t:24,d:"...",ep:2,g:80,l:1,wd:true,fm:true,w:0,p:1};
I.u[2313] = {n:"Respirador Acuático",t:24,d:"...",ep:2,g:81,l:1,wd:true,fm:true,w:0,p:1};
I.u[2314] = {n:"Frasco de Jiva",t:24,d:"...",ep:2,g:82,l:1,wd:true,fm:true,w:0,p:1};
I.u[2315] = {n:"Pelos de Colmillo Blando",t:54,d:"Antiguamente, Brujit Bardo hizo que se prohibiera la caza de los jóvenes Colmillos Blandos. Desde su exilio, la caza se volvió a permitir y los sastres vuelven a llenarse las alforjas.",ep:1,g:196,l:19,wd:true,fm:true,w:1,p:1};
I.u[2316] = {n:"Colmillo Amarillo",t:47,d:"El Colmillo Amarillo de Colmillo Blando asusta a todos aquellos que subestiman su poder.",ep:1,g:458,l:19,wd:true,fm:true,w:1,p:1};
I.u[2317] = {n:"Orejas de lobo",t:106,d:"Al examinarlas desde más cerca uno puede preguntarse como hace un colmillo blando para oír bien con todos esos bichos y otras porquerías que lleva dentro de las orejas.",ep:1,g:459,l:19,wd:true,fm:true,w:1,p:1};
I.u[2318] = {n:"Pata de oso",t:103,d:"Algunos goblins llevan una pata de oso alrededor del cuello. Una superstición cuyo origen y significado han sido completamente olvidados.",ep:1,g:460,l:12,wd:true,fm:true,w:1,p:1};
I.u[2320] = {n:"Collar Roto de Uginak",t:15,d:"Como cualquier buen Uginak, su collar proporciona informaciones. Viene escrito en él: \"Estoy perdido, mi barrio está por el camino de las Landas de Sidimote, por favor lléveme hasta mis dueños Brakmarianos, se lo agradecerán a palos\".",ep:14,g:462,l:51,wd:true,fm:true,w:5,p:1};
I.u[2321] = {n:"Morros de Uginak",t:15,d:"Tienes la impresión de que estos Morros de Uginak podrían babear indefinidamente. Tal vez sea porque este animal tiene fama de goloso eterno.",ep:14,g:463,l:51,wd:true,fm:true,w:1,p:1};
I.u[2322] = {n:"Colmillos de ratas",t:47,d:"No te equivoques, estos dientecitos son en realidad verdaderos colmillos muy bien afilados, malolientes y algo viejos. A veces sirven para reemplazar los dientes de oro de los Anutrofs más tacaños.",ep:1,g:464,l:50,wd:true,fm:true,w:1,p:1};
I.u[2323] = {n:"Columna vertebral",t:47,d:"Aquí tienes una columna vertebral en buen estado. No es tampoco un motivo para romper la tuya... No es intercambiable.",ep:1,g:465,l:34,wd:true,fm:true,w:2,p:1};
I.u[2324] = {n:"Sandía",t:46,d:"...",ep:1,g:466,l:1,wd:true,fm:true,w:2,p:1};
I.u[2325] = {n:"Plátano",t:46,d:"Una famosa adivinanza inventada por el pueblo de los anutrofs dice: \"Oro parece, plata no es. El que no lo adivine, buen yopuka es...\"",ep:1,g:467,l:1,wd:true,fm:true,w:1,p:1};
I.u[2326] = {n:"Naranja",t:46,d:"...",ep:1,g:468,l:1,wd:true,fm:true,w:1,p:1};
I.u[2327] = {n:"Manzana",t:46,d:"...",ep:1,g:469,l:1,wd:true,fm:true,w:1,p:1};
I.u[2328] = {n:"Pequeña perla dorada",t:15,d:"Esta perla dorada es un regalo de la pequeña larva que acompañaste. Su valor sentimental es inmenso. Su suavidad y su color lo convierten en un regalo idóneo para una persona algo feminina.",ep:5,g:483,l:1,wd:true,fm:true,w:1,p:1};
I.u[2329] = {n:"Pera",t:46,d:"...",ep:1,g:470,l:1,wd:true,fm:true,w:1,p:1};
I.u[2330] = {n:"Cápsula explosiva",t:15,d:"Esta cápsula contiene extractos de agrios mágicos. Se aconseja agitarla mucho antes de usarla para que la pulpa no se queda abajo.",ep:4,g:711,l:23,wd:true,fm:true,w:1,p:1};
I.u[2331] = {n:"Berenjena",t:46,d:"No es realmente nutritiva, algunos acompañan la berenjena con todo tipo de condimentos. Esta legumbre fruta tiene mala reputación aunque sea realmente benéfica para la salud. Excepto para la de los Bworks, pero nadie sabe por qué...",ep:1,g:472,l:1,wd:true,fm:true,w:1,p:10};
I.u[2332] = {n:"Caramelo de consolación",t:42,d:"Este caramelo ha evitado que te pusieras a llorar.",ep:13,g:135,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2333] = {n:"Caramelo rojo superpoderoso",t:42,d:"Este caramelo, aumentará tu atención durante los combates, por desgracia, tiene un sabor realmente asqueroso. (DOBLE CLIC PARA UTILIZAR, bonus de 20 en sabiduría y de 10 en Prospección para los 30 próximos combates).",ep:1,g:136,l:1,wd:true,fm:false,w:1,c:"PO!1723",u:true,p:1};
I.u[2336] = {n:"Cráneo de chafer",t:47,d:"Este cráneo ya no hará más ruido... Aunque nunca se sabe.",ep:1,g:480,l:16,wd:true,fm:true,w:1,p:1};
I.u[2337] = {n:"Libro mágico",t:25,d:"Parece que este libro es mágico. Muy extraño.",ep:1,g:7,l:1,wd:true,fm:true,w:1,p:50};
I.u[2338] = {n:"Viejo Libro",t:25,d:"...",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[2339] = {n:"Lista de equipos estándar",t:24,d:"Un guerrero de valor mediano debe llevar puesto otra cosa que andrajos o, al contrario, vestidos chillones. Por eso tendrá que encontrar: \n-Un camafeo al dedo mayor \n-Un pañuelo y un cinturón de vitalidad \n-Botas de Kluh \n-Una capa brakmariana",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2340] = {n:"Calzones de miliciano",t:24,d:"Estos son unos verdaderos calzones. Debes de ser uno increíble fetichista para poseer esto. O bien alguien se quiere reír de ti.",ep:2,g:84,l:1,wd:true,fm:true,w:0,p:1};
I.u[2341] = {n:"Arco de Mech Riorraw",t:2,d:"Este arco ha sido diseñado por Mech Riorraw, esta calibrado para poder atravesar el río de lava y llegar a lo alto de las murallas de Brakmar, ni más, ni menos.",ep:16,g:8,l:10,wd:true,fm:true,w:100,an:10,tw:true,e:[0,6,20,21,0,30,false,true],c:"Ps=1",p:0};
I.u[2342] = {n:"Anillo de Juramento",t:24,d:"Este anillo te ha sido entregado por Domen. Devolvérsela significaría que estás a favor de la destrucción de todo. Lo cual te cataloga como uno de los admiradores de Djaul.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[2343] = {n:"Pulsera de Djaul",t:24,d:"Esta pulsera te ha sido entregada por Djaul. Llevarla puesta significa que estás de acuerdo con sus propósitos.",ep:2,g:85,l:1,wd:true,fm:true,w:0,p:1};
I.u[2344] = {n:"Carta para Oto",t:24,d:"Esta carta te ha sido entregada por Domen para Oto.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2345] = {n:"Ojo de tortuga",t:24,d:"Ahora esta tortuga ya no se hará la listilla.",ep:2,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2346] = {n:"Traje de Tymador",t:14,d:"No, no se trata del famoso traje del dragovampi, el famoso murciélago volador. Esto es la vestimenta de un habitante del cementerio, o sea un Tymador.",ep:1,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[2347] = {n:"Informe de misión",t:24,d:"Este informe explica cómo se llevó el asalto de Brakmar por la muralla Este.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2348] = {n:"Tymador Attitude",t:31,d:"Tienes la Tymador attitude hasta que empieces un combate.",ep:1,g:17,l:1,wd:true,fm:false,w:0,m:true,u:true,p:1};
I.u[2349] = {n:"Carta para Oto",t:24,d:"Esta carta te ha sido entregada por Domen para Oto. Pero te has olvidado de dársela.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2350] = {n:"Bola de pelos",t:24,d:"Parece que esta bola de pelos perteneció a uno de tus enemigos.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2351] = {n:"Pan del Pankemante",t:33,d:"En este pan, hay de comer y de beber, escurriéndolo mucho, es posible llenar una jarrita de cerveza.",ep:16,g:13,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[2352] = {n:"Carta de Danathor",t:24,d:"\"He de hablar contigo, ven a verme en cuanto tengas un momento, hasta pronto mi joven amigo.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2353] = {n:"Carta de Larry Poller",t:24,d:"\"Hola, soy Larry Poller, nos hemos conocido durante la liberación del Coronel Lyeno. Te quiero pedir un favor: ven a verme cuando tengas un momento. Hasta pronto.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2354] = {n:"Sesos de tortuga",t:24,d:"Estos sesos de tortuga, si se preparan bien, se convierten en un plato suculento.",ep:2,g:89,l:1,wd:true,fm:true,w:0,p:1};
I.u[2355] = {n:"Polvo de Oni",t:24,d:"Este polvo azulado es un catalizador mágico muy potente.",ep:2,g:88,l:1,wd:true,fm:true,w:0,p:1};
I.u[2356] = {n:"Milagro",t:31,d:"Tienes un poder milagroso hasta que empieces un combate.",ep:13,g:19,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2357] = {n:"Madera de olivioleta",t:38,d:"Esta madera parece resistir a todas las temperaturas. No intentes quemarla para calentarte, pues te morirías de frío antes de que esta madera ardiera.",ep:14,g:481,l:50,wd:true,fm:true,w:5,p:0};
I.u[2358] = {n:"Madera de bombú",t:38,d:"Esta madera es la más blandita de todas. Es muy maleable y trabajarla procura un auténtico placer.",ep:13,g:482,l:50,wd:true,fm:true,w:5,p:0};
I.u[2359] = {n:"Broche Hoticili Ufot",t:24,d:"Este pequeño broche te ha sido entregado por Hoticili Ufot.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2360] = {n:"Acta de propiedad",t:24,d:"Esta acta de propiedad es la de la casa de Hoticili Ufot.",ep:2,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[2361] = {n:"Arco de Mulic Bere",t:2,d:"Este arco ha sido un invento del genial Mulic Bere. Su alcance máximo es simplemente increíble. El problema es que el alcance mínimo es casi igual de grande.",ep:16,g:10,l:10,wd:true,fm:false,w:100,an:10,tw:true,e:[0,6,17,23,0,30,false,true],p:0};
I.u[2362] = {n:"Predicción de Pako Rábano",t:24,d:"La predicción que Pako Rábano ha hecho sobre las próximas elecciones.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2364] = {n:"Piedra del Saber",t:50,d:"Esta piedra preciosa lo sabe todo y de vez en cuando comparte sus conocimientos.",ep:0,g:485,l:1,wd:true,fm:true,w:1,p:1};
I.u[2365] = {n:"Hoja de zarza de hestia",t:36,d:"Esta hoja, aparentemente normal y corriente, es un vegetal indispensable para ciertas recetas extrañas.",ep:16,g:415,l:1,wd:true,fm:true,w:1,p:1};
I.u[2366] = {n:"Caña para kralamares",t:20,d:"Esta caña de metal y diamante es la única caña capaz de aguantar el peso del kralamar. También se impregna del olor de kralamar para acariciar la oportunidad de pescar este monstruo.",ep:1,g:8,l:1,wd:false,fm:true,w:10,an:18,e:[2,6,1,9,30,30,false,false],p:1};
I.u[2367] = {n:"Lasmil Unanoches",t:10,d:"Lasmil sabía como multiplicar amistades, convidaba a menudo a sus compañeros en grandes fiestas disfrazadas. También tenía la fama de regalar suntuosas joyas para agradecer la presencia de sus invitados.",ep:8,g:21,l:37,wd:true,fm:true,w:20,c:"CW>49&Ps=1",p:3700};
I.u[2368] = {n:"Ramún el Eterno",t:10,d:"Ramún era un antiguo amigo de infancia de Nova, se perdieron de vista cuando Ramún decidió hacer una siesta eterna.",ep:2,g:22,l:37,wd:true,fm:true,w:50,c:"CW>49&Ps=2",p:1000};
I.u[2369] = {n:"Poderoso Cinturón Fulgurante",t:10,d:"Este magnífico cinturón nació a raíz de una apuesta de locos. El reto consistía en mejorar uno de los cinturones más hermosos de Amakna: el cinturón fulgurante. El ganador de la apuesta fue Akenota Treves.",ep:2,g:26,l:80,wd:true,fm:true,w:150,p:300000};
I.u[2370] = {n:"La Vejeta Tiva",t:10,d:"La Vegeta Tiva es de una ligereza incomparable. Además, su diseño original te aportará paz y amor en tu tierra...",ep:2,g:23,l:41,wd:true,fm:true,w:5,c:"CA>50",p:4575};
I.u[2371] = {n:"La Puleca",t:10,d:"Jiva te aconseja llevar este cinturón para las noches frías y rigurosas. Es tan cómoda que al ponérsela, uno pierde las ganas de moverse. Si la manchas la podrás lavar con Rimenel.",ep:13,g:24,l:27,wd:true,fm:true,w:30,p:2775};
I.u[2372] = {n:"Botas de Linfa Tiko",t:11,d:"Estas botas dan la impresión de caminar constantemente sobre hierba fresca. Constituyen la mejor solución para aquellos que desprenden un olor a pies más cercano al del Kesitufo que al de la Gelatina de Menta.",ep:5,g:18,l:39,wd:true,fm:true,w:5,c:"CC>50",p:4100};
I.u[2373] = {n:"Moon Boots",t:11,d:"El pelo de Moon es necesario para poder hacer estas botas pero también es, sin lugar a dudas, el pelo más abrigoso para los pies. Aunque llevar estas botas en recuerdo a Moon te calentará el corazón.",ep:14,g:19,l:62,wd:true,fm:true,w:30,p:10000};
I.u[2374] = {n:"Botas de Jame",t:11,d:"Jame era un ermitaño al que no le gustaban demasiado las visitas. Cuando recibía a invitados les enseñaba el numerito de su calzado desde muy, muy cerca...",ep:4,g:20,l:38,wd:true,fm:true,w:40,p:4000};
I.u[2375] = {n:"Botas O\'Torrino",t:11,d:"Gracias a estas botas, serás capaz de percibir el chasquido del viento que roza contra las velas de un barco situado en pleno Mar Rano, o bien oír los gemidos de un Chafer Lancero perdido en los recónditos del laberinto.",ep:13,g:21,l:77,wd:true,fm:true,w:40,p:15500};
I.u[2376] = {n:"Hacha Kemata",t:19,d:"Esta hacha es la única capaz de resistir a los poderes del Kaerlier y por consiguiente, la única en poder cortarlo.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,6,1,1,45,45,false,false],c:"PJ>2,79",p:1};
I.u[2377] = {n:"Pico Tron",t:21,d:"Este pico anutrof es el único en poder resistir a temperaturas extremas, permitiéndole extraer la famosa \'sangre de roca\'.",ep:0,g:1,l:1,wd:false,fm:true,w:10,e:[6,6,1,1,50,50,false,false],c:"PJ>24,79",p:1};
I.u[2378] = {n:"Sangre de roca",t:51,d:"Esta piedra de color carmín permite fabricar pócimas muy poderosas.",ep:16,g:459,l:1,wd:true,fm:true,w:0,p:1};
I.u[2379] = {n:"Madera de kaerlier",t:38,d:"Esta madera viene del muy raro Kaerlier. Sus propiedades son más bien... sorprendentes.",ep:14,g:140,l:40,wd:true,fm:true,w:5,p:20};
I.u[2380] = {n:"Capa de dolo",t:17,d:"A pesar de su nombre, ésta no es una capa dolosa. Sólo está hecha con trozos de Lodo de dolo, para proteger tu cuerpo de dolores y de malos olores.",ep:13,g:35,l:41,wd:true,fm:true,w:10,p:4500};
I.u[2381] = {n:"Capa Flotadora",t:17,d:"Esta capa ha sido recortada de un banderín que antiguamente ondeaba encima de la torre más alta del castillo de Amakna. Probablemente sea por eso que huele a ropa puesta a secar al aire...",ep:5,g:36,l:61,wd:true,fm:true,w:10,c:"CI>90",p:9500};
I.u[2382] = {n:"Capa Zono",t:17,d:"Zono era un zurcarák al que no le asustaba el vacío, decía que siempre caería sobre sus patas. Pero un día aterrizó sobre un Trool hambriento. Fue enterrado el mismo día en el mismo sitio donde se encontraron sus restos, o sea un poco por todos lados...",ep:14,g:37,l:36,wd:true,fm:true,w:10,p:6500};
I.u[2383] = {n:"Capa Sanguínea",t:17,d:"Hecha con tejido sanguíneo, la Capa Sanguínea tiene un aspecto como de cartón cuando se toca... como si el tinte rojizo hubiera coagulado.",ep:7,g:38,l:50,wd:true,fm:true,w:10,c:"CS>90",p:6000};
I.u[2384] = {n:"Botas Animales",t:11,d:"Podemos decirlo, estas botas tienen un toque... Mmhh... cómo explicarlo... bestial. Con lo cual que no te extrañe si un mediulubo se enamora de ti y de tus botas. Tal vez sea la peor de las cosas que te pueda ocurrir.",ep:14,g:22,l:94,wd:true,fm:true,w:40,p:23000};
I.u[2385] = {n:"La Pastosa",t:17,d:"Ideal para el jardín, la Pastosa puede también utilizarse como alfombra para la entrada de tu casa. En un principio fue diseñada para los Sadidas ya que no estropea el cabello, ni siquiera los pelos más frágiles e incluso algunos dicen que ralentiza su caída... obviamente, la del pelo.",ep:12,g:39,l:88,wd:true,fm:true,w:10,p:20000};
I.u[2386] = {n:"La Harapa",t:17,d:"Esta extraña capa saca toda su fuerza de su aspecto vetusto. Cuanto más sucia esté, más te servirá.",ep:13,g:40,l:53,wd:true,fm:true,w:10,p:7000};
I.u[2387] = {n:"La Peluda",t:17,d:"Hay que admitir que esta Capa desprende un fuerte olor muy molesto. A modo de descripción, se puede decir que este hedor se asemeja a una mezcla de pelos de monstruos diversos que forman este magnífico producto odorizante.",ep:14,g:41,l:63,wd:true,fm:true,w:10,c:"CW>30&CV>50",p:10500};
I.u[2388] = {n:"El Amuleto del Puzzle de la Garra",t:1,d:"Antiguamente, un Zurcarák llamado Dodge, rompió en mil pedazos un mapa del tesoro que estaba grabado sobre una piedra. Pensando haber conseguido formar de nuevo el mapa, se quedó con la piedra más grande para hacer un misterioso Amuleto. Nadie sabe qué ha pasado con el tesoro.",ep:14,g:36,l:44,wd:true,fm:true,w:5,p:4000};
I.u[2389] = {n:"Amuleto del Badulo",t:1,d:"A Dodge siempre le gustaba destrozar todo lo que le parecía atesorar cierto valor. Decía que era la prueba de que existía. A cada cual su propio rollo.",ep:14,g:37,l:32,wd:true,fm:true,w:5,p:3200};
I.u[2390] = {n:"Amuleto de la Bola",t:1,d:"Este Amuleto es casi perfecto, aumenta de forma considerable la sabiduría de quien lo lleve alrededor del cuello. Muy útil para parecer más listo con tus amigos, o para hacerte pasar por un alumno modelo.",ep:5,g:38,l:49,wd:true,fm:true,w:1,p:6400};
I.u[2391] = {n:"Amuleto de la Bobola",t:1,d:"Un viejo refrán de Sufokia dice: de la Bola un día, de la Bobola a lo mejor otro día. Podrás darte cuenta de que cuanto más antiguo es el refrán, más ridículo es.",ep:5,g:39,l:98,wd:true,fm:true,w:1,p:24400};
I.u[2392] = {n:"Dragolira modificada",t:1,d:"Gracias a los múltiples talentos de los artesanos de Amakna, la Dragolira Modificada destaca por su perfección.",ep:11,g:25,l:42,wd:true,fm:true,w:1,p:5000};
I.u[2393] = {n:"Amuleto Hortilla",t:1,d:"El osamodas Bek Ongüebos deseaba conseguir cierta notoriedad ante los miembros de su gremio y decidió entonces hacer un Amuleto revolucionario. Al final lo consiguió preparando un almuerzo para sus amigos. Curioso.",ep:1,g:40,l:17,wd:true,fm:true,w:10,p:1000};
I.u[2394] = {n:"El Brotecillo",t:1,d:"Ahíto de sol, el Brotecillo calienta los corazones además de proporcionar una sensación de invulnerabilidad frente a la tierra. Es también tan ligero que uno se olvida a menudo de quitárselo antes de irse a la cama.",ep:9,g:41,l:32,wd:true,fm:true,w:1,p:3000};
I.u[2395] = {n:"El fular del Tocino Loco",t:1,d:"El Tocino Loco era un vil pequeño demonio que siempre se quedaba plantado delante de la gente sin moverse. También resistía a la magia, lo cual imponía el respeto en aquella época. Desde entonces, el Tocino Loco se esconde en algún sitio y espera.",ep:8,g:42,l:42,wd:true,fm:true,w:15,p:5000};
I.u[2396] = {n:"La Lucecita",t:1,d:"Sylvelina no era muy ladina. Su madre, Luz, le regaló esta linterna diciendo \"¡Toma, al fin verás la luz!\". Ella tampoco era muy espabilada. Pero eso no le impidió tener una idea genial que iluminó la vida de su hija.",ep:7,g:43,l:15,wd:true,fm:true,w:5,p:1500};
I.u[2397] = {n:"La Chuchoría",t:1,d:"Chuchoría era un viejete al que le encantaba ensamblar cualquier cosa para construir objetos. Un día, creó este medallón con intrigantes formas. Cuando se lo llevó al cuello, sintió una extraña sensación. Sí señor, muy extraña sensación...",ep:13,g:44,l:30,wd:true,fm:true,w:10,p:3000};
I.u[2398] = {n:"El Ojo de Kanugro",t:1,d:"Fue regalado a Melyonen por el ilustre Kanugro Rook Y Balbúa para agradecerle de haberle presentado la que ahora es su mujer, Ar d\'riaaaaaannnaah como a él le gusta llamarla.",ep:13,g:45,l:52,wd:true,fm:true,w:1,p:7000};
I.u[2399] = {n:"El Jabún Suave",t:1,d:"Eko Lojista era un pastor de Jabunes, primos lejanos de los Jalató. En su rebaño, algunas bestias tenían una piel más suave que las demás. De hecho, se vendía mucho más cara y para diferenciar los animales, les ataba este collar alrededor del cuello.",ep:13,g:46,l:15,wd:true,fm:true,w:1,p:1};
I.u[2400] = {n:"Botas Animales Oscuras",t:11,d:"Podemos decirlo, estas Botas tienen un toque... Mmhh... cómo explicarlo... Oscuro. Con lo cual que no te extrañe si un mediulubo se enamora de ti y de tus Botas. Tal vez sea la peor de las cosas que te pueda ocurrir.",ep:14,g:23,l:122,wd:true,fm:true,w:35,p:38000};
I.u[2401] = {n:"Carta de Kwelsh",t:15,d:"Esta carta está relacionada con el maestro Kwelsh. Es lo único que sabes y lo único que debes saber.",ep:16,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[2402] = {n:"Espada de Seriane-Kerm",t:6,d:"Esta espada es un regalo honorífico que se le hace únicamente a los mercenarios endurecidos. Pero también corta muy bien.",ep:1,g:25,l:30,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[2403] = {n:"Tevisto",t:10,d:"Antiguamente se usaba para las liberaciones condicionales. Dicen que el Tevisto posee un poder suplementario con relación a los demás cinturones. Pero nadie lo ha encontrado aún. Más te valdría tenerlo siempre a la vista...",ep:13,g:25,l:49,wd:true,fm:true,w:10,p:6100};
I.u[2404] = {n:"Cinturón de la Rata",t:10,d:"Este cinturón perteneció a una Rata de las Cloacas, le sentaba de maravilla, muy ajustadita a las caderas, le permitía esconder sus michelines.",ep:2,g:27,l:55,wd:true,fm:true,w:10,p:8100};
I.u[2409] = {n:"Kwakosombrero de Llamas",t:16,d:"El Kwakosombrero de Llamas te dará realmente un aspecto de seductor de los tiempos modernos, lo cual será muy eficaz para que tus adversarios se dobleguen ante ti. Bueno, lo harán sobre todo para reírse como locos al verte vestido con este ridículo sombrero.",ep:13,g:39,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2410] = {n:"Abracaska",t:16,d:"La Abracaska te permite dormir... como un tronco.",ep:1,g:40,l:45,wd:true,fm:true,w:50,s:3,p:5500};
I.u[2411] = {n:"Sombrero del jalató",t:16,d:"Este magnífico sombrero permite ganar fuerza e inteligencia si consigues acostumbrarte a su olor.",ep:1,g:41,l:10,wd:true,fm:true,w:15,s:1,p:2050};
I.u[2412] = {n:"Kwapa de Llamas",t:17,d:"Esta capa es muy poco irritante pero aún así irrita un poco. Desafortunadamente, no te permitirá volar, ni siquiera planear y no servirá de nada que le cosas una gran \"M\" encima, no funcionará. Algunos lo pensaban. Como aquel sastre llamado Frants Reitchel que se tiró con ella puesta desde aquella torre de hierro... craso error.",ep:8,g:42,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2413] = {n:"Abrakapa",t:17,d:"Con estas hojas de abráknido podrás pavonearte en pleno bosque sin que nadie te reconozca realmente. Eso sí, ten cuidado con los abráknidos que podrían andar en busca de brotes primaverales...",ep:1,g:43,l:45,wd:true,fm:true,w:17,s:3,p:5500};
I.u[2414] = {n:"Capa Jalosa",t:17,d:"Esta capa lo tiene todo: resistencia, confort, buen color, rareza... En cambio su olor puede revelarse fatal para el tabique de las fosas nasales. Vamos, que uno tampoco puede pedirlo todo...",ep:1,g:44,l:10,wd:true,fm:true,w:30,s:1,p:2780};
I.u[2415] = {n:"Kwakhoja de Llamas",t:6,d:"La Kwakhoja de Llamas es una arma realmente hermosa. A falta de poder asustar a tu adversario con ella, podrá servirte para impresionarlo y de este modo sorprenderlo después con alguna vieja y vil astucia.",ep:5,g:52,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CI>50&CV>50",s:2,p:4600};
I.u[2416] = {n:"Martillo del jalató",t:7,d:"Las instrucciones de uso explican que este sorprendente martillo es capaz de liberar una energía colosal cuando se usa correctamente. Otro manual de instrucciones Osamodas traducido en Sadida...",ep:1,g:23,l:10,wd:true,fm:true,w:25,an:15,e:[5,5,1,1,40,40,false,true],s:1,p:845};
I.u[2417] = {n:"Paloabra",t:4,d:"Este bastón ha conservado toda la agresividad del abráknido, pero no ha conservado el olor a madera enmohecida que a menudo caracteriza los viejos abráknidos.",ep:1,g:23,l:45,wd:true,fm:true,w:10,an:12,tw:true,e:[3,4,1,1,30,50,false,false],s:3,p:5500};
I.u[2418] = {n:"Kwakanillo de Llamas",t:9,d:"Gracias a este anillo, si algún día te pierdes al entregar un mensaje, tu amo podrá tal vez encontrarte.",ep:5,g:43,l:42,wd:true,fm:true,w:2,s:2,p:4900};
I.u[2419] = {n:"Anillo De Boz Layt Yer",t:9,d:"Este anillo era del famoso Boz Layt Yer, héroe de los tiempos modernos. Su frase preferida trataba del Ninfi Tito y el más allá...",ep:1,g:44,l:10,wd:true,fm:true,w:10,s:1,p:775};
I.u[2420] = {n:"Anibra",t:9,d:"Tallar la Rama de Abráknido no es cosa fácil. Pero con empeño uno puede conseguir un anillo a la vez sobrio, elegante y refinado. Todo lo contrario de un Sadida en una taberna.",ep:1,g:45,l:40,wd:true,fm:true,w:10,s:3,p:4500};
I.u[2421] = {n:"Kwakobotas de Llamas",t:11,d:"Si te pones estos espolones de Kwak de Fuego tendrás que andar con pies de pluma para que un Sram de intenciones malignas no te los robe.",ep:5,g:25,l:40,wd:true,fm:true,w:5,s:2,p:4400};
I.u[2422] = {n:"Jalabotas",t:11,d:"Estas botas no tienen rival a nivel de comodidad, parece que el interior está forrado con lana de Jalató, pero también puedes sentir que un líquido circula entre los dedos de tus pies. ¿Será la Baba o la Sangre del Jalató? Poco importa.",ep:1,g:26,l:10,wd:true,fm:true,w:15,s:1,p:1700};
I.u[2423] = {n:"Abrabotas",t:11,d:"Los efectos de este par de Botas pueden también encontrarse si entras en alguna taberna. Después tendrás que consumir un poco o tal vez mucho para conseguir un efecto óptimo. Al día siguiente tendrás las piernas tan pesadas como estas botas.",ep:1,g:27,l:45,wd:true,fm:true,w:20,s:3,p:4500};
I.u[2424] = {n:"Amukwak de Llamas",t:1,d:"Con todas estas plumas alrededor del cuello, te parecerás a Aldo O\'hrado, gran aventurero Sacrógrito que realizó una auténtica Odisea en busca de una ciudad de oro.",ep:5,g:47,l:42,wd:true,fm:true,w:3,s:2,p:4900};
I.u[2425] = {n:"Amuleto del jalató",t:1,d:"Un buen Cuerno de Jalató, es un cuerno que procura calma y sabiduría. Un buen colgante de Jalató te proporcionará por lo tanto sabiduría y calma. O el contrario. O bien otra cosa. O entonces nada.",ep:1,g:48,l:3,wd:true,fm:true,w:10,s:1,p:550};
I.u[2426] = {n:"El Araknamú",t:1,d:"Esta pequeña arakna es la prueba viviente de que uno no está obligado a disecar un animal para hacer un amuleto. Te hará cosquillitas en el cuello o también puede que tenga bebés amuletos, esteee... araknas.",ep:1,g:49,l:20,wd:true,fm:true,w:10,s:3,p:1300};
I.u[2427] = {n:"Kwakcinto de Llamas",t:10,d:"Para pavonearse como un Kwak de Llamas durante la época de los amores, este cinturón te sentará genial, a condición de que sólo lleves eso.",ep:12,g:28,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2428] = {n:"Cinturón del jalató",t:10,d:"Fácil de poner, este cinturón es muy ligero a pesar de su talla. Da la impresión de que la lana es nueva. Lógico ya que según la leyenda hizo falta descuartizar un centenar de Jalatines para que tenga ese aspecto tan liso y sedoso.",ep:1,g:29,l:20,wd:true,fm:true,w:10,s:1,p:1253};
I.u[2429] = {n:"Abracinto",t:10,d:"Este cinturón te proporcionará confianza y unos abdominales de madera. Sin embargo, se recomienda hacerle un tratamiento anti Arakna todos los años, un poco como el que se hace para la cabellera de un Sadida pero con una dosis de antiparásito  tres veces menos elevada.",ep:1,g:30,l:45,wd:true,fm:true,w:25,s:3,p:4500};
I.u[2430] = {n:"Charco de gelatina azul",t:24,d:"Has sido un verdadero bruto con esta Gelatina Azul. Un día, quién sabe, pagarás por este crimen.",ep:7,g:91,l:1,wd:true,fm:true,w:0,p:1};
I.u[2431] = {n:"Charco de gelatina de limón",t:24,d:"Has sido un verdadero bruto con esta Gelatina de Limón. Un día, quién sabe, te aplastarán como tu le has hecho a ella.",ep:7,g:90,l:1,wd:true,fm:true,w:0,p:1};
I.u[2432] = {n:"Charco de gelatina de fresa",t:24,d:"Has sido un verdadero bruto con esta Gelatina de Fresa. Un día, quién sabe, te parecerás a una enorme mancha disforme como ella.",ep:7,g:92,l:1,wd:true,fm:true,w:0,p:1};
I.u[2433] = {n:"Charco de gelatina de menta",t:24,d:"Has sido un verdadero bruto con esta Gelatina de Menta. Un día, quién sabe, te verás reducido a simples restos, como ella.",ep:7,g:93,l:1,wd:true,fm:true,w:0,p:1};
I.u[2435] = {n:"Los Nykers",t:11,d:"Nyker fue el primer Aniripsa en ganar, muy por delante de los Zurcarák, el gran Maratón de Amakna. Gracias a sus botas artesanales, consiguió cruzar el Mar Rano sacándole una buena distancia a todos los Zurcarák que no se creían lo que estaban viendo: un Ani corriendo sobre el agua. Lo flipas.",ep:5,g:29,l:45,wd:true,fm:true,w:5,p:4800};
I.u[2436] = {n:"Gelatina de limón",t:110,d:"Este bote de gelatina de limón tiene un aspecto raro. Según dice Elrik Ola, esta jalea procedería de su casa. En concreto, del otro lado de la galaxia. O sea bastante lejos.",ep:7,g:490,l:45,wd:true,fm:true,w:1,p:1};
I.u[2437] = {n:"Gelatina limón real",t:110,d:"Algunos rumores dicen que la gelatina de limón real es mucho mejor que las demás. Puede que el limón oculte el sabor de la jalea.",ep:7,g:491,l:200,wd:true,fm:true,w:1,p:100};
I.u[2438] = {n:"Jalasombrero real",t:16,d:"El jalasombrero real es un objeto que nunca pasa de moda. Es elegante y proporciona fuerza e inteligencia a quien lo lleve puesto.",ep:1,g:42,l:50,wd:true,fm:true,w:45,s:4,p:100};
I.u[2440] = {n:"Espada Real del Jalató",t:6,d:"Mala pata pezuñera para tus adversarios, esta espada inflige daños de cada elemento.",ep:1,g:30,l:70,wd:true,fm:true,w:65,an:14,e:[4,4,1,1,30,50,false,false],s:4,p:30000};
I.u[2441] = {n:"Anillo Real del Jalató",t:9,d:"Este anillo aumenta la vida de su dueño al igual que el poder de atracción del olor de la hembra del Jalató Real.",ep:1,g:46,l:30,wd:true,fm:true,w:5,s:4,p:100};
I.u[2442] = {n:"Jalabotas Reales",t:11,d:"Son potentísimas y además brillan más que el charol... Estas botas son de lo más \"reales\". Pellízcame.",ep:1,g:30,l:50,wd:true,fm:true,w:50,s:4,p:6600};
I.u[2443] = {n:"Amuleto Real del Jalató",t:1,d:"Este amuleto aumenta la fuerza y la inteligencia de su portador.",ep:1,g:50,l:50,wd:true,fm:true,w:10,s:4,p:5000};
I.u[2444] = {n:"Cinturón Real del Jalató",t:10,d:"Este magnífico cinturón aumenta la vitalidad de quien lo lleve puesto y le permite soportar más fácilmente el peso de sus objetos. Es tan suave que incluso permite atar a tu dulcinea cuando se niega a quedarse en casa.",ep:1,g:31,l:52,wd:true,fm:true,w:10,s:4,p:7000};
I.u[2445] = {n:"Capa Jalosa Real",t:17,d:"Esta capa ha pertenecido al gran Jalató Real y además de favorecerte mucho, te proporcionará una fuerza fuera de lo común.",ep:1,g:46,l:50,wd:true,fm:true,w:60,s:4,p:50000};
I.u[2446] = {n:"Gelocapa",t:17,d:"No lleva ni hilos ni pelos... esta Capa es un auténtico misterio para los seres pensantes de Amakna, los cuales no deben ser más de una decena de personas.",ep:7,g:47,l:60,wd:true,fm:true,w:10,s:6,p:1000};
I.u[2447] = {n:"Gelosombrero",t:16,d:"Con este sombrero podrás estar seguro de que tus amigos sueñen con poder lamerte. En su época, este sombrero hubiese colmado los deseos de Capitán Chafer.",ep:5,g:43,l:60,wd:true,fm:true,w:23,s:6,p:9500};
I.u[2448] = {n:"Sesos de jalató",t:15,d:"No hay duda, estos sesos son los de un Jalató. Bien cocinado, este plato es el preferido de todos los Yopukitas que quieren ser grandes y fuertes. También vuelven inteligente, pero si se enteran los niños Yopukas, dejarían de comerlos.",ep:1,g:492,l:9,wd:true,fm:true,w:1,p:1};
I.u[2449] = {n:"Ejército de garrapatas",t:15,d:"Según cuentan los cazadores, un Ejército de Garrapatas hambriento podría devorar toda la lana de un Jalató en una sola noche. Algunos de los abrazafarolas más conocidos de las tabernas de Amakna incluso aseguran que puede acabar con la magnífica cabellera de un sadida.",ep:1,g:493,l:9,wd:true,fm:true,w:1,p:1};
I.u[2451] = {n:"Casco de jalató",t:47,d:"Antiguamente lo usaban como reposa vasos. Algunos alquimistas Aniripsas, bastante coquetos, reciclan el casco de jalató para hacer tazas. Pues eso le da buen sabor a sus cereales preferidos.",ep:1,g:495,l:9,wd:true,fm:true,w:1,p:1};
I.u[2453] = {n:"Ojo de jalató",t:109,d:"Antiguamente se hacía con este ojo una sopa suculenta. Tanto que se ha tenido que borrar la receta de los libros porque muchos cazadores solamente recuperaban los ojos abandonando en cualquier sitio la carcasa todavía humeante del pobre jalató.",ep:1,g:497,l:9,wd:true,fm:true,w:1,p:1};
I.u[2454] = {n:"Estómago de Jalató",t:15,d:"Un estómago de este tipo tiene eficaces propiedades elásticas. En cambio, no te extrañes si dentro quedan papillas de Trébol, al contrario ¡Alégrense señoritas! Esta papilla es buenísima para la piel.",ep:1,g:498,l:9,wd:true,fm:true,w:1,p:1};
I.u[2455] = {n:"Sangre de jalató",t:15,d:"Resulta imposible irse a cazar sin llevarse esta sangre de jalató. Su olor atrae a los jalatós más gordos. También atrae a las momoscas.",ep:1,g:499,l:9,wd:true,fm:true,w:1,p:1};
I.u[2460] = {n:"Ojo de jalatín",t:109,d:"Parece que no te quita el ojo de encima... Apostaría que te tiene manía...",ep:1,g:500,l:2,wd:true,fm:true,w:1,p:1};
I.u[2462] = {n:"Sesos de jefe de guerra jalató",t:15,d:"Sin duda el jefe de guerra jalató del cual has extraído estos sesos caminará bastante peor.",ep:1,g:501,l:19,wd:true,fm:true,w:1,p:1};
I.u[2463] = {n:"Diente de jefe de guerra jalató",t:47,d:"Hay que decir que no todo el mundo es capaz de extraer un diente de jefe de guerra. Date cuenta de que este diente tiene mucho más valor si está estropeado. No preguntes el porqué, parece ser que se trata de una historia de equilibrio económico.",ep:1,g:502,l:19,wd:true,fm:true,w:1,p:1};
I.u[2464] = {n:"Cola de jefe de guerra jalató",t:65,d:"Quédate agachado en el bosque, observa con paciencia, sin hacer ruido. Entonces, puede que veas a un jefe de guerra jalató feliz moviendo la colita. Sin embargo, solamente podrás ver esta escena durante la época de apareamiento.",ep:1,g:503,l:19,wd:true,fm:true,w:1,p:1};
I.u[2465] = {n:"Cuerno de jefe de guerra jalató",t:47,d:"Es menos manso que su pariente pero el jefe de guerra jalató atraviesa más fácilmente con sus cuernos a los srams y demás razas temerarias. A menudo se encuentran cachos de tejido pegados a sus cuernos, como si se trataran de trofeos.",ep:1,g:504,l:19,wd:true,fm:true,w:1,p:1};
I.u[2466] = {n:"Lengua de jefe de guerra jalató",t:15,d:"Esta lengua huele a Trool podrido...",ep:1,g:505,l:19,wd:true,fm:true,w:1,p:1};
I.u[2467] = {n:"Casco de jefe de guerra jalató",t:47,d:"Los zapateros dicen que este casco es uno de los más resistentes y maleables de la Provincia. Ahora será cuestión de saber qué entienden por \"maleable\". A fuerza de escucharlos se podría entender que son capaces de hacer botas con este casco.",ep:1,g:538,l:18,wd:true,fm:true,w:1,p:1};
I.u[2468] = {n:"Estómago de jefe de guerra jalató",t:15,d:"El interior de este estómago oculta unas cuantas sorpresas. Un dedito de anutrof, un cacho de nariz de osamoda... Casi podríamos volver a construir un héroe con todas estas partes.",ep:1,g:506,l:19,wd:true,fm:true,w:1,p:1};
I.u[2469] = {n:"Gelanillo",t:9,d:"Deja de comerte las uñas con este anillo y ¡empieza a lamerte los dedos!",ep:7,g:47,l:60,wd:true,fm:true,w:5,s:6,p:10000};
I.u[2470] = {n:"Gelatibotas",t:11,d:"Estas botas son muy cómodas en verano porque desprenden un olor a fresa salvaje que disimula fácilmente el de la transpiración de los dedos peludos de un viejo Sadida.",ep:5,g:31,l:60,wd:true,fm:true,w:50,s:6,p:1000};
I.u[2471] = {n:"Gelaturón",t:10,d:"Lo más difícil de superar con este cinturón es que cuando uno tiene hambre está muy tentado en hincarle el diente.",ep:7,g:32,l:60,wd:true,fm:true,w:15,s:6,p:1000};
I.u[2472] = {n:"Gelamú",t:1,d:"Aquí tienes un amuleto que traicionará tu pronunciado afecto a las orgías de Gelatina. Puedes encontrar algo mejor para valorizarte o brillar en sociedad, pero debes asumir hasta el final tu debilidad por la gelatina.",ep:5,g:51,l:60,wd:true,fm:true,w:4,s:6,p:1000};
I.u[2473] = {n:"Capa del Aventurero",t:17,d:"Bonita pero poco funcional, esta capa será un buen apaño para los jóvenes aventureros.",ep:1,g:48,l:1,wd:true,fm:true,w:7,s:5,p:100};
I.u[2474] = {n:"Sombrero del Aventurero",t:16,d:"Este sombrero no tiene gran utilidad aparte la de ahuyentar a las muchachas.",ep:1,g:44,l:1,wd:true,fm:true,w:12,s:5,p:100};
I.u[2475] = {n:"Anillo del Aventurero",t:9,d:"Un divertido pequeño anillo para los principiantes, divertirá a los niños o a los Zurcarák.",ep:1,g:48,l:1,wd:true,fm:true,w:5,s:5,p:10};
I.u[2476] = {n:"Botas del Aventurero",t:11,d:"Son unas botas muy sencillas pero idóneas para los jóvenes que toman camino de la aventura.",ep:1,g:32,l:1,wd:true,fm:true,w:15,s:5,p:10};
I.u[2477] = {n:"Cinturón del aventurero",t:10,d:"Un pequeño cinturón para los aventureros novatos.",ep:1,g:33,l:1,wd:true,fm:true,w:6,s:5,p:10};
I.u[2478] = {n:"Amuleto del Aventurero",t:1,d:"No muy chulo, no muy eficaz, pero divertido cuando tienes el set completo.",ep:1,g:52,l:1,wd:true,fm:true,w:2,s:5,p:10};
I.u[2479] = {n:"Cresta de puerkazo",t:15,d:"Este corte de pelo es una señal de madurez para el puerkazo. Por eso los puedes ver de vez en cuando a los jóvenes Aniripsas prepubertos pasearse por la ciudad con este pelucón sobre la cabeza. Sin embargo, no se atreven realmente a ir hasta las llanuras rocosas con él...",ep:13,g:507,l:18,wd:true,fm:true,w:1,p:1};
I.u[2480] = {n:"Calzoncillo de cuero de puerkazo",t:56,d:"\"Un puerkazo sin calzoncillo es un puerkazo muerto\", esta era la expresión favorita de Dal Mira, una feca adepta al Fequichismo. Su pasa tiempos favorito consistía en obligar sus \"amigos\" a ponerse un calzoncillo de puerkazo no muy limpio sobre la cabeza.",ep:13,g:508,l:18,wd:true,fm:true,w:1,p:1};
I.u[2481] = {n:"Hocico de puerkazo",t:15,d:"Este hocico rosa como las nalgas de los recién nacidos osamodas debe de ser útil para elaborar alguna receta. O también puede servir para hacer un bonito collar de hocico, pero para ello hay que ser valiente y asumir las miradas burlonas del vecindario.",ep:13,g:509,l:18,wd:true,fm:true,w:1,p:1};
I.u[2482] = {n:"Zapato de puerkazo",t:15,d:"Antiguamente, uno de estos zapatos había sido encontrado en las escaleras del gran palacio real. Algunos rumores contaban que ese zapato lo había perdido una puerkacita con prisas que había quedado en regresar a casa a medianoche.",ep:13,g:510,l:18,wd:true,fm:true,w:2,p:1};
I.u[2483] = {n:"Dentadura de puerkazo",t:47,d:"Algunos Puerkazos nacen sin dientes. Otros, después de una buena paliza, se despiertan desdentados, sin conseguir acordarse de lo ocurrido.",ep:13,g:511,l:30,wd:true,fm:true,w:1,p:1};
I.u[2484] = {n:"Tridente Roto",t:15,d:"He aquí un pequeño recuerdo de tu amigo Puerkazo. Ojalá no te guarde rencor hasta el punto de perseguirte por toda la comarca. Ojo, conociendo su carácter, puede que se comporte como un auténtico animal...",ep:13,g:512,l:18,wd:true,fm:true,w:2,p:1};
I.u[2485] = {n:"Vegasombrero",t:16,d:"La \"crème\" de la moda, pero sólo en el noreste de Amakna.",ep:1,g:45,l:40,wd:true,fm:true,w:25,s:10,p:4500};
I.u[2486] = {n:"Oreja de puerkazo",t:106,d:"Esta oreja impone el respeto, es un verdadero trofeo y demuestra que dominas perfectamente a los puerkazos. Sin embargo ten cuidado, no presumas demasiado delante de los demás puerkazos, seguro que ellos no te aclamarán.",ep:13,g:513,l:18,wd:true,fm:true,w:1,p:1};
I.u[2487] = {n:"Caparazón de scorbuto",t:107,d:"Ideal para confeccionar pesadas armaduras, el Scorbuto era antiguamente cazado por la Milicia de Brakmar ya que su tasa de reproducción superaba todos los récords. Ni las gelatinas conseguían reproducirse a esa velocidad.",ep:14,g:514,l:36,wd:true,fm:true,w:1,p:1};
I.u[2488] = {n:"Vísceras de scorbuto",t:15,d:"A simple vista, está claro que estas vísceras no tienen un aspecto muy apetitoso. No te equivocas, las vísceras de Scorbuto son asquerosas incluso si se cocinan con amor.",ep:14,g:445,l:36,wd:true,fm:true,w:1,p:1};
I.u[2489] = {n:"Vegacapa",t:17,d:"Esta elegante capa te convertirá en ferviente defensor de la naturaleza. Incluso algunos que la usaron acabaron militando en el gremio ecologista...",ep:1,g:49,l:58,wd:true,fm:true,w:15,s:10,p:1000};
I.u[2490] = {n:"Pata de scorbuto",t:103,d:"Suele ser poco común de poder recuperar un Pata de Scorbuto en un estado tan bueno. Ojalá la utilices adecuadamente y no para forzar cerraduras. Aunque pensándolo bien...",ep:14,g:515,l:36,wd:true,fm:true,w:1,p:1};
I.u[2491] = {n:"Ojo de Uginak",t:109,d:"Preocupante pero palpitante, este ojo de Uginak no refleja realmente lo que uno pueda esperar que refleje. Por ejemplo, en vez de verte reflejado ves a tu homólogo Dopeul. No intentes entenderlo.",ep:14,g:516,l:51,wd:true,fm:true,w:1,p:1};
I.u[2492] = {n:"Cadena de Uginak",t:15,d:"Obviamente, esta cadena viene de algún Uginak. Antes de que se rompiera servía probablemente para atar el Uginak y evitar que se escapara.",ep:14,g:517,l:51,wd:true,fm:true,w:2,p:1};
I.u[2493] = {n:"Corazón de Uginak",t:15,d:"Este corazón seguirá siéndote fiel. Mientras no lo vendas seguirá contigo dentro de tu mochila. Bonita atención.",ep:14,g:518,l:51,wd:true,fm:true,w:1,p:1};
I.u[2494] = {n:"Pomo de espada",t:15,d:"Seguro que hizo falta un golpe súper potente para romper esta mítica espada. Pues al que utilice la espada de un Uginak le entran unas irresistibles ganas de gritar de alegría. ¡Yaaahhjúúúúúú!",ep:14,g:519,l:51,wd:true,fm:true,w:2,p:1};
I.u[2495] = {n:"Ojo de kólerat",t:109,d:"Este Ojo brilla en la noche, incluso después de haberlo arrancado a su dueño. Puede ser una lámpara muy económica...",ep:2,g:520,l:9,wd:true,fm:true,w:1,p:1};
I.u[2496] = {n:"Cola de Kólerat",t:65,d:"Si la cortas correctamente, la cola del Kólerat sabe a salchichón. Lo más extraño es que si cortas rodajas gruesas, el sabor a salchichón desaparece totalmente. Otra enigma culinaria más en este Mundo.",ep:2,g:521,l:9,wd:true,fm:true,w:1,p:1};
I.u[2497] = {n:"Oreja de kólerat",t:106,d:"Parece ser que si te la acercas a la oreja, oirás el mar, o eso dicen.",ep:2,g:522,l:9,wd:true,fm:true,w:1,p:1};
I.u[2498] = {n:"Vegamú",t:1,d:"La Vegamú tiende a veces a atraer a los Moskitos, porque de lejos la confunden con una amiga. El chasco es todavía más tremendo cuando se encuentran con el portador.",ep:1,g:53,l:40,wd:true,fm:true,w:20,s:10,p:1000};
I.u[2499] = {n:"Hocico de Kólerat",t:15,d:"El Kólerat posee un olfato fuera de lo común. No le llega al tobillo del Uginak pero consigue olerlo a trescientos metros de distancia. Muy práctico para evitar a estos depredadores.",ep:2,g:523,l:9,wd:true,fm:true,w:1,p:1};
I.u[2500] = {n:"Kólerat muerto",t:15,d:"Hiciste bien en recogerlo, está intacto. Muerto pero intacto.",ep:2,g:524,l:9,wd:true,fm:true,w:10,p:1};
I.u[2501] = {n:"Cola de Colmillo Blando",t:65,d:"El Dios Osamodas no soporta que toquen a los animales salvajes: Él grita constantemente \"Es que son tan monos...\" Qué gracioso es, se nota que nunca ha sufrido una ablación por parte del \"mono\".",ep:1,g:525,l:19,wd:true,fm:true,w:1,p:1};
I.u[2502] = {n:"Patita de colmillo blando",t:103,d:"Las patitas de colmillo blando son bastante rebuscadas por los gastrónomos de la región. Posee propiedades mágicas como la de traerle suerte al que las posea. Ya no está nada mal.",ep:1,g:526,l:19,wd:true,fm:true,w:1,p:1};
I.u[2503] = {n:"Tejido de colmillo blando",t:55,d:"Con esto podrás ser tan astuto como el colmillo blando. Si tu sueño consistía en lucir un tejido en la cabeza y pasearte con aires felinos... entre tú y yo, ¡vaya ideas que se te ocurren!",ep:1,g:200,l:19,wd:true,fm:true,w:1,p:1};
I.u[2504] = {n:"Lengua de colmillo blando",t:15,d:"Vete a saber por donde ha pasado esta lengua antes de llegar hasta ti.",ep:1,g:527,l:19,wd:true,fm:true,w:1,p:1};
I.u[2505] = {n:"Croqueta",t:15,d:"Para atraer a un colmillo blando y poder luego domesticarlo, lánzale una croqueta. Ese alimento les chifla. Nunca te lo confesará pero habrás conseguido que sea tu amigo para toda la vida.",ep:1,g:528,l:19,wd:true,fm:true,w:1,p:1};
I.u[2506] = {n:"Cascabel",t:15,d:"Gracias a este cascabel, el culebrón puede oírse desde kilómetros a la ronda. De hecho menos mal, ya que a dos metros se podría confundir con la vegetación lujuriante de las Llanuras de Cania.",ep:13,g:529,l:10,wd:true,fm:true,w:1,p:1};
I.u[2507] = {n:"Lengua Bífida",t:15,d:"Armado con esta lengua podrás flagelar a tu gente. Tus amigos osamodas y sacrógritos se van a poner muy contentos...",ep:13,g:530,l:10,wd:true,fm:true,w:1,p:1};
I.u[2508] = {n:"Veneno de culebrón",t:15,d:"Este temible veneno puede acabar con todo un ejército de Jalatós rabiosos. Incluso antes era utilizado para poner orden en los rebaños, se echaba un poco de veneno en la punta de un bastón y listo.",ep:13,g:531,l:10,wd:true,fm:true,w:1,p:1};
I.u[2509] = {n:"Diente de Culebrón",t:47,d:"Este diente pertenecía a un Culebrón, de eso no hay duda posible. Podemos darnos cuenta de ello observando desde cerca el cacho de diente puntiagudo.",ep:13,g:432,l:10,wd:true,fm:true,w:1,p:1};
I.u[2510] = {n:"Estómago de Jabalí de las Llanuras",t:15,d:"Este estómago puede contener cosas increíbles, una Yopukita se pondría muy contenta al ver todas las espadas que podría guardar dentro.",ep:13,g:532,l:44,wd:true,fm:true,w:1,p:1};
I.u[2511] = {n:"Cuero de jabalí de las llanuras",t:56,d:"Con las propiedades que tiene este cuero, los artesanos zapateros estuvieron dudando mucho antes de confeccionar cinturones y botas. El problema era que este cuero no olía a nada. Muchos clientes pensaban que era cuero falso.",ep:2,g:410,l:44,wd:true,fm:true,w:10,p:1};
I.u[2512] = {n:"Cola de jabalí de las llanuras",t:65,d:"Bastantes cazadores furtivos Brakmarianos coleccionan este trofeo velludo. Hoy en día, se desconocen las razones de este saqueo.",ep:13,g:536,l:44,wd:true,fm:true,w:1,p:1};
I.u[2513] = {n:"Tejido de jabalí de las llanuras",t:55,d:"A la inversa del sabor de su cuero, el tejido del jabalí de las llanuras tiene un olor radical que cura hasta del catarro. Según cuenta la leyenda, este olor permite incluso despertar a un sadida en estado de hibernación.",ep:13,g:537,l:44,wd:true,fm:true,w:1,p:1};
I.u[2514] = {n:"Casco de jabalí de las llanuras",t:47,d:"En general, los Cascos de Jabalí están cubiertos de barro o de tierra, pero de vez en cuando, que no te sorprenda encontrar Biblops de todos los colores. Ya ves, tienes ya un punto en común con el Jabalí de las Llanuras: No os gustan los Biblops de las Llanuras.",ep:13,g:539,l:44,wd:true,fm:true,w:1,p:1};
I.u[2515] = {n:"Hocico de jabalí de las llanuras",t:15,d:"A primera vista, este hocico no está nada fresco. Sin embargo, este es el más fresco y tierno de todos los hocicos.",ep:13,g:540,l:44,wd:true,fm:true,w:1,p:1};
I.u[2516] = {n:"Colmillo de jabalí de las llanuras",t:47,d:"Este colmillo te recordará que el Jabalí de las Llanuras es el más antipático de los jabalíes. Efectivamente, está más gastada que un diente de Wabbit usado por las Zanahowias.",ep:13,g:541,l:44,wd:true,fm:true,w:1,p:1};
I.u[2517] = {n:"Megacapa",t:17,d:"Esta capa pertenecía a un famoso héroe que combatió al terrible Doctor Wily el cual quería invadir y dominar el mundo de los doce con sus propias invocaciones. El doctor Wily se murió antes de que todas sus invocaciones pudieran atacar.",ep:1,g:50,l:45,wd:true,fm:true,w:2,s:76,p:5500};
I.u[2518] = {n:"Capa Viewtiful",t:17,d:"La mismísima Silvia de Jodaw ha cosido esta sorprendente capa con viejas cortinas. Menos mal, no se nota mucho ya que se parece mucho a una fregona hervida en sangre de puerkazo.",ep:1,g:51,l:45,wd:true,fm:true,w:2,s:75,p:5500};
I.u[2519] = {n:"Megasombrero",t:16,d:"Este sombrero es el que necesitas para salir de las situaciones más extremas y brillar en sociedad.",ep:1,g:46,l:44,wd:true,fm:true,w:2,s:76,p:5200};
I.u[2520] = {n:"Casco Viewtiful",t:16,d:"Este casco perteneció al viejo Pepe, famoso héroe de la época antigua. Conocido por sus diversas hazañas, sin embargo es difícil entender lo que motiva la pasión de sus fans.",ep:1,g:47,l:44,wd:true,fm:true,w:2,s:75,p:5200};
I.u[2521] = {n:"Megabotas",t:11,d:"Roll, la amable hermana del dueño de estas botas estaba especializada en taxidermia astral. Antiguamente, nadie era capaz de entender la diferencia entre la taxidermia y la taxidermia astral. Pero hoy en día podemos imaginar que la taxidermia astral permite confeccionar criaturas disecadas astrales. Si eso te parece obvio ahora tal vez sea porque tus ancestros eran tontos.",ep:1,g:33,l:43,wd:true,fm:true,w:2,s:76,p:5000};
I.u[2522] = {n:"Botas Viewtiful",t:11,d:"Estas botas le permitían al famoso Bobo aumentar la potencia de su célebre pata giratoria. También se conoce bajo el nombre de \"Golpe rojo y caliente\". Todavía la gente sigue preguntándose por qué se le llamaba así ya que sus botas eran blancas.",ep:1,g:34,l:43,wd:true,fm:true,w:2,s:75,p:5000};
I.u[2523] = {n:"Megaturón",t:10,d:"Este cinturón ha sido especialmente hecho para proteger las caderas de los héroes, por lo cual no te servirá para nada.",ep:1,g:34,l:45,wd:true,fm:true,w:2,s:76,p:5600};
I.u[2524] = {n:"Cinturón Viewtiful",t:10,d:"Dicen que este cinturón ha sido fabricado por el mismísimo Capitán Bluh. Increíble aunque tú te lo creas siempre todo...",ep:1,g:35,l:46,wd:true,fm:true,w:2,s:75,p:5600};
I.u[2525] = {n:"Corazón del Maestro Cuerbok",t:15,d:"Sin su Corazón , su gorjeo va a ser de peor calidad. Pero sobre todo no le dogas nada porque el Maestro Cuerbok es muy susceptible.",ep:13,g:328,l:160,wd:true,fm:true,w:1,p:1};
I.u[2526] = {n:"Guadaña del Maestro Cuerbok",t:15,d:"En su origen, esta guadaña se usaba para segar Yopukas pero el Maestro Cuerbok se percató rápidamente que si se afilaba demasiado se podía utilizar para segar cualquier tipo de criatura.",ep:1,g:557,l:160,wd:true,fm:true,w:10,p:1};
I.u[2527] = {n:"Kesitufo",t:15,d:"El Maestro nos reserva muchas sorpresas, has encontrado en su bolsillo un famoso queso real, el Kesitufo. Como está empezado se puede suponer que al Maestro Cuerbok le encanta. A nivel del olor no es muy aconsejable guardarlo... Espantarías a todos los que te rodean.",ep:13,g:558,l:160,wd:true,fm:true,w:1,p:1};
I.u[2528] = {n:"Uña de kanugro",t:47,d:"Hay que ser fuerte y rápido para recuperar la Uña de un kanugro. Fuerte para extraerlo y rápido para que el animal no te propine una bofetada gigante.",ep:13,g:559,l:70,wd:true,fm:true,w:1,p:1};
I.u[2529] = {n:"Pócima de metal líquido",t:26,d:"Esta pócima permite proporcionarle uno poco más de realismo a una espada etérea.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2530] = {n:"Carabotas",t:11,d:"Un poco pesadas pero estas bonitas Carabotas harán de ti la reina de la noche.",ep:12,g:35,l:60,wd:true,fm:true,w:50,s:9,p:1000};
I.u[2531] = {n:"Caparasombrero",t:16,d:"Como tú, la tortuga tiene una cabeza muy pequeña. Cae genial ya que este sombrero está especialmente diseñado para ambas.",ep:12,g:48,l:60,wd:true,fm:true,w:24,s:9,p:10000};
I.u[2532] = {n:"Caracapa",t:17,d:"Una capa práctica y resistente que no te volverá famoso pero como ya no lo eras antes... ¿Cual es el problema?",ep:12,g:52,l:60,wd:true,fm:true,w:15,s:9,p:10000};
I.u[2534] = {n:"Kwapa de Hielo",t:17,d:"Ideal para refrescarse en la isla de Moon durante las temporadas de gran calor y perfecta para calmar los ardores de aquellos amigos demasiado atrevidos. Esta capa corresponde perfectamente a las necesidades del aventurero de los tiempos modernos.",ep:8,g:53,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2535] = {n:"Kwakosombrero de Hielo",t:16,d:"Este Kwakosombrero de Hielo te permitirá tener siempre las ideas frescas, incluso cuando ya no se te ocurra nada. Desafortunadamente, no es suficientemente potente para un Yopuka.",ep:13,g:49,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2537] = {n:"Kwakcinto de Hielo",t:10,d:"Idóneo para consolidar la piel de tus caderas, este cinturón te permitirá conservar al fresco lo que tienes bajo la cintura.",ep:12,g:36,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2538] = {n:"Pócima de metal pesado líquido",t:26,d:"Esta pócima permite proporcionarle más realismo a una espada etérea.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2539] = {n:"Pócima de Virutas de Madera",t:26,d:"Esta pócima permite proporcionarle un poco más de realismo a una obra esculpida etérea.",ep:1,g:16,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2540] = {n:"Pócima de Virutas de Madera Resistentes",t:26,d:"Esta pócima permite proporcionarle más realismo a una obra esculpida etérea.",ep:1,g:17,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2541] = {n:"Pócima de metal precioso líquido",t:26,d:"Esta pócima permite proporcionarle mucho más realismo a una espada etérea.",ep:2,g:15,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2542] = {n:"Pócima del Hogar",t:12,d:"Esta pócima permite regresar en cualquier instante a tu hogar.",ep:1,g:142,l:1,wd:true,fm:true,w:2,u:true,p:100};
I.u[2543] = {n:"Pócima de Virutas de Maderas Raras",t:26,d:"Esta pócima permite darle un gran realismo a una obra esculpida etérea.",ep:9,g:18,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2544] = {n:"Cuerbokhoja",t:6,d:"Terriblemente cortante e increiblemente chula, puede que esta hoja cause la envidia de tus amigos Cuerboks.",ep:1,g:32,l:45,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,20,50,false,false],s:8,p:4500};
I.u[2545] = {n:"Cuerbotas",t:11,d:"Estas botas proporcionan a su dueño una increíble impresión de ligereza, pero también pinta de imbécil.",ep:1,g:37,l:45,wd:true,fm:true,w:1,s:8,p:1000};
I.u[2546] = {n:"Cuerbosombrero",t:16,d:"Gracias a este magnífico sombrero tendrás por lo menos tan buena pinta como el tristemente célebre Maestro Cuerbok.",ep:1,g:50,l:45,wd:true,fm:true,w:23,s:8,p:1000};
I.u[2547] = {n:"Cuerbokapa Mastralis",t:17,d:"Antiguamente, los mejores sastres de Amakna se asociaron para utilizar los restos del cadáver del Maestro Cuerbok y hacer con ellos una capa de una belleza endiablada. Ponte esta capa si quieres ser el maestro.",ep:13,g:56,l:127,wd:true,fm:true,w:30,p:41000};
I.u[2549] = {n:"Lata de kanugro",t:15,d:"Esta lata de conserva contiene Kanugro que previamente ha sido descuartizado y enlatado al vacío. Muy práctico para transportar, el Kanugro en trozos es realmente el mejor amigo del hombre.",ep:13,g:560,l:70,wd:true,fm:true,w:1,p:1};
I.u[2550] = {n:"Tejido de Kanugro",t:55,d:"Con este tejido podrás hacerte una peluca maravillosa. Incluso podemos decir que se te verá llegar desde lejos, desde muy lejos.",ep:13,g:561,l:70,wd:true,fm:true,w:1,p:1};
I.u[2551] = {n:"Oreja de kanugro",t:106,d:"Aquí tienes el plato preferido del Uginak: oreja de kanugro con salsa. Pero tradicionalmente, se suele cocinar con mucha menta salvaje y algunas uñas para darle sabor.",ep:13,g:562,l:70,wd:true,fm:true,w:1,p:1};
I.u[2552] = {n:"Ojo de kanugro",t:109,d:"El ojo del kanugro se convirtió en un fenómeno de la moda, a menudo se pueden ver a aventureros con el Ojo alrededor del cuello.",ep:13,g:563,l:70,wd:true,fm:true,w:1,p:1};
I.u[2553] = {n:"Enorme Plomo",t:15,d:"Este es un verdadero plomo. Pesado como él mismo, te romperá los Dofus cuando menos te lo esperes. No hay nada más molesto que un plomazo de este tipo.",ep:1,g:564,l:40,wd:true,fm:true,w:500,p:1};
I.u[2554] = {n:"Costillas de Puerkazo",t:47,d:"Las costillas de puerkazo tienen un sabor particular. Algunas personas adoran comerlas con una salsita picante, otras las prefieren crudas. El puerkazo preferirá las tuyas. Para gustos y sabores...",ep:13,g:159,l:40,wd:true,fm:true,w:1,p:1};
I.u[2555] = {n:"Silla de montar de cuero",t:56,d:"Parece que el Puerkazo es muy delicado y que no lo asume muy bien. Pues había una silla de montar muy bien forrada escondida debajo de sus nalgas. Si se trabaja bien, se podría hacer con esta silla unas excelentes zapatillas.",ep:13,g:565,l:40,wd:true,fm:true,w:5,p:1};
I.u[2556] = {n:"Polen de blop",t:15,d:"Te presentamos la causa de todas las alergias benignas de este mundo. No te descuides, las alergias mortales empiezan siendo benignas. No lleves este tipo de Polen en tus bolsillos si no lo necesitas.",ep:5,g:566,l:34,wd:true,fm:true,w:1,p:1};
I.u[2557] = {n:"Pétalo de blop",t:35,d:"Aunque resulte un tanto extraño, los pétalos de blops no son comestibles, que estén cocidos o no. ¿Quién podía imaginárselo?",ep:5,g:567,l:34,wd:true,fm:true,w:1,p:1};
I.u[2558] = {n:"Blop Muerto",t:15,d:"Hiciste bien en recogerlo, está intacto. Muerto pero intacto.",ep:5,g:568,l:34,wd:true,fm:true,w:10,p:1};
I.u[2559] = {n:"Crines de Trool",t:15,d:"Semejantes crines no suelen ser habituales. Los únicos en poder permitirse el lujo de utilizarlos como sustituto capilar son los Anutrofs más ricos.",ep:4,g:569,l:115,wd:true,fm:true,w:1,p:1};
I.u[2560] = {n:"Hombrera de Trool",t:15,d:"Más vale observar esta hombrera en estas condiciones que admirarla de cerca mientras sigue colgada al hombro de un trool. ¿O acaso pretendes que te haga un desfile?",ep:4,g:570,l:115,wd:true,fm:true,w:5,p:1};
I.u[2561] = {n:"Pulsera de Fuerza de Trool",t:15,d:"Como si el trool necesitara una pulsera de Fuerza... \nEsta increíble máquina de triturar huesos tiene una en cada muñeca.",ep:4,g:571,l:115,wd:true,fm:true,w:5,p:1};
I.u[2562] = {n:"Calzoncillo de trool",t:56,d:"Viendo la pinta de su calzoncillo, parece que el Trool se sienta en cualquier sitio. Aunque gracias a este calzoncillo podemos determinar la edad de su dueño. Obviamente, para eso hay que tener una pizca de olfato...",ep:4,g:572,l:115,wd:true,fm:true,w:1,p:1};
I.u[2563] = {n:"Cala de madera del Tronkónido",t:38,d:"Para el tronkónido, esta cala es un pie, por eso se dice a menudo que el pie puede servir de cala...",ep:9,g:573,l:35,wd:true,fm:true,w:2,p:1};
I.u[2564] = {n:"Cejas de Tronkónido",t:38,d:"¿Querías conocer la técnica usada por el tronkónido para asustar a los visitantes imprudentes? Pues la tienes entre tus manos: un buen par de cejas muy gruesas.",ep:9,g:574,l:35,wd:true,fm:true,w:2,p:1};
I.u[2565] = {n:"Loncha de Tronkónido",t:15,d:"Cuidado, que no se te vaya a apolillar el estómago...",ep:9,g:575,l:35,wd:true,fm:true,w:2,p:1};
I.u[2566] = {n:"Loncha mágica de Tronkónido",t:15,d:"Esta Loncha parece distinta a las demás lonchas de Tronkónido. Cuando fue cortada, una luz cegadora surgió del Tronknido para luego desaparecer, dejando en el suelo la pobre Loncha.",ep:9,g:576,l:35,wd:true,fm:true,w:2,p:1};
I.u[2567] = {n:"Anticipación",t:29,d:"Esta bendición permite ser más vivo para los siguientes combates.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2568] = {n:"Reflejos Subhumanos",t:30,d:"Esta maldición te sume en un estado de semi inconsciencia y tus reflejos se ven disminuidos para el próximo combate.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2569] = {n:"Pergamino de Reflejos Sobrehumanos",t:14,d:"Este pergamino permite ser más vivo para el próximo combate.",ep:1,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2570] = {n:"Pergamino de Reflejos Subhumanos",t:14,d:"Este pergamino permite estar un poquillo inerte para el próximo combate.",ep:1,g:29,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2571] = {n:"Pata de prespic",t:103,d:"¿Cómo hace un prespic -y debes de estar haciéndote la misma pregunta- para ser tan ágil con sus dos míseros dedos en la pata? Vaya misterio...",ep:1,g:577,l:18,wd:true,fm:true,w:1,p:1};
I.u[2572] = {n:"Estómago de prespic",t:15,d:"\"Uno es lo que come\". Esta era la sabia recomendación del famoso cocinero Bontariano Jozé Andréz. Esto explica por qué el estómago del prespic es de color verde, como la hierba que ingiere.",ep:1,g:578,l:18,wd:true,fm:true,w:1,p:1};
I.u[2573] = {n:"Cola de prespic",t:65,d:"Es muy raro que el prespic utilice su cola y menos mal porque la fuerza que tiene en esta es sorprendente. Incluso algunos leñadores han visto Prespics en plena noche transportando troncos de madera con su colilla.",ep:1,g:579,l:18,wd:true,fm:true,w:1,p:1};
I.u[2574] = {n:"Crines de prespic",t:15,d:"Para las fiestas llamadas \"Vi ahí Pío\", estas crines son la mar de bonitas. Llévate contigo a un osamodas y todos creerán que eres una invocación.",ep:1,g:580,l:18,wd:true,fm:true,w:1,p:1};
I.u[2575] = {n:"Cabellera de mediulubo",t:15,d:"Cuando llegaste, el mediulubo tenía seguramente la misma intención que tú, es decir extraerte con más o menos delicadeza la cabellera. Has sido el más rápido...",ep:1,g:581,l:70,wd:true,fm:true,w:1,p:1};
I.u[2576] = {n:"Cabellera de minilubo",t:15,d:"Cuando llegaste, el minilubo tenía seguramente la misma intención que tú, es decir extraerte con más o menos delicadeza la cabellera. Ahora ya no se hará tanto el listillo y tendrá que llevar sombrero toda su vida...",ep:1,g:582,l:22,wd:true,fm:true,w:1,p:1};
I.u[2577] = {n:"Cabellera de maxilubo",t:15,d:"Cuando llegaste, el maxilubo tenía seguramente la misma intención que tú, es decir extraerte con más o menos tacto la cabellera. Trata esta cabellera con respeto, pues hubiera podido ser la tuya.",ep:2,g:583,l:198,wd:true,fm:true,w:1,p:1};
I.u[2578] = {n:"Ojo de mediulubo",t:109,d:"Incluso arrancado, este ojo sigue mirándote de una forma inquietante. Si te fijas con atención verás que el ojo sigue parpadeando. ¡Qué vitalidad tiene este mediulubo!",ep:1,g:584,l:70,wd:true,fm:true,w:1,p:1};
I.u[2579] = {n:"Ojo del minilubo",t:109,d:"Incluso arrancado, este ojo sigue mirándote de una forma inquietante. Si te fijas con atención verás que el ojo sigue parpadeando. ¡Qué vitalidad tiene este minilubo!",ep:1,g:585,l:22,wd:true,fm:true,w:1,p:1};
I.u[2580] = {n:"Ojo de maxilubo",t:109,d:"Es pequeño, redondo y (antiguamente) con pelos... \n¿Qué más podía ser? Obviamente, se trata del ojo del maxilubo...",ep:2,g:586,l:198,wd:true,fm:true,w:1,p:1};
I.u[2581] = {n:"Dientes del maxilubo",t:47,d:"En la familia de los milubos, si buscas el que tiene dientes largos has acertado. Es para llenarte mejor de babas hijito mío...",ep:2,g:587,l:198,wd:true,fm:true,w:1,p:1};
I.u[2582] = {n:"Testículos del maxilubo",t:15,d:"Si el precio de los testículos de mediulubo es escandaloso, entenderás sin dificultad que lo que tienes en las manos vale por lo menos un buen par de... lingotes.",ep:2,g:588,l:198,wd:true,fm:true,w:20,p:1};
I.u[2583] = {n:"Ojo de cangrejo",t:109,d:"A los marineros les gusta mucho este Ojo de cangrejo ya que se pueden capturar en tierra firme.",ep:1,g:589,l:4,wd:true,fm:true,w:1,p:1};
I.u[2584] = {n:"Mano del Boo",t:15,d:"Esta mano de boo está cubierta de lodo. A menos que no haya nada debajo de este lodo, ni siquiera una mano de boo.",ep:2,g:590,l:19,wd:true,fm:true,w:1,p:1};
I.u[2585] = {n:"Corazón de Lodo del Boo",t:15,d:"Con su corazón de lodo, el boo es difícil de clasificar en la cadena alimentaria. Pensándolo un poco, el boo debería estar al final de la cadena.",ep:2,g:591,l:19,wd:true,fm:true,w:1,p:1};
I.u[2586] = {n:"Ala de dragopavo pelirrojo salvaje",t:104,d:"Esta ala huele a azufre. Cualquier buen criador de dragopavos te dirá que es la parte más blanda para el churrasco. Procura poner en adobo la carne antes de asarla ya que el ala es la parte más insípida del bichejo.",ep:2,g:592,l:29,wd:true,fm:true,w:1,p:1};
I.u[2587] = {n:"Machete de leñador",t:19,d:"Este machete es la herramienta indispensable para cualquier leñador. No es que sea realmente útil, pues te será imposible cortar árboles con él, pero si te lo atas al cinturón te sentirás más tranquilo y a salvo de los ataques.",ep:1,g:6,l:3,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,30,30,false,false],c:"CV>2",p:20};
I.u[2588] = {n:"Ala de dragopavo",t:104,d:"Se puede decir que el Dragopavo doméstico es mucho mejor que su primo el salvaje. Para empezar, no tiene un sabor a azufre sino que su carne es sabrosísima y por eso suele ser la comida preferida de los niños.",ep:2,g:593,l:29,wd:true,fm:true,w:1,p:1};
I.u[2589] = {n:"Hachita Ermundo",t:19,d:"Esta pequeña hacha no puede cortar árboles, pero puede servirte para defenderte contra algunos pequeños monstruos. En cambio, si te cruzas con el Minotauroro ya puedes ponerte a correr...",ep:1,g:7,l:6,wd:true,fm:true,w:10,an:17,e:[10,4,1,1,40,40,false,false],p:60};
I.u[2590] = {n:"Hacha Vor\'Om",t:19,d:"Esta serie de hachas ha sido diseñada por un bwork aprendiz forjador. Está bien equilibrada y es relativamente poderosa. Este bwork acababa de crear la hacha de guerra más apropiada para el joven aventurero.",ep:1,g:13,l:12,wd:true,fm:true,w:15,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>10",p:120};
I.u[2591] = {n:"Cola de dragopavo pelirrojo salvaje",t:65,d:"El interés de esta cola es sencillo: pósalo sobre una roca redonda y dale vueltas a la cola. Cuando la cola se para, sigue la dirección indicada por la punta. Así se desplazaron los Sadida durante miles de años.",ep:2,g:594,l:27,wd:true,fm:true,w:1,p:1};
I.u[2592] = {n:"Cortadora de bombú",t:19,d:"Muy ligera y práctica, esta hacha facilita los gestos amplios necesarios para cortar el Bombú con toda seguridad.",ep:13,g:15,l:39,wd:true,fm:true,w:1,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>20&CW>20",p:390};
I.u[2593] = {n:"Podadora de olivioleta",t:19,d:"Esta hacha, hecha con olivioleta, es casi la única que resista a las ondas violetas de la olivioleta. Es como combatir el fuego con fuego.",ep:14,g:14,l:42,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>60",p:420};
I.u[2594] = {n:"Cola de dragopavo",t:65,d:"Cosa extraña, la Cola de dragopavo no posee ningún poder mágico. Igual que la cola del Cocodrail, la Cola le vuelve a crecer en poco tiempo. Una leyenda cuenta también que en una ocasión, de una de estas colas salió un dragopavo. Estás avisado.",ep:2,g:595,l:17,wd:true,fm:true,w:1,p:1};
I.u[2595] = {n:"Hacha de Piedra",t:19,d:"Esta hacha, aunque muy... primitiva, es muy eficaz... bueno, excepto para cortar árboles.",ep:5,g:2,l:51,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>50&CV>60",p:510};
I.u[2596] = {n:"Leche de dragopavo",t:15,d:"A los criadores les gusta poder ordeñar a sus dragopavos. El único problema es que esta Leche no se puede vender porque es asquerosa. Por eso solamente sirve para alimentar a los dragopavitos.",ep:2,g:424,l:29,wd:true,fm:true,w:1,p:1};
I.u[2597] = {n:"Hacha de Brecha",t:19,d:"Esta larga hacha se planta en cualquier intersticio de árbol para poder cortarlo mejor en dos. Su utilidad en combate es la misma ya que el adversario siempre tiene algún que otro intersticio que se puede explotar.",ep:14,g:16,l:54,wd:true,fm:true,w:20,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>70",p:540};
I.u[2598] = {n:"Espina de dragopavo pelirrojo salvaje",t:47,d:"Esta espina es una protuberancia ósea. Los dragopavos las usan tan poco que la gente se preguntaba cómo hacían para desgastarlas tanto. Desde que los biólogos los vieron frotarse contra los Trools, ya se sabe por qué...",ep:2,g:596,l:29,wd:true,fm:true,w:1,p:1};
I.u[2599] = {n:"Escama de dragopavo",t:47,d:"Esta escama la lleva el dragopavo en la espalda. Puede que te sirva para rascarte la entrepierna... Si consigues montar un dragopavo.",ep:2,g:597,l:29,wd:true,fm:true,w:1,p:1};
I.u[2600] = {n:"Cortadora de palabra",t:19,d:"Esta enorme hacha hace un ruido tremendo cuando se cae sobre algo, lo cual deja sin habla a los aventureros que han presenciado el golpe. No es poco.",ep:14,g:17,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>30&CV>30&CA>30",p:660};
I.u[2601] = {n:"Hacha Darsson",t:19,d:"Darsson era un audaz anutrof tan hábil como un panadero sin brazos. Ya que a menudo se le caía la pala durante los combates, tuvo la ingeniosa idea de atar un hacha de recambio a su cinturón. Eso le salvó varias veces la vida, hasta que dejó caer su hacha...",ep:14,g:18,l:57,wd:true,fm:true,w:15,an:17,e:[12,4,1,1,30,30,false,false],c:"CC>20&CA>20&CV>20",p:570};
I.u[2602] = {n:"Pétalo de Kosakepega",t:35,d:"El pétalo de Kosakepega no es más gordo que un ojo de cangrejo y lleva varias burbujas pegajosas que tienen una textura esponjosa cuando se tocan. Generalmente sirven para taponar los agujeros de los tejados después de las fuertes tempestades de fin de año.",ep:12,g:598,l:12,wd:true,fm:true,w:1,p:1};
I.u[2603] = {n:"Troceadora de Partes",t:19,d:"Esta hacha es muy útil para separar algunas partes recalcitrantes de un árbol, en particular, las pequeñas ampollas del tronco, esto con el objetivo de tener un árbol perfectamente liso y redondo.",ep:13,g:2,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CS>30",p:660};
I.u[2604] = {n:"Bardacha del Miliciano",t:19,d:"Los milicianos de Amakna emplean principalmente esta bardacha. Su longitud y su eficacia deben probablemente compensar otros aspectos...",ep:13,g:3,l:78,wd:true,fm:true,w:30,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>30&CS>30&CW>30&CC>5",p:780};
I.u[2605] = {n:"Piel de Kosakepega",t:59,d:"No te extrañes si te dicen que la piel de Kosakepega es pegajosa. Gracias a ella se puede pegar cualquier cosa al techo. Hay que confesar que también es gracias al campesino que patentó la idea: un cierto A. Royo Desivo",ep:12,g:599,l:12,wd:true,fm:true,w:1,p:1};
I.u[2606] = {n:"Hachilla Sabia",t:19,d:"Las múltiples inscripciones grabadas en esta gruesa hachilla recuerdan conceptos Amaknienses básicos. Su inventor, Claus Ansipedi, deseaba inculcarles un mínimo de cultura a los brutos empedernidos... en vano, se murió cuando su cráneo fue partido en dos.",ep:4,g:4,l:81,wd:true,fm:true,w:30,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CA>50&CI>50",p:810};
I.u[2607] = {n:"Kosakepega muerto",t:15,d:"Hiciste bien en recogerlo, está intacto. Muerto pero intacto.",ep:12,g:600,l:14,wd:true,fm:true,w:10,p:1};
I.u[2608] = {n:"Hacha Chachi",t:19,d:"Esta hacha te permitirá partir bworks en dos silbando los más gandes éxitos de Chulo Iflesias.",ep:18,g:1,l:84,wd:true,fm:true,w:18,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>100&CS>50",p:840};
I.u[2609] = {n:"Caparazón verde vacío",t:107,d:"¿Pero dónde está su dueño? Habrá salido a comprar pan con tomate...",ep:7,g:601,l:24,wd:true,fm:true,w:2,p:1};
I.u[2610] = {n:"Caparazón rojo vacío",t:107,d:"¿Pero dónde está su dueño? Se habrá mudado hace poco...",ep:7,g:602,l:24,wd:true,fm:true,w:2,p:1};
I.u[2611] = {n:"Caparazón amarillo vacío",t:107,d:"¿Pero dónde está su dueño? Estará haciendo una siesta dentro...",ep:7,g:603,l:24,wd:true,fm:true,w:2,p:1};
I.u[2612] = {n:"Hacha Pesquera",t:19,d:"Los marineros expertos utilizan esta larga hacha para enfrentarse a los pescados gigantes que atacan sus barcos. Podemos imaginar bastante bien los daños que puede causar contra monstruos más pequeños.",ep:14,g:4,l:87,wd:true,fm:true,w:32,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>50&CA>50",p:870};
I.u[2613] = {n:"Caparazón azul vacío",t:107,d:"¿Pero dónde está su dueño? Estará bajo la ducha...",ep:7,g:604,l:24,wd:true,fm:true,w:2,p:1};
I.u[2614] = {n:"Hacha Damesa",t:19,d:"Damesa era una hermosa princesa conocida por su candor y su magnífica tez blanquecina. Todo el mundo se sorprendió mucho cuando, durante una incursión Bwork en su ciudad, sacó esta hacha y aniquiló ella misma la mitad del ejército adverso.",ep:18,g:5,l:90,wd:true,fm:true,w:28,an:17,tw:true,e:[10,4,1,1,40,40,false,false],c:"CV>150&CW>50&CS>250",p:900};
I.u[2615] = {n:"Hacha del Lookabeer",t:19,d:"Esta hacha es famosa por su eficacia para acabar definitiva y rápidamente con una pelea entre Anutrofs borrachos.",ep:18,g:8,l:96,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>120",p:960};
I.u[2616] = {n:"Hala Barda",t:19,d:"El nombre de esta hacha viene de la sorpresa que produjo la actuación de Shikakira, primera trovadora de la historia de Amakna, en la ciudad de Brakmar. Cuando el público la oyó entonar notas tan agudas como su hacha, se exclamó: \"Hala, una Barda\".",ep:14,g:7,l:99,wd:true,fm:true,w:40,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>100&CS>100",p:990};
I.u[2617] = {n:"Rodaja de Nozdekoko",t:15,d:"Aaahh... Por fin un objeto que te hace pensar en las vacaciones. Esta Agencia de Viajes no tardará en tener noticias tuyas...",ep:12,g:605,l:14,wd:true,fm:true,w:1,p:1};
I.u[2618] = {n:"Kokopaja",t:15,d:"Para tomarse un refresco, no hay nada como una pajita de color. Ahora solamente queda encontrar un agujero en la nozdekoko.",ep:12,g:433,l:14,wd:true,fm:true,w:1,p:1};
I.u[2619] = {n:"Kokoleche",t:15,d:"Esta sí que es una buena idea: tener kokoleche en botella permite beber cuando uno lo desea, esté donde esté.",ep:12,g:423,l:14,wd:true,fm:true,w:1,p:1};
I.u[2620] = {n:"Ron de Calidad",t:15,d:"Este ron saldrá de una cava muy famosa. Al menos que se haya quedado dentro de algún bolsillo durante generaciones.",ep:12,g:177,l:94,wd:true,fm:true,w:1,p:1};
I.u[2621] = {n:"Barba de Le Chuko",t:15,d:"Acabas de arrancar los pelos de la barbilla de Le Chuko. Cosa extraña, también arrancaste los Dientes sin querer.",ep:12,g:606,l:94,wd:true,fm:true,w:1,p:1};
I.u[2622] = {n:"Hebilla de Le Chuko",t:15,d:"Desde esta hebilla, siete generaciones de piratas te contemplan.",ep:12,g:607,l:94,wd:true,fm:true,w:2,p:1};
I.u[2623] = {n:"Bwak Esquelético",t:15,d:"Los ganaderos siempre han pensado que los Bwaks volaban hasta un lugar lejano al final de su vida. Sin embargo, este Bwak es una excepción a la regla.",ep:12,g:608,l:94,wd:true,fm:true,w:1,p:1};
I.u[2624] = {n:"Hoja de kokoko",t:36,d:"Los aventureros más valientes quieren conseguir a toda costa una de estas hojas como recuerdo para no volver jamás a esta isla maldita. ¿Por qué no?",ep:12,g:609,l:42,wd:true,fm:true,w:1,p:1};
I.u[2625] = {n:"Muñeca Bodú Thierry",t:15,d:"Una fuerza se desprende de esta muñeca pero tienes la extraña sensación de que está llamando a alguien.",ep:12,g:610,l:51,wd:true,fm:true,w:2,p:1};
