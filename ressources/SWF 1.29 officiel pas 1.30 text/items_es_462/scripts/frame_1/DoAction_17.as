I.u[6924] = {n:"Dagas del Bandido",t:5,d:"Estas afiladas dagas son muy populares entre los bandidos y, por las mismas razones, impopulares entre los aventureros. Disponen de una magia que les permite robar kamas a sus adversarios. Es una especie de impuesto directo recaudado de forma muy original.",ep:1,g:9,l:12,wd:true,fm:true,w:1,an:13,e:[5,3,1,1,30,50,false,false],s:25,p:600};
I.u[6925] = {n:"Cinturón del Bandido",t:10,d:"Este cinturón te sentará como anillo al dedo si algún día te pasas al bando de los salteadores. Mientras tanto, te hará pasar por una persona más ridícula de lo que pareces.",ep:1,g:72,l:15,wd:true,fm:true,w:2,s:25,p:850};
I.u[6926] = {n:"Sombrero del prespic",t:16,d:"Con este sombrero de Prespic en la cabeza, te parecerás casi a Devi Cloquet, célebre cazadora de los tiempos modernos, dispuesta a hacerlo todo para ocultar su incipiente calvicie. Si querías hacer lo mismo, mala suerte, tendrás que contentarte con esta peluca pelirroja que, sin duda alguna, desprenderá un horrible olor en cuanto se ponga a llover.",ep:1,g:81,l:36,wd:true,fm:true,w:2,s:31,p:3600};
I.u[6927] = {n:"Capa de prespic",t:17,d:"Esta pequeña capa pelirroja también se puede usar como alfombrilla para poner los pies cuando te levantas de la cama. Eso te permitirá modernizar tu casa de una manera muy económica.",ep:1,g:75,l:37,wd:true,fm:true,w:3,s:31,p:3800};
I.u[6928] = {n:"Anillo del prespic",t:9,d:"Sobrio pero original, este anillo seducirá a los aventureros ávidos de lujosos trajes pero totalemente pelados, hasta el punto de despojar a ridículas criaturillas salvajes para poder adornarse con joyas. La tacañería no tiene límite.",ep:1,g:72,l:38,wd:true,fm:true,w:1,s:31,p:4000};
I.u[6929] = {n:"Cinturón del prespic",t:10,d:"Idóneo para tener siempre tus caderas calentitas, este cinturón tiene el inconveniente de irritar las pieles suaves. Sólo para duros de pelar.",ep:1,g:71,l:33,wd:true,fm:true,w:2,s:31,p:3000};
I.u[6930] = {n:"Casco del crujidor",t:16,d:"Este casco directamente tallado en la piedra vale su peso en oro. Te protegerá contra los ataques de un Crujibola y podrás al mismo tiempo dar cabezazo tras cabezazo al igual que un Deseobola. Con este casco, tus enemigos no darán pie con bola.",ep:5,g:85,l:44,wd:true,fm:true,w:200,s:26,p:5300};
I.u[6931] = {n:"Crujicapa",t:17,d:"Esta capa de piedra es un poco rígida, pero no deja de ser una excelente protección contra lapidaciones o más peligroso todavía, escupitajos de Crujidor.",ep:5,g:77,l:46,wd:true,fm:true,w:1,s:26,p:5800};
I.u[6933] = {n:"Botas del Crujidor",t:11,d:"Increíblemente pesadas pero no menos eficaces, estas botas de piedra te permitirán por fin tener una excusa para arrastrar los pies cuando tengas que defender a tu recaudador durante un combate perdido de antemano.",ep:5,g:52,l:47,wd:true,fm:true,w:10,s:26,p:4700};
I.u[6934] = {n:"Crujimuleto",t:1,d:"Este amuleto es tan pesado como un Blop bulímico, esto debería desanimar a aventureros demasiado frágiles para poder llevarlo. En cambio, si consigues soportar su peso, hay que reconocer que te favorecerá muchísimo.",ep:5,g:77,l:46,wd:true,fm:true,w:10,s:26,p:4600};
I.u[6935] = {n:"Cinturón del crujidor",t:10,d:"Si llevas este cinturón alrededor de las caderas, serás un aventurero respetado. Si lo llevas sobre la cabeza como si fuera una venda para el pelo, todos se reirán de ti en el poblado de Astrub.",ep:5,g:74,l:45,wd:true,fm:true,w:10,s:26,p:5400};
I.u[6936] = {n:"Escarasombrero verde",t:16,d:"Con este sombrero original, podrás hacer por fin que tus amigos crean que eres un cazador de escarahojas.",ep:3,g:78,l:44,wd:true,fm:true,w:2,s:27,p:5200};
I.u[6937] = {n:"Escarasombrero rojo",t:16,d:"Con este sombrero original, podrás hacer por fin que tus amigos crean que eres un cazador de escarahojas.",ep:3,g:77,l:44,wd:true,fm:true,w:2,s:28,p:5200};
I.u[6938] = {n:"Escarasombrero blanco",t:16,d:"Con este sombrero original, podrás hacer por fin que tus amigos crean que eres un cazador de escarahojas.",ep:3,g:79,l:44,wd:true,fm:true,w:2,s:29,p:5200};
I.u[6939] = {n:"Escarasombrero azul",t:16,d:"Con este sombrero original, podrás hacer por fin que tus amigos crean que eres un cazador de escarahojas.",ep:3,g:76,l:44,wd:true,fm:true,w:2,s:30,p:5200};
I.u[6940] = {n:"Escaracapa verde",t:17,d:"¿Quién no ha soñado nunca con ponerse una capa-caparazón de escarahojas? En cuanto te la pongas podrás hacerlo todo como un verdadero escarahoja, y tal vez consigas desplazarte deslizándote o derrapando. Una buena manera de dejar a una horda de trools totalmente flipada...",ep:3,g:74,l:45,wd:true,fm:true,w:2,s:27,p:5500};
I.u[6941] = {n:"Escaracapa azul",t:17,d:"¿Quién no ha soñado nunca con ponerse una capa-caparazón de escarahojas? En cuanto te la pongas podrás hacerlo todo como un verdadero escarahoja, y tal vez consigas desplazarte deslizándote o derrapando. Una buena manera de dejar a una horda de trools totalmente flipada...",ep:3,g:73,l:45,wd:true,fm:true,w:2,s:30,p:5500};
I.u[6942] = {n:"Escaracapa roja",t:17,d:"¿Quién no ha soñado nunca con ponerse una capa-caparazón de escarahojas? En cuanto te la pongas podrás hacerlo todo como un verdadero escarahoja, y tal vez consigas desplazarte deslizándote o derrapando. Una buena manera de dejar a una horda de trools totalmente flipada...",ep:3,g:72,l:45,wd:true,fm:true,w:2,s:28,p:5500};
I.u[6943] = {n:"Escaracapa blanca",t:17,d:"¿Quién no ha soñado nunca con ponerse una capa-caparazón de escarahojas? En cuanto te la pongas podrás hacerlo todo como un verdadero escarahoja, y tal vez consigas desplazarte deslizándote o derrapando. Una buena manera de dejar a una horda de trools totalmente flipada...",ep:3,g:71,l:45,wd:true,fm:true,w:2,s:29,p:5500};
I.u[6944] = {n:"Escaranillo verde",t:9,d:"Este anillo te permitirá tener un recuerdo conmovedor de todos los escarahojas que has exterminado y te preguntarás entonces si todo eso valía realmente la pena.",ep:3,g:69,l:43,wd:true,fm:true,w:2,s:27,p:5000};
I.u[6945] = {n:"Escaranillo rojo",t:9,d:"Este anillo te permitirá tener un recuerdo conmovedor de todos los Escarahojas que has exterminado y te preguntarás entonces si todo eso valía realmente la pena.",ep:3,g:68,l:43,wd:true,fm:true,w:2,s:28,p:5000};
I.u[6946] = {n:"Escaranillo blanco",t:9,d:"Este anillo te permitirá tener un recuerdo conmovedor de todos los Escarahojas que has exterminado y te preguntarás entonces si todo eso valía realmente la pena.",ep:3,g:67,l:43,wd:true,fm:true,w:2,s:29,p:5000};
I.u[6947] = {n:"Escaranillo azul",t:9,d:"Este anillo te permitirá tener un recuerdo conmovedor de todos los Escarahojas que has exterminado y te preguntarás entonces si todo eso valía realmente la pena.",ep:3,g:70,l:43,wd:true,fm:true,w:2,s:30,p:5000};
I.u[6948] = {n:"Escaracinto verde",t:10,d:"Antiguamente el Escaracinto servía para dar una indicación sobre su nivel en combates con los puños. Tener un Escaracinto Verde significaba que uno era un novato, uno rojo significaba que se lamía la sangre de los enemigos una vez estos exterminados, uno blanco significaba que uno era una verdadera máquina exterminadora de enemigos y una azul significaba que no se tenía suficientes kamas para comprar uno de los tres Escaracintos mencionados.",ep:3,g:67,l:46,wd:true,fm:true,w:2,s:27,p:5600};
I.u[6949] = {n:"Escaracinto blanco",t:10,d:"Antiguamente el escaracinto servía para dar una indicación sobre su nivel en combates con los puños. Tener un escaracinto verde significaba que uno era un novato, uno rojo significaba que se lamía la sangre de los enemigos una vez estos exterminados, uno blanco significaba que uno era una verdadera máquina exterminadora de enemigos y una azul significaba que no se tenía suficientes kamas para comprar uno de los tres escaracintos mencionados.",ep:3,g:69,l:46,wd:true,fm:true,w:2,s:29,p:5600};
I.u[6950] = {n:"Escaracinto rojo",t:10,d:"Antiguamente el escaracinto servía para dar una indicación sobre su nivel en combates con los puños. Tener un escaracinto verde significaba que uno era un novato, uno rojo significaba que se lamía la sangre de los enemigos una vez estos exterminados, uno blanco significaba que uno era una verdadera máquina exterminadora de enemigos y una azul significaba que no se tenía suficientes kamas para comprar uno de los tres escaracintos mencionados.",ep:3,g:68,l:46,wd:true,fm:true,w:2,s:28,p:5600};
I.u[6951] = {n:"Escaracinto azul",t:10,d:"Antiguamente el escaracinto servía para dar una indicación sobre su nivel en combates con los puños. Tener un escaracinto verde significaba que uno era un novato, uno rojo significaba que se lamía la sangre de los enemigos una vez estos exterminados, uno blanco significaba que uno era una verdadera máquina exterminadora de enemigos y una azul significaba que no se tenía suficientes kamas para comprar uno de los tres escaracintos mencionados.",ep:3,g:70,l:46,wd:true,fm:true,w:2,s:30,p:5600};
I.u[6952] = {n:"Sombrero del Mediulubo",t:16,d:"Con esta cabeza de mediulubo sobre el colodrillo, te parecerás a Gulio Iflesias, el famoso trovador cuya cabeza se encontró atrapada dentro del hocico de un mediulubo en agonía. Pues no soportó las canciones que el trovador quiso cantarle.",ep:1,g:131,l:61,wd:true,fm:true,w:4,s:32,p:10000};
I.u[6953] = {n:"Botinas del Mediulubo",t:11,d:"Estos botines recubiertos con pelos de mediulubo son practiquísimas para limpiar el polvo del parqué o sencillamente para limpiar la cabeza de tus rivales cuando están agonizando en el suelo.",ep:1,g:76,l:61,wd:true,fm:true,w:2,s:32,p:9700};
I.u[6954] = {n:"Capa del Mediulubo",t:17,d:"Esta capa de mediulubo constituye una excelente protección contra el frío pero también contra los aventureros cuyo sentido olfativo esté demasiado desarrollado.",ep:1,g:99,l:64,wd:true,fm:true,w:5,s:32,p:11000};
I.u[6955] = {n:"Cinturón del Mediulubo",t:10,d:"Utilizado como látigo, este cinturón puede revelarse más eficaz de lo que parece, para motivar de nuevo a tus compañeros de viaje, cuando el amor por el riesgo empieza a faltarles...",ep:1,g:92,l:49,wd:true,fm:true,w:2,s:32,p:6500};
I.u[6956] = {n:"Anillo de Mediulubo",t:9,d:"Cuidado, este anillo hará que tu dedo tenga un olor apestoso. Un olor que podría encubrir otro. Tal vez sea cosa buena para tu dedo y para tu entorno...",ep:1,g:103,l:51,wd:true,fm:true,w:2,s:32,p:7000};
I.u[6957] = {n:"Hoja del Crujidor",t:6,d:"Antiguamente, esta espada servía para cortar bloques de granito para construir las murallas de ciudades prestigiosas tales como Bonta o Brakmar. Hoy en día, esta arma es ante todo rebuscada por su capacidad para aplastar cualquier tipo de criatura viviente, con su consentimiento o sin él.",ep:5,g:54,l:37,wd:true,fm:true,w:10,an:14,tw:true,e:[5,6,1,1,50,50,false,true],s:26,p:3800};
I.u[6958] = {n:"Genialísimo Sombrero de Turtoga",t:16,d:"El último grito en la moda. Esta cofia te dará un estilo único y te permitirá mirar bajo las faldas de las jóvenes Ocras con toda discreción. Perfecta para las noches etílicas.",ep:5,g:82,l:22,wd:true,fm:true,w:12,p:1525};
I.u[6961] = {n:"Anillo del Bandido",t:9,d:"Este anillo es tan popular para los dentistas como para los bandidos que lo utilizan para romper uno a uno los dientes de los imprudentes. Es una forma de prevenir la aparición de caries como otra cualquiera.",ep:1,g:77,l:17,wd:true,fm:true,w:2,s:25,p:1000};
I.u[6962] = {n:"Regalo: Dofusiano",t:89,d:"Ni por todos los Dofus del Mundo te diríamos lo que hay en este paquete, pero te vamos a dar una pista: con lo que hay dentro te lo pasarás bomba y hasta montarás una fiesta.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6963] = {n:"Bolas del Minotobola",t:12,d:"Estas enormes bolas son realmente deliciosas. Siempre vienen por pares.",ep:1,g:143,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6964] = {n:"Pócima de ciudad: Brakmar",t:12,d:"Esta pócima a base de arroz permite que todas las personas de alineación brakmariana puedan volver a Brakmar instantáneamente.",ep:1,g:145,l:1,wd:true,fm:true,w:1,c:"Ps=2|Ps=0|Ps=3",u:true,p:1};
I.u[6965] = {n:"Pócima de ciudad: Bonta",t:12,d:"Esta pócima a base de arroz permite que todas las personas de alineación Bontariana puedan volver a Bonta instantáneamente.",ep:1,g:144,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=0|Ps=3",u:true,p:1};
I.u[6966] = {n:"Pergamino del hechizo especial Mala Sombra",t:75,d:"(Haz doble clic para aprender el hechizo) \nEste pergamino te permite aprender el hechizo Mala Sombra... Sólo para srams.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"PG=4",u:true,p:10000};
I.u[6967] = {n:"Pergamino de rango de mercenario: aprendiz",t:14,d:"Este pergamino permite que un mercenario sea ascendido a aprendiz.",ep:1,g:5,l:1,wd:false,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6968] = {n:"Pergamino de rango de mercenario: mercenario",t:14,d:"Este pergamino cerifica que ya eres un mercenario de verdad.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6969] = {n:"Pergamino de rango de mercenarior: gran mercenario",t:14,d:"Este pergamino permite que un mercenario sea ascendido a gran mercenario.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6970] = {n:"Pergamino de rango de mercenario: maestro mercenario",t:14,d:"Este pergamino permite que un mercenario sea ascendido a maestro mercenario.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6971] = {n:"Clint de discípulo seriane",t:16,d:"Este sombrero es una réplica bastante buena del famoso Clint: Será perfecto para los discípulos `SRVT:MERCENARY_SHORT_NAME` que quieran hacerse pasar por el maestro.",ep:1,g:38,l:1,wd:false,fm:true,w:20,c:"Ps=3",p:1};
I.u[6975] = {n:"Clint de neófito",t:16,d:"Este superpoderso sombrero es la insignia de SRVT:MERCENARY_SHORT_NAME`. Tiene el poder de protegerte de la lluvia y del sol, lo cual no está nada mal...",ep:1,g:38,l:1,wd:false,fm:true,w:20,p:1};
I.u[6978] = {n:"Peki",t:18,d:"Esta criatura se parece de lejos a un Wauwau. Su cabeza demuestra claramente que ha vivido enormes traumatismos que le llevaron a hacerse vegetariana. Sólo se alimenta con vegetales y plantas que crecen en la isla de Pandala.",ep:3,g:12,l:60,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6979] = {n:"Capa Depevepé",t:17,d:"Esta capa ofrece una buena protección contra los ataques de otros aventureros.",ep:1,g:59,l:50,wd:false,fm:true,w:10,p:5000};
I.u[6980] = {n:"Dofus Vulbis",t:23,d:"Gracias a este Dofus, gozarás de una gran popularidad con el sexo opuesto. Si solamente dejaras de creer ingenuamente a todo lo que te cuentan acerca de los Dofus y de sus virtudes...",ep:11,g:4,l:6,wd:false,fm:true,w:1,p:500000};
I.u[6981] = {n:"Dagas Heladas",t:5,d:"La hoja de estas dagas es de hielo lo cual resulta muy práctico para refrescar el aliento de tus enemigos. Ábreles la boca, planta en ella tu gruesa daga helada y listo.",ep:19,g:44,l:150,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>150",p:15};
I.u[6982] = {n:"Dagas de la Agonía",t:5,d:"Estas dagas estuvieron al remojo en la sangre de numerosas criaturas demoníacas, como por ejemplo la de niños, eso le confiere un toque realmente original.",ep:18,g:50,l:46,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5775};
I.u[6983] = {n:"Dagas de Agresión",t:5,d:"Aunque se afilen sólo una vez al año, estas dagas son muy letales. Están animadas por una de las más oscuras magias, se desplazan a veces solas durante la noche para plantarse, en el mejor de los casos, en las nalgas de los imprudentes... Otra historia que se cuenta a los jóvenes Yopukas para asustarlos.",ep:19,g:47,l:143,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>250&CA>100",p:15};
I.u[6984] = {n:"Dagas del Aprendiz Matador de Jalatines",t:5,d:"Estas dagas han pertenecido a un pobre Sadida, cuya riqueza fulgurante dejará huella en la historia de Amakna. Este sadida había decidido dedicar su existencia a la caza de los jalatines, lo cual provocaba la risa de todos los habitantes del pueblo. Incluso algunos curiosos venían de lejos para verlo cazar estas ridículas criaturas y para burlarse de él. Su venganza fue terrible, ya que entre tanto, se había vuelto lo suficientemente rico para pagar recompensas por las cabezas de aquellos que se habían reído de él.",ep:18,g:46,l:113,wd:true,fm:true,w:15,an:13,tw:true,e:[5,3,1,1,25,50,false,false],c:"CS>300&CA>100",p:32750};
I.u[6986] = {n:"Escudo del Monte Puaj Destrozado",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:1,l:1,wd:false,fm:true,w:20,c:"BI=non équipable",p:5400};
I.u[6987] = {n:"Piedrecita de Alma Azarosa",t:83,d:"Este runa ofrece una pequeña oportunidad de capturar almas no demasiado grandes... Está bien pero no es lo mejor que exista...",ep:5,g:1,l:1,wd:false,fm:true,w:1,tw:true,p:1250};
I.u[6988] = {n:"Sulik",t:16,d:"Antiguamente, lo llevaba puesto un Xelor salvaje cuya hermana había sido raptada por unos esclavistas sin escrúpulos. Este sombrero hará de ti un salvaje verdaderamente original.",ep:19,g:92,l:172,wd:true,fm:true,w:10,p:56100};
I.u[6989] = {n:"Krokop",t:16,d:"Este sombrero ha sido confeccionado hace mucho tiempo por unos sastres aprendices que querían protegerse contra las crisis de ira de Mirko el sastre. Este tenía la mala costumbre de diezmar a sus aprendices dándoles patadas en plena cabeza cuando no trabajaban suficientemente deprisa. Era una manera como otra para motivarlos en su trabajo.",ep:19,g:86,l:120,wd:true,fm:true,w:20,p:37025};
I.u[6990] = {n:"Falena",t:16,d:"Esta cofia es un homenaje a los primos lejanos de los Moskitos, las Falenas. Mucho más gordas, pero más buenas que los Moskitos, las Falenas tenían la mala costumbre de intentar reproducirse con todo y con cualquiera, pero sobre todo con cualquiera lo cual condujo a una extinción progresiva de su especie. Esta terrible historia no ha dejado indiferente a nadie y hoy en día, es corriente llamarle Falena a una persona que elige muy mal sus parejas.",ep:19,g:87,l:113,wd:true,fm:true,w:10,p:32925};
I.u[6991] = {n:"Guayaba",t:16,d:"Esta extraño sombrero se parece a una fruta muy gruesa, deshidratada y en descomposición, un poco lo que te ocurre a ti cuando te pasas la noche metido en la taberna.",ep:18,g:88,l:46,wd:true,fm:true,w:10,p:5800};
I.u[6992] = {n:"Kanipío",t:16,d:"Se trata de una versión embellecida de la célebre máscara Kaníbola, el Kanipío te permitirá hacerte pasar, en tu pandilla de amigos, por un verdadero cazador de Píos.",ep:12,g:89,l:55,wd:true,fm:true,w:5,p:8000};
I.u[6993] = {n:"Capa Gada",t:17,d:"Esta capa pertenecía a un famoso trovador que solía pasar sus vacaciones en la Isla de Moon. Una de sus canciones titulada \"Si yo fuera recaudador\" causó tal escándalo que fue quemado vivo cerca del Banco de Bonta... Afortunadamente, uno de los que estaban presentes consiguió rescatar su manto y apagar las llamas que lo estaban consumiendo...",ep:18,g:79,l:46,wd:true,fm:true,w:10,p:5600};
I.u[6994] = {n:"Capa Gorrogoma",t:17,d:"Esta creación híbrida entre una capa y un gorro hecho con una materia totalmente desconocida, es realmente sorprendente. Si fuera de cuero, le habría encantado a Capitán Chafer.",ep:1,g:80,l:58,wd:true,fm:true,w:10,p:8875};
I.u[6995] = {n:"Capa Dhora",t:17,d:"Esta poderosísima capa puede arrebatar el vigor de tus adversarios... una cualidad que comparte con la Momia Nova.",ep:18,g:81,l:105,wd:true,fm:true,w:10,p:28300};
I.u[6996] = {n:"Anillo Stradamus",t:9,d:"Stradamus era un viejo Anutrof, alcohólico perdido, que leía el futuro en las jarras de cerveza. Cuenta la leyenda que según su voluntad, fue enterrado verticalmente en una de las paredes de la taberna de Brakmar, para que \"ningún cobarde pueda derramar una cerveza sobre su tumba\". La típica leyenda que propagan los Maestros Serianes cuando organizan sus noches-borracheras.",ep:18,g:78,l:48,wd:true,fm:true,w:5,p:6075};
I.u[6997] = {n:"Anillo Fiutiuro",t:9,d:"La que creó este anillo pensaba que el fin del mundo estaba por llegar, se pasaba los días grabando sobre mesas de madera con su engastador que no había futuro para los habitantes de Amakna. Lo que sucedió a continuación sirvió para demostrarle que se equivocó.",ep:18,g:79,l:70,wd:true,fm:true,w:5,p:12730};
I.u[6998] = {n:"Alianza de Elya Wood",t:9,d:"Esta pequeña alianza está perfectamente adaptada para los deditos de Aniripsas. En cambio los Yopukas casi no pueden usarla por culpa de los dedos amorcillados que tienen y de su incapacidad para entender donde se pone una alianza.",ep:18,g:84,l:120,wd:true,fm:true,w:15,s:39,p:36000};
I.u[6999] = {n:"Medalla Hilama",t:1,d:"Hilama era un gran jefe espiritual que oficiaba en el lugar más apartado de las montañas. Tanto se aburría que se pasaba el día cosiendo gorritos amarillos para sus discípulos. La locura no tiene límites.",ep:18,g:83,l:31,wd:true,fm:true,w:3,p:2800};
I.u[7000] = {n:"Bambumuleto",t:1,d:"Este ridículo pequeño cacho de bambú esta dotado con poderes mágicos muy extraños. Antiguamente los llevaban los jóvenes Pandawas, cuando pasaban la pubertad. Tal vez tengas que esperar todavía unos cuantos años antes de atártelo al cuello...",ep:18,g:78,l:40,wd:true,fm:true,w:5,p:4400};
I.u[7001] = {n:"Talismán del Segador de Avena",t:1,d:"\"Avena tomando el sol, malvado girasol, quesos cebolla y pan ¿Quieres más Pacharán?\". Esto cantaba volviendo de sus vacaciones, pasadas en la Isla de Moon, el célebre trovador y agricultor Juaquín Siavena que tenía la costumbre de cantar cuando segaba...",ep:18,g:84,l:55,wd:true,fm:true,w:10,p:8000};
I.u[7002] = {n:"La Resinilla",t:1,d:"Este amuleto hecho con resina de Bambú propagará a tu alrededor un olor agradable. Muy eficaz para disimular tus Vientos de Pánico cuando los estés probando.",ep:18,g:85,l:94,wd:true,fm:true,w:5,p:22800};
I.u[7003] = {n:"Talismán de Elya Wood",t:1,d:"Este talismán ha sido creado con polvo de estrellas y piedras preciosas atrapadas en ámbar del Abráknido Ancestral. De ser explosiva la mezcla, no te recomiendo fabricarlo por tu propia cuenta, mejor que lo haga un joyero que odies.",ep:18,g:86,l:135,wd:true,fm:true,w:10,s:39,p:45600};
I.u[7004] = {n:"Mediana piedra de alma azarosa",t:83,d:"Esta runa ofrece una pequeña oportunidad de capturar almas relativamente elevadas...",ep:5,g:8,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7005] = {n:"Gran Piedra de Alma Azarosa",t:83,d:"Esta runa ofrece una pequeña oportunidad de capturar almas particularmente salvajes...",ep:5,g:9,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7006] = {n:"Enorme Piedra de Alma Azarosa",t:83,d:"Esta runa ofrece una pequeña oportunidad de capturar almas extremadamente ariscas...",ep:16,g:10,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7007] = {n:"Pequeña piedra de Alma",t:83,d:"Esta runa ofrece una oportunidad correcta de capturar almas no muy gruesas...",ep:5,g:2,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7008] = {n:"Mediana piedra de alma",t:83,d:"Esta runa ofrece una oportunidad correcta de capturar almas relativamente elevadas...",ep:5,g:12,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7009] = {n:"Gran Piedra de Alma",t:83,d:"Esta runa ofrece una oportunidad correcta de capturar almas particularmente salvajes...",ep:16,g:13,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7010] = {n:"Piedra de alma llena",t:85,d:"Esta piedra contiene las almas de un grupo de monstruos que están deseando volver a la vida para meterte los dedos por la nariz y sacártelos por la boca. Sólo sirve en las arenas previstas a tal efecto que podrás encontrar en las grandes ciudades.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7011] = {n:"Capa del Deseo Pelotero",t:17,d:"Esta capa única, casi con vida propia, está hecha con pelos de barba pelirroja. Está animada por una magia extraordinaria y tiene cierta tendencia a esconderse justo en el momento en que uno se marcha a la aventura y la necesita. Menos mal que compensa su falsedad con un extraordinario poder en combate. Lo cual hace de ella una \"vewdadewa máquina de guewa\" según dicen algunos wabbits.",ep:13,g:83,l:67,wd:false,fm:true,w:10,s:38,p:11875};
I.u[7012] = {n:"La Bostabola",t:1,d:"Este amuleto es, en principio, una golosina. Se podría comer si no hubiera sido antes revolcada bajo las axilas de una horda de hembras Bwork en celo... y eso durante 36 generaciones.",ep:7,g:87,l:77,wd:true,fm:true,w:10,s:38,p:15425};
I.u[7013] = {n:"Madera de bambú",t:38,d:"El bambú dobla y rompe, no es como la caña. \nAfortunadamente, son los dientes de los imprudentes los que se rompen antes al chocar contra esta madera. A veces, la naturaleza se pone al servicio de dentistas sin escrúpulos.",ep:18,g:673,l:50,wd:true,fm:true,w:5,p:0};
I.u[7014] = {n:"Madera de bambú sagrado",t:38,d:"A pesar de las apariencias, esta madera es sagrada. Solamente los mejores Pandawas tienen el permiso para cortar esa madera pero a veces ocurre que turistas leñadores no se \"cortan\" en volver de la isla de Pandala con un recuerdo del lugar. Por algo los turistas tienen mala fama...",ep:18,g:671,l:100,wd:true,fm:true,w:5,p:0};
I.u[7015] = {n:"Brotes de bambú",t:38,d:"Estos brotes de bambú no son comestibles porque no tienen ningún sabor. Por eso se desaconseja segarlos con una guadaña oxidada o dejarlos al remojo durante unos cuantos años en zumo de Zampávoro antes de servirlos a tus amigos. Esta es una vieja técnica que utilizaban los restauradores sin escrúpulos capaces de cualquier cosa para hacerte comer cualquier porquería.",ep:1,g:676,l:50,wd:true,fm:true,w:2,p:5};
I.u[7016] = {n:"Madera de bambú oscuro",t:38,d:"Galthus, el joven Pandawa le preguntó un día a su padre: \"Papá, ¿Cual es la diferencia entre el bambú y el bambú oscuro?\". Entonces recibió un merecido azote por hacer una pregunta tan tonta. Pues todos saben que lo que diferencia el Bambú del Bambú Oscuro es el grosor de sus semillas.",ep:18,g:672,l:60,wd:true,fm:true,w:5,p:0};
I.u[7017] = {n:"Madera de bambú dorado",t:38,d:"Galthus, el joven Pandawa le preguntó un día a su padre: \"Papá, ¿Cual es la diferencia entre el bambú y el bambú dorado?\". Entonces recibió un merecido azote por hacer una pregunta tan tonta. Pues todos saben que lo que diferencia el Bambú del bambú dorado es el tamaño de sus raíces.",ep:18,g:669,l:45,wd:true,fm:true,w:5,p:20};
I.u[7018] = {n:"Arroz",t:34,d:"Pegajoso o incluso viscoso, el arroz siempre es muy bien acogido por los Pandawas hambrientos.",ep:18,g:10,l:20,wd:true,fm:true,w:2,p:0};
I.u[7020] = {n:"Flor de loto",t:38,d:"Dicen que es la flor más antigua del mundo, simboliza la fecundidad pero también el desprendimiento ya que a veces sale del agua sin mojarse. Algunos jefes Pandawas utilizan este símbolo para hacerles comprender a sus fieles que tienen que vivir en el mundo sin que éste les afecte.",ep:1,g:141,l:30,wd:true,fm:true,w:1,p:2};
I.u[7022] = {n:"Bastón de Sanchoku",t:4,d:"Este bastón pertenecía al abuelo de Sanchoku: Sanchokán. Era famoso por ser un presumido. Cuenta la leyenda que este bastón mágico es capaz de alargarse para alcanzar a cualquier enemigo, o sencillamente para compensar algunos complejos de inferioridad.",ep:18,g:47,l:120,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,50,60,false,false],c:"CA>250&CV>300",p:36620};
I.u[7023] = {n:"Piedra de Aguamarina",t:51,d:"Generalmente esta piedra se puede encontrar por la zona de Pandala. Los Pandawas cuentan que esta piedra tiene poderes muy particulares. Todos hablan de ellos pero hasta ahora nadie ha podido comprobarlo. Un poco los yopukas inteligentes.",ep:1,g:75,l:60,wd:true,fm:true,w:5,p:600};
I.u[7024] = {n:"Piedra de topacio",t:51,d:"Esta extraña piedra servía hace mucho tiempo de alimento para los jóvenes crujibolas de algunos ganaderos de Pandala. Estas piedras se volvieron tan raras que se prohibió dárselas como pienso a los crujibolas.",ep:5,g:76,l:70,wd:true,fm:true,w:5,p:700};
I.u[7025] = {n:"Piedra de Agata",t:51,d:"El nombre de esta piedra viene de un río de Pandala en el cual antiguamente se podían encontrar en cantidades abundantes. Pero los tiempos han cambiado mucho y la explotación intensiva de sus yacimientos acabó agotarlos casi totalmente.",ep:5,g:128,l:80,wd:true,fm:true,w:5,p:1};
I.u[7026] = {n:"Aguamarina",t:50,d:"Esta piedra preciosa transparente y a veces ligeramente azulada es tan brillante que si la llevas alrededor del cuello, ocultará las arrugas más aparentes. Incluso los Pandawas no dudan en decir a los turistas: \n\"Haz feliz a tu dulcinea con esta piedra y acepta más fácilmente los efectos del tiempo sobre la gente que amas\".",ep:1,g:101,l:60,wd:true,fm:true,w:5,p:600};
I.u[7027] = {n:"Topacio",t:50,d:"Es muy apreciado por los joyeros por razones un poco sospechosas. Sin embargo, esta piedra preciosa no deja de ser un valor seguro para atraer la atención de los Cuerboks en medio de las llanuras de Cania.",ep:5,g:102,l:70,wd:true,fm:true,w:5,p:700};
I.u[7028] = {n:"Ágata",t:50,d:"Esta piedra saca su nombre de una hembra Pandawa muy poderosa, más conocida bajo el nombre de Ágata Ash, célebre en los lugares de vicio poco recomendables, como el bar de los Piratas de Sufokia por ejemplo donde pasó sus últimos años bailando encadenada a un gran mástil de barco plantado en medio del bar.",ep:5,g:103,l:80,wd:true,fm:true,w:5,p:800};
I.u[7029] = {n:"Cinturón de Sanchoku",t:10,d:"Cuando Sanchoku se comía demasiadas alubias mágicas, apretaba este cinturón muy fuerte alrededor de su cintura para contener lo mejor posible, los vientos de pánico que le hicieron famoso en toda la provincia de Amakna.",ep:13,g:80,l:86,wd:false,fm:true,w:10,c:"CS>100",p:18400};
I.u[7030] = {n:"Piel de kanugro",t:59,d:"Cuando la hayas depilado, la piel de Kanugro será muy suave, un poco como las hembras Sadidas.",ep:13,g:47,l:70,wd:true,fm:true,w:5,p:1};
I.u[7031] = {n:"Péndulo del Gúdulo",t:1,d:"El pobre Gúdulo ha perdido la cabeza tras un terrible combate contra Many. Afortunadamente, su amuleto no sufrió daños durante el enfrentamiento. Es más, conservó sus poderes hipnotizantes, pero también laxativos. Utilícese con moderación.",ep:18,g:90,l:46,wd:false,fm:true,w:2,p:5600};
I.u[7032] = {n:"Silicato",t:39,d:"Este mineral viene sin duda de las profundas minas oscuras de la isla de Pandala en las cuales Gardan Framin se enamoró locamente del espectro de una hembra Pandawa. Eso demuestra que el amor es ciego.",ep:16,g:111,l:70,wd:true,fm:true,w:5,p:0};
I.u[7033] = {n:"Dolomía",t:39,d:"\"Siempre dura e irrompible\" estas eran las palabras de Irko el Minero Oscuro acerca de la Dolomía.",ep:16,g:110,l:80,wd:true,fm:true,w:5,p:0};
I.u[7034] = {n:"Casco del Maestro Nabur",t:16,d:"Transmitido de generación en generación, este casco ha sido llevado incluso por el mismo Crail. Muchos aventureros le atribuyen poderes que no tiene, una característica común a numerosas divinidades y a un sinfín de héroes de los tiempos modernos...",ep:16,g:93,l:97,wd:false,fm:true,w:10,p:23000};
I.u[7035] = {n:"Piruta",t:40,d:"Esta aleación era muy utilizada para forjar hojas que no se oxidaban al contacto con la sangre y la baba de los enemigos.",ep:16,g:708,l:100,wd:true,fm:true,w:100,p:0};
I.u[7036] = {n:"Rutilo",t:40,d:"Esta aleación brillante es muy apreciada por los joyeros arruinados, que no pueden comprarse piedras preciosas y que aprovechan generalmente para hacer alianzas a un precio desafiando toda competencia. Muy práctico cuando quieres casarte por interés.",ep:16,g:707,l:100,wd:true,fm:true,w:100,p:0};
I.u[7037] = {n:"Bastón de Abuelita Bombón",t:4,d:"Este bastón pertenecía a la Abuelita Bombón en persona, una de las tres terribles sacerdotisas del amor. Una de sus extremidades está afilada y la otra está lustrada. Este bastón era sobre todo famoso por su polivalencia y su capacidad para plantarse en cualquier sitio. Uno no puede ser insensible a este aspecto.",ep:18,g:48,l:98,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,50,50,false,false],c:"CS>100&CV>300",p:24500};
I.u[7038] = {n:"Corona del Rey Gelax",t:16,d:"Esta corona perteneció al ilustre Rey Gelax, famoso por ser muy romántico y por su poder de seducción que marcó para toda la vida a más de una Gelatina hembra... Dicen incluso que es el padre de todas las Gelatinas de la comarca de Amakna, eso demuestra que su resistencia y su fertilidad no son solamente legendarias...",ep:7,g:94,l:79,wd:true,fm:true,w:15,p:15000};
I.u[7039] = {n:"Cinturón negro de Frank Lee Bruce",t:10,d:"Célebre luchador dominguero, Frank se reconvirtió en las artes marciales tras haber fracasado lamentablemente su examen de escultor de piedra.",ep:13,g:81,l:47,wd:true,fm:true,w:5,p:5900};
I.u[7040] = {n:"Arco de Kuri",t:2,d:"Este arco perteneció la mismísima Kuri, famosa sacerdotisa del amor y mano izquierda de la Abuelita Bombón. Nunca le des la espalda a una sacerdotisa del amor, una sola flecha de este arco bastaría para hacerte trizas el corazón, o incluso las nalgas si huyes corriendo.",ep:18,g:43,l:56,wd:true,fm:true,w:10,an:10,tw:true,e:[15,5,2,6,20,40,false,true],p:8300};
I.u[7041] = {n:"Pandrista",t:30,d:"También llamada el Galope del Pandawa, la Pandrista es una especialidad sobradamente  conocida por los viajeros. Sus síntomas: unas ganas imperiosas de ir al trono y la incapacidad de llegar a tiempo.",ep:18,g:8,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7042] = {n:"Sombrero Pandawa",t:14,d:"Contrariamente al Pandawa de Amakna, el Pandawa de Pandala sólo te dará ganas de ir a depositar un abono natural sobre el vegetal más cercano... O bien sobre un Miaumiau: Es igual de eficaz (para ti) y sobre todo más divertido.",ep:18,g:31,l:1,wd:false,fm:true,w:1,c:"PG!12",u:true,p:1000};
I.u[7043] = {n:"Dofus de los Hielos",t:23,d:"La leyenda cuenta que este espléndido Dofus salió del agujero helado de Aguabrial el dragón del Agua. La leyenda no dice que estaba resfriado aquel día, pero aún así es fácil de imaginar.",ep:1,g:5,l:1,wd:false,fm:true,w:1,p:1};
I.u[7044] = {n:"Falso Dofus",t:24,d:"Este Dofus no se parece a los demás Dofus y sin embargo...",ep:18,g:256,l:1,wd:false,fm:true,w:0,p:1};
I.u[7045] = {n:"Un frasco de Pandaburg",t:79,d:"La Pandaburg es una bebida sabrosa con mucho carácter y que, según parece, vuelve ciego, mudo y sordo pero lentamente. Vaya coincidencia, pues los Pandawas no tienen prisa.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[7046] = {n:"Un frasco de Pandapiler",t:79,d:"Según el erudito Hel Munster, este auténtico néctar podría seducir incluso a la diosa Pandawa, volviéndola muy eufórica. Cualquier Pandawa que se respete debería regalar sus Pandapilers a su venerada diosa.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[7047] = {n:"Un frasco de Pandapils",t:79,d:"Muy extraña esa vieja costumbre pandawallana de brindar con una pluma de tofu en el pelo y cantando: \"¡¡Pandapils, pandapils, lalalarila raaaaahh!!\". Y esa no es la peor de todas...",ep:18,g:4,l:1,wd:true,fm:true,w:1,p:1};
I.u[7055] = {n:"Un frasco de Pandneken",t:79,d:"\"Cierto es que las patas de bwak son cortas, pero alargarlas no le sería de ninguna utilidad\". Estas son las reflexiones a las que conduce la Pandneken. Por eso los Pandawas prefieren reservarla para las libaciones en honor a Pandawa.",ep:18,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[7056] = {n:"Krepita",t:16,d:"Este sombrero único perteneció a un xelor, famoso por sus ideas explosivas y su dominio del tiempo. Se murió de una manera bastante extraña. Lanzó un Viento de Pánico estrepitoso al mismo tiempo que desprendía chispas a su alrededor. Su muerte, según dicen, fue bastante agónica, pero tan luminosa que algunos llegaron a afirmar que la ciudad de Brakmar entera permaneció iluminada durante unos segundos.",ep:19,g:95,l:149,wd:true,fm:true,w:10,p:45850};
I.u[7057] = {n:"Asistente del shaman",t:32,d:"Llevate el ayudante a junto de la diosa, te estará muy agradecido.",ep:18,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7058] = {n:"Octovius",t:16,d:"Este sombrero ha sido confeccionado con los restos de Kralamares muertos y secados. Ten cuidado, puede volver a la vida si lo usas como guante de baño.",ep:18,g:96,l:77,wd:true,fm:true,w:10,p:15475};
I.u[7059] = {n:"Semilla de Pandoja",t:58,d:"Esta enorme semilla está llena de un aceite indigesto pero mágico. Cuentan que su cáscara es irrompible. Muchos artesanos la utilizan para hechizar sus armas y los tuertos la usan como ojo postizo.",ep:18,g:67,l:100,wd:true,fm:true,w:10,p:10};
I.u[7060] = {n:"Pandapiler especial",t:24,d:"El Zollo sabio te ha entregado este Panda para que se lo lleves al Maestro Pandawushu de la vía del agua.",ep:18,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[7061] = {n:"Transformación Miaumiau",t:31,d:"El Agua de la Fosa maldita de Miaugado te ha transformado durante un tiempo en Miaumiau, el más mínimo choque te hará volverte normal.",ep:18,g:21,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7062] = {n:"Poochan",t:32,d:"Debes llevar a Poochan hasta su novio.",ep:18,g:21,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7063] = {n:"Flor de los salteadorillos",t:35,d:"Esta bonita flor solamente crece en el pueblo de los salteadorillos, un poco como las salteadorillas... pero menos malvada.",ep:1,g:634,l:40,wd:true,fm:true,w:2,p:10};
I.u[7068] = {n:"Harina de arroz",t:52,d:"Esta harina es perfecta para hacer cemento o polvos de talco... Aunque no se recomienda mucho la segunda opción si se tiene en cuenta la primera.",ep:18,g:7,l:50,wd:true,fm:true,w:2,p:0};
I.u[7069] = {n:"Escudo de Sidimote Abollado",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:8,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:15650};
I.u[7070] = {n:"Escudo de los Salteadorillos Rasgado",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"BI=non équipable",p:30700};
I.u[7071] = {n:"Escudo del Leñador Hendido",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:4,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:1200};
I.u[7072] = {n:"Ftalmo desprendido",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:5,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:33000};
