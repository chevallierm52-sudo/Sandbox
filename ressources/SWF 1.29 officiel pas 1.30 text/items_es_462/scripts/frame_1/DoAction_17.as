I.u[7204] = {n:"Bastón del Shodanwa",t:4,d:"Este bastón es utilizado en regla general por los discípulos Pandawushuka que consiguieron alcanzar el grado de Shodanwa sin entre tanto perder el uso de sus brazos.",ep:18,g:49,l:46,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,false],c:"CV>30&CW>10",p:5775};
I.u[7205] = {n:"Bastón del Nidanwa",t:4,d:"Este bastón es utilizado en regla general por los discípulos Pandawushuka que consiguieron alcanzar el grado de Nidanwa sin entre tanto perder el uso de sus brazos.",ep:18,g:50,l:62,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>100",p:10125};
I.u[7206] = {n:"Bastón del Sandanwa",t:4,d:"Este bastón es utilizado en regla general por los discípulos Pandawushuka que consiguieron alcanzar el grado de Sandanwa sin entre tanto perder el uso de sus brazos.",ep:18,g:51,l:80,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,30,50,false,false],c:"CA>100&CV>70",p:16700};
I.u[7207] = {n:"Bastón de yondanwa",t:4,d:"Este bastón es utilizado en regla general por los discípulos Pandawushuka que lograron alcanzar el grado de yondanwa sin perder el uso de sus brazos en el intento.",ep:18,g:52,l:93,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>250",p:22500};
I.u[7208] = {n:"Hacha del Shodanwa",t:19,d:"Los discípulos Pandawushuka utilizan esta hacha cuando obtienen el grado de Shodanwa. Es también muy práctica para devastar los bosques de Bambúes y todas las criaturas que en ellos se esconden.",ep:18,g:37,l:36,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:3550};
I.u[7209] = {n:"Hacha del Nidanwa",t:19,d:"Los discípulos Pandawushuka utilizan esta hacha cuando obtienen el grado de Nidanwa. Es también muy práctica para devastar los bosques de Bambúes y todas las criaturas que en ellos se esconden.",ep:18,g:36,l:59,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],c:"CS>100&CV>50",p:9000};
I.u[7210] = {n:"Hacha del Sandanwa",t:19,d:"Los discípulos Pandawushuka utilizan esta hacha cuando obtienen el grado de Sandanwa. Es también muy práctica para devastar los bosques de Bambúes y todas las criaturas que en ellos se esconden.",ep:18,g:35,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:17800};
I.u[7211] = {n:"Hacha de yondanwa",t:19,d:"Los discípulos Pandawushuka utilizan esta hacha cuando obtienen el grado de yondanwa. Es también muy práctica para devastar los bosques de bambú y todas las criaturas que en ellos se esconden.",ep:18,g:34,l:98,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,50,50,false,false],c:"CI>150&CS>75&CV>85",p:24500};
I.u[7212] = {n:"La Cortadora de bambú",t:19,d:"Ligera y elegante, esta hacha te permitirá progresar fácilmente en los bosques de bambú de Pandala y defenderte eficazmente contra los Pandis más pérfidos, siempre dispuestos a atacar a los leñadores aislados por oscuros motivos de bolsas...",ep:18,g:33,l:26,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:2000};
I.u[7213] = {n:"Pala Ancefálica",t:8,d:"Esta pala parte supuestamente el aire a una velocidad increíble. Los que saben utilizarla correctamente, parten sobre todo los cráneos de sus enemigos con ella.",ep:19,g:41,l:142,wd:true,fm:true,w:15,an:16,tw:true,e:[10,5,1,1,40,70,false,false],c:"CC>400&CV>250",p:46050};
I.u[7214] = {n:"Sandalmatas",t:11,d:"Estas sandalias pertenecían a los Matas, una tribu de Uginaks que hoy ha desaparecido. Estos eran muy amigos con los Pandawas, lo cual había cambiado el color de su piel a lo largo de los años hasta volverse blanco con manchas negras. Todos fueron transformados en abrigos por una sastre muy cruel.",ep:18,g:59,l:30,wd:true,fm:true,w:10,p:2650};
I.u[7215] = {n:"Sandalias Fatales",t:11,d:"Algunas hembras Pandidas utilizaban estas sandalias para seducir a los aventureros perdidos y para atraparlos en horribles trampas.",ep:19,g:60,l:121,wd:true,fm:true,w:20,p:37400};
I.u[7216] = {n:"Sandalias Kotchielos",t:11,d:"Se les daban estas sandalias a los pandawas enfermos que necesitaban correr muy rápido cuando habían contraído el virus de la Pandrista, o cuando habían pasado una noche demasiado alcoholizada en la taberna.",ep:18,g:61,l:58,wd:true,fm:true,w:10,p:8975};
I.u[7217] = {n:"Sandalia Lambique",t:11,d:"La adicción número uno de los pandawas siempre ha sido el alcohol que con el tiempo aprendieron a conservar y a aromatizar. Estas sandalias han sido especialmente diseñadas para los pandawas alcohólicos, llevan un lastro en la suela para que puedas mantener los pies en el suelo con mayor frecuencia.",ep:19,g:62,l:159,wd:true,fm:true,w:50,p:50800};
I.u[7218] = {n:"Sandalia Ladín",t:11,d:"Ladín era un joven pandawa que coleccionaba lámparas de todos tipos, pero no por eso era un genio.",ep:18,g:63,l:76,wd:true,fm:true,w:15,p:14900};
I.u[7219] = {n:"Sandalia Leluya",t:11,d:"Estas sandalias se entregaban a los Pandidos al final de determinados rituales religiosos. Hoy en día se suelen llevar en los campeonatos de claqué.",ep:18,g:64,l:56,wd:true,fm:true,w:15,p:8200};
I.u[7220] = {n:"Billete de lotería",t:15,d:"Este es un magnífico billete de lotería. ¡Consérvalo preciosamente, puede que seas el ganador de la rifa!",ep:1,g:717,l:2,wd:true,fm:true,w:1,p:1};
I.u[7221] = {n:"Collar del Tanukui San",t:1,d:"Tanukui San llevó puesto este collar desde su más tierna infancia, lo cual le confiere un valor añadido no despreciable cuando se sabe de qué era capaz, incluso durante su niñez.",ep:19,g:92,l:152,wd:true,fm:true,w:10,p:49030};
I.u[7222] = {n:"Artefacto Pandawushu Agua",t:50,d:"Este artefacto mágico es utilizado por los discípulos Pandawushu para hechizar su indumentaria.",ep:1,g:104,l:1,wd:true,fm:true,w:1,p:1};
I.u[7223] = {n:"Artefacto Pandawushu Aire",t:50,d:"Este artefacto mágico es utilizado por los discípulos Pandawushu para hechizar su indumentaria.",ep:18,g:105,l:1,wd:true,fm:true,w:1,p:1};
I.u[7224] = {n:"Artefacto Pandawushu Tierra",t:50,d:"Este artefacto mágico es utilizado por los discípulos Pandawushu para hechizar su indumentaria.",ep:18,g:106,l:1,wd:true,fm:true,w:1,p:1};
I.u[7225] = {n:"Artefacto Pandawushu Fuego",t:50,d:"Este artefacto mágico es utilizado por los discípulos Pandawushu para hechizar su indumentaria.",ep:18,g:107,l:1,wd:true,fm:true,w:1,p:1};
I.u[7226] = {n:"Sombrero Akwadala",t:16,d:"Con este sombrero, te parecerás desde lejos a un Pandawushuka del pueblo de Akwadala. Desde cerca, te parecerás a un peluche ganado en la feria.",ep:18,g:146,l:43,wd:true,fm:true,w:2,s:34,p:5100};
