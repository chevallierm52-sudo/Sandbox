I.u[7234] = {n:"Escudo Akwadala hundido",t:82,d:"Este escudo, proveniente del pueblo de Akwadala, te será muy útil para poder parar golpes de todo tipo.",ep:18,g:31,l:1,wd:false,fm:true,w:2,c:"BI=non équipable",p:5350};
I.u[7235] = {n:"Escudo Tierradala enterrado",t:82,d:"Este escudo, proveniente del pueblo de Tierradala, te será muy útil para poder parar golpes de todo tipo.",ep:18,g:32,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:14100};
I.u[7236] = {n:"Escudo Fuegodala Quemado",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:33,l:1,wd:false,fm:true,w:15,c:"BI=non équipable",p:27100};
I.u[7237] = {n:"Escudo Airedala Volado",t:82,d:"Este pobre escudo ha visto demasiadas batallas, ya no sirve para nada en su estado actual. Tal vez Buwada, en el pueblo Pandala pueda reemplazarlo.",ep:18,g:30,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:11600};
I.u[7238] = {n:"Cinturón Akwadala",t:10,d:"Los Pandawas del pueblo de Akwadala siempre quisieron tener una cintura muy fina. Si aprietas este cinturón hasta su máximo conseguirás el mismo resultado.",ep:18,g:76,l:41,wd:true,fm:true,w:2,s:34,p:4600};
I.u[7239] = {n:"Cinturón Tierradala",t:10,d:"Los Pandawas del pueblo de Tierradala siempre quisieron tener una cintura muy fina. Si aprietas este cinturón hasta su máximo conseguirás el mismo resultado.",ep:18,g:78,l:49,wd:true,fm:true,w:10,s:36,p:6353};
I.u[7240] = {n:"Cinturón Fuegodala",t:10,d:"Los Pandawas del pueblo de Fuegodala siempre quisieron tener una cintura muy fina. Si aprietas este cinturón hasta su máximo conseguirás el mismo resultado.",ep:18,g:77,l:81,wd:true,fm:true,w:10,s:37,p:16925};
I.u[7241] = {n:"Cinturón Airedala",t:10,d:"Los pandawas del pueblo de Airedala siempre quisieron tener una cintura muy fina. Si aprietas este cinturón hasta su máximo conseguirás el mismo resultado.",ep:18,g:79,l:70,wd:true,fm:true,w:10,s:35,p:13000};
I.u[7242] = {n:"Geta de Akwadala",t:11,d:"Estas geta de madera han sido fabricadas por los mejores zapateros del pueblo de Akwadala. Muy bien aireadas, permitirán que tus verrugas tomen el aire y disfruten del paisaje.",ep:18,g:54,l:35,wd:true,fm:true,w:10,s:34,p:3350};
I.u[7243] = {n:"Geta de Tierradala",t:11,d:"Estas geta de madera han sido confeccionadas por los mejores zapateros del pueblo de Tierradala. Al ser adecuadamente ventiladas, tus verrugas podrán tomarse un respiro y disfrutar del paisaje.",ep:18,g:55,l:76,wd:true,fm:true,w:15,s:36,p:15000};
I.u[7244] = {n:"Geta de Fuegodala",t:11,d:"Estas geta de madera han sido fabricadas por los mejores zapateros del pueblo de Fuegodala. Muy bien aireadas, permitirán que tus verrugas tomen el aire y disfruten del paisaje.",ep:16,g:56,l:68,wd:true,fm:true,w:25,s:37,p:12050};
I.u[7245] = {n:"Geta de Airedala",t:11,d:"Estas geta de madera han sido fabricadas por los mejores zapateros del pueblo de Airedala. Al ser adecuadamente ventiladas, tus verrugas podrán tomarse un respiro y disfrutar del paisaje.",ep:18,g:57,l:57,wd:true,fm:true,w:10,s:35,p:8700};
I.u[7246] = {n:"Alianza Akwadala",t:9,d:"Esta alianza viene del pueblo Akwadala. Es más un amuleto de la suerte que una reliquia mágica pero te permitirá hacer que tus amigos crean que has encontrado a tu media naranja.",ep:1,g:80,l:37,wd:true,fm:true,w:2,s:34,p:3800};
I.u[7247] = {n:"Alianza Tierradala",t:9,d:"Esta alianza procede del pueblo Tierradala. Cuando lleves esta alianza que se parece más a un talismán que a una reliquia mágica, tus amigos pensarán que has encontrado a tu media naranja.",ep:18,g:81,l:77,wd:true,fm:true,w:10,s:36,p:15425};
I.u[7248] = {n:"Alianza Fuegodala",t:9,d:"Esta alianza viene del pueblo de Fuegodala. Es más un amuleto de la suerte que una reliquia mágica pero te permitirá hacer que tus amigos crean que has encontrado a tu media naranja.",ep:18,g:82,l:81,wd:true,fm:true,w:10,s:37,p:17000};
I.u[7249] = {n:"Alianza Airedala",t:9,d:"Esta alianza procede del pueblo Airedala. Es más un amuleto de la suerte que una reliquia mágica pero te permitirá hacer que tus amigos crean que has encontrado a tu media naranja.",ep:18,g:83,l:57,wd:true,fm:true,w:5,s:35,p:8600};
I.u[7250] = {n:"Amuleto Akwadala",t:1,d:"Sólo los habitantes del pueblo de Akwadala estaban autorizados a llevar este amuleto, que supuestamente es uno de los elementos más importantes de su traje tradicional. Mirándolo desde más cerca, uno puede preguntarse por qué.",ep:18,g:79,l:41,wd:true,fm:true,w:2,s:34,p:5050};
I.u[7251] = {n:"Amuleto Tierradala",t:1,d:"Sólo los habitantes del pueblo de Tierradala estaban autorizados a llevar este amuleto, que se ha ganado el premio de ser uno de los elementos más importantes de su traje tradicional. Para ser sincero, no entiendo por qué.",ep:18,g:80,l:80,wd:true,fm:true,w:10,s:36,p:16550};
I.u[7252] = {n:"Amuleto Fuegodala",t:1,d:"Sólo los habitantes del pueblo de Fuegodala estaban autorizados a llevar este amuleto, que supuestamente es uno de los elementos más importantes de su traje tradicional. Mirándolo desde más cerca, uno puede preguntarse por qué.",ep:18,g:81,l:91,wd:true,fm:true,w:10,s:37,p:21225};
I.u[7253] = {n:"Amuleto Airedala",t:1,d:"Sólo los habitantes del pueblo de Airedala estaban autorizados a llevar este amuleto, que supuestamente es uno de los elementos más importantes de su traje tradicional. Mirándolo desde más cerca, uno puede preguntarse por qué.",ep:18,g:82,l:62,wd:true,fm:true,w:10,s:35,p:10000};
I.u[7254] = {n:"Bastón Akwadala",t:4,d:"Este bastón servía para castigar a los jóvenes Pandawas demasiado revoltosos. Tres golpes en los dedos, quince en las nalgas, sesenta sobre la cabeza, dos en los ojos y todo se solucionaba.",ep:18,g:61,l:43,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,false],c:"CC>50",s:34,p:5040};
I.u[7255] = {n:"Hacha Tierradala",t:19,d:"Esta hacha fue desde el principio, pensada para cortar seres vivos. Ten cuidado, un sólo error de manipulación y acabarás partido en dos... y no precisamente de la risa.",ep:18,g:32,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],s:36,p:17635};
I.u[7256] = {n:"Dagas Airedala",t:5,d:"Estas dagas están tan afiladas como las garras de un Maxilubo, harán de ti un excelente aprendiz asesino.",ep:18,g:51,l:62,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>50",s:35,p:10105};
I.u[7257] = {n:"Sable Fuegodala",t:6,d:"Este sable ha sido forjado por Hotari Honza en persona. Parece ser que se trata de una de sus últimas creaciones antes de reconvertirse en cocinero. En todo caso, es una verdadera pieza de colección.",ep:18,g:64,l:76,wd:true,fm:true,w:1,an:14,e:[5,6,1,1,50,50,false,false],c:"CI>200&CA>60",s:37,p:14900};
I.u[7258] = {n:"Pelos de Pandikaze",t:54,d:"Estos pelos muy finos se parecen a los del trasero de una Sadidita...",ep:16,g:556,l:40,wd:true,fm:true,w:1,p:10};
I.u[7259] = {n:"Tejido de Pandikaze",t:55,d:"Este montón de pelos está casi intacto a pesar de la paliza que le diste al pobre Pandikaze...",ep:18,g:124,l:40,wd:true,fm:true,w:1,p:10};
I.u[7260] = {n:"Piel de Pandikaze",t:59,d:"Esta piel todavía tiene un ligero vello, tan suave como las axilas de una Aniripsa, pero sin el olor a sudor.",ep:18,g:40,l:40,wd:true,fm:true,w:2,p:10};
I.u[7261] = {n:"Madera de bambú mágico",t:38,d:"Es sorprendente, este cacho de bambú está impregnado con una magia igual de sorprendente. Incluso le permite desplazarse. Cuenta una leyenda tribal que todas las noches, anda llamando a la puerta de la gente que practica actividades libertinas. Por esa razón, los Pandawas suelen atarlo con una cadena antes de irse a la cama... Lo hacen para evitar problemas con el vecindario...",ep:18,g:670,l:220,wd:true,fm:true,w:5,p:20};
I.u[7262] = {n:"Raíz de bulbiflor",t:98,d:"Esta raíz de bulbiflor no es como las demás raíces, se puede masticar durante mucho tiempo sin que se te caigan los dientes. Ojo, tiene un sabor muy malo.",ep:18,g:142,l:26,wd:true,fm:true,w:2,p:20};
I.u[7263] = {n:"Raíz de bulbomatorral",t:98,d:"Esta raíz de bulbomatorral no es como las demás raíces, se puede masticar durante mucho tiempo sin que se te caigan los dientes. Ojo, tiene un sabor muy malo.",ep:18,g:143,l:42,wd:true,fm:true,w:2,p:20};
I.u[7264] = {n:"Raíz de bulbambú",t:98,d:"Esta raíz de bulbambú no es como las demás raíces, se puede masticar durante mucho tiempo sin que se te caigan los dientes. Ojo, no es como las demás golosinas... esta sabe fatal.",ep:18,g:145,l:67,wd:true,fm:true,w:2,p:20};
I.u[7265] = {n:"Raíz de bulbig",t:98,d:"Esta raíz de bulbig no es como las demás raíces, se puede masticar durante mucho tiempo sin que se te caigan los dientes. Ojo, tiene un sabor muy malo.",ep:18,g:144,l:150,wd:true,fm:true,w:2,p:20};
I.u[7266] = {n:"Flor de bulbiflor",t:35,d:"Esta flor solamente crece sobre la cabeza del bulbiflor, por lo tanto no intentes ponerla sobre la tuya... Tu sustrato no es tan rico...",ep:18,g:119,l:26,wd:true,fm:true,w:1,p:10};
I.u[7267] = {n:"Hoja de bulbomatorral",t:36,d:"Estas hojas solamente crecen sobre la cabeza del Bulbomatorral por lo cual no intentes hacerlas crecer sobre la tuya, puede que marchiten muy rápido.",ep:18,g:55,l:42,wd:true,fm:true,w:2,p:10};
I.u[7268] = {n:"Brotes de bulbambú",t:36,d:"Este brote solamente puede vivir sobre la cabeza del Bulbambú. No intentes ponerlos sobre la tuya... pues no encontraría nada interesante para comer.",ep:18,g:56,l:67,wd:true,fm:true,w:2,p:10};
I.u[7269] = {n:"Corteza mágica de Bulbig",t:96,d:"Esta corteza mágica es tan resistente como un escudo del Capitán Amakna, aunque es mucho más fea.",ep:18,g:105,l:150,wd:true,fm:true,w:2,p:10};
I.u[7270] = {n:"Corteza mágica del Bulbiflor",t:96,d:"Esta corteza es tan fina y frágil que podría servir para hacer encaje o ropa interior sexy...",ep:18,g:106,l:26,wd:true,fm:true,w:2,p:10};
I.u[7271] = {n:"Corteza mágica de Bulbomatorral",t:96,d:"Esta corteza rugosa es perfecta para confeccionar plantillas antiderrapantes.",ep:18,g:107,l:42,wd:true,fm:true,w:2,p:10};
I.u[7272] = {n:"Corteza mágica de Bulbambú",t:96,d:"Esta corteza muy lisa es perfecta para hacer parqués o pistas de baile.",ep:18,g:108,l:67,wd:true,fm:true,w:2,p:10};
I.u[7273] = {n:"Piel de Coolebra",t:59,d:"Esta piel de Coolebra se deslizará entre tus dedos con una facilidad desconcertante. Procura no hacer zapatos con ella, de lo contrario no lograrás quitártelas nunca.",ep:18,g:41,l:67,wd:true,fm:true,w:2,p:10};
I.u[7274] = {n:"Diente mágico de Coolebra",t:47,d:"Este diente no es como los demás, huele peor, como si se le hubiera incrustado el horrible aliento de la Coolebra.",ep:18,g:16,l:67,wd:true,fm:true,w:2,p:100};
I.u[7275] = {n:"Pelos de Kitsu Nae",t:54,d:"Estos pelos de Kitsu Nae son suaves como las crines de una hembra Trool. A que eso te trae buenos recuerdos... ¿eh?",ep:16,g:560,l:29,wd:true,fm:true,w:1,p:10};
I.u[7276] = {n:"Pelos de Kitsu Nufuego",t:54,d:"Estos pelos de Kitsu Nufuego son suaves como las crines de una hembra Trool. A que eso te trae buenos recuerdos... ¿eh?",ep:18,g:557,l:111,wd:true,fm:true,w:1,p:10};
I.u[7277] = {n:"Pelos de Kitsu Nere",t:54,d:"Estos pelos de Kitsu Nere son suaves como las crines de una hembra Trool. A que eso te trae buenos recuerdos... ¿eh?",ep:16,g:558,l:80,wd:true,fm:true,w:1,p:10};
I.u[7278] = {n:"Pelos de Kitsu Nakwa",t:54,d:"Estos pelos de Kitsu Nakwa son tan suaves como la grupa de una hembra Trool. Esto te traerá buenos recuerdos...",ep:1,g:559,l:60,wd:true,fm:true,w:1,p:10};
I.u[7279] = {n:"Piel de Kitsu Nae",t:59,d:"Esta piel de Kitsu Nae es de muy buena calidad, si se recorta para hacer varias tiras puede convertirse en un látigo estupendo. Es el regalo ideal para el día del padre...",ep:18,g:46,l:19,wd:true,fm:true,w:2,p:10};
I.u[7280] = {n:"Piel de Kitsu Nufuego",t:59,d:"Esta piel de Kitsu Nufuego es de muy buena calidad, si se recorta para hacer varias tiras puede convertirse en un látigo estupendo. Es el regalo ideal para el día del padre...",ep:18,g:44,l:111,wd:true,fm:true,w:2,p:10};
I.u[7281] = {n:"Piel de Kitsu Nere",t:59,d:"Esta piel de Kitsu Nere es de muy buena calidad, si se recorta para hacer varias tiras puede convertirse en un látigo estupendo. Es el regalo ideal para el día del padre...",ep:18,g:45,l:80,wd:true,fm:true,w:2,p:10};
I.u[7282] = {n:"Piel de Kitsu Nakwa",t:59,d:"Esta piel de Kitsu Nakwa es de una calidad excepcional, si se recorta para hacer varias tiras podrás hacer con ella un magnífico látigo. Sería un regalo ideal para los padres cuyos hijos son demasiado gamberros.",ep:1,g:43,l:60,wd:true,fm:true,w:2,p:10};
I.u[7283] = {n:"Piel de Tanukui San",t:59,d:"Esta enorme piel estirada de Tanukui San podría llegar a ser una excelente bolsa para guardar tus kamas.",ep:1,g:2,l:85,wd:true,fm:true,w:2,p:100};
I.u[7284] = {n:"Pelos de Tanukui San",t:54,d:"Estos pelos de Tanukui San no huelen muy bien pero poco importa, son pelos de Tanukui San.",ep:1,g:3,l:85,wd:true,fm:true,w:2,p:100};
I.u[7285] = {n:"Pata de araknawa",t:103,d:"Esta patita seguirá moviéndose durante bastante tiempo. Métela en el calzoncillo de tus enemigos para desestabilizarlos en pleno combate, ganarás sin gran esfuerzo.",ep:18,g:716,l:43,wd:true,fm:true,w:2,p:100};
I.u[7286] = {n:"Madera de bambuto",t:38,d:"La madera de Bambuto es casi tan cara como la de Pambuto y sin embargo es mucho más corriente. No hay quien lo entienda...",ep:18,g:675,l:47,wd:true,fm:true,w:2,p:100};
I.u[7287] = {n:"Hoja de bambuto",t:36,d:"Las hojas de bambuto son anchas y gruesas, un poco como las hembras bwork pero sin su agresividad.",ep:18,g:69,l:47,wd:true,fm:true,w:2,p:1};
I.u[7288] = {n:"Hoja de bambuto sagrado",t:36,d:"Esta gruesa hoja es tan dura y pesada que podría aplastarte si te durmieras debajo de un bambuto sagrado en otoño.",ep:18,g:68,l:120,wd:true,fm:true,w:2,p:100};
I.u[7289] = {n:"Madera de bambuto sagrado",t:38,d:"Esta madera no se puede dejar en manos de cualquiera, pero hasta ahora nadie supo por qué.",ep:18,g:674,l:120,wd:true,fm:true,w:10,p:100};
I.u[7290] = {n:"Raíz mágica de bambuto",t:98,d:"Esta raíz le permite al bambuto sacar toda su magia de la tierra antes de empezar un combate.",ep:18,g:100,l:20,wd:true,fm:true,w:2,p:10};
I.u[7291] = {n:"Raíz mágica de bambuto sagrado",t:98,d:"Esta raíz le permite al bambuto sagrado sacar toda su magia de la tierra antes de empezar un combate.",ep:18,g:99,l:87,wd:true,fm:true,w:2,p:100};
I.u[7292] = {n:"Pelos de Maho Firefux",t:54,d:"Estos pelos son los del Maho Firefux, una terrible criatura que no mata ni espanta aunque posea en realidad terribles poderes mágicos.",ep:18,g:202,l:150,wd:true,fm:true,w:2,p:1};
I.u[7293] = {n:"Pelos de Soryo Firefux",t:54,d:"Estos pelos vienen de una pequeña criatura pelirroja muy pilla, como muchas más.",ep:18,g:203,l:130,wd:true,fm:true,w:10,p:1};
I.u[7294] = {n:"Pelos de Yokai Firefux",t:54,d:"Estos gruesos pelos malolientes han sido arrancados con fuerza y determinación del trasero de una horrible criatura pelirroja.",ep:18,g:204,l:110,wd:true,fm:true,w:10,p:10};
I.u[7295] = {n:"Pelos de Pandora",t:54,d:"Estos pelos misteriosos permiten en general tejer capas o sombreros mágicos con propiedades sorprendentes.",ep:18,g:2,l:200,wd:true,fm:true,w:10,p:200};
I.u[7297] = {n:"Pelos de Pándulo",t:54,d:"Estos pelos mágicos son los suficientemente potentes como para resucitar a un reloj estropeado.",ep:18,g:206,l:150,wd:true,fm:true,w:1,p:1};
I.u[7298] = {n:"Piel de Maho Firefux",t:59,d:"Esta piel lisa y fina ofrece una excelente protección cuando  los ataques mágicos del Maho Firefux se vuelven contra él.",ep:18,g:42,l:150,wd:true,fm:true,w:1,p:100};
I.u[7299] = {n:"Piel de Soryo Firefux",t:59,d:"Esta piel era antiguamente utilizada para coser los calzoncillos de los niños con piel sensible. Los calzoncillos de piel de Soryo Firefux están aprobadas por las descendencia de Capitán Chafer.",ep:18,g:38,l:130,wd:true,fm:true,w:1,p:100};
I.u[7300] = {n:"Piel de Yokai Firefux",t:59,d:"Esta piel ofrece una excelente protección contra los golpes de bambú.",ep:18,g:37,l:110,wd:true,fm:true,w:1,p:100};
I.u[7301] = {n:"Piel de Leopardo",t:59,d:"Antiguamente, los pandawas utilizaban esta piel para confeccionar ropa interior minimalista.",ep:18,g:36,l:40,wd:true,fm:true,w:1,p:10};
I.u[7302] = {n:"Piel de Pandora",t:59,d:"La piel del Pandora te reservará muchas sorpresas si eres zapatero.",ep:18,g:1,l:200,wd:true,fm:true,w:10,p:100};
I.u[7303] = {n:"Piel de Pándulo",t:59,d:"Esta piel rugosa cambia de color con el tiempo.",ep:18,g:39,l:100,wd:true,fm:true,w:1,p:10};
I.u[7304] = {n:"Tejido de Maho Firefux",t:55,d:"Este mechón pelirrojo mágico está impregnado por una magia poderosísima. Envidia cochina, ¿eh?",ep:18,g:11,l:150,wd:true,fm:true,w:1,p:100};
I.u[7305] = {n:"Tejido de Soryo Firefux",t:55,d:"Este tejido de tamaño modesto es perfecto para colmar agujeros debajo de viejas puertas cuando se acerca el invierno.",ep:18,g:10,l:130,wd:true,fm:true,w:1,p:10};
I.u[7306] = {n:"Tejido de Yokai Firefux",t:55,d:"Este tejido viene de las partes más sensibles del Yokai Firefux que también huelen fatal. Muchos aventureros piensan que se trata de su bigote... pero están equivocados...",ep:18,g:9,l:110,wd:true,fm:true,w:1,p:10};
I.u[7307] = {n:"Tejido de Pandora",t:55,d:"Este tejido es casi tan raro como una buena sorpresa metida en la caja del Pandora.",ep:18,g:125,l:200,wd:true,fm:true,w:10,p:10};
I.u[7308] = {n:"Tejido de Pándulo",t:55,d:"A pesar de lo que te puedan decir algunos, este tejido no es comestible. Los que intentaron cocinarlo acabaron convertidos en Tanukui San. ¡Qué suerte tienen algunos!",ep:18,g:12,l:100,wd:true,fm:true,w:1,p:10};
