I.u[7097] = {n:"Escudo de Entrenamiento",t:82,d:"Este escudo se suele entregar a los discípulos que todavía no saben manipular correctamente esta arma defensiva.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[7098] = {n:"Martillo de forjador de escudos",t:7,d:"Este martillo es indispensable para poder crear escudos.",ep:18,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:500};
I.u[7102] = {n:"Espada del Caballero de Hielo",t:6,d:"El caballero de hielo era famoso por ser uno de los mejores forjadores de espadas de toda Amakna. Sólo el horrible y despiadado Lich se negaba a reconocer su inmenso talento. Al ver que una criatura como esta no se maravillaba ante sus creaciones, se ofendió y le puso un ultimátum: se negó a ejercer su oficio mientras el Lich no hiciera el esfuerzo de reconocer públicamente su talento de forjador de espadas. Pero el terrible Lich no dio el brazo a torcer, por lo cual el forjador estuvo obligado, varios centenares de años más tarde, a volver a su forja. Entre tanto, había olvidado completamente su oficio, y esta ridícula espada fue su última creación utilizable.",ep:1,g:51,l:12,wd:true,fm:true,w:10,an:14,e:[5,6,1,1,40,60,false,false],p:575};
I.u[7103] = {n:"La Xyothina",t:3,d:"Esta varita servía para decapitar a todos los paletos de Amakna. Eso nos deja suponer que ha servido mucho. Resulta interesante ver que se parece a un palo, incluso a un bastón... Puede que sirviera para realizar las más perversas fantasías de su dueño, que acabó dándole su nombre. Nadie conoce el final de esta sórdida historia.",ep:19,g:53,l:145,wd:true,fm:true,w:15,an:11,tw:true,e:[7,4,3,5,30,50,false,true],c:"CI>450&CV>200",p:10000};
I.u[7104] = {n:"Chanclas Pisadas",t:11,d:"Estas chanclas servían para practicar diferentes artes marciales. Tienen un aspecto poco innovador y su diseño es artísticamente nulo. Han caído muy rápido en el olvido, un poco como tú, pero no tan rápido.",ep:18,g:58,l:67,wd:true,fm:true,w:5,p:11700};
I.u[7105] = {n:"Amuleto de Pandala",t:24,d:"Este amuleto en apariencia muy sencillo contiene un misterio que solamente un Pandawa a punto de morirse es capaz de entender...",ep:18,g:48,l:0,wd:true,fm:true,w:0,p:1};
I.u[7106] = {n:"Larvamuleto",t:1,d:"Con esta cabeza de larva alrededor del cuello te parecerás a Ulrik Holgan, famoso domador de larvas de los tiempos modernos.",ep:5,g:88,l:26,wd:true,fm:true,w:5,s:33,p:1950};
I.u[7107] = {n:"Larvabotas",t:11,d:"¿Quién no ha soñado nunca con hundirse los pies en las entrañas de una larva? Desde luego que tú no, entonces aprovecha la ocasión y déjate llevar por tus instintos más absurdos...",ep:1,g:53,l:33,wd:true,fm:true,w:10,s:33,p:3150};
I.u[7108] = {n:"Larvabolso",t:81,d:"Este bolso original pero sin adornos estaba muy de moda antiguamente. Es el típico ejemplo del mal gusto que tenían tus antepasados.",ep:5,g:60,l:27,wd:true,fm:true,w:10,s:33,p:2150};
I.u[7109] = {n:"Larvasombrero",t:16,d:"Por fin, tienes la ocasión de poder parecerte a una verdadera larva. Por primera ver podrás mostrar abiertamente tu modo de vida larvesco.",ep:5,g:103,l:34,wd:true,fm:true,w:10,s:33,p:3225};
I.u[7110] = {n:"Varita Larvesca",t:3,d:"Esta aterradora varita es en realidad una tripa de larva desecada, encantada y finalmente rehidratada. Ahora ya no tiene un aspecto muy normal, uno poco como tú, pero sin el encanto.",ep:5,g:19,l:40,wd:true,fm:true,w:5,an:11,e:[5,3,2,4,40,50,false,true],s:33,p:4000};
I.u[7112] = {n:"Dofus Salpicado",t:23,d:"Solamente el apareamiento de un dragón negro y de uno blanco pudo permitir la puesta de un huevo como este. O puede que se trate de una estafa.",ep:1,g:8,l:6,wd:true,fm:true,w:1,p:50000};
I.u[7113] = {n:"Dofawa",t:23,d:"Este Dofus se parece curiosamente a un huevo de dragopavo salvaje... Por una vez, puede que las apariencias no engañen.",ep:1,g:9,l:6,wd:false,fm:true,w:1,p:10};
I.u[7114] = {n:"Dofus Ébano",t:23,d:"Oscuro como las tinieblas, duro como la roca, el dragón que trajo al mundo tal maravilla ha tenido que acordarse de ese día durante mucho, mucho tiempo...",ep:1,g:7,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7115] = {n:"Dofus Marfil",t:23,d:"Si su blancura no tiene equivalente es porque Dardondakal, el Dragón Blanco, blanquea cada mañana el Dofus de Marfil con su aliento (es un viejo truco que le enseñó su abuelita Dragón).",ep:1,g:11,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7116] = {n:"Anillo Mertá",t:9,d:"Este anillo tiene un hechizo muy extraño. Pues una vez que te lo hayas puesto al dedo, ya no podrás hablar con otra persona que no sea el Joyero que lo ha creado.",ep:18,g:91,l:59,wd:true,fm:true,w:5,p:9155};
I.u[7117] = {n:"Alianza Étnica",t:9,d:"Un grupo de trovadores cosmopolitas, pero malísimos, habían decidido utilizar esta alianza para poder reconocerse entre la muchedumbre que venía asistir a sus representaciones. Al final, esta alianza no les sirvió de nada porque en ningún momento llegaron a alcanzar la fama. Según ciertas malas lenguas o buenas orejas, se lo merecieron.",ep:18,g:92,l:53,wd:true,fm:true,w:5,p:7150};
I.u[7118] = {n:"Anillo Mamestro",t:9,d:"Este anillo con forma de mariposa nocturna no hará que tus manos llamen la atención, pero tal vez no sea mala cosa...",ep:18,g:94,l:90,wd:true,fm:true,w:5,p:20775};
I.u[7119] = {n:"Anillo Kohono",t:9,d:"Curiosamente, el joyero que creó este anillo tiene cierto parentesco con el célebre orfebre John Limon. Según su creador, este anillo tiene el poder de enemistar a integrantes de grupos de trovadores que llevaban años tocando juntos hasta el punto incluso de separarlos para emprender carreras de solistas. Hasta ahora nadie supo por qué...",ep:18,g:85,l:58,wd:true,fm:true,w:5,p:8750};
I.u[7120] = {n:"Anillo de Eon",t:9,d:"Este anillo pertenecía a un anciano que según ciertas leyendas, salvó de un terrible diluvio a todas las criaturas de la Isla de Moon llevándolas en su balsa. Otra versión de los hechos cuenta que cambió su balsa por un monito en vez de salvar a las criaturas de la isla.",ep:18,g:86,l:44,wd:true,fm:true,w:2,p:5350};
I.u[7121] = {n:"Anillo Cosonomial",t:9,d:"Este anillo con vida tiene un terrible embrujo capaz de enfermar a los aventureros más resistentes. Dicen que en su origen había sido creado para curar al que lo llevara puesto en el índice y que se volvió agresivo tras haber atravesado contra su voluntad lugares poco recomendables.",ep:18,g:87,l:50,wd:true,fm:true,w:5,p:6655};
I.u[7122] = {n:"Anillo Novato",t:9,d:"Anillo de los novatos por excelencia, también se trata del anillo que simboliza mejor un buen número de costumbres inconfesables. En todo caso, parece que te corresponda perfectamente.",ep:16,g:88,l:18,wd:true,fm:true,w:2,p:1100};
I.u[7123] = {n:"Anillo Bsceno",t:9,d:"Reservado para aventureros mayores de edad, este anillo puede chocar la sensibilidad de las más jóvenes criaturas.",ep:18,g:95,l:70,wd:true,fm:true,w:2,p:12900};
I.u[7124] = {n:"Dofus de leche",t:42,d:"Este Dofus posee un poder extraordinario, el de hacerte babear de felicidad.",ep:1,g:27,l:1,wd:false,fm:true,w:1,p:1};
I.u[7125] = {n:"Dofus de chocolate blanco",t:42,d:"Este huevo de Dofus posee un poder extraordinario, el de hacerte babear de felicidad.",ep:1,g:28,l:1,wd:false,fm:true,w:1,p:1};
I.u[7128] = {n:"Anillo Karina",t:9,d:"A pesar de lo que puedan pensar algunos, este anillo no tiene ninguna relación con la despampanante Karina que en varias ocasiones se mostró en el bar de los piratas de Sufokia llevando vestidos un tanto exóticos. En realidad, ha sido un músico que también criaba Tofus que le dio este nombre al anillo. Poniéndolo en el pulgar, es capaz de emitir un sonido parecido al que se puede oír cuando se le retuerce el pescuezo a un Tofu.",ep:18,g:89,l:54,wd:true,fm:true,w:5,p:7700};
I.u[7129] = {n:"Panda de chocolate",t:42,d:"No te confundas, no solamente el chocolate le da su sabor sino que la forma de la golosina le proporciona también su interés. Prueba un stropajo de chocolate, tal vez entiendas mejor.",ep:0,g:31,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[7130] = {n:"Receta del Dofus de chocolate",t:24,d:"La receta del Dofus de chocolate, lo mejor para impresionar a tus amigos.",ep:1,g:250,l:1,wd:false,fm:true,w:0,p:100};
I.u[7131] = {n:"Anillo Pyó",t:9,d:"Más de un aventurero ha soñado con esta joya antes que tú. Pues se le atribuyen muchas virtudes, como la de transformar a los más belicosos en tranquilos soñadores. Las instrucciones de uso explican claramente que no es aconsejable tirarlo al fuego, pero no llega a indicar el porqué.",ep:16,g:90,l:57,wd:true,fm:true,w:5,p:8475};
I.u[7132] = {n:"Anillo Rigamia",t:9,d:"Las últimas palabras del creador sirvieron de fuente de inspiración para nombrar este anillo: \"¡Oh, Rigamia mía!\" dijo en un estertor de agonía terriblemente divertido. Es importante subrayar que la realización de este anillo de Bambú es anterior a la aparición de los Bambúes. Un enigma que no se resolverá antes de que pasen unas cuantas décadas...",ep:16,g:96,l:49,wd:true,fm:true,w:5,p:6300};
I.u[7133] = {n:"Mixomawosis",t:30,d:"Cualquier Wabbit te lo podrá decir, si no quieres ver la vida en rojo, procura evitar como puedas la Mixomawosis.",ep:1,g:9,l:1,wd:false,fm:true,w:0,p:1};
I.u[7134] = {n:"Rabia",t:30,d:"Dicen que la rabia transforma completamente los seres infectados. Los guerreros se vuelven pacifistas y las personas tranquilas se vuelven agresivas. En cambio, las que ya babeaban antes, seguirán babeando.",ep:1,g:10,l:1,wd:false,fm:true,w:0,p:1};
I.u[7135] = {n:"Maloria",t:30,d:"Esta es una enfermedad que se transmite por las picaduras de los Moskitos que viven en lugares de clima tropical. La Maloria también es conocida por algunos indígenas bajo el nombre de Laporia porque parece que la enfermedad se transmite también por los escupitajos de Moskitos.",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[7136] = {n:"Medalla Kido",t:1,d:"Esta medalla pertenecía a un célebre Pandawa, maestro de una vieja escuela de artes marciales que enseñaba a sus discípulos a defenderse utilizando la fuerza de sus adversarios. Su escuela acabó desapareciendo ya que sus adversarios no eran ya suficientemente fuertes.",ep:19,g:89,l:125,wd:true,fm:true,w:10,p:40425};
I.u[7137] = {n:"Capa Huccino",t:17,d:"Esta capa ha sido diseñada para cumplir una función principal: la de matener despierto a su portador durante varios días seguidos. El resultado es muy efectivo ya que es tan rígida que, pase lo que pase, seguirás siempre en pie . Pero ten mucho cuidado, porque ya no serás capaz de atarte los cordones.",ep:16,g:15,l:44,wd:true,fm:true,w:15,p:5300};
I.u[7138] = {n:"Ortiz",t:17,d:"Los más grandes se la han puesto en alguna ocasión, su suavidad legendaria le ha llevado a la fama, la cual permite que se pueda llevar sin ropa interior en temporadas de calor. Una forma elegante de exhibicionismo que ha seducido a más de un aventurero.",ep:19,g:91,l:125,wd:true,fm:true,w:15,p:40175};
I.u[7139] = {n:"Cinturón de Santy",t:10,d:"Santy era un cazaprimas muy famoso en la provincia de Amakna, no había reto o concurso que le resistiera. Incluso había fundado un gremio con sus compañeros Fakas, Jami y Adnokana llamado \"Remolkamadrina\". Desafortunadamente se disolvió unos meses más tarde... dentro de un tonel de cerveza. Esto fue lo único que quedó de ellos.",ep:19,g:82,l:125,wd:true,fm:true,w:15,p:39975};
I.u[7140] = {n:"Xenatura",t:10,d:"Contrariamente a las apariencias, Xena no era una guerrera sino una zapatera. Sus formas generosas y su pasión sin límite por las tareas domésticas la predestinaban a una brillante carrera en las cervecerías de Amakna. Pero la fuerza del destino decidió por ella.",ep:19,g:83,l:125,wd:true,fm:true,w:15,p:40125};
I.u[7141] = {n:"Holuna",t:16,d:"Este extraño sombrero te protegerá contra los rayos del sol, incluso cuando es de noche. Ten cuidado, este sombrero vuelve a la vida una vez cada treinta años y se vuelve contra su amo intentando asfixiarlo durante su sueño.",ep:19,g:111,l:122,wd:true,fm:true,w:10,p:37925};
I.u[7142] = {n:"Piruk",t:16,d:"Algunos xelors utilizaban este sombrero para esconder su incipiente calvicie. Algunos anutrofs lo utilizaban, incluso, para esconder a sus mujeres. Esta era una forma muy hábil de esconder dos de los mayores problemas de la vida cotidiana.",ep:19,g:112,l:145,wd:true,fm:true,w:15,p:46980};
I.u[7143] = {n:"Solomonk",t:16,d:"El Solomonk era el sombrero de un viejo jefe de una tribu pandawa experto en pócimas laxativas. A menudo, los pandawas estaban obligados a probar ellos mismos los efectos de sus pócimas y por eso utilizaban este sombrero que aunque no les favorecía mucho por lo menos resultaba ser un buen orinal.",ep:19,g:123,l:120,wd:true,fm:true,w:50,p:36880};
I.u[7144] = {n:"Paliducha",t:16,d:"Ya hace tiempo que esta cofia de novia ha pasado de moda, tal vez por culpa de su encaje que parece datar de otra era. Ha sido reciclada como braga y si uno la coloca sobre una cabeza muy peluda, podría hacer entrar en trance al más hastiado de los chafers.",ep:19,g:116,l:108,wd:true,fm:true,w:15,p:29775};
I.u[7145] = {n:"Sombrero del Gaddi",t:16,d:"El Gaddi era una extraña criatura del mundo imaginario, los rasgos que mejor la caracterizaban eran su astucia extraordinaria, su total aversión por el reino vegetal y su facultad para ayunar durante varios días en tiempo de guerra. Obviamente era imposible  adiestrar una criatura tan compleja. Por eso la dejaron vivir en paz en las minas sin fondo de Kruup, donde conoció a una vieja Lich devoradora de jalatines.",ep:19,g:115,l:106,wd:true,fm:true,w:15,p:26375};
I.u[7146] = {n:"La Bertoza",t:16,d:"Este sombrero superpoderoso es más una peluca que otra cosa, pero poco importa ya que es superpoderoso. A su propietario le gustaba disfrazarse y hacerse pasar por otras personas para aprovecharse de los inocentones. Sus lúgubres juegos fueron descubiertos al final, al igual que su cráneo cuando le quitaron la cofia. Su inmenso talento le salvó la vida ya que se le propuso, unos días antes de ser ajusticiado, esculpir una estatua gigante con la efigie de las partes íntimas del maxilubo. Aún así lo quemaron vivo tras haber acabado la estatua.",ep:18,g:114,l:81,wd:true,fm:true,w:10,p:16925};
I.u[7149] = {n:"Cuadradito de chocolate negro",t:42,d:"Extraído del cacao bruto, este cuadradito de chocolate es sabrosísimo. Pero ten cuidado, no abuses del chocolate o tendrás problemas de digestión...",ep:1,g:34,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:200};
I.u[7150] = {n:"La Muleta",t:16,d:"Este sombrero de sorprendente nombre, pertenecía a un pobre Zurcarák que había perdido el uso de la palabra tras un terrible trauma. Artista empedernido, se le obligó a seguir una formación de Cervecero. Se ahogó dentro de un barril lleno de cerveza y de lágrimas cuando había cumplido catorce años. Afortunadamente, la cerveza no sufrió daños ya que el sacerdote encargado del funeral, cayó en un coma etílico durante varios años antes de retomar la ceremonia por donde la había dejado.",ep:19,g:109,l:111,wd:true,fm:true,w:20,p:31725};
I.u[7151] = {n:"Kolososo",t:16,d:"El eslogan publicitario de este casco era: \"Ponte un kolososo y pasarás por un loco... pero muy salado\". Los anuncios publicitarios nunca engañan, excepto este.\n¡Consíguelo ya!",ep:19,g:108,l:120,wd:true,fm:true,w:15,p:36925};
I.u[7152] = {n:"Kanístero",t:16,d:"Los bomberos de Amakna usaban este sombrero en forma de caldero cuando se incendiaban los campos de cereales. Hoy en día, sirve sobre todo a los cerveceros y a las camareras de las tabernas para limpiar los vómitos de sus mejores clientes.",ep:19,g:110,l:120,wd:true,fm:true,w:20,p:36675};
I.u[7153] = {n:"Martillo Bombo",t:7,d:"Este enorme martillo hace un ruido increíble cuando cae sobre un cráneo de Yopuka, ya que tiende a amplificar los sonidos. Sorprendente, pero terriblemente eficaz.",ep:19,g:51,l:126,wd:true,fm:true,w:15,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>200",p:40200};
I.u[7154] = {n:"Martillo Polgarcito",t:7,d:"Este ligero martillo, estaba en principio diseñado para los pequeños seres: los Xelors utilizaban el mango, y las Araknas recibían el mazo sobre la cabeza. Rápidamente ha sido desviado de su uso y ahora se convirtió en un pequeño juguete para los jóvenes Yopukas chapuceros.",ep:18,g:46,l:107,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>350&CV>200&CW>100",p:29475};
I.u[7155] = {n:"Martillo del Capitán Kodah",t:7,d:"El célebre Capitán Kodah utilizó durante decenas de años este terrible martillo para acabar con todos los que se oponían a él, incluido mujeres y niños. Sin embargo, su mal carácter legendario y su pronunciado gusto por el alcohol hicieron de él una persona muy respetada por los distintos ejércitos, tanto enemigos como aliados.",ep:18,g:48,l:113,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,40,60,false,false],c:"CI>150&CW>100&PG=5",p:32650};
I.u[7156] = {n:"Martillito Ronto",t:7,d:"Este martillo oxidado es perfecto para reventar arces, o Moskitos.",ep:18,g:50,l:107,wd:true,fm:true,w:20,an:15,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>150&CV>150&(PG=2|PG=5)",p:334251};
I.u[7157] = {n:"Martillito Holón",t:7,d:"Este martillo se utilizaba antiguamente para hacer sonar la campana de la iglesia de Amakna. Hoy en día, todavía sirve para hacer música machacando los huesos de los imprudentes por ejemplo.",ep:19,g:49,l:124,wd:true,fm:true,w:15,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CI>250",p:29400};
I.u[7158] = {n:"Martillo Katraz",t:7,d:"Diseñado para un alquimista reputado durante una estancia en las prisiones de Brakmar, este martillo tenía que servir, en su origen, para romper el material de alquimia de sus competidores.",ep:19,g:47,l:143,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CA>250&PG=5",p:46550};
I.u[7159] = {n:"Martillo Escarbador",t:7,d:"Este martillo de minero se puede utilizar como una pala o como pico según tus necesidades. Sin embargo, se proscribe su utilización en jardinería, ya que tiende a destruir definitivamente los céspedes.",ep:19,g:52,l:135,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>300",p:41200};
I.u[7160] = {n:"Arco Mático",t:2,d:"Este arco ha sido encantado hace mucho tiempo con una magia de las más oscuras. Esto debería preocupar a su propietario tanto como a sus enemigos.",ep:19,g:44,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CI>400&PG=9",p:36900};
I.u[7161] = {n:"Arco Jabato",t:2,d:"Este arco era utilizado principalmente para cazar los Jabalíes de las Llanuras. Pues es tan potente que permite matar con una sola flecha a varios jabatitos. Bueno, a condición de que estos estén perfectamente en fila.",ep:18,g:45,l:107,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CI>250&CA>150",p:29325};
I.u[7162] = {n:"Arco Mustabante",t:2,d:"Este arco pertenecía a un trovador independiente, conocido sobre todo por destruir los tímpanos de sus enemigos con sus cantos de guerra. Fue exiliado durante varios años en Pandala por culpa de sus odas capaces de ensordecer los Cuerboks de Brakmar. Tras haber causado la locura de varias generaciones de Pandawas, fue sencillamente entregado al gran Sorlok, para ser digerido lentamente durante más de 752 años.",ep:19,g:46,l:130,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,3,6,30,50,false,true],c:"CA>200&CC>70&PG=9",p:30000};
I.u[7163] = {n:"Arco Disuasivo",t:2,d:"Este arco era principalmente utilizado como un arma de disuasión. Su propietario explicaba que sus flechas estaban envenenadas, lo cual asustaba mucho la población local. De esta manera, conseguía también que sus enemigos dieran marcha atrás en el último momento.",ep:19,g:47,l:124,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"PG=9&CA>250",p:39050};
I.u[7164] = {n:"Arco Angélico",t:2,d:"Este arco ligero y frágil sedujo a un buen número de aventureros más interesados en las apariencias que en la eficacia.",ep:19,g:48,l:143,wd:true,fm:true,w:15,an:10,e:[5,5,2,6,30,50,false,true],c:"CA>120&CI>120&CC>120&CV>300",p:46025};
I.u[7165] = {n:"Varita Eide",t:3,d:"Esta varita explosiva fue sumergida dentro de la lava de un volcán en erupción antes de ser esculpida y hechizada. No es preciso decir que es muy poderosa a pesar de su ridículo aspecto.",ep:18,g:54,l:105,wd:true,fm:true,w:15,an:11,e:[5,4,3,6,50,50,false,true],c:"CI>300",p:28625};
I.u[7167] = {n:"Varita Cétera",t:3,d:"El artesano que está al origen de esta varita tenía numerosos aprendices que hacía trabajar durante largas jornadas. Se supone que tenía que enseñarles los secretos del oficio, pero en realidad era un pésimo pedagogo, empezaba siempre sus explicaciones pero no las terminaba nunca.",ep:18,g:50,l:43,wd:true,fm:true,w:5,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>60",p:5000};
I.u[7168] = {n:"Varita Kacikera",t:3,d:"Tras haber sido esculpida, esta varita fue sumergida dentro de un barril de ron durante varios años. Ya empieza a pudrirse, pero aún así conserva algunas propiedades mágicas suficientes para divertir o exterminar a tus aliados.",ep:18,g:51,l:63,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150",p:4800};
I.u[7169] = {n:"Varita Chispera",t:3,d:"Ideal para prender fuego o para poner ambiente durante las bodas aburridas. Esta varita te permitirá brillar al menos una vez en tu vida. No te pierdas esta ocasión.",ep:18,g:52,l:81,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>200",p:17000};
I.u[7170] = {n:"Varita Rosca",t:3,d:"Rosca era una leñadora muy poco femenina... bueno, digámoslo claramente: era fea como un cuerno de Jalató. Sin embargo, un panadero ciego y sordomudo creó esta varita para pedirle su mano. Rosca se conmovió tanto que se entregó entera a su futuro marido. Desde entonces los aventureros usan la expresión \"no comerse una Rosca\" cuando van de cacería y regresan sin haber atrapado nada.",ep:18,g:46,l:112,wd:true,fm:true,w:15,an:11,tw:true,e:[5,2,3,4,30,50,false,true],c:"CI>350&CV>200",p:32330};
I.u[7171] = {n:"Varita Despistada",t:3,d:"El escultor de esta varita tenía la mala costumbre de olvidar a sus hijos en el cole. Su esposa, una madre indigna como tantas otras, se alegraba cuando eso ocurría. Harto de tener tan mala memoria, esculpió esta varita que cobraba vida todos los días y le recordaba de ir a recoger a sus hijos. Luego intentó hacer otras varitas semejantes con el poder de recordar a su esposa de hacer las tareas domésticas, pero nunca alcanzó a tener el poder suficiente para conseguir aquel reto.",ep:19,g:47,l:127,wd:true,fm:true,w:15,an:11,tw:true,e:[10,4,4,6,40,60,false,true],c:"CI>300&CV>300",p:43125};
I.u[7172] = {n:"Varita Fekal",t:3,d:"Esta varita mágica todavía se usa para vaciar las fosas sépticas, limpiar los aseos y puede servir también para que te limpies las fosas nasales. Los escultores más expertos te explicarán que saca toda su magia de las inmundicias con las que ha podido estar en contacto y principalmente con las de tu nariz.",ep:18,g:49,l:105,wd:true,fm:true,w:20,an:11,tw:true,e:[10,4,2,4,30,60,false,true],c:"CI>200&CW>50",p:28375};
I.u[7173] = {n:"Varita Estranguladora",t:3,d:"Esta horrible varita es capaz de enrollarse alrededor del cuello de tus adversario para estrangularlos lenta y eficazmente. Una forma original y distinguida para matar a los adversarios que respetas un poco.",ep:18,g:48,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,4,50,50,false,true],c:"CI>50",p:2100};
I.u[7174] = {n:"Capa Pandawushu",t:17,d:"Esta capa es indispensable para el entrenamiento al Pandawushu...",ep:1,g:89,l:10,wd:true,fm:true,w:5,p:10};
I.u[7175] = {n:"Certificado shamánico",t:24,d:"Certificado médico indispensable para poder practicar el Pandawushuka.",ep:18,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[7176] = {n:"Raíz Kyerda Unida",t:4,d:"Aunque se trate de un bastón compuesto por varios trozos de raíces de Kyerda, esta obra tiene mucha clase... incluso se podría decir que es de clase muy obrera. Los cachos de madera que la componen no tenían un gran valor por separado pero una vez reunidos fueron poco a poco cobrando fama y poder. Dicen que quien posea este bastón \"agrupará a todos en la lucha final\". Ni los sabios de Amakna supieron decir de donde venía esta estúpida leyenda...",ep:19,g:53,l:143,wd:true,fm:true,w:15,an:12,e:[10,4,1,1,45,70,false,false],c:"CS>150&CV>400&CI>50&CA>50",p:46600};
I.u[7177] = {n:"Pañuelo Pandawushu",t:16,d:"Si te atas este pañuelo pandawushu alrededor del cráneo, podrás sin problema asustar a los jóvenes Zollos haciéndote pasar por un experto en artes marciales. No te olvides de pegar unos cuantos gritos para parecer más experto todavía.",ep:1,g:102,l:1,wd:false,fm:true,w:5,p:10};
I.u[7178] = {n:"Raíz Cynorrhodon",t:4,d:"Desde los albores de la lucha armada, los sadidas utilizan raíces mágicas como si fueran bastones. Sin embargo, parece ser que algunos se niegan todavía a utilizar esta por asemejarse más a una fruta que a una raíz. Fruta o raíz, poco importa. El caso es que haga mucho daño ahí donde caiga.",ep:18,g:58,l:86,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,50,50,false,false],c:"CI>150",p:19100};
I.u[7179] = {n:"Ruta y Camino: Bosque Maldito",t:25,d:"Este libro describe los mejores itinerarios turísticos del laberinto del bosque maldito... ¡Una nueva orientación para la vida del aventurero! Eso es lo que pone en la portada.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7181] = {n:"Raíz Sin Semilla",t:4,d:"Este bastón pertenecía a una joven sadidita que tenía dos pasiones en su vida: La jardinería y la canción. Hay que confesar que su jardín siempre estaba bien cuidado y lleno de especies con diversas propiedades curativas o recreativas. En cambio, cuando cantaba desafinaba hasta tal punto que sus amigos acababan siempre amordazándola y colgándola de uno de los olmos de su jardín.",ep:18,g:54,l:106,wd:true,fm:true,w:15,an:12,tw:true,e:[10,4,1,1,50,50,false,false],c:"CV>250&CW>60",p:28575};
I.u[7182] = {n:"Raíz Tziar",t:4,d:"Tziar no tenía mucha suerte, su marido era un tremendo vago incapaz de asumir su estatuto de cabeza de familia. La pobre Tziar estaba obligada a imponerle condiciones en permanencia: \"Te daré tu Gelatina de Fresa si vas a segar los cereales\" o bien \"Podrás fumar Champis cuando hayas esquilado a los Jalatós\" para citar solamente las frases más conocidas. Obviamente, esta historia no tiene nada que ver con esta raíz poderosísima, al menos que habiendo pertenecido durante tanto tiempo a esta mujer, acabe imponiéndote también condiciones.",ep:18,g:60,l:103,wd:true,fm:true,w:15,an:12,tw:true,e:[15,4,1,1,25,50,false,false],c:"CV>200",p:27280};
I.u[7183] = {n:"Raíz atractiva",t:4,d:"Esta raíz tiene formas puras, que algunos artesanos no dudarían en calificar de perfectas. Tal vez sea por eso que algunos aventureros le tienen más cariño que a su propia dulcinea.",ep:18,g:55,l:88,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>70",p:20000};
I.u[7184] = {n:"Raíz siniestra",t:4,d:"Esta terrible raíz es sobre todo famosa por su capacidad para desencadenar catástrofes climatológicas en aquellos lugares donde es utilizada. Procura entonces no utilizarla para patear el trasero de tus adversarios, nadie sabe les que podría ocurrir... a sus traseros.",ep:18,g:56,l:86,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>100",p:18945};
I.u[7185] = {n:"Raíz Cúbica",t:4,d:"Esta raíz te permitirá comprobar que todo cuerpo sumergido en un fluido experimenta un empuje vertical y hacia arriba igual al peso de fluido desalojado. Pero también la puedes utilizar para desnucar a tus enemigos, que estos estén sumergidos o no.",ep:18,g:57,l:103,wd:true,fm:true,w:20,an:12,e:[5,5,1,1,50,50,false,false],c:"CV>200&CW>150",p:27425};
I.u[7186] = {n:"Fecha de grado",t:24,d:"Sobre esta hoja está escrita la última fecha en la que pasaste de grado Pandawashuka.",ep:18,g:58,l:0,wd:true,fm:true,w:0,p:1};
I.u[7187] = {n:"Jakchir Arco",t:2,d:"Este arco tiene fama de robar el dinero del pueblo a distancia y con total impunidad. Lo más sorprendente es que, a pesar de eso, sigue siendo muy popular con el paso de los años. Afortunadamente para el pueblo, ya empieza a estar muy usado...",ep:19,g:50,l:124,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,4,6,30,2,false,true],c:"CA>100&CC>100&PG=9",p:40000};
I.u[7188] = {n:"Dagas Exprimidoras",t:5,d:"Estas dagas son perfectas para cortar frutas o para cortar la hierba bajo los pies de tus adversarios. Una forma original de sorprenderlos.",ep:18,g:48,l:113,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,35,50,false,false],c:"CA>100&CI>100",p:32575};
I.u[7189] = {n:"Rod Gers",t:4,d:"Este bastón es una versión mejorada del célebre God Rod. Ha sido diseñado y confeccionado tras numerosas pruebas que las Sacerdotisas del Amor hicieron con el God Rod. Incluso Kuri en persona ha utilizado este modelo, lo cual hace que sea de algún modo una pieza única.",ep:19,g:59,l:176,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,100,false,false],c:"CI>450",p:57000};
I.u[7190] = {n:"Dagas Maydhyn China",t:5,d:"Estas sublimes dagas han sido confeccionadas sobre medida para una Sramita insatisfecha. Pues estaba decepcionada por no encontrar dagas a su medida y decidió lanzar un reto a todos los forjadores de dagas de Amakna: Aquel que consiguiera forjar dagas capaces de matar de un golpe a cualquier Tofu podría pasar 3 noches en su compañía. A pesar de lo que pensaba, este anunció no tuvo el efecto que deseaba ya que nadie participó al desafío. Tuvo que esperar un centenar de años para que un forjador de dagas Anutrof retirado estuviera interesado por la recompensa que con el tiempo, había cambiado mucho...",ep:18,g:45,l:100,wd:true,fm:true,w:10,an:13,tw:true,e:[15,3,1,1,35,50,false,false],c:"CS>150&CA>150",p:21800};
I.u[7191] = {n:"Engastador de Ramugro",t:5,d:"Ramugro era un viejo Sram que se volvió un experto en la confección de joyas. Utilizaba este Engastador para sus creaciones, pero también para asesinar a sus propios clientes cuando se aburría demasiado en su joyería. Era famoso por su mal carácter e incluso destruía con su engastador sus creaciones más bellas. Hoy en día, los que utilizan estas dagas honran su memoria cortando con ella las partes más valiosas de las criaturas...",ep:19,g:49,l:127,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,30,false,false],c:"CA>200&CS>200",p:40825};
I.u[7192] = {n:"Garra de Grizmoh Guay",t:6,d:"Grizmoh Guay nunca consiguió utilizar correctamente esta garra. A fuerza de jugar a las cartas y a los juegos de dinero al mismo tiempo que bebía cerveza, sus músculos acabaron por atrofiarse muy rápido. Para otras persona, parece ser que este tipo de diversiones puede incluso llegar a atrofiar otros órganos.",ep:18,g:59,l:111,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>300&CA>120",p:31625};
I.u[7193] = {n:"Espada de Dark Vlad",t:6,d:"Solamente Dark Vlad en persona es capaz de hacer resurgir toda la magia de esta espada para volverla realmente resplandeciente. Si la llevas contigo, podrás demostrar con orgullo que no acabaste como aquellos ridículos aventureros que murieron atravesados por ella.",ep:19,g:61,l:126,wd:true,fm:true,w:20,an:14,e:[12,5,1,1,50,100,false,false],c:"CV>250&CI>300&PG=8",p:40625};
I.u[7194] = {n:"Arc Anum",t:2,d:"Este arco demuestra que la asociación de la tecnología y de la magia puede dar excelentes resultados. Sin embargo, cayó en el olvido muy rápidamente por razones todavía desconocidas. Incluso el artesano que creó este arco estuvo obligado a cerrar su tienda, lo cual entristeció a muchos de sus antiguos clientes.",ep:18,g:49,l:96,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"CI>200&CA>60&PG=9",p:23500};
I.u[7195] = {n:"Karnak",t:6,d:"Esta legendaria espada ha sido forjada durante los albores, por un ejército de Anutrofs borrachos, en el fondo de las minas de Grimoth. Desprende una aura de poder sorprendente, pero también un olor a cerveza caducada.",ep:19,g:60,l:158,wd:true,fm:true,w:15,an:14,tw:true,e:[10,5,1,1,50,80,false,false],c:"CV>300&CA>300&PG=8",p:51100};
I.u[7196] = {n:"Escudo Pandawushuka",t:82,d:"El Maestro Pandawushuka en persona te ha regalado este escudo con las armas de su escuela de artes marciales. Es el símbolo de una formación finalizada con éxito y honor.",ep:0,g:34,l:1,wd:true,fm:true,w:1,p:1};
I.u[7197] = {n:"Martillito Blerón",t:7,d:"En su origen, este martillo servía para romper las tabletas de chocolate, y hacerlas polvo. A lo largo de los años, adquirió un olor y un gusto deliciosos. Esta es una buena razón para que tus enemigos la prueben.",ep:19,g:53,l:150,wd:true,fm:true,w:100,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CI>150&CV>200&(PG=5|PG=2)",p:473751};
I.u[7198] = {n:"Afeitadora Nocturna",t:6,d:"Cualquier viejo Anutrof te lo podrá decir, una hermosa barba ha de estar cuidada día y sobre todo noche. Esta hoja está tan bien afilada que incluso puede servir para el vello de las damas.",ep:18,g:62,l:106,wd:true,fm:true,w:15,an:14,e:[10,4,1,1,50,50,false,false],c:"CS>200&CA>100",p:28925};
I.u[7199] = {n:"Espada Carnicera",t:6,d:"Esta espada pertenecía a Metzger, el carnicero. La utilizaba para extraer rápidamente las entrañas de sus enemigos y de este modo hacer salchichas que vendía por unos pocos kamas en los mercados de Bonta.",ep:19,g:63,l:135,wd:true,fm:true,w:15,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>200&CA>120&CV>300",p:44225};
I.u[7200] = {n:"Sable Shodanwa",t:6,d:"Los discípulos Pandawushuka utilizan este magnífico sable para alcanzar el grado Shodanwa sin perder la vida entre tanto.",ep:18,g:55,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>60",p:4300};
