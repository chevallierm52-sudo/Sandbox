I.u[2187] = {n:"Pischi Dicumpetición",t:41,d:"Este pescado solamente se puede pescar en las pischina de Sufokia. Es un cruce entre una multitud de especies de pescados.",ep:7,g:400,l:1,wd:true,fm:true,w:20,p:1};
I.u[2188] = {n:"Caña para pischis",t:20,d:"Sólo esta caña permite pescar los pischis en la pischina de Sufokia.",ep:7,g:8,l:1,wd:true,fm:true,w:2,an:18,e:[1,5,1,5,10,10,false,true],p:50};
I.u[2189] = {n:"Certificado de buen voto",t:24,d:"Este cachito de papel firmado por Satirev Refibrom demuestra que has votado durante un juicio... Y que has votado bien.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2190] = {n:"Formulario de pesquisa n° 33",t:80,d:"Este formulario permite generalmente hacer confesar a un sospechoso en algún caso criminal. Sólo tienes que cumplimentarlo para crear un falso interrogatorio de \"Oni Tecen\". (Haz clic y utilizálo sobre ti mismo).",ep:16,g:6,l:1,wd:true,fm:false,w:1,c:"PO=2177&Ps=1&Pa=27",u:true,p:100};
