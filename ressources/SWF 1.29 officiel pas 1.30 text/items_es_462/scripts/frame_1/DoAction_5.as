I.u[1889] = {n:"Pluma de cuerbok",t:53,d:"Antiguamente se usaba para escribir pero ahora esta pluma la usan principalmente los sastres de alta costura. Pues los cuerboks son cada vez menos generosos y ya no entregan sus plumas al primero que se les presenta. Definitivamente, la solidaridad se está perdiendo.",ep:1,g:327,l:20,wd:true,fm:true,w:1,p:1};
