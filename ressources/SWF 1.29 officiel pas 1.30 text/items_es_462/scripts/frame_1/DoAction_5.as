I.u[2192] = {n:"Documentos robados",t:24,d:"Estos documentos ultra secretos están sellados con un glifo de la muerte. Si lo abres no podrás leerlos.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2193] = {n:"Bola de pelos de Puja",t:24,d:"Le has partido la cara al hijo de Oto Mustam. Seguro que no le va a gustar nada.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2194] = {n:"Memo",t:24,d:"Traer 10 cortezas de abráknido.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2195] = {n:"Diente",t:24,d:"Este diente debe probablemente pertenecerte a lo visto de la paliza que te ha dado Oto Mustam. Será mejor esperar a que se calme antes de hablarle de nuevo si no quieres que te masacre otra vez.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2196] = {n:"Conocimiento",t:29,d:"Esta bendición permite ganar Inteligencia para los siguientes combates.",ep:18,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
