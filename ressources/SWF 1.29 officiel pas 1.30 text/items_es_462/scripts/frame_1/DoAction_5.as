I.u[2040] = {n:"Cofre escondido de Tsog",t:24,d:"Has encontrado el cofre de Tsog dentro de una cajita. Qué extraño, esta caja huele igual que Tsog, es un olor indescriptible.",ep:2,g:56,l:1,wd:true,fm:true,w:0,p:1};
I.u[2041] = {n:"Jamón maloliente de jalató",t:24,d:"Este jamón hiede a muerte aunque eso no tenga que ver con el fallecimiento prematuro de su propietario.",ep:1,g:64,l:20,wd:true,fm:true,w:0,p:1};
I.u[2042] = {n:"Hueso de Mak Gahan",t:24,d:"Has cogido este hueso tras haber esparcido los restos del cuerpo de Mak Gahan el chafer, por toda la habitación.",ep:1,g:57,l:1,wd:true,fm:true,w:0,p:1};
I.u[2043] = {n:"Nombre del asesino garabateado",t:24,d:"Sobre este cacho de papel pegajoso y maloliente se encuentra escrito el nombre del asesino del encargado del Gatokemao.",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2044] = {n:"Cerveza del Gatokemao",t:37,d:"Esta cerveza se parece demasiado al meo de gato... o no lo suficiente.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:6};
I.u[2045] = {n:"Recibo de caja",t:24,d:"Este documento demuestra que has traído una caja.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2046] = {n:"Llave de Brakmar",t:24,d:"Esta llave ha sido robada por una ardilla por oscuras razones.",ep:2,g:61,l:1,wd:true,fm:true,w:0,p:1};
I.u[2047] = {n:"Lista de los soldados que hacen una pausa",t:24,d:"Esta lista te ha sido entregada por el miliciano en la taberna. En ella se hallan escritos los siguientes nombres: \nBrank Thoof, Haco Norss, Jack Rottance, Kad Maxy",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2048] = {n:"Lista de los soldados que hacen una pausa",t:24,d:"Esta lista te ha sido entregada por el miliciano en la taberna. En ella se hallan escritos los siguientes nombres: \nHaco Norss, Tink Berval, Brank Thoof, Kad Maxy, Seta Bnamron",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2049] = {n:"Confesión del Guerrero Xale Gordinflón",t:24,d:"Xale Gordinflón reconoce no ir a la taberna, sin embargo se toma pausas a menudo.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2050] = {n:"Confesión del Guerrero Nager Nacmeil",t:24,d:"El guerrero Nager Nacmeil reconoce no tomarse pausas, porque no se siente muy bien en estos momentos.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2051] = {n:"Confesión Bishom Pot",t:24,d:"Bishom Pot lo confiesa todo, su comportamiento no tiene perdón.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2052] = {n:"Permiso firmado y fechado",t:24,d:"Este documento indica que estás de permiso durante un día entero.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
