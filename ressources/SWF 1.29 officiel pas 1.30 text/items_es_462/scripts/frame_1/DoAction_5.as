I.u[1792] = {n:"Lubina Fónica",t:41,d:"Se trata de una pariente de la lubina mericana. Hoy en día tiende a desaparecer. En gran parte ha sido diezmada por culpa de un estúpido rumor que pretendía que comerla era bueno para la voz.",ep:1,g:303,l:70,wd:true,fm:true,w:3,p:30};
