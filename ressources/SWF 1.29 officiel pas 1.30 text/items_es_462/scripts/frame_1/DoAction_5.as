I.u[2172] = {n:"Lista de muestras que tienes que encontrar",t:24,d:"Raaga te ha anotado rápidamente las pautas que tienes que seguir para encontrar buenas muestras de lava: \nBuscar en un perímetro de 5 lugares. Buscar pequeños picos.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2173] = {n:"Los secretos del lenguaje ardilla",t:25,d:"Este diccionario te enseña a dialogar con una ardilla, o por lo menos te ayudará un poco...",ep:2,g:6,l:1,wd:true,fm:true,w:1,u:true,p:50};
