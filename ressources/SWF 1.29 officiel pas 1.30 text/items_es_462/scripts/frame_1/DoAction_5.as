I.u[2074] = {n:"Bwak de Fuego",t:18,d:"Este entrañable pequeño bwak se convertirá, más tarde, en un terrible kwak. Hasta que ese momento llegue, no tengas miedo de que se quede a tu lado.",ep:1,g:3,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:2,p:1};
