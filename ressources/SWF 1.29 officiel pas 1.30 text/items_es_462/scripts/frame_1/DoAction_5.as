I.u[2078] = {n:"Testamento de Ixa Mustam",t:24,d:"El testamento del padre de Oto Mustam, está escrito en antiguo brakmariano, una lástima para ti, tu dominio de esta lengua se puede resumir con la palabra: \"Guo\' rhalys!\" .",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2079] = {n:"Vino de Zampávoro",t:24,d:"Parece ser que 20 años son necesarios para conseguir destilar zumo de Zampávoro sin hacer que el vino se vuelva tóxico.",ep:2,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[2080] = {n:"Zumo de Zampávoro",t:24,d:"El zumo de Zampávoro es tan tóxico como el zumo de scorbuto. Pero bien destilado da un vino con un sabor incomparable. Dicho esto, pocos son los que saben destilar este zumo. Y la mayor parte del tiempo son piratas.",ep:2,g:63,l:1,wd:true,fm:true,w:1,p:1};
I.u[2081] = {n:"Informe de Finche Aticus",t:24,d:"El informe del espía Finche Aticus indica una lista exhaustiva de las armas de Bonta y de sus efectivos.",ep:2,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[2082] = {n:"Jabato",t:32,d:"Cuando un joven jabato ve a sus padres morirse ante sus ojos, sigue el asesino para que este se ocupe de él.",ep:13,g:1,l:1,wd:true,fm:true,w:0,m:true,p:10};
I.u[2083] = {n:"Carta de Oto Mustam",t:24,d:"Una carta de tu amo dirigida a Vil Smis. Está escrita en un dialecto desconocido para evitar que los curiosos como tú le echen un vistazo.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2084] = {n:"Respuesta de Vil Smis",t:24,d:"Una respuesta de Vil Smis a Oto Mustam, totalmente incomprensible para el común de los mortales.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2085] = {n:"Cerveza de La Paliza Feliz",t:37,d:"No solamente no tiene gusto sino que además es carísima. Otro punto en común con las mujeres.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2086] = {n:"Cerveza de Almenú",t:37,d:"Esta cerveza aromatizada con Blop Guinda se puede llamar  también Manoca.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,p:3};
I.u[2087] = {n:"Cerveza de la Bagruta",t:37,d:"Esta cerveza vuelve más valiente durante un momento... pero ten cuidado con el bajón, porque el momento es muy breve.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2088] = {n:"Cerveza de la Jarradepalo",t:37,d:"Una vulgar cerveza, pero la Jarra está maravillosamente esculpida. Por una vez el contenedor vale más que el contenido. Una característica compartida con el cráneo de los yopuka y la prensa del corazón.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2089] = {n:"Cerveza del Pankemante",t:37,d:"Esta cerveza está caliente, por lo cual es muy difícil beberla en verano. En cambio, desprende un agradable olor a pan tostado, por eso es una cerveza ideal para los desayunos sin pan.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2090] = {n:"Cerveza del Chatarrero",t:37,d:"Esta cerveza tiene un gusto a chatarra muy desagradable, pero muy fortalecedor lo cual puede recordarte los besitos de la Momia Nova.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:7};
I.u[2091] = {n:"El Bwak: Criarlo bien",t:25,d:"Este libro explica cómo criar un Bwak.",ep:3,g:4,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2092] = {n:"El Miaumiau: Criarlo bien",t:25,d:"Este libro explica cómo criar un Miaumiau.",ep:3,g:3,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2093] = {n:"El Wabbit: Críalo bien",t:25,d:"Este libro explica cómo criar un wabbit.",ep:3,g:5,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2094] = {n:"Mistetas Oscuro",t:16,d:"El Mistetas Oscuro es un sombrero que ha sido creado con los restos de un Mistetas Despedazado cosido a mano sin anestesia. Ahora ya no obedece a nadie más que a su amo y le encanta morder a los desconocidos.",ep:14,g:33,l:50,wd:true,fm:true,w:5,p:6600};
I.u[2095] = {n:"El Oso",t:16,d:"El Oso es un sombrero confeccionado con la cabeza de un oso muerto. Sin embargo ha conservado un pelo sedoso. El sastre que lo hizo tenía que ser muy hábil para haber conseguido conservar la expresión de descontento del oso de origen.",ep:14,g:34,l:35,wd:true,fm:true,w:5,p:10000};
I.u[2096] = {n:"Dora Oscura de Bravo",t:16,d:"El fantasma Bravo fue el primero en comprender cómo utilizar correctamente el mimbre oscuro para otros fines que el de la gastronomía.",ep:14,g:35,l:37,wd:true,fm:true,w:5,p:3800};
I.u[2097] = {n:"Champo",t:16,d:"El Champo pertenecía a uno de los más grandes Maestros Boletus de Amakna. Valeroso y brillante, el Boletus Chichón era el único de su raza en haber conseguido hacerse respetar por los seres humanos.",ep:1,g:36,l:43,wd:true,fm:true,w:25,p:5000};
I.u[2098] = {n:"Certificado de admisión en la petrera: bwak de tierra",t:77,d:"Este certificado describe las características del bwak de tierra que has dejado en la petrera.",ep:3,g:21,l:1,wd:false,fm:true,w:1,p:100};
I.u[2099] = {n:"Certificado de admisión en la petrera: bwak de fuego",t:77,d:"Este certificado describe las características del bwak de fuego que has dejado en la petrera.",ep:3,g:23,l:1,wd:false,fm:true,w:1,p:100};
I.u[2100] = {n:"Certificado de admisión en la petrera: bwak de agua",t:77,d:"Este certificado describe las características del bwak de agua que has dejado en la petrera.",ep:3,g:22,l:1,wd:false,fm:true,w:1,p:100};
I.u[2101] = {n:"Certificado de admisión en la petrera: bwak de aire",t:77,d:"Este certificado describe las características del bwak de aire que has dejado en la petrera.",ep:3,g:20,l:1,wd:false,fm:true,w:1,p:100};
I.u[2102] = {n:"Certificado de admisión en la petrera: wabbit",t:77,d:"Este certificado describe las características del wabbit que has dejado en la petrera.",ep:3,g:25,l:1,wd:false,fm:true,w:1,p:100};
I.u[2103] = {n:"Formulario de Welloy Cab",t:24,d:"Escrito a pata por Welloy Cab, este informe le encantará a los aficionados de los números y de las frases sin sentido.",ep:1,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2104] = {n:"Témelo",t:16,d:"El Témelo era un inquietante casco confeccionado a partir de restos de Uginak y diversos detritus. Durante mucho tiempo ha sido llevado por Gurlo el Terrible, el Témelo fue la máxima representación de la desolación.",ep:14,g:37,l:48,wd:true,fm:true,w:30,p:6000};
I.u[2105] = {n:"Formulario de informe virgen",t:24,d:"Formulario de informe sin ninguna anotación. Está listo para que Welloy Cab lo rellene.",ep:1,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2106] = {n:"Lista de cebos para pescador",t:24,d:"Tienes que ir a por los cebos lo más rápidamente posible.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2107] = {n:"Cebos especiales",t:24,d:"Esta lata de cebos especiales se parece a una vulgar lata de Miaum.",ep:1,g:45,l:1,wd:true,fm:true,w:0,p:1};
