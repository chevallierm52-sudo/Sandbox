I.u[1912] = {n:"Muslo de jalató **",t:63,d:"Este muslo hiede a muerte aunque su olor no esté relacionado con la muerte prematura de su dueño.",ep:1,g:335,l:20,wd:true,fm:true,w:2,p:1};
