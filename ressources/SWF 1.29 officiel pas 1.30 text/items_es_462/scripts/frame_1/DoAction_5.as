I.u[1891] = {n:"Piel de culebrón",t:59,d:"¿Acaso no has soñado nunca con poseer un magnífico bolso en piel de culebrón? Pues tienes razón ya que su resistencia deja que desear...",ep:2,g:361,l:10,wd:true,fm:true,w:1,p:1};
