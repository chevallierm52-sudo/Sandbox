I.u[1844] = {n:"Trucha",t:41,d:"La trucha es un pescado fácil de pescar y los pescadores más experimentados las pescan con las manos. Suelen contar que estos animalitos son muy enamoradizos... Por eso existe la expresión \"Quererse mucho como la trucha al trucho\".",ep:1,g:394,l:1,wd:true,fm:true,w:3,p:0};
