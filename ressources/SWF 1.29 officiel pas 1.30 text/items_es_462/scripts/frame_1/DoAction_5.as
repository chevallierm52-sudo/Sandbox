I.u[1796] = {n:"Carpita de las arenas",t:41,d:"Esta carpita tiene un color parecido a la arena. Se trata de una evolución de la naturaleza que en teoría le permite volverse invisible para los demás depredadores. Una pena que no haya arena en el fondo de los lagos...",ep:1,g:307,l:40,wd:true,fm:true,w:3,p:1};
