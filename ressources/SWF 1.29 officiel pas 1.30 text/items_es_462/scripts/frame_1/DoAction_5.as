I.u[1784] = {n:"Raya azul",t:41,d:"La raya azul domina los fondos marinos donde se pasa el tiempo excavando agujeros minúsculos. Nadie sabe todavía por qué. De vez en cuando sube a la superficie lo cual es suficiente para que puedas atraparla en tu red.",ep:2,g:296,l:50,wd:true,fm:true,w:3,p:1};
