I.u[2157] = {n:"Clint",t:16,d:"El Clint es un sombrero sobrio pero bastante chulo. La última versión de este sombrero conviene tanto a las aventureras coquetas como a los aventureros viriles. Eso es, sin duda, una garantía de calidad.",ep:1,g:38,l:50,wd:true,fm:true,w:10,c:"Ps=3",p:1};
I.u[2158] = {n:"Carta de Oto Mustam para Sbab",t:24,d:"Esta carta, llena de ironía, sólo tiene por objetivo denigrar a Sbab.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2159] = {n:"Pergamino de Valentía",t:14,d:"Este pergamino te permite mejorar tu Fuerza, eso te puede servir cuando un Kanugro rabioso intente embestirte.",ep:1,g:2,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2160] = {n:"Pergamino del Desánimo",t:14,d:"Este pergamino te permite reducir la Fuerza de un determinado blanco, eso te puede servir cuando un Kanugro rabioso se dispone a embestir tu peor enemigo.",ep:1,g:4,l:1,wd:true,fm:true,w:1,ut:true,p:300};
