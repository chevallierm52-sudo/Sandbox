I.u[2111] = {n:"Alma del pescador",t:25,d:"Este libro explica los secretos para convertirse en un buen pescador.",ep:2,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2112] = {n:"Alma del cazador",t:25,d:"Este libro explica los secretos para convertirse en un buen cazador.",ep:3,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2114] = {n:"Alimento desconocido",t:15,d:"Este alimento es desconocido",ep:1,g:0,l:1,wd:true,fm:true,w:10,p:1};
I.u[2116] = {n:"Receta de la Nocabregor",t:24,d:"Para para hacer pólvora de Nocabregor, son necesarias 3 medidas de polvos mágicos y 1 de aceite de Kodo. \nSólo los artificieros o los magos son capaces de  realizar esta receta con la ayuda de un Sílex...",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2117] = {n:"Diente de Colmillo Blando rabioso",t:24,d:"Este diente se le arrancó a un lobo rabioso.",ep:2,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2118] = {n:"Capa Brakmariana",t:17,d:"Esta capa permite desplazarse por un cementerio sin ser reconocido, o disfrazarse en Chafosa cuando la extrema perversidad se hace realmente necesaria.",ep:1,g:20,l:1,wd:true,fm:true,w:7,c:"Ps=2",p:800};
I.u[2119] = {n:"Capa bontariana",t:17,d:"Esta capa te da alas. Incluso el humo que desprende cuando se quema hará que te sientas ligero, muy ligero...",ep:5,g:34,l:1,wd:true,fm:true,w:3,c:"Ps=1",p:800};
I.u[2120] = {n:"Palabras de Ixa Mustam",t:24,d:"\"Mi testamento se encuentra en el faro de Amakna, consíguete una Palita de Maderucha para desenterrarlo. ¡Y dale un sopapo de mi parte a mi hijo!\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2121] = {n:"Palabras de Tsog",t:24,d:"\"He escondido un cofre en la punta Este de Sufokia, en un túnel, debajo de unos toneles de vino. Te aconsejo que te equipes con una Palita de Maderucha para desenterrarlo.\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2122] = {n:"Carta de invitación para la celebración",t:24,d:"Esta carta está sellada, sería de mala educación abrirla.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2123] = {n:"Receta del Sonacixem",t:24,d:"Esta receta permite hacer sonacixem, un temible veneno mágico.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2124] = {n:"Formulario de Inspección rellenado",t:24,d:"Un formulario de inspección n°243 rellenado por Parissil Trool, a primera vista no es Brakmariano...",ep:2,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2127] = {n:"Carta de Zeurg",t:24,d:"Esta carta indica un sortilegio capaz de destruir los Holbaids.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
