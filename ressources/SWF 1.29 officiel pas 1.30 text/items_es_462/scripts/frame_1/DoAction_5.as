I.u[2178] = {n:"Formulario de pesquisa n° 36",t:80,d:"Este formulario permite identificar a posibles sospechosos en algún asunto criminal. (Haz clic sobre el pergamino y sobre alguien para utilizarlo).",ep:16,g:6,l:1,wd:true,fm:true,w:1,c:"PO!2181&PO!2177&Ps=1&Pa=27",ut:true,p:100};
I.u[2179] = {n:"Diente de dragopavo",t:47,d:"Este diente parece muy afilado. Podría convertirse en un arma escalofriante en manos de cualquiera. Menos mal que el dragopavo sólo la usa para masticar enchalada.",ep:2,g:419,l:20,wd:true,fm:true,w:2,p:1};
I.u[2180] = {n:"Informe de interrogatorio",t:24,d:"La coartada de esta persona parece irreprochable...",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2181] = {n:"Informe de interrogatorio",t:24,d:"Esta persona es sospechosa, su coartada no tiene ningún fundamento.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
