I.u[2162] = {n:"Pergamino de Rigidez",t:14,d:"Este pergamino te permite reducir la agilidad de un determinado blanco, eso te puede servir cuando tu enemigo no debe huir si un mediulubo se le acerca.",ep:16,g:5,l:1,wd:true,fm:true,w:1,ut:true,p:300};
