I.u[1788] = {n:"Raya de Farle",t:41,d:"Esta especie de raya ha sido descubierta por primera vez por Farle Ingals en persona durante una de sus grandes aventuras. Dicen que esta raya puede embrujar a los pescados de las profundidades con grito.",ep:1,g:300,l:50,wd:true,fm:true,w:3,p:20};
