I.u[1862] = {n:"El Palo de Amor",t:20,d:"La madera de esta caña desprende una resina olorosa que impregna el hilo y el anzuelo. Este olor suave debe asemejarse al perfume de una kralamarita ya que todos los kralamares se pegan al anzuelo.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1863] = {n:"Caña Jillo",t:20,d:"Jillo era el cocinero más famoso de la mesa redonda. Su particularidad residía en conseguir alimentos frescos delante del mismo cliente. Esta caña le servía para pescar los pescados indispensables para su famoso plato de \"Carpas a la Jillo\"",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
