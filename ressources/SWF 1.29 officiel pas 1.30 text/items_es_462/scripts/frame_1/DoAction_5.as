I.u[1779] = {n:"Lubina Mericana",t:41,d:"Se suele encontrar este pescado en los lagos y en los ríos que bajan desde los glaciares. Su grosor y su carne son muy apreciados por los pescadores.",ep:2,g:290,l:40,wd:true,fm:true,w:3,p:1};
