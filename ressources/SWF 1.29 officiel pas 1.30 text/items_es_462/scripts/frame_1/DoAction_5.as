I.u[1917] = {n:"Solomillo de cerdo",t:63,d:"Esta parte suculenta del jabalí está un poco sangrienta por ahora pero es un auténtico manjar.",ep:1,g:331,l:30,wd:true,fm:true,w:3,p:1};
