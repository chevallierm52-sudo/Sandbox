I.u[2175] = {n:"Amenaza del intendente",t:24,d:"Una amenaza escrita por Danathor, para no olvidar de vigilar su retaguardia en el futuro.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
