I.u[1064] = {n:"Pequeño Martillo R\'único",t:7,d:"Dicen que este martillo es una pieza única porque ha sido fabricado de forma artesanal por los antiguos forjadores Xelor. En cambio algunos cuentan que se trata de una de las letras del cartel publicitario de un herrero. Pruébalo sobre una cabeza y saca tus propias conclusiones.",ep:1,g:18,l:21,wd:true,fm:true,w:45,an:15,e:[5,4,1,1,40,40,false,false],c:"CI>28&CS>3",p:7000};
