I.u[1050] = {n:"Palita de Wukis",t:8,d:"Esta pala ha sido creada y utilizada por la familia Wukis durante la guerra intestina que hubo entre los grupos Ukis y Dukis, competidores directos de exportación de tofus asados. Es un arma temible, su único defecto es que te deja las manos grasientas.",ep:3,g:21,l:49,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>40&CS>40",p:5000};
