I.u[1084] = {n:"Martillo Tohrero",t:7,d:"Como lo indica su nombre, este martillo ha pertenecido a un Xelor llamado Tohr... Se murió electrocutado por un rayo cuando intentaba utilizar su arma para cobijarse de la lluvia. Triste final...",ep:9,g:20,l:81,wd:true,fm:true,w:60,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100",p:15000};
I.u[1085] = {n:"Martillo de los Falistos",t:7,d:"Los Falistos eran demonios Xelors. Rechazaron sus antiguos principios y desarrollaron su fuerza forjando martillos cada vez más potentes. Después de haber aportado el caos, fueron derrotados y exiliados bajo tierra. Pero algunas de sus armas siguen en circulación.",ep:9,g:19,l:79,wd:true,fm:true,w:70,an:15,tw:true,e:[15,7,1,1,50,25,false,false],c:"CS>79",p:10000};
I.u[1086] = {n:"Pintura negra",t:15,d:"Este bote de pintura te será muy útil para pintar cualquier cosa. Tu casa, tu Tofu doméstico, tus amigos, incluso puedes pintarte a ti mismo si te apetece.",ep:12,g:175,l:1,wd:true,fm:true,w:2,p:1};
I.u[1087] = {n:"Anillo Mental",t:9,d:"Este anillo puede aumentar levemente la inteligencia de su dueño.",ep:1,g:36,l:14,wd:true,fm:true,w:2,p:775};
I.u[1088] = {n:"Máscara Kaníbola",t:16,d:"Esta máscara es la réplica exacta, en un poco más grande, de las que llevan con orgullo los Kaníbolas importantes.",ep:12,g:26,l:40,wd:true,fm:true,w:10,p:5000};
