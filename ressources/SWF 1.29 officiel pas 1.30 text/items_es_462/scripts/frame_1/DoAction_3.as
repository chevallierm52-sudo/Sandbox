I.u[1059] = {n:"Pala de los Campos",t:8,d:"Esta pala es la preferida de los agricultores, sobre todo de los cosechadores de pwatatas.  \nAunque nada te impida usarla para desnucar a tus enemigos.",ep:1,g:17,l:15,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>15",p:750};
I.u[1060] = {n:"Pequeña Maza Da",t:7,d:"Se trata de una de las armas predilectas creadas por Da. Esta maza, tiene una aerodinámica calculada y parte dos veces mejor el aire, por lo cual también parte dos veces más rápidamente los cráneos. Dos buenas razones para poseer esta arma.",ep:1,g:16,l:18,wd:true,fm:true,w:40,an:15,e:[10,5,1,1,60,40,false,false],c:"CS>18&CI>2",p:3000};
