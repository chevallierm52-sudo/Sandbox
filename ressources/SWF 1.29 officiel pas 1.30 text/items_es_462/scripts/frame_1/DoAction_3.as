I.u[1324] = {n:"Hierba para gato",t:36,d:"Esta planta hace babear a cualquier Zurcarák.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1325] = {n:"Cáscara de nuez",t:46,d:"Esta cáscara, naturalmente sólida, resiste a cualquier tipo de agresión y resume bastante bien la ideología Feca.",ep:2,g:52,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1326] = {n:"Silex sangriento",t:51,d:"Esta piedra tan resistente como cortante parece haber sido utilizada contra alguna cosa o contra algún ser. Su aspecto bruto y peligroso parece ilustrar perfectamente la definición de un yopuka.",ep:2,g:47,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1327] = {n:"Hueso Tallado",t:47,d:"Este objeto de muerte se vuelve peligrosísimo una vez trabajado, exactamente como un Sram.",ep:2,g:48,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1328] = {n:"Kama enigmático",t:15,d:"Este Kama está acuñado con una cabeza de tofu que lleva una cofia muy extraña.",ep:1,g:182,l:1,wd:true,fm:true,w:10,p:1};
I.u[1329] = {n:"Madera elástica",t:38,d:"Esta gran rama de madera, por su consistencia elástica y su forma curvilínea, hace instantáneamente pensar en los Ocras.",ep:2,g:49,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1330] = {n:"Amuleto Blada",t:1,d:"Es una creación original del orfebre John Limon, hoy en día se trata de una de la joyas más clásicas.",ep:1,g:31,l:10,wd:true,fm:true,w:5,p:500};
I.u[1331] = {n:"Medalla Lacena",t:1,d:"Lacena era una discípula de Yopuka cuyo único talento consistía en cocinar. Dicen que el mismo Yopuka le dio esta medalla para compensar sus puntos débiles en el combate. Sin embargo, sólo los corazones puros pueden llevarla.",ep:7,g:23,l:51,wd:true,fm:true,w:10,c:"Ps=1&Pa>10",p:7000};
I.u[1332] = {n:"Viejo Trébol de 4 hojas",t:36,d:"Los tréboles de cuatro hojas son mucho más raros que los de cinco hojas. Cuando encuentras uno, es aconsejable dejarlo secar entre dos pergaminos de hechizos.",ep:2,g:50,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1333] = {n:"Pócima de Chispa",t:26,d:"Esta pócima caliente se utiliza generalmente para hechizar un poco todas las clases de objetos  gracias a la poca magia de fuego lleva atrapada.",ep:3,g:1,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1334] = {n:"Petaca de Azufre",t:48,d:"Este pequeño paquete lleno de azufre desprende un olor insoportable... El mismo que el del Osamodas.",ep:2,g:51,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1335] = {n:"Pócima de Llovizna",t:26,d:"Esta pócima casi hirviente se utiliza generalmente para hechizar un poco todas las clases de objetos gracias a la escasa magia de agua que lleva atrapada.",ep:3,g:2,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1336] = {n:"Ortigas",t:36,d:"Al frotar enérgicamente esta planta contra tu piel, sufrirás el martirio. Sin embargo, la estimulación que provoca es benéfica, esto es exactamente la filosofía de los Sacrógritos.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
