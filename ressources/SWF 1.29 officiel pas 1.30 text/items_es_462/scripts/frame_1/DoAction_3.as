I.u[915] = {n:"Gorro del Maestro Panadero",t:16,d:"Este gorro demostrará a todo el mundo que eres un Maestro Panadero. Cueces y amasas más rápido que lo demás Panaderos, eso a algo que ahora todos saben.",ep:0,g:74,l:1,wd:false,fm:true,w:1,c:"PJ>25,100",p:10000};
I.u[916] = {n:"Amuleto de Silicato",t:1,d:"Silicato realizó este Amuleto una mañana de invierno, para un famoso aventurero llamado Rimb Vardi, que perseguía a un viejo Bwork Mago, responsable de varias catástrofes naturales que su magia, demasiado aproximativa, había desencadenado.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"La Hoja de Otoño",t:1,d:"Este Broche ha sido realizado una mañana de otoño en medio de un bosque de Hayas y Olmos no muy lejos de la isla de Olag-lacustre. Muchos leñadores la consideran como una auténtica reliquia.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Ámbar ancestral",t:50,d:"Este ámbar es de un abráknido ancestral, tiene pues un valor inestimable, y puede conferir propiedades mágicas a algunos objetos si lo trabajan manos hábiles.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Dagas Ancestrales",t:5,d:"Estas magníficas dagas, forjadas a partir de Ámbar Ancestral y usando antiguos métodos, sirvieron durante la colonización de la isla de Moon, antes de que ésta se volviera otra vez salvaje.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Madera Ancestral",t:38,d:"Esta madera es la de un Olmo de la isla de Olag-lacustre, que ha sido fulminado una mañana de otoño, por un Bwork Mago que controlaba bastante mal sus hechizos elementales.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Martillo de forjador de hachas",t:7,d:"Una herramienta indispensable para forjar hachas.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Cortadora de abráknidos",t:19,d:"Esta hacha de guerra ha sido forjada por Kademlia Bulguro para luchar contra los más terroríficos Abráknidos. Cuenta la leyenda que esta arma legendaria ha matado, en una noche, a más Abráknidos que árboles hay en Amakna.",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Poderosas Botas de Klim",t:11,d:"La agilidad que confieren estas botas permitía a Klim el zapatero montar fácilmente sobre el lomo de cualquier jalató. Se murió al confundir un jalató con una gelatina, tras una noche demasiado alcoholizada en la taberna.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Madera Embrujada",t:38,d:"Un Mago Abráknido lanzó un hechizo sobre esta madera, para dar vida a un pequeño Abráknido tras haber dejado el palo mojado en agua. Por supuesto, esta madera es extremadamente mágica.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Cortadora de abráknido ancestral",t:19,d:"Esta hacha ha sido forjada por Kademlia Bulguro, para combatir el Abráknido Ancestral. Sólo los mejores guerreros pueden utilizarla.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Hoja de Ogralimde",t:6,d:"Ogralimde era un gran guerrero que debía su fuerza a Adyol su maestro, un poderoso Bwork Mago cuya inteligencia era sorprendente. Pero, a pesar de lo que cuenta la leyenda, el alumno nunca superó al maestro.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristalita",t:50,d:"Esta piedra mágica con ese nombre particular no debe ponerse manos de cualquiera dado el poder que puede proporcionar a las armas o a las joyas.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Mapa del tesoro de los mineros oscuros",t:24,d:"Este mapa indica el lugar donde se encuentra el cofre de los mineros oscuros: \n\"El cofre está en una isla, es necesario pasar detrás de una fundición para acceder a ella\".",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Mapa del Tesoro de los Panaderos Oscuros",t:24,d:"Este mapa indica el lugar donde se encuentra el cofre de los Panaderos Oscuros: \n\"El cofre está en una isla en el sur de Amakna, hay que pasar detrás de unas rocas, entre dos pequeños estanques\".",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Pequeña Capa de Rojez",t:17,d:"Esta capa aumenta la vida del que la lleve puesta.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
I.u[933] = {n:"Capa de Rojez",t:17,d:"Esta capa aumenta la vida del que la lleve puesta.",ep:1,g:13,l:13,wd:true,fm:true,w:5,p:650};
I.u[934] = {n:"Gran Capa de Rojez",t:17,d:"Esta capa aumenta la vida del que la lleve puesta.",ep:1,g:13,l:16,wd:true,fm:true,w:5,p:900};
I.u[935] = {n:"Pequeña Capa Azulada",t:17,d:"Esta capa aumenta la suerte del que la lleve puesta.",ep:1,g:18,l:1,wd:true,fm:true,w:5,p:560};
I.u[936] = {n:"Capa Azulada",t:17,d:"Esta capa aumenta la suerte del que la lleve puesta.",ep:1,g:18,l:3,wd:true,fm:true,w:5,p:1020};
I.u[937] = {n:"Gran Capa Azulada",t:17,d:"Esta capa aumenta la suerte del que la lleve puesta.",ep:1,g:18,l:6,wd:true,fm:true,w:5,p:1560};
I.u[938] = {n:"Mapa del Tesoro de los Herreos Oscuros",t:24,d:"Este mapa indica el lugar donde se encuentra el cofre de los Herreros Oscuros:",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Mapa del Tesoro de los Bworks",t:24,d:"Este mapa indica el lugar donde se encuentra el cofre de los Bworks: \n\"El acceso al cofre está situado en un callejón sin salida, en el Sudeste del bosque oscuro. Estará seguramente protegido por un grupo de Bworks\".",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Depedador",t:16,d:"El Depedador te protege contra los daños físicos.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Pañuelo Komuntot",t:16,d:"El Komuntot permite aumentar la sabiduría de quien lo lleve puesto.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Alisador",t:16,d:"El Alisador te protege contra los daños mágicos.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Pañuelito de vitalidad",t:16,d:"Este pañuelo permite aumentar la vitalidad de quien lo lleve puesto.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Pañuelo de vitalidad",t:16,d:"Este pañuelo permite aumentar la vitalidad de quien lo lleve puesto.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
I.u[945] = {n:"Pequeña Capa Oscura",t:17,d:"Esta capa aumenta la sabiduría del que la lleve puesta.",ep:1,g:15,l:8,wd:true,fm:true,w:5,p:375};
I.u[946] = {n:"Capa Oscura",t:17,d:"Esta capa aumenta la sabiduría del que la lleve puesta.",ep:1,g:15,l:12,wd:true,fm:true,w:5,p:600};
I.u[947] = {n:"Gran Capa Oscura",t:17,d:"Esta capa aumenta la sabiduría del que la lleve puesta.",ep:1,g:15,l:19,wd:true,fm:true,w:5,p:1200};
I.u[948] = {n:"Abracapa",t:17,d:"Esta magnífica capa es una sabia mezcla entre la esencia de abráknido y el buen jalató de siempre.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Gran Pañuelo de Vitalidad",t:16,d:"Este Pañuelo permite aumentar la vitalidad de quien lo lleve puesto.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Agujas e hilo",t:20,d:"Estas agujas y este hilo te permitirán ejercer el oficio de sastre.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Capa del Mediulubo Loco",t:17,d:"Esta capa ha sido creada con pelos y otros elementos orgánicos de varios mediulubos... Se puede decir que su olor es poderoso y duradero.",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Capa del tofu loco",t:17,d:"Esta capa, cosida con plumas de tofus, permite que el héroe que la lleve puesta corra más rápido y se escape más fácilmente de las zonas de placaje.",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"La Samulay",t:17,d:"La Samulay es una capa legendaria, bordada por los mejores sastres para los guerreros que prefieren los combates de cuerpo a cuerpo.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Capa Ylar",t:17,d:"La capa Ylar es un tipo de capa muy pedida por los peluqueros. Les encanta revolcarse en ella. Hace que los pelos del que la lleve puesta se vuelvan más resistentes.",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Capa Mariya",t:17,d:"Esta capa aumenta el alcance del que la lleve puesta, permitiéndole a su vez atinar los blancos muy alejados o impresionar a los aventureros un poco ingenuos.",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"La Jalatada",t:17,d:"La Jalatada aumenta los daños y la vitalidad del que la lleve puesta. Sin embrago, desprende un fuerte olor y puede ser que algún Jalató piense que eres uno de los suyos.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofustadora",t:17,d:"Esta capa es sin duda alguna una de las más poderosas del mundo. Aumenta todas las características del que la lleve puesta.",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Mapa del Tesoro 5",t:24,d:"-- a faire --",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Pócima wabbit",t:24,d:"Esta pócima es un remedio contra la mixomawosis. Un trago de este brebaje te permite visitar la isla de los wabbits sin temer por tu vida.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Llave wabbit",t:24,d:"Una de las tres llaves que permiten abrir la puerta del castillo wabbit.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Llave wabbit",t:24,d:"Una de las tres llaves que permiten abrir la puerta del castillo wabbit.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
I.u[963] = {n:"Llave wabbit",t:24,d:"Una de las tres llaves que permiten abrir la puerta del castillo wabbit.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Piedra de dopeul",t:50,d:"Esta piedra viene del mundo de los dopeuls. Tiene un enorme valor para algunos habitantes de Amakna.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Manual del Sastre",t:25,d:"(Doble clic para aprender el oficio de Sastre)\nEste manual de sastre te permite aprender los secretos del oficio. Para los que no tienen mucha imaginación, las primeras páginas proponen patrones sencillos que puedes recortar.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Capa Fulgurante",t:17,d:"Esta magnífica capa aumenta los puntos de acción del que la lleve puesta. También aumenta su vitalidad y su sabiduría.",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
I.u[968] = {n:"Cinturón Fulgurante",t:10,d:"Este magnífico cinturón aumenta los puntos de acción de quien lo lleve puesto. También aumenta su vitalidad y su sabiduría.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Corona del Wey Wabbit",t:16,d:"Esta magnífica corona perteneció al tristemente célebre Wey Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Bastón del Wey Wabbit",t:4,d:"Este bastón pertenecía al tristemente célebre Wey Wabbit.",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Capa del Wey Wabbit",t:17,d:"Esta capa pertenecía al tristemente célebre Wey Wabbit. Todavía está impregnada por su transpiración lo cual te permitirá recordar siempre ese magnífico combate en cuanto te la pongas.",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Dofus Zanahowia",t:23,d:"El Dofus Zanahowia aumenta la sabiduría de su portador.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Pata de araknela",t:24,d:"Una pata muy fina, pero muy peluda. Los mejores Alquimistas consiguen crear potentes venenos con el jugo que extraen de estas patas.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Cabeza del Campesino Desamparado",t:24,d:"Lo que tenía que ocurrir ha ocurrido, el Campesino Desamparado perdió finalmente la cabeza.",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Colmillo del Vampiro Cautivo",t:24,d:"Este diente muy puntiagudo, es el de un Vampiro. Poseerlo en tu inventario o llevarlo alrededor del cuello te permitirá impresionar a tus amigos haciéndoles creer que eres un cazador de Vampiros.",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Calawaza",t:16,d:"La calawaza tiene la particularidad de evitar la dispersión de partículas de magia, esto hace de ella un buen aislante mágico. Por eso algunos guerreros utilizan esta legumbre como sombrero.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Shigekax limón",t:42,d:"Vuelve a disfrutar el sabor de las golosinas de antaño... con este caramelo de limón preparado de forma tradicional.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Shigekax fresa",t:42,d:"Vuelve a disfrutar el sabor de las golosinas de antaño... con este caramelo de fresa preparado de forma tradicional.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Shigekax menta",t:42,d:"Vuelve a disfrutar el sabor de las golosinas de antaño... con este caramelo de menta preparado de forma tradicional.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Shigekax cereza",t:42,d:"Vuelve a disfrutar el sabor de las golosinas de antaño... con este caramelo de cereza preparado de forma tradicional.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Verdely",t:42,d:"Está preparado con gelatina de menta, aunque no haya conquistado a todos los vegetarianos, no deja de ser una especialidad de Amakna.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Rogely",t:42,d:"Está preparado con gelatina de fresa, aunque no haya conquistado a todos los vegetarianos, no deja de ser una especialidad de Amakna.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Blugely",t:42,d:"Preparado con gelatina azul, aunque haya disgustado a más de un vegetariano, no deja de ser una de las especialidades de Amakna.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multygely",t:42,d:"La multygely ha sido prohibida a la venta porque provocó la desaparición de muchos niños. Parece ser que envía a la persona que se la come dentro de sus peores pesadillas.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[997] = {n:"Nuez de kokoko",t:46,d:"Tan redonda como una bola de cañón, esta nuez posee además 3 agujeros muy prácticos para levantarla y lanzarla a lo lejos.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Calzón mono del Capitán Pirata",t:15,d:"El calzón del capitán Pirata demuestra que el ridículo puede matar de vez en cuando. Pero según parece, trae suerte a pesar de todo.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Tela poco apetitosa",t:55,d:"Pegajosa y apestosa, esta amplia tela no deja de ser sin embargo de menor calidad. Una pena que esté agujereada.",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Barril vacío",t:15,d:"Este gran barril está vacío desde hace mucho tiempo, a pesar de ello podemos adivinar lo que contenía: ron, kamas, piratas borrachos... un poco de todo, pero ciertamente nunca llevó agua.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Tabla de madera de kokoko",t:95,d:"¿Será un futuro fragmento de barco? ¿Un futuro suelo de casa? En cualquier caso, por ahora sólo es una tabla como cualquier otra.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"Tronco de kokoko",t:38,d:"Como todos los troncos, el del Kokotero es derecho y sólido, pero un poco más delgado que la media.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Viga de Madera de kokoko",t:38,d:"Una viga de madera sólida. Ten cuidado al manipularla, vete a saber por qué, parece que este tipo de material pesado siempre se siente atraído por el dedo gordo del pie...",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Indispensable Cuerda",t:15,d:"Todos los aventureros saben que siempre hay que tener una cuerda como esta... Sin embargo, nadie la lleva nunca consigo.",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Recibo para una balsa",t:24,d:"Un recibo firmado por la mano de Kib Roca y que indica que tu balsa estará lista dentro de poco.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Sombrero Pirata",t:24,d:"Un sombrero con formas imponentes, una insignia de muerte bordada en la parte delantera, un forro para hacer bonito, este sombrero de pirata es un clásico entre los capitanes.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Garfio",t:24,d:"Accesorio indispensable para los piratas desafortunados, este garfio reemplaza ventajosamente una mano. Su color le da además un aspecto bastante elegante.",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Mandíbula colgante",t:24,d:"Esta mandíbula en forma de collar proviene, seguramente, del enfado que un capitán tuvo con un marinero que se había partido de risa al verle los calzoncillos a su jefe.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Calavera de Pirata",t:24,d:"Una calavera con un paño demuestra que un pirata, incluso muerto, todavía puede ocultar su calvicie.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Carapazón verde",t:24,d:"Este es el caparazón de una tortuga loca que creía se ninja.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1011] = {n:"Carapazón amarillo",t:24,d:"Este es el caparazón de una tortuga loca que sin duda abusó de substancias peligrosas.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Carapazón rojo",t:24,d:"Este es el caparazón de una tortuga loca que se comía tomates y queso sobre pan caliente.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Carapazón azul",t:24,d:"Este es el caparazón de una tortuga loca que quería imitar a Zowo, el Zollo enmascarado.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Máscara verde",t:24,d:"Una máscara de Kaníbola Reidor, a la efigie de la Verdura, condimento imprescindible para la carne.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Máscara Amarilla",t:24,d:"Una máscara de Kaníbola Llorador, a la efigie del Rayo, elemento que asusta a menudo a la carne joven.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Máscara roja",t:24,d:"Una máscara de Kaníbola Colérico, a la efigie del Fuego, elemento imprescindible para la asar la carne.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Máscara Azul",t:24,d:"Una máscara de Kaníbola Sorprendido, a la efigie del Agua, elemento desalterante entre dos bocados de carne.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Kola",t:15,d:"Este tarro de gelatina rosa con buen olor no debe en ningún caso servir de alimento. De lo contrario no podrás volver a hablar jamás dado lo pegajosa que es.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Casco",t:16,d:"Llevar este casco significa adoptar un look único... A medio camino entre lo cómico y lo ridículo.",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Casco roto",t:15,d:"Este casco te ha salvado la vida, pero él no consiguió salvar la suya.",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Alas de madera",t:17,d:"Quienes hayan soñado desde siempre con poder volar como un Kwak, pueden regresar a sus quehaceres porque estas alas solamente les convertirán en un peligro público y encima estúpido.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Alas rotas",t:104,d:"Estas alas no dejan de recordarte que hoy hubieras tenido que quedarte en cama.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Botella de ron",t:15,d:"La etiqueta porne \"ron añejo - 10 años de edad\", pero resulta imposible verificarlo. Una nota precisa también que no hay que abusar de él por los caminos so pena de mareo.",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
I.u[1026] = {n:"Cuchillito de Stek",t:5,d:"El ilustre loco Stek Rokefor encargó hacer estos extraños y temibles cuchillos. Nadie sabía para qué servían hasta que intentó regalar comida a su dios.",ep:1,g:13,l:32,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>32&CS>10",p:3000};
