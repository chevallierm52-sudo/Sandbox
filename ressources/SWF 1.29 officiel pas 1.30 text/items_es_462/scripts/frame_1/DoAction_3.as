I.u[1054] = {n:"Cruel Pala Paleta",t:8,d:"Esta herramienta es un cruce entre una pala y una paleta, la Pala Paleta perdió su carácter útil para convertirse en un arma famosísima. Se maneja con rapidez y se puede guardar  fácilmente gracias a su pequeño tamaño, es el accesorio ideal de cualquier Anutrof al que le guste el alcohol.",ep:13,g:15,l:53,wd:true,fm:true,w:20,an:16,e:[5,3,1,1,40,40,false,false],c:"CC>47",p:5000};
I.u[1055] = {n:"Pequeña Pala de Kutulú",t:8,d:"Los habitantes de la isla Kutulú fabrican artesanalmente estas terribles palas con materias de aquí y de allí (pero sobre todo del allí). Malísimas para excavar, están hechas solamente para asustar a los espíritus y a los niños revoltosos.",ep:8,g:19,l:25,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>22&CI>3",p:1500};
