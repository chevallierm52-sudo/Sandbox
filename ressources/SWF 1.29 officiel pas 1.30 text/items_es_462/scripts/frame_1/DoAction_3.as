I.u[1036] = {n:"Pequeña Daga Engañadora",t:5,d:"Esta daga Sram tiene una forma particularmente engañadora. Tan engañadora que uno puede preguntarse si realmente se trata de una daga. Y cuando se consigue la respuesta, suele ser demasiado tarde.",ep:7,g:11,l:53,wd:true,fm:true,w:1,e:[14,3,1,1,30,50,false,false],c:"CA>53&CS>18",p:7000};
