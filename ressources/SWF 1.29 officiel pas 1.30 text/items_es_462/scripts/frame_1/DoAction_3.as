I.u[1068] = {n:"Macita Damelklavel",t:7,d:"Esta maza le permitió al gran Thuno hacerse con el corazón de su dulcinea llamada Damelklavel... se acercó a su balcón, trepó por las hiedras y le propinó un buen golpe en la cocorota. La leyenda no cuenta cómo hizo para sacarle el corazón... a veces es mejor no saber ciertas cosas.",ep:2,g:14,l:34,wd:true,fm:true,w:40,an:15,e:[7,4,1,1,50,50,false,false],c:"CI>10&CS>10",p:14000};
