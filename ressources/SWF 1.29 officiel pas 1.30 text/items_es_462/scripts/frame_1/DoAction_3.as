I.u[1030] = {n:"Colas de Gatitos",t:5,d:"Este par de dagas es en realidad un magnífico juguete. Ha sido creado para los jóvenes Zurcaráks, su producción ha sido prohibida cuando un niño adepto de Sram se puso a jugar con ellos.",ep:14,g:20,l:25,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>40&CS>20&CV>20",p:1800};
I.u[1031] = {n:"Dagas Crueles de Elorie Entuwan",t:5,d:"Estas magníficas dagas pertenecieron a la Sramita más cruel que Amakna haya conocido. Bueno, una de las más crueles... En realidad sólo lo era un poco más que las demás, vamos o por lo menos tanto como las demás, lo cual ya es bastante.",ep:1,g:7,l:40,wd:true,fm:true,w:1,an:13,e:[12,3,1,1,30,50,false,false],c:"CA>40",p:4000};
I.u[1032] = {n:"Pequeña hoja de Parra",t:5,d:"Según cuenta la leyenda, el viejo Parra forjó estas hojas para que la Amaknidad estuviera a salvo de la desnudez. Así fue como la gente empezó a luchar entre sí para despojarse mutuamente y no pasar frío durante las noches de intenso frío. Bueno, todos te dirán que nunca hay que tomarse las leyendas al pie de la letra... Aunque esta sea cierta.",ep:1,g:14,l:44,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>44&CC>5",p:5000};
