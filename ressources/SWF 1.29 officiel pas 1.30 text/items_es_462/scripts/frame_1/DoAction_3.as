I.u[1141] = {n:"Pluma de kwak de tierra",t:53,d:"Esta pluma tiene la particularidad de resistir a la caída de piedras, por eso nunca encontrarás a un kwak de tierra enterrado.",ep:5,g:223,l:24,wd:true,fm:true,w:1,p:20};
I.u[1142] = {n:"Pico de kwak de tierra",t:47,d:"Con este pico extraordinariamente sólido, los kwaks de tierra pueden hacer agujeros en la tierra, sólo por el placer de hacer agujeros en la tierra con su pico. Definitivamente los kwaks de tierra son muy extraños...",ep:5,g:222,l:24,wd:true,fm:true,w:1,p:20};
