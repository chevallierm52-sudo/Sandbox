I.u[1040] = {n:"Cuchillos Sangrientos de Ortimus Contrari",t:5,d:"Ortimus Contrari es una leyenda que los asesinos suelen contar entre ellos. Dicen que Ortimus cumple con sus contratos de una forma totalmente opuesta a los métodos tradicionales. No pidas más explicaciones, podrías morirte al instante.",ep:9,g:19,l:80,wd:true,fm:true,w:15,an:13,e:[15,3,1,1,20,50,false,false],c:"CA>79&CS>40",p:10000};
I.u[1041] = {n:"Espada rota del Caballero Desafortunado",t:5,d:"Esta espada ha sido un regalo para la armadura de gala de un joven Yopuka llamado Bajo Skalera. Desafortunadamente, durante su primera misión como caballero, resbaló sobre una piedra. En realidad, aquella piedra era el dedo meñique del pie de un crujidor...",ep:1,g:43,l:35,wd:true,fm:true,w:20,an:13,e:[5,5,1,1,30,50,false,false],c:"CS>20",p:3000};
I.u[1042] = {n:"Palita de Vello Durmiente",t:8,d:"Esta pala está hecha con una madera muy rara. Según la leyenda, cualquier joven muchacha que roce esta pala con sus cabellos, entrará en un sueño eterno. Téngase en cuenta de que en caso de contactos repetidos, los efectos se aplican a cualquiera.",ep:1,g:20,l:34,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>26",p:3200};
