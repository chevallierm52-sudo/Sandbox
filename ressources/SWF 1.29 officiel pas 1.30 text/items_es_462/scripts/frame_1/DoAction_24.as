I.u[10784] = {n:"Amuleto de principiante",t:1,d:"Nadie sabe qué es lo que puede aportarte este amueto, pero todo el mundo sabe que te quita credibilidad.",ep:0,g:163,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10785] = {n:"Anillo de principiante",t:9,d:"Este anillo protegerá tus dedos de los mocos de tus adversarios.",ep:0,g:190,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10786] = {n:"Piel de koalak inmaduro",t:24,d:"El pequeño koalak inmaduro al que has arrancado la piel no estaba de acuerdo en cedértela pero no importa. Al fin de cuentas eras más fuerte y más cruel que él.",ep:20,g:811,l:1,wd:true,fm:true,w:1,p:10};
I.u[10787] = {n:"Ala de dragopavo pelirrojo salvaje",t:24,d:"Esta ala huele a azufre. Cualquier buen criador de dragopavos te dirá que es la parte más blanda para el churrasco. Procura poner en adobo la carne antes de asarla ya que el ala es la parte más insípida del bichejo.",ep:2,g:812,l:29,wd:true,fm:true,w:1,p:1};
I.u[10788] = {n:"Ala de dragopavo",t:24,d:"Se puede decir que el dragopavo doméstico es mucho mejor que su primo el salvaje. Para empezar, no tiene un sabor a azufre sino que su carne es sabrosísima y por eso suele ser la comida preferida de los niños.",ep:2,g:813,l:29,wd:true,fm:true,w:1,p:1};
I.u[10789] = {n:"Pelos irritantes de koalak montés",t:24,d:"Estos pelos están recubiertos con savia de kalipto, lo cual les da un aspecto brillante. Desafortunadamente, no se pueden utilizar en alta costura por culpa de su olor a dragopavo muerto.",ep:20,g:814,l:1,wd:true,fm:true,w:1,p:100};
I.u[10790] = {n:"Hueso mágico de Mamá Koalak",t:24,d:"La Mamá Koalak posee huesos particularmente resistentes que no ceden bajo su peso. No podemos decir lo mismo de Badiz Mismal el célebre trovador que perdió sus dos brazos al ser aplastado por las enormes nalgas de la Mamá Koalak. La curiosidad es el peor de los defectos.",ep:20,g:815,l:1,wd:true,fm:true,w:1,p:10};
I.u[10791] = {n:"Pelos de barba urticantes del warko marrón",t:24,d:"Estos pelos son urticantes, lo suficiente como para transformar los besos del warko marrón en armas de destrucción masiva.",ep:20,g:816,l:1,wd:true,fm:true,w:1,p:10};
I.u[10792] = {n:"Pócima de curación de principiante",t:12,d:"Este frasco sirvió en su tiempo para las muestras de orina. Pero ahora contiene una pócima capaz de devolverte los puntos de vida perdidos.",ep:0,g:2,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10793] = {n:"Pan de principiante",t:33,d:"Está manío, te hace daño en las encías, huele a calzoncillos de bwork, pero te devuelve puntos de vida. ¡Así que déjate de tonterías y cómetelo!",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10794] = {n:"Botas de principiante",t:11,d:"Calentitas por dentro y heladas por fuera, con estas botas podrás darle un buen par de patadas en el culo a los muñecos de nieve sin que se les funda el trasero.",ep:0,g:2,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10795] = {n:"Pescado Remifasolasi de principiante",t:49,d:"Si aporreas fuertemente este pescado, lo oirás resonar. Si te lo comes, en cuanto te den dos tortas te transformarás en instrumento de música. Din don dan diiiin.",ep:0,g:92,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10796] = {n:"Carne picante de principiante",t:69,d:"Este rollito de carne picada picante contiene los ingredientes más indigestos que se pueden encontrar en la comarca de Amakna...pero está tan bueno que tu barriguita quiere más.",ep:0,g:113,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10797] = {n:"Espada Nsiosa de principiante",t:6,d:"En cuanto la sacas de la vaina, esta espada corta jamón, anutrofs, cojos, bailarines, anutrofs cojos enrollados en una loncha de jamón bailando en una noche de luna llena. Pero por el contrario, para cortar los monstruos a rodajitas es bastante ineficaz.",ep:0,g:96,l:1,wd:false,fm:true,w:1,an:14,e:[5,4,1,1,40,50,false,false],s:150,p:1};
I.u[10798] = {n:"Escudo de principiante",t:82,d:"Este escudo no te pretegerá de tu estupidez.",ep:0,g:55,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10799] = {n:"Cinturón de principiante",t:10,d:"Si no tienes vaina para tu daga, ni se te ocurrra guardarla el el calzoncillo, por no extraviarla podrías perder otra cosa. Te aconsejamos que en ese tipo de casos la guardes entre tus michelines y que la sujetes con este magnifico cinturón.",ep:0,g:10,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10800] = {n:"Capa de principiante",t:17,d:"Con esta capa podrás volar. Sólo tienes que cerrar los ojos, apretar los puños, abrir la boca y saltar desde un precipicio desplegando los brazos y gritando \"Vueloooooo\". En pocos instantes te despertarás con las piernas rotas... y sin un solo diente. Siempre hay que leer hasta el final, y desconfiar de las tonterías como esta.",ep:0,g:3,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10801] = {n:"Casco de principiante",t:16,d:"Este wok oculta perfectamente tu calvicie. Desafortunadamente, no es lo suficientemente grande como para ocultar tu falsa modestia.",ep:0,g:264,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10802] = {n:"Dragún dorado",t:18,d:"Más dorado que los dragunes negros, menos rosa que los dragunes rosas, y más raro que los dragunes esqueleto... con este dragún serás el centro de todas las miradas, incluso siendo más feo que un pío. Esta mascota devoradora de almas sólo come los dopeuls de los templos de clase.",ep:0,g:57,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:151,p:1};
I.u[10804] = {n:"Regalo: dragún dorado",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Quizás, esta vez, los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10805] = {n:"Transformación fantasma dragún dorado",t:27,d:"Te has transformado en fantasma para poder penetrar en el Santuario de las Mascotas.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10806] = {n:"Certificado de admisión en la petrera: dragún dorado",t:77,d:"Este certificado describe las características del dragún dorado que has dejado en la petrera.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10807] = {n:"Fantasma de dragún dorado",t:90,d:"Este dragún dorado aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10808] = {n:"Hormona de dragún dorado",t:48,d:"Esta hormona de crecimiento deshidratada se puede utilizar en la elaboración de una potente pócima que mejorará a tu mascota.",ep:0,g:240,l:1,wd:true,fm:true,w:1,p:10};
