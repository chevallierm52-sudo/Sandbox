I.u[10414] = {n:"Corona Koninginnedag",t:16,d:"Esta corona te la podrás poner el día en que se conmemora el cumpleaños de la reina. Tiene poderosos poderes mágicos... incluso puede hacer que el que se la ponga se vuelva naranja,....así se podrá camuflar entre toda la gente que se disfraza de este color.",ep:0,g:251,l:1,wd:false,fm:true,w:10,p:1};
I.u[10417] = {n:"Piedra de alma de guardián de mazmorra",t:85,d:"Esta piedra contiene las almas de un grupo de monstruos que están deseando volver a la vida para meterte los dedos por la nariz y sacártelos por la boca. Sólo sirve en las arenas previstas a tal efecto que podrás encontrar en las grandes ciudades.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10418] = {n:"Piedra de alma de archimonstruo",t:85,d:"Esta piedra contiene las almas de un grupo de monstruos y, al menos, la de un archimonstruo que están deseando volver a la vida para meterte los dedos por la nariz y sacártelos por la boca. Sólo sirve en las arenas previstas a tal efecto que podrás encontrar en las grandes ciudades.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
