I.u[10657] = {n:"Buscador de ogrinas",t:18,d:"Esta extraña mascota es fruto del cruce de los mejores buscadores de trufas de Amakna. Su gran hocico le permite encontrar hasta las ogrinas que se encuentran bajo el agua. La búsqueda de la ogrina implica un proceso fisiológico tan complejo y en el que se gasta tanta energía, que esta criatura se ve obligada a alimentarse de almas de monstruos para crecer. Sólo devora las almas de las criaturas que viven en las playas de la Isla de Otomai, donde creció. Otomai tardó varios años en crear esta especie que, según cuentan, quería utilizar para enmendar uno de sus errores o para encontrar algo que había perdido o que se le había escapado. No se sabe muy bien.",ep:0,g:56,l:1,wd:true,fm:true,w:10,p:1};
I.u[10658] = {n:"Fantasma de Buscador de ogrinas",t:90,d:"Este Buscador de ogrinas aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:56,l:1,wd:true,fm:true,w:1,p:1};
I.u[10659] = {n:"Huevo de buscador de ogrinas",t:72,d:"Este extraño huevo contiene una pequeña criatura mágica. Incúbalo, seguro que al final acabas siendo papá.",ep:0,g:206,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10660] = {n:"Regalo: huevo de buscador de ogrinas",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10661] = {n:"Certificado de admisión en la petrera: buscador de ogrinas",t:77,d:"Este certificado describe las características del buscador de ogrinas que has dejado en la petrera.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10662] = {n:"Runa Pa Prospe",t:78,d:"Con esta runa tendrás más suerte para encontrar objetos raros.",ep:0,g:36,l:20,wd:true,fm:true,w:1,p:10};
I.u[10663] = {n:"Empanada de carne de jalató",t:33,d:"Hay que tener un estómago a prueba de bombas para tragarse esta empanada. La carne de jalató que se ha utilizado y que no siempre está fresca, le da un sabor parecido al de las ostras con chocolate. Toda una delicia para los bworks.",ep:0,g:71,l:20,wd:true,fm:true,w:1,c:"Sc=1",u:true,ut:true,p:1};
I.u[10664] = {n:"Abrákllota",t:94,d:"Tan delicada como el resto de bellotas, sólo hay que frotarla levemente para que expulse al abráknido cautivo en su interior.",ep:0,g:15,l:1,wd:true,fm:true,w:0,c:"Sc=2&(PB=4|PB=22|PB=33|PB=169|PB=170|PB=486|PB=168)",u:true,p:0};
I.u[10665] = {n:"Cofre de Jorbak",t:94,d:"Si Jorbak ha perdido toda su fortuna, ¿qué podría haber en este extraño cofre? Ábrelo para descubrirlo.",ep:0,g:16,l:1,wd:true,fm:true,w:1,u:true,p:0};
I.u[10667] = {n:"Huella de Jorbak",t:24,d:"Has conseguido advertir cuando se hará visible el espíritu de Jorbak. Es inútil precipitarse.",ep:0,g:251,l:1,wd:true,fm:true,w:0,p:0};
I.u[10668] = {n:"Buena suerte de Jorbak",t:28,d:"Durante algún tiempo te beneficiarás de la suerte de Jorbak.",ep:0,g:16,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10669] = {n:"Pócima de sapomorros",t:12,d:"¡Así aprenderás a no beber cualquier cosa!",ep:0,g:18,l:1,wd:true,fm:true,w:1,c:"Sc=4",u:true,p:0};
I.u[10670] = {n:"Pergamino de Perfobland",t:94,d:"Tan simples de seguir como una receta de cocina wabbit, las indicaciones de este pergamino revelan un secreto fascinante.",ep:0,g:17,l:1,wd:true,fm:true,w:1,c:"Sc=5",u:true,p:0};
I.u[10673] = {n:"Pócima de HmmMmmMmmm",t:12,d:"HmmMmmMmmm.",ep:0,g:191,l:1,wd:true,fm:false,w:1,c:"Sc=7",u:true,ut:true,p:1};
I.u[10674] = {n:"Mmmmm",t:28,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmmm mmmmm mmmm mmmmmmm.",ep:0,g:18,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10675] = {n:"Regalo: Dofusiano",t:89,d:"Ni por todos los Dofus del Mundo te diríamos lo que hay en este paquete, pero te vamos a dar una pista: con lo que hay dentro te lo pasarás bomba y hasta montarás una fiesta.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10676] = {n:"Doble efecto Tyk Tak",t:28,d:"Tu prospección y tu sabiduría se verán incrementadas durante varios combates.",ep:0,g:19,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10677] = {n:"Shigekax Tyk Tak",t:42,d:"Vuelve a disfrutar el sabor de las golosinas de antaño... con este caramelo preparado de forma tradicional (aumenta en 100 puntos la prospección y la sabiduría durante 20 combates).",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"PO!10676",u:true,p:1};
I.u[10678] = {n:"Viajar Sin Perder el Norte",t:25,d:"Arpagnagrobis ha escrito este libro para todos los aventureros que no saben utilizar ni la brújula ni los zaaps.",ep:0,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10680] = {n:"Recuerdo sangrante del Gultarminator",t:24,d:"Has arrancado este corazón a la esencia maléfica de Gultard. Ahora podrás ponerlo en tu escritorio... ¿a que es un bonito recuerdo?",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10681] = {n:"Transformación en sapomorros",t:31,d:"¡Bien hecho!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[10682] = {n:"El secreto de Perfobland",t:29,d:"La suerte y la felicidad van de la mano.",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10685] = {n:"Casco Goldpex",t:16,d:"Cuando te pongas este casco de oro, otros le pondrán precio a tu cabeza: ¡Valdrá su peso en oro!",ep:0,g:254,l:52,wd:false,fm:true,w:10,s:151,p:7325};
I.u[10686] = {n:"Capa Goldpex",t:17,d:"Esta capa de tela, recuvierta de un finísima capa de oro, es mágica. Atrae la mirada y envia la luz directamente a la retina de quienes intenten apuñalarte por la espalda. Te resultará imprescindible si eres amigo de algún sram.",ep:0,g:171,l:54,wd:false,fm:true,w:10,s:151,p:7750};
I.u[10687] = {n:"Anillo Goldpex",t:9,d:"Este anillo es tan pesado que aumenta considerablemente la inercia de tu puño cuando te lias a repartir tortas. Cuando empieces a castigar al enemigo, te resultará casi imposible parar.",ep:0,g:182,l:51,wd:false,fm:true,w:10,s:151,p:6862};
I.u[10688] = {n:"Cinturón Goldpex",t:10,d:"Este cinturón resulta muy practico para colgarte de la cintura unos lingotes de oro. ¡Pasarán totalmente desapercibidos!",ep:0,g:166,l:53,wd:false,fm:true,w:10,s:151,p:7525};
I.u[10689] = {n:"Regalo: Espada de Gruut",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
