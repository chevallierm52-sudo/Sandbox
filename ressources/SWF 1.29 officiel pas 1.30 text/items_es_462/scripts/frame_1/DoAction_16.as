I.u[6884] = {n:"Llave de la Mazmorra del Bworker",t:84,d:"Esta llave permite entrar en la mazmorra del Bworker. Ojo, esta llave se autodestruirá después de haber sido utilizada.",ep:4,g:713,l:30,wd:true,fm:true,w:1,p:100};
I.u[6885] = {n:"Ficha del Bworker",t:15,d:"Perfecta para jugar a cara o cruz o para matar a tus enemigos con un lanzamiento de moneda, esta ficha en oro masivo hará de ti un jugador feliz, pero tal vez desafortunado.",ep:13,g:90,l:100,wd:true,fm:true,w:1,p:100};
I.u[6886] = {n:"Capa de los Mercenarios de Astrub",t:17,d:"Capa de los Mercenarios de Astrub.",ep:1,g:59,l:1,wd:false,fm:true,w:10,p:1};
