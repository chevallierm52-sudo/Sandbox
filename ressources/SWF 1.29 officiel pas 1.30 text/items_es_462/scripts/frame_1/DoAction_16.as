I.u[6601] = {n:"Pólvora de Artificio",t:48,d:"Cuando tus invitados empiezan a aburrirse, la mejor solución consiste en utilizar la famosa Hada Artificial que podrás hacer tú mismo con esta pólvora y diversos ingredientes. Esta hada hará que tu fiesta se vuela caliente, caliente...",ep:16,g:670,l:1,wd:true,fm:true,w:1,p:100};
I.u[6602] = {n:"Sangre de rata Hyoactiva",t:24,d:"Las normas de seguridad Bontariana preconizan mantenerse a una distancia de 100 purgadas de cualquier sustancia Hyoactiva so pena de multiplicar su tiempo de juego por tres.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[6603] = {n:"Peluche de jalató",t:61,d:"Este peluche es la réplica exacta de un jalató, sus creadores le han incluso impregnado el olor del animal. No te extrañes entonces si hueles mal al despertarte por las mañanas.",ep:13,g:671,l:1,wd:true,fm:true,w:10,p:1};
I.u[6604] = {n:"Kuakuá",t:18,d:"Mejor que el Tofu, mejor que el Jalató o incluso mejor que el Yopuka, el Kuakuá es el campeón de la estupidez.",ep:1,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[6605] = {n:"Peluche del jalató real",t:61,d:"Este peluche es realmente real, desde las costuras hasta el forro, todo ha sido bien pensado. Un excelente regalo para los niños consentidos o para los hijos de ricachones.",ep:13,g:672,l:1,wd:true,fm:true,w:10,p:1};
I.u[6606] = {n:"Peluche del dopeul sadida",t:61,d:"Este peluche contiene en el forro un enorme despertador, muy útil para los sadidas que tienen el sueño pesado. En cambio, se desaconseja llevarlo contigo si te acuestas debajo de un carpe. En esos casos, el tiempo ya no tiene importancia.",ep:13,g:673,l:1,wd:true,fm:true,w:10,p:1};
I.u[6607] = {n:"Peluche del dopeul zurcarák",t:61,d:"Este pequeño peluche divierte a los zurcaráks de todas las edades.",ep:13,g:674,l:1,wd:true,fm:true,w:10,p:1};
I.u[6608] = {n:"Peluche del dopeul yopuka",t:61,d:"Este peluche se parece hasta cierto punto a un verdadero yopuka, es tonto como las piedras y su cabeza no contiene ningún relleno.",ep:13,g:675,l:1,wd:true,fm:true,w:10,p:1};
I.u[6610] = {n:"Peluche del dopeul sram",t:61,d:"Este peluche ha sido robado a un joven sram, él mismo se lo había robado a uno de sus amigos.",ep:13,g:677,l:1,wd:true,fm:true,w:10,p:1};
I.u[6611] = {n:"Peluche del dopeul aniripsa",t:61,d:"Este peluche podría casi volar si sus alas no estuvieran tan usadas. Evidentemente, este peluche no es de primera mano. Pero poco importa, no deja de ser un bonito regalo.",ep:13,g:678,l:1,wd:true,fm:true,w:10,p:1};
I.u[6612] = {n:"Peluche del dopeul anutrof",t:61,d:"Atención, este peluche es muy pesado. Se ha rellenado con Piedra de Bauxita y Pepitas de Oro.",ep:13,g:679,l:1,wd:true,fm:true,w:10,p:1};
I.u[6613] = {n:"Peluche del dopeul feca",t:61,d:"Este peluche es casi irrompible, perfecto para los jóvenes fecas traviesos y poco cuidadosos.",ep:13,g:680,l:1,wd:true,fm:true,w:10,p:1};
I.u[6614] = {n:"Peluche del dopeul osamodas",t:61,d:"Dicen que este peluche puede invocar otros pequeños peluches si la cuidas correctamente. Se trata de una vieja leyenda para forzar los jóvenes osamodas a no comer.",ep:13,g:681,l:1,wd:true,fm:true,w:10,p:1};
I.u[6615] = {n:"Peluche del dopeul ocra",t:61,d:"Este peluche muy bonito está hecho para ser enviado muy lejos sobre tus colegas de juego, una especie de bumerán que no vuelve nunca hacia el que lo lanza.",ep:13,g:682,l:1,wd:true,fm:true,w:10,p:1};
I.u[6616] = {n:"Peluche del dopeul xelor",t:61,d:"Este peluche hace un ruido extraño. Parece que contiene un reloj dentro de la cabeza. Perfecto para conciliar el sueño de los jóvenes xelors.",ep:13,g:683,l:1,wd:true,fm:true,w:10,p:1};
I.u[6617] = {n:"Peluche del jabalí",t:61,d:"Este peluche se parece increíblemente a un peluche de jabalí. Impresionante. Podrás notar que sus pelos son verdaderos pelos de jabalí. Eso es ciertamente una garantía de calidad.",ep:13,g:684,l:1,wd:true,fm:true,w:10,p:1};
I.u[6618] = {n:"Peluche del tofu",t:61,d:"¿Quién no ha soñado nunca con poder abrazar una reliquia de tofu? Tal vez tú. Entonces, eso significa que sueles comprar tonterías o que tus amigos no saben hacerte regalos.",ep:13,g:685,l:1,wd:true,fm:true,w:10,p:1};
I.u[6619] = {n:"Peluche del champi",t:61,d:"Este champi no tiene espinas dolorosas o veneno paralizante. Sin embargo es genial para asustar a los yopukas más inocentones.",ep:13,g:686,l:1,wd:false,fm:true,w:10,p:1};
I.u[6620] = {n:"Peluche del prespic",t:61,d:"Este prespic de peluche no lanzará agujas ni se volverá invisible. Pero desempeñará su papel de peluche de maravilla y causará la envidia de tus amigos.",ep:13,g:687,l:1,wd:true,fm:true,w:10,p:1};
I.u[6621] = {n:"Peluche del wabbit",t:61,d:"El wabbit en peluche sigue siendo una referencia, tal vez porque nunca pasa de moda. Una pena que no tengas esa suerte.",ep:13,g:688,l:1,wd:true,fm:true,w:10,p:1};
I.u[6622] = {n:"Sonajero de Dark Vlad",t:15,d:"Este sonajero perteneció a Dark Vlad en persona lo cual basta para demostrar que se trata de un objeto de gran valor... aunque en el fondo se trate de un Sonajero de lo más corriente.",ep:13,g:696,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6624] = {n:"Peluche del dragocerdo",t:61,d:"Este peluche es un ejemplar único. Pero ojo, es para un público mayor de edad.",ep:13,g:689,l:1,wd:true,fm:true,w:10,p:1};
I.u[6625] = {n:"Boliche del Maestro Cuerbok",t:15,d:"Este magnífico juguete perteneció al Maestro Cuerbok en persona. Como era demasiado estúpido para saber cómo utilizarlo, lo usaba para dar golpes sobre las cabezas de sus queridos pequeños Cuerboks. Cada cual se entretiene a su manera.",ep:13,g:710,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6626] = {n:"Comba de Capitán Chafer",t:15,d:"Para mantener sus articulaciones en forma, Capitán Chafer utilizaba esta famosa comba. Desde que desapareció de Amakna, esta cuerda pasa de unas manos a otras.",ep:13,g:695,l:1,wd:true,fm:true,w:1,p:50};
I.u[6627] = {n:"Hadita Artificial Multicolor",t:74,d:"Este hada artificial sorprenderá y dejará sin habla a tus amigos, incluso a los más curados de espanto. Muy útil para celebrar la creación de tu gremio.",ep:1,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:350};
