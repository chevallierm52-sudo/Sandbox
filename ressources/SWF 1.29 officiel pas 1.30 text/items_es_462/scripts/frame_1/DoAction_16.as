I.u[6894] = {n:"Superpoderoso Miaumiau de Combate (MJ)",t:18,d:"Este superpoderoso Miaumiau de combate encarna de maravilla el superpoder. Es muy impresionante. Pero ojo, sólo los Masters de Juego más valientes pueden conseguirlo.",ep:1,g:1,l:1,wd:false,fm:false,w:10,c:"PX=3|PX=5",p:1};
I.u[6895] = {n:"Pequeño Miaumiau de Combate (MJ)",t:18,d:"Menos superpoderoso que el superpoderoso Miaumiau de Combate, pero sin embargo muy poderoso, esta mascota sigue siendo un valor seguro para cualquier Master de Juego que se respete. En cambio, hay que confesar que es mucho más sucio. No te olvides de lavarlo de vez en cuando con agua hirviendo para que conserve su bonito color.",ep:1,g:9,l:1,wd:false,fm:true,w:10,p:1};
I.u[6897] = {n:"Pluma de pío azul",t:53,d:"Esta pequeña pluma de pío ha sido directamente arrancada del trasero de un pobre pío sin defensa.",ep:1,g:114,l:1,wd:true,fm:true,w:1,p:10};
I.u[6898] = {n:"Pluma de pío violeta",t:53,d:"Esta pequeña pluma de pío ha sido directamente arrancada del trasero de un pobre pío sin defensa.",ep:1,g:115,l:1,wd:true,fm:true,w:1,p:10};
I.u[6899] = {n:"Pluma de pío verde",t:53,d:"Esta pequeña pluma de pío ha sido directamente arrancada del trasero de un pobre pío sin defensa.",ep:1,g:116,l:1,wd:true,fm:true,w:1,p:10};
I.u[6900] = {n:"Pluma de pío rojo",t:53,d:"Esta pequeña pluma de pío ha sido directamente arrancada del trasero de un pobre pío sin defensa.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:10};
I.u[6902] = {n:"Pluma de pío amarillo",t:53,d:"Esta pequeña pluma de pío ha sido directamente arrancada del trasero de un pobre pío sin defensa.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[6903] = {n:"Pluma de pío rosa",t:53,d:"Esta pequeña pluma de pío ha sido directamente arrancada del trasero de un pobre pío sin defensa.",ep:1,g:119,l:1,wd:true,fm:true,w:1,p:10};
I.u[6904] = {n:"Protección usada del Bworker",t:15,d:"A veces el amor causa todavía más estragos que la guerra. Vete decirle eso al Bworker, el ser más precavido de Amakna...",ep:1,g:714,l:200,wd:true,fm:true,w:1,p:1000};
I.u[6905] = {n:"Paquete sorpresa bwork",t:89,d:"La apertura de este paquete requiere por parte de su propietario, una gran serenidad, que influirá directamente sobre la calidad de su contenido.",ep:1,g:42,l:1,wd:true,fm:true,w:4,u:true,p:100};
I.u[6906] = {n:"Pergamino de rango de mercenario: mercenario neófito",t:14,d:"Este pergamino es el formulario de entrada al clan de los mercenarios. Quien lo consiga será inscrito en los registros del clan como neófito.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6907] = {n:"Neutralizador",t:14,d:"Permite dar la alineación neutra al personaje escogido.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6908] = {n:"Vellurón",t:10,d:"Peludo pero elegante, este cinturón hará que pienses a veces en tu dulcinea.",ep:1,g:75,l:18,wd:true,fm:true,w:2,s:21,p:1050};
I.u[6909] = {n:"Pies de jabalí",t:11,d:"Estas botas son ideales para caminar sobre el fango y para rayar los parqués. En general están prohibidas en todas las pistas de baile.",ep:1,g:51,l:22,wd:true,fm:true,w:2,s:21,p:1525};
I.u[6910] = {n:"Anillo del jabalí",t:9,d:"Antes se ponía este anillo en las patas de los jabalíes en celo para que los ganaderos pudieran reconocerlos fácilmente. Hoy te toca llevarlo. Las interpretaciones son infinitas.",ep:1,g:73,l:19,wd:true,fm:true,w:2,s:21,p:1200};
I.u[6911] = {n:"Araknotón",t:9,d:"Este ridículo anillito te permitirá combatir mejor tu fobia de las Araknas.",ep:1,g:76,l:5,wd:true,fm:true,w:1,s:22,p:275};
I.u[6912] = {n:"Araknocinto",t:10,d:"Creado con viejos restos de Araknas en estado de descomposición, este cinturón recobrará vida por momentos y se lo pasará en grande mordiéndote las caderas. ¡Malditos bichos!",ep:1,g:73,l:6,wd:true,fm:true,w:1,s:22,p:305};
I.u[6913] = {n:"Araknosombrero",t:16,d:"Con este sombrero te parecerás a una Arakna salvaje. En el mejor de los casos, espantarás a los Moskitos más ingenuos.",ep:1,g:83,l:6,wd:true,fm:true,w:2,s:22,p:305};
I.u[6914] = {n:"La Cortadora de arakna",t:19,d:"Hecho muy extraño, la arakna, sólo tiene cuatro piernas velludas, esto significa que con solamente cuatro hachazos, podrás transformarla en Arakna Tronco.",ep:1,g:31,l:8,wd:true,fm:true,w:5,an:17,e:[5,4,1,1,50,50,false,false],s:22,p:600};
I.u[6915] = {n:"Mos Kitano",t:9,d:"Este anillo es tan ligero que te permitirá realizar todas las acrobacias posibles con los dedos. Muy práctico para humillar a un rival diez veces más pequeño que tú, aplastándole la cabeza con el pulgar.",ep:1,g:71,l:21,wd:true,fm:true,w:2,s:23,p:1400};
I.u[6916] = {n:"Mochila del Pequeño Moskito",t:81,d:"Antiguamente, esta mochila hecha con piel y alas de Moskitos causaba furor en los colegios. Hoy en día, pasó totalmente de moda y ha sido reemplazado, en el corazón de los niños, por la Pequeña Mochila de escolar del Jefe Cocodrail. Es absurdo, cuando uno sabe que esta es mucho más cara y sobre todo más fea. Historias de moda...",ep:1,g:59,l:16,wd:true,fm:true,w:2,s:23,p:900};
I.u[6917] = {n:"Moskitogarruleto",t:16,d:"Esta cofia debe su nombre sorprendente a la excentricidad del primer Anutrof que la descubrió al registrar un viejo Moskito enfermo. Muy útil para los aventureros novatos, permite ante todo que las Araknas hambrientas se vuelvan locas por ti.",ep:1,g:80,l:15,wd:true,fm:true,w:2,s:23,p:900};
I.u[6918] = {n:"Amuleto del moskito",t:1,d:"Menos eficaz y menos apreciado que el célebre Araknamú, este pequeño amuleto tiene sin embargo mucho encanto cuando se lleva solo, sobre un cuerpo muy peludo.",ep:1,g:75,l:15,wd:true,fm:true,w:2,s:23,p:800};
I.u[6919] = {n:"Anillo de champi champ",t:9,d:"Los champi champs no tienen fama de ser unas criaturas muy simpáticas. Te envenenan la vida en cuanto pueden, muerden muy fuerte y tienen muy mal carácter. Parece mentira como estas viles criaturillas te hacen pensar a veces en tu pareja...",ep:1,g:74,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6920] = {n:"Alianza de champi champ",t:9,d:"Cuando un champi champ se casa, le regala esta alianza a su dulcinea. Como esta no tiene brazos, la deposita cuidadosamente sobre una de sus espinas. Si te pones esta alianza, romperás los lazos del matrimonio que unían a estas dos criaturas y en el mejor de los casos, el champi champ en cuestión te confundirá con su dulcinea.",ep:1,g:75,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6921] = {n:"Champisombrero",t:16,d:"Antiguamente se utilizaba en infusión, incluso a veces se fumaba. Este sombrero de Champi Champ tiene, desde luego, muchas utilidades.",ep:1,g:84,l:9,wd:true,fm:true,w:3,s:24,p:425};
I.u[6922] = {n:"Capa del Champi Champ",t:17,d:"Si un Champi Champ rabioso es ya de por sí impresionante, un Champi Champ rabioso con capa es todavía peor. Pues esta capa encarna cierta forma de superpotencia vestimentaria, aunque haya que confesar que es bastante fea.",ep:1,g:76,l:9,wd:true,fm:true,w:2,s:24,p:450};
I.u[6923] = {n:"Amuleto del Bandido",t:1,d:"Este amuleto perteneció antiguamente al gran ladrón \"Hazo\", famoso por su crueldad sin límites y su muerte estúpida. Su vida fue digna de un cuento de Aniripsa, se murió ahogado y aplastado en una prensa de aceite justo cuando acababa de purgar una pena de prisión de un centenar de años por el robo de una Castaña de Cajú.",ep:1,g:76,l:16,wd:true,fm:true,w:2,s:25,p:900};
