I.u[6690] = {n:"Tijeras estropeadas",t:80,d:"Unas tijeras estropeadas de lo más comunes.",ep:1,g:33,l:1,wd:true,fm:true,w:2,ut:true,p:1};
I.u[6706] = {n:"Venda de la Momia Nova",t:15,d:"Estas vendas son tan viejas como su propietario y vice versa. A lo largo del tiempo, se han impregnado con poderes mágicos de la Momia Nova, pero también con su olor a carne en descomposición.",ep:1,g:712,l:150,wd:true,fm:true,w:1,p:1000};
I.u[6707] = {n:"Capa de la Momia Nova",t:17,d:"Esta capa está hecha con las vendas malolientes de la Momia Nova. Eso excitará a todos los habitantes de los cementerios vecinos.",ep:14,g:63,l:75,wd:false,fm:true,w:10,p:14600};
I.u[6708] = {n:"Certificado Dopeul",t:24,d:"Este certificado indica la fecha de tu última victoria frente a un dopeul.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6712] = {n:"Capa Huchina",t:17,d:"Esta magnífica capa huele a flor salvaje. Eso no significa que harás enloquecer a la primera Ocrita que pase pero es suficiente para encubrir los olores de un Sadida descuidado.",ep:1,g:82,l:71,wd:true,fm:true,w:10,p:13100};
I.u[6713] = {n:"Lorsothisas",t:5,d:"Impregnadas con la sangre del terrible Lordsotho, estas dagas le permitieron vencer al rey de los chafers durante el famoso concurso de lanzamiento de dagas de la feria del Trool. Desde aquel día, el rey de los chafers ya no se atrevió a mostrarse más con su calzoncillo de cuero y se exilió con el ilustre Capitán Chafer en las cercanías del cementerio de Pandala.",ep:1,g:34,l:100,wd:false,fm:true,w:10,an:13,e:[10,3,1,1,30,30,false,false],c:"PN~Lordsoth",p:1};
I.u[6716] = {n:"Nomoon",t:18,d:"Parece que este monito hurtador ya te quiere mucho. Aunque sea muy dócil, es sin embargo muy exigente a nivel alimentario y sólo come los vegetales que crecen en su isla.",ep:3,g:11,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6717] = {n:"Wauwau negro",t:18,d:"Con este perrito, podrás disfrutar de interminables paseos para que haga pis. Ha sido criado con raíces salvajes, te desaconsejamos darle de comer... pues podrías perder una mano. (ESTA LEGENDARIA MASCOTA NO NECESITA COMER).",ep:1,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6718] = {n:"Miaumiau Blanco",t:18,d:"Esta pequeña bola de pelo bribona y cariñosa ha engatusado a más de una chica sin distinción de clases. Es por lo tanto un temible animal. \n(ESTA MASCOTA LEGENDARIA NO NECESITA COMER)",ep:1,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6719] = {n:"Sombrero del Hombre Oso",t:16,d:"Este extraño sombrero perteneció al tristemente célebre Hombre Oso. Se cosió con restos de la cabeza de un oso en descomposición. Este sombrero te permitirá no pasar desapercibido, y sobre todo, dejar gracias a su olor original, un rastro de tu paso.",ep:1,g:64,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6720] = {n:"Capa del Hombre Oso",t:17,d:"Esta bonita capa ha sido llevada durante años por el célebre Hombre Oso. No hará de ti un oso pero con ella podrás rivalizar con los más grandes.",ep:8,g:58,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6721] = {n:"Botas del Hombre Oso",t:11,d:"Estas botas están forradas con piel de oso. Permitirán al que se las ponga mantener los pies siempre calentitos aun metinedo el pie en la nieve...",ep:2,g:51,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6722] = {n:"Alianza del Hombre Oso",t:9,d:"El Hombre Oso jamás se quitó esta alianza a pesar de que su mujer fuera devorada ante sus ojos por un oso que acababa de invocar y eso para impresionar a su dulcinea. Semejante proeza la dejó pasmada...",ep:1,g:66,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6723] = {n:"Amuleto del Hombre Oso",t:1,d:"El Hombre Oso llevaba este amuleto alrededor del cuello cuando se enfrentó a los salteadorillos de la guarida de Bimdhul. Cuenta la leyenda que le salvó la vida, pero cuando uno lo observa desde más cerca, se da cuenta de que realmente se trata de una leyenda.",ep:1,g:74,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6724] = {n:"Cinturón del Hombre Oso",t:10,d:"Este pequeño cinturón recubierto con pelos de oso es ideal para esconder tus michelines. Por eso es aconsejable que no te lo quites nunca para no decepcionar a tu media naranja.",ep:1,g:66,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6725] = {n:"Bastón del Hombre Oso",t:4,d:"El Hombre Oso utilizaba este bastón para domar sus invocaciones de oso y a veces, para azotar a sus hijos cuando estos no hacían sus deberes al volver del cole. Este hombre sí que sabía educar a sus hijos.",ep:14,g:46,l:20,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CA>50&CV>50",s:12,p:1300};
I.u[6731] = {n:"Amukwak de Hielo",t:1,d:"Con este amuleto alrededor del cuello, podrías intentar hacer que tu entorno crea que tienes un aliento fresco. Déjalo, es una pérdida de tiempo.",ep:1,g:71,l:42,wd:true,fm:true,w:3,s:13,p:4900};
I.u[6732] = {n:"Kwakanillo de Hielo",t:9,d:"Este pequeño anillo era antiguamente muy codiciado por las Anutrofitas que preferían utilizarlo para decorarse los dedos de los pies. Sin duda una manera inmejorable de esconder las verrugas.",ep:1,g:63,l:42,wd:true,fm:true,w:2,s:13,p:4900};
I.u[6735] = {n:"Raíz de mazorral",t:98,d:"Esta diminuta raíz encarna perfectamente la falsedad. Nadie sabe por qué, pero todo el mundo lo sabe.",ep:12,g:96,l:22,wd:true,fm:true,w:5,p:200};
I.u[6736] = {n:"Capullo de Mazorral",t:108,d:"Este pequeño capullo de Mazorral contiene una savia almibarada y pegajosa. Si por desgracia pisas un viejo Mazorral escondido entre la vegetación, te quedarás pegada a este hasta que devore completamente tus botas. En cambio, si consigues cortar un capullo de Mazorral intacto, podrás hacer que se calle el más pesado de los Fecas dándoselo para que lo use como chicle.",ep:12,g:97,l:22,wd:true,fm:true,w:5,p:1};
I.u[6737] = {n:"Corteza de Mazorral",t:96,d:"El Mazorral no tiene realmente verdaderas ramas como cualquier otro árbol. Sin embargo tiene una fina corteza resistente y llena de asperidades. Es muy práctico para crear mangos de herramientas que no resbalan o para dar palizas a los niños más traviesos. En ambos casos, la satisfacción está garantizada... para el que  utiliza el mango, claro.",ep:12,g:98,l:22,wd:true,fm:true,w:5,p:200};
I.u[6738] = {n:"Cráneo de Jefe Crocodail",t:47,d:"Este enorme cráneo es una ilustración de la desastrosa higiene dental del Jefe Crocodail. No ha desaparecido la magia, el alma del Jefe Crocodail lo ha elegido como residencia principal. Acabará derramando abundantes lágrimas de Crocodail si te portas mal con él.",ep:4,g:637,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6739] = {n:"Piel de crocodail",t:59,d:"Lograr un trozo completo de piel de Crocodail es casi un milagro, suele occurrir que los cazadores sólo recuperen algunas escamas. Ideal para fabricar un bolso, esta vieja piel convencerá a los sastres de ropa interior de combate.",ep:4,g:601,l:36,wd:true,fm:true,w:10,p:1000};
I.u[6740] = {n:"Piel del Jefe Crocodail",t:59,d:"Esta piel hecha de una múltiples escamas es en todos sus aspectos superior a una piel tradicional de Crocodail. La parte exterior de la piel del Jefe Crocodail es más resistente y cubierta de escamas afiladas, mientras que la parte interior se suave. Cuéntase algunos viejos sastres confunden ambas partes a la hora de fabricar ropa interior. Pero no se sabe si se ganaron un mayor número de clientes.",ep:4,g:600,l:69,wd:true,fm:true,w:10,p:1000};
I.u[6742] = {n:"Mazorramuleto",t:1,d:"Este amuleto está hecho a partir de una mezcla de hojas de Mazorral y de desperdicios de la Isla de Moon. Se parece más a un collar de flores que a un verdadero amuleto, pero te permitirá seducir sin gran esfuerzo la fauna local de la Isla de Moon compuesta, casi exclusivamente, por horribles criaturas. De este modo, no habrá Mazorra que te resista, te saltarán todas al cuello para hacerte chupetones. Los más desafortunados en amor sabrán contentarse con eso.",ep:12,g:69,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6743] = {n:"Mazorralianza",t:9,d:"Coge unas hojas de Mazorral, haz una pila, déjalas macerar en alcohol vencido, perfóralas, bébete el resto de alcohol, pega las hojas alrededor de un trozo de corteza, pégale trozos de hoja de Kokoko con una materia pegajosa y listo, ya tienes una magnífica Mazorralianza. Huele fatal y te será particularmente útil para justificar y esconder el olor de tus dedos si tienes tendencia a meterlos en cualquier sitio. Sobre todo ahí donde no debes...",ep:12,g:60,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6744] = {n:"Mazorrabotas",t:11,d:"Una vez que hayas probado estas botas ya no podrás separarte de ellas. No es que sean excepcionales, pero son increíblemente pegajosas. Una característica demasiado a menudo compartida con las hembras Mazorralas.",ep:12,g:47,l:34,wd:true,fm:true,w:5,s:16,p:3200};
I.u[6745] = {n:"Cinturón Mazorralizo",t:10,d:"Notable creación artesanal a base de restos de Mazorrales y de desperdicios que se han recogido a lo largo de las playas de Moon, en medio de la nauseabunda espuma de mar. Si llevas este cinturón solo, tendrás una pinta sorprendente. Eso desconcentrará a tus adversarios o soprenderá al ser amado. De esta forma, podrás controlar perfectamente la situación.",ep:12,g:62,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6746] = {n:"Amukwak de Tierra",t:1,d:"Antiguamente lo llevaba Oto Mustam, jefe de los guerreros de Brakmar. Este pequeño amuleto sólo le servía para ponerse guapo durante las orgías organizadas en Brakmar. Todo un programa.",ep:5,g:72,l:42,wd:true,fm:true,w:3,s:14,p:4900};
I.u[6747] = {n:"Amukwak del Viento",t:1,d:"Cuando sopla el viento sobre sus plumas, el Kwak de Viento se siente libre como el aire y se deja planear como una hoja muerta llevada por una borrasca. Contrariamente a lo que se pueda pensar, es bastante impresionante.",ep:5,g:70,l:42,wd:true,fm:true,w:3,s:15,p:4900};
I.u[6748] = {n:"Kwakanillo de Tierra",t:9,d:"Si te lo pones como Dios manda, este anillo te permitirá adornar tus dedos amorcillados. Desafortunadamente para algunos, su eficacia queda limitada a los dedos.",ep:5,g:64,l:42,wd:true,fm:true,w:2,s:14,p:4900};
I.u[6749] = {n:"Kwakanillo de Viento",t:9,d:"Este anillo es tan ligero que podría volar con el primer soplido. Pero no te hagas ilusiones, en caso de producirse, no volarás con él. En el mejor de los casos la gente se burlará de ti.",ep:5,g:62,l:42,wd:true,fm:true,w:2,s:15,p:4900};
I.u[6750] = {n:"Kwakhoja de Hielo",t:6,d:"Aquí tienes una hoja fría y cortante, despertará los instintos más primitivos de los que la usan.",ep:1,g:51,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CC>50&CV>50",s:13,p:4600};
I.u[6751] = {n:"Kwakhoja de Tierra",t:6,d:"\"Esta afilada hoja es perfecta para los aventureros endurecidos en busca de sensaciones nuevas\". Esto es lo que pone en las instrucciones de uso de esta espada. Hay que decir que las instrucciones de uso ya no son lo que eran.",ep:5,g:53,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>50&CV>50",s:14,p:4600};
I.u[6752] = {n:"Kwakhoja del Viento",t:6,d:"Esta espada es ideal para cortar nubes, pero también podrá servirte para hacer viento si la agitas como un abanico. Una excelente técnica para diezmar los Moskitos o para desfigurar a tus adversarios.",ep:5,g:50,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CA>50&CV>50",s:15,p:4600};
I.u[6753] = {n:"Kwakobotas de hielo",t:11,d:"Son ideales para patinar sobre lagos helados. Estas botas son también muy valiosas cuando tengas que mantener los pies al fresco, o a la hora de guardar tu merienda durante los días de mucha calor. Sin embargo, no es aconsejable ponerlas a secar cerca del fuego, pues puede que no las vuelvas a ver más.",ep:2,g:36,l:40,wd:true,fm:true,w:5,s:13,p:4400};
I.u[6754] = {n:"Kwakobotas de Tierra",t:11,d:"\"No hay nada mejor que las Kwakobotas de tierra para caminar por la tierra\", eso decía Rola Ingals la ilustre labradora, justo antes de que se volviera ciega al recibir un terrón gigante que le saltó los ojos.",ep:5,g:49,l:40,wd:true,fm:true,w:5,s:14,p:4400};
I.u[6755] = {n:"Kwakobotas del Viento",t:11,d:"Rudimentarias pero eficaces, estas botas son de una ligereza sorprendente. Se emplean a veces, tras haber aportado mejoras, para como manga de aire para indicar la dirección y la fuerza del viento. En estos casos, es aconsejable ubicarse en el lado adecuado de la manga de aire para no morir asfixiado.",ep:5,g:48,l:40,wd:true,fm:true,w:5,s:15,p:4400};
I.u[6756] = {n:"Kwapa de Tierra",t:17,d:"Idóneo para camuflarse en terrón gigante, esta capa te permitirá atacar por sorpresa a los labradores y robarles sus riquezas. Por eso está principalmente diseñada para coleccionadores de silex.",ep:8,g:64,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6757] = {n:"Kwapa del Viento",t:17,d:"Ligera y refinada, esta creación puede también servir como cortina para los aventureros más humildes. Antiguamente, la Momia Nova en persona quería hacerse con ella para poder vestirse decentemente cuando salía por la noche. Un ejemplo que algunos deberían seguir...",ep:8,g:62,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6758] = {n:"Kwakcinto de Tierra",t:10,d:"El Kwak de Tierra no es muy sociable y todos saben que se caza sobre todo para sus plumas. Si llevas este cinturón alrededor de las caderas, te expones a muchos problemas con los cazadores de Kwaks de Tierra que creerán desde lejos que eres un viejo Kwak encamado y en decadencia. Finalmente, las apariencias no siempre engañan.",ep:12,g:65,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6759] = {n:"Kwakcinto de Viento",t:10,d:"\"La única manera de poder atrapar un viejo macho Kwak de Viento contrariado consiste en disfrazarse de hembra Kwak de Viento contrariada. Entonces el macho intentará comprender por qué la hembra está contrariada e intentará, con todos los métodos que están a su alcance, satisfacer a la hembra. Una vez que el macho esté satisfecho con su actuación, hay que aprovechar su estado de gloria para desplumarlo\". Esto es lo que se puede leer en la sección doce del tomo tres acerca de la caza de los Kwaks de Viento. Además está claramente mencionado que este cinturón es indispensable para hacerse pasar por una hembra Kwak de Viento. Ya sabes lo que te queda.",ep:12,g:63,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6760] = {n:"Kwakosombrero de Tierra",t:16,d:"Este Kwakosombrero de Tierra es tan pesado que te permitirá mantener los pies anclados a la tierra en permanencia, pero también te hará caer de vez en cuando. No se puede tenerlo todo.",ep:13,g:71,l:41,wd:true,fm:true,w:25,s:14,p:4600};
I.u[6761] = {n:"Kwakosombrero del Viento",t:16,d:"Para que tu pelo se mantenga al viento incluso cuando estás equipado con un sombrero, no hay nada mejor que este simpático Kwakosombrero del Viento que te permitirá sin duda alguna, dejar libre curso a tu expresión capilar en todas circunstancias. Esto es suficiente para dejar atónito al más veterano de los Chafers.",ep:13,g:69,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6762] = {n:"Mazoporrazo",t:4,d:"\"Para mazar a porrazos, lo mejor es tener un buen Mazoporrazo\". Esto es lo que se podía leer en un anuncio publicitario que proponía a los aventureros construirse este bastón a partir de recursos escondidos y diseminados por toda la isla de Moon. Como un juego de pistas pero sin las pistas.",ep:12,g:44,l:32,wd:true,fm:true,w:5,e:[15,4,1,1,20,70,false,false],s:16,p:2900};
I.u[6763] = {n:"Mazorracapa",t:17,d:"Cuentan que los Mazorrales muertos son muy cómodos cuando una vez que se hayan descompuesto al sol. Con el tiempo se vuelven más flexibles y suaves. A cuántos aventureros les gustaría que su dulcinea fuera como esta materia...",ep:12,g:61,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6764] = {n:"Mazorrasombrero",t:16,d:"Con este sombrero, no tendrás aspecto de ser muy astuto. Pero más que si no lo llevaras, entonces mejor guardarlo.",ep:12,g:68,l:31,wd:true,fm:true,w:5,s:16,p:2800};
I.u[6765] = {n:"Leleche",t:79,d:"Cuidado, el embalaje precisa que no hay que darle esta leche a un joven miaumiau, pues podría manchar tu casa.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:4};
I.u[6766] = {n:"Espiga de Farle",t:1,d:"Este amuleto de aspecto básico fue creado a partir de tres espigas de trigo mágicas, cubiertas con polvo de piedra preciosa y segadas en las llanuras de Snossios durante la decimotercera cosecha de Istrabraq. Confiere una valentía fuera de lo común, lo cual le permite segar llanuras y valles sin sentir nunca el cansancio.",ep:1,g:68,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6767] = {n:"Pulsera Mágica de Farle",t:9,d:"Esta pulsera de piedras preciosas ha sido recubierta con una tela de Cáñamo por Shika para no llamar la atención de los Cuerboks cuando Farle segaba su cebada.",ep:13,g:61,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6768] = {n:"Soki",t:32,d:"Te llevas a este pobre miaumiau para distraerlo.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[6769] = {n:"Bastón de Farle",t:4,d:"Este precioso bastón lleva unas púas en su extremidad lo cual hace de él una excelente horca. Farle lo usaba para hacer inmensos pajares, más altos que el más alto de los Olmos que crecía antiguamente en el bosque de Litneg. Algunos cuentan que fue el mismo Brus Bulguro quien cortó la madera necesaria para la fabricación de este bastón, a cambio de las monstruosas raciones diarias de copos de avena que Shika Ingals le llevaba. Él las devoraba antes de marcharse a derribar bosques enteros.",ep:14,g:43,l:80,wd:true,fm:true,w:10,an:12,tw:true,e:[10,5,1,1,45,45,false,true],c:"CS>100&CV>100",s:17,p:16500};
I.u[6770] = {n:"Raratón",t:15,d:"Este Raratón ha sido desalojado a escobazos de la casa de Abuela.",ep:1,g:282,l:1,wd:true,fm:true,w:10,p:1};
I.u[6771] = {n:"Anillo Té",t:9,d:"Este anillo todavía no hizo sus pruebas. Se trata de un producto único realizado por un joyero aprendiz durante un examen importante. Está fabricado con un anillo de hierro clásico bañado en una solución de Té mágico.",ep:1,g:1,l:4,wd:false,fm:true,w:1,p:50};
I.u[6773] = {n:"Amuleto Incakodo",t:1,d:"Este amuleto fue creado en la pura tradición Inkakodo, lo cual explica su nombre. Se trata de uno de los primeros métodos de creación, por ser uno de los más sencillos que se enseñan a los joyeros aprendices. Vale, el objeto no es muy poderoso pero tampoco hay que pedirle demasiado.",ep:1,g:19,l:1,wd:false,fm:true,w:1,p:25};
I.u[6774] = {n:"Zuecos de Farle",t:11,d:"Estos zuecos han sido tallados en maderas muy raras, reforzadas con retales de cueros de incalculable valor y forrados con cereales mágicos. Tan ligero como elegante y confortable, este par de zuecos resistirá al paso del tiempo sin la más mínima marca. A ciertos aventureros un tanto misóginos les gustaría poder decir lo mismo de su dulcinea.",ep:9,g:46,l:80,wd:true,fm:true,w:10,s:17,p:16600};
I.u[6775] = {n:"Capa de Farle",t:17,d:"Esta capa hecha con tejido y pieles le permitía a Farle Ingals sembrar campos enteros durante una temporada completa y sin tener que pararse. Pues una vez doblada y utilizada como si fuera una alforja, su capacidad parece casi ilimitada. Nadie conoce realmente al sastre que hizo esta maravilla, la leyenda sólo cuenta que dejó el oficio cuando sus clientes empezaron a confundir sus capas con vulgares bayetas. ¡Qué forma más triste de retirarse!",ep:13,g:70,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6776] = {n:"Farlacinto",t:10,d:"Este cinturón lo usaba Farle Ingals como mandil de carnicero cuando tenía que degollar sus rebaños de Jalatós. Una labor ingrata y cruel que sin embargo él cumplía con un placer no disimulado.",ep:4,g:61,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6778] = {n:"Farlasombrero",t:16,d:"Este sombrero de paja ha sido confeccionado con una multitud de espigas mágicas trenzados entre ellos. Su interior ha sido forrado con diversos pelos y telas cosidas a mano por Shika Ingals, esposa de Farle. Más bonito que el paletoso y más estilizado que el Témelo, este sombrero te protegerá del baldío durante centenares de cosechas al mismo tiempo que te proporcionará un aspecto vivaracho y realmente \"guay\". Lo suficiente para improvisarse rey o reina de los campos.",ep:13,g:67,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6779] = {n:"Informe del espía sram",t:24,d:"Informe del espía Ztiv Oztin, recuperado con cierta dificultad de entre las manos de Joe Pierlivet.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6780] = {n:"Espada del Novato",t:6,d:"Esta arma, aparentemente rudimentaria, te dará la impresión de saber luchar.",ep:1,g:96,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6781] = {n:"Varita del Novato",t:3,d:"Esta arma, aparentemente rudimentaria, te dará la impresión de saber luchar.",ep:1,g:8,l:1,wd:true,fm:true,w:10,an:11,e:[5,4,2,3,50,50,false,true],p:1};
I.u[6782] = {n:"Bastón del Novato",t:4,d:"Esta arma aparentemente rudimentaria te dará la impresión de saber luchar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6783] = {n:"Arco del Novato",t:2,d:"Esta arma, aparentemente rudimentaria, te dará la impresión de saber luchar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,6,50,50,false,true],p:1};
I.u[6784] = {n:"Dagas del Novato",t:5,d:"Esta arma, aparentemente rudimentaria, te dará la impresión de saber luchar.",ep:1,g:10,l:1,wd:true,fm:true,w:10,an:13,e:[5,3,1,1,30,50,false,false],p:1};
I.u[6785] = {n:"Martillo del Iniciado",t:7,d:"Esta arma aparentemente rudimentaria te dará la impresión de saber luchar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:15,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6786] = {n:"Pala del Novato",t:8,d:"Esta arma, aparentemente rudimentaria, te dará la impresión de saber luchar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6787] = {n:"Ficha rellenada válida",t:80,d:"Esta pequeña ficha lleva escrita el nombre de un posible candidato para ser repartidor de panadero.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW>1499&CA>49",p:0};
I.u[6788] = {n:"Galletas",t:24,d:"Estas galletas acaban de salir del horno. Hay que entregarlas antes de que enfríen. ¿Acaso piensas que tienes tiempo para examinarlas de esa manera?",ep:1,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[6789] = {n:"Amuleto de los Campos",t:1,d:"Este pequeño amuleto florece en primavera, pero marchita en verano, seca en otoño y pudre en invierno. \nLa ocasión idónea para cambiar de pinta según las estaciones.",ep:1,g:73,l:10,wd:false,fm:true,w:5,s:18,p:500};
I.u[6790] = {n:"Ficha para rellenar",t:80,d:"Esta ficha se parece a una hoja sencilla, sin embargo al contacto con la piel de un indivíduo, muestra enseguida si la persona corresponde a los criterios mencionados en el membrete.",ep:1,g:6,l:1,wd:false,fm:true,w:0,ut:true,p:0};
I.u[6791] = {n:"Anillo Campestre",t:9,d:"Con este hermosillo anillo al dedo, podrás intentar pasar casi desapercibido en medio de los campos.",ep:1,g:65,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6792] = {n:"La Plantamaza de los Campos",t:4,d:"Este bastón en forma de flor ha sido creado con restos de flores campestres que fallecieron durante horribles y crueles batallas. Toda la rabia y la ira de estas pobres plantas está contenida en este ridículo bastón. Los Srams más falsos lo utilizan para convencer a las ignorantes. Las engañan dándoles a pensar que les regalan un ramo de flores. Cuando estas imprudentes se ponen a su alcance, los srams las golpean (con razón) en plena cocorota...",ep:1,g:45,l:10,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,45,50,false,false],c:"CV>20",s:18,p:500};
I.u[6793] = {n:"Anillo Té",t:9,d:"Este anillo ha hecho sus pruebas, una pequeña marca en su interior lo demuestra. Se trata de un objeto único realizado por un joyero aprendiz durante un examen importante. Está fabricado con un anillo de hierro clásico bañado en una solución de Té mágico.",ep:1,g:1,l:4,wd:true,fm:true,w:1,p:50};
I.u[6794] = {n:"Botas Campestres",t:11,d:"No hay nada mejor como estas botas hechas con restos de flores campestres para aplastar aquellas miserables flores que crecen en tus campos. Además estas botas harán que tus pies desprendan un maravilloso olor a flor. Una pena que no exista algún equivalente de estas botas para los calzones...",ep:1,g:50,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6795] = {n:"Capucha de los Campos",t:17,d:"Si quieres ser la más bella para ir al baile, esta es la capa que necesitas.",ep:1,g:65,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6796] = {n:"Cinturón Florido",t:10,d:"Con este cinturón decorado con pequeños pétalos ciñendo tus caderas, podrás sin problema hacerte pasar por una primera bailarina en medio de un combate perdido de antemano. Eso podría dejar atónito un ejército de Chafers y te permitiría sacar partido a la situación.",ep:1,g:64,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6797] = {n:"Sombrero Campestre",t:16,d:"Si siempre has soñado con ser florista y tener un aliento perfumado al agua de rosas, es el momento de adoptar este extraño sombrero.",ep:1,g:70,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6798] = {n:"Flor de dizbi",t:24,d:"Su perfume es ligero, sutil, embriagador... Pero solamente los sadidas y los aniripsas conocen el secreto de estas flores.",ep:1,g:117,l:1,wd:false,fm:true,w:0,p:1};
I.u[6799] = {n:"Hoja del Jefe Bwork",t:6,d:"Aunque es igual de tronchante que una lágrima de Bwork, esta espada del Jefe Bwork tiene la gran ventaja de ser mucho más pesada. Es ciertamente menos manejable pero basta con dejarla caer sobre tu adversario para cortarlo en dos, como si fuera una vulgar loncha de Tronkónido. Si tu enemigo no muere de dolor, se morirá de vergüenza, y tú de risa.",ep:1,g:48,l:100,wd:true,fm:true,w:100,an:14,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>200&CA>200&CV>200",s:19,p:25000};
I.u[6800] = {n:"Capa Banal",t:17,d:"Esta capa está hecha con lana de Jalatín. No te será de ninguna utilidad al menos que quieras tener un aspecto chulo... Y aún así...",ep:1,g:15,l:1,wd:true,fm:true,w:1,p:1};
I.u[6801] = {n:"Capa Invernal",t:17,d:"Esta capa banal lleva un forro cosido con mucha delicadeza. Es muy abrigosa y desprende una fragancia muy agradable. Puedes llevarla puesta o utilizarla como si fuera una piel de bestia para adornar tu chimenea.",ep:1,g:18,l:1,wd:true,fm:true,w:2,p:1};
I.u[6802] = {n:"Orejeras",t:16,d:"Estas orejeras muy suaves harán que tus orejitas estén siempre calentitas.",ep:1,g:73,l:1,wd:true,fm:true,w:10,p:1};
I.u[6803] = {n:"Extracto de flor de Dizbi",t:24,d:"Simplemente... ¡No lo bebas!",ep:1,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[6804] = {n:"Amuleto del Jefe Bwork",t:1,d:"De aspecto básico, este amuleto en forma de sílex tallado está sin embargo dotado con una magia muy potente capaz de transformar a un Bwork en princesa, o al revés, no se sabe.",ep:1,g:66,l:100,wd:true,fm:true,w:1,s:19,p:25600};
I.u[6805] = {n:"Brazal del Jefe Bwork",t:9,d:"Con este pequeño anillo, la gente en tu entorno piensará que te has casado con un gran Jefe Bwork y que te regaló este brazal como regalo de boda. Podrás vacilar en cada una de las noches de fiesta de la Taberna si no tienes mucha conversación.",ep:1,g:58,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6806] = {n:"Fragmento de madera",t:24,d:"Este fragmento de madera viene de una construcción reciente, roja según parece...",ep:1,g:246,l:1,wd:false,fm:true,w:0,p:1};
I.u[6807] = {n:"Botas del Jefe Bwork",t:11,d:"Desde lejos, estas botas se parecen a las botas tradicionales de Bwork. Desde cerca también. Y sin embargo, son botas de Jefe Bwork. Más resistentes, más poderosas y más apestosas. Te permitirán marcar diferencias en los combates perdidos de antemano.",ep:1,g:44,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6808] = {n:"Cacho de tela arrancado",t:24,d:"Este cacho de tela blanca es muy suave y está muy manchado.",ep:1,g:247,l:1,wd:false,fm:true,w:0,p:1};
I.u[6809] = {n:"Descripción aproximativa",t:24,d:"Esta descripción describe a una pequeña muchacha vestida con colores oscuros y con el cabello rubio.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6810] = {n:"Informe de actividad del barrio",t:24,d:"Este informe estipula que ningún incidente ha sido constatado en el barrio el día del robo de la casa. \nExcepto la vista de un tymador durante la noche del incidente.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6811] = {n:"Capa del Jefe Bwork",t:17,d:"Esta capa despedazada y llena de agujeros te convertirá en un gran guerrero bwork. Es perfecta si quieres aterrorizar a los ancianos del pueblo. En cambio puede que te resulte más difícil seducir a tu media naranja con ella, a menos que la lleves totalmente desnudo lo cual te permitirá también seguir espantando a los ancianos del pueblo.",ep:1,g:60,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6812] = {n:"Calzoncillo del Jefe Bwork",t:10,d:"Te bastará con llevar este calzoncillo y aún así tendrás una pinta muy chula siempre y cuando la talla corresponda a tu silueta y no se te vaya abajo durante una partida de salto a la comba demasiado animada.",ep:1,g:59,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6813] = {n:"Casco del Jefe Bwork",t:16,d:"Si realmente quieres parecer al tonto del pueblo, este casco es el tuyo. Con un poco de suerte no se notará siquiera la diferencia cuando te lo quites.",ep:1,g:65,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6814] = {n:"Conjunto de trozos de madera",t:24,d:"Este conjunto de trozos de madera forma un cama muy blandita, ideal para un Pío.",ep:1,g:248,l:1,wd:false,fm:true,w:0,p:1};
I.u[6815] = {n:"Jeringuilla de Nibe Lula",t:24,d:"Nibe Lula te ha dado esta jeringuilla para sacar una muestra de sangre de Radlu Minite el Minero Oscuro.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6816] = {n:"Muestra de sangre",t:24,d:"Por fin has conseguido sacar una muestra de sangre de Radlu Minite. Muy apetitoso.",ep:1,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[6817] = {n:"Amuleto del Jefe Cocodrail",t:1,d:"Este sorprendente amuleto fue creado a partir de un Escudo Reptil del cual se extrajeron las múltiples piedras preciosas. Se trata pues de una joya particularmente pesada pero muy resistente. Tu cuello estará totalmente a salvo de los vampiros, pero también de los chupetones de aldeanas demasiado atrevidas...",ep:4,g:67,l:70,wd:true,fm:true,w:100,s:20,p:12700};
I.u[6818] = {n:"Rosa demoníaca cortada",t:35,d:"Esta flor, que antes era demoníaca, ahora es un regalo angélico. Dicho esto, si a cambio solamente recibes una sonrisa forzada, podrás hacer con ella confitura.",ep:1,g:118,l:1,wd:false,fm:true,w:1,p:1};
I.u[6819] = {n:"Brazal del Jefe Cocodrail",t:9,d:"Fíjate bien, esto es una pulsera aunque se parezca mucho a un guante. Las apariencias a veces engañan.",ep:4,g:59,l:70,wd:true,fm:true,w:20,s:20,p:12800};
I.u[6820] = {n:"Hierba curativa",t:24,d:"Esta hierba es el ingrediente principal de viejos remedios de alquimista. Ya no se usa hoy en día. La gente prefiere usar el trébol ya que no provoca picores en la cara, lo cual hay que reconocer que es una ventaja.",ep:1,g:103,l:1,wd:true,fm:true,w:0,p:1};
I.u[6821] = {n:"Hoja del Jefe Cocodrail",t:6,d:"Ha sido fabricada a partir de restos encontrados dentro de un Jefe Cocodrail. Esta arma se revelará muy eficaz si eres los suficientemente guapo, hábil, inteligente y fuerte para manejarla. Con un poco de suerte, acabarás encontrando alguien que aceptará cambiártela por una espada de maderucha.",ep:4,g:49,l:70,wd:true,fm:true,w:100,an:14,e:[12,6,1,1,40,40,false,false],c:"CA>150&CC>150&CV>100",s:20,p:12800};
I.u[6822] = {n:"Pinchazo de despertamiento",t:24,d:"Esta jeringuilla contiene un remedio tan potente que podría despertar a un muerto. Además, parece ser que el ilustre muerto-viviente Hyrkul se lo inyectaba a menudo. No se puede encontrar mejor prueba de su eficacia.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6823] = {n:"Pócima a base de plantas",t:24,d:"El olor nauseabundo de esta pócima podría casi despertar a un sadida durante su siesta... o... si el sadida es joven y está a punto de despertarse.",ep:1,g:500,l:1,wd:true,fm:true,w:0,p:1};
I.u[6824] = {n:"Piedra de Cuidados Fugitivos",t:24,d:"Esta piedra de cuidados pierde su poder muy rápidamente, es preciso rodearla con un metal que absorbe algunas radiaciones, para confinar el efecto de la piedra y poder preservar así su eficacia. La gente prefiere utilizar amuletos normales casi tan eficaces como este y sobre todo mucho más baratos.",ep:1,g:104,l:1,wd:false,fm:true,w:0,p:1};
I.u[6825] = {n:"Zapatillas Corvas del Jefe Cocodrail",t:11,d:"Estas magníficas zapatillas de piel y de escamas de Jefe Cocodrail llevan afilados dientes en sus extremidades. Ten cuidado si le haces piecitos a tu dulcinea, no vayas a rasgarle sus bonitas medias de lana de Tabi...",ep:4,g:45,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6826] = {n:"Piedra de cuidado engastada",t:24,d:"Este amuleto es una piedra de cuidados fugitivos está engastado en un trozo de metal muy raro. Si lo sujetas en tu mano obtienes una sensación de bienestar, el cansancio se va y el cerebro se libera. Y además se te puede ver de noche con él.",ep:1,g:105,l:1,wd:false,fm:true,w:0,p:1};
I.u[6827] = {n:"Carta de Joe Pierlivet",t:24,d:"¡Joe te ha entregado esta carta para que se la lleves a uno de sus buenos amigos, Howard el Siperonada, un Yopuka que.. esteee... cómo decir... ¡Vamos, que es un Yopuka!",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6828] = {n:"Pomo de espada",t:24,d:"Este pomo no te transformará en un experto en manejo de espada pero puede que te ayude.",ep:1,g:97,l:1,wd:false,fm:true,w:0,p:1};
I.u[6829] = {n:"Espada recién forjada",t:24,d:"Esta espada acaba de ser forjada.",ep:1,g:98,l:1,wd:false,fm:true,w:0,p:1};
I.u[6830] = {n:"Pequeña mochila de escolar del jefe cocodrail",t:81,d:"En Amakna la vuelta al cole también es una experiencia dolorosa para los niños. Sobre todo para los jóvenes yopukas para quienes eso es sinónimo de calvario con pruebas infranqueables. Reconfórtalos con esta magnífica mochila de piel y escamas de jefe cocodrail y rellena de multitud de pelos.",ep:14,g:58,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6831] = {n:"Cinturón del Jefe Cocodrail",t:10,d:"Aunque este cinturón recubierto con minúsculas piedras preciosas sea demasiado rígido para servir de látigo, puede sin embargo ser utilizado de forma más convencional, para evitar por ejemplo, que tus polainas se te caigan a los tobillos.",ep:4,g:60,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6832] = {n:"Repartidor de Cerveza",t:32,d:"El repartidor de cerveza es tan importante como un guardia jurado que transporta los fondos de un banco. Aunque mucho más arisco.",ep:1,g:15,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6833] = {n:"Bolsa de Kamas sospechosa",t:24,d:"Estos kamas parecen llegar de un otro tiempo, sería necesario fundirlos rápidamente antes de que decidan volver de dónde han venido.",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6834] = {n:"Sombrero del Jefe Cocodrail",t:16,d:"Si has soñado siempre con parecerte a un Cocodrail sin tampoco tener que transformarte en Cocodrail, este sombrero está hecho para ti. Pero no creas que utilizándolo podrás hacer que tus amigos crean que has matado tú mismo a un Cocodrail. Pues nadie se lo creería, aparte tú mismo claro...",ep:4,g:66,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6835] = {n:"Metal transmutado",t:24,d:"La bolsa de kamas sospechosa ha sido transmutada con destreza por Nibe Lula. Ya se puede crear una espada con este metal...",ep:1,g:241,l:1,wd:true,fm:true,w:0,p:1};
I.u[6836] = {n:"Espada grosera",t:24,d:"He aquí una espada forjada por las manos de Aduano, pero parece aún demasiado frágil para ti. Nibe Lula el Alquimista debería poder hacer algo para remediarlo.",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6837] = {n:"Espada Brincadora",t:24,d:"He aquí una espada hecha para ti, ligera y temible. Pero falta un pequeño toque final, algo de Zurcarák...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6838] = {n:"Espada de fuego grosera",t:24,d:"El agua de luna parece hacer su efecto. Esta espada es solidísima pero le falta algo de Zurcarák...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6839] = {n:"Espada de Yinguiciado",t:6,d:"Esta arma lleva el sello de Meow Meow, puede que haga de ti un zurcarák legendario, tal vez...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=0",p:1};
I.u[6840] = {n:"Espada de Yanguiciado",t:6,d:"Esta arma lleva el sello de Meow Meow, puede que haga de ti un Zurcarák legendario, a lo mejor...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=1",p:1};
I.u[6841] = {n:"Tejido de oso",t:55,d:"Este extraño tejido huele a oso. Las mujeres ya no podrán resistirte más.",ep:1,g:121,l:22,wd:true,fm:true,w:1,p:500};
I.u[6842] = {n:"Diente de oso",t:47,d:"Este extraño diente perteneció a un viejo oso. O más bien a una invocación de oso lo cual hay que reconocer es totalmente diferente ya que en realidad lo que tienes entre tus manos es un diente invocado. Muy interesante.",ep:1,g:432,l:22,wd:true,fm:true,w:1,p:500};
I.u[6843] = {n:"Hueso de Oso",t:47,d:"Este hueso puntiagudo se rompió durante un terrible combate contra uno de los Osos invocados por el Hombre Oso. Era demasiado tarde para poner un empaste sobre la pata de este pobre Oso agonizante y gimiendo de dolor a causa de tus repetidos ataques. Has preferido rematarlo despacito asfixiándolo con baba de Jalató, despedazarlo y luego arrancarle este hueso cuando todavía esta consciente. Uno no tiene que ser despiadado con las invocaciones.",ep:1,g:48,l:22,wd:true,fm:true,w:1,p:500};
I.u[6844] = {n:"Pelos de oso",t:54,d:"A veces, el Hombre Oso se pone a depilar a una de sus invocaciones de oso para divertirse o para pasar el rato. Después recupera los pelos para confeccionarse ropa interior de gran calidad y muy rebuscada por los cazadores solitarios a los cuales les gusta las sensaciones y los olores fuertes.",ep:1,g:195,l:22,wd:true,fm:true,w:1,p:500};
I.u[6845] = {n:"Piel de oso",t:59,d:"Esta piel rugosa y sin pelos es el fruto de un largo trabajo de depilación intensiva con aceite hirviente y hierro calentado al rojo vivo. Que no te extrañe entones si huele a chamusquina.",ep:1,g:35,l:22,wd:true,fm:true,w:1,p:500};
I.u[6846] = {n:"Frasco de cristal de pálido Anthir",t:24,d:"Un vulgar frasco a primera vista. Sin embargo, posee un poder que sólo los Xelors saben explotar...",ep:1,g:99,l:1,wd:false,fm:true,w:0,p:1};
I.u[6847] = {n:"Saco de granos de specia",t:24,d:"Grano bastante raro que no sirve para gran cosa. ¡¿Quién ha dicho como los xelors?!",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6848] = {n:"Madera Floriturada",t:24,d:"Madera de mediana factura.",ep:1,g:100,l:1,wd:false,fm:true,w:0,p:1};
I.u[6849] = {n:"Caja de Constipositorio",t:24,d:"Los únicos en conocer el modo de empleo son los Anutrofs. Quizá sea simplemente porque es preferible no saber demasiadas cosas acerca de sus secretos... ¡¡¡Y vaya secretos!!!",ep:1,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[6850] = {n:"Pizaya",t:24,d:"Una de las especialidades culinarias de Astrub, la pizaya tiene la ventaja de poder comerse en cualquier sitio y en cualquier momento, aparte quizá en el barrio de los carniceros ya que el olor de ese sitio es insoportable...",ep:1,g:107,l:1,wd:false,fm:true,w:0,p:1};
I.u[6852] = {n:"Peluche de la feria",t:24,d:"El peluche que Yori Khas ha ganado en la feria del trool...",ep:1,g:151,l:1,wd:true,fm:true,w:0,p:1};
I.u[6853] = {n:"Madera de carvayinio",t:24,d:"Esta madera tiene la particularidad de crecer derechita, como un bastón. Muy práctico para almacenarla...",ep:1,g:100,l:1,wd:true,fm:true,w:0,p:1};
I.u[6854] = {n:"Piel de larva azul",t:24,d:"Un cacho de carne pegajosa arrancada de una pobre larva sin defensa.",ep:1,g:101,l:1,wd:false,fm:true,w:0,p:1};
I.u[6855] = {n:"Arquito de Enileda",t:24,d:"Fruto del trabajo de la famosa escultora de arcos Enileda, este pequeño arco no es una referencia en sí.",ep:1,g:244,l:1,wd:true,fm:true,w:0,p:1};
I.u[6856] = {n:"Tijeras para rosa demoníaca",t:20,d:"La forma de estas tijeras está especialmente estudiada para cortar el tallo de cualquier rosa demoníaca sin estropear los pétalos. Podrás hacerlo incluso si la rosa te muerde el gemelo.",ep:1,g:22,l:1,wd:true,fm:true,w:2,an:13,e:[5,3,1,1,20,20,false,false],p:1};
I.u[6857] = {n:"Cerveza de Astrub",t:37,d:"Una vulgar cerveza que favorece el desarrollo de tu músculo abdominal, más famosa bajo el nombre de \"Koroniñita\".",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:4};
I.u[6858] = {n:"Ficha rellenada pero no válida",t:80,d:"Esta pequeña ficha lleva escrito el nombre de un candidato, desafortunadamente, no válido para ser repartidor de panadero. La manchita roja abajo indica que o no era lo suficientemente fuerte o no lo suficientemente ágil para esa profesión.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW<1500|CA<50",p:0};
I.u[6859] = {n:"Par de tijeras",t:24,d:"Unas tijeras que no matan ni espantan... incluso algunos peluqueros cuentan que cortan pero no peinan...",ep:1,g:150,l:1,wd:true,fm:true,w:0,p:1};
I.u[6862] = {n:"Manuscrito del Oso",t:24,d:"Este extraño pergamino explica cómo el Hombre Oso ha aprendido a invocar osos. Increíble.",ep:1,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[6863] = {n:"Casco de los Mercenarios de Astrub",t:16,d:"Casco de los Mercenarios de Astrub.",ep:1,g:72,l:1,wd:false,fm:true,w:10,p:1};
I.u[6864] = {n:"Flor de rosa oscura",t:24,d:"Una flor de rosa tan oscura que, en comparación, su sombra parece destellar.",ep:2,g:106,l:23,wd:true,fm:true,w:0,p:1};
I.u[6865] = {n:"Nota",t:24,d:"\"Cita en el linde del bosque para la entrega\"",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6866] = {n:"Cacho de capa",t:24,d:"Un cacho de capa azul de los que te han atacado. Aunque no parezca, les has dado una buena paliza.",ep:1,g:249,l:1,wd:false,fm:true,w:0,p:1};
I.u[6867] = {n:"Nota de cosecha",t:24,d:"Para no olvidarte de la hora a la cual tienes que cosechar el biento, la has escrito sobre este papel.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6868] = {n:"Tabla de castaño",t:95,d:"Esta tabla de castaño se utiliza a veces para construir casas pero suele ser más común emplearlas para hacer trampas para moscas...",ep:1,g:1,l:10,wd:true,fm:true,w:10,p:20};
I.u[6869] = {n:"Yori Khas",t:32,d:"Yori Khas ya no sabe donde está su casa, por eso tienes que llevarla de vuelta...",ep:1,g:14,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6870] = {n:"Noai Aludem",t:32,d:"Noai Aludem está ahora bajo tu control. Debes llevarlo sano y salvo hasta la prisión.",ep:13,g:8,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6871] = {n:"Tortacia Leukocitina",t:32,d:"Tortacia está ahora bajo tu control. Debes ahora llevarla hasta la prisión y que llegue sana y salva.",ep:1,g:11,l:1,wd:false,fm:true,w:0,m:true,p:1};
