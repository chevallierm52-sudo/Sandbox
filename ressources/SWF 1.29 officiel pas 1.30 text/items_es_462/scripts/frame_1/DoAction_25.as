I.u[10966] = {n:"Transformación en larva",t:31,d:"Las malas lenguas insinuarían que se ha despertado tu yo profundo. ¿No tendrán algo de razón?",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=21",p:0};
I.u[10967] = {n:"Sesos de larva",t:69,d:"Hay que estar muy desesperado para comerse esto. ¡No! ¡¡No lo hagas!!",ep:0,g:113,l:1,wd:false,fm:true,w:0,c:"Sc=21",u:true,ut:true,p:1};
I.u[10968] = {n:"Transformación en wabbit",t:31,d:"Por extraño que parezca, no tienes ganas de zanahowia.",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=22",p:0};
I.u[10969] = {n:"Pócima de fwescuwa",t:12,d:"La dulzura de una zanahowia mezclada con la frescura de un dragopavo maratoniano. No encontrarás nada mejor para devolverte la forma. ¡Salud!",ep:0,g:141,l:20,wd:false,fm:true,w:1,c:"Sc=22",u:true,ut:true,p:1};
I.u[10970] = {n:"Sudor de dragopavo",t:15,d:"Pero ¿cómo has hecho para conseguir eso? O mejor, ¿por qué lo has hecho?... Tú eres un poco rarito, ¿no?",ep:0,g:773,l:1,wd:false,fm:true,w:1,p:1};
I.u[10971] = {n:"Morral Lanac",t:81,d:"Equipado con este morral podrás hacer las mil y una canalladas y siempre con la sonrisa en los labios, pillín.",ep:0,g:25,l:20,wd:false,fm:true,w:10,c:"Sc=23",p:1};
I.u[10972] = {n:"Seguidor cuerbok",t:31,d:"Aunque parezca muy afectuoso, sospechas que esta ave se escapará volando en cuanto se acerque el peligro.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,c:"Sc=24",p:0};
I.u[10973] = {n:"Pócima de destino desconocido",t:12,d:"Una voz resuena en tu conciencia diciéndote que no te bebas el contenido de este frasco. En realidad, ¡es tu nariz! Esta mezcla huele peor que el sobaco de un bwork centenario.",ep:0,g:189,l:20,wd:false,fm:true,w:1,c:"Sc=25",u:true,p:10};
