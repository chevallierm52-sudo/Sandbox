I.u[11115] = {n:"Pehkaíto d\'aperirel",t:30,d:"Parece que volvió la primavera. El olor de las flores, del campo verde... pero sobre todo la peste de ese úridnac que llevas a la espalda.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[11116] = {n:"Úridnac",t:94,d:"A este pescado le gusta mucho la gente, así que se quedará pegado al primer bañista que se despiste \nSin embargo, tiene un ritmo biológico bastante particular: Se tira todo el año hibernando, salvo durante el mes de aperirel, cuando Siluate caluenta las dulces aguas en que propsera.",ep:0,g:19,l:1,wd:false,fm:false,w:1,c:"SG=3&POX11115",u:true,ut:true,p:0};
