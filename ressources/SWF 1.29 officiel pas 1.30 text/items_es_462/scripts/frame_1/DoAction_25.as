I.u[11213] = {n:"Garrapatas de jalamut",t:24,d:"Más resistentes que el calzoncillo de kriptonita del Capitán Chafer y más agresivas que un rebaño de rastreadores astrubienses, estas garrapatas son un auténtico calvario para su anfitrión.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[11214] = {n:"Sangre de jalamut infectado",t:24,d:"Ésta es una muestra de sangre obtenida de un jalamut que estaba lleno de garrapatas.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11215] = {n:"Sangre de jalamut de guerra infectado",t:24,d:"Ésta es una muestra de sangre obtenida de un jalamut de guerra que estaba lleno de garrapatas.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11216] = {n:"Sangre de jalamut legendario infectado",t:24,d:"Ésta es una muestra de sangre obtenida de un jalamut legendario que estaba lleno de garrapatas.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11217] = {n:"Sangre de jalamutín infectado",t:24,d:"Ésta es una muestra de sangre obtenida de un jalamutín que estaba lleno de garrapatas.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11218] = {n:"Sobre para Otomai",t:24,d:"Wogew Lewmitanyo te ha encargado que le des este sobre a Otomai. En el hay varios documentos con información importante sobre las garrapatas que atacan a los jalamúts, y también a los wabbits.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[11219] = {n:"Cola del Jalamut Real",t:65,d:"En verano, el Jalamút Real utiliza esta cola para espantar los moskitos. El resto del año no le sirve para nada, así que no es de extrañar que a veces se olvide de que la tiene.",ep:0,g:755,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11221] = {n:"Lana del Jalamut Real",t:57,d:"Nadie sabe exactamente cuando llegaron los jalamúts a Frigost. Lo que sí se sabe es que ya llevan mucho tiempo allá, porque aún se puede encontrar ropa interior hecha con lana de jalamut y transmitida de padres a hijos durante varias generaciones de frigosteños.",ep:0,g:213,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11222] = {n:"Pico de pekegüino",t:47,d:"Cuando no está firmemente pegado a la cabeza del pekegüino, este pico suele estar firmemente clavado en tus nalgas",ep:0,g:662,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11223] = {n:"Pluma de pekegüino",t:53,d:"Antaño, los pekagüinos sólo venían a la Isla de Frigost durante unos días de invierno. Ahora que la isla está helada han decidido quedarse. ¡Una ocasión perfecta para desemplumarlos todo el año!",ep:0,g:646,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11224] = {n:"Ala de barrigüino",t:104,d:"Ni siquiera los frigosteños saben para qué le sirven al barrigüino unas alas tan ridículamente pequeñas... evidentemente, no para volar, ¡ni siquiera para despegar!",ep:0,g:216,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11225] = {n:"Piel de barrigüino",t:59,d:"Es grasienta, parece que no la han lavado nunca y brilla. No, no se trata de tu peluquín, sino de la piel de un barrigüino.",ep:0,g:49,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11226] = {n:"Aceite de mamagüina",t:60,d:"Este aceite se ha extraído del cadáver de una mamagüina. Haces todo lo posible por no recordar lo que tuviste que hacer para obtenerlo.",ep:0,g:72,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11227] = {n:"Pelusa de mamagüina",t:54,d:"A todos los frigosteños les gusta rellenar su ropa interior con bolas de esta pelusa. Algunos dice que se para pasar menos frio... sólo los yopukas se lo siguen creyendo.",ep:0,g:675,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11228] = {n:"Espina gigante de chamángüino",t:47,d:"En Frigost hay muchas preguntas que no tiene respuesta, pero lo que es aún más inquietante, ¡también hay muchas respuestas que no tienen pregunta! ¿Resultado? Nunca sabrás de dónde sacó esta espina el chamángüino.",ep:0,g:663,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11229] = {n:"Pelo de barba de chamángüino",t:54,d:"La barba del chamángüino apesta a pescado y a espuma de acerdar. Los frigosteños aprecian muy particularmente esta deliciosa mezcla, pues sirve como repelente de jalamuts, y también de amigos molestos.",ep:0,g:674,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11230] = {n:"Cola de pingüindos",t:65,d:"No te fíes de su pequeño tamaño, esta cola sabe llegar a su destino sin perderse en el camino.",ep:0,g:753,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11231] = {n:"Oreja de pingüindos",t:106,d:"Como suelen estar ocultas por un pez medio descompuesto, las orejas del pingüindos sólo oyen una cosa: la llamada de compañeras disponibles durante el periodo de reproducción. Por consiguiente puedes reírte del pingüindos a su cara sin correr ningún riesgo, a no ser que te parezcas a una posible compañera...",ep:0,g:625,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11232] = {n:"Pluma del Morsagüino Real",t:53,d:"Los frigosteños respetan mucho al Morsagüino Real, ya que lo ven como un bicho que tiene un título importante, así que es la ocasión de matar algo importante.",ep:0,g:647,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11233] = {n:"Huevo del Morsagüino Real",t:105,d:"No hace falta que finjas estar sorprendido, este enorme huevo ha tenido que salir de algún sitio...",ep:0,g:643,l:135,wd:false,fm:true,w:10,an:0,p:10};
