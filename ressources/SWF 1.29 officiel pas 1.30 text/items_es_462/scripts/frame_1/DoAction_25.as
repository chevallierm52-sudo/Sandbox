I.u[11084] = {n:"Sombrero de Gadjèt",t:16,d:"Gadjèt era uno de los manitas más creativos del Mundo de los Doce, pero por desgracia también uno de los más despistados. Se cuenta que un día hasta confundió entre su yunque y la cabeza de su mujer. “¡Una suerte que los yunques no griten!” dijo al respecto...",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6400};
I.u[11085] = {n:"Cinturón de Gadjèt",t:10,d:"Si te pones este cito del revés y lo aprietas lo bastante fuerte, puede que consigas activar el módulo integrado de retromagia. Nunca ha funcionado correctamente, pero siempre puedes intentar activarlo a ver que pasa... y luego venderle el cinturón a otro igual de inocente que tú.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6358};
I.u[11086] = {n:"Capa de Gadjèt",t:17,d:"Gadjèt fabricó esta capa esperando poder volar con ella. Su objetivo final era escapar más fácilmente de los castigos cotidianos que le administraba su mujer.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6350};
I.u[11087] = {n:"Anillo de Gadjèt",t:9,d:"Muchas generaciones de manitas han usado este anillo, que te protegerá las falanges de los golpes de martillo. Desgraciadamente, no se vende por lotes de cinco.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6453};
I.u[11088] = {n:"Sombrero de Grilyan",t:16,d:"Grilyan era un gran mago, famoso por haber inventado las bolsitas de te impermeables... aunque luego olvidó como fabricarlas.",ep:0,g:0,l:49,wd:false,fm:true,w:10,s:164,p:6325};
I.u[11089] = {n:"Capa de Grilyan",t:17,d:"Esta capa debería ser capaz de protegerte el trasero de las mordeduras de las monstruoplantas.",ep:0,g:0,l:48,wd:false,fm:true,w:10,s:164,p:6250};
I.u[11090] = {n:"Anuncio de busca y captura",t:24,d:"“Se busca: Letalina Sigisbul” pone en la cabezera de este cartel.",ep:0,g:821,l:1,wd:false,fm:true,w:0,p:0};
I.u[11091] = {n:"Botas de Grilyan",t:11,d:"Según parece, el mago Grilyan caombió un anillo mágico por este par de botas. Si esto es cierto, fue una estafa porque estas botas  ni siquiera tienen forro interior.",ep:0,g:0,l:46,wd:false,fm:true,w:10,an:0,s:164,p:5600};
I.u[11092] = {n:"Amuleto de Grilyan",t:1,d:"Grilyan llevaba puesto este amuleto justo en el momento en que... en que... ¿y qué más da? Ahora Grilyan está muerto y su amuleto te pertenece.",ep:0,g:0,l:45,wd:false,fm:true,w:10,s:164,p:5450};
