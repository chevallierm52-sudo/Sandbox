I.u[10979] = {n:"Martillo de Hectopp",t:7,d:"A Hectopp le encantaba ir arrastrando este martillo al andar. Es cierto que era más vago que el sastre de Tarzán, pero lo hacía sobre todo para anunciar su llegada a los rivales.\nEsta arma está impregnada de la magia de Hectopp. Puede que logres encarnarlo al usarla.",ep:0,g:74,l:30,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,50,50,false,false],c:"CA>50",s:158,p:2800};
