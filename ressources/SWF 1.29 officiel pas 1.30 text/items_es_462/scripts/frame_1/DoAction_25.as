I.u[10899] = {n:"Bastón del zoth Manitú",t:4,d:"El zoth Manitú fue funcionario, aplazaba los problemas en lugar de resolverlos. Pero poco importa porque todos los zoths le temían: gritaba más fuerte que ningún otro, y eso es suficiente para ser jefe de los zoths. El alma de Manitú está aún impregnada en este bastón. Quizás puedas encarnarte en él cuando lo utilices.",ep:0,g:91,l:50,wd:false,fm:false,w:10,an:12,e:[5,3,1,1,40,50,false,false],p:6000};
I.u[10900] = {n:"Trozo de cáscara",t:24,d:"Tienes en tu mano uno de los restos de aquellos gigantescos cascarones que salieron en la penínsulita de los dragohuevos. Ni siquiera sirve como cenicero.",ep:0,g:767,l:1,wd:false,fm:true,w:0,p:0};
I.u[10901] = {n:"Colmillo gigante",t:24,d:"Grasmera y Grozilla participaron en un combate épico. Todo lo que ahora queda de ellos es este gigantesco canino. ¿Quién habría creído que tú estuviste presente en el combate?",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:0};
I.u[10902] = {n:"Tanga del zoth Manitú",t:24,d:"Ahora puedes decir sin temor a equivocarte que el zoth Manitú anda en cueros sin su taparrabos.",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10903] = {n:"Llave del antro del zoth Manitú",t:24,d:"Esta llave te abrirá la puerta para luchar contra el zoth Manitú.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[10904] = {n:"Grozillamu",t:1,d:"Este amuleto demuestra tu indudable capacidad para romper los huevos sin hacerlos tortilla.",ep:0,g:157,l:51,wd:false,fm:true,w:10,p:7050};
I.u[10906] = {n:"Escudo dragónico",t:82,d:"Este escudo está hecho con una escama de Grozilla, es muy pesado pero tiene una calidad excepcional. Sólo los luchadores más increíbles pueden lucir este gran escudo.",ep:0,g:51,l:1,wd:false,fm:false,w:10,p:0};
I.u[10908] = {n:"Regalo: del beta-test de mazmorras de DOFUS 2.0",t:89,d:"Te has ganado este Regalo: por haber pasado más tiempo en las mazmorras de la beta de DOFUS 2.0 que el común de los mortales.",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10909] = {n:"Feromona de tofu",t:48,d:"Esta feromona disecada y en polvo, podría atraer a un tofu a kilómetros de distancia...¡si tus propias feromonas no lo asfixian antes!",ep:0,g:241,l:1,wd:false,fm:true,w:1,p:1};
I.u[10910] = {n:"Regalo: DOFUS 2.0 edición de coleccionista",t:89,d:"¡IMPORTANTE! ESTE Regalo: SÓLO PUEDES ABRIRLO EN UN SERVIDOR DOFUS 2.0.\nEste set te volverá hasta inteligente, a condición de que no digas ni \"mu\". Y si no funciona, por lo menos servirá para que impresiones a las habitantes de Astrub.",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10911] = {n:"Pócima de recuerdo de Mr. Scuty",t:12,d:"La «Pócima de recuerdo de Mr. Scuty», que es mucho más untuosa y sabrosa que una pócima de recuerdo clásica, te llevará al zaap de Astrub sin importar donde estés. Su doble efecto te garantiza un uso más prolongado y que dura más, mucho más tiempo.\nLa «Pócima de recuerdo de Mr. Scuty» es una marca registrada, propieda de las empresas Kyrc & Spuky.",ep:0,g:26,l:1,wd:false,fm:false,w:0,c:"Sc=666",u:true,p:0};
I.u[10912] = {n:"Regalo: de Nawidad porquería",t:89,d:"No todos los regalos de Nawidad tienen el mismo tamaño. Los aventureros que no han sabido ser lo suficientemente temerarios se llevan a casa una porquería de regalos y el derecho a llorar por haber sido el blanco de todas las burlas.",ep:0,g:2,l:6,wd:false,fm:true,w:10,u:true,p:1};
I.u[10913] = {n:"Regalo: de Nawidad normalucho",t:89,d:"El que hizo este Regalo: no se esmeró demasiado. «Con que sea nomaluscho bastará» -se decía a si mismo.",ep:0,g:2,l:7,wd:false,fm:true,w:20,u:true,p:1};
I.u[10914] = {n:"Regalo: de Nawidad potencialmente superpoderoso",t:89,d:"Según pone en la etiqueta sujeta con el lazito, éste puede ser un gran regalo. Sin embargo, todos los aventureros te dirán que nunca hay que fiarse en lo que pone en las etiquetas de los lazitos.",ep:0,g:2,l:8,wd:false,fm:true,w:30,u:true,p:1};
I.u[10915] = {n:"Órdenes de misión de Félix Nawidad",t:24,d:"Félix Nawidad te ha desvelado la identidad de uno de los ladrones del almacen de Papá Nowel. Si no consigues vencerlo en las siguientes dos horas, podrás volver a ver a Félix Nawidad para que te dé nuevas órdenes de misión.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10916] = {n:"Agradecimiento de Félix Nawidad",t:24,d:"Félix Nowel ha apreciado tu victoria y te da las gracias. Vuelve a verlo dentro de 24 horas, volverá a necesitar tu ayuda si no ha recuperado todas las cajas.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10917] = {n:"Caja pequeña de regalos",t:24,d:"Esta cajita llega directamente del almacén de Papá Nowel. Si se la devuelves a su dueño, serás un héroe.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10918] = {n:"Caja de regalos",t:24,d:"Esta caja llega directamente del almacén de Papá Nowel. Si se la devuelves a su dueño, serás un héroe.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10919] = {n:"Caja grande de regalos",t:24,d:"Esta gran caja llega directamente del almacén de Papá Nowel. Si se la devuelves a su dueño, serás un héroe.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10920] = {n:"Galletas de Nawidad",t:24,d:"Éstas sí que son una galletas preparadas con amor y esmero. Una pena que no puedas probarlas.",ep:0,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[10921] = {n:"Regalo: sellado del Minotobola",t:24,d:"Nadie sabe lo que contiene este regalo, el Minotobola se llevó el secreto a la tumba. ¿Hay que recordarte que es culpa tuya? La verdad es que te portaste como un boludo...",ep:0,g:715,l:1,wd:false,fm:true,w:0,p:1};
