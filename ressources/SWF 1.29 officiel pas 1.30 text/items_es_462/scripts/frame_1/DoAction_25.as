I.u[11041] = {n:"Espada Hondbaz",t:6,d:"Pesada, poco manejable, desafilada y fea. Manejar esta espada no te hará más fuerte ni más temible, sólo más ridículo. Al verla uno se pregunta cómo ha hecho Gúltar para ser tan temible manejando una espada tan mediocre.",ep:0,g:99,l:40,wd:false,fm:true,w:10,an:14,e:[6,4,1,1,40,40,false,false],s:159,p:4000};
I.u[11042] = {n:"Cordón Periñón",t:10,d:"Gúltar recibió este cinturón de manos de su padre, cuando tan sólo tenía 5 años. A pesar de su aspecto simple, este cinto te mantendrá el pantalón a la altura de la cadera. Además, puede servir de cuerda para tender la ropa o ¡hasta de comba!",ep:0,g:175,l:40,wd:false,fm:true,w:10,s:159,p:4300};
I.u[11043] = {n:"Gorro Kalipsis",t:16,d:"Este gorro va tan prieto que comprime el cráneo y provoca alucinaciones. Por suerte, Gúltar sólo lo llevaba de joven, y además de poco relleno, su cráneo era pequeño. Esto delata sus orígenes...",ep:0,g:265,l:41,wd:false,fm:true,w:10,s:159,p:4500};
I.u[11044] = {n:"Restos de la familia de Gúltar",t:24,d:"Huesos, polvo y alguna joya mortuoria, esto es todo lo que transportas.",ep:0,g:818,l:1,wd:false,fm:true,w:0,p:0};
I.u[11045] = {n:"Capa Stinencia",t:17,d:"Gúltar llevó esta capa hasta que conoció a las tres hermanas. Luego la olvidó en el fondo de un armario.",ep:0,g:179,l:43,wd:false,fm:true,w:10,s:159,p:5050};
I.u[11046] = {n:"Collar maldito de Cabotina",t:24,d:"Con lo potente que es el aura maléfica de este collar, te cuesta muchísimo no deshacerte de él.",ep:0,g:819,l:1,wd:false,fm:true,w:0,p:0};
I.u[11047] = {n:"De Rorc",t:32,d:"De Rorc se ha rendido, llévaselo preso a Letalina.",ep:0,g:29,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11048] = {n:"Pistas para DarkVlad",t:24,d:"Un plano muy sencillo y una pócima de inteligencia. Con esto,  incluso Dark Vlad debería ser capaz de salir de su laberinto.",ep:0,g:820,l:1,wd:false,fm:true,w:0,p:0};
