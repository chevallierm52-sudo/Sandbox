I.u[11009] = {n:"Hormona de miaumiau de las nieves",t:48,d:"Esta hormona de crecimiento deshidratada se puede utilizar en la elaboración de una potente pócima que mejorará a tu mascota.",ep:0,g:262,l:1,wd:true,fm:true,w:1,p:10};
