I.u[11190] = {n:"Regalo: Amuleto del YeCh\'Ti",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti. Atención, este regalo sólo puede abrirse en DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11191] = {n:"Botas del mazmorreitor",t:11,d:"Tienen las suelas desgastadas, pero son muy cómodas. Estas botas han pisado el suelo de las mazmorras más escabrosas y la cabeza de las criaturas más tenebrosas.",ep:0,g:162,l:73,wd:true,fm:true,w:10,an:0,p:13700};
I.u[11192] = {n:"Regalo: Mazmorreitor",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti. Atención, este regalo sólo puede abrirse en DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11193] = {n:"Tabla de álamo temblón",t:95,d:"Con esta plancha, los manitas pueden construir cosas de madera como, por ejemplo, un sarcófago de madera.",ep:0,g:23,l:100,wd:false,fm:true,w:10,p:10};
I.u[11194] = {n:"Harina de sucaritazz",t:52,d:"Esta harina tiene la particularidad de disolverse en la leleche, dándole así un peculiar sabor a chocolate. Los habitantes de una antigua isla desaparecida, adeptos de los postres con gelatina, preferían disolverla en agua.",ep:0,g:260,l:100,wd:false,fm:true,w:1,p:1};
I.u[11195] = {n:"El guesfguiado",t:30,d:"Tendrías que ir a que te curen, antes de que se agrave tu caso.",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11196] = {n:"Kama de hielo",t:24,d:"Como la falta de metal no les permitía acuñar más moneda, los frigsteños decidieron acuñar sobre hielo y usar estas monedas para el intercambio local. Esta moneda no tienen ningún valor al exterior de la isla.",ep:0,g:825,l:1,wd:false,fm:true,w:0,p:1};
I.u[11197] = {n:"La guinitis",t:30,d:"La campaña de vacunación contra esta enfermedad ya le ha costado al burgo de Frigost la módica suma de 2.000 millones de kamas y no ha dado ningún resultado concluyente. Cualquiera creería que a los frigosteños les gusta tirar el dinero por la ventana.",ep:0,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11198] = {n:"Vacuna contra el catago",t:24,d:"Esta vacuna te protege eficazmente contra el guesfguiado, pero sus efectos se disipan muy rápido así que tendrás que renovarla cada semana.",ep:0,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[11199] = {n:"Grano de sucaritazz",t:58,d:"Este grano, frío al contacto, desprende un fuerte olor a cacao.",ep:0,g:0,l:100,wd:false,fm:true,w:1,p:1};
I.u[11200] = {n:"Regalo: Escudo HispáÑico",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti. ",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[11201] = {n:"Muestra de sangre de jalamut",t:24,d:"Le has sacado esta muestra de sangre a un jalamut que tenía un guesfguiado.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11202] = {n:"Agua de mar isotónica",t:24,d:"Albert Pess necesita esta agua para su trabajo buscando una vacuna para el guesfguiado.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[11203] = {n:"Altamisa",t:24,d:"Dadas sus propiedades, este hierbajo les resulta muy útil a los alquimistas, a los aniripsas y a los alquimistas aniripsas. Una planta análoga a esta también sirve para confeccionar un licor muy apreciado por los marineros, los anutrofs y los marineros anutrofs.",ep:0,g:103,l:1,wd:false,fm:true,w:0,p:1};
I.u[11204] = {n:"Muestra de sangre de La Bestia",t:24,d:"Te ha costado, pero al final has conseguido extraer esta muestra de sangre. Esperemos que resulte tan útil que valga la pena tanto esfuerzo.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
