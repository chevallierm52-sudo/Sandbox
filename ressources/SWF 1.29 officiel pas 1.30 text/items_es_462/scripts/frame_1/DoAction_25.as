I.u[10984] = {n:"Amuleto del YeCh\'Ti",t:1,d:"Al colgar de tu cuello sobre tu pecho imberbe podrás aparentar ser tan peludo como el YeCh\'Ti, lo que puede llegar a asustar a tus enemigos.",ep:0,g:162,l:66,wd:false,fm:false,w:10,an:0,p:11500};
I.u[10985] = {n:"Miaumiau de las nieves",t:18,d:"Este miaumiau ha conocido las más duras nieves del Mundo de los Doce. Nadie sabe cómo ha llegado a Amakna, pero los ancianos comentan que alguien lo trajo desde la Isla de Frigost, donde todo el año es desiembro, para luchar contra la proliferación de wabbits. Esta mascota devoradora de almas sólo come wabbits.",ep:0,g:62,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10986] = {n:"Fantasma de miaumiau de las nieves",t:90,d:"Este miaumiau de las nieves aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:62,l:1,wd:true,fm:true,w:1,p:1};
