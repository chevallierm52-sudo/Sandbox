I.u[10809] = {n:"Pócima de mejora de dragún dorado",t:116,d:"Si utilizas esta potente pócima aumentarás las capacidades de tu mascota de forma definitiva. Ojo, tu mascota sólo puede asimilar una dosis... si le das más, puede que eso provoque resultados muy decepcionantes.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PO=10802",u:true,p:10};
I.u[10810] = {n:"Hormona de buscador de ogrinas",t:48,d:"Esta hormona de crecimiento deshidratada se puede utilizar en la elaboración de una potente pócima que mejorará a tu mascota.",ep:0,g:234,l:1,wd:false,fm:true,w:1,p:10};
I.u[10811] = {n:"Pócima de mejora de buscador de ogrinas",t:116,d:"Utilizando esta potente pócima aumentarás las capacidades de tu mascota de forma definitiva. Ojo, tu mascota solamente puede asimilar una dósis... si le das más, puede que eso provoque resultados muy decepcionantes.",ep:0,g:54,l:1,wd:true,fm:true,w:1,c:"PO=10657",u:true,p:10};
I.u[10812] = {n:"Mensaje anónimo",t:24,d:"«Si buscas un trabajo fácil y bien pagado, ven a verme al norte de la ciudad, al este de la estatua de Sram. Ven solo.»",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10813] = {n:"Lista de nombres",t:24,d:"Encontraste esta lista en la casa de Prandacilla Dragcuin. Parece que se trata de pandawas.",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10814] = {n:"Caja para Pandilla",t:24,d:"Debes llevarle esta caja a Pandilla, que estará en el pueblo de Akwadala. No tienes ni idea de lo que puede haber dentro.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10815] = {n:"Líquido extraño",t:24,d:"Essel Dawa te ha pedidio que solicites la ayuda de Mago de Zo para analizar este líquido.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[10816] = {n:"Pétalo marchito de rosa demoníaca",t:24,d:"Este pétalo arrugado ha perdido su esplendor. De hecho, su textura actual recuerda a la piel de los anutrofs.",ep:0,g:817,l:1,wd:false,fm:true,w:0,p:1};
I.u[10817] = {n:"Anti-adicción",t:24,d:"Este prototipo de antidoto deberia poder curar la adiccion al zumo de stropajo.",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[10818] = {n:"Hacha de novato",t:19,d:"Esta arma, aparentemente rudimentaria, te dará la impresión de saber luchar.",ep:0,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[10825] = {n:"Ghulificado",t:30,d:"¿Tantos esfuerzos para acabar así?",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10826] = {n:"Orden de exulsión",t:24,d:"Como no te has portado bien con tu anfitrión, ha decidido cerrarte el acceso a su cripta durante las próximas 24 horas.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:0};
I.u[10827] = {n:"Pócima de curación larvesca",t:12,d:"Un líquido anaranjado y burbujeante. ¿Quién podría beberse algo así?",ep:0,g:192,l:1,wd:true,fm:true,w:1,c:"Sc=7",u:true,ut:true,p:0};
I.u[10828] = {n:"Casco de jálabol",t:16,d:"Se dice que el ridículo nunca mato a nadie. Cierto, pero con este casco parecerás realmente ridículo.",ep:0,g:253,l:29,wd:false,fm:true,w:10,c:"Sc=10",p:2400};
I.u[10829] = {n:"Caña Peskamas",t:20,d:"Gracias a este bastón, saldrás ganando en todos los regateos.",ep:0,g:91,l:40,wd:false,fm:true,w:10,an:12,e:[7,3,1,1,40,50,false,false],c:"Sc=13",p:4200};
I.u[10830] = {n:"Capa banana",t:17,d:"¿Llevas una capa banana en el bolsillo o es sólo que te alegras de verme?",ep:0,g:172,l:28,wd:false,fm:true,w:10,c:"Sc=14",p:2305};
I.u[10831] = {n:"Bananaranja",t:46,d:"Flambeada o en rodajas, bañada de chocolate o al natural, esta fruta es un postre delicioso, la tomes como la tomes.",ep:0,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[10832] = {n:"Crujirroca",t:94,d:"Esta brillante piedra encierra un crujibola de pocas luces. Pareece que sólo podrás utilizarla cerca de otros cruijdores o crujibolas...",ep:0,g:18,l:1,wd:false,fm:true,w:20,c:"Sc=15&(PB=2|PB=96|PB=480)",u:true,p:0};
I.u[10833] = {n:"Miaullleta",t:33,d:"Esta galleta es muy extraña: cuando la muerdes, ¡maulla!",ep:0,g:4,l:1,wd:false,fm:true,w:2,c:"Sc=16",u:true,ut:true,p:0};
I.u[10834] = {n:"Ushanka Guau",t:16,d:"Tampoco necesitas gran cosa para parecerte a un uginak. ¡Cuidado con las pulgas!",ep:0,g:256,l:11,wd:false,fm:true,w:10,c:"Sc=17",p:530};
I.u[10835] = {n:"Marca de novato",t:50,d:"Pisoteado, mordisqueado, aplastado, lavado, secado y planchado. Te las han dado por todos lados. Ya no sólo te duele el cuerpo, ¡te duele hasta el ego!",ep:0,g:707,l:1,wd:false,fm:true,w:1,p:0};
I.u[10836] = {n:"Jalaboleto",t:1,d:"Llevas con orgullo este amuleto, símbolo de tu participación en esta gran manifestación deportiva. Es lo minimo para conservar un poco de orgullo después de haber acabado bajo la melé del J.C. Trool.",ep:0,g:158,l:64,wd:false,fm:true,w:1,c:"Sc=18",p:11765};
I.u[10838] = {n:"Anaranjado",t:30,d:"¡Esto te pasa por beber cosas raras sin saber lo que hay dentro!",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10839] = {n:"Don Bollo",t:33,d:"Uno puede dejarse los dientes en un bollo si está muy duro. Si quieres probarlo, ¡allá tú!",ep:0,g:12,l:1,wd:false,fm:true,w:100,c:"Sc=8",u:true,p:0};
I.u[10840] = {n:"Don Bollo comestible",t:33,d:"Esté esta más blando. ¡Qué aproveche!",ep:0,g:12,l:1,wd:true,fm:true,w:1,c:"Sc=8",u:true,ut:true,p:0};
I.u[10841] = {n:"Marrón",t:30,d:"¿Nadie te avisó de los efectos secundarios?",ep:0,g:1,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10842] = {n:"Transformación en miaumiau",t:31,d:"Tenía que pasar y ha pasado. ¡Ahora no vengas quejándote cuando vomites bolas de pelos!",ep:0,g:21,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=16",p:0};
I.u[10843] = {n:"Nota sobre Krtek",t:24,d:"Has anotado a qué hora fue la paliza a Krtek. Así, sabrás cuándo volver para darle otra.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10844] = {n:"Mmmmm",t:31,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmmm mmmmm mmmm mmmmmmm.",ep:0,g:19,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[10846] = {n:"Ferocapa",t:17,d:"Cada vez que te cruzas con un tofu quiere frotarse contra tu pierna como si estuviese preso de un extraño frenesí. ¿No será esta capa la que les atrae?",ep:0,g:173,l:61,wd:false,fm:true,w:10,c:"Sc=19",p:9700};
I.u[10847] = {n:"Botas de Ravelaca",t:11,d:"Ravelaca se ponía estas botas una vez al año, pero se las quitaba todos los días al acostarse. De esto se deduce que estas botas son mágicas.",ep:0,g:151,l:53,wd:true,fm:true,w:10,s:152,p:7400};
I.u[10848] = {n:"Botas de Kunye",t:11,d:"Estas botas tan coquetas pueden servirte de yunque. Su anterior propietario te recomienda que no bailes con ellas.",ep:0,g:152,l:52,wd:false,fm:true,w:10,s:153,p:7175};
I.u[10849] = {n:"Cinturón de Ravelaca",t:10,d:"Este cinturón fue fabricado sobre un armazón metálico imantado que atrae las bolsas de los imprudentes que osan acercarse demasiado.",ep:0,g:169,l:51,wd:true,fm:true,w:10,s:152,p:6825};
I.u[10850] = {n:"Cinturón de Kunye",t:10,d:"Kunye tenía muchas debilidades: las araknas, las cosquillas, y las araknas cosquillosas.",ep:0,g:167,l:52,wd:false,fm:true,w:10,s:153,p:7100};
I.u[10851] = {n:"Cinturón de Napazam",t:10,d:"Este cinturón aún está recubierto de harina. Quizás porque Napazam, el panadero oscuro, lo utilizaba como delantal. Esperemos que no sea la harina con la que se enharinaba el trasero.",ep:0,g:168,l:51,wd:false,fm:true,w:10,s:154,p:6928};
I.u[10852] = {n:"Amuleto de Ravelaca",t:1,d:"Ravelaca le robó este amuleto a Odirruba, un goblin al que no le hacía gracia ningún chiste (ni siquiera los buenos).",ep:0,g:156,l:53,wd:true,fm:true,w:10,s:152,p:7405};
I.u[10853] = {n:"Amuleto de Napazam",t:1,d:"Con este amuleto podrás amasarte la piel del cuello sin utilizar las manos.",ep:0,g:155,l:53,wd:false,fm:true,w:10,s:154,p:7400};
I.u[10854] = {n:"Anillo de Kunye",t:9,d:"Kunye, el herrero, cambio este anillo por un espada que perteneció a Dam Antium.",ep:0,g:183,l:54,wd:false,fm:true,w:10,s:153,p:7650};
I.u[10855] = {n:"Anillo de Napazam",t:9,d:"Este anillo lo han introducido en una mezcla de una gran cantidad de levaduras diferentes y hasta se dice que tiene la capacidad de transformar en moho a aquellos que lo lucen. Pero algunos aventureros no ven el cambio...",ep:0,g:184,l:51,wd:false,fm:true,w:10,s:154,p:6975};
I.u[10856] = {n:"Hacha de Ravelaca",t:19,d:"Ravelaca era un pésimo bandido al que le remordía la conciencia y por eso tenía que devolver todo lo que robaba. El alma del bandido Ravelaca está aún impregnada en esta arma mágica. Si la equipas, quizás consigas encarnarte en él.",ep:0,g:58,l:47,wd:true,fm:false,w:10,an:17,e:[5,4,1,1,40,50,false,false],s:152,p:5900};
I.u[10857] = {n:"Martillo de Kunye",t:7,d:"Con este martillo se forjó una bragueta de kriptonita para el capitán Chafer. El alma del herrero oscuro Kunye esta aún impregnada en esta arma. Si la equipas, quizás te encarnes en él.",ep:0,g:724,l:51,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,40,50,false,false],s:153,p:7000};
I.u[10858] = {n:"Vaguita de Napazam",t:3,d:"El célebre francés Napazam solía decir: «La mejog manega de gesolveg los pgoblemas es gepagtig pan pan panes. Con mi vaguita impondgé ogden». Y lo cierto es que se servía de esta arma para castigar a los inocentes. La magia de Napazam, el panadero oscuro, está aún impregnada en este arma. Quizás consigas encarnarte en él al utilizarla.",ep:0,g:73,l:53,wd:false,fm:false,w:10,an:11,e:[5,4,3,5,50,50,false,false],s:154,p:5000};
I.u[10860] = {n:"Pócima de cambio de nombre",t:12,d:"Con esta pócima podrás cambiar de nombre, así ya nadie se acordará de que hubo un tiempo en que te llamaste Xx-naruto-killer-feca-xX. Podrás disfrutar de una nueva vida, sin bromas de mal gusto, y por fin llegar a ser alguien.",ep:0,g:718,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10861] = {n:"Pócima de cambio de colores",t:12,d:"En la etiqueta se puede leer: «¿Cansado de que te traten de viejo verde? ¿Te gustaria que te vieran como a un príncipe azúl? ¡¡Pues no lo pienses más y usa esta pócima!!».",ep:0,g:717,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10862] = {n:"Pócima de cambio de sexo",t:12,d:"Esta pócima, que se bebe a morro, te hará que seas él si eres ella o que seas ella si eres él.\n¡Atención! El abuso de su consumo no perjudica la salud.",ep:0,g:719,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10863] = {n:"Araknuza",t:18,d:"Esta arakna es realmente malvada, insulta, grita, salta por todos lados y hasta morderá a quien se descuide, pero tú la quieres mucho aunque no sepas por qué. La naturaleza la ha dotado de un apetito feroz, a este devorador de almas le encanta atacar y a los moskitos y a las larvas.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10864] = {n:"Miscaludo",t:18,d:"Éste no es un champi champ como los demás. Se crió  junto a una jauría de mediulubos, aunque eso no explica por qué tiene tantos pelos en el sobaco... A este devorador de almas le encanta el marisco y sólo comerá criaturas de las playas.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10865] = {n:"Tofucilazo",t:18,d:"A este tofu ya le han caído 11 rayos en la cabeza. Si lo acaricias te dará calambres, pero si no lo acaricias, es capaz de fulminarte... ¡Tú eliges! Este devorador de almas odia a las ratas y se las zampa en cuanto se le presenta la ocasión.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10866] = {n:"Otazo",t:18,d:"A esta mascota le gustan las alcachofas con sangre de rasgabola, las endivias con pelos de tufo y las canciones de Badiz Mustabante. También parece gustarle tu compañía. Este devorador de almas sólo se alimenta de las criaturas de La Oscura Jungla.",ep:0,g:61,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10867] = {n:"Fantasma de araknuza",t:90,d:"Esta araknuza aún no ha dejado el mundo de los vivos, te toca encontrar la forma de resucitarlo o de abandonarlo definitivamente como buen cobarde que eres.",ep:0,g:57,l:1,wd:true,fm:true,w:1,p:1};
