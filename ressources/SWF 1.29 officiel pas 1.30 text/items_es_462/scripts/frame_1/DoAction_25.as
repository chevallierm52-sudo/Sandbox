I.u[11174] = {n:"Llave de la Mazmorra de los Jalamúts",t:84,d:"Con esta llave podrás entrar en el invernáculo donde se esconde el Jalamut real.",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[11175] = {n:"Llave de la Mazmorra de los Güinos",t:84,d:"Los güinos utilizan esta llave porque tiene la peculiaridad de flotar sobre el agua salada. Con ella podrás entrar en su mazmorra.",ep:0,g:255,l:1,wd:false,fm:true,w:1,p:1};
