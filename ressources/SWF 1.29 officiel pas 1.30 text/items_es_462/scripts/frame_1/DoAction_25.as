I.u[10871] = {n:"Regalo: araknuza",t:89,d:"Si agitas este regalo, te darás cuenta de que la caja no está vacía. Puede que por una vez los dioses no se hayan reído de ti.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
