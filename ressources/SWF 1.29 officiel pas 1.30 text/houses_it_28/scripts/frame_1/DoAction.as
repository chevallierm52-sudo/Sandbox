H.h[66] = {n:"Casa Piccola di paglia",d:"Questa piccola casa dal tetto di paglia piacerà molto agli appassionati di pesca perché è vicina al fiume. Ha un piano, ma per salirci bisogna usare la scala messa gratuitamente a disposizione dal proprietario, purtroppo la scalinata non è compresa in questo tipo di case."};
H.h[67] = {n:"Casa Piccola di paglia",d:"Questa piccola casa dal tetto di paglia piacerà molto agli appassionati di pesca perché è vicina al fiume. Ha un piano, ma la scalinata non è compresa, bisognerà usare la scala messa gentilmente a disposizione."};
H.h[68] = {n:"Casa Piccola",d:"Questa piccola casa ha solo un piano abitabile, il granaio non è più accessibile da quando ci abita una famiglia di ratti."};
H.h[69] = {n:"Casa a due piani",d:"Questa casa ha due piani e piacerà sicuramente a coloro che organizzano grandi feste, ma non piacerà per niente a chi odia salire le scale."};
H.h[70] = {n:"Casa a un piano",d:"Questa casa è vicina al fiume e al villaggio, posizione che compensa il fatto di avere un solo piano. Attenzione però, quando il fiume è in piena, il pianterreno è spesso inondato."};
H.h[74] = {n:"Casa vicino alla bottega",d:"Questa piccola casa ha un piano, il suo vantaggio principale risiede nel fatto di essere situata accanto alla bottega di Séline e Charlotte e a pochi passi dal centro del villaggio. Piacerà alle coppie che amano tuttavia conservare un po\' d\'intimità grazie ai due letti separati del primo piano."};
H.h[75] = {n:"Capanna della Fontana",d:"Questa capanna ha solo un piano, ma è situata sulla piazza della fontana, luogo ideale per chi ama mostrare i propri beni al popolo."};
H.h[76] = {n:"Caseggiato della Fontana",d:"Questo caseggiato a due piani apparteneva a un ricchissimo notaio che lo ha lasciato vuoto dopo essere scomparso in circostanze misteriose."};
H.h[77] = {n:"Caseggiato vicino alla Taverna",d:"Questo caseggiato che dispone di un solo piano è apprezzato moltissimo dai birraioli che non riescono a ritrovare la via di casa dopo essersi dilungati troppo tempo alla Taverna. Infatti, questo caseggiato si trova a pochi passi dalla Taverna."};
H.h[78] = {n:"Grande Casa di Maestro",d:"Questa casa dei Maestro, che ha tre stanze e un piano, è indubbiamente destinata alle persone più ricche di Amakna. È comunque abbastanza grande per ospitare più famiglie sempre che accettino di vivere in comune, un po\' come le formiche."};
H.h[79] = {n:"Caseggiato della Panetteria",d:"Questo caseggiato a un piano era un tempo usato da una famosa panettiera come negozio. Ora completamente ristrutturato a norma di legge, questo caseggiato non ha niente da invidiare alle altre abitazioni in termini di confort."};
H.h[80] = {n:"Capanna della Panetteria",d:"Questa capanna a un piano apparteneva a una famosa panettiera cui il nome resta sconosciuto. È la casa ideale per ogni Panettiere o Panettiera che si rispetti."};
H.h[81] = {n:"Casa vicino al Tempio Xelor",d:"Questa piccola casa ha solo una stanza, ma ha il vantaggio di essere situata vicino al tempio Xelor e alla panetteria."};
H.h[82] = {n:"Capanna vicino al Tempio Xelor",d:"Questa capanna a un piano è situata proprio davanti al tempio Xelor, quindi è la postazione ideale per i seguaci di Xelor."};
H.h[83] = {n:"Capanna del Sarto",d:"Questa capanna a un piano apparteneva al sarto più famoso di Amakna, Elvis Tros, specialista nella confezione di pantaloni blu."};
H.h[84] = {n:"Casetta di Bowis",d:"Questa splendida piccola casa è stata costruita da Bowis il Ciabattino in persona, per cui è delle costruzioni più famose di Amakna. È sicuramente il luogo più visitato dai turisti dopo la panetteria di Xavier il Panettiere."};
H.h[85] = {n:"Capanna dei Pappatutto",d:"Questa affascinante capanna ha un piano. È spesso circondata da Pappatutto affamati, ma la sua vicinanza al tempio Kanojedo le conferisce comunque un interesse particolare agli occhi degli avventurieri principianti."};
H.h[87] = {n:"Capanna vicino alla bottega Ocra",d:"Questa capanna a un piano era la dimora di Edridge Valling prima che si trasferisse a vivere nel granaio del suo negozio. I muri sono ancora tutti bucherellati dagli impatti delle frecce, che danno alla capanna un certo fascino. "};
H.h[88] = {n:"Casa vicino al deposito Ocra",d:"Questa piccola casa ha una sola stanza, ma è molto cara a causa della vicinanza con il negozio di Edridge Valling. Infatti, molti sono i corteggiatori di Edridge che l\'hanno comprata per frequentarla più più spesso."};
H.h[89] = {n:"Chalet della Fonderia",d:"Questo chalet in legno, ha un piano ed è situato vicino alla fonderia. Gli appassionati di metalli in fusione non saranno delusi da questa casa. Attenzione però, la zona è spesso infestata da Pappatutto."};
H.h[90] = {n:"Baracca del Marinaio",d:"Questa baracca ha una sola stanza ma è posizionata molto bene. È riparata dai venti più forti e la sua esposizione ad est le permette di approfittare ogni giorno del sole mattutino. E come tutti sanno, farsi accarezzare la pelle dal sole del mattino, non ha prezzo."};
H.h[91] = {n:"Capanna del Pescatore",d:"Questa capanna che ha una sola stanza è stata classificata costruzione storica. Qui, infatti, Francisco Kabrul, il celebre Menestrello Forgiatore di Asce, ha scritto la maggior parte delle sue canzoni."};
H.h[92] = {n:"Dimora del Pescatore",d:"Questa dimora che ha una sola stanza non avrebbe niente di orgininale se non fosse che il famoso Bowis vi ha passato la maggior parte della sua infanzia."};
H.h[93] = {n:"Casetta del Pescatore",d:"Questa piccola casa di pescatori ha solo una stanza e la facciata dovrebbe essere ristrutturata, ma ha il suo fascino."};
H.h[94] = {n:"Capanna del Pescatore",d:"Questa capanna da pescatore ha un piano. Tempo fa era utilizzata come deposito di granchi."};
H.h[95] = {n:"Caseggiato Scafo",d:"Questo vecchio caseggiato ha un piano. Apparteneva al Capitano Iglut, prima che ottenesse un\'alloggio di servizio all\'interno delle mura della prigione."};
H.h[96] = {n:"Piccola baracca vicino al porto",d:"Questa piccola baracca ha una sola stanza, ma dalla parte del mare, questo rende possibile l\'ascolto della risacca per tutto il giorno, e aiuta a distrarsi."};
H.h[97] = {n:"Grande Casa Scafo del porto",d:"Questa grande casa con il tetto a scocca di nave ha tre stanze, è quindi una casa di Maestro. La vicinanza all\'acqua permette, in caso di eccesso, di versare la spazzatura direttamente nel mare senza aspettare il giornio di raccolta rifiuti. Una visione un po\' particolare del confort, insomma."};
H.h[109] = {n:"Casa della Ferrovia",d:"Questa piccola casa ha una sola stanza. Apparteneva a un vecchio capostazione, Hassan Séhef, che l\'ha lasciata dopo che la ferrovia è stata abbandonata."};
H.h[110] = {n:"Casa Piccola vicino ai binari",d:"Questa piccola casa ha solo una stanza. Apparteneva a un vecchio minatore che andava a lavoro in un piccolo carrello da minerali."};
H.h[111] = {n:"Caseggiato dei Pappatutto",d:"Questa casa dal tetto di paglia ha un piano piuttosto ben arredato, bisogna riconoscerlo. Il vecchio proprietario aveva l\'abitudine di nutrire i Pappatutto che passavano davanti alla casa mettendoli così all\'ingrasso per parecchi mesi, poi li sgozzava con vecchie daghe arrugginite. Una specie di rituale abbastanza particolare."};
H.h[112] = {n:"Casetta dei Pappatutto",d:"Questa casetta ha una sola stanza, ma è comunque molto ambita perché la presenza di un branco di Pappatutto selvatici la rende molto interessante agli occhi degli amatori di Pappatutto."};
H.h[113] = {n:"Casa dei Funghi",d:"Questa piccola casa ha solo una stanza. Apparteneva a un vecchio Alchimista che usava molti funghi per le sue pozioni dagli effetti troppo spesso sottovalutati. Attenzione, i funghi che vi crescono attorno sono spesso pericolosi, a volte persino aggressivi."};
H.h[114] = {n:"Casa Piccola vicino alla piazza",d:"Questa piccola casa di marinai è situata in un luogo molto frequentato dai turisti, non adatto alle persone che cercano tranquillità ma può essere la scelta adatta per le persone a cui mancano amici di passaggio."};
H.h[115] = {n:"Casa Piccola vicino alla piazza",d:"Questa piccola casa di marinai ha solo una piccola stanza, è adatta alle persone poco materialiste e che sanno accontentarsi di poco senza dare tanto peso al confort come elemento essenziale nell\'acquisto di una casa."};
H.h[116] = {n:"Casa Piccola vicino alla piazza",d:"Questa casa di marinai non ha che una sola stanza ma, per ragioni sconosciute, ha la reputazione di facilitare la fecondità delle coppie che ci vivono. L\'unico letto e le sue modeste dimensioni giocano evidentemente un ruolo importante in questa diceria."};
H.h[117] = {n:"Casa Piccola vicino alla piazza",d:"Questa piccola casa di pescatori è ben piazzata, infatti è proprio accanto alla fontana del porto. Purtroppo ha solo una stanza ma questo difetto è compensato dal prezzo che è ragionevole per una casa di questo tipo."};
H.h[118] = {n:"Casa Scafo vicino alla piazza",d:"Questa casa a un piano con il tetto a scocca di nave è situata nei pressi della piazza del porto, proprio davanti alla fontana, posizione che interesserà soprattutto i mercanti che in tal modo non avranno molta strada da fare per andare al porto a vendere all\'asta."};
H.h[119] = {n:"Casa Scafo del porto",d:"Questa casa con il tetto a scocca di nave ha un piano da cui si gode vista sul faro, piacerà sicuramente ai più romantici abitanti di Amakna che amano sedurre approfittando della luce del faro per creare esplicite ombre cinesi, e dio solo sa quanti ce ne sono."};
H.h[120] = {n:"Casa Piccola del porto",d:"Questa piccola casa ha solo una stanza, ma è così affascinante che i turisti non resistono alla tentazione di comprarla. Il fatto che il bagno si affacci direttamente sul mare forse c\'entra qualcosa."};
H.h[122] = {n:"Casa del guardiano di Kanojedo",d:"Questa casa ha solo una stanza abitabile (il granaio è ormai inutilizzabile a causa di un\'invasione di termiti mangiategole). Situata proprio accanto al tempio Kanojedo, è generalmente riservata ai guardiani del tempio."};
H.h[123] = {n:"Casa Piccola vicino al ponte",d:"Questa casa ha solo una stanza molto vasta. È situata su un\'isola abbastanza grande, lontana dalla civiltà ma allo stesso tempo vicino a un ponte, e a qualche passo da una fonderia. Le spese non sono comprese."};
H.h[124] = {n:"Casa del Giardiniere",d:"Questa piccola casa ha una sola stanza. Ha però un piccolo orto ed è situata vicino alla costa, per la gioia di tutti i contadini poco fortunati che adorano passare le vacanze in un luogo tranquillo."};
H.h[125] = {n:"Capanna vicino al lago",d:"Questa capanna ha un piano classico, e anche una piccola dépendance a lato, da comprare separatamente. Questo ti consentirà di alloggiarvi facilmente un custode o i tuoi domestici."};
H.h[126] = {n:"Casetta vicino al lago",d:"Questa casetta ha solo una stanza, ma è situata vicino al lago e alla costa, per la gioia degli appassionati di pesca d\'acqua dolce e salata."};
H.h[127] = {n:"Casa Piccola vicino al lago",d:"Questa piccola casa di apparenza modesta ha solo una stanza, ma spaziosa e ben organizzata. Gli appassionati di pesca in acqua dolce e di bagni apprezzeranno il fatto che si trovi vicino al lago."};
H.h[128] = {n:"Capanna con viale",d:"Questa capanna ha solo un piano, ma le due stanze sono molto grandi, abbastanza per organizzare belle partite di Tragic The Gardening. La cura degli alberi del viale è a carico del proprietario."};
H.h[129] = {n:"Casa di MAX-LoL",d:"Questa piccola casa ha solo un piano, ma ha il vantaggio di essere situata su una piccola isola, questo la rende facilmente difendibile in caso di attacchi di Ladrurbi per esempio."};
H.h[130] = {n:"Casa Scafo di Nave",d:"Questa casa a un piano ha per tetto la scocca di una vecchia nave arenata, che può sempre essere utile in caso di grandi inondazioni o maree  fuori dal comune."};
H.h[131] = {n:"Casa Piccola del marinaio",d:"Questa piccola casa ha un piano. Vicina al porto e a una lingua di mare fangoso, sarà l\'ideale per gli allevatori di granchi che sopportano la presenza di vicini."};
H.h[132] = {n:"Casetta dei Pescatori",d:"Questa casetta dei pescatori ha una sola stanza e, con l\'andar del tempo, il mare se ne è allontanato rendendola meno interessante. Le persone meno ricche sapranno però accontentarsi e ne approfitteranno per risparmiare e mettere qualche soldo da parte."};
H.h[133] = {n:"Casa dal tetto a scafo",d:"Questa casa molto originale ha un tetto a scocca di nave che eviterà al proprietario di cambiare le tegole dopo ogni tempesta. Questa casa ha due piani ben arredati."};
H.h[134] = {n:"Casa Piccola del fiume",d:"Questa piccola casa ha una stanza modesta, ed è quindi adatta agli avventurieri solitari o a conquilini di taglia molto piccola."};
H.h[135] = {n:"Casa Piccola del Pescatore",d:"Questa piccolissima casa di pescatori con una sola stanza, è molto ambita dagli amanti del pesce che possono piacevolmente pescare restando a casa propria."};
H.h[136] = {n:"Casa dei Pappatutto",d:"Questa casa ha un piano piuttosto grande, abbastanza per accogliere i ricevimenti dell\'Ambasciatore. In offerta con questa casa c\'è un carretto da fieno. Attenzione però, il vecchio proprietario allevava dei Pappatutto che sono stati liberati nei dintorni delle proprietà."};
H.h[137] = {n:"Capanna vicino al ciliegio selvatico",d:"Questa casa ha un piano e una magnifica scalinata in legno di quercia. Il tetto di paglia e il ciliegio selvatico che cresce davanti all\'entrata, ne fanno una casa molto rustica, ma molto amata dalle persone che vogliono distinguersi."};
H.h[138] = {n:"Casa Piccola vicino al ciliegio selvatico",d:"Questa casa ha solo una stanza, ma molto vasta. D\'estate un magnifico ciliegio selvatico fa ombra ai proprietari di questa affascinante dimora."};
H.h[139] = {n:"Casa vicino alla Segheria",d:"Questa casa è piccola ma ha comunque un piano. La vicinanza alla segheria ne fa la casa ideale per i proprietari della segheria."};
H.h[140] = {n:"Capanna della Segheria",d:"Questa piccola casa ha un piano classico, ma è situata vicino alla segheria. Sarà sicuramente adatta ai taglialegna che odiano perdere tempo per rendersi sul luogo di lavoro."};
H.h[141] = {n:"Casa di Aria Knofob",d:"Casa dei PNG"};
H.h[142] = {n:"Casa montanara",d:"Questa casa ha una sola stanza, ma è spaziosa e ben arredata."};
H.h[143] = {n:"Grande Casa Scafo del porto",d:"Questa grande casa con il tetto a scocca di nave ha due piani, è quindi una casa di Maestro. La vicinanza al porto ne fa una dimora ideale per coloro che amano viaggiare. Però il granaio è lugubre e pieno di ragnatele."};
H.h[144] = {n:"Casa Sufokia",d:"Ambiente nobile, con vista sul mare e alto confort interno. Questa casa ti sedurrà per la ricchezza del suo arredamento."};
H.h[145] = {n:"Gran Casa Sufokia",d:"Una casa isolata la cui l\'architettura stupisce per la luminosità e il confort. Al primo piano c\'è un magnifico giardino interno, ideale per rilassarsi cullati dal suono dell\'oceano."};
