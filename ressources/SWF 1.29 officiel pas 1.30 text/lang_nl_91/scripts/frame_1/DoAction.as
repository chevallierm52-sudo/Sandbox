SRV_MSG_20 = "Deze server is alleen toegankelijk voor bepaalde spelers, of voor alle abonnees. Je kunt dus niet inloggen als je niet aan deze voorwaarden voldoet.";
SRV_MSG_21 = "Voorwerpen zijn in bewaring gegeven bij je bank.";
SRV_MSG_22 = "Je huidige ambachtslevel is niet hoog genoeg om dit voorwerp te maken. Je moet een hoger level hebben. Om dit levelvoorwerp %1 te maken, moet je minstens level %2 hebben voor dit beroep.";
SRV_MSG_23 = "Door het wijzigen van de effecten van toverspreuk %1, is jouw personage deze spreuk \'vergeten\', en krijg je daarom %2 verhogingspunten terug.";
SRV_MSG_24 = "De server vond ongeldige datums bij %1 van je niet uitruilbare huisdieren.\nDe ruildatum is aangepast naar morgen voor elke van deze huisdieren.";
SRV_MSG_25 = "De server heeft abnormale voedingscondities van een van je huisdieren gezien.\nHet magere huisdier heeft een toevoeging van voeding, vitaminen en mineralen gehad.\nHet heeft nu een schijnende huid en zijde oogjes";
SRV_MSG_26 = "Je bent zojuist overleden aan je verwondingen.";
SRV_MSG_27 = "Dit rijk is vol. Alleen accounts die al een karakter op deze server hebben of accounts die zijn uitgenodigd door hun peetvader kunnen het bezoeken.";
SRV_MSG_28 = "Je kunt de structuur van openbare paddocks niet wijzigen.";
SRV_MSG_29 = "Verbinding geweigerd. \nEr is een beveiligings probleem in je Internet verbinding gedetecteerd: \nje publieke IP adres is niet consistent, daardoor is het niet mogelijk om je verbinding toe te staan. \nNeem contact op met je netwerk administrator of je Internet Service Provider (ISP) om er voor te zorgen dat je IP adres hetzelfde is als wanneer je inlogd en wanneer je de spel server kiest. Deze IP problemen komen meestal voor op een netwerk waar meerdere Internet verbindingen op zijn aangesloten.";
SRV_MSG_3 = "Vanwege onderhoud, zal de server enkele minuten onderbroken worden.";
SRV_MSG_30 = "Verbinding geweigerd.\nJe kan geen verbinding maken op deze server omdat je verbinding is verlopen.\nZorg ervoor dat je alle downloads en video of muziek steams stop zet om je verbindingssnelheid te optimaliseren.";
SRV_MSG_31 = "Verbinding geweigerd.\nDe spel server heeft niet de benodigde toegangsinformatie ontvangen na je log-in.\nProbeer het nog een keer. Als je dit probleem blijft houden, neem dan contact op met je netwerk administrator of je Internet Service Provider (ISP). Dit probleem komt waarschijnlijk door een verkeerde DNS instelling of een automatische doorsturing.";
SRV_MSG_32 = "Wacht %1 seconde voor je verbinding maakt om andere spelers niet te storen.";
SRV_MSG_33 = "Gratis toegang op deze server is gelimiteerd tot een specifieke taal en/of community. Je verbinding laat zien dat je op een andere server of community moet spelen, afhankelijk van het land waar je woont.\nVerander je server en kies er een van je community of maak een account aan op een server passende bij je land/community.";
SRV_MSG_34 = "Verbinding niet mogelijk\n %1 accounts zijn al verbonden met het spel vanaf jouw IP %2. Vanwege meerdere incidenten van misbruik van accounts, zijn een paar van je hoster\'s IP adressen gelimiteerd op het punt van simultane verbindingen.\nAbonnee accounts hebben veel minder beperkingen.\nJe kunt de support over dit <a href=\"http://support.ankama.com/en/faq/718\"><u> hier</u></a> een bericht sturen.";
SRV_MSG_35 = "Deze server is alleen voor een bepaalde speelgroep, jij hebt geen toegang.\nIn sommige landen, is er geen selectie voor groepen en zal het op basis van geografische locatie worden ingedeeld.\nJe kunt de support er <a href=\"http://support.ankama.com/en/faq/716\"><u> hier</u></a> een bericht over sturen.";
SRV_MSG_36 = "Al je spreukpunten zijn hersteld vanwege de meerdere veranderingen die gemaakt zijn in hoe spreuken werken.";
SRV_MSG_37 = "Speltijd verlopen.\nZodat alle bezoekers de tijd hebben om in te loggen, is de duur dat een account verbonden kan zijn met spel beperkt. Je kunt je account over een paar uur weer in deze kamer gebruiken.\nVoor een toernooi, moet je contact opnemen met iemand van de staff, zodat je account dispensatie zal hebben tijdens het toernooi.";
SRV_MSG_38 = "Je hebt je niet aan het veiligheidslevel van dit account gehouden, waardoor de beperkte modus geactiveerd wordt als je inlogd op het spel en bepaalde acties niet mogelijk meer zijn. Bekijk de <a href=\'URL FAQ SUPPORT\'> FAQ Account Beveiliging </a> voor meer informatie.";
