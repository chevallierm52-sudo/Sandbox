VERSION = 91;
SIM = new Object();
SIM[24] = {m:"Eines schönen Tages fiel ich in König Allisters Kloschüssel. Das war vielleicht ein toller Streich!",s:-1,l:1,p:1};
SIM[25] = {m:"Ich habe Hunger! Jetzt gib mir endlich was, sonst futtere ich deine Gegenstände!",s:3,l:1,p:1};
SIM[26] = {m:"Gib mir endlich was zu essen, sonst mampf ich deine Kamas!",s:3,l:1,p:1};
SIM[27] = {m:"Mach ihn fertig, den Looser!",s:-1,l:1,p:1};
SIM[28] = {m:"Wer ist dieser Strolch, der es wagt, unsere Ruhe zu stören?",s:-1,l:1,p:1};
SIM[29] = {m:"Diese schreckliche Person hat nur bekommen, was sie verdient hat!",s:-1,l:1,p:1};
SIM[30] = {m:"Ich kann\'s kaum glauben, dass du so schlecht bist, dich von einem solchen Knirps besiegen zu lassen...",s:-1,l:1,p:1};
SIM[31] = {m:"Endlich mal ein kritischer Treffer! Wurde auch Zeit...",s:-1,l:1,p:1};
SIM[32] = {m:"Wie kommt es, dass du immer mehr kritische Patzer als kritische Treffer machst?",s:-1,l:1,p:1};
SIM[33] = {m:"Wenigstens einmal kein kritischer Patzer...",s:-1,l:1,p:1};
SIM[34] = {m:"Noch ein Sieg, den du einzig und allein mir zu verdanken hast!",s:-1,l:1,p:1};
SIM[35] = {m:"Versuch, nächstes Mal mal nicht so planlos durch die Gegend zu torkeln. Langsam hab ich nämlich wirklich die Nase voll, immer solche Looser wie dich aufzugabeln.",s:-1,l:1,p:1};
SIM[36] = {m:"Schau dir mal diesen Anfänger an... Du solltest ihn schnell aggressen, das wäre ein leichter Sieg!",s:-1,l:1,p:1};
SIM[37] = {m:"Schau mal, wer gerade gekommen ist... Ich glaube, das ist DER Moment, um abzuhauen.",s:-1,l:1,p:1};
SIM[38] = {m:"Wenn du nur genauso oft kritisch treffen würdest, wie er!",s:-1,l:1,p:1};
SIM[39] = {m:"Himmel, das ist ja voll der Looser! Du bist wirklich eine absolute Niete, wenn es darum geht, dir die passenden Freunde auszuwählen!",s:-1,l:1,p:1};
SIM[40] = {m:"Was? Du bringst es fertig, erst jetzt vorbeizukommen? Bin ich dir denn überhaupt nichts wert?",s:3,l:1,p:0.1};
SIM[41] = {m:"Ich glaub\', du hast gerade einen Verbündeten erwischt... Du solltest dich wirklich mal untersuchen lassen...!",s:-1,l:1,p:1};
SIM[42] = {m:"Eines Tages werde ich dir beibringen, deine Freunde sorgfältig auszuwählen.",s:-1,l:1,p:1};
SIM[43] = {m:"Jetzt sei mal nicht so geizig! Gib schon her, was du da grad gekriegt hast! Immer behältst du das Beste für dich!",s:-1,l:1,p:1};
SIM[44] = {m:"Ich kann mich nicht erinnern, schon mal einen so idiotischen Abenteurer wie dich aufgegabelt zu haben.",s:-1,l:1,p:1};
SIM[45] = {m:"Komm, nun gib schon her!",s:-1,l:1,p:1};
SIM[46] = {m:"Und wieder daneben... Haha!",s:1,l:1,p:1};
SIM[47] = {m:"Eines schönen Tages musste ich mir ein Lied von Oh\'Nein anhören. Noch 12 Jahre später hatte sich mein Gehör davon nicht erholt.",s:-1,l:1,p:0.2};
SIM[48] = {m:"Kennst du schon die Story vom Kirbull, der einen mit seinen Kopfstößen ganz kirre machen kann?",s:2,l:1,p:0.1};
SIM[49] = {m:"Eines Tages werde ich \'nen Dora Bora heiraten.",s:-1,l:1,p:0.1};
SIM[50] = {m:"Und da kam auf einmal dieser Widerling an und sagte:\"Eh, du Lump, nicht ich bin hier der Böse, sondern du!\" Da konnte ich mich natürlich nicht mehr halten vor Lachen...",s:2,l:1,p:0.1};
SIM[51] = {m:"Es heißt, Allisters rechte Hinterbacke sei ausgeprägter als die Linke. Doch weiß ich, dass dem nicht so ist. Jedes Mal, wenn er auf mir saß, litt ich nämlich genauso.",s:-1,l:1,p:0.5};
SIM[52] = {m:"Lichen ist wirklich sowas von cool!",s:-1,l:1,p:0.01};
SIM[53] = {m:"Ich hatte eine schwere Kindheit. Ich hatte nämlich einen Abenteurer, der am Zaap von Astrub Schreihandel betrieb. Nun bin ich taub.",s:-1,l:1,p:0.1};
SIM[54] = {m:"Du erinnerst mich irgendwie an ein Monster... Ich weiß nur nicht mehr welches. War es meine Schwiegermutter?",s:-1,l:1,p:0.1};
SIM[55] = {m:"Das Problem mit Astrub ist der chronische Mangel an Großbränden.",s:-1,l:1,p:0.1};
SIM[57] = {m:"Ich habe schon einmal einen Féca gesehen, der etwas anderes tat, als Panzer zu wirken und mit gesenkten Kopf in den Nahkampf zu stürzen. Das war aber leider nur im Traum...",s:-1,l:1,p:0.1};
SIM[58] = {m:"Ich habe schon einmal einen Iop gesehen, der rechnen konnte. Aber da war ich auch besoffen.",s:-1,l:1,p:0.1};
SIM[59] = {m:"Hunger!!!",s:-1,l:1,p:1};
SIM[62] = {m:"Jetzt bin ich wieder für ein paar Monate gesättigt.",s:-1,l:1,p:1};
SIM[63] = {m:"Irgendwie war das zu viel Futter... Ich glaub, ich muss mich gleich in dein Inventar übergeben.",s:-1,l:1,p:1};
SIM[64] = {m:"Ich würde dir gern helfen, aber ich habe wirklich zu viel gefuttert. Ein anderes Mal, vielleicht.",s:-1,l:1,p:1};
SIM[65] = {m:"Noch mehr zu futtern?!? Jetzt reicht\'s aber! Ich bin doch keine Weihnachtsgans!!",s:-1,l:1,p:1};
SIM[66] = {m:"Wenn du mich nicht so vollgestopft hättest, so hätte ich dir dein Leben retten können!",s:-1,l:1,p:1};
SIM[67] = {m:"Ok, du hast gewonnen. Ganz toll. Schön, dass du dich freust. Das ist aber noch lange kein Grund, mich mit Gegenständen vollzustopfen!",s:-1,l:1,p:1};
SIM[68] = {m:"Die Devs krigen das schon hin!",s:-1,l:10,p:0.01};
SIM[70] = {m:"Also, nach den Kämpfen, ja, da verschwinden ja meistens so Gegenstände, nich? Die glauben alle, das käme durch diese Beschwörungen... Naja, Hauptsache, die beschwören mich mal nicht!",s:-1,l:3,p:1};
SIM[71] = {m:"Es geht das Gerücht, reden verscheuche die Fische...",s:-1,l:5,p:1};
SIM[72] = {m:"Ich glaube an den Weißnachts-Minotoball. Und du?",s:-1,l:1,p:1};
SIM[73] = {m:"Ahhhh! Der wird mich vielleicht endlich von dir befreien!",s:-1,l:1,p:1};
SIM[74] = {m:"Also, wenn du dich weiterhin von Hinz und Kunz platt walzen lässt, dann bin ich über alle Berge, ist dir das klar?",s:3,l:1,p:1};
SIM[75] = {m:"Verräter! Und das alles nur für ein bisschen Action...!",s:-1,l:1,p:1};
SIM[76] = {m:"Du solltest es mal mit \"Gegenstand füttern\" versuchen! Ich wette, das bringt dir jede Menge kritische Treffer ein.",s:-1,l:1,p:1};
SIM[77] = {m:"Wunderbar! Der war eh zu nichts nütze!",s:1,l:5,p:1};
SIM[78] = {m:"Also, wenn mich jemand sucht: ich bin in deinem Sack!",s:-1,l:10,p:1};
SIM[79] = {m:"Ich hoffe, das hat endlich mal weh getan!",s:1,l:5,p:1};
SIM[80] = {m:"Ha! Das ist einen Screenshot wert!",s:2,l:10,p:0.5};
SIM[81] = {m:"Ich sollte mir die gegnerische Front mal aus der Nähe ansehen...",s:-1,l:5,p:1};
SIM[82] = {m:"He, ich glaube, da ruft dich jemand zum Essen!",s:-1,l:1,p:1};
SIM[83] = {m:"Das hast du schon mal besser hinbekommen...",s:-1,l:15,p:1};
SIM[84] = {m:"Neulich war ich in Astrub, am Zaap. Da gab es so einen Wettbewerb... Wer am lautesten schreit oder so...",s:-1,l:15,p:0.5};
SIM[85] = {m:"In meinem früheren Leben hab ich mal ein Faultier geseh\'n. Da musste ich sofort an einen Sadida denken.",s:-1,l:8,p:1};
SIM[86] = {m:"Das letzte Mal hat mich ein Wabbit gebissen. Ich glaube, dew hatte sogaw ne ansteckende Kwankheit...",s:-1,l:12,p:0.5};
SIM[87] = {m:"Wer Zaapis sät, wird Überraschungen ernten... aber gut: Lieber einen Zaapi vor der Tür, als einen Sadida im Bett...",s:-1,l:16,p:1};
SIM[88] = {m:"Schon zurück?? Und, hast du mir was mitgebracht?",s:-1,l:7,p:1};
SIM[89] = {m:"Du solltest dir deine Freunde wirklich sorgfältiger aussuchen! (Und ich meine Eigentümer...)",s:-1,l:14,p:1};
SIM[90] = {m:"He du, wann gibt\'s was zu essen?",s:-1,l:1,p:1};
SIM[91] = {m:"Der Letzte, der mich nicht anständig gefüttert hat, ist unter geheimnisvollen Umständen  v e r s c h w u n d e n...!",s:-1,l:17,p:1};
SIM[92] = {m:"Los! Auf ihn! Das ist doch bloß \'n Weichei!",s:-1,l:3,p:1};
SIM[93] = {m:"Ok ok... Ich werde schon jemanden finden, der dir deinen Gegenstand herstellt.",s:-1,l:9,p:1};
SIM[94] = {m:"Auf einem Bein ist nicht gut stehen!",s:-1,l:6,p:1};
SIM[95] = {m:"Als ich damals gegen diesen Drachen losgezogen bin, ja, da hab ich dem den Schwanz abgebissen, aber ohne zu zucken!",s:-1,l:18,p:1};
SIM[96] = {m:"Mmmmh! Sieht so aus, als würde ich was zum Einwerfen kriegen!",s:-1,l:12,p:1};
SIM[97] = {m:"Schaaaaaaaade..... Beinahe, ja... Beinahe hättest du\'s geschafft! ... Wie jetzt, ich bin nicht glaubwürdig???",s:-1,l:9,p:1};
SIM[98] = {m:"Eine Toilette, bitte! Wo sind hier die Toiletten???",s:-1,l:7,p:1};
SIM[99] = {m:"Ich habe mich lange Zeit gefragt, wer dümmer ist: die Goblins oder die Bworks... Ich bin zu dem Schluss gelangt, dass beide außer Konkurrenz laufen...",s:-1,l:11,p:1};
SIM[100] = {m:"Warum hacken nur alle auf diesen unseeligen Blops herum?",s:-1,l:9,p:1};
SIM[101] = {m:"Was gibt es denn da so Geheimnisvolles im Turm von Gisgoul?",s:-1,l:4,p:0.25};
SIM[102] = {m:"Oh wie schön! Das sieht aber lecker aus!",s:-1,l:4,p:1};
SIM[103] = {m:"Verlass dich bloß nicht auf mich! Solange du mich hier vor Hunger umkommen lässt, mache ich keinen Finger mehr krumm!",s:-1,l:1,p:1};
SIM[104] = {m:"Hunger!!! Ich brauche Nachschub!!!",s:-1,l:1,p:1};
SIM[105] = {m:"Du überraschst mich jeden Tag ein bisschen mehr...",s:-1,l:8,p:1};
SIM[106] = {m:"Ich hoffe doch, du wirst mich jetzt nicht schon wieder mit Gegenständen versorgen!",s:-1,l:1,p:1};
SIM[107] = {m:"Ist das nichts für mich dabei in dem Haufen?",s:-1,l:1,p:1};
SIM[108] = {m:"Naja... Dass du ab und zu mal überzeugend wirkst, heißt noch lange nicht, dass du wirklich was auf dem Kerbholz hast!",s:-1,l:1,p:1};
SIM[109] = {m:"Och, lass mal, du brauchst dich nicht so abhetzen. Ich komme schon alleine klar. Komm einfach später wieder vorbei. Wenn ich verhungert bin, zum Beispiel.",s:-1,l:5,p:1};
SIM[110] = {m:"Oh... Ein kleiner süßer Feind! Los, zeig ihm, was Sache ist! Dann krieg ich vielleicht endlich wieder mal was zwischen die Zähne!",s:-1,l:1,p:1};
SIM[111] = {m:"Sieht so aus, als sei dir dein Gegner ebenbürtig...",s:2,l:5,p:1};
SIM[112] = {m:"Dafür brauchst du mich nicht. Außerdem hab ich Herzschmerzen. Und Rücken.",s:-1,l:1,p:1};
SIM[113] = {m:"Hmmmm... Glück gehabt eben...",s:-1,l:5,p:1};
SIM[114] = {m:"Na so was... Nicht, dass ich dich drum gebeten hätte, mir was zum Futtern vorbeizubringen...",s:-1,l:1,p:1};
SIM[115] = {m:"Schade, dass es hier keine Werte unter Null gibt...",s:1,l:1,p:1};
SIM[116] = {m:"Hast du vielleicht zwischendurch mal auf die Uhr geschaut? Du könntest wenigstens Bescheid geben, wenn du so lange weg bleibst!",s:-1,l:6,p:0.5};
SIM[117] = {m:"Action, Mann! Sonst kürz ich\'s Taschengeld!",s:-1,l:5,p:1};
SIM[118] = {m:"Ganz recht! Mann muss sein Territorium verteidigen!",s:-1,l:7,p:0.5};
SIM[119] = {m:"Angriff ist die beste Verteidigung!",s:-1,l:8,p:0.5};
SIM[120] = {m:"Im Kampf sind alle Mittel recht! (Hauptsache keine Schmachpunkte!)",s:-1,l:11,p:0.5};
SIM[121] = {m:"Aggro! Hauptsache aggro! Action will ich sehen!",s:-1,l:1,p:1};
SIM[122] = {m:"Angst? Was ist das?",s:1,l:15,p:0.3};
SIM[123] = {m:"Hiiiiiiilfe! Mein Eigentümer soll entführt werden!",s:-1,l:6,p:0.7};
SIM[124] = {m:"Ich glaube, diese Person kann dich nicht ausstehen.",s:-1,l:3,p:0.6};
SIM[125] = {m:"Also, ich will dich ja nicht beleidigen, aber... dein Gegner hat doch mehr Talent als du.",s:-1,l:4,p:0.5};
SIM[126] = {m:"Selbst ein Spatz hätte das nicht besser hinbekommen!",s:-1,l:2,p:1};
SIM[127] = {m:"Schau genau hin, wie dein Mitstreiter das anstellt. Mal seh\'n, ob du das genauso hinbekommst.",s:-1,l:9,p:0.5};
SIM[128] = {m:"Er hat ganz bestimmt nicht geblufft!",s:-1,l:6,p:0.5};
SIM[129] = {m:"Das dürfte jetzt gleich ganz schön weh tun...!",s:-1,l:5,p:1};
SIM[130] = {m:"Der kriegt das ziemlich gut auf die Reihe. Nicht wie manch andere...",s:-1,l:10,p:0.2};
SIM[131] = {m:"Wow! Das hast du mich jetzt echt beeindruckt!",s:-1,l:12,p:1};
SIM[132] = {m:"Alle Achtung! Das hätte ich dir niemals zugetraut!",s:-1,l:13,p:0.7};
SIM[133] = {m:"Nicht übel. Weiteer so!",s:-1,l:2,p:1};
SIM[134] = {m:"Ich kaufe ein B, ein R, ein A, ein V und ein O.... BRAVO!",s:-1,l:16,p:0.2};
SIM[135] = {m:"Wenn das doch nur öfter mal passieren würde...!",s:-1,l:8,p:0.1};
SIM[136] = {m:"Das kann doch nicht wahr sein! Was ist denn das für ein Blindgänger?!",s:3,l:5,p:0.8};
SIM[137] = {m:"Müssen wir uns diesen Blindgänger wirklich zumuten?",s:3,l:10,p:0.8};
SIM[138] = {m:"Selbst ein Spatz hätte das nicht besser hinbekommen!",s:-1,l:2,p:1};
SIM[139] = {m:"Oh je oh je... Dieser Bettsockenträger...!",s:2,l:3,p:1};
SIM[140] = {m:"Was ist denn das für ein Mädchenversteher?! Hast du den etwa aufgegabelt?",s:-1,l:11,p:0.5};
SIM[141] = {m:"Such dir das nächste Mal besser jemand kompetenteren aus!",s:-1,l:7,p:1};
SIM[142] = {m:"Weißt du... Kritische Treffer passieren nicht einfach so automatisch...",s:-1,l:6,p:0.5};
SIM[143] = {m:"Denkst du, dass der spielen kann?",s:-1,l:12,p:1};
SIM[144] = {m:"Und ich sage dir eins: der blufft!",s:-1,l:6,p:0.5};
SIM[145] = {m:"Also, bei dem, was ich da eben gesehen habe... Du hast wirklich keinen Grund zu prahlen!",s:-1,l:8,p:0.8};
SIM[146] = {m:"Was wollte er noch mal tun?",s:2,l:10,p:0.6};
SIM[147] = {m:"Ja, genaus so! Ja! Neee... Nicht doch! Vorsicht! Himmelherrgott, hättest du bloß auf mich gehört, dann wäre dir das nicht passiert...",s:-1,l:4,p:1};
SIM[148] = {m:"Das ist nicht sehr nett.",s:-1,l:3,p:0.7};
SIM[149] = {m:"Das nennt man also einen Kritischen Patzer...!",s:-1,l:14,p:0.2};
SIM[150] = {m:"Wenn man auf der ganzen Linie Null ist, ist das noch lange kein Grund zum Verzweifeln! Es kann doch nur besser werden!",s:-1,l:13,p:0.1};
SIM[151] = {m:"Sieht so aus, als müsste ich dir erstmal beibringen, wie man seine 10 Finger benutzt...",s:-1,l:8,p:0.5};
SIM[152] = {m:"Mörder! Wie konntest du nur! So kaltblütig diesen Gegenstand kaltmachen... Und das vor meinen Augen!",s:3,l:11,p:0.2};
SIM[153] = {m:"Glücklicherweise warst nicht du es, der mich erschaffen hat!",s:-1,l:5,p:1};
SIM[154] = {m:"Hör auf! Du tust dir damit nur selber weh!",s:-1,l:7,p:0.8};
SIM[155] = {m:"Sag mal, wie willst du eigentlich reich werden, bei dem Materialschaden, den du ständig anrichtest?",s:-1,l:9,p:1};
SIM[156] = {m:"Ärger dich nicht. Vielleicht klappt\'s ja beim nächsten Mal.",s:-1,l:13,p:0.5};
SIM[157] = {m:"Das Handwerk ist deine Sache offenbar nicht...",s:1,l:15,p:0.5};
SIM[158] = {m:"Also, ich will ja nicht die Stimmung verderben, aber die NPCs kriegen das besser hin!",s:-1,l:17,p:0.2};
SIM[159] = {m:"Oh, das ist die Grundlage für grooooßen Reichtum! Weiter so, Chef!",s:-1,l:9,p:1};
SIM[160] = {m:"Wow! Kannst du mir auch so ein Ding machen? Bitte bitte!",s:-1,l:8,p:0.5};
SIM[161] = {m:"Juhu! Noch ein Gegenstand, den du nicht erst am Verkaufsstand suchen musst!",s:-1,l:10,p:0.5};
SIM[162] = {m:"Können wir das nicht verschieben?",s:-1,l:6,p:1};
SIM[163] = {m:"Bein nächsten Mal versuch\'s mal damit: \"Ich bin gekommen, Frieden zustiften!\"",s:-1,l:5,p:0.5};
SIM[164] = {m:"Ich glaube, es ist jetzt an der Zeit, dass wir uns schlafen legen.",s:-1,l:2,p:1};
SIM[165] = {m:"Vergiss nicht, Energie aufzutanken! Ich habe nämlich keine Lust, als Geist neben dir herzuspazieren.",s:-1,l:8,p:1};
SIM[166] = {m:"Wann noch mal hatte sich in diesem Kampf das Blatt zu unseren Gunsten gewendet?",s:-1,l:7,p:0.5};
SIM[167] = {m:"Zum stinkenden Bwork! Wir haben verloren... Ich könnte meine Nähte auflösen...",s:-1,l:15,p:0.2};
SIM[168] = {m:"Hättest du mich besser versorgt, wäre DAS nicht passiert! Jedenfalls nicht in dieser uneleganten Form.",s:-1,l:10,p:0.8};
SIM[169] = {m:"Dummheit, verlaß ihn nicht, sonst steht er ganz allein.",s:-1,l:12,p:0.8};
SIM[170] = {m:"Siehste? So was kommt von so was!",s:1,l:11,p:0.5};
SIM[171] = {m:"Du bist eben nicht der Hellste, das ist doch kein Problem! Nimm dich einfach an, so wie du bist, dann geht\'s dir besser.",s:-1,l:16,p:0.1};
SIM[172] = {m:"Gewonnen! War doch ganz einfach, hör mal!",s:2,l:15,p:0.2};
SIM[173] = {m:"Das grenzte zwar an Schwerstarbeit, aber immerhin! Es hat sich gelohnt!",s:-1,l:10,p:0.5};
SIM[174] = {m:"Noch ein paar Kämpfe wie diese, und du bist eine Legende!",s:-1,l:20,p:0.1};
SIM[175] = {m:"Lass ihnen doch das nächste Mal eine Chance, dann können wir uns wenigstens ein bisschen amüsieren.",s:-1,l:5,p:0.5};
SIM[176] = {m:"Ich weiß nicht, ich kann mir nicht helfen... Irgendwie hast du etwas von einer belebten Truhe an dir...",s:-1,l:11,p:0.2};
SIM[178] = {m:"Da hat dir leibhaftig der Gott Enutrof beigestanden!",s:-1,l:4,p:1};
SIM[179] = {m:"Ist dir der Gott Enutrof leibhaftig begegnet?",s:-1,l:14,p:0.1};
SIM[180] = {m:"Bei all dem, was du da eingeheimst hast, hast du wirklich keine Ausrede mehr, mich verhungern zu lassen!",s:-1,l:7,p:1};
SIM[181] = {m:"Ehrlich, ich kann nichts dafür! Das war mein Eigentümer!",s:-1,l:10,p:0.6};
SIM[182] = {m:"Schlecht gezielt... Das ist einer unserer Verbündeten! Naja, das war er...",s:-1,l:6,p:1};
SIM[183] = {m:"Schlechter Zeitpunkt... Mein Eigentümer hat gerade Tofuguano auf den Augen...",s:-1,l:12,p:0.5};
SIM[184] = {m:"Wenn der sich hier das nächste Mal einnistet, schmeiß ihn einfach raus, hörst du?",s:-1,l:3,p:1};
SIM[185] = {m:"Noch so ein Schlag, und ich zeige dich bei den Behörden an!",s:3,l:16,p:0.2};
SIM[186] = {m:"Warte mal... Der dich da eben ins Jenseits befördert hat, war das nicht einer unserer Verbündeten?",s:-1,l:13,p:0.5};
SIM[187] = {m:"Sieh\'s doch mal von der positiven Seite: du kannst als Biodünger verwertet werden!",s:1,l:9,p:0.5};
SIM[188] = {m:"Einen Augenblick lang dachte ich, du würdest es tatsächlich schaffen.",s:-1,l:6,p:0.5};
SIM[189] = {m:"Bist du sicher, dass es gehen wird? Du sahst eben so blass aus...",s:-1,l:2,p:1};
SIM[190] = {m:"Das ist gar nicht mal so unbequem hier auf dem Boden. He! Hörst du??? Wach auf!!!",s:-1,l:11,p:1};
SIM[191] = {m:"Da hast du ganz schön eine auf den Hut bekommen...",s:2,l:14,p:0.8};
SIM[192] = {m:"Ha! Da siehst du, was du davon hast, wenn du mich halb verhungern lässt!",s:1,l:7,p:0.8};
SIM[193] = {m:"Ich kann mich nicht entscheiden, ob du zu bedauern bist oder nicht...",s:-1,l:3,p:0.4};
SIM[194] = {m:"Gut so! Das hat er nun davon.",s:1,l:2,p:1};
SIM[195] = {m:"Da sieh mal einer an! Du bist tatsächlich in der Lage, dich zu wehren!",s:-1,l:5,p:0.5};
SIM[196] = {m:"Ich hätte nicht mit ihm tauschen wollen...",s:-1,l:13,p:0.5};
SIM[197] = {m:"Glück gehabt... Sein Leiden hat ein Ende. Im Gegensatz zu meinem...",s:-1,l:11,p:1};
SIM[198] = {m:"Kann ich mir nachher seine Ausrüstung einverleiben?",s:-1,l:4,p:1};
SIM[199] = {m:"Kommt nicht in Frage, dass ich auch nur meine Lippen an diese Ausrüstung lege!",s:3,l:6,p:1};
SIM[200] = {m:"Wenn du das nächste Mal sterben willst, dann gib mir bitte vorher Bescheid, damit ich mir einen neuen Eigentümer suchen kann.",s:-1,l:5,p:1};
SIM[201] = {m:"Wäre ich bloß lieber in diesem Geschenkpaket geblieben...",s:-1,l:10,p:0.2};
SIM[202] = {m:"Gut, ich geb es ja schon zu... Ich habe was gegessen, als du dich kurz weggedreht hattest.",s:-1,l:6,p:0.2};
SIM[203] = {m:"He! Hast du nicht was vergessen?",s:-1,l:9,p:1};
SIM[204] = {m:"Wärst du auch nur eine Minute zu spät gekommen, wäre ich abgewandert.",s:-1,l:8,p:0.2};
SIM[205] = {m:"Ist ja schön, dass du auch mal hier vorbeikommst...",s:3,l:4,p:1};
SIM[206] = {m:"Kuuuuuuscheln!",s:-1,l:6,p:1};
SIM[207] = {m:"Oh... Du hast mir soooo gefehlt! Komm her, gib mir ein Küsschen!",s:-1,l:18,p:0.4};
SIM[208] = {m:"Und? Was steht heute Aufregendes auf der Tagesordnung?",s:-1,l:19,p:0.8};
SIM[209] = {m:"Vergiss nicht, mir auf Wiedersehen zu sagen, bevor du dich ausloggst!",s:-1,l:10,p:1};
SIM[210] = {m:"Dein Anblick lässt mein Herz vor Freude höher schlagen!",s:-1,l:20,p:0.2};
SIM[211] = {m:"Um der Götter willen! Einer dieser hässlichen Goblins will sich hier breitmachen!",s:-1,l:15,p:0.5};
SIM[212] = {m:"Muarrrrhhhh! Hast du geseh\'n, auf welcher Stufe der spielt?",s:2,l:10,p:0.5};
SIM[213] = {m:"He! Guck mal, da! Ein Neueinsteiger! Ein richtiger Neueinsteiger!",s:1,l:6,p:0.6};
SIM[214] = {m:"Hoho! Da ist einer, der keine Angst vorm Sterben hat!",s:-1,l:19,p:1};
SIM[215] = {m:"Jetzt wird\'s hier langsam ein bisschen eng, findest du nicht?",s:-1,l:13,p:1};
SIM[216] = {m:"Ok, jetzt besteht eine günstig Gelegenheit, sich hier aus dem Staub zu machen!",s:-1,l:8,p:0.7};
SIM[217] = {m:"Ich habe so das Gefühl, du wirst dir gleich einen tüchtigen Hieb einfangen...",s:-1,l:5,p:0.6};
SIM[218] = {m:"Du kennst Fallansters berühmten Schlusssatz, nicht? \"Lasst uns das Weite suchen, meine Freunde!\"",s:-1,l:18,p:0.4};
SIM[219] = {m:"Komm, gib mir ein Küsschen, bitte! Zeig mir, dass du mich lieb hast!",s:-1,l:16,p:0.3};
SIM[220] = {m:"Irgendwann begleite ich dich nach Bonta. Hach wird das herrlich werden! Die ganze Nacht lang Dummheiten verzapfen und die Leute ärgern...!",s:-1,l:8,p:0.6};
SIM[221] = {m:"Weißt du was? ... Ach nee, schon gut, vergiss es einfach.",s:-1,l:7,p:1};
SIM[222] = {m:"Deine Stimme ist genauso reizend wie die von Oh\'Nein...",s:-1,l:9,p:0.3};
SIM[223] = {m:"Schau mal! Hör mal! Wie die Blumen riechen...!",s:-1,l:6,p:0.4};
SIM[224] = {m:"Hab keine Angst und gib es endlich zu... Ich bin die große Liebe deines Lebens!",s:-1,l:10,p:0.1};
SIM[225] = {m:"Der Verwalter Danathor stinkt nach Camembert... Da wundert\'s mich kaum, dass er keine Freunde hat...",s:-1,l:5,p:0.2};
SIM[226] = {m:"Weißt du, was der Unterschied zwischen einem Sadida und einer Schlafmütze ist?",s:2,l:4,p:0.3};
SIM[227] = {m:"Wie wär\'s mit einer kleinen Fresssackhatz? Nur so zum Spaß?",s:-1,l:2,p:1};
SIM[228] = {m:"Stell dir mal vor, dieser Schlüpfer wäre lebendig... Da überkommt einem das blanke Grausen, nicht?",s:-1,l:11,p:0.5};
SIM[229] = {m:"Weißt du was dieser Allister von Frauen versteht? Rein gar nichts!",s:2,l:3,p:0.4};
SIM[230] = {m:"Wenn ich ein Lendenschurz wäre, dann wollte ich einem Eniripsa gehören.",s:-1,l:12,p:0.2};
SIM[231] = {m:"Solltest du nicht jetzt grad deine Hausaufgaben machen?",s:-1,l:2,p:0.7};
SIM[232] = {m:"Wie oft muss ich dir das denn noch sagen... Du sollst nicht in der Nase bohren!",s:3,l:13,p:0.4};
SIM[233] = {m:"Warum kann man mich nicht einfach mittels Schmiedmagie herstellen? Das Leben wäre so viel einfacher...",s:-1,l:15,p:0.3};
SIM[234] = {m:"Der \"Tag der Zähne\", sagt dir das was? Das ist der Tag, an dem man sie sich putzen sollte. Du kannst das allerdings auch öfter machen...!",s:-1,l:6,p:0.5};
SIM[235] = {m:"Manche Iops sind ja ganz hübsch anzuseh\'n. Aber noch lange nicht so hübsch wie du!",s:-1,l:10,p:0.1};
SIM[236] = {m:"Weißt du was, mein Schatz? Ich hab dich lieb!",s:-1,l:20,p:0.1};
SIM[237] = {m:"Küsschen! Küsschen! Küsschen! Und nochmal Küsschen!",s:-1,l:5,p:1};
SIM[238] = {m:"Du und ich, wir sind unzertrennlich, stimmt\'s?",s:-1,l:14,p:0.8};
SIM[239] = {m:"Eigentlich liebe ich ja nur dich allein!",s:-1,l:16,p:0.5};
SIM[240] = {m:"Weiißt du was? Die Fresssäck sind unter ihrem Fell ganz nackt! Die müssen unheimlich frieren...",s:-1,l:8,p:0.2};
SIM[241] = {m:"Nur mal so zu deiner Info... Ein Pandawa ist nicht etwa ein Wa von Pandala!",s:-1,l:7,p:0.2};
SIM[242] = {m:"Naja, du bist zwar nicht grad das Hübscheste, was es in ganz Amakna zu sehen gibt, aber ich hab dich trotzdem lieb!",s:-1,l:8,p:0.1};
SIM[243] = {m:"Schau mir in die Augen, Kleines! ... Nee, lass mal, ich spinne nur so vor mich hin...",s:2,l:12,p:0.6};
SIM[244] = {m:"Wenn du mich hier verhungern lässt, dann kannst du aber was erleben!",s:3,l:14,p:0.8};
SIM[245] = {m:"Wenn du mir ab und zu mal was zu futtern gäbest, ja, dann könnte ich das Leben wenigstens genießen!",s:-1,l:13,p:0.4};
SIM[246] = {m:"Falls du\'s noch nicht gemerkt hast: ich befinde mich grade im Hungerstreik!!!",s:-1,l:9,p:0.7};
SIM[247] = {m:"Kennst du den Unterschied zwischen dir und mir? Nein? Du hast gerade was gegessen!",s:-1,l:15,p:0.9};
SIM[248] = {m:"Wenn ich dir ein Küsschen gebe, krieg ich dann was zu futtern?",s:-1,l:17,p:0.1};
SIM[249] = {m:"Kannst du mir mal \'ne Pizza bestellen? So für zwischendurch?",s:-1,l:10,p:0.2};
SIM[250] = {m:"Oh du Sonne meines Lebens! Ich dien\' dir nicht vergebens! Krieg ich jetzt was zu futtern?",s:-1,l:11,p:0.3};
SIM[251] = {m:"Also, wenn ich von dir nur Burger kriege, dann musst du dich nicht wundern, dass ich aus den Nähten gehe.",s:-1,l:9,p:1};
SIM[252] = {m:"Aha! Jetzt kapiere ich, was du vorhast! Du willst mich mästen, um mich an den Höchstbietenden zu verscherbeln!",s:-1,l:7,p:0.2};
SIM[253] = {m:"Bitte bitte, hör auf! Ich tu auch alles, was du willst, aber hör auf, mich zu mästen!",s:-1,l:12,p:1};
SIM[254] = {m:"Uuuurks... \'tschuldigung.... Kleine Verdauungsstörung...",s:-1,l:5,p:0.5};
SIM[255] = {m:"Welchen Unterschied gibt\'s wohl zwischen dem Gewicht einer Feder und meinem, hm? Gar keinen!",s:-1,l:3,p:0.2};
SIM[256] = {m:"Stopp! Sofort! Ich glaub. Ich muss mich übergeben...",s:-1,l:2,p:1};
SIM[257] = {m:"Tut mw leid, ich weagiewe allewgisch auf Ewzeugnisse auf Kawottenbasis.",s:-1,l:11,p:0.5};
SIM[258] = {m:"Mach nur so weiter! Du brauchst dich dann aber nicht wundern, wenn ich so dick werde wie König Allister!",s:-1,l:16,p:0.1};
SIM[259] = {m:"Stör mich jetzt nicht! Ich verdaue grade!",s:-1,l:12,p:0.5};
SIM[260] = {m:"Uuuurks.... \'tschuldigung... Die Natur verlangt ihr Recht...",s:-1,l:4,p:1};
SIM[261] = {m:"Da kann nicht wahr sein! Wer hat denn das verzapft? Das brennt in den Augen, das Zeug!",s:3,l:10,p:0.2};
SIM[262] = {m:"Ich bin sicher, dass du es geschafft hättest, wenn deine Finger nicht so mit Ringen behangen gewesen wären.",s:-1,r:"9255",l:1,p:0.7};
SIM[263] = {m:"Oh je... Ich sehe dich schon deine Ringe verkaufen, um deine Verluste zu kompensieren...",s:-1,r:"9255",l:10,p:0.5};
SIM[264] = {m:"Alle Abenteurer stehen ihren Mann - nur nicht meiner, der ist nämlich keiner...",s:-1,r:"9255",l:15,p:1};
SIM[265] = {m:"Bald hab ich Geburtstag! Krieg ich dann ein Naschamulett von dir?",s:-1,r:"9255",l:2,p:0.2};
SIM[266] = {m:"Ha! Dieser Schlag war mein Verdienst!",s:1,r:"9255",l:14,p:0.4};
SIM[267] = {m:"Wenn du nicht so ein Faible für Schmuck hättest, würde ich dir gar nicht so auf die Nerven gehen. Dann wäre ich nämlich gar nicht hier!",s:-1,r:"9255",l:9,p:0.8};
SIM[268] = {m:"Hör nicht drauf, was dir so ein Ring erzählt! Ringe lügen alle wie gedruckt.",s:-1,r:"9255",l:18,p:0.7};
SIM[269] = {m:"Kannst du mal wieder auf Ringjagd gehen? Ich würde mir nämlich gerne wieder mal meiner Einzigartigkeit bewusst werden!",s:-1,r:"9255",l:19,p:0.1};
SIM[270] = {m:"Ein Ring ist schon nichts Besonderes... Aber gleich zwei Ringe... Da verlier\' ich ja absolut das Interesse...",s:-1,r:"9255",l:17,p:0.3};
SIM[271] = {m:"Du solltest deine Ringe besser bei der Bank hinterlegen. Da sind sie nämlich in Sicherheit.",s:-1,r:"9255",l:16,p:0.4};
SIM[272] = {m:"Es gibt nur 2 Dinge im Leben, an denen ich wirklich hänge: Schmuck, und du!",s:-1,r:"9255",l:20,p:0.2};
SIM[273] = {m:"Ich musste mich entscheiden zwischen Amulett oder Unterhose... Das fiel mir nicht besonders schwer.",s:-1,r:"9255",l:4,p:0.5};
SIM[274] = {m:"Wenn ich nicht bald was zu futtern bekomme, muss ich den Gürtel enger schnallen! Mal seh\'n wie du damit klarkommst!",s:3,r:"9255",l:10,p:0.3};
SIM[275] = {m:"Gut gegessen ist halb verdaut! Ein Piepmatz-Amulett käme jetzt gerade richtig...",s:-1,r:"9255",l:8,p:1};
SIM[276] = {m:"Wenn ich ein Amulett des Schattenbergmanns futtere, dann werde ich eine große Leuchte sein, nicht?",s:-1,r:"9255",l:5,p:0.6};
SIM[277] = {m:"Farles Getreide ist ein Grundnahrungsmittel, und außerdem Bio!",s:-1,r:"9255",l:13,p:0.7};
SIM[278] = {m:"Wenn DU Hunger bekommst, dann isst du was, stimmt\'s? Siehst du, mir geht\'s genauso!",s:-1,r:"9255",l:3,p:0.8};
SIM[279] = {m:"Wenn du mich weiter so mästest, sehe ich bald so aus wie der Kuhloss von Toelts!",s:-1,r:"9255",l:12,p:0.2};
SIM[280] = {m:"Ich hätte jetzt gerne ein kleines Verdauuungsamulett. Hast du keins dabei?",s:-1,r:"9255",l:6,p:0.5};
SIM[281] = {m:"Vielleicht verschont er dich, wenn du ihm einen Ring abgibst?",s:-1,r:"9255",l:7,p:0.8};
SIM[282] = {m:"Ich würde mich ja gerne geistig mit ihm duellieren, aber wie ich sehe, ist er unbewaffnet...",s:-1,r:"9255",l:11,p:1};
SIM[283] = {m:"Hallo! Bringst du mich heute zu Moon?",s:-1,r:"9255",l:15,p:0.4};
SIM[284] = {m:"Wie wär\'s mit einem kleinen kulinarischen Ausflug auf die Wabbit-Insel?",s:-1,r:"9255",l:9,p:0.4};
SIM[285] = {m:"Du bekommst das nur so gut hin, weil ich so geschickt bin!",s:-1,r:"9256",l:5,p:0.8};
SIM[286] = {m:"Neiiiin! Um der Götter willen! So wirst du niemals gewinnen! Ich hoffe, mein Schaden hat kein Gehirn genommen...",s:3,r:"9256",l:18,p:1};
SIM[287] = {m:"Was hätte ich denn deiner Meinung nach tun sollen? Ich bin nur ein Ring!",s:-1,r:"9256",l:11,p:0.6};
SIM[288] = {m:"Ein Ring ist gut. Zwei wären besser...",s:-1,r:"9256",l:4,p:0.5};
SIM[289] = {m:"Der Götter sind derer zwölf, aber ich bin einzigartig!",s:-1,r:"9256",l:12,p:0.2};
SIM[290] = {m:"Sieh mal zu, dass du an diesen Ring da rankommst. Der macht mir nämlich schöne Augen.",s:-1,r:"9256",l:10,p:0.4};
SIM[291] = {m:"Bitte leg dir doch mal was Weiches unter, bevor du dich schlafen legst, ja? Sonst krieg ich wieder blaue Flecke...",s:-1,r:"9256",l:8,p:0.7};
SIM[292] = {m:"Sag, bin ich nicht das schönste Schmuckstück auf der Welt der Zwölf?",s:-1,r:"9256",l:19,p:0.3};
SIM[293] = {m:"Oh! Du hast so sanfte Hände! Wer macht denn bei euch den Abwasch?",s:-1,r:"9256",l:16,p:0.2};
SIM[294] = {m:"Für mich bist du jemand ganz Besonderes!",s:-1,r:"9256",l:20,p:0.1};
SIM[295] = {m:"\"Ein Ring, sie alle zu beherrschen...\" Ha! Die Rede ist von mir!",s:-1,r:"9256",l:11,p:0.5};
SIM[296] = {m:"Keine Sorge: Alles wird gut!",s:-1,r:"9256",l:15,p:0.4};
SIM[297] = {m:"Darf ich dir ein kleines Geheimnis ins Ohr flüstern? Ja? Du bist mein liebster Schatz! Juhu!!!",s:-1,r:"9256",l:15,p:0.4};
SIM[298] = {m:"Ja ja, ignorier mich nur ruhig...",s:-1,r:"9256",l:2,p:0.4};
SIM[299] = {m:"Hilfe! Ich will nicht mein Lebtag lang in einer dunklen Truhe auf der Bank herumliegen!",s:-1,r:"9256",l:3,p:0.2};
SIM[300] = {m:"Gib\'s zu, du hasst mich! Du willst sehen, wie ich am Hunger zu Grunde gehe...",s:-1,r:"9256",l:6,p:0.2};
SIM[301] = {m:"Ich habe Hunger! Wo ist der Gelano, den du mir versprochen hast?",s:-1,r:"9256",l:9,p:0.5};
SIM[302] = {m:"Gut gegessen ist halb verdaut! Ein Piepmatz-Ring käme jetzt gerade richtig...",s:-1,r:"9256",l:8,p:1};
SIM[303] = {m:"Gib mir den gueneyrösen Ring aller Ringe zu futtern, und ich werde dich zum reichsten Geschöpf der Welt machen!",s:-1,r:"9256",l:13,p:0.2};
SIM[304] = {m:"Du brauchst mich gar nicht so zu mästen, weißt du? Ich habe nämlich gar keinen Bandwurm!",s:-1,r:"9256",l:14,p:0.8};
SIM[305] = {m:"Es gibt fast 6 Milliarden Amaknianer...Und ausgerechnet dir muss ich begegnen...",s:3,r:"9256",l:6,p:0.5};
SIM[306] = {m:"Hier der Plan: Du hältst ihn fest, während ich Verstärkung suche, ok?",s:-1,r:"9256",l:17,p:0.7};
SIM[307] = {m:"Tut mir leid... Ich glaube, ich habe keine... Kraft... zu... kämpfen...",s:-1,r:"9256",l:7,p:0.8};
SIM[308] = {m:"Endlich bist du zurück! Ich dachte schon, du hättest mich vergessen...",s:-1,r:"9256",l:10,p:0.4};
SIM[309] = {m:"Leg mich das nächste Mal besser ab, bevor du dir dein Hinterteil kratzt!",s:-1,r:"9256",l:1,p:1};
SIM[310] = {m:"Zeig\'s ihm! Tritt ihm auf die Füße! Beiß ihn in den Arm und in den Hintern!",s:-1,r:"9233",l:4,p:0.5};
SIM[311] = {m:"He du! Warum greifst du meinen Besitzer an?",s:-1,r:"9233",l:9,p:0.3};
SIM[312] = {m:"Endlich! Endlich kommst du wieder zu dir! Das nenne ich ausgleichende Gerechtigkeit!",s:-1,r:"9233",l:10,p:0.8};
SIM[313] = {m:"Bald hab ich Geburtstag! Krieg ich dann einen Naschumhang von dir?",s:-1,r:"9233",l:2,p:0.2};
SIM[314] = {m:"Mein ehemaliger Besitzer hat das besser hinbekommen! Naja, war ja auch ein Sram...",s:-1,r:"9233",l:11,p:0.4};
SIM[315] = {m:"Ich habe alles getan, um dich zu beschützen, aber es war nicht genug...",s:-1,r:"9233",l:13,p:0.2};
SIM[316] = {m:"Niemand beschützt dich so gut, wie ich!",s:-1,r:"9233",l:19,p:0.7};
SIM[317] = {m:"Wenn ich gekonnt hätte, dann hätte ich ihm eine gepfeffert! Das kannst du mir ruhig glauben!",s:-1,r:"9233",l:14,p:0.5};
SIM[318] = {m:"Es wäre ziemlich nett, wenn du dich von mir erheben würdest...!",s:3,r:"9233",l:6,p:0.8};
SIM[319] = {m:"Ich kann dich vor vielen Dingen bewahren, aber nicht vor deiner eigenen Dummheit, weißt du?",s:-1,r:"9233",l:4,p:0.7};
SIM[320] = {m:"Mir ist kalt...! Warum bin eigentlich immer ich dafür zuständig, dich zu wärmen, und nicht umgekehrt?!",s:-1,r:"9233",l:1,p:0.4};
SIM[321] = {m:"Weißt du was? Du solltest mich rot anmalen und blaue Strumpfhosen tragen. Dann hätten wir mal ein bisschen Spaß, so zur Abwechslung.",s:-1,r:"9233",l:5,p:0.2};
SIM[322] = {m:"Wenn du wüsstest, was die Leute alles hinter deinem Rücken erzählen...",s:-1,r:"9233",l:7,p:0.2};
SIM[323] = {m:"Kom her und kuschel dich an, dann wird dir gleich wärmer!",s:-1,r:"9233",l:12,p:0.4};
SIM[324] = {m:"Selbst König Allister kann nicht solch schöne Schmuckstücke wie mich sein eigen nennen!",s:-1,r:"9233",l:20,p:0.2};
SIM[325] = {m:"Ich bin die Personifizierung aller glorreichen Majestäten höchstpersönlich!",s:-1,r:"9233",l:15,p:0.3};
SIM[326] = {m:"He! Ich bin weder ein Handtuch noch ein Wischlappen! Ich bin ein Umhang!!!",s:-1,r:"9233",l:18,p:1};
SIM[327] = {m:"Ich habe grade so einen Wurm im Ohr... \"Die Mächte um sich schlagen / Wir schau\'n uns an und wissen / Wir müssen nichts sagen\"... Passt, ne?",s:-1,r:"9233",l:13,p:0.2};
SIM[328] = {m:"Hilfe! Ich will nicht in den Schmutzige-Wäsche-Beutel! Ich sage auch nie nie mehr, dass du ein hässlicher... äh... Piepmatz bist!",s:-1,r:"9233",l:13,p:0.4};
SIM[329] = {m:"Das nächste mal, wenn du mal musst, denke bitte daran, dass ich hinter dir stehe, ja?",s:-1,r:"9233",l:7,p:1};
SIM[330] = {m:"Gut gegessen ist halb verdaut! Ein Piepmatz-Umhang käme jetzt gerade richtig...",s:-1,r:"9233",l:8,p:1};
SIM[331] = {m:"Auch Mäßigung im Übermaß ist schädlich! Wenn du mich weiter so auf Diät hältst, werde ich noch wie ein chogrelotischer Heenchenumhang enden...",s:-1,r:"9233",l:12,p:0.5};
SIM[332] = {m:"Gelacapes sind nicht übel. Wenn sie nur nicht so an den Zähnen kleben würden...",s:-1,r:"9233",l:9,p:0.4};
SIM[333] = {m:"Ich glaube, ich habe mir jetzt ausreichend Nahrungsreserven für den Winterschlaf zugelegt.",s:-1,r:"9233",l:10,p:0.6};
SIM[334] = {m:"Ok, du stürzt dich auf den da rechts, und ich mich auf den da links!",s:-1,r:"9233",l:17,p:1};
SIM[335] = {m:"Lass ihn mir! Bitte lass ihn mir!",s:-1,r:"9233",l:16,p:0.8};
SIM[336] = {m:"Pfff... Dieser Gegner verdient noch nicht einmal, dass ich ihn ansehe!",s:-1,r:"9233",l:18,p:0.5};
SIM[337] = {m:"Ist das \'n Er oder \'ne Sie? Von hier aus kann ich das nicht so gut erkennen...",s:2,r:"9233",l:13,p:0.3};
SIM[338] = {m:"Irgendwie riecht\'s hier unangenehm... Bist du nicht grad eben reingekommen?",s:-1,r:"9233",l:3,p:0.2};
SIM[339] = {m:"Glaub mir bitte: das hier ist nur ein trauriges Missverständnis...!",s:-1,r:"9234",l:6,p:0.4};
SIM[340] = {m:"Also, da sag ich doch glattweg \"Hut ab!\"",s:-1,r:"9234",l:7,p:0.5};
SIM[341] = {m:"Bald hab ich Geburtstag! Krieg ich dann einen Naschelm von dir?",s:-1,r:"9234",l:2,p:0.2};
SIM[342] = {m:"Wenn du den HmmMmmMmmm tragen würdest, hätte ich das ja noch verstanden, aber so... Ich finde, das geht ganz und gar nicht!",s:3,r:"9234",l:18,p:0.3};
SIM[343] = {m:"Hör auf, so rumzuspinnen!",s:3,r:"9234",l:11,p:0.5};
SIM[344] = {m:"Bei den Göttern! Welch ein Schlag! Lass es besser bleiben, das Versuchen ist der erste Schritt zum Versagen...",s:-1,r:"9234",l:16,p:0.5};
SIM[345] = {m:"Dieses Individuum hat es einfach nicht verdient, an deiner Seite zu kämpfen.",s:-1,r:"9234",l:15,p:0.3};
SIM[346] = {m:"Muss ich jetzt auch so tun, als sei ich tot?",s:-1,r:"9234",l:5,p:0.4};
SIM[347] = {m:"Keine Frage, ich stehe dir ausgezeichnet!",s:-1,r:"9234",l:15,p:0.8};
SIM[348] = {m:"Ersten: Ich bin lebendig. Zweitens: Ich habe meinen Sitz auf deinem Kopf. Ergebnis: Ergo tuum cerebrum sum!",s:-1,r:"9234",l:16,p:0.5};
SIM[349] = {m:"Selbst König Allister muss neidisch auf dich sein, weil du mich besitzt!",s:-1,r:"9234",l:13,p:0.2};
SIM[350] = {m:"Schau dir mal diesen Hut an! Der hat null Klasse... Genau richtig für mich!",s:2,r:"9234",l:9,p:0.5};
SIM[351] = {m:"Weißt du was? Von hier aus kann ich sehen, was du in deinen Ohren hast... Das sieht ganz und gar nicht gut aus...",s:-1,r:"9234",l:6,p:0.2};
SIM[352] = {m:"Du bekommst das nur so gut hin, weil ich dich auf Schritt und Tritt begleite.",s:-1,r:"9234",l:20,p:0.4};
SIM[353] = {m:"Wäre ich ein Umhang, würde ich dich wärmen. Leider bin ich nur eine bescheidene Kopfbedeckung...",s:-1,r:"9234",l:10,p:0.6};
SIM[354] = {m:"Die Sadida-Mädchen sind wohlgeformt, dass kann man wohl sagen. Genau wie ich!",s:-1,r:"9234",l:17,p:0.2};
SIM[355] = {m:"Selbst Rushus Hörner sind nur billiger Tand im Vergleich zu meinem Glanz!",s:-1,r:"9234",l:19,p:0.1};
SIM[356] = {m:"Ich hatte schon interessantere Gespräche mit Wollpullis...",s:-1,r:"9234",l:20,p:0.1};
SIM[357] = {m:"Gib\'s zu, wir wissen zwar nicht, wohin wir wollen, werden aber als erste da sein.",s:1,r:"9234",l:14,p:0.3};
SIM[358] = {m:"Andere wären begeistert, wenn sie mich an ihrer Seite wüssten!",s:-1,r:"9234",l:5,p:0.2};
SIM[359] = {m:"Ich schütze deinen Kopf vor der Sonne, aber wer schützt mich?",s:-1,r:"9234",l:10,p:0.4};
SIM[360] = {m:"Gut gegessen ist halb verdaut! Ein Piepmatz-Hut käme jetzt gerade richtig...",s:-1,r:"9234",l:8,p:1};
SIM[361] = {m:"Groß ist deine Schönheit! Und noch größer mein Hunger!!!",s:-1,r:"9234",l:4,p:0.6};
SIM[362] = {m:"Was meinst du, ob ich so einen Dofus runterkriege?",s:-1,r:"9234",l:11,p:0.3};
SIM[363] = {m:"Sei gewarnt! Wenn du mir mit einem Pilzkäppchen ankommst, dann muss ich mich übergeben...",s:-1,r:"9234",l:12,p:0.2};
SIM[364] = {m:"Pfui, so ein Haufen Flöhe hier! Wenn die anfangen zu husten, dann hör ich nicht mehr, wenn du mich zum Futtern rufst!",s:-1,r:"9234",l:1,p:0.1};
SIM[365] = {m:"Könntest du bitte ab und zu mal dran denken, dir die Haare zu waschen?",s:-1,r:"9234",l:3,p:0.2};
SIM[366] = {m:"Denke dran: Feinde können grausam sein!",s:-1,r:"9234",l:8,p:0.2};
SIM[367] = {m:"Einen Moment lang dachte ich, es käme ein neuer Feind vorbei, aber wie ich sehe, ist es nur ein armer Verirrter.",s:-1,r:"9234",l:7,p:0.3};
