A.s[29] = {n:"Discepolo di Brumario",d:"Spinti da uno smodato gusto per il lugubre, i discepoli di Brumario devono dimostrare buone conoscenze nella mescolanza degli ingredienti mortiferi.",o:8,av:20,f:[[10,1]]};
A.s[30] = {n:"Spia Oscura",d:"Coperta dal suo mantello di tenebre, la Spia oscura farà versare un mare di lacrime e farà sanguinare le spade, e non il contrario.",o:8,av:40,f:[[10,2]]};
