A.b[0] = {s:0,e:10,n:"Requiem",d:"Il tuo schieramento è talmente debole che la sua sopravvivenza è minacciata."};
A.b[1] = {s:10,e:20,n:"Superstite",d:"Il tuo schieramento sopravvive difficilmente in ambienti molto ostili."};
A.b[2] = {s:20,e:30,n:"Guerriglia",d:"Il tuo schieramento resiste ancora e sempre all\'invasore!"};
A.b[3] = {s:30,e:40,n:"Minoranza",d:"Il tuo schieramento è in ginocchio, ma non tarderà a rialzarsi."};
A.b[4] = {s:40,e:50,n:"Coabitazione",d:"L\'equilibrio del Mondo sfavorisce il tuo schieramento."};
A.b[5] = {s:50,e:60,n:"Status quo",d:"Il tuo schieramento domina di poco la Bilancia del Mondo."};
A.b[6] = {s:60,e:70,n:"Dominio",d:"I tuoi nemici non osano più uscire di casa;\r\n            il tuo schieramento domina."};
A.b[7] = {s:70,e:80,n:"Tirannia",d:"La potenza del tuo schieramento è tale da farti dubitare dell\'esistenza di nemici."};
A.b[8] = {s:80,e:90,n:"Conquistatore",d:"Il tuo schieramento non ha più predatori e la guerra è quasi vinta."};
A.b[9] = {s:90,e:100,n:"Apogeo",d:"Il tuo schieramento è all\'apogeo e (probabilmente) i tuoi nemici non esistono più."};
A.s[0] = {n:"Neutro",d:"",o:0,av:0,f:[]};
A.s[1] = {n:"Neofita",d:"Le nuove recrute hanno scelto di proteggere la vedova e l\'orfano. Tuttavia, il loro addestramento è appena cominciato e non hanno ancora scelto una specializzazione. Le loro ambizioni e le loro attitudi li aiuteranno nella scelta.",o:1,av:0,f:[]};
A.s[2] = {n:"Discepolo di Menalt",d:"Desiderosi di sviluppare le loro attitudini guerrigliere, i discepoli di Menalt devono dimostrare di possedere forza e coraggio durante lunghi e dolorosi allenamenti.",o:2,av:20,f:[[22,1,[200]],[21,1]]};
A.s[3] = {n:"Scudiero",d:"Uno Scudiero degno di questo nome non si preoccupa della stanchezza;\r\n            e lo dimostrerà ogni giorno durante allenamenti lunghi e dolorosi.",o:2,av:40,f:[[22,2,[400]],[21,2]]};
A.s[4] = {n:"Cavaliere della Speranza",d:"",o:2,av:60,f:[[21,3],[22,3,[600]]]};
A.s[5] = {n:"Campione Meraviglioso",d:"",o:2,av:80,f:[[22,4,[800]],[21,4]]};
A.s[6] = {n:"Eroe Leggendario",d:"",o:2,av:100,f:[[21,5],[22,5,[1000]]]};
A.s[7] = {n:"Discepolo di Jiva",d:"Desiderosi di sviluppare i loro poteri magici, i discepoli di Jiva devono scoprire dentro se stessi la forza spirituale che li guiderà nella apprendimento della magia.",o:3,av:20,f:[[23,1]]};
A.s[8] = {n:"Apprendista",d:"Colui o colei che rivendica lo stato di Apprendista deve meritare tale titolo onorifico curando i feriti e i moribondi nel pieno della battaglia.",o:3,av:40,f:[[23,2]]};
A.s[9] = {n:"Adepto degli Scritti",d:"",o:3,av:60,f:[[23,3]]};
A.s[10] = {n:"Maestro delle Pergamene",d:"",o:3,av:80,f:[[23,4]]};
A.s[11] = {n:"Guardiano del Sapere",d:"",o:3,av:100,f:[[23,5]]};
A.s[13] = {n:"Discepolo di Silvosse",d:"Desiderosi di sviluppare le loro qualità di spia, i discepoli di Silvosse devono imparare a raccogliere informazioni utili senza dare nell\'occhio.",o:4,av:20,f:[[10,1]]};
A.s[14] = {n:"Spia",d:"Autoproclamarsi spia è roba da niente, solo i fatti contano. Immobile come una quercia, silenziosa come una pietra, solo una Spia veramente esperta potrà venire a conoscenza di tutto ciò che accade nella regione.",o:4,av:40,f:[[10,2]]};
A.s[15] = {n:"Cacciatore di Rinnegati",d:"",o:4,av:60,f:[[10,3]]};
A.s[16] = {n:"Assassino Supremo",d:"",o:4,av:80,f:[[10,4]]};
A.s[17] = {n:"Maestro delle Illusioni",d:"",o:4,av:100,f:[[10,5]]};
A.s[18] = {n:"Neofita",d:"Le nuove recrute sono state plasmate nella melma più immonda che ci sia. Anche se già altamente sleali, non sono ancora dei nemici temibili a causa della loro stoltezza. L\'addestramento e le specializzazioni che seguiranno dovrebbero rimediare a questo inconveniente.",o:5,av:0,f:[]};
A.s[19] = {n:"Discepolo di Djaul",d:"Spinti dall\'amore per l\'odio, i discepoli di Djaul devono imparare che in battaglia non ci sono nemici, ma solo teste da spaccare.",o:6,av:20,f:[[22,1,[200]],[21,1]]};
A.s[20] = {n:"Tagliagole",d:"Essere un Tagliagole al soldo di Djaul richiede grandi qualità fisiche e un\'immoralità senza limiti.",o:6,av:40,f:[[21,2],[22,2,[400]]]};
A.s[21] = {n:"Cavaliere della Disperazione",d:"",o:6,av:60,f:[[22,3,[600]],[21,3]]};
A.s[22] = {n:"Campione del Caos",d:"",o:6,av:80,f:[[21,4],[22,4,[800]]]};
A.s[23] = {n:"Eroe dell\'Apocalisse",d:"",o:6,av:100,f:[[22,5,[1000]],[21,5]]};
A.s[24] = {n:"Discepolo di Ecate",d:"Spinti dal vizio, i discepoli di Ecate devono dimostrare la loro capacità di raccogliere informazioni e disinformare.",o:7,av:20,f:[[23,1]]};
A.s[25] = {n:"Apprendista Oscuro",d:"Colui o colei che rivendica lo stato di Apprendista deve meritare tale titolo onorifico stregando i vivi, i morti e persino di morti viventi.",o:7,av:40,f:[[23,2]]};
A.s[26] = {n:"Adepto dei Dolori",d:"",o:7,av:60,f:[[23,3]]};
