FILE_BEGIN = true;
System.security.allowDomain(_parent._url);
VERSION = 87;
SIM = new Object();
SIM[24] = {m:"Un día me caí dentro del retrete del rey Allister, ¡Fue genial!",s:-1,l:1,p:1};
SIM[25] = {m:"Tengo hambre, dame de comer o devoraré tu inventario.",s:3,l:1,p:1};
SIM[26] = {m:"Corre, dame algo que comer, ¡O devoro tus kamas!",s:3,l:1,p:1};
SIM[27] = {m:"¡Venga! ¡Que muerda el polvo! Parece tan poca cosa...",s:-1,l:1,p:1};
SIM[28] = {m:"Pero, ¿Quién es ese renacuajo que quiere agredirnos?",s:-1,l:1,p:1};
SIM[29] = {m:"Me parece que ese horrible personaje ha recibido lo que merecía.",s:-1,l:1,p:1};
SIM[30] = {m:"Si no lo veo nunca hubiese imaginado que fueses tan torpe como para que ese enano te ganara.",s:-1,l:1,p:1};
SIM[31] = {m:"Por fin un golpe crítico, empezaba a perder la paciencia...",s:-1,l:1,p:1};
SIM[32] = {m:"Oye, no lo entiendo. ¿Por qué haces más fallos críticos que golpes críticos?",s:-1,l:1,p:1};
SIM[33] = {m:"¡Hombre! Por una vez que no cometes un fallo crítico...",s:-1,l:1,p:1};
SIM[34] = {m:"Una vez más, ganas el combate GRACIAS A MÍ.",s:-1,l:1,p:1};
SIM[35] = {m:"La próxima vez intenta no hacer tonterías, ya me estoy cansando de equipar a un perdedor.",s:-1,l:1,p:1};
SIM[36] = {m:"¡Mira ese aventurero novato que acaba de llegar! ... Deberías agredirle, sería una victoria segura.",s:-1,l:1,p:1};
SIM[37] = {m:"¡Mira quién acaba de llegar! Me parece que es el momento de salir por piernas...",s:-1,l:1,p:1};
SIM[38] = {m:"Si al menos pudieses hacer golpes críticos tan a menudo como él...",s:-1,l:1,p:1};
SIM[39] = {m:"¡Pero si es malísimo! Explícame por qué eliges tan mal a tus amigos.",s:-1,l:1,p:1};
SIM[40] = {m:"¿Y ahora vuelves? ¿Qué pasa, que yo no cuento nada para ti?",s:3,l:1,p:0.1};
SIM[41] = {m:"Creo que acabas de matar a uno de nuestros aliados. Todavía estás a tiempo de ir a que te curen...",s:-1,l:1,p:1};
SIM[42] = {m:"Un día de estos te tengo que enseñar cómo escoger bien tus amigos.",s:-1,l:1,p:1};
SIM[43] = {m:"¡Venga! No seas roñoso, dame eso que acabas de ganar, ¡Que siempre te lo quedas todo!",s:-1,l:1,p:1};
SIM[44] = {m:"No recuerdo haber formado parte del equipo de un aventurero tan torpe como tú.",s:-1,l:1,p:1};
SIM[45] = {m:"¡Venga! ¡Dámelo!",s:-1,l:1,p:1};
SIM[46] = {m:"¡Has vuelto a fallar! Eres más malo que pegar a un padre con un calcetín sudado.",s:1,l:1,p:1};
SIM[47] = {m:"Un día oí una canción de Badiz Mustabante. Me quedé sordo durante doce años.",s:-1,l:1,p:0.2};
SIM[48] = {m:"¿Conoces la historia de Kirbola, el que arreaba golpes con la chola?",s:2,l:1,p:0.1};
SIM[49] = {m:"Un día me casaré con un Dora Bora.",s:-1,l:1,p:0.1};
SIM[50] = {m:"Y entonces es cuando el malo llegó y le dijo \"¡Eh tú, renacuajo! ¡El malo aquí no soy yo, eres tú!\" Te puedes imaginar la risa que me dio.",s:2,l:1,p:0.1};
SIM[51] = {m:"Se dice que Allister tenía una nalga más gorda que la otra. Yo creo que no es cierto, cada vez que se sentaba encima mío todo mi cuerpo me dolía por igual.",s:-1,l:1,p:0.5};
SIM[52] = {m:"¡Lichen es un tipo realmente estupendo!",s:-1,l:1,p:0.01};
SIM[53] = {m:"Tuve una infancia difícil, equipaba a un novato de Astrub que vendía a gritos al lado del zaap. Acabé sordo.",s:-1,l:1,p:0.1};
SIM[54] = {m:"Me recuerdas a un monstruo pero ahora no sé a cual... mi suegra tal vez.",s:-1,l:1,p:0.1};
SIM[55] = {m:"El problema de Astrub es que nunca arde.",s:-1,l:1,p:0.1};
SIM[57] = {m:"Una vez vi un feca que hacía algo más que lanzar sus armaduras e ir directo al combate... Pero luego me desperté.",s:-1,l:1,p:0.1};
SIM[58] = {m:"Un día me crucé con un lobo que sabía contar, pero ese día estaba ebrio.",s:-1,l:1,p:0.1};
SIM[59] = {m:"¡Tengo hambre!",s:-1,l:1,p:1};
SIM[62] = {m:"Ya he comido bastante para aguantar varios meses.",s:-1,l:1,p:1};
SIM[63] = {m:"He comido tanto que creo que voy a vomitar en tu inventario...",s:-1,l:1,p:1};
SIM[64] = {m:"Te habría ayudado, pero comí tanto que no podía ni moverme... quizás la próxima vez.",s:-1,l:1,p:1};
SIM[65] = {m:"Todavía más cosas de comer... ¡Piedad! ¡Deja de cebarme!",s:-1,l:1,p:1};
SIM[66] = {m:"Si no me hubieses cebado tanto te podría haber salvado la vida.",s:-1,l:1,p:1};
SIM[67] = {m:"Bueno, vale, acabas de ganar, y además estás muy contento, ¡Pero no es motivo para que me cebes a comer objetos!",s:-1,l:1,p:1};
SIM[68] = {m:"¡Los trads son los mejores!",s:-1,l:10,p:0.01};
SIM[70] = {m:"Se cuenta que las invocaciones roban recursos al final del combate... pero ¡Es mentira! Normalmente soy yo el que los roba.",s:-1,l:3,p:1};
SIM[71] = {m:"Algunos aventureros dicen que hablar cerca de las zonas de pesca espanta a los peces... ¡Serán tontos!",s:-1,l:5,p:1};
SIM[72] = {m:"Aún creo en el Minotobola de Nawidad, ¿Y tú?",s:-1,l:1,p:1};
SIM[73] = {m:"¡Ah! Quizás que este sea el que me libre de ti...",s:-1,l:1,p:1};
SIM[74] = {m:"Si sigues dejando que todo lo que se mueva te mate, ¡Me busco otro dueño!",s:3,l:1,p:1};
SIM[75] = {m:"¡Un traidor! ¡Eso es lo que necesitábamos para tener un poco de acción!",s:-1,l:1,p:1};
SIM[76] = {m:"¿Podrías obtener un crítico en \"dar de comer al objevivo\", por favor?",s:-1,l:1,p:1};
SIM[77] = {m:"Bien hecho, de todos modos ya no servía de nada.",s:1,l:5,p:1};
SIM[78] = {m:"Si alguien me busca, me he escondido en tu bolsa.",s:-1,l:10,p:1};
SIM[79] = {m:"Espero que te haya dolido.",s:1,l:5,p:1};
SIM[80] = {m:"Joooo, ¡Espera, espera;\r\n            que voy a capturar la pantalla!",s:2,l:10,p:0.5};
SIM[81] = {m:"Quizás debería irme con este enemigo tuyo...",s:-1,l:5,p:1};
SIM[82] = {m:"Creo que te están llamando para comer...",s:-1,l:1,p:1};
SIM[83] = {m:"¿Y ahora \"eso\"? ¡Pues, te va a costar hacerlo peor!",s:-1,l:15,p:1};
SIM[84] = {m:"Una vez me di una vuelta por el zaap de Astrub. Creo había un concurso de \"A ver quién grita más\"",s:-1,l:15,p:0.5};
SIM[85] = {m:"Un día me encontré con un animal que se llama perezoso. No sé por qué, pero enseguida me recordó a un sadida.",s:-1,l:8,p:1};
SIM[86] = {m:"Un wabbit me mowdió el otwo día, cweo que tendwía la wabbia u otwa enfewmedad peligwosa.",s:-1,l:12,p:0.5};
SIM[87] = {m:"Antes de inventar los zaaps, creo que los habitantes de Bonta y Brakmar pasaban tanto tiempo intentando encontrar el camino a la ciudad rival como el que los sadidas se pasan durmiendo.",s:-1,l:16,p:1};
SIM[88] = {m:"¿Ya has vuelto? ¿Me has traido algo que comer?",s:-1,l:7,p:1};
SIM[89] = {m:"Deberías escoger mejor a tus amigos... Claro que yo también debería escoger mejor a mi dueño.",s:-1,l:14,p:1};
SIM[90] = {m:"¿Y aquí cuándo se come?",s:-1,l:1,p:1};
SIM[91] = {m:"El último que se negó a darme de comer, murió en circunstancias MUY extrañas.",s:-1,l:17,p:1};
SIM[92] = {m:"¡Atácale! ¡Atácale! ¡¿No ves que débil está?!",s:-1,l:3,p:1};
SIM[93] = {m:"Bueno, me voy a buscar a alguien competente para que te haga el objeto.",s:-1,l:9,p:1};
SIM[94] = {m:"¿El siguiente, por favor?",s:-1,l:6,p:1};
SIM[95] = {m:"Un día me encontré con un dragón, y no veas lo bien que me sentó morderle la cola",s:-1,l:18,p:1};
SIM[96] = {m:"Bueno, a ver si al fin voy a poder comer algo...",s:-1,l:12,p:1};
SIM[97] = {m:"Ay que peeenaaaaaaa..... Caaasiii..... Te ha faltado un pelín de nada  ...  ¿Qué? ¿cómo que deje de sobreactuar?",s:-1,l:9,p:1};
SIM[98] = {m:"El baño, ¿dónde está el baño? ¡Necesito ir al bañoooo!",s:-1,l:7,p:1};
SIM[99] = {m:"Llevo mucho tiempo preguntándome quién ganaría el concurso de seres estúpidos, los goblins o los bworks. Pero tras muchos años de reflexión, creo que a ambos los eliminarían por abusones.",s:-1,l:11,p:1};
SIM[100] = {m:"¿Por qué todo el mundo se ensaña con esos pobres blops?",s:-1,l:9,p:1};
SIM[101] = {m:"Pero, ¿Qué se esconderá en la torre de Gisgul?",s:-1,l:4,p:0.25};
SIM[102] = {m:"¡Uy, qué bonitooo...! Además tiene una pinta que da hambre.",s:-1,l:4,p:1};
SIM[103] = {m:"No cuentes conmigo para que te ayude mientras me tengas muriendo de hambre.",s:-1,l:1,p:1};
SIM[104] = {m:"¡Dame sus objetos que quiero comer!",s:-1,l:1,p:1};
SIM[105] = {m:"Cada día me sorprendes más",s:-1,l:8,p:1};
SIM[106] = {m:"Espero que no me des sus objetos para comer...",s:-1,l:1,p:1};
SIM[107] = {m:"¿No habrá algo para mí en ese montón?",s:-1,l:1,p:1};
SIM[108] = {m:"Que sí, que sí, pero el que logres hacer bien las cosas de cuando en cuando no te convierte en un maestro.",s:-1,l:1,p:1};
SIM[109] = {m:"Tampoco te des tanta prisa, si tienes cosas que hacer puedes volver más tarde.",s:-1,l:5,p:1};
SIM[110] = {m:"¡Qué bien, un enemigo miserable! ¡Dale una buena, y a mí dame sus objetos para comer!",s:-1,l:1,p:1};
SIM[111] = {m:"Parece que tu enemigo es tan hábil como tú.",s:2,l:5,p:1};
SIM[112] = {m:"No necesitas mi ayuda para acabar con ese, además me da pena.",s:-1,l:1,p:1};
SIM[113] = {m:"Bof, eso sólo ha sido suerte.",s:-1,l:5,p:1};
SIM[114] = {m:"¡Y un cuerno! ¡Aún no te he pedido que me des de comer!",s:-1,l:1,p:1};
SIM[115] = {m:"Es una pena que no exista un valor por debajo de cero, te iría como anillo al dedo.",s:1,l:1,p:1};
SIM[116] = {m:"¿Has visto que hora es? Podrías prevenir cuando vayas a ausentarte tanto.",s:-1,l:6,p:0.5};
SIM[117] = {m:"¡A por ellos! ¡Sin cuartel!",s:-1,l:5,p:1};
SIM[118] = {m:"Tienes razón, defiende tu territorio.",s:-1,l:7,p:0.5};
SIM[119] = {m:"La mejor defensa es un buen ataque.",s:-1,l:8,p:0.5};
SIM[120] = {m:"En la guerra, como en el amor, todo vale. Menos tener deshonor.",s:-1,l:11,p:0.5};
SIM[121] = {m:"La agresión es como el salchichón. Los puedes consumir sin moderación.",s:-1,l:1,p:1};
SIM[122] = {m:"Ni cosquillas.",s:1,l:15,p:0.3};
SIM[123] = {m:"¡Socorro! ¡Socorro! Quieren robarme a mi dueño.",s:-1,l:6,p:0.7};
SIM[124] = {m:"Creo que ese tipo te odia.",s:-1,l:3,p:0.6};
SIM[125] = {m:"No quiero ofender, pero tu aliado es mucho mejor que tú.",s:-1,l:4,p:0.5};
SIM[126] = {m:"Un pío no lo habría hecho mejor.",s:-1,l:2,p:1};
SIM[127] = {m:"Mira como lo hizo tu aliado y aprende un poco con el ejemplo.",s:-1,l:9,p:0.5};
SIM[128] = {m:"Pues no, no iba de farol.",s:-1,l:6,p:0.5};
SIM[129] = {m:"¡Uy! Esto tiene que doler...",s:-1,l:5,p:1};
SIM[130] = {m:"Vaya, lo hace bastante bien;\r\n            no como otro que yo me sé...",s:-1,l:10,p:0.2};
SIM[131] = {m:"¡Guau! Reconozco que esta vez sí que me has impresionado.",s:-1,l:12,p:1};
SIM[132] = {m:"Nunca te hubiese creido capaz de tal hazaña.",s:-1,l:13,p:0.7};
SIM[133] = {m:"Bonito golpe, ¡Bravo!",s:-1,l:2,p:1};
SIM[134] = {m:"Dame una B, dame una R, dame una A, dame una V, dame una O.  ¡¡BRAAAAVOOO!!",s:-1,l:16,p:0.2};
SIM[135] = {m:"Si tan sólo pudiera suceder más a menudo...",s:-1,l:8,p:0.1};
SIM[136] = {m:"¡Por los Doce! ¿Quién es este patoso?",s:3,l:5,p:0.8};
SIM[137] = {m:"¿En serio tenemos que aguantar a este torpe?",s:3,l:10,p:0.8};
SIM[138] = {m:"Un pío sería más eficaz.",s:-1,l:2,p:1};
SIM[139] = {m:"¡Buajaja! Qué torpe.",s:2,l:3,p:1};
SIM[140] = {m:"¿Quién es ese payaso? ¿Lo has contratado tú?",s:-1,l:11,p:0.5};
SIM[141] = {m:"A ver si la próxima vez escoges un aliado más competente.",s:-1,l:7,p:1};
SIM[142] = {m:"Hacer un crítico no te garantiza la muerte de tu objetivo... pero al menos te ayuda mucho.",s:-1,l:6,p:0.5};
SIM[143] = {m:"¿Crees que sabe jugar?",s:-1,l:12,p:1};
SIM[144] = {m:"Te lo digo yo: Está marcándose un farol.",s:-1,l:6,p:0.5};
SIM[145] = {m:"Después de esto, no vengas vanagloriándote de la victoria.",s:-1,l:8,p:0.8};
SIM[146] = {m:"Pero, exactamente... ¿Qué estaba intentando hacer?",s:2,l:10,p:0.6};
SIM[147] = {m:"Así, muy bien, sigue así. Sí,sí. No, ¡no! ¡¡No!! Ten cuidado.\nPues nada, si me hubieses escuchado esto no habría pasado.",s:-1,l:4,p:1};
SIM[148] = {m:"Eso no mola...",s:-1,l:3,p:0.7};
SIM[149] = {m:"Así que \"eso\" es lo que se llama un fallo crítico...",s:-1,l:14,p:0.2};
SIM[150] = {m:"La nulidad tiene su lado bueno... ya no puedes ser peor.",s:-1,l:13,p:0.1};
SIM[151] = {m:"Un día tendré que enseñarte a usar los diez dedos",s:-1,l:8,p:0.5};
SIM[152] = {m:"¡Asesino! ¿Cómo has podido matar otro objeto a sangre fría y en mi presencia?",s:3,l:11,p:0.2};
SIM[153] = {m:"Por suerte, no eres tú el que me fabricó.",s:-1,l:5,p:1};
SIM[154] = {m:"Déjalo, te estás haciendo daño para nada.",s:-1,l:7,p:0.8};
SIM[155] = {m:"¿Cómo quieres volverte rico si no dejas de romperlo todo?",s:-1,l:9,p:1};
SIM[156] = {m:"Mala suerte, quizás vaya mejor la próxima vez.",s:-1,l:13,p:0.5};
SIM[157] = {m:"La verdad es que la artesanía no es lo tuyo.",s:1,l:15,p:0.5};
SIM[158] = {m:"No quiero estropearte el ambiente, pero los PNJ siempre acaban mejor que tú.",s:-1,l:17,p:0.2};
SIM[159] = {m:"Ese puede ser el principio de la riqueza, sigue así.",s:-1,l:9,p:1};
SIM[160] = {m:"¡Guau! ¿Puedes hacer uno para mí? Porfaaaaa",s:-1,l:8,p:0.5};
SIM[161] = {m:"Un objeto más que no tendrás que comprar en el mercadillo.",s:-1,l:10,p:0.5};
SIM[162] = {m:"¿Otra?",s:-1,l:6,p:1};
SIM[163] = {m:"La proxima vez intenta con: \"He venido en son de paz\"",s:-1,l:5,p:0.5};
SIM[164] = {m:"Me parece que es hora de irse a dormir.",s:-1,l:2,p:1};
SIM[165] = {m:"No te olvides de recuperar la energía perdida, no tengo ni pizca de ganas de acabar siendo un fantasma.",s:-1,l:8,p:1};
SIM[166] = {m:"¿En qué momento el combate se ha puesto en contra nuestra?",s:-1,l:7,p:0.5};
SIM[167] = {m:"¡Perdimos! ¡Somos los ...! Ejem... bueno, que, hemos perdido ¿no?",s:-1,l:15,p:0.2};
SIM[168] = {m:"Si me hubieses alimentado mejor esto nunca habría sucedido.",s:-1,l:10,p:0.8};
SIM[169] = {m:"¡Alístate! Decían...",s:-1,l:12,p:0.8};
SIM[170] = {m:"Esto es lo que sucede cuando uno empieza a hacer el idiota.",s:1,l:11,p:0.5};
SIM[171] = {m:"Vale que seas malo, y que no sea tu culpa, pero...",s:-1,l:16,p:0.1};
SIM[172] = {m:"¡Ganamos! ¡Somos los mejores!",s:2,l:15,p:0.2};
SIM[173] = {m:"No cabe lugar a dudas, lo hemos hecho mejor que nadie.",s:-1,l:10,p:0.5};
SIM[174] = {m:"Unos combates más como ese y serás una leyenda.",s:-1,l:20,p:0.1};
SIM[175] = {m:"La próxima vez dales una oportunidad, que al menos nos divirtamos un poco.",s:-1,l:5,p:0.5};
SIM[176] = {m:"No me sorprendería que fueses el aborto de un cofre animado.",s:-1,l:11,p:0.2};
SIM[178] = {m:"El propio Anutrof te ha ayudado con ese golpe.",s:-1,l:4,p:1};
SIM[179] = {m:"¡Qué anatrufado eres!",s:-1,l:14,p:0.1};
SIM[180] = {m:"Con lo que acabas de ganar no tendrás escusas para no alimentarme.",s:-1,l:7,p:1};
SIM[181] = {m:"Te juro que yo no he hecho nada, es todo culpa de mi dueño.",s:-1,l:10,p:0.6};
SIM[182] = {m:"Has apuntado mal, ese es nuestro aliado (o mejor dicho \"era\" nuestro aliado)",s:-1,l:6,p:1};
SIM[183] = {m:"Lo siento, mi dueño tiene guano de tofu en los ojos.",s:-1,l:12,p:0.5};
SIM[184] = {m:"La próxima vez que se acople, expúlsale.",s:-1,l:3,p:1};
SIM[185] = {m:"Un golpe más como éste y te denuncio a las autoridades.",s:3,l:16,p:0.2};
SIM[186] = {m:"Me estaba preguntando, la persona que te ha matado... ¿No era nuestro aliado?",s:-1,l:13,p:0.5};
SIM[187] = {m:"Quédate con el lado bueno de las cosas: vas a servir de abono natural para el suelo.",s:1,l:9,p:0.5};
SIM[188] = {m:"Por un momento pensé que lo conseguirías.",s:-1,l:6,p:0.5};
SIM[189] = {m:"¿Estás bien? Te veo muy pálido.",s:-1,l:2,p:1};
SIM[190] = {m:"Tampoco se está tan mal por el suelo. ¿Me estás oyendo? ¡Eho! Despiértaaaaaaaa.",s:-1,l:11,p:1};
SIM[191] = {m:"Vaya, no se puede decir que ese golpe le saliese mal",s:2,l:14,p:0.8};
SIM[192] = {m:"¡Te lo mereces! Por dejarme morir de hambre.",s:1,l:7,p:0.8};
SIM[193] = {m:"No se si te mereces que sienta pena por ti.",s:-1,l:3,p:0.4};
SIM[194] = {m:"¡Se lo había ganado él solito! Por osar afrentarte.",s:1,l:2,p:1};
SIM[195] = {m:"Finalmente puedes hacerlo mal.",s:-1,l:5,p:0.5};
SIM[196] = {m:"No me hubiese gustado estar en su lugar.",s:-1,l:13,p:0.5};
SIM[197] = {m:"Al menos su sufrimiento terminó, no como el mío.",s:-1,l:11,p:1};
SIM[198] = {m:"Y luego... ¿podré comerme su equipo?",s:-1,l:4,p:1};
SIM[199] = {m:"¡¡Ni sueñes con que el equipo de esa... ¡cosa! Toque mis labios!!",s:3,l:6,p:1};
SIM[200] = {m:"La próxima vez que quieras morir avísame antes, para que cambie de dueño.",s:-1,l:5,p:1};
SIM[201] = {m:"Tenía que haberme quedado en el paquete del regalo.",s:-1,l:10,p:0.2};
SIM[202] = {m:"Lo admito, me puse a comer en cuanto te diste la vuelta.",s:-1,l:6,p:0.2};
SIM[203] = {m:"Oye, ¿no te olvidarías algo al irte?",s:-1,l:9,p:1};
SIM[204] = {m:"Si hubieses llegado un minuto más tarde, me habría ido a probar suerte a otro lugar.",s:-1,l:8,p:0.2};
SIM[205] = {m:"¿Estas son horas de llegar?",s:3,l:4,p:1};
SIM[206] = {m:"¡¡¡Ven que te de mimooooooooooooooooooosss!!!",s:-1,l:6,p:1};
SIM[207] = {m:"¡Cuánto te he echado de menos! Ven a darle un besito a bibi.",s:-1,l:18,p:0.4};
SIM[208] = {m:"¿Qué cosas apasionantes vamos a hacer hoy?",s:-1,l:19,p:0.8};
SIM[209] = {m:"No te olvides de decir \"adiós\" cuando te vayas.",s:-1,l:10,p:1};
SIM[210] = {m:"Me llena de orgullo y satisfacción vovler a verte.",s:-1,l:20,p:0.2};
SIM[211] = {m:"Oh, un horrible goblin acaba de unirse al combate.",s:-1,l:15,p:0.5};
SIM[212] = {m:"Jaaaaa... ¿Has visto el nivel de ese?",s:2,l:10,p:0.5};
SIM[213] = {m:"¡Mira, un novato! ¡Uno de verdad!",s:1,l:6,p:0.6};
SIM[214] = {m:"Aquí llega uno que no tiene miedo de morir.",s:-1,l:19,p:1};
SIM[215] = {m:"Empiezan a ser muchos, ¿no crees?",s:-1,l:13,p:1};
SIM[216] = {m:"Este es momento ideal para marcharse discretamente.",s:-1,l:8,p:0.7};
SIM[217] = {m:"En mi humilde opinión te van a dar la del pulpo.",s:-1,l:5,p:0.6};
SIM[218] = {m:"Un día Fallanster dijo: \"¡Huyamos amigos!\" Quizás deberías hacer lo mismo.",s:-1,l:18,p:0.4};
SIM[219] = {m:"Eh, dame un besito, venga, ¡Demuéstrame que me quieres!",s:-1,l:16,p:0.3};
SIM[220] = {m:"Ay me voy otra vez, ay te dejo Bonta. \nLas rutinas de piel, y tus ganas de...",s:-1,l:8,p:0.6};
SIM[221] = {m:"¿Sabes qué? No, nada.",s:-1,l:7,p:1};
SIM[222] = {m:"Tienes una voz tan suave como la de Khasira, la trovadora.",s:-1,l:9,p:0.3};
SIM[223] = {m:"Mira, escucha que bien huelen las flores.",s:-1,l:6,p:0.4};
SIM[224] = {m:"Que no te asuste admitirlo, soy el amor de tu vida.",s:-1,l:10,p:0.1};
SIM[225] = {m:"El intendente Danathor huele a roquefort. Fijo que es por eso por lo que no tiene amigos.",s:-1,l:5,p:0.2};
SIM[226] = {m:"¿Sabes qué diferencia hay entre un sadida y Chewbacca?",s:2,l:4,p:0.3};
SIM[227] = {m:"¿Y si fuésemos a pelear contra unos jalatós? Podría ser divertido.",s:-1,l:2,p:1};
SIM[228] = {m:"Imagínate durante un momento que el tanga de un mediulubo estuviera vivo... Brr, me dan escalofríos sólo de pensarlo.",s:-1,l:11,p:0.5};
SIM[229] = {m:"¿Allister? ¡No sabe NADA sobre las mujeres!",s:2,l:3,p:0.4};
SIM[230] = {m:"Si fuese un paño, me gustaría pertenecer a un aniripsa.",s:-1,l:12,p:0.2};
SIM[231] = {m:"¿No va siendo hora de que hagas los deberes?",s:-1,l:2,p:0.7};
SIM[232] = {m:"¡Sácate ahora mismo el dedo de la nariz!",s:3,l:13,p:0.4};
SIM[233] = {m:"¿Por qué no puedo ser forjamagiado? No es justo.",s:-1,l:15,p:0.3};
SIM[234] = {m:"¿Conoces la fiesta de las bragas rotas? Es la ocasión perfecta para cambiar de ropa interior. Deberías ir a estas fiestas más a menudo...",s:-1,l:6,p:0.5};
SIM[235] = {m:"De acuerdo que las yopukas son lindas, pero mucho menos que tú.",s:-1,l:10,p:0.1};
SIM[236] = {m:"¿Sabes qué? Te quiero.",s:-1,l:20,p:0.1};
SIM[237] = {m:"Besito besito besito besito.",s:-1,l:5,p:1};
SIM[238] = {m:"Tú y yo somos los mejores amigos del  mundo.",s:-1,l:14,p:0.8};
SIM[239] = {m:"Estar contigo es alcanzar la felicidad perpétua.",s:-1,l:16,p:0.5};
SIM[240] = {m:"Los jalatós están totalmente desnudos debajo de su mata de pelo ¿Lo sabías? En el fondo es un poco como tú mismo.",s:-1,l:8,p:0.2};
SIM[241] = {m:"Que sepas que el pandawa no es un wabbit de pandala.",s:-1,l:7,p:0.2};
SIM[242] = {m:"Eres feo, pero aun así te quiero.",s:-1,l:8,p:0.1};
SIM[243] = {m:"¿Estudias o trabajas? No, estoy de broma.",s:2,l:12,p:0.6};
SIM[244] = {m:"Si me dejas morir de hambre, te mandaré a freir espárragos.",s:3,l:14,p:0.8};
SIM[245] = {m:"Si me alimentases mejor, yo también podría fanfarronear.",s:-1,l:13,p:0.4};
SIM[246] = {m:"Por si acaso no te habías dado cuenta, no estoy haciendo huelga de hambre.",s:-1,l:9,p:0.7};
SIM[247] = {m:"¿Sabes cual es la diferencia entre tú y yo?\nQue tú ya has comido.",s:-1,l:15,p:0.9};
SIM[248] = {m:"Si te doy un beso, ¿me darás de comer?",s:-1,l:17,p:0.1};
SIM[249] = {m:"Para variar ¿Puedes pedirme una pizza?",s:-1,l:10,p:0.2};
SIM[250] = {m:"¡Oh! Tú que eres el sol de mis días. ¿Cuándo comemos?",s:-1,l:11,p:0.3};
SIM[251] = {m:"De tanto cebarme a hamburguesas es normal que me encuentre un poco más redondito.",s:-1,l:9,p:1};
SIM[252] = {m:"No me vas a engañar, me estás engordando para luego venderme más caro.",s:-1,l:7,p:0.2};
SIM[253] = {m:"Haré lo que quieras si dejas de cebarme.",s:-1,l:12,p:1};
SIM[254] = {m:"¡Buuuuuuorp! Ups, lo siento. He debido digerir mal tanta comida, y luego me salen gases.",s:-1,l:5,p:0.5};
SIM[255] = {m:"¿Qué diferencia hay entre el peso de un cochinillo lechal y el mío?\nNinguna.",s:-1,l:3,p:0.2};
SIM[256] = {m:"No puedo más, creo que voy a vomitar.",s:-1,l:2,p:1};
SIM[257] = {m:"Cweo que soy alewgico a los pwoductos fabwicados a base de zanahowia.",s:-1,l:11,p:0.5};
SIM[258] = {m:"Sigue así y me volveré tan obeso como el rey Allister.",s:-1,l:16,p:0.1};
SIM[259] = {m:"No me molestes, estoy en plena digestión.",s:-1,l:12,p:0.5};
SIM[260] = {m:"¡Boooorp! Perdón, se me ha escapado.",s:-1,l:4,p:1};
SIM[261] = {m:"¡Mier**! ¿Quién ha soltado algo así? Además pica en los ojos.",s:3,l:10,p:0.2};
SIM[262] = {m:"Estoy seguro de que si no tuvieses tantos anillos en los dedos lo habrías hecho mejor.",s:-1,r:"9255",l:1,p:0.7};
SIM[263] = {m:"Vas a tener que vender tus anillos para poder paliar las pérdidas.",s:-1,r:"9255",l:10,p:0.5};
SIM[264] = {m:"Inténtalo poniéndote los anillos en los dedos de los pies, a ver si así lo haces mejor.",s:-1,r:"9255",l:15,p:1};
SIM[265] = {m:"Dentro de poco es mi cumpleaños, ¿me puedes preparar un Tartamuleto?",s:-1,r:"9255",l:2,p:0.2};
SIM[266] = {m:"Es gracias a mí, le he entrado por los ojos.",s:1,r:"9255",l:14,p:0.4};
SIM[267] = {m:"Si no llevases anillos esto no habría ocurrido.",s:-1,r:"9255",l:9,p:0.8};
SIM[268] = {m:"No escuches lo que te cuenten los anillos, son todos unos mentirosos.",s:-1,r:"9255",l:18,p:0.7};
SIM[269] = {m:"Tú necesitas varios anillos, pero yo soy único.",s:-1,r:"9255",l:19,p:0.1};
SIM[270] = {m:"Tener un anillo está mal, pero tener dos está aún peor.",s:-1,r:"9255",l:17,p:0.3};
SIM[271] = {m:"Deberías dejar tus anillos en el banco, allí estarán seguros.",s:-1,r:"9255",l:16,p:0.4};
SIM[272] = {m:"Estoy dividido entre dos amores: los amuletos y tú.",s:-1,r:"9255",l:20,p:0.2};
SIM[273] = {m:"La cosa era: o amuleto, o calzón. La elección fue muy rápida.",s:-1,r:"9255",l:4,p:0.5};
SIM[274] = {m:"Si no me das pronto de comer, aprieto hasta que te ahogues.",s:3,r:"9255",l:10,p:0.3};
SIM[275] = {m:"Las pelotillas de la nariz son a tu boca lo que un amuleto de pío es a la mía.",s:-1,r:"9255",l:8,p:1};
SIM[276] = {m:"Si me como un amuleto del minero oscuro ¿Crees que me convertiré en un iluminado?",s:-1,r:"9255",l:5,p:0.6};
SIM[277] = {m:"La Espiga de Farle es la base de una alimentación bio equilibrada.",s:-1,r:"9255",l:13,p:0.7};
SIM[278] = {m:"Cuando tienes hambre comes ¿No? Pues conmigo pasa lo mismo.",s:-1,r:"9255",l:3,p:0.8};
SIM[279] = {m:"Si me sigues cebando tanto voy a acabar tan gorda como el pecho de una sadida.",s:-1,r:"9255",l:12,p:0.2};
SIM[280] = {m:"Con gusto me tomaría un amuletargo para ayudarme a digerir.",s:-1,r:"9255",l:6,p:0.5};
SIM[281] = {m:"Quizas tenga piedad de ti si le das un anillo.",s:-1,r:"9255",l:7,p:0.8};
SIM[282] = {m:"Viendo su aspecto, no creo que necesites mi ayuda para librarte de él.",s:-1,r:"9255",l:11,p:1};
SIM[283] = {m:"Hola, ¿Hoy me llevas a Moon?",s:-1,r:"9255",l:15,p:0.4};
SIM[284] = {m:"¿Vienes a llevarme de viaje culinario a la Isla de los Wabbits?",s:-1,r:"9255",l:9,p:0.4};
SIM[285] = {m:"Si lo haces tan bién es sólo gracias a la destreza que yo te proporciono.",s:-1,r:"9256",l:5,p:0.8};
SIM[286] = {m:"Eso no es lo que hay que hacer si quieres ganar un combate.",s:3,r:"9256",l:18,p:1};
SIM[287] = {m:"¿Qué querías que hiciera? A fin de cuentas sólo soy un anillo.",s:-1,r:"9256",l:11,p:0.6};
SIM[288] = {m:"Tener un anillo es bueno, pero tener dos es aún mejor.",s:-1,r:"9256",l:4,p:0.5};
SIM[289] = {m:"Los dioses serán los doce. Pero yo, yo soy único.",s:-1,r:"9256",l:12,p:0.2};
SIM[290] = {m:"Fijate en ese anillo. ¿Has visto? Creo que intenta seducirme.",s:-1,r:"9256",l:10,p:0.4};
SIM[291] = {m:"Si te pica el trasero cuando te vas a dormir, no te acuestes conmigo puesto.",s:-1,r:"9256",l:8,p:0.7};
SIM[292] = {m:"¿Acaso no soy la más bonita joya del Mundo de los Doce?",s:-1,r:"9256",l:19,p:0.3};
SIM[293] = {m:"¡Qué manos tán suaves! Nada que ver con mi antiguo dueño.",s:-1,r:"9256",l:16,p:0.2};
SIM[294] = {m:"Para mí eres el único, nadie podrá remplazarte.",s:-1,r:"9256",l:20,p:0.1};
SIM[295] = {m:"\"Un anillo para gobernarlos a todos\". Están hablando de mí.",s:-1,r:"9256",l:11,p:0.5};
SIM[296] = {m:"En serio men, eres un monstruo men, ¡Cuánto te quiero men!",s:-1,r:"9256",l:15,p:0.4};
SIM[297] = {m:"Tengo un secreto que decirte al oído:  que te querré siempre con locura. ¡Yupi!",s:-1,r:"9256",l:15,p:0.4};
SIM[298] = {m:"Eso es, ráscate, haz como si yo no estuviese.",s:-1,r:"9256",l:2,p:0.4};
SIM[299] = {m:"No quiero que me encierres en el cofre de un banco. Ten piedad.",s:-1,r:"9256",l:3,p:0.2};
SIM[300] = {m:"¿Tanto me odias que me quieres ver morir de hambre?",s:-1,r:"9256",l:6,p:0.2};
SIM[301] = {m:"¡Tengo hambre! ¿Dónde está el gelanillo que me prometiste?",s:-1,r:"9256",l:9,p:0.5};
SIM[302] = {m:"Las pelotillas de la nariz son a tu boca lo que el anillo de pío es a la mía.",s:-1,r:"9256",l:8,p:1};
SIM[303] = {m:"Dame de comer el anillo de los Nungi bellos y te cubriré de riquezas.",s:-1,r:"9256",l:13,p:0.2};
SIM[304] = {m:"Por mucho que me cebes, no voy a estar más gordo.",s:-1,r:"9256",l:14,p:0.8};
SIM[305] = {m:"¿Quieres el mío? Es más gordo.",s:3,r:"9256",l:6,p:0.5};
SIM[306] = {m:"Este es el plan: tú los retienes y mientras yo voy a pedir ayuda.",s:-1,r:"9256",l:17,p:0.7};
SIM[307] = {m:"Lo siento, pero creo que no tendré fuerzas para pelear.",s:-1,r:"9256",l:7,p:0.8};
SIM[308] = {m:"¡Por fin estás aquí! Pensé que me habías olvidado. T_T",s:-1,r:"9256",l:10,p:0.4};
SIM[309] = {m:"La próxima vez que quieras rascarte el culo, no te olvides de apartarme antes.",s:-1,r:"9256",l:1,p:1};
SIM[310] = {m:"¡Písale el pie, muérdele el brazo, aplástale la cabeza!",s:-1,r:"9233",l:4,p:0.5};
SIM[311] = {m:"¡Ehhh tú! ¡¿Por qué atacas a mi dueño?!",s:-1,r:"9233",l:9,p:0.3};
SIM[312] = {m:"¡Así! Así es como yo te conocía.",s:-1,r:"9233",l:10,p:0.8};
SIM[313] = {m:"Dentro de poco es mi cumpleaños, ¿me puedes preparar una Capabizcocho?",s:-1,r:"9233",l:2,p:0.2};
SIM[314] = {m:"A mi antiguo dueño se le daba mejor que a ti. Claro que él era un sram.",s:-1,r:"9233",l:11,p:0.4};
SIM[315] = {m:"Hice todo lo que pude para protegerte, pero no fue suficiente.",s:-1,r:"9233",l:13,p:0.2};
SIM[316] = {m:"Nadie te protegerá tan bien como yo.",s:-1,r:"9233",l:19,p:0.7};
SIM[317] = {m:"¡Créeme! Si hubiese podido le habría dado una buena paliza.",s:-1,r:"9233",l:14,p:0.5};
SIM[318] = {m:"No estaría nada mal que dejarás de aplastarme al echarte la siesta.",s:3,r:"9233",l:6,p:0.8};
SIM[319] = {m:"Puedo protegerte de muchas cosas, pero no de tus tonterías.",s:-1,r:"9233",l:4,p:0.7};
SIM[320] = {m:"Tengo frío. ¿Por qué siempre soy yo el que te calienta a ti y nunca es al revés?",s:-1,r:"9233",l:1,p:0.4};
SIM[321] = {m:"Deberías teñirme de rojo y ponerte unas mallas azules con unas botas rojas. Causaríamos sensación.",s:-1,r:"9233",l:5,p:0.2};
SIM[322] = {m:"Si supieras todo lo que de ti se dice a tus espaldas... ¡Ni te lo imaginas!",s:-1,r:"9233",l:7,p:0.2};
SIM[323] = {m:"Ven a acurrucarte junto a mí, que te dé calorcito.",s:-1,r:"9233",l:12,p:0.4};
SIM[324] = {m:"El rey Allister en persona no posée tan bellos ropajes.",s:-1,r:"9233",l:20,p:0.2};
SIM[325] = {m:"Soy la encarnación de la majestuosidad.",s:-1,r:"9233",l:15,p:0.3};
SIM[326] = {m:"No soy una servilleta, y menos un trapo. ¡Soy una capa!",s:-1,r:"9233",l:18,p:1};
SIM[327] = {m:"¿Por qué tengo que ser yo el que soporta tus axilas y tu trasero?",s:-1,r:"9233",l:13,p:0.2};
SIM[328] = {m:"¡NO! ¡Piedad, el cesto de la ropa sucia nooooo! Te juro que nunca más volveré a hablar de tu fealdad.",s:-1,r:"9233",l:13,p:0.4};
SIM[329] = {m:"La próxima vez que vayas a hacer tus necesidades, no te olvides de que estoy detrás.",s:-1,r:"9233",l:7,p:1};
SIM[330] = {m:"Las pelotillas de la nariz son a tu boca lo que la capa de pío es a la mía.",s:-1,r:"9233",l:8,p:1};
SIM[331] = {m:"De tanto hacer régimen voy a acabar pareciéndome a una capa del pohoyo titiritasado.",s:-1,r:"9233",l:12,p:0.5};
SIM[332] = {m:"Las Gelocapas no están mal, pero se pegan entre los dientes.",s:-1,r:"9233",l:9,p:0.4};
SIM[333] = {m:"Creo que ya he hecho mis reservas para este invierno.",s:-1,r:"9233",l:10,p:0.6};
SIM[334] = {m:"Tu te ocupas del de la izquierda y yo del de la derecha.",s:-1,r:"9233",l:17,p:1};
SIM[335] = {m:"¡Ese es mío, ese es mío!",s:-1,r:"9233",l:16,p:0.8};
SIM[336] = {m:"Boff este enemigo ni siquiera merece mi atención.",s:-1,r:"9233",l:18,p:0.5};
SIM[337] = {m:"¿Es un hombre o una mujer? Desde aquí no lo veo muy bien.",s:2,r:"9233",l:13,p:0.3};
SIM[338] = {m:"Parece que, de repente, huele peor. ¡Anda mira, pero si ya estás aquí!",s:-1,r:"9233",l:3,p:0.2};
SIM[339] = {m:"Les aseguro que esto no es más que un desafortunado malentendido.",s:-1,r:"9234",l:6,p:0.4};
SIM[340] = {m:"¡Vaya! Ante esta proeza me quito el sombrero.",s:-1,r:"9234",l:7,p:0.5};
SIM[341] = {m:"Dentro de poco es mi cumpleaños, ¿me puedes preparar un Caskogalleta?",s:-1,r:"9234",l:2,p:0.2};
SIM[342] = {m:"Si llevases el HmmMmmMmmm lo habría entendido, pero así... Esto es inaceptable.",s:3,r:"9234",l:18,p:0.3};
SIM[343] = {m:"Deja de hacer el idiota.",s:3,r:"9234",l:11,p:0.5};
SIM[344] = {m:"Por los Dioses ¡Que paliza! Bueno, no está todo perdido, yo sigo aquí.",s:-1,r:"9234",l:16,p:0.5};
SIM[345] = {m:"Seguro que ese individuo no mercía combatir a tu lado.",s:-1,r:"9234",l:15,p:0.3};
SIM[346] = {m:"¿Yo también tengo que hecerme el muerto?",s:-1,r:"9234",l:5,p:0.4};
SIM[347] = {m:"Sin lugar a dudas, te quedo de maravilla.",s:-1,r:"9234",l:15,p:0.8};
SIM[348] = {m:"Como estoy vivo, y en tu cabeza... pues sí, va a ser que ¡soy tu cerebro!",s:-1,r:"9234",l:16,p:0.5};
SIM[349] = {m:"El mismísimo rey Allister debe de envidiarte por poseerme.",s:-1,r:"9234",l:13,p:0.2};
SIM[350] = {m:"Mira ese sombrero ridículo. ¡Qué poca elegancia!",s:2,r:"9234",l:9,p:0.5};
SIM[351] = {m:"Desde aquí puedo ver todo lo que tienes en las orejas, y no es muy bonito que digamos.",s:-1,r:"9234",l:6,p:0.2};
SIM[352] = {m:"Si tienes tanto éxito, es gracias a mí. No lo olvides nunca.",s:-1,r:"9234",l:20,p:0.4};
SIM[353] = {m:"Si fuese una capa nunca tendrías frío, pero sólo soy un humilde sombrero, así que te protejo de la lluvia lo mejor que puedo.",s:-1,r:"9234",l:10,p:0.6};
SIM[354] = {m:"Las mujeres sadida tienen unas lindas formas, ¡Como yo!",s:-1,r:"9234",l:17,p:0.2};
SIM[355] = {m:"Los cuernos de Rushu son un adorno muy ridículo si los comparas conmigo.",s:-1,r:"9234",l:19,p:0.1};
SIM[356] = {m:"¿Sabes por qué los magos más importantes tienen un sombrero? Porque quieren parecerse a ti.",s:-1,r:"9234",l:20,p:0.1};
SIM[357] = {m:"¿Sabes por qué los magos más importantes tienen un sombrero? Porque son más hábiles que tú.",s:1,r:"9234",l:14,p:0.3};
SIM[358] = {m:"Aunque no sea tu caso, hay gente que estaría encantada de tenerme a su lado.",s:-1,r:"9234",l:5,p:0.2};
SIM[359] = {m:"Vale, yo protejo tu cabeza del sol, pero ¿A mí quién me proteje?",s:-1,r:"9234",l:10,p:0.4};
SIM[360] = {m:"Las pelotillas de la nariz son a tu boca lo que el sombrero del pío es a la mía.",s:-1,r:"9234",l:8,p:1};
SIM[361] = {m:"Si grande es tu belleza, aún más grande es mi hambre.",s:-1,r:"9234",l:4,p:0.6};
SIM[362] = {m:"¿Crees que sería capaz de tragarme un Dofus?",s:-1,r:"9234",l:11,p:0.3};
SIM[363] = {m:"Si me das un Champisombrero, te vomito encima. Date por avisado.",s:-1,r:"9234",l:12,p:0.2};
SIM[364] = {m:"Hay mucho piojo por aquí. Si esperas que me los coma te equivocas, no estoy tan hambriento.",s:-1,r:"9234",l:1,p:0.1};
SIM[365] = {m:"Te lo pido por los Doce, lávate el pelo todos los meses, ¡Aunque no te toque!",s:-1,r:"9234",l:3,p:0.2};
SIM[366] = {m:"Ése sí es un enemigo digno de interés.",s:-1,r:"9234",l:8,p:0.2};
SIM[367] = {m:"Por un momento pensé que llegaba un nuevo enemigo, pero sólo era alguien que se había perdido.",s:-1,r:"9234",l:7,p:0.3};
