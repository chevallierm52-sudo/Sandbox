Q.s[40] = {n:"Consegna della miniera",d:"",r:[null,null,null,null,null,null]};
Q.s[39] = {n:"Consegna di Podbra Monco",d:"",r:[null,null,null,null,null,null]};
Q.s[143] = {n:"Caccia selvaggia",d:"Oscure creature rovinano gli affari di Vuoiun Amission, liberarsene sembra la soluzione più appropriata... almeno fino a quando non sia chiaro cosa ci facciano qui.",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"Le uova possono nuotare?",d:"Non ci sono più agentis infectofus nelle piume dei Tofu malati. Però le loro uova potrebbero essere una traccia per gli Aniripsa. Altri kama facili!",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"Si verserà sangue!",d:"Vuoi saperne di più su te stesso e decidi di recarti in un luogo sanguinoso... la macelleria.",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"C\'è odore di bruciato!",d:"Il tuo padrone ha sentito che un minatore è stato recentemente cambiato in minatore scuro. Vuole vederlo con i propri occhi.",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"Stupidi Anutrof!",d:"Gli Anutrof hanno scoperto qualcosa, avranno bisogno di te.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Estratto di Dzibi",d:"Il fiore non va bene così com\'è, bisogna farne un\'infusione!",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Consegna rapida",d:"Devi portare l\'infusione al Maestro di classe se vuoi che ti costruisca un bastone!\nSe nel frattempo riesci a portare un\'infusione anche al tuo fornitore di fiori, questi sarà estremamente contento.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Fiore di Dzibi",d:"Se vuoi che il tuo Maestro di classe ti costruisca un bastone degno di questo nome, devi trovare il fiore di Dizbi.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"Abbiamo fame!",d:"I Pappatutto d\'Allisteria hanno fame. Devi nutrirli tutti!",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Sanguinaccio Bollito di Pappatutto",d:"Salva la tradizione del buon Sanguinaccio Bollito di Pappatutto.",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Combatti se sei un Feca!",d:"Il celebre Fallanster ti ha chiesto di addestrare sua figlia al combattimento.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"La via dell\'Acqua",d:"La via dell\'acqua consiste nel resistere con ogni mezzo al contatto con l\'acqua, che si tratti di assorbimento o immersione (parziale e totale). Non bere mai, lavarsi solo in caso di necessità. Trova il maestro della via dell\'Acqua: ne sa più di quello che sembra.",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"Il saggio Volpo",d:"Una venditrice pandawaiana di bevande ti consiglia di incontrare il saggio Volpo. Secondo lei, solo lui conosce la verità su Pandala e i suoi segreti.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"La statua della dea",d:"Il Grandapan ha accettato con gioia il regalo degli Anutrof. È un appassionato ammiratore dei cercatori di Dofus, e ti accoglierà a braccia aperte.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"Il Grandapan: un pandawa simpatico",d:"Gli Anutrof in cura dallo Sciamano ti consigliano di andare da Grandapan. Oltre a essere molto informato sulle abitudini locali, è anche un eccellente conoscitore delle leggende Pandawaiane.",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Libagioni per la dea",d:"Grazie a voi, l\'Assistente dello Sciamano può cominciare il rituale di ringraziamento della dea. Sarà pronto appena gli avrai fatto un\'offerta pandawaiana tradizionale.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"Al servizio del re",d:"Al re piace cavalcare, bisogna trovargli dei dragacchini.",r:[75000,null,null,null,null,null]};
