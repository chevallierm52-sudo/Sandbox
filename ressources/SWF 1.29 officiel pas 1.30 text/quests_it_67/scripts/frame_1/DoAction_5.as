Q.s[144] = {n:"...o zanne di Xelor.",d:"Gli Xelor sembrano interessati. Secondo Vuoiun, servirebbero per mettere delle lancette alle clessidre... ma non è sicuro.",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Trova il fuorilegge",d:"Certi dicono di aver visto Qil Bil vicino le pianure di Sidimote.\nQil Bil è ricercato per estirpazione di arti.\nÈ condannato all\'imprigionamento a Astrub.",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"Riarruolati, diceva.",d:"Snori Nairb ha promesso di condividere i suoi kama e la sua esperienza con te se ti arruoli nella milizia di Brakmar.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"Chi semina vhent, raccoglie Artempesta!",d:"Per provare la sua teoria sulla comparsa dei fiori carnivori, Trapchet ti chiede di seminare delle rose oscure, e di raccoglierle...",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"L\'afono e la flora",d:"Treffiori, un amico di Trapchet, risiede a Amakna e conosce perfettamente la flora della regione. Devi chiedergli informazioni sui fiori aggressivi che ci crescono.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"L\'Epyss di Leone",d:"Erty Trapchet vuole studiare i semi di dente di leone, per compararli con L\'Epyss...",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"L\'annaffiatore annaffiante",d:"Erty Trapchet ha dimenticato di occuparsi delle sue piante, devi andare da lui per annaffiarle.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"Ma quale erbario!",d:"Per le sue ricerche, Trapchet ha bisogno di studiare la distribuzione geografica dei fiori che crescono attorno a Astrub.",r:[6500,500,null,null,null,null]};
Q.s[60] = {n:"Diamine, ma certo!",d:"-",r:[null,null,null,null,null,null]};
Q.s[56] = {n:"Inchiesta sulla scomparsa di... una casa",d:"",r:[null,null,null,null,null,null]};
