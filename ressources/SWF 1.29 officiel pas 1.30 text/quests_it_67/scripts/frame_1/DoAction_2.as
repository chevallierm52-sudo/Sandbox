Q.s[720] = {n:"Il Tabi di Grace.",d:"Grace Malcin, a Bonta, ha dei problemi con il suo Tabi.",r:[25000,null,null,null,null,null]};
Q.s[919] = {n:"Un Eca impaniflippa moltissimo.",d:"Ora puoi fabbricare delle Chiavi e ispezionare il covo dei banditi alla ricerca d\'indizi. Una Corda da Scalata non sarà inutile per scendere nel covo.",r:[80000,null,null,null,null,null]};
Q.s[916] = {n:"Gattina miaomiao.",d:"Devi mettere le mani sulla Chiave del covo, il che porta per forza a mettere le mani su un bandito che la possiede. L\'ex-amante di Hersa potrebbe rivelarsi utile.",r:[null,null,null,null,null,null]};
Q.s[917] = {n:"Chiave, senza l\'inglese.",d:"Devi fare delle copie della Chiave del covo dei banditi prima di poterci entrare con altri avventurieri per poter recuperare tutti i documenti relativi all\'inchiesta.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Attività illecite.",d:"Piani sospetti si tramano nel quartiere dei Panettieri. Amayiro ti ha chiesto di indagare.",r:[17000,null,null,null,null,null]};
Q.s[689] = {n:"Allenamento con il bastone.",d:"Amayiro ti ha chiesto 20 Bastoni di Legnuccio per allenare le sue truppe.",r:[4000,null,null,null,null,null]};
Q.s[718] = {n:"Una richiesta di Danathor.",d:"Danathor ti ha mandato una lettera per chiederti assistenza.",r:[11500,null,null,null,null,null]};
Q.s[719] = {n:"Larry Poller.",d:"Larry Poller ha chiesto il tuo aiuto. Si trova vicino alla Torre di Bonta.",r:[11500,null,null,null,null,null]};
Q.s[1035] = {n:"Scopri il segreto della Statua.",d:"Persimol ha nascosto il suo Segreto ai piedi della Statua. Piegati per raccoglierlo.",r:[null,null,null,null,null,null]};
Q.s[751] = {n:"Aiuta Raaga.",d:"Trova Raaga nelle miniere del nord e chiedigli il suo rapporto.",r:[13500,null,null,null,null,null]};
Q.s[738] = {n:"Il rapporto della spia.",d:"Oto ti ha chiesto di trovare la spia Finch Aticus, a Bonta, e di chiedergli il suo rapporto.",r:[5200,null,null,null,null,null]};
Q.s[743] = {n:"Alla ricerca di veleno magico.",d:"Devi trovare qualcuno a Brakmar che sappia preparare dei veleni magici.",r:[8200,null,null,null,null,null]};
Q.s[335] = {n:"Al lavoro",d:"Vai a chiedere al capomastro cosa devi fare.",r:[250,250,null,null,null,null]};
Q.s[382] = {n:"Al lavoro",d:"Vai a chiedere al capomastro cosa devi fare.",r:[250,250,null,null,null,null]};
Q.s[383] = {n:"Al lavoro",d:"Vai a chiedere al capomastro cosa devi fare.",r:[250,250,null,null,null,null]};
Q.s[784] = {n:"Per un cuore valoroso, niente è impossibile.",d:"Devi trovare un membro della famiglia Terra e portarlo da Mel Aghignavon. Di sicuro Setag, il Maestro di classe Anutrof, potrà aiutarti.",r:[200000,null,null,null,null,null]};
Q.s[956] = {n:"Ordine o contrordine?",d:"Visto che l\'attuale Piano d\'attacco non è stato confermato, devi trovare la sua conferma o le modifiche presso l\'ufficiale Kapi Tagno e fare un rapporto su queste informazioni ad Amayiro.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Piano d\'attacco.",d:"Amayiro teme un assalto imminente dei Brakmariani. Devi trovare il loro Piano d\'attacco per permettere ad Amayiro di preparare loro un comitato d\'accoglienza degno di questo nome.",r:[null,null,null,null,null,null]};
Q.s[358] = {n:"Allenamento",d:"Bisogna far perdere tutta la paglia a uno spaventapasseri animato.",r:[25,null,null,null,null,null]};
Q.s[755] = {n:"Del legno per Oto.",d:"Oto vuole 10 cortecce d\'Alberagno per fare del legno per riscaldare.",r:[16300,null,null,null,null,null]};
Q.s[946] = {n:"Arruolati, diceva.",d:"Snori Nairb ti ha fatto entrare illegalmente nella milizia di Bonta. Per ufficializzare la cosa, devi andare a trovare Amayiro.",r:[null,null,null,null,null,null]};
Q.s[945] = {n:"Arruolati, diceva.",d:"Snori Nairb ti ha fatto entrare illegalmente nella milizia di Brakmar. Per ufficializzare la cosa, devi andare a trovare Oto Mustam.",r:[null,null,null,null,null,null]};
Q.s[752] = {n:"Ritrova la spia.",d:"Una spia è riuscita a scappare da Brakmar con dei documenti importanti. Una delle guardie a nord di Brakmar l\'ha forse vista.",r:[14200,null,null,null,null,null]};
Q.s[979] = {n:"Sconfiggi il dabol.",d:"In caso di vittoria contro il dabol, il maestro dei combattimenti ti ricompenserà.",r:[null,null,null,null,null,null]};
Q.s[503] = {n:"Materie prime.",d:"Nara il Forgiatore, nella Miniera del Territorio Porcos, ha bisogno di materie prime per fabbricare un equipaggiamento standard destinato ai miliziani di Bonta.",r:[140000,null,null,null,null,null]};
