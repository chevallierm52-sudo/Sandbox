Q.s[704] = {n:"Salva Lyeno.",d:"Devi salvare il Colonnello Lyeno: è scomparso nella parte Est della Foresta degli Alberagni.",r:[12800,null,null,null,null,null]};
Q.s[722] = {n:"Un\'altra richiesta del cuciniere.",d:"Il cuoco della milizia ha chiesto di nuovo i tuoi servigi.",r:[31000,null,null,null,null,null]};
Q.s[1088] = {n:"La fabbrica dei giochi.",d:"Delle abominevoli creature hanno svaligiato il deposito di Babbo Nawal. Devi recuperare le casse con i regali che hanno rubato, con o senza il loro consenso, e portarle a Felice Nawal.",r:[null,1000,[[10920,1]],null,null,null]};
