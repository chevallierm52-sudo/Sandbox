Q.s[726] = {n:"Disossa Mak.",d:"Sconfiggi Mak Gahan lo Chafer e porta una delle sue ossa a Oto Mustam.",r:[50,null,null,null,null,null]};
Q.s[536] = {n:"Cattura la Spia.",d:"Una Spia Bontariana si è infiltrata nella Torre ed ha rubato dei documenti. Bisogna utilizzare uno Zaap per intercettarlo, ad Est della strada che porta a Bonta, dalla parte di Brakmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Tutto bene in casa Ladrurbi.",d:"Adesso hai un\'idea molto precisa di dove si trovi il nascondiglio dei Ladrurbi. Non rimane che verificare le tue informazioni.",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"La cripta, che storia!",d:"Devi visitare le cinque cripte del cimitero di Amakna.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"Per qualche Ladrurbo in più...",d:"Devi infiltrarti tra i Ladrurbi e andare a parlare con Vil Smis.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"In territorio nemico.",d:"Devi infiltrarti nell\'edificio della milizia di Bonta e scoprire dove i nemici depositano le loro armi.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"Proprio una grossa cassa.",d:"Devi eludere la vigilanza del guardiano per prendergli le Chiavi del magazzino. In seguito devi rubare una Cassa d\'equipaggiamento e portarla a Mulic Ber per una Perizia.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"I mantelli brakmariani.",d:"Oto ti ha chiesto cinque mantelli brakmariani. Può indicarti come fabbricarli.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Un po\' d\'acqua",d:"Tenva Labroc ha bisogno d\'acqua per le sue ninfette.",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"Ricerche per un Corno.",d:"Il sedicente guardiano del Corno Davola dovrebbe trovarsi nella fitta giungla dell\'Isola di Moon. Secondo le voci che girano, devi portare un Furbacapo e avere della Glutoberg per fare in modo che appaia.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"Le informazioni del capitano.",d:"Devi trovare il modo di entrare in comunicazione col defunto capitano Tsog, per ottenere le informazioni che deve comunicare. Il Capitan Alrok conosce l\'ubicazione della tomba di Tsog.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Trova il colpevole.",d:"Trova l\'assassino di Rimaraf e porta il modulo riempito a Amayiro.",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Prove false.",d:"Trova un modo di fregare Amayiro presentandogli delle prove false. Danathor ti aiuterà sicuramente.",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"Il sangue dei ratti.",d:"Amayiro ti ha chiesto di annientare quattro Ratti d\'Hyoactiv nelle fogne di Bonta.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Persone di fiducia.",d:"Amayiro ha bisogno di persone di fiducia per partecipare alla messinscena dei falsi poteri del Corno Davola.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"Una messinscena minuziosa.",d:"Per finalizzare la messinscena Amayiro ha bisogno di Terhmiti presenti sui Croccaroc e del Grasso di Gelatina Reale, qualsiasi Gelatina andrà bene.",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"Ancora raccolta...",d:"Gli Ocra sono gli specialisti delle frecciate. Sembra che nelle zampe delle Arakni malate ci sia un veleno... business is business...",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"La chiamata del pazzo",d:"Aillof chiede una Pala di Legnuccio per costruire un rifugio antiapocalisse.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"Pane a tavola",d:"Per costruire la sua capanna indistruttibile, Aillof chiede due tavole di Castagno e un po\' di pane, per sopravvivere almeno 3 giorni dopo il disastro...",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Caponata.",d:"Bisogna riunire gli Ingredienti necessari nel Paiolo primordiale: un Oggetto di ogni tipo ed un Alchimista, un Panettiere, un Contadino, un Macellaio, un Pescivendolo.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"L\'arte di cucinare senza affaticarsi, o quasi.",d:"Devi trovare le Ricette degli Ingredienti elencati sul foglio che Oto Mustam ti ha consegnato.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Le nostre amiche bestie.",d:"Amayiro vorrebbe saperne di più su Garutar. Oshimo, il guardiano del Cianil ha di sicuro delle informazioni su questa tartaruga.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Glinsegnamenti glazie ai Volpi.",d:"Garutar nel passato ha fiancheggiato e difeso i Volpi. I Volpi, a Sud dell\'Isole dei Wabbit, forse non l\'hanno dimenticato.",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Raccolta di mutande.",d:"Devi sconfiggere dei miliziani di Bonta e... recuperare le loro mutande. Oto ne vuole cinque.",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Bosco d\'Arash",d:"Procurati del legno di Arash: sacrificando la natura, potresti diventare suo alleato.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Rituale",d:"Trova la persona che ti aiuterà a fabbricare il tuo bastone da neofita.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Mostra il tuo talento",d:"I tuoi talenti crescono ma non tutti ne sono convinti.",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"È l\'oro, Moon.",d:"Il sedicente guardiano del Corno Davola dovrebbe trovarsi nella fitta giungla dell\'Isola di Moon. Secondo le voci che girano, devi portare un Furbacapo e avere della Glutoberg per fare in modo che appaia.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"Della bava per confezionare un gioiello?",d:"Devi recuperare dei materiali per confezionare un Gioiello: 5 Lingotti d\'Oro, 1 Bava di Pappatutto Reale e 1 Madreperla. La Madreperla si ottiene lucidando 10 Madreperle Grezze che si trovano sui crostacei e i molluschi dell\'isola d\'Otomai.",r:[80000,null,null,null,null,null]};
Q.s[1063] = {n:"La fabbrica dei giochi.",d:"Delle abominevoli creature hanno svaligiato il deposito di Babbo Nawal. Devi recuperare le casse con i regali che hanno rubato, con o senza il loro consenso, e portarle a Felice Nawal.",r:[null,1000,[[10920,1]],null,null,null]};
