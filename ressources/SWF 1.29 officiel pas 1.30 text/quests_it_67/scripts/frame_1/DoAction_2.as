Q.s[963] = {n:"Una Bidonata.",d:"Per sabotare l\'equipaggiamento di Bonta, Oto Mustam vuole che tu sostituisca gli strumenti dei suoi Forgiatori con 5 Martelli Martel.",r:[null,null,null,null,null,null]};
Q.s[904] = {n:"Un Aiutino.",d:"Oto Mustam è molto soddisfatto del lavoro del Forgiatore che equipaggia la milizia di Bonta e ti incarica di fare in modo che continui in questa direzione.",r:[null,null,null,null,null,null]};
Q.s[905] = {n:"Una Mano.",d:"Ollatem Ossa ha appena ricevuto del Minerale Greggio e nuovi strumenti. Devi approfittare della sua assenza, tra le 17 e le 21, per rubare il Minerale Greggio e scambiare i suoi strumenti.",r:[122000,null,null,null,null,null]};
Q.s[204] = {n:"Trova il fuorilegge",d:"Zatoishwan è stato visto nei pressi di Terradala. \nÈ condannato all\'imprigionamento a Astrub.",r:[null,112500,null,null,null,null]};
