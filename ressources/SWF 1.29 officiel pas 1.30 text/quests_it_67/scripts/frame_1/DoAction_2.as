Q.s[365] = {n:"La chiave tra i denti",d:"Se vuoi la chiave del dongione, devi battere un grosso Pappatutto rabbioso.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"Sadikè?",d:"Danathor ha ancora bisogno dei tuoi servizi per mettere le mani sul Libro Magico del Bwork Mago delle caverne rinomato per aver lanciato il sortilegio della Grafiosi.",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Sadidarna.",d:"Touh Flowa ti ha indicato dove si trova l\'entrata della Prigione Vegetale. Visto che la sua mente era un po\' annebbiata, speriamo che non abbia dimenticato di dirti qualcosa.",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"Una chiave su un scoiattolo.",d:"Devi ritrovare uno scoiattolo a Brakmar: ha rubato una chiave importante. Riportala a Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Porta le casse.",d:"Bisogna portare a Oto le casse d\'armi bianche che si trovano nella torre di Brakmar.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Dei Geta per Milon.",d:"Per punirti del fatto di non aver potuto impedire ai ladri di rubare il Gioiello, Milon ti ha chiesto di portargli dei Geta Focodala.",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Ridisossa Mak Gahan.",d:"Mak Gahan lo Chafer vuole la rivincita.",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Linglés si prende una bella lavata di capo.",d:"William Linglés ha di nuovo bisogno di ricevere una lezione.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"Tac e Tic.",d:"Devi trovare uno Stratega e convincerlo a raggiungere i ranghi di Bonta.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Fraka Kyper.",d:"Oto Mustam vuole avere l\'opinione di Fraka Kyper per la sua offensiva contro Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Ritorno verso Oto.",d:"La battaglia è finita, Oto Mustam aspetta il tuo rapporto.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Scaramuccia.",d:"In questo momento si sta svolgendo un combattimento vicino alla Baia di Cania, a metà strada tra Bonta e Brakmar. Bisogna raggiungerlo e aiutare Brakmar a vincere!",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Allenamento al martello.",d:"Oto ha bisogno di dieci Martelli di Legnuccio per l\'allenamento delle sue truppe.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"Il Cristallo Oscuro.",d:"Devi prendere il passaggio segreto nell\'atelier degli Alchimisti con dei Maestri nel loro mestiere. Ti serve anche una Pozione di Raffica, un\'Armonia e una Kobalite.",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"Il crimine non paga.",d:"Il messaggio è stato spedito al Captain Starky. Aspettando la sua risposta, dovresti andare a vedere se Sabina se n\'è rimasta tranquilla.",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"Il riscatto.",d:"Ora che Sabina è sotto sorveglianza, devi trovare un modo per contattare il Captain Starky ed esigere un Cristallo di Kain Dharyn in riscatto.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"Condotta in prigione",d:"Devi portare di forza Sabina davanti ad Oto Mustam. Devi fare attenzione in modo che non scappi alla prima occasione.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"Il rapimento di Sabina.",d:"Devi rapire Sabina e metterla in un luogo da cui non possa scappare.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"Il crimine pagherà, parola di Brakmariano.",d:"I Bontariani hanno tentato di liberare Sabina. Non andrà a finire così! Devi far capir loro chi comanda.",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Sfida Puja.",d:"Sei tenuto a sfidare Puja Mustam, il figlio di Oto, e a perdere. Ma non ti farai mica uccidere da questo marmocchio?",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"Una nuova dentiera.",d:"Devi estrarre dei denti di Pappatutto per confezionare una dentiera. Devi portarne abbastanza per fare una dentiera umana... Insomma, umanoide.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"Il grande sbucciamento.",d:"Devi sbucciare delle patate per cena. La cucina si trova sotto la milizia.",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"Sconfiggerò il Manitù Zoth.",d:"Devi sconfiggere il Manitù Zoth e portare una prova della tua vittoria a Bob l\'Anutrof.",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Ammansire, che bello!",d:"Bisogna trovare un modo per ammansire Garutar e mettere le mani sul Corno Davola. I residenti dell\'Isola di Moon possono aiutarti.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"Torna da Oto.",d:"Visto che lo Stratega ha abbandonato la città, puoi tranquillamente lasciar pensare ad Oto Mustam di averlo ucciso.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Domatore di bestie, ma anche di animali.",d:"Oto Mustam vuole conoscere il segreto dell\'Addomesticamento di Canin Blandi. Devi tornare alla biblioteca di Bonta per trovare degli indizi.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"I salsicciotti di un salame.",d:"Visto che Oto Mustam è convinto che tu stia cercando d\'imbrogliarlo, bisogna assolutamente ritrovare il Gioiello prima di essere trasformato in un salsicciotto.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"Vittoria!",d:"Xefires ha accettato le condizioni e, al momento opportuno, sarà pronto per tradire Bonta. Oto sarà contento di questa notizia.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"Il colloquio.",d:"Sei pronto, non resta che ritrovare Xefires alla Taverna del Pandawa Ubriaco per consegnargli la lettera e concordare un appuntamento per la sua risposta.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Vendetta, Bwa ha ha ha ha!.",d:"Il covo dei banditi contiene delle trappole. Devi trovare un Tuttofare almeno di livello 30 per accompagnarti ed aiutarti a neutralizzare le trappole che proteggono il loro nascondiglio.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"A rapporto.",d:"La battaglia è finita, Mel Aghignavon attende il tuo rapporto.",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Scaramuccia.",d:"In questo momento si sta svolgendo un combattimento vicino alla Baia di Cania, a metà strada tra Bonta e Brakmar. Bisogna raggiungerlo e aiutare Bonta a vincere!",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Offerta di lavoro.",d:"Oto Mustam vuole sapere chi ha assassinato il gestore della Taverna del Maokemao.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"La poltiglia di Blop.",d:"Bisogna portare della poltiglia di Blop macinata ad Oto. Può darti la ricetta.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Trova il testamento.",d:"Devi trovare il testamento di Oto nella tomba di suo padre, nel cimitero - la si riconosce dal mazzo di fiori che la circonda. Per entrare devi esserti trasformato in spirito.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"Pirata a molo.",d:"Grazie a Xefires sai che il bastimento Bontariano La Sedecrem trasporta numerosi Oggetti Magici nelle stive. Devi trovarlo e far man bassa sulla sua mercanzia.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Liquidazione totale.",d:"Un\'Etram deve dei soldi a Oto Mustam. Visto che non glieli ha ancora restituiti, lui ha deciso di eliminarla: un\'azione esemplare. Forse la troverai in una sala da gioco illegale.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Equipaggia i guerrieri.",d:"Oto teme un attacco di Bonta e ti ha chiesto di equipaggiare alcuni guerrieri di Brakmar con l\'equipaggiamento speciale.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Cricca.",d:"Kosuke Ichazum aveva ragione: Ollatem Ossa ha ottenuto il contratto per equipaggiare la milizia di Bonta grazie alla sua cricca di amici e non grazie alle sue competenze da Forgiatore.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Forgiare con i piedi.",d:"Devi investigare sul fornitore dell\'equipaggiamento della milizia e mettere alla prova il Forgiatore che lo fabbrica.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"Il pozzo del pazzo.",d:"Devi localizzare i Pozzi delle Anime Imbrattate per rivelare tutto il potenziale delle Pietre d\'Imbrattatura. Il Maestro dell\'Ordine dello Spirito Malsano, Divad Dleifrepok, potrà aiutarti.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Alchimia malefica.",d:"Devi procurarti delle Pietre d\'Imbrattatura. Solo i Minatori le sanno fabbricare a partire dalle creazioni grezze di un Alchimista pazzo.",r:[null,null,null,null,null,null]};
