Q.s[519] = {n:"La spia ferita.",d:"Devi riacciuffare la Spia ferita che si dirige verso Brakmar e recuperare i Documenti.\nPerò hai trovato una lettera nella tua borsa...",r:[205000,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[1192] = {n:"Ginetta, l\'imperfezione al femminile",d:"Ginetta è stata rapita da un Kanigloo. Gromeo ha provato a salvarla, invano. Ti supplica di riportargliela.",r:[804000,25000,[[11196,2]],null,null,null]};
Q.s[1191] = {n:"Riconciliazione burrascosa",d:"I Capuè sembrano essere estranei al furto dei cereali, ma qualcosa non quadra.\nBisogna scoprire cosa.",r:[null,null,null,null,null,null]};
Q.s[1190] = {n:"La verità esce anche dalla bocca degli adulti...",d:"Ginetta ha un piano per scoprire cos\'è realmente accaduto al riguardo del furto. Tocca a te scoprirlo.",r:[null,null,null,null,null,null]};
Q.s[1189] = {n:"Amore impossibile",d:"Gromeo e Ginetta non si possono sposare a causa di una disputa fra le due famiglie. Ti implorano di trovare una soluzione.",r:[null,null,null,null,null,null]};
Q.s[1184] = {n:"Estratto da un\'ispezione.",d:"Larry Tutthe è sovraccarico e ha bisogno di una mano.",r:[null,null,null,null,null,null]};
Q.s[1183] = {n:"In cerca di aiuto.",d:"Larry Tutthe ha bisogno di un nuovo assistente e ti ha incaricato del reclutamento.",r:[null,null,null,null,null,null]};
Q.s[488] = {n:"Torna da Oto.",d:"Ti sei occupato dello Stratega, devi tornare da Oto.",r:[null,null,null,null,null,null]};
Q.s[907] = {n:"Domatore di bestie, ma anche di animali.",d:"Oto Mustam vuole conoscere il segreto dell\'Addomesticamento di Canin Blandi. Devi tornare alla biblioteca di Bonta per trovare degli indizi.",r:[134000,null,null,null,null,null]};
Q.s[1021] = {n:"Abbatti lo Stratega.",d:"Hai deciso di ricorrere alla soluzione più estrema. La più Brakmariana, insomma.",r:[null,null,null,null,null,null]};
Q.s[1177] = {n:"Scortare il ferito.",d:"Devi scortare un cacciatore ferito al Borgo di Frigost perchè venga curato dal dottor Albert Pes.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1178] = {n:"Scortare il poco dotato.",d:"Devi scortare un cacciatore ferito al Borgo di Frigost perchè venga curato dal dottor Albert Pes.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1179] = {n:"Scortare il pessimo cacciatore.",d:"Devi scortare un cacciatore ferito al Borgo di Frigost perchè venga curato dal dottor Albert Pes.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1180] = {n:"A tutta velocità.",d:"Mentre Djauns sorveglia il suo tesoro devi recuperare un tiro di Baubau delle nevi e portarglielo. Hai i minuti contati.",r:[null,25000,[[11196,1]],null,null,null]};
Q.s[1186] = {n:"Una creatura si sveglia",d:"Un Alchimista potrà aiutarti meglio a comprendere l\'identità della creatura trovata nelle Lacrime di Uronigride.",r:[null,null,null,null,null,null]};
Q.s[1185] = {n:"I prelievi di Ogivol Victor",d:"Ogivol Victor ha bisogno del tuo aiuto per prelevare l\'acqua minerale e analizzarla per renderla potabile.",r:[null,null,null,null,null,null]};
Q.s[1181] = {n:"La coperta dello YeCh\'Ti.",d:"I Frigostiani hanno preparato una spedizione punitiva per sbarazzarsi dello YeCh\'Ti. Hanno bisogno di Pellicce intatte di Ghiacciopaz per disturbare la sua vigilanza.",r:[null,null,null,null,null,null]};
Q.s[1182] = {n:"Concorso di orrendi Pupazzomostri.",d:"Il piccolo Nic e i suoi amici hanno deciso di fare un concorso e tu sei il giudice. Devi scegliere quale fra i pupazzomostri di neve è il più orribile.",r:[null,null,null,null,null,null]};
Q.s[1188] = {n:"Omicidio a sangue freddo",d:"Spirito Prigioniero vuole vendicarsi dell\'agricoltore che lo ha ucciso. Ti ha chiesto di essere il suo braccio vendicatore.",r:[null,null,null,null,null,null]};
Q.s[1187] = {n:"Folli Ghiacchiopaz",d:"Dei Ghiacciopaz completamente folli hanno cominciato ad attaccare i viaggiatori. Devi sconfiggerli.",r:[null,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[409] = {n:"Chi mi ama mi segua!",d:"Il pwincipe di We ti ha chiesto un seguito degno della sua grandezza... Viste le prodezze in combattimento, la dieta particolare e il senso estetico, ci vogliono almeno quattro persone per assisterlo.",r:[45000,null,null,null,null,null]};
Q.s[693] = {n:"Porta la polvere.",d:"Devi portare dieci pods di polvere da sparo a Amayiro. Puoi comprarla a Bonta da Mub Ricifitra.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"L\'Invocazione sconosciuta.",d:"Amayiro ti ha chiesto di informarti presso Zeorg (il Maestro di classe Osamodas) a proposito dell\'Invocazione sconosciuta usata da Brakmar.",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Trova una falla.",d:"Devi trovare qualcosa di interessante sugli ingranaggi della grande porta di Brakmar.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"Volo sul nido di un cuculo.",d:"Amayiro vuole tendere un\'imboscata ai Brakmariani per testare il materiale nuovo e la coesione dei miliziani.",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Intercettazione brutale.",d:"Devi intercettare un convoglio d\'armi che passerà al margine della Foresta degli Alberagni per raggiungere il Villaggio dei Brigandini. Dei rinforzi sarebbero i benvenuti.",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"Il vecchio Orefice.",d:"Secondo il capo dei ladri, l\'Orefice di Brakmar Milon Coricel avrebbe delle informazioni.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"Bishom Pot, il ritorno.",d:"Amayiro sospetta Brakmar d\'essere all\'origine dei problemi di Bonta. Forse Bishom Pot, spia miliziana a Brakmar, ha scoperto qualcosa.",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Sotterraneo rigoroso",d:"Solo otto valorosi saranno capaci di conquistare questo sotterraneo.",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Sotterraneo misterioso",d:"Una pietra che sporge dalla montagna e una porta nascosta... Bisognerà trovare dei volontari per arrivare alla fine di questo cammino...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"Il sotterraneo della Biblioteca",d:"In tutti i sotterranei delle biblioteche si trovano tantissimi libri e tele di arakni...ma in questo particolare sotterraneo serpeggia un\'inquietante atmosfera misteriosa...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Sotterraneo tenebroso",d:"Una porta nascosta nella montagna porta a un sotterraneo, ma è ancora da scoprire in che modo...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Sotterraneo impenetrabile",d:"Attenzione alle Draguova! Devi attraversario il loro territorio per accedere a questa nuova grotta...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Sotterraneo rischioso",d:"Questo sotterraneo rischia di farti perdere la pazienza.",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Dal taverniere.",d:"Devi recuperare la carta di Amayiro e una birra dal Taverniere Fubuk.",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"La patata bollente.",d:"Devi pelare 200 pods di patate e portarle al cuoco della milizia.",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"Un Champello per Amayiro.",d:"Amayiro ti ha chiesto di portargli un Champello comune. Ne troverai sui Maestri Boleti.",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Pinta Gono vuole leggere la ricetta",d:"Ha già comprato tutto il materiale per il suo birrificio. Gli manca solo la ricetta.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Trova la ricetta della birra Bwork",d:"Pinta Gono cerca la ricetta della famosa birra Bwork. Pensa che si trovi in una strana sala del territorio Bwork.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Assalto al castello del We.",d:"Devi recuperare la Bandana di Garutar che è nelle mani dei Wobot nel Dongione del We Wabbit.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"Moda altamente rischiosa.",d:"Bisogna trovare un modo per far ritrovare alla Bandana Rotta il suo splendore e le condizioni in cui era un tempo. Un Sarto potrà aiutarti.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Recupero movimentato.",d:"Hai trovato la Spia in tempo, ma i Brakmariani non ti lasceranno di sicuro i documenti. Bisogna portarli a Amayiro a tutti i costi.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"Piccolo scherzo tra nemici.",d:"I Brakmariani dovevano consegnare i documenti al loro superiore. Hai redatto dei documenti falsi per sostituirli e portare i nemici su una falsa pista.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Corsa contro il tempo.",d:"Una Spia Bontariana sta fuggendo da Brakmar verso l\'Est. Bisogna ritrovarla e scortarla. Hai i minuti contati!",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Rapporto protetto.",d:"In questo momento un rapporto che ti bombarda di rimproveri dovrebbe trovarsi nella Torre degli Ordini di Bonta. Devi assolutamente metterci le mani sopra per provare la tua innocenza.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"Per vivere, ci vogliono dei viveri.",d:"Sotto la pressione del Consiglio, Amayiro ti ha tolto l\'inchiesta e ormai sei di corvé per l\'approvvigionamento.",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Furto alla torre.",d:"Trova un complice per distogliere l\'attenzione della guardia mentre effettuerai il furtarello.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"La fabbrica dei giochi.",d:"Delle abominevoli creature hanno svaligiato il deposito di Babbo Nawal. Devi recuperare le casse con i regali che hanno rubato, con o senza il loro consenso, e portarle a Felice Nawal.",r:[null,1000,[[10920,1]],null,null,null]};
