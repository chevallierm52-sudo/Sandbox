Q.s[7] = {n:"Papappa",d:"Chiedi a chi incontri informazioni sulla dieta di un Maomao medio. Poi torna con un po\' di cibo per il Maomao.",r:[1220,null,null,null,null,null]};
Q.s[9] = {n:"Maomao, un eroe?",d:"Aiutare questo povero Maomao a essere considerato un eroe dalla sua \"amicetta\".",r:[3060,null,null,null,null,null]};
Q.s[6] = {n:"Lalatte per un Maomao",d:"Porta il lalatte al povero Maomao.",r:[1220,null,null,null,null,null]};
Q.s[8] = {n:"Passeggiata col maomao",d:"Portare a passaggio il Maomao in città",r:[1500,null,null,null,null,null]};
Q.s[13] = {n:"Anello regalo",d:"Shani ti ha regalato un anello che possiede poteri nascosti. Per scoprirli devi uccidere un Alberagno.",r:[11000,1200,[[6793,1]],null,null,null]};
Q.s[12] = {n:"...un po\' spinosa",d:"Shani ha mal calcolato il numero delle spine di Fun Fung necessarie alla prova di domani. Vanne a prendere altre.",r:[2600,250,null,null,null,null]};
Q.s[11] = {n:"Riciclaggio d\'acqua puzzolente",d:"Portare la bava di Pappatutto a Shani Sings",r:[1700,200,null,null,null,null]};
Q.s[10] = {n:"Un amuleto peloso?",d:"Portare delle zampe di Arakne all\'Orefice, servono per la fabbricazione di un amuleto.",r:[1700,null,[[6773,1]],null,null,null]};
Q.s[24] = {n:"Borseggiatore",d:"Trova un metodo per procurarti il rapporto della spia e portalo a Ztiv Oztin.",r:[1200,null,[[6784,1]],null,null,null]};
Q.s[22] = {n:"La spia della mutua",d:"Trova Ztiv Oztin e proponigli i tuoi servizi...",r:[1200,null,null,null,null,null]};
Q.s[20] = {n:"Discrezione assicurata",d:"Trova Ogivol Scalarach, dovresti trovare l\'entrata del suo rifugio sotto una botola nascosta nel pavimento del deposito di legno.",r:[600,null,null,null,null,null]};
Q.s[121] = {n:"Trova e scorta il fuorilegge",d:"È probabile che Padgref Demoel si trovi a Nord-Ovest delle pianure di Cania, vicino al bosco di Litneg. \nÈ condannato all\'imprigionamento a Astrub con l\'accusa di deterioramento di Pappatutto domestico e baccano notturno.",r:[null,84500,null,null,null,null]};
Q.s[26] = {n:"Cercasi gambe rapide",d:"Il Panettiere ha urgentemente bisogno di fare 4 consegne. Vai a portare i dolci ai clienti il più velocemente possibile.",r:[1000,null,null,null,null,null]};
Q.s[29] = {n:"Alla ricerca del nuovo fattorino",d:"Trova una persona forte e agile che assuma il posto di nuovo fattorino.",r:[2000,250,null,null,null,null]};
Q.s[28] = {n:"Un fattorino seduttore",d:"Controlla che il fattorino Luk Drif sia veramente malato.",r:[2000,500,null,null,null,null]};
Q.s[30] = {n:"Un\'ultima consegna",d:"Vai a consegnare il dolce alla nonna.",r:[5000,null,null,null,null,null]};
Q.s[103] = {n:"La casa di Kolon",d:"Piañu Kolon ha dimenticato dove abita, è spaventatissima e non vuole più andare in città da sola...",r:[5750,250,null,null,null,null]};
Q.s[33] = {n:"Il mazzo di lino",d:"Bisogna trovare dei fiori di lino per la madre di Piañu Kolon. Solo gli alchimisti possono raccogliere questi fiori.",r:[2000,200,null,null,null,null]};
Q.s[31] = {n:"I banditi monchi",d:"L\'accampamento dei banditi monchi si trova a nord della foresta di Astrub, il peluche ce l\'ha sicuramente uno di loro...",r:[2000,null,null,null,null,null]};
Q.s[37] = {n:"In guardia Uomo Orso!",d:"Secondo Abrazelon bisogna attaccare l\'Uomo Orso in gruppo per essere sicuri che utilizzi il suo manoscritto in combattimento. Devi poi portarglielo per l\'autenticazione.",r:[9000,2500,null,null,null,null]};
Q.s[35] = {n:"Rapporto Osamodas",d:"Abrazelon Sixgrif ha parlato dell\'Uomo Orso, che è capace di controllare creature molto potenti. Prima di inseguirlo, dovrai avvertire Mang Iapoco delle tue scoperte...",r:[3000,null,null,null,null,null]};
Q.s[34] = {n:"La bestia pelosa",d:"Il pastore Mang Iapoco ha dei problemi con una bestia pelosa, cerca qualcuno che ne sappia di più su questa creatura...",r:[750,null,null,null,null,null]};
Q.s[36] = {n:"Sulle tracce dell\'Orso",d:"Devi seguire le tracce dell\'orso e scoprire dove si trova la sua tana...",r:[3000,null,null,null,null,null]};
Q.s[53] = {n:"Imbottitura puzzolente",d:"Alit ti consiglia di aggiungere un\'imbottitura al mantello. Ma per farlo devi portargli della lana di Pappatutto.",r:[3500,null,[[6801,1]],null,null,null]};
Q.s[54] = {n:"E tutto per un paraorecchie!",d:"Porta i materiali necessari alla fabbricazione di un paraorecchie. Alcuni saranno difficili da ottenere, dovrai chiedere aiuto.",r:[11000,500,[[6802,1]],null,null,null]};
Q.s[52] = {n:"Bisogno di lana",d:"Il sarto Alit ha bisogno di lana di Pappaton bianco e nero. Se gliene porti ti farà probabilmente un regalo su misura...",r:[2500,null,[[6800,1]],null,null,null]};
Q.s[49] = {n:"Bisogno di rinforzi",d:"Vai a cercare aiuto presso i Feca e gli Aniripsa.",r:[1200,null,null,null,null,null]};
Q.s[51] = {n:"Bisogno di una pala",d:"Torna a fare il tuo rapporto a Joe per ottenere la ricompensa che ti spetta.",r:[1200,null,[[6786,1]],null,null,null]};
Q.s[45] = {n:"Bisogno di manodopera",d:"Trova Howard il Simanul e consegnagli la lettera di Joe Pierlivet.",r:[600,null,null,null,null,null]};
Q.s[55] = {n:"Il sangue del Wabbit GM",d:"",r:[null,null,null,null,null,null]};
Q.s[57] = {n:"Analisi del sangue",d:"",r:[null,null,null,null,null,null]};
Q.s[58] = {n:"Wogew Wabbit",d:"",r:[null,null,null,null,null,null]};
Q.s[76] = {n:"La necessità di saperla usare",d:"Impara a utilizzare la tua nuova arma attaccando qualche insetto.",r:[900,null,null,null,null,null]};
Q.s[67] = {n:"Come forgiare una spada per negati",d:"Hai bisogno di un forgiatore per creare una spada.",r:[null,null,null,null,null,null]};
Q.s[68] = {n:"L\'utilità di una buona elsa",d:"Trova un\'elsa per fare fabbricare la tua spada.",r:[1200,null,null,null,null,null]};
Q.s[69] = {n:"L\'importanza delle rifiniture",d:"Porta la spada appena forgiata al tuo maestro.",r:[900,null,[[6780,1]],null,null,null]};
Q.s[63] = {n:"...dubbio!",d:"Porta la spada al tuo Maestro di classe. Ci metterà il marchio della tua classe.",r:[1200,null,null,null,null,null]};
Q.s[61] = {n:"Un metallo sospetto",d:"Porta la borsa di kama sospetti a una persona che possa cavarne qualcosa di interessante.",r:[600,null,null,null,null,null]};
Q.s[62] = {n:"Raffinazione sospetta",d:"Trasforma il tuo metallo sospetto.",r:[1200,null,null,null,null,null]};
Q.s[72] = {n:"Rubacuori",d:"I sassolini provengono dai dintorni delle miniere a nord-est del villaggio. Qui troverai il forziere di Luk.",r:[4000,null,null,null,null,null]};
Q.s[150] = {n:"La ricompensa",d:"Vai a prendere la tua ricompensa da Luk Drif.",r:[5000,null,[[1519,1]],null,null,null]};
Q.s[71] = {n:"Alla ricerca dei sassolini",d:"Esamina i sassolini per farne il paragone con quelli trovati da Luk. Per farlo, devi recarti nei differenti luoghi sospetti.",r:[1500,250,null,null,null,null]};
Q.s[70] = {n:"Scambio metaria con appuntamento",d:"Luk deve risolvere il problema del forziere e si deve anche preparare per il suo appuntamento. Vagli a comprare due rose, una per ogni ragazza.",r:[1500,500,null,null,null,null]};
Q.s[73] = {n:"Corri Forest!",d:"Ti piacciono i bambini? Questo lo odierai...",r:[600,50,null,null,null,null]};
Q.s[75] = {n:"Arco-Ocra-Arco-Moi",d:"Ah, che bello farsi fare il primo arco.",r:[1200,null,[[6783,1]],null,null,null]};
Q.s[78] = {n:"Ocratastrofe",d:"Adesso devi imparare ad usare l\'arco.",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Trova la fuorilegge",d:"Certi dicono di aver visto Frakacia Leukocytina vicino al villaggio dei Banditi Monchi.\nÈ ricercata per iniezioni illegali di emoglobina.\nÈ condannata all\'imprigionamento a Astrub.",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Trova il fuorilegge",d:"Certi dicono di aver visto Nervius Brekdaun vicino alla foresta degli Alberagni.\nÈ ricercato per furto di gioielli.\nÈ condannato all\'imprigionamento a Astrub.",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Trova il fuorilegge",d:"Certi dicono di aver visto Brumen Tinctorias vicino alle Lande di Sidimote. \nÈ ricercato per insubordinazione all\'ordine cosmico. \nÈ condannato all\'imprigionamento a Astrub.",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Trova il fuorilegge",d:"Fuduglen percorre tutta Astrub in cerca di buonissime ghiande da mettere sotto i denti.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Trova il fuorilegge",d:"Ogivol è stato visto vicino a Brakmar. È ricercato per aver sottratto una marea di cose, tra le quali dei documenti segreti.\nÈ condannato all\'imprigionamento a Astrub.",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Scorta di Miscuglio",d:"Tek Abir, l\'oste del villaggio, è obbligato a mischiare la birra con l\'acqua perché gliela rubano. Cerca il fattorino sulla strada di Sud-Ovest e scortalo.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"La fine dell\'oppressione?",d:"Metti fine al furto di birra.",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Kit di visione",d:"Trova diverse risorse per aiutare Chronokwartz a vedere il futuro.",r:[600,null,null,null,null,null]};
Q.s[92] = {n:"Il futuro non è roseo!",d:"Chronokwartz ti parla del tuo futuro immediato.",r:[1200,null,null,null,null,null]};
Q.s[91] = {n:"Il futuro è avventura!",d:"Chronokwartz ha bisogno di una pelle di larva per finire la sua invenzione.",r:[1200,null,null,null,null,null]};
Q.s[94] = {n:"Consegna",d:"Porta il rimedio che hai ottenuto a Clint Pot. Serve a curare i Tofu o gli Anutrof, non si sa bene. Ricordati di fare un rapporto al tuo Maestro di classe.",r:[1800,null,[[6785,1]],null,null,null]};
Q.s[93] = {n:"Suborhube...",d:"Aiuta il tuo Maestro di classe a trovare una medicina che curi i suoi Tofu.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"Prima sala",d:"Scopri come servirti dei tre Dofus.",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Seconda sala",d:"Trova la chiave.",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"Tic Tac!",d:"...",r:[2500,20,null,null,null,null]};
Q.s[145] = {n:"...forbici",d:"Con le forbici nuove che hai trovato, Tag Lia sarà al settimo cielo!",r:[1750,null,null,null,null,null]};
Q.s[133] = {n:"Un bel paio...",d:"Tag Lia Ciuf cerca delle forbici forgiate, ti consiglia di andare dal forgiatore del mercatino per comprargliene un paio...",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Capelli... sempre capelli...",d:"Tag Lia cerca tutti i tipi di capelli degli abitanti di Astrub, per farne delle parruche.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"Un primo indizio",d:"Gli Anutrof partiti alla ricerca dei fiutatutto si sono probabilmente persi nelle profondità delle gallerie. Questi luoghi sono infestati da miliratti d\'Isgustosi...",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"Uno tuo vale più di 2 pods di ratto",d:"Sbarazzati di questo Ratto d\'Isgustoso... sembra malato, non dovrebbe essere troppo difficile... insomma, se ci si prova in gruppo.",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"L\'inizio della fortuna",d:"Raccogli 10 zampe di Arakne per Vuoiun Amission. O per te... chissà? Comunque sia, sembra essere redditizio.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Piume malate",d:"Con venti piume si dovrebbe poter fare un piumino, nonostante l\'aspetto delle piume...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Ricompensa meritata",d:"Riparla con la nonna e mostrale la testa di scuiscuit.",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"La cantina infestata",d:"Andare nella cantina della nonna e sterminare la minaccia.",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Battere il miliziano.",d:"Devi battere Tarke il miliziano nella sala di fianco.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Dai del pane.",d:"Devi portare 20 unità di Pane di Grano Integrale a Amayiro.",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"I denti del Pappatutto.",d:"Devi strappare i denti a un Pappatutto, il numero esatto di una dentiera umana, e portarli a Ned, a Sud-Ovest della città.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"Una lezione al fratellino.",d:"Devi battere il miliziano Torcha e portarne la prova ad Amayiro.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Ritrova il Cuervoc.",d:"Devi ritrovare il Cuervoc che ha rubato la collana della figlia del sindaco, batterlo e recuperare la collana. Il Cuervoc si trova nei pressi della torre.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Caccia al cinghiale.",d:"Devi trovare il Cinghiale Aggressivo a Sud di Bonta e batterlo.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"La riparazione della Katana.",d:"Devi chiedere a Kosuke il forgiatore di riparare la lama di Amayiro in cambio dell\'assegno.",r:[4600,null,null,null,null,null]};
Q.s[690] = {n:"Bastona il cattivo pagatore.",d:"Il Taverniere Batosta deve una grossa somma a Amayiro: devi assolutamente convincerlo di pagare.",r:[null,null,null,null,null,null]};
Q.s[692] = {n:"Comunica con la Spia.",d:"Devi trovare Bishom Pot a Brakmar e farti dare le informazioni che Amayiro ha chiesto.",r:[5200,null,null,null,null,null]};
Q.s[694] = {n:"Chiudi la breccia.",d:"Shere Hacanon, all\'entrata di Bonta, ha bisogno di quattro Pietre di Croccaroc delle Pianure per tappare le brecce delle mura.",r:[6400,null,null,null,null,null]};
Q.s[696] = {n:"Collezione di elmi.",d:"Devi portare 15 Elmi di Chafer Scelto a Amayiro.",r:[7600,null,null,null,null,null]};
Q.s[698] = {n:"Poltiglia per il Tabi.",d:"Portare della Poltiglia di Fiori di Blop a Amayiro. Per ottenere questa Poltiglia, devi macinare quattro Fiori di Blop di colori diversi in un Frantoio Munster.",r:[8800,null,null,null,null,null]};
Q.s[700] = {n:"Agilità per Amayiro.",d:"Amayiro ti ha chiesto 20 Anelli di Agilità.",r:[10000,null,null,null,null,null]};
Q.s[702] = {n:"Porta i mantelli.",d:"Amayiro ti ha chiesto di portare 10 Mantelli Bontariani al capitano Koda, qui accanto. Si fabbricano con una Tintura Magica Blu, una Piuma di Cuervoc e una Lana di Pappaton Bianco.",r:[11400,null,null,null,null,null]};
Q.s[705] = {n:"Alle 21.",d:"Danathor ti ha chiesto di incontrarlo alle 21 con gli ingredienti indicati sulla lista.",r:[13500,null,null,null,null,null]};
Q.s[708] = {n:"Carne per il cuoco.",d:"Il cuoco della milizia di Bonta, Rei Nicuc, ha bisogno di 10 Cosce di Tofu.",r:[13500,null,null,null,null,null]};
Q.s[707] = {n:"Assassinio rifiutato.",d:"Torna da Amayiro.",r:[null,null,null,null,null,null]};
Q.s[712] = {n:"Porta il veleno.",d:"Il capitano Assacarf, della prigione di Bonta, ha bisogno di 30 pods di Veleno di Scorbuto.",r:[15600,null,null,null,null,null]};
Q.s[714] = {n:"Combattimento... per finta?",d:"Devi trovare Dike Tarak nel quartiere Nord, sfidarlo e vincere.",r:[null,null,null,null,null,null]};
Q.s[713] = {n:"Combattimento... per finta.",d:"Devi trovare Dike Tarak nel quartiere Nord, sfidarlo, e perdere.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Trova una falla.",d:"Amayiro ti ha chiesto di esplorare il Cimitero dei Torturati, a Est di Brakmar, e di vedere se c\'è una faglia nella difesa della città. Avrai sicuramente bisogno di materiale particolare.",r:[19000,null,null,null,null,null]};
Q.s[717] = {n:"Lavoro a scelta.",d:"Devi portare a Amayiro 20 Tavole di Frassino o 10 Radici di Alberagno.",r:[21000,null,null,null,null,null]};
Q.s[721] = {n:"Raid a Brakmar.",d:"Amayiro ti ha chiesto di battere dei guerrieri Brakmariani e di prendergli dieci badge.",r:[28000,null,null,null,null,null]};
Q.s[723] = {n:"Una bella lezione.",d:"Un certo William Linglés disturba gli abitanti di Bonta: bisogna farlo stare buono... con le maniere forti.",r:[34000,null,null,null,null,null]};
Q.s[724] = {n:"Nelle prigioni di Brakmar.",d:"Amayiro ti ha chiesto di salvare Hué Dapyus, nella prigione di Brakmar, e di riportarlo alla milizia Bontariana.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"Pandrista a gogo!",d:"Trova un mercante ambulante: potrai pagare a lui la tassa sulla Pandrista. Insisti moltissimo.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"C\'è il sole a Pandala",d:"Al tuo arrivo a Pandala, sei invitato a metterti in regola con l\'amministrazione: devi pagare la tassa sulla Pandrista.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"Il mio primo Sciaman Party",d:"Vai a chiedere urgentemente aiuto allo Sciamano!",r:[4700,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[170] = {n:"Un nuovo messaggio del saggio",d:"Un messaggero ha un messaggio per te, parlagli!",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Piccolo allenamento con lo scudo",d:"Per ringraziarti della consegna, il forgiatore di scudi ti regala un piccolo scudo d\'allenamento. Parla con il maestro del Dojo per fare un piccolo allenamento.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"L\'accento sul viaggio",d:"Il saggio Volpo ti chiede di andare al villaggio di Erdala... o di Terradala, impossibile essere sicuri con il suo accento. Una volta arrivato, parla con il maestro Pandawushu.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"Dal forgiatore di Scudi",d:"A Terradala, nessuno è disponibile per portare le risorse alla fucina di scudi. Eppure gli scudi sono indispensabili per i guerrieri Pandawa... Menomale che ci sei tu!",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Chi ha paura del cattivo maomao?",d:"Poochan cerca il suo futuro marito,ma di lui sa solo che dovrebbe trovarsi a Pandala, e che ha paura dei maomao. Per Poochan tanto vale trasformarsi in maomao e saltare in braccio a tutti, no?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Accordo consensuale",d:"Secondo l\'usanza è il padre che decide con chi i propri figli si sposeranno. Devi convicere il padre di cederti suo figlio. Devi fare tutto il possibile per ottenerlo.",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Conquista dei Dento",d:"Per liberare Lanma dal suo impegno, devi rompere la promessa di matrimonio che ha con una ragazza del Dojo Dento.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"Ricompensa?",d:"Poochan ti aspetta.",r:[7000,null,null,null,null,null]};
Q.s[174] = {n:"Passeggiata nello Spazio e nel Tempo di Amakna",d:"Questo Balzo nell\'Energia e nel Tempo di Amakna (B.E.T.A.) potrà salvare il mondo!",r:[null,null,null,null,null,null]};
Q.s[173] = {n:"Un Kuartz ed è fatta...",d:"Amin propone a Henual di usare il rimedio ultimo: ...il kuartz!",r:[null,null,null,null,null,null]};
Q.s[172] = {n:"C\'è posta per Amin!",d:"Devi andare al tempio Xelor per consegnare una lettera da parte del guardiano Henual.",r:[null,null,null,null,null,null]};
Q.s[178] = {n:"Bere o non bere?",d:"Un mercante ambulante ti venderà sicuramente una delle bevande fermentate che hanno reso celebre l\'isola. Non ti rimane che trovarne uno!",r:[null,null,null,null,null,null]};
Q.s[185] = {n:"Passaggio di grado Rokwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Rokwa.",r:[30000,null,null,null,null,null]};
Q.s[184] = {n:"Passaggio di grado Gokwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Gokwa.",r:[30000,null,null,null,null,null]};
Q.s[183] = {n:"Passaggio di grado Yonkwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Yonkwa.",r:[20000,null,null,null,null,null]};
Q.s[180] = {n:"Passaggio di grado Ikwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Ikwa.",r:[5000,null,null,null,null,null]};
Q.s[187] = {n:"Inizio dell\'allenamento",d:"Per cominciare l\'allenamento, bisogna ottenere un certificato sciamanico e una divisa Pandawushuka.",r:[null,null,[[7313,1]],null,null,null]};
Q.s[182] = {n:"Passaggio di grado Sankwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Sankwa.",r:[15000,null,null,null,null,null]};
Q.s[181] = {n:"Passaggio di grado Nikwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Nikwa.",r:[10000,null,null,null,null,null]};
Q.s[191] = {n:"Yondanwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Yondanwa.",r:[60000,null,null,null,null,null]};
Q.s[190] = {n:"Sandanwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Sandanwa.",r:[50000,null,null,null,null,null]};
Q.s[186] = {n:"Shodanwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Shodanwa.",r:[30000,null,null,null,null,null]};
Q.s[189] = {n:"Nidanwa",d:"Devi presentarti al maestro di sabato per fare l\'esame del grado Nidanwa.",r:[40000,null,null,null,null,null]};
Q.s[175] = {n:"Leggenda Volpa",d:"Finalmente! Sei arrivato alla meta! Ma le sorprese non sono finite! Il Volpo dell\'isola dei Wabbit ti rivelerà un grande segreto custodito da tempo...",r:[7500,null,null,null,null,null]};
Q.s[188] = {n:"Nel tempio del tuo dio",d:"Stai preparando la tua prossima spedizione seguendo i consigli del saggio Volpo. Per questo devi andare nel tempio della tua divinità a Amakna.",r:[7500,null,null,null,null,null]};
Q.s[176] = {n:"Dark Vlad, uno che ha due...!",d:"Purificati l\'anima e lavati le orecchie: il saggio Volpo ti rivela la verità sul Dofus di Pandala.",r:[40000,null,null,null,null,null]};
Q.s[193] = {n:"Il ricettacolo dei Dofus",d:"Il Grandapan ha accettato con gioia il regalo degli Anutrof. È un appassionato ammiratore dei cercatori di Dofus, e ti accoglierà a braccia aperte. Per soddisfare la tua curiosità sui Dofus, ti invita ad andare al ricettacolo dei Dofus.",r:[1500,null,null,null,null,null]};
Q.s[192] = {n:"Baci da Astrub",d:"Lo sciamano non ha tempo per te, è occupatissimo con i Pandikaze, la malattia degli Anutrof d\'Astrub e tutto il resto... Ti consiglia allora di parlare direttamente con Pyrita, un Anutrof in quarantena... se vuoi veramente aiutarlo.",r:[1500,null,null,null,null,null]};
Q.s[194] = {n:"La Via dell\'Acqua",d:"La Via dell\'Acqua consiste nel resistere in ogni modo... all\'assorbimento e all\'immersione (parziale e totale) in acqua. Non bere mai, lavarsi solo in caso di necessità. Trova il Maestro della Via dell\'Acqua: ne sa più di quello che sembra.",r:[10000,null,null,null,null,null]};
Q.s[207] = {n:"Il Grandapan",d:"Portare il falso Dofus al Grandapan.",r:[2200,null,null,null,null,null]};
Q.s[195] = {n:"Scudiero, Palafreniere, stesso combattimento.",d:"Dei Brakmariani hanno distrutto alcuni granai Bontariani. Bisogna trovare un modo per far mangiare le Cavalcature della milizia. Prova ad andare all\'atelier degli Alchimisti e parla con Merlisello.",r:[50000,null,null,null,null,null]};
Q.s[196] = {n:"Nella panni della spia.",d:"Dopo l\'incendio dei magazzini di viveri appiccato dai Brakmariani, Ebru Of El vuole sapere cosa stanno escogitando i nemici.",r:[50000,null,null,null,null,null]};
Q.s[197] = {n:"Alzatevi e camminate.",d:"Elviana Tirips vuole interrogare i Rinnegati Bontariani ma prima di poterlo fare... deve risuscitarli.",r:[50000,null,null,null,null,null]};
Q.s[782] = {n:"Agricoltura ad alto rischio.",d:"Fraka ha fiutato i piani di Bonta per accrescere la sua produzione di cereali. Ha bisogno di 20 Semi di Scorbuto affinché questa produzione sia utile per i progetti di Brakmar.",r:[50000,null,null,null,null,null]};
Q.s[200] = {n:"Brakmariani buoni a nulla.",d:"Siccome gli agenti Brakmariani sono degli incapaci, Fraka ti ha chiesto di andare ad Astrub per convincere il mercante Bontariano Raymond Santho a riapprovvigionare Brakmar.",r:[null,null,null,null,null,null]};
Q.s[783] = {n:"Intossicazione alimentare.",d:"Grazie al tuo rapporto, Olledrob ti ha affidato 20 Grani di Scorbuto modificati da deporre nell\'atelier degli Alchimisti di Bonta. Bisogna lasciarli di notte, quando Merlisello l\'Incatenatore dorme.",r:[50000,null,null,null,null,null]};
Q.s[198] = {n:"Inquietudini Brakmariane.",d:"Olledrob si chiede cosa si stia tramando a Bonta in questo momento. Ti manda sul posto per entrare in contatto con la spia Finch Aticus.",r:[null,null,null,null,null,null]};
Q.s[787] = {n:"Ho detto: Alzati e cammina!",d:"\"La maledizione d\'Orazzal\" ti ha insegnato come obbligare un\'anima a reincarnarsi contro la sua volontà. Per farlo bisogna creare una pozione particolare e seguire un rituale preciso.",r:[50000,null,null,null,null,null]};
Q.s[199] = {n:"Alzati e cammina.",d:"Divad non riesce a risuscitare Terra Tibya per interrogarlo. Bisogna quindi improvvisare un Incantesimo di Risurrezione che possa farlo, ecco la missione che ti è stata affidata.",r:[null,null,null,null,null,null]};
Q.s[201] = {n:"Trova il fuorilegge",d:"Rok è stato visto a Nord di Pandala.\nÈ condannato all\'imprigionamento a Astrub.\n",r:[null,6250,null,null,null,null]};
Q.s[202] = {n:"Trova il fuorilegge",d:"Musha è stato visto a Sud di Pandala.\nÈ condannato all\'imprigionamento a Astrub.",r:[null,64000,null,null,null,null]};
Q.s[203] = {n:"Trova il fuorilegge",d:"Marzwel è stato visto nei pressi di Erdala\nÈ condannato all\'imprigionamento a Astrub.",r:[null,25000,null,null,null,null]};
Q.s[206] = {n:"Trova la fuorilegge",d:"Ermyn è stata vista nei pressi di Terradala.\nÈ condannata all\'imprigionamento a Astrub.",r:[null,16000,null,null,null,null]};
Q.s[785] = {n:"Interrogazione a sorpresa.",d:"Elviana Tirips vuole sapere che informazioni i Rinnegati Bontariani hanno dato ai Brakmariani e sarai tu ad occuparti dell\'interrogatorio.",r:[200000,null,null,null,null,null]};
Q.s[786] = {n:"La caccia ai Rinnegati è aperta.",d:"Dei Rinnegati Bontariani si sono rifugiati a Brakmar. Devi ritrovarli ed eliminarli, poi portarne i resti a Bonta.",r:[200000,null,null,null,null,null]};
Q.s[209] = {n:"Il segreto di Terra Tibya",d:"Terra Tibya è finalmente risuscitata. Non ti resta che convincerla a rivelarti il suo segreto.",r:[200000,null,null,null,null,null]};
Q.s[208] = {n:"Il ponte di Terra Tibya",d:"Olledrob Oterges vuole impadronirsi delle Statuette di Sumens. Ti ha incaricato di catturare la loro guardia.",r:[200000,null,null,null,null,null]};
Q.s[214] = {n:"Parla a Bassofronte, Capo Mercenario di Astrub",d:"Bassofronte conosce le leggi relative al traffico di Dofawa.",r:[1000,45,[[7929,1]],null,null,null]};
Q.s[213] = {n:"Parla al Mago Ax",d:"Il Mago Ax dovrebbe poter analizzare le uova di Tofu e il Dofus.",r:[1000,null,null,null,null,null]};
Q.s[212] = {n:"Uova di Tofu per Nowa",d:"Porta a Nowa: x2 uova di Tofu",r:[1000,5,null,null,null,null]};
Q.s[217] = {n:"Porta una piuma di Pìu viola a Acidrik",d:"Ne ha bisogno per togliere la magia di Herdegriz dal plagio del suo libro.",r:[1500,100,[[7930,1]],null,null,null]};
Q.s[216] = {n:"Ottieni il libro falso di Acidrik",d:"Questo libro si intitola \"il tempo dei draghi\" e non \"il Tempo dei Draghi\".",r:[1000,200,null,null,null,null]};
Q.s[215] = {n:"Porta una birra a Acidrik",d:"È capace di leggerti il futuro nella schiuma di una buona birra.",r:[500,null,null,null,null,null]};
Q.s[219] = {n:"Vai dove l\'Infinito e il Nulla si uniscono",d:"Qui, troverai una risposta riguardo all\'anima di Menalt.",r:[1500,50,[[7934,1]],null,null,null]};
Q.s[234] = {n:"Simbolo e simbolismo",d:"Torna da Nistracolamus per scoprire il significato di questo famoso simbolo.",r:[1000,null,null,null,null,null]};
Q.s[218] = {n:"Scopri la statua del dio Xelor",d:"Bisogna ricordare il simbolo inciso sul martello del dio.",r:[500,null,null,null,null,null]};
Q.s[220] = {n:"La caverna del Culosse",d:"Si dice che il Culosse abiti questa caverna da molti lustri. L\'allevatore che vi si è avventurato non è mai tornato indietro...",r:[null,null,null,null,null,null]};
Q.s[221] = {n:"Un\'occhiata ai galeotti",d:"I prigionieri di Astrub sembrano irrequieti. Un Mercenario ti chiede di aiutarlo a sorvegliarli.",r:[1000,null,[[133,1]],null,null,null]};
Q.s[233] = {n:"Una bastonata ai galeotti",d:"Hai calmato i prigionieri di Astrub. Parlane a Edgg Komb.",r:[1000,50,null,null,null,null]};
Q.s[222] = {n:"Visita del castello di Allister",d:"Deghi Ketiristu ti propone di visitare i nuovi locali del castello e del porto.",r:[7000,50,null,null,null,null]};
Q.s[224] = {n:"Tavole per l\'impalcatura",d:"Porta delle tavole di frassino a Kartier Tremen per finire i tetti del castello di Allister.",r:[3000,876,null,null,null,null]};
Q.s[227] = {n:"Carne di larva",d:"Porta dei pezzi di carne di larva a Kartier Tremen perché possa sfamare gli operai.",r:[10000,1012,null,null,null,null]};
Q.s[226] = {n:"Grano per gli operai",d:"Porta del grano a Kartier Tremen perché possa sfamare gli operai.",r:[3500,599,null,null,null,null]};
Q.s[225] = {n:"Sassi per tappare i buchi",d:"Porta della selce a Kartier Tremen per finire i muri del castello di Allister.",r:[3500,1022,null,null,null,null]};
Q.s[232] = {n:"Kartier Tremen preferisce bere con un amico",d:"Ha bisogno di una birra e di un amico per passare una bella serata.",r:[7500,3000,null,null,null,null]};
Q.s[228] = {n:"Una bella tavola",d:"Kartier Tremen vuole stupire la sua futura fidanzata con una bella tavola ben guarnita.",r:[4000,4000,null,null,null,null]};
Q.s[230] = {n:"Un anello per Monabella",d:"Kartier Tremen vuole invitare Monabella a cena per chiederle di diventare la sua fidanzata.",r:[2500,null,null,null,null,null]};
Q.s[229] = {n:"Un anello per dessert",d:"Kartier Tremen vuole un anello di fidanzamento.",r:[8500,3000,null,null,null,null]};
Q.s[231] = {n:"Kartier Tremen si consola con Verru Kosa",d:"Invita Verru Kosa a condividere la cena.",r:[2500,null,null,null,null,null]};
Q.s[237] = {n:"I lunghi denti della corruzione",d:"Lo squalo offre dei kama a Verru Kosa.",r:[10500,null,null,null,null,null]};
Q.s[235] = {n:"La scia",d:"Verru Kosa cerca una squalo.",r:[2100,null,null,null,null,null]};
Q.s[238] = {n:"Denti da latte",d:"Verru Kosa ha voglia di un po\' di latte.",r:[12600,null,[[992,8],[989,8],[991,4]],null,null,null]};
Q.s[239] = {n:"Il sorriso dello squalo",d:"Lo squalo è contento di come stanno andando le cose.",r:[4800,null,null,null,null,null]};
Q.s[236] = {n:"Il vero squalo",d:"Verru Kosa vuole che io cacci lo \"slaquo\" dal porto.",r:[null,null,null,null,null,null]};
Q.s[242] = {n:"Una pozione di leccapiedi per un buon affare",d:"Kara Kiri forse vuole un po\' di pozione per i suoi affari con Allister.",r:[16500,1000,null,null,null,null]};
Q.s[240] = {n:"Gli ingredienti della pozione di leccapiedi",d:"Corno di Pappacol, Petalo di Rosa Demoniaca, Kralamore pulito e Semi di Papavero: ecco gli ingredienti necessari per fare una buona pozione di leccapiedi.",r:[6000,6000,null,null,null,null]};
Q.s[241] = {n:"Una pozione di leccapiedi per una rompiscatole",d:"Bisogna portare la pozione a Monabella.",r:[7500,689,null,null,null,null]};
Q.s[243] = {n:"Fai la birra",d:"Ghedin Lursgrò ha bisogno di bere birra per affrontare lo squalo.",r:[7000,30,null,null,null,null]};
Q.s[244] = {n:"Acqua nel luppolo",d:"A Ghedin Lursgrò è venuto mal di testa a furia di mischiare le birre.",r:[2000,40,null,null,null,null]};
Q.s[245] = {n:"Un po\' di birra",d:"Lo scaricatore berrebbe qualcosa per tirarsi su il morale.",r:[1000,30,null,null,null,null]};
Q.s[249] = {n:"Un Maomao per una rorompi",d:"Monabella vuole un Maomao bianco... sembra quasi che voglia partire in vacanza con uno zoo!",r:[150000,5000,null,null,null,null]};
Q.s[248] = {n:"Cavalcatura e olio per le vacanze",d:"Monabella ha bisogno di un dragacchino e olio di girasole per andare a riposarsi al sole nella sua futura capanna.",r:[140000,5000,null,null,null,null]};
Q.s[246] = {n:"Prigione e agenzia immobiliare",d:"Monabella vorrebbe trovare il vecchio rifugio di un galeotto per arredarlo a suo piacimento.",r:[20000,null,null,null,null,null]};
Q.s[247] = {n:"Capanna",d:"Monabella vuole una casa isolata lontana dalla corte.",r:[50000,null,null,null,null,null]};
Q.s[250] = {n:"Traffico di patate",d:"Bisogna consegnare i sacchi di patate alla prigione del porto.",r:[2000,null,null,null,null,null]};
Q.s[252] = {n:"Povera mela",d:"Mifach vuole che tu ringrazi Rocco Fidelio per le patate.",r:[2500,1200,null,null,null,null]};
Q.s[251] = {n:"Una pala per patate",d:"Mifach O\' Bel vorrebbe coltivare patate per soddisfare il proprio piacere personale.",r:[3000,null,[[538,12]],null,null,null]};
Q.s[253] = {n:"Bistecche di Dragacchino",d:"Kara Kiri, il macellaio ufficiale di Allister ha bisogno di carne fresca.",r:[5000,2500,[[10384,15]],null,null,null]};
Q.s[256] = {n:"Visita la biblioteca",d:"Visita la biblioteca",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[258] = {n:"Visita la biblioteca",d:"Visita la nuova biblioteca",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[261] = {n:"Dei ronzini per le bestie!",d:"Il miliziano è stato chiaro, gli servono dei dragacchini, e subito!",r:[75000,null,null,null,null,null]};
Q.s[262] = {n:"Cartografa la regione delle montagne dei Koalaks",d:"Zampalenta il cartografo non è più tanto giovane per fare lunghi viaggi.",r:[12000,50,[[7934,1]],null,null,null]};
Q.s[263] = {n:"Una raccolta facile",d:"Sulle montagne Koalaks crescono orchidee. Devi portarne un bel mazzo a Maskara.",r:[7500,4000,null,null,null,null]};
Q.s[264] = {n:"Una grande lista",d:"Koka Dekolak ha bisogno di materie prime molto specifiche.",r:[30000,null,[[989,10],[281,2]],null,null,null]};
Q.s[265] = {n:"Una consegna difficile",d:"Koka Dekolak vuole ancora materie molto specifiche, che si trovano in territorio Koalak.",r:[120000,6000,[[283,10],[548,5],[580,10]],null,null,null]};
Q.s[266] = {n:"Un\'ultima corsa per Koka",d:"Koka ha bisogno ancora una volta del tuo talento di raccoglitore.",r:[350000,11000,[[539,30],[991,10],[548,5],[6964,5],[6965,5]],null,null,null]};
Q.s[267] = {n:"La chiave del dongione",d:"Mostra la tua determinazione a Pappatuttater e vinci la chiave del dongione dei Pappatutto.",r:[7500,200,[[1568,1]],null,null,null]};
Q.s[268] = {n:"Il giro del mondo",d:"Metag, il guerriero, ti ha parlato di una reliquia dai favolosi poteri. Prima di proseguire devi fargli vedere quello che vali.",r:[5000,null,null,null,null,null]};
Q.s[281] = {n:"Andare dal Mastro",d:"Metag ha accettato di farti provare, ti manda dall\'enigmatico Mastro di Chiavi.",r:[10000,null,null,null,null,null]};
Q.s[271] = {n:"Continua l\'avventura",d:"Devi continuare a mostrare la tua determinazione.",r:[30000,null,null,null,null,null]};
Q.s[280] = {n:"Vai oltre",d:"Il Mastro di Chiavi ti ha mandato dal primo dei suoi amici.",r:[null,null,null,null,null,null]};
Q.s[270] = {n:"Continua l\'avventura",d:"Devi continuare a mostrare la tua determinazione.",r:[30000,null,null,null,null,null]};
Q.s[269] = {n:"Combatti nel primo dongione",d:"La missione dell\'artefatto è iniziata, affronta i mostri del dongione dei campi.",r:[15000,null,null,null,null,null]};
Q.s[272] = {n:"Continuare l\'avventura",d:"Devi continuare a mostrare la tua determinazione.",r:[40000,null,null,null,null,null]};
Q.s[273] = {n:"Per il titolo",d:"Pat ti serve come arbitro per questa parte della missione.",r:[45000,null,null,null,null,null]};
Q.s[279] = {n:"Passa alla tappa successiva",d:"Pat Akess ti ha indirizzato verso la persona che può aiutarti a dimostrare il tuo valore.",r:[null,null,null,null,null,null]};
Q.s[278] = {n:"Per il titolo",d:"Pat non ti molla con lo sguardo neanche un secondo.",r:[75000,null,null,null,null,null]};
Q.s[276] = {n:"Per il titolo",d:"Pat ti osserva attentamente.",r:[55000,null,null,null,null,null]};
Q.s[275] = {n:"Per il titolo",d:"Pat giudicherà le tue capacità.",r:[45000,null,null,null,null,null]};
Q.s[277] = {n:"Per il titolo",d:"Pat ha gli occhi fissi su di te.",r:[65000,null,null,null,null,null]};
Q.s[274] = {n:"Per il titolo",d:"Pat ti serve come arbitro per questo round.",r:[45000,null,null,null,null,null]};
Q.s[288] = {n:"Una semplice tappa",d:"Nonostante l\'asprezza dei combattimenti che hai dovuto portare a termine, si trattava solo di una semplice tappa.",r:[null,null,null,null,null,null]};
Q.s[283] = {n:"Non perder tempo",d:"Crys non sta per niente meglio. È meglio sbrigarsi prima che le sue condizioni peggiorino.",r:[135000,null,null,null,null,null]};
Q.s[284] = {n:"Dai dai dai!",d:"Malgrado i suoi stati d\'animo, Crys ti permette di continuare la tua caccia alla reliquia.",r:[145000,null,null,null,null,null]};
Q.s[287] = {n:"L\'ultima battaglia?",d:"Credevi fosse la tua ultima battaglia prima della vittoria.",r:[175000,null,null,null,null,null]};
Q.s[282] = {n:"Vai altrove",d:"Crys è un po\' stressato. È meglio fare subito quello che chiede.",r:[125000,null,null,null,null,null]};
Q.s[285] = {n:"Una vera sfida",d:"Crys ti manda in posti sempre più pericolosi.",r:[155000,null,null,null,null,null]};
Q.s[286] = {n:"Ancora uno",d:"Senti che la tua missione avanza... lentamente.",r:[165000,null,null,null,null,null]};
Q.s[296] = {n:"L\'ultima chiave",d:"Kal ti ha dato l\'ultima delle sue chiavi. Stai per giungere alla meta.",r:[450000,null,null,null,null,null]};
Q.s[297] = {n:"Consacrazione?",d:"Kal non ha potuto confidarti nulla. Torna dal Mastro di Chiavi.",r:[null,null,null,null,null,null]};
Q.s[289] = {n:"Un messaggio molto chiaro",d:"Kal, una specie di macchina, ti aiuta a portare avanti la tua missione. Con lui almeno, gli obiettivi sono chiari.",r:[250000,null,null,null,null,null]};
Q.s[291] = {n:"Guasto tecnico",d:"Kal non ha risolto i suoi problemi ma ciò non ti impedisce di andare avanti nella tua missione.",r:[350000,null,null,null,null,null]};
Q.s[295] = {n:"Manca un bullone",d:"Kal è bloccato ma ti dà le chiavi.",r:[400000,null,null,null,null,null]};
Q.s[290] = {n:"Problemi?",d:"Kal non ha potuto trasmetterti la totalità del messaggio ma con la chiave puoi facilmente indovinare quello che devi fare.",r:[300000,null,null,null,null,null]};
Q.s[299] = {n:"Il maestro stallone",d:"Il maestro ti prende per una vera e propria macchina da guerra, ancora una prova!",r:[725000,null,null,null,null,null]};
Q.s[298] = {n:"Il maestro dei nastri",d:"Il maestro ha deciso di farti passare altre prove. Sta diventando pesante.",r:[500000,null,null,null,null,null]};
Q.s[301] = {n:"Il maestro decolla.",d:"Finalmente! Il maestro di chiavi ti ha affidato l\'ultima prova.",r:[875000,null,null,null,null,null]};
Q.s[300] = {n:"Il maestro delle regole",d:"Sembra proprio che tu non possa scappare a questa interminabile lista di massacri. Ma se bisogna passarci per forza...",r:[800000,null,null,null,null,null]};
Q.s[307] = {n:"Il maestro del gioco",d:"Ancora un territorio ostile da attraversare.",r:[650000,null,null,null,null,null]};
Q.s[306] = {n:"Il maestro pericoloso.",d:"Questa volta, il maestro ti manda nel bel mezzo di territori in conflitto.",r:[575000,null,null,null,null,null]};
Q.s[302] = {n:"Finalmente!",d:"Finalmente, sei alla fine delle tue sofferenze. Adesso Metag deve mantenere la promessa. L\'ultima reliquia della sua famiglia sarà tua!",r:[1000000,null,null,null,null,null]};
Q.s[315] = {n:"Servizio rapido",d:"La Filtunga di Pol deve essere già pronta.",r:[null,null,null,null,null,null]};
Q.s[312] = {n:"Ai fornelli!",d:"La ricetta della Filtunga è nelle tue mani. Non ti resta che trovare tutti gli ingredienti perché Pol possa preparare il celebre piatto.",r:[115000,5000,null,null,null,null]};
Q.s[311] = {n:"Un piatto unico",d:"La crudele Paindep minaccia di mangiare i bambini di El se non le si offre qualcosa di meglio.",r:[75000,null,null,null,null,null]};
Q.s[313] = {n:"Gli ingredienti",d:"Pol il cuoco cucinerà la ricetta se gli porti tutti gli ingredienti.",r:[115000,null,null,null,null,null]};
Q.s[316] = {n:"La liberazione",d:"Pol ha finito la Filtunga, Paindep dovrebbe essere soddisfatta.",r:[120000,null,null,null,null,null]};
Q.s[310] = {n:"La piccola capanna nella foresta",d:"Il giovane Jorg ha parlato di una capanna segreta nella foresta dei dragacchini.",r:[25000,null,null,null,null,null]};
Q.s[309] = {n:"Il giro del villaggio",d:"I paesani hanno sicuramente visto i bambini di El. Interrogali per ottenere qualche informazione.",r:[35000,null,null,null,null,null]};
Q.s[308] = {n:"Una madre preoccupata",d:"Dama El è preoccupata. Sta cercando i suoi figli nel villaggio di Amakna.",r:[null,null,null,null,null,null]};
Q.s[314] = {n:"Fast food",d:"Adesso Pol ha tutto quello che gli serve per cucinare la Filtunga. Non rimane che aspettare.",r:[15000,null,null,null,null,null]};
Q.s[321] = {n:"Uccidere dei Bwork",d:"Gobacief vuole che i Bwork siano massacrati prima che loro massacrino i Goblin.",r:[20000,1000,null,null,null,null]};
Q.s[322] = {n:"Krazybwork vuole tornare stupido",d:"Krazybwork ha mangiato troppi Goblin durante la battaglia di Bworkdrift. È diventato intelligente ma vuole tornare stupido. La cosa migliore è di dargli un colpo in testa!",r:[null,500,[[8527,1]],null,null,null]};
Q.s[323] = {n:"Bworkidé il paxifiko",d:"Bastone o non bastone?",r:[15000,null,null,null,null,null]};
Q.s[325] = {n:"Ritaglia seguendo i puntini",d:"Bworknroll ha bisogno di riempire la sua creatura di organi freschi (e succosi).",r:[150000,null,null,null,null,null]};
Q.s[326] = {n:"Non dimenticarti la cosa più importante: il mollusco!",d:"Bworknroll ha bisogno di un mollusco che esca dall\'acqua per finire la sua creatura dei sogni.",r:[230000,5000,null,null,null,null]};
Q.s[324] = {n:"Un utile scalpello",d:"Bworknroll ha bisogno di pezzi per mettere insieme la sua compagna ideale.",r:[120000,null,null,null,null,null]};
Q.s[375] = {n:"Che denti grandi che hai...",d:"Un Buulupo ti fa una proposta allettante.",r:[null,null,null,null,null,null]};
Q.s[376] = {n:"Iscrizione",d:"Se Bworknroll accetta il pagamento, Titi potrà diventare un mago.",r:[null,null,null,null,null,null]};
Q.s[328] = {n:"Accompagna Titi",d:"Il padre di Titi vorrebbe che diventasse mago. Per questo, bisogna portarlo dal più potente dei Bwork Maghi con qualcosa da mangiare.",r:[null,null,null,null,null,null]};
Q.s[374] = {n:"Titi ha una borsa di studio",d:"Bworknroll ha accettato d\'insegnare la magia a Titi. Annuncia la notizia al padre.",r:[null,null,null,null,null,null]};
Q.s[330] = {n:"Pelli verdi",d:"Bworkospino vuole pelli di goblin per le sue femmine.",r:[45000,30000,null,null,null,null]};
Q.s[331] = {n:"Una bacchetta e una panoplia",d:"Capo Bworkestre ha bisogno di provare la propria virilità alla sua dolce e tenera metà chiedendo regali ai visitatori di passaggio.\nCon una panoplia Prespic, spera di proteggersi dai colpi di mattarello della sua amata bworketta.",r:[45000,35000,null,null,null,null]};
Q.s[340] = {n:"Parole parole parole...",d:"Gobrosa preferisce essere una schiava e allevare dei Pìu. È una triste verità da rivelare al suo pretendente...",r:[20000,null,null,null,null,null]};
Q.s[339] = {n:"Spennare Gobrosa",d:"Gobmiket è geloso dei Pìu di Gobrosa. Solo i battiti del suo piccolo cuore di goblin verde devono fare palpitare quello di Gobrosa.",r:[3000,null,null,null,null,null]};
Q.s[337] = {n:"Riempirsi la pancia",d:"Bworksina è pronta a cedere la schiava in cambio del suo peso in birra Bwork.",r:[12000,null,null,null,null,null]};
Q.s[338] = {n:"Concedi il pretendente",d:"Gobrosa e Gobmiket si riuniranno?",r:[null,3000,null,null,null,null]};
Q.s[336] = {n:"Trova il rifugio di Bworksina",d:"Gobrosa è rinchiusa là dentro.",r:[1000,null,null,null,null,null]};
Q.s[354] = {n:"Combatti per la guardia",d:"Il capitano ti ha affidato un compito facile ma utile.",r:[195,null,null,null,null,null]};
Q.s[345] = {n:"Cambio di guardia",d:"Disskray ti ha chiesto di controllare che le guardie facciano bene il loro lavoro.",r:[230,null,null,null,null,null]};
Q.s[362] = {n:"Tornare in vita",d:"Aymé Ternel ti ha trasformato in fantasma, usa la fenice per tornare in vita.",r:[null,null,null,null,null,null]};
Q.s[363] = {n:"Osiamo Osa!",d:"Questo Osa vanitoso merita una bella lezione!",r:[500,null,[[8534,1]],null,null,null]};
Q.s[368] = {n:"Combatti per la guardia",d:"Il capitano ti ha affidato un compito facile ma utile.",r:[195,null,null,null,null,null]};
Q.s[369] = {n:"Combatti per la guardia",d:"Il capitano ti ha affidato un compito facile ma utile.",r:[195,null,null,null,null,null]};
Q.s[370] = {n:"Combatti per la guardia",d:"Il capitano ti ha affidato un compito facile ma utile.",r:[195,null,null,null,null,null]};
Q.s[372] = {n:"Trova dell\'aguerelo",d:"Malgrado il forte accento hai capito la domanda di Marylork.",r:[75,75,null,null,null,null]};
Q.s[373] = {n:"Lykhen sragiona",d:"Lykhen racconta la sua vita di vecchio avventuriero.",r:[10,null,null,null,null,null]};
Q.s[385] = {n:"Trova il rifugio dei Ladrurbi",d:"Yse Vewybad ti ha dato delle informazioni sulla posizione dei Ladrurbi. Vai a fare un giro nei pressi del cimitero.",r:[9000,null,null,null,null,null]};
Q.s[384] = {n:"Trova l\'Etram",d:"Yse Vewybad ti ha parlato di un Etram importante ad Amakna... Ma dove si trovano gli Etram a Amakna?",r:[1000,null,null,null,null,null]};
Q.s[394] = {n:"Trova il pretendente",d:"Devi trovare un pretendente per Allisteria, la figlia del fratello del re.",r:[15000,null,null,null,null,null]};
Q.s[395] = {n:"Alla ricerca di informazioni",d:"Vil Smis vuole che tu scopra cosa si sta preparando al castello. Devi trovare una persona che lo sappia.",r:[3000,null,null,null,null,null]};
Q.s[396] = {n:"Cercare l\'ago in un pagliaio",d:"Adesso sai che il re deve far sposare sua nipote... ma con chi?",r:[12000,null,null,null,null,null]};
Q.s[402] = {n:"Falsa identità",d:"Come puoi ben vedere, Uba Tessé ti ha trasformato in Wabbit. Non ti rimane che andare al castello per sabotare questo matrimonio.",r:[50000,25000,null,null,null,null]};
Q.s[401] = {n:"Dopo la ricetta, gli ingredienti.",d:"Adesso che Uba ha la formula, non gli rimane che trovare gli ingredienti.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"Una formula, solo una!",d:"Devi trovare gli alchimisti sparsi per Amakna.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit wulez !",d:"Trovare un modo per trasformarsi in Wabbit.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"All\'ingrasso",d:"Hai l\'uovo di tofu obeso, ma il solo uovo non farà niente al pwincipe... bisogna mettere all\'ingrasso il pulcino che c\'è dentro.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Un uovo tutto nuovo",d:"Vil Smis ti ha chiesto di portargli un uovo di tofu obeso. Ma devi trovare il nido...",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"Assassini da assoldare",d:"Vil Smis non può usare il blopisiero avvelenato e sceglie l\'attacco frontale. Per questo, ha bisogno di soldi per assoldare degli assassini.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"Un regalo avvelenato",d:"Vil Smis ha deciso di evitare il contatto diretto e di fare le cose nel modo più tradizionale per i Ladrurbi: con l\'inganno.",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Guastafeste",d:"Gli assassini hanno fallito con il principe... Vil Smis ti chiede di assoldare un Volpo per ucciderlo.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"Morte al tofu!",d:"Sai più o meno dove il pwincipe di We è andato a cacciare... a sud di Bonta o giù di là. Adesso bisogna trovarlo.",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"Al lavoro",d:"Vai a chiedere al capomastro cosa devi fare.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Un favore o... per favore?",d:"L\'intendente San Lavals ti chiede di dare una mano per gli ultimi preparativi del matrimonio.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"Prima tappa",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"Un travestimento per Smeralda",d:"Smeralda cerca disperatamente una panoplia Koalak.",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Rispondi al questionario",d:"Il Guardiano del Ponte della Morte esige che tu risponda correttamente alle sue domande.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Come preparare un viaggio",d:"Il Capitano Kradoc ha bisogno di numerosi oggetti per poterti accogliere nella sua barca.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"Il Forziere Maledetto del Flib",d:"La barca del Capitano Kradoc si è arenata sull\'isola dei naufraghi. Devi ritrovare il Forziere Maledetto del Flib e qualche altro oggetto per riparare la barca.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"Non passerai!",d:"Il Cavaliere Nero e Rosa è fermamente deciso a non lasciarti passare. Forse è arrivato il momento di usare le maniere forti.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"Una pozione per il professore",d:"Il Professor Furnesol ha bisogno di una Pozione Bulbica per tornare al lavoro.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Macchine per l\'allevamento",d:"Polka Merer ha bisogno di macchine di allevamento per le sue creature.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"Una questione di farina",d:"Paolina Pan-duro, la panettiera, ha intenzione di tagliare la farina di Xavier il Panettiere con diversi tipi di farina a buon mercato. Lei ha avuto l\'idea, tocca a te trovare le farine ora!",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"Alla ricerca del figlio nascosto",d:"Il Dottor Nauh ha perso suo figlio in un laboratorio infestato di terribili creature selvagge. Devi ritrovarlo e assicurarti che sia ancora in vita.",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"Il Dottore è lugubre",d:"Il Povero Dottor Le Gubré ha perso sua moglie. Aiutalo a ritrovarla nella Giungla Oscura e cerca di persuaderla a tornare dal marito perché lui possa riprendere le sue ricerche.",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"L\'equipaggiamento migliorato",d:"Spit Fayer cerca un casco e un mantello da pilota migliorati. Solo un sarto esperto potrà aiutarti.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Due Dragacchini per Flip Flap",d:"Flip Flap vorrebbe che tu gli portassi un certificato di Dragacchino Rosso e un certificato di Dragacchino Mandorla.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Caccia nella Giungla Oscura",d:"Coccodrail Dandy vorrebbe che tu cacciassi per lui qualche creatura della Giungla Oscura.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Caccia nelle Pianure",d:"Coccodrail Dandy vorrebbe che tu cacciassi per lui numerose creature delle Pianure.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Caccia sulla spiaggia",d:"Coccodrail Dandy vorrebbe che tu eliminassi certe creature sulla spiaggia di Corallo.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Caccia nell\'Albero Hakam",d:"Coccodrail Dandy vorrebbe che tu cacciassi per lui qualche creatura dell\'Albero Hakam.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Caccia nella Torbiera senza fondo",d:"Coccodrail Dandy vorrebbe che tu cacciassi per lui qualche creatura della Torbiera senza Fondo.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"Un esempio per i Pirati",d:"Kito ti ha chiesto di fare un esempio per i Pirati che gli lanciano delle palle di cannone.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"Il Cavaliere Nero e Rosa",d:"Peggy la Porkass vorrebbe che tu affrontassi il terribile Cavaliere Nero e Rosa al posto suo.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"Lo scambio maledetto",d:"Farle Ingals è sicuramente la sola persona a Amakna in grado di rendere utilizzabile questa spada maledetta...",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"Veloce, veloce!",d:"Milon sembra essere sul punto di essere svaligiato. Bisogna impedirlo subito.",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Esca sbagliata?",d:"Il viaggio è stato senza incidenti. I banditi non hanno attaccato... Amayiro aspetta il tuo rapporto.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"Trappola per Ecaflip.",d:"Amayiro vuole tendere un\'imboscata ai banditi ed ha bisogno di un Gioiello di gran valore per attirarli nella sua trappola.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Scorta Gerl.",d:"La tua missione è scortare la truppa dei Mercanti di Gerl fino ad Astrub.",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"A rapporto.",d:"Il convoglio è stato attaccato da alcuni banditi Ecaflip che assomigliano a quelli di cui hai scoperto l\'accampamento. Amayiro aspetta il tuo rapporto per convincere il Consiglio ad agire.",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Una buona Rigalata.",d:"Si dice che Rigal Mano Uncinata, al Tempio Etram, possieda numerose informazioni, ma ogni informazione ha un prezzo. Resta da sapere a quanto ammonta il tuo.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"È fresco il mio veleno.",d:"Devi trovare le riserve di veleno di Brakmar e rubare il registro dei clienti dell\'atelier degli Alchimisti. Bishom Pot forse potrà aiutarti.",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"Il Bignami dell\'alchimia.",d:"Devi rubare il registro dei clienti nell\'atelier degli Alchimisti di Brakmar e portarlo a Rigal Mano Uncinata.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Complicità aumentata.",d:"Per penetrare nelle riserve di veleno di Brakmar, avrai bisogno dei servizi di un Etram o di una Spia qualificata.",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Acchiappa-tonto.",d:"Un appuntamento tra un Brakmariano e il Bontariano corrotto avrà luogo alla Torre di Bonta. Bisogna catturarli tutti e due, se possibile.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"Nessuna via d\'uscita per i traditori.",d:"Devi fare il giro dei miliziani per appostarli alla Torre di Bonta.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"Bwork, che puzza!",d:"O Epuop Tik non sa altro, o si rifiuta di dirtelo. Ad ogni modo, i Bwork Maghi dovrebbero essere meno reticenti nel darti informazioni su uno dei loro.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Danathor, cosa stai tramando ancora?",d:"Sembra che Danathor abbia una nuova offerta da farti. Probabilmente qualcosa di losco.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"La Bambola Incantata.",d:"Devi trovare quattro Sadida abbastanza esperti per invocare delle Gonfiabili per un rituale nelle Acque Incantate dei Laghi Koalak.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Formidabilissimo.",d:"Se togli la maledizione che pesa su Jibworkfloscio, in segno di riconoscimento ti dirà di sicuro quello che sa. Ti ha suggerito di informarti in biblioteca.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"Alla ricerca del cancelliere amareggiato.",d:"Aigurraf, Cancelliere dell\'Ordine dell\'Occhio Attento, va di taverna in taverna da quando il suo topo è sparito. Bisogna riportarlo da Ebru Of El.",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Uscita di prigione.",d:"Devi salvare un guerriero che è stato catturato da Bonta: si trova nella prigione della milizia Bontariana, nel sottosuolo.",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"Il nemico intimo.",d:"Trova ed elimina il bersaglio.",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Vinci il combattimento.",d:"Continua ad attaccare il tuo Bersaglio per vincere il combattimento. Salta un turno con il tasto  {ui,banner,btn_skipTurn::Fine del Turno} per recuperare i {ui,banner,lbl_pa,2::PA} e i {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Termina il combattimento",d:"Vinci il combattimento contro il mostro. Attenzione, i turni di gioco d\'ora in poi avranno una durata limitata. La {ui,banner,tx_artwork,3::Capacità di tempo rimanente} indica quanto tempo ti resta prima della fine del turno.",r:[null,null,null,null,null,null]};
Q.s[1042] = {n:"Spostamento sulla mappa.",d:"Benvenuto nel tutorial guidato. Fai un clic sinistro con il tuo mouse attorno al tuo personaggio per farlo spostare. Se clicchi lontano dal tuo personaggio, correrà, altrimenti camminerà.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Passa il tuo turno.",d:"Quando hai terminato le tue azioni, fai un clic sinistro sul tasto {ui,banner,btn_skipTurn::Fine del Turno} con il mouse per accelerare lo svolgimento del combattimento e recuperare i {ui,banner,lbl_pa,2::PA} e i {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Equipaggia un Oggetto.",d:"Apri l\'interfaccia di {ui,banner,btn_character,1::Caratteristiche}. Seleziona l\'{ui,storage,grid::Anello del Principiante} , che hai appena vinto, tenendo premuto il pulsante sinistro del mouse e deponilo nell\'{ui,characterSheetUi,slot_2,2::Area riservata all\'Anello} della scheda del personaggio.\nPuoi equipaggiarlo anche effettuando un doppio clic sinistro con il mouse sull\'{ui,storage,grid::Anello del Principiante}.",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"Equipaggia gli oggetti",d:"Apri l\'interfaccia delle {ui,banner,btn_character,1::Caratteristiche} ed equipaggia sul tuo personaggio gli Oggetti vinti.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Come puoi spostarti durante il combattimento.",d:"Il tuo personaggio ha a disposizione alcuni {ui,banner,lbl_pm,2::Punti Movimento} (PM) per spostarsi. Spostarsi di una casella costa 1 PM. Sposta il personaggio con un clic sinistro del mouse su una casella.\nRecupererai i {ui,banner,lbl_pm,2::PM} all\'inizio del prossimo turno.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Utilizza un Incantesimo.",d:"Seleziona {ui,banner,gd_spellitemotes,0::un Incantesimo} e fai un clic sinistro con il mouse su un Bersaglio. Alcuni Incantesimi possono essere lanciati sui nemici, altri sugli alleati o sul tuo personaggio. La Portata dell\'Incantesimo è indicata dalle caselle blu. Gli Incantesimi hanno bisogno di {ui,banner,lbl_pa,2::Punti Azione} (PA) per essere lanciati. Recupererai i {ui,banner,lbl_pa,2::PA} all\'inizio del prossimo turno.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Scegli la tua posizione di partenza.",d:"Fai un clic sinistro su una delle {cell,272::Caselle Blu} con il mouse per scegliere la tua posizione di partenza e clicca sul tasto {ui,banner,btn_ready:: Pronto} per cominciare il combattimento.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Cambia mappa.",d:"Per cambiare mappa, sposta il cursore su uno dei {arrow,1280,520,0,0::lati dello schermo} e fai un clic sinistro con il mouse quando il cursore si trasforma in freccia.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Sconfiggi il mostro.",d:"Per continuare la tua missione, innanzitutto devi andare nella sala successiva {arrow,700,870,0,1::salle suivante} e dare inizio ad un combattimento contro il mostro {monster,2781::le monstre}.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Concludi l\'Apprendimento.",d:"Per convalidare la tua missione, devi parlare con {npc,1222::Guida A\'Naso} .",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Comincia una Missione.",d:"Parla con {npc,1222::Guida A\'Naso} per lanciare una Missione (i PNG che propongono Missioni hanno un punto esclamativo sulla loro testa).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Parla ad un PNG.",d:"Fai un clic sinistro su {npc,1222::Guida A\'Naso} con il tuo mouse e seleziona l\'azione «Parla» per dialogare con lui.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Dai inizio ad un combattimento.",d:"Fai un clic sinistro sullo {monster,2785::Spaventapasseri di Incarnam} con il mouse per dare inizio ad un combattimento.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"Una vita complicata.",d:"Avresti dovuto seguire i consigli di Ke Kasin e non fidarti. Ora, si direbbe che qualcuno voglia farti la pelle. Ahimé, la vita non è facile come si vuol credere.",r:[null,null,null,null,null,null]};
Q.s[1058] = {n:"Ne usciremo tutti vivi.",d:"Grazie al tuo aiuto, Ke Kasin è in grado di estirpare il male che colpisce il Mercato di Bevande Pandawa, a condizione di trovare un antidoto.",r:[3000,null,[[10818,1]],null,null,null]};
Q.s[1056] = {n:"La bella vita.",d:"Appena arrivato, ti è già stato proposto un modo per guadagnarti da vivere facilmente senza fare troppi sforzi. Cosa chiedere di più?",r:[null,null,null,null,null,null]};
Q.s[1091] = {n:"La fabbrica dei giochi.",d:"Delle abominevoli creature hanno svaligiato il deposito di Babbo Nawal. Devi recuperare le casse con i regali che hanno rubato, con o senza il loro consenso, e portarle a Felice Nawal.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1054] = {n:"Non tradurre.",d:"Non tradurre! Missione utilizzata per far apparire in permanenza un punto esclamativo sul PNG Fata Sorriso.",r:[null,null,null,null,null,null]};
