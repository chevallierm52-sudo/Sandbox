Q.s[1123] = {n:"Sei in grado di scotennare i Pappabuk?",d:"Truffo ti ha chiesto di placare gli ardori di Realbuk, diventato aggressivo a causa del caldo tropicale della serra e della mancanza di cibo.",r:[165500,null,null,null,null,null]};
Q.s[1165] = {n:"Il mio regno per un pescetto.",d:"Waldos FieldChester Potcobble vuole cucinare un Pescetto reale in occasione di una cena a lume di candela con Aurora Boreale. Ti ha incaricato di fornirglielo.",r:[null,null,null,null,null,null]};
