Q.s[1126] = {n:"Il popolo migratore.",d:"Il Capitano Ardier ti ha proposto una magnifica crociera sulla sua autentica nave per andare a visitare la lontana Isola di Frigost.",r:[34000,null,null,null,null,null]};
Q.s[1124] = {n:"Un sindaco seducente...",d:"Il mozzo Haka ti ha indicato dove trovare il sindaco donna che potrà darti informazioni sul Borgo di Frigost e sui suoi abitanti.",r:[17000,null,null,null,null,null]};
Q.s[1125] = {n:"Sito di incontri.",d:"Per familiarizzare con il Borgo, la sindaco Stoletta ti ha chiesto di incontrare diverse personalità di Frigost.",r:[170000,null,null,null,null,null]};
Q.s[1139] = {n:"Affrontare La Bestia.",d:"Devi riuscire a prelevare un Campioncino di Sangue sulla cavia di Albert Pes.",r:[340000,null,[[11198,1]],null,null,null]};
Q.s[1138] = {n:"Suscettibilità a fior di pelle.",d:"Albert Pes ha bisogno di acqua di mare isotonica. Solo il Capitan Ciuk sa come procurarsela.",r:[null,null,null,null,null,null]};
Q.s[1137] = {n:"Ros Olia.",d:"Devi portare ad Albert Pes dei Campioncini di Sangue di Pappabuk malato.",r:[null,null,null,null,null,null]};
Q.s[1148] = {n:"Pane senza giochi.",d:"Il Capo Tosto ha bisogno di enormi quantità di Legno per alimentare il riscaldamento dei cannoni a vapore.",r:[201000,null,[[11196,1]],null,null,null]};
