Q.s[1142] = {n:"Problema di tubature.",d:"Nelly Clerichetta, la Capo Tuttofare, è sparita mentre andava a riparare le tubature dell\'Atelier dei Contadini. Francky, il suo dipendente, ti ha chiesto di ritrovarla.",r:[null,null,null,null,null,null]};
Q.s[1145] = {n:"Quattro fantastici di ritorno in città.",d:"Devi trovare i Sopravvissuti, vittime di uno strano maleficio. Devi scortarli in città uno ad uno.",r:[603000,10000,[[11196,1]],null,null,null]};
Q.s[1144] = {n:"Fantastica passeggiata nella Foresta.",d:"Molti Frigostiani assunti dal Capo Tosto sono scomparsi nella Foresta dei Pini Perduti. Devi scoprire cos\'è successo.",r:[null,null,null,null,null,null]};
