Q.s[1119] = {n:"È l\'ora della mewendina.",d:"Hai trovato una Piuma Vibrante di Pinguinotto, ma è impossibile capire a cosa serva. Per fortuna hai sentito dai Pescatori che ne parlavano citando Gina Forma. Forse lei potrà darti più informazioni.",r:[5000,null,[[11134,1]],null,null,null]};
Q.s[1127] = {n:"Semi dei campi.",d:"Per creare delle specie di Cereali più resistenti al freddo, Cassy Operaia ti ha chiesto di portarle diversi tipi di Semi.",r:[510000,10000,[[11196,1]],null,null,null]};
Q.s[492] = {n:"Martello e Incudine.",d:"Oto Mustam crede che Bonta sia aiutata da un Forgiatore Mercenario. Devi cercare negli atelier dei Forgiatori o dei Minatori per trovare degli indizi.",r:[146000,null,null,null,null,null]};
Q.s[1128] = {n:"Pini o panini?",d:"Cassy Operaia vuole diversificare la produzione di cereali e ha bisogno di nuove varietà di semi.",r:[603000,20000,[[11196,1]],null,null,null]};
Q.s[1129] = {n:"Salute di ferro.",d:"I Pinguinotti sembrano più resistenti grazie ad un\'alimentazione ricca di ferro. Cassy Operaia ti chiede di massacrarne un po\' per recuperare le loro riserve di semi.",r:[669000,30000,[[11196,2]],null,null,null]};
Q.s[1130] = {n:"Il sale della terra",d:"La mancanza di sale ha fatto nascere numerosi casi di astrubismo fra i Frigostiani. Per estinguere quest\'epidemia Cassy Operaia vuole provare a coltivare Granelli di Sale in una serra adatta.",r:[null,null,null,null,null,null]};
Q.s[1131] = {n:"Alterazioni cerealifere",d:"Cassy Operaia vuole incrociare i Frostiss con della Gran Ata e del Gran Oy perchè possa resistere naturalmente ai parassiti e alle erbe infestanti.",r:[null,null,null,null,null,null]};
Q.s[1132] = {n:"Rinforzo genetico",d:"Cassy Operaia vuole dei Granelli di Basalto per rinforzare la resistenza ai bruschi cambiamenti di temperatura dei Frostiss. Le serve anche del Grano Chia da incrociare con i Granelli di Sale.",r:[null,null,null,null,null,null]};
