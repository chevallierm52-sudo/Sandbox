Q.s[903] = {n:"Sette anime oppure niente.",d:"Devi catturare le Anime dei sette banditi e portarle ai Pozzi delle Anime Imbrattate per assoggettarle. Avrai bisogno di Brakmariani vili al punto da potersi scegliere una specialità.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Ritrova la Spia.",d:"Devi trovare rapidamente la Spia ferita sulla strada verso Bonta e recuperare i Documenti. La Spia deve essere più vicina a Bonta che a Brakmar.",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Giro delle taverne.",d:"Il bandito a cui apparteneva la Spada probabilmente è passato in una taverna, perciò i tavernieri sanno di sicuro qualcosa.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Inchiesta importante.",d:"Fai il giro delle guardie di Brakmar e effettua un resoconto delle guardie che non fanno pausa.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Domatore di bestie, ma anche di animali.",d:"Oto Mustam vuole conoscere il segreto dell\'Addomesticamento di Canin Blandi. Devi tornare alla biblioteca di Bonta per trovare degli indizi.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Fino a Brakmar.",d:"Lo Stratega ha accettato di seguirti fino a Brakmar.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Un altro rapporto.",d:"Devi trovare Trojen Tihpor nei pressi delle mura di Bonta e recuperare il suo rapporto.",r:[19000,null,null,null,null,null]};
