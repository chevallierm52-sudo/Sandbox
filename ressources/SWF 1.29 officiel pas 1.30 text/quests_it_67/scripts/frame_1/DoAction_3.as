Q.s[737] = {n:"La raccolta di veleno.",d:"Oto Mustam ha bisogno di 20 pods di veleno di Scorbuto.",r:[4600,null,null,null,null,null]};
Q.s[485] = {n:"Raccolta di Veleno.",d:"Le spie a Bonta hanno bisogno di Veleno: un Veleno raro in possesso solo dei Bwork Maghi. Le spie si nascondono nel quartiere Sud-Ovest di Bonta.",r:[null,null,null,null,null,null]};
Q.s[906] = {n:"Il buon nascondiglio.",d:"Devi trovare un nuovo nascondiglio per le spie tra l\'area attuale e la biblioteca. Se necessario, devi neutralizzare i suoi eventuali occupanti.",r:[128000,null,null,null,null,null]};
Q.s[535] = {n:"Un piccolo fallimento.",d:"Alcune tracce di combattimento, due armi abbandonate per terra, un Etram deceduto: tutto fa credere che tu non sia arrivato in tempo.",r:[205000,null,null,null,null,null]};
Q.s[918] = {n:"Exoram l\'Etram.",d:"Hai riportato Exoram al tempio Etram. Questa volta farà meglio a darti le informazioni che ti ha promesso.",r:[70000,null,null,null,null,null]};
Q.s[892] = {n:"Un Etram più stupido del vero.",d:"Exoram si è messo di nuovo nei guai. Se vuoi delle informazioni su Xefires, bisognerà aiutarlo di nuovo.",r:[null,null,null,null,null,null]};
Q.s[447] = {n:"Infiltrarsi o gettarsi nel mucchio, questo è il problema.",d:"Secondo le tue scoperte, sembra che Exoram sia tenuto prigioniero nell\'accampamento Goblin, a meno che non sia già morto.",r:[null,null,null,null,null,null]};
Q.s[448] = {n:"Sulle tracce dell\'Etram.",d:"Exoram è stato liberato dai Goblin. Ora devi ripartire sulle sue tracce per metterci la mano su.",r:[null,null,null,null,null,null]};
Q.s[493] = {n:"Nella Grotta Porcos.",d:"Devi tentare di convincere il Forgiatore della Grotta Porcos ad unirsi alla causa di Brakmar.",r:[152000,null,null,null,null,null]};
Q.s[759] = {n:"Lezione d\'umiltà.",d:"Oto ti ha ordinato di portargli 40 occhi di larve blu.",r:[23000,null,null,null,null,null]};
Q.s[760] = {n:"Sbarazzati della larva dorata.",d:"Devi trovare un modo per sbarazzarti della larva dorata che ti segue.",r:[25000,null,null,null,null,null]};
Q.s[452] = {n:"Un fiasco... temporaneo.",d:"Xefires ha rifiutato l\'offerta, ma non è detta l\'ultima parola. Un Gioiello potrà rabbonirlo.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"L\'incontro.",d:"Ora che il luogo in cui si trova Xefires è stato identificato, bisogna trovare la Taverna del Pandawa Ubriaco e fargli la proposta. È lì a partire dalle 16.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"Un messaggio da far passare.",d:"Oto vuole che tu passi il suo messaggio a Vil Smis nel covo dei Ladrurbi situato nel cimitero d\'Amakna.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"Nuovo pericolo che fa paura.",d:"Numerosi guerrieri Brakmariani sono stati sconfitti ed abbandonati sulla strada verso Astrub. Bisogna andare ad investigare laggiù, ma prima Oto Mustam vuole un\'Anima di Canin Blando.",r:[140000,null,null,null,null,null]};
Q.s[747] = {n:"Riscuoti la tassa.",d:"Devi riscuotere la nuova tassa di Oto in ogni taverna di Brakmar. Completa libertà di dare una batosta ai tavernieri che non vogliono pagare.",r:[10700,null,null,null,null,null]};
Q.s[889] = {n:"Una lettera classificata X.",d:"Devi trovare l\'identità di questo famoso X. La lettera fa riferimento ad un luogo in cui va spesso. Trovare questo luogo permetterà di saperne di più.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Ritorno dalla torre.",d:"Hai trovato un pezzo di carta molto interessante. Bisogna mostrarlo a Oto.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"La torre disordine.",d:"Trova a Bonta un personaggio importante che potrebbe venir corrotto. Oto ha suggerito di cercare nella Torre.",r:[null,null,null,null,null,null]};
Q.s[792] = {n:"Alla ricerca del cancelliere depresso.",d:"Tabach, cancelliere dell\'Ordine del Cuore Valoroso, va di taverna in taverna da quando il suo gatto è sparito. Bisogna riportarlo da Mel Aghignavon.",r:[null,null,null,null,null,null]};
Q.s[793] = {n:"Alla ricerca della cancelliera.",d:"Ybaul, Cancelliera dell\'Ordine dello Spirito Redentore, va di taverna in taverna alla ricerca dei suoi fratelli. Bisogna riportarla da Elviana Tirips.",r:[null,null,null,null,null,null]};
Q.s[795] = {n:"Osso di cuore.",d:"Fraka Kyper ti ha chiesto di portargli 1 Osso di Chafer per provargli il tuo valore.",r:[null,null,null,null,null,null]};
Q.s[797] = {n:"Mal occhio.",d:"Olledrob Oterges ti ha chiesto di portargli 1 Occhio di Cuervoc per provargli il tuo valore.",r:[null,null,null,null,null,null]};
Q.s[210] = {n:"Per un cuore sanguinante, niente è impossibile.",d:"Devi impadronirti delle Statuette, simbolo del bene e del male dell\'umanità, e portarle a Fraka. Sono nascoste in una Miniera abbandonata vicino al Tempio Anutrof.",r:[200000,null,null,null,null,null]};
Q.s[796] = {n:"Peli al mento.",d:"Divad Dleifrepok ti ha chiesto di portargli 1 Pelo di Barba di Bwork Mago per provargli il tuo valore.",r:[null,null,null,null,null,null]};
Q.s[1071] = {n:"La fabbrica dei giochi.",d:"Delle abominevoli creature hanno svaligiato il deposito di Babbo Nawal. Devi recuperare le casse con i regali che hanno rubato, con o senza il loro consenso, e portarle a Felice Nawal.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1106] = {n:"null",d:"",r:[10000,10000,null,null,null,null]};
Q.s[1113] = {n:"Raccolta di Cereali.",d:"Fedele alle sue abitudini, Annetta Dimposta è andata a dormire invece di approvvigionare Frigostina. La Panettiera ti ha quindi chiesto di sostituire la sua dipendente.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1114] = {n:"Raccolta di Fiori.",d:"Non potendo lasciare il suo Atelier senza sorveglianza, Erbor Ista ti ha chiesto di essere il suo fornitore.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1115] = {n:"Raccolta di Pesci.",d:"Con l\'arrivo massiccio di Avventurieri, le riserve di Pescetti diminuiscono a vista d\'occhio. Ecco perché Arist Ogat ti ha chiesto di riapprovvigionarla.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1117] = {n:"Raccolta di Minerali.",d:"Lo sfruttamento delle miniere è praticamente ridotto a zero da molti decenni e le riserve di Ossidiana, utile per la fusione delle Fedi, sono a secco. Laurent Arancia ti ha quindi proposto di aiutarlo a ralimentare le scorte.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1116] = {n:"Raccolta di Carni.",d:"Con l\'arrivo massiccio di Avventurieri, le riserve di Carne diminuiscono a vista d\'occhio. Ecco perché Sim Enthal ti ha chiesto di riapprovvigionarlo.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1118] = {n:"Raccolta di Legno.",d:"Il Capo Tosto ha bisogno di una quantità astronomica di Legno come combustibile per il sistema di disgelo del porto. Ti ha chiesto di dargli una mano.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1107] = {n:"Caccia ai Pappabuk.",d:"Clyde Parker ti ha chiesto di sbarazzarti dei Pappabuk nei Campi di Ghiaccio.",r:[170000,null,[[11196,1]],null,null,null]};
