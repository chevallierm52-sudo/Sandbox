Q.s[1170] = {n:"Trova e porta la creatura.",d:"Alcuni dicono di averlo visto dirigersi verso il Crepaccio Asparago dopo una delle sue sconfitte, a nord dell\'isola. Deve essere catturato e portato al Borgo dove è ricercato per le sue spedizioni carnivore nei confronti dei Pappabuk d\'allevamento.",r:[null,380000,[[11196,3]],null,null,null]};
