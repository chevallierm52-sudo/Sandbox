Q.s[1167] = {n:"Ros Olia.",d:"Temendo la propagazione della Ros Olia, Mac Ghiacciver ha bisogno di numerosi vaccini.",r:[2230000,15000,[[11196,5]],null,null,null]};
Q.s[1166] = {n:"Inverno un giorno, inverno per sempre.",d:"Mac Ghiacciver ha bisogno di manodopera qualificata. Devi convincere la Sindaco di Frigost a cercare gente nel Borgo.",r:[null,null,null,null,null,null]};
