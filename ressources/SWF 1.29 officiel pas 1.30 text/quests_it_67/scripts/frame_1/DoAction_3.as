Q.s[1159] = {n:"Andarsene, semplicemente.",d:"Bisalius Vinlentinus è alla ricerca di piante pre-glaciazione per fare degli incroci.",r:[603000,20000,[[11196,1]],null,null,null]};
Q.s[1160] = {n:"La famiglia dei Rabarbapapà.",d:"Per migliorare il gusto delle piante, Bisalius Vinlentinus vuole usare del Rabarbapapà filato, che solo i Pinguinotti possiedono.",r:[669000,30000,[[11196,2]],null,null,null]};
Q.s[1197] = {n:"Bassa marea",d:"Per aiutare il dottore di Frigost, Bisalius Vinlentinus ha bisogno di 70 Cri-santemi.",r:[null,null,null,null,null,null]};
Q.s[1198] = {n:"Alla ricerca delle rose perdute",d:"Bisalius Vinlentinus ha bisogno di nuove piante che nascono unicamente nelle Lacrime di Uronigride.",r:[null,null,null,null,null,null]};
Q.s[1199] = {n:"Viaggio al centro del tunnel",d:"Per anticipare un eventuale periodo caldo, Bisalius Vinlentinus vuole incrociare le specie di piante attuali con quelle delle Grotte di Lava.",r:[null,null,null,null,null,null]};
