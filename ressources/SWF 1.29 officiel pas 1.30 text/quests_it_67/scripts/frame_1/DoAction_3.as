Q.s[1155] = {n:"640, anno esotico.",d:"Per riabilitare il vecchio villaggio di Frigost, Aurora Boreale ha optato per un misto di legno di Pioppo Tremulo e tavole di legno di Kalipto, che devi fornirle.",r:[223000,15000,[[11196,1]],null,null,null]};
