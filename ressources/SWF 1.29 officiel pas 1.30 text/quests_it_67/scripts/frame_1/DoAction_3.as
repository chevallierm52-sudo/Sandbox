Q.s[1149] = {n:"Il foro e la fauna.",d:"Damar, il Capo dei Pescatori del Lago Ghiacciato, ha bisogno di materiali per riparare i suoi attrezzi da pesca.",r:[446000,15000,[[11196,1]],null,null,null]};
