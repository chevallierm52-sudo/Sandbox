Q.s[898] = {n:"La conferma.",d:"Pandalida ha approfittato del tuo combattimento per fuggire, di sicuro si è rifugiata a casa sua. DEVI convincerla a consegnare la lettera a Xefires.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intimidazione intima.",d:"Bisogna intimidire Pandalida saccheggiando casa sua. Hai bisogno di 3 Paste alla Ta Trak, pasta ottenuta pestando 15 Musi di Cinghiale, 5 Barattoli di Glutovora e 1 Piuma di Serpipiuma.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"Il postino.",d:"Bisogna trovare un modo di far arrivare la lettera a Xefires. È spesso alla Taverna del Pandawa Ubriaco, ma ormai si rifiuta di parlare con te.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"Il cambio.",d:"Devi trovare il guerriero Tink Berval e chiedergli di dare il cambio a Skiappa Fuut.",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"Il torto ruga.",d:"Dato che Garutar ha fame e che le maniere forti non funzionano, bisogna trovare un modo per avvelenarla. Un abitante dell\'Isola conosce di sicuro l\'alimentazione delle tartarughe.",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Gira la Tartaruga sul dorso...",d:"Dato che non riesci ad estorcere le informazioni semplicemente chiedendole, forse è meglio utilizzare metodi più diretti... ",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Trasformazione",d:"Poss\'Ybel vuole che tu le fornisca qualche prodotto finito, frutto delle tue raccolte.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Trasformazione",d:"Poss\'Ybel vuole una mini pozione di cura fatta con un fiore di lino e un poco di acqua.",r:[50,null,null,null,null,null]};
Q.s[379] = {n:"Trasformazione",d:"Poss\'Ybel vuole che tu le fornisca qualche prodotto finito, frutto delle tue raccolte.",r:[50,15,null,null,null,null]};
Q.s[380] = {n:"Trasformazione",d:"Poss\'Ybel vuole che tu le fornisca qualche prodotto finito, frutto delle tue raccolte.",r:[50,15,null,null,null,null]};
Q.s[686] = {n:"Bracca i trincatori.",d:"Devi fare il giro delle taverne di Bonta per trovare i miliziani che non sono al loro posto e chiedere loro i badge.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Condizioni di scambio",d:"Anta ti ha fatto una lista di quello che vuole in cambio della sua collana magica.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"Sono volontario",d:"Disskray vuole sapere se i paesani hanno notato qualcosa di strano o inusuale.",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Sciaman connexion",d:"Lo sciamano è un Pandawa che sa parecchie cose sulle azioni di certi tipi... Apparentemente, non è tutto rose e fiori a Pandala!",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"Alla salute della dea!",d:"Nuovo arrivato a Pandala, l\'Assistente Sciamano ti chiede di onorare la tua dea: un\'offerta spirituale sarebbe l\'ideale... la tua iniziazione comincia.",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Trova un lavoretto",d:"Poster Nhin ha sicuramente un lavoretto da affidarti.",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"Una ricetta per Pipeletta",d:"Pipeletta aspetta la ricetta delle crêpes di Astrub per poterle preparare quando verranno i suoi nipotini.",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"Il walzer delle rocciose.",d:"Scendi nel covo del banditi con una corda. Non andarci da solo!",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"Gattina carina.",d:"Il tuo incontro con i banditi ti ha insegnato che Hersa Artiglio Oscuro ne sa di più di quello che voglia ammettere. Non resta che parlarle senza farsi sfigurare.",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"Riparo tranquillo.",d:"Amayiro ti ha chiesto d\'indagare nelle Pianure di Cania per trovare il covo dei banditi. Secondo le tue informazioni, non sarebbe lontano dalla fiera del Trool, verso Ovest.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Pretty Nara",d:"Nara ti ha fornito la lunga lista di Dotazioni di cui ha bisogno per fabbricare l\'equipaggiamento della milizia di Bonta. Devi portargliele nella Miniera dei Porcos.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Agenzia immobiliare.",d:"Hai visitato i diversi luoghi indicati da Setag. Non resta che convincere Nara a trasferirsi in uno di questi.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"Ricerca immobiliare.",d:"Nara ti ha chiesto di trovare un luogo isolato in cui installare la sua Fucina e il suo materiale.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Trasporto di casse.",d:"Devi portare quattro casse da Amayiro all\'avamposto di Bonta, a Sud della città.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Dai prova di te",d:"Siccome non sei tanto conosciuto nei dintorni, gli autoctoni non sanno ancora se possono fidarsi di te.",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"Alla salute!",d:"Hai la birra, se la dai a Aymé dovresti recuperare tutta l\'energia.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Aymé vuole della birra",d:"Aymé vuole della birra, perché non se la va a prendere?",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"L\'amico delle bestie.",d:"Devi scoprire da dove viene Garutar. Un esperto di animali potrà indirizzarti nelle tue ricerche. Oshimo, il responsabile del Cianil, è un buon inizio.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"Il Wabbit e la Tartaruga.",d:"Secondo Oshimo, Garutar dovrebbe avere un nemico mortale. Lalepre Velhoce dovrebbe aver firmato un patto con i demoni per avere più potenza. Risiede sull\'Isola dei Wabbit Scheletro.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Agenda",d:"Aggiungi un giocatore alla tua lista di amici.",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"Di chi è il Kiki?",d:"Ma\'Ster ti ha sfidato a battere il mostro nascosto nella sua tana.",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Gioco Trool regole avanzate",d:"Raxitiko è terrorrizato. Sa che i Bwork lo daranno al Trooll che vuole sfidarlo a una partita del gioco Trooll regole avanzate. Bisogna assolutamente eliminare questo Trooll che minaccia l\'integrità fisica di Raxitico.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"Pellegrinaggio insanguinato.",d:"Affronta il dabol di ogni tempio di classe.",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Annienta le tartarughe.",d:"Oto ti ha chiesto di uccidere dieci tartarughe dell\'isola di Moon. I loro occhi costituiranno una buona prova.",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Del vino per Oto.",d:"Devi portare a Oto del vino di Glutovora. Dove sarà?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"Il colloquio.",d:"Una persona importante di Brakmar ha chiesto d\'incontrarti. Si trova nel sottosuolo della torre di Brakmar.",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Pozioni energizzanti.",d:"Oto Mustam ha bisogno di tre pozioni Pahoa Raid.",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"Il riparo riparato.",d:"Grazie al messaggio del capo dei ladri sei stato in grado di trovare il suo covo. Perché non fare un giro da quelle parti prima di tornare dalla milizia?",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"Compra l\'equipaggiamento.",d:"Devi comprare l\'equipaggiamento che Oto ha indicato sulla lista ed equipaggiarlo prima di tornare da lui.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"32 denti d\'oro!",d:"Devi portare una dentiera d\'oro per Mak. Puoi trovarne sugli Chafer Scelti, ma di sicuro anche il forgiatore di Brakmar può fornirtene una.",r:[28000,null,null,null,null,null]};
Q.s[487] = {n:"Penetra nella biblioteca.",d:"Le spie a Bonta hanno fallito nell\'assassinio, quindi bisogna commetterlo al posto loro. L\'obiettivo è uno Stratega che risiede nella biblioteca di Bonta, ma attenzione ai cani da guardia.",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Assassinio.",d:"Ora puoi entrare nella biblioteca per occuparti dello Stratega.",r:[null,null,null,null,null,null]};
Q.s[750] = {n:"Umiliare Sbab?",d:"Oto ti ha chiesto di portare dieci orecchie di Tiwabbit a Sbab per farla inorridire. Ma forse c\'è un\'altra soluzione se non hai voglia di farlo.",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Dai una batosta ai Bontariani.",d:"Oto ti ha chiesto una birra della Batosta. La taverna della Batosta si trova a Bonta.",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Ritrova i documenti.",d:"I documenti segreti non erano sulla spia. Forse la fauna delle lande di Sidimote se n\'è impossessata.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"La Rivelazione.",d:"Sotto al Mercatino degli Alchimisti c\'è un armadio. Basta mettertici davanti per far aprire il passaggio segreto. Il Mago Ax ti attende laggiù.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"Il Mago Ax.",d:"Amayiro ti ha chiesto d\'interrogare il Mago Ax per conoscere le modalità di utilizzo del Corno Davola e i suoi poteri.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"Ritorno all\'ovile.",d:"È tempo di tornare a Bonta e di fare il punto con Amayiro.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"La sapienza essenziale.",d:"Vai ad imparare la tecnica di cattura d\'anima. La chiave del dongione deve trovarsi sulle creature della regione.",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Gli elmi di Chafer",d:"Oto vuole dieci Elmi di Chafer che si trovano al Cimitero dei Torturati.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Presenza Brakmariana.",d:"Hai attaccato un Brakmariano che era già là, ma che non possedeva ancora il Corno Davola. Se Ecaflip è dalla tua parte, forse riuscirai a trovare il Corno Davola prima dei Brakmariani.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"La decisione di Garutar.",d:"Convinci Garutar a scambiare la Bandana Rattoppata con il Corno Davola. Hai bisogno di un Furbacapo e di una Bottiglia di Glutoberg per fare in modo che appaia.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Caccia al lupo.",d:"Oto ti ha chiesto di cacciare da Brakmar un lupo che gironzola attorno alla facciata.",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"Così vicini all\'obiettivo.",d:"Norb sa dove si trova il Forgiatore Eremita, non ti resta che convincerlo a svelare il suo nascondiglio. Forse Amayiro potrà aiutarti.",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Così forgeranno...",d:"Bisogna trovare un Forgiatore competente che accetti di fabbricare un equipaggiamento per Bonta.",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Un\'altra storia di brilli.",d:"Secondo le tue fonti, il Taverniere di Sufokia dovrebbe avere delle informazioni su un potente Corno Magico.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"Chi fa da sé, fa per tre.",d:"L\'informazione rivelata dal Taverniere del Ripata non è utilizzabile così com\'è. Una ricerca presso gli eruditi potrebbe avverarsi più fruttuosa.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, koko?",d:"Presagendo la prossima missione che Oto Mustam ti affiderà, è meglio preparare il terreno ed acquistare qualche Noce di Kokoko.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Carapaci.",d:"Il Taverniere del Ripata ti ha chiesto un carapace di Tartaruga di Moon di ogni colore. Forse, però, opterai per un metodo più rapido.",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Combatti il Lupus Minimus.",d:"Un combattimento che mette a dura prova tutte le tue capacità.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Una missione quasi compiuta.",d:"Ora la via è libera, anche se i Goblin non costituivano una vera minaccia. Finalmente Exoram potrà rivelarti quello che sa e Oto Mustam sarà fiero di te.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"Abrakadabra, sono ancora io.",d:"Exoram non è tranquillo perché ha sentito dei rumori sospetti e delle risate beffarde più a Nord. Se puoi assicurargli che la via è libera, ti darà le informazioni prese su Xefires.",r:[null,null,null,null,null,null]};
Q.s[445] = {n:"Abrakadabra, eccomi qua.",d:"Hai riferito delle informazioni utili a Oto Mustam. Ti ha chiesto di sostituire un miliziano per andare nella Foresta degli Alberagni a cercare un Etram che conosce Xefires.",r:[null,null,null,null,null,null]};
Q.s[891] = {n:"Una missione per niente compiuta.",d:"Delle tracce di lotta e dei resti di karne indicano che Exoram si è battuto ed è stato catturato o ucciso. Oto Mustam sarà furioso di scoprirlo.",r:[65000,null,null,null,null,null]};
Q.s[444] = {n:"I bei bar di Bonta.",d:"Bisogna trovare delle informazioni su Xefires. I tavernieri di Bonta forse potrebbero fornire una pista.",r:[null,null,null,null,null,null]};
