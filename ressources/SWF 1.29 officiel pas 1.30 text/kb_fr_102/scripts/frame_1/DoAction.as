KBT[15] = {i:15,c:"Les <a href=\"asfunction:onHref,PictoIndicator,-1,7000\">Zaaps</a> permettent de sauvegarder votre position, et de voyager entre les différents <a href=\"asfunction:onHref,PictoIndicator,-1,7000\">Zaaps</a> que votre personnage connaît.",l:46};
