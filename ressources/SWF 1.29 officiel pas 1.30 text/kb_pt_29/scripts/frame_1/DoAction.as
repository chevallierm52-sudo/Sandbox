KBT[29] = {i:29,c:"Esta interface permite que você visualize o mapa da área onde seu personagem está.\nVocê pode escolher lugares importantes e exibi-los selecionando os diferentes <a href=\"asfunction:onHref,UiIndicator,MapExplorer,_mcFilter4\">filtros</a>.",l:61};
