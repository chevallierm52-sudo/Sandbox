G = new Object();
G[1] = {sn:"Feca",ln:"El Escudo Feca",ep:1,d:"Los fecas son unos leales protectores. Los grupos de aventureros se los rifan gracias a sus poderes de protección pero también porque manejan el bastón como nadie sabe hacerlo. Las generaciones fecas se enorgullecen de ser unos defensores fuera de serie a los cuales los sabios han confiado los objetos más valiosos que existen.",sd:"Una clase de protectores. Sus armaduras reducen los daños sufridos por sus aliados.",s:[3,17,6,4,2,1,9,18,20,14,19,5,16,8,12,11,10,7,15,13,1901],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[2] = {sn:"Osamodas",ln:"El Látigo de Osamodas",ep:1,d:"Los osamodas tienen el poder de invocar criaturas y resultan ser excelentes domadores. Corre el rumor de que utilizan la piel de sus enemigos para hacerse sus trapitos. Si quieres saber si es cierto, puedes ir tú mismo a preguntarles... ¡Pero ten cuidado! No sea que termines transformado en algún que otro complemento de moda.",sd:"Una clase de invocadores. Utilizan sus invocaciones para luchar a distancia.",s:[23,34,21,26,22,35,28,37,30,27,24,33,25,38,36,32,29,39,40,31,1902],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[3] = {sn:"Anutrof",ln:"Los Dedos de Anutrof",ep:1,d:"¡Los anutrofs son unos impenitentes cazadores de tesoros! Cualquier producto, objeto o criatura les interesa siempre y cuando puedan conseguir kamas a cambio. Lo primero que hace un anutrof cuando se encuentra con otro aventurero es sopesarlo con su mirada. Cierto: para un anutrof, un aventurero es una criatura cargada de productos y repleta de objetos... ¡Que después pueden vender!",sd:"Una clase de cazadores de tesoros. Saben desembrujar. También pueden ralentizar los movimientos de sus enemigos.",s:[51,41,43,49,42,47,48,45,53,46,52,44,50,54,55,56,58,59,57,60,1903],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[150,3],[230,4],[330,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[60,3],[100,4],[150,5]]};
G[4] = {sn:"Sram",ln:"La Sombra de Sram",ep:1,d:"Los srams son unos asesinos a los que les encantan las bolsas y más aún cuando están repletitas de kamas. La vida de un sram se podría resumir a las siguientes acciones: poner trampas, rasgar túnicas, tomar prestadas las joyas valiosas y la no menos útil prestidigitación... ¡Ahora lo ves, ahora no lo ves... porque la joya yo te robé!",sd:"Una clase de bandidos. Gracias a la invisibilidad y a sus trampas consiguen atacar a sus enemigos por la espalda.",s:[65,72,61,66,68,63,74,64,79,78,71,62,69,77,73,67,70,75,76,80,1904],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[100,2],[200,3],[300,4],[400,5]],b15:[[0,2],[50,3],[150,4],[250,5]]};
G[5] = {sn:"Xelor",ln:"El Reloj de Arena de Xelor",ep:1,d:"Los xelors son los magos que dominan el tiempo y todos los mecanismos que dan la hora: carrillones, relojes de pared y péndulos... les obedecen a la perfección. Juegan con el tiempo para ralentizar a un enemigo o teletransportarse al lugar que les apetezca.",sd:"Una clase de magos. Utilizan sus hechizos para ralentizar a sus enemigos e impedirles actuar.",s:[81,83,82,84,100,92,88,93,85,96,98,86,89,90,87,94,99,95,91,97,1905],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[6] = {sn:"Zurcarák",ln:"La Moneda de Zurcarák",ep:1,d:"Los guerreros zurcaráks son unos jugadores empedernidos capaces incluso de arriesgar una de sus siete vidas por una simple apuesta. Un buen zurcarák no lo dudará un segundo, si tiene que jugarse el pellejo para llevarse el premio gordo, lanzará los dados al aire para ganar el combate... aunque, a veces, la suerte es traicionera y ¡¡puede que lo pierda todo!!",sd:"Una clase de guerreros jugadores. Sus ataques se basan principalmente en el azar.",s:[102,103,105,109,113,111,104,119,101,107,116,106,117,108,115,118,110,112,114,120,1906],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[7] = {sn:"Aniripsa",ln:"Las Manos de Aniripsa",ep:1,d:"Los aniripsas son curanderos que curan con una simple palabra. Las utilizan sobre todo para curar a sus aliados pero a veces también para herir a sus enemigos. Entre ellos, los hay que se han convertido en cazadores de palabras, en expertos del verbo o en exploradores de los idiomas olvidados.",sd:"Una clase de curadores. Utilizan sus hechizos para curar a sus aliados.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[8] = {sn:"Yopuka",ln:"El Corazón de Yopuka",ep:1,d:"¡Los yopukas son unos intrépidos y temerarios guerreros! Lo cierto es que los yopukas saben hacer hablar a las armas como nadie. Y lo de que un buen baño de sangre por la mañana temprano le recarga las pilas para todo el día, es una verdad como un puño. Su impetuoso temperamento hace que sean unos maravillosos paladines... pero en ciertas ocasiones, ¡son también unas auténticas calamidades con patas!",sd:"Una clase de guerreros jugadores. Sus hechizos ofensivos les permiten causar daños impresionantes.",s:[142,143,141,144,145,146,147,148,154,150,151,155,152,153,149,156,157,158,160,159,1908],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[9] = {sn:"Ocra",ln:"El Alcance de Ocra",ep:1,d:"Precisión, agilidad y destreza son las palabras clave para describir a los ocras. Estos arqueros son unos valiosos aliados contra los adeptos al cuerpo a cuerpo. Saben guardar las distancias para dominar el campo de batalla lanzando flechas aceradas al enemigo. ¡Vamos, que saben cómo hacer daño!",sd:"Una clase de arqueros. Están especializados en los ataques a distancia.",s:[169,164,161,163,165,172,167,168,162,170,171,166,173,174,176,175,178,177,179,180,1909],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[50,2],[150,3],[250,4],[350,5]]};
G[10] = {sn:"Sadida",ln:"El Zapato de Sadida",ep:1,d:"¡Los sadidas son invocadores que fabrican temibles ungüentos y venenos! Cualquier sadida digno de su condición es capaz confeccionar muñecas de curación y de guerra y de invocar zarzas para atacar a sus enemigos.",sd:"Una clase de brujos. Utilizan sus muñecas para luchar y embrujar a sus enemigos.",s:[193,183,200,198,195,182,192,197,189,181,199,191,186,196,190,194,185,184,188,187,1910],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[250,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[11] = {sn:"Sacrógrito",ln:"La Sangre de Sacrógrito",ep:1,d:"¡Los sacrógritos son unos berserkers cuya fuerza aumenta cuando reciben golpes! Cualquier grupo debería tener en sus filas a, al menos, uno de estos guerreros ya que no temen las heridas y muy a menudo están en primera línea de batalla. El sacrógrito es realmente el compañero ideal para pasar largas noches luchando.",sd:"Una clase de protectores. Son muy resistentes y resisten a los golpes de sus aliados.",s:[431,432,434,444,449,436,437,439,433,443,440,442,441,445,438,446,447,448,435,450,1911],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,3],[100,4],[150,5]],b11:[[0,1,2]],b12:[[0,3]],b13:[[0,3],[100,4],[150,5]],b14:[[0,3],[100,4],[150,5]],b15:[[0,3],[100,4],[150,5]]};
G[12] = {sn:"Pandawa",ln:"La Jarrita de Pandawa",ep:18,d:"El discípulo de Pandawa saca su fuerza legendaria de las bebidas fermentadas. Su espinazo flexible, sus hombros robustos le permiten soportar varias veces su peso: el pandawa no duda en levantar del suelo a sus aliados para protegerlos, o lanzar por los aires a sus enemigos para herirlos (o matarlos, los días que están más en forma).",sd:"Una clase de guerreros portadores. La bebida los vuelve más fuertes, pueden levantar a sus aliados.",s:[686,692,687,689,690,691,688,693,694,695,696,697,698,699,700,701,702,703,704,705,1912],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[200,3]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[50,2],[200,3]],b14:[[0,1],[50,2],[200,3]],b15:[[0,1],[50,2],[200,3]]};
