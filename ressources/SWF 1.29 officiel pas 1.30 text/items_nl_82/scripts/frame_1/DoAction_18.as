I.u[8237] = {n:"Rode Piwin Riem",t:10,d:"Deze kleine riem zal je heupen accentueren als je voor belangrijke mensen vecht.",ep:1,g:96,l:1,wd:true,fm:true,w:1,s:60,p:1};
