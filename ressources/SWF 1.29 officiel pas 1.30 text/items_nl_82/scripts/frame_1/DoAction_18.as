I.u[8211] = {n:"Pingu Geest",t:18,d:"Dit wezen is overduidelijk ontsnapt uit een dierentuin of van een ver eiland. Het is bekend om de schade van zijn meester als gevolg van gevechten te verbeteren. Het meest bijzondere is (dat hij soms deelt met zijn meester) dat zijn adem naar rotte vis stinkt. We raden je aan zijn bek dicht te timmeren, zelfs als je de hamer en de spijkers apart moet bestellen. Let op, dit wezentje is zeer veeleisend, hij eet alleen maar vis.",ep:3,g:38,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8213] = {n:"Rode Piwi Amulet",t:1,d:"Dit amulet lijkt gemaakt te zijn van een hoofdje van uitgedroogde Piwi. De koketterie kent geen enkele limiet.",ep:1,g:100,l:1,wd:true,fm:true,w:1,s:60,p:1};
I.u[8214] = {n:"Blauwe Piwi Amulet",t:1,d:"Dit amulet lijkt gemaakt te zijn met een klein gedroogd Piwi hoofd. Er gaat niets boven een eerste indruk.",ep:1,g:101,l:1,wd:true,fm:true,w:1,s:61,p:1};
I.u[8215] = {n:"Paarse Piwi Amulet",t:1,d:"Dit amulet is kennelijk gemaakt met een klein gedroogd Piwi hoofd. Er gaat niets boven een eerste indruk.",ep:1,g:102,l:1,wd:true,fm:true,w:1,s:62,p:1};
