I.u[8231] = {n:"Rode Piwi Cape",t:17,d:"Als je klein genoeg bent bedekt deze van Piwi veren gemaakte cape wellicht je achterkant.Een bescheiden bescherming die tenminste de aandacht van je vettige haar en vreselijke wratten weg trekt.",ep:1,g:103,l:1,wd:true,fm:true,w:10,s:60,p:100};
