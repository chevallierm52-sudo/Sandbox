I.u[8241] = {n:"Gele Piwi Riem",t:10,d:"Deze riem accentueert je heupen als je voor berlangrijke mensen vecht.",ep:1,g:100,l:1,wd:true,fm:true,w:1,s:72,p:1};
I.u[8242] = {n:"Roze Piwi Riem",t:10,d:"Deze kleine riem zal je heupen accentueren als je voor belangrijke mensen vecht.",ep:1,g:101,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8243] = {n:"Rode Piwi Hoed",t:16,d:"Met deze hoed op zie je er misschien belachelijk uit, maar je bent gewoon aanbiddelijk. Het leven is een kwestie van keuzes.",ep:1,g:137,l:1,wd:true,fm:true,w:1,s:60,p:1};
