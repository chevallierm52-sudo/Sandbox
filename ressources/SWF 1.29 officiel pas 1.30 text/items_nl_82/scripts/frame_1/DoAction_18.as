I.u[8225] = {n:"Rode Piwi Sandalen",t:11,d:"Perfect voor het beschermen van je voetboogje, zijn deze sandalen ook perfect voor het plattrappen van de wezentjes die tussen de grassprietjes kruipen, zoals de Xélors of de Eniripsas bijvoorbeeld.",ep:1,g:78,l:1,wd:true,fm:true,w:1,s:60,p:1};
I.u[8226] = {n:"Blauwe Piwi Sandalen",t:11,d:"Deze zijn perfect om je kleine voeten te beschermen en kleine beestjes te verpletteren die door het gras kruipen, zoals Xelors of Eniripsa\'s bijvoorbeeld.",ep:1,g:79,l:1,wd:true,fm:true,w:1,s:61,p:1};
