I.u[8070] = {n:"Kampioensriem",t:10,d:"Met deze riem om je heupen, verberg je gemakkelijk dat wat je niet goed tot je recht laat komen.",ep:1,g:88,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8071] = {n:"Mini Kampioen",t:18,d:"Dit kleine wezen wil slechts kampioenen volgen, hij loopt dus de kans jou een paar dagen te volgen, waarna hij er zich bewust van zal worden dat je een bedrieger bent. Vanaf dat moment zal jij hem volgen als een schoothondje.",ep:1,g:32,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:45,p:1};
I.u[8072] = {n:"Kaliptus Dofus",t:23,d:"Niemand kent de draak die deze Dofus gecreëerd heeft. Het gerucht gaat dat hij een ongelooflijk aantal Kaliptus blaadjes verwerkt heeft voor hij het ei legde en dood ging door een vreselijke onderbuikse wind crisis.",ep:1,g:10,l:6,wd:false,fm:true,w:1,p:500000};
I.u[8073] = {n:"Skeunk\'s Schuilplaats Sleutel",t:84,d:"Rigroulak heeft je deze sleutel gegeven in ruil voor de Koolich set. Deze sleutel geeft je toegang tot de schuilplaats van de Skeunks.",ep:13,g:11,l:1,wd:true,fm:true,w:1,p:100};
I.u[8075] = {n:"Dok Alako Boomerang",t:15,d:"Dit vreemd gevormde stuk hout reisde lange tijd door de lucht tussen vijanden linies voor bij brak. Het gerucht gaat dat hij altijd terug vliegt naar zijn eigenaar, maar zelden in zijn handen...",ep:20,g:722,l:1,wd:true,fm:true,w:1,p:10};
I.u[8076] = {n:"Koalak Meester Boomerang",t:15,d:"Dit vreemd gevormde stuk hout reisde lange tijd door de lucht tussen vijanden linies voor bij brak. Het gerucht gaat dat hij altijd terug vliegt naar zijn eigenaar, maar zelden in zijn handen...",ep:20,g:723,l:1,wd:true,fm:true,w:1,p:10};
I.u[8077] = {n:"Bruine Warko Boomerang",t:15,d:"Dit vreemd gevormde stuk hout reisde een lange tijd door de lucht tussen vijanden klassen voordat het brak. Het gerucht gaat dat het altijd terug zal vliegen naar zijn eigenaar, maar zelden in diens handen..",ep:20,g:724,l:1,wd:true,fm:true,w:1,p:10};
I.u[8078] = {n:"Calyptushouten Plank",t:95,d:"Met deze plank kunnen doe-het-zelvers houten voorwerpen maken, zoals bijvoorbeeld een doodskinst.",ep:20,g:22,l:70,wd:true,fm:true,w:10,p:10};
I.u[8079] = {n:"Kleine Witte Bow Meow Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8080] = {n:"Kleine Zwarte Bow Wow Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8081] = {n:"Tas met Beukenhout",t:100,d:"Deze zak bevat een indrukwekkende hoeveelheid Beukenhout.",ep:1,g:55,l:1,wd:true,fm:true,w:250,u:true,p:100};
I.u[8082] = {n:"Reapalak weefsel",t:55,d:"Dit weefsel ruikt naar de dood, in aanmerking genomen dat je ruikt alsof je dood bent. Het verschil is noemenswaardig.",ep:20,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8083] = {n:"Viseralak Bot",t:47,d:"Dit bot is nogal sponzig en laat de Viseralak drijven als hij valt terwijl hij een grote vangst wil ophalen.",ep:20,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[8084] = {n:"Piralak Huid",t:59,d:"Deze huid, bedekt met littekens, werd steviger dan een rots maar bleef extreem soepel. Het is de perfecte huid om zwepen en smakeloze sandalen te maken.",ep:20,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[8085] = {n:"Bos Koalak Haren",t:54,d:"Deze haren zijn bedekt met Kaliptus sap, wat ze een schijnende glinstering geeft. Helaas kunnen ze niet voor haute couture gebruikt worden omdat ze naar rottende Dragokalkoen stinken.",ep:20,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[8086] = {n:"Geshredde Drakoalak Hoofddeksel",t:15,d:"Dit vreemd uitziende hoofddeksel verborg de vervroegde kaalheid van de Drakoalak. Het een beetje oefening kan het binnenkort ook de jouwe verbergen.",ep:20,g:725,l:1,wd:true,fm:true,w:1,p:100};
I.u[8087] = {n:"Spreuk \'Bijl Vaardigheid\'",t:73,d:"(Dubbelklikken om deze spreuk te leren)                             Deze rol leert je hoe je meer schade toe kunt brengen als je een bijl gebruikt.",ep:20,g:8,l:20,wd:false,fm:true,w:1,u:true,p:10000};
I.u[8088] = {n:"Gyver Stok",t:3,d:"Deze van rommel gemaakte stok bevat een verbazingwekkende energie. Men zegt dat hij zichzelf kan verplaatsen om zijn doel te kiezen en zijn bezitter te beschermen als deze op sterven ligt. De Chouque zou met betrekking tot deze stok hebben gezegd \"Ik geloof dat je van je stokje bent gevallen\". Arme Chouque.",ep:20,g:56,l:128,wd:true,fm:true,w:10,an:11,e:[5,5,2,5,40,50,false,true],c:"CI>250",p:41257};
I.u[8089] = {n:"Iots Stok",t:3,d:"Iots was een papegaai die alles herhaalde, men zegt dat deze stok van zijn snavel werd gehouwen.",ep:20,g:57,l:138,wd:true,fm:true,w:20,an:11,tw:true,e:[5,4,3,4,40,50,false,true],c:"CI>150&CA>100&CC>100&CS>100",p:44125};
I.u[8090] = {n:"Caraïbische Staf",t:4,d:"Deze staf heeft al mensen betoverd of mensen hebben hem betoverd of vinden hem betoverend. Men weet het niet precies.",ep:20,g:64,l:114,wd:true,fm:true,w:10,an:12,tw:true,e:[5,5,1,1,35,50,false,true],c:"CI>200&CA>150",p:33520};
I.u[8091] = {n:"Palm Stok",t:4,d:"Deze stok komt uit het zuiden en zal er op alle mogelijke manieren altijd terugkeren.",ep:20,g:65,l:134,wd:true,fm:true,w:20,an:12,tw:true,e:[20,4,1,1,150,150,false,true],c:"CS>150&CA>150&CI>150",p:43550};
I.u[8092] = {n:"Bottwin Dolken",t:5,d:"De bottwin is niet goed, de bottwin is niet slecht, maar met zijn dolken in zijn hand is er niemand die graag met hem vecht.",ep:20,g:56,l:135,wd:true,fm:true,w:20,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CS>250&CA>100",p:43510};
I.u[8093] = {n:"Mick Dolk",t:5,d:"Het dragen van deze dolken maakt je niet meteen een held... Ze kunnen je als een heldin laten lijken als je ze in je broek draagt.",ep:0,g:64,l:58,wd:true,fm:true,w:1,e:[-1,-1,1,1,-1,-1,false,false],p:4253};
I.u[8094] = {n:"Lachend Zwaard",t:6,d:"Dit zwaard illustreert heel goed een oud Iop gezegde, als de vijand vergaat, lacht het zwaard.",ep:20,g:66,l:169,wd:true,fm:true,w:30,an:14,e:[10,5,1,1,50,50,false,true],c:"CS>450&CV>450",p:49010};
I.u[8095] = {n:"Ayassalama Sabel",t:6,d:"Dit zwaard werd voornamelijk uit estetisch oogpunt gesmeden om te dienen als decoratie voor een waardevolle schoorsteen. Maar omdat dit zwaard zijn waarde heeft bewezen tijdens slachtingen, wordt hij regelmatig gebruikt. De mensen hebben waarlijk geen enkel respect voor kunst.",ep:20,g:67,l:143,wd:true,fm:true,w:20,an:14,e:[15,4,1,1,80,50,false,true],c:"CI>300&CS>130&(PG=6|PG=8|PG=11)",p:44587};
I.u[8096] = {n:"Mawoke Hamer",t:7,d:"Zijn vorige eigenaar danste met de Boowolf. Hij is dood en verslonden.",ep:20,g:56,l:140,wd:true,fm:true,w:20,an:15,e:[5,5,1,1,30,45,false,true],c:"CI>250&CC>250",p:44541};
I.u[8097] = {n:"Doink Hamer",t:7,d:"Alvorens je schedel tot pap te slaan, laat deze hamer je eerst het leven door een roze bril zien.",ep:20,g:57,l:129,wd:true,fm:true,w:30,an:15,e:[5,4,1,1,40,15,false,true],c:"CS>250&CI>150",p:42658};
I.u[8098] = {n:"Lemmet Thoven",t:19,d:"Deze bijl is erg speciaal. Zijn vibrerende lemmet speelt prachtige muziek als je je vijanden in stukken hakt.",ep:0,g:38,l:1,wd:false,fm:true,w:1,an:17,e:[10,4,1,1,50,50,false,true],p:1};
I.u[8099] = {n:"Bijl van Leugens",t:19,d:"Het gerucht gaat dat dit wapen in een fontein van pure bliksem is gedipt, en vervolgens besprenkeld is met sterrenstof. Andere geruchten spreken dit verhaal weer volledig tegen.",ep:20,g:39,l:116,wd:true,fm:true,w:10,an:17,tw:true,e:[7,5,1,1,35,50,false,false],c:"CA>120&CV>150",p:34562};
I.u[8100] = {n:"Aas Bijl",t:19,d:"Deze bijl is op diverse plaatsen met gaten doorboord zodat hij bij elke slag een vrolijk en elegant gefluit laat horen als je je vijanden ermee raakt. Maar hun geschreeuw overstemt het eerste. Da\'s nou jammer.",ep:20,g:40,l:112,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,40,50,false,false],c:"CS>150&CW>150",p:30300};
I.u[8101] = {n:"Tchaud Kloofhamer",t:19,d:"Deze bijl werd gemaakt door Brouce Boulgoure toen hij zich wierp op het beroep van bakker om zijn vriend Xavier de bakker een plezier te doen. Zijn bedoeling was een taartschep te maken.",ep:20,g:41,l:128,wd:true,fm:true,w:1,an:17,e:[5,4,1,1,20,30,false,false],c:"CI>230&CA>60&CV>250",p:444};
I.u[8102] = {n:"Legendarische Krakler Steen",t:51,d:"Men zegt dat deze steen het hart van de Legendarische Krakler zou kunnen zijn. Wat zeker is, is dat de Legendarische Krakler nooit een zwaar hart heeft gehad, deze steen is dus ongelofelijk licht, waardoor er voorwerpen van gemaakt kunnen worden die geschikt zijn voor personen die vooral op zoek zijn naar mobiliteit, handigheid en bescherming. Eenvoudigweg super.",ep:5,g:457,l:120,wd:true,fm:true,w:50,p:100};
I.u[8103] = {n:"Spinnen Boog",t:2,d:"Deze boog is eigenlijk het versteende haar van een te diep in slaap gevallen Sadida, waarop de Arachnees hun webben hebben gespind.",ep:20,g:53,l:121,wd:true,fm:true,w:20,an:10,tw:true,e:[5,5,2,6,30,50,false,true],c:"CS>100&CA>100&CI>100&CC>100&CV>200",p:34857};
I.u[8104] = {n:"Chtelion Boog",t:2,d:"Deze boog, van twijfelachtige kleur, is perfect voor het paraderen op de Zaap van Bonta en hoewel je hiermee niet doorgaat voor een haantje, trekt hij wel alle kippetjes aan. Hij laat je vijanden omvallen van verbazing of ze vinden hem afstotelijk, zo komt hij een heel eind zonder dat je ook maar één pijl hoeft af te schieten.",ep:20,g:54,l:129,wd:true,fm:true,w:20,an:10,tw:true,e:[7,4,2,6,35,40,false,true],c:"CI>300&CV>300&CA>100",p:42510};
I.u[8106] = {n:"Beroepsvergeetdrankje: Klusser",t:44,d:"Deze toverdrank zal je het beroep van Klusser doen vergeten.",ep:7,g:2,l:1,wd:false,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[8107] = {n:"ne pas traduire",t:25,d:"ne pas traduire",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8108] = {n:"Tofu-amulet",t:1,d:"Deze amulet is licht als een Tofuveer en kan om je nek of voorhoofd gedragen worden, voor de avonturiers die op zoek zijn naar originaliteit.",ep:3,g:95,l:22,wd:true,fm:true,w:5,s:50,p:1525};
I.u[8109] = {n:"Tofu Ring",t:9,d:"Deze ring is zo belachelijk dat hij werkelijk niets voorstelt, maar kan toch onmisbaar blijken te zijn. Je vijanden riskeren namelijk zoveel medelijden met je te hebben, dat ze je afmaken in plaats van je afgrijselijk te laten lijden. Je moet altijd de positieve kant van dingen zien.",ep:3,g:100,l:21,wd:true,fm:true,w:5,s:50,p:1350};
I.u[8110] = {n:"Tofu Stok",t:3,d:"In tegenstelling tot wat sommige avonturiers zouden geloven, wordt dit stokje niet gebruikt door de Tofus (veel te stom om te weten hoe ze zo\'n wapen zouden moeten gebruiken), maar tegen de Tofus. Met behulp van de Tofu-veren waar hij uit bestaat kunnen jagers immers de bruidsstoet van de Tofus nadoen om ze vervolgens makkelijker te vangen. Maar hoe ver gaan die vreselijke jagers eigenlijk om hun moordlust te bevredigen?",ep:3,g:58,l:25,wd:true,fm:true,w:10,an:11,e:[5,6,2,2,50,50,false,false],s:50,p:100};
I.u[8111] = {n:"Tofu Pantoffels",t:11,d:"Licht en tegelijkertijd buigzaam. Deze pantoffels blijven warm in de winter en fris in de zomer. Alleen kunnen ze niet in de machine gewassen worden.",ep:3,g:73,l:23,wd:true,fm:true,w:10,s:50,p:1575};
I.u[8112] = {n:"Tofu Cape",t:17,d:"Deze vreemde cape lijkt in tweeën geknipt te zijn. Maar waarom zou hij in tweeën geknipt zijn? Niemand weet het, ook al heeft iedereen zijn eigen mening over deze kwestie.",ep:3,g:97,l:26,wd:true,fm:true,w:10,s:50,p:2000};
I.u[8113] = {n:"Tofu Riem",t:10,d:"Deze riem is ideaal om Tofus mee te wurgen en voor de jagers om de avonturiers die hun grondgebied tijdens het jachtseizoen betreden, te geselen. We raden je dan ook af om geen grapjes uit te halen met onze jagervrienden. De Tofus zijn niet de enige die getikt zijn!",ep:3,g:89,l:22,wd:true,fm:true,w:5,s:50,p:1553};
I.u[8114] = {n:"Helmetofu",t:16,d:"Deze werkhelm is een mode-artikel geworden voor bevallige avonturiersters. Waar gaat het heen met deze wereld ?",ep:3,g:128,l:23,wd:true,fm:true,w:5,s:50,p:1575};
I.u[8116] = {n:"Vergulde Scaramuts",t:16,d:"Deze muts is perfect om je acné mee te verbergen, of je engelengezichtje.",ep:6,g:129,l:58,wd:true,fm:true,w:10,s:51,p:8900};
I.u[8117] = {n:"Vergulde Scaracape",t:17,d:"Deze cape, die goudkleuriger is dan de klassieke Scaracape en minder zwart dan een Zwarte Scaracape, is perfect om je gezwellen mee te bedekken. Hij werd vroeger gebruikt door de Vergulde Scaraknobbel om zijn afschuwelijke knobbel te verbergen. Tegenwoordig wordt deze cape vooral gebruikt om enorme konten te bedekken. Het komt erop neer dat deze cape populair is.",ep:6,g:98,l:58,wd:true,fm:true,w:10,s:51,p:8980};
I.u[8118] = {n:"Vergulde Scaraknobbel Stok",t:3,d:"Deze magische stok is perfect om oude meubels af te stoffen of bejaarden.",ep:6,g:59,l:59,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,60,false,false],s:51,p:9300};
I.u[8119] = {n:"Vergulde Scarariem",t:10,d:"Als je ervan houdt om helemaal naakt op de stranden van het Moon Eiland te paraderen, dan ben je gelijk helemaal verliefd op deze riem, beroemd vanwege het feit dat het een uitstekende dallesdekker is.",ep:6,g:90,l:51,wd:true,fm:true,w:10,s:51,p:6825};
I.u[8120] = {n:"Verguld Scaraknobbel Amulet",t:1,d:"Gedragen op een behaard bovenlijf, komt dit amulet het beste tot z\'n recht, want het combineert mooi met het haar.",ep:6,g:96,l:45,wd:true,fm:true,w:5,s:51,p:5375};
I.u[8121] = {n:"Vergulde Scaraknobbel Ring",t:9,d:"De Scaraknobbel is een vreemd wezen. Geknobbeld en foeilelijk sinds haar geboorte, is ze het mikpunt van spot bij de andere Scarabladeren. Misschien voel je je daardoor verwant met dit wezen.",ep:6,g:101,l:43,wd:true,fm:true,w:5,s:51,p:5000};
I.u[8122] = {n:"Vergulde Scaralaarzen",t:11,d:"Met deze kromme laarzen kun je makkelijk de meest steile hellingen beklimmen, of de velden omploegen zonder ploeg.",ep:6,g:74,l:54,wd:true,fm:true,w:10,s:51,p:7725};
I.u[8123] = {n:"Boeren Amulet",t:1,d:"Dit amulet is geparfumeerd met Wilde Zonnebloemolie en fijne kruiden. Het kan dus prima dienen als aas voor de gevaarlijke herkauwers die je zou willen vangen, zoals Veelvraten of schoonmoeders bijvoorbeeld.",ep:1,g:97,l:20,wd:true,fm:true,w:5,s:47,p:1255};
I.u[8124] = {n:"Mudariem van de Boer",t:10,d:"Deze riem is onwijs bijzonder, omdat er een bermuda van vlasvezel aan vast zit. Het is een ideale riem voor wie ervan houdt zich snel van zijn kleding te ontdoen, en over te gaan tot de actie in het veld. Let evenwel op, wegens de hygiëne is deze riem verboden in openbare zwembaden.",ep:1,g:91,l:20,wd:true,fm:true,w:10,s:47,p:1300};
I.u[8125] = {n:"Boeren Zonnehoed",t:16,d:"Om je tegen te zon te beschermen als je op het land werkt, is er niets beter dan een Boerenkinkel pet. Om je tegen de zon te beschermen als je op het land werkt en je bent arm, dan is er niets beter dan de beroemde Boeren Zonnehoed.",ep:1,g:130,l:19,wd:true,fm:true,w:10,s:47,p:1200};
I.u[8126] = {n:"Aangetaste Wanten van de Boer",t:9,d:"Deze aangetaste wanten zijn echte juweeltjes. Men zegt dat ze bedekt zijn met diamantstof, waardoor ze bijzonder sterk geworden zijn. Ze beschikken over een schuurkant, ideaal om het achterwerk van Veelvraten mee te schuren, of dat van je echtgenote.",ep:1,g:102,l:12,wd:true,fm:true,w:5,s:47,p:600};
I.u[8127] = {n:"Versleten Boerenzeis",t:22,d:"Deze robuuste maar beschadigde zeis heeft al heel veel dienst gedaan en snijdt nogal slecht. Daarentegen is hij heel geschikt voor het uittrekken van zachte en oppervlakkige huid. Heel nuttig in de strijd tegen de spataderen van je tegenstanders.",ep:1,g:2,l:17,wd:true,fm:true,w:1,an:17,e:[5,3,1,1,50,50,false,false],s:47,p:950};
I.u[8128] = {n:"Boerinnen Laarzen",t:11,d:"Deze laarzen zijn gevuld met tarwestro, dat de transpiratie absorbeert en waardoor je heel goedkoop giftige champignons kunt kweken. Dankzij hun zachte zolen worden deze laarzen aangeraden door de scheidsrechters van de Vreetbal federatie.",ep:1,g:75,l:18,wd:true,fm:true,w:5,s:47,p:1100};
I.u[8129] = {n:"Aboowolfmulet",t:1,d:"Achter deze bijnaam schuilt in werkelijkheid een redelijk krachtig amulet. Het is gemaakt van hoektanden, tanden en botten van de Boowolf, hetgeen verklaart waarom hij zo stinkt. Als hij niet bij je hals past, past hij zich prima bij je adem.",ep:1,g:98,l:57,wd:true,fm:true,w:10,s:32,p:8550};
I.u[8130] = {n:"Boowolf Bijl",t:19,d:"Deze verschrikkelijke bijl heeft al meer dan een onvoorzichtige avonturier kunnen onthoofden. En toch hakt hij nogal slecht, er zijn soms wel tien pogingen nodig om een beetje weerbarstige keel door te hakken.",ep:1,g:42,l:55,wd:true,fm:true,w:10,an:17,tw:true,e:[5,6,1,1,50,50,false,false],s:32,p:8125};
I.u[8131] = {n:"Tas van de Boer",t:81,d:"Deze tas, die erg in de mode is bij jonge scholieren, is ideaal om er dierlijk en plantaardig meel in op te slaan. Als je hem opent, uitvouwt en de naden loshaalt, kan hij ook nog als rok dienen als je niet bang bent je harige dijen te laten zien.",ep:1,g:3,l:19,wd:true,fm:true,w:1,s:47,p:1153};
I.u[8132] = {n:"Zwarte Scarariem",t:10,d:"Aan deze riem ontbreekt elke originaliteit. Hij lijkt echter goed te passen bij je kapsel.",ep:6,g:93,l:43,wd:true,fm:true,w:10,s:49,p:4955};
I.u[8133] = {n:"Zwarte Scaramuts",t:16,d:"Dit is het perfecte hoofddeksel voor degenen die het somber inzien.",ep:6,g:132,l:53,wd:true,fm:true,w:10,s:49,p:7350};
I.u[8134] = {n:"Zwarte Scaracape",t:17,d:"Als je geen geld hebt om een Ravencape Mastralis te kopen, maar je wilt wel de Arachnees bang maken door je in het zwart te kleden, dan is dit de cape die je moet hebben.",ep:6,g:100,l:53,wd:true,fm:true,w:10,s:49,p:7575};
I.u[8135] = {n:"Sleutel van de Bwork Toren",t:84,d:"Met deze verrassende sleutel kan je de Toren van de Bworks ingaan, maar er niet levend uitkomen.",ep:1,g:234,l:1,wd:true,fm:true,w:1,p:100};
I.u[8136] = {n:"Zwarte Scararing",t:9,d:"Deze fantastische ring kan om de grote teen gedragen worden. Ideaal om je wratten en ingegroeide nagels mee te verbergen.",ep:6,g:104,l:48,wd:true,fm:true,w:10,s:49,p:6200};
I.u[8137] = {n:"Vergulde Scaraknobbel Ingewanden",t:15,d:"Deze ingewanden zijn gedeeltelijk verantwoordelijk voor de moeilijke indigestie van de Vergulde Scaraknobbel. Je kunt ze dus zonder schuldgevoel bakken.",ep:6,g:726,l:70,wd:true,fm:true,w:5,p:100};
I.u[8138] = {n:"Zwart Scarablad Schild",t:107,d:"Als je hem één slag omdraait, is dit schild een prima asbak.",ep:6,g:727,l:40,wd:true,fm:true,w:5,p:100};
I.u[8139] = {n:"Sleutel van de Scarablad Toren",t:84,d:"Met deze prachtige gouden sleutel kan je de Toren van de Scarabladeren binnengaan. Dacht je dat je alles gezien had?",ep:1,g:233,l:1,wd:true,fm:true,w:1,p:100};
I.u[8140] = {n:"Zwarte Scarablad Voelsprieten",t:15,d:"Het zwarte Scarablad heeft nooit enig nut gehad van zijn eigen voelsprieten. De natuur doet echt rare dingen.",ep:6,g:728,l:40,wd:true,fm:true,w:1,p:100};
I.u[8141] = {n:"Zwarte Scarablad Vleugels",t:104,d:"In tegenstelling tot wat sommige avonturiers denken, zijn de vleugels van het Zwarte Scarablad niet zwart, maar wit. Nog een mysterie van de natuur, die de bewogen discussies in de herberg voedt.",ep:6,g:729,l:40,wd:true,fm:true,w:1,p:100};
I.u[8142] = {n:"Geheime Sleutel van het Koninklijke Tofuhuis",t:84,d:"Deze sleutel geeft toegang tot het Koninklijke Tofuhuis. Er wacht je een flink pak slaag.",ep:3,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[8143] = {n:"Veld Sleutel",t:84,d:"Deze sleutel geeft je toegang tot de Veld Grot... Alleen je kunt er niet meer mee naar buiten.",ep:1,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8144] = {n:"Mojo van de Moowolf",t:15,d:"Dit flesje bevat alle viriele kracht van de Moowolf. Pas op, de inhoud is niet eetbaar.",ep:2,g:730,l:1,wd:true,fm:true,w:1,p:1};
I.u[8145] = {n:"Bwork Bier",t:37,d:"Bworkbier maakt een Féca op afstand dronken en een Sadida van 15 voet hoog. Men weet niet precies of het door of van Bworks gemaakt wordt, of allebei.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8146] = {n:"Legendarische Krakler Laarzen",t:11,d:"Als je van dansen houdt en graag op andersmans tenen staat, dan zijn deze laarzen bijzonder geschikt.",ep:5,g:77,l:86,wd:true,fm:true,w:10,s:52,p:19150};
I.u[8147] = {n:"Legendarische Kraklerhelm",t:16,d:"Deze verbeterde versie van de Kraklerhelm, beschermt je tegen vallende stenen, maar niet tegen haaruitval.",ep:5,g:133,l:80,wd:true,fm:true,w:10,s:52,p:16530};
I.u[8148] = {n:"Legendarische Krakler Hamer",t:7,d:"Deze enorme hamer is eigenlijk het zwaard van de Krakler, met een steen van de Legendarische Krakler. Je tegenstanders zullen er versteld van staan als ze het zien... net voordat je ze ermee verplettert.",ep:5,g:58,l:81,wd:true,fm:true,w:10,an:15,e:[7,5,1,1,40,50,false,false],c:"CA>100&CI>50",s:52,p:16850};
I.u[8149] = {n:"Legendarische Krakring",t:9,d:"Deze met edelstenen bezette steen is ideaal om de slapen of het voorhoofd van je tegenstanders eens en voor altijd van een merk te voorzien.",ep:18,g:105,l:80,wd:true,fm:true,w:10,s:52,p:16775};
I.u[8150] = {n:"Legendarische Krakler Amulet",t:1,d:"Dit ogenschijnlijk eenvoudige amulet bevat heel wat geheimen, inclusief het geheim dat verklapt welke geheimen het heeft.",ep:5,g:99,l:84,wd:true,fm:true,w:10,s:52,p:18350};
I.u[8151] = {n:"Vreetbuik",t:18,d:"Dit monstertje volgt je overal en voedt zich met de overblijfselen van zijn soortgenoten. Dan weer angstaanjagend, dan weer vermakelijk, vrolijkt hij je leven op voor dat hij het je misschien voor altijd ontneemt.",ep:3,g:35,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8152] = {n:"Legendarische Krakler Riem",t:10,d:"De legendarische Krakler droeg deze riem om zijn tenen, jij om je middel of misschien om je enkels...",ep:5,g:94,l:80,wd:true,fm:true,w:10,s:52,p:16506};
I.u[8153] = {n:"Boomchnisch",t:18,d:"Net als jij, verdraagt deze kleine Abraknyde zijn familie niet meer en heeft besloten zich te verzetten. Vandaag begeleidt hij je en houdt het aantal  familieleden bij die je hebt kunnen vernietigen.",ep:3,g:34,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8154] = {n:"El Scarador",t:18,d:"Dit kleine charmante uit het zuiden afkomstige kevertje is eigenlijk erg geducht. Omdat hij vroeger toen hij jong was door z\'n vrienden vernederd werd, besloot hij zich te wreken en hij helpt je dan ook met het uitdelen van schoppen onder de kont van alle Scarabladeren die je zult tegenkomen.",ep:3,g:36,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8155] = {n:"Minifoux",t:18,d:"Dit schitterende wezen is verre familie van de beroemde Lenalds van het Wabbiteiland. Het is stoutmoediger en heeft minder discipline, maar helpt je bij je gevechten. Hij kan je ook helpen om z\'n eigen familieleden te verslaan.",ep:3,g:37,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8156] = {n:"Sleutel van de Canidae Toren",t:84,d:"Met deze sleutel kun je de verschrikkelijke Canidae Toren betreden. Als je eenmaal binnen bent, wordt je vrolijk afgemaakt.",ep:1,g:235,l:1,wd:true,fm:true,w:1,p:1};
I.u[8157] = {n:"Magisch Bloemblaadje van de Hongerige Zonnebloem",t:35,d:"Net als andere magische voorwerpen, is dit bloemblaadje indrukwekkend, en verspreidt een machtig aura evenredig aan de geloofwaardigheid van de avonturiers die het observeren.",ep:1,g:2,l:20,wd:true,fm:true,w:1,p:100};
I.u[8158] = {n:"Tofurby Smeerveer",t:53,d:"De dikbuikige Tofurby smeert regelmatig vet op zijn veren, zodat de veren niet loslaten. Een techniek die al zo oud is als de wereld en die sommige Enutrofs in staat stelt hun haar te behouden, zelfs na de puberteit.",ep:3,g:1,l:50,wd:true,fm:true,w:1,p:10};
I.u[8159] = {n:"Verguld Scaraknobbel Schild",t:107,d:"Gedragen op het hoofd, biedt dit schild bescherming tegen slecht weer en guanovallen.",ep:6,g:731,l:70,wd:true,fm:true,w:5,p:100};
I.u[8160] = {n:"Vergulde Scaraknobbel Voelsprieten",t:15,d:"Als je wilt lijken op Korgamone de Kapoen van de Karpaten, dan duw je gewoon deze voelsprieten in je neusgaten en loop je zingend door het boerenland waarbij je je kont van rechts naar links beweegt.",ep:6,g:732,l:70,wd:true,fm:true,w:1,p:100};
I.u[8161] = {n:"Vergulde Scaraknobbel Vleugels",t:104,d:"Als je altijd gedroomd hebt om te vliegen als een dikke Piwi, maak dan deze vleugels vast aan je riem en spring van de kerktoren van Brakmar. Je hebt kans dat je zult lijken op een platgestampte Raaf en ben je het lachertje van de dag voor de Brakmariërs en een lekker hapje voor de Raven.",ep:6,g:733,l:70,wd:true,fm:true,w:1,p:100};
I.u[8162] = {n:"Pwompwoen Hoofd",t:16,d:"Je zult er nog achterlijker uitzien dan gewoonlijk met deze magische Pwompwoen op je hoofd, maar denk aan de vloek van Halouine, die sommige wezens in vreemde misvormde beesten veranderd....\nHet zou lijken dat alleen dit hoofddeksel je kan beschermen tegen deze vloek.",ep:1,g:134,l:1,wd:true,fm:true,w:1,p:1};
I.u[8163] = {n:"Kabuto",t:16,d:"Deze helm werd vroeger gedragen door de ordehandhavers van de grote steden en wordt heden gebruikt om hen die de gevestigde orde bestrijden en meer willen weten over wie hun wereld leidt, af te schrikken.",ep:20,g:135,l:101,wd:true,fm:true,w:10,p:26000};
I.u[8164] = {n:"Vreetbuik Cadeau",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden en Eniripsapoeder om het te verzorgen.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8165] = {n:"Boomchnisch Cadeau",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden en Eniripsapoeder om het te verzorgen.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8166] = {n:"Cadeau El Scarador",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden en Eniripsapoeder om het te verzorgen.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8167] = {n:"Minifoux Cadeau",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden en Eniripsapoeder om het te verzorgen.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8168] = {n:"Cadeau van Halouine",t:89,d:"Halouine was bij lange na de grootste Pwompwoen-teler van het hele continent. Helaas was hij tevens de leerling van een Bwork Magus die een beetje te veel in de geheime geneesmiddelen zat. Om de wedstrijd van de grootste met Porkassmest geteelde Pwompwoen te winnen, speelde Halouine vals door de Bwork Magus in te roepen, die een nieuwe toverspreuk uitprobeerde op de Pwompwoenen. Degenen die die betoverde Pwompwoenen proefden, werden gedurende enkele dagen veranderd in vreemde misvormde wezens, en dat ieder jaar in dezelfde periode. Deze vloek lijkt soms ook over te gaan op avonturiers die te dicht bij deze vervloekte schepsels komen. Om deze bezwering af te wenden zetten inwoners van Amakna en omgeving een Pwompwoen op hun hoofd gedurende enkele dagen, in de hoop dat dat hen redt. Het meest verrassende is wel dat het lijkt te werken.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[8169] = {n:"Transformatie Halouine Veelvraat",t:27,d:"Je bent getransformeerd in Halouine Veelvraat. Je moet proberen een andere avonturier te overmeesteren om van deze vreselijke vloek af te komen.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8170] = {n:"Transformatie Halouin Tofu",t:27,d:"Je bent getransformeerd in een Halouine Tofu. Je moet proberen een andere avonturier te overwinnen om je te verlossen van deze vreselijke vloek.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8171] = {n:"Geest van de Boomchnisch",t:90,d:"Deze Geest heeft de wereld der levenden nog niet verlaten en wacht op jou om hem weer te doen herleven of om hem eens en voor altijd lafhartig achter de laten.",ep:3,g:34,l:1,wd:true,fm:true,w:1,p:1};
I.u[8172] = {n:"Vreetbuik Geest",t:90,d:"Deze Geest heeft de wereld der levenden nog niet verlaten, hij wacht op jou om hem weer tot leven te brengen of om hem eens en voor altijd lafhartig achter te laten.",ep:3,g:35,l:1,wd:true,fm:true,w:1,p:1};
