I.u[8249] = {n:"Drinker Veer",t:53,d:"Deze veer gebruikt en gedrenkt met geesten is zeer ontvlambaar. Hij is erg handig om een geroosterde Drinker mee te roosteren.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[8250] = {n:"Crowfox Haar",t:54,d:"De Crowfox vindt het heerlijk zich te verkleden als een Kraai. Niemand weet echter waarom, aangezien de meest kwaadaardige breinen hun eigen mening over dingen hebben...",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[8251] = {n:"Peki Haar",t:54,d:"Wie zou geloofd hebben dat een Peki een stel haren weg zou geven alleen om jou een plezier te doen? Niemand, behalve Garlik Jorisk, beroemde doofus van Amakna, bekend om zijn oneerlijkheid en zijn pathologische liefde voor gevulde Pekis.",ep:18,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[8252] = {n:"Getemde Kraaien Veer",t:53,d:"Deze vettige veer behoort toe aan een Getemde Kraai die zijn hele leven opgesloten zat en gedwongen werd om te eten tot hij vet genoeg was om de hele ruimte van zijn kooi op te vullen.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[8253] = {n:"Spons Amulet",t:1,d:"Dit amulet wordt vaak aangezien voor een gelukstas-kado... Je wint hem eigenlijk op de schietbaan.",ep:1,g:106,l:11,wd:true,fm:true,w:2,s:63,p:525};
I.u[8254] = {n:"Spons Ring",t:9,d:"Deze ring, aangeboden als trouwring, stuurt twee overweldigende berichten naar de drager: “Ik hou van je” en “Ga de afwas doen”. Perfect voor degenen die er een hekel aan hebben om dezelfde dingen steeds te moeten herhalen.",ep:1,g:112,l:10,wd:true,fm:true,w:2,s:63,p:500};
I.u[8255] = {n:"Spons Schop",t:8,d:"Vele onervaren avonturiers zullen zijn vreselijk krachtige wapren herinneren, gebruikt als een verdediging tegen zodes van de aarde. Eenmaal nat, wordt hij zacht en kan hij gerold worden, hoewel het meestal twee zwakkelingen kost om het te doen.",ep:1,g:44,l:10,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,true],s:63,p:500};
I.u[8256] = {n:"Spons Laarzen",t:11,d:"Met deze laarzen kunnen Eniripsas lopen op water... wat nogal nutteloos is aangezien ze al kunnen vliegen, maar het imponeert de menigte. Normale mensen kunnen deze laarzen altijd gebruiken om hun voeten te ontbladeren terwijl ze in hun huis zitten...",ep:1,g:84,l:11,wd:true,fm:true,w:5,s:63,p:525};
I.u[8257] = {n:"Spons Riem",t:10,d:"Deze riem liet Vlad zijn seizoensbad nemen zonder zijn leven in gevaar te brengen. Inderdaad, geen enkele Iop slaagde erin om zoveel te leren als de hondenpeddel.",ep:1,g:102,l:10,wd:true,fm:true,w:5,s:63,p:500};
I.u[8258] = {n:"Spons Cape",t:17,d:"Deze cape is perfect om jezelf te camoufleren in de natuurlijke omgeving. Nou ja, je voegt meer een plezierige aanraking toe aan het landschap, maar hey, wie wil er nou onzichtbaar zijn?",ep:1,g:109,l:10,wd:true,fm:true,w:1,s:63,p:505};
I.u[8259] = {n:"Spons Helm",t:16,d:"Instructies: “Bied deze helm aan je echtgenoot aan. Maak hem stevig aan zijn hoofd vast en sleep hem aan zijn voeten de keuken door. Nu heb je een schone, glimmende vloer. Wees voorzichtig dat je hem niet verdrinkt terwijl je de helm afspoelt.” Dit somt de staat van het moderne huwelijk op. Feministen.",ep:1,g:143,l:11,wd:true,fm:true,w:10,s:63,p:525};
I.u[8260] = {n:"Kaliptus Hoofdband",t:16,d:"Met deze hoofdband zien de Iops er knapper uit dan ooit!",ep:20,g:124,l:133,wd:true,fm:true,w:10,p:43500};
I.u[8262] = {n:"A Moolet",t:1,d:"A Moolet bevat een vreemde substantie die in de ingewanden van de Moowolf gevonden wordt, sommigen beweren dat het gaat om de essentie van het monster, anderen denken dat hij alleen maar een niet zo frisse Kirball had verorberd.",ep:20,g:107,l:143,wd:true,fm:true,w:1,s:55,p:44850};
I.u[8263] = {n:"Moowolf Ring",t:9,d:"Pas op, van deze ring gaat je vinger bijzonder stinken. De ene geur kan de andere overheersen. Dat is misschien maar beter ook, voor je vinger en voor je omgeving...",ep:20,g:113,l:126,wd:true,fm:true,w:10,s:55,p:40190};
I.u[8264] = {n:"Moowolf Laarzen",t:11,d:"Deze laarzen worden gedreven door de enorme eetlustvan de Moowolf. Als je tenen naar kaas ruiken, loop je de kans dat ze je bijten.",ep:18,g:85,l:131,wd:true,fm:true,w:20,s:55,p:42840};
I.u[8265] = {n:"Moowolf Cape",t:17,d:"De staart van de Moowolf is zo mooi en zo lang dat hij over de grond sleept. Sommige jaloerse avonturiers hebben de Moowolf ervan ontdaan en dragen hem nu in de hoop virieler over te komen.",ep:20,g:110,l:139,wd:true,fm:true,w:10,s:55,p:44500};
I.u[8266] = {n:"Moowolf Riem",t:10,d:"Deze gekleurde riem heeft een geweldige paarse pluk aan de voorkant, als je hem achterstevoren draagt kun je je als een Wabbit vermommen.",ep:20,g:103,l:125,wd:true,fm:true,w:1,s:55,p:1};
I.u[8267] = {n:"Moowolf Muts",t:16,d:"Bij het in stukken snijden van de Moowolf, ontdekte de jagers dat deze slechts een grote hoorn bezit die van de ene naar de andere kant van zijn kop loopt, hetgeen de Iops die hem met groot enthousiasme dragen totaal niet hindert.",ep:4,g:144,l:141,wd:true,fm:true,w:10,s:55,p:44600};
I.u[8268] = {n:"Minotoror Halsketting",t:1,d:"Deze ketting bescherme de Minotoror tegen vlooien, tekens en zelfs luizen. Je kunt zelf beslissen of jij hem nodig hebt of niet.",ep:18,g:112,l:111,wd:true,fm:true,w:1,s:54,p:31260};
I.u[8269] = {n:"Minotoror Ring",t:9,d:"In tegenstelling tot wat sommige avonturiers beweren, heeft de Minotoror deze ring nooit gedragen, omdat hij hem eenvoudig nooit om zijn klompen kreeg.",ep:21,g:117,l:105,wd:true,fm:true,w:1,s:54,p:28010};
I.u[8270] = {n:"Minotot Armband",t:9,d:"Deze armand beschermt de hele arm van een Eniripsa, maar hij wordt er drie keer zwaarder door.",ep:21,g:116,l:151,wd:true,fm:true,w:10,s:57,p:45425};
I.u[8271] = {n:"Ring van de VarkensDraak",t:9,d:"Met deze ring van leer en ivoor kan je makkelijker je partners stimuleren.",ep:18,g:115,l:108,wd:true,fm:true,w:1,s:58,p:29600};
I.u[8272] = {n:"Minotot Ketting",t:1,d:"Met deze ketting kon de Minotot zijn nek beschermen en voorkomen dat hij tenonder ging tengevolge van een stomme slag van de Wabbit.",ep:21,g:111,l:158,wd:true,fm:true,w:20,s:57,p:47800};
I.u[8273] = {n:"Varkens Draak Ketting",t:1,d:"Aan deze ketting zit een lus die om de nek van de Varkensdraak kon worden gedaan als zijn eigenaar hem voor een nachtelijke wandeling wilde meenemen.",ep:21,g:110,l:100,wd:true,fm:true,w:1,s:58,p:25470};
I.u[8274] = {n:"Minotoror Bijl",t:19,d:"Deze bijl heeft het hoofd afgehakt van een van de gevaarlijkste Minotorors die de provincie Amakna ooit heeft gekend. Het meest ongelofelijke van dit verhaal is dat het je totaal koud schijn te laten.",ep:21,g:44,l:109,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,40,50,false,true],s:54,p:30110};
I.u[8275] = {n:"Minotot Scepter",t:4,d:"Deze scepter is versierd met een Slangenkop van edelstenen waarmee je jonge avonturiers kunt verjagen en je ze een schop onder hun roze billetjes verkoopt.",ep:21,g:67,l:151,wd:true,fm:true,w:50,an:12,tw:true,e:[5,4,1,1,40,50,false,false],s:57,p:46200};
I.u[8276] = {n:"Minotor Laarzen",t:11,d:"Natuurlijk zijn deze verschrikkelijke laarzen gemaakt van de huid en de vacht van de Minotoror, veel te zwaar om de legendarische hardloopwedstrijd van de baai van Amakna te winnen. Daarentegen, kun je ze wel gebruiken om de voeten van de andere concurrenten bij de startlijn te vermorzelen.",ep:21,g:89,l:113,wd:true,fm:true,w:40,s:54,p:32290};
I.u[8277] = {n:"Minotot Sandalen",t:11,d:"Met deze ongelofelijke sandalen kun je in de meest gevaarlijke wateren baden, zonder je voeten te bezeren. Let echter op, ze hebben wel de reputatie de bodem van ligbaden te beschadigen.",ep:21,g:88,l:163,wd:true,fm:true,w:20,s:57,p:48400};
I.u[8278] = {n:"Muilen van de VarkensDraak",t:11,d:"Een goed paar muiltjes en je voelt je daarna sterker, machtiger, beter presteren. En toch zijn het slechts muiltjes.",ep:20,g:87,l:93,wd:true,fm:true,w:5,s:58,p:22800};
I.u[8279] = {n:"Minotoror Mantel",t:17,d:"Neem een Minotoror. Bind hem stevig vast. Neem een gigantische schaaf en schil zijn huid in één keer. Hier! Je hebt een Minotoror Mantel!",ep:21,g:117,l:109,wd:true,fm:true,w:10,s:54,p:30500};
I.u[8280] = {n:"Minotot Cape",t:17,d:"Dit is dé cape die je moet hebben om \'s avonds uit te gaan, of als verleiding op het gemaskerde bal van Kapitein Chafer.",ep:21,g:116,l:156,wd:true,fm:true,w:40,s:57,p:48850};
I.u[8281] = {n:"Varkens Draak Cape",t:17,d:"Met deze cape zie je er niet uit als een Speen Varkentje, maar je kunt je ermee verkleden voor een feestje en daar een mooi varkentje versieren.",ep:20,g:118,l:103,wd:true,fm:true,w:10,s:58,p:27500};
I.u[8282] = {n:"Minotoror Riem",t:10,d:"Deze soepele riem kun je gebruiken om op de billen van ongehoorzame kinderen te slaan. De gesp ervan markeert mogelijk zelfs hun huid, maar het zal hun vast hun lesje leren, voorgoed.",ep:21,g:106,l:111,wd:true,fm:true,w:1,s:54,p:1};
I.u[8283] = {n:"Minotot Riem",t:10,d:"De Minotot gebruikte deze stijve riem om zijn grote heup vast te houden om te voorkomen dat hij omviel wanneer er droogte was.",ep:21,g:105,l:149,wd:true,fm:true,w:30,s:57,p:49950};
I.u[8284] = {n:"Minotot Muts",t:16,d:"Deze muts wordt in de familie van de Minotot van generatie op generatie doorgegeven.  Dat verklaart gedeeltelijk de geur van rottend haarroos.",ep:21,g:151,l:157,wd:true,fm:true,w:20,s:57,p:47652};
I.u[8285] = {n:"VarkensDraak Muts",t:16,d:"Uitgedost met deze enorme schedel lijk je op een Grizboule met harde vacht, maar zonder vacht. Genoeg om je vrouwelijke bewonderaars sprakeloos te maken.",ep:20,g:150,l:98,wd:true,fm:true,w:10,s:58,p:24500};
I.u[8286] = {n:"Dreggon Cape",t:17,d:"Volgens de legende zal deze met schalen bedekte cape je beschermen tegen bliksem, bonen en vooral tegen “femme fatales”...",ep:11,g:115,l:127,wd:true,fm:true,w:10,s:56,p:41000};
I.u[8287] = {n:"Dreggon Helm",t:16,d:"Een engel zoals jij kan gemakkelijk doorgaan voor een ongenadige krijger met zo\'n enge en onevenredige helm op. Als dat niet werkt, kun je hem altijd nog gebruiken als een mantelrek.",ep:11,g:149,l:128,wd:true,fm:true,w:10,s:56,p:41500};
I.u[8288] = {n:"Dreggon Riem",t:10,d:"De meest bedorven breinen van Amakna zeggen dat deze riem als prothese gebruikt kan worden. Niemand begreep waarom en gelukkig bleek het gerucht niet waar. Het is gewoon een eenvoudige Dreggon Riem.",ep:20,g:104,l:124,wd:true,fm:true,w:1,s:56,p:1};
I.u[8289] = {n:"Dreggon Ring",t:9,d:"Deze ring, direct in vorm van een gigantische Dreggon schaal gesneden, beschermt een klein deel van je falanx. Misschien het belangrijkste deel...",ep:20,g:114,l:128,wd:true,fm:true,w:10,s:56,p:41468};
I.u[8290] = {n:"Drakei Amulet",t:1,d:"Gemaakt van de schubben van de Drakei, beschermt dit amulet op doeltreffende wijze je adamsappel, of je amandelen. Genoeg om het verschil te maken op het strijdveld.",ep:11,g:108,l:124,wd:true,fm:true,w:1,s:56,p:38930};
I.u[8291] = {n:"Drakei Laarzen",t:11,d:"Deze laarzen zijn perfect om de Veelvraat te doden tijdens een potje Vreetbal of om je vijanden meer te laten lijden bij een schop onder hun kont.",ep:20,g:86,l:129,wd:true,fm:true,w:20,s:56,p:41500};
I.u[8292] = {n:"Drakei Zwaard",t:6,d:"Met dit zwaard, scherp als het avondscheermes, kun je je zelfs \'s ochtends scheren, maar alleen de oksels.",ep:11,g:68,l:127,wd:true,fm:true,w:30,an:14,e:[8,5,1,1,40,50,false,true],c:"CS>200&CA>200",p:41025};
I.u[8293] = {n:"Drakei Bijl",t:19,d:"Deze bijl doorklieft boter net zo makkelijk als schedels, of was het nou andersom.",ep:20,g:43,l:126,wd:true,fm:true,w:20,an:17,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>180&CW>80",p:40854};
I.u[8294] = {n:"Drakei Hamer",t:7,d:"Deze hamer, zwaarder dan een lege Krakkerschedel, maar minder stevig dan een dijbeen van een Grot Kirball, is toch nog steeds een geducht wapen.",ep:20,g:59,l:123,wd:true,fm:true,w:30,an:15,e:[10,5,1,1,45,50,false,true],c:"CI>200&CC>100",p:38542};
I.u[8295] = {n:"Drakei Boog",t:2,d:"Deze boog is zo krachtig dat je er rotte Drakeieren mee over de muren van Brakmar kunt schieten. Wat zonde!",ep:20,g:55,l:122,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,8,40,50,false,true],c:"CS>300&CV>250",p:38015};
I.u[8296] = {n:"Dreggon Wand",t:3,d:"Deze wand lijkt effectiever wanneer je hem als knuppel of Moskito mepper gebruikt!",ep:21,g:60,l:124,wd:true,fm:true,w:10,an:11,e:[5,3,2,5,30,30,false,true],c:"CI>100&CA>200",p:37884};
I.u[8297] = {n:"Dreggon Staff",t:4,d:"Één einde van deze staf is bewapend met een lange, scherpe punt. Niemand weet waar die vandaan komt, maar je kunt wel raden waar het meestal naartoe gaat.",ep:20,g:66,l:124,wd:true,fm:true,w:30,an:12,tw:true,e:[5,5,1,1,30,50,false,true],c:"CS>300&CA>150&CV>300",p:39800};
I.u[8298] = {n:"Shika\'s Oren",t:1,d:"Shika hielp Farle tijdens het oogsten, door de magische oren die onder haar zeis vielen,op te rapen. Ze maakte er altijd een ketting van. Alhoewel ze van hun wortels ontdaan waren en ook van hun steel, bleven deze magische oren toch ieder jaar in dezelfde periode rijpen.",ep:18,g:113,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8299] = {n:"Magische Armband van Shika",t:9,d:"Deze armband bedekte Shika\'s armen, waardoor ze beschermd was tegen zonnebrand en de snavelaanvallen van de Raven die aangetrokken werden door haar stralende schoonheid. Ze zijn nog doordrenkt met haar heerlijke zweet.",ep:21,g:118,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8300] = {n:"Shika Staf",t:4,d:"Met deze op maat gemaakte stok kon Shika de hoogste hooimijten van heel Amakna creëren. De legende vertelde dat ze zo groot waren, dat de zeelieden ze gebruikten als herkenningspunt om te weten of ze al dan niet de kust van Amakna naderden.",ep:20,g:69,l:80,wd:true,fm:true,w:10,an:12,e:[10,5,1,1,45,45,false,false],s:53,p:16500};
I.u[8301] = {n:"Shikas Klompen",t:11,d:"Deze klompen zijn bedacht zodat Shika nooit de zaailingen vertrapt als ze de vlakten van Snossios inzaaide. Ze liet er hoge hakken aan toevoegen, zodat ze ´s morgens vrijelijk door de stoppels kon rennen, zonder haar klompen met dauw te vullen, of zonder haar gevoelige enkels te verwonden.",ep:21,g:91,l:80,wd:true,fm:true,w:10,s:53,p:16600};
I.u[8302] = {n:"Shika\'s Cape",t:17,d:"Bloemen uit de oogsttijd zijn aan deze uit graan gemaakte cape vastgenaaid. Het wordt door zo\'n krachtige magie gedreven dat Shika het als bescherming tegen bliksem gebruikte tijden stormige nachten.",ep:20,g:120,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8303] = {n:"Shika\'s Riem",t:10,d:"Deze lederen riem beschermde Shika\'s dijen als ze door tarwevelden rende om de Gobbals die hun kudde verloren waren terug te brengen. Er wordt gezegd dat de riem, bedekt met pollen van magische granen, in het maanlicht schitterde en Farle hielp te vermijden dat hij de benen van zijn vrouw afhakte als hij zijn graanvelden oogstte \'s nachts.",ep:21,g:107,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8304] = {n:"Shikamuts",t:16,d:"Deze muts, bedekt met vele oogstbloemen gaf een vrolijk voorkomen aan Shika als ze \'s ochtends vroeg de heuvels van Koln ging ploegen.",ep:20,g:156,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8305] = {n:"Mominotor Relikwie",t:24,d:"Om een Minotoror tegen te komen heb je dit vreemde relikwie nodig.",ep:21,g:119,l:1,wd:false,fm:true,w:0,p:1};
I.u[8306] = {n:"Relikwie van Déminoboule",t:24,d:"Dit vreemde relikwie is onmisbaar om de Minotoror te kunnen ontmoeten.",ep:21,g:120,l:1,wd:false,fm:true,w:0,p:1};
I.u[8307] = {n:"Sleutel van de Minotot Kamer",t:84,d:"Deze sleutel, vervaardigd uit diverse materialen, zal je een audiëntie verschaffen met de angstaanjagende Minotot. Als je het tot het einde volhoudt, maakt het een prachtig verhaal voor bars en picknick tafels in het land. Je zult ook een pijnlijke kont hebben, als je het overleeft om het verhaal te vertellen... Succes!",ep:13,g:15,l:1,wd:true,fm:true,w:1,p:10};
I.u[8308] = {n:"Scaratos Schelp",t:107,d:"Deze kleine glimmende schelp is erg nuttig om leuke sieraden te maken tegen lage kosten die je vervolgens voor een fortuin verkoopt als je een Astrubiaan hebt overtuigd dat het een krachtige souvenir is waardoor je de lucht in kunt vliegen en onzichtbaar bent.",ep:21,g:735,l:1,wd:true,fm:true,w:1,p:10};
I.u[8309] = {n:"Quetsnakiatl Veer",t:53,d:"Deze veer is bedekt met magische steenstof wat verklaart waarom een deel van de veren van Quetsakiatl zwaarder is dan drie delen Tofu veren. Het draait allemaal om logisch beredeneren.",ep:21,g:4,l:1,wd:true,fm:true,w:10,p:1};
I.u[8310] = {n:"Gelatine Gelei",t:110,d:"Deze pot gelei bevat een substantie met weerzinwekkende geur en verschrikkelijke smaak, en toch droom je er elke dag heimelijk van je in te smeren met deze substantie. Nog zo\'n gedragsstoornis van je, die waarschijnlijk andere verbergt...",ep:21,g:736,l:1,wd:true,fm:true,w:1,p:1};
I.u[8311] = {n:"Minokid Haar",t:54,d:"Deze haar lijkt bedekt te zijn met zacht-harig-Tuftie-musk gebaseerde brylcreème en grot Kirball vet. Ze zien er bijna smakelijk uit.",ep:21,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[8312] = {n:"Minoskito Huid",t:59,d:"Deze huid, versleten door zand en zeezout, is zo dun als een oude sok die versleten is door zand en zeezout. Nou kun je zeggen dat de Minoskito op een oude sok lijkt, maar dat doe je toch niet.",ep:21,g:604,l:1,wd:true,fm:true,w:1,p:1};
I.u[8313] = {n:"Minotoror Femur",t:47,d:"Dit bot is fors genoeg om als steunbalk te gebruiken of om bakstenen in pakken van tien te breken. Dit is handig als je het huis van je buren wilt verwoesten. Onnodig voor mensen van gezonde geest.",ep:2,g:644,l:1,wd:true,fm:true,w:1,p:1};
I.u[8314] = {n:"Khamelerost Huid",t:59,d:"Deze geroosterde huid beschermt gevoelige huiden tegen straaltjes zonlicht. Het is in het bijzonder strakpassende huid.",ep:21,g:603,l:1,wd:true,fm:true,w:1,p:1};
I.u[8315] = {n:"Manderisha Huid",t:59,d:"Deze gepukkelde huid is kennelijk bedekt met een vergif die iedereen in een gedroogde Karaball kan veranderen.",ep:21,g:602,l:1,wd:true,fm:true,w:1,p:1};
I.u[8316] = {n:"De Minifoux: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek, geschreven door Oshimo Diklip, legt uit hoe je een Minifoux moet fokken.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8317] = {n:"El Scarador : Hoe fok je je favoriete huisdier",t:25,d:"Dit boek geschreven door Oshimo Diklip gaat over  hoe je je El Scarador het beste kunt fokken.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8318] = {n:"Boomchnisch: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek geschreven door Oshimo Diklip legt uit hoe je een Boomchnisch het beste opvoedt.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8319] = {n:"Vreetbuik: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek, geschreven door Oshimo Diklip, legt uit hoe je een Vreetbuik moet fokken.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8320] = {n:"Sleutel van het Draak Varken Doolhof",t:84,d:"Nadat je verdwaalde in het Draak Varken doolhof realiseerde je je dat je de sleutel van het Draak Varken hol was vergeten. Gelukkig hadden je Porco vrienden een reserve bij zich.",ep:15,g:16,l:1,wd:true,fm:true,w:1,p:100};
I.u[8321] = {n:"Deminoball Haar",t:54,d:"Het is nutteloos om vol te houden! Deze laarzen zijn niet eetbaar.",ep:21,g:664,l:100,wd:true,fm:true,w:1,p:10};
I.u[8322] = {n:"Mumminotor Haar",t:54,d:"Onder zijn verband verbergt de Mumminotor een hele zachte achterkant waar menig prinses jaloers op zou zijn.",ep:21,g:663,l:100,wd:true,fm:true,w:1,p:10};
I.u[8323] = {n:"Deminoball Leder",t:56,d:"Dit gebarsten en ruwe leder doet je herinneren aan jouw geliefde wangen.",ep:21,g:657,l:100,wd:true,fm:true,w:1,p:10};
I.u[8324] = {n:"Mumminotor Leder",t:56,d:"De Mumminotor heeft altijd een gevoelige huid gehad, daarom moet hij bedekt worden met een heleboel verbanden. Hatelijke roddelaars zeggen dat hij dat doet om andere verrassende dingen te verbergen...",ep:21,g:656,l:100,wd:true,fm:true,w:1,p:10};
I.u[8325] = {n:"Mominotor Muts",t:16,d:"Als je je gezicht wilt behoeden voor de tand des tijds, raden we je deze muts aan. Let op, hij beschermt je absoluut onvoldoende tegen geheugenverlies.",ep:0,g:157,l:110,wd:false,fm:true,w:10,s:59,p:100};
I.u[8326] = {n:"Momminotor Verband",t:15,d:"Dit verband, om de hoorns maar speciaal om intieme delen heen gewikkeld, werd gedrenkt in de magie van de Mumminotor gedurende de voorbijgaande jaren. Dit verband, stinkend en angstaanjagend, is een essentieel element om te verzamelen voor archeologen nou.",ep:21,g:734,l:100,wd:true,fm:true,w:1,p:10};
I.u[8327] = {n:"Deminoball Hoorn",t:47,d:"Op het eerste gezicht lijkt deze impressieve hoorn niet erg nuttig. En als je eens beter kijkt, lijkt hij nog steeds niet erg nuttig: een beetje als een leger van teken.",ep:21,g:643,l:100,wd:true,fm:true,w:1,p:10};
I.u[8328] = {n:"Mumminotor Hoorn",t:47,d:"Deze hoorn, ingewikkeld in een magisch verband, moet wel erg duur zijn, erg geliefd, verschrikkelijk ruikend en vervloekt. Een beetje zoals een mummy zou zijn.",ep:21,g:642,l:100,wd:true,fm:true,w:1,p:10};
I.u[8329] = {n:"TEST",t:84,d:"x",ep:1,g:0,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8330] = {n:"Vliegende Drakei Muts",t:16,d:"Met deze kleine muts kan de vliegende Drakei zich storten op zijn vijanden zonder het risico builen op te lopen op de schedel. Deze muts, die sinds lange tijd gebruikt wordt op de bouwterreinen van Amakna, is weer in populariteit toegenomen na de invasie van Astrub door de illustere troep afgetoomde Moowolfs van de Kruup berg. Er zit geen enkele logica in dit verhaal, maar maakt dat wat uit?",ep:13,g:152,l:72,wd:true,fm:true,w:10,p:16000};
I.u[8331] = {n:"Drakostes Muts",t:16,d:"Voorzien van dit hoofddeksel, kan je je zonder moeite vermommen en de eerste de beste goedgelovige Astrubiër verleiden en oplichten als je dat zou willen, door hem een wilde liefdesnacht achter een grote iep voor te stellen voor slechts 100 kamas.",ep:18,g:153,l:95,wd:true,fm:true,w:10,p:23000};
I.u[8333] = {n:"Kwestman Cape",t:17,d:"Deze mysterieuze cape komt tevoorschijn tijdens koude seizoenen, en maakt het bedriegers mogelijk door te gaan voor een vrijgevige oude man.",ep:1,g:119,l:19,wd:true,fm:true,w:10,p:1205};
I.u[8334] = {n:"Kwestman Hoed",t:16,d:"Met deze hoed kan je de littekens op je schedel bedekken. Dan kan je eindelijk aardig worden gevonden door kinderen.",ep:1,g:155,l:22,wd:true,fm:true,w:10,p:1478};
I.u[8335] = {n:"Heel klein Kwestcadeautje",t:89,d:"Het Ankama-team wenst je vrolijke en gelukkige feestdagen. Dit cadeau zal je zo gelukkig maken als je nog nooit bent geweest.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8336] = {n:"Kwestcadeautje",t:89,d:"Het Ankama-team wenst je vrolijke en gelukkige feestdagen. Dit cadeau zal je zo gelukkig maken als je nog nooit bent geweest.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8337] = {n:"Kwestcadeau",t:89,d:"Het Ankama-team wenst je vrolijke en gelukkige feestdagen. Dit cadeau zal je zo gelukkig maken als je nog nooit bent geweest.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8338] = {n:"Kwest Zwaard",t:6,d:"Dit vreemde zwaard zal je niet onoverwinnelijk maken, maar je kan hem misschien gebruiken om sneeuwballen te doden.",ep:1,g:69,l:1,wd:false,fm:true,w:1,an:14,e:[1,1,1,1,2,2,false,true],p:1};
I.u[8339] = {n:"Groot Kwestcadeau",t:89,d:"Het Ankama-team wenst je vrolijke en gelukkige feestdagen. Dit cadeau zal je zo gelukkig maken als je nog nooit bent geweest.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8340] = {n:"Ongelofelijk Kwestcadeau",t:89,d:"Het Ankama-team wenst je vrolijke en gelukkige feestdagen. Dit cadeau zal je zo gelukkig maken als je nog nooit bent geweest.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8341] = {n:"Laarsananas",t:11,d:"Deze laarzen ruiken naar ananassap getrokken in een subtraat van kapotte sokken. Het voordeel is dat niemand je ooit zal vragen om ze uit te trekken als je naar een vriend gaat.",ep:1,g:90,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8342] = {n:"Draggon Toevluchtsoord Sleutel",t:84,d:"Deze sleutel, gemaakt van pressie-gebonden Dreggon schelpen, zal je toegang geven tot het vreselijke Dreggon Toevluchtsoord, bekend om zijn vreemd stille inwoners.",ep:10,g:18,l:1,wd:true,fm:true,w:1,p:100};
I.u[8343] = {n:"Dreggon Grot Sleutel",t:84,d:"Je dacht dat je alles had gezien in het Dreggon Toevluchtsoord, maar NEE! Bij lange na niet. Ik denk zelfs dat deze sleutel je dood wordt.",ep:10,g:17,l:1,wd:true,fm:true,w:1,p:100};
I.u[8344] = {n:"Zwarte Dragoss Hoorn",t:47,d:"Het is niet zo puntig als een Xelor klokhand maar veel steviger. Deze hoorn laat de Dragoss een Spanking Sessie veranderen in een Cracking Sessie.",ep:11,g:648,l:50,wd:true,fm:true,w:1,p:10};
I.u[8345] = {n:"Saffieren Dragoss Hoorn",t:47,d:"Het is niet zo puntig als een Xelor klokhand maar veel steviger. Deze hoorn laat de Dragoss een Spanking Sessie veranderen in een Cracking Sessie.",ep:11,g:647,l:50,wd:true,fm:true,w:1,p:10};
I.u[8346] = {n:"Witte Dragoss Hoorn",t:47,d:"Het is niet zo puntig als een Xelor klok hand, maar het is veel steviger. Deze hoorn laat de Dragoss een Spankink sessie veranderen in een Cracking sessie.",ep:11,g:646,l:50,wd:true,fm:true,w:1,p:10};
I.u[8347] = {n:"Gouden Dragoss Hoorn",t:47,d:"Het is niet zo puntig als een Xelor klok hand, maar het is veel steviger. Deze hoorn laat de Dragoss een Spankink sessie veranderen in een Cracking sessie.",ep:11,g:645,l:50,wd:true,fm:true,w:1,p:10};
I.u[8348] = {n:"Zwarte Dragoss Schelp",t:111,d:"Je kunt deze schelp gebruiken om te beschermen wat voot jou geliefd is.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Saffieren Dragoss Schelp",t:111,d:"Je kunt deze schelp gebruiken om jouw meest dierbare dingen te beschermen.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
I.u[8350] = {n:"Witte Dragoss Schelp",t:111,d:"Je kunt deze schelp gebruiken om jouw meest dierbare dingen te beschermen.",ep:11,g:740,l:50,wd:true,fm:true,w:1,p:10};
I.u[8351] = {n:"Gouden Dragoss Schelp",t:111,d:"Je kunt deze schelp gebruiken om jouw meest dierbare dingen te beschermen.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Zwarte Dragoss schub",t:59,d:"Je zou deze schaal kunnen gebruiken om een prachtig paar laarzen te maken of gevechtsondergoed.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Saffieren Dragoss schub",t:59,d:"Je zou deze schaal kunnen gebruiken om een mooi paar laarzen te maken of gevechtsondergoed.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"Witte Dragoss schub",t:59,d:"Je zou deze schaal kunnen gebruiken om een mooi paar laarzen te maken of gevechtsondergoed.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Gouden Dragoss schub",t:59,d:"Je zou deze schaal kunnen gebruiken om een mooi paar laarzen te maken of gevechts ondergoed.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Dragostess Huid",t:59,d:"Glad en geparfumeerd met bloed van jonge avonturiers, de huid van Dragostesses is onweerstaanbaar hierdoor. Het wordt gebruikt om laarzen of riemen te maken, deze huid kan worden gewassen in een wasmachine op elke temperatuur.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Dragostess Hoorn",t:47,d:"De Dragostess heeft twee kleine hoorns achter op het hoofd. Laatstgenoemde zorgen ervoor dat ze makkelijk liefdesgolven kan opvangen, gestuurd door Dreggons tijdens het broedseizoen, welke eigenlijk nooit eindigt voor ze.",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Dragostess Bescherming",t:111,d:"Dit paar Dreggon schelpen beschermt de Dragostess tegen liefde op het eerste gezicht. Mannen kunnen het ook gebruiken, maar ze moeten het beneden de gordel dragen.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Vliegende Dreggon Vleugel",t:104,d:"Zelfs als deze vleugel beschadigd, bescheurd en verbrand is, kan de Vliegende Dreggon nog steeds vrij boven wrakken vliegen als een jonge zorgeloze Moskito.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Vliegende Dreggon Huid",t:59,d:"Deze donkere huid is bedekt met een massa van kleine schubben welke de aerodynamiek van de Vliegende Dreggon zouden moeten verbeteren. Eigenlijk zijn ze nutteloos en gaan mensen er enkel door praten.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Vliegende Dreggon Hoorn",t:47,d:"De Vliegende Dreggon gebruikt zijn hoorn mikkend apparaat om zijn doel niet te missen als hij drinkt en vliegt.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Dreggon Krijger Huid",t:59,d:"De Dreggon Krijgershuid, sterk genoeg om zijn eigen lemmet te kunnen tegenhouden, staat ook bekend omdat hij eetbaar is... maar je moet het eerst een aantal jaren koken.",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Dreggon Krijger Hoorn",t:47,d:"De Dreggon Krijger heeft drie verschillende hoorns: twee achterop zijn hoofd en een derde boven zijn snuit. Na een gevecht belandt er meestal een hoorn in het achterwerk van zijn slachtoffer en de andere twee eindigen roekeloos in de neusgaten. Maar van tijd tot tijd vergist de Dreggon Krijger zich, denkend dat de achterkant de neusgaten zijn, en dit maakt het enkel nog slechter voor zijn slachtoffers.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Dreggon Krijger Lederen Riem",t:15,d:"Deze lederen draagband laat de Dreggon Krijger zijn schoudervulling vastmaken of vervangen.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Crocabulia Gebroken Hoorn",t:47,d:"Crocabulia heeft haar eigen hoorn gebroken tijdens een vreselijk gevecht terwijl ze een ei beschermde waar de kleine Crocoburio 15 jaar later uit kwam.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Cape van Roodkapje",t:17,d:"Deze cape was van een beroemde Chapon, een oud gevogelte met lange veren dat ervan hield te pronken voor de Zaap van Bonta voor zijn hoenderhof, bestaande uit goedgelovige musjes en onvolwassen kippetjes",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Crocabulia Huid",t:59,d:"Deze rode huid laat je een cape maken voor de Kleine Rode Waddling Kapoen als je niet bang bent voor het mokken van je bondgenoten.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Cracabulia Tand",t:47,d:"Deze enorme tand is er op het laatste moment uit getrokken, net voor Crocabulia haar mond voor eeuwig sloot.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Stukje van de Schelp van Terrakubiack de Krijger",t:111,d:"Dit stukje schelp, toebehorend aan Terrakubiack de Krijger, zou je moeten helpen om een sleutel te maken die je toegang geeft tot het Dreggon Toevluchtsoord.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Stukje van de Schelp van Ignilicrobur de Krijger",t:111,d:"Dit stukje schelp, toebehorend aan Ignilicrobur de Krijger, zou je toegang moeten geven tot het Dreggon Toevluchtsoord.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Stukje van de Schelp van Aeroktor de Krijger",t:111,d:"Dit stukje schelp toebehorend aan Aeroktor de Krijger zou je moeten helpen om toegang te verkrijgen tot het Dreggon Toevluchtsoord.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Stukje van de Schelp van Aquabralak de Krijger",t:111,d:"Dit stukje schelp, toebehorend aan Aquabralak de Krijger zou je moeten helpen om een sleutel te maken die je toegang verschaft tot het Dreggon Toevluchtsoord.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Steen van Ignirkocropos de Uitgehongerde",t:51,d:"Deze steen kan een krachtige magische golf bevrijden die een magische deur activeert en open maakt, als en alleen als het gebundeld wordt met de andere drie stenen die erin horen.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Steen van Aqualikros de Genadeloze",t:51,d:"Deze steen kan een krachtige magie bevrijden welke een magische deur kan openen en activeren, alleen en alleen als het gecombineerd wordt met de drie overige stenen.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Steen van Terraburkahl de Trouweloze",t:51,d:"Deze steen kan een krachtige magie bevrijden welke een magische deur kan openen en activeren, alleen en alleen als het gecombineerd wordt met de drie overige stenen.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Steen van Aerogoburius de Kwaadaardige",t:51,d:"Deze steen kan een krachtige magische golf bevrijden die een magische deur activeert en open maakt, als en alleen als het gebundeld wordt met de andere drie stenen die erin horen.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Klus Rune",t:88,d:"Met deze magische steen kunnen de Doe-het-zelvers hun positie doorgeven aan hun klanten.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Magisch Fragment",t:88,d:"Dit magische fragment bevat een deel van de magie die vroeger in een voorwerp zat. Met een beetje geluk zou je een paar magische runen moeten kunnen terughalen.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Levens Rune",t:78,d:"Deze kleine rune heeft het vermogen sterker te maken.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Peki weefsel",t:55,d:"Dit weefsel werd gebruikt om het harige achterwerk van de Peki te bedekken voordat je besloot om hem aan de verkeerde kant te knuffelen.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Magische Peki Staart",t:65,d:"Deze staart is zo magisch dat hij nog steeds kronkelt ook al is hij afgesneden, gedroogd en gevuld! Als je slim genoeg bent, kun je hem misschien ergens anders voor gebruiken dan gewoon hangende boven je schoorsteen.",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Maan Huid",t:59,d:"Ontdaan van zijn zachte huid was arme Maan verrast en kon enkel wegrennen de jungle in terwijl hij zijn pijn uitschreeuwde. Dit is een leuk slaapverhaaltje die je je kinderen vast zult vertellen om ze in slaap te krijgen.",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Magische Maan weefsel",t:55,d:"Dit weefsel lijkt magisch en dat vind je moeilijk te geloven. Maar ooit zul je de waarheid moeten aanschouwen... Je bent te stom om te zeggen of iets magisch is of niet. Volg niet je Astrubiaanse moordenaars instincten en vertrouw op de aanwijzingen.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Shin Larve Huid",t:59,d:"Deze huid van de Shin Larve is nog plakkeriger en kleveriger dan je kan voorgestellen. Hij doet je denken aan de laatste prinses die je hebt bevrijd.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Shin Larve Tand",t:47,d:"Niemand had kunnen vermoeden dat een Shin Larve een mond vol tanden had. Misschien wel omdat de Shin Larve slechts één enkele tand heeft.",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Trillende Veer van de Koninklijke Tofu",t:53,d:"Koninklijker dan de veer van de Koninklijke Tofu, meer trillend dan de veer van een Trillende Kirboule van de mijnen van Kruup, kan deze veer iedereen die je maar wil, waar je maar wil, kietelen. In de handleiding wordt beschreven dat het onderhoud relatief eenvoudig is.",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Bworkette Huid",t:59,d:"De Bworkette heeft je toegestaan een stukje van haar huid te nemen in ruil voor je clementie. Maar ze is vergeten je te zeggen dat ze haar grote broer de Bworker heeft gewaarschuwd, die met plezier een stukje van de jouwe zal afscheuren.",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Bworkettehaar",t:54,d:"De Bworkette heeft een gladde huis, behalve onder de oksels. Het is wel nodig om de koekjes die ze onder haar oksels rolt af en toe te kruiden.",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Farle\'s Varkens Huid",t:59,d:"Als je luistert naar wat de fokkers zeggen, was Farle de grootste varkens fokker (zowel mannelijke als vrouwelijke varken). Maar ze waren allemaal jaloers op Shika. Hoe dan ook, wat zeker is, is dat hij degene is die Farle\'s Varkens creeërde en ze zijn naam gaf, alsof ze zijn toonbeeld waren.",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"Dorgan Ation Huid",t:59,d:"Dorgan Ation is nogmaals erg vrijgevig geweest naar jou toe ondanks zijn slechte humeur. Hij gaf je deze huid voor hij weg ging en zeurde als een Armzalig Zwijn. Hoe durft ie!",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"Blodz Uker Huid",t:59,d:"De Blods Uker die je met een kaasschaaf hebt bewerkt om een dunne huid te krijgen zal dit de rest van zijn leven herinneren. We kunnen ons zelfs voorstellen dat hij wrok tegen je koestert voor een lange tijd. Reken er niet op dat hij je de weg vertelt als je nog eens in zijn doolhof verdwaald raakt.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Draak Varken Haar",t:54,d:"Hoewel je grondig gezocht hebt kon je niet vinden van welk lichaamsdeel deze haar van het Draak Varken vandaan kwam. Zoek nog wat beter. De anatomie van het Draak Varken is vol verrassingen...",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Mega Legendarische Krakler Steen",t:51,d:"Deze enorme steen lijkt op een steen van de legendarische Krakler en toch is het er geen een, hij is veel meer.",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Mojo van de Boowolf",t:15,d:"Dit flesje bevat alle mannelijke kracht van de Boowolf. Pas op, de inhoud is niet eetbaar.",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Wa Wabbit Haar",t:54,d:"De Wa Wabbit is meestal erg gierig en deinst al terug als zijn haren gedeeld moeten worden. Zeer zeldzaam, om je moed te belonen (of je zachtheid te kopen) besluit hij om je één van zijn lichaamsdelen te geven. Hoe aandoenlijk!",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Wa Wabbit weefsel",t:55,d:"Niemand weet echt waar de Wa Wabbit dit weefsel vandaan heeft, en niemand wil het kennelijk ook weten. Storend en verontrustend, de origine van dit weefsel blijft één van de grootste mysteries van heel Amakna.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Pandora Meester Haar",t:54,d:"Wederom toen de Pandora Meester wilde opscheppen heeft hij een lesje geleerd die hij niet snel zal vergeten. Hij had beter in zijn doos kunnen blijven.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Pandora Meester weefsel",t:55,d:"Of het nou zijn hoofd of zijn achterkant bedekt, dit weefsel redde het leven van Pandora Meester meer dan eens! Maar niet die ene keer.",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Pandora Meester Huid",t:59,d:"Versleten door magische aanvallen, gedroogd door de wind van Pandala Eiland. Hierdoor heeft de huid nou een erg slechte kwaliteit. Maar je lijkt eraan vast te zitten alsof je een geliefde souvenir wilt bewaren van de moedige Pandora Meester, die je menig maal heeft geprobeerd te vermoorden. Hierdoor kunnen we duidelijk verschil maken tussen een echt monster en een bangerik.",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Koolich Steen",t:51,d:"Hoewel de Koolich behoorlijk vrijgevig is, was hij niet echt blij toen hij deze grote steen aan jou gaf. Dat is begrijpelijk als men weet wat je ermee gaat doen.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
I.u[8403] = {n:"Koolich Vlecht",t:15,d:"Deze grote vlecht was door de Koolich zelf gemaakt, enkele jaren geleden. Met de jaren mee werd het net zo stijf als een rots. Hoe dan ook, hij houdt nog steeds een slijmerig gemeen vocht bij zich dat nu en dan Moskito\'s aantrekt. Het meest verrassende is nog dat deze vlecht perfect bij de Koolich paste. Net als een dikke Slob had je het belachelijke idee om hem te stelen.",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Skeunk Huid",t:59,d:"Dit stukje huid komt waarschijnlijk van de hielen van een Skeunk, wat de mooie geelachtige kleur verklaart. Hoewel deze oude huid je geen trendy kleren laat maken, kun je er nog steeds “retro”kleren mee maken wat jongere generaties leuk zullen vinden.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Skeunk Haar",t:54,d:"Skeunk denkt er niet over om hun volledige lichaam te scheren. Hier is bewijs.",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Minotot Wol",t:57,d:"Deze wol is in het bijzonder dun, wat het mogelijk maakt voor de Minotot om niet overal kroeshaar te hebben. Niemand weet waarom hij dit heeft. Misschien zou je moeten proberen om haar transplantaten te maken van deze wol zodat je in staat bent om een overvloedige bruine haargroei op je borstkas te laten zien. Zie, zelfs dromen uit je kindertijd kunnen uitkomen!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Minotot Leder",t:56,d:"Dit leder, bijna net zo zeldzaam als Gobball leder, is perfect voor creaties die soepele naden vereisen... lederen maskers bijvoorbeeld.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Minotot Hoef",t:47,d:"Deze hoef trapte op net zoveel koeievlaaien als op eerlijke avonturiers. Het moet gezegd worden, het is vaak moeilijk om het verschil te zien.",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
I.u[8409] = {n:"Minotot Hoorn",t:47,d:"Van een afstand af lijkt deze hoorn op een gigantische extreem krachtige Gobball hoorn. Verrassend genoeg lijkt hij van dichtbij op een Minotot hoorn.",ep:21,g:655,l:400,wd:true,fm:true,w:1,p:10};
I.u[8410] = {n:"Minotot Femur",t:47,d:"Dit indrukwekkende bot slaagde er in om het overmatige gewicht van de Minotot eeuwenlang te dragen. Zulke voeten verdienen het om wat aandacht te krijgen.",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8411] = {n:"Mominotor Amulet",t:1,d:"Dit vervloekte amulet, bedekt met windsels, stelt je misschien in staat de vloek van het labyrint van Minotoror te overleven. Maar niets is minder zeker, misschien is het slechts een hebbeding om de toeristen voor de gek te houden.",ep:0,g:114,l:111,wd:false,fm:true,w:5,s:59,p:31300};
I.u[8412] = {n:"Mominotor Ring",t:9,d:"Deze ring gemaakt van in elkaar gerolde windsels van Mominotor stinkt erger, is nogal lelijk, maar is een uitstekend verband voor als je je vinger tussen één van de deuren van het labyrint van Minotoror hebt gekregen.",ep:0,g:119,l:111,wd:false,fm:true,w:10,s:59,p:31525};
I.u[8413] = {n:"Mominotor Hamer",t:7,d:"Het blok steen aan het uiteinde van deze hamer is in windsels van de Mominotor gewikkeld om de sappen te absorberen van de wezens die je zult pletten, of simpelweg om ze minder pijn te doen, en ze niet te snel te doden.",ep:0,g:60,l:112,wd:false,fm:true,w:10,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>100&CI>200&CW>150",s:59,p:100};
I.u[8414] = {n:"Drakei Dolken",t:5,d:"Deze dolken zijn ideaal om het kapje van een zachtgekookt Drakei Ei af te slaan. Bovendien zijn ze erg licht, waardoor je er snel vandoor kunt gaan als de rest van de Drakei-gemeenschap het in de gaten krijgt.",ep:20,g:58,l:128,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CS>150&CI>150&CA>100",p:39854};
I.u[8415] = {n:"Mominotor Laarzen",t:11,d:"Gevoerd en versierd met windsels van Mominotor, zijn deze laarzen tegelijkertijd heel comfortabel en erg warm. Ze doen je misschien aan iemand denken.",ep:0,g:92,l:110,wd:false,fm:true,w:10,s:59,p:31255};
I.u[8416] = {n:"Mominotor Cape",t:17,d:"Gemaakt van de gevlochten windsels van de Mominotor, zal deze cape je een stijl geven alsof je regelrecht uit het graf komt. Je vijanden kunnen groen zien van jaloezie.",ep:0,g:122,l:111,wd:false,fm:true,w:10,s:59,p:31780};
I.u[8417] = {n:"Taart Schep",t:8,d:"Dit kleine schepje is aan een jonge Enutrof gegeven, hij was er zo aan gehecht dat hij het vlak voor zijn dood nog steeds gebruikte.",ep:20,g:43,l:131,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CC>250&CA>100",p:42514};
I.u[8418] = {n:"Mominotor Riem",t:10,d:"Deze grote band van Mominotor bezit een bijzondere toegevoegde waarde, waarvan de oorsprong evenwel miskend blijft. Maar wat doet het ertoe, hij wordt duur verkocht, en zijn vloek zal de ontbinding van de heupen van de vrienden aan wie je deze riem geeft versnellen, wat, dat moet toegegeven worden, eenvoudigweg van onschatbare waarde is.",ep:0,g:108,l:112,wd:false,fm:true,w:10,s:59,p:32255};
I.u[8419] = {n:"Moh Schep",t:8,d:"Met deze schep heeft kapitein Machab de buik van Grobill Dick, de grote Witte Krakamor, opengereten.",ep:20,g:42,l:115,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>200",p:33653};
I.u[8420] = {n:"Drakei Schep",t:8,d:"De Drakei graven graag onderaardse gangen, maar gebruiken daarvoor geen schep. De Enutrof gemeenschap heeft lange tijd dit raadsel onderzocht en kwam tot de ontdekking dat het minder belangrijk is te weten waar de schep vandaan komt, dan te weten hoe je ermee moet  slaan.",ep:20,g:45,l:127,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,40,40,false,true],c:"CC>200&CS>100",p:42154};
I.u[8421] = {n:"Certificaat van Plaatsing in Kennel: Lelijke Kleine Raaf",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Lelijke Kleine Raaf die je in de kennel hebt geplaatst.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8424] = {n:"Compensatiecadeau van de fokker",t:89,d:"Dit voor fokkers bestemde cadeau bevat genoeg om een omheining met prima fokmachines te vullen.\n(Attentie, de voorwerpen in dit cadeau zijn erg zwaar, je loopt het risico te zwaar belast te raken als je het opent).",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8425] = {n:"Beurs met 10000 Kamas",t:100,d:"Deze beurs is erg zwaar, hij bevat zeker een waar fortuin. Een koopman zal hem heel graag van je willen overnemen tegen zijn waarde in kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:100000};
I.u[8426] = {n:"Rookbommetje",t:74,d:"Dit rookbommetje creëert een rookgordijntje dat helaas niet je kleine acties aan het oog kan onttrekken.",ep:1,g:30,l:1,wd:false,fm:true,w:1,c:"(PX=3)|(PX=4)",ut:true,p:1};
I.u[8428] = {n:"Bewolkt Onzichtbaarheids Drankje",t:12,d:"Dit drankje laat je toe om terug te gaan naar het laatst bewaarde punt zonder spoor.",ep:0,g:26,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,ut:true,p:1};
I.u[8430] = {n:"Magische Gele Ballon",t:94,d:"In tegenstelling tot de vervalsingen die in op de Trool kermis vindt, kan deze ballon zich afdoen met gratie en gemak. Een pracht om aanschouwen, hij is handgemaakt met Aardbei Gelei ooglid, volgens de tradities van de grote magus Betsy Krokerr.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8431] = {n:"Cyclonale Rook Drankje",t:12,d:"Dit rook drankje creëert een wervelend rookscherm die al je acties met stijl verbergt.",ep:0,g:29,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,p:1};
I.u[8435] = {n:"Rode Magische Ballon",t:94,d:"In tegenstelling tot de vervalsingen die men op de Trool kermis vindt, weet deze ballon tenminste weg te vliegen met gratie en gemak. Met de hand gemaakt zoals vroeger, met een waar ooglid van Aardbeien Gelei volgens traditioneel recept van de grote magiër Vahy Nez.",ep:1,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8436] = {n:"Zachte Eik Grot Sleutel",t:84,d:"Deze sleutel geeft je toegang tot de meest intieme delen dat de anatomie van de Zachte Eik... Wedden dat je het niet eens weet als je bij die speciale plek komt? Net zo storend en opwindend als de veel geliefde Amaknaanse sport van naakte Judo, laat deze reis je handen niet leeg, dat is zeker...",ep:1,g:236,l:1,wd:true,fm:true,w:1,p:100};
I.u[8437] = {n:"Sleutel van de Verzandde Toren",t:84,d:"Met deze sleutel, gemaakt op basis van zee-afval en schelpen, krijg je toegang tot het strand waar zich het fijnste zand van de gehele kust van de Zee van Asse bevindt.",ep:1,g:237,l:1,wd:true,fm:true,w:1,p:100};
I.u[8438] = {n:"Sleutel van de Ratten Toren van Brakmar",t:84,d:"Met deze sleutel heb je toegang tot Ratten Toren die in de riolen. Je hoeft je niet te vermommen, je kunt ongezien naar binnen, zelfs als je geen Brakmarier bent.",ep:1,g:238,l:1,wd:true,fm:true,w:1,p:100};
I.u[8439] = {n:"Sleutel van de Ratten Toren van Bonta",t:84,d:"Met deze sleutel kun je de Rattentoren betreden die in de riolen van Bonta is gelegen. Daarvoor hoef je je niet te verkleden, je komt ongezien binnen, zelfs als je geen Bontariër bent.",ep:1,g:239,l:1,wd:true,fm:true,w:1,p:100};
I.u[8441] = {n:"Billalo",t:16,d:"Bill wilde een stralenkrans. Hij schreeuwde zo hard en hij kreeg zo\'n driftbui dat hij zijn zin kreeg. Een echte kleine duivel.",ep:22,g:159,l:100,wd:true,fm:true,w:1,p:25540};
I.u[8442] = {n:"Zwarte Rat Masker",t:16,d:"Met dit masker kon Brouce Boulgoure op subtiele wijze een schuilplaats van de Riool Ratten binnendringen om een iepenboom bij de wortels te kappen. Hij heeft uiteindelijk alle ratten in de schuilplaats in de pan gehakt want hij was in werkelijkheid niet erg discreet met zijn grote houten klompen.",ep:2,g:158,l:102,wd:true,fm:true,w:1,s:68,p:17222};
I.u[8443] = {n:"Cape van de Zwarte Rat",t:17,d:"Deze cape kan van iedere soort haar gemaakt worden, op voorwaarde dat ze zo smerig mogelijk zijn. Ze worden gevlecht en vervolgens met behulp van diverse afscheidingen vastgezet. De geur kan niet gekozen worden.",ep:13,g:123,l:105,wd:true,fm:true,w:5,s:68,p:18356};
I.u[8444] = {n:"Dolken van de Zwarte Rat",t:5,d:"Met de lemmets, zowel snijdend en beschadigd, van deze dolken kun ja de ledematen van je tegenstanders afhakken met verontrustend gemak, terwijl je er verzekerd van kunt zijn dat je tegelijkertijd een indrukwekkend stuk huid mee zult nemen. Jammer dat ze niet verroest, witgloeiend en giftig zijn als je ze gebruikt.",ep:8,g:59,l:108,wd:true,fm:true,w:5,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CW>100&CV>300",s:68,p:19358};
I.u[8445] = {n:"Halsband van de Zwarte Rat",t:1,d:"De rat die deze halsband bezat, dacht dat hij het hoofd van zijn clan werd. Hij is opgegeten door een woedende Lenald.",ep:18,g:115,l:103,wd:true,fm:true,w:5,s:68,p:17650};
I.u[8446] = {n:"Laarzen van de Zwarte Rat",t:11,d:"Let op als je deze laarzen aandoet, komt het wel eens voor dat ze nog één of twee voeten van de vorige eigenaar bevatten.",ep:13,g:93,l:101,wd:true,fm:true,w:10,s:68,p:18700};
I.u[8447] = {n:"Riem van de Zwarte Rat",t:10,d:"In tegenstelling tot zijn witte bontarische neef, houdt de Zwarte Rat van bescheidenheid, en draagt dus een eenvoudige stoffen riem. Maar hij draagt ook graag zoveel mogelijk wapens bij zich, die een hels lawaai maken als ze bij iedere pas tegen elkaar stoten.",ep:13,g:109,l:101,wd:true,fm:true,w:5,s:68,p:18934};
I.u[8448] = {n:"Ring van de Zwarte Rat",t:9,d:"Draai deze ring naar rechts als je de hand van een vijand moet schudden, en naar links als je die van een vriend moet schudden. In ieder geval wordt je ontraden te applaudiseren met deze ring.",ep:20,g:120,l:98,wd:true,fm:true,w:5,s:68,p:16980};
I.u[8449] = {n:"Transformatie van de Boomchnid Toren",t:27,d:"Een Boomchnid heeft je gebeten en je bezweerd met een vreemde vloek.",ep:9,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8450] = {n:"Zwaard van de Witte Rat",t:6,d:"Dit Wapen is het symbool van de Witte Rat. Het staat er bekend om zijn mogelijkheid vijand en bondgenoot met hetzelfde gemak door te hakken.",ep:16,g:71,l:109,wd:true,fm:true,w:10,an:14,tw:true,e:[5,5,1,1,40,50,false,false],c:"CA>150&CS>100",s:67,p:17542};
I.u[8451] = {n:"Muts van de Witte Rat",t:16,d:"Met deze muts lijkt de Witte Rat op een echte Witte Rat uit Bonta. Zonder deze muts, lijkt hij op een echte Witte Rat uit Bonta zonder muts.",ep:13,g:160,l:105,wd:true,fm:true,w:10,s:67,p:18451};
I.u[8452] = {n:"Cape van de Witte Rat",t:17,d:"Deze cape staat symbool voor een witte rat uit het riolenstelsel van Bonta, hij is aan hem gegeven na een lang en moeilijk examen, en hij draagt hem met trots tot aan zijn dood, dat wil zeggen nooit lang.",ep:14,g:124,l:102,wd:true,fm:true,w:5,s:67,p:17025};
I.u[8453] = {n:"Halsband van de Witte Rat",t:1,d:"Als je hem als een halsband draagt, zal hij je beschermen tegen de giftige dampen die uit de riolen komen. Als je hem daarentegen als een riem draagt, zullen het je bondgenoten zijn die tegen jouw giftige dampen beschermd zijn.",ep:18,g:116,l:103,wd:true,fm:true,w:5,s:67,p:18900};
I.u[8454] = {n:"Handschoen van de Witte Rat",t:9,d:"Deze handschoen was in het bezit van Marie Thee, kokkin van het paleis van Bonta. Ze gebruikte hem voor het afmaken van de Veelvraten die weigerden zich te laten kelen, de wilde planten die niet in de sla wilden, en de klanten die ze niet wilden eten.",ep:18,g:121,l:101,wd:true,fm:true,w:5,s:67,p:17150};
I.u[8455] = {n:"Riem van de Witte Rat",t:10,d:"In tegenstelling tot wat zijn zwarte brakmarese neef gelooft, houdt de witte rat er ook van om dingen in het geheim te doen. De metalen verbindingen van deze riem zijn versterkt met teer en maken geen enkel geluid, behalve als zijn drager op jammerlijke wijze ten val komt, dat wil dus zeggen vaak, aangezien hij een paar ton weegt.",ep:16,g:110,l:102,wd:true,fm:true,w:150,s:67,p:18850};
I.u[8456] = {n:"Laarzen van de Witte Rat",t:11,d:"Met deze laarzen is je evenwicht perfect, zelfs bij sterke wind zul je slechts een duimbreed opzij gaan.",ep:3,g:94,l:99,wd:true,fm:true,w:10,s:67,p:17650};
I.u[8457] = {n:"Ceremonie Masker van de Ratten Heer",t:16,d:"Dit hoofddeksel heeft niets te maken met een Dora... Helemaal niets, zeg ik je! Het is dus niet nodig om valse geruchten te verspreiden naar aanleiding van het gebrek aan inspiratie of luiheid van zijn ontwerper. Integendeel, het is juist heel leuk.",ep:13,g:173,l:133,wd:true,fm:true,w:10,s:64,p:43300};
I.u[8458] = {n:"Ceremonie Cape van de Ratten Heer",t:17,d:"Deze gekleurde cape maakt je een bevoorrecht doelwit. Alleen levendige en behendige avonturiers hebben hem lang kunnen dragen.",ep:14,g:125,l:130,wd:true,fm:true,w:10,s:64,p:42030};
I.u[8459] = {n:"Ceremonie Halsband van de Ratten Heer",t:1,d:"Om te voorkomen dat hij van hem gestolen wordt, wordt deze halsband om de nek van de erfgenaam van de Meester van de ratten gedaan bij zijn geboorte. Zo is, als hij volwassen is, de enige manier om hem van hem af te nemen, hem te onthoofden. Men steelt hem evengoed van hem.",ep:18,g:117,l:134,wd:true,fm:true,w:5,s:64,p:45842};
I.u[8460] = {n:"Ceremonie Ring van de Ratten Heer",t:9,d:"Deze ring is gemaakt in een periode dat de meester van de ratten verminkt was geraakt en nog maar één vinger had. De ongelukkige meesters die na hem kwamen hadden al hun vingers nog.",ep:20,g:122,l:131,wd:true,fm:true,w:5,s:64,p:42542};
I.u[8461] = {n:"Ceremonie Riem van de Ratten Heer",t:10,d:"De figuren op deze riem geven de indruk dat je vuur in je achterste hebt. Het gezichtsbedrog is zo overtuigend dat de dragers ervan er zelf ook in geloven en brullend als een kip zonder kop rondrennen. Dat komt precies overeen met het ritueel van de ceremonie.",ep:16,g:111,l:133,wd:true,fm:true,w:10,s:64,p:43358};
I.u[8462] = {n:"Ceremonie Laarzen van de Ratten Heer",t:11,d:"De eerste Heer van de Ratten is gestorven toen hij per ongeluk in een plas met smeltende lava stapte. Deze laarzen worden door zijn heren gedragen als eerbewijs. Let op, ze zijn niet vuurvast.",ep:13,g:95,l:134,wd:true,fm:true,w:10,s:64,p:43541};
I.u[8463] = {n:"Oer Boomchelm",t:16,d:"Dit hoofddeksel moet gemaakt zijn voor Jicé Aoewer, want hij heeft een plat hoofd. Je kunt er gerust mee pronken dus. Hij heeft het in feite gemaakt na de overwinning op de Oer Boomchnid toen die zijn noten tussen z\'n billen brak, maar schept er niet zo over op.",ep:9,g:174,l:114,wd:true,fm:true,w:10,s:65,p:33150};
I.u[8464] = {n:"Oer Boomccape",t:17,d:"s Zomers mag de Oer Boomchnid zich graag koesteren in de zon, maar het hout van deze donkere bossen kan er niet goed tegen. Deze cape is gemaakt met schillen van zijn schors.",ep:18,g:126,l:114,wd:true,fm:true,w:5,s:65,p:33524};
I.u[8465] = {n:"Oer Halsketting",t:1,d:"Met deze halsketting om je nek komt je baard nog beter uit. Heb je geen baard, dan is dat je eigen schuld.",ep:20,g:118,l:110,wd:true,fm:true,w:10,s:65,p:31542};
I.u[8466] = {n:"Oer Ring",t:9,d:"Op de avonden dat je teveel gedronken hebt, zie je misschien de Moskito die in deze ring gevangen zit naar je knipogen. Maar vertel dit maar niet aan je vrienden, hij doet maar alsof.",ep:9,g:123,l:113,wd:true,fm:true,w:5,s:65,p:33241};
I.u[8467] = {n:"Oer scheenbeschermers",t:11,d:"Met deze massief houten scheenbeschermers hebben je benen niets meer te vrezen. Ze zijn daarentegen niet te combineren met het dragen van laarzen. Je kan ze gebruiken om je te beschermen tijdens Vreetbal wedstrijden, maar het zal moeilijk voor je zijn om de bal te raken zonder je laarzen.",ep:20,g:96,l:110,wd:false,fm:true,w:10,s:65,p:31524};
I.u[8468] = {n:"Oer Boomchriem",t:10,d:"Deze riem wordt geacht je de voorouderlijke viriliteit te geven. Of dat nu waar is of niet, het effect is achterhaald.",ep:9,g:112,l:111,wd:true,fm:true,w:10,s:65,p:32101};
I.u[8469] = {n:"Slappe Eik Talisman",t:1,d:"Dit uit het hart van de Slappe Eik gesneden stuk hout bezit een grote kracht, zoals bijvoorbeeld de Slappe Eik boos maken.",ep:20,g:119,l:138,wd:true,fm:true,w:10,s:66,p:44521};
I.u[8470] = {n:"Slappe Eik Ring",t:9,d:"Deze ring is een houten uitwerpsel van de Slappe Eik, maar de geur is hetzelfde.",ep:9,g:124,l:139,wd:true,fm:true,w:5,s:66,p:43014};
I.u[8471] = {n:"Zondagse teenslippers van de Slappe Eik",t:11,d:"s Zondags doet de Weke Eik een middagdutje en als hij dan wakker wordt, ziet hij graag dat een gehoorzame Stamchnid hem deze teenslippers brengt zonder er om te hoeven vragen. Helaas heeft hij geen voeten, dus ze zijn nog spiksplinternieuw.",ep:20,g:97,l:136,wd:true,fm:true,w:5,s:66,p:43521};
I.u[8472] = {n:"Gebruikte Cape van de Slappe Eik",t:17,d:"Meer dan 200 jaar geleden is er een onschuldig stuk stof vast komen te zitten in de takken van de Slappe Eik. De boom is er omheen en er doorheen gegroeid, zodat de stof geïmpregneerd is met zijn magie. Het is voortaan onlosmakelijk verbonden met dit grote stuk hout, wat het minder praktisch en ontvlambaar maakt, maar zijn macht is ongekend.",ep:18,g:127,l:142,wd:true,fm:true,w:10,s:66,p:44578};
I.u[8473] = {n:"Slappe Eik Herfst String",t:10,d:"De Slappe Eik draagt in de herfst deze string om zijn waardevolle eikels te beschermen. In de zomer sjouwt hij er open en bloot mee.",ep:9,g:113,l:141,wd:true,fm:true,w:10,s:66,p:44514};
I.u[8474] = {n:"Slappe Eik Muts",t:16,d:"Hoe je deze muts ook draagt, men heeft altijd de indruk dat hij niet recht staat.",ep:9,g:166,l:145,wd:true,fm:true,w:10,s:66,p:45241};
I.u[8476] = {n:"Eerste sleutel van de Sfincter gevangenis",t:24,d:"Deze sleutel is niet voldoende om in de Sfincter gevangenis te kunnen binnendringen, je hebt de andere sleutel nodig!",ep:1,g:502,l:1,wd:false,fm:true,w:0,p:100};
I.u[8477] = {n:"Tweede sleutel van de Sfincter",t:24,d:"Deze sleutel is niet voldoende om in de Sfincter Toren te kunnen binnendringen, je hebt de andere sleutel nodig!",ep:1,g:503,l:1,wd:false,fm:true,w:0,p:100};
I.u[8478] = {n:"Hielenlikkers Drankje",t:12,d:"Deze zeer illegale toverdrank wordt gevreesd door de grootsten. Een enkele slok en de persoon heeft nog maar één obsessie, de hielen van de dichtstbijzijnden likken. Er zijn mensen die beweren dat er varianten bestaan die andere plekken als doel hebben. De ongelukkige drinker zal dan een slechte adem krijgen.",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:10};
I.u[8480] = {n:"Hielenlikkers Drankje",t:24,d:"Dit in hoge mate illegale drankje wordt zelfs door de grootsten gevreesd. Inderdaad: slechts een klein slokje en de drinker ervan heeft nog slechts één obsessie: de hielen van de dichtstbijzijnde persoon likken. Het gerucht gaat dat er een alternatieve versie is die op iets anders doelt. De enige aanwijzing wat betreft die plek is de slechte adem van de ongelukkige drinkers.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:10};
I.u[8481] = {n:"Riool Rat Haar",t:54,d:"Dit haar is vies en stinkt, hij is door de meest ongezonde riolen van de regio gesleurd. En toch glanst hij nog.",ep:2,g:670,l:42,wd:true,fm:true,w:1,p:10};
I.u[8482] = {n:"Riool Ratten Huid",t:59,d:"Deze huid is bedekt met kleine littekens die getuigen van de moeilijke jeugd die de Riool Rat heeft gehad. Je kunt best wel een beetje medelijden met hem hebben !",ep:2,g:621,l:42,wd:true,fm:true,w:1,p:10};
I.u[8483] = {n:"Riool Sjamaan Huid",t:59,d:"Deze huid kan, als hij eenmaal gewassen is, dienst doen als vloerbedekking of als deurmat.",ep:2,g:622,l:40,wd:true,fm:true,w:1,p:10};
I.u[8484] = {n:"Riool Sjamaan Haar",t:54,d:"Dit type haar werd vroeger gebruikt voor namaak-snorren, maar kan eveneens perfect dienen voor namaak-okselhaar.",ep:2,g:671,l:40,wd:true,fm:true,w:1,p:10};
I.u[8485] = {n:"Zwarte Rat Stof",t:55,d:"Deze stof kan dienen als spons als je hem wikkelt om een latje van zacht hout, of zelfs als kontenkrabber. Ach ja, smaken verschillen.",ep:2,g:725,l:100,wd:true,fm:true,w:1,p:10};
I.u[8486] = {n:"Witte Ratten Stof",t:55,d:"Deze stof is net zo vet als een Wabbitvacht die gedrenkt is in Blopvet. Het beschermt je goed tegen de kou, vooral als je hem in lichtelaaie zet.",ep:2,g:726,l:100,wd:true,fm:true,w:1,p:10};
I.u[8487] = {n:"Sfincter Stof",t:55,d:"Deze Stof lijkt bedekt met een vreemd chemisch product met onbekende bijwerkingen. Het is beter deze Stof niet te lang in je handen te houden, er zou een grote bos haar kunnen gaan groeien.",ep:2,g:727,l:200,wd:true,fm:true,w:10,p:100};
I.u[8488] = {n:"Ellepijp van de Zwarte Rat",t:47,d:"Dit bot van de rat kan worden uitgehold, geboord en worden bewerkt om er vervolgens een muziekinstrument van te maken, of een blaaspijp als je niet muzikaal bent.",ep:2,g:658,l:100,wd:true,fm:true,w:10,p:10};
I.u[8489] = {n:"Witte Rat Tand",t:47,d:"Deze tand is in werkelijkheid een vreselijke hoektand waarmee de Witte Rat veel ziektes doorgaf door zijn slachtoffers ermee te bijten. Ook een manier om zich ervan te verzekeren dat zijn slachtoffers zouden overlijden, ook al kon hij ze niet gelijk afmaken. Alle middelen zijn geoorloofd om respect af te dwingen.",ep:2,g:659,l:100,wd:true,fm:true,w:10,p:10};
I.u[8490] = {n:"Sfincter Cell Dijbeen",t:47,d:"Sfincter was niet het type dat grapjes maakt met botten, hij brak ze in tweeën, dan in drieën, dan in vieren en soms zelfs in vijfen als hij de ingedommelde menigte tijdens een slaapverwekkend gevecht weer op wilde krikken.",ep:2,g:657,l:200,wd:true,fm:true,w:10,p:10};
I.u[8491] = {n:"Zwarte Rat Huid",t:59,d:"De Zwarte Rat staat bekend om zijn slechte adem, maar ook om de ruwe huid van zijn achterwerk. Dat is erg makkelijk om niet van de toiletpot te glijden. Helaas neemt de Zwarte Rat niet de moeite om naar het toilet te gaan, want hij leeft altijd in de riolen.",ep:2,g:623,l:100,wd:true,fm:true,w:1,p:10};
I.u[8492] = {n:"Witte Rat Huid",t:59,d:"De Witte Rat schept er een enorm plezier in zich te vervelen in de diepte van zijn riolen en te wachten op een persoon die hem wel wil komen troosten. Vervolgens profiteert hij van de naïviteit en de goedgelovigheid van zijn slachtoffers om ze levend in stukken te snijden en ze te bakken na ze eerst gevuld te hebben met cashewnoten. Arme cashewnoten.",ep:2,g:624,l:100,wd:true,fm:true,w:1,p:10};
I.u[8493] = {n:"Sfincter Cel Huid",t:59,d:"Wie had ooit gedacht dat je op een dag de huid van de beroemde Sfincter in je handen zou kunnen houden? Zeker niet Sfincter. Zijn te grote zelfvertrouwen is er de oorzaak van dat hij zichzelf heeft verloren.",ep:2,g:625,l:200,wd:true,fm:true,w:10,p:100};
I.u[8494] = {n:"Oer Boomchnid Schors",t:96,d:"Deze schors valt van de Oer Boomchnid, zonder dat je hem er met je tanden af hoeft te trekken.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[8495] = {n:"Schijf van de Oer Boomchnid",t:108,d:"Het sap van deze verschrompelde knop werd vroeger helemaal uitgezogen door een hongerig wezen. Als je het in het water gooit, kun je zien dat het z\'n oorspronkelijke vorm weer aanneemt, opzwelt, en als je heel lang wacht, verrot.",ep:9,g:755,l:200,wd:true,fm:true,w:1,p:10};
I.u[8496] = {n:"Wortel van de Oer Boomchid",t:98,d:"Deze wortel, die zelf van zijn eigenaar afgerukt is, kan je voor je billen slaan of om je enkels draaien. Vies beest!",ep:9,g:668,l:200,wd:true,fm:true,w:1,p:10};
I.u[8497] = {n:"Recept van de filtounga",t:24,d:"Dit boek bevat de geheimen van de filtounga, het mythische gerecht bedacht door Schuim Vraat.",ep:16,g:95,l:1,wd:true,fm:true,w:0,u:true,p:10};
I.u[8498] = {n:"Kaniger Vlees",t:63,d:"Dit vlees is zo teder als een Mushd hersen.",ep:13,g:375,l:80,wd:true,fm:true,w:1,p:1};
I.u[8499] = {n:"Koalak Vlees",t:63,d:"Meestal is Koalak vlees aardig stevig. Je kunt het wat fijner maken als je er met een Kaliptus koffer op slaat. Net zoals je dat bij ongehoorzame kinderen doet.",ep:20,g:376,l:60,wd:true,fm:true,w:1,p:1};
I.u[8500] = {n:"Crocodyle Vlees",t:63,d:"Dit smakeloze vlees kan gedurende vele jaren worden bewaard in de modder, totdat het gaat rotten en eindelijk een beetje smaak krijgt.",ep:4,g:377,l:70,wd:true,fm:true,w:1,p:1};
I.u[8501] = {n:"Geconserveerd Kanigrouvlees",t:64,d:"Dit Kanigrouvlees kan nu enkele dagen worden bewaard alvorens te worden gebruikt in een gerecht.",ep:13,g:387,l:80,wd:true,fm:true,w:1,p:10};
I.u[8502] = {n:"Geconserveerd Koalakvlees",t:64,d:"Dit Koalakvlees kan nu enkele dagen bewaard worden voordat het voor een gerecht gebruikt wordt.",ep:20,g:388,l:120,wd:true,fm:true,w:1,p:10};
I.u[8503] = {n:"Geconserveerd Crocodyle Vlees",t:64,d:"Dit Crocodylevlees kan nu meerdere dagen bewaard worden voor het in een gerecht gebruikt wordt.",ep:4,g:389,l:70,wd:true,fm:true,w:1,p:10};
I.u[8504] = {n:"Kanigrou Entrecote",t:69,d:"Warm of koud, deze entrecote verzadigt de grootste vreetzakken.",ep:13,g:132,l:80,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8505] = {n:"Koalak Filet",t:69,d:"Dit stuk vlees vult zelfs de grootste magen.",ep:20,g:133,l:120,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8506] = {n:"Crocodyl Entrecote",t:69,d:"Dit indrukwekkende stuk vlees is erg moeilijk te verteren, dat is duidelijk te zien. Maar de gulzigheid wint het altijd van het redelijk verstand.",ep:4,g:134,l:70,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8507] = {n:"Filtunga Gerecht",t:69,d:"De Filtunga is een uniek gerecht. Het perfecte mengsel van ingrediënten geeft het een hemelse smaak. Warm serveren met een tikje slagroom en takje peterselie.",ep:1,g:136,l:100,wd:true,fm:true,w:1,c:"Cv<100",u:true,ut:true,p:1};
I.u[8508] = {n:"Filtounga-gerecht",t:24,d:"Dit gerecht is voor Paindep de tovenares.",ep:1,g:120,l:1,wd:true,fm:true,w:0,p:1};
I.u[8509] = {n:"Bwork bier recept",t:25,d:"De grote magiër Bworknroll onthult hier het heilige recept van het Bworkbier. Hij spaart geen enkel geheim van het maken van dit bier. Hij gaat zelfs zo ver dat hij de beste manier om het te proeven geeft. Een genot voor de liefhebbers, een nachtmerrie voor hen die dit bier al gedronken hebben zonder het te kennen.",ep:1,g:130,l:10,wd:false,fm:true,w:5,u:true,p:500};
I.u[8511] = {n:"",t:102,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:10,tw:true,e:[20,7,4,12,50,30,true,true],p:1};
I.u[8513] = {n:"Scalpel van Bworknroll",t:5,d:"Om \"stukjes\" wezen te verzamelen, is er niets beter dan de scalpel van de Bworknroll, die de vitaliteit van de afgerukte ledematen bewaart. Je moet hem tijdens het gevecht gebruiken om de gewenste delen te bemachtigen.",ep:1,g:60,l:40,wd:true,fm:true,w:10,an:13,e:[10,4,1,1,30,50,false,false],c:"Qa=166",p:100};
I.u[8514] = {n:"Vampier Hersenen",t:15,d:"Constant overladen met bloedlichaampjes zuigen de hersenen van een vampier alle beschikbare rode bloedlichaampjes op. Dat is de reden dat vampiers er zo bleek uitzien. Bij de Iops zijn het voornamelijk de voeten die het bloed opzuigen, vandaar dat ze beter kunnen springen dan nadenken...",ep:3,g:492,l:20,wd:true,fm:true,w:2,u:true,p:10};
I.u[8515] = {n:"Trool Bot",t:47,d:"Als je de stevigheid en het gewicht van een Troollbot vaststelt, begrijp je beter waarom hun klappen tijdens een spelletje Trooll zo veel pijn doen.",ep:4,g:640,l:5,wd:true,fm:true,w:50,p:50};
I.u[8516] = {n:"Hart van Bworkselhaat",t:15,d:"Deze harteloze Bworkette die haar zoon Krazybwork in een beerput heeft gegooid is vervloekt door Bworknroll die ze haar liefde heeft geweigerd. Opgesloten in een kelder, voedt ze zich iedere dag met haar eigen hart. Iedere nacht groeit het en slaat weer vol vuur.",ep:4,g:518,l:33,wd:true,fm:true,w:33,p:33};
I.u[8517] = {n:"Mumussel",t:15,d:"Deze mooie en frisse Mumussel is een geweldig gezelschap voor Bworks als ze van hun vrouwen gaan plunderen.",ep:3,g:756,l:1,wd:true,fm:true,w:3,p:21};
I.u[8518] = {n:"Mumussel en Frietjes",t:69,d:"Vanuit de diepten van de Asse Zee verzamelen Mumussels wier die ze onder hun oksels rollen. Als het materiaal op een frans frietje lijkt gaan ze naar het strand om ze in de zon te laten bruinen voor ze ze opeten.",ep:3,g:135,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:30};
I.u[8519] = {n:"Gatrool",t:69,d:"Deze rituele taart gevuld met Troolstront is een oud bwork recept. Alleen een Bwork die een Trooll met blote handen heeft overwonnen heeft het recht ervan te eten. Als hij dat gevecht heeft overleefd, is hij bereid alles te eten!",ep:1,g:136,l:5,wd:true,fm:true,w:20,u:true,p:200};
I.u[8520] = {n:"Gratrool",t:60,d:"Met dit dikke en voedzame vet kan je de meeste voedingsmiddelen koken in oude stoofpotten zonder dat ze aankoeken. Sommige handige Osamodas gebruiken het tevens om Tofus in zekere plekken te laten glijden die de Iopmoraal afkeurt.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[8521] = {n:"De rode cape",t:17,d:"De rode cape is een gewild voorwerp onder megalomanen. Als hij eenmaal om hun frêle schouders hangt, denken ze dat ze Superman worden of een oppermachtige tovenaar, tot ze een Minotoror tegenkomen.",ep:1,g:128,l:9,wd:false,fm:true,w:1,p:200};
I.u[8522] = {n:"Magische Effectenwerper",t:74,d:"Dit verbazingwekkende voorwerp is een concentratie van onstabiele zwarte magie. Niemand kan voorspellen wat \'t precies is, maar het wordt aangeraden niet te lang te wachten om hem te gebruiken.",ep:1,g:31,l:1,wd:false,fm:true,w:0,ut:true,p:1};
I.u[8523] = {n:"De relikwie van de Robill",t:24,d:"Dit vertrouwde voorwerp vloeit voort uit een supersterke magische stroom. Doorgegeven van generatie op generatie, heeft het niets van zijn kracht verloren. Er zijn slechts weinig voorwerpen waar zo\'n kracht van uitgaat. Misschien is het zelfs in aanraking geweest met een Dofus...",ep:1,g:714,l:200,wd:true,fm:true,w:0,p:1};
I.u[8524] = {n:"Pingu Geest",t:90,d:"Deze Geest heeft de wereld van de levenden nog niet verlaten, het hangt van jou af om een manier te vinden om hem weer tot leven te wekken, of hem voor eens en voor altijd lafhartig in de steek te laten.",ep:3,g:45,l:1,wd:true,fm:true,w:1,p:1};
I.u[8525] = {n:"Piwi Ei",t:69,d:"Piwi eieren zijn een echte traktatie voor degenen die zin hebben in wat zoets! Echter, ze komen erg snel uit als ze dichtbij een hittebron zijn. Daarom moet je hem niet te lang in je broekzak of mond laten ! Inderdaad, binnen een paar minuten zou er een mini Piwi uit het ei kunnen komen. En vertrouw ons maar, een hongerige Piwi tussen je tanden of die zich een weg door je kleren vergaart is niet iets wat je kunt gebruiken als je kietelig bent.",ep:4,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[8526] = {n:"Bow Kennel Certificaat voor: Bloederige Koalak",t:77,d:"Dit certificaat beschrijft de karaktereigenschappen van het huisdier die je in de Bow Kennel hebt gezet.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8527] = {n:"Gobtrotter",t:11,d:"Deze Goblinhuid laarzen waren gemaakt door Planbworksek om de vijand (als mogelijk van achteren) snel aan te vallen. Deze laarzen hebben menig Bwork kameraad gered in oorlogstijd.",ep:4,g:98,l:14,wd:true,fm:true,w:20,p:400};
I.u[8528] = {n:"Pannenkoeken Recept",t:25,d:"Dankzij Magik Oliver maak je eindelijk het perfecte pannenkoeken deeg om je kleinkinderen vredig naar bed te sturen. Wat is het geheime ingrediënt van dit vullende recept? Magische Genezing natuurlijk!",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[8529] = {n:"Zaap Hamer",t:24,d:"Niks is beter dan deze hamer om een gebroken Zaap te repareren.",ep:1,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[8530] = {n:"Ruskie Hoed",t:16,d:"Deze hoed houdt je oren warm en absorbeert de alcohol uit je adem. Waar kun je nog meer om vragen?",ep:22,g:167,l:151,wd:true,fm:true,w:10,p:46280};
I.u[8531] = {n:"Konijnen Pet",t:16,d:"Wie zou het durven om zo\'n belachelijke pet te dragen? Niemand, als jij het niet zou doen.",ep:1,g:168,l:33,wd:true,fm:true,w:6,p:3000};
I.u[8532] = {n:"Onverschillige Konijnencape",t:17,d:"De kracht van deze cape? Als je je wegdraait van iemand zal je uiterste onverschilligheid hem onmiddellijk doen huilen. Enkel voor de hatelijken onder jullie.",ep:1,g:129,l:14,wd:true,fm:true,w:1,p:775};
I.u[8533] = {n:"Flud",t:16,d:"De Flud is niet echt een hoed. Het is meer een parasiet die zich op hoofden van welbespraakte, luide of agressieve mensen wil vestigen. Zijn walgelijke voorkomen verdrijft alles en overtuigt zijn drager ervan om nog luider te schreeuwen wat totaal nutteloos is aangezien deze mensen toch niks te zeggen hebben...",ep:1,g:169,l:1,wd:true,fm:true,w:1,s:69,p:100};
I.u[8534] = {n:"Cape S\'logue",t:17,d:"Deze opgevulde cape absorbeert al het omringende geluid, wat zijn drager onderdompelt in een leven van ongelooflijk rare stiltes.",ep:1,g:130,l:1,wd:true,fm:true,w:10,s:69,p:100};
I.u[8535] = {n:"Crashers",t:11,d:"Deze getas zijn zo licht dat ze de eigenaar ervan laten rennen en springen wanneer er een actie begint. Gevorderde avonturiers haten ze... Elke Tom Dick en Harry komt en stort zich onuitgenodigd op hun gevechten.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8536] = {n:"Spamette",t:10,d:"deze riem moet strak worden gedragen... zo strak dat het de drager forceert om te stamelen, shudden en in het algemeen sukkelend in de imiterende stijl van Thrustin Timbertake.",ep:1,g:114,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8537] = {n:"Pluswan",t:9,d:"Deze kleine ring heeft geen enkel nut behalve dat je er extreem flitsend uit ziet. Misschien willen mensen nu met je praten.",ep:1,g:125,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8538] = {n:"Issa Mess",t:1,d:"Na diverse nachten van hard werken kondigde de meest beroemde juwelier van Astrub, ook bekend omdat hij opgevoed was door Bworks, aan: “c u l8r @ d gld hs”.  Zelfs de bekende historicus Champo Lhyon kon het bericht niet ontcijferen.",ep:1,g:120,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8539] = {n:"Leerling Lumberjacks Bijl",t:19,d:"Ook al kun je niet goed met bijlen omgaan, je zult jezelf niet pijn doen met deze stompe bijl. Als je maar lang en hard genoeg hakt, kan je misschien wat bomen omver krijgen.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:0};
I.u[8540] = {n:"Leerling Boers Zeis",t:22,d:"Dit is een zeis van gemiddelde kwaliteit, maar ga niet klagen... Hij is verdorie gratis. Hij oogst, wat wil je nog meer?",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[8541] = {n:"Leerling Visser\'s Hengel",t:20,d:"Deze hengel had altijd een betere vorm. Hoewel het touw een beetje afgerafeld is en de hoek stomp, zal je geen probleem hebben om een paar gudgeons te vangen.",ep:1,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,1,100,100,false,false],p:1};
I.u[8542] = {n:"Leerling Alchemists Handschoenen",t:20,d:"Je kunt zien dat die handschoenen veel geld waar zijn. Je kunt amper het zweet van de vorige eigenaar ruiken, je kunt je vingers er amper in krijgen, je zou zweren dat er helemaal geen gat in zit.                                                                  Hoe dan ook, die handschoenen zijn gewoon stom.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:1};
I.u[8543] = {n:"Ginger Ale",t:79,d:"Deze mix van gember, ziel en prik verfrist jonge makkers bij hun aankomst in Incarnam, terwijl voor ieder ander dit bubbelende, vage gele drankje amper genoeg is om voor een boer-wedstrijd te oefenen.",ep:1,g:4,l:1,wd:true,fm:true,w:1,c:"PL<16",u:true,ut:true,p:1};
I.u[8544] = {n:"Bow Kennel Certificaat voor: Pingoku",t:77,d:"Dit certificaat beschrijft de karakteristieken van de Pingoku die je in de Bow Kennel hebt gestopt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8545] = {n:"Incarnam Grot Sleutel",t:84,d:"Deze sleutel geeft je toegang tot de Incarnam Grot waar de verschrikkelijke Snoowolf leeft.",ep:1,g:19,l:1,wd:true,fm:true,w:1,p:10};
I.u[8546] = {n:"Snoowolf Huid",t:59,d:"Deze licht krullende huid zal een prachtig kleed maken voor op je bed. Iemand is al een tijdje op zoek geweest naar deze huid. Probeer uit te zoeken wie... en krijg zo veel Kamas als mogelijk ervoor!",ep:1,g:3,l:1,wd:true,fm:true,w:10,p:1};
I.u[8547] = {n:"Skiril Trinsfirmitinik",t:31,d:"Cirsid hizilnits irik nik gidik fir yik.",ep:1,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8548] = {n:"Wabbit Twansfowmatie",t:31,d:"De vewvloekte wottels zijn slecht voow de gezondheid.",ep:8,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
