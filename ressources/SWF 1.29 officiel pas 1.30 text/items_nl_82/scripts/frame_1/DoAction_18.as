I.u[8181] = {n:"Legendarische Kraklocape",t:17,d:"Deze dikke cape van ruwe steen maakt van jou een dikke stenen bruut.",ep:5,g:101,l:84,wd:true,fm:true,w:10,s:52,p:18200};
