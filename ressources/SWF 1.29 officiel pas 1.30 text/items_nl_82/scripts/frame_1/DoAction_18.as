I.u[8233] = {n:"Groene Piwi Cape",t:17,d:"Als je klein genoeg bent, bedekt deze Piwi veren cape misschien je achterkant. Een bescheiden bescherming die in elk geval de aandacht van je vette haar en je vreselijke wratten weg trekt.",ep:1,g:105,l:1,wd:true,fm:true,w:10,s:71,p:100};
