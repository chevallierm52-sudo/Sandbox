I.u[3647] = {n:"De Buik-Ramp",t:5,d:"Deze sikkelvormige dolk diende om verdwaalde reizigers te ontdoen van hun darminhoud. Hij dankt zijn naam aan de zuippartijen die zijn eigenaar zichzelf toestond in de herberg na zijn arme slachtoffers te hebben beroofd.",ep:13,g:31,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:17800};
I.u[3648] = {n:"Kapitein Chafer Dolkje",t:5,d:"Als Kapitein Chafer is verdwenen, dan hou jij zijn dolk in je hand. Als het heft in de handen is van de beroemde Kapitein Chafer, waar kan dan het lemmet is zijn...",ep:14,g:32,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>50",p:18000};
I.u[3649] = {n:"Niet Dolk",t:5,d:"De beroemde ambachtsman Dolquevito kreeg het idee een dergelijke dolk te maken. Hij was meer bedreven in het gokken en minder aanbevelenswaardige activiteiten en dit was zijn laatste echt interessante vinding. Je kan je een slechter eind van je loopbaan bedenken.",ep:9,g:33,l:95,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:23000};
I.u[3650] = {n:"Meeens Dolk",t:5,d:"Deze krachtige dolken zijn het resultaat van de samenwerking van de enige ambachtslieden die het eens waren over de toekomst van hun beroep. Ze waren maar met z\'n tweeën. Ze stierven allebei toen ze het niet eens konden worden over de naam voor deze dolken.",ep:3,g:34,l:120,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>100",p:37000};
I.u[3651] = {n:"Lucinatieha Dolk",t:5,d:"Een belachelijk kleine ambachtsman, genaamd Slaillehine, kreeg het briljante idee deze schitterende dolken te maken. Van de ene op de andere dag, stond iedereen in de rij voor zijn smidse, hetgeen hem op het idee bracht voor de naam van deze dolk.",ep:9,g:35,l:90,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CV>30&CA>100&CS>70",p:22000};
I.u[3652] = {n:"Marijn Aqua Staf",t:4,d:"Marijn Aqua wist om te gaan met mannen, haar staf wist de avances van de grootste Iop ridders af te slaan. Pas veel later ontdekte men dat ze een als meisje verklede jongen was.",ep:12,g:30,l:112,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,40,false,false],c:"CI>250&CA>100&CV>100",p:32000};
