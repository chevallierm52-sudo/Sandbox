I.u[8913] = {n:"Bollig Drankje",t:12,d:"Dit drankje is gemaakt van aftreksels van bollen die gedrenkt zijn in Klough brij. De meest brutale alchemisten gebruiken rijstebloem in plaats van Klough brij, wat je niet langer kunt vinden. Hoewel het onmogelijk lijkt, raak je wel aan de smaak gewend.",ep:22,g:23,l:110,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[8914] = {n:"Klusjesman Informatie Kaart",t:24,d:"Deze kaart bevat alle nodige informatie om de klusjesman te vinden die hierin beschreven staat.",ep:0,g:176,l:1,wd:false,fm:true,w:0,c:"PJ>65,50",p:1};
I.u[8915] = {n:"Lege Klusjesman Informatie Kaart",t:80,d:"Deze lege kaart zou gevuld moeten zijn met alle nodige informatie om een Klusjesman te identificeren.",ep:0,g:6,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[8916] = {n:"Tynril Amber",t:50,d:"Deze amber is anders dan de anderen. Als je je ogen dicht doet, ermee schudt en de manische tango van Kapitein Chafer danst voel je het wellicht vibreren en gloeien alsof een mysterieuze geest het heeft belichaamd. Om eerlijk te zijn die je er uit als een gek, maar dan een schijnende en vibrerende!",ep:22,g:1,l:100,wd:true,fm:true,w:10,p:1};
I.u[8917] = {n:"Grotto Hesque Sleutel",t:84,d:"Deze vreemde sleutel geeft je toegang tot de Grotto Hesque in één stuk.",ep:22,g:244,l:1,wd:true,fm:true,w:1,p:1};
I.u[8918] = {n:"Verbeterde Helm",t:16,d:"In theorie zou deze helm je pruik op je hoofd moeten houden als je besluit op een Scaraleaf te gaan rijden. Simpelweg onbetaalbaar!",ep:22,g:25,l:1,wd:true,fm:true,w:10,p:1};
I.u[8919] = {n:"Verbeterde Houten Vleugels",t:17,d:"Deze verbeterde houten vleugels zijn gevuld en lichter gemaakt dankzij veren en hoge-kwaliteit weefsel. Aangezien het geraamte nog steeds van hout is, zal het niet moeilijk zijn om neer te storten!",ep:22,g:22,l:30,wd:true,fm:true,w:10,p:2633};
I.u[8922] = {n:"Handtas van Kamas",t:24,d:"Deze handtas bevat een aanzienlijk bedrag Kama. Kies voorzichtig wie je wilt omkopen.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8923] = {n:"Zak met Aardappelen",t:24,d:"Een zak met aardappelen... Wat doe je met een zak aardappelen. Idioot.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8924] = {n:"Rahm Boog",t:2,d:"Lang geleden verdwaalde er een man genaamd Rahm in de jungle. Heb je van Viet Rahm gehoord?",ep:22,g:59,l:151,wd:true,fm:true,w:10,an:10,e:[10,3,2,7,30,50,false,true],c:"CA>200",p:46105};
I.u[8925] = {n:"Kleine Boog Slaap",t:2,d:"Deze vreemde boog was uitgesneden door een Sadidette tijdens een zeer productieve slaapwandeling. Alleen al door er naar te kijken voel je je slaperig – dat geldt voor zowel de boogschutter als het doel.",ep:22,g:60,l:185,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,3,8,30,50,false,true],c:"CA>300&CI>300",p:51125};
I.u[8926] = {n:"Dagg\'Adou",t:5,d:"Deze dolken zijn perfect om bananen aan te duwen of om koffie te malen. Sommigen gebruiken ze zelfs om appels en peren in stukken te slaan.",ep:22,g:65,l:175,wd:true,fm:true,w:10,an:13,tw:true,e:[7,3,1,1,30,30,false,false],c:"CA>250&CC>250&CS>150",p:49775};
I.u[8927] = {n:"Gaga Dolken",t:5,d:"Lang geleden leefde er een gekke Sram genaamd Gaga... deze jongen stal van de rijken en gaf het aan de armen.",ep:22,g:66,l:171,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>350&CA>200",p:49280};
I.u[8928] = {n:"Porkeez Dolken",t:5,d:"Porkeez is een betere drinker dan een krijger, en laat me je vertellen dat hij niet beter wordt naarmate de tijd verstrijkt. Ik zou niet bij hem gaan kijken als hij met zijn dolken bezig is.",ep:22,g:67,l:158,wd:true,fm:true,w:10,an:13,e:[15,2,1,1,30,50,false,false],c:"CA>300",p:47275};
I.u[8929] = {n:"Kriss Tobal",t:5,d:"Dit moet niet verward worden met de beroemde staf met een soortgelijke naam. Het lemmet op dit stuk gereedschap verspillen veel meer bloed.",ep:22,g:68,l:149,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CI>250&CC>250",p:45875};
I.u[8930] = {n:"Fuchsia",t:6,d:"Vele trotse avonturiers weigerden dit wapen vanwege zijn kleur. Velen van hetzelfde gingen dood door zijn lemmet.",ep:22,g:78,l:163,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,30,50,false,false],c:"CA>300&CI>300",p:48245};
I.u[8931] = {n:"Az\'tech",t:6,d:"Dit zwaard behoorde aan een oude machtsgeile Enutrof toe. Net als zijn ego is het van puur goud gemaakt.",ep:22,g:79,l:186,wd:true,fm:true,w:10,an:14,tw:true,e:[7,5,1,1,45,50,false,false],c:"CA>200&CC>200&CS>200",p:51275};
I.u[8932] = {n:"Kukri Kura",t:6,d:"Lachen! Even kaas zeggen! Geweldig, in tweeën gebroken!",ep:22,g:80,l:179,wd:true,fm:true,w:10,an:14,e:[7,4,1,1,40,50,false,false],c:"CS>300&CA>150",p:50330};
I.u[8933] = {n:"Zieke Bijl",t:19,d:"Ourag\'han was een oude Pandawa met een huid zo zacht dat hij bekend stond als Slippiderm. Zijn lichaamsgeur deed echter een andere naam rijzen. Hij noemde zijn vertrouwde bijl hetzelfde.",ep:22,g:49,l:162,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,50,50,false,false],c:"CW>250&CS>300",p:47900};
I.u[8934] = {n:"Michael Dougle Bijl",t:19,d:"Gedreven door agrarische razernij toen een kwaadaardige eekhoorn een rijstekorrel van hem had gestolen tijdens de zomervakantie op Pandala Eiland, gebruikte Brouce Boulgour deze bijl om elke bamboe stok plat te leggen waar de eekhoorn op sprong. De Pandawas in het dorp moesten hem de helft van hun voorraad bamboe wijn geven om zo te voorkomen dat hij het hele bamboe bos verwoestte. Echt iets voor oude Broucey.",ep:22,g:50,l:158,wd:true,fm:true,w:10,an:17,e:[7,5,1,1,50,50,false,false],c:"CC>150&CA>150&CI>150",p:47542};
I.u[8935] = {n:"Hickory Schop",t:8,d:"Zelfs als jonge Iopette droomde Mel van draken bezweren. Met een schep als zwaard en een rots als draak prees ze haar bedrevenheid aan in de achtertuin. De zuivere vermelding van een schep laat de arme rots stuiptrekken.",ep:22,g:48,l:176,wd:true,fm:true,w:10,an:16,e:[7,4,1,1,35,50,false,false],c:"CC>250&CI>250",p:49985};
I.u[8936] = {n:"Schop Shattkitou",t:8,d:"Dit is een wilde schop die zijn eigenaar probeert te bijten elke keer dat hij opgepakt wordt. Het maakt hoogst ongebruikelijke geluiden als hij blij is en kan alleen gepacificeerd worden met de sussende geluiden van klokken.",ep:22,g:49,l:137,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>150&CA>200",p:43945};
I.u[8937] = {n:"Schop Egant",t:8,d:"Een listige Enutrof werd een piraat nadat hij uitvond dat er meer schatten op een fris lichaam te vinden zijn dan in een verrot graf. Zijn bloedrode schop was zijn symbool en vervulde de zeilers van deze wateren met terreur.",ep:22,g:50,l:156,wd:true,fm:true,w:10,an:16,e:[7,5,1,1,20,50,false,false],c:"CS>250&CI>250",p:49455};
