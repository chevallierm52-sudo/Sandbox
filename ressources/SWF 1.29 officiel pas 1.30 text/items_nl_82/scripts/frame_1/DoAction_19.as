I.u[8958] = {n:"Ecaflip Poot",t:6,d:"Ecaflip hield zijn poot uit voor je, maar alles wat je hebt gevonden is een klauw... En die is niet eens zo scherp als je eerst dacht... Misschien was hij toch geen god...",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
