I.u[8964] = {n:"Ecaflip Poot",t:6,d:"“Fortuin stemt de dapperen gunstig”, fluisteren de volgelingen van Ecaflip. Nu je klaar bent kun je ons laten zien hoe je moet spelen. Dit zuivere, prestigieuze zwaard is erg zeldzaam.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
