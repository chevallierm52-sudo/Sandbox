I.u[8966] = {n:"Perfecte Ecaflip Poot",t:6,d:"Dit zwaard vertegenwoordigt het incarneren van het geluk van de god Ecaflip. In je hand houd je de zuiverste versie van de Ecaflip Poot, welke een getuigenis is van jouw ongelooflijke, enigszins onwaardige geluk.",ep:1,g:81,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
