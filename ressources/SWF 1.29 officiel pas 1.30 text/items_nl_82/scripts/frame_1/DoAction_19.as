I.u[8985] = {n:"Hippi-Ho voor Dragoone en Minifoux",t:116,d:"Met deze krachtige pil kun je de sterkte van je Treechster of Minimino permanent verhogen. Maar wees voorzichtig! Niet meer dan één dosis geven... Anders heb je een dode Treechster of Minimino in je handen... Nu we het daar over hebben, beide vleessoorten zijn erg, erg eetbaar. Je kunt ze het beste gemarineerd laten staan voor... oké, ik houd er wel over op...",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"PO=7519|PO=8155",u:true,p:1};
I.u[8986] = {n:"Hippi-Ho voor Gobtubby en Ghast",t:116,d:"Met deze krachtige pil kun je de sterkte van je Treechster of Minimino permanent verhogen. Maar wees voorzichtig! Niet meer dan één dosis geven... Anders heb je een dode Treechster of Minimino in je handen... Nu we het daar over hebben, beide vleessoorten zijn erg, erg eetbaar. Je kunt ze het beste gemarineerd laten staan voor... oké, ik houd er wel over op...",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"PO=8151|PO=7518",u:true,p:1};
I.u[8987] = {n:"Hippi-Ho voor El Scarador en Croum",t:116,d:"Met deze krachtige pil kun je de sterkte van je Treechster of Minimino permanent verhogen. Maar wees voorzichtig! Niet meer dan één dosis geven... Anders heb je een dode Treechster of Minimino in je handen... Nu we het daar over hebben, beide vleessoorten zijn erg, erg eetbaar. Je kunt ze het beste gemarineerd laten staan voor... oké, ik houd er wel over op...",ep:1,g:10,l:1,wd:true,fm:true,w:1,c:"PO=8154|PO=7520",u:true,p:1};
I.u[8988] = {n:"Hippi-Ho voor Treechster en Minimino",t:116,d:"Met deze krachtige pil kun je de sterkte van je Treechster of Minimino voorgoed verhogen. Maar wees voorzichtig! Geef het niet meer dan één dosis... Anders heb je een dode Treechster of Minimino in je handen... Nu je het zegt, beide vleessoorten zijn erg, erg eetbaar. Je kunt de marinade het beste laten trekken voor... oké, ik houd er over op...",ep:1,g:11,l:1,wd:true,fm:true,w:1,c:"PO=8153|PO=7522",u:true,p:1};
I.u[8989] = {n:"Lucht Pikoko Helm",t:16,d:"Met deze helm op kun je hopen dat je de lucht invliegt als je ronddraait op de snelheid van het geluid. Wat de landing betreft, dat moet je zelf uitzoeken.",ep:22,g:209,l:154,wd:true,fm:true,w:10,p:44350};
I.u[8990] = {n:"Prisma van Verovering",t:112,d:"Deze magische steen kan de donkerste hoek met een schitterende gloed vullen – verspil je kostbare urine niet om je territorium af te bakenen. Niet met mate te gebruiken als je een overwinnende geest hebt. Waarschuwing! Je kunt alleen een prisma plaatsen als je duidelijk je rang laat zien (met de speler vs speler modus geactiveerd), en als je in een omgeving zonder andere prisma\'s bent. De omgeving waar je je overwinningsprisma wilt plaatsen moet grenzen aan een tenminste 5-minuten oude geallieerde omgeving.",ep:4,g:1,l:1,wd:true,fm:true,w:10,c:"PL>9&PP>2",u:true,p:1};
I.u[8991] = {n:"Hoofd Band",t:9,d:"Deze koude, slijmerige ring stopt nooit met het zuigen op je vinger vanaf het moment dat je hem om doet. Als je voorbij zijn gladheid kunt kijken zijn zijn fantastisch krachten voor jou om te gebruiken.",ep:22,g:145,l:189,wd:true,fm:true,w:10,s:97,p:55000};
I.u[8992] = {n:"Vervloekte Zeis van de Blord Krijger",t:22,d:"Dit lemmet snijdt zowel tarwe als vijanden, maar het maakt je bondgenoten ook extreem jaloers. Dat is de bestemming van machtige mensen.",ep:22,g:3,l:200,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,100,50,false,false],p:58000};
I.u[8993] = {n:"Vervloekte Zwaard van de Blord Krijger",t:6,d:"In dit zwaard schuilt een immense kracht waarmee vele slachtoffers hoofdstukken in geschiedenisboeken zullen vullen. Aan de andere kant is er bewezen dat het hanteren van dit wapen dodelijk gevaarlijk is. Is er iemand die zijn boosaardige geweld kan temmen?",ep:20,g:83,l:200,wd:true,fm:true,w:10,an:14,tw:true,e:[10,5,1,1,100,2,false,false],p:58000};
I.u[8994] = {n:"Coralator weefsel",t:55,d:"Deze vochtige doek was lang onder water verborgen waar delen van koraal zijn oppervlakte draad voor draad bedekten. Het is jammer dat hij zo hard als steen is – anders was het een goede zakdoek geweest.",ep:22,g:728,l:150,wd:true,fm:true,w:1,p:100};
I.u[8995] = {n:"weefsel van Gourlo de Vreselijke",t:55,d:"In het verleden is deze weefsel als blarenverband gebruikt door Gourlo de Verschrikkelijke, nou is hij nog steeds gedrenkt in een duizelingwekkende stank. Het grappige is, als je één keer eraan snuift krijg je een ongelooflijke honger.",ep:22,g:729,l:150,wd:true,fm:true,w:1,p:100};
I.u[8996] = {n:"Geweldiger Bherb Huid",t:59,d:"Deze huid is zachter dan de achterkant van Kilibris. Het zal je geweldig goed doen.",ep:22,g:48,l:250,wd:true,fm:true,w:1,p:100};
I.u[8997] = {n:"Verscheurde Tynril Huid",t:59,d:"Deze huid bedekte wellicht een gevoelig deel van de Tynril. Arme kerel.",ep:22,g:629,l:400,wd:true,fm:true,w:1,p:100};
I.u[8998] = {n:"Kimbo\'s Kostbare Steen",t:50,d:"Laat me je een klein verhaal vertellen... enkele lange jaren lang zoog de Kimbo op deze geliefde steen om hem zachter te maken. Daarna schoof hij hem in zijn neusgat. Hmm, soms zoogt moeder natuur haar kleintjes.",ep:22,g:109,l:900,wd:true,fm:true,w:1,p:100};
I.u[9000] = {n:"",t:82,d:"",ep:0,g:10,l:1,wd:false,fm:true,w:10,c:"PP>5",p:1};
I.u[9001] = {n:"Sidimote Schild",t:82,d:"Dit schild herinnert je tegenstanders eraan dat je opgegroeid bent op de Sidimote heide. Dat alleen al zou genoeg moeten zijn om ze af te schrikken.",ep:18,g:8,l:1,wd:true,fm:true,w:10,c:"PP>4",p:15650};
I.u[9002] = {n:"Phtalmo",t:82,d:"Deze cape is bedekt met kijkers om je van die verwoestende multi-slechte ogen te geven. Onstopbaar.",ep:18,g:5,l:1,wd:true,fm:true,w:10,c:"PP>4",p:33000};
I.u[9003] = {n:"Inn Schild",t:82,d:"De Innhouder bij de Feubuk Brouwerij in Bonta was zo verveeld op een dag toen hij plotseling het idee kreeg om zijn uitsmijters uit te rusten met neon adverterende schilden.",ep:18,g:6,l:1,wd:true,fm:true,w:10,c:"PP>3",p:16200};
I.u[9004] = {n:"Akwadala Schild",t:82,d:"Om kwade of sterke slagen te voorkomen zou dit schild van Akwadala genoeg moeten zijn.",ep:14,g:31,l:1,wd:true,fm:true,w:2,c:"PP>2",s:34,p:5350};
I.u[9005] = {n:"Fan Schild",t:82,d:"Als je bondgenoten buiten adem raken, of als je de lucht wilt zuiveren na een onverwachte uitbarsting van paniek, kan dit schild je leven redden. Het enige wat je hoeft te doen is het heftig in alle richtingen schudden, net zoals je dat doet met een hongerige baby.",ep:18,g:11,l:1,wd:true,fm:true,w:10,c:"PP>8",p:54450};
I.u[9006] = {n:"Sadida Schild",t:82,d:"Van origine werd dit schild gebruikt als bankje door de Sadidas, als ze moesten rusten. Als je je voeten erin stopt zal hij je tegen een grote verscheidenheid van aanvallen. Niks zal je beschermen tegen het wrede lachen van jouw tegenstanders.",ep:18,g:12,l:1,wd:true,fm:true,w:10,c:"PP>6",p:18700};
I.u[9007] = {n:"Schild met Instructies",t:82,d:"Dit verrassende beest bedekt je schild in Lederen Instructies van de Lancer Chafer, welke zijn gekookt, schoon gemaakt en uitgerekt zodat ze de arm perfect omklemmen zoals ze dat bij de volle, royale krommingen van Lancer Chafer\'s... Volgens mij is dat wel genoeg nou.",ep:18,g:13,l:1,wd:true,fm:true,w:10,c:"PP>5",p:26700};
I.u[9008] = {n:"Asse Schild",t:82,d:"Dit prachtige schild bevat een paar druppels van de Asse Zee. Niet alleen brengt het geluk, maar je kunt hem ook als veldfles gebruiken.",ep:18,g:16,l:1,wd:true,fm:true,w:10,c:"PP>7",p:32450};
I.u[9009] = {n:"Boomchnid Schild",t:82,d:"Verborgen achter dit schild zouden naieve avonturiers je kunnen verwarren met een Treechnid en gillend weg kunnen rennen. De meesten zullen enthousiast aanvallen, denkend dat ze wat amber uit je kunnen halen.",ep:18,g:19,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5950};
I.u[9010] = {n:"Pandawa Schild",t:82,d:"Perfect als je bij de Pandala wilt horen, of ergens anders wilt afsteken! Het grootste voordeel van dit schild is dat het volkomen bedekt is door hypoallergene Pandawa haren, dus je hoeft je ondergoed en uitrusting niet in aparte koffers in te pakken terwijl je op vakantie gaat.",ep:18,g:22,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5600};
I.u[9011] = {n:"Vuur Wijzerplaat",t:82,d:"Dit speciale schild zal je beschermen tegen het Vuur element en zal je tegenstanders genoeg tijd geven.. Genoeg tijd om hun laatste wensen te bedenken welteverstaan!",ep:18,g:24,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9012] = {n:"Lucht Wijzerplaat",t:82,d:"Dit speciale schild zal je beschermen tegen het Lucht element en zal je tegenstanders genoeg tijd geven.. Genoeg tijd om hun laatste wensen te bedenken welteverstaan!",ep:18,g:26,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9013] = {n:"Aarde Kiesschijf",t:82,d:"Dit speciale schild zal je beschermen tegen het Aarde element en zal je tegenstanders genoeg tijd geven.. Genoeg tijd om hun laatste wensen te bedenken welteverstaan!",ep:18,g:27,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9014] = {n:"Water Wijzerplaat",t:82,d:"Dit speciale schild zal je beschermen tegen het Water element en zal je tegenstanders genoeg tijd geven.. Genoeg tijd om hun laatste wensen te bedenken welteverstaan!",ep:18,g:25,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9015] = {n:"Lumberjack Schild",t:82,d:"Dit schild beschermde Lumberjacks tegen het vallen uit bomen. Zijn functie veranderde snel en nu is het vaker gebruikt om krijgers te beschermen tegen vijanden die op ze willen landen zonder te waarschuwen!",ep:18,g:4,l:1,wd:true,fm:true,w:10,c:"PP>1",p:1200};
I.u[9016] = {n:"Rijdier Stinkkend Schild",t:82,d:"Dit groenige en stinkende schild blijft een eerste keus bescherming als je met de beesten van de groenige en stinkende Mount Stinkky moet vechten.",ep:18,g:1,l:1,wd:true,fm:true,w:20,c:"PP>2",p:5400};
I.u[9017] = {n:"Imp Schild",t:82,d:"Als het je liefste droom is om een echte imp te worden, is dit het schild dat je nodig hebt. Doorgegeven van generatie op generatie, het laat je alle jonge Astrubiaanse avonturiers die je wil beroven zonder zelf gewond te raken.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"PP>6",p:30700};
I.u[9018] = {n:"Hart kwartier",t:82,d:"Een befaamde avonturier spendeerde zijn hele leven aan het zoeken van de vier delen van dit schild. Sommigen zeggen dat als dit schild compleet is, het precies het tegenovergestelde effect van het breken van een spiegel heeft.",ep:18,g:7,l:1,wd:true,fm:true,w:10,c:"PP>3",p:13000};
I.u[9019] = {n:"Bawbaaws Schild",t:82,d:"Niet alle Wabbits zijn aardige kleine dieren. Eigenlijk zijn alle Wabbits laaghartige dieren. Sommigen krijgen er een kick van om hun wowtels in stukken te slaan met dit enorme schild en een bad te nemen in het sap ervan.",ep:18,g:2,l:1,wd:true,fm:true,w:15,c:"PP>3",p:10500};
I.u[9020] = {n:"Derma Tho",t:82,d:"Dit schild van huid zal zo perfect passen als een handschoen. Vergeet zijn wratten en steenpuisten niet te behandelen van tijd tot tijd om te voorkomen dat ze versleten raakt.",ep:18,g:3,l:1,wd:true,fm:true,w:10,c:"PP>2",p:2200};
I.u[9021] = {n:"Amakna Kapitein Schild",t:82,d:"Een jonge avonturier droomde eens over zich aansluiten bij de Bonta militie om de onderdrukten te beschermen. Toen hij moreel gezien niet geschikt bleek, nam een Amakna Alchemist contact met hem op die zijn goedheid misbruikte, zodat hij als cavia kon dienen voor zijn drankjes. Je zult blij zijn dat dit een verhaal is die .. nou ja, in het midden is het vrolijk... eindigt. Hij werd zo sterk dat hij voor altijd bekend is geworden als Kapitein Amakna en hij had een beroemd onverwoestbaar schild die voor hem alleen was gesmeden. Het einde... nou ja, dat wil je niet weten.",ep:18,g:14,l:1,wd:true,fm:true,w:30,c:"PP>9",p:63200};
I.u[9022] = {n:"Kloome",t:82,d:"Dit enorme schild redde de beroemde avonturier Kloome van een vreselijke dood: verpletterd worden onder het gewicht van een Crackler die verliefd op hem was. De legende vertelt niet of hij de bijkomende effecten van zijn volgende romance met het stenen beest overleefde.",ep:18,g:15,l:1,wd:true,fm:true,w:10,c:"PP>4",p:22100};
I.u[9023] = {n:"Vliegend Schild",t:82,d:"Hoewel het erg vreemd mag klinken zeggen sommigen dat dit schild van hout en haar de lichtste avonturiers laat vliegen voor een kort moment... een laatste poging om hun vijanden te shockeren voor ze plat op hun gezicht gaan.",ep:18,g:17,l:1,wd:true,fm:true,w:1,c:"PP>0",p:1200};
I.u[9024] = {n:"Chouque Schil",t:82,d:"De Chouque gebruikte dit schil om zichzelf tegen vriendschappelijke kanonballen die zijn vrienden regelmatig naar hem opgooiden te beschermen. Sommige gekke verhalen vertellen dat enkele van die ballen leefden.",ep:18,g:18,l:1,wd:true,fm:true,w:10,c:"PP>6",p:36850};
I.u[9025] = {n:"Gobball Schild",t:82,d:"Hoewel het alles behalve nutteloos is, zal de stank ervan alleen al je beroemd maken, overal. Dit schild vergezelt menig jonge avonturier op hun eerste opdrachten – misschien is dat de reden waarom zo weinig het tot de dertig redden...",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PP>0",p:400};
I.u[9026] = {n:"Bowisse\'s Schild",t:82,d:"Dit schild is een eerbetoon aan Bowisse\'s Mantel welke zelf een eerbetoon aan een beroemd aandenken gecomposeerd uit die driehoekige vormen was. God, al deze geschiedenis maakt me slaperig.",ep:18,g:21,l:1,wd:true,fm:true,w:10,c:"PP>3",p:10150};
I.u[9027] = {n:"Crackler Schild",t:82,d:"Dit stenen schild is eigenlijk van het hoofd van een Crackler gemaakt, gekraakt door de voet van een Minotoror. Een perfecte combinatie van een groot hoofd en stinkende voeten.",ep:5,g:23,l:1,wd:true,fm:true,w:10,c:"PP>2",p:6300};
I.u[9028] = {n:"Terrdala Schild",t:82,d:"Om kwaadaardige of forse slagen te voorkomen zou dit schild van Terrdala genoeg moeten zijn.",ep:18,g:32,l:1,wd:true,fm:true,w:10,c:"PP>3",s:36,p:14100};
I.u[9029] = {n:"Feudala Schild",t:82,d:"Om kwaadaardige of forse slagen te voorkomen zou dit schild van Feudala genoeg moeten zijn.",ep:18,g:33,l:1,wd:true,fm:true,w:15,c:"PP>5",s:37,p:27100};
I.u[9030] = {n:"Aerdala Schild",t:82,d:"Om kwaadaardige of forse slagen te voorkomen zou dit schild van Aerdala genoeg moeten zijn.",ep:18,g:30,l:1,wd:true,fm:true,w:10,c:"PP>4",s:35,p:11600};
I.u[9031] = {n:"Gore Meester\'s Ring (Alleen GM)",t:9,d:"In deze tijd was de Gore Meester erg sterk en had alles wat hij nodig had: geld, vrouwen en nog meer. Hij verdiende het niet allemaal omdat hij zijn kracht van deze ring had. Tot de dag dat hij roekeloos de straat overstak. En BOEM! Niet meer Gore Meester. Sindsdien geven gewetenloze personen het door aan andere gewetenloze mensen.",ep:0,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[9035] = {n:"Gilde Paddock Drankje",t:12,d:"Dit drankje laat je terug gaan naar je gilde paddock.",ep:5,g:25,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[9036] = {n:"Dorps Drankje: Zoth",t:12,d:"Dit drankje teleporteert je naar Zoth Dorp, als je de dingen in je bezit hebt.",ep:0,g:24,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9037] = {n:"Ontdekkings Drankje",t:14,d:"Dit drankje laat je alle onzichtbare karakters om je heen ontsluieren.",ep:0,g:0,l:1,wd:true,fm:true,w:1,p:10};
I.u[9038] = {n:"Klein Aanval Drankje",t:14,d:"Dit drankje maakt je zo kwaad dat je automatisch vijanden aanvalt die te dicht bij komen.",ep:0,g:32,l:1,wd:true,fm:true,w:1,c:"Pg=21",u:true,p:10};
I.u[9039] = {n:"Prisma Oproep Drankje",t:12,d:"Dit drankje teleporteert je naar de dichtstbijzijnde omgevings prisma.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9040] = {n:"Gemiddeld Aanval Drankje",t:14,d:"Dit drankje maakt je zo kwaad dat je automatisch vijanden aanvalt die te dichtbij komen.",ep:0,g:33,l:1,wd:true,fm:true,w:1,c:"Pg>21,1",u:true,p:10};
I.u[9041] = {n:"Groot Aanval Drankje",t:14,d:"Dit drankje maakt je zo kwaad dat je automatisch vijanden aanvalt die te dichtbij komen.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Pg>21,2",u:true,p:10};
I.u[9042] = {n:"Krachtig Aanval Drankje",t:14,d:"Dit drankje maakt je zo kwaad dat je automatisch vijanden aanvalt die te dichtbij komen.",ep:0,g:36,l:1,wd:false,fm:true,w:1,c:"Pg>21,3",u:true,p:10};
