I.u[8961] = {n:"Ecaflip Poot",t:6,d:"Bijgelovigen denken dat een simpel been van een konijn rond de nek je geluk en fortuin kan brengen. Dankzij dit legendarische zwaard zul je deze theorie uit kunnen proberen. Zijn lemmet is extreem scherp... Doet je dat niet herinneren aan een zwaard dat je ooit kende?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8962] = {n:"Ecaflip Poot",t:6,d:"Bijgelovigen geloven dat een simpel konijnenbeen om je nek geluk en fortuin kan brengen. Dankzij dit legendarische zwaard zul je deze theorie uit kunnen proberen. Zijn lemmet is extreem scherp... geeft je dat niet herinneringen aan een zwaard die je ooit kende?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
