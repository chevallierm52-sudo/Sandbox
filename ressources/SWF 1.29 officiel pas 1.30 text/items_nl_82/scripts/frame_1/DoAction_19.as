I.u[8557] = {n:"Batofu Veer",t:53,d:"Deze veer, geplukt van de oksel van Batofu, ruikt als een voorouderlijk gemarineerde Doobitchoo.",ep:3,g:120,l:20,wd:true,fm:true,w:1,p:10};
I.u[8558] = {n:"Konijnen Hoed",t:16,d:"Als je van plan bent om met de Wabbits te communiceren, heb je deze hoed wellicht nodig. Als je er goed wilt uitzien, doe hem dan bij degene naast je op.",ep:1,g:170,l:6,wd:true,fm:true,w:10,p:12000};
I.u[8559] = {n:"De HmmMMmmMmmm",t:16,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:2,g:171,l:42,wd:true,fm:true,w:1,p:420};
I.u[8561] = {n:"Pandawa Jong",t:18,d:"Dit schattige Pandawa Jong zal blij zijn om met jou de wereld rond te reizen en de mysteries te ontdekken met zijn grote, ronde ogen. Dit getemde huisdier eet rijst, maar kan ook gevoed worden met hazelnoten.",ep:3,g:42,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8563] = {n:"Litol Goblait",t:32,d:"Litol moet zijn toekomstige magie leraar leren kennen.",ep:1,g:18,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[8564] = {n:"Bow Kennel Certificaat voor: Pandawa Jong",t:77,d:"Dit certificaat beschrijft de karaktereigenschappen van het Pandawa Jong die je in de Bow Kennel hebt gezet.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8565] = {n:"Pandawa Jong Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:3,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[8566] = {n:"Pingoku Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8567] = {n:"Pandawa Jong Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8568] = {n:"Pandawa Jong Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals eten en een paar genezende Eniripsa poeders.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8569] = {n:"Doro L. Blak",t:16,d:"Deze pet behoorde van oorsprong toe aan een kleine Xelorette die eruit getrapt was voor het ontwrichten van de tijdspassage. De legende gaat dat ze ooit verscheidene dagen van de inwoners van Amakna heeft gestolen. Ze moest aardig wat zoetigheden uitdelen om het goed te maken.",ep:22,g:172,l:129,wd:true,fm:true,w:10,p:42512};
I.u[8570] = {n:"Bontaarse Rat Haar",t:54,d:"Deze haar behoorde toe aan de Bonta rioolratten. Inderdaad, ze waren de enigen die haarbossen hadden die bij de kleur van de stadswallen pasten.",ep:2,g:672,l:40,wd:true,fm:true,w:1,p:10};
I.u[8571] = {n:"Brakmaarse Rat Haar",t:54,d:"Deze haar behoorde toe aan de Brakmaarse rioolratten. Inderdaad, ze waren de enigen die haarbossen hadden die perfect bij de kleur van de stadswallen pasten.",ep:2,g:673,l:40,wd:true,fm:true,w:1,p:10};
I.u[8572] = {n:"Vergeetachtigheids Drankje: \"Rijdier Temmen\"",t:43,d:"Dit drankje laat je één leven van de spreuk: “Rijdier Temmen” vergeten.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8573] = {n:"Vergeetachtigheids Drankje: \"Trouweloosheids Boomerang\"",t:43,d:"Dit drankje laat je een leven van de spreuk: “Trouweloosheids Boomerang” vergeten.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8575] = {n:"Eerste Bloed Staf",t:4,d:"Een beroemde Feca krijger die in de jungle van Pandala woonde zei schijnbaar vaak: “Om de oorlog te winnen, moet je de oorlog worden”.",ep:1,g:71,l:200,wd:false,fm:true,w:20,an:12,tw:true,e:[7,3,1,2,42,42,false,true],c:"PN~xxramboplxx",p:100000};
I.u[8576] = {n:"Yse Veywbad\'s Aanbevelings Rol",t:24,d:"Yse Vewybad heeft je deze rol gegeven om je te bedanken voor je hulp.",ep:2,g:26,l:20,wd:false,fm:true,w:0,p:1};
I.u[8588] = {n:"Schurk Embleem",t:24,d:"Dit embleem, door een Schurk gegeven, is misschien de sleutel om hun hol binnen te komen.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[8590] = {n:"Contract tussen Vil Smisse en Yse Vewybad",t:24,d:"Dit contract bewijst Yse Vewybad\'s verraad. Je hoeft het enkel nog naar de juiste persoon te brengen.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[8593] = {n:"Wa Wabbit Transformatie Drankje",t:27,d:"Uba Tesse heeft je dit drankje gegeven. Je verandert in een Wabbit hierdoor waarmee je door kunt gaan als Allisteria\'s kandidaat.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8594] = {n:"Wa Wabbit Twansfowmatie Drankje",t:27,d:"Uba Tesse heeft je dit drankje gegeven. Je verandert in een Wabbit hierdoor waarmee je door kunt gaan als Allisteria\'s kandidaat.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8595] = {n:"Zwaarlijvige Tofu Ei",t:24,d:"Dit ei bevat een zwaarlijvige Tofu... een beest die mogelijk de Pwins van Wa zal verslaan in de toekomst.",ep:1,g:122,l:1,wd:true,fm:false,w:0,p:1};
I.u[8596] = {n:"Crimson Klauw",t:6,d:"Dit scherpe zwaard kreeg zo\'n elegante crimson kleur door duizenden Bworks leeg te halen. Daarvoor was het gewoon paarsig.",ep:22,g:72,l:145,wd:true,fm:true,w:15,an:14,tw:true,e:[8,6,1,1,45,100,false,false],c:"CS>350&CV>400",p:52000};
I.u[8597] = {n:"Forceren-te-eten drankje",t:24,d:"Dit drankje laat Vil Smisse zijn Tofu met overgewicht die jij voor hem hebt meegebracht forceren te eten",ep:3,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[8598] = {n:"Emments Dolken",t:5,d:"Deze lemmets hebben overal gaten zodat ze een mooi fluitend geluid maken als je er snel mee handelt. De gaten zijn ook erg nuttig als je je vijanden neerhaalt.",ep:22,g:61,l:67,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CA>100",p:10654};
I.u[8599] = {n:"Klauwen",t:5,d:"Deze dolken waren gesmeed voor een manicure-verslaafde Ecaflipette. Ze hield niet van die zware zwaarden die niet goed bij haar perfect gelakte klauwen pasten.",ep:22,g:62,l:69,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,30,false,true],c:"CA>100&CS>100",p:11254};
I.u[8600] = {n:"Te lui om naar boven te gaan",t:30,d:"Het is niet zo gek dat je uitgeput bent,  je schreeuwt zo hard steeds. Wacht eens 6 minuten ofzo... Misschien ben je dan niet zo lui.",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8603] = {n:"Wabbit Prins\' Dienaar\'s Verhuurbedrijf",t:24,d:"Met dit verhuurbedrijf zal de Dienaar van de Wabbit Prins erg trendy zijn.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8604] = {n:"Stengel Zwaard",t:6,d:"Dit glimmende zwaard is perfect om bloemen mee te trimmen, zelfs als ze zichzelf beschermen. Het kan zelfs bomen snijden.",ep:22,g:73,l:100,wd:true,fm:true,w:10,an:14,e:[15,8,1,1,40,50,false,false],c:"CS>250&CI<1",p:25654};
I.u[8605] = {n:"Rubberen Zwaard",t:6,d:"Dit lemmet is ingesmeerd om makkelijker in zijn insteking te glijden. Echter, hij kan na gebruik niet schoon gemaakt worden en moet weg worden gegooid, vooral wanneer hij met bloed bedekt is. Onthoud dat zijn voornaamste gebruik het beschermen van jou is.",ep:22,g:74,l:73,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,40,50,false,true],c:"CS>80&CI>80&CA>80",p:14000};
I.u[8606] = {n:"Trouw Jurk",t:24,d:"De trouwjurk van de bruid is voorzichtig ingepakt in dit prachtige pakket. Het moet enkel nog naar de steward San Lavalss gebracht worden.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8607] = {n:"Gevulde Staf",t:4,d:"Het is een grote staf met nagels erin geslagen. Hoop niet op iets anders in deze staf, hij is simpel en je vijanden verliest zijn tanden er makkelijk mee.",ep:22,g:72,l:107,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,50,false,true],c:"CA>150&CI>150",p:29856};
I.u[8608] = {n:"Afgedankte Staf",t:4,d:"Het gerucht gaat dat een Sadida genaamd Fraye deze staf gebruikte om zijn vrouw en zoon te beschermen tegen een woedende kudde Gobballs. Erg jammer dat hij dacht dat zijn familie bij de monsters hoorde tijdens het gevecht.",ep:22,g:73,l:85,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,35,40,false,true],c:"CW>150&CV>200",p:20000};
I.u[8609] = {n:"Bushi\'Bow",t:2,d:"Deze boog is licht, delicaat, elegant en ruikt naar kersenboom bloemen. Maar kijk uit, als je hem goed gebruikt kan hij ook dodelijk zijn.",ep:22,g:56,l:81,wd:true,fm:true,w:15,an:10,tw:true,e:[5,4,3,7,30,50,false,true],c:"CA>200",p:16900};
I.u[8610] = {n:"Boog Liwood",t:2,d:"Als je deze boog hoog houdt en vreugdevol “Pampulilu” zegt, zie je er absoluut belachelijk uit.",ep:22,g:57,l:79,wd:true,fm:true,w:10,an:10,tw:true,e:[7,5,4,7,30,50,false,true],c:"CI>150&CC>150",p:15320};
I.u[8611] = {n:"Wand Anders?",t:3,d:"Deze wand behoort toe aan een beroemde Grinegau die geweldige koffie maakt, maar die geen vrouwen kan krijgen.",ep:22,g:61,l:72,wd:true,fm:true,w:15,an:11,e:[5,3,2,4,15,50,false,true],c:"CI>100&CC>100",p:16500};
I.u[8612] = {n:"De Bidjiz",t:3,d:"Met de Bidjiz blijf je waarschijnlijk in leven omdat je tegenstanders beginnen te dansen als ze de discobal aan het einde van deze wand zien.",ep:22,g:62,l:79,wd:true,fm:true,w:10,an:11,tw:true,e:[10,4,2,5,40,50,false,true],c:"CA>150",p:18000};
I.u[8613] = {n:"Schop Minster",t:8,d:"Deze schop, die gemaakt is als een smidmagisch meesterwerk, graaft erg slecht, behalve als het om het hoofd van je tegenstander gaat.",ep:22,g:46,l:70,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,30,50,false,false],c:"CC>100",p:13540};
I.u[8614] = {n:"RIP Schop",t:8,d:"Deze schop is een geweldige uitvinding. Hij kan graven delven, en bovenop gezet worden als kruis, vooropgesteld dat er één mede-avonturier per keer dood gaat... Anders moet je de andere graven delven met je handen.",ep:22,g:47,l:66,wd:true,fm:true,w:1,an:16,tw:true,e:[5,4,1,1,20,30,false,false],c:"CI>100&CC>50",p:1};
I.u[8615] = {n:"Rode Hamer",t:7,d:"Deze hamer slaat met gemak een schedel tot poeder... wat precies de reden is dat hij een tomatenrode kleur heeft.",ep:22,g:61,l:83,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100&CV>100",p:17560};
I.u[8616] = {n:"Hamer Zery",t:7,d:"Deze hamer was gemaakt toen Koning Stefan heerste over miljoenen mensen en ze terroriseerde.",ep:22,g:62,l:178,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,40,50,false,true],c:"CI>350&CW>180",p:10000};
I.u[8617] = {n:"Spinnende Bijl",t:19,d:"Je huisdier, je passie.",ep:22,g:45,l:62,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,20,30,false,false],c:"CV>150",p:10200};
I.u[8618] = {n:"Eerie Bijl",t:19,d:"Deze vreemde bijl is gemaakt om Bworks gemakkelijk te onthoofden. Het gemak waarmee hij ook Astrubs inwoners kan onthoofden geeft duidelijk te kennen dat er een verbinding is tussen deze twee volken. Maar niemand heeft nog ontdekt wat dat precies is.",ep:22,g:46,l:80,wd:true,fm:true,w:10,an:17,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>120&CA>60",p:16700};
I.u[8619] = {n:"Hoed Ariutokinabot",t:16,d:"Dankzij deze krijger hoed slaan de Iops echt een figuur. Het enige probleem is dat het iets van hun gezichtsveld belemmert en het voorkomt dat ze de woorden van hun tegenstanders horen. Deze hoed is gemaakt voor iedereen die liever slaat voor hij nadenkt.",ep:22,g:175,l:40,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8620] = {n:"",t:28,d:"",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8621] = {n:"Vervloekte Wottel",t:94,d:"Deze smakelijke wottel lijkt gewoon, maaw hij is betovewd. Kan jij de vewleiding weewstaan om je tanden erin te zetten?",ep:8,g:6,l:21,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[8624] = {n:"Magische Blauwe Ballon",t:94,d:"In tegenstelling tot de vervalsingen die in op de Trool kermis vindt, kan deze ballon zich afdoen met gratie en gemak. Een pracht om aanschouwen, hij is handgemaakt met Aardbei Gelei ooglid, volgens de tradities van de grote magus Betsy Krokerr.",ep:1,g:7,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8625] = {n:"Magische Groene Ballon",t:94,d:"Deze groene ballon is een delicatesse die gemaakt is door een groene larva te dwingen om een Luidegit paddenstoel op te eten. De ogen van de larva rolden er tijdens het eten uit en zijn verkocht aan Bworks als voorafjes. Deze ballon inspireerde Betsy Krokerr in sommige van haar meest bekende recepten.",ep:1,g:8,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8626] = {n:"Nisitik Miditik",t:94,d:"Dizik smikilijkik hizilnik lijkik zik tik zinik giwinik, mir hij vilik dik bitiviriknik mik z\'nik hilik snik. Zik jij wirstind kinninik bidinik inik dik virlidiknik ik ik likkik ip tik knibbilinik?",ep:6,g:9,l:21,wd:false,fm:true,w:1,u:true,ut:true,p:100};
I.u[8627] = {n:"Sarr Ys\'s Fluit",t:3,d:"Collega en vriend van de bekende Guy-Guy (nabije ouder van de Zachte Eik), Sarr Ys is een minstreel wiens betoverende melodieën gegraveerd zijn in Amakna\'s collectieve bewusteloosheid. Helaas heeft deze briljante arties een tragisch Quaquack ongeluk gehad na een bepaald vochtige nieuwjaarsavond viering.",ep:1,g:63,l:1,wd:false,fm:true,w:10,an:11,e:[10,6,2,3,100,30,false,true],p:1};
I.u[8628] = {n:"Ukando Hoed",t:16,d:"Dit hoofddeksel geeft zelfvertrouwen roekeloosheid aan iedereen die hem draagt. Dankzij het hoofddeksel ga je altijd door met denken dat je heldendaden kunt uithalen. Vergeet hem niet af te zetten zo af en toe want anders kom je in onvermijdelijke sitauaties terecht!",ep:22,g:185,l:40,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8629] = {n:"Hoed Tsokey",t:16,d:"Elke keer dat je tegenstander dit hoofddeksel ziet, wordt hij zo stil als het graf. Niemand durft te vragen waar het op moet lijken. Maar dat is goed, Srams zijn niet zo lichtgeraakt.",ep:22,g:179,l:40,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8630] = {n:"Hoed Lelie",t:16,d:"Deze hoed lijkt op de Sulik en de Paperb\' Hoed. Maar aangezien hij erg comfortabel is en Xelors hem nooit afzetten – zelfs niet in hun slaap, wordt hij meestal Hoed Lelie genoemd. Het verspreidt een fijne, plezierige waterlelie geur wat helpt bij het slapen. Echter, het prikkelt ook snurken zo ondraagbaar als het lied van de Pad tijdens het parings seizoen.",ep:22,g:177,l:40,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8631] = {n:"Hoed Wisholdoo",t:16,d:"Dankzij deze hoed weten Eniripsas altijd om te gaan met spoedgevallen. Inderdaad, alle eerste hulp tips zijn discreet op de voering geschreven. Ze zien er zo uit alsof ze net geslaagd zijn hoewel niemand normaliter zo\'n belachelijke hoed zou dragen voor een school ceremonie!",ep:22,g:184,l:40,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8632] = {n:"Pet Ricott",t:16,d:"Gezien de naam van de cape zouden we kunnen denken dat hij oranje is. Niet dus! Bovendien is deze mode accessoire meer een masker dan een hoed. Waarom hebben de makers hem dan zo genoemd? Om nieuwsgierige mensen te laten praten!",ep:22,g:178,l:40,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8633] = {n:"Pet Rayer",t:16,d:"De gescherpte punten die uit deze pet komen laten je niet alleen je vijanden pijn doen maar verhogen ook je kans om geraakt te worden door blikseminslag tijdens een storm. Inderdaad, Sacriers zijn een soort die ervan houden om anderen net zoveel pijn te doen als hunzelf. De heerlijke geur van gegrild vlees: ideaal om je dag te beginnen!",ep:22,g:180,l:40,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8634] = {n:"Coole Kap",t:16,d:"Dankzij dit hoofddeksel lijk je echt op een hoornig beest. Mensen zullen zich omdraaien om het grote paar hoorns te bewonderen op je hoofd. Deze voorraadkamer-achtige hoed kan ook je voedsel vers houden net zoals hooi voor Gobballs en brood voor Tofu\'s.",ep:22,g:181,l:40,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8635] = {n:"Helm Hicc",t:16,d:"Deze helm laat de drager beloftes maken die hij meteen vergeet. Komt het omdat hij drukt uitoefent op het deel van je hersens welke je geheugen of je taal reguliert? Niemand weet het echt. Wat er toe doet is enkel rekening te houden met minder extravagante woorden.",ep:22,g:176,l:40,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8636] = {n:"Robin Hoodie Hoofddeksel",t:16,d:"Robbie Hood was een beroemde Cra die in de bossen leefde. Dit verklaart waarom de groen gekleurde pet in het landschap versmolten is. Hij wilde altijd het recht in eigen handen nemen en spendeerde al zijn tijd in het stelen van geld van de armen voor een goed doel: zichzelf!",ep:22,g:186,l:40,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8637] = {n:"Geluks Hoed",t:16,d:"Met deze hoed op verhoogt Feca zijn kans net als die van zijn bondgenoten. Als je groep wordt begeleidt door een Feca met een Geluks Hoed op, ben je er zeker van om aan te komen bijna zonder een schram. En hij ruikt zo verschrikkelijk dat hij perfect is om jezelf ook nog te beschermen.",ep:22,g:182,l:40,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8638] = {n:"Sthood",t:16,d:"Deze hoed kan gebruikt worden om slecht weer af te weren, maar hij is ook geweldig voor koken. Het laat je de sterkte van een vlam regelen met een tip van het hoofd. Nou weet je waarom Enutrofs zulke gespierde nekken hebben.",ep:22,g:183,l:40,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8639] = {n:"Mantel Orporal",t:17,d:"De drijvende cape is essentieel om je een krijgers aura te geven, speciaal voor wanneer je je van je vijanden wegdraait. Sommigen denken dat het versterkt is door een metalen blad die bekwaam is om de geniepigste aanvallen te voorkomen.",ep:22,g:131,l:80,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8640] = {n:"Cash\'n Cape",t:17,d:"Gesneden uit een zacht en sterk weefsel. Deze cape geeft de Ecaflips het idee dat ze altijd de beste zijn, wat er ook gebeurt. Als ze winnen, willen ze dit kledingstuk dragen en hun beloning claimen: “En nou, geef me het geld!”",ep:22,g:133,l:80,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8641] = {n:"F-Ha(r)t",t:17,d:"Deze cape is zo licht en dus dat het kleinste beetje wind (van alle soorten wind) hem van je af blaast... Niet echt discreet na een maaltijd met groenten en gegiste drankjes.",ep:22,g:140,l:80,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8642] = {n:"Cap Cape",t:17,d:"De donkere kleur van deze cape past goed bij elk kledingstuk, van elke kleur. Aangezien het een wijde cae is, kan hij ook je hoofd en oren beschermen.",ep:22,g:141,l:80,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8643] = {n:"Cape Sulitis",t:17,d:"De Cape Sulitis zou zacht om de schouders van de drager moeten worden geslagen om te voorkomen dat het achterste tendinitis krijgt en zijn gewrichten stijf worden. De genezende werking van dit kledingstuk worden benijdt door de Pandawas die een boel tijd steken in het dragen van vijanden en bondgenoten. Ze zouden maar wat graag zo\'n kledingstuk hebben!",ep:22,g:134,l:80,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8644] = {n:"Cape o\' Tbelly",t:17,d:"Dit item wordt gebruikt om de Sadidas gewichtsproblemen te verbergen. Omdat ze meestal slapen in plaats van een sport beoefenen worden de karakters van deze soort aardig zwaarlijvig. Sadidettes hebben anti-uithongerings middelen hebben die ze vleiend in de ogen van mannen plaatsen, Sadidas gebruiken deze cape om die van hun te verbergen.",ep:22,g:139,l:80,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8645] = {n:"Cape Ytal",t:17,d:"Dit kledingstuk is een belangrijk deel van de stijl van de Sacriers. Ze gebruiken het om hun wonden te verbinden, om bloed af te vegen, om hun voeten te verwarmen tijden de koude seizoenen. We kunnen het niet genoeg zeggen – deze soort is bang van bevroren grond!",ep:22,g:138,l:80,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8646] = {n:"Cape Anama",t:17,d:"Deze zachte cape wordt soms gebruikt door de Osamodettes als een breed gerande hoed. Mannelijke Osamodas gebruiken het enkel als cape. Dankzij de tekeningen welke dit kledingstuk decoreren heeft deze karakter soort een reputatie weten te bemachtigen van openhartigheid. Inderdaad, ze kunnen niet in hun vuistje lachen omdat de lach op de cape genaaid is!",ep:22,g:137,l:80,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8647] = {n:"Cape Wuera",t:17,d:"Pandawas gebruiken deze cape als bescherming tegen slecht weer en als een dans accessoire. Ze leggen hem op de vloer, in het midden van een cirkel dronken dansers. Dat beginnen ze met hun geïmproviseerde choreografie waarin ze met hun voeten de grond niet mogen raken buiten de door dit kledingstuk  afgebakende omgeving",ep:22,g:142,l:80,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8648] = {n:"Cape Hulco",t:17,d:"Deze cape kreeg zijn naam van een originele Cra die een speciaal gevoel voor richting had. Hij kon in zijn eigen huis verdwalen, en dat was nou niet bepaald een grote plek! Zijn belangrijkste probleem was dat bepaalde hersenfuncties misvormd waren. Inderdaad, alle plekken leken voor hem hetzelfde: een groot strand, omringd met palmbomen, gebaad in het warme licht van de zonsondergang.",ep:22,g:132,l:80,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8649] = {n:"Cape Adossia",t:17,d:"De warme en comfortabele kleuren van deze cape kunnen de drager ervan op een denkbeeldige reis mee nemen, in zonnige landen, vol met ravijnen door erosie, en rotsige taferelen, uitgesneden uit kliffen en diverse rotsen. Het is erg nuttig om de kou, grijze en regenachtige dagen te vergeten.",ep:22,g:136,l:80,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8650] = {n:"Cape Hernaum",t:17,d:"Enutrofs hebben de gewoonte om kaarten op hun cape te tekenen. Ze leven in zo\'n rotzooi dat ze amper de toiletten kunnen vinden en dit is nogal een probleem, speciaal wanneer je heel erg nodig moet.",ep:22,g:135,l:80,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8651] = {n:"Bloederige Riem",t:10,d:"Deze prachtige riem voegt wat toe aan het prestige van de verschijning van Iops. Er wordt gezegd dat het centrale kruis een afneembaar wapen kan worden als hun zwaarden niet binnen bereik zijn. Dit is duidelijk een legende. Enkel Srams zijn oneerlijk genoeg om zulke dingen te doen.",ep:22,g:116,l:130,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8652] = {n:"Riem Sterous",t:10,d:"Als een Ecaflip zich verveelt neemt hij de kaarten van zijn riem en gaat hij patience spelen. Als hij vecht kan hij de kaarten als projectiel gebruiken. Sneller dan zijn schaduw trekt hij een kaart en als de overwinning aan zijn kant is, is er altijd tijd voor een spelletje!",ep:22,g:117,l:130,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8653] = {n:"Klinkende Riem",t:10,d:"De naam van deze riem komt van het specifieke geluid dat het maakt. De botten die de riem opleuken knallen tegen elkaar aan, en voorkomen dat de Shrams, zelfs de onzichtbare, onopgemerkt kunnen gaan.  Dan zou je makkelijk een gesprek als deze kunnen horen: “Verrassend dat iemand een Klinkende Riem draagt? Je hebt nogal wat verwachting!",ep:22,g:118,l:130,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8654] = {n:"Slapeloze Riem",t:10,d:"Het onophoudelijke tikkende geluid van het kloksysteem van deze riem voorkomt dat Xelors gaan slapen tijdens een eeuwig durend gevecht. Het wordt met klem geadviseerd om deze riem af te doen voor je gaat slapen.",ep:22,g:119,l:130,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8655] = {n:"Blub Riem",t:10,d:"Hoewel dit niet het snikken stopt, kan deze riem vele medicinale goederen vasthouden. Dit is vooral belangrijk voor de Eniripsa\'s... als ze een zere keel hebben, kunnen ze hun spreuken niet juist uitspreken. En als ze stemloos zijn... nou ja, dan zijn ze zo nuttig als een berenhuid jas in een oven.",ep:22,g:120,l:130,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8656] = {n:"Riem Atio",t:10,d:"De reden waarom de ontwerpers van deze mode accessoire een poppenhoofd naast het kruis hebben geplaatst is nog steeds onbekend. Vele theorieën hebben de revu gepasseerd maar iedereen weet dat het slechts een broodje-aap verhaal is!",ep:22,g:121,l:130,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8657] = {n:"Riem Pado",t:10,d:"De Pados, krijgers van een oude stam bekend voor hun liefde voor bloed, zouden de eerste aanbidders kunnen zijn van de godin Sacrier. Onder zijn onschuldige voorkomen is deze riem een echt geraffineerd martelaars instrument.",ep:22,g:122,l:130,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8658] = {n:"Diezzle Ring",t:10,d:"Osamodas staan er om bekend dat ze impulsief zijn. Ze neigen ernaar om erg lichtgeraakt te zijn. De diverse gespen aan zijn riem zijn er voor bedoeld om ze af te remmen in hun spontaniteit. “Voor je je boosheid ontvlamt en je ogen met bloed doorstromen, raak al de hoorns van je fantastische Diezzle Riem aan!”",ep:22,g:123,l:130,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8659] = {n:"Kleverige Val",t:10,d:"Deze riem helpt Pandawas om (bijna) rechtop te staan wanneer ze dronken zijn, wat bijna altijd zo is. Op die momenten denken ze dat ze aan de grond vastgeplakt zitten, hoewel zwaartekracht op geen enkele manier gerelateerd kan worden aan deze sensatie. Zwaartekracht is te druk om wetenschappers neer te meppen met appels.",ep:22,g:124,l:130,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8660] = {n:"Targ Riem",t:10,d:"Deze riem laat je flodderige kleding tegenhouden (om gevoelige zielen niet weg te jagen) en hij biedt een doel aan aan leerling Cras. Inderdaad, hen wordt geleerd om middenin te schieten maar nooit onder de gordel.",ep:22,g:125,l:130,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8661] = {n:"Girdle Riem",t:10,d:"Fecas bewaren hun overlevingsgoederen zuinig in een kleine tas, wat voornamelijk bestaat uit Crackrock brood. Daarom kan dit voedsel het zo lang uithouden. De Sekuritee Riem verzekert de tas stevig rond hun taille, omdat er nog steeds te veel ongelukkig ontstaan door het vallen van deze tas, door nalatigheid of gewoon stommigheid.",ep:22,g:126,l:130,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8662] = {n:"Riem Urgid",t:10,d:"Deze riem is een erg handige accessoire, gebruikt door mannelijke Enutrofs. Dankzij de kaart die er op genaaid is, kunnen ze hun hik verbergen als ze verdwalen terwijl ze op zoek zijn naar de toiletten.",ep:22,g:127,l:130,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8663] = {n:"Laars-a-Hoop",t:11,d:"Met deze laarzen aan zijn de Iops altijd als eerste op het slagveld en doen ze de plek opleven. Het is algemene kennis deze karaktersoort er dol op is om het publiek te amuseren met hun krijgersprestaties. Maar niemand neemt ze ooit serieus vanwege hun intelligentie, welke het tegenovergestelde van hun kracht is.",ep:22,g:100,l:100,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8664] = {n:"Slaapharen",t:11,d:"Er wordt gezegd dat Sadidas zich nooit alleen voelen, aangezien ze een heleboel poppen kunnen bezweren die hun gezelschap kunnen houden. Dankzij deze schoenen kun jij ook vaarwel zeggen tegen het eenzame gevoel! Je kunt tegen ze praten en buiten deze slaapharen zal niemand het spelletje ooit bloot kunnen leggen. Als je ze op hebt gezet, voel je je echt goed zelfs als je je eigenlijk schaamt om ermee naar buiten te gaan.",ep:22,g:105,l:100,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8665] = {n:"Laarzen Hox",t:11,d:"Gedrenkt in een stevig product maken deze laarzen de kromming van je benen perfect en strijden ze tegen de natuurlijk dodelijke aard van Srams. Deze crème heeft spectaculaire effecten op Sramettes maar lijken absoluut nutteloos op Srams. Misschien een hormonaal probleem?",ep:22,g:102,l:100,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8666] = {n:"Laarzen Ero",t:11,d:"Deze laarzen, gecreëerd door een Xelor artiest, zouden hem sneller moeten laten verven. En het werkt! Ze verwringen echter ons zicht en vooral ons gevoel voor afstand. Met deze laarzen aan ziet alles er wat ronder uit. De schilderijen, van de Xelor, gewaardeerd door de Sadidas, maakten de royale rondingen van grotere vrouwen erg populair.",ep:22,g:103,l:100,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8667] = {n:"Laarzem Ulism",t:11,d:"Dankzij deze laarzen ben je altijd beschermd tegen toxines die uit de grond komen. We kunnen nooit achterdochtig genoeg zijn als het gaat om microben en andere bacillen die daar omheen hangen. Enkele waarnemers zeggen dat deze schoenen meer een slaperige look hebben dan een laarzige. Maar goed, zo noemen de Eniripsa\'s ze. Komt het door hun grootte dat ze alles vanuit een ander oogpunt zien?",ep:22,g:104,l:100,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8668] = {n:"Laarzen Hanik",t:11,d:"Hun voorliefde voor planten zorgt dat Sadidas enkel schoenen dragen die uitgerust zijn met bloemachtige herkenning. Dankzij hun herkennings systeem voorkomt het dat de drager ervan zeldzame planten vertrapt. Echter, het voorkomt niet dat je in diverse soorten uitwerpselen stapt als je niet uitkijkt.",ep:22,g:101,l:100,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8669] = {n:"Genagelde Tongen",t:11,d:"In tegenstelling tot andere soorten vinden Sacriers het geweldig om met een doorn in hun voet te leven en willen ze deze niet laten verwijderen. De pijn die ze voelen herinnert ze eraan dat ze leven en geven ze een razende energie om hun vijanden te verslaan. Behalve dat laten de bloedruppels altijd een spoor achter zodat ze ten alle tijden de weg naar huis terug kunnen vinden.",ep:22,g:106,l:100,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8670] = {n:"Wawka Laarzen",t:11,d:"Krokodyl Dandy heeft vaak een goeie kans en vaak een goeie vrouw verloren door zijn eeuwige drank om door de outback heen te dwalen. Zijn beroemdheid groeide snel en er werd hem zelfs een sponsordeal aangeboden door de befaamde schoenmakers van Aerdala, maar toen hij zag wat ze hem aanboden gooide hij ze terug en riep “Dat zijn geen laarzen... DIT zijn laarzen.”",ep:22,g:107,l:100,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8671] = {n:"Geweldig Coralator Overblijfsel",t:24,d:"Dit indrukwekkende overblijfsel ontdoet je misschien van al je zorgen.",ep:22,g:152,l:1,wd:true,fm:true,w:0,p:1};
I.u[8672] = {n:"Goulo het Verschrikkelijke Overblijfsel",t:24,d:"Dit indrukwekkende overblijfsel ontdoet je misschien van al je zorgen.",ep:22,g:153,l:31,wd:true,fm:true,w:0,p:1};
I.u[8673] = {n:"Geweldiger Bherb Overblijvsel",t:24,d:"Dit indrukwekkende overblijfsel ontdoet je misschien van al je zorgen.",ep:22,g:154,l:61,wd:true,fm:true,w:0,p:1};
I.u[8674] = {n:"Tynril Overblijfsel",t:24,d:"Dit indrukwekkende overblijfsel ontdoet je misschien van al je zorgen.",ep:22,g:155,l:101,wd:true,fm:true,w:0,p:1};
I.u[8675] = {n:"Kimbo Overblijfsel",t:24,d:"Dit indrukwekkende overblijfsel ontdoet je misschien van al je zorgen.",ep:22,g:156,l:141,wd:true,fm:true,w:0,p:1};
I.u[8676] = {n:"Kwaadaardig Zwaard",t:6,d:"Vlad werd verliefd op dit prachtige zwaard. Hij deed mee aan de meest angstaanjagende Dragokart race ooit om genoeg geld te verzamelen zodat hij het zwaard kon kopen. Helaas wist hij niet dat het zwaard vervloekt was...",ep:1,g:75,l:95,wd:true,fm:true,w:1,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8677] = {n:"Ross Geest",t:18,d:"Dit schattige Konijn is het favoriete huisdier van de beroemde Meester Nero Jack. Laat je niet voor de gek houden door zijn voorkomen, hij kan erg angstaanjagend zijn in gevecht. Dit huisdier eet enkel Wowtels en andere planten.",ep:3,g:44,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8678] = {n:"Satanass Hoed",t:16,d:"Lang geleden was Satanass een figuurskater die Holyball on Ice afsneed op de glijbanen van de Tweede Zone. Terwijl hij aan het bijkomen was van een verwonding aan zijn stuitbeen had hij een levensveranderende openbaring: zijn bestemming was om de meest talenvolle Dragokart rijder van zijn tijd te worden! Een kleine schok zorgt soms voor forse brok.",ep:1,g:187,l:36,wd:true,fm:true,w:20,p:3550};
I.u[8679] = {n:"Ross Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:3,g:46,l:1,wd:true,fm:true,w:1,p:1};
I.u[8680] = {n:"Slijmerige schub",t:59,d:"Deze slijmerige, slipperige schaal liet de eigenaar ontsnappen als ze gevangen waren door vreemde avonturiers die met hun tanden visten. Helaas was het totaal niet nuttig tegen een goed gemikte slag met een roestig zwaard.",ep:1,g:626,l:10,wd:true,fm:true,w:1,p:1};
I.u[8681] = {n:"Raul Mops\' Huid",t:59,d:"Raul Mops heeft een echte zwakte. Hij vindt het heerlijk om zichzelf met water, wijn of zelfs azijn in te smeren. Maar bovenal houdt hij ervan om zich om te rollen in glazen flessen, terwijl hij cirkels maakt in geschilde uien. Nog een beest met vreemde en mysterieuze gewoonten.",ep:1,g:627,l:40,wd:true,fm:true,w:1,p:1};
I.u[8682] = {n:"Spons Mob Huid",t:59,d:"Beide kanten van deze huid kunnen worden gebruikt voor je huishoudelijke projecten. De zachte huid is voor het schoonmaken van delicate plekken, en de ruwe zijde is om al je voorheen niet toegankelijke lichaamsdelen te plagen.",ep:1,g:628,l:10,wd:true,fm:true,w:1,p:1};
I.u[8683] = {n:"Pingoku Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals een paar genezende Eniripsa poeders.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8684] = {n:"Bow Kennel Certificaat voor: Ross",t:77,d:"Dit certificaat beschrijft de karakteristieken van de Ross die je in de Bow Kennel hebt gestopt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8685] = {n:"Bow Kennel Certificaat voor: Bilby",t:77,d:"Dit certificaat omschrijft de karaktereigenschappen van de Bilby die je in de Bow Kennel hebt gezet.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8686] = {n:"Ross Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals eten en een paar genezende Eniripsa poeders.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8687] = {n:"Bliby Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals een paar genezende Eniripsa poeders.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8688] = {n:"Ross Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Overwinnings Teken",t:24,d:"Je hebt met gemak de volgeling verslagen. Hij beaamde dit en gaf je deze rol.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Transformatie Drankje Formule",t:24,d:"Die boek bevat theorieën van diverse alchemisten over de mogelijkheid van Wabbit Twansfowmatie. Het enige wat het laat zien is hoe weinig ze over dit onderwerp gedaan hebben.",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Feanor",t:18,d:"Dankzij dit huisdier geven al je klasgenoten je puppy ogen. Hier is een tip: tel je kippen niet voor ze leggen! Je zuult je snel realiseren dat je geliefde gehypnotiseerd is door Fëanor. Het zal zelfs geen voordeel zijn: degene voor wie je ooit oog had zal aan een rauwe Snapper gaan kauwen en tegen je benen op gaan wrijven... Niet het beste. Dit huisdier eet alleen vis.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Geconfijte Chillipeper",t:42,d:"Deze gekonfijte cayennepeper is even explosief als de spanningen van het suspensoir van de duivel. Dit geestverruimend mengsel van suiker en vuur leidde een Dragokalkoen naar een reeks van omstreden overwinningen in de Werelddragokart Kampioenschappen voor hij door alle belangrijke sportverenigingen geweerd werd.  Je kunt het gebruiken als een zetpil indien je vlug moet vertrekken of als een pil indien naar binnen komen je probleem is.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"Zwaard Hikk",t:6,d:"Zoals Brice zei: “Grootte doet er niet toe, enkel de manier waarop hij handelt”.",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
I.u[8696] = {n:"",t:23,d:"",ep:0,g:14,l:1,wd:false,fm:true,w:1,p:1};
I.u[8697] = {n:"",t:23,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[8698] = {n:"",t:23,d:"",ep:0,g:16,l:1,wd:false,fm:true,w:1,p:1};
I.u[8699] = {n:"Tynril Hoed",t:16,d:"Met deze hoed op heb je altijd de net-uit-bed look, zelfs als je uren hebt besteed aan het borstelen van je haar. Het moet opvallen dat de Tynril schors-type haren krullen als het vochtig weer is, waarmee het de meest betrouwbare weersvoorspelling in de wereld is. Wees daarom extreem voorzichtig en houd het weg van vlammen als je niet een menselijke fakkel wilt zijn.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Smaragd Schild",t:16,d:"Dit hoofddeksel is geïmproviseerd uit een gebroken Smaragd Dofus. Het ei is niet echt leeg, dus trakteer je zelf op een fijn, opkikkerend bad.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Gejatte Zwaard",t:6,d:"Dit luxueuze zwaard behoorde toe aan een beroemde dief, die bekend stond omdat hij telkens bestolen werd als hij een misdaad pleegde.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8702] = {n:"",t:4,d:"",ep:0,g:74,l:1,wd:false,fm:true,w:1,an:12,tw:true,e:[0,0,1,1,0,0,false,false],p:1};
I.u[8703] = {n:"",t:5,d:"",ep:0,g:63,l:1,wd:false,fm:true,w:1,an:13,e:[1,0,1,1,1,1,false,false],p:1};
I.u[8704] = {n:"Jester Hoed",t:16,d:"Als je deze twee kleine belletjes schudt, ben je wellicht in staat om muziek te maken.",ep:22,g:190,l:160,wd:true,fm:true,w:10,p:47625};
I.u[8706] = {n:"Fëanor Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:3,g:48,l:1,wd:true,fm:true,w:1,p:1};
I.u[8707] = {n:"Bow Kennel Certificaat voor: Fëanor",t:77,d:"Dit certificaat omschrijft de karaktereigenschappen van de Fëanor die je in de Bow Kennel hebt gezet.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8708] = {n:"Bow Kennel Certificaat voor: Atooin",t:77,d:"Dit certificaat beschrijft de karakteristieken van de Atooin die je in de Bow Kennel hebt gestopt.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Fëanor Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Fëanor Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals eten en een paar genezende Eniripsa poeders.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Stukje van Goldemort",t:110,d:"Gefeliciteerd! Je bent erin geslaagd om een stuk van Goldemort\'s lichaam te stelen. Je zou een aasgier trots maken!",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Betas Bernacles",t:11,d:"In sommige landen lijkt het alsof de Getas Bernacle op vijanden worden gegooid om om duellen uit te lokken. Ook als dit grappig klinkt verschilt het niet zoveel van het slaan van je tegenstander met handschoenen. Het voordeel van de Getas Bernacle is dat ze een reukbrouwsel toevoegen aan hun eigenlijke slag. Pandawas waren al nooit bekend om hun voet hygiëne...",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Honoh Ring",t:9,d:"Het dragen van deze riem is een eer. Het betekent dat je een trouwe aanbidder van de godin Cra bent, de enige die ooit openbaarde hoe je snel en efficiënt kan schieten.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Blaber Ring",t:9,d:"De welbespraaktheid van de Ecaflips is aardig bekend. Ze kunnen je altijd wel ompraten om je te laten spelen. Deze ring viert hun nooit mislukkende drang om te praten. Je kunt hem ook gebruiken als reserve om jezelf te krabben... bijna overal!",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Leeuw Ring",t:9,d:"Osamodettes houden van deze ring welke een extra katachtige toevoeging aan hun manier van lopen geeft. Omdat ze altijd zo dichtbij monsters zijn gaan ze zich zelf als echte monsters gedragen. In het echt zijn ze zo toegewijd en zorgzaam als leeuwinnen moeders.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Ring Bellious",t:9,d:"Haatvolle roddelaars claimen dat deze ring de meest nuttige mode accessoire in de wereld is. De vleugels die er aan vast zijn gemaakt kunnen nogal irritant zijn als je een zakdoek uit je zak wilt halen. Maar goed, Iops hebben geen zakdoeken noch zakken... dus het is oké. Behalve dat verwonden zij hun vijanden elke keer dat ze voorbij komen. Je gaat je afvragen of het niet een Sacrier sieraad is uiteindelijk.",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Memo Ring",t:9,d:"Fecas gebruikten de mini schilden op deze ring als memo borden om liefdesbriefjes of dingen-te-doen lijstjes te schrijven. Dit sieraad heeft als bijnaam het anti-vergeetachtigheids schild. Het beschermt je echter niet tegen stotteren of het uitschieten van je tong.",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Herinner Ring",t:9,d:"Dankzij dit item kunnen Enutrofs hun vrolijke tijden herinneren wanneer ze willen. Ze moeten bewoon de schop die erin is gereden eruit trekken. Om de herinnering nog zuiverder te maken, moet je er een specifieke geur aan toevoegen... Succes!",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Chee Ring",t:9,d:"De godin Eniripsa gaf dit item aan haar aanbidders als teken van hun spirituele eenheid tijdens de les spreuk inwijding. Incidenteel kunnen Eniripsa\'s ook als spons armband gebruikt worden om het bloed van hun bondgenoten af te wassen.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Oor Ring",t:9,d:"Deze sieraad neigt ernaar om Pandawas de duivels te laten beledigen na twee of drie biertjes... vergeet niet het oude spreekwoord “Stokken en stenen kunnen mijn botten breken, maar een dronken beer-achtig beest kan me nooit pijn doen.”",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Elkebi Ring",t:9,d:"Deze sieraad met een schedel erop was traditioneel geofferd aan alle Sram kinderen als beloning voor hun verraad en slagen onder de riem. De andere soorten wilden dit soort praktijken in diskrediet brenken aangezien het kinderen overprikkelt en ze in kleine duivels verandert.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Subma Ring",t:9,d:"Deze ring is de enige sieraad die de tijd kan vertellen en die absoluut waterdicht is. Sommigen geloven dat als je de plannen vergroot en wijzigt van dit item, je hem kunt veranderen in een voertuig die onder water kan bewegen. Waar komen die ideeën vandaan?",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Hai Ring",t:9,d:"In tegenstelling tot de geruchten laten Sadidas hun haren niet hangen...Dit haar is om een prachtige ring heen geschikt om de voordelen te versterken. Knip het nooit af! Dankzij de Hooi Ring ben je altijd perfect!",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"Ring Neinwonwon",t:9,d:"Als je een karakter ziet die geen Sacrier is, draag dan de Ring Ninewonwon, breng hem direct naar de intensive care. Inderdaad, deze sieraad is extreem schadelijk. Over het algemeen verliezen mensen hun koelte als ze de poel van bloed aanschouwen, veroorzaakt door deze ring.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Crusuede Shoenen",t:11,d:"Deze schoenen laten de drager ervan de hele nacht dansen, ondanks blaren en likdoorns! Ze dansen op het ritme van de nacht en maken kleine “biep biep” geluiden wanneer ze naast religieuze artifacten komen. Je zult zo helder als een knoop zijn de volgende dag, klaar voor wat slachtingen.",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Verlichtings Laarzen",t:11,d:"Als Fecas beschaamd zijn en van onderwerp willen veranderen beginnen ze altijd over hun Verlichtings Laarzen. Ze praten over de manier waarop je door het land heen kunt lopen. Als hun bondgenoten in problemen zijn op het slagveld, zorgen deze comfortabele laarzen ervoor dat ze herstellen en de bedreiging afweren.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Veggie Laarzen",t:11,d:"De verscheidene riemen om deze schoenen kunnen worden gebruikt als reservestringen om de kapotten van je boog te vervangen. Jonge Craettes gebruiken ze ook om groenten te koken. De voetengeur lijkt ze niet te storen.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Versleten Koraal",t:51,d:"Het Koraal verliest zichzelf van de Carolator, enkel wanneer het droog weer is. Koraal is iets prachtigs en sommigen maken er zelfs sieraden van. Sommige anderen eten het schaamteloos... maar de laatsten zijn erg zeldzaam en als ze het wel eten komt het omdat ze het verwarden met krab sticks.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Coralator Coccyx",t:47,d:"Dit op een aanzienwekkende plek staande bot laat de Coralator met waardigheid zitten. Nou hij dood is kun je het nog steeds gebruiken om jouw gezag te vestigen op zijn medebeesten.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Groot Koraal",t:51,d:"Het enige verschil tussen het Versleten Koraal en het Geweldige Koraal is de grootte en wat je er mee kunt doen. Echter, een hele boel Versleten Koralen kunnen nooit één Geweldig Koraal vervangen.",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Kurasso Koraal",t:51,d:"De bijzondere kleur van dit koraal komt van het ongezonde dieet van de Craboral. Nog iemand die zijn 5 stuks fruit en groente per dag vergeet!",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Mahlibuh Koraal",t:51,d:"De bijzondere kleur van dit koraal komt van het ongezonde dieet van de Craboral. Nog iemand die zijn 5 stuks fruit en groente per dag vergeet!",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Passoah Koraal",t:51,d:"De bijzondere kleur van dit koraal komt van het ongezonde dieet van de Craboral. Nog iemand die zijn 5 stuks fruit en groente per dag vergeet!",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Mojeeto Koraal",t:51,d:"De bijzondere kleur van dit koraal komt van het ongezonde dieet van de Craboral. Nog iemand die zijn 5 stuks fruit en groente per dag vergeet!",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Gepolijste Stenen Hart",t:51,d:"Het enige dat een Crackler\'s hart onderscheidt van een gepolijste Crackler is finesse waarmee het item gebroken kan worden tussen je tenen wanneer je het het minste verwacht.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Gepolijste Bal",t:51,d:"Van welk deel van de Crackrock anatomie komt deze bal? En waarom komen ze vaak in paren?",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Groot Heiligbeen",t:47,d:"De Coralator biedt een bot van zijn achterkant aan. De Geweldige Coralator staat je toe om bezit te nemen van een ander deel van zijn anatomie, ongeveer in hetzelfde gebied.",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Sparo\'s Humerus",t:47,d:"Hoewel dit bot een humerus wordt genoemd is het moeilijk te zeggen of hij echt van Sparo\'s arm komt. Toen hij dood ging werd zijn skeler in een vat gestopt en in stukken geslagen. Het klinkt pijnlijk, zelfs voor een bot.",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Flib\'s Stomp",t:47,d:"Als ik jou was pakte ik dit ding niet op – de mond waar dit vandaan komt is net ze schoon als het kruis van de duivel. Maar goed, jij bent de avonturier, jij kent jouw zaken!",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Kido Snavel",t:47,d:"Deze snavel is zo breekbaar dat Otomai\'s volgelingen hem gebruiken om trainingspijlen met stompe einden te maken om niemand te bezeren.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Craboral Tang",t:47,d:"Vermijd het om een Craboral\'s tang te schudden! Je zult je hand maar verliezen doordat je vriendelijk was.",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Kurasso Petal",t:35,d:"De kleur van dit bloemblad suggereert zijn twijfelachtige origine. Alcoholmisbruik kan zelfs in de creaties van Otomai\'s volgelingen worden gevonden.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Mahlibuh Petal",t:35,d:"De kleur van dit bloemblad suggereert zijn twijfelachtige origine. Alcoholmisbruik kan zelfs in de creaties van Otomai\'s volgelingen worden gevonden.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8747] = {n:"Passoah Kroonblad",t:35,d:"De kleur van dit bloemblad openbaart zijn twijfelachtige origine. Alcohol misbruik kan zelfs in de creaties van Otomai\'s volgelingen gezien worden.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Mojeeto Bloemblad",t:35,d:"De kleur van dit bloemblad suggereert zijn twijfelachtige origine. Alcoholmisbruik kan zelfs in de creaties van Otomai\'s volgelingen worden gevonden.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Kurasso Lamp",t:36,d:"De Palmbloem groeit niet uit een zaadje maar een bol gedrenkt in alcohol. Waarom? Gewoon!",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Mahlibuh Bulb",t:36,d:"De Palmbloem groeit niet uit een zaadje maar uit een bol gedrenkt in alcohol. Waarom? Gewoon!",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Passoah Bulb",t:36,d:"De Palmbloem groeit niet uit een zaadje maar uit een bol gedrenkt in alcohol. Waarom? Gewoon!",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Mojeeto Bulb",t:36,d:"De Palmbloem groeit niet uit een zaadje maar uit een bol gedrenkt in alcohol. Waarom? Gewoon!",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Manen in Bloem",t:36,d:"Deze manen zijn het onwaarschijnlijke resultaat van hybridisatie tussen haren en bloembladen, hetgeen het een dubbele allergeen maakt. Daarom kun je beter wegblijven als je hier gevoelig voor bent aangezien een enkele nies je hersens aan kan tasten.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Barbrossa\'s Belachelijke Baard",t:54,d:"Dit kleine haarbosje herinnert je aan je vakanties dankzij zijn geur van zand, zonnescherm en alcohol. Wat jammer dat het zo naar buskruit stinkt!",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Flib\'s Rode Bosje",t:54,d:"Niemand weet of de kleur van dit bosje natuurlijk is of veroorzaakt is door tijdloos bosvuur.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Kilibriss Achterkant",t:54,d:"De achterkant van een Kilibriss is licht en veel gezocht om matrassen te maken. Terwijl ze wachten op nieuwe soorten levende matrassen die tijdens safaris vermoord kunnen worden, jagen ambachtsmannen actief op Kilibrissen.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Barbrossa\'s Shirt",t:15,d:"Heb je een insectenverdelger nodig? Doe Barbrossa\'s Shirt gewoon aan! De ene kant geeft het effect dat mensen automatisch overgeven als ze binnen een straal van 5 voeten bij je in de buurt komen.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Gourlo\'s Uiteengerukte Shorts",t:15,d:"Niemand heeft ooit een intact paar shorts van Gourlo gevonden aangezien hij ze altijd in brand stak door te spelen met buskruit.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Flib\'s Vervloekte Kleine Doos",t:15,d:"Deze doos is Flib-vormig... tenzij het het tegenovergestelde is! In ieder geval is het nog steeds een vervloekte kleine kist.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Sparo\'s Sjaal",t:15,d:"Deze sjaal is een essentiele accessoire voor zowel de zomer als de winter seizoenen. Het geeft je een originele uitstraling, maar een beetje kitscherig. Zijn flitsende kleur zal zeker mannelijke Gobballs opwinden, maar is dat echt wat je wilt?",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Gourlo\'s Explosieve Poeder",t:48,d:"Om te compenseren voor het kanon die hij niet als arm kom transplanteren gaat Gourlo nooit weg zonder wapen. Hij kan niet erg snel schieten aangezien hij moet wachten tot het poeder droog is elke keer.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Gepolijst Hersen Fragment",t:50,d:"Dankzij dit fragment leer je de goede manieren van Crackler: handen verpletteren als groet.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Mufafah Snor",t:15,d:"Dikker dan die van de Kittenvis, kan Mufahah\'s snor gebruikt worden om kwasten te maken voor Marylork de schilder.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Wenkbrauw van de Geweldiger Bherb",t:15,d:"Om te bewijzen dat hij de baas is, zijn de wenkbrauwen van de Geweldiger Bherb altijd gefronst, zelfs na zijn dood.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Kilibriss Staf",t:15,d:"Dankzij zijn lengte zal deze staf je toelaten om de moeilijkste plekjes te bereiken en jezelf overal te kunnen krabben.",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Kido Achterkant Veer",t:53,d:"Een van Otomai\'s grootste raadsel kwam voort uit deze bron: wat is zwaarder? Honderd doppen Kido veren of honderd doppen Pyrute?",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Eenvoudige Pikoko Vleugel",t:104,d:"De Pikoko was nooit beroemd voor zijn vliegcapaciteiten. Als je zijn vleugels hebt gezien, dan begrijp je waarom.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Afgerukt Pumbaa Oor",t:106,d:"Als je dit oor bij die van jou houdt zul je de galop van het eenvoudige zwijn horen in plaats van het bulderen van de zee.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Eenvoudige Pikoko Noot",t:111,d:"Er zit geen melk in deze Pikoko Noot maar je vindt er wat hersen sap met een paar drijvende neuronen.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Tynril Schors",t:96,d:"Deze schors is nieuwsgierig gebogen. Het ziet eruit alsof hij door een rasp is gehaald.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Floramor Schors",t:96,d:"Deze schors is nieuwsgierig besneden. Hij ziet eruit alsof hij door een rasp is gehaald.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Rotaflor Schors",t:96,d:"Deze schors is nieuwsgierig besneden. Hij ziet eruit alsof hij door een rasp is gehaald.",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Gwass Schors",t:96,d:"Deze schors is nieuwsgierig uitgehakt. Het lijkt erop dat hij door een rasp is gehaald.",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Barkritter Schors",t:96,d:"Deze schors is nieuwsgierig gebogen. Het ziet eruit alsof hij door een rasp is gehaald.",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Warguerite Schors",t:96,d:"Deze schors is nieuwsgierig gebogen. Het ziet eruit alsof hij door een rasp is gehaald.",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Donkere Pikoko Noot",t:111,d:"Er zit geen melk in deze Pikoko Noot, maar je vindt er wat hersensap met enkele drijvende neuronen.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Tynril Pistil",t:36,d:"Bloemen komen overeen met de seksuele organen van de plant. De stamper is een deel van de bloem. Nu kun je denken wat je wil.",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Floramor Meeldraad",t:36,d:"De meeldraad is het mannelijke orgaan van een plant. Ja! Ondanks zijn voorkomen is Floramor kennelijk een man...",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Rotaflor Carpel",t:36,d:"Een kleine biologieles: de bloemen zijn de sexuele organen van de plant en de stamper is het deel van de bloem terwijl het vruchtblad deel van de stamper is. Ik laat het aan jou over te beslissen wat wat doet.",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Gwass Sepal",t:36,d:"Dit Gwass lichaamsdeel is altijd groen, hoe dan ook. Komt het door de overvloed van chlorofyl of door iets anders?",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Barkritter Calyx",t:36,d:"Doe maar geen moeite om de Barkritter Calyx te proberen te gebruiken om iets mee te drinken. Het lijkt misschien op een kop, maar het is zo stevig als een zeef.",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Warguerite Schutblad",t:36,d:"Het Warguerite schutblad verwijst naar een omgeving waar fatsoen me tegenhoudt om uit te halen.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Donkere Pikoko Amandelen",t:15,d:"De Donkere Pikoko is niet zo gek zodra zijn amandelen verwijderd zijn. Nou ja, dit is geen verrassing, aangezien een operatie meestal zijn einde betekent.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Donkere Treecklers Achillespees",t:15,d:"Je zult de Donkere Treeckler niet verslaan door een pijl in zijn Achillespees te schieten. Maar je kunt het altijd proberen...",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Donkere Treeckler Zaad",t:58,d:"Met een heleboel geduld, tijd, water en mest kan je misschien een Treeckler in je tuin laten groeien zodat je kunt oefenen om tegen hem te vechten. Het is waarschijnlijk makkelijker om de boot naar Otomai\'s Eiland te pakken...",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Cheeken Vlecht",t:15,d:"Deze dikke en ruwe haren kunnen als een dweil gebruikt worden of om je kaalheid te verbergen. Maar je moet het vele, vele keren wassen voordat je ze gebruikt.",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Cheeken Cloaca",t:15,d:"Nee, het is niet walgelijk! Het is natuurlijk!",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Lucht Pikoko Achterhoede",t:15,d:"Deze achterhoede laat je items creeëren die je achter je moeten beschermen.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Kimbo Sok",t:15,d:"Ondanks dat het zo lijkt, draagt Kimbo wel sokken, alleen niet aan zijn voeten. Hij rolt ze liever op om ze in strategische plekken te stoppen.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Moopet Volproppen",t:15,d:"De natuur is enkel gescheiden royaal geweest voor de Moopets, het achterste moet een smoes verzinnen om een levend ding te passeren.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Moopet weefsel",t:55,d:"Dit weefsel heeft een vreemde textuur maar zal snel elk zedig monster snel kleden.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Lucht Pikoko Noot",t:111,d:"Er zit geen melk in deze Pikoko Noot, maar je vindt er wat hersensap met enkele drijvende neuronen.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Slakmet Schelp",t:111,d:"Deze schelp, rond en glimmend, is gepolijst met slobber vele eeuwen. Elk met zijn eigen.",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Kimbo Pruik",t:54,d:"Om zijn vroege haalheid te verbergen zet Kimbo deze stomme pruik op. Gelukkig voor hem bedekt deze kokosnoot het meeste ervan.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Lichte Treeckler Knoop",t:38,d:"Kapitein Chafer hoorde de naam van dit voorwerp en vanaf toen was de Treeckler ook wel bekend als “Knobbel Hoofd”.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Lichte Treeckler Stomp",t:38,d:"Een stom anders dan alle andere stompen, en hij spint.",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Gevederde Staart van de Geweldiger Bherb",t:65,d:"Één voor één, jaar na jaar. De veren van de Bherb zijn verbonden met zijn staat. Je kunt zijn leeftijd vertellen door de beharing of zijn borstel.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Pumbaa Oksel Haar",t:54,d:"Zelfs als hij het vaak afscheert groeit zijn haar altijd weer dik en stinkend aan. Dus de stank komt niet van zweet.",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Zoth weefsel",t:55,d:"Doordat deze weefsel gemaakt is van zachte en stevige materialen is hij perfect vastgemaakt aan het Zoth figuur en verbergt het essentiële.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Quassingue weefsel",t:55,d:"Deze doek heeft meer gaten dan een blok zwitserse kaas en hij veegt vuil sneller op dan een epileptische Gobball. Als deze doek eraan komt, verdwijnt het schuim.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Zoth Krijger Scheenbeen",t:47,d:"Net als alle andere botten van de Zoth Krijger, is dit scheenbeen menig maal gebroken geweest. Het is perfect genezen en werd telkens sterker. Als het kon praten zou het zeggen: “Waar je niet aan dood gaat, maakt je sterker”.",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Zoth Volgeling\'s Knieschijf",t:47,d:"Aangezien een Zoth Discipel altijd met zijn knieën aanvalt, is zijn knieschijf extreem groot en sterk geworden. Ik ken schildpadden die hun schelp voor een van die dingen zouden omruilen.",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Zoth Meester\'s Gulp",t:15,d:"De gulp van Zoth Meester is bijzonder. Hij is speciaal gemaakt om vlees niet uit elkaar te rukken. Avonturiers die ooit door hun gulp zijn getraumatiseerd snappen waarom.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Zoth Meisjes Zakdoek",t:15,d:"Het Zoth meisje gebruikt deze zakdoek niet om haar tranen weg te vegen maar om het bloed van haar vijanden mee weg te vegen.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Zoth Sergeant\'s Label",t:15,d:"Dit opgesmukte label op weefsel, gegeven door zijn moeder, is meer een herinnering uit zijn kindertijd dan een militair insigne.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Ouassingue Sap",t:15,d:"Tenzij je verrekte dronken bent kun je een Ouassingue sap nooit verwarren met welk ander drinkbaar vocht dan ook. De misselijkmakende geur zal zelfs de blinden afschrikken.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
I.u[8808] = {n:"Mopy Koning weefsel",t:55,d:"Deze doek heeft meer gaten dan een blok zwitserse kaas en hij veegt vuil sneller op dan een epileptische Gobball. Als deze doek eraan komt, verdwijnt het schuim.",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"Mopy Koning Binnenstebuiten Shorts",t:15,d:"Net zoals hun voorouder, Mopy Koning Dagobert, dragen alle Mopy Koningen hun shorts binnenstebuiten. Wat nogal verwarrend is, is dat het hun magen niet binnenstebuiten doet keren.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Gedroogd Mopeat Turf",t:15,d:"Deze uit rottende groenten gemaakte turf heeft ongelooflijke absorptie krachten. Mama Bworks bewaren ze voor de maandelijkse bezoekjes van Tante Floe.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Miremop Dubbel Kin",t:15,d:"De Bourbassingue spendeert het meeste van zijn tijd aan het nemen van modderbaden in de hoop af te slanken. Hij is nog nooit een pond kwijt geraakt, maar zijn dubbele kin past tenminste goed bij zijn figuur.",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Gigantische Kralove Inkt",t:15,d:"Slijmerig en compact. Kralove inkt kan gebruikt worden om te romantische brieven te schrijven of om je kamer bedroevend zwart te verven afhankelijk van hoe je liefdesleven is.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Gigantische Kralove Zuiger",t:15,d:"Gezien de grootte van deze sucker is er geen twijfel mogelijk over zijn greep. En als je hem verwijdert is het slurpende geluid oorverdovend.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Handtas van 5,000 Kamas",t:100,d:"Deze zware handtas moet een fortuin waard zijn.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Handtas van 1,000 Kamas",t:100,d:"Deze handtas is zwaar – hij moet een fortuin waard zijn. Een handelsman zal hem vast willen ruilen voor de waarde in Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Kado: Kwaadaardig Zwaard",t:89,d:"Als je deze doos krachtig schudt, zul je zien dat hij leeg is. Voor deze ene keer hebben de goden geen grapje met je uitgehaald.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Kado: Satanass\' Hoed",t:89,d:"Als je deze doos krachtig schudt, zul je zien dat hij leeg is. Voor deze ene keer hebben de goden geen grapje met je uitgehaald.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"Mopy Koning Souvereign Cape",t:17,d:"Deze van Mopy Koning weefsel gemaakte cape heeft micro gaatjes om het zweet beter af te voeren in geval van intensieve krachtinspanning, zoals tijdens agressief strijdgewoel in moerassen. Hoewel deze cape de vochtigheid afdrijft houdt het de warmte in. Op deze manier ben je altijd droog, in welke situatie dan ook. Jammer dat de gevormde geur zo sterk is!!!",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Ouassingue Cape",t:17,d:"Hoewel deze cape niet zo krachtig is als de Mopy Koning Cape, heeft hij hetzelfde zweetafdrijvende systeem. Je kunt je door elke situatie heen slaan met deze cape, als je kunt vechten terwijl je je adem inhoudt... de stank is ondraaglijk!",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Zoth Sergeant Masker",t:16,d:"Dankzij dit masker ben je opgewassen tegen allerlei gevaren, onbevreesd! Maar dat is vrij normaal aangezien het je uitzicht belemmert.",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Zoth Volgeling Hoed",t:16,d:"Vanaf een afstand lijkt deze hoed op een lampenkap met twee gaten voor de ogen. En van dichtbij... Ook.",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Lichte Treeckler Masker",t:16,d:"Dit masker helpt niet om katers te voorkomen of te genezen, maar het geeft je tenminste de kans om de effecten te verbergen.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Donker Treeckler Masker",t:16,d:"Dit masker helpt je niet om katers te voorkomen of genezen, maar het geeft je tenminste de kans om de effecten wat te verbergen. De donkere aanraking geeft simpelweg aan dat je in een slechte bui bent... en dat je niet geïrriteerd zou moeten zijn en dat je er klaar voor bent om een aantal slagen uit te delen aan iedereen die dat niet respecteert!",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Slakmet",t:16,d:"Met dit op lijk je op een Slakmet. Natuurlijk beschermt het je hoofd tegen slagen, maar maakt dat alle slobber op je hoofd acceptabel?",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Grote Coralator Knuppel",t:7,d:"Deze knuppel, groter, zwaarder en krachtiger, maakt een luider kabaal wanneer hij vijanden slaat. Een weetje – hij is lichter en heeft een betere greep. De Coralator die we ervoor gebruikt hebben was niet voor niets zo geweldig!",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Zoth Meisje Hamer",t:7,d:"Ondanks haar kleine gestalte draagt het Zoth meisje een enorme hamer bij zich. Het is een manier om haar spierstructuur te versterken. Er is geen reden om gewichten rond haar polsen en enkels te plaatsen om haar sterkte te verhogen.. Slepen met deze hamer is genoeg!",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Zoth Krijger Bijl",t:19,d:"De Zoth Krijger is gewend om twee bijlen te dragen omdat hij de linkerkant van zijn vijand niet kan bereiken met zijn rechter hand. Het is moeilijk te zeggen of dit door zijn lichaamsvorm komt of door aangeboren onbeholpenheid.",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Cheeken Vleugel",t:16,d:"De Cheeken is een vreemdgevleugeld beest die net zoveel energie heeft als de vogelgriep en net zo intelligent als een Tofu is. Er hoeft niet gezegd te worden dat hij speciale aanleg had om te overleven. Echter, sommige mensen lijken van zijn vreemde, op gevlochten dweil lijkende haar te houden. Menselijke aard is een oneindig mysterie!",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Brabrossa\'s Hoed",t:16,d:"Deze hoed is groot genoeg om Barbrossa\'s belachelijk haarloze hoofd en baard te verbergen. Maar het zal geen groothoofdige schedels bedekken.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8830] = {n:"Flib\'s Pruik",t:16,d:"Altijd al gedroomd om het haar van Polly Darton te hebben? Neem deze indrukwekkende maar hinderlijke pruik,  verlaagd tot op je noot dan! Niet alleen zal het de dansvloer in de club schoonmaken, het zal die dodelijke slagen op je hoofd ook verzachten!",ep:0,g:198,l:1,wd:false,fm:true,w:1,p:1};
I.u[8832] = {n:"Slakmet Slobber",t:15,d:"Dit Slakmet slobber breekt niet de botten van een Pikoko, maar het lijmt je wel vast aan de grond.",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Coralator Knuppel",t:7,d:"Deze hamer heeft zijn leuke kleur van de stukken Coralator die ervoor gebruikt zijn. In tegenstelling tot wat mensen denken was het van origine niet om Iops en andere vijanden te verpletteren, het was een deurklopper voor de hardhorenden.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Donkere Treeckler Tak",t:3,d:"Deze tak werd gebruikt om lichaamsonderdelen af te schrapen die anders niet toegankelijk waren. Maak je geen zorgen, de donkere kleur is authentiek, het heeft niks te maken met de variërende soorten van bewaarplaatsen vervat in de ontoegankelijke gaten van de Treeckler.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Lichte Treeckler Tak",t:3,d:"Deze tak werd gebruikt om lichaamsonderdelen af te schrapen die anders niet toegankelijk waren. Het verklaart waarschijnlijk de vreemde geur van de tak.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Rotaflor Stam",t:4,d:"Rotaflors gebruiken hun stam om hun oren schoon te maken. Maar staf beeldhouwers gebruiken ze liever als wapen. Dit bewijst, als nodig, dat er geen beschrijving is van smaken.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Zoth Meester Staf",t:4,d:"De Zoth Meester kan iedereen verslaan met zijn staf. Hij is niet bang voor welke vijand dan ook! Wat heel normaal is aangezien hij niks kan zien met de hoed op! Hoewel dit een heel nuttige techniek is om te vechten kan het een probleem opleveren als je wilt eten. Met een beperkt zicht veld heeft de Meester Zoth altijd problemen gehad met eten zonder op iedereen te knoeien...",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Tynril Rhizome",t:4,d:"Net als onkruid kan de Tynril oneindig doorgaan met voortplanten dankzij een stukje wortelstok. Dit is na het opmerken dat enkele beeldhouwers een staf maakten van Tynril. Zij dachten dat ze gemakkelijk en goedkoop konden kweken voor ze het aan de hoogste bieder verkochten. Maar het werkte niet!",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Thierry Voodoo Masker",t:16,d:"Dit is kennelijk het enige masker waarmee je kunt eten terwijl je hem op hebt.",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Jay Voodoo Masker",t:16,d:"Jay Kannibalen voelen zich vaak “blauw” en verven hun haar blauw. Komt dat door een zielig liefdesverhaal einde of door iets anders? Moeilijk om zeker te zeggen. Maar het zou geweldig zijn als ze het masker gewoon konden dragen en ophouden met het zingen van hun droefgeestigheid.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Sarbak Voodoo Masker",t:16,d:"Vele manen geleden waren de Kannibalen reizende acteurs, gerespecteerd om hun komedies en tragedies, zoals afgebeeld op twee maskers – de ene lachend, de ander wreed. Toen hun opperhoofd het vrolijke masker kwijt raakte, verlaagden ze zich tot gruwelijkheden.",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Boogschutter Voodoo Masker",t:16,d:"Kannibaal boogschutters konden zich niet concentreren en goed mikken tenzij ze erg boos waren. Om ze de hele tijd rood te laten zien, hebben ze hun maskers in deze kleur geverfd.",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Krokodyl Dandy Hoed",t:16,d:"Met deze hoed op denkt de Krokodyl dat hij erg trendy is. Als het mogelijk zou zijn was mode niet erg huisdierig geweest. Hij kan zich beter niet realiseren hoe belachelijk hij is, inderdaad, de Krokodyl is nogal lichtgeraakt...",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"Mopy Koning Soeverein Hoed",t:16,d:"Als een koninklijke hoed, heeft deze hoed dezelfde deugdzaamheden als de Mopy Koning Cape. Zijn micro-luchtingsvermogen verzekert een betere afdrijving van zweet zodat je altijd je hoofd koel houdt. Helaas heeft hij ook dezelfde mankementen als de cape: zijn stank is zo erg dat iemand hem zo in stukken kan hakken.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Ouassingue Hoed",t:16,d:"Hoewel hij minder efficiënt is dan de koninklijke hoed is deze goed genoeg om zweet af te voeren. Te goed misschien. Of je het nu draagt of niet, het maakt geen verschil.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Zoth Meisje Hoed",t:16,d:"De hoed van Zoth meisje heeft de vreemde gewoonte om haar dingen dubbel te laten zien, wat verklaart waarom ze lispelt...",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Zoth Krijger Helm",t:16,d:"Deze helm heeft dezelfde voordelen als andere Zoth hoeden – het beschermt je tegen de zon ongeacht hoe heet het is, tegen slagen op je hoofd, en het voorkomt dat de drager ervan zich bewust is van gevaar door zijn gezichtsveld te belemmeren. Hoe dan ook, het perfecte hoofddeksel voor een krijger.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Zoth Meester Hoed",t:16,d:"De Zoth Meester hoed heeft het geweldige voordeel dat hij het gezichtsveld nog meer belemmert dan andere helmen. Dankzij die hoed kun je de beroemde vechttechniek genaamd “wezel” gebruiken. Botweg gezegd, je hoeft alleen maar in het rond te slaan met je kracht. Dan wordt je compleet onvoorspelbaar en weet je zeker dat je je vijanden verlaat (of in elk geval om ze zo te verrassen dat je ze goedgerichte slagen kunt toebrengen).",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Barkritter Wortel",t:4,d:"Deze stok is een stevig favoriet bij de koffer-vrouwen. Maar het zal ongetwijfeld welk meisje dan ook verleiden. Waarschijnlijk.",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Floramor Wortel",t:4,d:"Als je bijgelovig bent en altijd moet afkloppen aan hout, kies deze Floramor Wortel! Aan de andere kant kun je ook voorzichtig zijn en proberen niet de tak door te zagen waar je op zit en vooral niet je vingers in de weg houden!",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"Gedragen Schatkaart",t:24,d:"Shika gebeurtenis",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"Crack Sparrow\'s Eigen Verdorde Hoed",t:16,d:"Je zegt dat een kraken, met de meest bedorven adem ooit, je overal zal volgen? Nou, ga er maar mee om: het is slechts een kleine belemmering dat de hoed met zich meebrengt!",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"Sharkal Schild",t:82,d:"Dit schild is zeker een goede bescherming, maar laat je niet voor de gek houden. Hij zal het niet lang houden.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Bherbal Bherb Riem",t:10,d:"Als Bherb vlinders heeft, draagt hij zijn Bherbaalse riem en schakelt ze gezond uit.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Laarzen Kwish",t:11,d:"Deze laarzen maken een walgelijk zuigend geluid bij elke stap die je zet, wat je doet herinneren aan de liefdesliederen van een krolse Trool, als je dat ooit gehoord hebt. Een pijnlijke herinnering waar je makkelijk zonder zou kunnen.",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"Mopy Koning Soeverein Zegel",t:9,d:"Deze zegel geeft aan dat de eigenaar is de ongetwijfelde beheerser van het Bodemloze Veen Moeras van Otomai\'s Eiland. Het is moeilijk voor te stellen dat er een landelijker koninkrijk is als dit.",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Koraal Ring",t:9,d:"Deze ring is van de nog steeds warme vinger van een net geslachte Coralator getrokken. Zijn moeder verwachtte hem vor diner, totdat ze zag dat hij was veranderd in een grafsteen. Koraal is niet altijd zo versteend in het hart als men denkt.",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Ronde Kimbo Sandalen",t:11,d:"Enkel Kimbos, met hun gekke voeten, voelen zich comfortabel in deze sandalen. Zij zijn echter niet de enigen die voordeel kunnen trekken uit de krachten van de sandalen. Maar wees voorzichtig, draag ze niet verkeerd om!",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Parkinn Pan Pikokowal Riem",t:10,d:"Parkinn Pan geloofde echt dat hij door deze met Pikoko vleugels getrimde riem kon vliegen, maar hij wist niet dat slechts een enkele Pikoko kon vliegen. Daarom stortte hij elke keer dat hij van de Boom Keeholo afsprong, systematisch neer. Zijn bijnaam “Koek” komt van “zo plat vallen als een pannenkoek”.",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothulet",t:1,d:"Dit amulet is gewoon een stuk hout met een stuk gescheurd weefsel. Maar Zoths zijn er van overtuigd dat het krachten heeft. Oude gekken!",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Slakmet Boog",t:2,d:"Deze boogpees is gemaakt van Slakmet slobber, niet te droog met een unieke elasticiteit. Echter, zijn slijmerige en kleverige textuur doet je herinneren aan... nou ja, niets eigenlijk, maar het is aardig onplezierig.",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Slakmet Ring",t:9,d:"Deze ring is uitgesneden uit Slakmet carapace en kan iedereen en alles weerstaan.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Krachtige Verblindende Mantel",t:17,d:"Deze van Zoth weefsels geweven cape heeft een buitengewone kracht van een onbekende oorsprong.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Moopet Cape",t:17,d:"Met deze cape op heb je zin in wat azijn.",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Cheeken Bijl",t:19,d:"De Cheeken Snavel op dit wapen is totaal nutteloos, en is meer een handicap dan wat anders. Gelukkig is hij vrij krachtig.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Houten Treeckler Laarzen",t:11,d:"Deze laarzen zijn zo zwaar dat ze in de categorie wapens zouden moeten vallen. Inderdaad, ze maken de lichtste schop dodelijk.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Donkere Treeckler Riem",t:10,d:"Deze riem, gekerfd in een Donkere Treeckler, is niet buigzaam genoeg om je vrij te laten in al je bewegingen, maar het beschermt je tenminste goed.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Lichte Treeckler Riem",t:10,d:"Uitgesneden uit een Lichte Treeckler, deze riem beschermt je niet goed, maar hij is tenminste buigbaar genoeg om je ruimte te geven in je bewegingen.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Ring Dikuloos",t:9,d:"Deze sieraad is niet geliefd maar heeft de perfecte maat om de moorgale te doseren in een belgroot, op smaak gemaakt met een beetje Glaviooze.",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Krabelt",t:10,d:"Eindelijk een goed excuus om de zee te ruiken!",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Ouassulet",t:1,d:"Deze sieraad probeert soms voedsel van je te stelen als je aan het eten bent, dus laat hem niet te laag hangen.",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Inkt Sluier",t:17,d:"Deze vreemde cape lijkt van zwarte inkt gemaakt te zijn, maar vreemd genoeg gedraagt het zich als weefsel – het rent niet. Wat de vlekken betreft, dat is een ander verhaal. Je achterkant zal nooit meer schoon zijn,",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Kringlove",t:9,d:"Eenmaal om je vinger, zul je hem nooit meer af kunnen krijgen. De zuignappen zijn veel te sterk.",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kidommer",t:7,d:"Deze hamer is niet handig, niet echt mooi, niet erg ergonomisch, niet krachtig, te licht, te breekbaar, ongebalanceerd, te schitterend en stinkt. Maar hij heeft tenminste mooie kleuren.",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
I.u[8879] = {n:"Gepolijste Ring",t:9,d:"Helaas is deze ring enkel aan de buitenkant gepolijst. Je stopt je vinger in een gat met scherpe rots fragmenten. Het wordt aangeraden voor Sacriers.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Amufafah",t:1,d:"Deze ketting zorgt ervoor dat de drager ervan wil schreeuwen... de Mufafah snor hangt laag en kietelt de tepels constant.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Solo\'s Ring",t:9,d:"Solo was een aardige goed-voor-niks, zoals hij zichzelf omschreef. Maar daardoor ontsprong hij de dans niet, toen hij publiekelijk werd opgehangen in het centrum van het dorp omdat hij het slipje van de vrouw van het opperhoofd had gestolen. Solo was niet echt slim, maar hij was wel erg aardig...",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Gilde Huis Drankje",t:12,d:"Dit drankje zorgt ervoor dat je terug kan gaan naar je gilde huis.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Tabby Bow Meow Geest",t:90,d:"Deze Tabby Bow Meow heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Tabby Bow Meow Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8887] = {n:"Bow Kennel Certificaat voor: Tabby Bow Meow",t:77,d:"Dit certificaat omschrijft de karaktereigenschappen van de Tabby Bow Meow die je in de Bow Kennel hebt gezet.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8888] = {n:"Bow Kennel Certificaat voor: Schadelijke Eekhoorn",t:77,d:"Dit certificaat beschrijft de karakteristieken van de Schadelijke Eekhoorn die je in de Bow Kennel hebt gestopt.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8889] = {n:"Bow Kennel Certificaat voor: Leopardo",t:77,d:"Dit certificaat omschrijft de karaktereigenschappen van de Leopardo die je in de Bow Kennel hebt gezet.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8890] = {n:"Tabby Bow Meow Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals een paar genezende Eniripsa poeders.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
