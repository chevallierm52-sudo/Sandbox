I.u[7396] = {n:"Voorspoed",t:29,d:"Deze zegening verhoogt je Waterweerstand gedurende de komende gevechten.",ep:18,g:10,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7397] = {n:"Inzicht",t:29,d:"Deze zegening verhoogt je Vuur weerstand gedurende de komende gevechten.",ep:18,g:9,l:1,wd:true,fm:true,w:0,m:true,p:1};
