I.u[7493] = {n:"Vaster van de Sieraadmagus",t:5,d:"Deze vaster maakt de sieraden die je hebt gecreëerd nog verblindender.",ep:2,g:52,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=63",p:1000};
I.u[7494] = {n:"Kleermaker Magus Naald",t:20,d:"Met deze magische naald kun je de kwaliteit van je ontwerpen behoorlijk verbeteren.",ep:9,g:23,l:1,wd:false,fm:true,w:1,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=64",p:1000};
I.u[7495] = {n:"Schoenmagiër Leder Snijder",t:5,d:"Deze magische Leder Snijder staat je toe om leder te snijden en huid beter af te schrapen. Het is een ideaal gereedschap om oude laarzen en riemen te verbeteren.",ep:2,g:53,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=62",p:1000};
I.u[7496] = {n:"Drankje van Massale Wederopstanding",t:14,d:"Met dit drankje kun je alle geallieerden om je heen tot leven wekken.",ep:0,g:60,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7497] = {n:"Drankje van Massale Vrijheid",t:14,d:"Met dit drankje kun je de zielen van je vijanden vrij laten, je stuurt ze dan direct naar hun graf en zorg je er voor dat ze niet opnieuw tot leven gewekt kunnen worden.",ep:0,g:59,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7498] = {n:"Klein Gifdrankje van Enorme Genezing",t:14,d:"Dit drankje geneest alle gealliëerden op de kaart.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"Pg>23,2",u:true,p:10};
I.u[7499] = {n:"Dorps Drankje: bij de Ijs Kwaks\'",t:12,d:"Dit drankje teleporteert je naar het Ijs Kwak Dorop, als je dat bezit.",ep:0,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7500] = {n:"Dorps Drankje: bij de Vuur Kwaks\'",t:12,d:"Dit drankje teleporteert je naar het Vuur Kwak Dorp, als je dat bezit.",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7501] = {n:"Dorps Drankje: bij de Wind Kwaks\'",t:12,d:"Dit drankje teleporteert je naar het Wind Kwak Dorp, als je dat bezit.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7502] = {n:"Drankje van Verzamelen",t:12,d:"Met dit drankje kun je een verzamelpunt maken. Hier kunnen avonturiers zich verzamelen om met jou een dorp te verdedigen of aan te vallen. Dit magische rankje zorgt er ook voor dat de mensen die met jou mee gaan op avontuur, hun positie kunnen opslaan en vanaf dat punt weer snel kunnen starten.",ep:0,g:21,l:1,wd:false,fm:true,w:1,p:1};
I.u[7505] = {n:"Beroepsvergeetdrankje: \'Kleermagus\'",t:44,d:"Door dit drankje vergeet je het beroep van Kleermagus.",ep:9,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7506] = {n:"Beroepsvergeetdrankje: \'Juweliermagus\'",t:44,d:"Door dit drankje vergeet je het beroep van Juwemagus",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7507] = {n:"Beroepsvergeetdrankje: \'Schoenmagus\'",t:44,d:"Door dit drankje vergeet je het beroep van Schoenmagus",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7508] = {n:"Handtekening Rune",t:50,d:"Met deze rune kunnen toegewijde kunstenaars hun creaties signeren.\n(te gebruiken bij het maken van een voorwerp in aanvulling op de ingrediënten)",ep:18,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[7509] = {n:"Eerste Deel van de Draak Varken Doolhof Sleutel",t:84,d:"Als deze snuit je niet aanspreekt, probeer er dan niet iets van te maken. Je zult de hele terugweg geslagen worden.",ep:13,g:1,l:1,wd:true,fm:true,w:1,p:100};
I.u[7510] = {n:"Tweede deel van de Draak Varken Doolhof Sleutel",t:84,d:"Dit stuk is mogelijk een deel van de sleutel die de schatkist opent waar je altijd van droomde. Het is misschien ook de sleutel van je graf.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[7511] = {n:"Draak Varken Doolhof Sleutel",t:84,d:"Als je denkt dat deze sleutel je vieze varkensvrienden zal aantrekken, snap je het niet echt... Het opent enkel de kooi van het Draak Varken.                                                      Wees voorzichtig, na gebruik vernietigt het zichzelf.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:100};
I.u[7512] = {n:"Varkens Geest",t:24,d:"Deze trofee getuigt van je liefde voor varkens. Vergeet evenwel niet te douchen voordat je terug gaat naar je vrouw als je niet in het hok bij de Veelvraten wil slapen.",ep:1,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[7513] = {n:"Sandaal Titude",t:11,d:"Titude, een bescheiden Enutrof Schoenmaker, was nog kleiner dan een Xelor.  De legende vertelt dat hij deze sandalen gemaakt heeft om zo zijn geliefde vrouw, een beenloze Eniripsa, op de lippen te kussen.",ep:20,g:67,l:122,wd:true,fm:true,w:10,p:37800};
I.u[7514] = {n:"Harry\'s Laarzen",t:11,d:"Harry was een oude wijze, die zijn dagen doorbracht met vissen op de kades van Sufokia. Zijn grote snor deed hem een beetje lijken op Danous Kwaide, beroemd acteur van een theatergezelschap dat regelmatig in de herberg van Amakna optrad. Dit was enkel een inleiding voor de grootse bier- en vleesballenorgies.",ep:20,g:70,l:123,wd:true,fm:true,w:10,p:37850};
I.u[7515] = {n:"Itaineflam Cape",t:17,d:"Deze cape komt niet van jouw universum en toch schijnt hij zeer goed te passen bij de kleur van je Vreetzakjeswollen netkousen.",ep:20,g:92,l:148,wd:true,fm:true,w:10,p:47925};
I.u[7516] = {n:"Bimd\'Oule Hoed",t:16,d:"Een oude Enutrof, bekend onder de naam van Dhy-Ah-Mhanhd, verbitterd door eeuwen van tegenslag, ontdekte als eerste deze verschrikkelijk hoed, verborgen in een alkoof in de grotten van Bimd\'Oule. Later ging hij in ballingschap ver weg van Amakna om te ontkomen aan verveling en om nieuwe horizonten te ontdekken. De legende vertelt dat hij één keer per eeuw terugkeert naar zijn geboortegrond om de spot te drijven met zijn oude vrienden, maar vooral uit nostalgie.",ep:20,g:121,l:110,wd:true,fm:true,w:10,p:31675};
I.u[7517] = {n:"Ripate Bier",t:37,d:"Dit bier is zo zuur, dat de pul waarin het wordt geserveerd de levensverwachting heeft van een Moskito.",ep:7,g:4,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7518] = {n:"Fotome",t:18,d:"Dit verrassende wezen komt uit het hiernamaals en zal er niet naar terugkeren, behalve als je hem er, ongelukkiger wijze, naartoe begeleidt...",ep:3,g:13,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7519] = {n:"Roze Draakje",t:18,d:"Dit draakje heeft een roze huid net als de billen van een vrouwtjes Bwork. \nEen goede manier om tegen lage kosten en zonder risico te fantaseren, of om gewoonweg goede herinneringen op te halen. Gelukkig is dit draakje niet alleen het voorwerp van je fantasie, maar het is vooral een zeer krachtig en wijs wezen. Let echter wel op, want zijn vraatzucht is net zo groot als de perversiteit van een Chafer tijdens volle maan, en het eet alleen maar andere huisdieren.",ep:3,g:14,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7520] = {n:"Croum",t:18,d:"Een gepensioneerde tinnen soldaat, een metalen wezen dat weer tot leven is geroepen. Hij volgt je overal en zal alles doen om je te verdedigen met gevaar voor eigen leven, als je hem maar regelmatig te eten geeft. Maar verwacht niet dat hij alle slagen in jouw plaats opvangt, hij vervangt dus niet de beginnende avonturiers van Astrub.",ep:3,g:15,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7521] = {n:"Cadeau Fotome",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden, voedsel en Eniripsapoeder om het te verzorgen.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7522] = {n:"Minimino",t:18,d:"Deze tamme en schoongemaakte baby Minotoror kan worden benaderd en geaaid zonder het risico een hand te verliezen. Blijf echter voorzichting, want soms herneemt de natuur zijn rechten en kan het vernietigende instinct van dit wezen weer naar boven komen op een moment dat je op hem rekent. Om slechte ervaringen te voorkomen, voed hem net als je eigen kinderen op met stokslagen.",ep:3,g:21,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7523] = {n:"Gember Meowette",t:18,d:"Geen tomcat kan dit lieflijke rossige beest weerstaan... zelfs niet de gelukkist getrouwden van ze!                           (DIT LEGENDARISCHE HUISDIER HOEFT NIET TE ETEN).",ep:1,g:40,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7524] = {n:"Tabby Bow Meow",t:18,d:"Dit verrassende beest is het resultaat van een kruisfok tussen een Witte Bow Meow en een Zwarte Bow Meow. Hij eet enkel vis.",ep:3,g:41,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7525] = {n:"Cadeau Rose Draakje",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden, voedsel en Eniripsapoeder om het te verzorgen.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7526] = {n:"Croum Cadeau",t:89,d:"Als je dit cadeau bij je oor houdt of als je het hevig heen en weer schudt, zul je misschien vreemde geluiden horen die wijzen op de aanwezigheid van een nog levend wezen. Wacht niet langer, maak het snel open. Je zult er een fantastisch huisdier aantreffen, en ook een handboek over zijn opvoeding, voedsel en Eniripsa poeder om hem te verzorgen.\n(LET OP, dit cadeau bevat een zwaar voorwerp, het kan zijn dat je boven het toegestane gewicht komt als je het opent, zorg er dus voor dat je je bevrijdt van wat zware voorwerpen of vraag een vriend je te helpen.)",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7527] = {n:"Cadeau Minimino",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden, voedsel en Eniripsapoeder om het te verzorgen.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
