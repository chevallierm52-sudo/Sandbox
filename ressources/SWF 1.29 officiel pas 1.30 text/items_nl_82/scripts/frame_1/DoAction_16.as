I.u[7550] = {n:"Geest van Croum",t:90,d:"Deze Geest heeft de wereld van de levenden nog niet verlaten, het hangt van jou af om een manier te vinden om hem weer tot leven te wekken, of hem voor eens en voor altijd lafhartig in de steek te laten.",ep:3,g:15,l:1,wd:true,fm:true,w:1,p:1};
I.u[7551] = {n:"Minimo Geest",t:90,d:"Deze Minimino Geest heeft de wereld der levenden nog niet verlaten, hij wacht op jou om hem weer tot leven te brengen of het eens en voor altijd lafhartig achter te laten.",ep:3,g:16,l:1,wd:true,fm:true,w:1,p:1};
I.u[7552] = {n:"Kalkocape",t:17,d:"Soms als een krijger en een Drakokalkoen paren, kunnen er vreemde dingen gebeuren.\nDeze cape is daarvan het levende bewijs, want er zijn Drakokalkoenveren op genaaid. De Drakokalkoen die zich voor deze cape heeft opgeofferd, heeft hem gegeven aan de beroemde minstreel Pol Akartney, op hun trouwdag. Blijkbaar heeft Moco Prostato er zelfs een liedje over geschreven.",ep:2,g:90,l:50,wd:true,fm:true,w:5,s:42,p:25000};
I.u[7553] = {n:"Kalkoenhoed",t:16,d:"Als je er altijd van hebt gedroomd om op een Drakokalkoen te lijken, dan is het nu of nooit. Maar als je leven je lief is, dan raden we je aan om gedurende de kerstperiode er niet mee door de straten van Amakna te lopen.",ep:2,g:118,l:50,wd:true,fm:true,w:10,s:42,p:15000};
I.u[7554] = {n:"Kalkoenlaarzen",t:11,d:"Je vriendinnen zullen jaloers zijn op deze laarzen. Deze laarzen brengen je naar het feest van de ambassadeur om een van die schitterende kleine gouden chocolaatjes te bemachtigen.",ep:2,g:65,l:50,wd:true,fm:true,w:3,s:42,p:5000};
I.u[7555] = {n:"Kalkoring",t:9,d:"Dankzij deze ring zullen je vrienden over je zeggen: \"Ze lijkt echt sprekend op een kalkoen\".",ep:2,g:97,l:50,wd:true,fm:true,w:1,s:42,p:1000};
I.u[7556] = {n:"Kalkoe Cadeau",t:89,d:"Dit cadeaupakket bevat een deel van een beroemde vermomming. Daarmee worden je vrienden de Drakokalkoenen groen van jaloezie.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7557] = {n:"Sleutel van de Boomchnid Toren",t:84,d:"Deze sleutel van Boomchnidschors kan wortel schieten als je hem op een warme vochtige plek legt, net als bijvoorbeeld een Bworkonderbroek.",ep:1,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[7558] = {n:"Bworky Haar",t:24,d:"Deze haren blijven niet lang in je tas... In ieder geval dat is te hopen voor je.",ep:14,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[7559] = {n:"Goudoriem",t:10,d:"Men zegt dat deze riem, toen zijn eerste eigenaar hem omdeed, hij iedere keer tegen zichzelf keerde. Wat maar weer bevestigt dat je wel een beetje gestoord moet zijn om zo´n ding te dragen.",ep:22,g:85,l:164,wd:true,fm:true,w:0,p:48200};
I.u[7560] = {n:"Rune Ree Pareer Water",t:78,d:"Met deze rune kan je de elementaire schade van het type Water absorberen.",ep:1,g:31,l:10,wd:true,fm:true,w:1,p:10};
