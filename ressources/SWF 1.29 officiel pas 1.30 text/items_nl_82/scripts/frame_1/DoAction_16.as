I.u[7124] = {n:"Dofus met melk",t:42,d:"Dit Dofus-ei bezit een vermogen zonder weerga: je te laten kwijlen van geluk.",ep:1,g:27,l:1,wd:false,fm:true,w:1,p:1};
I.u[7125] = {n:"Dofus met witte chocola",t:42,d:"Dit Dofus-ei bezit een vermogen zonder weerga: je te laten kwijlen van geluk.",ep:1,g:28,l:1,wd:false,fm:true,w:1,p:1};
I.u[7126] = {n:"Mini Dofus-eitjes",t:42,d:"Deze eitjes zijn rood, groen en zelfs blauw, en hebben een vreemde onbeschrijfelijke smaak. Je hoeft ze slechts te proeven om niet als een gek te sterven.",ep:0,g:29,l:1,wd:false,fm:true,w:1,p:1};
I.u[7127] = {n:"Dofus Schelpen",t:42,d:"...",ep:1,g:30,l:1,wd:false,fm:true,w:1,p:1};
I.u[7128] = {n:"OkaRinga",t:9,d:"In tegenstelling tot wat sommigen denken, heeft deze ring niets te maken met de mooie Karin, die meerdere malen op exotische wijze optrad in de piratenbar van Sufokia. Eigenlijk heeft een musicus die Tofus fokt deze naam aan deze ring gegeven. Als je hem eenmaal om je duim hebt gedaan, maakt hij een geluid dat lijkt op een stervende Tofu.",ep:18,g:89,l:54,wd:true,fm:true,w:5,p:7700};
I.u[7129] = {n:"Chocolade Panda",t:42,d:"Vergis je niet, het is niet alleen de chocola die de smaak geeft, de vorm van het lekkers draagt ook zijn steentje bij aan de smaak. Proef maar eens een chocolade Ouassingue, dan begrijp je het misschien beter.",ep:0,g:31,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[7130] = {n:"Recept van chocolade Dofus",t:24,d:"Het recept van chocholade Dofus, een must om je vrienden mee te verbluffen.",ep:1,g:250,l:1,wd:false,fm:true,w:0,p:100};
I.u[7131] = {n:"Opiom Ring",t:9,d:"Menig avonturier voor jou heeft gedroomd van dit sieraad. Men dicht het enorme deugden toe, zoals bijvoorbeeld het veranderen van de meest oorlogszuchtigen in rustige dromers. De handleiding vermeldt duidelijk dat het niet wordt aangeraden hem in het vuur te werpen, maar niet het waarom.",ep:16,g:90,l:57,wd:true,fm:true,w:5,p:8475};
I.u[7132] = {n:"O\'Ring Ami",t:9,d:"Deze ring ontleent zijn naam aan de laatste woorden van zijn maker : \"O\'Ring, Ami!\" riep hij met een vreselijk vermakelijk gereutel van pijn. Het is belangrijk te constateren dat de vervaardiging van deze Bamboe-ring dateert van voor de komst van Bamboe . Nog een raadsel dat de komende decennia niet zal worden ontrafeld.",ep:16,g:96,l:49,wd:true,fm:true,w:5,p:6300};
I.u[7133] = {n:"Mixomawose",t:30,d:"Iedere Wabbit zal het je zeggen, als je het leven niet door een rode bril wil zien, vermijd dan als de pest de Mixomawose.",ep:1,g:9,l:1,wd:false,fm:true,w:0,p:1};
I.u[7134] = {n:"Woede",t:30,d:"Men zegt dat woede de getroffen personen totaal verandert. Strijdlustige personen worden meegaand, en rustige personen worden agressief. Daarentegen zullen zij die daarvoor al kwijlden dat nog steeds blijven doen.",ep:1,g:10,l:1,wd:false,fm:true,w:0,p:1};
I.u[7135] = {n:"Maloria",t:30,d:"Maloria, ziekte die verspreid wordt door de Moskitos (Muskieten) die in de gebieden leven met een tropisch klimaat, wordt ook wel Molaria genoemd door sommige inheemse personen, want de ziekte schijnt ook overgebracht te worden door Moskitospuug.",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[7136] = {n:"Medaikido",t:1,d:"Deze medaille behoorde toe aan een beroemde Pandawa, meester van een oude oosterse gevechtsschool die zijn leerlingen leerde zich te verdedigen door gebruik te maken van de kracht van hun tegenstander. Zijn school werd uiteindelijk gesloten omdat zijn tegenstanders niet meer sterk genoeg waren.",ep:19,g:89,l:125,wd:true,fm:true,w:10,p:40425};
I.u[7137] = {n:"Huccino Cape",t:17,d:"Deze cape was maar om één reden met de hand genaaid: om een cape te maken die drager ervan dagen achtereen wakker zou houden. En dit is het resultaat: hij is zo hard en onbuigzaam dat hij je in alle omstandigheden rechtop houd. Pas echter wel op, want je kunt dan niet meer je veters strikken.",ep:16,g:15,l:44,wd:true,fm:true,w:15,p:5300};
I.u[7138] = {n:"Ortiz",t:17,d:"Deze cape is gedragen door de grootsten ter wereld, en staat vooral bekend om zijn legendarische zachtheid, waardoor hij zonder ondergoed gedragen kan worden tijdens warme dagen. Een geraffineerde vorm van exhibitionisme waardoor meer dan één persoon verleid is.",ep:19,g:91,l:125,wd:true,fm:true,w:15,p:40175};
I.u[7139] = {n:"Sloot Riem",t:10,d:"Sula de schoenmaakster hield ervan te flaneren door de velden op zoek naar een onmogelijke liefde. Omdat zij dit niet vond, stierf ze toen ze in een grote met vuilnis gevulde sloot viel, dicht bij het Varkens Gebied. Haar lichaam werd pas 70 jaar later gevonden, toen de sloot werd geleegd. Haar broer zou toen hebben geroepen :  \"Ik heb altijd gedacht dat ze ergens moest zijn\", net voordat hij zelf in de sloot viel.",ep:19,g:82,l:125,wd:true,fm:true,w:15,p:39975};
I.u[7140] = {n:"Xenature",t:10,d:"In tegenstelling tot haar verschijning, was Xena geen strijdster, maar een schoenmaakster. Door haar rijkelijke vormen en haar ongelimiteerde passie voor huishoudelijk werk was een schitterende carriere in de café-restaurants van Amakna voor haar voorbestemd. Het lot heeft anders beslist.",ep:19,g:83,l:125,wd:true,fm:true,w:15,p:40125};
I.u[7141] = {n:"Holoone",t:16,d:"Deze vreemde hoed zal je tegen zonnestralen beschermen, zelfs \'s nachts. Pas op, eens in de drie decennia komt hij weer tot leven en keert hij zich tegen zijn meester door te proberen hem te laten stikken in zijn slaap.",ep:19,g:111,l:122,wd:true,fm:true,w:10,p:37925};
I.u[7142] = {n:"Paruik",t:16,d:"Deze hoed werd gebruikt door bepaalde Xelors, om hun beginnende kaalheid te verbergen. Sommige Enutrofs gebruikten hem zelfs om hun vrouw te verbergen. Een handige manier om twee grote problemen van het alledaagse leven te verbergen.",ep:19,g:112,l:145,wd:true,fm:true,w:15,p:46980};
I.u[7143] = {n:"Solomonk",t:16,d:"De Solomonk was de hoed van een oude chef van een Pandawa-stam, expert in het maken van laxerende drankjes. De bewuste Pandawas waren vaak genoodzaakt de effecten van hun drankjes op zichzelf uit te proberen, waarbij ze dit type hoed gebruikten. Dit ware goeie vervangers voor de po.",ep:19,g:123,l:120,wd:true,fm:true,w:50,p:36880};
I.u[7144] = {n:"Bruidssluier",t:16,d:"Deze bruidssluier is al lang uit de mode, waarschijnlijk vanwege het kantwerk uit een andere eeuw. Gerecycled als onderbroek en indien gedragen op een goed behaard hoofd, zou het toch de meest onverschillige Chafer in vervoering moeten kunnen brengen.",ep:19,g:116,l:108,wd:true,fm:true,w:15,p:29775};
I.u[7145] = {n:"Gaddie Muts",t:16,d:"De Gaddie, een vreemd wezen uit een denkbeeldige wereld, staat vooral bekend om zijn buitengewone listigheid, zijn totale aversie voor alles wat vegetaal is en zijn vermogen om in oorlogstijd gedurende meerdere dagen te vasten. Een dergelijk moeilijk te begrijpen wezen was vanzelfsprekend onmogelijk om te overmeesteren. Men liet het dus in alle rust leven in de bodemloze mijnen van Kruup, waar het kennismaakte met een oude Liche, verslindster van Veelvraten.",ep:19,g:115,l:106,wd:true,fm:true,w:15,p:26375};
I.u[7146] = {n:"Berthusalem",t:16,d:"Deze superkrachtige muts lijkt meer op een pruik dan iets anders, maar dat doet er niet toe, de muts is superkrachtig. Inderdaad zijn eigenaar hield ervan zich te verkleden en zich voor te doen als iemand anders, teneinde beter te kunnen profiteren van naïeve personen. Zijn rare lugubere spelletjes werden uiteindelijk ontdekt, net als zijn schedel, toen zijn muts afging. Zijn onmetelijke acteertalent redde hem het leven, want hij stelde enkele dagen voor zijn dood voor om een enorm beeld te maken van de intieme delen van de Moowolf. Hij kwam na het voltooien van het beeld alsnog op de brandstapel terecht.",ep:18,g:114,l:81,wd:true,fm:true,w:10,p:16925};
I.u[7147] = {n:"Stuk Melkchocola",t:42,d:"...",ep:0,g:32,l:1,wd:true,fm:true,w:1,p:1};
I.u[7148] = {n:"Stuk witte chocola",t:42,d:"...",ep:1,g:33,l:1,wd:false,fm:true,w:1,p:1};
I.u[7149] = {n:"Stuk Zwarte Chocola",t:42,d:"Dit stuk chocola, gemaakt van pure cacao, smaakt overheerlijk. Pas op dat je er niet teveel van eet, anders krijg je last van je darmen.",ep:1,g:34,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:200};
I.u[7150] = {n:"Cruk",t:16,d:"Deze hoed met een vreemde naam was ooit van een arme Ecaflip, die niet meer kon praten na een verschrikkelijk trauma. Artiest in hart en nieren, werd hij gedwongen een opleiding tot bierbrouwer te volgen. Hij verdronk in een met bier en tranen gevuld vat, toen hij ongeveer veertien jaar was. Gelukkig was het bier daardoor niet verloren, want de priester die verantwoordelijk was voor de begrafenis raakte gedurende enkele jaren door de alcohol in een coma, waarna hij zijn dienst weer voortzette daar waar hij gebleven was.",ep:19,g:109,l:111,wd:true,fm:true,w:20,p:31725};
I.u[7151] = {n:"Reuss",t:16,d:"De advertentie voor deze helm luidde : \"Deze indrukwekkende kleihelm maakt van u een reus met kleien hoofd\". Na een diepgaand onderzoek kom je tot de conclusie komen dat het niet gemaakt is van klei, maar van lood. Vandaar het lood, in het kader van de kosten drukken",ep:19,g:108,l:120,wd:true,fm:true,w:15,p:36925};
I.u[7152] = {n:"Kanistere",t:16,d:"Deze hoed in de vorm van een kuip werd door de brandweermannen van Amakna gebruikt bij branden in de graanakkers. Tegenwoordig wordt hij vooral gebruikt door Bierbrouwers en serveersters die wandelende vaten zijn geworden.",ep:19,g:110,l:120,wd:true,fm:true,w:20,p:36675};
I.u[7153] = {n:"Hubohu Hamer",t:7,d:"Deze enorme hamer maakt een ongelooflijk geluid als hij op het hoofd van een Iop neerkomt, want hij heeft de neiging de nagalm te versterken. Verbazingwekkend maar vreselijk doeltreffend.",ep:19,g:51,l:126,wd:true,fm:true,w:15,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>200",p:40200};
I.u[7154] = {n:"Speelgoed Hamer",t:7,d:"Deze lichte hamer was in principe bestemd voor kleine wezens;\r\n            de Xelors gebruikten de steel en de Arachnees kregen de hamer op hun kop. Als snel werd hij voor iets anders gebruiken en dient nu als speelgoed voor de jonge Iop doe-het-zelvers.",ep:18,g:46,l:107,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>350&CV>200&CW>100",p:29475};
I.u[7155] = {n:"Donderse Hamer",t:7,d:"De beroemde Kapitein Hardrock heeft deze verschrikkele hamer gedurende tientallen jaren gebruikt om iedereen die hem in de weg stond een kopje kleiner te maken, vrouwen en kinderen incluis. Zijn legendarisch slechte karakter en zijn voorliefde voor alcohol maakte hem toch tot een gerespecteerd persoon binnen de verschillende legeronderdelen, zowel vijanden als bondgenoten.",ep:18,g:48,l:113,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,40,60,false,false],c:"CI>150&CW>100&PG=5",p:32650};
I.u[7156] = {n:"Rosterd Hamer",t:7,d:"Deze roestige hamer is uitstekend geschikt om esdoorns te splijten of  Moskitos.",ep:18,g:50,l:107,wd:true,fm:true,w:20,an:15,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>150&CV>150&(PG=2|PG=5)",p:334251};
I.u[7157] = {n:"Klok Hamer",t:7,d:"Deze hamer werd vroeger gebruikt om de kerkklok van Amakna te luiden. Vandaag de dag dient hij nog steeds om muziek te maken door bijvoorbeeld de botten van onvoorzichtigen te verbrijzelen.",ep:19,g:49,l:124,wd:true,fm:true,w:15,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CI>250",p:29400};
I.u[7158] = {n:"Bajus Hamer",t:7,d:"Deze hamer, gemaakt door een bekende alchemist tijdens een verblijf in de gevangenis van Brakmar, was bedoeld om de alchemisteninstrumenten van zijn concurrenten kapot te slaan.",ep:19,g:47,l:143,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CA>250&PG=5",p:46550};
I.u[7159] = {n:"Berg Hamer",t:7,d:"Deze mijnwerkershamer kan worden gebruikt zowel als schep en als houweel. Het is verboden hem te gebruiken om te tuinieren, want hij verwoest het gras voorgoed.",ep:19,g:52,l:135,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>300",p:41200};
I.u[7160] = {n:"Soeze Boog",t:2,d:"Deze boog is lang geleden betoverd met een onduidelijke betovering. Genoeg om zowel zijn eigenaar als diens vijanden ongerust te maken.",ep:19,g:44,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CI>400&PG=9",p:36900};
I.u[7161] = {n:"Fris Boog",t:2,d:"Deze boog wordt vooral gebruikt om op de Everzwijnen van de Vlaktes te jagen. Hij is zo krachtig dat hij met slechts een pijl meerdere everzwijnjonkies kan doden, op voorwaarde dat ze in het gelid staan.",ep:18,g:45,l:107,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CI>250&CA>150",p:29325};
I.u[7162] = {n:"Place Boog",t:2,d:"Deze boog was van een onafhankelijke minstreel die vooral beroemd was om het slopen van de oren van zijn vijanden met zijn strijdliederen. Hij werd gedurende een aantal jaren verbannen naar Pandala, omdat zijn liederen de Raven van Brakmar doof maakten. Na meerdere generaties Pandawas gek te hebben gemaakt, werd hij eenvoudigweg levend aan de grote Sorlok overgeleverd, om langzaam gedurende 752 jaar verteerd te worden. Hij ontdekte hier een nieuwe vorm van intens genot.",ep:19,g:46,l:130,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,3,6,30,50,false,true],c:"CA>200&CC>70&PG=9",p:30000};
I.u[7163] = {n:"Wegda Boog",t:2,d:"Deze boog werd voornamelijk gebruikt als afschrikwapen. Zijn eigenaar vertelde aan ieder die het maar horen wilde dat zijn pijlen vergiftigd waren, wat de lokale bevolking voldoende afschrikte. Zo wist hij alle lafhartigen die hem dwarsboomden terug te laten deinzen.",ep:19,g:47,l:124,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"PG=9&CA>250",p:39050};
I.u[7164] = {n:"Engelien Boog",t:2,d:"Deze lichte en zwakke boog heeft veel avonturiers voor zich gewonnen, die meer gaan voor het uiterlijk dan voor de doeltreffendheid",ep:19,g:48,l:143,wd:true,fm:true,w:15,an:10,e:[5,5,2,6,30,50,false,true],c:"CA>120&CI>120&CC>120&CV>300",p:46025};
I.u[7165] = {n:"Kili Stokaro",t:3,d:"Dit explosieve stokje is gedoopt in de lava van een uitbarstende vulkaan voordat het bewerkt werd. Het is vanzelfsprekend dat het veel kracht bezit, ondanks zijn  belachelijke uiterlijk.",ep:18,g:54,l:105,wd:true,fm:true,w:15,an:11,e:[5,4,3,6,50,50,false,true],c:"CI>300",p:28625};
I.u[7167] = {n:"Etcetera Stok",t:3,d:"De maker van dit stokje had veel leerlingen die hij lange dagen liet werken. Hij werd geacht hen de kneepjes van het vak bij te brengen, maar was een erg slechte leraar;\r\n            was hij eenmaal aan een uitleg begonnen, dan maakte hij die nooit af.",ep:18,g:50,l:43,wd:true,fm:true,w:5,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>60",p:5000};
I.u[7168] = {n:"Pinted Wand",t:3,d:"Ooit  uitgehakt, deze wand was gedrenkt in bier voor vele decennia \'om er wat magische krachten in te doen\', zoals de mensen die hem maakten zeiden. Helaas begon hij te rotten, maar hij heeft enkele magische aspecten... hij kan wormen de aarde uit lokken bijvoorbeeld. Houd je van vissen toevallig?",ep:18,g:51,l:63,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150",p:4800};
I.u[7169] = {n:"Vonk Stok",t:3,d:"Zeer geschikt om een vuur mee aan te steken of om saaie huwelijken nieuw leven in te blazen. Met deze stok kun je misschien één keer in je leven de vonken ervanaf laten spatten. Ik zou die kans grijpen.",ep:18,g:52,l:81,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>200",p:17000};
I.u[7170] = {n:"Creizy Stufh Stok",t:3,d:"Creizy de banketbakker was zo gek dat hij met de houthakster Stufh trouwde, en haar de volgende dag liet stikken in zijn veel te vette gebakjes. Sinds deze gebeurtenis spreekt men van het \"Creizy Stufh\", om rare, gekke gebeurtenissen weer te geven.",ep:18,g:46,l:112,wd:true,fm:true,w:15,an:11,tw:true,e:[5,2,3,4,30,50,false,true],c:"CI>350&CV>200",p:32330};
I.u[7171] = {n:"Verstrooide Stok",t:3,d:"De maker van deze stok had de vervelende gewoonte te vergeten zijn kinderen van school te halen. Zijn vrouw, net als vele anderen een ontaarde moeder, verheugde zich daarover. Omdat hij zich er bewust van was zo verstrooid te zijn, maakte hij deze stok die elke dag tot leven kwam en hem eraan herinnerde dat hij zijn kinderen moest halen. Vervolgens heeft hij geprobeerd een soortgelijke stok te maken om zijn vrouw eraan te herinneren dat ze het huishouden moest doen, maar deze stok was daar niet krachtig genoeg voor.",ep:19,g:47,l:127,wd:true,fm:true,w:15,an:11,tw:true,e:[10,4,4,6,40,60,false,true],c:"CI>300&CV>300",p:43125};
I.u[7172] = {n:"Snot Wand",t:3,d:"Deze magische wand wordt nog steeds gebruikt om septische tanks te legen, sloten schoon te maken en in neuzen te peuteren. De meeste geïnformeerde beeldhouwers kunnen je vertellen dat het alle magie van de viezigheid waar hij doorheen is gegaan verleend... in de realiteit komt het van de smurrie van je snoet.",ep:18,g:49,l:105,wd:true,fm:true,w:20,an:11,tw:true,e:[10,4,2,4,30,60,false,true],c:"CI>200&CW>50",p:28375};
I.u[7173] = {n:"Wurggghh Stok",t:3,d:"Deze verschrikkelijke stok kan zich om de nek van je tegenstanders wikkelen om ze zo langzaam maar zeker te wurgen. Een originele en voorname manier om tegenstanders die je een beetje respecteert, te doden.",ep:18,g:48,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,4,50,50,false,true],c:"CI>50",p:2100};
I.u[7174] = {n:"Pandawushu Cape",t:17,d:"Deze cape is onontbeerlijk voor de beoefening van Pandawushu...",ep:1,g:89,l:10,wd:true,fm:true,w:5,p:10};
I.u[7175] = {n:"Shamaans Certificaat",t:24,d:"Medisch certificaat dat onmisbaar is voor de praktijk van een Pandawushuka.",ep:18,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[7176] = {n:"Willei Wortel",t:4,d:"De maker van dit kleine wonder is een zekere Frank, stafsnijder van beroep. Je kunt er de hemel mee verduisteren en het bloed laten stromen van vijanden die geen bloed hebben. Men zegt dat hij er meer dan duizend uur aan heeft gewerkt. Dat laat zelfs je vijanden niet koud.",ep:19,g:53,l:143,wd:true,fm:true,w:15,an:12,e:[10,4,1,1,45,70,false,false],c:"CS>150&CV>400&CI>50&CA>50",p:46600};
I.u[7177] = {n:"Pandawushu Hoofdband",t:16,d:"Met deze Pandawushu Hoofdband om je hoofd geknoopt, kun je zonder moeite de jonge Lenalds bang maken, door je voor te doen als een Meester in oosterse gevechtsport. Vergeet niet om enkele oorlogskreten te slaan om nog geloofwaardiger over te komen.",ep:1,g:102,l:1,wd:false,fm:true,w:5,p:10};
I.u[7178] = {n:"Froot Wortel",t:4,d:"Als er niet zo onophoudelijk betoogd werd over of dit ding een vrucht of een wortel is, zou het een prima wapen zijn.",ep:18,g:58,l:86,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,50,50,false,false],c:"CI>150",p:19100};
I.u[7179] = {n:"Weg en pad :  Vervloekte Bos",t:25,d:"In dit boek staan de beste toeristische routes door het labyrint van het vervloekte bos... een Must! Tenminste, dat staat op de omslag.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7181] = {n:"Semilla Wortel",t:4,d:"Sémilla was een jonge Sadidette, die erg geïnteresseerd was in tuinieren en daarbij, een miserabele zangeres. Zij schepte er trouwens een ondeugend plezier in regelmatig harken te ontvangen, maar vreemd genoeg, veel minder schoppen.",ep:18,g:54,l:106,wd:true,fm:true,w:15,an:12,tw:true,e:[10,4,1,1,50,50,false,false],c:"CV>250&CW>60",p:28575};
I.u[7182] = {n:"Cha Tage Wortel",t:4,d:"Cha Tage had geen geluk, haar man was een grote nietsdoener, die niet in staat was zijn status als hoofd van de familie (waartoe hij toch was uitverkoren) gestand te doen. Zij moest hem telkens voorwaarden voorhouden: Je krijgt Aarbeiengelei als je het graan maait\" of zelfs \"Je mag roken als je de Veelvraats hebt geschoren\", om maar een paar bekende zinnen aan te halen.  Nauurlijk heeft dit verhaal niets te maken met de zeer krachtige wortel, tenzij hij jou ook chanteert...",ep:18,g:60,l:103,wd:true,fm:true,w:15,an:12,tw:true,e:[15,4,1,1,25,50,false,false],c:"CV>200",p:27280};
I.u[7183] = {n:"Huzohide Wortel",t:4,d:"Deze wortel heeft zuivere vormen, waarvan sommige ambachtslieden niet aarzelen deze als perfect te kwalificeren. Wellicht dat bepaalde avonturiers er meer waarde aan hechten dan aan hun geliefden.",ep:18,g:55,l:88,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>70",p:20000};
I.u[7184] = {n:"Ramp Wortel",t:4,d:"Deze vreselijke wortel is vooral bekend om zijn capaciteit om klimaatrampen op te roepen op de precieze plek waar hij gebruikt wordt. Vermijd het om je vijanden ermee rond te trappen... Het is misbruik waardoor jij en al je vrienden verbrand zouden kunnen worden tot chips, verdronken in een vloed, in stukjes geblazen, beneveld tot... nou ja, het laatste zou nog niet zo erg zijn, maar gebruik hem gewoon niet oké?",ep:18,g:56,l:86,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>100",p:18945};
I.u[7185] = {n:"Wortel \'Een",t:4,d:"Het gebruiken van deze wortel tijdens een gevecht zou erg makkelijk moeten zijn. Desondanks kan het gebeuren dat de wortel ineens tot leven komt en doet wat hij zelf wil... Dit is voornamelijk wanneer de eigenaar schreeuwt “Dit is niet de gewone Wortel \'Een, wel?”. Nou, het is inderdaad de gewone Wortel \'Een.",ep:18,g:57,l:103,wd:true,fm:true,w:20,an:12,e:[5,5,1,1,50,50,false,false],c:"CV>200&CW>150",p:27425};
I.u[7186] = {n:"Overgang van rang",t:24,d:"Op dit blaadje staat de laatste datum dat je bent overgegaan naar Pandawashuka-rang.",ep:18,g:58,l:0,wd:true,fm:true,w:0,p:1};
I.u[7187] = {n:"Boogris Jultsin",t:2,d:"Deze boog staat bekend om het in alle terughoudendheid en op afstand bestelen van het volk. Het meest verbazingwekkende is dat hij gedurende al die jaren toch heel erg populair is gebleven. Gelukkig voor het volk, begint deze boog te slijten.",ep:19,g:50,l:124,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,4,6,30,2,false,true],c:"CA>100&CC>100&PG=9",p:40000};
I.u[7188] = {n:"Citrusan Dolken",t:5,d:"Deze dolken zijn bijzonder geschikt voor het snijden van fruit of om het gras voor de voeten van je tegenstanders te maaien. Een originele manier om ze te verrassen.",ep:18,g:48,l:113,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,35,50,false,false],c:"CA>100&CI>100",p:32575};
I.u[7189] = {n:"Rod Staf",t:4,d:"Deze vreemde staf is een verbeterde versie van de beroemde God Rod. Deze staf is namelijk bedacht en gemaakt na vele tests door de Liefdespriesteressen van de God Rod. Dit model is zelfs gebruikt en versleten door Kuri zelf, waardoor hij al uniek is.",ep:19,g:59,l:176,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,100,false,false],c:"CI>450",p:57000};
I.u[7190] = {n:"Maydhyn China Dolken",t:5,d:"Deze buitengewone dolken zijn speciaal gemaakt voor een Sramette die behoefte had aan veel sensatie. \nZe was zo teleurgesteld dat ze geen dolken naar haar smaak kon vinden, dat ze alle dolksmeden van Amakna uitdaagde: degene die erin zou slagen dolken te smeden die welke Tofu dan ook in één keer konden doden, mocht 3 nachten in haar gezelschap doorbrengen. In tegenstelling tot haar verwachting, had deze advertentie niet het gewenste effect, want niemand nam de uitdaging aan. Zij moest honderd jaar wachten tot een gepensioneerde Enutrof dolksmid geïnteresseerd was in de beloning, die met de jaren wel wat was veranderd...",ep:18,g:45,l:100,wd:true,fm:true,w:10,an:13,tw:true,e:[15,3,1,1,35,50,false,false],c:"CS>150&CA>150",p:21800};
I.u[7191] = {n:"Ramougre Dolk",t:5,d:"Ramougre was een oude Sram, en was meester in het maken van juwelen. Zowel voor zijn creaties als voor het vermoorden van zijn klanten, maakte hij gebruik van deze dolk, als hij zich een beetje teveel verveelde in zijn juwelierswinkel. Hij stond bekend om zijn zeer slechte karakter, omdat hij soms zijn mooiste creaties verwoestte met deze dolk. Vandaag de dag eren de gebruikers van deze dolken hem, want ze gebruiken hem voornamelijk om geslachtsdelen af te snijden.",ep:19,g:49,l:127,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,30,false,false],c:"CA>200&CS>200",p:40825};
I.u[7192] = {n:"Grizmine Klauw",t:6,d:"Grizmine heeft deze klauw nooit op juiste wijze weten te gebruiken. Door te kaarten en te gokken en door het drinken van bier, verzwakten zijn spieren. Het schijnt dat dit soort tijdverdrijf bij sommige personen ook andere organen kan aantasten.",ep:18,g:59,l:111,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>300&CA>120",p:31625};
I.u[7193] = {n:"Dark Vlad Zwaard",t:6,d:"Alleen Dark Vlad zelf is in staat om alle magie uit dit zwaard te halen en om hem werkelijk sprankelend te maken. Door hem te dragen kun je trots laten zien dat het nog niet met je gedaan is, zoals die belachelijke avonturiers die onder dit zwaard zijn geneuveld.",ep:19,g:61,l:126,wd:true,fm:true,w:20,an:14,e:[12,5,1,1,50,100,false,false],c:"CV>250&CI>300&PG=8",p:40625};
I.u[7194] = {n:"Arcanum Boog",t:2,d:"Deze boog is het bewijs dat het samengaan van techniek en toverkunst uitstekende resultaten kan opleveren. En toch is deze boog om nog onbekende redenen in de vergetelheid geraakt. De ambachtsman die deze boog had gecreëerd moest overigens zijn winkel sluiten, hetgeen door menig klant werd betreurd.",ep:18,g:49,l:96,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"CI>200&CA>60&PG=9",p:23500};
I.u[7195] = {n:"Karnak",t:6,d:"Dit legendarische zwaard werd \'s ochtends gesmeed door een legertje dronken Enutrofs, onder in de mijnen van Grimoth. Hij straalt een verbazingwekkende kracht uit, maar ook een verschraalde bierlucht.",ep:19,g:60,l:158,wd:true,fm:true,w:15,an:14,tw:true,e:[10,5,1,1,50,80,false,false],c:"CV>300&CA>300&PG=8",p:51100};
I.u[7196] = {n:"Pandawushuka Schild",t:82,d:"De Meester Pandawushuka biedt je persoonlijk dit schild aan, met de kleuren van zijn school van oosterse vechtsporten. Het is het symbool van een met succes en eervol afgeronde opleiding.",ep:0,g:34,l:1,wd:true,fm:true,w:1,p:1};
I.u[7197] = {n:"Tobleronde Hamer",t:7,d:"Deze hamer diende oorspronkelijk om er chocoladerepen mee te breken om er chocoladepoeder van te maken. In de loop der jaren heeft hij een heerlijke geur en smaak gekregen. Reden te meer om je vijanden te laten proeven.",ep:19,g:53,l:150,wd:true,fm:true,w:100,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CI>150&CV>200&(PG=5|PG=2)",p:473751};
I.u[7198] = {n:"Avond Scheermes",t:6,d:"Alle oude Enutrofs kunnen je het vertellen, een mooie baard is een goed onderhouden baard. Het mes is zo goed geslepen, dat hij uitstekend geschikt is voor iets te erg behaarde dames.",ep:18,g:62,l:106,wd:true,fm:true,w:15,an:14,e:[10,4,1,1,50,50,false,false],c:"CS>200&CA>100",p:28925};
I.u[7199] = {n:"Abatz Zwaard",t:6,d:"Dit zwaard behoorde toe aan een slager genaamd Franky Abatz, die hem gebruikte om vijanden open te rijten voor worsten vlees. Vroeger ging ik wel naar die kraam... Geloof me, ik heb die bastaard laten betalen voor elke worst die hij verkocht...",ep:19,g:63,l:135,wd:true,fm:true,w:15,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>200&CA>120&CV>300",p:44225};
I.u[7200] = {n:"Shodanwa Sabel",t:6,d:"Deze fantastische sabel wordt gebruikt door de Pandawushuka discipelen als ze erin slagen de graad van Shodanwa te bereiken zonder ondertussen te sterven.",ep:18,g:55,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>60",p:4300};
I.u[7201] = {n:"Nidanwa Sabel",t:6,d:"Deze prachtige sabel wordt gebruikt door de discipelen van Pandawushuka als ze het niveau van Nidanwa behalen en ondertussen niet zijn overleden.",ep:18,g:56,l:66,wd:true,fm:true,w:15,an:14,e:[10,5,1,1,50,50,false,false],c:"CA>80",p:11300};
I.u[7202] = {n:"Sandanwa Sabel",t:6,d:"Deze prachtige sabel wordt gebruikt door de discipelen van Pandawushuka als ze het niveau van Sandanwa behalen en ondertussen niet zijn overleden.",ep:18,g:57,l:83,wd:true,fm:true,w:10,an:14,e:[10,5,1,1,50,50,false,false],c:"CS>120",p:17800};
I.u[7203] = {n:"Yondanwa Sabel",t:6,d:"Deze prachtige sabel wordt door de Pandawushuka discipelen gebruikt als het ze lukt om de rang van Yondanwa te bereiken zonder ondertussen het loodje te leggen.",ep:18,g:58,l:93,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,50,50,false,false],c:"CA>100",p:22175};
I.u[7204] = {n:"Shodanwa Staf",t:4,d:"Deze staf wordt in de regel gebruikt door de discipelen van Pandawushuka, die het niveau van Shodanwa hebben bereikt zonder het gebruik van hun armen te verliezen.",ep:18,g:49,l:46,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,false],c:"CV>30&CW>10",p:5775};
I.u[7205] = {n:"Nidanwa Staf",t:4,d:"Deze staf wordt in de regel gebruikt door de Pandawushuka discipelen die erin geslaagd zijn de graad van Nidanwa te bereiken zonder in de tussentijd het gebruik van hun arm te hebben verloren.",ep:18,g:50,l:62,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>100",p:10125};
I.u[7206] = {n:"Sandanwa Staf",t:4,d:"Deze staf wordt in de regel gebruikt door de Pandawushuka discipelen die erin geslaagd zijn de graad van Sandanwa te bereiken zonder in de tussentijd het gebruik van hun arm te hebben verloren.",ep:18,g:51,l:80,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,30,50,false,false],c:"CA>100&CV>70",p:16700};
I.u[7207] = {n:"Yondanwa Staf",t:4,d:"Deze staf wordt in de regel gebruikt door de Pandawushuka discipelen die erin geslaagd zijn de graad van Yondanwa te bereiken zonder in de tussentijd het gebruik van hun arm te hebben verloren.",ep:18,g:52,l:93,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>250",p:22500};
I.u[7208] = {n:"Shodanwa Bijl",t:19,d:"Deze bijl wordt gebruikt door de discipelen van Pandawushuka, als zij het niveau van Shodanwa behalen. Hij is ook erg geschikt om Bamboebossen en alles wat zich daar schuil houdt, te verwoesten.",ep:18,g:37,l:36,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:3550};
I.u[7209] = {n:"Nidanwa Bijl",t:19,d:"Deze bijl wordt gebruikt door de discipelen van Pandawushuka wanneer ze de graad van Nidanwa bereiken. Hij is tevens zeer handig om Bamboebossen en allen die zich daar verstoppen neer te hakken.",ep:18,g:36,l:59,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],c:"CS>100&CV>50",p:9000};
I.u[7210] = {n:"Sandanwa Bijl",t:19,d:"Deze bijl wordt gebruikt door de discipelen van Pandawushuka wanneer ze de graad van Sandanwa bereiken. Hij is tevens zeer handig om Bamboebossen en allen die zich daar verstoppen neer te hakken.",ep:18,g:35,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:17800};
I.u[7211] = {n:"Yondanwa Bijl",t:19,d:"Deze bijl wordt gebruikt door de discipelen van Pandawushuka wanneer ze de graad van Yondanwa bereiken. Hij is tevens zeer handig om Bamboebossen en allen die zich daar verstoppen, neer te hakken.",ep:18,g:34,l:98,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,50,50,false,false],c:"CI>150&CS>75&CV>85",p:24500};
I.u[7212] = {n:"Bamboe Kliever",t:19,d:"Met deze lichte en elegante bijl kan je gemakkelijk vooruitkomen in de Bamboebossen van Pandala, en je doelmatig verdedigen tegen de meest bedrieglijke Pandis, die altijd klaar staan om geïsoleerde houthakkers aan te vallen vanwege een ellendige beursgeschiedenis...",ep:18,g:33,l:26,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:2000};
I.u[7213] = {n:"Klief Schep",t:8,d:"Deze schep wordt geacht de lucht met een ongelovelijke snelheid te doorklieven. Degenen die weten hoe ze ermee om moeten gaan, klieven er voornamelijk de schedels van hun vijanden mee.",ep:19,g:41,l:142,wd:true,fm:true,w:15,an:16,tw:true,e:[10,5,1,1,40,70,false,false],c:"CC>400&CV>250",p:46050};
I.u[7214] = {n:"Sandalen Matiërs",t:11,d:"Deze sandalen waren van de Matiërs, een Ouginaksstam, die inmiddels verdwenen is. Zij waren verwant aan de Pandawas, wat na enige generaties resulteerde in een verandering van de kleur van hun vacht. Die was wit geworden met zwarte vlekken. Een wrede kleermaakster heeft ze allemaal verwerkt in jassen.",ep:18,g:59,l:30,wd:true,fm:true,w:10,p:2650};
I.u[7215] = {n:"Plaag Sandalen",t:11,d:"Deze sandalen werden gebruikt door sommige Panditvrouwtjes om verdwaalde avonturiers te verleiden en hen in verschrikkelijk vallen te lokken.",ep:19,g:60,l:121,wd:true,fm:true,w:20,p:37400};
I.u[7216] = {n:"Kohol Sandalen",t:11,d:"Deze sandelen werden aan zieke Pandawas gegeven die hardhollend naar de wc moesten als ze het Pandrista virus hadden opgelopen of als ze een drankovergoten avond in de herberg hadden doorgebracht.",ep:18,g:61,l:58,wd:true,fm:true,w:10,p:8975};
I.u[7217] = {n:"Gedistilleerde Sandalen",t:11,d:"De Pandawas hebben altijd al iets met alcoholische drank gehad. In de loop der tijd hebben ze geleerd hoe ze dit het beste kunnen bewaren en er meer smaak aan te geven. Wat deze sandalen betreft, deze zijn speciaal gemaakt voor beschonken Pandawas. De zolen zijn verzwaard om vaker voet aan de grond te kunnen houden.",ep:19,g:62,l:159,wd:true,fm:true,w:50,p:50800};
I.u[7218] = {n:"Adin Sandalen",t:11,d:"Adin was een jonge Pandawa, een groot verzamelaar van lampen, maar zelf was hij geen licht.",ep:18,g:63,l:76,wd:true,fm:true,w:15,p:14900};
I.u[7219] = {n:"Leluja Sandalen",t:11,d:"Deze sandalen werden toevertrouwd aan Pandits aan het eind van religieuze rituelen. Vandaag de dag worden ze vooral gebruikt voor de kampioenschappen tapdansen.",ep:18,g:64,l:56,wd:true,fm:true,w:15,p:8200};
I.u[7220] = {n:"Lotto-ticket",t:15,d:"Je hebt in je handen een fantastisch lotto-ticket, bewaar het zorgvuldig, het zou zomaar kunnen dat je de gelukkige uitverkorene bent van de zeer grote lottotrekking!",ep:1,g:717,l:2,wd:true,fm:true,w:1,p:1};
I.u[7221] = {n:"Tanukouï Ketting",t:1,d:"Iedere Tanukouï San draagt deze ketting vanaf z\'n jeugd. Het heeft zelfs nog meer waarde als je weet waartoe hij allemaal in staat is, zelfs als kind.",ep:19,g:92,l:152,wd:true,fm:true,w:10,p:49030};
I.u[7222] = {n:"Pandawushu Water Artefact",t:50,d:"Dit magische voorwerp wodt gebruikt door de Pandawushu volgelingen om hun uitrusting te betoveren.",ep:1,g:104,l:1,wd:true,fm:true,w:1,p:1};
I.u[7223] = {n:"Pandawushu Lucht Artefact",t:50,d:"Dit magische kunstvoorwerp wordt gebruikt door de Pandawushu discipelen om hun instrumenten mee te betoveren.",ep:18,g:105,l:1,wd:true,fm:true,w:1,p:1};
I.u[7224] = {n:"Pandawushu Aarde Artefact",t:50,d:"Dit magische voorwerp wodt gebruikt door de Pandawushu volgelingen om hun uitrusting te betoveren.",ep:18,g:106,l:1,wd:true,fm:true,w:1,p:1};
I.u[7225] = {n:"Pandawushu Vuur Artefact",t:50,d:"Dit magische voorwerp wordt door de Pandawushu discipelen gebruikt om hun uitrusting te betoveren.",ep:18,g:107,l:1,wd:true,fm:true,w:1,p:1};
I.u[7226] = {n:"Akwadala Hoed",t:16,d:"Vanaf een afstand lijk je met deze hoed op net op een Pandawushuka uit Akwadala. Als men je van dichterbij ziet, lijk je er helemaal niet op.",ep:18,g:146,l:43,wd:true,fm:true,w:2,s:34,p:5100};
I.u[7227] = {n:"Terrdala Hoed",t:16,d:"Vanaf een afstand lijkt je net op een Pandawushuka van Terrdala. Van dichterbij zie je er GEK uit!",ep:18,g:147,l:75,wd:true,fm:true,w:10,s:36,p:14575};
I.u[7228] = {n:"Feudala Hoed",t:16,d:"Van een afstand lijk je op een Pandawushuka van Feudala dorp. Van dichtbij, zie je er GEK uit!",ep:18,g:145,l:98,wd:true,fm:true,w:20,s:37,p:24800};
I.u[7229] = {n:"Aerdala Hoed",t:16,d:"Met deze hoed op je hoofd, lijk je van veraf op een Pandawushuka uit het dorp Aerdala. Van dichtbij lijk je nergens op.",ep:18,g:148,l:64,wd:true,fm:true,w:10,s:35,p:10100};
I.u[7230] = {n:"Akwadala Mantel",t:17,d:"Deze mantel komt uit Akwadala. Je kunt hem als deurmat gebruiken of zelfs als vloerkleed als je net uit het water komt.",ep:18,g:113,l:41,wd:true,fm:true,w:10,s:34,p:4550};
I.u[7231] = {n:"Terrdala Cape",t:17,d:"Deze cape, afkomstig uit het dorp Terrdala, kan ook als deurmat gebruikt worden of zelfs als dweil, voor als je net uit het water komt.",ep:18,g:112,l:63,wd:true,fm:true,w:15,s:36,p:10305};
I.u[7232] = {n:"Feudala Mantel",t:17,d:"Deze mantel komt uit Feudala. Hij kan gebruikt worden als deurmat of zelfs als vloerdoek als je net uit het water komt.",ep:18,g:111,l:92,wd:true,fm:true,w:10,s:37,p:21750};
I.u[7233] = {n:"Aerdala Cape",t:17,d:"Deze cape, die uit het dorp Aerdala komt, kan als deurmat dienen of zelfs als dweil als je net uit het water komt.",ep:18,g:114,l:65,wd:true,fm:true,w:10,s:35,p:11200};
I.u[7234] = {n:"Verslonden Akwadala Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:31,l:1,wd:false,fm:true,w:2,c:"BI=non équipable",p:5350};
I.u[7235] = {n:"Begraven Terrdala Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:32,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:14100};
I.u[7236] = {n:"Verbrande Feudala Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:33,l:1,wd:false,fm:true,w:15,c:"BI=non équipable",p:27100};
I.u[7237] = {n:"Weggevlogen Aerdala Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:30,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:11600};
I.u[7238] = {n:"Akwadala Riem",t:10,d:"Pandawas uit Akwadala letten altijd op hun figuur. Als je deze riem zo strak mogelijk aantrekt, zou je goed resultaat moeten boeken aangaande je flubberige buik.",ep:18,g:76,l:41,wd:true,fm:true,w:2,s:34,p:4600};
I.u[7239] = {n:"Terrdala Riem",t:10,d:"De Pandawas uit het dorp Terrdala hebben altijd een slanke taille willen houden. Door deze riem zo strak mogelijk aan te halen zou je hetzelfde resultaat moeten krijgen.",ep:18,g:78,l:49,wd:true,fm:true,w:10,s:36,p:6353};
I.u[7240] = {n:"Feudala Riem",t:10,d:"De Pandawas uit het dorp Feudala hebben altijd een slanke taille willen houden. Door deze riem zo strak mogelijk aan te trekken, zou je hetzelfde resultaat moeten bereiken.",ep:18,g:77,l:81,wd:true,fm:true,w:10,s:37,p:16925};
I.u[7241] = {n:"Aerda riem",t:10,d:"Pandawas uit Aerdala denken altijd aan hun figuur. Als je deze riem zo strak mogelijk om doet, zul je goede resultaten boeken wat betreft je flubberige buik.",ep:18,g:79,l:70,wd:true,fm:true,w:10,s:35,p:13000};
I.u[7242] = {n:"Akwadala Geta",t:11,d:"Deze houten Getas waren gemaakt door de beste schoenmakers van Akwadala. Aangezien ze nogal open zijn  zullen je wratten goed kunnen ademen en van het landschap kunnen genieten.",ep:18,g:54,l:35,wd:true,fm:true,w:10,s:34,p:3350};
I.u[7243] = {n:"Terrdala Geta",t:11,d:"Deze houten Getas zijn gemaakt door de beste schoenmakers van het dorp Terrdala. Ze zijn erg luchtig en zo komen je wratten in aanraking met de lucht en  kunnen ze genieten van het landschap.",ep:18,g:55,l:76,wd:true,fm:true,w:15,s:36,p:15000};
I.u[7244] = {n:"Feudala Geta",t:11,d:"Zeer luchtig, maken ze het je wratten mogelijk een luchtje te scheppen en van het landschap te genieten.",ep:16,g:56,l:68,wd:true,fm:true,w:25,s:37,p:12050};
I.u[7245] = {n:"Aerdala Geta",t:11,d:"Deze houten Getas zijn gemaakt door de beste schoenmakers van het dorp Aerdala. Ze zijn erg luchtig en zo komen je wratten in aanraking met de lucht en  kunnen ze genieten van het landschap.",ep:18,g:57,l:57,wd:true,fm:true,w:10,s:35,p:8700};
I.u[7246] = {n:"Akwadala Trouw Ring",t:9,d:"Deze Trouw Ring komt uit Akwadala. Het is meer een geluks amulet dan een magisch souvenir, maar je vrienden zullen nog steeds denken dat je je zielsverwant gevonden hebt.",ep:1,g:80,l:37,wd:true,fm:true,w:2,s:34,p:3800};
I.u[7247] = {n:"Terrdala Trouwring",t:9,d:"Deze trouwring komt van het dorp Terrdala. Het is eerder een mascotte dan een magische relikwie, waarmee je je vrienden kunt laten geloven dat je je zielsverwant hebt gevonden.",ep:18,g:81,l:77,wd:true,fm:true,w:10,s:36,p:15425};
I.u[7248] = {n:"Feudala Trouw Ring",t:9,d:"Deze Trouw Ring komt uit Feudala. Het is meer een geluks amulet dan een magisch souvenir, maar je vrienden zullen nog steeds denken dat je je zielsverwant gevonden hebt.",ep:18,g:82,l:81,wd:true,fm:true,w:10,s:37,p:17000};
I.u[7249] = {n:"Aerdala Trouwring",t:9,d:"Deze trouwring komt van het dorp Aerdala. Meer een talisman dan een magisch relikwie, toch kun je er je vrienden mee doen geloven dat je je zielsverwant hebt gevonden.",ep:18,g:83,l:57,wd:true,fm:true,w:5,s:35,p:8600};
I.u[7250] = {n:"Akwadala Amulet",t:1,d:"Alleen de inwoners van het dorp Akwadala hadden toestemming dit amulet te dragen, dat wordt geacht één van de belangrijkste elementen van hun traditionele kostuum te zijn. Als je er nader naar kijkt vraag je je af waarom.",ep:18,g:79,l:41,wd:true,fm:true,w:2,s:34,p:5050};
I.u[7251] = {n:"Terrdala Amulet",t:1,d:"Alleen de bewoners van het dorp Terrdala mochten dit amulet dragen, en kan worden gezien als een van de belangrijkste elementen van hun traditionele kostuum. Als je er goed naar kijkt, vraag je je af waarom.",ep:18,g:80,l:80,wd:true,fm:true,w:10,s:36,p:16550};
I.u[7252] = {n:"Feudala Amulet",t:1,d:"De enige mensen die dit amulet mochten dragen waren de inwoners van Feudala. Dit amulet is onderdeel van hun formele en traditionele kledij hoewel iedereen zich nog steeds afvraagt waarom.",ep:18,g:81,l:91,wd:true,fm:true,w:10,s:37,p:21225};
I.u[7253] = {n:"Aerdala Amulet",t:1,d:"Alleen de inwoners van het dorp Aerdala hadden toestemming dit amulet te dragen, dat beschouwd wordt als één van de belangrijkste elementen van hun traditionele kostuum. Als je er goed naar kijkt, vraag je je af waarom.",ep:18,g:82,l:62,wd:true,fm:true,w:10,s:35,p:10000};
I.u[7254] = {n:"Akwadala Staf",t:4,d:"Deze staf was bedoeld om jonge onstuimige Pandawas een verwoesting te geven. Drie tikken op de vingers, vijftien op de rug, zestig op het hoofd, twee op de ogen en dat is alles!",ep:18,g:61,l:43,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,false],c:"CC>50",s:34,p:5040};
I.u[7255] = {n:"Terrdala Bijl",t:19,d:"Vanaf het begin was deze bijl bedacht voor het hakken van levende wezens. Pas op, één enkel foutje en je loopt de kans gehalveerd te worden.",ep:18,g:32,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],s:36,p:17635};
I.u[7256] = {n:"Aerdala Dolken",t:5,d:"Deze dolken zijn scherp als de klauwen van de Moowolf, hiermee zul je een uitstekende leerling-moordenaar zijn.",ep:18,g:51,l:62,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>50",s:35,p:10105};
I.u[7257] = {n:"Feudala Sabel",t:6,d:"Deze sabel is door Hotari Honza zelf gesmeden. Het schijnt dat het een van zijn laatste werken is voor hij zich omschoolde tot kok. In ieder geval, een echt collector\'s item.",ep:18,g:64,l:76,wd:true,fm:true,w:1,an:14,e:[5,6,1,1,50,50,false,false],c:"CI>200&CA>60",s:37,p:14900};
I.u[7258] = {n:"Pandikaze Haren",t:54,d:"Deze extreem dunne haren lijken uit de romp van een vrouwelijke Sadida getrokken te zijn, maar vergis je niet, want dat is niet zo.",ep:16,g:556,l:40,wd:true,fm:true,w:1,p:10};
I.u[7259] = {n:"Pandikaze weefsel",t:55,d:"Deze stapel haren is bijna intact ondanks de straf die je deze arme Pandikaze Geest moet hebben gegeven door ze eruit te trekken.",ep:18,g:124,l:40,wd:true,fm:true,w:1,p:10};
I.u[7260] = {n:"Pandikaze huid",t:59,d:"Deze huid is nog licht bedekt door dons, zo zacht als de oksels van een Eniripsa maar.. zonder de zweetgeur.",ep:18,g:40,l:40,wd:true,fm:true,w:2,p:10};
I.u[7261] = {n:"Magisch Bamboe Hout",t:38,d:"Heel verrassend is dit stukje Bamboe geïmpregneerd met een verrassende magie, waardoor het zich kan verplaatsen. Volgens een stamlegende komt het iedere nacht op de deur kloppen van de woningen waarvan de eigenaren losbandige activiteiten zouden plegen. De Pandawas nemen dus vaak de moeite het aan de ketting te leggen voordat ze gaan slapen, om ongemakken te voorkomen.",ep:18,g:670,l:220,wd:true,fm:true,w:5,p:20};
I.u[7262] = {n:"Bolbiflora Wortel",t:98,d:"Deze wortel van de Bolbiflora is anders dan de andere wortels, je kan er lang op kauwen zonder je tanden te verliezen. Pas op, in tegenstelling tot het echte snoepgoed is hij helemaal niet lekker.",ep:18,g:142,l:26,wd:true,fm:true,w:2,p:20};
I.u[7263] = {n:"Bolstruik Wortel",t:98,d:"De Bolstruik Wortel is niet zo als alle andere wortels, je kan er lang op kauwen zonder al je tanden te verliezen. Let op, in tegenstelling tot echte zoetigheid, smaakt hij niet lekker.",ep:18,g:143,l:42,wd:true,fm:true,w:2,p:20};
I.u[7264] = {n:"Bulbamboo Wortel",t:98,d:"Deze Wortel van Bulbamboo is niet zoals andere wortels. Er kan tijden op gekauwd worden zonder dat je tanden er uit vallen. Wees voorzichtig, want in tegenstelling tot echte snoepjes smaken ze vreselijk!",ep:18,g:145,l:67,wd:true,fm:true,w:2,p:20};
I.u[7265] = {n:"Bolbig Wortel",t:98,d:"Deze wortel van Bolbamboe lijkt niet op andere wortels, je kunt er heel lang op kauwen zonder al je tanden te verliezen. Maar let op, in tegenstelling tot echt snoepgoed, smaakt hij niet lekker.",ep:18,g:144,l:150,wd:true,fm:true,w:2,p:20};
I.u[7266] = {n:"Bloem van de Bolbiflora",t:35,d:"Deze bloem groeit slechts op één enkele plaats, op het hoofd van de Bolbiflora, probeer het dus niet met dat van jou, de ondergrond is niet zo rijk.",ep:18,g:119,l:26,wd:true,fm:true,w:1,p:10};
I.u[7267] = {n:"Bolstruikblaadje",t:36,d:"Deze blaadjes groeien slechts op één plek, op het hoofd van de Bolstruik, probeer ze dus niet op het jouwe te laten groeien, ze zouden de kans lopen snel te verleppen.",ep:18,g:55,l:42,wd:true,fm:true,w:2,p:10};
I.u[7268] = {n:"Bolbamboescheutjes",t:36,d:"Deze scheut groeit slechts op één plaats, op het hoofd van de Bolbamboe, probeer het dus niet op het jouwe, hij zal er niets vinden dat interessant is om te eten.",ep:18,g:56,l:67,wd:true,fm:true,w:2,p:10};
I.u[7269] = {n:"Magisch Bolbig Schors",t:96,d:"Deze magische schors is net zo sterk als een Schild van Kapitein Amakna, maar lang niet zo mooi.",ep:18,g:105,l:150,wd:true,fm:true,w:2,p:10};
I.u[7270] = {n:"Magische Schors van de Bolbiflora",t:96,d:"Deze schors is zo fijn en breekbaar, dat hij gebruikt zou kunnen worden bij het maken van kant of ondeugend ondergoed.",ep:18,g:106,l:26,wd:true,fm:true,w:2,p:10};
I.u[7271] = {n:"Magische Schors van de Bolstruik",t:96,d:"Deze ruwe schors is perfect voor het maken van anti-slip zolen.",ep:18,g:107,l:42,wd:true,fm:true,w:2,p:10};
I.u[7272] = {n:"Magische Bulbamboo schors",t:96,d:"Deze gladde schors is perfect om houten vloeren of dansvloeren te maken.",ep:18,g:108,l:67,wd:true,fm:true,w:2,p:10};
I.u[7273] = {n:"Ringslang Huid",t:59,d:"Deze huid van een ringslang glipt je door de vingers zoals geen andere huid ooit heeft gedaan. Maak er geen schoenen van, want je krijgt ze nooit meer uit.",ep:18,g:41,l:67,wd:true,fm:true,w:2,p:10};
I.u[7274] = {n:"Magische Tand van Ringslang",t:47,d:"Deze tand is niet als de andere, hij stinkt meer dan de andere, alsof de vreselijke adem van de Ringslang zich erin vastgezet heeft.",ep:18,g:16,l:67,wd:true,fm:true,w:2,p:100};
I.u[7275] = {n:"Haren van Kitsou Nae",t:54,d:"Die Kitsou Nae haren zij zo zacht als de romp van een vrouwelijke Trool. Iets wat je kan doen herinneren aan goede tijden...",ep:16,g:560,l:29,wd:true,fm:true,w:1,p:10};
I.u[7276] = {n:"Haren van Kitsou Nufeu",t:54,d:"Die Kitsou Nufeu haren zijn zo zacht als de romp van een vrouwelijke Trool. Iets wat je kan doen denken aan goeie herinneringen...",ep:18,g:557,l:111,wd:true,fm:true,w:1,p:10};
I.u[7277] = {n:"Haren van Kitsou Nere",t:54,d:"Die Kitsou Nae haren zij zo zacht als de romp van een vrouwelijke Trool. Iets wat je kan doen herinneren aan goede tijden...",ep:16,g:558,l:80,wd:true,fm:true,w:1,p:10};
I.u[7278] = {n:"Kitsou Nakwa Haar",t:54,d:"Dit haar van Kitsou Nakwa is zo zacht als de kont van een vrouwelijke Trool. Dat doet je denken aan mooie tijden.",ep:1,g:559,l:60,wd:true,fm:true,w:1,p:10};
I.u[7279] = {n:"Kitsou Nae huid",t:59,d:"Deze huid van topkwaliteit kan in dunne stroken gesneden worden om een goeie zweep te maken. Het ideale kado voor ouders van luidruchtige en brutale kinderen.",ep:18,g:46,l:19,wd:true,fm:true,w:2,p:10};
I.u[7280] = {n:"Kitsou Nufeu huid",t:59,d:"Deze huid van topkwaliteit kan in dunne stroken gesneden worden om een goeie zweep te maken. Het ideale kado voor ouders van luidruchtige en brutale kinderen.",ep:18,g:44,l:111,wd:true,fm:true,w:2,p:10};
I.u[7281] = {n:"Kitsou Nere\'s huid",t:59,d:"Deze Kitsou Nere\'s huid is van een uitzonderlijke kwaliteit, in dunne riemen gesneden, het zou een perfecte zweep kunnen zijn. Het is het perfecte kado voor ouders van onbeschofte kinderen.",ep:18,g:45,l:80,wd:true,fm:true,w:2,p:10};
I.u[7282] = {n:"Kitsou Nakwa Huid",t:59,d:"Deze huid van Kitsou Nakwa is van uitzonderlijke kwaliteit, in vele stroken gesneden zou hij een prima zweep kunnen vormen. Het ideale cadeau om aan ouders te geven wier kinderen te brutaal zijn.",ep:1,g:43,l:60,wd:true,fm:true,w:2,p:10};
I.u[7283] = {n:"Tanukoui San Huid",t:59,d:"Van deze enorme uitgerekte huid van Tanukouï San kun je heel goed een portemonnee maken om je kamas in op te bergen.",ep:1,g:2,l:85,wd:true,fm:true,w:2,p:100};
I.u[7284] = {n:"Tanukouï San Haar",t:54,d:"Deze Tanukouï San haren ruiken niet erg lekker, maar wat doet het ertoe, het zijn uiteindelijk wel Tanukouï San haren.",ep:1,g:3,l:85,wd:true,fm:true,w:2,p:100};
I.u[7285] = {n:"Arachnawa Poot",t:103,d:"Dit pootje zal nog lang blijven trappelen. Laat het in de broek van je vijanden glippen om hen midden in het gevecht uit hun evenwicht te halen, je zal zonder probleem winnen.",ep:18,g:716,l:43,wd:true,fm:true,w:2,p:100};
I.u[7286] = {n:"Bamboetohout",t:38,d:"Het hout van de Bamboeto is bijna even veel waard als dat van de Culbuto, en toch is het veel gangbaarder. Je begrijpt er niets van.",ep:18,g:675,l:47,wd:true,fm:true,w:2,p:100};
I.u[7287] = {n:"Bamboetoblaadje",t:36,d:"De Bamboetoebladeren zijn stevig en dik, een beetje zoals de vrouwelijke Bworks, zonder de agressiviteit.",ep:18,g:69,l:47,wd:true,fm:true,w:2,p:1};
I.u[7288] = {n:"Heilig Bamboeto Blaadje",t:36,d:"Dit enorme blad is zo hard en zwaar, dat het je levend kan pletten als je in de herfst onder een Heilige Bamboeto in slaap zou vallen.",ep:18,g:68,l:120,wd:true,fm:true,w:2,p:100};
I.u[7289] = {n:"Heilig Bamboetohout",t:38,d:"Dit hout moet niet in handen van zomaar iedereen komen, maar niemand weet nog waarom.",ep:18,g:674,l:120,wd:true,fm:true,w:10,p:100};
I.u[7290] = {n:"Magische Bambooto Wortel",t:98,d:"Deze Wortel staat de Heilige Bambooto toe om zijn magie uit de grond te trekken voor een gevecht.",ep:18,g:100,l:20,wd:true,fm:true,w:2,p:10};
I.u[7291] = {n:"Magische Heilige Bambooto Wortel",t:98,d:"Deze wortel staat de Heilige Bambooto toe om zijn magie uit de grond te trekken voor een gevecht.",ep:18,g:99,l:87,wd:true,fm:true,w:2,p:100};
I.u[7292] = {n:"Maho Vuurfoux Haren",t:54,d:"Deze haren komen van een Maho Vuurfoux. Het beest ziet eruit als iets uit een Bwork nachtmerrie, maar oordeel niet te gauw – het is erg dodelijk.",ep:18,g:202,l:150,wd:true,fm:true,w:2,p:1};
I.u[7293] = {n:"Soryo Firefoux Haar",t:54,d:"Deze haren komen van een klein rossig kwaadaardig wezentje, zoals zovelen.",ep:18,g:203,l:130,wd:true,fm:true,w:10,p:1};
I.u[7294] = {n:"Yokai Firefoux Haar",t:54,d:"Deze dikke en stinkende haren zijn met kracht en vastberadenheid uit het achterwerk van een vreselijk rossig wezen gerukt.",ep:18,g:204,l:110,wd:true,fm:true,w:10,p:10};
I.u[7295] = {n:"Pandora\'s Haren",t:54,d:"Deze mysterieuze haren helpen het naaien van magische hoeden en capes met verrassende magische effecten,",ep:18,g:2,l:200,wd:true,fm:true,w:10,p:200};
I.u[7297] = {n:"Pandulum Haren",t:54,d:"Deze kleine magische haren zijn sterk genoeg om een gebroken klok opnieuw het leven in te blazen.",ep:18,g:206,l:150,wd:true,fm:true,w:1,p:1};
I.u[7298] = {n:"Maho Vuurfoux Huid",t:59,d:"Deze dunne en zachte huid biedt een voortreffelijke bescherming tegen diverse magische aanvallen welke de Maho Vuurfoux aanschouwt als zijn eigen spreuken naar hem terug draaien.",ep:18,g:42,l:150,wd:true,fm:true,w:1,p:100};
I.u[7299] = {n:"Soryo Firefoux Huid",t:59,d:"Deze huid werd vroeger gebruikt voor het aan elkaar naaien van de onderbroekjes van de kinderen met een gevoelige huid. De onderbroekjes van huid van de Soryo Firefoux worden goedgekeurd door de nakomelingen van Kapitein Chafer.",ep:18,g:38,l:130,wd:true,fm:true,w:1,p:100};
I.u[7300] = {n:"Yokai Firefoux Huid",t:59,d:"Deze dikke vacht biedt een prima bescherming tegen Bamboeslagen.",ep:18,g:37,l:110,wd:true,fm:true,w:1,p:100};
I.u[7301] = {n:"Leopardo huid",t:59,d:"Deze huid werd door Pandawa\'s gebruikt om licht te maken en zeer minimaal ondergoed.",ep:18,g:36,l:40,wd:true,fm:true,w:1,p:10};
I.u[7302] = {n:"Pandora Huid",t:59,d:"Als je een schoenmaker bent heeft de Pandora huid meer dan één verrassing in petto voor je.",ep:18,g:1,l:200,wd:true,fm:true,w:10,p:100};
I.u[7303] = {n:"Pandulum Huid",t:59,d:"De kleur van zijn ruwe huid verandert regelmatig, maar niemand weet waarom.",ep:18,g:39,l:100,wd:true,fm:true,w:1,p:10};
I.u[7304] = {n:"Maho Vuurfoux weefsel",t:55,d:"Deze rode weefsel heeft een magische kracht. Ik zou het zelfde over jou willen zeggen, maar...",ep:18,g:11,l:150,wd:true,fm:true,w:1,p:100};
I.u[7305] = {n:"Soryo Firefoux Stof",t:55,d:"Deze stof van bescheiden formaat is perfect voor het dichtstoppen van de gaten onder de oude deuren als de winter nadert.",ep:18,g:10,l:130,wd:true,fm:true,w:1,p:10};
I.u[7306] = {n:"Yokai Firefoux Stof",t:55,d:"Deze stof komt van de gevoeligste delen van de Yokai Firefoux, die ook de slechtst riekende zijn. Veel avonturiers denken dat het om zijn snor gaat, maar ze vergissen zich.",ep:18,g:9,l:110,wd:true,fm:true,w:1,p:10};
I.u[7307] = {n:"Pandora weefsel",t:55,d:"Dit weefsel is misschien net zo zeldzaam als een goeie verrassing in de Pandora doos.",ep:18,g:125,l:200,wd:true,fm:true,w:10,p:10};
I.u[7308] = {n:"Pandulum weefsel",t:55,d:"Deze weefsel is niet eetbaar ondanks wat men zegt.. De laatste die hem probeerde te koken eindigde als een Tanukouï San. Nogal een streling van geluk voor sommigen van hen!",ep:18,g:12,l:100,wd:true,fm:true,w:1,p:10};
I.u[7309] = {n:"Pandikaze Sleutel",t:84,d:"Deze sleutel geeft je toegang tot de Pandikaze Grot. Wees voorzichtig, hij vernietigt zichzelf na gebruik.",ep:13,g:229,l:1,wd:true,fm:true,w:1,p:100};
I.u[7310] = {n:"Sleutel van de Bol Grot",t:84,d:"Met deze sleutel kan je de Bol grot betreden. Pas op, hij wordt vernietigd na gebruik.",ep:1,g:230,l:1,wd:true,fm:true,w:1,p:100};
I.u[7311] = {n:"Sleutel van de Kitsounes Toren",t:84,d:"Met deze sleutel kan je de Toren van de Kitsounes betreden. Pas op, hij wordt vernietigd na gebruik.",ep:1,g:231,l:1,wd:true,fm:true,w:1,p:100};
I.u[7312] = {n:"Sleutel van de Firefoux Toren",t:84,d:"Met deze sleutel kan je de Toren van de Firefoux betreden. Pas op, hij wordt vernietigd na gebruik.",ep:2,g:232,l:1,wd:true,fm:true,w:1,p:100};
