I.u[7379] = {n:"Pandikaze Geest weefsel",t:55,d:"Deze stapel haren is bijna intact ondanks de straf die je deze arme Pandikaze Geest moet hebben gegeven door ze eruit te trekken.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7380] = {n:"Maho Vuurfoux Geest weefsel",t:55,d:"Dit roodgekleurde magische weefsel is gedrenkt in ultrakrachtige magie. Niet echt iets om te delen!",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7381] = {n:"Soryo Vuurfoux Geest weefsel",t:55,d:"Dit bescheiden weefsel is perfect om de gaten onder de oude deuren op te vullen wanneer de Winter begint.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7382] = {n:"Leopardo Geest weefsel",t:55,d:"Dit weefsel is niet zo zacht als de muziek van een Leopardo maar het is nog steeds erg nuttig. Waarvoor? Dat is een goeie vraag...",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7383] = {n:"Yokai Vuurfoux Geest weefsel",t:55,d:"Deze weefsel komt van de meest gevoelige delen van de Yokai Vuurfoux Geest welke de meest stinkenden zijn. Een heleboel avonturiers hebben het mis als ze denken dat we het over zijn snor hebben.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7384] = {n:"Pandulum Geest weefsel",t:55,d:"In tegenstelling tot de ontvangen ideeën is dit weefsel niet eetbaar. De laatsten die het probeerden te koken zijn veranderd in Tanukouï San. Wat een geluk voor sommigen van hen!",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7385] = {n:"Tanukuoï Geest weefsel",t:55,d:"Dit weefsel komt uit de oksels van de Tanukouï San Geest, beroemd voor hun zachtheid en hun geur die op rottend Kraaienvlees lijkt... in het gunstigste geval!",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7386] = {n:"Tanukouï San Testikels",t:15,d:"Deze enorme testikels zijn bedekt met een heel zacht donslaagje dat wonderwel toveraanvallen afwendt, maar ook de slagen met stelten die de Tanukouï San zichzelf toebrengt als hij niet oplet, of als hij in trance raakt door de bezwering door een vrouwelijke Tanuki Chan. In ieder geval heb je niet zomaar iets in je handen.",ep:1,g:2,l:120,wd:true,fm:true,w:200,p:10};
I.u[7387] = {n:"`SRVT:MERCENARY_CLAN` Clan",t:25,d:"Je zult alles, maar dan ook alles te weten komen over de `SRVT:MERCENARY_SHORT_NAME`! Door `SRVT:MERCENARY_LEADER`, Grootmeester `SRVT:MERCENARY_SHORT_NAME.",ep:1,g:19,l:1,wd:true,fm:true,w:1,u:true,p:1};
