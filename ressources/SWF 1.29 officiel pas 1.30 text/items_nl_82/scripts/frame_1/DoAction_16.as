I.u[7536] = {n:"Wafwaf Geest",t:90,d:"Deze Wafwaf heeft de wereld van de levenden nog niet verlaten, het hangt van jou af een manier te vinden hem weer tot leven te wekken, of hem lafhartig in de steek te laten voor eens en voor altijd.",ep:1,g:4,l:1,wd:true,fm:true,w:1,p:1};
