I.u[7428] = {n:"Dorps Drankje: Terrdala",t:12,d:"Dit drankje maakt het mogelijk je te teleporteren naar het Dorp van Terrdala, als je het bezit.",ep:0,g:10,l:1,wd:false,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:1};
