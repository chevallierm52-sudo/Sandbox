I.u[7368] = {n:"Ster Stok",t:3,d:"De maker van deze stok wilde dat hij er de vallende sterren mee kon vernietigen, die hem uit zijn slaap hielden. Volgens de legende wilde hij, toen hij totaal bezopen uit de herberg kwam, zijn stok uitproberen, maar verwarde de maan met een vallende ster. De stok was werkelijk zo krachtig, dat hij de maan in tweeën brak, en één helft viel midden in de Asse Zee, waardoor het Moon eiland, zoals wij het nu kennen, werd gevormd. Nog een achtelijk verhaal om te vertellen tijdens een avondje met vrienden in de kroeg.",ep:19,g:55,l:126,wd:true,fm:true,w:15,an:11,e:[5,4,2,4,50,50,false,true],c:"CS>100&CV>150&CI>300",p:39355};
I.u[7369] = {n:"Bambooto Amber",t:50,d:"Deze amber hangt gewoonlijk boven op de Bambooto. Het wordt voornamelijk als sieraad gebruikt, maar het kan gevaarlijk zijn als de Bambooto op je valt bijvoorbeeld. Wat een slim beest!",ep:18,g:2,l:40,wd:true,fm:true,w:2,p:100};
I.u[7370] = {n:"Heilige Bambooto Amber",t:50,d:"Deze amber is het enige rijkdom van de Heilige Bambooto. Dit is wellicht waarom het zo bitter en gemeen is naar de toeristen die Pandala Eiland ontdekken.",ep:18,g:1,l:120,wd:true,fm:true,w:2,p:100};
