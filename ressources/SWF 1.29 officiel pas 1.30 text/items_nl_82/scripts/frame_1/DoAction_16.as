I.u[7400] = {n:"Verbonden Schriftrol",t:87,d:"Met deze schriftrol kan je je doelwit lokaliseren, zodat je erop kunt jagen.",ep:1,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:1};
I.u[7401] = {n:"Maagdelijke schriftrol",t:87,d:"Met deze schriftrol kan je een doelwit \'markeren\' zodat je erop kunt jagen.",ep:16,g:1,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,ut:true,p:100};
I.u[7402] = {n:"Partij van tien maagdelijke schriftrolen",t:87,d:"Met deze partij kan je <b>een enkel doelwit</b> ´markeren´ om er vervolgens meerdere keren op te kunnen jagen.",ep:16,g:3,l:10,wd:false,fm:true,w:10,c:"Ps!0&PP>0",u:true,ut:true,p:500};
I.u[7403] = {n:"Bot van de Leopardo Geest",t:47,d:"Imps gebruikten dit smalle puntige bot als neus decoratie. Een elegante manier om een hoekige neus te verbeteren, bijvoorbeeld.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7404] = {n:"Bot van de Maho Vuurfoux Geest",t:47,d:"Dit bot is nog steeds doorgedrenkt in zelfgemaakte magie. Wees niet verbaasd als het weer tot leven komt en het probeert de overblijfselen van zijn eigenaar te vinden.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7405] = {n:"Bot van de Pandikaze Geest",t:47,d:"Dit bot is het enige wat nog over is van de geest die jij hebt vernietigd. Helaas voor jou lijkt er geen magische kracht in te schuilen.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7406] = {n:"Bot van Pandora\'s Geest",t:47,d:"Dit bot is nog niet uit Pandora\'s Doos gekomen... maar we hebben alle reden om te geloven dat dit nog wel gaat gebeuren.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7407] = {n:"Bot van de Pandulum Geest",t:47,d:"Dit prachtig uitgehouwen bot kan als hand voor een gigantische klok gebruikt worden. Gewoon essentieel.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7408] = {n:"Geest Soryo Vuurfoux Bot",t:47,d:"De eerste keer dat de Soryo Vuurfoux een bot brak, probeerde hij wraak te nemen on de eerste man die hij tegen kwam. Op dat moment liep Jon Lemon, minstreel van beroep, zingend rond toen hij de Soryo Vuurfoux tegenkwam. Niemand weet wat er daarna gebeurde. Het enige wat opgemerkt kon worden nadien was dat zijn stem veel hoger was geworden.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7410] = {n:"Bot van de Tanukoui San Geest",t:47,d:"Door uit alle macht het onmetelijke gewicht te dragen van hun enorme testikels zijn de botten van de Tanukuoi San extreem sterk geworden.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7411] = {n:"Bot van de Yokai Vuurfoux Geest",t:47,d:"Dit bot zou gebruikt kunnen zijn om de schedels van brutale avonturiers open te breken, of om Enutrofs de grond in te drijven net als asperges. Maar nou het in jouw beheer is, is zijn doel ietwat bescheidener.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7412] = {n:"Pak van Honderd Maagdelijke Rollen",t:87,d:"Met dit pak kun je <b>een specifiek doel</b> “markeren” waar je verscheidene keren op kunt jagen.",ep:16,g:3,l:10,wd:false,fm:true,w:100,c:"Ps!0&PP>0",u:true,ut:true,p:3500};
I.u[7413] = {n:"Rol “Wijs met je Vinger”",t:25,d:"(Dubbelklikken om deze emotie te leren)                             Met deze rol kun je met “je Vinger Wijzen” om ofwel de weg te laten zien ofwel valsspelers te veroordelen.",ep:18,g:9,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7414] = {n:"Kleine Witte Bow Meow",t:18,d:"Deze pluizige bal haar krabt, bijt en knijpt alles wat dichtbij komt, inclusief de hand die hem voedt! Het is een angstaanjagend maar onweerstaanbaar aantrekkelijk en fascinerend beest. Wees voorzichtig, dit beest is niet alleen snel aangebrand, maar ook erg kieskeurig over zijn dieet. Hij eet alleen vers vlees van gejaagde beesten.",ep:3,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7415] = {n:"Kleine Zwarte Bow Wow",t:18,d:"Dit vreemde kleine beest eet alleen verse vis. Maar maak je geen zorgen, zijn gezonde gezelschap maakt meer dan goed voor de dehydraterende vis adem.",ep:3,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7417] = {n:"Certificaat van Plaatsing in Kennel : Peki Peki",t:77,d:"Dit certificaat beschrijft de kenmerken van de Peki Peki die je in de kennel hebt geplaatst.",ep:3,g:26,l:1,wd:false,fm:true,w:1,p:100};
I.u[7418] = {n:"Certificaat van Plaatsing in Kennel : Kleine witte MiauwMiauw",t:77,d:"Dit certificat beschrijft de eigenschappen van de kleine Witte MiauwMiauw die je in de kennel hebt geplaatst.",ep:3,g:27,l:1,wd:false,fm:true,w:1,p:100};
I.u[7419] = {n:"Certificaat van Plaatsing in Kennel: Kleine Zwarte Wafwaf",t:77,d:"Dit certificaat beschrijft de eigenschappen van het Zwarte Hondje dat je in de kennel hebt geplaatst.",ep:3,g:28,l:1,wd:false,fm:true,w:1,p:100};
I.u[7420] = {n:"Certificaat van Plaatsing in Kennel: Nomoon",t:77,d:"Dit certificaat beschrijft de eigenschappen van Nomoon die je in de kennel hebt ondergebracht.",ep:3,g:35,l:1,wd:false,fm:true,w:1,p:100};
I.u[7421] = {n:"Beroepsvergeetdrankje : Schildsmid",t:44,d:"Dit drankje doet je het beroep van schildsmid vergeten.",ep:18,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7422] = {n:"Maskananas",t:16,d:"Dit masker in de vorm van exotisch fruit is echt een collectors item. Hij dient nergens voor, hooguit om je echt origineel en smakelijk eruit te laten zien. En dat is al heel wat.",ep:1,g:117,l:1,wd:true,fm:true,w:1,s:74,p:10};
I.u[7423] = {n:"Gouden Larva Ei",t:12,d:"Hoe vreemd het ook lijkt, deze Gouden Larva eieren zijn niet gelegd door Gouden Larvae maar door meer voorkomende soorten – groene, oranje en zelfs blauwe. De natuur zit vol met teleurstellende verrassingen.",ep:1,g:715,l:10,wd:true,fm:true,w:1,u:true,p:1};
I.u[7425] = {n:"Kleine Gouden Larva",t:32,d:"Deze Larva is net uitgebroed. Aangezien het eerste wat hij van de wereld zag jouw gezicht is, denkt hij dat jij zijn moeder bent.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[7426] = {n:"Dorps Drankje: Feudala",t:12,d:"Dit drankje teleporteert je naar het Dorp van Feudala, als je dat bezit.",ep:0,g:11,l:1,wd:false,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:1};
