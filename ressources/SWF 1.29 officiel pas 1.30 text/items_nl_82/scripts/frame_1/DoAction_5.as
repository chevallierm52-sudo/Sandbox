I.u[2194] = {n:"Memoblok",t:24,d:"Verzamel 10 Boomchnid-schorsen.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2195] = {n:"Tand",t:24,d:"Deze tand moet haast wel van jou zijn gezien het pak slaag dat je van Oto Mustam hebt gekregen. \nHet zou wellicht verstandig zijn te wachten tot hij gekalmeerd is alvorens hem weer te spreken als je niet weer afgetuigd wilt worden.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2196] = {n:"Kennis",t:29,d:"Deze zegening verhoogt je intelligentie voor je volgende gevechten.",ep:18,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2197] = {n:"De Scheidings Kracht",t:14,d:"Met deze ringen kan je de heilige banden van het huwelijk doorbreken.",ep:1,g:13,l:1,wd:true,fm:true,w:0,ut:true,p:1};
I.u[2198] = {n:"Kennis Schriftrol",t:14,d:"Met deze schriftrol kan je je intelligentie verbeteren, wat handig kan zijn om je kalmte te bewaren tegenover twee Bworks.",ep:1,g:7,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2199] = {n:"Stompzinnigheids Schriftrol",t:14,d:"Met deze schriftrol kan je de intelligentie van één enkel doel verminderen, wat handig kan zijn als je vijand op het punt staat in paniek te raken bij het naderen van twee Bworks.",ep:1,g:8,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2200] = {n:"Bedreiging van Satirev Refibrom",t:24,d:"De opperrechter van Brakmar wil je niet meer zien. Het lijkt erop dat hij je niet in zijn hart gesloten heeft... nou ja hij heeft er toch geen.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2201] = {n:"Sereniteit",t:29,d:"Met deze zegening kan je Wijsheid winnen voor de komende gevechten.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2202] = {n:"Seniliteit",t:30,d:"Deze vloek ontneemt je de Wijsheid voor het eerstvolgende gevecht.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2203] = {n:"Matigings Schriftrol",t:14,d:"Met deze schriftrol kan je je wijsheid verbeteren, wat handig kan zijn als om sneller bij de enkel van Dark Vlad te komen.",ep:1,g:9,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2204] = {n:"Seniliteits Schriftrol",t:14,d:"Met deze schriftrol kan je de wijsheid van één enkel doelwit verminderen, wat handig kan zijn als je vijand probeert sneller bij de enkel van Dark Vlad te komen.",ep:1,g:10,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2205] = {n:"Verandering van rang",t:24,d:"Dit papier geeft aan dat je al een verandering van rang hebt doorgevoerd.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2206] = {n:"Godsend",t:29,d:"Deze zegening verhoogt je Geluk gedurende de komende gevechten.",ep:18,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2207] = {n:"Detentie Papier",t:24,d:"Op dit papier staan de misdaden die je hebt gepleegd, evenals de datum waarop je gevangen bent genomen...",ep:2,g:73,l:1,wd:true,fm:true,w:0,p:1};
I.u[2208] = {n:"Pech",t:30,d:"Deze vloek ontneemt je het Geluk voor het eerstvolgende gevecht.",ep:1,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2209] = {n:"Voordeel Schriftrol",t:14,d:"Met deze schriftrol kan je je Geluk verbeteren, wat handig kan zijn om gemakkelijker een tofu te vinden in een hooiberg.",ep:1,g:11,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2210] = {n:"Pech Schriftrol",t:14,d:"Met deze schriftrol kan je de Kans van één enkel doelwit verminderen, wat handig kan zijn als je vijand zijn geluk probeert.",ep:1,g:12,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2211] = {n:"Iop Kostuum",t:14,d:"Dankzij deze potsierlijke uitdossing zul je schitteren op de mondaine bals. De enige zorg is dat men je vaak zal zeggen dat je zo slim bent als een Iop.",ep:1,g:14,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2212] = {n:"Xelor Kostuum",t:14,d:"Met deze hoed en enkele bijhorende voorwerpen, is de gelijkenis overduidelijk. Zonder enige twijfel ben je een Xelor.",ep:1,g:15,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2213] = {n:"Sadide Kostuum",t:14,d:"Er is heel weinig nodig om op een sadida te lijken: uit bed komen, mistige blik en kop klem in het rectum. Effect gegarandeerd.",ep:1,g:16,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2214] = {n:"Iop instelling",t:31,d:"Je hebt de Iop instelling totdat je weer een vecht aangaat.",ep:1,g:4,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2215] = {n:"Xelor instelling",t:31,d:"Je hebt de instelling van een Xelor totdat je weer een gevecht aangaat.",ep:1,g:5,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2216] = {n:"Sadida instelling",t:31,d:"Je hebt de Sadida instelling totdat je weer een vecht aangaat.",ep:1,g:6,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2217] = {n:"Feca Kostuum",t:14,d:"Deze pruik komt regelrecht uit een oude kast, dat zie je aan het tikkeltje \"retro\" aspect van dit hoofddeksel. Daarentegen is het verbijsterend hoeveel je op een feca kunt lijken als je hem op je hoofd zet (omdat je dat graag wil).",ep:1,g:17,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2218] = {n:"Feca instelling",t:31,d:"Je hebt de Feca instelling totdat je weer een vecht aangaat.",ep:1,g:7,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2219] = {n:"Eniripse Kostuum",t:14,d:"Met deze eniripsa-vleugels kan je niet vliegen. Ga dus niet met deze potsierlijke uitdossing lopen opscheppen tegenover je vrienden, je loopt het risico voor gek te staan bij het landen.",ep:1,g:18,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2220] = {n:"Eniripsa instelling",t:31,d:"Je hebt de Eniripsa instelling totdat je weer een vecht aangaat.",ep:1,g:8,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2221] = {n:"Enutrof Kostuum",t:14,d:"Deze valse baard doet je zeker op een Enutrof lijken, maar hij geeft je eveneens een adem die die van een op zaterdagavond uitgaande Enu waardig is. Om een verdomde koorts van de krijgen.",ep:1,g:19,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2222] = {n:"Enurof instelling",t:31,d:"Je hebt de instelling van een Enutrof totdat je weer een gevecht aangaat.",ep:1,g:9,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2223] = {n:"Sacrier Kostuum",t:14,d:"Een beetje tofu-bloed en neplittekens, een piratenblik en het is rond. Je kan deelnemen aan de bijeenkomsten van de sacriers terwijl je voor één van hen doorgaat zonder verdacht te worden gevonden.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2224] = {n:"Sacrier instelling",t:31,d:"Je hebt de Sacrier instelling totdat je weer een vecht aangaat.",ep:1,g:10,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2225] = {n:"Sram Kostuum",t:14,d:"Een Kwane, een cape over het hoofd, het gezichtsbedrog is perfect. Als je dit kostuum draagt lijk je op een weerzinwekkend en verwerpelijk personage dat diep uit het kerkhof komt: simpelweg een Sram.",ep:1,g:21,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2226] = {n:"Sram instelling",t:31,d:"Je hebt de Sram instelling totdat je weer een vecht aangaat.",ep:1,g:11,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2227] = {n:"Osamoda Kostuum",t:14,d:"Voor sommigen erg aanlokkelijk, je kan jezelf voorzien van deze gespleten staart en van deze hoorntjes. Als je het eenmaal aanhebt, zal dit kostuum je als een tweede huid passen en kan je je ongevraagd mengen in de welbekende vee-ie-pee feesten die de Osamodas in het geheim geven.",ep:1,g:22,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2228] = {n:"Osamodas instelling",t:31,d:"Je hebt de Osamodas instelling totdat je weer een vecht aangaat.",ep:1,g:12,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2229] = {n:"Ecaflip Kostuum",t:14,d:"Hier kan je oren van heel zachte wabbitvacht, een gestreepte staart en een doos opgewonden vlooien vinden. Geen twijfel, als je deze vieze beestjes je buren in de maag splitst, kan men niet twijfelen aan je transformeertalent.",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2230] = {n:"Ecaflip instelling",t:31,d:"Je hebt de Ecaflip instelling totdat je weer een vecht aangaat.",ep:1,g:13,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2231] = {n:"Cra Kostuum",t:14,d:"De Cra, je zult het al hebben opgemerkt, flaneert vaak met zijn pijlkoker. Niet verbazend dus dat men, gewapend met dit voorwerp, je aanziet voor één van hen. Maar het is slechts schijn, wat een gein, om hen iedere keer te slim af te zijn.",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2232] = {n:"Cra instelling",t:31,d:"Je hebt de Cra instelling totdat je weer een vecht aangaat.",ep:1,g:14,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2233] = {n:"Overbijt",t:10,d:"Deze riem werd gemaakt door Xof de Lenald, die het geniale idee had om alle tanden die hij maar kon vinden op het Wabbitslagveld op te rapen. Sinds die dag is dit een gewoonte geworden.",ep:8,g:20,l:28,wd:true,fm:true,w:20,c:"CS<40&CI>80",p:2400};
I.u[2234] = {n:"Bonta instelling",t:31,d:"Je hebt de Bonta instelling totdat je weer een vecht aangaat.",ep:1,g:15,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2235] = {n:"Brakmar instelling",t:31,d:"Je hebt de Brakmar instelling totdat je weer een vecht aangaat.",ep:1,g:16,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2236] = {n:"Bontisch Kostuum",t:14,d:"Met deze kledij zullen vele reizigers je begroeten en je de weg vragen.",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2237] = {n:"Brakmar Kostuum",t:14,d:"Voorzien van deze zaken zul je door iedereen gevreesd worden.",ep:1,g:26,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2239] = {n:"Eniripsapoeder",t:48,d:"Dit poeder wordt in kleine hoeveelheden gemaakt door de vleugels van de Eniripsa. Het schijnt heilzame gaven te hebben voor huisdieren.",ep:3,g:260,l:1,wd:true,fm:true,w:1,p:1000};
I.u[2240] = {n:"Klein Rood Feewerk",t:74,d:"Ideaal voor huwelijksfeestjes en uitstekend voor het Onderbroekenfeest van Kapitein Chafer.",ep:16,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:350};
I.u[2241] = {n:"Koninklijke Mint Gelei",t:110,d:"De Koninklijke Gelei heeft meerdere te stoutmoedige avonturiers beroofd en uiteindelijk verpletterd. Let op, het wordt afgeraden om \'m te eten als een gewone Mint Gelei.",ep:7,g:408,l:100,wd:true,fm:true,w:1,p:100};
I.u[2242] = {n:"Koninklijke Aardbeien Gelei",t:110,d:"Koninklijke geconcentreerde Aardbeien Gelei kan iedere pacifist transformeren in een bloeddorstige oorlogsmachine. Let dus op dat je het niet serveert als aperatief aan je vrienden.",ep:7,g:409,l:150,wd:true,fm:true,w:1,p:100};
I.u[2245] = {n:"Scurvion Pincer",t:47,d:"Ooit gebruikt als rug krabber (toen een rug nog een rug was en een man een man was), nu wordt het gebruikt om jassen op te hangen. Ik denk dat het de hele trieste geschiedenis van de Wereld van Twaalf opsomt.",ep:14,g:411,l:36,wd:true,fm:true,w:1,p:1};
I.u[2246] = {n:"Gebroken Kroon van de Koninklijke Tofu",t:15,d:"Deze kroon is gebroken door krachtige magische aanvallen, of door de laatste kopstoot die de Koninklijke Tofu je heeft proberen uit te delen.",ep:3,g:412,l:100,wd:true,fm:true,w:10,p:250};
I.u[2247] = {n:"Koninklijke Tofu Veer",t:53,d:"Slechts een Iop realiseert zich niet dat deze veer van het achterwerk van een Koninklijke Tofu komt. En toch is dat makkelijk te zien, want de veer is veel dikker.",ep:3,g:413,l:100,wd:true,fm:true,w:11,p:250};
I.u[2248] = {n:"Ouginak Haar",t:54,d:"Deze haarsoort kan je warm houden aangezien je helemaal bezweet bent na het vasthouden ervan. Tenzij je bezweet bent omdat je bang bent om nog een Ouginak tegenkomt die wellicht ziet wat je vast houdt;\r\n            een Ouginak haar, en dus zijn vriend wil wreken.",ep:14,g:414,l:51,wd:true,fm:true,w:1,p:1};
I.u[2249] = {n:"Stamchnid Blaadje",t:36,d:"Dit Blaadje geeft absoluut de Stamchnid de benodigde kracht om te vechten. Dan nog moet je weten hoe je het moet gebruiken. Wat meteen in je opkomt, is het fijn te hakken en in boontjes te stoppen. Een feestmaal.",ep:2,g:415,l:35,wd:true,fm:true,w:1,p:1};
I.u[2250] = {n:"Stamchnid Hout",t:38,d:"Dit stuk hout klinkt hol. Het groene sap dat eruit ontsnapt, is een teken dat dit deel niets anders was dan de neus van de Stamchnid.",ep:9,g:416,l:35,wd:true,fm:true,w:1,p:100};
I.u[2251] = {n:"Mega Krakler Steen",t:51,d:"Ik zal deze Mega Steen nooit als eerste gooien!",ep:5,g:417,l:45,wd:true,fm:true,w:15,p:150};
I.u[2252] = {n:"Gouden Tand van de Krakler",t:47,d:"Je hebt zojuist zonder gewetensbezwaar de tanden getrokken van de Krakler die je pad kruisde. Jammer dat hij er slechts één bezat, een heel gebit zou makkelijk de kosten van de Zaap voor een hele maand hebben gedekt.",ep:5,g:418,l:31,wd:true,fm:true,w:5,p:1};
I.u[2253] = {n:"Greedovore Bloem",t:35,d:"Deze Bloem vergemakkelijkt het transport door je ingewanden. Ze wordt warm aanbevolen na een verblijf bij je favoriete kok.",ep:12,g:420,l:42,wd:true,fm:true,w:1,p:100};
I.u[2254] = {n:"Schurkass Blaadje",t:36,d:"Het blaadje van de Schurkass heeft een hele aparte smaak, tussen noten en een beetje frisse wellust. Je gerechten zullen in ieder geval een beetje schurkassachtig smaakje hebben, als je er al van wil eten.",ep:2,g:421,l:22,wd:true,fm:true,w:1,p:1};
I.u[2255] = {n:"Rapport van de Spion",t:24,d:"Geen enkele gevaarlijke activiteit op dit moment. De legerleiding is ondersteboven van de moord op één van hen. Het schijnt dat een bontariër dat op zijn geweten heeft.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2256] = {n:"Karkas van rioolrat",t:24,d:"Deze rat is slechts koud vlees. Eentje minder in de ingang van het riool.",ep:2,g:121,l:1,wd:true,fm:true,w:0,p:1};
I.u[2257] = {n:"Stukje rioolmuur",t:24,d:"Dit stukje rioolmuur is gevonden in de maag van een dingetje.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2259] = {n:"Karne Tand",t:47,d:"In je hand heb je nu het oudste spel van Amakna. De spelregels zijn eenvoudig. Gooi een Tand in de lucht en probeer hem met dezelfde hand op te vangen, terwijl je ondertussen een tweede Karne Tand van de grond raapt.",ep:4,g:13,l:16,wd:true,fm:true,w:1,p:20};
I.u[2260] = {n:"Kaartje van een brakmariër",t:24,d:"Iemand heeft dit visitekaartje in je uitrusting geschoven. Het lijkt een brakmariër te zijn. Dit kaartje vermeldt dat de Strijders geïnteresseerd zijn in je talent om te moorden en stellen je voor je in het gestoorde brakmarische avontuur te storten.",ep:2,g:72,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2261] = {n:"Snottergeest",t:30,d:"Een Snottergeest achtervolgt je. Hij voedt zich met je geur en met je levenskracht.",ep:1,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2262] = {n:"Beschrijving van de moordenaar",t:24,d:"Je hebt een Bontariër gevonden die de geur van bloed verpestte. Alle informatie die je hebt kunnen verzamelen over dit personage staat op dit stukje papier beschreven.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2263] = {n:"Bloed Snuffende Staf",t:80,d:"Deze staff is bezete door een snuivende geest. Zijn Imp-achtige voorkomen kwelt items en levende dingen evenzeer met een speciale geur voor hij terug gaat naar het Land van de niet-echt-levend-maar-ver-van-doden.",ep:16,g:25,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[2264] = {n:"Goblin Huid",t:59,d:"Een Duiveltje spot graag met je en is een stiekemerd, maar als je hem in stukjes hakt, zal dit stuk venijn wat minder brutaal zijn.",ep:4,g:422,l:16,wd:true,fm:true,w:1,p:1};
I.u[2265] = {n:"Beschrijving van een Bontariër",t:24,d:"Je hebt een snottergeest bevrijdt maar hij heeft zich niet gehecht aan de persoon waarop je doelde. Je hebt wat informatie over de persoon opgeschreven op dit stukje papier om je eraan te helpen herinneren.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2266] = {n:"Speenvarkensmelk",t:15,d:"Deze Varkensmelk komt van een Speenvarken. Je weet nooit, voor het geval je dacht dat het bij een Tofu gevonden werd, dat is niet zo.",ep:1,g:423,l:18,wd:true,fm:true,w:1,p:1};
I.u[2267] = {n:"Dragomelk",t:15,d:"Hoeveel boerenhanden zijn er nodig om een Dragokalkoen te melken? Zeven. Een om te melken en de andere zes om zijn kist te tillen.",ep:2,g:424,l:70,wd:true,fm:true,w:2,p:1};
I.u[2268] = {n:"Bwork Boogschutter Schedel",t:15,d:"Deze Schedel zou wel eens de nieuwe mode kunnen worden bij de Enutrofs: de toupet. Een beetje anti-luismiddel en je bent de meest gedistingeerde Enutrof van de wereld.",ep:4,g:425,l:24,wd:true,fm:true,w:1,p:1};
I.u[2269] = {n:"Blauwe Larve Oog",t:24,d:"Je hebt zojuist dit Oog onbeschadigd bemachtigd. Goed bereid, zijn vertroebelde ogen een genot voor een ontbijt. Dit larve-oog bewijst aan Oto dat je een blauwe larve gedood hebt.",ep:1,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2270] = {n:"Tros Larve-eieren",t:24,d:"Deze tros eieren lijkt op een grote tros druiven. Maar je kan ze beter niet eten.",ep:1,g:83,l:1,wd:true,fm:true,w:0,p:1};
I.u[2271] = {n:"Paars Bworkleer",t:56,d:"Er waren nog veel geheimen rond om dit Bwork ambachtswerk. Sommige avonturiers denken dat de paarsachtige tint kwam van de Goblins, maar het leer heeft een onbekende oorsprong. Vreemd.",ep:4,g:426,l:31,wd:true,fm:true,w:1,p:1};
I.u[2272] = {n:"Vergulde larve",t:32,d:"Deze larve wordt geboren in een ei. Omdat zijn eerste blik op jou is gericht, beschouwt hij je als zijn moeder.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[2273] = {n:"Purperen Stof",t:55,d:"Licht en zacht als je het aanraakt, dat kan je zeggen over deze vreemde Purperen Stof. Op het etiket aan de binnenkant staat \"made in taai wan\".",ep:2,g:427,l:23,wd:true,fm:true,w:1,p:1};
I.u[2274] = {n:"Kaars van de Duistere Mijnwerker",t:15,d:"Neem een Enutrof. Als het donker is in de mijn, zie je hem niet meer. De Duistere Mijnwerker zie je, als hij in het donker is, ook niet meer, want nu heb jij zijn kaars.",ep:1,g:428,l:24,wd:true,fm:true,w:10,p:10000};
I.u[2275] = {n:"Armzalig Zwijnen Leder",t:56,d:"Het Armzalig Zwijn verdween uit de voedingsketen. Mensen moesten Zwijnen met Varkens laten verenigen om Armzalige Zwijnen weer Eenvoudige Cania te zien vullen. Het Armzalig Varken is boos op de hele wereld sindsdien.",ep:2,g:429,l:40,wd:true,fm:true,w:10,p:1};
I.u[2277] = {n:"Shroud",t:55,d:"Om zichzelf geloofwaardiger te maken rollen Geesten zich op in een Shroud. Dat is een manier om verloren avonturieren af te schrikken.",ep:14,g:430,l:65,wd:true,fm:true,w:1,p:1000};
I.u[2278] = {n:"Onzichtbare stof",t:55,d:"Deze stof was ooit van Harry Taupeur, mollenjager. Hij bedekte zich ermee om de Mollen in zijn tun in de val te lokken. De charismatische Kapitein Chafer heeft het zich toegeëigend voordat hij op mysterieuze wijze verdween...",ep:1,g:431,l:23,wd:true,fm:true,w:1,p:1};
I.u[2279] = {n:"Scherpe Tand",t:47,d:"Deze Tand heeft aan een Vampier toebehoord, daar is geen twijfel over. Dan kan je zien door van heel dichtbij het uiteinde van de Tand te bekijken, dat zo puntig is al het maar kan zijn.",ep:3,g:432,l:15,wd:true,fm:true,w:1,p:1};
I.u[2280] = {n:"Vampierstro",t:15,d:"Onderschat nooit een Vampier, vooral als hij een strootje in zijn hand heeft, hij zou je bloed kunnen opzuigen tot zijn dorst gelest is.",ep:3,g:433,l:22,wd:true,fm:true,w:1,p:1};
I.u[2281] = {n:"Bloederige Stof",t:55,d:"Deze stof lijkt levend, de Vampiers gebruiken deze stof om zich mee te verkleden voor een gekostumeerd bal.",ep:3,g:434,l:15,wd:true,fm:true,w:1,p:1};
I.u[2282] = {n:"Witte Haarlok",t:15,d:"Ziehier het bewijs dat sommige monsters zich veel zorgen maken.",ep:1,g:435,l:24,wd:true,fm:true,w:1,p:1};
I.u[2283] = {n:"Kwoan Oog",t:109,d:"Dit Kwoan oog heeft verrassende hypnotiserende effecten, het komt erop neer dat je altijd een oogje in het zeil moet houden als je hem gebruikt.",ep:3,g:436,l:8,wd:true,fm:true,w:1,p:1};
I.u[2284] = {n:"Notitie van Larry Stotales",t:24,d:"De ingang van de legendarische grot met de gulden larven bevindt zich iets ten westen van Amakna. Met behulp van de verborgen krachten van de gulden larve kan je er naar binnen. Pas op als je kleine larve schade oploopt zal hij in de armen van zijn vader vluchten.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2285] = {n:"Duistere Stof",t:55,d:"Het bijzondere van deze Stof is geen punt van discussie meer. Dit gezegd hebbende, irriteert hij bij aanraking, zeer zeker omdat, in het gunstigste geval, een Ouginak gedurende jaren zijn neus erin gesnoten heeft.",ep:3,g:437,l:50,wd:true,fm:true,w:1,p:1};
I.u[2286] = {n:"Verbanden",t:15,d:"Deze verbanden zijn revolutionair: drie keer zo dik, ultrasterk en pimpelpaars geparfumeerd. Het is een hoge-kwaliteits product.",ep:2,g:438,l:51,wd:true,fm:true,w:1,p:1};
I.u[2287] = {n:"Zwart Leer",t:56,d:"Dit leer is al behandeld. Zijn herkomst is niet duidelijk maar de kleur komt waarschijnlijk van een speciale verfstof.",ep:1,g:439,l:74,wd:true,fm:true,w:1,p:1};
I.u[2288] = {n:"Wabbit Poot",t:103,d:"Talloze toeristen gaan enkel naar het Wabbit Eiland om een Wabbit Poot mee te nemen, want het brengt geluk. Helaas is dat niet het geval, maar het moet gezegd worden, dat het toerisme er slechter van wordt.",ep:8,g:440,l:18,wd:true,fm:true,w:1,p:1};
I.u[2290] = {n:"Wit Scarablad Schild",t:107,d:"Je hebt niet veel nodig om een mooie lampenkap te bezitten. Even tussen neus en lippen door, moet dit schild toch een ander nut hebben. Dat hopen we tenminste.",ep:3,g:441,l:32,wd:true,fm:true,w:1,p:1};
I.u[2291] = {n:"Blauw Scarablad Schild",t:107,d:"Je hebt niet veel nodig om een mooie lampenkap te bezitten. Even tussen neus en lippen door, moet dit schild toch een ander nut hebben. Dat hopen we tenminste.",ep:3,g:442,l:32,wd:true,fm:true,w:1,p:1};
I.u[2292] = {n:"Rood Scarablad Schild",t:107,d:"Je hebt niet veel nodig om een mooie lampenkap te bezitten. Even tussen neus en lippen door, moet dit schild toch een ander nut hebben. Dat hopen we tenminste.",ep:3,g:443,l:32,wd:true,fm:true,w:1,p:1};
I.u[2293] = {n:"Groen Scarablad Schild",t:107,d:"Je hebt niet veel nodig om een mooie lampenkap te bezitten. Even tussen neus en lippen door, moet dit schild toch een ander nut hebben. Dat hopen we tenminste.",ep:3,g:444,l:32,wd:true,fm:true,w:1,p:1};
I.u[2294] = {n:"Ingewanden van het Scarablad",t:15,d:"Op het eerste gezicht lijken deze ingewanden niet erg smakelijk. En toch, gehakt en met fijne zongedroogde kruiden, een beetje wilde munt, en gestoofd in een roestige ketel, zullen deze ingewanden de grootste lekkerbek onder de Chafers dolgelukkig maken.",ep:3,g:445,l:32,wd:true,fm:true,w:1,p:1};
I.u[2295] = {n:"Fragment van Reptielen Zwaard",t:15,d:"Met dit ZwaardFragment op je schoorsteenmantel kan je er prat op gaan de Crocodyl getemd te hebben, net zoals de excentrieke Mikool J., beter bekend onder de naam Crocodyl Dandie.",ep:4,g:446,l:69,wd:true,fm:true,w:10,p:1};
I.u[2296] = {n:"Reptielen Schild",t:15,d:"Waarvoor kun je nou zo\'n mooi met edelstenen versierd schild gebruiken? Totdat je het antwoord gevonden hebt, kun je hem gebruiken als dienblad om thee aan je vrienden te serveren.",ep:4,g:447,l:69,wd:true,fm:true,w:15,p:1};
I.u[2297] = {n:"Kruisboog Pijl",t:15,d:"Deze Pijl kan gebruikt worden om een kort maar scherp wapen te maken. Je kunt \'t ook gebruiken als tandenstoker. De keus is aan jou.",ep:1,g:125,l:34,wd:true,fm:true,w:1,p:1};
I.u[2298] = {n:"Staart van de Duivel",t:65,d:"Je hebt zojuist de Duivel bij de Staart gepakt, wat erg onaangenaam moet zijn.",ep:0,g:448,l:1,wd:true,fm:true,w:1,p:1};
I.u[2299] = {n:"Epaulet van de Dark Vlad",t:15,d:"Deze Epaulet moet meer dan één gevecht ondergaan hebben. Zelfs al ziet hij er niet erg sterk uit, je kan beter niet de Dark Vlad op de schouder slaan als je wapen je lief is.",ep:2,g:449,l:120,wd:true,fm:true,w:5,p:80};
I.u[2300] = {n:"Been Fragment",t:47,d:"Dit stuk been was ooit het overblijfsel van de Chafer uit de neotilischte tijd en het hapje van de Moowolf. Maar je hebt grote kans dat geen van tweeën waar is.",ep:9,g:450,l:43,wd:true,fm:true,w:1,p:1};
I.u[2301] = {n:"Kolerat Snorhaar",t:15,d:"Deze niet erg stevige snorharen laten je opscheppen tegenover je vrienden... of maken een imitatie van Salv en Torh Bali, Geweldige Brakmaarse Schilders.",ep:2,g:451,l:9,wd:true,fm:true,w:1,p:1};
I.u[2302] = {n:"Krab Tong",t:15,d:"De denkende hoofden van Amakna vragen zich nog steeds af wat het nut is van deze tong voor de krab. Ze zouden er waarschijnlijk aanstoot aannemen als ze het antwoord wisten.",ep:1,g:452,l:4,wd:true,fm:true,w:1,p:1};
I.u[2303] = {n:"Schoongemaakte Krabben Schild",t:107,d:"Goed schoongemaakt, kan deze Krabben Schaal diverse voorwerpen bevatten. Niettemin zullen genoemde voorwerpen eeuwig de min of meer verstorende geur van de Krab dragen.",ep:1,g:453,l:4,wd:true,fm:true,w:2,p:1};
I.u[2304] = {n:"Fragment van Gepolijste Steen",t:51,d:"Dit Fragment is afkomstig van de linkerbil van een Krakler van de Vlakten. Er is geen beter middel om een Arachnee te laten barsten, behalve misschien een Krakler in persoon.",ep:5,g:454,l:45,wd:true,fm:true,w:5,p:1};
I.u[2305] = {n:"Fragment van Puntig Steen",t:51,d:"Dit Fragment komt van het rechterschouderblad van een Krakler uit de Vlaktes. Als het al niet een stuk van zijn buik is. In ieder geval, leg deze steen niet zomaar overal neer.",ep:5,g:455,l:45,wd:true,fm:true,w:5,p:1};
I.u[2306] = {n:"Krakler Hart",t:51,d:"Hart van steen, zie je niet de liefde die ik je toedraag. Als je zo doorgaat, laat ik je op de grond liggen, ik laat me niet gek maken.",ep:5,g:456,l:45,wd:true,fm:true,w:5,p:1};
I.u[2307] = {n:"Chafer Lansier Schild",t:24,d:"...",ep:2,g:75,l:1,wd:true,fm:true,w:0,p:1};
I.u[2308] = {n:"Brakmar Badge",t:24,d:"Aan de hand van deze badge kun je een krijger identificeren terwijl hij aan het sterven is op het strijdveld. Het schijnt dat sommigen ze sparen, in Bonta.",ep:2,g:76,l:1,wd:true,fm:true,w:0,p:1};
I.u[2309] = {n:"Rode Kaars",t:24,d:"Een rode kaars, niet zoals de anderen...",ep:1,g:77,l:1,wd:true,fm:true,w:0,p:1};
I.u[2310] = {n:"Groene kaars",t:24,d:"...",ep:2,g:78,l:1,wd:true,fm:true,w:0,p:1};
I.u[2311] = {n:"Blauwe Kaars",t:24,d:"...",ep:2,g:79,l:1,wd:true,fm:true,w:0,p:1};
I.u[2312] = {n:"Bloedpoeder",t:24,d:"...",ep:2,g:80,l:1,wd:true,fm:true,w:0,p:1};
I.u[2313] = {n:"Water Respirator",t:24,d:"...",ep:2,g:81,l:1,wd:true,fm:true,w:0,p:1};
I.u[2314] = {n:"Flesjes Jiva",t:24,d:"...",ep:2,g:82,l:1,wd:true,fm:true,w:0,p:1};
I.u[2315] = {n:"Bloedwolf Haar",t:54,d:"Broujitte Fardot riep ooit een verbod uit op het doden van jonge Bloedwolven. Sinds haar ballingschap is de jacht weer geopend en de kleermakers vullen opnieuw hun zakken.",ep:1,g:196,l:19,wd:true,fm:true,w:1,p:1};
I.u[2316] = {n:"Gele Tand",t:47,d:"De Gele Tand van Bloedwolf zorgt ervoor dat eenieder die zijn kracht onderschat, zeven kleuren bagger schijt.",ep:1,g:458,l:19,wd:true,fm:true,w:1,p:1};
I.u[2317] = {n:"Wolven Oren",t:106,d:"Als je er goed naar kijkt, vraag je je af hoe een Bloedwolf  iets kan horen met al die beestjes en al het vuil in zijn Oren.",ep:1,g:459,l:19,wd:true,fm:true,w:1,p:1};
I.u[2318] = {n:"Berenklauw",t:103,d:"Sommige kwelgeesten dragen een berenklauw om hun nek. Iedereen is de herkomst en de betekenis van deze bijgelovigheid vergeten.",ep:1,g:460,l:12,wd:true,fm:true,w:1,p:1};
I.u[2319] = {n:"Witte Borstelige Staart",t:65,d:"Voor één keer heeft deze staart echt niets vreemds, behalve dat niemand weet waar hij vandaan kan komen. Misschien van een monster met een Witte Borstelige Staart, maar zelfs de specialisten durven zich er niet aan te wagen.",ep:0,g:461,l:40,wd:true,fm:true,w:1,p:1};
I.u[2320] = {n:"Ouginak Halsband",t:15,d:"Deze halsband geeft informatie over de Ouginak. Er zit een bericht ingeschreven: “Ik ben verdwaald, mijn buurten zijn gesitueerd op het pad naar de Sidimotes Landen, bedankt dat je me hebt terug gebracht naar mijn Brakmaarse meesters, je zult als beloning meppen om je oren krijgen.”",ep:14,g:462,l:51,wd:true,fm:true,w:5,p:1};
I.u[2321] = {n:"Fijngehakte Ouginak",t:15,d:"Is het ooit door je hoofd gegaan dat die Ouginak stukken eindeloos zouden kunnen kwijlen? Nou ja, het angstaanjagende ervan is dat ze het waarschijnlijk echt kunnen, aangezien Ouginaks bekend staan om hun altijd aanhoudende gulzigheid.",ep:14,g:463,l:51,wd:true,fm:true,w:1,p:1};
I.u[2322] = {n:"Hoektanden van Ratten",t:47,d:"Vergis je niet, deze melktandjes zijn in wezen echte scherpe hoektanden, stinkend en versleten. Ze dienen soms voor het vervangen van gouden tanden van de wat gierige Enutrofs.",ep:1,g:464,l:50,wd:true,fm:true,w:1,p:1};
I.u[2323] = {n:"Wervelkolom",t:47,d:"Dit is nou een wervelkolom van goede makelij. Maar vermijd sowieso om je rug te verdraaien.",ep:1,g:465,l:34,wd:true,fm:true,w:2,p:1};
I.u[2324] = {n:"Watermeloen",t:46,d:"...",ep:1,g:466,l:1,wd:true,fm:true,w:2,p:1};
I.u[2325] = {n:"Banaan",t:46,d:"De beroemde minstreel Andervan Diun schreef ooit een ode aan deze vrucht: \"Het Bananen Lied.",ep:1,g:467,l:1,wd:true,fm:true,w:1,p:1};
I.u[2326] = {n:"Sinaasappel",t:46,d:"...",ep:1,g:468,l:1,wd:true,fm:true,w:1,p:1};
I.u[2327] = {n:"Appel",t:46,d:"...",ep:1,g:469,l:1,wd:true,fm:true,w:1,p:1};
I.u[2328] = {n:"Kleine Vergulde Parel",t:15,d:"Deze vergulde parel is een cadeau van de kleine larve die je hebt vergezeld. Deze parel heeft voor jou dan ook een grote sentimentele waarde. Zijn zachtheid en kleur maken het dan ook een perfect cadeau voor een enigzins vrouwelijk persoon.",ep:5,g:483,l:1,wd:true,fm:true,w:1,p:1};
I.u[2329] = {n:"Peer",t:46,d:"...",ep:1,g:470,l:1,wd:true,fm:true,w:1,p:1};
I.u[2330] = {n:"Explosieve Capsule",t:15,d:"Deze capsule bevat magische citrusextracten. Het wordt aangeraden hem te schudden voor gebruik zodat het vruchtvlees niet op de bodem blijft liggen.",ep:4,g:711,l:23,wd:true,fm:true,w:1,p:1};
I.u[2331] = {n:"Aubergine",t:46,d:"De aubergine is niet echt voedzaam, sommigen doen er allerlei specerijen bij. Deze groentevrucht heeft een slechte reputatie maar hij is toch goed voor de gezondheid. Behalve voor die van de Bworks, maar niemand weet waarom.",ep:1,g:472,l:1,wd:true,fm:true,w:1,p:10};
I.u[2332] = {n:"Troost Snoepje",t:42,d:"Door dit snoepje hoef je niet te huilen.",ep:13,g:135,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2333] = {n:"Supermachtig Rood Snoepje",t:42,d:"Dit snoepje zal je concentratie verhogen tijdens gevechten, pech, het heeft echt een smerige smaak. (DUBBELKLIK OM TE GEBRUIKEN, bonus van 20 in wijsheid en 10 in Onderzoek voor de eerstvolgende 30 gevechten)",ep:1,g:136,l:1,wd:true,fm:false,w:1,c:"PO!1723",u:true,p:1};
I.u[2334] = {n:"Snoepje met Smaak van Blauwe Gelei",t:42,d:"Alle frisheid van de Blauwe Gelei is gevat in dit belachelijk kleine snoepje. Ideaal voor degenen die een Bwork-adem hebben.",ep:0,g:137,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[2335] = {n:"Modr Snoepje",t:42,d:"Om snel cariës te krijgen of je hele gebit voortijdig te verliezen.",ep:0,g:138,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2336] = {n:"Chafer Schedel",t:47,d:"Deze Schedel zal nooit meer klappertanden... alhoewel.",ep:1,g:480,l:16,wd:true,fm:true,w:1,p:1};
I.u[2337] = {n:"Magisch Boek",t:25,d:"Dit boek lijkt wel magisch. Heel vreemd.",ep:1,g:7,l:1,wd:true,fm:true,w:1,p:50};
I.u[2338] = {n:"Oud Boekje",t:25,d:"...",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[2339] = {n:"Lijst van standaarduitrusting",t:24,d:"Een strijder van gemiddelde waarde behoort iets anders dan lompen te dragen of, in tegenstelling, klinkende voorwerpen, hij geeft dus de voorkeur aan:\n-Zwart-wit om de middelvinger\n-Een bandana en een riem van levenskracht\n-Kluh Laarzen\n-Een Brakmar cape",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2340] = {n:"Boxershort van militielid",t:24,d:"Dit is inderdaad een boxershort van een militielid. Je moet wel een echte fetisjist zijn om dit bezitten. Of iemand wil de draak met je steken.",ep:2,g:84,l:1,wd:true,fm:true,w:0,p:1};
I.u[2341] = {n:"Mech Riorraw\'s Boog",t:2,d:"Mech Riorraw maakte deze boog. Hij kan lava rivieren doorkruizen en de top van Brakmaarse muren bereiken. Niets meer, niets minder.",ep:16,g:8,l:10,wd:true,fm:true,w:100,an:10,tw:true,e:[0,6,20,21,0,30,false,true],c:"Ps=1",p:0};
I.u[2342] = {n:"Ring van trouw",t:24,d:"Deze ring heb je van Domen gekregen. Hem teruggeven betekent dat je voor verwoesting van alle dingen bent. Dat plaatst je aan de zijde van de bewonderaars van Djaul.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[2343] = {n:"Armband van Djaul",t:24,d:"Deze armband heb je van Djaul gekregen. Als je hem draagt, betekent dat dat je zijn voorstellen accepteert.",ep:2,g:85,l:1,wd:true,fm:true,w:0,p:1};
I.u[2344] = {n:"Brief voor Oto",t:24,d:"Deze brief is aan je gegeven door Domen voor Oto.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2345] = {n:"Schildpad Oog",t:24,d:"Deze schildpad zal nu geen kattekwaad meer uithalen.",ep:2,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2346] = {n:"Gladjanus Kostuum",t:14,d:"Nee, dit is niet het vermaarde kostuum van de drakovamp, de beroemde vliegende vleermuis. Dit is potsierlijke uitdossing van een bewoner van het kerkhof, een soort Gladjanus.",ep:1,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[2347] = {n:"Missie-Verslag",t:24,d:"Dit verslag legt uit hoe de aanval van Brakmar door de oostelijke muur is gegaan.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2348] = {n:"Gladjanus instelling",t:31,d:"Je hebt de instelling van een Gladjanus totdat je weer een gevecht aangaat.",ep:1,g:17,l:1,wd:true,fm:false,w:0,m:true,u:true,p:1};
I.u[2349] = {n:"Brief voor Oto",t:24,d:"Deze brief is aan je gegeven door Domen voor Oto. Maar je bent vergeten hem aan hem te geven.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2350] = {n:"Haarlok",t:24,d:"Het schijnt dat Deze pluk haar aan één van je vijanden toebehoorde.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2351] = {n:"Pinchaut Brood",t:33,d:"Met dit brood heb je meteen gegeten en gedronken, als je het goed uitwringt, kan je er een bierkroes mee vullen.",ep:16,g:13,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[2352] = {n:"Brief van Danathor",t:24,d:"\"Ik moet je spreken, kom naar me toe zodra je tijd hebt, tot spoedig jonge vriend.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2353] = {n:"Brief van Larry Poller",t:24,d:"\"Hallo, ik ben Larry Poller, we hebben elkaar ontmoet bij de bevrijding van Colonel Lyeno. Ik wil je een gunst vragen. Kom naar me toe als je even hebt. Tot gauw.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2354] = {n:"Hersenen van een Schildpad",t:24,d:"Deze schildpadhersenen worden, als ze op de juiste wijze bereid worden, een verrukkelijk gerecht.",ep:2,g:89,l:1,wd:true,fm:true,w:0,p:1};
I.u[2355] = {n:"Oni Stof",t:24,d:"Dit blauwachtige stof is een zeer sterke toverkatalysator.",ep:2,g:88,l:1,wd:true,fm:true,w:0,p:1};
I.u[2356] = {n:"Wonder",t:31,d:"Je hebt een Fantastische Kracht tot je volgende gevecht.",ep:13,g:19,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2357] = {n:"Oliviolethout",t:38,d:"Dit Hout lijkt tegen alle temperaturen te kunnen. Inderdaad, probeer geen vuur te maken om je te verwarmen, je loopt de kans dood te gaan van de kou voordat het Hout pakt.",ep:14,g:481,l:50,wd:true,fm:true,w:5,p:0};
I.u[2358] = {n:"Bomboehout",t:38,d:"Dit hout is het zachtste van allemaal. Het is naar wens te vormen en is een genot om mee te werken.",ep:13,g:482,l:50,wd:true,fm:true,w:5,p:0};
I.u[2359] = {n:"Heticili Ufot Broche",t:24,d:"Deze kleine broche heb je gekregen van Heticili Ufot.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2360] = {n:"Eigendomsakte",t:24,d:"Dit is de eigendomsakte van het huis van Heticili Ufot.",ep:2,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[2361] = {n:"Mulic Bere\'s Boog",t:2,d:"Deze boog is een creatie van de bezielde Mulic Bere. Zijn maximale bereik is gewoon ongelooflijk. Het probleem is dat het minimale bereik ook ongelooflijk kan zijn.",ep:16,g:10,l:10,wd:true,fm:false,w:100,an:10,tw:true,e:[0,6,17,23,0,30,false,true],p:0};
I.u[2362] = {n:"Voorspelling van Paro Cabanne",t:24,d:"De voorspelling die Paro Cabanne heeft gedaan over de komende verkiezingen.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2364] = {n:"Kennis Steen",t:50,d:"Deze edelsteen weet alles en verdeelt af en toe.",ep:0,g:485,l:1,wd:true,fm:true,w:1,p:1};
I.u[2365] = {n:"Blaadje van de Hestia Bramenstruik",t:36,d:"Dit blaadje van een bramenstruik ziet er onschuldig uit, en is een onmisbare plant voor bepaalde vreemde recepten.",ep:16,g:415,l:1,wd:true,fm:true,w:1,p:1};
I.u[2366] = {n:"Krakamor Hengel",t:20,d:"Deze hengel, van metaal en diamant, is de enige hengel die het gewicht van een kralamour kan dragen. Hij is tevens geïmpregneerd met de geur van de krakamorette om een kleine kans te hebben dit monster te vangen.",ep:1,g:8,l:1,wd:false,fm:true,w:10,an:18,e:[2,6,1,9,30,30,false,false],p:1};
I.u[2367] = {n:"De Vriend Lehunui",t:10,d:"Lehunui wist veel vrienden te maken, hij nodigde zijn kameraden vaak uit voor grote gekostumeerde feesten. Hij had ook de reputatie niet op de kleintjes te letten en bood ze kostbare sieraden om ze voor hun komst te bedanken.",ep:8,g:21,l:37,wd:true,fm:true,w:20,c:"CW>49&Ps=1",p:3700};
I.u[2368] = {n:"De Eeuwige Ramoune",t:10,d:"Ramoune was een vroegere jeugdvriend van Pina, ze zijn elkaar uit het oog verloren toen Ramoune besloot een eeuwige siësta te gaan doen.",ep:2,g:22,l:37,wd:true,fm:true,w:50,c:"CW>49&Ps=2",p:1000};
I.u[2369] = {n:"Krachtige Flitsende Riem",t:10,d:"Deze prachtige riem is gemaakt naar aanleiding van een gekke weddenschap. De uitdaging was om een van de mooiste riemen te maken van Amakna: de flitsende riem. Deze weddenschap werd gewonnen door Pakape Prométhé.",ep:2,g:26,l:80,wd:true,fm:true,w:150,p:300000};
I.u[2370] = {n:"De Veget Hatief",t:10,d:"Hele lichte uitrusting, die voor wat tederheid zorgt in de wrede wereld van parende Bworks.",ep:2,g:23,l:41,wd:true,fm:true,w:5,c:"CA>50",p:4575};
I.u[2371] = {n:"Comfleecy Riem",t:10,d:"Deze riem wordt je door Jiva persoonlijk aangeraden, voor de koude en strenge nachten. Als er vlekken op komen, je kan hem wassen met Rimennelle.",ep:13,g:24,l:27,wd:true,fm:true,w:30,p:2775};
I.u[2372] = {n:"Lymph a Tik Laarzen",t:11,d:"Met deze laarzen heb je de indruk altijd op vers gras te lopen. Ze zijn perfect voor mensen met stinkvoeten.",ep:5,g:18,l:39,wd:true,fm:true,w:5,c:"CC>50",p:4100};
I.u[2373] = {n:"Maan Laarzen",t:11,d:"Maan Haar, gebruikt om deze laarzen te maken, is absoluut ideaal om je voeten warm te houden. Deze laarzen zijn ook een hartverwarmende herinnering aan Maan.",ep:14,g:19,l:62,wd:true,fm:true,w:30,p:10000};
I.u[2374] = {n:"Tarsy Laarzen",t:11,d:"Tarsy was een heremiet, een kluizenaar, die een hekel had aan bezoek. Als bewijs ontving hij gasten en liet hen de grootte van z\'n Laarzen zien.",ep:4,g:20,l:38,wd:true,fm:true,w:40,p:4000};
I.u[2375] = {n:"Orino laarzen",t:11,d:"Dankzij deze laarzen zul je in staat zijn de wind in de zeilen van een boot midden op de Asse Zee te horen, of de zuchten van een Chafer Lansier, verdwaald in het diepst van het labyrint.",ep:13,g:21,l:77,wd:true,fm:true,w:40,p:15500};
I.u[2376] = {n:"Hemal bijl",t:19,d:"Dit is de enige bijl die de machten van de Kaerlier kan weerstaan en dus de enige die hem kan kappen.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,6,1,1,45,45,false,false],c:"PJ>2,79",p:1};
I.u[2377] = {n:"Trhon Houweel",t:21,d:"Deze Enutrofhouweel is de enige die tegen extreme temperaturen kan, waardoor hij het vermaarde \'rotsbloed\' kan opdiepen. ",ep:0,g:1,l:1,wd:false,fm:true,w:10,e:[6,6,1,1,50,50,false,false],c:"PJ>24,79",p:1};
I.u[2379] = {n:"Kaerlierhout",t:38,d:"Dit hout komt van de zeer zeldzame Kaerlier. Zijn eigenschappen zijn nogal... verbazingwekkend.",ep:14,g:140,l:40,wd:true,fm:true,w:5,p:20};
I.u[2380] = {n:"Modr Cape",t:17,d:"Dit is een vreemde cape, gemaakt van stukjes Modr, maar toch blijft hij heel. Eenmaal om je schouders, kun je er zelfs een gangmaker mee worden.",ep:13,g:35,l:41,wd:true,fm:true,w:10,p:4500};
I.u[2381] = {n:"Wapperende Cape",t:17,d:"Deze cape werd gemaakt van een vaandel die vroeger op de hoogste kasteeltoren van Amakna stond. Vandaar dat hij ruikt naar in de wind gedroogd wasgoed.",ep:5,g:36,l:61,wd:true,fm:true,w:10,c:"CI>90",p:9500};
I.u[2382] = {n:"Maimpa Cape",t:17,d:"Maimpa was een Ecaflip die maling had aan leegte, en beweerde dat hij altijd op zijn pootjes terecht zou komen. Maar op een dag landde hij op een hongerige Trool. Hij werd begraven op de plek waar men zijn overblijfselen vond. Dus eigenlijk een beetje overal.",ep:14,g:37,l:36,wd:true,fm:true,w:10,p:6500};
I.u[2383] = {n:"Bloederige Cape",t:17,d:"De Bloederige Cape, op basis van een bloederige stof, voelt aan als karton, alsof de rode kleur gestold is.",ep:7,g:38,l:50,wd:true,fm:true,w:10,c:"CS>90",p:6000};
I.u[2384] = {n:"Dieren Laarzen",t:11,d:"Het mag gezegd worden, deze laarzen zien er een beetje ... hmmm... beestachtig uit. Wees dus niet verbaasd als een Boowolf verliefd wordy op je Laarzen. Dat is misschien het ergste wat je kan overkomen...",ep:14,g:22,l:94,wd:true,fm:true,w:40,p:23000};
I.u[2385] = {n:"De Grazer",t:17,d:"Ideaal voor de tuin, maar de Grazer kan ook worden gebruikt als deurmat voor de voordeur. Hij is in principe gemaakt voor de Sadidas, hij maakt zelfs de meest kwetsbare haren schoon. Sommige beweren dat hij tevens haaruitval zou tegengaan.",ep:12,g:39,l:88,wd:true,fm:true,w:10,p:20000};
I.u[2386] = {n:"Het Vod",t:17,d:"Deze vreemde cape ontleent zijn kracht aan zijn aftandse uiterlijk. Hoe smeriger, hoe beter.",ep:13,g:40,l:53,wd:true,fm:true,w:10,p:7000};
I.u[2387] = {n:"Harige Cape",t:17,d:"Het moet gezegd worden, deze Cape ruikt zeer onaangenaam. De verklaring van deze stank is, omdat het een mengsel van monsterharen is.",ep:14,g:41,l:63,wd:true,fm:true,w:10,c:"CW>30&CV>50",p:10500};
I.u[2388] = {n:"Klauwpuzzel Amulet",t:1,d:"Ooit verbrijzelde een Ecaflip, genaamd Dodge, een steen in duizend stukken waarop een schatkaart was gegraveerd. Hij dacht dat hij de kaart wel weer kon samenstellen en hij bewaarde het grootste stuk om er een mysterieus amulet van te maken. Niemand weet wat er met de schat gebeurd is.",ep:14,g:36,l:44,wd:true,fm:true,w:5,p:4000};
I.u[2389] = {n:"Badoul Amulet",t:1,d:"Dodge hield ervan alles wat in zijn ogen waarde had uit elkaar te laten barsten. Hij zei dat dat het bewijs was dat hij bestond. Ieder zijn ding.",ep:14,g:37,l:32,wd:true,fm:true,w:5,p:3200};
I.u[2390] = {n:"Mazzel Amulet",t:1,d:"Dit amulet is bijna perfect, hij vergroot aanzienlijk de wijsheid van degene die hem om z\'n nek draagt. Erg handig om tegenover je vrienden wijzer te lijken of door te gaan voor een goede leerling.",ep:5,g:38,l:49,wd:true,fm:true,w:1,p:6400};
I.u[2391] = {n:"Mazzmazzel Amulet",t:1,d:"Een oud Sukofia-gezegde van Sufokia luidt : \"De ene dag mazzel, de volgende dag dubbelmazzel\". Je kunt constateren dat, hoe ouder het gezegde, hoe belachelijker.",ep:5,g:39,l:98,wd:true,fm:true,w:1,p:24400};
I.u[2392] = {n:"Gewijzigde Dragolier",t:1,d:"Dankzij de ambachtsmannen van Amakna, die multi getalenteerd zijn, is de Gewijzigde Dragolier bijna perfect.",ep:11,g:25,l:42,wd:true,fm:true,w:1,p:5000};
I.u[2393] = {n:"Omelet Amulet",t:1,d:"De Osamodas Onehaieuf Bek die absoluut zocht naar waardering van zijn medegildeleden, besloot een revolutionair Amulet te maken. Hij kwam erop toen hij een ontbijtje voor z\'n vrienden maakte. Vreemd...",ep:1,g:40,l:17,wd:true,fm:true,w:10,p:1000};
I.u[2394] = {n:"De Knop",t:1,d:"Gekust door de zon, is de Knop hartverwarmend en geeft het een gevoel van onkwetsbaarheid aan de drager ervan. Het is zo licht, dat we vaak vergeten \'m af te doen als we gaan slapen.",ep:9,g:41,l:32,wd:true,fm:true,w:1,p:3000};
I.u[2395] = {n:"Spek Gek Sjaal",t:1,d:"De Gekke Spek was een gemeen duiveltje dat graag voor mensen doodstil bleef staan. Hij was ook bestand tegen toverkunsten, wat toenertijd veel respect afdwong. Sinds die tijd houdt de Gekke Spek zich ergens verborgen en wacht af.",ep:8,g:42,l:42,wd:true,fm:true,w:15,p:5000};
I.u[2396] = {n:"Lou Ptiote",t:1,d:"Sylveline was niet echt slim. Haar moeder, Lou, gaf haar een lantaarn als kado, en vertelde haar dochter dat ze zou “schijnen in de nacht”. Het is niet nodig om te zeggen dat Lou ook niet zo slim was, hoewel ze het slimme idee had om haar dochter een lantaarn te geven, wat het leven van Sylveline verlichtte vanaf dat moment.",ep:7,g:43,l:15,wd:true,fm:true,w:5,p:1500};
