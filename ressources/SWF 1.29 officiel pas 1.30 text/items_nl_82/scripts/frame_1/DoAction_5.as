I.u[2120] = {n:"Woorden van Ixa Mustam",t:24,d:"\"Mijn testament bevindt zich in de vuurtoren van Amakna, neem een klein Houten Schepje mee om het op te graven. En geef mijn zoon een draai om zijn oren namens mij!\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2121] = {n:"Woorden van Tsog",t:24,d:"\"Ik heb een schatkist verstopt op de oostelijke punt van Sufokia, in een tunnel, onder de wijnvaten. Ik raad je aan je uit te rusten met een Houten Schepje om hem op te graven.\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2122] = {n:"Uitnodigingsbrief voor de ceremonie",t:24,d:"Deze brief is verzegeld en hem openen zou onbeleefd zijn.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
