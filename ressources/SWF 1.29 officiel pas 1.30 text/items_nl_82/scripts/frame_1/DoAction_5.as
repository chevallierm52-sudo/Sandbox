I.u[2021] = {n:"Schitterende Hop",t:34,d:"Deze hop bezit een heel bescheiden schitterend aura, dat de magie onthult die moeder aarde hem heeft gegeven.",ep:1,g:475,l:30,wd:true,fm:true,w:2,p:0};
I.u[2022] = {n:"Magisch Hop Meel",t:52,d:"Dit meel werd gemaakt van glimmende Hop. Ongetwijfeld  bevat het magische eigenschappen.",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[2024] = {n:"Briochette",t:33,d:"Deze kleine brioche is gemaakt van magische hop. Dit verklaart de enorme hoeveelheid energie die je krijgt als je het eet.",ep:1,g:8,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2025] = {n:"Magische Briochette",t:33,d:"Deze kleine brioche is gemaakt van magische hop. Dit verklaart de enorme hoeveelheid energie die je krijgt als je het eet.",ep:1,g:8,l:20,wd:true,fm:true,w:1,c:"Cv<20",u:true,p:1};
I.u[2026] = {n:"Storm Vlas",t:34,d:"Dit Vlas heeft de ergste stormen doorstaan, en is meer dan zeven keer weer opgekomen, wat op zich al nogal bijzonder is voor Vlas, dat moet gezegd worden. Na meer dan 148 jaar geweekt te hebben in de magische rosé van de velden van de Grote Pahti, zullen zijn vezels met een beetje geluk eindelijk bruikbaar zijn.",ep:1,g:476,l:40,wd:true,fm:true,w:1,p:0};
I.u[2027] = {n:"Magische Lijn Meel",t:52,d:"Dit meel is gemaakt met Stormlijn. Het heeft waarschijnlijk dezelfde weerstand.",ep:1,g:254,l:1,wd:true,fm:true,w:1,p:0};
I.u[2028] = {n:"Stevig Magisch Brood",t:33,d:"Dit brood is gemaakt van linnenstormbloem, hetgeen verklaart waarom dit brood niet vet is en lekker smaakt.",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"Cv<30",u:true,ut:true,p:1};
I.u[2029] = {n:"Duurzaam Rogge",t:34,d:"Deze Duistere graansoort is het gelukt in onmogelijke omstandigheden te groeien.",ep:1,g:477,l:50,wd:true,fm:true,w:2,p:0};
I.u[2030] = {n:"Magisch Rogge Meel",t:52,d:"Dit meel bevat alle goede eigenschappen van de Sterke Rogge. In geval van overmatige consumptie heeft dit meel een belangrijke laxerende eigenschap.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[2031] = {n:"Stevig Rogge Brood",t:33,d:"De brood is gemaakt met Stevig Roggemeel, wat het een afschuwelijk smaakt geeft, maar het heeft wel een goede voedingswaarde.",ep:1,g:9,l:10,wd:true,fm:true,w:1,c:"Cv<40",u:true,ut:true,p:1};
I.u[2032] = {n:"Suiker Gerst",t:34,d:"Deze zeer zeldzame Gerst heeft tijdens het ontspruiten gezoet regenwater opgenomen, wat hem onschatbare magische eigenschappen heeft gegeven.",ep:1,g:477,l:10,wd:true,fm:true,w:2,p:0};
I.u[2033] = {n:"Gerstesuiker Meel",t:52,d:"Dit meel wordt gemaakt van Gerst en Suiker, en maakt het brood zo licht dat het bij de eerste de beste windvlaag wegwaait. Dat is geen reden om er meer van te eten dan dan normaal.",ep:1,g:256,l:1,wd:true,fm:true,w:1,p:0};
I.u[2034] = {n:"Gerste Suiker",t:42,d:"Door de suiker uit de gerstesuiker te onttrekken, kan men dit snoepje met een magische smaak maken.",ep:1,g:128,l:1,wd:true,fm:true,w:1,c:"Cv<50",u:true,p:50000};
I.u[2035] = {n:"Euforische Hennep",t:34,d:"Deze hennepstengel lijkt bijzonder sterke remmende effecten te hebben.Gebruikt door een specialist zou hij een zeker belang kunnen onthullen.",ep:1,g:478,l:70,wd:true,fm:true,w:1,p:0};
I.u[2036] = {n:"Goudhoudende Haver",t:34,d:"Als je naar deze haver kijkt, lijkt het of het goud huilt, teken van de grote magische kracht die het opgeslagen heeft tijdens de groei.",ep:1,g:551,l:20,wd:true,fm:true,w:2,p:0};
I.u[2037] = {n:"Goudhoudende Haver Meel",t:52,d:"Dit meel is verkregen van goudhoudende haver, wat een mooie zachte goudkleur en een ontegenzeggelijke magische kracht geeft. Maar dat wil nog niet zeggen dat je hiermee een magische banketbakker wordt.",ep:1,g:250,l:1,wd:true,fm:true,w:1,p:0};
I.u[2038] = {n:"Goudhoudend Havermout Brood",t:33,d:"Dit brood met luchtige kruim is gewoonweg perfect.",ep:1,g:5,l:10,wd:true,fm:true,w:2,c:"Cv<70",u:true,ut:true,p:1};
I.u[2039] = {n:"Cijfer voor de jagerstoets",t:24,d:"Je hebt geprobeerd te slagen voor de toets om jager te worden.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2040] = {n:"Verborgen schatkist van Tsog",t:24,d:"Je hebt de schatkist van Tsog teruggevonden in een doosje. Merkwaardig hoe dat doosje hetzelfde ruikt als Tsog, een niet te beschrijven geur.",ep:2,g:56,l:1,wd:true,fm:true,w:0,p:1};
I.u[2041] = {n:"Slechtriekende Veelvraat Dij",t:24,d:"Dit dijbeen stinkt naar dood hoewel dat geen verband houdt met het voortijdig overlijden van zijn eigenaar.",ep:1,g:64,l:20,wd:true,fm:true,w:0,p:1};
I.u[2042] = {n:"Bot van Mak Gahan",t:24,d:"Je hebt dit bot gepakt nadat je het lichaam van Mak Gahan de Chafer hebt verspreid over alle hoeken van de kamer.",ep:1,g:57,l:1,wd:true,fm:true,w:0,p:1};
I.u[2043] = {n:"Neergekrabbelde naam van de moordenaar",t:24,d:"Op dit plakkerige en stinkende stukje papier staat de naam van de moordenaar van de exploitant van de Verbrakat.",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2044] = {n:"Verbrakat Bier",t:37,d:"Dit bier lijkt teveel op kattepis... Of niet genoeg.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:6};
I.u[2045] = {n:"Kistbon",t:24,d:"Dit document bewijst dat je een kist hebt teruggebracht.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2046] = {n:"Sleutel van Brakmar",t:24,d:"Deze sleutel werd om duistere redenen gestolen door een eekhoorn.",ep:2,g:61,l:1,wd:true,fm:true,w:0,p:1};
I.u[2047] = {n:"Lijst van pauzerende soldaten",t:24,d:"Deze lijst is aan je gegeven door het militielid in de herberg. De volgende namen staan erop:\nBrank Thoof, Haco Norss, Jack Rottance, Kad Maxy",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2048] = {n:"Lijst van pauzerende soldaten",t:24,d:"Deze lijst is aan je gegeven door het militielid in de herberg. De volgende namen staan erop:\nHaco Norss, Tink Berval, Brank Thoof, Kad Maxy, Seta Bnamron",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2049] = {n:"Bekentenis van de Strijder Xale DuGros",t:24,d:"Xale DuGros geeft toe niet naar de herberg te gaan, toch neemt hij regelmatig pauze.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2050] = {n:"Bekentenis van de Strijder Nager Nacmeil",t:24,d:"De strijder Nager Nacmeil bekent dat hij niet langer meer pauze neemt, want hij voelt zich nu niet zo goed.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2051] = {n:"Bekentenis van Bishom Pot",t:24,d:"Bishom Pot bekent alles, zijn gedrag is onvergeeflijk.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2052] = {n:"Getekende en gedateerde vrijstelling",t:24,d:"Dit document geeft aan dat je een vrije dag hebt.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2053] = {n:"Badge van militielid Allen Tokar",t:24,d:"Badge van de militielid Allen Tokar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2054] = {n:"Badge van militielid Tek Aput",t:24,d:"Badge van militielid Tek Aput",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2055] = {n:"Badge van militielid Bill lédebar.",t:24,d:"Badge van militielid Bill lédebar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2056] = {n:"Kraaien Oog",t:109,d:"Een kraaienoog is altijd handig... zolang je weet hoe je het kwaadaardige oog moet vermijden.",ep:1,g:326,l:20,wd:true,fm:true,w:1,p:100};
I.u[2058] = {n:"Brandon\'s Hart",t:15,d:"Dit menselijk hart komt vast en zeker van de befaamde Lhi, die een passie voor kraaien had.",ep:1,g:328,l:20,wd:true,fm:true,w:5,p:500};
I.u[2059] = {n:"Dode Raaf",t:15,d:"Goed dat je hem hebt opgeraapt, hij is nog ongeschonden. Dood, maar ongeschonden.",ep:1,g:329,l:20,wd:true,fm:true,w:10,p:100};
I.u[2060] = {n:"Kraaienpoot",t:103,d:"Je hoeft niet de poot van een kraai te breken. Vooral niet omdat, zoals je weet, integenstelling tot het wabbit been, kraaienpoten ongeluk brengen.",ep:1,g:330,l:20,wd:true,fm:true,w:1,p:10};
I.u[2061] = {n:"Kraaien Mantel",t:17,d:"Deze mantel, niet erg mooi op \'t eerste gezicht, is hoe dan ook zeer efficiënt. Als je gewend kunt raken aan de geur van Kraai in ontbindende staat.",ep:1,g:15,l:45,wd:true,fm:true,w:5,p:5600};
I.u[2062] = {n:"Camouflage",t:31,d:"Je bent gecamoufleerd in je omgeving, totdat je je weer in de strijd mengt.",ep:1,g:1,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2063] = {n:"Vliegende Laarzen",t:11,d:"Deze laarzen, gemaakt van zeer vele deeltjes van een Raaf-kadaver, geven aan hun drager een vreemd licht gevoel, vergelijkbaar met dat wat veroorzaak wordt door het nuttigen van geroosterde Boleten.",ep:1,g:17,l:41,wd:true,fm:true,w:15,p:4500};
I.u[2064] = {n:"Camouflage Schriftrol",t:14,d:"Met behulp van deze schriftrol ben je gecamoufleerd in je omgeving totdat je je weer in de strijd mengt. Vermijd plotselinge bewegingen en verdachte geluiden als je niet ontdekt wil worden...",ep:16,g:1,l:10,wd:true,fm:true,w:1,c:"Pg=10&PM=B",u:true,p:250};
I.u[2065] = {n:"Elite Chafer Helm",t:24,d:"Deze helm van een Chafer is beschadigd, maar nog steeds doeltreffend als je deel wil uitmaken van de elite.",ep:2,g:59,l:1,wd:false,fm:true,w:0,p:1};
I.u[2066] = {n:"Kanigrou Staf",t:4,d:"De staf is een redelijke kopie van die van een Kanigrou. Hij heeft veel verrassingen in petto, maar niet alleen maar leuke verrassingen...",ep:13,g:22,l:54,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,50,false,false],c:"CS>50&CA>40&CC>30",p:5400};
I.u[2067] = {n:"Vergeetdrankje: \'Flamiche\'",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de elementaire betovering \'Flamiche\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2068] = {n:"Vergeetdrankje: \'Wottel\'",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de elementaire betovering \'Wottel\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2069] = {n:"Vergeetdrankje: \'Moon Hamer\'",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de elementaire betovering \'Moon Hamer\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2070] = {n:"Shako",t:16,d:"Deze helm van bot heeft lange tijd in de zakken van een Kanigrou gezeten. Ondanks dat hij versleten en gekrast is, behoudt hij toch enkele mooie eigenschappen.",ep:9,g:58,l:34,wd:true,fm:true,w:15,p:3200};
I.u[2071] = {n:"Vergeetdrankje: \'Bevrijding\'",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de elementaire betovering \'Bevrijding\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2072] = {n:"Vergeetdrankje: \'Bliksem\'",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de elementaire betovering \'Bliksem\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[2073] = {n:"Vergeetdrankje: \'Brokkel\'",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de bijzondere betovering \'Brokkel\'",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2074] = {n:"Vuur Bwak",t:18,d:"Dit schattige bwakje zal later een verschrikkelijke kwak worden. Tot die tijd kan je hem rustig aan je zijde houden.",ep:1,g:3,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:2,p:1};
I.u[2075] = {n:"Water Bwak",t:18,d:"Deze lieve kleine Bwak wordt later een weerzinwekkende Kwak. Tot die tijd kun je hem gerust zonder angst bij je houden.",ep:1,g:2,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:13,p:1};
I.u[2076] = {n:"Lucht Bwak",t:18,d:"Deze lieve kleine Bwak wordt later een weerzinwekkende Kwak. Tot die tijd kun je hem gerust zonder angst bij je houden.",ep:1,g:4,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:15,p:1};
I.u[2077] = {n:"Aarde Bwak",t:18,d:"Deze lieve kleine bwak wordt later een afschuwelijke kwak. Tot die tijd kun je hem gerust bij je houden.",ep:1,g:5,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:14,p:1};
I.u[2078] = {n:"Testatament van Ixa Mustam",t:24,d:"Het testament van de vader van Oto Mustam, het is geschreven in oud Brakmariaans, jammer voor je, je kennis van deze taal is beperkt tot het woord: \"Guo\'rhalys !\"",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2079] = {n:"Greedovore wijn",t:24,d:"Het schijnt dat er 20 jaar nodig is om sap van Greedovore te distilleren zonder een giftige wijn te maken.",ep:2,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[2080] = {n:"Greedovore Sap",t:24,d:"Het sap van de Greedovore is even giftig als het sap van de scheurbuik. Maar goed gedistilleerd wordt het een wijn met onvergelijkbare smaak. Dat gezegd hebbende, er zijn maar weinig mensen die weten hoe ze dit sap moeten distilleren. En meestal zijn dat piraten.",ep:2,g:63,l:1,wd:true,fm:true,w:1,p:1};
I.u[2081] = {n:"Rapport van Finche Aticus",t:24,d:"Het rapport van de spion Finche Aticus geeft een complete lijst van de wapens van Bonta en zijn manschappen.",ep:2,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[2082] = {n:"Jong Wild Zwijn",t:32,d:"Als een klein wild zwijn getuige is van de dood van zijn ouders, smeekt hij de moordenaar om voor hem te zorgen.",ep:13,g:1,l:1,wd:true,fm:true,w:0,m:true,p:10};
I.u[2083] = {n:"Brief van Oto Mustam",t:24,d:"Een brief van je meester gericht aan Vil Smisse. Hij is geschreven in een onbekend dialect om te voorkomen dat nieuwsgierigen zoals jij er een blik op werpen.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2084] = {n:"Antwoord van Vil Smisse",t:24,d:"Een antwoord van Vil Smisse aan Oto Mustam, totaal onbegrijpelijk voor de gemiddelde sterveling.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2085] = {n:"Slahumma Bier",t:37,d:"Niet alleen heeft dit bier geen enkele smaak, maar het is bovendien onbetaalbaar. Nog een overeenkomst met het vrouwenvolk.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2086] = {n:"Alakarte Bier",t:37,d:"Dit bier met Blop Griotte smaak wordt ook wel eens Manoca genoemd.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,p:3};
I.u[2087] = {n:"Bagrutte Bier",t:37,d:"Dit bier maakt je voor een heel kort moment moediger... pas evenwel op voor de val, want het moment is echt heel erg kort.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2088] = {n:"Houten Bierkroes Bier",t:37,d:"Een klassiek bier, maar de kroes is daarentegen beeldschoon gevormd. Nu heeft de houder eens meer waarde en belang dan de inhoud. Een eigenschap die het deelt met de schedel van de Iop en de volkspers.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2089] = {n:"Brantwam Bier",t:37,d:"Dit bier is warm, waardoor het \'s zomers moeilijk te drinken is. Daarentegen scheidt het een aangename geur af van geroosterd brood, waardoor het een perfect bier is voor ontbijt zonder brood.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2090] = {n:"Swashbuckler Bier",t:37,d:"Dit bier heeft een zeer onaangename ijzeren nasmaak, maar is sterk revitaliserend, wat doet denken aan de zoenen van Com Pina.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:7};
I.u[2091] = {n:"De Bwak: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek legt uit hoe je een Bwak moet fokken.",ep:3,g:4,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2092] = {n:"De MiauwMiauw: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek is een handleiding voor het fokken van een MiauwMiauw.",ep:3,g:3,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2093] = {n:"De Wabbit: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek legt uit hoe je een Wabbit moet fokken.",ep:3,g:5,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2094] = {n:"Duistere Makroute",t:16,d:"De Duistere Makroute is een hoed, gemaakt van een Verscheurde Makroute, die zonder verdoving weer gehecht is. Hij luistert alleen maar naar zijn baas en mag graag onbekenden bijten.",ep:14,g:33,l:50,wd:true,fm:true,w:5,p:6600};
I.u[2095] = {n:"De Beer",t:16,d:"De Beer is een hoed gemaakt van de kop van een dode beer. Toch is de vacht nog zacht. De maker moest wel erg handig zijn om erin te slagen de ontevreden uitdrukking van de beer te behouden.",ep:14,g:34,l:35,wd:true,fm:true,w:5,p:10000};
I.u[2096] = {n:"Dappers Duistere Dora",t:16,d:"De Geest Dapper was de eerste die begreep hoe je de Duistere Teenwilg voor nog meer dingen kon gebruiken dan alleen voor gastronomische doeleinden.",ep:14,g:35,l:37,wd:true,fm:true,w:5,p:3800};
I.u[2097] = {n:"Champo",t:16,d:"De Champo behoorde tot een van de grootste Fungi Meesters van Amakna. Gnion de Boleet was dapper en vernuftig en was de enige van zijn soort die erin slaagde respect af te dwingen bij de mensen.",ep:1,g:36,l:43,wd:true,fm:true,w:25,p:5000};
I.u[2098] = {n:"Certificaat van Plaatsing in Kennel: Aard Bwak",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Aard Bwak die je in de kennel hebt geplaatst.",ep:3,g:21,l:1,wd:false,fm:true,w:1,p:100};
I.u[2099] = {n:"Certificaat van Plaatsing in Kennel : Vuur Bwak",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Vuur Bwak die je zojuist in de kennel hebt geplaatst.",ep:3,g:23,l:1,wd:false,fm:true,w:1,p:100};
I.u[2100] = {n:"Certificaat van Plaatsing in Kennel : Water Bwak",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Water Bwak die je in de kennel hebt geplaatst.",ep:3,g:22,l:1,wd:false,fm:true,w:1,p:100};
I.u[2101] = {n:"Certificaat van Plaatsing in Kennel: Lucht Bwak",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Lucht Bwak die je in de kennel hebt geplaatst.",ep:3,g:20,l:1,wd:false,fm:true,w:1,p:100};
I.u[2102] = {n:"Certificaat van Plaatsing in Kennel: Wabbit",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Wabbit die je in de kennel hebt geplaatst.",ep:3,g:25,l:1,wd:false,fm:true,w:1,p:100};
