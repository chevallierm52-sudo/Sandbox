I.u[2118] = {n:"Brakmar Cape",t:17,d:"Met deze cape kan je incognito over een kerkhof gaan, of je vermommen als Chafeuse als je een behoefte van extreme perversiteit voelt opkomen.",ep:1,g:20,l:1,wd:true,fm:true,w:7,c:"Ps=2",p:800};
