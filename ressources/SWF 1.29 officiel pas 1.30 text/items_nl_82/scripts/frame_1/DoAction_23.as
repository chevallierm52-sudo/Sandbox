I.u[10786] = {n:"Onvolwassen Koalak Huid",t:24,d:"De kleine onvolwassen Koalak die je ontveld hebt wilde het niet aan je geven. Wat kan jou dat schelen, jij was sterker en gemener.",ep:20,g:811,l:1,wd:true,fm:true,w:1,p:10};
I.u[10787] = {n:"Vleugel van de Wilde Rossige Drakokalkoen",t:24,d:"Deze Vleugel ruikt naar zwavel. Iedere goede Drakokalkoenfokker zal je vertellen dat dit het meest malse deel is voor een BBQ. Kruid het vlees evenwel, want de Vleugel is het meest smakeloze deel.",ep:2,g:812,l:29,wd:true,fm:true,w:1,p:1};
I.u[10788] = {n:"Drakokalkoen Vleugel",t:24,d:"Men kan zeggen dat de tamme Drakokalkoen beter is dan zijn wilde neef. Hij heeft sowieso geen zwavelachtige nasmaak, maar het vlees is zo smaakvol als je je maar kan wensen, waardoor het het favoriete gerecht van alle kleintjes is.",ep:2,g:813,l:29,wd:true,fm:true,w:1,p:1};
I.u[10789] = {n:"Bos Koalak Haren",t:24,d:"Deze haren zijn bedekt met Kaliptus sap, wat ze een schijnende glinstering geeft. Helaas kunnen ze niet voor haute couture gebruikt worden omdat ze naar rottende Dragokalkoen stinken.",ep:20,g:814,l:1,wd:true,fm:true,w:1,p:100};
I.u[10790] = {n:"Mama Koalak Bot",t:24,d:"Mama Koalak heeft met name stevige botten die niet onder haar gewicht breken. Jammer genoeg geldt dit niet voor Jon Lemon, beroemd minstreel, die het gebruik van beide armen verloor toen hij werd verpletterd door de enorme dijen van Mama Koalak.",ep:20,g:815,l:1,wd:true,fm:true,w:1,p:10};
I.u[10791] = {n:"Bruine Warko Baard Haren",t:24,d:"Deze haren zijn onmisbaar om van simpele Bruine Warko kussen een wapen voor massale vernietiging te maken. Erg onmisbaar inderdaad.",ep:20,g:816,l:1,wd:true,fm:true,w:1,p:10};
