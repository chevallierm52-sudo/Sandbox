I.u[10657] = {n:"Ogrine Zoeker",t:18,d:"Deze vreemde huisdier is het resultaat van het kruisen van Amakna\'s beste truffeljagers. Zijn enorme snuit laat het Ogrine vinden, zelfs als het onder water verborgen is. Het kostte Otomai een paar jaar om dit beest te maken. Er wordt gezegd dat hij het gebruikte om iets te vinden waarvan hij dacht dat hij het kwijt geraakt was, iets was aan hem ontsnapt was. Hiermee heeft hij een van zijn vele fouten rechtgezet. Niemand weet het zeker. Wat wel zeker is, is dat het proces van Ogrine jagen zo complex is en zo veel energie nodig heeft, dat dit diertje monster zielen moet eten om te groeien. Het is op de kust van Otomai\'s eiland opgegroeid, dus zal het alleen de zielen van de monsters daar eten.",ep:0,g:56,l:1,wd:true,fm:true,w:10,p:1};
I.u[10658] = {n:"Ogrine Zoeker Geest",t:90,d:"Deze Ogrine Zoeker Geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:0,g:56,l:1,wd:true,fm:true,w:1,p:1};
I.u[10659] = {n:"Ogrine Jager Ei",t:72,d:"Dit vreemde ei bevat een klein magisch wezen. Houd het warm en het zal zeker uitkomen.",ep:0,g:206,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10660] = {n:"Geschenk: Ogrine Jager Ei",t:89,d:"Als je deze doos wild schudt en er je oor bij houdt, hoor je een vreemd geluid... net als een klein huilend diertje... ja, misschien wil je het toch niet schudden. Open het gewoon. Je zult een geweldig huisdiertje daarin vinden en wat eten en helende Eniripsa poeders.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
