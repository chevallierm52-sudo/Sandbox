I.u[10544] = {n:"Jellufo",t:18,d:"Dit wezen voor ergens anders is door zijn vorige meester getraind om alleen blop monsters te eten. Dit kan het vreemde uiterlijk en zijn Blop-achtige adem verklaren.",ep:0,g:55,l:1,wd:true,fm:true,w:10,p:1};
I.u[10552] = {n:"Ughat",t:16,d:"Dit kapsel zal je oren beschermen tegen de kou en slechte grappen.",ep:0,g:245,l:41,wd:true,fm:true,w:10,s:134,p:4525};
I.u[10553] = {n:"Tolot\'s Helm",t:16,d:"Alleen een Gobbowl speler kan het gekke idee bedenken om zichzelf als Tofu te verkleden om hun tegenstander te immiteren. De aerodynamische vormgeving van de helm geeft de drager de mogelijkheid om sneller te bewegen. Misschien is het toch geen vreemd idee. Ach, je valt in ieder geval op tussen de rest.",ep:0,g:252,l:41,wd:false,fm:true,w:10,s:142,p:4550};
I.u[10554] = {n:"Beneji\'s Helm",t:16,d:"Het is de geintegreerde rode zonnebril die deze helm de beste keus maakt voor elke fanatieke Lamechester United speler.",ep:0,g:253,l:41,wd:false,fm:true,w:10,s:143,p:4550};
I.u[10555] = {n:"Real Gobbly Schild",t:82,d:"Dit imposante schild draagt het teken van vele Gobbowl wedstrijden. Hoe robuust en intimiderend het ook is, het komt niet van pas in een echt gevecht. Je kunt het beter gebruiken om kiekeboe te spelen met Veelvraatjes.",ep:0,g:54,l:1,wd:false,fm:true,w:10,c:"PP>0",s:142,p:1};
I.u[10556] = {n:"Lamechester United Schild",t:82,d:"Dit imposante schild laat precies zien hoe de huidige jeugd is: stijl boven inhoud;\r\n            wel blaffen, maar niet bijten. Het zal je geen goed doen in een echt gevecht, behalve als je vijand je met een ballon te lijf gaat.",ep:0,g:53,l:1,wd:false,fm:true,w:10,c:"PP>0",s:143,p:1};
I.u[10557] = {n:"Real Gobbly Handschoen",t:9,d:"Deze oude handschoen helpt je om Gobbowl ballen te vangen of elk ander rond ding dat bedekt is met wol. Wat je er mee gaat doen, mag je helemaal zelf weten...",ep:0,g:176,l:43,wd:true,fm:true,w:10,s:142,p:4500};
I.u[10558] = {n:"Lamechester United Handschoen",t:9,d:"Met deze handschoen aan je hand, kun je doen alsof je een beroemde Gobbowl speler bent terwijl je overgooit met je BowWow.",ep:0,g:177,l:43,wd:true,fm:true,w:10,s:143,p:4500};
I.u[10559] = {n:"Tolot\'s Riem",t:10,d:"Gobbowl wedstrijden zijn gewelddadig en deze riem is ontwikkeld om spelers te beschermen tegen klappen op hun spieren. Je kunt echter ook gebruiken om je hamer aan op te hangen tijdens het klussen. Handig toch?",ep:0,g:159,l:41,wd:false,fm:true,w:10,s:142,p:4600};
I.u[10560] = {n:"Mounu\'s Riem",t:10,d:"Ze zeggen dat Gobbowl een spel is voor echte mannen. Deze riem is ook voor echte mannen, met genoeg opvulling om lage klappen op te vangen. Het is ook goed om jonge Srams te trainen.",ep:0,g:160,l:41,wd:false,fm:true,w:10,s:143,p:4600};
I.u[10561] = {n:"Real Gobbly Schoenen",t:11,d:"Deze schoenen bestaan al een tijdje in deze wereld, dat kun je in ieder geval ruiken. Trek ze aan en je zult er uit zien als een echte Gobbowl speler. Schop je veters in een paar Veelvraatjes en de fans zullen aan komen vliegen.",ep:0,g:144,l:42,wd:false,fm:true,w:10,s:142,p:4825};
I.u[10562] = {n:"Lamechester United Schoenen",t:11,d:"\"Modieuze schoenen krijgen de schijdsrechter aan je kant\" leest het laatste artikel en de kranten zitten er eens niet naast. Als ze goed gepoetst zijn, zal het er uit zien alsof de tegenstander je omver duwde, terwijl je uitgleedt. Gefeliciteerd! Je hebt net de basis van Gobbowl geleerd.",ep:0,g:145,l:42,wd:false,fm:true,w:10,s:143,p:4825};
I.u[10563] = {n:"Magische Orb",t:50,d:"Deze orb laten je je karakteristieke punten uitdelen. Tempelmeesters weten hoe het gebruikt kan worden.",ep:0,g:460,l:1,wd:true,fm:true,w:100,p:1000};
