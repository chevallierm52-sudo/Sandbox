I.u[10863] = {n:"Tarzantula",t:18,d:"Tarzantula is enorm slecht gemanierd, ze springt overal rond, ze gilt de hele tijd, ze bijt iedereen die ze tegenkomt – maar je houdt toch van haar, ook al weet je niet waarom. Moeder natuur heeft haar gezegend met een enorme eetlust, en daarom houdt deze zieleneter ervan Moskitos en Larvas op te vreten.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10864] = {n:"Smush",t:18,d:"Deze unieke Champ Champ is opgevoed door een roedel Boowolven, wat nog steeds niet verklaart waarom hij zulke harige oksels heeft. Deze zieleneter houdt van voedsel uit de zee, en daarom eet alleen zulke beesten.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10865] = {n:"Tofrazzle",t:18,d:"Tofrazzle is 11 keer door de bliksem geraakt terwijl ze opgroeide. Ze zal je een elektrische schok geven als je haar aait, en ze zal je een elektrische schok geven als je haar niet aait. Het is aan jou om te kiezen. Deze zieleneter haat ratten, en zal vooraan staan om ze te eten als ze beschikbaar zijn.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10866] = {n:"Sting",t:18,d:"Sting de Prespic houdt van artisjok harten gesmoord in Bherb Bloed, luxe salades met Pikoko Haar, en liedjes van Jon Lennon. Hij lijkt ook van jouw gezelschap te genieten. Deze zieleneter is alleen nogal kieskeurig over de beesten die hij eet. Hij houdt alleen van de smaak van beesten uit de Donkere Jungle.",ep:0,g:61,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10867] = {n:"Tarzantula Geest",t:90,d:"Deze Tarzantula Geest heeft de wereld van de levenden nog niet verlaten. Zal je een manier vinden om hem weer tot leven te wekken, of als een lafaard hem voor eeuwig verlaten?",ep:0,g:57,l:1,wd:true,fm:true,w:1,p:1};
