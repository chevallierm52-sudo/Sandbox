I.u[246] = {n:"Grote Vijl Schep",t:8,d:"Met deze vijlschep van uitstekende makelij wordt je een dappere strijder.",ep:1,g:5,l:17,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>7&CC>10",p:1000};
I.u[247] = {n:"Krachtige Vijl Schep",t:8,d:"Met deze vijlschep van uitstekende makelij wordt je een dappere strijder.",ep:1,g:5,l:19,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>9&CC>10",p:1150};
I.u[250] = {n:"Ares",t:8,d:"Half bijl, half schep, Ares was een van de zeven wapens die de duivel Kajlir gebruikte om het Enutrof Broederschap van  verzamelaars van Paarse Dofus te verslaan.",ep:9,g:9,l:72,wd:true,fm:true,w:50,an:16,e:[10,4,1,1,50,50,false,false],c:"CC>200",p:14000};
I.u[251] = {n:"Grijsbaard",t:8,d:"Grijsbaard was het lievelingswapen van de dwergduivel Assan Cehef, die vele dorpelingen onverwacht terrorriseerde.",ep:1,g:11,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1250};
I.u[252] = {n:"Kleine Levens Riem",t:10,d:"Deze riem verlengt het leven van zijn drager, voor meer zekerheid tijdens een gevecht.",ep:1,g:9,l:1,wd:true,fm:true,w:6,p:100};
I.u[253] = {n:"Levendige Riem",t:10,d:"Deze riem verlengt het leven van zijn drager, voor meer veiligheid tijdens het gevecht.",ep:1,g:9,l:2,wd:true,fm:true,w:9,p:200};
I.u[254] = {n:"Grote Levendige Riem",t:10,d:"Deze riem verlengt het leven van zijn drager, voor meer veiligheid tijdens het gevecht.",ep:1,g:9,l:6,wd:true,fm:true,w:9,p:300};
I.u[255] = {n:"Indrukwekkende Levens Riem",t:10,d:"Deze riem verlengt het leven van zijn drager, voor meer veiligheid tijdens het gevecht.",ep:1,g:9,l:8,wd:true,fm:true,w:9,p:400};
I.u[256] = {n:"Kleine Kracht Riem",t:10,d:"Deze riem verhoogt de kracht van zijn drager.",ep:1,g:11,l:1,wd:true,fm:true,w:6,p:100};
I.u[257] = {n:"Kracht Riem",t:10,d:"Deze riem vergroot de kracht van degene die hem draagt.",ep:1,g:11,l:2,wd:true,fm:true,w:12,p:200};
I.u[258] = {n:"Grote Kracht Riem",t:10,d:"Deze riem vergroot de kracht van zijn drager.",ep:1,g:11,l:6,wd:true,fm:true,w:12,p:300};
I.u[259] = {n:"Indrukwekkende Kracht Riem",t:10,d:"Deze riem vergroot de kracht van zijn drager.",ep:1,g:11,l:8,wd:true,fm:true,w:12,p:400};
I.u[260] = {n:"Kleine Behendigheids Riem",t:10,d:"Deze riem vergroot de behendigheid van de drager ervan.",ep:1,g:8,l:1,wd:true,fm:true,w:6,p:100};
I.u[261] = {n:"Behendigheids Riem",t:10,d:"Deze riem vergroot de behendigheid van degene die hem draagt.",ep:1,g:8,l:3,wd:true,fm:true,w:10,p:200};
I.u[262] = {n:"Grote Behendigheids Riem",t:10,d:"Deze riem verhoogt de Behendigheid van zijn drager.",ep:1,g:8,l:6,wd:true,fm:true,w:10,p:300};
I.u[263] = {n:"Indrukwekkende Behendigheidsriem",t:10,d:"Deze riem verhoogt de Behendigheid van zijn drager.",ep:1,g:8,l:8,wd:true,fm:true,w:10,p:400};
I.u[264] = {n:"Kleine Verwarde Boog",t:2,d:"Deze verwarde boog is een basiswapen, maar onderschat zijn nut niet.",ep:1,g:3,l:14,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>14&CS>4",p:750};
I.u[265] = {n:"Misleidende Boog",t:2,d:"De misleidende boog is een basisvoorwerp, maar je moet zijn nut niet verwaarlozen.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>16&CS>6",p:900};
I.u[266] = {n:"Grote Misleidene Boog",t:2,d:"De misleidende boog is een basisvoorwerp, maar zijn nut moet niet verwaarloosd worden.",ep:1,g:3,l:18,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>18&CS>8",p:1050};
I.u[267] = {n:"Krachtige Verwarrende Boog",t:2,d:"De verwarrende boog is een basiswapen, maar dat houdt niet in dat ie niet interessant is.",ep:1,g:3,l:19,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>19&CS>9",p:1200};
I.u[270] = {n:"Xaveur",t:2,d:"De Xaveur is een nuttige boog. Hij behoorde toe aan de grote  Xavier de Bakker. Tussen twee ovenbaksels bracht hij brood aan de monsters die rond zijn bakkerij hingen.",ep:7,g:5,l:60,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,9,30,100,false,true],c:"CA>60&CV>15",p:9050};
I.u[271] = {n:"De Chafer Hamer",t:7,d:"Een mooi vreemd en fascinerend wapen, dat uitermate geschikt is voor het lijf-aan-lijfgevecht, zoals de beste Chafers doen.",ep:1,g:9,l:21,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,40,30,false,false],c:"CS>10&CI>11",p:1350};
I.u[272] = {n:"Nomoon",t:2,d:"Deze boog is krachtig genoeg om een pijl naar de maan te schieten.",ep:7,g:9,l:28,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,12,30,50,false,true],c:"CA>28&CV>5",p:2350};
I.u[273] = {n:"Yamato Koord",t:2,d:"Het Yamato Koord heeft menig monsterhart doen beven. Dit scherpe wapen weet zijn pijlen te richten op de meest verborgen plekken.",ep:7,g:10,l:33,wd:true,fm:true,w:18,an:10,tw:true,e:[10,4,2,7,30,50,false,false],c:"CA>33&CS>10",p:3000};
I.u[274] = {n:"Klauw Puzzelstuk",t:51,d:"Een heel zeldzaam stuk uit de schat van Dodge, één van de grootste Ecaflips van Amakna.",ep:1,g:267,l:12,wd:true,fm:true,w:1,p:100};
I.u[276] = {n:"Stuk van de Schat van Badoul",t:15,d:"Een heel zeldzaam stuk uit een schat verborgen door de beroemde Dodge, één van de grootste Ecaflipstrijders uit Amakna.",ep:1,g:268,l:12,wd:true,fm:true,w:1,p:100};
I.u[278] = {n:"Rotsige ring",t:9,d:"Een ring gezet met zeldzame stenen. Hij dankt zijn naam aan de verschillende stenen die nodig zijn om hem te maken.",ep:1,g:4,l:15,wd:true,fm:true,w:4,p:800};
I.u[279] = {n:"Veelvraat Traan",t:1,d:"Volgens een vermaarde avonturier bevat dit amulet de traan van een Veelvraat, met de geur en eigenschappen van het afkooksel van Veelvraatleer.",ep:1,g:7,l:2,wd:true,fm:true,w:5,p:200};
I.u[280] = {n:"Regenboog Ketting",t:1,d:"Deze ketting is erg gewild onder verzamelaars, je zult er dus een goede prijs voor kunnen krijgen.",ep:1,g:11,l:6,wd:true,fm:true,w:6,p:300};
I.u[281] = {n:"Appel",t:42,d:"Deze appel herstelt enkele verloren health points. Op het hoofd van een vriend, kan hij als schietschijf dienen.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[282] = {n:"Fles Sterke Gezondheid",t:12,d:"Deze fles geeft je een paar Health Points terug... Ahum, misschien is het een goed idee om eerst even je HP te checken voordat je dit opdrinkt, anders verlies je deze Gezondheids Fles...",ep:1,g:39,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[283] = {n:"Zorgflesje",t:12,d:"Dit flesje geeft enkele verloren levenspunten terug, maar pas op, als je een flesje gebruikt terwijl je je maximum aan HP hebt, gaat het verloren...",ep:1,g:3,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[284] = {n:"Zout",t:48,d:"Zout is een gemalen mineraal, waarmee je smaak aan je brood kunt geven.",ep:2,g:260,l:1,wd:true,fm:true,w:1,p:10};
I.u[285] = {n:"Tarwe Meel",t:52,d:"Meel wordt gemaakt van gemalen tarwegranen, erg geschikt om brood van te bakken, pannenkoeken, wafels en lekkere koekjes, maar vooral om gekke spelletjes mee te doen met je jeugdvijanden.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[286] = {n:"Bakkers Gist",t:48,d:"Dit is een noodzakelijk bestanddeel om het brood te laten rijzen.",ep:1,g:137,l:1,wd:true,fm:true,w:1,p:1};
I.u[287] = {n:"Sesam Zaad",t:58,d:"Dit zaad is bijzonder rijk aan proteïne om heerlijk brood van te maken, maar het verbouwen van sesam is moeilijk in het klimaat van Amakna, waardoor het een zeldzaam en duur zaad is.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[288] = {n:"Wilde Zonnebloem Zaad",t:58,d:"Dit graan dat rijk is aan proteines, kan een heel bijzondere smaak geven aan brood. De enige manier om eraan te komen is een Wilde Zonnebloem te doden of het te kopen!",ep:1,g:6,l:12,wd:true,fm:true,w:1,p:10};
I.u[289] = {n:"Graan",t:34,d:"Graan is al sinds mensenheugenis een onmisbaar ingrediënt van het voedsel van de inwoners van Amakna en de Tofus.",ep:1,g:9,l:1,wd:true,fm:true,w:2,p:0};
I.u[290] = {n:"Champignon",t:15,d:"Met of zonder crème, champignons zijn altijd lekker. De eenvoudigste manier om eraan te komen is door een Champ Champ te doden.",ep:1,g:1,l:5,wd:true,fm:true,w:1,p:10};
I.u[291] = {n:"Boowolf Haar",t:54,d:"Dit haar is anders dan ander haar, hij bevat bijzondere eigenschappen waardoor hij zeer gewild is bij alchemisten.",ep:1,g:8,l:70,wd:true,fm:true,w:1,p:1};
I.u[292] = {n:"Boowolf Testikels",t:15,d:"Deze enorme testikels zijn bedekt met een vreemd, bijzonder zacht en warm dons. Het is praktisch onmogelijk ze in hun geheel te verkrijgen na een gevecht tegenover een Boowolf, wat gedeeltelijk hun schandalig hoge prijs verklaart.",ep:1,g:10,l:70,wd:true,fm:true,w:20,p:50};
I.u[293] = {n:"Kleine Krakler Schep",t:8,d:"Het enige wat net zo stevig is als een Krakler, is een Krakler. Vandaar dat deze schep, die bestemd is voor de jacht op Kraklers, is gemaakt van Krakler Steen.",ep:1,g:7,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1200};
I.u[294] = {n:"Krakler Schep",t:8,d:"Het enige wat net zo stevig is als een Krakler, is een Krakler. Vandaar dat deze schep, die bestemd is voor de jacht op Kraklers, is gemaakt van Krakler Steen.",ep:1,g:7,l:23,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>8&CC>15",p:1600};
I.u[295] = {n:"Grote Krakler Schep",t:8,d:"Het enige wat net zo stevig is als een Krakler, is een Krakler. Vandaar dat deze schep, die bestemd is voor de jacht op Kraklers, is gemaakt van Krakler Steen.",ep:1,g:7,l:26,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>11&CC>15",p:2000};
I.u[296] = {n:"Krachtige Krakler Schep",t:8,d:"Het enige wat net zo stevig is als een Krakler, is een Krakler. Vandaar dat deze schep, die bestemd is voor de jacht op Kraklers, is gemaakt van Krakler Steen.",ep:1,g:7,l:29,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>14&CC>15",p:2400};
I.u[297] = {n:"Laarzen van de Kleine Veelvraat",t:11,d:"Deze laarzen zijn gemaakt van Veelvraatleer en stellen de fokkers in staat makkelijker de Veelvraat te benaderen om ze, dankzij de geur die ervan afkomt, te doden.",ep:1,g:3,l:1,wd:true,fm:true,w:2,p:100};
I.u[298] = {n:"Tofueske Sandalen",t:11,d:"Deze sandalen zijn gemaakt met de veren van gekookte Tofu, en de zool is van onverslijtbare Tofu-snavel. Om nog onverklaarbare reden, wordt de drager ervan soms een beetje maf... als een Tofu.",ep:1,g:4,l:1,wd:true,fm:true,w:7,p:100};
I.u[299] = {n:"Faillet Laarzen",t:11,d:"De aanval is de beste verdediging. Met deze anti-agressie laarzen kun je zonder moeite een groep agressors uitroeien.",ep:1,g:8,l:24,wd:true,fm:true,w:30,p:1800};
I.u[300] = {n:"Papaver Zaad",t:58,d:"Dit zaad geeft hallucinerende eigenschappen aan het brood dat gewaardeerd wordt door avonturiers die willen uitrusten na een moeilijk gevecht.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:1};
I.u[301] = {n:"Tofu Veren",t:53,d:"Tofuveren worden veel gebruikt bij het naaien voor diverse vullingen. En bovenal, vergeet niet, een kilo Tofuveren weegt evenveel als een kilo lood.",ep:1,g:14,l:4,wd:true,fm:true,w:1,p:10};
I.u[302] = {n:"Pompoen",t:68,d:"Pompoenen groeien in de akkers en zijn amper iets groter dan de testikels van de boowolf, maar smaken veel lekkerder.",ep:4,g:12,l:15,wd:true,fm:true,w:5,p:10};
I.u[303] = {n:"Essenhout",t:38,d:"Essenhout is geen kwaliteitshout, maar het groeit overal en relatief snel. Pas evenwel op dat je het niet dicht bij een sterke hittebron opslaat, het is ontvlambaar.",ep:1,g:17,l:1,wd:true,fm:true,w:5,p:0};
I.u[304] = {n:"Veelvraat Leer",t:56,d:"Dit sterke leer is het belangrijkste materiaal voor de leerbewerkers die er laarzen, riemen en zelfs gesels van maken. Het enige nadeel is dat het ruikt naar het zweet van een bronstige Veelvraat... en daar maak je geen vrienden mee.",ep:1,g:16,l:9,wd:true,fm:true,w:2,p:1};
I.u[305] = {n:"Wabbit Tand",t:47,d:"De tanden van de Wabbit zijn zelfs nog erg nuttig voor de bereiding van drankjes dankzij hun krachtige eigenschappen. Zelfs als ze beschadigd zijn door het knagen op wortels.",ep:8,g:13,l:20,wd:true,fm:true,w:1,p:1};
I.u[306] = {n:"Bloem van de Duivelse Paardenbloem",t:35,d:"Op de juiste manier gekookt en vervolgens gedroogt, verliest deze bloem haar giftige eigenschappen en kan geconsumeerd worden als kruidenthee, maar de bloem van de Duivelse Paardenbloem wordt vooral gebruikt voor het amuseren van de jeugd op zoek naar romantiek. Zeg nou zelf, wie heeft er nooit tegen een Duivelse Paardenbloem geblazen om die prachtige zaadjes, zacht als de liefkozing van een zonnestraal op de blaadjes met een nog van rose doordrongen charme, in de nek van het zo begeerde wezen te laten waaien? Misschien Iops, die in plaats van blazen, de neiging hebben de zaadjes in te ademen en daardoor op jammerlijke wijze in vreselijke stuiptrekkingen te stikken.",ep:1,g:18,l:5,wd:true,fm:true,w:1,p:10};
I.u[307] = {n:"Moskitovleugel",t:104,d:"Deze zeer fijne vleugels hebben de bijzondere eigenschap de uitstraling van personen die erop durven te kauwen te bevorderen. Hun smaak komt redelijk dicht bij die van rotte Kwak-eieren, daarom worden ze voornamelijk gebruikt voor de wijsheidsdrankjes.",ep:1,g:19,l:2,wd:true,fm:true,w:1,p:1};
I.u[308] = {n:"Witte Dreggon Schelp",t:111,d:"Deze schelp is bijna onbreekbaar maar als ze het generaties lang polijsten, kunnen de beste juweliers zijn magische krachten gebruiken om amuletten te maken met uitzonderlijke krachten,",ep:11,g:21,l:64,wd:true,fm:true,w:5,p:1};
I.u[309] = {n:"Duivels Rozenblaadje",t:35,d:"Deze bloemblaadjes hebben zeer sterke zinnenprikkelende krachten, wat ze het ideale cadeau maakt om de uitverkorene van je hart te veroveren. Het is een wijs besluit te vermijden ze als kruidenthee te consumeren, aangezien ze dan het omgekeerde effect hebben.",ep:1,g:20,l:6,wd:true,fm:true,w:1,p:10};
I.u[310] = {n:"Chafer Bot",t:47,d:"Dit bot is bijna onbreekbaar, maar eenmaal in contact met water, wordt het heel zacht, waardoor de alchemisten het makkelijker kunnen gebruiken.",ep:1,g:15,l:34,wd:true,fm:true,w:5,p:1};
I.u[311] = {n:"Water",t:15,d:"Water is nuttig voor vele dingen, en hoe troebeler het is, hoe meer smaak het geeft aan het bier (pas evenwel op, gedronken water explodeert).",ep:1,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[312] = {n:"IJzer",t:39,d:"IJzer is heel nuttig voor smeden en voor hen die metaal gebruiken, sommigen gebruiken het zelfs voor het strijken.",ep:1,g:24,l:1,wd:true,fm:true,w:5,p:0};
I.u[313] = {n:"Goud",t:39,d:"Goud is een zeldzaam en edel metaal, door zijn intrinsieke kwaliteiten is het een eerste keus metaal voor het vervaardigen van wapens of bijzonder machtige voorwerpen met verfijnd uiterlijk.",ep:1,g:22,l:80,wd:true,fm:true,w:5,p:0};
I.u[315] = {n:"Diamant",t:50,d:"Alle juweliers van Amakna zijn dol op deze steen die een uitmuntende bekwaamheid vereist om te kunnen bewerken. Je moet je vaak in gevaarlijke mijnen wagen om ze te vinden, maar gelukkig zijn diamanten eeuwig.",ep:1,g:25,l:50,wd:true,fm:true,w:10,p:5000};
I.u[316] = {n:"Smaragd",t:50,d:"Gloeiend glanzend groen, deze prachtige sieraad kan met gemak een kikker in een prins veranderen, geen kus vereist.",ep:1,g:23,l:50,wd:true,fm:true,w:10,p:5000};
I.u[317] = {n:"Kleine Tabi Staf",t:4,d:"Deze staf was erg handig voor Amakna fokkers die hun kudde Tabis bij elkaar wilden houden. Het doet eigenlijk niet zoveel, maar is erg licht. Geweldig om achter Tabis aan te rennen.",ep:7,g:6,l:30,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:2650};
I.u[318] = {n:"Tabi Staf",t:4,d:"Deze staf was erg handig voor Amakna fokkers die hun kudde Tabis bij elkaar wilden houden. Het doet eigenlijk niet zoveel, maar is erg licht. Geweldig om achter Tabis aan te rennen.",ep:7,g:6,l:34,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:3200};
I.u[319] = {n:"Grote Tabi Staf",t:4,d:"Deze staf was erg handig voor Amakna fokkers die hun kudde Tabis bij elkaar wilden houden. Het doet eigenlijk niet zoveel, maar is erg licht. Geweldig om achter Tabis aan te rennen.",ep:7,g:6,l:37,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>25",p:3750};
I.u[320] = {n:"Krachtige Tabi Staf",t:4,d:"Deze staf was erg handig voor Amakna fokkers die hun kudde Tabis bij elkaar wilden houden. Het doet eigenlijk niet zoveel, maar is erg licht. Geweldig om achter Tabis aan te rennen.",ep:7,g:6,l:40,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>30",p:4300};
I.u[323] = {n:"Kam Assutra Amulet",t:1,d:"Dit amulet geeft bijzondere eigenschappen aan zijn drager, deze voelt van binnen een geheimzinnige uitstraling met als gevolg dat zijn fysieke vermogen wel 10 keer groter wordt.",ep:1,g:4,l:43,wd:true,fm:true,w:5,p:5000};
I.u[324] = {n:"Krokette Amulet",t:1,d:"Dit amulet heeft de eigenschap roze te worden op de dagen dat de drager in een goed humeur is. Men zegt eveneens dat het je kans om goede voorwerpen te vinden, vertienvoudigd.",ep:1,g:7,l:6,wd:true,fm:true,w:5,p:300};
I.u[325] = {n:"Sram amulette",t:1,d:"Dit amulet is gemaakt van kleine schedels en is gehouwen uit botten door een van de grootste Sram Juweliers. Het is uniek. Zijn drager kan er makkelijker mee ontsnappen uit hachelijke situaties",ep:1,g:3,l:2,wd:true,fm:true,w:5,p:200};
I.u[326] = {n:"Deulegarnoulle Amulet",t:1,d:"Dit amulet komt uit de noordelijke regio\'s en verleent zijn drager de mogelijkheid om makkelijker wezens te bezweren.",ep:1,g:2,l:33,wd:true,fm:true,w:4,p:3000};
I.u[327] = {n:"Karne Ridders Lemmet",t:6,d:"Dit lemmet is oorspronkelijk gesmeden voor de Karne Ridders en was eigenlijk te zwaar voor deze zwakke kwelgeesten. Toch is en blijft hij licht voor een normaal persoon, zodat je er heel snel mee kunt slaan.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,50,20,false,false],c:"CS>32",p:900};
I.u[328] = {n:"Schnij-schnij",t:6,d:"Dit vreemd gevormde dubbele lemmet werd oorspronkelijk gebruikt voor het snoeien van bomen om vooruit te komen in ondoordringbare bossen. De houthakkers bemerkten al snel dat het tevens een uitgelezen wapen is om elke vorm van bedreiging uit te roeien.",ep:1,g:4,l:18,wd:true,fm:true,w:28,an:14,e:[6,5,1,1,20,60,false,false],c:"CS>36",p:1050};
I.u[329] = {n:"Triompf Boog",t:2,d:"Zoals zijn naam aangeeft, kun je met deze boog makkelijk een gevecht winnen. Een groot architect Cra zonder verbeelding heeft deze naam gegeven aan een van zijn constructies.",ep:7,g:11,l:30,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,10,30,50,false,true],c:"CA>30&CC>5&CS>10",p:1950};
I.u[331] = {n:"Regen Boog",t:2,d:"Dit is de meest begeerde boog van heel Amakna, men zegt dat daar waar zijn pijlen vallen, je een schat kunt vinden. Vreemd genoeg werkt dat alleen maar als het regent terwijl de zon schijnt.",ep:7,g:16,l:22,wd:true,fm:true,w:19,an:10,tw:true,e:[10,5,2,11,30,50,false,true],c:"CA>22&CC>15",p:1500};
I.u[332] = {n:"Jeannes Boog",t:2,d:"Jeanne was een beetje getikt, zij hoorde de Tabis boeren in haar hoofd. Om te voorkomen dat zij zichzelf zou bezeren met haar boog, werd hij in beslag genomen en men besloot  hem levend te verbranden om zo de stemming te verhogen tijdens de feestelijke opening van de herberg.",ep:7,g:15,l:30,wd:true,fm:true,w:23,an:10,tw:true,e:[10,4,2,9,30,50,false,true],c:"CS>10&CA>30",p:2550};
I.u[333] = {n:"Stok Ba-rood",t:3,d:"Oorspronkelijk bedoeld om te eten, is deze stok een gevreesd wapen geworden. In feite heeft Xavier de Bakker het 234 jaar vergeten in zijn oven, terwijl hij weg was om brood uit te delen aan de monsters rondom zijn bakkerij.",ep:3,g:9,l:50,wd:true,fm:true,w:1,an:11,e:[5,3,3,5,50,50,false,true],c:"CW>40&CI>100",p:6650};
I.u[334] = {n:"Liriel Stok",t:3,d:"Deze toverstok was van de Eniripsa Liriel die onder afschuwelijk lijden overleed aan een overdosis aardbeien en zijn vleugels verloor in een reutel die je bloed deed stollen. De verzamelaars doen bijna een moord voor deze als verdoemd bekend staande stok.",ep:7,g:5,l:20,wd:true,fm:true,w:13,an:11,e:[5,5,2,3,50,50,false,true],c:"CI>40",p:1300};
I.u[335] = {n:"Bwork Magus Staf",t:4,d:"Zonder hun staf zijn de Bwork Magus net zo onschadelijk als de Tofus zonder hun Becos. Dat zegt genoeg over de kracht van deze staf.",ep:7,g:1,l:58,wd:true,fm:true,w:28,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>58&CA>20",p:8900};
I.u[336] = {n:"Staf van Groot Vader Wabbit",t:4,d:"Met deze staf kun je Wottels ontlopen. Met vraagt zich af waarvoor dat goed is in een gevecht.",ep:8,g:1,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",p:2900};
I.u[337] = {n:"Bwork Boogschutter Boog",t:2,d:"Deze boog is er simpel in gebruik want hij is aangepast aan de intelligentie van een Bwork Boogschutter, zodat hij ook bijna gebruikt kan worden door een Tofu. Daarentegen heb je de kracht nodig van een Krakler om hem te spannen.",ep:7,g:4,l:20,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>20&CA>20",p:1300};
I.u[338] = {n:"Kleine Bwork Lemmet",t:6,d:"Dit ogenschijnlijk primitieve zwaard wordt zeer gewaardeerd door de meest debiele Bworks, die niet weten hoe ze een boog of een staf moeten hanteren. Sommige halen zelfs het heft en het lemmet door elkaar, waar hun tegenstanders onbedaarlijk om moeten lachen.",ep:1,g:13,l:21,wd:true,fm:true,w:30,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>42",p:1400};
I.u[339] = {n:"Chafer Lemmet",t:6,d:"Dit lemmet behoorde toe aan de slager Metzger en was gesmeden voor het doorzagen van botten. De Chafer wist dit gereedschap aan de slager te ontfutselen en het is nu een van de meeste geduchte wapens waarmee je iemand kunt amputeren.",ep:1,g:5,l:27,wd:true,fm:true,w:20,an:14,e:[20,6,1,1,15,60,false,false],c:"CS>54&CC>10",p:2100};
I.u[340] = {n:"Leurnettes",t:5,d:"Volgens de legende kan je met deze dolken van alles stelen, maar vooral van alles van iedereen, of omgekeerd, maar niemand weet meer precies hoe de legende ging.",ep:1,g:9,l:12,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>12",p:600};
I.u[341] = {n:"Eurfolles Dolken",t:5,d:"Deze legendarische dolken zijn ware collectors items voor iedere zichzelf respecterende Sram, ze worden zelfs zozeer vereerd, dat sommige Srams weigeren ze te stelen.",ep:7,g:10,l:46,wd:true,fm:true,w:10,an:13,e:[10,2,1,1,30,50,false,false],c:"CA>46",p:5600};
I.u[342] = {n:"Pickeur Hamer",t:7,d:"Deze zeer bijzonder hamer is gemaakt van Kwaksnavels, en dat verklaart waarom hij erg steekt als je met deze hamer wordt geslagen.",ep:5,g:12,l:18,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>12&CS>6",p:1100};
I.u[345] = {n:"Kleine Graaf Schep",t:8,d:"Na een wat te rijkelijk beschonken avond in de herberg die uitmondde in een knokpartij, heeft een Enutrof ontdekt dat deze schep, die oorspronkelijk gemaakt is voor grote bouwwerkzaamheden, een uitstekend wapen was.",ep:1,g:8,l:25,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>5&CC>20",p:1900};
I.u[346] = {n:"Stormkeer Ring",t:9,d:"Volgens sommige legendes beschermt deze ring zijn drager tegen stortbuien. Maar dat is nog nooit bewezen, aangezien het in Amakna nooit regent.",ep:1,g:34,l:17,wd:true,fm:true,w:4,p:1000};
I.u[347] = {n:"Vergulde Wortelstok",t:8,d:"Deze schep is bijzonder geschikt om het onkruid wortelstok te vernietigen. Bovendien is het een uitstekend wapen om iets anders dan wortelstok te vernietigen.",ep:1,g:10,l:40,wd:true,fm:true,w:30,an:16,e:[10,4,1,1,50,50,false,false],c:"CS>10&CC>30",p:4400};
I.u[348] = {n:"Selderij-Thee Laarzen",t:11,d:"De laarzen behoorden toe aan een kok die altijd haast had en die hollend zijn selderij en thee ging halen op het platteland van Amakna.",ep:2,g:5,l:53,wd:true,fm:true,w:20,p:6700};
I.u[350] = {n:"Zilver",t:39,d:"Zilver is een glimmend metaal dat zeer gewaardeerd wordt door juweliers, in tegenstelling tot wat sommige personen je willen doen geloven, heeft het geen enkel speciaal effect op vampiers. Behalve als het zielige vampieren zijn... of artistieke vampieren... Maken vampieren juwelen? Dat... weten we niet... Maar goed, als het een hele nare vampier is die alleen maar bloed wil zien, zal het niet helpen. Verkoop dat ding gewoon.",ep:1,g:28,l:60,wd:true,fm:true,w:5,p:0};
I.u[351] = {n:"Amakna Bier",t:37,d:"Dit bier herstelt je levens punten. Vergeet echter niet het oude gezegde – \'Soms drink je je drinken en soms drinkt je drinken jou.\'",ep:2,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[352] = {n:"Klein Heilig Zwaard",t:6,d:"Een heilig zwaard dat wordt uitgedeeld aan jonge strijders tijdens hun opleiding.",ep:1,g:1,l:13,wd:true,fm:true,w:30,e:[5,4,1,1,50,50,false,false],c:"CS>26&CV>5",p:700};
I.u[353] = {n:"Kleine Ridder Zwaard",t:6,d:"Het zwaard van de Kleine Ridder is sterk en doeltreffend, als hij goed gebruikt wordt, kan hij enorme schade aan je vijanden toebrengen.",ep:7,g:9,l:21,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>42",p:1400};
I.u[354] = {n:"De Klebik",t:6,d:"Dit type zwaard was gesmeed voor de bewaking van een rijke beroemde handelaar. Hij is voornamelijk bedoeld om dieven af te schrikken, maar het is ook een geducht wapen om dieven om te brengen of eerlijke lastige klanten.",ep:1,g:11,l:25,wd:true,fm:true,w:20,e:[12,4,1,1,30,60,false,false],c:"CS>50&CW>5",p:1850};
I.u[355] = {n:"Waarde Ring",t:9,d:"Deze ring geeft kracht en moed aan zijn drager.",ep:1,g:7,l:12,wd:true,fm:true,w:4,p:600};
I.u[356] = {n:"Weerstands Riem",t:10,d:"Door deze riem verhoogt de drager zijn weerstand en krijgt hij meer uithoudingsvermogen.",ep:1,g:3,l:27,wd:true,fm:true,w:16,p:2200};
I.u[357] = {n:"De Staart",t:6,d:"Dit zwaard symboliseert het deel van hun lichaam waar de Ecaflips het meest trots zijn. Dit zwaard vat heel goed de manier van doen van de spelers samen.",ep:1,g:18,l:13,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>26&CA>10",p:650};
I.u[358] = {n:"Helse Staart",t:6,d:"De Helse Staart is werkelijk hels... Hij maakt je tegenstanders of je teamgenoten helemaal gek, en verandert je teamgenoten in tegenstanders als je het slecht aanpakt. Daarentegen lijkt het tegenovergestelde nooit voor te komen.",ep:1,g:18,l:21,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>42&CA>10",p:1400};
I.u[359] = {n:"De Ecalisator",t:9,d:"Deze ring werd lang geleden door koning Alister Snoc gegeven aan Isidor, een slimme kat, waarmee hij de onvergelijkbare behendigheid van deze Ecaflip erkende.",ep:1,g:35,l:29,wd:true,fm:true,w:3,p:2400};
I.u[360] = {n:"Tiwabbit Oren",t:106,d:"Deze kleine bruine behaarde oren smaken naar dode boowolf als ze eenmaal gekookt zijn. Daarentegen worden ze zeer gewaardeerd als ze bereid zijn met koninklijke gelei.",ep:8,g:30,l:11,wd:true,fm:true,w:1,p:10};
I.u[361] = {n:"Wowtel",t:68,d:"Het is het enige voedsel dat de Tiwabbit Wosungree kan eten. Het is een goed excuus voor hun zware vertraging.",ep:2,g:31,l:20,wd:true,fm:true,w:1,p:2};
I.u[362] = {n:"Blauwe Larve Huid",t:59,d:"Deze zeer gladde huid vormt een goed ingrediënt voor toverdrankjes.",ep:1,g:32,l:2,wd:true,fm:true,w:1,p:2};
I.u[363] = {n:"Oranje Larva Huid",t:59,d:"Deze verrukkelijk zachte huid is een geweldig ingrediënt voor magische drankjes.",ep:1,g:33,l:9,wd:true,fm:true,w:1,p:2};
I.u[364] = {n:"Groene Larve Huid",t:59,d:"Deze gladde huid is een uitstekend ingrediënt voor toverdrankjes.",ep:1,g:34,l:7,wd:true,fm:true,w:1,p:100};
I.u[365] = {n:"Arachnee Poot",t:103,d:"Heel fijn, maar zeer behaard pootje. Door de alchemisten zeer gewaardeerd om zijn euforiserende eigenschappen, het is het zwakke puntje dat hun ruïneerde.",ep:1,g:35,l:2,wd:true,fm:true,w:1,p:10};
I.u[366] = {n:"Tofu Snavel",t:47,d:"Dit belachelijk kleine Tofusnaveltje, dat er onschuldig uitziet, is ondertussen erg scherp. De Amakna boogschutters gebruiken ze al eeuwen als pijlpunten.",ep:1,g:37,l:4,wd:true,fm:true,w:1,p:2};
I.u[367] = {n:"Tofu Ei",t:105,d:"Dit Ei heeft de eigenschap te stinken als een rot ei, ook al is het geen rot ei, dus stel je eens voor hoe het ruikt als het wel verrot is. Daarentegen weet niemand wie er nou het eerst in Amakna was, de Tofu of het Tofu Ei.",ep:1,g:38,l:4,wd:true,fm:true,w:1,p:1};
I.u[368] = {n:"Aardbeien Gelei",t:110,d:"Deze heerlijke aardbeiengelei heeft meer dan één avontuurlijke zoetekauw ziek gemaakt. Zoals het befaamde spreekwoord zegt: \"alles is gif, niets is gif, het gaat om de hoeveelheid\". In het geval van aardbeiengelei geldt dus: vermijd een overdosis.",ep:5,g:40,l:28,wd:true,fm:true,w:1,p:100};
I.u[369] = {n:"Mint Gelei",t:110,d:"Deze heerlijke mintgelei heeft een beter effect op een avonturier met een beetje een te zieke smaak. Het heeft een kalmerend effect op het moraal van je hele team als je het inneemt ingeval van slechte adem.",ep:5,g:41,l:10,wd:true,fm:true,w:1,p:100};
I.u[370] = {n:"Koninklijke Blauwige Gelei",t:110,d:"Deze heerlijke gelei is afkomstig van de honingverwerking en -gisting van de Koninklijke Gelei. Deze gelei, die niet te eten is in onbewerkte vorm, is niet meer dan een eersteklas ingrediënt voor snoepjes.",ep:7,g:407,l:50,wd:true,fm:true,w:1,p:100};
I.u[371] = {n:"Moskito Wenkbrauw",t:15,d:"De Moskito heeft lange fijne wenkbrauwen die zijn verleidelijke ogen goed doen uitkomen. Door zijn grote gevoeligheid zijn de wenkbrauwen vaak doordrenkt met tranen die nog onbekende eigenschappen hebben.",ep:1,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[372] = {n:"Hoofdband van de Zwarte Tiwabbit",t:15,d:"Met deze hoofdband heb je de allure van een krijger voor de Zwarte Tiwabbit die hem draagt. Deze traditie om een hoofdband te dragen komt blijkbaar van de Wabbit Wambo.",ep:8,g:29,l:11,wd:true,fm:true,w:1,p:2};
I.u[373] = {n:"Stengel van de Duivelse Paardenbloem",t:36,d:"Deze stengel, zo soepel als riet, buigt maar breekt niet, wat hem een eerste keus element maakt voor het maken van zwepen en andere attributen die onmisbaar zijn bij het opvoeden van kinderen.",ep:1,g:45,l:6,wd:true,fm:true,w:1,p:10};
I.u[374] = {n:"Tong van de Duivelse Paardenbloem",t:36,d:"De groene kleur van deze tong komt door het overmatig eten van mintgelei waar de Duivelse Paardenbloem verzot op is.",ep:1,g:555,l:5,wd:true,fm:true,w:1,p:2};
I.u[375] = {n:"Boze Tofu Tand",t:47,d:"De Boze Tofu heeft zijn ridicuul kleine snavel ingeruild voor ridicuul grote tanden. Niet makkelijk om te weten wat nu het gevaarlijkst is, behalve dan door het zelf uit te proberen.",ep:1,g:47,l:3,wd:true,fm:true,w:1,p:1};
I.u[376] = {n:"Boze Tofu Vleugel",t:104,d:"Dit belachelijk kleine vleugeltje is niet van groot belang voor de Boze Tofu, behalve om de lucht in beweging te brengen om de Moskitos uit hun evenwicht te brengen.",ep:1,g:48,l:3,wd:true,fm:true,w:1,p:1};
I.u[377] = {n:"Champ Champ Doorn",t:15,d:"Deze giftige doorn beschermt de Champ Champ tegen lijfelijke aanvallen, maar zorgt er daarentegen ook voor dat hij niet kan liefkozen zonder hen die hem lief zijn te doden. Gelukkig voor hem gebruikt de Champ Champ Sporme dat hij over een afstand schiet om zich voort te planten.",ep:1,g:49,l:5,wd:true,fm:true,w:1,p:1};
I.u[378] = {n:"Champ Champ Sporma",t:15,d:"Dit sporma is het \"kleine zaadje\" van de Champ Champ waarmee hij zijn kleintjes een beetje overal kan verspreiden, waar dan ook. Let op, het sporma van de Champ Champ wordt vooral aangetrokken door stinkende voeten en de geur van de Laarzen van Bowisse.",ep:1,g:50,l:5,wd:true,fm:true,w:1,p:1};
I.u[379] = {n:"Krab Schaar",t:47,d:"Deze buitenpropotionele schaar is bijna hol, de Krab kan er maar net het publiek mee verbluffen en voor een baas doorgaan. Daarentegen heeft hij wel de naam onbreekbaar te zijn.",ep:1,g:51,l:4,wd:true,fm:true,w:1,p:1};
I.u[380] = {n:"Blaadje van de Wilde Munt",t:36,d:"Dit is het basisvoedsel van de Groene Gelei, als je munt ruikt, leidt daar dan dus niet automatisch uit af dat er munt vlak bij je is.",ep:1,g:52,l:30,wd:true,fm:true,w:1,p:0};
I.u[381] = {n:"Aardbei",t:46,d:"Dit is het voedingsmiddel op basis van aardbeiengelei. Als je een aardbeienlucht ruikt, ben je misschien op het juiste spoor.",ep:7,g:53,l:28,wd:true,fm:true,w:1,p:1};
I.u[382] = {n:"Karne Ruiter Nagel",t:47,d:"Deze vieze en gebruikte nagel heeft overal rondgezworven, maar voornamelijk op weinig aan te raden plekken. Het is dan ook aan te bevelen om hem niet overal te laten rondzwerven en vooral niet op weinig aan te raden plekken.",ep:3,g:54,l:16,wd:true,fm:true,w:1,p:1};
I.u[383] = {n:"Hoorn van de Veelvraat",t:47,d:"De Hoornen van Veelvraat zijn glanzend en zacht als leer, om onbekende redenen houden Osamodas er in het bijzonder van.",ep:1,g:55,l:9,wd:true,fm:true,w:1,p:1};
I.u[384] = {n:"Veelvraat Wol",t:57,d:"Deze dikke wol ruikt naar een  Bwork die zich verwaarloost, maar is toch erg warm en tast vooral niet de gevoelige huid aan, wat Eniripsas zeker waarderen bij hun ondergoed.",ep:1,g:56,l:9,wd:true,fm:true,w:1,p:1};
I.u[385] = {n:"Veelvraat Kwijl",t:15,d:"Dit etterige kwijl krijgt zijn geur van het feit dat de Veelvraat zijn tijd verdrijft met zijn wol te likken, wat tevens de oorzaak is van de walgelijke adem van de Veelvraat.",ep:1,g:57,l:9,wd:true,fm:true,w:1,p:1};
I.u[386] = {n:"Everzwijn Snuit",t:15,d:"Deze varkenssnuit is kwaliteitsgereedschap om de grootste eikels die in het onderhout ronddwalen te verjagen. In tegenstelling tot de snuit van het DrakenVarken, deze is wegens zijn walgelijke geur niet te eten.",ep:1,g:58,l:14,wd:true,fm:true,w:1,p:1};
I.u[387] = {n:"Slagtand van Everzwijn",t:47,d:"Met deze slagtand kan het Everzwijn zich verdedigen en als bijkomstigheid zijn jachtsnuit ontdoen van eikels. Vergeet dus niet ze met levenswater te reinigen alvorens er poeder van te maken.",ep:1,g:59,l:14,wd:true,fm:true,w:1,p:1};
I.u[388] = {n:"Everzwijnhaar",t:54,d:"Deze bijzonder sterke haren worden onder andere gebruikt voor het maken van penselen en bezems. Sommige mensen hebben last van hevige allergie bij het contact met deze haren, het is dus aanbevolen er niet hard tegenaan te wrijven.",ep:1,g:60,l:14,wd:true,fm:true,w:1,p:1};
I.u[389] = {n:"Wilde Zonnebloem Olie",t:60,d:"Deze olie wordt sterk aangeraden door voedingsdeskundigen vanweg zijn hoge gehalte aan essentiële vette zuren. Door zijn gehalte aan goede vetten en lage concentratie slechte vetten is deze olie een goede keuze.",ep:1,g:61,l:12,wd:true,fm:true,w:1,p:100};
I.u[390] = {n:"Noten Olie",t:60,d:"Deze olie met een fruitige smaak wordt gebruikt in gebak om smaak aan bepaalde koekjes te geven. Deze olie met weinig verzadigde vetten kan niet lang bewaard worden, zelfs niet in een gesloten fles.",ep:4,g:62,l:32,wd:true,fm:true,w:1,p:100};
I.u[391] = {n:"Cashew Noot",t:58,d:"Van deze cashewnoot kan olie worden gemaakt als hij onrijp wordt geoogst. Eenmaal gedroogd, kan hij altijd dienst doen als speelgoed voor de wat onnozele Iopkinderen.",ep:4,g:63,l:32,wd:true,fm:true,w:1,p:10};
I.u[392] = {n:"Pekan Noot",t:58,d:"Met deze Pekannoot kan je olie maken, maar het verdient de voorkeur om hem gedroogd te consumeren met het oog op de laxerende effecten van zijn olie.",ep:4,g:64,l:32,wd:true,fm:true,w:1,p:10};
I.u[393] = {n:"Eikel",t:58,d:"Everzwijnen zijn dol op eikels, en iedereen of bijna iedereen vraagt zich af waarom.",ep:1,g:65,l:14,wd:true,fm:true,w:1,p:10};
I.u[394] = {n:"Hazel Noot",t:58,d:"Deze kleine Hazelnoot is heerlijk, vooral gecombineerd met een chocoladereep. Jammer dat er in Amakna geen chocola bestaat.",ep:1,g:66,l:14,wd:true,fm:true,w:1,p:1};
I.u[395] = {n:"Klavertje 5",t:36,d:"Dit klavertje vormt een essentieel element in het voedsel van de Tabis. De fokkers letten evenwel goed op de mate waarin het Klavertje 5 een opgezette buik veroorzaakt bij de tabis.",ep:1,g:67,l:20,wd:true,fm:true,w:1,p:0};
I.u[396] = {n:"Palm Olie",t:60,d:"Licht van smaak en geur is deze olie geschikt voor vele doeleinden, van frituren tot het bereiden van een slasaus.",ep:3,g:68,l:32,wd:true,fm:true,w:1,p:100};
I.u[397] = {n:"Koode  Olie",t:60,d:"Deze zeldzame olie is een waar élixer. Dit uitstekende smeermiddel voorkomt dat raderwerken en drijfwerken vastlopen en slijten. Deze olie komt voort uit een ingewikkelde melange van diverse oliën.",ep:4,g:69,l:32,wd:true,fm:true,w:1,p:100};
I.u[398] = {n:"Palmvrucht",t:46,d:"Als je deze vreemde vrucht perst krijg je een gezuiverde olie. Jammer dat deze vrucht bijna niet geperst kan worden door zijn schelp die bijna even hard is als de zool van de laarzen van de Bowisse.",ep:3,g:81,l:32,wd:true,fm:true,w:1,p:10};
I.u[399] = {n:"Sesam Olie",t:60,d:"Deze uit sesamzaad gewonnen olie onderscheidt zich door zijn rijke smaak van gegrilde hazelnoten. Jammer dat zijn geur meer lijkt op gegrilde Veelvraat in plaats van wilde mintblaadjes.",ep:1,g:71,l:1,wd:true,fm:true,w:1,p:100};
I.u[400] = {n:"Gerst",t:34,d:"Gerst is een graansoort die voor bier wordt gebruikt, maar ook voor vee en soms voor bierdrinkend vee.",ep:1,g:82,l:10,wd:true,fm:true,w:2,p:0};
I.u[401] = {n:"Hop",t:34,d:"De bloem van de vrouwelijke hopplant omvat de voor de brouwer nuttige kernprincipes, vooral de bittere hars en essentiële oliën. \"Dat doet me denken aan mijn Biologie-lessen, alleen heb ik nooit Biologie gehad\". Aldus Gabrielle Naye bij het zien van deze omschrijving, toegegeven - lichtelijk geromantiseerd.",ep:1,g:80,l:30,wd:true,fm:true,w:2,p:0};
I.u[402] = {n:"Poeder Gist",t:48,d:"Gist waarvan de cellen niet aan elkaar kleven en dus een tijdje in het bier blijven hangen alvorens te neer te slaan. Dit gist is bijzonder zeldzaam, wat de exorbitant hoge prijs verklaart.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[403] = {n:"Uitvlokkend Gist",t:48,d:"Deze gistcellen plakken aan elkaar vast en haasten zich naar de bodem van de gistkuip in plaats van in de most te drijven. Het is een vrij gangbaar gist, dat men bij de belangrijkste grossiers kan vinden.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[404] = {n:"Biergist",t:48,d:"Dit is klassiek gist, dit is onmisbaar voor de rijping van bier, en dus onmisbaar voor ieder levend wezen dat zich met bier voedt.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[405] = {n:"Malt",t:34,d:"Deze naam is gegeven aan gekiemde gerst. Dit is het eerste klas ingrediënt voor kwaliteitsbier. Pas evenwel op, malt is pervers en heeft de neiging het bier tijdens het kiemen te absorberen, een beetje als de Tot na een zware dag jagen op de Tofus.",ep:1,g:83,l:60,wd:true,fm:true,w:2,p:0};
I.u[406] = {n:"Wo Wabbit Maag",t:15,d:"Deze maag kan heel makkelijk uitzetten, wat de moeilijke vertering van de Wo Wabbit, die de neiging heeft zich te buiten te gaan aan gefermenteerde Wottellikeur, bijzonder vergemakkelijkt.",ep:8,g:146,l:39,wd:true,fm:true,w:1,p:10};
I.u[407] = {n:"Prespic Stekel",t:47,d:"Voor het schoonmaken van je tanden of om een nieuwe pijlpunt te maken, niets beters dan de Prespic Stekel",ep:1,g:134,l:18,wd:true,fm:true,w:1,p:50};
