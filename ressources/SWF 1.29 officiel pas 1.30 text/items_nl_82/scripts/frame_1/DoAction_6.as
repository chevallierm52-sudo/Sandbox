I.u[2397] = {n:"Rommel Pot",t:1,d:"De oude Rommel Pot mocht graag van alles en nog wat maken. Op een dag maakte hij dit intrigante gevormde medaillon. Toen hij het om zijn nek had gedaan, voelde hij een vreemde sensatie. Een zeer vreemde sensatie...",ep:13,g:44,l:30,wd:true,fm:true,w:10,p:3000};
I.u[2398] = {n:"Kanigrou Oog",t:1,d:"De beroemde Kanigrou Rook Y Balboua heeft hem gegeven aan Melyonen om haar te bedanken dat zij hem aan zijn toekomstige vrouw heeft voorgesteld, Ar d\'rieeeeeeeeeneuh zoals hij haar placht te noemen.",ep:13,g:45,l:52,wd:true,fm:true,w:1,p:7000};
I.u[2399] = {n:"Het Zachte Kalf",t:1,d:"Jozébo Vez was een kalfsherder. Kalveren zijn verre neven van de Veelvraat. In zijn kudde liepen enkele beesten met een veel zachtere vacht dan de andere. Deze beesten brachten meer geld op en om zijn beesten te onderscheiden, bond hij hen deze halsband om.",ep:13,g:46,l:15,wd:true,fm:true,w:1,p:1};
I.u[2400] = {n:"Duistere Dieren Laarzen",t:11,d:"Het moet gezegd worden, deze laarzen zijn een ietwat ... Duister.  Verbaas je dus niet als een Vampier verliefd wordt op jou en je laarzen. Dat is wel het ergste wat je kan overkomen.",ep:14,g:23,l:122,wd:true,fm:true,w:35,p:38000};
I.u[2401] = {n:"Kwelsh Kaart",t:15,d:"Deze kaart is verbonden aan de meester Kwelsh. Dat is alles wat je weet en wat je moet weten.",ep:16,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[2402] = {n:"Zwaard van Sériane-Kerm",t:6,d:"Dit zwaard is een erecadeau dat men alleen geeft aan volleerde huurlingen. Maar het snijdt ook erg goed.",ep:1,g:25,l:30,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[2403] = {n:"Peeka Riem",t:10,d:"In vergane dagen werd het gebruikt als parool, de Peeka Riem heeft kennelijk een reserve kracht met betrekking tot andere riemen. Maar niemand weet nog wat. Je kunt maar beter een oogje in het zeil houden.",ep:13,g:25,l:49,wd:true,fm:true,w:10,p:6100};
I.u[2404] = {n:"Ratten Riem",t:10,d:"Deze riem is van een Riool Rat geweest, hij stond hem wondermooi, mooi aansluitend ter hoogte van de heupen, hielp hij hem zijn liefdesheft te verbergen.",ep:2,g:27,l:55,wd:true,fm:true,w:10,p:8100};
I.u[2409] = {n:"Vuur Kwak Muts",t:16,d:"Met de Vuur Kwak Muts zie je er echt uit als een verleider, en dat is handig om je tegenstanders te vloeren, als ze niet meer kunnen van het lachen als ze je \'m op hebt.",ep:13,g:39,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2410] = {n:"Boomchelm",t:16,d:"Met de Boomchelm kan je een houten kop vermijden.",ep:1,g:40,l:45,wd:true,fm:true,w:50,s:3,p:5500};
I.u[2411] = {n:"Veelvraat Hoed",t:16,d:"Deze fantastische hoed stelt zijn drager in staat kracht en intelligentie te winnen, als deze tenminste de geur kan verdragen.",ep:1,g:41,l:10,wd:true,fm:true,w:15,s:1,p:2050};
I.u[2412] = {n:"Vuur-Kwape",t:17,d:"Deze cape, heel weinig irritant, maar toch een beetje, moet toegegeven worden, kan je niet laten vliegen, zelfs niet zweven. Zelfs als je er een \"M\" op naait zal het niet gaan, hoewel sommigen daar staalhard in geloofden. Jammer.",ep:8,g:42,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2413] = {n:"Boomccape",t:17,d:"Gekleed met Boomchnid Bladeren, kun je mooi paraderen midden in het bos zonder dat je echt herkend wordt. Let echter op de Boomchnids die op zoek zijn naar lenteknoppen.",ep:1,g:43,l:45,wd:true,fm:true,w:17,s:3,p:5500};
I.u[2414] = {n:"Vretende Cape",t:17,d:"Deze cape heeft alles om in de smaak te vallen: sterk, comfortabel, mooie kleur, zeldzaam... Daarentegen is zijn geur vreselijk voor de nasale regionen. Maar ach, je kan nou eenmaal niet alles hebben.",ep:1,g:44,l:10,wd:true,fm:true,w:30,s:1,p:2780};
I.u[2415] = {n:"Vlammend Kwaklemmet",t:6,d:"Het Vlammende Kwaklemmet is een heel stijlvol wapen. Als je tegenstander er niet bang voor is, kun je hem gebruiken om indruk op hem te maken door hem vervolgens met een oude bedrieglijke list te verrassen.",ep:5,g:52,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CI>50&CV>50",s:2,p:4600};
I.u[2416] = {n:"Veelvraat Hamer",t:7,d:"In de handleiding staat dat deze wonderlijke hamer een kolossale energie verspreidt als hij op juiste wijze wordt gebruikt. Nog een Osamodas handleiding, vertaald naar Sadida...",ep:1,g:23,l:10,wd:true,fm:true,w:25,an:15,e:[5,5,1,1,40,40,false,true],s:1,p:845};
I.u[2417] = {n:"Boomcstaf",t:4,d:"Deze staf heeft alle agressiviteit van de Boomchnid behouden, maar niet de geur van vochtig hout, die zo kenmerkend is voor de oude Boomchnids.",ep:1,g:23,l:45,wd:true,fm:true,w:10,an:12,tw:true,e:[3,4,1,1,30,50,false,false],s:3,p:5500};
I.u[2418] = {n:"Vuur Kwak Ring",t:9,d:"Dankzij deze ring kan je meester je wellicht terugvinden als je verdwaalt tijdens het bezorgen van een boodschap.",ep:5,g:43,l:42,wd:true,fm:true,w:2,s:2,p:4900};
I.u[2419] = {n:"Bouze Le Clercs Ring",t:9,d:"Deze ring was van de bekende Bouze le Clerc, redder van de moderne tijd. Zijn favoriete zin ging over het \"One indige en Daar voorbij\"",ep:1,g:44,l:10,wd:true,fm:true,w:10,s:1,p:775};
I.u[2420] = {n:"Ringboom",t:9,d:"De Tak van de Boomchnid bewerken is niet eenvoudig. Maar met doorzettingsvermogen kan je uiteindelijk een ring krijgen die tegelijkertijd sober, elegant en geraffineerd is. Totaal het tegenovergestelde van een Sadida in een herberg.",ep:1,g:45,l:40,wd:true,fm:true,w:10,s:3,p:4500};
I.u[2421] = {n:"Vuur Kwak Laarzen",t:11,d:"Met die sporen van de Vuur Kwak om, blijft er niets anders over dan op eieren te lopen en je niet te laten bestelen door een kwaadgezinde Sram.",ep:5,g:25,l:40,wd:true,fm:true,w:5,s:2,p:4400};
I.u[2422] = {n:"Vreetlaarzen",t:11,d:"Deze laarzen hebben een ongeëvenaard comfort, de binnenkant lijkt gevoerd met Veelvraatwol, maar je voelt eveneens een vloeistof tussen de tenen doorcirculeren. Blijft de vraag of dat Veelvraatkwijl of -bloed is. Maakt niet uit.",ep:1,g:26,l:10,wd:true,fm:true,w:15,s:1,p:1700};
I.u[2423] = {n:"Boomlaarzen",t:11,d:"De effecten van dit paar laarzen kan ook heel goed bereikt worden in een herberg. Je moet vervolgens een beetje, nee zelfs heel veel, consumeren voor een optimaal effect. De volgende dag zullen je benen even zwaar aanvoelen als deze laarzen.",ep:1,g:27,l:45,wd:true,fm:true,w:20,s:3,p:4500};
I.u[2424] = {n:"Vuur Amukwak",t:1,d:"Met je nek vol veren, lijk je op Aldo Rado, groot Sacrier avonturier op zoek naar een gouden stad.",ep:5,g:47,l:42,wd:true,fm:true,w:3,s:2,p:4900};
I.u[2425] = {n:"Veelvraat Amulet",t:1,d:"Een goede Veelvraat Hoorn is een Hoorn die kalmte en wijsheid bezorgt. Een Goede Veelvraathanger zal je dus wijsheid en kalmte brengen. Of het tegenovergestelde. Of iets anders. Of niets dus.",ep:1,g:48,l:3,wd:true,fm:true,w:10,s:1,p:550};
I.u[2426] = {n:"De Arachnamu",t:1,d:"Deze kleine Arachnee is het levende bewijs dat het niet nodig is een dier te op te zetten om er een amulet van te maken. Ze zal je in je nek kietelen en zal misschien een web weven voor je mond als je te vaak gaapt, of als je een te slechte adem hebt.",ep:1,g:49,l:20,wd:true,fm:true,w:10,s:3,p:1300};
I.u[2427] = {n:"Vuur Kwak Riem",t:10,d:"Deze riem is uitstekend geschikt om als een Vuur Kwak te paraderen tijdens de paartijd, op voorwaarde dat je niets anders draagt.",ep:12,g:28,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2428] = {n:"Veelvraat Riem",t:10,d:"Makkelijk om te doen, maar toch blijkt deze riem erg licht voor zijn grootte. De wol lijkt nieuw te zijn. Normaal, want volgens de legende waren er zeker honderd vreetzakjes nodig om dit gladde en zijdeachtige aspect te krijgen.",ep:1,g:29,l:20,wd:true,fm:true,w:10,s:1,p:1253};
I.u[2429] = {n:"Boomchriem",t:10,d:"Deze riem maakt je zelfverzekerd en heel gespierd.  Een anti-Arachnee behandeling wordt wel elk jaar aangeraden. Net zoals het kapsel van een Sadida, maar gelukkig met drie keer minder anti-parasieten.",ep:1,g:30,l:45,wd:true,fm:true,w:25,s:3,p:4500};
I.u[2430] = {n:"Plas van Blauwe Gelei",t:24,d:"Je hebt je echt als een bruut gedragen tegenover deze Blauwe Gelei. Wie weet zul je op een dag betalen voor dit misdrijf.",ep:7,g:91,l:1,wd:true,fm:true,w:0,p:1};
I.u[2431] = {n:"Plas van Citroen Gelei",t:24,d:"Je hebt je echt als een bruut gedragen tegenover deze Citroen Gelei. Wie weet wordt jij net zoals hij op een dag geplet.",ep:7,g:90,l:1,wd:true,fm:true,w:0,p:1};
I.u[2432] = {n:"Plas van Aardbeien Gelei",t:24,d:"Je hebt je echt als een bruut gedragen tegenover deze Aardbeien Gelei. Wie weet lijk je op een dag wel op een grote misvormde vlek zoals dit.",ep:7,g:92,l:1,wd:true,fm:true,w:0,p:1};
I.u[2433] = {n:"Plas van Mint Gelei",t:24,d:"Je hebt je echt als een bruut gedragen tegenover deze Mint Gelei. Wie weet blijft er op een dag van jou ook weinig over, net als van deze gelei.",ep:7,g:93,l:1,wd:true,fm:true,w:0,p:1};
I.u[2435] = {n:"De Eni Kère",t:11,d:"Kère was de enige Eniripsa die voor de Ecaflips, de grote Marathon van Amakna won. Dankzij zijn ambachtelijke laarzen stak hij de Asse Zee over en liet alle stomverbaasde Ecaflips zien dat een Eni ook over water kan rennen. Klasse.",ep:5,g:29,l:45,wd:true,fm:true,w:5,p:4800};
I.u[2436] = {n:"Citroen Gelei",t:110,d:"Deze pot Citroen Gelei ziet er vreemd uit. Volgens Elrik Ola was deze gelei ooit van hem. Om precies te zijn, uit de andere hoek van de melkweg. Wat dus wil zeggen, dat het niet naast de deur is.",ep:7,g:490,l:45,wd:true,fm:true,w:1,p:1};
I.u[2437] = {n:"Plas van Koninklijke Citroen Gelei",t:110,d:"Volgens sommige geruchten is de Koninklijke Citroen Gelei beter dan de andere gelei. Misschien omdat de citroen de smaak van de gelei verhult.",ep:7,g:491,l:200,wd:true,fm:true,w:1,p:100};
I.u[2438] = {n:"Koninklijke Vreetpruik",t:16,d:"De Koninklijke Vreetpruik is een voorwerp dat niet aan mode onderhevig is. Elegant als hij is, verschaft hij zijn drager kracht en intelligentie.",ep:1,g:42,l:50,wd:true,fm:true,w:45,s:4,p:100};
I.u[2440] = {n:"Koninklijk Veelvraat Zwaard",t:6,d:"Dit zwaard weet niet goed naar welke pijpen het moet dansen... Het brengt schade toe aan alle elementen.",ep:1,g:30,l:70,wd:true,fm:true,w:65,an:14,e:[4,4,1,1,30,50,false,false],s:4,p:30000};
I.u[2441] = {n:"Koninklijke Veelvraat Ring",t:9,d:"Deze ring verhoogt het leven van de drager, net als de geur van het vrouwtje van de Koninklijke Veelvraat haar aantrekkingskracht vergroot.",ep:1,g:46,l:30,wd:true,fm:true,w:5,s:4,p:100};
I.u[2442] = {n:"Koninklijke Vraatlaarzen",t:11,d:"Ze glanzen, ze ademen macht, deze laarzen zijn in alle opzichten \"koninklijk\".",ep:1,g:30,l:50,wd:true,fm:true,w:50,s:4,p:6600};
I.u[2443] = {n:"Koninklijke Veelvraat Amulet",t:1,d:"Dit amulet vergroot de kracht en de intelligentie van zijn drager.",ep:1,g:50,l:50,wd:true,fm:true,w:10,s:4,p:5000};
I.u[2444] = {n:"Koninklijke Veelvraat Riem",t:10,d:"Deze prachtige riem verhoogt de vitaliteit van de drager ervan en waarmee hij makkelijker voorwerpen kan dragen. Hij is zo zacht dat je er zelfs je liefje mee kunt vastbinden als zij weigert thuis te blijven.",ep:1,g:31,l:52,wd:true,fm:true,w:10,s:4,p:7000};
I.u[2445] = {n:"Koninklijke Vreet Cape",t:17,d:"Deze door de grote Koninklijke Veelvraat gedragen cape geeft je, naast een fabelachtige stijl, ook een buitengewone kracht.",ep:1,g:46,l:50,wd:true,fm:true,w:60,s:4,p:50000};
I.u[2446] = {n:"Gelocape",t:17,d:"Deze cape, die ontdaan is van draden en haren, blijft een mysterie voor de denkende koppies van Amakna, en dat kunnen er dus niet meer zijn dan een stuk of tien.",ep:7,g:47,l:60,wd:true,fm:true,w:10,s:6,p:1000};
I.u[2447] = {n:"Gelohoed",t:16,d:"Met dit hoofddeksel kun je er zeker van zijn dat je vrienden ervan zullen dromen om je te bekijken. Een hoed waar Kapitein Chafer dolgelukkig mee geweest zou zijn toentertijd.",ep:5,g:43,l:60,wd:true,fm:true,w:23,s:6,p:9500};
I.u[2448] = {n:"Veelvraat Hersens",t:15,d:"Zonder enige twijfel zijn dit de Hersens van de Veelvraat. Goed bereid, is dit het lievelingsgerecht van alle kleine Iops die groot en sterk willen worden. Ze worden er ook intelligenter van, maar als men dat zou zeggen tegen de Iop kinderen, zouden ze er zeker veel minder van eten.",ep:1,g:492,l:9,wd:true,fm:true,w:1,p:1};
I.u[2449] = {n:"Teken Leger",t:15,d:"Een hongerig leger Teken kan, aldus de jagers, de hele wollen vacht van een Veelvraat in een nacht verslinden. Enkele kroegtijgers bevestigen zelfs dat zo\'n leger zelfs de prachtige manen van een Sadida kan verslinden.",ep:1,g:493,l:9,wd:true,fm:true,w:1,p:1};
I.u[2451] = {n:"Veelvraat Klomp",t:47,d:"Werden ze vroeger als onderzetters gebruikt, sommige Eniripsa alchemisten, toegegeven, nogal koket, hergebruiken de Veelvraat Klomp als Kom. Dat geeft smaak aan hun favoriete corn flakes.",ep:1,g:495,l:9,wd:true,fm:true,w:1,p:1};
I.u[2453] = {n:"Veelvraat Oog",t:109,d:"Vroeger maakte men van dit Oog een heerlijke soep. Zo smakelijk dat men het recept uit de boeken heeft moeten verbannen, want veel jagers namen alleen de ogen en lieten het karkas van de arme Veelvraat ziedend achter.",ep:1,g:497,l:9,wd:true,fm:true,w:1,p:1};
I.u[2454] = {n:"Maag van een Veelvraat",t:15,d:"Dit soort Maag bezit doelmatige elastische kwaliteiten. Wees daarentegen niet verbaasd als hij in de Klavertjespap blijft zitten, nee, in tegendeel, Jongedames, verheugt u, deze pap is zeer goed voor de huid.",ep:1,g:498,l:9,wd:true,fm:true,w:1,p:1};
I.u[2455] = {n:"Veelvraat Bloed",t:15,d:"Je kunt niet gaan jagen zonder dit Veelvraat Bloed als aas;\r\n            de lucht trekt grotere Veelvraten aan. Hij trekt ook heel doeltreffend Moskito\'s aan. Men weet nog steeds niet waarom.",ep:1,g:499,l:9,wd:true,fm:true,w:1,p:1};
I.u[2460] = {n:"Vreetzakjes Oog",t:109,d:"Het is niet zo dat het Vreetzakje je in de gaten houdt, maar je hebt toch de indruk dat hij het op je gemunt heeft.",ep:1,g:500,l:2,wd:true,fm:true,w:1,p:1};
I.u[2462] = {n:"Veelvraat Oorlogs Chef Hersens",t:15,d:"Het kan niet anders of de Veelvraat Oorlogschef, waarvan je zojuist de Hersens hebt verwijderd, krijgt hoe langer hoe meer moeite met denken.",ep:1,g:501,l:19,wd:true,fm:true,w:1,p:1};
I.u[2463] = {n:"Veelvraat Oorlogs Chef Tand",t:47,d:"Een Tand van een Oorlogs Chef trekken is niet iedereen gegeven, helaas maar waar. Merk op dat deze Tand meer waard is als hij rot is. Vraag me niet waarom, het schijnt te maken te hebben met een economisch evenwicht.",ep:1,g:502,l:19,wd:true,fm:true,w:1,p:1};
I.u[2464] = {n:"Veelvraat Oorlogs Chef Staart",t:65,d:"Blijf op de grond in het Woud zitten, kijk geduldig, zonder geluid te maken, en misschien zie je een vrolijke Veelvraat Oorlogschef die met zijn staart kwispelt. Maar dat onschuldige gebaartje vindt alleen plaats in de paringstijd.",ep:1,g:503,l:19,wd:true,fm:true,w:1,p:1};
I.u[2465] = {n:"Veelvraat Oorlogs Chef Hoorn",t:47,d:"Minder zacht dan zijn soortgenoot, is de Veelvraat Oorlogschef handiger in het aan de spies rijgen van de Srams en andere vermetele rassen. Men vindt vaak stukjes stof aan hun hoornen, een beetje als een soort trofee.",ep:1,g:504,l:19,wd:true,fm:true,w:1,p:1};
I.u[2466] = {n:"Veelvraat Oorlogs Chef Tong",t:15,d:"De uitdrukking \"een smaak van dooie vogeltjes\" is echt van toepassing op de Chef Oorlogs Veelvraat. Je krijgt de indruk dat hij een bedorven Trool heeft gegeten.",ep:1,g:505,l:19,wd:true,fm:true,w:1,p:1};
I.u[2467] = {n:"Veelvraat Oorlogs Chef Klomp",t:47,d:"Volgens de schoenmakers is deze Klomp één van de sterkste en de meest rekbare van de Provincie. Blijft de vraag wat ze verstaan onder \"rekbaar\". Als je ze zo hoort zou je denken dat ze laarsen kunnen maken met behulp van deze Klomp.",ep:1,g:538,l:18,wd:true,fm:true,w:1,p:1};
I.u[2468] = {n:"Maag van een Veelvraat Oorlogschef",t:15,d:"Binnen in deze Maag zit een verrassing verborgen. Klein Duimpje van Enutrof, puntje van de neus van Osamoda... Je zou zo ongeveer een Held kunnen samenstellen van al deze stukjes.",ep:1,g:506,l:19,wd:true,fm:true,w:1,p:1};
I.u[2469] = {n:"Gelano",t:9,d:"Met deze ring kun je niet op je nagels bijten, lik ze dus af!",ep:7,g:47,l:60,wd:true,fm:true,w:5,s:6,p:10000};
I.u[2470] = {n:"Gelolaarzen",t:11,d:"Deze laarsen zijn \'s zomers zeer conformtabel, want ze geven een bosaardbeienlucht af. Het verdoezelt goed de zweetlucht waardoor je je kunt bevrijden uit de tenen van een ouwe Sadida met harige poten.",ep:5,g:31,l:60,wd:true,fm:true,w:50,s:6,p:1000};
I.u[2471] = {n:"Geloriem",t:10,d:"Het moeilijkste met deze Geloriem is als je vreselijke honger hebt. Je bent snel geneigd om erin te bijten.",ep:7,g:32,l:60,wd:true,fm:true,w:15,s:6,p:1000};
I.u[2472] = {n:"Gelamu",t:1,d:"Dit is een amulet, dat je uitgesproken smaak zal verraden voor Gelei orgies. Er zijn betere manieren om op de voorgrond te treden of te schitteren in gezelschap, maar je moet wel je zwak voor Gelei tot het eind toe aanvaarden.",ep:5,g:51,l:60,wd:true,fm:true,w:4,s:6,p:1000};
I.u[2473] = {n:"Avonturiers Cape",t:17,d:"Van goede kwaliteit maar weinig prestaties leverend, zullen de jonge avonturiers er toch gelukkig mee zijn.",ep:1,g:48,l:1,wd:true,fm:true,w:7,s:5,p:100};
I.u[2474] = {n:"Avonturieren Hoed",t:16,d:"Deze hoed is eigenlijk nergens goed voor.. hoewel, het jaagt de jongens toch aardig goed weg...",ep:1,g:44,l:1,wd:true,fm:true,w:12,s:5,p:100};
I.u[2475] = {n:"Avonturiers Ring",t:9,d:"Een kleine sympathieke ring voor beginnelingen en waar kleine kinderen leuk mee kunnen spelen, of Ecaflips.",ep:1,g:48,l:1,wd:true,fm:true,w:5,s:5,p:10};
I.u[2476] = {n:"Avonturierslaarzen",t:11,d:"Laarzen van eenvoudige makelij maar ideaal voor jongeren die zich op het moeilijke pad van het avontuur wagen.",ep:1,g:32,l:1,wd:true,fm:true,w:15,s:5,p:10};
I.u[2477] = {n:"Avonturiersriem",t:10,d:"Een riempje voor de avonturiers in het gras.",ep:1,g:33,l:1,wd:true,fm:true,w:6,s:5,p:10};
I.u[2478] = {n:"Avonturiers Amulet",t:1,d:"Niet echt van grote kwaliteit, niet echt doeltreffend, maar  leuk als je over de wapenrusting beschikt.",ep:1,g:52,l:1,wd:true,fm:true,w:2,s:5,p:10};
I.u[2479] = {n:"Armzalig Zwijn kapsel",t:15,d:"Dit kapsel is een teken van volwassenheid bij het Armzalig Zwijn. Dit is waarom jonge geslachtsrijpe Eniripsa\'s soms gezien worden terwijl ze rond de stad heen dwalen met hetzelfde kapsel.  Maar ze zouden niet de Rocky Plains in gaan hiermee.",ep:13,g:507,l:18,wd:true,fm:true,w:1,p:1};
I.u[2480] = {n:"Armzalig Zwijn Instructies",t:56,d:"“Een Armzalig Zwijn zonder instructies is een dood Armzalig Zwijn.” Dit was de favoriete uitdrukking van Dame Harre, een volgeling van Feca en een toegewijde glurende Tom. Haar favoriete verleden-tijd was haar vrienden besluipen en een Armzalig Zwijn op hun hoofd zetten.",ep:13,g:508,l:18,wd:true,fm:true,w:1,p:1};
I.u[2481] = {n:"Armzalig Everzwijn Snuit",t:15,d:"Deze snuit, zo roze als de billen van een Osamodas baby, kunnen zeker in een recpt gebruikt worden. Of je kunt een ketting van de snuit maken, maar dan moet je ook dapper genoeg zijn om deze voor de ogen van je buren te dragen.",ep:13,g:509,l:18,wd:true,fm:true,w:1,p:1};
I.u[2482] = {n:"Armzalige Mejuffrouw Varken Schoen",t:15,d:"Lang geleden vond een knappe prins deze schoen onder de traptreden van zijn koninklijke paleis. Er wordt gezegd dat de eigenaar ervan erg veel haast had om de oven uit te zetten.",ep:13,g:510,l:18,wd:true,fm:true,w:2,p:1};
I.u[2483] = {n:"Armzalig Varken Gebit",t:47,d:"Sommige Armzalige Zwijnen hebben geen tanden in het begin. Andere worden op een morgen wakker met een gat in hun mond, terwijl ze geen idee hebben hoe ze hun kauwers verloren zijn.",ep:13,g:511,l:30,wd:true,fm:true,w:1,p:1};
I.u[2484] = {n:"Gebroken Trident",t:15,d:"Bewaar het als een aandenken van het Wilde Zwijn dat je net verslagen hebt. Het probleem is dat hij het tegen je zou kunnen gebruiken. Het is beter om hem niet nog een keer tegen te komen, want Wilde Zwijnen zijn erg dwars.",ep:13,g:512,l:18,wd:true,fm:true,w:2,p:1};
I.u[2485] = {n:"Vegahoed",t:16,d:"Helemaal je van het in de mode, maar alleen in het noord-oosten van Amakna.",ep:1,g:45,l:40,wd:true,fm:true,w:25,s:10,p:4500};
I.u[2486] = {n:"Armzalig Zwijn Oor",t:106,d:"Dit Oor zal respect ontlokken van de spelers om je heen. Het is net zo goed een trofee als een bewijs dat jij Armzalige Zwijnen kunt temmen. Maar wees voorzichtig, niet laten zien wanneer er andere Armzalige Zwijnen in de buurt zijn want zij zouden het verkeerd op kunnen vatten.",ep:13,g:513,l:18,wd:true,fm:true,w:1,p:1};
I.u[2487] = {n:"Scurvion Schelp",t:107,d:"Ideaal om zware uitrustingen te maken, werd er op de Scurvion  gejaagd door de Militia van Brakmar vanwege zijn ongelooflijke record-brekinggraad van reproductie. Zelfs de Geleien werden overtroffen.",ep:14,g:514,l:36,wd:true,fm:true,w:1,p:1};
I.u[2488] = {n:"Scurvion Entrails",t:15,d:"Op het eerste gezicht lijken deze ingewanden niet erg smakelijk. Eerlijk genoeg. Scurvion ingewanden zijn eigenlijk opstandig, zelfs als ze met liefde gekookt worden.",ep:14,g:445,l:36,wd:true,fm:true,w:1,p:1};
I.u[2489] = {n:"Vegacape",t:17,d:"Een elegante cape die je onweerstaanbaar maakt bij de liefhebbers van mooie planten.",ep:1,g:49,l:58,wd:true,fm:true,w:15,s:10,p:1000};
I.u[2490] = {n:"Scurvion Been",t:103,d:"Het is vrij zeldzaam om een Scurvion been in zo\'n goede conditie te krijgen. Gebruik het wijs, om deuren open te breken bijvoorbeeld...Grapje, of misschien niet...",ep:14,g:515,l:36,wd:true,fm:true,w:1,p:1};
I.u[2491] = {n:"Ouginak Oog",t:109,d:"Kijk eens naar dit verstorende maar opwindende oog;\r\n            het laat niet zien wat je zou verwachten. Bijvoorbeeld: in plaats van jezelf die je je tegenhanger, een Dopple. Het is nogal hinderlijk.",ep:14,g:516,l:51,wd:true,fm:true,w:1,p:1};
I.u[2492] = {n:"Ketting",t:15,d:"Deze verdoemde Ketting komt duidelijk van een Ouginak. Voor hij brak is hij waarschijnlijk gebruikt om zijn beest vast te binden zodat die niet kon ontsnappen.",ep:14,g:517,l:51,wd:true,fm:true,w:2,p:1};
I.u[2493] = {n:"Ouginak Hart",t:15,d:"Dit hart blijft je trouw. Zolang je hem niet verkoopt of omruilt, zal hij in je tas blijven. Wat een fijne gedachte!",ep:14,g:518,l:51,wd:true,fm:true,w:1,p:1};
I.u[2494] = {n:"Zwaard Pommel",t:15,d:"Een ultra-krachtige slag moet nodig zijn geweest om door dit Mythische Zwaard te komen. Degene die het Zwaard van een Ouginak vasthoudt kan niet anders doen dan brullen met vreugde! Woohoo!",ep:14,g:519,l:51,wd:true,fm:true,w:2,p:1};
I.u[2495] = {n:"Kolerat Oog",t:109,d:"Dit Oog geeft licht in de duisternis zelfs als hij van het gezicht van zijn eigenaar afgetrokken is. Het is zo fel dat je je favoriete strips de hele nacht kunt lezen.",ep:2,g:520,l:9,wd:true,fm:true,w:1,p:1};
I.u[2496] = {n:"Kolerat staart",t:65,d:"Voorzichtig gesneden, de Staart van de Kolera smaakt als een worstje. Het gekke is, dat wanneer je hem in grote stukken snijdt de worstensmaak verdwijnt. Nog een bestaand culinair raadsel in deze wereld.",ep:2,g:521,l:9,wd:true,fm:true,w:1,p:1};
I.u[2497] = {n:"Kolerat Oren",t:106,d:"Houd het bij je oor en je hoort misschien de zee.",ep:2,g:522,l:9,wd:true,fm:true,w:1,p:1};
I.u[2498] = {n:"Vegamu",t:1,d:"De Vegamu heeft soms de neiging Moskitos aan te trekken, die hem van verre aanzien voor een vriendin. Ze zijn vaak teleurgesteld als ze de drager van het amulet zien.",ep:1,g:53,l:40,wd:true,fm:true,w:20,s:10,p:1000};
I.u[2499] = {n:"Kolerat neus",t:15,d:"De Kolerat heeft een ongelooflijk goede neus, niet zo goed als de Ouginak, maar hij kan evengoed roofdieren ruiken binnen een straal van 300 meter. Erg handig om roofdieren te vermijden.",ep:2,g:523,l:9,wd:true,fm:true,w:1,p:1};
I.u[2500] = {n:"Dode Kolerat",t:15,d:"Je hebt er goed aan gedaan dit op te rapen, want het is intact. Dood, maar intact.",ep:2,g:524,l:9,wd:true,fm:true,w:10,p:1};
I.u[2501] = {n:"Bloedwolf Staart",t:65,d:"De God Osamodas verdraagt niet dat men aan de wilde dieren komt: \"Ze zijn zo schattig\" schreeuwt hij constant. Dat is grappig, je kan zien dat hij nooit door toedoen van zo\'n \"schatje\" iets verloren heeft.",ep:1,g:525,l:19,wd:true,fm:true,w:1,p:1};
I.u[2502] = {n:"Bloedwolf Pootje",t:103,d:"De Pootjes van de Bloedwolf worden tamelijk gewaardeerd door de plaatselijke smulpapen. Ze bezitten magische vermogens, zoals het brengen van geluk aan zijn eigenaar. Dat is al heel wat.",ep:1,g:526,l:19,wd:true,fm:true,w:1,p:1};
I.u[2503] = {n:"Bloedwolf Stof",t:55,d:"Hiermee kan je er net zo guitig uitzien als de Bloedwolf. Als je ervan droomt een Stofje op je hoofd te planten en op katachtige wijze te bewegen, nou, dan heb je rare dromen, onder ons gezegd.",ep:1,g:200,l:19,wd:true,fm:true,w:1,p:1};
I.u[2504] = {n:"Bloedwolf Tong",t:15,d:"Deze Tong moet op aardig wat plaatsen hebben rondgehangen voordat ie bij jou terecht kwam.",ep:1,g:527,l:19,wd:true,fm:true,w:1,p:1};
I.u[2505] = {n:"Kroket",t:15,d:"Als je een Bloedwolf wil temmen, werp hem dan een Kroket toe, ze zijn er dol op. Hij zal het niet toegeven, maar je bent vrienden voor het leven.",ep:1,g:528,l:19,wd:true,fm:true,w:1,p:1};
I.u[2506] = {n:"Bel",t:15,d:"Je kunt de Plissken van een grote afstand af horen dankzij zijn bel. En gelukkig maar, want ze zijn slecht zichtbaar in de  weelderige begroeiing van de Eenvoudige Cania.",ep:13,g:529,l:10,wd:true,fm:true,w:1,p:1};
I.u[2507] = {n:"Gevorkte Tong",t:15,d:"Je kunt je vrienden slaan met deze Tong. Je Osamodas en Sacrier vrienden zullen erg blij zijn.",ep:13,g:530,l:10,wd:true,fm:true,w:1,p:1};
I.u[2508] = {n:"Plissken Vergif",t:15,d:"Dit verschrikkelijke vergif kan winnen van een heel leger furieuze gobballs. Het was eigenlijk ook om kuddes onder controle te houden;\r\n            giet maar wat over je staf heen en kijk eens aan!",ep:13,g:531,l:10,wd:true,fm:true,w:1,p:1};
I.u[2509] = {n:"Plissken Tand",t:47,d:"Deze tand behoorde toe aan een Plissken. Dat kan echt niet anders. We kunnen dat zien aan het scherpe uiteinde van de tand.",ep:13,g:432,l:10,wd:true,fm:true,w:1,p:1};
I.u[2510] = {n:"Eenvoudige Everzwijn Maag",t:15,d:"Deze maag is groot genoeg om vele dingen vast te houden. Een door de hemel gestuurde kans voor een Io[ om zijn Zwaarden uit te zoeken.",ep:13,g:532,l:44,wd:true,fm:true,w:1,p:1};
I.u[2511] = {n:"Eenvoudig Zwijn Leder",t:56,d:"Ondanks de hoge kwaliteit weigerden schoenmakers vele jaren om dit leder te gebruiken. Klanten dachten dat het nep was omdat er geen geur aan zat! Zoals gezegd wordt, beoordeel een laars nooit door zijn geur.",ep:2,g:410,l:44,wd:true,fm:true,w:10,p:1};
I.u[2512] = {n:"Eenvoudig Zwijn staart",t:65,d:"Vele brakmaarse stropers verzamelen deze harige trofee. De reden is nog steeds onbekend.",ep:13,g:536,l:44,wd:true,fm:true,w:1,p:1};
I.u[2513] = {n:"Eenvoudige Everzwijn weefsel",t:55,d:"In tegenstelling tot zijn leder heeft de Eenvoudig Zwijn weefsel een geur die radicaal tegen neusproblemen helpt. Het kan zelfs een Sadida in winterslaap wakker maken.",ep:13,g:537,l:44,wd:true,fm:true,w:1,p:1};
I.u[2514] = {n:"Eenvoudige Everzwijn Hoef",t:47,d:"De Hoeven van Zwijnen zijn algemeen bedekt met modder en vuil, maar soms ook met kleurrijke Biblops, wat niet echt ongewoon is. Het Eenvoudige Zwijn haat de Biblops net zo erg als jij.",ep:13,g:539,l:44,wd:true,fm:true,w:1,p:1};
I.u[2515] = {n:"Eenvoudig Zwijn Snuit",t:15,d:"Op het eerste gezicht lijkt deze snuit niet zo vers. Maar vergis je niet, het is de gevoeligste en meest verfijnde snuit die ooit gesnoven heeft.",ep:13,g:540,l:44,wd:true,fm:true,w:1,p:1};
I.u[2516] = {n:"Eenvoudig Zwijn Slagtand",t:47,d:"Deze slagtand van een Wild Zwijn zal je eraan herinneren hoe onplezierig dit type zwijn is. Inderdaad, de Slagtand is net zo versleten als een Wabbit tand die wortels op heeft gegeten.",ep:13,g:541,l:44,wd:true,fm:true,w:1,p:1};
I.u[2517] = {n:"Megacape",t:17,d:"Deze cape behoorde toe aan een beroemde held die beroemd werd vanwege het confronteren van de verschrikkelijke Dokter Wily. Dit beest wilde in de Wereld van Twaalf binnenvallen en domineren met zijn leger van bezweerde monsters. De goede Dokter ging dood voor zijn handlangers klaar waren met hun \'laatste avondmaal\'.",ep:1,g:50,l:45,wd:true,fm:true,w:2,s:76,p:5500};
I.u[2518] = {n:"Viootiful Cape",t:17,d:"Silvia naaide deze bizarre cape van oude gordijnen. Gelukkig kun je dat niet echt meer zien omdat het meer op een dweil lijkt die gekookt is in het bloed van een Armzalig Zwijn.",ep:1,g:51,l:45,wd:true,fm:true,w:2,s:75,p:5500};
I.u[2519] = {n:"Megahelm",t:16,d:"Deze helm is perfect om de meest extreme situaties en de meest exclusieve gezelschappen te overtreffen.",ep:1,g:46,l:44,wd:true,fm:true,w:2,s:76,p:5200};
I.u[2520] = {n:"Vioutifoule Helm",t:16,d:"Deze helm is van de goede oude Jojo geweest, beroemde held uit de oude tijd. Hoewel hij bekend is vanwege zijn verschillende heldendaden, heeft men toch moeite de passie van zijn fans te begrijpen.",ep:1,g:47,l:44,wd:true,fm:true,w:2,s:75,p:5200};
I.u[2521] = {n:"Megalaarzen",t:11,d:"Roll, de lieflijke zuster van de eigenaar van de laarzen, gespecialiseerd in astrale taxidermie. Lang geleden wist niemand het verschil tussen astrale taxidermie en normale taxidermie. Tegenwoordig is het makkelijk te zien dat astrale taxidermie over het volproppen van astrale beesten gaat. Als je nog steeds niet snapt waar het mis ging, weet je dus duidelijk niet hoe stom ze waren.",ep:1,g:33,l:43,wd:true,fm:true,w:2,s:76,p:5000};
I.u[2522] = {n:"Viootifool Laarzen",t:11,d:"Deze laarzen laten de beroemde Jojo zijn beroemde roundhouse schop perfectioneren, welke ook wel bekend was als de “Hete Rode Schop”. Niemand weet waar die naam vandaan komt aangezien de laarzen inmiskenbaar wit zijn!",ep:1,g:34,l:43,wd:true,fm:true,w:2,s:75,p:5000};
I.u[2523] = {n:"Megabelt",t:10,d:"Deze riem is speciaal gemaakt om de heupen van onze waardevolle helden te beschermen. Totaal nutteloos voor jou dus.",ep:1,g:34,l:45,wd:true,fm:true,w:2,s:76,p:5600};
I.u[2524] = {n:"Viootifool Riem",t:10,d:"Het gerucht gaat dat deze riem gecreëerd was door Kapitein Blooe zelf. Is dat niet ongelooflijk..ongelooflijk! Je gelooft me wel, nietwaar?",ep:1,g:35,l:46,wd:true,fm:true,w:2,s:75,p:5600};
I.u[2525] = {n:"Hart van de Meester Raaf",t:15,d:"Zonder zijn Hart zal zijn gezang schade oplopen. Maar zeg het hem vooral niet, want de Meester Raaf is erg lichtgeraakt.",ep:13,g:328,l:160,wd:true,fm:true,w:1,p:1};
I.u[2526] = {n:"Meester Raaf Zeis",t:15,d:"Deze zeis was oorspronkelijk bedoeld om Iop te maaien, maar Meester Raaf kwam er al snel achter dat hij zo scherp was, dat hij voor het maaien van van alles en nog wat gebruikt kon worden.",ep:1,g:557,l:160,wd:true,fm:true,w:10,p:1};
I.u[2527] = {n:"Clakoss",t:15,d:"De Meester zit vol met verrassingen, in zijn zak zat een Clakoss, beroemde koninklijke kaas. Het feit dat hij aangebroken is, bewijst dat de Meester Raaf er dol op is. Wat betreft de geur, kan men je alleen maar aanraden hem niet bij je te houden.",ep:13,g:558,l:160,wd:true,fm:true,w:1,p:1};
I.u[2528] = {n:"Kaniger Nagel",t:47,d:"Je moet krachtig en snel zijn om een nagel van een Kaniger te pakken – krachtig om te trekken en snel om te voorkomen dat je een mep om je oren krijgt.",ep:13,g:559,l:70,wd:true,fm:true,w:1,p:1};
I.u[2529] = {n:"Vloeibaar Metaaldrankje",t:26,d:"Met dit drankje kun je aan een vluchtig zwaard weer een beetje realiteitszin geven.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2530] = {n:"Caralaarzen",t:11,d:"Een beetje zwaar maar erg mooi, je zult de koningin van de nacht zijn met deze Caralaarzen aan.",ep:12,g:35,l:60,wd:true,fm:true,w:50,s:9,p:1000};
I.u[2531] = {n:"Carapet",t:16,d:"Net als jij hebben schildpadden kleine hoofden. Wat toevallig! Deze pet is precies groot genoeg voor jullie tweeën.",ep:12,g:48,l:60,wd:true,fm:true,w:24,s:9,p:10000};
I.u[2532] = {n:"Caracape",t:17,d:"Een praktische, goed gemaakte mantel. Je wordt er geen kampioen mee, maar ik kan dan ook niks bedenken waar je wél een kampioen mee zou worden...",ep:12,g:52,l:60,wd:true,fm:true,w:15,s:9,p:10000};
I.u[2534] = {n:"IJs-Kwape",t:17,d:"Ideaal om zich te verfrissen op het eiland Moon tijdens het warme seizoen, en perfect om de hartstocht van je meest ondernemende vrienden te bekoelen, zal deze cape aan de verwachtingen van de moderne avonturier kunnen beantwoorden.",ep:8,g:53,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2535] = {n:"IJs Kwak Muts",t:16,d:"Met deze IJs Kwak Muts heb je altijd frisse ideeën, ook al zijn je ideeën bijna uitgeput. Hij is echter niet krachtig genoeg voor een Iop.",ep:13,g:49,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2537] = {n:"IJs Kwaktuur",t:10,d:"Ideaal om de heupen te verstevigen en om alles onder deze riem fris te houden.",ep:12,g:36,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2538] = {n:"Zwaar vloeibaar metaal Drankje",t:26,d:"Met dit drankje kun je weer wat realiteitszin geven aan een hemels lemmet.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2539] = {n:"Houtkrul Drankje",t:26,d:"Met dit drankje kun je weer wat realiteitszin geven aan een hemels beeldhouwwerk.",ep:1,g:16,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2540] = {n:"Stevig Houtkrul Drankje",t:26,d:"Met dit drankje kun je weer realiteitszin geven aan een vluchtig beeldhouwwerk.",ep:1,g:17,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2541] = {n:"Vloeibaar Edelmetaal Drankje",t:26,d:"Met deze toverdrank kun je een groot deel realiteit geven aan een hemels lemmet.",ep:2,g:15,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2542] = {n:"Huis Drankje",t:12,d:"Met dit drankje kom je altijd weer thuis.",ep:1,g:142,l:1,wd:true,fm:true,w:2,u:true,p:100};
I.u[2543] = {n:"Ongewoon Hout Scheerbeurt Drankje",t:26,d:"Dit drankje brengt de realiteit naar een hemels beeldhouwwerk.",ep:9,g:18,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2544] = {n:"Ravelemmet",t:6,d:"Vreselijk scherp en van ongelovelijke klasse, riskeer je met dit lemmet de Raven om je heen jaloers te maken.",ep:1,g:32,l:45,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,20,50,false,false],s:8,p:4500};
I.u[2545] = {n:"Raaflaarzen",t:11,d:"Met deze laarzen voel je je heel erg licht en vooral achterlijk.",ep:1,g:37,l:45,wd:true,fm:true,w:1,s:8,p:1000};
I.u[2546] = {n:"Ravekapsel",t:16,d:"Dankzij deze fantastische pruik zul je minstens zoveel klasse hebben als de droevig vermaarde Meester Raaf.",ep:1,g:50,l:45,wd:true,fm:true,w:23,s:8,p:1000};
I.u[2547] = {n:"Ravecape Mastralis",t:17,d:"De beste kleermakers van Amakna hebben zich ooit verenigd om de resten van de huid van de Meester Raaf te gebruiken zodat ze er een weelderige cape van konden maken. Met zo\'n cape om je schouders ben jij de meester.",ep:13,g:56,l:127,wd:true,fm:true,w:30,p:41000};
I.u[2549] = {n:"Kaniger Blikje",t:15,d:"Dit blik bevat een Kaniger in stukjes gesneden. Erg handig om te dragen, een Kaniger in stukjes is echt je beste vriend.",ep:13,g:560,l:70,wd:true,fm:true,w:1,p:1};
I.u[2550] = {n:"Kaniger weefsel",t:55,d:"Dit weefsel is een perfecte en prachtige vervanging voor haar. Het dit op kan niemand je missen!",ep:13,g:561,l:70,wd:true,fm:true,w:1,p:1};
I.u[2551] = {n:"Kaniger Oor",t:106,d:"Het is de favoriete maaltijd van de Ouginak: Kaniger oren met eenvoudige saus. Het is traditioneel gekookt met een boel wilde mint en enkele Nagels om smaak toe te voegen.",ep:13,g:562,l:70,wd:true,fm:true,w:1,p:1};
I.u[2552] = {n:"Kaniger Oog",t:109,d:"Het Oog van de Kaniger is een modefenomeen: kijk gewoon naar al die avonturiers om je heen die het om hun nek dragen...",ep:13,g:563,l:70,wd:true,fm:true,w:1,p:1};
I.u[2553] = {n:"Grote Kogel",t:15,d:"Dit is een echte Kogel. Buitengewoon zwaar, zal hij altijd je schedel doorboren als hem dat goeddunkt. Niets vervelenders dan enigerlei grote Kogel.",ep:1,g:564,l:40,wd:true,fm:true,w:500,p:1};
I.u[2554] = {n:"Armzalig Zwijn fijngehakt",t:47,d:"Armzalig Zwijnenstukjes hebben een speciale smaak. Sommigen koken het in een kruidig sap, anderen eten het rauw. En wat het Armzalig Zwijn betreft, hij geeft de voorkeur aan de jouwe. Ieder zijn eigen... recept.",ep:13,g:159,l:40,wd:true,fm:true,w:1,p:1};
I.u[2555] = {n:"Lederen Zadel",t:56,d:"Het Armzalig Zwijn is een zwak oud beest maar hij heeft het moeilijk met dat te accepteren. We weten dit omdat hij zijn zadel vult met veren zodat het comfortabeler is. Het is precies zoals ze zeggen, het bewijs zit hem in de vulling.",ep:13,g:565,l:40,wd:true,fm:true,w:5,p:1};
I.u[2556] = {n:"Bloppollen",t:15,d:"Dit is de bron van alle goedaardige allergiën van de wereld. De enige zorg is, dat alle dodelijke allergiën beginnen met een goedaardige allergie. Kortom, houd deze Pollen niet in je zak als je ze niet nodig hebt.",ep:5,g:566,l:34,wd:true,fm:true,w:1,p:1};
I.u[2557] = {n:"Blop Bloemblaadje",t:35,d:"Hoe vreemd het ook lijkt, bloemblaadjes van de Blops zijn niet eetbaar, gekookt noch rauw. Wie zou dat gedacht hebben?",ep:5,g:567,l:34,wd:true,fm:true,w:1,p:1};
I.u[2558] = {n:"Dode Blop",t:15,d:"e hebt er goed aan gedaan deze op te pikken, hij is ongeschonden. Dood, maar ongeschonden.",ep:5,g:568,l:34,wd:true,fm:true,w:10,p:1};
I.u[2559] = {n:"Trool Manen",t:15,d:"Dergelijke manen zijn niet erg gangbaar. Alleen de rijkste Enutrofs kunnen het zich permitteren er een vervangende haarbos van te laten maken.",ep:4,g:569,l:115,wd:true,fm:true,w:1,p:1};
I.u[2560] = {n:"Trool Epaulet",t:15,d:"Je kan beter in deze omstandigheden deze Epaulet bekijken dan hem bewonderen als hij nog op de schouder van een Trool zit. Het mankeert er nog maa aan dat hij er een défilé van maakt!",ep:4,g:570,l:115,wd:true,fm:true,w:5,p:1};
I.u[2561] = {n:"Trool Krachtarmband",t:15,d:"Alsof de Trool een Krachtarmband nodig heeft... Deze ongelofelijke machine dat botten fijnmaalt heeft er één om elke pols.",ep:4,g:571,l:115,wd:true,fm:true,w:5,p:1};
I.u[2562] = {n:"Trool Slip",t:56,d:"Gezien de staat van zijn onderbroek, gaat de Trool overal op zitten. Zo kun je ook de leeftijd van zijn eigenaar bepalen. Met je neus, natuurlijk...",ep:4,g:572,l:115,wd:true,fm:true,w:1,p:1};
I.u[2563] = {n:"Houten Spie van de Stamchnid",t:38,d:"Deze stut werkt als een voet voor de Tronknyde, want de voet dient als stut. Ongelukkigerwijze is de Troknyde altijd op zoek naar een stut.",ep:9,g:573,l:35,wd:true,fm:true,w:2,p:1};
I.u[2564] = {n:"Stamchnid Wenkbrauwen",t:38,d:"Wil je de techniek van de Stamchnid kennen om onvoorzichtige bezoekers te laten schrikken? Wel, je hebt het bij de hand: een paar grote lekker dikke Wenkbrauwen.",ep:9,g:574,l:35,wd:true,fm:true,w:2,p:1};
I.u[2565] = {n:"Stamchnid Schijf",t:15,d:"Nadat je een mooie Schijf van deze Stamchnid hebt gesneden, trekt hij een lang gezicht.",ep:9,g:575,l:35,wd:true,fm:true,w:2,p:1};
I.u[2566] = {n:"Magische Stamchnid Schijf",t:15,d:"Deze Schijf lijkt er anders uit te zien dan de andere Stamchnid schijven. Op het moment dat hij gesneden wordt, flitst er een verblindend licht van de Stamchnid en verdwijnt vervolgens, waarna enkel de Schijf op de grond ligt.",ep:9,g:576,l:35,wd:true,fm:true,w:2,p:1};
I.u[2567] = {n:"Anticipatie",t:29,d:"Met deze zegening ben je energieker voor het eerstvolgende gevecht.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2568] = {n:"Submenselijke Reflexen",t:30,d:"Deze vloek dompelt je in een staat van half-bewuszijn en je reflexen zullen daardoor minder zijn bij het eerstvolgende gevecht.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2569] = {n:"Bovenmenselijke Reflexen Schriftrol",t:14,d:"Met deze schriftrol ben je energieker voor het eerstvolgende gevecht.",ep:1,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2570] = {n:"Onmenselijke Reflexen Schriftrol",t:14,d:"Met deze schriftrol kan je een futloos draadje zijn voor het eerstvolgende gevecht.",ep:1,g:29,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2571] = {n:"Prespic Poot",t:103,d:"Hoe kan een Prespic, en je zult je dit ook zeker afvragen, zo lenig zijn met deze twee ongelukkige tenen? Het is en blijft een mysterie.",ep:1,g:577,l:18,wd:true,fm:true,w:1,p:1};
I.u[2572] = {n:"Prespic Maag",t:15,d:"\"Door de hele tijd hetzelfde te eten, ga je uiteindelijk lijken op wat je eet\". Dat waren de wijze woorden van de Bontarische kok Jon-kierre Poff. Dat verklaart waarom de Prespic een groene Maag heeft van het ingenomen gazon.",ep:1,g:578,l:18,wd:true,fm:true,w:1,p:1};
I.u[2573] = {n:"Prespic Staart",t:65,d:"De Prespic gebruikt zijn staart slechts zelden, en gelukkig maar, want de kracht die daarin huist blijkt verrassend. Sommige houthakkers hebben zelfs Prespics gezien die midden in de nacht met hun staart blokken Hout rondsleepten.",ep:1,g:579,l:18,wd:true,fm:true,w:1,p:1};
I.u[2574] = {n:"Prespic Manen",t:15,d:"Voor \"Vee-Ai-Pie\" feestjes van Osamodas discipelen is deze haardos perfect. Iedereen zal je voor een bezworen wezen aanzien.",ep:1,g:580,l:18,wd:true,fm:true,w:1,p:1};
I.u[2575] = {n:"Boowolf Schedel",t:15,d:"Bij jouw komst had de Boowolf hoogst waarschijnlijk dezelfde intentie als jij, dat wil zeggen je met min of meer diplomatie te ontdoen van je schedel. Je was hem lekker te vlug af.",ep:1,g:581,l:70,wd:true,fm:true,w:1,p:1};
I.u[2576] = {n:"MiliBoowolf Schedel",t:15,d:"Toen je aankwam, had de MiliBoowolf ongetwijfeld dezelfde bedoeling als jij, dat wil zeggen met meer of minder gevoeligheid je Schedel eraf halen. Zie hier de ondeugd zonder het topje van zijn schedel.",ep:1,g:582,l:22,wd:true,fm:true,w:1,p:1};
I.u[2577] = {n:"Moowolf Schedel",t:15,d:"Toen hij je zag, had de Moowolf vast hetzelfde doel als jij, dat wil zeggen om met min of meer tact jouw Schedel te verwijderen. Hij mag wel oppassen dat ie geen hoofdverkoudheid oploopt.",ep:2,g:583,l:198,wd:true,fm:true,w:1,p:1};
I.u[2578] = {n:"Boowolf Oog",t:109,d:"Zelfs als je hem hebt losgerukt, blijft de blik van de Boowolf  op je gericht. En als je goed kijkt, zul je denken dat hij je met zijn beide ogen volgt, in plaats van met één.",ep:1,g:584,l:70,wd:true,fm:true,w:1,p:1};
I.u[2579] = {n:"MiliBoowolf Oog",t:109,d:"Zelfs uitgerukt, rust de blik van de MiliBoowolf-ogen nog op jou. En als je goed kijkt, knippert het Oog nog. Wat een vitaliteit, die MiliBoowolf.",ep:1,g:585,l:22,wd:true,fm:true,w:1,p:1};
I.u[2580] = {n:"Moowolf Oog",t:109,d:"Zelfs uitgerukt, rust de blik van de Moowolf-ogen op jou. En als je goed kijkt, fronst hij zijn wenkbrauwen als je naar hem wijst. Zeker weten, de Moowolf is er niet voor de grap.",ep:2,g:586,l:198,wd:true,fm:true,w:1,p:1};
I.u[2581] = {n:"Moowolf Tanden",t:47,d:"Als je in de familie van de Boowolfs degene met de grootste tanden zoekt, heb je zojuist een goede slag geslagen. Dat is om beter op je te kunnen kwijlen, kind.",ep:2,g:587,l:198,wd:true,fm:true,w:1,p:1};
I.u[2582] = {n:"Moowolf Testikels",t:15,d:"Als men een schandalige prijs vraagt voor de Testikels van de Moowolf, begrijp je dat wat je in je handen hebt een handvol.... geld waard is.",ep:2,g:588,l:198,wd:true,fm:true,w:20,p:1};
I.u[2583] = {n:"Krabben Oog",t:109,d:"Zoetwater zeelieden lusten graag Krabben Oog, want je kunt ze op het vasteland vangen.",ep:1,g:589,l:4,wd:true,fm:true,w:1,p:1};
I.u[2584] = {n:"Modrhand",t:15,d:"Deze Boohand is helemaal bedekt met modder. Of misschien zit er helemaal niets onder deze modder, zelfs niet de hand van Boo.",ep:2,g:590,l:19,wd:true,fm:true,w:1,p:1};
I.u[2585] = {n:"Modrhart van Boo",t:15,d:"Met zijn Modrhart is het moeilijk de Boo de plaatsen in de voedselketen. Erover nadenkend, komt de Boo zeker niet boovenaan de keten.",ep:2,g:591,l:19,wd:true,fm:true,w:1,p:1};
I.u[2586] = {n:"Vleugel van de Wilde Rossige Drakokalkoen",t:104,d:"Deze Vleugel ruikt naar zwavel. Iedere goede Drakokalkoenfokker zal je vertellen dat dit het meest malse deel is voor een BBQ. Kruid het vlees evenwel, want de Vleugel is het meest smakeloze deel.",ep:2,g:592,l:29,wd:true,fm:true,w:1,p:1};
I.u[2587] = {n:"Houthakkers Bijltje",t:19,d:"Dit bijltje is onontbeerlijk voor elke houthakker. Niet dat hij nu echt zo nuttig is, je kunt er geen boom mee kappen, maar als hij aan je riem hangt, kalmeert hij en stelt hij gerust.",ep:1,g:6,l:3,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,30,30,false,false],c:"CV>2",p:20};
I.u[2588] = {n:"Drakokalkoen Vleugel",t:104,d:"Men kan zeggen dat de tamme Drakokalkoen beter is dan zijn wilde neef. Hij heeft sowieso geen zwavelachtige nasmaak, maar het vlees is zo smaakvol als je je maar kan wensen, waardoor het het favoriete gerecht van alle kleintjes is.",ep:2,g:593,l:29,wd:true,fm:true,w:1,p:1};
I.u[2589] = {n:"Hevlavlav Bijltje",t:19,d:"Deze kleine bijl is niet geschikt om bomen mee te kappen, maar dient om zich tegen sommige kleine monsters te verdedigen. Echter, sta je oog in oog met een Minotoror, zet het dan op een lopen.",ep:1,g:7,l:6,wd:true,fm:true,w:10,an:17,e:[10,4,1,1,40,40,false,false],p:60};
I.u[2590] = {n:"Vôr\'Om Bijl",t:19,d:"Deze serie bijlen werd gemaakt door een Bwork leerlingsmid. Hij is goed in balans en redelijk krachtig. Deze Bwork heeft hiermee DE oorlogsbijl uitgevonden voor jonge avonturiers.",ep:1,g:13,l:12,wd:true,fm:true,w:15,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>10",p:120};
I.u[2591] = {n:"Staart van de Wilde Rossige Drakokalkoen",t:65,d:"Het belang van deze staart is simpel: zet hem op een ronde rots en laat de Staart draaien. Als de Staart stopt, ga dan in de richting die de punt aangeeft. Dat is de manier waar de Sadida zich al millennia lang verplaatsen.",ep:2,g:594,l:27,wd:true,fm:true,w:1,p:1};
I.u[2592] = {n:"Bombu Kliever",t:19,d:"Deze zeer licht en makkelijk hanteerbare bijl vergemakkelijkt de weidse bewegingen die nodig zijn om in alle zekerheid de Bombu te kappen.",ep:13,g:15,l:39,wd:true,fm:true,w:1,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>20&CW>20",p:390};
I.u[2593] = {n:"Paarse Oliviolet Snoeier",t:19,d:"Deze bijl, gemaakt van Paars Oliviolet, is de enige die de paarse golven van de Paarse Oliviolet weerstaat. Zoiets als kwaad met kwaad bestrijden.",ep:14,g:14,l:42,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>60",p:420};
I.u[2594] = {n:"Drakokalkoen Staart",t:65,d:"Vreemd genoeg, heeft de Drakokalkoen Staart geen enkele magische kracht. Net als bij de Crocodyl groeit de Staart weer snel aan. Een legende vertelt ook dat een Drakokalkoen aan het eind van zijn Staart was gegroeid. Je bent dus gewaarschuwd.",ep:2,g:595,l:17,wd:true,fm:true,w:1,p:1};
I.u[2595] = {n:"Stenen Bijl",t:19,d:"Deze erg primitieve bijl is daarom niet minder doeltreffend. Zoiets als sommige oudjes.",ep:5,g:2,l:51,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>50&CV>60",p:510};
I.u[2596] = {n:"Drakokalkoen Melk",t:15,d:"Fokkers waarderen het als ze hun Drakokalkoenen kunnen melken. Het enige probleem is dat deze melk niet verkoopt, want hij is weerzinwekkend. Hij is dus alleen geschikt voor het voeden van kleine Drakokalkoentjes.",ep:2,g:424,l:29,wd:true,fm:true,w:1,p:1};
I.u[2597] = {n:"Breek Bijl",t:19,d:"Deze lange bijl wringt zich  door elke kier of spleet van bomen om ze beter in tweeën te hakken. Hij heeft hetzelfde nut tijdens een gevecht, de tegenstander heeft altijd wel een of twee kieren of openingen om munt uit te slaan.",ep:14,g:16,l:54,wd:true,fm:true,w:20,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>70",p:540};
I.u[2598] = {n:"Stekel van de Wilde Rossige Drakokalkoen",t:47,d:"Deze Stekel is niets anders dan een uitstekend bot. De Drakokalkoen gebruikt het zo weinig, dat je je afvraagt wat ze gedaan heeft om het zo toe te takelen. Sinds Biologen hebben gezien hoe ze tegen Trools aan schuren, begrijpen ze het beter.",ep:2,g:596,l:29,wd:true,fm:true,w:1,p:1};
I.u[2599] = {n:"Stekel van de Drakokalkoen",t:47,d:"Deze Stekel, die op de rug van de Drakokalkoen zit, zou misschien kunnen dienen om je kruis te krabben, als je erin slaagt op een Drakokalkoen te rijden.",ep:2,g:597,l:29,wd:true,fm:true,w:1,p:1};
I.u[2600] = {n:"Hak Bijl",t:19,d:"Deze grote bijl maakt een monsterlijk geluid als hij op iets terecht komt, met als gevolg dat alles erom heen stil wordt. Dat is alvast meegenomen.",ep:14,g:17,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>30&CV>30&CA>30",p:660};
I.u[2601] = {n:"Darsson Bijl",t:19,d:"Darsson was een dappere Enutrof, handvaardig als zijn voeten. Omdat hij vaak tijdens een gevecht zijn schep liet vallen, had hij het geniale idee opgevat een reservebijl aan zijn riem vast te maken. Dat heeft hem menig maal het leven gered, totdat hij zijn bijl liet vallen...",ep:14,g:18,l:57,wd:true,fm:true,w:15,an:17,e:[12,4,1,1,30,30,false,false],c:"CC>20&CA>20&CV>20",p:570};
I.u[2602] = {n:"Trukikol Bloemblaadje",t:35,d:"Niet groter dan een krabbeoog, bestaat het bloemblaadje van de Trukikol uit meerdere aan elkaar plakkende luchtbelletjes die sponsachtig aanvoelen. Het dient meestal voor het dichtplakken van de gaten in de daken na de hevige stormen aan het eind van het jaar.",ep:12,g:598,l:12,wd:true,fm:true,w:1,p:1};
I.u[2603] = {n:"Delen Kliever",t:19,d:"Deze bijl is erg nuttig om bepaalde recalcitrante delen van een boom af te snijden, met name de kleine zwellingen van de stam, om een zo recht en rond mogelijk boom te verkrijgen.",ep:13,g:2,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CS>30",p:660};
I.u[2604] = {n:"Militielid Bijl",t:19,d:"Deze bijl wordt voornamelijk gebruikt door de militieleden van Amakna. Zijn lengte en doeltreffendheid zal waarschijnlijk iets anders moeten compenseren.",ep:13,g:3,l:78,wd:true,fm:true,w:30,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>30&CS>30&CW>30&CC>5",p:780};
I.u[2605] = {n:"Glukoko huid",t:59,d:"Wees niet verbaasd als je verteld wordt dat de Glukoko huid plakt. Je kunt vanalles op het plafond plakken hierdoor. We danken het aan een boer die er patent op aanvroeg, zijn naam was Rollio van Scautche.",ep:12,g:599,l:12,wd:true,fm:true,w:1,p:1};
I.u[2606] = {n:"Slimme Bijl",t:19,d:"Op dit grote bijltje, zijn vele inscripties gekerft die aan de grondbeginselen van Amakna herinneren. Zijn uitvinder Claus Ansipedi wilde hiermee een schijn van cultuur meegeven aan echte woestelingen... vergeefse moeite, want hij stierf aan een ingeslagen schedel.",ep:4,g:4,l:81,wd:true,fm:true,w:30,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CA>50&CI>50",p:810};
I.u[2607] = {n:"Dode Glukoko",t:15,d:"Je hebt er goed aan gedaan dit op te rapen, want het is intact. Dood, maar intact.",ep:12,g:600,l:14,wd:true,fm:true,w:10,p:1};
I.u[2608] = {n:"Globetrotter Bijl",t:19,d:"Deze bijl reist de hele wereld rond en voornamelijk naar het zuiden. Want dit type bijl is gesmeden in het zuiden van Amakna door een klein beroem schatjagersgilde die bekend zijn om hun doeltreffendheid.",ep:18,g:1,l:84,wd:true,fm:true,w:18,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>100&CS>50",p:840};
I.u[2609] = {n:"Lege Groene Schelp",t:107,d:"Maar waar is de eigenaar? Misschien is hij op stap gegaan om brood met tomaat erop te kopen.",ep:7,g:601,l:24,wd:true,fm:true,w:2,p:1};
I.u[2610] = {n:"Lege Rode Schelp",t:107,d:"Maar waar is de eigenaar? Hij is waarschijnlijk kort geleden verhuisd.",ep:7,g:602,l:24,wd:true,fm:true,w:2,p:1};
I.u[2611] = {n:"Lege Gele Schelp",t:107,d:"Maar waar is de eigenaar? Misschien binnen een dutje aan het doen.",ep:7,g:603,l:24,wd:true,fm:true,w:2,p:1};
I.u[2612] = {n:"Vissen Sabel",t:19,d:"Deze lange bijl wordt gebruikt door ervaren zeelieden om reuzenvissen te trotseren die hun boten aanvallen. Men kan zich makkelijk voorstellen hoeveel schade hij kan aanrichten tegen veel kleinere monsters.",ep:14,g:4,l:87,wd:true,fm:true,w:32,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>50&CA>50",p:870};
I.u[2613] = {n:"Lege Blauwe Schelp",t:107,d:"Maar waar is de eigenaar? Misschien onder de douche.",ep:7,g:604,l:24,wd:true,fm:true,w:2,p:1};
I.u[2614] = {n:"Dame Oises Bijl",t:19,d:"Dame Oise was een allerliefste prinses die onschuld en frisheid uitstraalde. Iedereen was dan ook verrast toen zij, tijdens een aanval op de stad door de Bwork, met deze bijl in haar eentje de helft van het vijandige leger neersloeg.",ep:18,g:5,l:90,wd:true,fm:true,w:28,an:17,tw:true,e:[10,4,1,1,40,40,false,false],c:"CV>150&CW>50&CS>250",p:900};
I.u[2615] = {n:"Lookabeer Bijl",t:19,d:"Deze bijl staat bekend om zijn doeltreffende manier om eens en voor altijd en zeer snel een ruzie tussen dronken Enutrofs te beëindigen.",ep:18,g:8,l:96,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>120",p:960};
I.u[2616] = {n:"Bards Hel",t:19,d:"Deze bijl dankt zijn naam aan de test die werd gedaan om zijn verschrikkelijke doeltreffendheid te bewijzen: een gigantische bijl, een mythofobiac en een hal met barden.",ep:14,g:7,l:99,wd:true,fm:true,w:40,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>100&CS>100",p:990};
I.u[2617] = {n:"Kokosnoot Moot",t:15,d:"Haaaaahh... eindelijk iets dat je doet denken aan de vakantie.",ep:12,g:605,l:14,wd:true,fm:true,w:1,p:1};
I.u[2618] = {n:"Kokorietje",t:15,d:"Om een fris drankje op te slurpen, heb je een gekleurd rietje nodig. En dan moet je een gat in de Kokonoot vinden...",ep:12,g:433,l:14,wd:true,fm:true,w:1,p:1};
I.u[2619] = {n:"Kokomelk",t:15,d:"Wat een goed idee! Kokomelk in een fles! Je kunt het drinken waar en wanneer je wilt.",ep:12,g:423,l:14,wd:true,fm:true,w:1,p:1};
I.u[2620] = {n:"Kwaliteits Rum",t:15,d:"Deze oude rum komt vast uit een hoog gewaardeerde kelder. Tenzij het uit een veldfles komt die generaties lang vergeten in iemands zak heeft gezeten.",ep:12,g:177,l:94,wd:true,fm:true,w:1,p:1};
I.u[2621] = {n:"Le Choque\'s baard",t:15,d:"Je hebt net de baard van de kin van Le Chouque afgerukt. Vreemd genoeg kwam zijn tand met de baard mee... dit komt misschien omdat hij al zo lang dood is.",ep:12,g:606,l:94,wd:true,fm:true,w:1,p:1};
I.u[2622] = {n:"Le Chouque\'s Kronkeling",t:15,d:"Vanaf de top van deze kronkeling kijken zeven generaties piraten al neer op jou.",ep:12,g:607,l:94,wd:true,fm:true,w:2,p:1};
I.u[2623] = {n:"Broodmagere Bwak",t:15,d:"Fokkers hebben altijd geloofd dat de Bwaks wegvlogen aan het einde van hun leven...deze Bwak moet een uitzondering zijn.",ep:12,g:608,l:94,wd:true,fm:true,w:1,p:1};
I.u[2624] = {n:"Kokokoblaadje",t:36,d:"Stoutmoedige jagers willen hoe dan ook en koste wat kost onder het mom van soevenir een Kokokoblaadje meenemen, om vervolgens nooit meer op dit vervloekte eiland terug te komen. Waarom niet?",ep:12,g:609,l:42,wd:true,fm:true,w:1,p:1};
I.u[2625] = {n:"Thierry Voodoo Pop",t:15,d:"Sterkte vloeit voort uit deze pop en je hebt het vreemde gevoel dat hij iemand roept.",ep:12,g:610,l:51,wd:true,fm:true,w:2,p:1};
I.u[2626] = {n:"Jay Voodoo Pop",t:15,d:"Sterkte vloeit voort uit deze pop en je hebt het vreemde gevoel dat hij iemand roept.",ep:12,g:611,l:51,wd:true,fm:true,w:2,p:1};
I.u[2627] = {n:"Sarbak Voodoo Pop",t:15,d:"Sterkte vloeit voort uit deze pop en je hebt het vreemde gevoel dat hij iemand roept.",ep:12,g:612,l:51,wd:true,fm:true,w:2,p:1};
I.u[2628] = {n:"Boogschutter Voodoo Pop",t:15,d:"Sterkte is afkomstig van deze pop en je hebt het vreemde gevoel dat hij op iemand wacht.",ep:12,g:613,l:51,wd:true,fm:true,w:2,p:1};
I.u[2629] = {n:"Minotoris Caracape",t:17,d:"Deze cape van koninklijk allure, biedt vooral een ongelofelijke bescherming. Een beroemde vrouwelijke kleermaker kreeg hierdoor naam, net voordat zij stierf doordat ze onder de voet gelopen werd door de menigte.",ep:13,g:55,l:121,wd:true,fm:true,w:10,p:38500};
I.u[2630] = {n:"Greedovore pot",t:15,d:"De Greedovore is kortgezegd niet erg vrijgevig. Je hebt erg veel geluk gehad als hij je deze pot tot aan de nok toe gevuld heeft gegeven. Je moet gewoon nog even kijken wat je ermee doet.",ep:12,g:614,l:44,wd:true,fm:true,w:1,p:1};
I.u[2631] = {n:"Greedovore maag",t:15,d:"Dit is de meest bestendige maag die je ooit zult zien. Hij is zo elastisch dat je je er zelfs in zou kunnen verschuilen, als je dit zou willen.",ep:12,g:615,l:44,wd:true,fm:true,w:1,p:1};
I.u[2632] = {n:"Greedo Rum",t:15,d:"Deze fles van per ongeluk in een Greedovore achtergebleven en vreemd genoeg is de rum verbeterd. Deel je ontdekking niet met boeren want dan zullen alle warenhuizen vol staan met Greedovores.",ep:12,g:177,l:44,wd:true,fm:true,w:1,p:1};
I.u[2633] = {n:"Misleidende Rum",t:15,d:"Een slinkse truc van de Ambusher is om een fles met rum te vullen met..nou ja, rum. Maar de geur kan gemakkelijk vanaf een afstand herkend worden... ja, het is de geur van gedroogde Glukoko.",ep:12,g:177,l:24,wd:true,fm:true,w:1,p:1};
I.u[2634] = {n:"Gebroken Speer",t:15,d:"De Ambusher zal zich slecht op zijn gemak voelen met deze Speer. Het valt nog te bezien of je hem kunt gebruiken...",ep:12,g:616,l:24,wd:true,fm:true,w:2,p:1};
I.u[2635] = {n:"Toe-Jam Brood",t:33,d:"Dit recept is ontstaan door een rivaal van Xavier de Bakker, te weten Danioul Garnioul de Bakker. Zijn naam was zo belachelijk dat zijn klanten niet ophielden hem te bespotten.  Hij wreekte zich door het deeg alleen nog maar met zijn voeten te kneden.",ep:1,g:13,l:80,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2636] = {n:"Parelhoen Brood",t:33,d:"Dit brood bevat lekker stukjes vlees, die de smaak en het uiterlijk hebben van gevogelte, maar dat is niet zo. Als je er goed naar kijkt, kun je een lichte geur van Tofu ontdekken.",ep:1,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2637] = {n:"De Klauw",t:6,d:"Dit gebogen lemmet, gemaakt van been, kraakbeen en hoorn, is even scherp als een Ecaflipklauw. En een beetje groter en schoner.",ep:13,g:33,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[2638] = {n:"Scherpe Klauw",t:6,d:"Dit zwaard is honderd procent natuurlijk en werkt als een zesde klauw aan de hand van een Ecaflip. Nu we het hier toch over hebben, pas op dat je niet je neus ermee krabt !",ep:14,g:34,l:68,wd:true,fm:true,w:12,an:14,e:[12,4,1,1,30,50,false,false],c:"CV>30&CA>30&CS>30",p:6800};
I.u[2639] = {n:"Nep Ceangal Klauw",t:6,d:"Een Ecaflippinsmid kreeg inspiratie dit zwaard te smeden na haar mislukking om de eeuwenoude techniek met dezelfde naam te beheersen. Ze zei tegen zichzelf dat deze klauw haar niet in de steek zou laten.",ep:14,g:35,l:95,wd:true,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[2640] = {n:"Carnivoor Staf",t:4,d:"Deze vreemd gevormde Staf komt niet hier vandaan. Hij ruikt naar de oude donkere en vochtige plekken van Brakmar.",ep:1,g:24,l:30,wd:true,fm:true,w:56,an:12,e:[3,5,1,1,20,50,false,false],s:7,p:1000};
I.u[2641] = {n:"Toady",t:16,d:"Rood, wit en vooral top, je maakt het met deze hoed absoluut tijdens de altijd geslaagde feestavonden  van de ambassadeur.",ep:1,g:51,l:30,wd:true,fm:true,w:10,s:7,p:2700};
I.u[2642] = {n:"Rib Kaak",t:47,d:"De Rib is al een pietsie mager, maar als hij ook zijn Kaak verliest, wordt hij net zo aanvallend als een leger overwinterende teken.",ep:3,g:617,l:33,wd:true,fm:true,w:1,p:1};
I.u[2643] = {n:"Draak Varken hoorn",t:47,d:"Deze hoorn behoorde toe aan één van de meest beroemde roofdieren van de Amakna bergen: het Draak Varken. Vele jagers zouden hun hele familie verkopen om te kopen wat jij in je handen hebt. Dat is voor jou een droom mogelijkheid om een familie te krijgen voor weinig!",ep:2,g:618,l:70,wd:true,fm:true,w:1,p:1};
I.u[2644] = {n:"Draak Varken staart",t:65,d:"Dit grote stuk van een Draak Varken staart is een waar genot. Bak het met enkele Sesam Zaadjes, het geheel bedekt met een Sauce Age en je gasten zullen niet meer weg willen gaan, is dat niet fantastisch? Nee? Nou ja...",ep:2,g:619,l:70,wd:true,fm:true,w:1,p:1};
I.u[2645] = {n:"Draak Varken Snuit",t:15,d:"Het Draak Varken rook die niet aankomen. Hahaha.",ep:2,g:620,l:70,wd:true,fm:true,w:1,p:1};
I.u[2646] = {n:"Leren Onderbroek van het Speen Varken",t:56,d:"Deze grote onderbroek zal het Speenvarken heel blij maken, de naden zijn elastisch en versterkt, voor een grotere doelmatigheid tijdens de komende gevechten. Volgens de traditie mag deze onderbroek nooit gewassen worden, op straffe van het verliezen van zijn wezenlijke nog onbekende maar tegenwoordig gevreesde eigenschappen.",ep:1,g:621,l:20,wd:true,fm:true,w:1,p:1};
I.u[2647] = {n:"Speenvarken Oor",t:106,d:"Op het Speenvarken wordt normaliter niet om zijn Oren gejaagd, maar eerder om zijn ivoor. Maar ja, bij gebrek aan Ivoor...",ep:1,g:623,l:20,wd:true,fm:true,w:1,p:1};
I.u[2648] = {n:"Kwak Klauwen",t:15,d:"De Kwak is geen lijkenpikker, maar heeft toch een vreemde substantie onder zijn klauwen, die we hier maar niet zullen beschrijven.",ep:1,g:624,l:30,wd:true,fm:true,w:1,p:1};
I.u[2649] = {n:"Aard Worm",t:15,d:"De Aardworm is het lievelingsgerecht van wilde Kwaks. Hoewel hij uit de maag van een Kwak is gehaald, leeft hij toch nog. Wat vreemd.",ep:5,g:625,l:30,wd:true,fm:true,w:1,p:1};
I.u[2650] = {n:"Water Worm",t:15,d:"Deze Worm is het lievelingsgerecht van de wilde Kwaks. Wat vreemder is, is dat hij bleef leven terwijl hij uit de Maag van de Kwak gehaald was.",ep:1,g:626,l:30,wd:true,fm:true,w:1,p:1};
I.u[2651] = {n:"Vuur Worm",t:15,d:"Deze Worm is het lievelingsgerecht van de wilde Kwaks. Wat vreemder is, is dat hij bleef leven terwijl hij uit de Maag van de Kwak gehaald was.",ep:5,g:627,l:30,wd:true,fm:true,w:1,p:1};
I.u[2652] = {n:"Lucht Worm",t:15,d:"Deze Worm is het lievelingsgerecht van de wilde Kwaks. Het vreemde is dat hij nog leefde toen hij uit de maag van de Kwak werd gehaald.",ep:5,g:628,l:30,wd:true,fm:true,w:1,p:1};
I.u[2653] = {n:"Dode Volwassen Arachnee",t:15,d:"Je hebt er goed aan gedaan hem op te rapen, hij is ongeschonden. Dood, maar ongeschonden.",ep:1,g:629,l:43,wd:true,fm:true,w:10,p:1};
I.u[2654] = {n:"Volwassen Arachnee Ei",t:105,d:"Het probleem met de Arachnees is dat het kan gebeuren dat je jezelf in gezelschap van meerdere generaties treft in een paar dagen van warmte. Dus als het snikheet weer is, ga dan niet teveel in het Bos van de Boomchnids wandelen.",ep:1,g:630,l:43,wd:true,fm:true,w:1,p:1};
I.u[2655] = {n:"Rafelige Riem",t:10,d:"Deze riem is gemaakt van de resten van de Meester Raaf, zorgvuldig aan elkaar genaaid. Je zou je gerespecteerd moeten voelen als je hem eenmaal om hebt. Het Ezelshoofd heeft er zelfs mee ingestemd zijn gesp te lenen voor deze gelegenheid.",ep:13,g:56,l:120,wd:true,fm:true,w:10,p:36938};
I.u[2656] = {n:"Duurzaam Draad",t:15,d:"Als de Schoenmakers en Kleermakers het bestaan van de Duurzame Draad zouden kennen, zou de Week van de Duurzame Draad, de Jaarmarkt van de Duurzame Draad en de heilige dag van de Duurzame Draad bestaan.",ep:1,g:631,l:43,wd:true,fm:true,w:1,p:1};
I.u[2659] = {n:"Wilde Zonnebloem Bloemblaadje",t:35,d:"Dit Bloemblaadje beweegt. Ja, het beweegt naar de zon. Doe het \'s morgens in je rechterzak, dan zal het \'s avonds in je linkerzak zitten.",ep:1,g:632,l:12,wd:true,fm:true,w:1,p:1};
I.u[2661] = {n:"Blaadje van Wilde Zonnebloem",t:36,d:"Dit deel van de Zonnebloem is niet alleen het blaadje van de plant, het is ook zijn plantengewelf. Wees dus niet verbaasd als het naar voeten ruikt.",ep:1,g:633,l:12,wd:true,fm:true,w:1,p:1};
I.u[2662] = {n:"Duivelse Roos Kwijl",t:15,d:"Een woedende Roos heeft de kwade gewoonte te kwijlen op wie er maar te dicht in de buurt durft te komen. Maar het schijnt dat het een teken van affectie is. Een Duivelse en bovendien affectieve Roos, je denkt dat je alles gehad hebt.",ep:1,g:634,l:8,wd:true,fm:true,w:1,p:1};
I.u[2663] = {n:"Mest",t:15,d:"Elke mooie plant heeft behoefte aan mest. Daarom hebben Enutrofettes op leeftijd dat niet nodig.",ep:1,g:635,l:8,wd:true,fm:true,w:1,p:1};
I.u[2664] = {n:"Crocodylebot",t:47,d:"Dit groenige en op z\'n minst wat vreemde bot komt van de poot van een Crocodyl. Deze laatste heeft ongetwijfeld Crocodyletranen gehuild toen hij begreep dat hij een poot minder had.",ep:4,g:636,l:36,wd:true,fm:true,w:2,p:100};
I.u[2665] = {n:"Gestoord Kruid",t:36,d:"Dit is het soort Kruid dat men in een Veelvraat-hok zou doen. Dit Kruid is gestoord omdat het af en toe opstaat en ontsnapt uit het hok, wat niet normaal is voor een bosje kruiden.",ep:1,g:637,l:9,wd:true,fm:true,w:1,p:1};
I.u[2666] = {n:"Minotoror hoef",t:47,d:"Minotoror heeft zeker vele avonturiers met zijn hoef verpletterd. Nou hij slechts één been over heeft, ziet hij er vast stom uit als hij sierlijk probeert te vechten. Hij ziet er ofwel stom ofwel gevaarlijk uit.",ep:2,g:800,l:125,wd:true,fm:true,w:1,p:1};
I.u[2667] = {n:"Minotoror Staart",t:65,d:"Het is een wonder om een staart van een Minotoror te zien zonder de Minotoror zelf eraan vast. Het arme ding zal er overal naar zoeken. Tenzij hij zich niet bewust is van de situatie, wat ook goed mogelijk is.",ep:2,g:640,l:125,wd:true,fm:true,w:1,p:1};
I.u[2669] = {n:"Vleermuis",t:15,d:"Soms veranderen Vampiers zich in Vleermuizen, om beter te kunnen vluchten. Maar ze voelen zich verplicht een lachje te laten ontsnappen voordat ze vluchten. Dat klinkt ongeveer zo: \"niap nioop niap niap\". Dat lachje kan een heel leger op de vlucht jagen... een leger teken.",ep:3,g:641,l:21,wd:true,fm:true,w:1,p:1};
I.u[2673] = {n:"Rot ei",t:105,d:"Het is gewoonweg schandelijk. Hoe kan je een Tofu-ei in staat van ontbinding fokken? Je moet wel echt een Kwade geest zijn om zulke ideeën te hebben.",ep:1,g:642,l:3,wd:true,fm:true,w:1,p:1};
I.u[2674] = {n:"Pompoentje",t:46,d:"Het pompoentje is heerlijk in dit jaargetijde. Niet te klein maar wel met veel smaak, maar ook niet te groot waardoor het gaat lijken of een Pwompwoen. Rijk aan vocht en het wordt vergoed door Och Meja.",ep:4,g:643,l:15,wd:true,fm:true,w:1,p:1};
I.u[2675] = {n:"Boze Tofu Veer",t:53,d:"De Boze Tofu heeft zeker niet veel Veren meer en zal zo een flinke verkoudheid oplopen, dus verbaas je niet als je hem \'s nachts hoort niesen.",ep:1,g:644,l:3,wd:true,fm:true,w:1,p:1};
I.u[2676] = {n:"Dood Oog",t:15,d:"Je hebt er goed aan gedaan hem op te rapen, hij is nog ongeschonden. Dood, maar ongeschonden.",ep:4,g:645,l:274,wd:true,fm:true,w:10,p:1};
I.u[2677] = {n:"Chouque Riem",t:10,d:"Deze riem is gemaakt van de meest krachtige elementen van de Chouque, te weten zijn beroemde onderbroek. Daarmee breng je de vrouwelijke vrijbuiters van de piratenbar in beroering.",ep:12,g:41,l:98,wd:true,fm:true,w:10,p:25000};
I.u[2678] = {n:"Kokokette Riem",t:10,d:"Deze riem lijkt bijna op een lendendoek en is uitstekend geschikt om je onopvallend te bewegen tussen de Kokokos van het Moon eiland, of gewoon als je een Kokoko wilt versieren.",ep:12,g:40,l:42,wd:true,fm:true,w:10,p:4800};
I.u[2681] = {n:"Gele Schildpad Riem",t:10,d:"Deze kleine riemr is ideaal om gevoelige delen tegen kritieke treffers te beschermen. Controleer wel of de schoenmaker de oorspronkelijke bewoner van dit schild heeft verwijderd alvorens hem te proberen.",ep:7,g:43,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2683] = {n:"Blauwe Schilpad Riem",t:10,d:"Deze kleine riem is ideaal om gevoelige delen te beschermen tegen zware stoten. Controleer wel of de schoenmaker de eigenaar van het pantser goed heeft verwijderd alvorens hem te proberen.",ep:7,g:44,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2685] = {n:"Groene Schildpad Riem",t:10,d:"Deze kleine riem is ideaal voor de bescherming van gevoelige delen bij kritieke treffers. Controleer echter of de schoenmaker goed de eigenaar van dit pantser heeft verwijderd alvorens hem te proberen.",ep:7,g:42,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2687] = {n:"Rode Schildpad Riem",t:10,d:"Deze kleine riem is ideaal voor de bescherming van gevoelige delen bij kritieke treffers. Controleer echter of de schoenmaker goed de eigenaar van dit pantser heeft verwijderd alvorens hem te proberen.",ep:7,g:45,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2688] = {n:"Kleef Riem",t:10,d:"Een ding is zeker, heb je eenmaal deze riem om, dan loop je nooit het risico hem te verliezen. Een geluk voor vergeetachtigen en voor slachtoffers van herhaaldelijke diefstal.",ep:12,g:46,l:50,wd:true,fm:true,w:10,p:6600};
I.u[2689] = {n:"Banisatie Riem",t:10,d:"De schoenmaker die deze riem maakte van de overblijfselen van een Drakokalkoen had niet veel fantasie om er zo\'n stomme naam aan te geven.",ep:2,g:47,l:29,wd:true,fm:true,w:10,p:2400};
I.u[2710] = {n:"Wilde Banisatie Riem",t:10,d:"Versterkt met ijzer is dit een verbeterde versie van de klassieke Verbannen Riem, die speciaal gemaakt is om Wilde Drakokalkoenen in de wilde contreien te verdrijven.",ep:2,g:48,l:32,wd:true,fm:true,w:10,p:3000};
