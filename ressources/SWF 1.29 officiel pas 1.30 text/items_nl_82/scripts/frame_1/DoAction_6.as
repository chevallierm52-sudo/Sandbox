I.u[2803] = {n:"Krab Riem",t:10,d:"Deze vreemde riem is gemaakt van stukjes schaar en de schaal van een krab. Ook al gebruik je de meest krachtige toverkunst, hij blijft nog steeds stinken, daar moet je maar aan wennen.",ep:1,g:49,l:8,wd:true,fm:true,w:2,p:400};
I.u[2804] = {n:"Boowige Riem",t:10,d:"De beroemde Boowolf heeft zijn waardevolle organen beschikbaar gesteld voor de fabricage van deze ongelofelijke riem, die kracht uitstraalt ondanks zijn enigzins vreemde uiterlijk en die bij alle perverse Chafers gewild is.",ep:2,g:50,l:81,wd:true,fm:true,w:10,p:16800};
I.u[2805] = {n:"Magische Boowolf Testikels",t:15,d:"Niemand weet precies hoe het gekomen is, maar op een dag bleken deze testikels begiftigd met magische krachten die, dat moet toegegeven worden, nogal duister zijn.",ep:1,g:650,l:80,wd:true,fm:true,w:20,p:1000};
I.u[2806] = {n:"Magische Moowolf Testikels",t:15,d:"Hoe vreemd het ook mag lijken, deze testikels bezitten magische kracht. Men weet niet wat de Moowolf daar aan had en dat is misschien maar beter ook.",ep:2,g:651,l:198,wd:true,fm:true,w:10,p:2000};
I.u[2807] = {n:"Moowige Riem",t:10,d:"Het is Bowisse de Schoenmaker in hoogsteigen persoon die deze riem gemaakt heeft. Hij heeft hem aangeboden aan Brouce Boulgoure toen deze erin geslaagd is een Slappe Eik met zijn blote handen te vellen, heel lang geleden.",ep:2,g:51,l:129,wd:true,fm:true,w:20,p:50000};
I.u[2808] = {n:"Varkens Draak Riem",t:10,d:"Met deze riem word je onweerstaanbaar. Echter, Bowisse raadt je aan niet te dicht bij een Varkens Draak te komen met deze riem, want dat zou woeste driften in hem wakker kunnen maken.",ep:2,g:52,l:77,wd:true,fm:true,w:20,s:58,p:16000};
I.u[2809] = {n:"Chafeuse Riem",t:10,d:"Achter deze enigzins belachelijke naam, gaat een prachtige creatie schuil van Bowisse de Schoenmaker, die tijdens een wandeling door de Skelettentoren het idee kreeg om de overblijfselen van zijn vijanden te gebruiken.",ep:3,g:53,l:49,wd:true,fm:true,w:10,p:6500};
I.u[2810] = {n:"Pikante Riem",t:10,d:"Dankzij de magische krachten van deze prachtige rossige riem kun je je beter concentreren en sneller leren. De droom van iedere slechte leerling van Amakna.",ep:1,g:54,l:26,wd:true,fm:true,w:6,p:2000};
I.u[2811] = {n:"Ouginak-riem",t:10,d:"Zie hier een riem die de liefhebbers van sterke emoties zeker zal bevallen. Inderdaad is deze laatste speciaal gemaakt om zonder risico een Ouginak te kunnen benaderen. Zijn doelmatigheid is evenwel nog niet bewezen.",ep:14,g:55,l:65,wd:true,fm:true,w:10,p:11000};
