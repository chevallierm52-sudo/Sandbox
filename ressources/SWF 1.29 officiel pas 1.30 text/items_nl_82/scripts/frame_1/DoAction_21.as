I.u[9566] = {n:"Raydi Schild",t:82,d:"Ze zeggen dat het allereerste Raydi schild in één van de ravijnen van Pandala was gesmeed en dat Pandala zelf, godin der godinnen, een handje heeft geholpen. Sommigen zeggen dat hij beschermt tegen stralen terwijl anderen zeggen dat hij daar juist van gemaakt is. Realiteit of fictie? Reclamestunt van de Schilden Smeden...? Wie weet... de tijd zal het zeggen.",ep:0,g:34,l:1,wd:false,fm:true,w:1,p:5000};
I.u[9567] = {n:"Zwarte Wab Hoed",t:16,d:"Met deze hoed op, lijk je op een gemaskerde wreker tenzij het een gevraagde trog is? Je weet hoe Wabs zijn...",ep:0,g:235,l:49,wd:true,fm:true,w:10,s:127,p:6325};
I.u[9569] = {n:"Zwarte Wab Cape",t:17,d:"De kleine pompom aan het einde van deze cape is de beste stofdoek ooit... Hij is zo klein dat hij zelfs onder je meubels kan komen. Vergeet hem niet af te doen als je in het veld gaat werken.",ep:0,g:164,l:46,wd:true,fm:true,w:10,s:127,p:5600};
