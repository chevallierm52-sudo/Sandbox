I.u[9652] = {n:"Alowa Hoofdband",t:16,d:"Deze hoofdband is perfect om zweet te absorberen of om je “Alowa Houding” te laten zien.",ep:0,g:236,l:48,wd:true,fm:true,w:10,s:129,p:6175};
I.u[9653] = {n:"Kwakap",t:16,d:"De vleugels op deze pet beschermen je voor je beledigingen.",ep:0,g:237,l:42,wd:true,fm:true,w:10,s:140,p:4825};
I.u[9654] = {n:"Alowa Cape",t:17,d:"Deze cape flatteert de krommingen van je achterkant, of de bult op je rug.",ep:0,g:165,l:48,wd:true,fm:true,w:10,s:129,p:6105};
I.u[9655] = {n:"Alowa Sandalen",t:11,d:"De zolen van deze sandalen zijn dikker dan reguliere sandalen om er zeker van te zijn ze tegen het gewicht van de zwaardere Alowas kunnen.",ep:0,g:132,l:49,wd:true,fm:true,w:10,s:129,p:6475};
I.u[9656] = {n:"Bezwijkende Skates",t:11,d:"Met deze skates kun je snel van een trap af, maar je vergroot wel de kans op een gigantische val! Jij mag kiezen!",ep:0,g:133,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9657] = {n:"Pooparoze Staf",t:4,d:"Wie gaf die staf zo\'n vreselijke verschijning? Nou, niemand weet dat... Maar je moet het nog steeds gebruiken tegen je vijanden... hoe stom JIJ er dan ook uit ziet.",ep:0,g:82,l:42,wd:true,fm:true,w:10,an:12,e:[1,3,1,1,10,40,false,false],c:"CV>60&CW>30",s:140,p:4200};
I.u[9658] = {n:"Alowa Amulet",t:1,d:"Dit is een zuivere bloemen ketting. Het behoort een magische geur af te geven en verandert een Alowa in een Alowaian...",ep:0,g:144,l:47,wd:true,fm:true,w:10,s:129,p:6000};
I.u[9659] = {n:"Bezwijkende Ketting",t:1,d:"Erala droeg dit amulet haar hele kindertijd. Niemand weet wat er in zit, zij ook niet.",ep:0,g:143,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9660] = {n:"Gesplitte Cape",t:17,d:"Twee staarten aan een lichaam... Een droom die eindelijk uitkomt!",ep:0,g:166,l:47,wd:true,fm:true,w:10,s:128,p:5825};
I.u[9661] = {n:"Angora Bow Meow Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:0,g:26,l:1,wd:true,fm:true,w:1,p:1};
