I.u[9916] = {n:"Speciale Spreuk Rol: \'Spirituele Lijn\'",t:75,d:"Deze rol leert je de spreuk \'Spirituele Lijn\'... voor Osamodas alleen.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"PG=2",u:true,p:10000};
I.u[9917] = {n:"Bonus Scroll",t:24,d:"Deze scroll vertelt je wie je doelwit is.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9919] = {n:"Mento Ring",t:9,d:"Let op mentoren, deze ring tovert je om in een scholier en een uil! Alleen dragen als je over de wereld heen trekt om kinderen te zoeken die je wat kunt leren om om lachen te delen...",ep:0,g:7,l:1,wd:false,fm:false,w:0,p:0};
I.u[9920] = {n:"Bonus Ontvangen Scroll",t:24,d:"Deze scroll bewijst dat het doelwit succesvol geneutraliseerd is.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9921] = {n:"Slamdance Armband",t:9,d:"Ze zeggen dat deze armband blinkt, maar alleen als je in een herberg bent of midden in de nacht.",ep:0,g:168,l:45,wd:true,fm:true,w:10,s:132,p:5525};
I.u[9922] = {n:"Slamdance Riem",t:10,d:"Deze riem bevat een gigantisch krachtige magneet welke het dicht houdt zonder pin. Het wordt vaak gebruikt als extra bescherming met een",ep:0,g:154,l:38,wd:true,fm:true,w:10,s:132,p:4050};
I.u[9923] = {n:"Slamdance Schoenen",t:11,d:"De mensen die op hun hoofd dansen zullen deze schoenen weinig kunnen gebruiken. Maar als je af en toe je voeten gebruikt, zijn ze precies wat je nodig hebt.",ep:0,g:135,l:40,wd:true,fm:true,w:10,s:132,p:4300};
I.u[9924] = {n:"",t:16,d:"",ep:0,g:239,l:42,wd:true,fm:true,w:10,s:139,p:4825};
I.u[9925] = {n:"",t:9,d:"",ep:0,g:169,l:44,wd:true,fm:true,w:10,s:139,p:4400};
I.u[9926] = {n:"",t:19,d:"",ep:0,g:57,l:39,wd:true,fm:true,w:10,an:17,e:[3,5,1,1,20,50,false,false],c:"CC>60&CV>50&CW>30",s:139,p:3900};
I.u[9927] = {n:"",t:11,d:"",ep:0,g:136,l:42,wd:true,fm:true,w:10,s:139,p:4805};
I.u[9928] = {n:"Siks Wonn Ein Laarzen",t:11,d:"Deze laarzen hebben ongeveer 12 uur nodig om ze aan te krijgen en nog langer om ze uit te doen. Dat geeft je net genoeg tijd om elke dag nog even te slapen, zo lang je vrijgezel, werkeloos en erg goed met je handen bent.",ep:0,g:137,l:42,wd:true,fm:true,w:10,s:131,p:4750};
I.u[9929] = {n:"Siks Wonn Ein Riem",t:10,d:"De achilleshiel zit niet altijd onder de knieën, weet je. Soms is het net onder het middel. In dat geval zal deze zware maar effectieve riem al die watjes wat gerust stellen.",ep:0,g:155,l:41,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9930] = {n:"Siks Wonn Ein Masker",t:16,d:"Dit masker geeft je niet alleen het uiterlijk van een beangstigend, moordend monster, maar het beschermt je wangetjes ook tegen gemene windvlagen en de hete zon.",ep:0,g:240,l:38,wd:true,fm:true,w:10,s:131,p:4000};
I.u[9931] = {n:"Slamdance Vette Kapsel",t:16,d:"Lang aan de achterkant, kort bovenop, dit kapsel heeft een slechte reputatie, maar dat zul je snel veranderen.",ep:0,g:241,l:39,wd:true,fm:true,w:10,s:132,p:4255};
I.u[9932] = {n:"Pluk van Herbergier Bagrutte\'s  haar",t:24,d:"Deze vieze pluk haar was uit een van de oksels van Herbergier Bagrutte getrokken. De geur zorgt ervoor dat je nooit meer aan iets wilt ruiken.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[9933] = {n:"Siks Wonn Ein Cape",t:17,d:"Elke man weet dat het meest gevaarlijke element van worstelen uit het publiek bestaat. Dus als de stoelen en flessen naar je hoofd vliegen, wikkel je dan goed in in deze mantel en bescherm jezelf.",ep:0,g:167,l:42,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9934] = {n:"Sleutel van de Paddock",t:24,d:"De goblins zijn uitgerust met standaard gereedschap, dus ze hergebruiken zoveel mogelijk en dit is geen uitzondering. Wie had ooit gedacht dat een simpel bot hun paddock kon openen? Jij niet in elk geval.",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9935] = {n:"Klimtouw",t:15,d:"Dit is nog eens sterk touw en verkocht het allerbeste aan klimmers die omhoog wilden. Het gaat ook naar beneden, maar dat is minder populair. Mensen van Amakna gebruiken het vaak met spijkerpoepen.",ep:0,g:170,l:1,wd:false,fm:true,w:5,p:1};
I.u[9936] = {n:"Darth Vaydhat",t:16,d:"Deze helm is perfect voor mensen die er te aardig uitzien. Dat kan erg gevaarlijk zijn in de Wereld van Twaalf.",ep:0,g:242,l:37,wd:true,fm:true,w:10,s:117,p:3825};
I.u[9937] = {n:"De Chatlin",t:16,d:"Deze hoed komt met een neppe tandenborstelsnor, welke erg leuk is tot je wordt aangezien voor een erge dictator.",ep:0,g:243,l:37,wd:true,fm:true,w:10,s:116,p:3700};
I.u[9938] = {n:"Swodor",t:6,d:"Dit zwaard is 18 maanden lang ondergedompeld in geconcentreerd vuurvliegjes sap om het te laten gloeien in het donker. Het stinkt nu ook in het donker, trouwens.",ep:0,g:91,l:38,wd:true,fm:true,w:10,an:14,tw:true,e:[5,4,1,1,50,50,false,false],c:"CV>30&CS>20&CW>20",s:117,p:3800};
I.u[9939] = {n:"De Chapstok",t:4,d:"Deze flexibele bamboestok is zeker niet om op te leunen... probeer het in de lucht rond te draaien.",ep:0,g:88,l:37,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"CC>25",s:116,p:3700};
I.u[9940] = {n:"Ruwe Moeder der Parels",t:51,d:"Deze moeder des parels zal beeldschoon zijn als die geslepen is.",ep:0,g:10,l:20,wd:true,fm:true,w:1,p:10};
I.u[9941] = {n:"Moeder der Parels",t:50,d:"Dit materiaal is gemaakt van arogoniet kristallen en schelpiet. Het was onbekend tot Otomai Eiland werd ontdekt en schelpiet was gevonden. Dit element is erg kostbaar voor alchemisten, alhoewel de recepten waarin het gebruikt wordt altijd jaloers bewaakt worden.",ep:0,g:4,l:50,wd:true,fm:true,w:10,p:5000};
I.u[9942] = {n:"Ring der Dood",t:9,d:"Deze ring is ook bekend als de Zwarte Band, maar ook al heeft het twee namen, is het nog niet klaar. Het is wel sterk genoeg om een kleine planeet te vernietigen.",ep:0,g:170,l:36,wd:true,fm:true,w:10,s:117,p:3600};
I.u[9943] = {n:"Paar o\'Shuplins",t:11,d:"Deze schoenen zijn zoals het gerucht gaat opgegeten door een verhongerende goudmijner om daarna weer in elkaar gezet te worden toen het er aan de andere kant weer uit kwam. Dat moet zijn waarom ze zo blinken.",ep:0,g:138,l:43,wd:true,fm:true,w:10,s:116,p:4975};
I.u[9944] = {n:"De Chavate",t:1,d:"Dit amulet zal je er uit laten zien als een edelman, zelfs als je net uit de goot bent gekropen.",ep:0,g:145,l:43,wd:true,fm:true,w:10,s:116,p:5000};
I.u[9945] = {n:"Newddha de Profeet\'s Zak",t:81,d:"Newddha de Profeet is beroemd omdat hij op de rijkdom van zijn familie teert en onder een Kokonut boom zit te wachten op verlichting. In plaats daarvan viel een grote Kokonut op zijn hoofd, waardoor hij al die spirituele onzin in een keer achter zich liet.",ep:0,g:33,l:38,wd:true,fm:true,w:10,s:117,p:4050};
I.u[9946] = {n:"Kain Daryn Kristal",t:24,d:"Kain Daryn\'s beroemdheid als een schatjager spreid zich tot ver in Amakna. Hij heeft vele kristallen ontdekt met geweldige eigenschappen, inclusief de kracht om rond te kijken zonder zijn handen te gebruiken. Kain vertelde niemand waar de kristallen gevonden konden worden en tot op de dag van nu zijn nog vele Enutrofs er naar op zoek.",ep:0,g:744,l:1,wd:false,fm:true,w:0,p:1};
I.u[9947] = {n:"Betoverde Kain Daryn Kristal",t:24,d:"Dit Kain Daryn Kristal is betoverd om de hebzucht van iedereen die het ziet te vergroten.",ep:0,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9948] = {n:"Chef Dief\'s Scheen",t:24,d:"De Chef Dief zal moeite hebben met een Scheenbeen minder te lopen! Naja, daar zal hij wel van leren.",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9949] = {n:"Tra Khben Lijm",t:110,d:"Deze lijm is uitgevonden door de beroemde Tra Khben, een geologist die gesprecialiseerd was in ecosystemen en oogsten, en wie last had van een zere rug sinds een zeer jonge leeftijd. Deze lijm is bekend omdat elk organisch materiaal waar het mee in aanraking komt keihard wordt. Tra Khben gebruikte deze eigenschap om rechtop te kunnen staan. Toen de geologist dood ging, werd het erg populair bij Enutrofs, voor een geheel andere reden. Het enige nadeel is de geur, wat de slechte adem van vele Enutrof mijnwerkers verklaard.",ep:0,g:42,l:1,wd:false,fm:true,w:1,p:1};
I.u[9950] = {n:"Onzuivere Blauwe Corruptah Steen",t:51,d:"Deze steen zal zijn volledige potentie krijgen als die geslepen is.",ep:0,g:151,l:1,wd:false,fm:true,w:5,p:1};
I.u[9951] = {n:"Onzuivere Gele Corruptah Steen",t:51,d:"Deze steen zal zijn volledige potentie krijgen als die geslepen is.",ep:0,g:145,l:1,wd:false,fm:true,w:5,p:1};
I.u[9952] = {n:"Onzuivere Groene Corruptah Steen",t:51,d:"Deze steen zal zijn volledige potentie krijgen als die geslepen is.",ep:0,g:76,l:1,wd:false,fm:true,w:5,p:1};
I.u[9953] = {n:"Blauwe Corruptah Steen",t:50,d:"Deze steen kan onwillende zielen corrupt maken, wat handig is bij het transformeren van Tofus in Slechte Tofus. Als ze gecombineerd worden met andere Corruptah Stenen, kan het de drager complete controle over de zielen geven.",ep:0,g:460,l:50,wd:false,fm:true,w:10,p:100};
I.u[9954] = {n:"Gele Corruptah Steen",t:50,d:"Deze steen kan onwillende zielen corrupt maken, wat handig is bij het transformeren van Tofus in Slechte Tofus. Als ze gecombineerd worden met andere Corruptah Stenen, kan het de drager complete controle over de zielen geven.",ep:0,g:463,l:50,wd:false,fm:true,w:10,p:100};
I.u[9955] = {n:"Groene Corruptah Steen",t:50,d:"Deze steen kan onwillende zielen corrupt maken, wat handig is bij het transformeren van Tofus in Slechte Tofus. Als ze gecombineerd worden met andere Corruptah Stenen, kan het de drager complete controle over de zielen geven.",ep:0,g:461,l:50,wd:false,fm:true,w:10,p:100};
I.u[9956] = {n:"Steen van Corrupte Zielen",t:24,d:"Deze steen komt uit de Bron van de Corrupte Zielen. Het kan gebruikt worden om de zielen van wezens die erin gevangen zijn te controleren.",ep:0,g:462,l:1,wd:false,fm:true,w:0,p:1};
I.u[9957] = {n:"",t:114,d:"",ep:0,g:6,l:40,wd:false,fm:false,w:15,an:14,tw:true,e:[3,5,1,1,45,90,false,true],p:1};
I.u[9958] = {n:"Kist met Bontariaanse Uitrusting",t:24,d:"Deze kist bevat de benodigdheden voor de perfect kleine militiaman. Als de kwaliteit van de kist in de buurt komt van wat er in zit, zal de militia tevreden moeten zijn met een heleboel nederlagen.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9959] = {n:"Expert verslag",t:24,d:"Zoals je verwachtte, bevestigd dit verslag de slechte kwaliteit van de Bontariaanse militia\'s uitrusting. Oto Mustam zal verheugd zijn met dit nieuws.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9960] = {n:"Sleutels van de Warenhuis",t:24,d:"Deze glazen bokaal bevat dat wat over is van wat in Sennuig\'s maag vast zat. Het goede nieuws is dat de sleutels van het warenhuis er ergens in zit. Enige wat je nog moet doen is je hand er in steken en de sleutels er uit halen. Vergeet niet je vingers daarna af te likken!",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9961] = {n:"Hurriaanse Hamer",t:7,d:"Deze stenen hamer was uitgevonden om smeden te verleiden te denken dat ze een hamer van hoge kwaliteit in hun handen hebben. Het is af te raden om het aan te raken, zelfs om er niets mee te doen.",ep:0,g:2,l:1,wd:true,fm:false,w:5,an:15,e:[5,4,1,1,60,20,false,false],p:10};
I.u[9962] = {n:"Krat met Mineralen",t:24,d:"Je hebt deze krat met mineralen gestolen, zodat Latem Sa nieuwe uitrusting kon maken voor de Bontariaanse militia.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9963] = {n:"Smid\'s Hamer",t:24,d:"Je hebt deze hamer gestolen van Latem Sa en vervangen met een Shammer. De smid is zo incompetent dat hij waarschijnlijk het verschil niet eens merkt.",ep:0,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9964] = {n:"Khamelerost Dragoturkey Gift",t:89,d:"Als je dit object hevig schud en je oor er bij houdt, hoor je een vreemd geluid... net alsof een klein beestje aan het huilen is... ja, misschien is het beter om het niet te schudden.. Ahh, open het ding gewoon.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9965] = {n:"Hondenfok Techniek",t:24,d:"Deze methode, ontworpen door de beroemde WafWaf trainer Roy Sigfred, legt uit hoe je een Wittige Slagtand kunt temmen en het de beste vriend van de man te maken. Het mag vrouwen alsnog niet.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9966] = {n:"Buit van de Convooi",t:24,d:"Je hebt deze buit gekregen in de aanval op de Bontariaanse Convooi. Stampitor de Barbaar, wie je in de Bramariaanse Militia kunt vinden, zal je bast goed betalen voor je moeite. Hij zal je misschien zelfs heelhuids laten gaan.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
