I.u[9594] = {n:"De Godfather\'s Gobtubby",t:18,d:"Deze Gobtubby lijkt normaal te zijn... Maar zijn wol lijkt zwart te worden op sommige plekken. Geef het wat tijd en je zult verbaasd staan!",ep:0,g:46,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9595] = {n:"De Godfather\'s Gobtubby Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:0,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[9596] = {n:"Kado: De Godfather\'s Gobtubby",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals een paar genezende Eniripsa poeders.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9597] = {n:"De Godfather\'s Gobtubby Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
