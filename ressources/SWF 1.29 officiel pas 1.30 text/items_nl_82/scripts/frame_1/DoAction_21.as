I.u[9582] = {n:"Gepantserde Dragokalkoen",t:97,d:"Dit certificaat geeft je de volmacht om jouw rijdier in een stal op te halen.                                                                      Waarschuwing! Dit certificaat is slechts 20 dagen geldig. Nadat deze tijd verstreken is, wordt je rijdier teruggestuurd naar de wildernis en is je certificaat niet langer geldig. Je zult niet in staat zijn om je rijdier op te eisen. Laat je rijdier altijd in een stal als je weg gaan voor langere tijd.",ep:0,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
