I.u[9603] = {n:"Bericht over de Vergadering",t:24,d:"Dit is een bericht over de discussie tussen Silvosse en Maimane. Het enige waar ze over praatten was over hoe ze Djaul konden benadelen.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:0};
I.u[9604] = {n:"Vals Document van Maimane",t:24,d:"Dit document is zo gekreukt als je zou denken – het heeft de laatste weken in de maag van een Trool rondgezwommen. Het goede is dat iedereen zal denken dat de Bontaren van het valse papier af wilden komen.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:0};
I.u[9605] = {n:"Getuigenis van een Amaknean",t:24,d:"Deze getuigenis was gegeven door een corrupte militair genaamd Retep Sellers en verklaart dat Maimane verscheidene keren gezien was in Amakna terwijl hij anto anti-demonische slogans verspreidde.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:0};
I.u[9606] = {n:"Bericht over Maimane",t:24,d:"Dit bericht over Maimane door Austinamou Flowa de beroemde spion verklaart hoe Maimane dolken verzamelde om zijn leger uit te rusten ter voorbereiding op een gevecht tegen Djaul en zijn bondgenoten.",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:0};
