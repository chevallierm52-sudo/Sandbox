I.u[9541] = {n:"De Godfather\'s Fedora",t:16,d:"Deze speciale hoed laat je lijken op de Godfather. Je zou trots moeten zijn!",ep:0,g:234,l:43,wd:true,fm:true,w:10,s:126,p:5100};
I.u[9542] = {n:"De Godfather\'s Gepolijste Oxfords",t:11,d:"Deze schoenen glimmen erg, zelfs als ze afgedragen zijn. Ze zijn perfect om je tegenstanders te imponeren als ze ze in hun gezicht krijgen.",ep:0,g:130,l:40,wd:true,fm:true,w:10,s:126,p:4450};
I.u[9543] = {n:"De Godfather\'s Ring",t:9,d:"Deze zware ring geeft meer kracht aan je slagen en meer passie aan je liefkozingen...",ep:0,g:166,l:40,wd:true,fm:true,w:10,s:126,p:0};
I.u[9544] = {n:"Duisternis Tormentator",t:114,d:"Dit angstaanjagende magische wapen was gemaakt door de beroemde klusjesman Hissering. Het leidt de magische energie van zijn gebruiker in goede banen alvorens hij het eruit schiet met geweldige kracht en geeft ze nieuwe spreuken om te gebruiken. Met dit wapen word je een ander persoon en je Tormentator wordt je enige vriend totdat jij besluit dat je er klaar mee bent.",ep:0,g:1,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
