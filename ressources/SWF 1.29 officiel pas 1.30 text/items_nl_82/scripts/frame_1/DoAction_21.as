I.u[9549] = {n:"De Godfather\'s Broek\'n Jarretels",t:10,d:"Het motto van de kleermaker die dit wonder maakte was “Zelfs in het hart van de actie moet je broek altijd om je kont blijven hangen, wat zo zal zijn dankzij de hoge kwaliteit vlas bretels”. Dit is echt geen goed motto...",ep:0,g:152,l:48,wd:true,fm:true,w:10,s:126,p:6175};
I.u[9550] = {n:"Locatie van velden",t:24,d:"Merlinmagus vertelde je waar de militie de Transgenesis spreuk gaat gebruiken. Je moet je haasten en daar komen voor je te laat bent.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9551] = {n:"Gewijzigd Scurvion Zaad",t:24,d:"Deze scurvion zaden waren gewijzigd, maar je kunt het verschil niet zien. Het probleem is dat je wel degelijk het verschil tussen deze zaden en Poppy zaden kunt zien. Alleen een idioot zou die vergissing maken.",ep:0,g:405,l:1,wd:false,fm:true,w:0,p:1};
