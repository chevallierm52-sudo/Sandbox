I.u[9576] = {n:"Zwarte Wab Laarzen",t:11,d:"Met deze laarzen, gemaakt van de huid van het achterwerk van de Zwarte Wabbit, kun je wraak nemen op deze gemene kleine diertjes, aangezien ze het gevoel hebben dat ze hun eigen achterwerken schoppen elke keer dat het ergens tegenaan schopt.",ep:0,g:131,l:47,wd:true,fm:true,w:10,s:127,p:5850};
