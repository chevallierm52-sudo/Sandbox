I.u[9718] = {n:"Gargantuan Perfecte Ziel Steen",t:83,d:"Deze unieke steen was gecreëerd met slechts één doel voor ogen – het vangen van de ziel van de Kralove. Je kunt het weten door er naar te kijken, of eraan te ruiken...",ep:0,g:24,l:1,wd:false,fm:true,w:1,tw:true,c:"Qa=439",p:0};
