I.u[9644] = {n:"Jong Wild Zwijn Kado",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals een paar genezende Eniripsa poeders.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
