I.u[9663] = {n:"Slait Noren",t:16,d:"Ze zijn wellicht bedekt met gevoerde roest, maar het zijn de meest aerodynamische oren die je ooit zult tegenkomen.",ep:0,g:238,l:49,wd:true,fm:true,w:10,s:128,p:6375};
