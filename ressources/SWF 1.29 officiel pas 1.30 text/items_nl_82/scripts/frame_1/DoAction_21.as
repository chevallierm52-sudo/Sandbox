I.u[9785] = {n:"Rushu\'s Shushu",t:18,d:"Deze demoon zal je gezelschap houden tijdens al je ronddolingen van de Asturb Zaap naar de begraafplaats en misschien zelfs naar de begraafplaats bij de Astrub Zaap. Hij zit vol met bittere haat jegens Ouassingues... het is een lang verhaal, maar het heeft te maken met een vieze vloer en een emmer met heet water. Als je een Ouassingue aanvalt, zal deze demoon blij zijn je te helpen!",ep:0,g:52,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9786] = {n:"Geest van Rushu\'s Shushu",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:0,g:49,l:1,wd:true,fm:true,w:1,p:1};
