I.u[9808] = {n:"Kado: Rushu\'s Shushu",t:89,d:"Als je dit voorwerp krachtig schudt en het bij je oor houdt, zul je een vreemd geluid horen... zoals een klein diertje dat huilt.. ja, misschien wil je het toch ook niet schudden.. Ahhh, kom op, open maken. Je zult een geweldig huisdier erin vinden, evenals een paar genezende Eniripsa poeders.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9809] = {n:"Rushu\'s Shushu Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9810] = {n:"Bow Kennel Certificaat voor: Rushu\'s Shushu",t:77,d:"Dit certificaat omschrijft de karaktereigenschappen van het huisdier die je in de Bow Kennel hebt gezet.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[9811] = {n:"Neutraliteiten Formulier",t:24,d:"Dit formulier is terug gebracht naar de militie van het Kasteel van Amakna door Morgan Faym\'n. Het zal neutraal moeten worden.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9812] = {n:"Desertie Formulier",t:24,d:"Dit formulier die je verlating bevestigt is terug gebracht naar jou door Morgan Faym\'n. Het zal neutraal moeten worden.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
