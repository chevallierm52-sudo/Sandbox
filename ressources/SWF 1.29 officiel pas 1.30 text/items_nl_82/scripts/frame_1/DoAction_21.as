I.u[9617] = {n:"Angora Bow Meow",t:18,d:"Deze kleine wolbaal heeft meer weerstand tegen de kou dan een ordinaire Bow Meow. Hij is zachter om te aaien, maar hij is irritanter dan zijn kortharige neef... ten eerste weigert hij iets anders dan vis en vlees te eten.",ep:0,g:50,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9618] = {n:"Kado: De Godfather\'s Ring",t:89,d:"Als je deze doos krachtig schudt, zul je zien dat hij leeg is. Voor deze ene keer hebben de goden geen grapje met je uitgehaald.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9619] = {n:"Tiwabbit Wosungree",t:18,d:"Dit beest is een beetje stom. De enige manier om hem vooruit te laten gaan is door een wowtel aan een stok te binden en aan zijn rug te plakken. Gelukkig is hij aardig goed getraind en krijg je geen nare verrassingen uit zijn achterkant, in tegenstelling tot sommige andere beesten die ik zou kunnen noemen. Deze zielenkauwer zal zich graag voeden met de overblijfselen van andere Wabbits.",ep:0,g:51,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9620] = {n:"Miniminotot",t:18,d:"Deze Minimino was meegebracht door Minitot zelf...dus nou is het een Miniminotot.. Helaas is het karakter van het beest  overgeslagen op het onschuldige diertje, samen met enige vieze lichaamsgeuren. Deze roofzuchtige zielenkauwer zal zich voeden met de overblijfselen van beesten van Minotorror Eiland.",ep:0,g:49,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9621] = {n:"Derde Kado van de Zon",t:89,d:"Deze tas was er nog niet een minuut geleden... wat zit er in?                                                                                  (DUBBELKLIKKEN OM TE OPENEN).",ep:0,g:32,l:1,wd:false,fm:false,w:1,u:true,p:0};
I.u[9622] = {n:"Tempus Bloomus",t:36,d:"Deze plant is net zo mysterieus en onverwachts als zijn naam. Een beetje hier, een beetje daar, en hopelijk nergens anders want dan zouden we niet alles krijgen. Je zou het naar de tempel van Xelor moeten brengen. Xelors zijn de enigen die de essentie van het bestaan van deze bloem uit kunnen zoeken.",ep:0,g:638,l:1,wd:false,fm:false,w:1,p:0};
I.u[9623] = {n:"Krokodyl",t:18,d:"Laat je niet voor de gek houden, de puntige tanden van dit beest zullen ooit in je achterkant eindigen, dat is zeker. Dit huisdier eet enkel vis en vlees.",ep:0,g:47,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9624] = {n:"Zwarte Dragoone",t:18,d:"Neem één Roze Dragoone, dompel hem onder in zwarte verf, gooi er wat goudstof naar, dip hem in olie, dan water en als hij dan nog niet dood is gegaan door verstikking heb je een Zwarte Dragoone. Deze zielenslikker leeft enkel op overblijfselen van Dreggons.",ep:0,g:48,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
