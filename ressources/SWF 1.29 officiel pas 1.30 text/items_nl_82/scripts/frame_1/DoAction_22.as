I.u[10043] = {n:"Wanna be Fair",t:30,d:"Een extreem krachtige schoonheidscreme heeft je veranderd in... wow! Onthoud wel dat zo knap zijn ook gevaarlijk kan zijn!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10044] = {n:"Mily\'s Schoonheidscreme",t:12,d:"Mily smeert diet elke ochtend op haar lichaam om er jong en knap uit te zien. Probeer het maar eens! Zorg wel dat je niet in een gevecht raakt echter, als je geraakt wordt zul je er uit komen te zien als een oude heks.",ep:0,g:40,l:1,wd:false,fm:true,w:1,u:true,p:1};
