I.u[10073] = {n:"Hispaniaans Schild",t:82,d:"De legendarische Dal-Uk-Wet, die het Hispaniaanse rijk heeft verenigd, had een magisch schild! Sir-Dal, zijn kleinkind, heeft kopieën laten maken om zijn beste krijgers te belonen. Dit schild is een van die kopieën.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[10074] = {n:"Brief van de Chef Dief",t:24,d:"Dit is gevonden bij een van de inbrekers die je versloeg bij Milone\'s huis:\nMilone de juwelier heeft net een erg waardevol juweel gemaakt. Wat je er ook voor moet doen, steel het. Gelukkig gaf Milone een kopie, maar dat is niet dankzij jou.\nAan de achterkant van het bericht, is een gids van hoe je in hun schuilplaats kunt komen. Je wraak zal zoet zijn, maar je kunt het niet alleen",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10075] = {n:"Verschrikkelijk Slijm",t:24,d:"Dit verschrikkelijke slijm verscheen in je zak alsof het vieze magie was die het deed.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[10076] = {n:"Uniek Hispaniaans Schild",t:82,d:"De legendarische Dal-Uk-Wet, die het Hispaniaanse rijk heeft verenigd, had een magisch schild! Jaren later heeft Sir-Dal, zijn kleinkind, kopieën laten maken om zijn beste krijgers te belonen... maar dit is de originele en meeste sterke van allen!",ep:0,g:40,l:1,wd:false,fm:true,w:30,c:"PP>9",p:63200};
I.u[10077] = {n:"Terra Cogita",t:32,d:"Begeleid Terra Cogita en neem hem mee naar Jerhyn Gholein.",ep:0,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10078] = {n:"Deni Hoobe",t:32,d:"Je moet Deni Hoobe escorteren en beschermen. Het is alsof de goden zich tegen je hebben gekeert sinds hij bij je is gekomen.",ep:0,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10079] = {n:"Intre Brood",t:33,d:"Dit brood is erg gewilt onder de Iops voor de eigenschap dat het krijgers met enorme moed vult. De vele doden na het eten van dit brood zijn bewijs dat het werkt. Xavier de Bakker is gestopt dit brood te maken toen een grote groep zwakke troubadours de regio een winter lang de regio onveilig maakte.",ep:0,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[10080] = {n:"Afvalligen Bericht",t:24,d:"Dit bericht roept de afvalligen op naar de Scarablad kerker te komen. Je zult zelf ook daarheen moeten om meer informatie te krijgen.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10081] = {n:"Bericht van de Chef van de Afvalligen",t:24,d:"In dit bericht, vraagt de chef van de afvalligen hem te spreken in het zuiden van de Bandieten Territorium. Dit is je kans om je te ontdoen van deze verrader.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10082] = {n:"Mojeetov Cocktail",t:24,d:"Wat krijg je als je een Mojeeto Blad perst? Alcoholische sap dat voor een heleboel cocktails gebruikt wordt. Otomai\'s discipelen houden erg veel van deze drankjes en drinken dan ook vele liters tijdens zomer festivallen.",ep:0,g:762,l:1,wd:false,fm:true,w:0,p:1};
I.u[10083] = {n:"",t:49,d:"",ep:0,g:80,l:1,wd:false,fm:true,w:3,u:true,ut:true,p:1};
I.u[10084] = {n:"Waarschuwingsfluitje",t:24,d:"Dit fluitje was bedacht voor Roy Sigfried\'s methode van honden fokken en kan gebruikt worden om tamme Wittige Slagtanden op te roepen. Je kunt alleen de meester van een Wittige Slagtand die niet van jou is, niet nadoen. Het werkt ook op wilde Wittige Slagtanden.",ep:0,g:755,l:1,wd:false,fm:true,w:0,p:1};
I.u[10085] = {n:"Bevel van executie",t:87,d:"Het beval kan niet verkeerd begrepen worden. Vind je doelwit.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:0};
I.u[10086] = {n:"Hoektand van een Veld Bandiet",t:24,d:"Het gevecht met de Veld Bandieten was zo gewelddadig dat een van hen een tand verloor.",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:1};
I.u[10087] = {n:"Xarthan\'s ontmoeting",t:24,d:"Dit bericht is geschreven door een Brakmariaan. Het zegt dat Xarthan naar de Toren van Bonta moet komen na zijn volgende bespreking. Dat betekent dat hij daar al kan zijn.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10088] = {n:"Gebruikte zakdoek",t:24,d:"Je hebt deze zakdoek gevonden tijdens je gevecht met Xephires. Het is een mooi souvenier en het zou van pas kunnen komen als je verkouden wordt. Je zou er ook een hoedje van kunnen maken, als je er een beetje gestoord uit wilt zien.",ep:0,g:756,l:1,wd:false,fm:true,w:0,p:1};
I.u[10089] = {n:"Doos met Goederen",t:24,d:"Xephires vroeg je om deze doos met goederen aan raadslid Boyowa, bij Grandapan\'s plaats, te geven om je \'goodwill\' te tonen. Je weet niet goed wat er in zit, maar je weet dat het wel erg waardevol is.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10090] = {n:"Nara\'s Lijst met Goederen",t:24,d:"Nara heeft een lijst gemaakt wat ze nodig heeft. 20 Eikenhout, 1 Zwafelzakje, 30 IJzer, 1 Kouartz, 5 Bakeleliet en 10 Eenvoudig Zwijn Leder.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10091] = {n:"Notities van Erazal\'s Verwensing",t:24,d:"Erazal\'s Verwensing laat zien hoe je een ziel terug tot leven kunt wekken tegen zijn wil in. Je hebt 1 eenheid Phoenix Bloed, 5 eenheden Magische Heling en 1 Lear Amulet, van een Treechnid en Duistere Treechnid lijken, nodig.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10092] = {n:"Bevel van Annulering",t:24,d:"Deze brief van een paar uur geleden, geeft aan dat de aanval op Bonta geannuleerd is, vanwege de verbeteringen in de uitrusting van de militiemannen en het vangen van de verrader Xephires.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
