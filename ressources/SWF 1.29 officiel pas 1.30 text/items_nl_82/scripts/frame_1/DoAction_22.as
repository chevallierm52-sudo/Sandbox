I.u[10184] = {n:"Noke\'s Masker",t:16,d:"Noke hield er van om dit masker op te zetten en zich in het bos te verstoppen om wandelaars te laten schrikken. Ze stierf een lange tijd geleden nadat ze haar weerspiegeling zag in een plas water.",ep:0,g:249,l:42,wd:true,fm:true,w:10,s:135,p:4700};
I.u[10185] = {n:"Noke\'s Mantel",t:17,d:"Noke droomde er van om een grote boze wolf te worden. Met deze mantel over haar schouders zag ze er echter meer uit als de drie kleine biggetjes.",ep:0,g:170,l:41,wd:true,fm:true,w:10,s:135,p:4600};
I.u[10186] = {n:"Noke\'s Ketting",t:1,d:"Deze ketting van zwijnentanden zal zwijnen afschrikken, en met geluk, ook je schoonmoeder.",ep:0,g:150,l:41,wd:true,fm:true,w:10,s:135,p:4525};
I.u[10187] = {n:"Noke\'s Dolken",t:5,d:"Lange tijd geleden, zijn deze dolken gebruikt om een wild zwijn van al zijn dromen te ontdoen.",ep:0,g:76,l:41,wd:true,fm:true,w:10,an:13,tw:true,e:[12,3,1,1,30,45,false,false],c:"CS>50&CW>50&CV>80",s:135,p:4000};
I.u[10188] = {n:"Oxo Helm",t:16,d:"Deze helm heeft een handige eigenschap welke je de Oxon taal laat vertalen. Het is ook geluidsdicht.",ep:0,g:250,l:43,wd:true,fm:true,w:10,s:133,p:5075};
I.u[10189] = {n:"Oxo Ring",t:9,d:"Deze ring was van de Oxon Koning. Hij hield er van om met de terugkaatsende zonnestralen van zijn ring te spelen en \"Pas op voor de Oxon Laser\" te zeggen.",ep:0,g:175,l:37,wd:true,fm:true,w:10,s:133,p:3875};
I.u[10190] = {n:"Oxo Schoenen",t:11,d:"Vergeet deze schoenen niet aan te doen als je met je hoofd in de wolken loopt. Ook al zien ze er leuk uit, draag ze niet als je gaat dansen, als je je voeten op de grond wilt houden.",ep:0,g:143,l:38,wd:true,fm:true,w:10,s:133,p:3925};
I.u[10191] = {n:"Oxo Riem",t:10,d:"Deze riem is perfect als je moet uitrusten en je oma\'s Oxo Bucco moet verwerken.",ep:0,g:158,l:37,wd:true,fm:true,w:10,s:133,p:373};
I.u[10192] = {n:"Gift: Siks Wonn Ein Cape",t:89,d:"Als je deze doos heen en weer schudt, kom je er achter dat deze niet leeg is. Misschien houden de goden je eens niet voor de gek.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
