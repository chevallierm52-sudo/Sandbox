I.u[10207] = {n:"Bos met sleutels",t:24,d:"De lange stukken op deze sleutels zijn erg flexibel, maar ze zullen snel hun beweeglijkheid verliezen en alleen hun magische kunsten terugkrijgen na een week. Met deze bos in je zak, kun je door elke kerkerdeur die je wilt.",ep:0,g:774,l:1,wd:false,fm:true,w:0,p:0};
