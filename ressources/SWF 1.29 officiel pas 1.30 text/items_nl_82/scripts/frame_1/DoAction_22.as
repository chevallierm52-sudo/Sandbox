I.u[10414] = {n:"Koninginnedag Kroon",t:16,d:"De kroon wordt normaal gedragen op het dag van het feest om de verjaardag van de illustere koninginnen te vieren. Zijn magische krachten zijn erg krachtig en het kan de kleur van de persoon die het draagt veranderen in oranje. Dit zal het makkelijker maken om je te verstoppen tussen mensen die deze kleur kleding dragen.",ep:0,g:251,l:1,wd:false,fm:true,w:10,p:1};
