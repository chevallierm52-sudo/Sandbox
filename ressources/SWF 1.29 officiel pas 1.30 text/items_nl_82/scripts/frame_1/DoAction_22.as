I.u[10125] = {n:"Boog van de Bandiet Boogschutter",t:2,d:"Deze boog was van een bandiet boogschutter die het gebruikte om zijn slachtoffers van veraf af te maken, om zijn kleren maar niet vies te maken. De magie die het bezit is van zo\'n kracht dat het het hart van een onschuldige in de meest moedige kan maken.",ep:0,g:67,l:30,wd:true,fm:false,w:10,an:10,tw:true,e:[2,6,3,5,40,40,false,true],p:3000};
I.u[10126] = {n:"Zwaard van de Swashbuckling Bandiet",t:6,d:"Dit zwaard behoorde tot een legendarische swashbuckler die er niet van hield achter zijn vijanden aan te lopen. Hij leerde hoe hij kon kruipen en sluipen en dan hun benen er af te hakken in de nacht. De magie die het bezit is van zo\'n kracht dat het een schuldig hart kan veranderen in de moed van een swashbuckler.",ep:0,g:92,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,40,40,false,false],p:3000};
I.u[10127] = {n:"Staf van de Dolende Bandiet",t:4,d:"De dolende bandiet die deze staf gebruikte dronk nogal vaak, en gebruikte deze staf om recht te blijven staan terwijl hij deed waar hij goed in was - zakkenrollen. De magie die het bezit verandert het meest onschuldige hart nog in een sluwe bandiet.",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:12,e:[5,6,1,1,40,40,false,false],p:3000};
