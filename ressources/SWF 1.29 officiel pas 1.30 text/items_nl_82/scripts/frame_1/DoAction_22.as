I.u[10103] = {n:"Brief voor Fidji Merline",t:24,d:"Ebru van El heeft je deze brief voor Fidji Merline toevertrouwd. Je moet de Brakmariaanse Klusjesvrouw haar instructies exact opvolgen.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[10104] = {n:"Aangepaste Voedingsbak",t:24,d:"Deze voedingsbak was aangepast om aubergines te verbergen. Je wilt echt niet vastzitten op een rijdier die net hiervan gegeten heeft. De gassen die vrijkomen na zoveel aubergines te eten hebben al vaker tot ongevallen geleid.",ep:0,g:759,l:1,wd:false,fm:true,w:0,p:1};
I.u[10105] = {n:"Harig Been",t:24,d:"Deze Arachnee poot is bedekt met Arachnee en MiauwMiauw haren en kan een gevreesde wapen zijn als Shush Tercesasti er mee geconforteerd wordt.",ep:0,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[10106] = {n:"Vampirina",t:18,d:"Dit beangstigende wezen geniet er van om vloed uit haar slachtoffers te zuigen en als je niet oplet ben jij de volgende. Wat ze het leukst vindt, echter, is haar tanden in een groot vies skelet te zetten en het af te sabbelen. We zeiden toch dat ze beangstigend was.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10107] = {n:"Borbat",t:18,d:"Dit huisdier had een lange, zware kindertijd, beginnend met zijn naam. Misschien verklaart dit waarom hij enkel geeft om Ouassingues vermoorden en ze te verslinden.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10108] = {n:"Vampirina Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Vind je een manier om het te laten herrijzen of laat je het voor eens en altijd in de steek?",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
