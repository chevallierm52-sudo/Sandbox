I.u[9990] = {n:"Cheeka\'s Broche",t:24,d:"Deze Broche is aan je gegeven door Cheeka voor je dappere acties tijdens de aanval op het konvooi. Het staat ook voor haar belofte om je persoonlijk te bedanken als ze terug komt in Bonta.",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9993] = {n:"Sabine",t:32,d:"Je moet Sabine naar de Militiegebouwen in Brakmar brengen.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9995] = {n:"Vastgebonden Huurling Perkament",t:87,d:"Dit perkament zal je de locatie van een doelwit vertellen, waardoor je ze sneller kunt vinden.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps=3",u:true,p:1};
I.u[9996] = {n:"",t:87,d:"",ep:0,g:3,l:10,wd:false,fm:true,w:100,ut:true,p:3500};
I.u[9997] = {n:"Sleutel van de Schuilplaats van de Bandieten",t:24,d:"Dit is de sleutel van de schuilplaats van de bandieten. Grimpil vertelde je over een mechanisme dat de deur automatisch sluit als iemand naar binnen gaat. Dat is waarom iedereen die bij de gang hoort een kopie van de sleutel heeft.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9999] = {n:"Kopie van de Sleutel van de Schuilplaats van Bandieten",t:84,d:"Deze kopie van de sleutel van de schuilplaats van de Ecaflip bandieten valt bijna uiteen. Als je het wilt gebruiken zoals het is, zal het waarschijnlijk breken. Dit allemaal, plus dat er geen veiligheidscertificaat is, laat je geloven dat de sleutel nep is. Je kunt best gelijk hebben!",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10000] = {n:"Pluk van Grimpil\'s Vacht",t:24,d:"Als je deze pluk vacht in je hand houdt voel je wat activiteit daarbinnen. Je kijkt beter en ja... nee.... Het is helemaal geen vacht, het is een pluk van enorme luizen en teken.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[10001] = {n:"",t:87,d:"",ep:0,g:3,l:10,wd:false,fm:true,w:10,ut:true,p:500};
I.u[10002] = {n:"",t:87,d:"",ep:0,g:1,l:10,wd:false,fm:false,w:1,ut:true,p:100};
I.u[10003] = {n:"Nowaine Jelly",t:110,d:"Alleen Liroye Merline kent het recept van deze kunstmatige jelly. Als het wordt vermengd met natte klei, wordt de jelly hard en neemt de vorm aan van alles wat er ingeschoven zit. Dit product is erg handig voor het maken van een mal.",ep:0,g:47,l:1,wd:false,fm:true,w:0,p:1};
I.u[10004] = {n:"Hoe Nowaine Jelly te gebruiken",t:24,d:"Dit document over 1,001 manieren om de Nowaine Jelly te gebruiken was geschreven door Liroye Merline. Hier is wat ze zegt over kopiëren van sleutels:\n- 1 Nowaine Jelly\n- 1 eenheid Wild Gras\n- 1 eenheid Bakelelite",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10005] = {n:"Vertrouwelijke Documenten",t:24,d:"Een lijst van vertrouwelijke Bontariaanse documenten. Je zou je kunnen afvragen wat deze geheime papieren in de schuilplaats van de bandieten doen.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10006] = {n:"Verdacht Verslag",t:24,d:"Dit verslag is erg slecht nieuws voor je. Het beschuldigt je niet loyaal aan Bonta te zijn en plaatst je in verband met meerdere twijfelachtige gebeurtenissen. Alleen een expert kan je vertellen of het document echt is of niet.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10007] = {n:"Fles met Brakmariaans Vergif",t:24,d:"Deze fles met Brakmariaans vergif is bereid zoals oma het altijd deed. Het etiket zegt je om \'het uit de buurt te houden van iedereen. Behalve als ze Bontariaans zijn.\'",ep:0,g:39,l:1,wd:false,fm:true,w:0,p:1};
I.u[10008] = {n:"Klantenbestand",t:24,d:"Het bestand toont alle klanten die de Alchemistenwerkplaats in Brakmar hebben bezocht de laatste paar weken. Het probleem is dat alles in Brakmariaans is geschreven - je snapt er geen snars van.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10009] = {n:"Xephires",t:32,d:"Breng Xephires de verrader naar Amayiro. Ze hebben een paar dingen te... bespreken.",ep:0,g:24,l:1,wd:false,fm:true,w:0,m:true,p:1};
