I.u[10133] = {n:"Bandiet Tovenaars Staf",t:3,d:"Lang, lang geleden behoorde deze toverstok aan een Bandiet Tovenaar die het gebruikte om zijn vijanden te vernietigen. De magie die het bezit heeft zoveel kracht dat het het meest onschuldige hart nog in iets slechts kan veranderen.",ep:0,g:72,l:30,wd:true,fm:false,w:10,an:11,tw:true,e:[2,5,2,4,40,40,false,true],p:3000};
