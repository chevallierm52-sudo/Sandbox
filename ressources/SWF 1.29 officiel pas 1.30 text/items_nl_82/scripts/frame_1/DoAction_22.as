I.u[10155] = {n:"Amlugo",t:1,d:"Dit amulet moet je beschermen tegen willekeurige onthoofdingen, maar het vergroot de kans om te sterven door verhanging.",ep:0,g:147,l:43,wd:true,fm:true,w:10,s:134,p:5030};
I.u[10156] = {n:"Slugo",t:11,d:"Deze slippers zijn comfortabeler dan je gemiddelde schoeisel, maar het is lastig te zeggen waarom... misschien masseren de parasieten er in wel je voeten.",ep:0,g:140,l:41,wd:true,fm:true,w:10,s:134,p:4575};
I.u[10157] = {n:"Belugo",t:10,d:"Deze riem is gemaakt van de resten van Flax draden. Het wordt ook gebruikt door vuilniszakken dicht te binden.",ep:0,g:157,l:43,wd:true,fm:true,w:10,s:134,p:5025};
