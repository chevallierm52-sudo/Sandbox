I.u[10061] = {n:"Vampier Laarzen",t:11,d:"Ze zeggen dat Hertogin Bathory deze laarzen nog heeft gedragen. Haar kennende, zouden ze mooi zacht moeten zijn... hoop alleen dat er niet te veel puisten op zitten.",ep:0,g:139,l:41,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4550};
