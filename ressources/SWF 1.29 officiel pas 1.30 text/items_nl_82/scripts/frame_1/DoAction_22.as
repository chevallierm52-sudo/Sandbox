I.u[10417] = {n:"Kerker Wachter Ziel Steen",t:85,d:"Deze steen bevat zielen van een groep wezens die allemaal maar een ding willen: terug tot leven worden gewekt om wraak te nemen. Je kunt het echter alleen in geschikte arena\'s gebruiken, vlakbij elke grote stad.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10418] = {n:"Aardsmonster Ziel Steen",t:85,d:"Deze steen bevat zielen van een groep wezens - inclusief ten minste een aardsmonster - die allemaal maar een ding willen: terug tot leven worden gewekt om wraak te nemen. Je kunt het echter alleen in geschikte arena\'s gebruiken, vlakbij elke grote stad.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
