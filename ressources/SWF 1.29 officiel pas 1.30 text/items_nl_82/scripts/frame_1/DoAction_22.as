I.u[10054] = {n:"Vampier Ring",t:9,d:"Deze ring heeft drie jaar doorgebracht in een plas met Borbat poep. Het is wel nog steeds magisch.",ep:0,g:171,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4703};
I.u[10055] = {n:"Vampier Amulet",t:1,d:"Dit amulet zou Vampieren moeten weerhouden je bloed te drinken. Het idee is dat ze moeten denken dat jij ook een Vampier bent.",ep:0,g:146,l:45,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:5500};
I.u[10056] = {n:"Vampier Riem",t:10,d:"Deze riem geeft niet alleen licht in het donker, maar het geeft ook licht in het licht, alhoewel dat lastig te bevestigen is.",ep:0,g:156,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4805};
I.u[10057] = {n:"Jagers Steen",t:78,d:"Zoals Lezan de Wijze zou zeggen - \"Nou, slechte jagers zien gewoon iets, ja, en dan schieten ze het. En dan toch, goede jagers, ja, zien iets en schieten het. Als goede jagers.\"\nJe kunt met deze steen kijken of dat klopt.",ep:0,g:60,l:10,wd:false,fm:true,w:1,p:10};
I.u[10058] = {n:"Vampier Cape",t:17,d:"Bram had toch gelijk, je moet wel oppassen voor volwassen mannen die rondlopen met makeup en lange wapperende mantels.",ep:0,g:168,l:41,wd:true,fm:true,w:5,c:"PO!10119",s:130,p:4550};
