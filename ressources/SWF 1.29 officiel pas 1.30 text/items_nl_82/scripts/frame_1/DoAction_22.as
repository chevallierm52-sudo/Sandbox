I.u[10016] = {n:"Kelt\'bijl",t:24,d:"Deze bijl ziet er erg standaard uit. Het lijkt alsof het uit een ander tijdperk komt. Het is van zo\'n lage kwaliteit dat het lijkt of je er nog geen Trunknid mee zou kunnen omhakken.",ep:0,g:746,l:1,wd:false,fm:true,w:0,p:1};
I.u[10017] = {n:"Nara\'s Katana",t:24,d:"Deze katana is gemaakt door Nara toen hij zijn ultieme tests had doorstaan. Er is er niets zoals dit...het komt in de buurt bij de Kelt\'bijl wat betreft kwaliteit.",ep:0,g:53,l:1,wd:false,fm:true,w:0,p:1};
I.u[10018] = {n:"Plan voor de Wasknijper",t:15,d:"Dit plan is zo simpel dat zelfs een jonge Iop het kan begrijpen. Laten we het niet overdrijven. In de handen van een klusjesman, kan het zelfs gebruikt worden om dingen te maken. Als de klusjesman een Iop is, berg je dan maar. Voor dit plan heb je het plan, 10 Kalyptushouten Planken en 10 Aluminites nodig.",ep:0,g:767,l:1,wd:false,fm:true,w:1,p:1};
I.u[10019] = {n:"Emmer met Wasknijpers",t:15,d:"In deze emmer zitten voldoende wasknijpers om het ondergoed van de volledige Amakna garnisoen op te hangen. Je kunt ze ook gebruiken om dierenhuiden te drogen.",ep:0,g:768,l:1,wd:false,fm:true,w:10,p:1};
I.u[10020] = {n:"Mishandelde Pop",t:24,d:"Het is moeilijk te geloven dat deze lelijke, stinkende pop ooit een Bwork Magus was. Dan denk je \'Zijn Bworks niet lelijker en stinkender dan dit popje?\'",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10021] = {n:"Gerepareerde Pop",t:24,d:"Je vraagt je af of het popje voor of na de reparatie van Maskara beter af was. Een ding is wel zeker...alleen een god zou een popje mooier kunnen maken dan het eerst was. Nu weet je waarom de Bwork Magus zichzelf jaren opgesloten heeft in een grot.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10022] = {n:"Betoverde Pop",t:24,d:"Het is betoverend om deze betoverde pop terug te zien in de armen van de betoveraar die het betoverd heeft bij het betoverde meer. Als hij nog zou leven, zou Jon Lemon vast een onpopulair liedje erover geschreven hebben.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10023] = {n:"Lijst van Rondes",t:24,d:"In tegenstelling tot wat de naam doet vermoeden, gaat deze lijst niet over de rondingen van Bwork Mama\'s, maar over de routes van de Brakmariaanse patrouilles. Er zijn zo veel mogelijkheden voor een hinderlaag.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10024] = {n:"Oude Bwork Spreukboek",t:24,d:"Dit oude spreukboek heeft toebehoord aan een Bwork Magus van de grotten, dus de illustraties zijn moeilijk te begrijpen  voor moderne Bwork Magussen van de grotten en nog lastiger voor gewone Bwork Magussen. Laten we hopen dat Danathor er wat nuttigs in vind. Het zou jammer zijn als zoveel moeite voor niets zou zijn.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
