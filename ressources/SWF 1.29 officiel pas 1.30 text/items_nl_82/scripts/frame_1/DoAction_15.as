I.u[7097] = {n:"Training Schild",t:82,d:"Dit Schild wordt aan volgelingen gegeven die nog niet weten hoe ze een schild correct moeten gebruiken.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[7098] = {n:"Schildsmid Hamer",t:7,d:"Deze hamer is onmisbaar bij het maken van schilden.",ep:18,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:500};
I.u[7101] = {n:"Handboek van de Schildsmid",t:25,d:"Test om het beroep van Schildsmid te leren",ep:0,g:8,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7102] = {n:"IJs Ridder Zwaard",t:6,d:"De IJs Ridder stond bekend als de belangrijkste zwaardsmid van heel Amakna. Alleen de verschrikkelijke en onverbiddelijke Liche weigerde zijn onmetelijke talent te erkennen. Gegriefd dat een dergelijk wezen niet verrukt was van zijn creaties, stelde hij hem een ultimatum : hij weigerde nog langer zijn beroep uit te oefenen zolang de Liche niet publiekelijk zijn talent als zwaardsmid wilde erkennen. Maar dan ken je de verschikkelijk Liche niet, die geen duimbreed toegaf. De smid moest pas vele honderden jaren later besluiten zijn beroep weer op te pakken. Intussen was hij de kneepjes van zijn vak vergeten en dit belachelijke zwaard was zijn laatst bruikbare creatie.",ep:1,g:51,l:12,wd:true,fm:true,w:10,an:14,e:[5,6,1,1,40,60,false,false],p:575};
I.u[7103] = {n:"De Xyothine",t:3,d:"Deze Wand werd gebruikt om alle sukkels van Amakna te onthoofden. Het is voldoende om te zeggen dat het een boel actie heeft gezien. Het is interessant om te zien hoeveel gelijkenis hij vertoont met een staf of zelfs een wandelstok... Hij is mogelijk gebruikt om de kwaadaardige fantasieën van de eigenaar die hem vernoemd heeft te bevredigen. Niemand zal ooit het laatste woord over dit laaghartige verhaal hebben.",ep:19,g:53,l:145,wd:true,fm:true,w:15,an:11,tw:true,e:[7,4,3,5,30,50,false,true],c:"CI>450&CV>200",p:10000};
I.u[7104] = {n:"Ring Slippers",t:11,d:"Deze slippers dienden om verschillende oosterse vechtsporten mee te bedrijven. Ze zien er weinig vernieuwend en artistiek gezien totaal mislukt uit, en zijn daarom snel in het vergeetboek geraakt, net als jij, maar dan toch een beetje minder snel.",ep:18,g:58,l:67,wd:true,fm:true,w:5,p:11700};
I.u[7105] = {n:"Amulet van Pandala",t:24,d:"Dit amulet dat er erg eenvoudig uitziet bevat een geheim dat alleen een Pandawa die op het punt staat te sterven kan begrijpen...",ep:18,g:48,l:0,wd:true,fm:true,w:0,p:1};
I.u[7106] = {n:"Larvamulet",t:1,d:"Met deze larvekop om je nek lijk je op Ulrik Holgan, beroemde larventemmer uit de moderne tijd.",ep:5,g:88,l:26,wd:true,fm:true,w:5,s:33,p:1950};
I.u[7107] = {n:"Larvelaarzen",t:11,d:"Wie heeft er nou nooit van gedroomd zijn voet rechtstreeks in de ingewanden van een larve te laten wegzinken? In ieder geval jij niet, dus profiteer ervan en laat je gaan.",ep:1,g:53,l:33,wd:true,fm:true,w:10,s:33,p:3150};
I.u[7108] = {n:"Larvazak",t:81,d:"Deze originele maar oersaaie zak was lang geleden erg in de mode. Een typisch voorbeeld van de slechte smaak van je voorouders.",ep:5,g:60,l:27,wd:true,fm:true,w:10,s:33,p:2150};
I.u[7109] = {n:"Larvemuts",t:16,d:"Eindelijk wordt je de mogelijkheid geboden op een echte larve te lijken. Je kan eindelijk je larve-achtige levensstijl openlijk tonen.",ep:5,g:103,l:34,wd:true,fm:true,w:10,s:33,p:3225};
I.u[7110] = {n:"LarveStok",t:3,d:"Dit angsaanjagende stokje is in feite een gedroogde, daarna betoverde en uiteindelijk gerehydrateerde larvendarm. Het lijkt voortaan nergens meer op, een beetje zoals jij in feite, behalve dat jij niet eens betoverd bent.",ep:5,g:19,l:40,wd:true,fm:true,w:5,an:11,e:[5,3,2,4,40,50,false,true],s:33,p:4000};
I.u[7112] = {n:"Gevlekte Dofus",t:23,d:"Alleen het paren van een zwarte draak met een witte draak kan het maken van zo´n ei mogelijk hebben gemaakt. Of anders gaat het om bedrog.",ep:1,g:8,l:6,wd:true,fm:true,w:1,p:50000};
I.u[7113] = {n:"Dofawa",t:23,d:"Deze Dofus lijkt vreemd genoeg op een ei van een wilde Drakokalkoen... Schijn bedriegt nu misschien eens niet.",ep:1,g:9,l:6,wd:false,fm:true,w:1,p:10};
I.u[7114] = {n:"Ebben-Dofus",t:23,d:"Duister als de duisternis, hard als steen. Grougalorasalar de Zwarte Draak heeft de Ebben Dofus gelegd om hem gezelschap te houden. Hij was simpelweg vergeten dat een ei, hoe magisch ook, niet praat.",ep:1,g:7,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7115] = {n:"Ivoren Dofus",t:23,d:"Er wordt gezegd dat de paarlen witheid hiervan niet geëvenaard kan worden. Hetzelfde kan over de Draakvarken tand gezegd worden.",ep:1,g:11,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7116] = {n:"Merta Ring",t:9,d:"De betovering van deze ring is heel vreemd. Als hij eenmaal om je vinger zit, kun je alleen nog maar tegen de juwelier praten die hem gemaakt heeft.",ep:18,g:91,l:59,wd:true,fm:true,w:5,p:9155};
I.u[7117] = {n:"Ethnische  Trouwring",t:9,d:"Een groep kosmospolitische, maar bijzonder slechte minstrelen, had besloten deze trouwring te gebruiken om elkaar te herkennen in de menigte die naar hun voorstelling zou komen kijken. Uiteindelijk had deze trouwring totaal geen nut, want ze hadden geen succes. Volgens sommige kwaadsprekers met goed gehoor, was dat geheel terecht.",ep:18,g:92,l:53,wd:true,fm:true,w:5,p:7150};
I.u[7118] = {n:"Nacht Fladdering",t:9,d:"Deze ring in de vorm van een grote nachtvlinder zal je handen niet goed doen uitkomen, maar dat is misschien ook maar beter zo...",ep:18,g:94,l:90,wd:true,fm:true,w:5,p:20775};
I.u[7119] = {n:"Ring Ha",t:9,d:"De juwelier die deze ring heeft gemaakt, is, in tegenstelling tot de schijn, geen familie van de beroemde zwaardsmid. Volgens zijn maker, doet deze ring je denken aan de wildernis zonder daar lichamelijk de effecten van te ondervinden. Niemand heeft tot nu toe begrepen wat hij bedoelt.",ep:18,g:85,l:58,wd:true,fm:true,w:5,p:8750};
I.u[7120] = {n:"Noha Ring",t:9,d:"Deze ring was ooit van een oude man, die volgens sommige geruchten alle wezens van het eiland Moon heeft gered van een verschrikkelijke zondvloed. Een andere versie van de feiten is dat hij zijn vlot had ingeruild voor een aapje, in plaats van de wezens te redden.",ep:18,g:86,l:44,wd:true,fm:true,w:2,p:5350};
I.u[7121] = {n:"Nozocomiaal Ring",t:9,d:"Deze levende ring bevat een verschrikkelijke betovering, die de meest sterke avonturiers ziek kan maken. Men zegt dat hij oorspronkelijk bedoeld was om de drager ervan te verzorgen en dat hij gevaarlijk en agressief is geworden doordat hij gedwongen op gevaarlijke en agressieve plekken moest vertoeven.",ep:18,g:87,l:50,wd:true,fm:true,w:5,p:6655};
I.u[7122] = {n:"Beginne Ring",t:9,d:"Deze ring bij uitstek geschikt voor beginnelingen. Hij staat ook symbool voor een aantal schandelijke zeden. Hij lijkt precies voor je gemaakt te zijn. Perfect.",ep:16,g:88,l:18,wd:true,fm:true,w:2,p:1100};
I.u[7123] = {n:"Sjokhe Ring",t:9,d:"Alleen gereserveerd voor ervaren avonturiers want met deze ring loop je het risico je omgeving te choqueren als hij is gemaakt van jonge onschuldige wezens.",ep:18,g:95,l:70,wd:true,fm:true,w:2,p:12900};
