I.u[6904] = {n:"Versleten Bescherming van de Bworker",t:15,d:"Liefde brengt soms meer ravage en schade dan een oorlog. Dat zul je een Bworker niet duidelijk kunnen maken.",ep:1,g:714,l:200,wd:true,fm:true,w:1,p:1000};
I.u[6905] = {n:"Bwork Verrassingspakket",t:89,d:"Het openen van dit pak vereist van de kant van zijn bezitter een grote kalmte, wat direct invloed zal hebben op de kwaliteit van de inhoud.",ep:1,g:42,l:1,wd:true,fm:true,w:4,u:true,p:100};
I.u[6906] = {n:"`SRVT:MERCENARY_INTRONIZER` Nieuweling",t:14,d:"Deze schriftrol is het toegangsformulier naar de `SRVT:MERCENARY_SHORT_NAME`. Degene aan wie het wordt voorgesteld zal ingeschreven worden in de registers van de clan, als nieuweling.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6907] = {n:"Neutralisator",t:14,d:"Dit kan alle registers betreffende de persoon vernietigen, of het nou is in de wacht van Bonta, Brakmar, of in de Seriane clan.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6908] = {n:"Bandriem",t:10,d:"Harig maar elegant, doet deze riem je soms aan je geliefde denken.",ep:1,g:75,l:18,wd:true,fm:true,w:2,s:21,p:1050};
I.u[6909] = {n:"Everzwijn Poten",t:11,d:"Deze laarzen zijn perfect om in de modder te lopen en om het parket te beschadigen. Over het algemeen zijn ze verboden op elke dansvloer.",ep:1,g:51,l:22,wd:true,fm:true,w:2,s:21,p:1525};
I.u[6910] = {n:"Everzwijn Ring",t:9,d:"Deze ring werd door de everzwijnfokkers om de poten van hun bronstige everzwijnen gebonden om ze makkelijker te herkennen. Nu draag jij deze ring. Iedereen mag er van denken wat hij wil.",ep:1,g:73,l:19,wd:true,fm:true,w:2,s:21,p:1200};
I.u[6911] = {n:"Arachnoton",t:9,d:"Met deze belachelijk kleine ring kun je makkelijker van je Arachneefobie af komen.",ep:1,g:76,l:5,wd:true,fm:true,w:1,s:22,p:275};
I.u[6912] = {n:"Arachnotuur",t:10,d:"Deze riem, gemaakt van oude bedorven overblijfselen van Arachnees, valt zeker in de smaak. Somt komt hij tot leven en bijt dan graag in je heupen. Rotbeesten !",ep:1,g:73,l:6,wd:true,fm:true,w:1,s:22,p:305};
I.u[6913] = {n:"Arachna Hoofddeksel",t:16,d:"Uitgemonsterd met dit hoofddeksel, lijkt je op een wilde Arachnee. In het beste geval schrik je er ietwat naïeve Moskitos mee af.",ep:1,g:83,l:6,wd:true,fm:true,w:2,s:22,p:305};
I.u[6914] = {n:"Boomchnid Kliever",t:19,d:"Vreemd feit, de Arachnee heeft slechts vier behaarde poten, wat betekent dat je met slechts vier slagen met je bijl hem kan veranderen in een Arachnee-romp.",ep:1,g:31,l:8,wd:true,fm:true,w:5,an:17,e:[5,4,1,1,50,50,false,false],s:22,p:600};
I.u[6915] = {n:"Mos Kitano",t:9,d:"Met deze erg lichte ring krijg je zeer beweeglijke en behendige vingers. Erg handig om een tien keer kleinere tegenstander dan jezelf te vernederen door zijn hoofd met je duim te verbrijzelen.",ep:1,g:71,l:21,wd:true,fm:true,w:2,s:23,p:1400};
I.u[6916] = {n:"Kleine Moskito Tas",t:81,d:"Deze tas, gemaakt van de huid en de vleugels van Moskitos had vroeger veel succes bij schoolgaande kinderen. Vandaag de dag is hij totaal  verouderd en in de kinderharten vervangen door de Kleine schooltas van de Chef Crocodyl. Of de Grote schooltas. Hoe dan ook, deze zijn veel duurder maar vooral minder mooi. Helaas, zo gaat het met de mode.",ep:1,g:59,l:16,wd:true,fm:true,w:2,s:23,p:900};
I.u[6917] = {n:"Moskitohoed",t:16,d:"Deze hoed met verrassende naam dankt zijn naam aan de buitennissigheid van de eerste Enutrof die hem heeft ontdekt toen hij een oude zieke Moskito vilde. Deze erg nuttige hoed voor beginnende avonturiers, stelt je in staat om hongerige Arachnees helemaal verzot op je te laten worden.",ep:1,g:80,l:15,wd:true,fm:true,w:2,s:23,p:900};
I.u[6918] = {n:"Moskito Amulet",t:1,d:"Minder doeltreffend en minder gewild dan de beroemde Arachnamu. Toch heeft dit amulet heel veel charme, zeker als hij alleen wordt gedragen op een zeer behaard lichaam.",ep:1,g:75,l:15,wd:true,fm:true,w:2,s:23,p:800};
I.u[6919] = {n:"Champ Champ Ring",t:9,d:"De Champ Champ heeft nooit bekend gestaan als een erg sympathiek wezen. Hij verziekt je leven zodra hij maar kan, hij bijt hard en heeft een ongenaam karakter. Verbazingwekkend hoe zo\'n lelijk klein wezen je soms doet denken aan je partner.",ep:1,g:74,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6920] = {n:"Champ Champ Trouwring",t:9,d:"Als de Champ Champ trouwt, geeft hij deze trouwring aan zijn geliefde. Aangezien deze laatste geen armen heeft, wordt de trouwring zorgvuldig op een van haar doornen geplaatst. Als je deze ring in je bezit krijgt, verbreek je het huwelijk tussen de twee wezen en in het beste geval zal de Champ Champ jou uitkiezen als zijn bruid.",ep:1,g:75,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6921] = {n:"Champmuts",t:16,d:"Deze zeer in de smaak vallende muts van de Champ Champ werd vroeger gebruikt als kruidenthee en soms zelfs gerookt.",ep:1,g:84,l:9,wd:true,fm:true,w:3,s:24,p:425};
I.u[6922] = {n:"Champ Champ Cape",t:17,d:"Het enige dat indrukwekkender is dan een woeste Champ Champ, is een woeste Champ Champ met een cape. Deze cape bevat een bepaalde vorm van superkracht, hoewel hij niet echt mooi is.",ep:1,g:76,l:9,wd:true,fm:true,w:2,s:24,p:450};
I.u[6923] = {n:"Bandiet Amulet",t:1,d:"Dit amulet behoorde ooit toe aan de grote bandiet \"Thisme\", bekend om zijn onbeperkte wreedheid en zijn idiote dood. Zijn leven was een Eniripsa sprookje waardig, hij verdronk en werd fijngemalen in een oliepers toen hij net een gevangenisstraf van meer dan honderden jaren had uitgezeten vanwege het stelen van een cashewnoot.",ep:1,g:76,l:16,wd:true,fm:true,w:2,s:25,p:900};
I.u[6924] = {n:"Bandietendolken",t:5,d:"Deze geslepen dolken zijn geliefd onder bandieten en niet geliefd onder jonge avonturiers om dezelfde reden, zij beschikken namelijk over een betovering waardoor ze kamas van hun tegenstanders kunnen stelen. Een wel zeer bijzondere vorm van belasting.",ep:1,g:9,l:12,wd:true,fm:true,w:1,an:13,e:[5,3,1,1,30,50,false,false],s:25,p:600};
I.u[6925] = {n:"Bandiet Riem",t:10,d:"Deze opvallende riem zal je uitstekend staan als je op een dag bij de zaak van de bandieten van de grote weg gaat dienen. In de tussentijd zal hij je er alleen maar belachelijker doen uitzien.",ep:1,g:72,l:15,wd:true,fm:true,w:2,s:25,p:850};
I.u[6926] = {n:"Prespicmuts",t:16,d:"Met dit hoofddeksel van een Prespic op je hoofd lijkt je bijna op Dévie Cloquette, beroemde jaagster uit de moderne tijd, tot alles bereid om haar beginnende kaalheid te verbergen. Geen geluk voor jou als je hetzelfde wilde doen, je zal het moeten doen met een rossige pruik, die duidelijk een vreselijke geur zal verspreiden zodra het begint te regenen.",ep:1,g:81,l:36,wd:true,fm:true,w:2,s:31,p:3600};
I.u[6927] = {n:"Prespic Cape",t:17,d:"Deze roodachtige kleine cape kan eveneens dienst doen als bedkleedje, of als deurmat, iets om op goedkope wijze het interieur van je woning wat op te knappen.",ep:1,g:75,l:37,wd:true,fm:true,w:3,s:31,p:3800};
I.u[6928] = {n:"Prespic Ring",t:9,d:"Tegelijkertijd sober en toch origineel, zal deze ring avonturiers die luxe pracht begeren maar totaal verknipt zijn, kunnen verleiden, zozeer zelfs dat zij belachelijke kleine wezentjes stropen om zich met sieraden te behangen. Bekrompenheid ken geen grens.",ep:1,g:72,l:38,wd:true,fm:true,w:1,s:31,p:4000};
I.u[6929] = {n:"Prespic Riem",t:10,d:"Ideaal om de heupen warm te houden, heeft deze riem echter het nadeel te irriteren en de zachte huid aan te tasten. Te reserveren voor harde bikkels.",ep:1,g:71,l:33,wd:true,fm:true,w:2,s:31,p:3000};
I.u[6930] = {n:"Krakler Helm",t:16,d:"Deze uit steen gehakte helm is zijn gewicht in goud waard. Hij zal je beschermen tegen de aanvallen van een Krakkop omdat je hem kopstoten kan geven zoals die van een Desirokop. Genoeg om je tegenstanders hun hoofd te laten verliezen.",ep:5,g:85,l:44,wd:true,fm:true,w:200,s:26,p:5300};
I.u[6931] = {n:"Kraklocape",t:17,d:"Deze stenen cape is een beetje te onbuigzaam, maar hij blijft toch een prima bescherming tegen stenen, of, nog gevaarlijker, tegen het spugen van Kraklers.",ep:5,g:77,l:46,wd:true,fm:true,w:1,s:26,p:5800};
I.u[6933] = {n:"Krakler Laarzen",t:11,d:"Met deze ongelofelijk zware, maar toch redelijk effectieve, stenen laarzen heb je eindelijk een excuus als je treuzelt bij het verdedigen van je belastingontvanger in een bij voorbaat verloren strijd.",ep:5,g:52,l:47,wd:true,fm:true,w:10,s:26,p:4700};
I.u[6934] = {n:"Krakamulet",t:1,d:"Dit amulet is even zwaar als een Blop die boulimia heeft, dat zou de avonturiers die een beetje te fragiel zijn om ze te dragen moeten ontmoedigen. Daarentegen moet erkend worden dat, als je zijn gewicht eenmaal kan dragen, dit je wel een trotse uitstraling geeft.",ep:5,g:77,l:46,wd:true,fm:true,w:10,s:26,p:4600};
I.u[6935] = {n:"Krakler Riem",t:10,d:"Draag je deze riem om je middels dan dwing je het respect af van je avontuurlijke collega\'s. Draag je hem om je hoofd, dan mikpunt van spot in Astrub.",ep:5,g:74,l:45,wd:true,fm:true,w:10,s:26,p:5400};
I.u[6936] = {n:"Groene Scaramuts",t:16,d:"Uitgedost met dit originele hoofddeksel, kan je eindelijk je vrienden doen geloven dat je een Scarablad-jager bent.",ep:3,g:78,l:44,wd:true,fm:true,w:2,s:27,p:5200};
I.u[6937] = {n:"Rode Scaramuts",t:16,d:"Uitgedost met dit originele hoofddeksel, kan je eindelijk je vrienden doen geloven dat je een Scarablad-jager bent.",ep:3,g:77,l:44,wd:true,fm:true,w:2,s:28,p:5200};
I.u[6938] = {n:"Witte Scaramuts",t:16,d:"Uitgedost met dit originele hoofddeksel kan je eindelijk je vrienden doen geloven dat je een Scrarablad-jager bent.",ep:3,g:79,l:44,wd:true,fm:true,w:2,s:29,p:5200};
I.u[6939] = {n:"Blauwe Scaramuts",t:16,d:"Uitgedost met dit originele hoofddeksel, kan je eindelijk je vrienden doen geloven dat je een Scarablad-jager bent.",ep:3,g:76,l:44,wd:true,fm:true,w:2,s:30,p:5200};
I.u[6940] = {n:"Groene Scaracape",t:17,d:"Wie heeft er nou nooit van gedroomd een cape in de vorm van een Scarablad-schelp te dragen? Als je hem eenmaal om hebt, zou je erin moeten slagen voor een echte Scarafeuile door te gaan, en misschien lukt het je je glijdend en slippend te verplaatsen. Zo kan je een horde Trools van hun stuk brengen.",ep:3,g:74,l:45,wd:true,fm:true,w:2,s:27,p:5500};
I.u[6941] = {n:"Blauwe Scaracape",t:17,d:"Wie heeft er nou nooit van gedroomd om een cape in de vorm van een Scarablad-schelp te dragen? Als je hem eenmaal om hebt, zou je erin moeten slagen voor een echte Scarablad door te gaan, en misschien lukt het je je glijdend en slippend te verplaatsen. Zo kan je een horde Trools van hun stuk brengen.",ep:3,g:73,l:45,wd:true,fm:true,w:2,s:30,p:5500};
I.u[6942] = {n:"Rode Scaracape",t:17,d:"Wie heeft er nou nooit van gedroomd om een cape in de vorm van een Scarablad-schelp te dragen? Als je hem eenmaal om hebt, zou je erin moeten slagen voor een echte Scarablad door te gaan, en misschien lukt het je je glijdend en slippend te verplaatsen. Zo kan je een horde Trools van hun stuk brengen.",ep:3,g:72,l:45,wd:true,fm:true,w:2,s:28,p:5500};
I.u[6943] = {n:"Witte Scaracape",t:17,d:"Wie heeft er nou nooit van gedroomd een cape in de vorm van een Scarablad-schelp te dragen? Als je hem eenmaal om hebt, zou je erin moeten slagen voor een echte Scarafeuile door te gaan, en misschien lukt het je je glijdend en slippend te verplaatsen. Zo kan je een horde Trools van hun stuk brengen.",ep:3,g:71,l:45,wd:true,fm:true,w:2,s:29,p:5500};
I.u[6944] = {n:"Groene Scararing",t:9,d:"Door deze ring om je vinger te dragen, kan je ontroerd raken als je denkt aan alle Scarabladeren die je hebt uitgeroeid. Dan vraag je je misschien af of dat alles nou werkelijk de moeite waard was.",ep:3,g:69,l:43,wd:true,fm:true,w:2,s:27,p:5000};
I.u[6945] = {n:"Rode Scararing",t:9,d:"Door deze ring om je vinger te dragen, kan je ontroerd raken als je denkt aan alle Scarabladeren die je hebt uitgeroeid. Dan vraag je je misschien af of dat alles nou werkelijk de moeite waard was.",ep:3,g:68,l:43,wd:true,fm:true,w:2,s:28,p:5000};
I.u[6946] = {n:"Witte Scararing",t:9,d:"Door deze ring om je vinger te dragen kan je met weemoed denken aan alle Scarabladeren die je uitgeroeid hebt. Misschien vraag je je dan af of dat nou werkelijk al die moeite waard was.",ep:3,g:67,l:43,wd:true,fm:true,w:2,s:29,p:5000};
I.u[6947] = {n:"Blauwe Scararing",t:9,d:"Door deze ring om je vinger te dragen, kan je ontroerd raken als je denkt aan alle Scarabladeren die je hebt uitgeroeid. Dan vraag je je misschien af of dat alles nou werkelijk de moeite waard was.",ep:3,g:70,l:43,wd:true,fm:true,w:2,s:30,p:5000};
I.u[6948] = {n:"Groene Scarature",t:10,d:"De Scarature diende vroeger voor het geven van een indicatie van je niveau van vechten met de blote hand. Een groene Scarature bezitten betekende dat je een beginneling was, een rode betekende dat je het bloed van je vijanden oplikte als je ze afgemaakt had, een witte betekende dat je een echte vechtmachine was die vijanden uitroeide, en een blauwe betekende dat je niet genoeg kamas had om één van de andere drie Scaratures te kopen.",ep:3,g:67,l:46,wd:true,fm:true,w:2,s:27,p:5600};
I.u[6949] = {n:"Witte Scarature",t:10,d:"De Scarature diende vroeger voor het geven van een indicatie van je niveau van vechten met de blote hand. een groene Scarature bezitten betekende dat je een beginneling was, een rode betekende dat je het bloed van je vijanden oplikte als je ze afgemaakt had, een witte betekende dat je een echte vechtmachine was die vijanden uitroeide, en een blauwe betekende dat je niet genoeg kamas had om één van de andere drie Scaratures te kopen.",ep:3,g:69,l:46,wd:true,fm:true,w:2,s:29,p:5600};
I.u[6950] = {n:"Rode Scarature",t:10,d:"De Scarature diende vroeger voor het geven van een indicatie van je niveau van vechten met de blote hand. een groene Scarature bezitten betekende dat je een beginneling was, een rode betekende dat je het bloed van je vijanden oplikte als je ze afgemaakt had, een witte betekende dat je een echte vechtmachine was die vijanden uitroeide, en een blauwe betekende dat je niet genoeg kamas had om één van de andere drie Scaratures te kopen.",ep:3,g:68,l:46,wd:true,fm:true,w:2,s:28,p:5600};
I.u[6951] = {n:"Blauwe Scarature",t:10,d:"De Scarature diende vroeger voor het geven van een indicatie van je niveau van vechten met de blote hand. een groene Scarature bezitten betekende dat je een beginneling was, een rode betekende dat je het bloed van je vijanden oplikte als je ze afgemaakt had, een witte betekende dat je een echte vechtmachine was die vijanden uitroeide, en een blauwe betekende dat je niet genoeg kamas had om één van de andere drie Scaratures te kopen.",ep:3,g:70,l:46,wd:true,fm:true,w:2,s:30,p:5600};
I.u[6952] = {n:"Boowolf hoofddeksel",t:16,d:"Met deze Boowolf-kop op je hoofd lijk je op Frats Blauwer, illustere minstreel die zijn tijd vooruit was, en wiens hoofd teruggevonden werd tussen de kaken van een stervende Boowolf die het niet meer aankon om te luisteren naar de liedjes die de minstreel aan hem opdrong.",ep:1,g:131,l:61,wd:true,fm:true,w:4,s:32,p:10000};
I.u[6953] = {n:"Boowolf Laarsjes",t:11,d:"Deze met Boowolfharen bedekte laarsjes zijn erg handig om stoffig parket mee schoon te maken, of eenvoudigweg om het hoofd van je tegenstanders mee schoon te maken als ze stervend op de grond liggen.",ep:1,g:76,l:61,wd:true,fm:true,w:2,s:32,p:9700};
I.u[6954] = {n:"Boowolf Cape",t:17,d:"Deze Boowolfhuid vormt een uitstekende bescherming tegen de kou, maar ook tegen avonturiers met een iets te sterk ontwikkelde reukzin.",ep:1,g:99,l:64,wd:true,fm:true,w:5,s:32,p:11000};
I.u[6955] = {n:"Boowolf String",t:10,d:"Als zweep gebruikt, kan deze string zich nuttiger tonen dan hij lijkt, om je reisgezellen weer te motiveren, als hun liefde voor gevaar begint te tanen.",ep:1,g:92,l:49,wd:true,fm:true,w:2,s:32,p:6500};
I.u[6956] = {n:"Boowolfring",t:9,d:"Pas op, door deze ring zal je vinger bijzonder slecht gaan ruiken. Een geur die mogelijkerwijs een andere kan bedekken. Dat is misschien voor je vinger en voor je omgeving een hele goede zaak...",ep:1,g:103,l:51,wd:true,fm:true,w:2,s:32,p:7000};
I.u[6957] = {n:"Krakler Lemmet",t:6,d:"Dit zwaard werd vroeger gebruikt om blokken graniet uit te hakken voor de muren van prestigieuze steden zoals Bonta of Brakmar. Tegenwoordig is dit wapen vooral gewild wegens zijn vermogen alle soorten levende wezens te verpletteren, of ze er in toestemmen of niet.",ep:5,g:54,l:37,wd:true,fm:true,w:10,an:14,tw:true,e:[5,6,1,1,50,50,false,true],s:26,p:3800};
I.u[6958] = {n:"Briljante Muts van Torte Hou",t:16,d:"Met dit hoofddeksel op, bijna modern nog, heb je een unieke stijl en kun je heel discreet onder de rokken van Craettes kijken. Ideaal voor beschonken zomeravonden.",ep:5,g:82,l:22,wd:true,fm:true,w:12,p:1525};
I.u[6961] = {n:"Bandiet Ring",t:9,d:"Deze ring is net zo populair bij tandartsen als bij bandieten, die hem gebruiken om één voor één de tanden van onvoorzichtige personen te breken. Het is een manier om cariës te voorkomen.",ep:1,g:77,l:17,wd:true,fm:true,w:2,s:25,p:1000};
I.u[6962] = {n:"Verjaardagscadeau",t:89,d:"Gefeliciteerd met je verjaardag. Het is niet mogelijk de inhoud van dit cadeau te onthullen, maar weet dat je hiermee tegelijkertijd kan losbarsten en kan feesten. Dat moet ook, want het is een feestdag.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6963] = {n:"Minotobal Ballen",t:12,d:"Deze enorme ballen zijn werkelijk heerlijk. Het eind is niet meteen in zicht, maar wat maakt het uit.",ep:1,g:143,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6964] = {n:"Stadsdrankje: Brakmar",t:12,d:"Met deze op basis van rijst gemaakte toverdrank kunnen alle bondgenoten van Brakmar in een oogwenk naar de stad Brakmar terugkeren.",ep:1,g:145,l:1,wd:true,fm:true,w:1,c:"Ps=2|Ps=0|Ps=3",u:true,p:1};
I.u[6965] = {n:"Stadsdrankje: Bonta",t:12,d:"Met deze drank op basis van rijst kunnen de bondgenoten van Bonta in een wip naar de stad Bonta terugkeren.",ep:1,g:144,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=0|Ps=3",u:true,p:1};
I.u[6966] = {n:"Speciale Spreukrol: Jinx",t:75,d:"(Dubbelklik om de spreuk te leren)\nDeze rol leert je de spreuk \'Jinx\', alleen voor Srams.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"PG=4",u:true,p:10000};
I.u[6967] = {n:"`SRVT:MERCENARY_INTRONIZER` Leerling",t:14,d:"Deze schriftrol is de sleutel waarmee een `SRVT:MERCENARY_SHORT_NAME` gepromoveerd kan worden tot leerling.",ep:1,g:5,l:1,wd:false,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6968] = {n:"`SRVT:MERCENARY_INTRONIZER` `SRVT:MERCENARY_SHORT_NAME`",t:14,d:"Deze schriftrol is de sleutel waarmee een `SRVT:MERCENARY_SHORT_NAME` gepromoveerd kan worden tot volwaardig `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6969] = {n:"`SRVT:MERCENARY_INTRONIZER` Groot `SRVT:MERCENARY_SHORT_NAME`",t:14,d:"Deze schriftrol is de sleutel waarmee een `SRVT:MERCENARY_SHORT_NAME` gepromoveerd kan worden tot Groot `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6970] = {n:"`SRVT:MERCENARY_INTRONIZER` Meester",t:14,d:"Deze schriftrol is de sleutel waarmee een `SRVT:MERCENARY_SHORT_NAME` bevorderd kan worden tot Meester `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6971] = {n:"Clint van de `SRVT:MERCENARY_SHORT_NAME` discipel",t:16,d:"Deze hoed is een redelijk goede replica van de beroemde Clint, hij is uitermate geschikt voor de discipelen van `SRVT:MERCENARY_SHORT_NAME` die zich voor willen doen als de meester.",ep:1,g:38,l:1,wd:false,fm:true,w:20,c:"Ps=3",p:1};
I.u[6975] = {n:"Clint van de beginneling",t:16,d:"Deze supermachtige hoed is het onderscheidingsteken van de Seriane. Hij heeft het vermogen je te beschermen tegen regen en zon, en dat is al heel wat...",ep:1,g:38,l:1,wd:false,fm:true,w:20,p:1};
I.u[6978] = {n:"Peki",t:18,d:"Van een afstand af lijkt dit beest net op een Bow Wow. Een enkele blik op zijn hoofd en je ziet dat hij vreselijke beproevingen heeft doorstaan... welke hem uiteindelijk vegetarisch maakten en hem een levenslang abonnement op de Huisdieren Begraafplaats vereniging gaf. Hij kan enkel groenten en planten eten die op Pandala Eiland groeien.",ep:3,g:12,l:60,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6979] = {n:"Vaipay Zwaard Cape",t:17,d:"Deze cape biedt bescherming tegen andere avonturiers die jou dan weer de schuld kunnen geven.",ep:1,g:59,l:50,wd:false,fm:true,w:10,p:5000};
I.u[6980] = {n:"Vulbis Dofus",t:23,d:"Deze Dofus is gelegd door een draak, die besloten heeft anoniem te blijven. De meest opmerkelijke avonturiers vragen zich altijd af waarom.",ep:11,g:4,l:6,wd:false,fm:true,w:1,p:500000};
I.u[6981] = {n:"IJs Dolken",t:5,d:"Het lemmet van deze dolken is van ijs, dus erg praktisch om de adem van je vijanden te verfrissen. Doe hun mond open, zet er deze grote ijsdolk in en klaar is Kees.",ep:19,g:44,l:150,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>150",p:15};
I.u[6982] = {n:"Dagg\'Onies",t:5,d:"Deze dolken zijn in bloed gedrenkt van diverse slechte beesten, zoals kinderen. Ze zijn zeer speciaal.",ep:18,g:50,l:46,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5775};
I.u[6983] = {n:"Aanstekelijke dolken",t:5,d:"Deze dolken, die slechts één keer in de tien jaar worden geslepen, zijn daarom niet minder dodelijk. Bezield door de meest zwarte magie, verplaatsen ze zich helemaal alleen tijdens de nacht om zich in het beste geval te steken in het achterwerk van onvoorzichtigen... Nog een verhaal dat wordt verteld aan jonge Iops om ze bang te maken.",ep:19,g:47,l:143,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>250&CA>100",p:15};
I.u[6984] = {n:"Dolken van de Leerling Veelvraat Jager",t:5,d:"Deze dolken behoorden toe aan een arme Sadida, van wie zijn bliksemsnelle rijkdom geschiedenis heeft gemaakt in Amakna. Deze Sadida had zijn leven gewijd aan de jacht op Veelvraten, waar alle dorpsbewoners hartelijk om moesten lachen. Sommige nieuwsgierigen kwamen van verre om hem te zien jagen op deze belachelijke wezens en om hem uit te lachen. Zijn wraak was zoet, want intussen was hij rijk genoeg geworden om een losprijs op de hoofden te zetten van diegenen die de spot met hem dreven.",ep:18,g:46,l:113,wd:true,fm:true,w:15,an:13,tw:true,e:[5,3,1,1,25,50,false,false],c:"CS>300&CA>100",p:32750};
I.u[6986] = {n:"Gebroken Mont Kipou Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:1,l:1,wd:false,fm:true,w:20,c:"BI=non équipable",p:5400};
I.u[6987] = {n:"Kleine Gewaagde Zielsteen",t:83,d:"Met deze rune heb je een kleine kans om kleine zielen te vangen.",ep:5,g:1,l:1,wd:false,fm:true,w:1,tw:true,p:1250};
I.u[6988] = {n:"Sulik",t:16,d:"Deze hoed werd vroeger gedragen door een wilde Xelor wiens zuster ooit eens zonder mededogen werd ontvoerd door slavenhandelaren. Met deze weelderige hoed zie je er echt wild uit.",ep:19,g:92,l:172,wd:true,fm:true,w:10,p:56100};
I.u[6989] = {n:"Krokop",t:16,d:"Deze hoed is langgeleden gemaakt door kleermakersleerlingen die zich wilde beschermen tegen de woedeaanvallen van kleermaker Mirko. Deze laatste had de vervelende gewoonte zijn leerlingen te doden door ze hard tegen het hoofd te trappen als ze niet snel genoeg werkten. Dat is ook een methode om leerlingen te motiveren weer aan het werk te gaan.",ep:19,g:86,l:120,wd:true,fm:true,w:20,p:37025};
I.u[6990] = {n:"Motmuts",t:16,d:"Deze muts is een eerbetoon aan de verre familie van de Moskitos, de Motten. Groter, maar ook aardiger dan de Moskitos, hadden de Motten de neiging te paren met wie dan ook, maar vooral waar dan ook, wat heeft geleid tot het geleidelijk uitsterven van hun ras. Dit vreselijk feit heeft niemand onverschillig gelaten, en vandaag de dag is het gangbaar een avonturier uit te maken voor Mot, als men wil aangeven dat hij erg slecht zijn partner kiest.",ep:19,g:87,l:113,wd:true,fm:true,w:10,p:32925};
I.u[6991] = {n:"Guavehoed",t:16,d:"Deze vreemde hoed lijkt op een uitgedroogde rottende vrucht, zo\'n beetje als jij na een avond in de herberg doorgebracht te hebben.",ep:18,g:88,l:46,wd:true,fm:true,w:10,p:5800};
I.u[6992] = {n:"Kannipiwi",t:16,d:"Met deze verfraaide versie van het beroemde Kanniboule masker, kun je met de Kannipiwi voor je vrienden doorgaan als een echte Piwi-jager.",ep:12,g:89,l:55,wd:true,fm:true,w:5,p:8000};
I.u[6993] = {n:"Hallelujah Cape",t:17,d:"Lonard Kohen, beroemde minstreel van beroep, bleef altijd maar zingen tot hij zijn stem verloor. Hij werd levend verbrand bij de bank van Bonta, na zijn schandalige lied \"Laat haar koken, met haar ogen open\"",ep:18,g:79,l:46,wd:true,fm:true,w:10,p:5600};
I.u[6994] = {n:"Hoed Cape",t:17,d:"Deze kruising tussen een hoed en een cape is werkelijk verbazingwekkend. Als hij gemaakt zou zijn van leer, zou Kapitein Chafer hem zeker aanbidden.",ep:1,g:80,l:58,wd:true,fm:true,w:10,p:8875};
I.u[6995] = {n:"Houte Cape",t:17,d:"Deze zeer krachtige cape heeft al meer dan één onvoorzichtig persoon die probeerde hem te dragen, om te laten vallen, een eigenschap die hij deelt met Com Pina.",ep:18,g:81,l:105,wd:true,fm:true,w:10,p:28300};
I.u[6996] = {n:"No Stradamusring",t:9,d:"Stradamus was een oude Enutrof, totaal dronken, die de toekomst las in bierpullen. De legende vertelt dat hij, op zijn verzoek, vertikaal in één van de muren van de herberg van Brakmar begraven werd, zodat \"geen enkele bange schijterd een biertje op zijn graf zou kunnen omgooien\". Het soort legende dat rondgebazuind wordt in de loop van de zuippartijen die door de Sériane Meesters worden georganiseerd.",ep:18,g:78,l:48,wd:true,fm:true,w:5,p:6075};
I.u[6997] = {n:"Fioutioure Ring",t:9,d:"De maakster van deze ring dacht dat het einde van de wereld nabij was, zij bracht haar dagen door met het kerven van houten tafels met haar gereedschap, en zei dat er geen toekomst meer was voor de bewoners van Amakna. De tijd bewees haar ongelijk.",ep:18,g:79,l:70,wd:true,fm:true,w:5,p:12730};
I.u[6998] = {n:"Trouwring van Elya Wood",t:9,d:"Deze kleine trouwring is bijzonder geschikt voor de kleine vingers van de Eniripsas. Echter de Iops kunnen hem bijna niet gebruiken vanwege hun grote worstachtige vingers, en hun onnozelheid om begrijpen waar men een trouwring draagt.",ep:18,g:84,l:120,wd:true,fm:true,w:15,s:39,p:36000};
I.u[6999] = {n:"Lahilama Medaille",t:1,d:"Lahilama is een groot spiritueel leider die zijn zetel hoog in de bergen had. Hij verveelde zich zo erg, dat hij zijn dagen doorbracht met het fabriceren van gele mutsen voor zijn discipelen. Gekte kent geen grenzen.",ep:18,g:83,l:31,wd:true,fm:true,w:3,p:2800};
I.u[7000] = {n:"Bambamulet",t:1,d:"Dit belachelijk kleine stukje bamboe bezit vreemde magische krachten. Hij werd vroeger gedragen door jonge Pandawas, die net de pubertijd waren ontgroeid. Misschien dat jij nog enkele jaren moet wachten alvorens hem om je nek te kunnen dragen...",ep:18,g:78,l:40,wd:true,fm:true,w:5,p:4400};
I.u[7001] = {n:"Havermaaier Amulet",t:1,d:"\"Ik ben geen Tikoko, de Trukikols staan me goed, ik ben geen Tikoko, een Tikokoooooo...\". Dat zong Djannes de beroemde boerenminstreel bekend van het zingend maaien van haver, luidkeels toen hij terugkwam van zijn vakantie op het Moon eiland",ep:18,g:84,l:55,wd:true,fm:true,w:10,p:8000};
I.u[7002] = {n:"Kleine Hars",t:1,d:"Dit amulet van Bamboehars verspreidt een aangename geur om je heen. Erg doeltreffend om je pogingen met Paniek Winden te verdoezelen.",ep:18,g:85,l:94,wd:true,fm:true,w:5,p:22800};
I.u[7003] = {n:"Elya Wood Amulet",t:1,d:"Dit amulet wordt gemaakt van sterrenpoeder en edelstenenpoeder van de Voorvaderlijk Boomchnid barnsteen. Dit mengsel kan explosief zijn en daarom wordt afgeraden om het zelf samen te stellen, laat dat dus liever over aan een Juwelier die je niet zo mag.",ep:18,g:86,l:135,wd:true,fm:true,w:10,s:39,p:45600};
I.u[7004] = {n:"Gemiddelde Gewaagde Zielsteen",t:83,d:"Met deze rune kan je redelijk grote zielen te vangen.",ep:5,g:8,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7005] = {n:"Grote Gewaagde Zielsteen",t:83,d:"Deze Rune biedt een kleine kans bijzonder wilde zielen te vangen...",ep:5,g:9,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7006] = {n:"Enorme Gewaagde Zielsteen",t:83,d:"Met deze steen heb je een kleine kans behoorlijk gewaagde zielen te vangen.",ep:16,g:10,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7007] = {n:"Kleine Zielsteen",t:83,d:"Deze rune geeft een redelijke kans kleine zielen te kunnen vangen.",ep:5,g:2,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7008] = {n:"Gemiddelde Zielsteen",t:83,d:"Deze rune geeft je een redelijke kans om relatief hogere zielen te vangen...",ep:5,g:12,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7009] = {n:"Grote Zielsteen",t:83,d:"Deze rune biedt een redelijke kans om bijzonder woeste zielen te vangen...",ep:16,g:13,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7010] = {n:"Volle Zielsteen",t:85,d:"Deze zielsteen bevat de zielen van een groep monsters die alleen terug willen keren tot het leven om zich op jou te wreken. Hij kan echter slechts gebruikt worden in speciaal daarvoor bestemde arenas, gelegen in de grote steden.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7011] = {n:"Wens O\'Bol Cape",t:17,d:"Deze bijna levende cape van rode baardharen is uniek in zijn soort. Bezield met bijzondere magie, kan hij zijn drager behoorlijk in de maling nemen door zich altijd te verstoppen op het moment op avontuur te gaan, wanneer men het meest nodig heeft. Gelukkig wordt het bedrog  door een volkomen betrouwbare gevechtskracht gecompenseerd, de Wabbits zeggen niet voor niet dat het een \"echte oowlogsmechine is\".",ep:13,g:83,l:67,wd:false,fm:true,w:10,s:38,p:11875};
I.u[7012] = {n:"De Doubitch Bol",t:1,d:"Dit amulet is eigenlijk een snoepje. Je zou \'m kunnen opeten, ware het niet dat het daarvoor al 36 generaties lang onder de oksels heeft gezeten van een horde loopse Bwork wijfjes.",ep:7,g:87,l:77,wd:true,fm:true,w:10,s:38,p:15425};
I.u[7013] = {n:"Bamboehout",t:38,d:"In tegenstelling tot rozen, buigt en breekt bamboe. Gelukkig zijn het meestal de tanden van onvoorzichtige avonturiers die breken onder de bamboeslagen. Soms stelt zelfs de natuur zich in dienst van gewetenloze tandartsen.",ep:18,g:673,l:50,wd:true,fm:true,w:5,p:0};
I.u[7014] = {n:"Heilig Bamboe Hout",t:38,d:"In tegenstelling tot wat het lijkt, is dit hout heilig. Normaliter kunnen alleen de beste Pandawas dit hout hakken, maar soms gebeurt het dat houthakkende toeristen zonder schroom met een plaatselijk soevenir vertrekken na hun reis op het eiland van Pandala. Stomme toeristen.",ep:18,g:671,l:100,wd:true,fm:true,w:5,p:0};
I.u[7015] = {n:"Bamboescheutjes",t:38,d:"Deze bamboescheutjes zijn niet geschikt voor consumptie, want ze hebben werkelijk geen enkele smaak. Het wordt dus aangeraden ze te maaien met een roestige zeis, of ze enkele jaren te laten weken in het sap van Greedovore voor ze aan je vrienden te serveren. Nog een oude praktische tip, ontleend aan weinig scrupuleuze restauranthouders die tot alle listen bereid zijn om je alles maar te laten slikken.",ep:1,g:676,l:50,wd:true,fm:true,w:2,p:5};
I.u[7016] = {n:"Duister Bamboe Hout",t:38,d:"Walloh, de jonge Pandawa, vroeg op een dag aan zijn vader \"Wat is het verschil tussen Bamboe en Duister Bamboe, Papa?\". Hij kreeg een welverdiende klap voor zijn kop voor het stellen van zo\'n domme vraag, iedereen weet wat het verschil is tussen Bamboe en Duister Bamboe, dat is de grootte van hun zaden.",ep:18,g:672,l:60,wd:true,fm:true,w:5,p:0};
I.u[7017] = {n:"Verguld Bamboe Hout",t:38,d:"Walloh, de jonge Pandawa, vroeg op een dag aan zijn vader \"Wat is het verschil tussen Bamboe en Gulden Bamboe, Papa?\". Hij kreeg een wel verdiend pak op z\'n billen voor het stellen van zo\'n domme vraag, iedereen weet wat het verschil is tussen Bamboe en Gulden Bamboe, dat is het formaat van hun wortels.",ep:18,g:669,l:45,wd:true,fm:true,w:5,p:20};
I.u[7018] = {n:"Rijst",t:34,d:"Klevend, of zelfs plakkering, heeft rijst altijd succes bij hongerige Pandawas.",ep:18,g:10,l:20,wd:true,fm:true,w:2,p:0};
I.u[7020] = {n:"Lotus Bloem",t:38,d:"Men zegt dat dit de oudste nu nog bekende bloem is, ze symboliseert vruchtbaarheid, maar ook onthechting, omdat ze soms uit het water opduikt zonder nat te worden. Sommige Pandawa chefs gebruiken dit symbool om hun getrouwen duidelijk te maken dat ze in de wereld moeten leven zonder gehecht te raken.",ep:1,g:141,l:30,wd:true,fm:true,w:1,p:2};
I.u[7022] = {n:"Sangroku\'s Staf",t:4,d:"Deze staf behoorde toe aan Sangroku\'s grootvader, Sangrokane, beroemd voor zijn grote hoofd. De legende vertelt dat deze staf zich tot elke gewenste lengte kan uitrekken... gebruik hem om je vijanden mee plat te krijgen of om hem in je broek te stoppen, je bent altijd een winnaar hiermee...",ep:18,g:47,l:120,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,50,60,false,false],c:"CA>250&CV>300",p:36620};
I.u[7023] = {n:"Aquamarijn Steen",t:51,d:"Deze steen wordt gewoonlijk gevonden in de omgeving van het eiland van Pandala. De Pandawas zeggen dat deze steen bijzondere krachten bezit. Iedereen praat erover, maar niemand heeft het kunnen ontdekken. Net zoiets als de intelligente Iops.",ep:1,g:75,l:60,wd:true,fm:true,w:5,p:600};
I.u[7024] = {n:"Topazen Steen",t:51,d:"Deze vreemde steen werd heel lang geleden gebruikt als voedsel voor de jonge Krakrots van sommige fokkers van Pandala. Deze stenen zijn zo zeldzaam geworden, dat het nu verboden is ze als voedsel voor Krakrots te gebruiken.",ep:5,g:76,l:70,wd:true,fm:true,w:5,p:700};
I.u[7025] = {n:"Agaathsteen",t:51,d:"Deze steen dankt zijn naam aan de rivier in Pandala waarin hij vroeger in overvloed gevonden werd. Maar de tijden zijn erg veranderd, en de intensieve exploitatie van deze vindplaatsen heeft hem uiteindelijk bijna onvindbaar gemaakt.",ep:5,g:128,l:80,wd:true,fm:true,w:5,p:1};
I.u[7026] = {n:"Aquamarijn",t:50,d:"Deze transparante, soms enigszins blauwe edelsteen is zo schitterend, dat als je hem om je hals draagt, hij de meest markante rimpels verbergt. De Pandawas aarzelen overigens niet om de toeristen toe te roepen : \"Met deze steen maakt u uw geliefde gelukkiger en accepteert u makkelijker de kwellingen die degenen waar u om geeft moet doorstaan. Een goede manier om in één klap twee vliegen te vangen.",ep:1,g:101,l:60,wd:true,fm:true,w:5,p:600};
I.u[7027] = {n:"Topaas",t:50,d:"Deze edelsteen wordt om wat duistere redenen erg gewaardeerd door juweliers, maar blijft waardevol om de aandacht te trekken van de Raven die leven in de Vlaktes van Cania.",ep:5,g:102,l:70,wd:true,fm:true,w:5,p:700};
I.u[7028] = {n:"Agaat",t:50,d:"Deze steen ontleent zijn naam aan een zeer krachtig vrouwtjes Pandawa, bekend onder de naam Agaat Pahtes, vermaard in louche en weinig aanbevelingswaardige tenten, zoals de bar van de Sufokia Piraten bijvoorbeeld, waar zij haar laatste jaren doorbracht, al dansend vastgeketend aan een grote scheepsmast die midden in de bar was bevestigd.",ep:5,g:103,l:80,wd:true,fm:true,w:5,p:800};
I.u[7029] = {n:"Sangroku Riem",t:10,d:"Toen Sangroku zich te goed had gedaan aan de magische bonen, trok hij deze riem strak om zijn middel om zoveel mogelijk de paniekwinden in bedwang te houden, die hem beroemd hebben gemaakt in de gehele provincie van Amakna.",ep:13,g:80,l:86,wd:false,fm:true,w:10,c:"CS>100",p:18400};
I.u[7030] = {n:"Kaniger Huid",t:59,d:"Eenmaal geschoren is de Kaniger huid erg zacht, een beetje zoals de vrouwelijke Sadidas.",ep:13,g:47,l:70,wd:true,fm:true,w:5,p:1};
I.u[7031] = {n:"Flooey\'s Klok",t:1,d:"De arme Flooey was gek geworden tijdens een vreselijk gevecht met Many. Gelukkig is zijn amulet niet beschadigd tijdens het gevecht en heeft het al zijn hypnotiserende krachten behouden, maar ook zijn laxerende werking. Gebruik hem dus met mate.",ep:18,g:90,l:46,wd:false,fm:true,w:2,p:5600};
I.u[7032] = {n:"Silicaat",t:39,d:"Dit mineraal komt ongetwijfeld uit de diepe Duistere mijnen van het eiland van Pandawa waarin Gardan Framine is gevallen, hartstochtelijk verliefd op een spook van een vrouwelijke Pandawa. Zo zie je maar, liefde kent geen enkele grens.",ep:16,g:111,l:70,wd:true,fm:true,w:5,p:0};
I.u[7033] = {n:"Dolomiet",t:39,d:"\"Altijd hard, en onbreekbaar\" dat waren de woorden van Irko de Duistere Mijnwerker over Dolomiet.",ep:16,g:110,l:80,wd:true,fm:true,w:5,p:0};
I.u[7034] = {n:"Meester Nabur Helm",t:16,d:"Van generatie op generatie overgedragen, zou deze misvormde helm gedragen zijn door Crail himself. Veel avonturiers dichten hem krachten toe die hij niet bezit, een eigenschap die in onze moderne tijd vaak wordt toegeschreven aan goden en helden.",ep:16,g:93,l:97,wd:false,fm:true,w:10,p:23000};
I.u[7035] = {n:"Pyruut",t:40,d:"Dit mengsel werd gebruikt om lemmets te smeden die niet roesten als ze in contact komen met bloed of speeksel van vijanden.",ep:16,g:708,l:100,wd:true,fm:true,w:100,p:0};
I.u[7036] = {n:"Rutiel",t:40,d:"Dit glimmende metaalmengsel word erg gewaardeerd door geruïneerde juweliers, die zich geen edelstenen kunnen veroorloven en die van dit metaalmengsel trouwringen maken voor een spotprijsje. Goede tip als je absoluut wil trouwen om het geld.",ep:16,g:707,l:100,wd:true,fm:true,w:100,p:0};
I.u[7037] = {n:"Wandelstok van Omaatje Snoep",t:4,d:"Deze wandelstok behoorde toe aan Omaatje Snoep, een van de drie verschrikkelijke priesteressen van de liefde. Aan één kant geslepen en aan de andere kant glimmend, was deze wandelstok beroemd om zijn veelzijdigheid en zijn vermogen om zich overal in te steken. Niemand kon er ongevoelig onder blijven.",ep:18,g:48,l:98,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,50,50,false,false],c:"CS>100&CV>300",p:24500};
I.u[7038] = {n:"Kroon van de Gelax Koning",t:16,d:"Deze kroon was ooit van de illustere Koning Gelax, beroemd om zijn uitbundige romantiek en zijn verleidingsvermogen, dat het leven heeft getekend van menig vrouwtjes Gelei... Men zegt zelfs, dat hij min of meer de vader is van alle Gelei in de omgeving van Amakna. Zijn uithoudingsvermogen en zijn legendarische vruchtbaarheid zijn daar het bewijs van.",ep:7,g:94,l:79,wd:true,fm:true,w:15,p:15000};
I.u[7039] = {n:"Zwarte Riem van Frank Lee Bruce",t:10,d:"Beroemde zondagsvechter Frank heeft zich laten omscholen in oosterse gevechtstechnieken nadat hij jammerlijk was gezakt voor zijn diploma van steenhouwer.",ep:13,g:81,l:47,wd:true,fm:true,w:5,p:5900};
I.u[7040] = {n:"Kuri Boog",t:2,d:"Deze boog was van Kuri persoonlijk, een beroemde priesteres van de liefde, en de linkerhand van Omaatje Snoep. Draai nooit je rug naar een priesteres van de liefde, een pijl van deze boog kan gemakkelijk je hart verscheuren, of je billen als je deze tegenstandster de rug toekeert. ",ep:18,g:43,l:56,wd:true,fm:true,w:10,an:10,tw:true,e:[15,5,2,6,20,40,false,true],p:8300};
I.u[7041] = {n:"Pandrista",t:30,d:"Ook wel Galop van de Pandawa genoemd, is de Pandrista een specialiteit van de Pandala die de reizigers goed kennen. De symptomen: Dringend verlangen om de troon te bestijgen, gevolgd door het onvermogen een drol te draaien die die naam waardig is.",ep:18,g:8,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7042] = {n:"Hoofddeksel van Pandawa",t:14,d:"In tegenstelling tot de Pandawa van Amakna, zal de Pandawa van Pandala je niet op je kop timmeren, alleen heel veel zin geven natuurlijke mest te deponeren op de dichtstbijzijnde plant... Of bij gebrek daaraan, op een miauwmiauw: dat is even doeltreffend (voor jou) en vooral veel grappiger.",ep:18,g:31,l:1,wd:false,fm:true,w:1,c:"PG!12",u:true,p:1000};
I.u[7043] = {n:"IJs Dofus",t:23,d:"Volgens de legende is de geweldige Dofus uit het berijpte gat van Aguabrial de Waterdraak gekomen. De legende vertelt er niet bij dat hij die dag verkouden was maar dat laat zich ook wel makkelijk raden.",ep:1,g:5,l:1,wd:false,fm:true,w:1,p:1};
I.u[7044] = {n:"Dofus Zeis",t:24,d:"Deze Dofus lijkt niet op de andere Dofus en toch...",ep:18,g:256,l:1,wd:false,fm:true,w:0,p:1};
I.u[7045] = {n:"Een flesje Pandaburg",t:79,d:"De Pandaburg is een smaakvolle drank, die naar het schijnt je blind, stom en doof maakt, maar heel langzaam. Dat komt goed uit, de Pandawas hebben geen haast.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[7046] = {n:"Een flesje Pandapiler",t:79,d:"Volgens de erudiete Hel Munster, zou deze onvervalste nectar de godin Pandawa zelf zeer bekoren, en haar helemaal buiten zinnen maken. Elk zichzelf respecterend Pandawa zou Pandapilers aan zijn aanbeden godin moeten offeren.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[7047] = {n:"Een flesje Pandapils",t:79,d:"Vreemd, deze oude pandawaanse gewoonte die wil dat men proost, een Tofu-veer op het hoofd, al zingend: \"Pandapils, Pandapils, tralalalaLAHIEHOE!\". En dat is nog niet eens het ergste...",ep:18,g:4,l:1,wd:true,fm:true,w:1,p:1};
I.u[7048] = {n:"Een flesje Pandalartois",t:79,d:"Pandalartois is uiterst giftig en zelfs het drinken van een kleine hoeveelheid brengt functiestoornissen van het zenuwgestel teweeg. Maar omdat het lekker is, drinken de Pandawas er elke dag van, zoals de Pandawa doet!",ep:0,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[7049] = {n:"Een flesje Panduff",t:79,d:"Ideaal voor je drankoffers aan de godin, op voorwaarde dat je het volgende ritueel respecteert: strek je uit op de grond, tegenover het standbeeld, drink een slokje Panduff, drink dan een grote teug en ten slotte het belangrijkste: drink een hele grote slok Panduff. Kijk het standbeeld van de godin strak aan. Na enkele dagen deze leefregel gevolgd te hebben, zal ze zeker aan je verschijnen. Zo niet, ga dan een shamaan om raad vragen.",ep:0,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[7050] = {n:"Een flesje Panduvel",t:79,d:"Geef een vis aan een Pandawa en hij zal een hele dag eten. Leer een Pandawa vissen en hij zal zijn dagen in een vissersboot Panduvel drinkend doorbrengen (oud Pandawaans gezegde).",ep:0,g:7,l:1,wd:true,fm:true,w:1,p:1};
I.u[7051] = {n:"Een flesje Pandarium Tremens",t:79,d:"\"Het Pandarium Tremens is het bewijs dat Pandawa van ons houdt en wil dat wij gelukkig zijn\". Deze dankbede, gericht tot de godin, is tevens een bewijs van vrede tussen alle Pandawas.",ep:0,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[7052] = {n:"Een flesje Pandakwa",t:79,d:"Het verschil tussen een Pandakwa en de godin Pandawa is slechts het Pandakwa, ze maken het zonder alcohol.",ep:0,g:10,l:1,wd:true,fm:true,w:1,p:1};
I.u[7053] = {n:"Een flesje Vodkawa",t:79,d:"\"Om te weten of een glas Vodkawa te veel is geweest, moet je hem toch gedronken hebben\". Dit oude pandawaïaanse gezegde is de oorzaak van talloze feestelijke uitspattingen. Het is ook de inspiratiebron van bepaalde liedjes van de superberoemde minstreel Moco Prostato.",ep:0,g:8,l:1,wd:true,fm:true,w:1,p:1};
I.u[7054] = {n:"Een flesje Whisdawa",t:79,d:"Met de Whisdawa is het net als met borsten. Eén is niet genoeg en drie is te veel (oud pandawanees gezegde).",ep:0,g:11,l:1,wd:true,fm:true,w:1,p:1};
I.u[7055] = {n:"Pandneken Veldfles",t:79,d:"“Het is waar dat Bwak benen kort zijn, maar het heeft geen enkel nut ze langer te maken”. Een gesprek als deze is wat je krijgt als je een Pandneken hebt verorberd. Daarom houden Pandawa\'s het liever als offer voor hun Pandawa.",ep:18,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[7056] = {n:"Kracklin Kepie",t:16,d:"Deze uniek hoed was ooit van een Xelor, die bekend was om zijn explosieve ideeën en zijn controle over de tijd. Hij is op een ongebruikelijke manier overleden. Hij liet een Paniek Wind, waardoor alle hoeden afwaaiden en vergat dat zijn eigen hoed kleine vonkjes om hem heen wierp. Zijn dood schijnt behoorlijk pijnlijk geweest te zijn, maar zo verlichtend, dat de hele stad Brakmar gedurende een paar seconden verlicht werd. ",ep:19,g:95,l:149,wd:true,fm:true,w:10,p:45850};
I.u[7057] = {n:"Shaman\'s Assistent",t:32,d:"Breng de assistent naar de godin, hij zal dankbaar zijn.",ep:18,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7058] = {n:"Octovius",t:16,d:"Deze muts is gemaakt van resten dode gedroogde Krakamors. Pas op want als je hem als badmuts gaat gebruiken loop je het risico dat ze weer tot leven komen.",ep:18,g:96,l:77,wd:true,fm:true,w:10,p:15475};
I.u[7059] = {n:"Pandouille Zaad",t:58,d:"Deze enorme graankorrel is overladen met een onverteerbare, maar magische olie. Zijn dop staat bekend als onbreekbaar, ontelbare kunstenaars gebruiken hem om wapens te betoveren, en anderen gebruiken hem als magisch varkentje bij het jeu de boule.",ep:18,g:67,l:100,wd:true,fm:true,w:10,p:10};
I.u[7060] = {n:"Speciale Pandapiler",t:24,d:"De wijze Lenald heeft je deze Pandapiler gegeven om het naar de Pandawushu Meester van het waterpad te brengen.",ep:18,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[7061] = {n:"Bow Meow Vloek",t:31,d:"Het water van de bron juice-sane-ki-oak van de Bow Meow heeft je tijdelijk in een Bow Meow veranderd. De lichtste schok maakt je weer normaal.",ep:18,g:21,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7062] = {n:"Poochan",t:32,d:"Je moet Poochan naar haar toekomstige echtgenoot brengen.",ep:18,g:21,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7063] = {n:"Rovers Bloem",t:35,d:"Deze mooie bloem groeit alleen in het dorp van de Imps, een beetje als de Impette, maar een beetje minder ondeugend.",ep:1,g:634,l:40,wd:true,fm:true,w:2,p:10};
I.u[7064] = {n:"Jeuk Orchidee",t:35,d:"Deze mooie Orchidee is vooral bekend voor het veroorzaken van vreselijke jeuk bij eenieder die haar waagde te plukken.",ep:1,g:633,l:40,wd:true,fm:true,w:2,p:10};
I.u[7068] = {n:"Rijst Meel",t:52,d:"Dit meel is uitstekend geschikt om cement mee te maken of als draagstoel van Ouginak.",ep:18,g:7,l:50,wd:true,fm:true,w:2,p:0};
I.u[7069] = {n:"Sidimote Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:8,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:15650};
I.u[7070] = {n:"Geschaaft Rovers Schild",t:82,d:"Dit eerlijke schild heeft te veel veldslagen gezien. Het is niet meer in een goede staat. Misschien dat Bouwada in het Pandala dorp het voor je kan vervangen.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"BI=non équipable",p:30700};
