I.u[6642] = {n:"Krachtig Urandal Zwaard",t:6,d:"Dit zwaard is een erecadeau dat men alleen geeft aan volleerde huurlingen. Maar het snijdt ook heel goed.",ep:1,g:25,l:50,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[6643] = {n:"Modr IJsje",t:42,d:"Dit heerlijke ijs wordt op ambachtelijke wijze gemaakt op het Booden boerderijtje dat probeert de Boo verplicht te maken in alle ijsdesserts.",ep:13,g:143,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:150};
I.u[6644] = {n:"Wayal Hoorn",t:42,d:"Het bovenste deel van dit ijsje is geïnspireerd op de zeer beroemde hoed van de Wa, wat een tamelijk geslaagd effect geeft.",ep:13,g:144,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:120};
I.u[6646] = {n:"Bontarisch ijs",t:42,d:"Dit ijs, subtiele combinatie van twee fruitsmaken, toont \"alle know-how van de engelen\"... Nou ja, \'t is maar wat je wil geloven.",ep:13,g:145,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:90};
I.u[6647] = {n:"Brakmar Magma",t:42,d:"Dit ijsje, dat knapperig met zacht combineert, toont \"nog eens de superioriteit van de brAkmar\"... Nou ja, \'t is maar wat je wil geloven.",ep:13,g:146,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:90};
I.u[6648] = {n:"Rode Ballon",t:15,d:"Deze ballon is een souvenir van de Trool kermis.",ep:13,g:690,l:1,wd:true,fm:true,w:1,p:15};
I.u[6649] = {n:"Blauwe Ballon",t:15,d:"Deze ballon is een souvenir van de kermis van de trooll",ep:13,g:691,l:1,wd:true,fm:true,w:1,p:15};
I.u[6650] = {n:"Groene Ballon",t:15,d:"Deze ballon is een souvenir van de troolkermis",ep:13,g:692,l:1,wd:true,fm:true,w:1,p:15};
I.u[6651] = {n:"Gele Ballon",t:15,d:"Deze ballon is een souvenir van de troolkermis",ep:13,g:693,l:1,wd:true,fm:true,w:1,p:15};
I.u[6652] = {n:"Troolkermis Sneeuwbal",t:15,d:"Deze leuke sneeuwbal komt prachtig uit op de schoorsteenmantel.",ep:13,g:694,l:1,wd:true,fm:true,w:1,p:15};
I.u[6653] = {n:"Kaartje voor de Trool Kermis",t:24,d:"Met dit kaartje heb je toegang tot de kermis.",ep:13,g:94,l:1,wd:true,fm:true,w:0,p:1};
I.u[6654] = {n:"Riolerings Bestuurders Laarzen",t:11,d:"Het toppunt van absurdheid is dat de Riolerings Bestuurder verslonden is door de vrouwelijke Riolerings Bestuurder. Hij moest meer dan 100 jaar verwerkt worden voor hij eindelijk dood ging. Zijn laarzen waren gelukkig steviger dan hij en zijn ook nog steeds in goede conditie.",ep:16,g:28,l:83,wd:true,fm:true,w:10,p:17800};
I.u[6655] = {n:"Verrassende Gelukstas",t:89,d:"De personen die dit bij je bank hebben afgegeven, zijn echt genereus, en hebben hun vriendschap aan je willen betuigen. (DUBBELKLIK OM DE TAS TE OPENEN)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6656] = {n:"Verrassende Gelukstas",t:89,d:"De personen die dit bij je bank hebben afgegeven, zijn echt genereus, en hebben hun vriendschap aan je willen betuigen. (DUBBELKLIK OM DE TAS TE OPENEN)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6657] = {n:"Vervangingstas",t:89,d:"ne pas traduire ce texte.",ep:1,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[6658] = {n:"Gevulde Boowolf",t:61,d:"Deze Gevulde Boowolf zal je warm houden en verspreidt in je slaapkamer een plezierige geur van Dode Boowolf\'s transpiratie.",ep:13,g:699,l:1,wd:true,fm:true,w:10,p:1};
I.u[6659] = {n:"Nep Kwakwak",t:15,d:"Vertrouw het niet, deze kwakwak is een valse, geef hem aan Vrek Avare naast de Eendenstal om een beloning te krijgen.",ep:1,g:700,l:1,wd:true,fm:true,w:1,p:1};
I.u[6660] = {n:"Hoed van de Bruidegrom",t:16,d:"Wie kan er nou Nee tegen je zeggen met zo´n hoed?! Aan jou de Glorie en veroveringen!",ep:2,g:53,l:1,wd:true,fm:true,w:5,c:"PS=0",p:1000};
I.u[6661] = {n:"Kwakwak Hengel",t:20,d:"Met deze hengel kun je een kwakwak vissen in de kermisstand van Trool.",ep:13,g:8,l:1,wd:true,fm:true,w:10,an:18,e:[0,10,1,1,50,2,false,false],p:1};
I.u[6662] = {n:"Hoed van de Bruid",t:16,d:"Laat hem smelten als een muntgelei in de zon met die fantastische hoed van zijde van larven uit het zuiden, wasbaar met zoet water.",ep:2,g:54,l:1,wd:true,fm:true,w:5,c:"PS=1",p:1000};
I.u[6663] = {n:"Boeket van duivelse Rozen",t:6,d:"Met dit prachtige boeket van blaadjes van duivelse rozen kan je aan je geliefde laten zien dat je bereid bent 1000 en 1 gevaren te trotseren voor zijn of haar lieve smoeltje. En dat zonder je ook maar één keer Au te doen, voor een gering bedrag aangepast aan de kleine beurs.",ep:2,g:47,l:1,wd:false,fm:true,w:3,an:14,e:[1,4,1,1,50,50,false,true],p:70};
I.u[6664] = {n:"Speciale Kattiteit Toverschrifrol",t:75,d:"(Dubbelklik om de betovering te leren)\nDeze schriftrol stelt je in staat de betovering Kattiteit te leren...alleen voorbehouden aan Ecaflips.",ep:2,g:5,l:1,wd:true,fm:true,w:1,c:"PG=6",u:true,p:10000};
I.u[6666] = {n:"Tofu Lolly",t:42,d:"Deze heerlijke lolly heeft de smaak van Tofu-extract. Een feest voor je papillen, een ramp voor je adem.",ep:13,g:147,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:30};
I.u[6667] = {n:"Trool Lolly",t:42,d:"Een lolly die echt smaak heeft en die vooral eindeloos is. Bij voorkeur onder vrienden te nuttigen.",ep:13,g:148,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6668] = {n:"Tofu Hot Dog",t:42,d:"Deze nogal vette worst stelt je in staat op krachten te komen, om de andere worsten die je zojuist gegeten hebt te kunnen verteren.",ep:13,g:150,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6669] = {n:"Troolburger",t:42,d:"Deze indrukwekkende burger kan een heel leger uitgehongerde Chafers weer op de been krijgen. Met mate te gebruiken, want overmatig gebruik van Trool is schadeijk voor de gezondheid.",ep:13,g:149,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:600};
I.u[6670] = {n:"Wilde Zonnebloempatat",t:42,d:"Deze patat is gesneden uit de stengels van de Wilde Zonnebloem, vervolgens zijn ze gebakken in olie van de Wilde Zonnebloem, kwestie van dat ze zich een beetje thuis voelen terwijl ze gebakken worden.",ep:13,g:151,l:1,wd:false,fm:true,w:1,u:true,p:300};
I.u[6671] = {n:"Boon",t:58,d:"...",ep:1,g:471,l:1,wd:true,fm:true,w:1,p:1};
I.u[6672] = {n:"Xavier Bakkers Meel",t:52,d:"Dit meel is buitengewoon licht en fijn, en is bovendien zo zacht dat ze wordt gebruikt om de billetjes van jonge Iops droog te houden. Daarna wordt dit meel hergebruikt om zodoende meer smaak te geven aan het brood.",ep:1,g:250,l:100,wd:true,fm:true,w:1,p:0};
I.u[6673] = {n:"Zwarte Tofu Veer",t:24,d:"De veer van een Zwarte Tofu...",ep:1,g:96,l:1,wd:false,fm:true,w:0,p:1};
