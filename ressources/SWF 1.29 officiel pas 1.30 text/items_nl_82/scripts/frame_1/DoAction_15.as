I.u[6616] = {n:"Gevulde Xelor Dopple",t:61,d:"Deze Gevulde Xelor Dopple maakt een vreemd geluid. Hij heeft een klok in zijn Gevulde hoofd, een soort slaapliedje om jonge volgelingen van Xelor in slaap te zingen.",ep:13,g:683,l:1,wd:true,fm:true,w:10,p:1};
I.u[6617] = {n:"Volgepropt Zwijn",t:61,d:"Dit Gevulde Zwijn lijkt ongelooflijk veel op een volgepropt Zwijn. Erg indrukwekkend! De haren komen van een echt zwijn. Iets van echte kwaliteit.",ep:13,g:684,l:1,wd:true,fm:true,w:10,p:1};
I.u[6618] = {n:"Gevulde Tofu",t:61,d:"Wie heeft er nog nooit gedroomd dat hij een Tofu strak tegen zijn borst hield? Jij? Nou, in dat geval, je koopt echt alles of je vrienden hebben geen smaak als ze je wat aanbieden.",ep:13,g:685,l:1,wd:true,fm:true,w:10,p:1};
I.u[6619] = {n:"Gevulde Moes",t:61,d:"Deze Mush heeft geen pijnlijke doorn of verlammend gif. Maar hij is angstaanjagend genoeg om de stomste Iops bang te maken.",ep:13,g:686,l:1,wd:false,fm:true,w:10,p:1};
I.u[6620] = {n:"Gevulde Prespic",t:61,d:"Deze Gevulde Prespic heeft geen doorn en kan zichzelf niet onzichtbaar maken. Maar het is een leuk speeltje en maakt al je vrienden jaloers.",ep:13,g:687,l:1,wd:true,fm:true,w:10,p:1};
I.u[6621] = {n:"Gevulde Wabbit",t:61,d:"De Gevulde Wabbit is onvermijdbaar omdat hij nooit uit de mode raakt. In tegenstelling tot jou.",ep:13,g:688,l:1,wd:true,fm:true,w:10,p:1};
I.u[6622] = {n:"Ratel van de Donkere Vlad",t:15,d:"Deze ordinaire ratel behoorde ooit toe aan Donkere Vlad, wat genoeg is om het onbetaalbaar te maken.",ep:13,g:696,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6624] = {n:"Gevulde Draak Varken",t:61,d:"Dit Gevulde Draak Varken is uniek. Maar wees voorzichtig, het is enkel geschikt voor een passend publiek.",ep:13,g:689,l:1,wd:true,fm:true,w:10,p:1};
I.u[6625] = {n:"Kop-en-Ball van Heer Kraai",t:15,d:"Dit prachtige speeltje behoorde ooit toe aan Heer Kraai. Te stom om te begrijpen hoe het werkt gebruikte hij hem om zijn kleine kraaien te verpletteren. Iedereen heeft recht op tijdverdrijf.",ep:13,g:710,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6626] = {n:"Kapitein Chafer\'s springtouw",t:15,d:"Kapitein Chafer gebruikte dat springtouw om zijn vingergewrichten in vorm te houden. Sinds hij uit Amakna is verdwenen is het van hand tot hand gegaan.",ep:13,g:695,l:1,wd:true,fm:true,w:1,p:50};
I.u[6627] = {n:"Klein Veelkleurig Feewerk",t:74,d:"Dit Feewerk zal zelfs je meest onverschillige vrienden verblinden en verbazen. Erg bruikbaar om het vertrek van je gilde te vieren.",ep:1,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:350};
