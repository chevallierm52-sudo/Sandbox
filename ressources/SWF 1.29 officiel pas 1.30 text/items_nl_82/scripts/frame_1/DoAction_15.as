I.u[6677] = {n:"Krachtig Seriane-Kerm Zwaard",t:6,d:"Dit zwaard wordt als bewijs van eer cadeau gegeven alleen aan voortreffelijke huurlingen. Maar hij is ook heel erg scherp.",ep:1,g:25,l:70,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:10};
I.u[6679] = {n:"Feca Haarlok",t:24,d:"Een plukje haar van feca...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=1",p:1};
