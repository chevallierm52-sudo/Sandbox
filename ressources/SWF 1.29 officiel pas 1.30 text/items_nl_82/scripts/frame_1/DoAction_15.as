I.u[6685] = {n:"Eniripsa Haarlok",t:24,d:"Een pluk haar van Eniripsa...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=7",p:1};
I.u[6686] = {n:"Iop Haarlok",t:24,d:"Een plukje haar van een Iop...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=8",p:1};
I.u[6687] = {n:"Cra Haarlok",t:24,d:"Een haarlok van Cra...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=9",p:1};
I.u[6688] = {n:"Sadida Haarlok",t:24,d:"Een pluk haar van Sadida...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=10",p:1};
I.u[6689] = {n:"Sacrier Haarlok",t:24,d:"Een plukje haar van Sacrier...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=11",p:1};
I.u[6690] = {n:"Beschadigde schaar",t:80,d:"Een beschadigde schaar, niets over te vermelden.",ep:1,g:33,l:1,wd:true,fm:true,w:2,ut:true,p:1};
I.u[6706] = {n:"Com Pina Windsel",t:15,d:"Deze windsels zijn net zo out als hun eigenaar, en hijzelf net zo oud als zijn windsels. In de loop der tijd zijn ze doordrongen geraakt van de magische krachten van de Com Pina, maar ook van zijn geur van huis en ontbinding.",ep:1,g:712,l:150,wd:true,fm:true,w:1,p:1000};
I.u[6707] = {n:"Com Pina Cape",t:17,d:"Deze stinkende cape is gemaakt van de riekende windsels van Com Pina. Genoeg om de bewoners van de omliggende begraafplaatsen op te winden.",ep:14,g:63,l:75,wd:false,fm:true,w:10,p:14600};
I.u[6708] = {n:"Dopeul Certificaat",t:24,d:"Dit certificaat vermeldt de datum van je laatste overwinning op een Dopple.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6712] = {n:"Hucijn Cape",t:17,d:"Deze prachtige cape ruikt naar bosbloemen. Niet genoeg om een Craette gek op je te laten worden, maar genoeg om de geur van een vieze Sadida te verhullen.",ep:1,g:82,l:71,wd:true,fm:true,w:10,p:13100};
I.u[6713] = {n:"Lordsoth Dolken",t:5,d:"Deze dolken, doorweekt van het bloed van de vreselijke Lordsoth, hebben hem in staat gesteld de koning van de Chafers te vellen tijdens de beroemde wedstrijd dolkwerpen bij de Trool Kermis. De koning van de Chafers heeft sinds die dag nooit meer een stukje van zijn leren onderbroek durven tonen, en is met de illustere kapitein Chafer in ballingschap gegaan in de omgeving van het kerkhof van Pandala.",ep:1,g:34,l:100,wd:false,fm:true,w:10,an:13,e:[10,3,1,1,30,30,false,false],c:"PN~Lordsoth",p:1};
I.u[6716] = {n:"Nomoon",t:18,d:"Deze knijperige kleine aap schijnt je nou leuk te vinden. Hij is erg gedwee maar heeft een enorme eetlust. Hij eet alleen dingen die inheems zijn op zijn eigen eiland.",ep:3,g:11,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6717] = {n:"Zwarte Wafwaf",t:18,d:"Met deze kleine wafwaf, proef je de geneugten van kleine plasjeswandelingen. Wegens zijn sterke wilde wortels, wordt het afgeraden hem te eten te geven, op straffe van het verliezen van een hand.\n(DIT LEGENDARISCHE HUISDIER HOEFT NIET TE ETEN)",ep:1,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6718] = {n:"Witte MiauwMiauw",t:18,d:"Van dit ondeugende en aanhalige pluizebolletje is het vrouwenvolk kapot, ongeacht welke klasse. Een geducht dier dus. \n(DIT LEGENDARISCHE HUISDIER HOEFT NIET TE ETEN)",ep:1,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6719] = {n:"Berenman Muts",t:16,d:"Dit vreemde hoofddeksel heeft toebehoord aan de triest bekende Beren Man. Gemaakt van de overblijfselen van een rottende berenkop, stelt dit hoofddeksel je in staat niet ongezien te blijven en vooral, dankzij zijn originele geur, een spoor van je doorgang na te laten.",ep:1,g:64,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6720] = {n:"Berenman Cape",t:17,d:"Deze mooie cape werd vele jaren gedragen door de beroemde Berenman. Je wordt er geen beer mee, maar je kunt je wel meten met de grootsten.",ep:8,g:58,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6721] = {n:"Berenman Laarzen",t:11,d:"Deze laarzen zijn gevoerd met berenvacht. Goed om warme voeten te houden, zelfs als je een koudbloedig type bent.",ep:2,g:51,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6722] = {n:"Berenman Trouwring",t:9,d:"De Berenman heeft deze trouwring nooit afgedaan, ook al werd zijn vrouw voor zijn ogen door een van zijn bezworen beren verslonden. Alleen maar om indruk te maken op zijn geliefde. Ze was inderdaad zeer onder de indruk.",ep:1,g:66,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6723] = {n:"Berenman Amulet",t:1,d:"De Berenman droeg deze amulette om zijn nek toen hij de harnassen trotseerde in het hol van Bimdhoul. Volgens de legende heeft het zijn leven gered, maar als je het goed bekijkt, bemerk je dat het slechts een legende is.",ep:1,g:74,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6724] = {n:"Berenman Riem",t:10,d:"Deze berenharen riem is ideaal om je love handles te verbergen. Men raadt aan om hem nooit af te doen om je geliefde niet teleur te stellen.",ep:1,g:66,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6725] = {n:"Berenman Staf",t:4,d:"De Berenman gebruikte deze staf om zijn bezweerde beren te dresseren en soms om zijn kinderen op de vingers te slaan als deze niet hun huiswerk maakten als ze uit school kwamen. Dat is nog eens een man die begrijpt hoe je kinderen moet opvoeden.",ep:14,g:46,l:20,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CA>50&CV>50",s:12,p:1300};
I.u[6731] = {n:"IJs Amukwak",t:1,d:"Met dit amulet om je nek zou je je omgeving kunnen laten geloven dat je een frisse adem hebt. Laat maar zitten, vergeefse moeite.",ep:1,g:71,l:42,wd:true,fm:true,w:3,s:13,p:4900};
I.u[6732] = {n:"IJs Kwak Ring",t:9,d:"Deze kleine ring was vroeger zeer gewild bij de Enutrofettes die ze om hun tenen deden. Een uitstekende manier om hun wratten te verbergen.",ep:1,g:63,l:42,wd:true,fm:true,w:2,s:13,p:4900};
I.u[6735] = {n:"Ambusher Wortel",t:98,d:"Deze kleine wortel belichaamt verraad perfect. Niemand weet waarom, maar iedereen weet het.",ep:12,g:96,l:22,wd:true,fm:true,w:5,p:200};
I.u[6736] = {n:"Ambusher Knop",t:108,d:"Deze kleine Ambusher Knop bevat een klevend en siroopachtig sap. Als je het ongeluk hebt om op een oude Ambusher te stappen die verborgen zit in het hoge gras, blijf je mogelijk gevangen totdat hij je laarzen helemaal opgeslokt heeft. Aan de andere kant, als je een intacte Ambusher knop weet te pakken, zal je een zeurende Feca tot zwijgen kunnen brengen door het aan hem te geven als kauwgom.",ep:12,g:97,l:22,wd:true,fm:true,w:5,p:1};
I.u[6737] = {n:"Ambusher Schors",t:96,d:"De Ambusher heeft geen echte takken zoals elke andere zelfrespecterende boom. Echter, hij heeft een dunne schors die aardig uitgehard is en bedekt door een groot aantal knobbels. Erg handig om gereedschapshandvaten te maken die niet door je vingers glippen, of om op de achterkant van de meest brutale kinderen te slaan. In beide situaties ben je compleet tevreden als jij degene bent die het handvat vast heeft.",ep:12,g:98,l:22,wd:true,fm:true,w:5,p:200};
I.u[6738] = {n:"Schedel van de Chef Crocodyl",t:47,d:"Deze enorme schedel getuigt van de vreselijke mondhygiëne van de Chef Crocodyl. Wat wel leuk is, is dat het nog een zekere magie bezit, de geest van de Chef Crocodyl woont er nog in. Soms huilt hij nog grote Crocodylentranen als je niet lief tegen hem bent.",ep:4,g:637,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6739] = {n:"Crocodyle Huid",t:59,d:"Erin slagen een heel stuk Crocodylehuid te hebben is bijna een wonder, meestal nemen stropers slechts enkele schubben mee. Ideaal om een tas van te maken, maar deze oude huid zal ook de kleermakers die gevechtsondergoed maken blij maken.",ep:4,g:601,l:36,wd:true,fm:true,w:10,p:1000};
I.u[6740] = {n:"Chef Crocodyl Huid",t:59,d:"Deze huid, die bestaat uit een enorm aantal schubben, is in alle opzichten beter dan een klassieke Crocodyle-huid. De buitenkant van de huid van de Chef Crocodyl is namelijk steviger en bedekt met zeer scherpe puntige schubben, terwijl de binnenkant bijzonder zacht is. Men zegt dat sommige oude kleermakers de twee kanten verwarren bij het maken van ondergoed. De geschiedenis vertelt niet of hen dat meer of minder clientele bezorgt...",ep:4,g:600,l:69,wd:true,fm:true,w:10,p:1000};
I.u[6741] = {n:"Onzichtbare Kopknijper",t:16,d:"Deze kopknijper dient nergens voor.",ep:0,g:75,l:200,wd:false,fm:true,w:0,p:1};
I.u[6742] = {n:"Bedrieglijk Amulet",t:1,d:"Dit amulet is gemaakt van een mengsel van Schurkass-bladeren en afval van het Moon eiland. Het lijkt meer op een bloemenketting dan op een echt amulet, maar je kunt er met weinig moeite de lokale fauna van het Moon eiland mee verleiden, die voornamelijk uit gruwelijke wezens bestaat. Zo zal geen enkele Schurkass je kunnen weerstaan en je bespringen om je een zuigzoen te geven. De minder gelukkigen in de liefde kunnen hiermee een beetje hun hart ophalen.",ep:12,g:69,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6743] = {n:"Bedrieglijke Trouw Ring",t:9,d:"Men neme enkele Ambusher blaadjes, stapelt ze op een hoop, laat ze weken in oude alcohol, doorboor ze, drink de overgebleven alcohol, steek de blaadjes in een stukje schors, maak enkele stukjes Kokoko blaadjes klaar met een slijmerig materiaal en daar is een geweldige Bedrieglijke Trouw Ring. Het ruikt verschrikkelijk en zal erg handig zijn om de geur van je vingers te rechtvaardigen als je het gebruik hebt om ze overal te stoppen. Speciaal waar je dat niet zou moeten doen.",ep:12,g:60,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6744] = {n:"Ambusherlaarzen",t:11,d:"Als je deze laarzen eenmaal hebt aan gehad, kun je er niet mee weg gaan. Niet omdat ze zo bijzonder zijn, maar omdat ze zo kleverig zijn. Iets wat ze (te) vaak delen met de vrouwelijke Ambushers...",ep:12,g:47,l:34,wd:true,fm:true,w:5,s:16,p:3200};
I.u[6745] = {n:"Bedrieglijke Riem",t:10,d:"Bijzondere ambacht gemaakt van overblijfselen van Ambushers en afval opgepikt op de Maan stranden, in het middel van het gemene schuim, deze riem, als je hem alleen draagt, geeft je een verrassend uiterlijk. Genoeg om je vijanden in verlegenheid te brengen of om je geliefden te verrassen, je zult voordeel kunnen trekken uit dit speciale moment als jij voor één keer aan het langste einde trekt.",ep:12,g:62,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6746] = {n:"Aarde Amukwak",t:1,d:"Vroeger werd dit amuletje gedragen door Oto Mustam, oorlogschef van Brakmar, het diende alleen om hem mooi te maken tijdens de orgies die in Brakmar werden georganiseerd. Een heel programma.",ep:5,g:72,l:42,wd:true,fm:true,w:3,s:14,p:4900};
I.u[6747] = {n:"Wind Amukwak",t:1,d:"Als de wind door zijn veren waait, voelt de Wind Kwak zich zo vrij als een vogeltje en laat zich als een oud dood blad zweven, voortgedreven door een wervelwind. Integenstelling tot de heersende opvatting, is dat redelijk indrukwekkend..",ep:5,g:70,l:42,wd:true,fm:true,w:3,s:15,p:4900};
I.u[6748] = {n:"Aarde Kwak Ring",t:9,d:"Indien verstandig gedragen, kun je met deze ring je worstevingers verfraaien. Jammer genoeg voor sommigen, werkt het alleen maar voor vingers.",ep:5,g:64,l:42,wd:true,fm:true,w:2,s:14,p:4900};
I.u[6749] = {n:"Wind Kwak Ring",t:9,d:"Deze ring is zo licht, dat hij makkelijk kan wegvliegen bij de eerste windvlaag. Maar reken daar maar niet op, als het gebeurt, vlieg jij niet mee. In het beste geval zullen ze je uitlachen.",ep:5,g:62,l:42,wd:true,fm:true,w:2,s:15,p:4900};
I.u[6750] = {n:"IJs Kwak Lemmet",t:6,d:"Dit koude en scherpe lemmet ontwaakt de meest primitieve instincten van degenen die het gebruiken.",ep:1,g:51,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CC>50&CV>50",s:13,p:4600};
I.u[6751] = {n:"Aarde Kwak Lemmet",t:6,d:"\"Dit scherpe maar niet vermomde lemmet, is prima voor  avonturiers met ervaring en die op zoek zijn naar nieuwe indrukken. \"Dit kan men lezen in de gebruiksaanwijzing van dit zwaard. De gebruiksaanwijzingen zijn duidelijk niet meer wat ze geweest zijn.",ep:5,g:53,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>50&CV>50",s:14,p:4600};
I.u[6752] = {n:"Wind Kwak Lemmet",t:6,d:"Ideaal om wolken te snijden, maar dit lemmet kan ook worden gebruikt als waaier om jezelf een beetje frisse lucht te geven. Het is ook een uitstekende techniek om Moskitos uit te roeien of om je vrienden te verminken.",ep:5,g:50,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CA>50&CV>50",s:15,p:4600};
I.u[6753] = {n:"IJs Kwak Laarzen",t:11,d:"Ideaal als schaats op de bevroren meren.Deze laarzen zijn ook erg nuttig om je voeten fris te houden, of om er je twaalfuurtje in te bewaren op warme dagen. Het is echter af te raden ze te laten drogen bij de open haard, want dan zul je ze nooit meer terugzien.",ep:2,g:36,l:40,wd:true,fm:true,w:5,s:13,p:4400};
I.u[6754] = {n:"Aarde Kwak Laarzen",t:11,d:"\"Er is niets beters dan om met Aard Kwak Laarzen op het land te struinen\", aldus het devies van Rola Ingalsse de beroemde ploegster, net voordat ze blind werd toen ze een grote aardkluit tegen haar ogen kreeg.",ep:5,g:49,l:40,wd:true,fm:true,w:5,s:14,p:4400};
I.u[6755] = {n:"Wind Kwak Laarzen",t:11,d:"Primitief maar doeltreffend, worden deze verbazingwekkend lichte laarzen soms gebruikt na ze bewerkt te hebben tot windzak om de richting en kracht van de wind aan te geven. Daarom wordt aangeraden om aan de juiste kant van de windzak te gaan staan, om verstikking te voorkomen.",ep:5,g:48,l:40,wd:true,fm:true,w:5,s:15,p:4400};
I.u[6756] = {n:"Aarde-Kwape",t:17,d:"Ideaal voor camouflage in een kluit aarde, kan je met behulp van deze cape de landarbeiders bij verrassing aanvallen en hun beroven van hun rijkdommen. Hij is dus met name gereserveerd voor de verzamelaars van vuursteen.",ep:8,g:64,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6757] = {n:"Wind-Kwape",t:17,d:"Licht en geraffineerd, kan deze creatie eventueel dienen als gordijn voor de meest armlastige. Hij werd vroeger zeer begeerd door de Com Pina zelf, die correct gekleed wenste te zijn als hij \'s avonds uit ging. Een voorbeeld dat sommigen zouden kunnen volgen.",ep:8,g:62,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6758] = {n:"Aarde Kwaktuur",t:10,d:"De Aarde Kwak is niet erg sociaal en men jaagt vooral op hem vanwege zijn veren, dat is algemeen bekend. Als je deze riem om je middel draagt, stel je je bloot aan menig bedrog van de kant van de Aarde Kwakjagers, die je zullen aanzien voor een oude krakkemikkige Kwak op zijn retour. Schijn bedriegt niet altijd.",ep:12,g:65,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6759] = {n:"Wind Kwaktuur",t:10,d:"\"De enige manier om een oud ontstemd mannetjes Wind Kwak te vangen, is door je te verkleden als een ontstemd vrouwtjes Wind Kwak. Dan, als het mannetje probeert te begrijpen waarom het vrouwtje ontstemd is, zal hij met alle mogelijke middelen waarover hij beschikt, proberen het vrouwtje te bevredigen. Als het mannetje eenmaal tevreden is over zijn prestatie, moet je van zijn gelukzaligheid profiteren en hem ontdoen van zijn veren.\" Dit kan men lezen in deel twaalf van boek drie over de jacht op de Wind Kwaks. Daarin wordt duidelijk aangegeven dat deze riem een noodzakelijk element is om jezelf voor te doen als een vrouwtjes Wind Kwak. Je weet nu wat je te doen staat.",ep:12,g:63,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6760] = {n:"Aarde Kwak Muts",t:16,d:"Deze muts van de Aardekwak is zo zwaar dat je daarmee altijd de voeten aan de grond houdt, maar hij kan je soms ook doen omvallen. Je kan niet alles hebben.",ep:13,g:71,l:41,wd:true,fm:true,w:25,s:14,p:4600};
I.u[6761] = {n:"Wind Kwak Muts",t:16,d:"Om de haren in de wind te kunnen houden, zelfs met een muts op, gaat er niets boven deze sympatieke Wind Kwak Muts, die je zonder enige twijfel in staat stelt je elk kapsel te dragen in bijna alle omstandigheden. Dat is voldoende om de meest onverschillige Chafers met de mond vol tanden te laten staan.",ep:13,g:69,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6762] = {n:"Ambusher-op",t:4,d:"“Voor een por, gaat er niets boven een Ambusher-op.” Dit zou gelezen kunnen worden op het reclame pamflet van het A-Team Reisbureau, welke zijn klanten aanbood om deze staf te herbouwen van diverse bronnen rondgestrooid op Maan Eiland. Een beetje als schatjagen maar er zijn geen kaarten.",ep:12,g:44,l:32,wd:true,fm:true,w:5,e:[15,4,1,1,20,70,false,false],s:16,p:2900};
I.u[6763] = {n:"Ambusherot",t:17,d:"Zoals het verhaal vertelt zijn dode Ambushers erg comfortabel wanneer ze onder de zon gerot zijn. Mettertijd worden ze inderdaad flexibeler en zachter. Vele avonturiers zouden maar wat graag hetzelfde over hun geliefden willen kunnen zeggen.",ep:12,g:61,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6764] = {n:"Ambushhoofddeksel",t:16,d:"Dit hoofddeksel geeft je niet bepaald een slimme uitstraling, wel? Maar je ziet er hoe dan ook minder stom uit met dat ding op. Dus ophouden!",ep:12,g:68,l:31,wd:true,fm:true,w:5,s:16,p:2800};
I.u[6765] = {n:"Memelk",t:79,d:"Let op, er staat duidelijk op de verpakking deze melk niet te geven aan een jonge Miauwmiauw, hij zou enkele vlekken in je woning kunnen maken.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:4};
I.u[6766] = {n:"Aren van Farle",t:1,d:"Dit op het oog primitieve amulet is gemaakt van drie magische tarwe-aren, bedekt met het stof van edelstenen en gekapt in de laagvlakten van Snossius gedurende de dertiende oogst van Istrabraq. Hij geeft buitengewone moed aan zijn drager, die daarmee in staat is laagvlakten en valleien te maaien zonder ooit te falen.",ep:1,g:68,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6767] = {n:"Magische Farle Armband",t:9,d:"Deze armband van edelstenen was bedekt met een hennepdoek van Shika, om te voorkomen dat hij de aandacht van de Raven zou trekken, terwijl Farle zijn gerst zaaide.",ep:13,g:61,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6768] = {n:"Soki",t:32,d:"Je neemt deze ongelukkige miauwmiauw mee om hem af te leiden.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[6769] = {n:"Farle Staf",t:4,d:"Deze prachtige staf is aan beide einden voorzien van erg mooie tanden, zodat hij goed dienst kan doen als landbouwvork. Farle maakte er enorme hooibergen mee, hoger dan de grootste Iepen die vroeger in het Egidraa Bos  groeiden. Men vertelt dat Brouce Boulgoure persoonlijk het hout, dat hij nodig had om deze staf te maken, had gekapt in ruil voor de monsterlijke dagelijkse hoeveelheden havermout, aangeboden door Shika Ingalsse, die hij verzwolg alvorende hele bossen met de grond gelijk te maken.",ep:14,g:43,l:80,wd:true,fm:true,w:10,an:12,tw:true,e:[10,5,1,1,45,45,false,true],c:"CS>100&CV>100",s:17,p:16500};
I.u[6770] = {n:"Muimuis",t:15,d:"Deze Muimuis is met een bezemzwaai het huis van Grootmoeder uitgegooid.",ep:1,g:282,l:1,wd:true,fm:true,w:10,p:1};
I.u[6771] = {n:"No Thee Ring",t:9,d:"Deze ring heeft zich nog niet bewezen. Het is een unieke vervaardiging, gemaakt door een leerling juwelier ter gelegenheid van een belangrijke test. Hij is gemaakt op basis van een ring van klassiek ijzer gedoopt in een oplossing van magische Thee.",ep:1,g:1,l:4,wd:false,fm:true,w:1,p:50};
I.u[6773] = {n:"Tude Amulet",t:1,d:"Dit amulet is gemaakt op Tude wijze, vandaar zijn naam. Het is één van de eerste vervaardigingsmethodes die men, omdat het één van de eenvoudigste is, aan leerling juweliers leert. Dit product is zeker niet machtig, maar men moet er dan ook niet teveel van verwachten.",ep:1,g:19,l:1,wd:false,fm:true,w:1,p:25};
I.u[6774] = {n:"Farles Klompen",t:11,d:"Deze klompen zijn van zeldzaam hout gemaakt en versterkt met waardevol leer en gevuld met magische granen. Zowel licht, elegant als comfortabel kunnen deze klompen de kwellingen der tijd weerstaan. Veel vrouwonvriendelijke avonturiers zouden graag hetzelfde willen zeggen over hun geliefden.",ep:9,g:46,l:80,wd:true,fm:true,w:10,s:17,p:16600};
I.u[6775] = {n:"Farle Cape",t:17,d:"Met deze cape van stof en leer kon Farle Ingalsse hele velden inzaaien tijdens een heel seizoen zonder ooit te hoeven stoppen. Eenmaal opgevouwen kon hij dienst doen als grote reiszak. Niemand kent de kleermaker die dit wonder mogelijk maakte, de legende vertelt alleen dat hij zich uit zijn beroep heeft teruggetrokken toen zijn klanten zijn capes verwarden met dweilen. Wat een triest einde van zo\'n fijn beroep !",ep:13,g:70,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6776] = {n:"Farlatuur",t:10,d:"Deze riem deed tevens dienst als slagersschort van Farle Ingalsse als hij zijn Veelvraatkudde moest slachten. Een ondankbare en wrede taak, waar hij zich overigens met merkbaar plezier van wist te kwijten.",ep:4,g:61,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6778] = {n:"Farle Hoed",t:16,d:"Deze strooien hoed is gemaakt van magische gevlochten aren, en de binnenkant is opgevuld met diverse haren en door Shika Ingalsse, de vrouw van Farle, met de hand gestikte gestoffen. Met veel meer klasse dan de Sukel en veel meer stijl dan de Knudduh.Deze hoed beschermt je tegen de hitte zoals hij dat ook deed voor Farle tijdens een hondertal oogsten. En je ziet er ook vrolijk en cool mee uit. In ieder geval genoeg om je als veldkoning of veldkoningin te gedragen.",ep:13,g:67,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6779] = {n:"Rapport van de spion Sram",t:24,d:"Rapport van de spion Ztiv Oztin, met enige moeite bemachtigd uit de handen van Joe Steenknoeier.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6780] = {n:"Zwaard van de ingewijde",t:6,d:"Dit primitief uitziende wapen geeft je de indruk dat je kunt vechten.",ep:1,g:96,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6781] = {n:"Stok van de Ingewijde",t:3,d:"Dit primitief uitziende wapen geeft u de indruk dat u kunt vechten.",ep:1,g:8,l:1,wd:true,fm:true,w:10,an:11,e:[5,4,2,3,50,50,false,true],p:1};
I.u[6782] = {n:"Staf van de ingewijde",t:4,d:"Dit wapen, dat er primitief uitziet, zal de indruk wekken dat je goed kunt vechten.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6783] = {n:"Boog van de ingewijde",t:2,d:"Dit wapen, dat er primitief uitziet, zal de indruk wekken dat je goed kunt vechten.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,6,50,50,false,true],p:1};
I.u[6784] = {n:"Dolk van de ingewijde",t:5,d:"Dit wapen, dat er primitief uitziet, zal de indruk wekken dat je goed kunt vechten.",ep:1,g:10,l:1,wd:true,fm:true,w:10,an:13,e:[5,3,1,1,30,50,false,false],p:1};
I.u[6785] = {n:"Hamer van de ingewijde",t:7,d:"Dit ogenschijnlijk primitieve wapen geeft de indruk dat je kunt vechten.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:15,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6786] = {n:"Schep van de ingewijde",t:8,d:"Dit primitief uitziende wapen geeft u de indruk dat u kunt vechten.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6787] = {n:"Geldig ingevulde kaart",t:80,d:"Dit kaartje bevat de naam van een potentiële kandidaat voor bezorger van de bakker.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW>1499&CA>49",p:0};
I.u[6788] = {n:"Taarten",t:24,d:"Deze taarten komen net uit de oven. Ze moeten afgeleverd worden terwijl ze nog warm zijn. Denk je nou echt dat je genoeg tijd hebt om ze zo te bestuderen?",ep:1,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[6789] = {n:"Veld Amulet",t:1,d:"Dit kleine amulet bloeit in het voorjaar, maar verdroogt in de zomer, verwelkt in de herfst en rot in de winter. Een geweldige gelegenheid om je look aan te passen aan het seizoen.",ep:1,g:73,l:10,wd:false,fm:true,w:5,s:18,p:500};
I.u[6790] = {n:"Invulformulier",t:80,d:"Dit invulformulier lijkt een eenvoudig blaadje, echter eenmaal in contact met iemands huid, geeft het blad onmiddellijk aan of iemand aan de criteria voldoet die bovenaan het formulier zijn gesteld.",ep:1,g:6,l:1,wd:false,fm:true,w:0,ut:true,p:0};
I.u[6791] = {n:"Buiten Ring",t:9,d:"Met deze ring om je vinger kun je bijna ongemerkt door de velden en akkers lopen.",ep:1,g:65,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6792] = {n:"Veld Staf",t:4,d:"Deze bloemvormige staf is gemaakt van overblijfselen van veldbloemen die tijdens verschrikkelijk wrede gevechten zijn gesneuveld. Alle woede en haat van deze arme planten zit in deze belachelijk kleine staf. Dit wapen wordt gebruikt door de meest bedriegelijke Srams, die onwetende en domme dames proberen te overtuigen dat ze hen een bloemboeket willen aanbieden. Eenmaal binnen handbereik, ontvangt de ontwetende domme dame een welverdiende klap op het hoofd.",ep:1,g:45,l:10,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,45,50,false,false],c:"CV>20",s:18,p:500};
I.u[6793] = {n:"No Thee Ring",t:9,d:"Deze ring heeft zich bewezen, dat kun je zien aan een merktekentje aan de binnenkant. Het is een unieke vervaardiging, gemaakt door een leerling juwelier ter gelegenheid van een belangrijke test. Hij is gemaakt op basis van een ring van klassiek ijzer gedoopt in een oplossing van magische Thee.",ep:1,g:1,l:4,wd:true,fm:true,w:1,p:50};
I.u[6794] = {n:"Veld Laarzen",t:11,d:"Niets beter dan een paar laarzen gemaakt van overgebleven veldbloemblaadjes om de ellendige veldbloemen in je akkers plat te trappen. Bovendien, met deze laarzen ruiken je voeten eindelijk heerlijk. Jammer dat er niet zoiets bestaat voor onderbroeken.",ep:1,g:50,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6795] = {n:"Paarse Cape",t:17,d:"Als je de mooiste wilt zijn op het bal, dan moet je deze cape hebben.",ep:1,g:65,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6796] = {n:"Gebloemde Riem",t:10,d:"Met deze met bloemblaadjes versierde riem om je middel kun je zonder probleem je voordoen als een primaballerina te midden van een gevecht waarvan van te voren vaststaat dat je gaat verliezen.Zo kun je dus een leger Chafers uit het veld slaan en zodoende het gevecht weer in jouw voordeel doen keren.",ep:1,g:64,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6797] = {n:"Veld Muts",t:16,d:"Als je er altijd van gedroomd hebt om bloemist te worden en een adem te hebben die naar rozenwater ruikt, dan is dit je kans.",ep:1,g:70,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6798] = {n:"Dizbi Bloem",t:24,d:"Zijn geur is licht, subtiel, bedwelmend...Maar alleen de Sadidas kennen het geheim van deze bloemen.",ep:1,g:117,l:1,wd:false,fm:true,w:0,p:1};
I.u[6799] = {n:"Lemmet van de Bwork Chef",t:6,d:"Dit lemmet van de Bwork Chef, snijdend als het lemmet van een Bwork, heeft het voordeel veel zwaarder te zijn. Hij is absoluut moeilijker te hanteren, maar het is voldoende hem op zijn tegenstander te laten vallen om hem doormidden te klieven, net zoals een alledaagse snee van een Stamchnid. Als je vijand niet van pijn sterft, gaat hij wel dood van schaamte, en jij lacht je dood.",ep:1,g:48,l:100,wd:true,fm:true,w:100,an:14,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>200&CA>200&CV>200",s:19,p:25000};
I.u[6800] = {n:"Gewone Cape",t:17,d:"Deze cape is van Vreetzakjes-wol gemaakt. Hij dient nergens voor, behalve om er goed uit te zien... En dan nog...",ep:1,g:15,l:1,wd:true,fm:true,w:1,p:1};
I.u[6801] = {n:"Winterse Cape",t:17,d:"Een leuke, zeer warme en zeer sterk geurende voering is op bewonderenswaardige wijze aan een alledaagse cape genaaid. Om je schouders, of als berenvel voor de open haard, zal deze cape eindelijk nuttig zijn.",ep:1,g:18,l:1,wd:true,fm:true,w:2,p:1};
I.u[6802] = {n:"Oorwarmer",t:16,d:"Met deze zachte oorwarmer blijven je flaporen lekker warm.",ep:1,g:73,l:1,wd:true,fm:true,w:10,p:1};
I.u[6803] = {n:"Dizbi Bloem Extract",t:24,d:"Vermijd hiervan te drinken... eenvoudig!",ep:1,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[6804] = {n:"Amulet van de Chef Bwork",t:1,d:"Dit amulet in de vorm van geslepen vuursteen ziet er primitief uit, maar is toch voorzien van een zeer sterke toverkracht die een Bwork in een prinses kan veranderen, of omgekeerd, niemand weet het.",ep:1,g:66,l:100,wd:true,fm:true,w:1,s:19,p:25600};
I.u[6805] = {n:"Armband van de Chef Bwork",t:9,d:"Gewapend met dit ringetje kan je je omgeving laten geloven dat je met een grote Chef Bwork bent getrouwd en dat hij je deze armband heeft gegevens als huwelijkscadeau. Iets om jezelf interessant te maken tijdens de geanimeerde feestavonden in de Herberg als je niet veel hebt om over te praten.",ep:1,g:58,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6806] = {n:"Houten Fragment",t:24,d:"Dit houten fragment is afkomstig van een recente constructie, waarschijnlijk rood.",ep:1,g:246,l:1,wd:false,fm:true,w:0,p:1};
I.u[6807] = {n:"Laarzen van de Chef Bwork",t:11,d:"Van veraf lijken deze laarzen op klassieke Bwork laarzen. Van dichtbij ook. En toch zijn het laarzen van Chef Bwork. Omdat ze sterker en krachtiger zijn en meer stinken, zullen ze het verschil uitmaken in een bij voorbaat verloren strijd.",ep:1,g:44,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6808] = {n:"Afgescheurd stukje stof",t:24,d:"Dit witte stukje stof is tegelijkertijd heel zacht en erg bezoedeld.",ep:1,g:247,l:1,wd:false,fm:true,w:0,p:1};
I.u[6809] = {n:"Vage omschrijving",t:24,d:"Deze omschrijving beschrijft een klein meisje gekleed in een donkere kleur en met blonde haren.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6810] = {n:"Wijkactiviteitenrapport",t:24,d:"In dit rapport staat dat er geen voorval is geconstateerd in de wijk op de dag van de diefstal van het huis. Behalve het visioen van een gladjanus in de nacht van het voorval.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6811] = {n:"Chef Bwork Cape",t:17,d:"Deze gescheurde cape vol met gaten zal je doen lijken op een grote Bwork-strijder. Hij is perfect als je de oudjes van het dorp wil terroriseren. Daarentegen wordt het waarschijnlijk wat moeilijk een zusterziel te verleiden, tenzij je hem draagt terwijl je helemaal naakt bent, waarbij je bovendien nog steeds de oudjes van het dorp kunt laten schrikken.",ep:1,g:60,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6812] = {n:"Onderbroek van de Chef Bwork",t:10,d:"Deze onderbroek van paars leer is op zichzelf al voldoende, je kunt ermee volstaan alleen dit te dragen, je zult er toch trots uitzien, op voorwaarde dat hij de juiste maat is en dat hij je niet van de kont zakt tijdens een iets te beweeglijk potje touwtje springen.",ep:1,g:59,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6813] = {n:"Chef Bwork Helm",t:16,d:"Als je nou echt met een debiel hoofd wil rondlopen, is deze helm perfect voor je. Met een beetje geluk ziet men niet eens het verschil als je hem afzet.",ep:1,g:65,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6814] = {n:"Geheel van stukjes hout",t:24,d:"Dit geheel van stukjes hout maakt een lekker zacht bedje, ideaal voor een Piwi.",ep:1,g:248,l:1,wd:false,fm:true,w:0,p:1};
I.u[6815] = {n:"Injectienaald van Eli Bel",t:24,d:"Eli Bel heeft je deze injectienaald gegeven om een bloedmonster te nemen van Radly Minite de Duistere Mijnwerker.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6816] = {n:"Bloed Monster",t:24,d:"Het is je eindelijk gelukt een bloedmonster te nemen van Radlu Minite. Zeer appetijtelijk.",ep:1,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[6817] = {n:"Chef Crocodyls Amulet",t:1,d:"Dit wonderlijke amulet is gemaakt van een Reptielenschild, waarvan men de vele edelstenen heeft afgehaald. Het is dus een bijzonder zwaar sieraad om te dragen, maar is werkelijk heel erg sterk. Je hals zal volledig beschermd zijn tegen vampiers, maar ook tegen de zuigzoenen van de al te ondernemende dorpsbewoonsters.",ep:4,g:67,l:70,wd:true,fm:true,w:100,s:20,p:12700};
I.u[6818] = {n:"Afgeknipte Duivelse Roos",t:35,d:"Deze bloem, die vroeger duivels was, is tegenwoordig een engelachtig cadeau voor een persoon. Dit gezegd hebbende, als je er slechts een neutrale blik voor terug krijgt, kan je er altijd nog jam van maken.",ep:1,g:118,l:1,wd:false,fm:true,w:1,p:1};
I.u[6819] = {n:"Chef Crocodyl Armband",t:9,d:"Deze armband lijkt veel op een handschoen en toch is het geen handschoen maar een armband. Uiterlijk bedriegt.",ep:4,g:59,l:70,wd:true,fm:true,w:20,s:20,p:12800};
I.u[6820] = {n:"Geneeskruid",t:24,d:"Dit kruid is het belangrijkste ingrediënt van oude geneesmiddelen van de alchemist. Het wordt tegenwoordig helemaal niet meer gebruikt. Men neemt liever het klavertje omdat dat geen jeuk in het gezicht veroorzaakt, wat, dat moet toegegeven worden, een pluspunt is.",ep:1,g:103,l:1,wd:true,fm:true,w:0,p:1};
I.u[6821] = {n:"Chef Crocodyl Lemmet",t:6,d:"Dit wapen, gemaakt van de brokstukken die gevonden zijn op een Chef Crocodyl, is heel doeltreffend als je redelijk mooi, behendig, intelligent en sterk genoeg bent om hem te hanteren. Met een beetje mazzel vind je wel iemand die hem wil ruilen voor een houten zwaard.",ep:4,g:49,l:70,wd:true,fm:true,w:100,an:14,e:[12,6,1,1,40,40,false,false],c:"CA>150&CC>150&CV>100",s:20,p:12800};
I.u[6822] = {n:"Ontwaakinjectie",t:24,d:"Deze injectie bevat een zo sterk medicijn dat het een dode weer zou kunnen wekken. Overigens schijnt het dat de illustere levende dode Hyrkul zich er regelmatig mee injecteerde. Een sterker bewijs van haar doelmatigheid kan je niet vinden.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6823] = {n:"Toverdrank op basis van planten",t:24,d:"Deze toverdrank, met misselijkmakende geur, zou een sadida uit zijn siesta kunnen wekken... Of bijna... Als de sadida jong is en op het punt staat wakker te worden.",ep:1,g:500,l:1,wd:true,fm:true,w:0,p:1};
I.u[6824] = {n:"Vluchtige Zorg Steen",t:24,d:"Deze zorgsteen verliest zijn kracht heel snel, je moet een metaal eromheen doen dat bepaalde stralingen absorbeert, om het effect van de steen te bewaren om zo zijn effectiviteit te handhaven. Men heeft deze liever dan de standaard amuletten die bijna even efficient en zeker veel goedkoper zijn.",ep:1,g:104,l:1,wd:false,fm:true,w:0,p:1};
I.u[6825] = {n:"Chef Crocodyls Scherpe Pantoffels",t:11,d:"Deze prachtige pantoffels zijn gemaakt van de huid en de schubben van de Chef Crocodyl en zijn voorzien van scherpe tanden. Kijk dus uit als je voetje vrijt met je geliefde, want je zou wel eens haar Tabi-wollen kousen kapot kunnen maken.",ep:4,g:45,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6826] = {n:"Gezette Zorgsteen",t:24,d:"Deze amulet is een vluchtige zorgsteen gezet in een stukje zeldzaam metaal. Hem in je hand vasthouden veroorzaakt een gevoel van welbehagen, vermoeidheid verdwijnt en je hoofd is leeg. En bovendien kan men je ermee in het donker zien.",ep:1,g:105,l:1,wd:false,fm:true,w:0,p:1};
I.u[6827] = {n:"Brief van Joe Steenknoeier",t:24,d:"Joe heeft je deze brief toevertrouwd opdat je hem naar een goede vriend van hem brengt, Howard de Jamaarnee, een Iop die... hoe zal ik het zeggen... nou ja, een Iop!",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6828] = {n:"Zwaardheft",t:24,d:"Dit zwaardheft zal je niet veranderen in de nummer één zwaardvechter maar het kan je erbij helpen.",ep:1,g:97,l:1,wd:false,fm:true,w:0,p:1};
I.u[6829] = {n:"Zojuist gesmeed Zwaard",t:24,d:"Dit zwaard is zojuist gesmeed.",ep:1,g:98,l:1,wd:false,fm:true,w:0,p:1};
I.u[6830] = {n:"Kleine schooltas van de Chef Crocodyl",t:81,d:"Ook in Amakna is het nieuwe schooljaar een pijnlijke opgave voor de jonge kinderen. Vooral voor de jonge Iops, voor wie het begin van het nieuwe schooljaar een echte lijdensweg is. Beur ze op met deze schitterende schooltas van leer en schubben van de Chef Crocodyl en gevuld met vele haren.",ep:14,g:58,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6831] = {n:"Chef Crocodyl Riem",t:10,d:"Te stijf om als zweep te kunnen fungeren, kan deze met edelstenen bedekte riem op een conventionele manier gebruikt worden, bijvoorbeeld om te voorkomen dat je slobkousen afzakken.",ep:4,g:60,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6832] = {n:"Bier Bezorger",t:32,d:"De bierbezorger is net zo belangrijk als een begeleider van een geldtransport. Behalve dan dat hij veel kribbiger is.",ep:1,g:15,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6833] = {n:"Twijfelachtige Kamas beurs",t:24,d:"Deze kamas lijken uit een andere tijd te komen, je moet ze snel smelten voordat ze besluiten weer terug te gaan naar waar ze vandaan komen.",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6834] = {n:"Chef Crocodyl Muts",t:16,d:"Als je altijd al op een Crocodyl hebt willen lijken zonder er werkelijk een te worden, dan is deze muts geschikt. Denk niet dat je vrienden denken dat je ooit een Crocodyl gedood hebt, als je deze muts op hebt. Niemand zal je geloven, behalve misschien alleen jij zelf.",ep:4,g:66,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6835] = {n:"Getransmuteerd metaal",t:24,d:"De twijfelende kamas-beurs is handig getransmuteerd door Eli Bel. Voortaan is een zwaard klaar om met dit metaal gemaakt te worden...",ep:1,g:241,l:1,wd:true,fm:true,w:0,p:1};
I.u[6836] = {n:"Rudimentair Zwaard",t:24,d:"Dit is een zwaard dat door Twehfingas gesmeed is, maar het lijkt nog te zwak voor jou. De alchemist Eli Bel zou er wat mee moeten kunnen doen.",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6837] = {n:"Huppelzwaard",t:24,d:"Een zwaard dat voor jou gemaakt lijkt te zijn, licht en ontzagwekkend. Maar er ontbreekt een final touch aan, iets Ecaflips...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6838] = {n:"Rudimentair Vuurzwaard",t:24,d:"Het maanwater schijnt zijn effect te hebben. Dit zwaard is van een alles weerstaanbare stevigheid, maar er ontbreekt iets Ecaflips...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6839] = {n:"Yingnitie Zwaard",t:6,d:"Dit door Meow Meow (Miauw Miauw) gewaarmerkte wapen zou van jou een legendarische Ecaflip kunnen maken, eventueel...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=0",p:1};
I.u[6840] = {n:"Yanguru Zwaard",t:6,d:"Dit door MiauwMiauw gewaarmerkte wapen zou van jou een legendarische Ecaflip kunnen maken, eventueel...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=1",p:1};
I.u[6841] = {n:"Beren Stof",t:55,d:"Deze vreemde stof ruikt naar Beer. Genoeg om een niet onbelangrijk deel van het vrouwelijke geslacht te doen wankelen.",ep:1,g:121,l:22,wd:true,fm:true,w:1,p:500};
I.u[6842] = {n:"Beren Tand",t:47,d:"Deze vreemde tand heeft aan een oude Beer toebehoord. Of liever gezegd, aan een bezwering van een Beer, wat, dat moet je toegegeven, iets totaal anders is, want in feite heb je in je handen een bezworen tand. Heel interessant.",ep:1,g:432,l:22,wd:true,fm:true,w:1,p:500};
I.u[6843] = {n:"Beren Bot",t:47,d:"Dit puntige bot is gebroken tijdens een vreselijk gevecht tegen één van de beren, opgeroepen door de BerenMan. Het was te laat nog gips om de poot van deze arme Beer te doen, die kreunend van de pijn verging door jouw herhaalde aanvallen. Je hebt ervoor gekozen hem een langzame dood te bezorgen door hem in Veelvraatspeeksel te laten stikken, hem aan stukken te hakken en vervolgens dit bot uit hem te trekken terwijl hij nog bij bewustzijn was. Geen medelijden voor de aangeroepenen.",ep:1,g:48,l:22,wd:true,fm:true,w:1,p:500};
I.u[6844] = {n:"Beren Haar",t:54,d:"Soms besluit de BerenMan één van zijn Beren-aanroepingen te epileren, voor de lol of om de tijd te verdrijven. Hij verzamelt vervolgens de haren om er kwaliteitsondergoed van te maken, zeer gewaardeerd door eenzame jagers die aangetrokken worden door het gevoel en de sterke geur.",ep:1,g:195,l:22,wd:true,fm:true,w:1,p:500};
I.u[6845] = {n:"Beren Huid",t:59,d:"Deze ruwe en kale huid is het resultaat van het lang en intensief waxen met gekookte olie en een brandijzer. Kijk daarom niet vreemd op dat hij een beetje aangebrand ruikt.",ep:1,g:35,l:22,wd:true,fm:true,w:1,p:500};
I.u[6846] = {n:"Kristallen flesje van licht Anthir",t:24,d:"Op het eerste gezicht gewoon flesje. Het bezit evenwel een kracht die alleen de Xelors weten uit te buiten.",ep:1,g:99,l:1,wd:false,fm:true,w:0,p:1};
I.u[6847] = {n:"Zak Epyss Graan",t:24,d:"Nogal zeldzaam graan, dat niet erg nuttig is. Wie zei zoals de Xelors?!",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6848] = {n:"Versierd Bos",t:24,d:"Bos van middelmatige makelij.",ep:1,g:100,l:1,wd:false,fm:true,w:0,p:1};
I.u[6849] = {n:"Doos van Subosycold",t:24,d:"De enigen die de gebruiksaanwijzing kennen zijn de Enutrofs. Misschien wel eenvoudigweg omdat men liever niet te veel weet over hun geheimen... En wat voor een geheimen!!!",ep:1,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[6850] = {n:"Pizzhap",t:24,d:"De pizzhap, één van de culinaire specialiteiten van Astrub, heeft het voordeel dat hij overal en altijd gegeten kan worden, met uitzondering misschien van de wijk van de slagers want daar is de lucht onverdragelijk...",ep:1,g:107,l:1,wd:false,fm:true,w:0,p:1};
I.u[6852] = {n:"Knuffelbeest van de Kermis",t:24,d:"Het knuffelbeest dat Huil Babby heeft gewonnen op de Trool kermis...",ep:1,g:151,l:1,wd:true,fm:true,w:0,p:1};
I.u[6853] = {n:"Haasthout",t:24,d:"Dit hout heeft de eigenaardigheid kaarsrecht te groeien, als een stok. Nogal handig voor opslag.",ep:1,g:100,l:1,wd:true,fm:true,w:0,p:1};
I.u[6854] = {n:"Blauwe Larve Huid",t:24,d:"Stukje kleverige huid afgerukt van een arme weerloze larve.",ep:1,g:101,l:1,wd:false,fm:true,w:0,p:1};
I.u[6855] = {n:"Kleine boog van Enileda",t:24,d:"Vrucht van het werk van de bekende bogenmaakster Enileda, is deze boog niet een model op zich.",ep:1,g:244,l:1,wd:true,fm:true,w:0,p:1};
I.u[6856] = {n:"Schaar voor duivelse roos",t:20,d:"De vorm van deze schaar is speciaal bestudeerd voor het afknippen van de stengel van iedere duivelse roos zonder de doornen te beschadigen. En dit zelfs terwijl ze je in de kuiten bijt.",ep:1,g:22,l:1,wd:true,fm:true,w:2,an:13,e:[5,3,1,1,20,20,false,false],p:1};
I.u[6857] = {n:"Astrub Bier",t:37,d:"Een klassiek bier dat de ontwikkeling van de spier in je onderbuik bevordert, beter bekend onder de naam six pack.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:4};
I.u[6858] = {n:"Ingevulde maar niet geldige Kaart",t:80,d:"Dit kaartje bevat helaas de naam van een kandidaat die niet geldig is om bezorger van de bakker te zijn. Het rode plekje onderaan geeft aan dat hij hetzij niet genoeg kracht gezat, hetzij niet behendig genoeg was voor dit beroep.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW<1500|CA<50",p:0};
I.u[6859] = {n:"Schaar",t:24,d:"Een schaar die van geen meter kamt... hij zou zelfs eerder de neiging hebben te knippen dan te kammen, vertellen sommige kappers...",ep:1,g:150,l:1,wd:true,fm:true,w:0,p:1};
I.u[6862] = {n:"Manuscript van de Beer",t:24,d:"Deze vreemde schriftrol legt uit hoe de Beren Man heeft geleerd Beren op te roepen. Ongelofelijk.",ep:1,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[6863] = {n:"Helm van de Huurlingen van Astrub",t:16,d:"Helm van de huurlingen van Astrub.",ep:1,g:72,l:1,wd:false,fm:true,w:10,p:1};
I.u[6864] = {n:"Bloem van de Duistere roos",t:24,d:"Een roos die zo donker is dat zijn schaduw in vergelijking lijkt te fonkelen.",ep:2,g:106,l:23,wd:true,fm:true,w:0,p:1};
I.u[6865] = {n:"Notitie",t:24,d:"\"Afspraak aan de rand van het bos voor de levering\"",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6866] = {n:"Stukje cape",t:24,d:"Een stukje blauwe cape van degenen die je aangevallen hebben. Alsof er niets aan de hand is heb je ze een pak slaag gegeven.",ep:1,g:249,l:1,wd:false,fm:true,w:0,p:1};
I.u[6867] = {n:"Oogstnotitie",t:24,d:"Om niet te vergeten hoe laat je de Vhan moet oogsten, heb je het op dit papiertje geschreven.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6868] = {n:"Kastanjehouten Plank",t:95,d:"Deze Kastanjehouten plank wordt soms gebruikt voor het bouwen van huizen, maar meestal gebruikt men hem voor het maken van vliegenvallen...",ep:1,g:1,l:10,wd:true,fm:true,w:10,p:20};
I.u[6869] = {n:"Huil Babby",t:32,d:"Huil Babby is de weg naar zijn huis kwijt, je moet hem dus terugbrengen...",ep:1,g:14,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6870] = {n:"Nomarrow Transplent",t:32,d:"Nomarow Transplent is nu in jouw beheer. Breng hem veilig naar het huis van bewaring.",ep:13,g:8,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6871] = {n:"Frakacia Leukocytine",t:32,d:"Frakacia is nu onder jouw controle. Je kunt haar nu veilig naar de gevangenis brengen.",ep:1,g:11,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6872] = {n:"Nervoes Breekdoun",t:32,d:"Nervoes Breekdoun is nu onder jouw controle. Het is aan jou hem veilig naar de gevangenis te brengen.",ep:1,g:10,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6873] = {n:"Qil Bil",t:32,d:"Qil Bil is nu in jouw beheer. Breng hem veilig naar het huis van bewaring.",ep:14,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6874] = {n:"Brumen Tinctorias",t:32,d:"Brumen Tinctorias is nu in jouw beheer. Breng hem veilig naar het huis van bewaring.",ep:14,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6875] = {n:"Eikelhorn",t:32,d:"Eikelhorn is nu onder jouw controle. Je kunt \'m nu veilig naar de gevangenis brengen.",ep:1,g:12,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6876] = {n:"Ogivol Scarlarlin",t:32,d:"Ogivol is nu in jouw beheer. Breng hem veilig naar het huis van bewaring.",ep:16,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6884] = {n:"Sleutel van de Bwork Toren",t:84,d:"Met deze sleutel kan je de Bwork Toren betreden. Pas op, hij wordt vernietigd na gebruik.",ep:4,g:713,l:30,wd:true,fm:true,w:1,p:100};
I.u[6885] = {n:"Bworker\'s Penning",t:15,d:"Goed om kop of munt te spelen of om je vijand te vermoorden na het opgooien van een munt, deze puur gouden penning maakt een gelukkige speler van je, maar misschien ook ongelukkig...",ep:13,g:90,l:100,wd:true,fm:true,w:1,p:100};
I.u[6886] = {n:"Astrub Huurling Cape",t:17,d:"Cape van de huurlingen van Astrub.",ep:1,g:59,l:1,wd:false,fm:true,w:10,p:1};
