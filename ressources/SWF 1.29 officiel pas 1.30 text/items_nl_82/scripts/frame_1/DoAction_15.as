I.u[6894] = {n:"Superkrachtige Gevechts MiauwMiauw (MJ)",t:18,d:"Deze superkrachtige gevechts-MiauwMiauw belichaamt wonderwel de superkracht. Heel indrukwekkend. Maar let op, hij is voorbehouden aan Spel Meesters die hem op de juiste waarde schatten.",ep:1,g:1,l:1,wd:false,fm:false,w:10,c:"PX=3|PX=5",p:1};
I.u[6895] = {n:"Kleine Gevechts Miauwmiauw (MJ)",t:18,d:"Minder oppermachtig van de oppermachtige Gevechts Miauwmiauw, maar toch erg machtig, blijft dit huisdier een zekere waarde voor iedere zichzelf respecterende Meester van het spel. Daarentegen moet toegegeven worden dat hij duidelijk sneller vuil wordt. Vergeet hem niet af en toe hardgrondig met kokend water te wassen opdat hij zijn volle pracht bewaart.",ep:1,g:9,l:1,wd:false,fm:true,w:10,p:1};
I.u[6897] = {n:"Blauwe Piwi Veer",t:53,d:"Deze kleine Piwiveer is rechtstreeks uit het achterste van een arme Piwi getrokken, die nergens om had gevraagd.",ep:1,g:114,l:1,wd:true,fm:true,w:1,p:10};
