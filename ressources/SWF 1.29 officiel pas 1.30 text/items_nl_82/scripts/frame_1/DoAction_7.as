I.u[3203] = {n:"Stam Ring",t:9,d:"De herkomst van deze ring is op z\'n minst twijfelachtig, men denkt dat hij heeft toebehoord aan een stam vegetarische Sadidas Kaniboules die varens van het ergste soort aten. Vast en zeker een verhaal om de jonge Sadidas bang te maken.",ep:11,g:49,l:51,wd:true,fm:true,w:5,p:7000};
I.u[3204] = {n:"Bonta Riem",t:10,d:"Deze riem is erg in de mode in Bonta. De gesp is voorzien van het speldje van de beroemde broederschap van schoenmakers.",ep:3,g:37,l:53,wd:true,fm:true,w:10,c:"Ps=1",p:7400};
I.u[3205] = {n:"Brakmar Riem",t:10,d:"Deze riem is erg in de mode in de riolen van Brakmar. Zeer geschikt om de indruk te geven een keiharde te zijn. Maar om een keiharde te worden, zijn er betere middelen.",ep:13,g:38,l:53,wd:true,fm:true,w:10,c:"Ps=2",p:7500};
I.u[3206] = {n:"De Xerbo",t:10,d:"Speciaal gemaakt om handige strijders mee te belonen. Hij wordt gedragen zonder ondergoed en alleen in de winter.",ep:13,g:39,l:67,wd:true,fm:true,w:7,p:13000};
I.u[3207] = {n:"Comfortabele Laarzen",t:11,d:"Deze laarzen zitten zo lekker licht en comfortabel, dat je er alleen maar tevreden mee kunt zijn. Bij het zien van je zolen, zal je zelfs je tegenstander je een blije en jaloerse glimlach toewerpen. Maar dat valt nog te bezien.",ep:1,g:38,l:17,wd:true,fm:true,w:10,p:950};
I.u[3208] = {n:"Bwork Boogschutter Onderbroek",t:56,d:"De Bwork Boogschutter had de kwade gewoonte zijn leren onderbroek te gebruiken om zijn pijlen in op te bergen. Dat verklaart wellicht uiteindelijk waarom de pijlen van de Bwork Boogschutter giftig heten te zijn.",ep:1,g:649,l:23,wd:true,fm:true,w:1,p:1};
I.u[3209] = {n:"Bwork Magus Schedel",t:15,d:"Al snel proberen jonge Enutrofs een Schedel van de Bwork Magus te bemachtigen, om hun ontluikende kaalheid te verbergen. Uitgedost met een zo beestachtig iets, lijken ze nog belachelijker dan normaal, maar de Bworklucht die eraf komt, verhult met gemak hun regelmatig van alcohol doordrenkte adem.",ep:4,g:653,l:23,wd:true,fm:true,w:1,p:1};
