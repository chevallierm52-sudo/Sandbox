I.u[7805] = {n:"De Drakokalkoenen: Hoe fok je je favoriete huisdier",t:25,d:"Dit indrukwekkende boek legt je uit hoe je Drakokalkoenen moet vangen, fokken en berijden. Het is geschreven door Oshar Marif zelf. Een kwalitatief goed stukje werk.",ep:16,g:19,l:1,wd:false,fm:true,w:1,u:true,p:500};
I.u[7806] = {n:"Rijdier Certificaat",t:97,d:"Dit certificaat geeft je de volmacht om jouw rijdier in een stal op te halen.                                                                      Waarschuwing! Dit certificaat is slechts 20 dagen geldig. Nadat deze tijd verstreken is, wordt je rijdier teruggestuurd naar de wildernis en is je certificaat niet langer geldig. Je zult niet in staat zijn om je rijdier op te eisen. Laat je rijdier altijd in een stal als je weg gaan voor langere tijd.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
