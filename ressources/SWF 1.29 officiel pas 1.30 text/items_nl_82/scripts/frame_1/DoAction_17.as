I.u[7634] = {n:"Klassieke Drakobil",t:93,d:"Met behulp van dit mechanische achterwerk, bedekt met leer, raakt het meest onverschillige mannelijke rijdier opgewonden. Hiermee worden bovendien bepaalde moederinstincten opgeroepen bij vrouwelijke rijdieren. Het lijkt tevens zeer goed te werken bij Iops.",ep:1,g:3,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[7635] = {n:"Drakobil van Leer van Wit Vreetzakjes Leer",t:93,d:"Met behulp van dit mechanische achterwerk, bedekt met leer, raakt het meest onverschillige mannelijke rijdier opgewonden. Hiermee worden bovendien bepaalde moederinstincten opgeroepen bij vrouwelijke rijdieren. Het lijkt tevens zeer goed te werken bij Iops.",ep:3,g:78,l:1,wd:true,fm:true,w:10,ut:true,p:1};
