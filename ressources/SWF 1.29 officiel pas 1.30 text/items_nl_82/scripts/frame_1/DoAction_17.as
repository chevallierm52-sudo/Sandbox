I.u[7680] = {n:"Ougaat",t:16,d:"Dit hoofddeksel is niks dan een stuk van Ougaa\'s hoofd. Ouga was een god die aanbeden werd door de Porcos. Doordat hij opgevuld is met weefsel, veren en wol kan iedereen dit hoofddeksel dragen, vooropgesteld dat iemand de geur en het gewicht ervan aandurft.",ep:23,g:120,l:178,wd:true,fm:true,w:200,s:118,p:57850};
I.u[7682] = {n:"Drinkbak van Kokokos Hout",t:93,d:"Met deze drinkbak kan je toekomstige rijdier zijn dorst lessen of erin pootje baden gedurende de warme seizoenen. Gevuld met water en met een paar toverdrankjes, moet hij je rijdier helpen tijdens zijn groei.",ep:12,g:91,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[7683] = {n:"Voerbak van Oer Hout",t:93,d:"Met behulp van deze voerbak zou je rijdier niet moeten verhongeren, of het lekkers dat je hem toestopt weer kunnen uitspugen. Hij dient om je rijdier een beetje energie te geven als deze laatste tekenen van zwakte toont.",ep:2,g:92,l:1,wd:true,fm:true,w:10,ut:true,p:1};
