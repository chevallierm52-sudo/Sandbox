I.u[8050] = {n:"Onvolwassen Koalak Huid",t:59,d:"De kleine onvolwassen Koalak die je ontveld hebt wilde het niet aan je geven. Wat kan jou dat schelen, jij was sterker en gemener.",ep:20,g:3,l:1,wd:true,fm:true,w:1,p:10};
I.u[8051] = {n:"Sative Koalak Huid",t:59,d:"Het is raadzaam dit vel niet in te nemen als je niet een nachtspiegel of een boom bij de hand hebt.",ep:0,g:4,l:1,wd:true,fm:true,w:1,p:10};
I.u[8052] = {n:"Koalak Meester Huid",t:59,d:"Dit oude en versleten huid beschermde de achterkant van de Koalak Meester. Er zitten nog steeds rossige sporen op, het bewijs van een gek en rusteloos leven.",ep:20,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[8053] = {n:"Koalak Ruiter Huid",t:59,d:"Deze gescheurde huid was versleten tegen dat van het Rijdier van Koalak Ruiter. Duidelijk een bewijs van goede kwaliteit.",ep:20,g:6,l:1,wd:true,fm:true,w:1,p:10};
I.u[8054] = {n:"Drakoalak Huid",t:59,d:"De geur van deze huid zou je moeten herinneren aan die van de schuren van het Kasteel van Amakna. Erg handig om gevoelige zielen af te schrikken en ze te doden voor ze besluiten met je mee te gaan in een grot.",ep:20,g:7,l:1,wd:true,fm:true,w:1,p:10};
I.u[8055] = {n:"Mama Koalak Bot",t:47,d:"Mama Koalak heeft met name stevige botten die niet onder haar gewicht breken. Jammer genoeg geldt dit niet voor Jon Lemon, beroemd minstreel, die het gebruik van beide armen verloor toen hij werd verpletterd door de enorme dijen van Mama Koalak.",ep:20,g:638,l:1,wd:true,fm:true,w:1,p:10};
I.u[8056] = {n:"Wilde Koalak Femur",t:47,d:"Dit bot, ooit uitgesneden en gevormd als een dolk, kan zo gebruikt worden of als een kook-doorsteker.",ep:20,g:639,l:1,wd:true,fm:true,w:1,p:10};
I.u[8057] = {n:"Koalak Grafdelver Scheenbot",t:47,d:"Dit bot kan als schop gebruikt worden om lichamen op te graven en ze te beroven, als je er van houdt om je vakanties bij begraafplaatsen door te brengen. Toevallig is het ook het scheenbeen van de Koalak Grafdelver.",ep:20,g:640,l:1,wd:true,fm:true,w:1,p:10};
I.u[8058] = {n:"Koalak Mummy Ulna",t:47,d:"Dit bot heeft al zijn pracht behouden dankzij de vele omzwachtelingen van de Koalak Mummy, welke een goeie bescherming geeft tegen de meest krachtige magische aanvallen.",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8059] = {n:"Kersen Koalak Haren",t:54,d:"Deze haren zijn bedekt met Blop pollen, waardoor ze een geweldige smaak hebben maar een afgrijselijke geur.",ep:20,g:660,l:1,wd:true,fm:true,w:1,p:10};
I.u[8060] = {n:"Koko Koalak Haren",t:54,d:"Deze haren zijn bedekt met Blop pollen, welke hun een verrukkelijke smaak geeft, maar een walgelijke geur.",ep:20,g:662,l:1,wd:true,fm:true,w:1,p:10};
I.u[8061] = {n:"Pippin Koalak Haren",t:54,d:"Deze haren zijn bedekt met Blop pollen, waardoor ze een geweldige smaak hebben maar een afgrijselijke geur.",ep:20,g:661,l:1,wd:true,fm:true,w:1,p:10};
I.u[8062] = {n:"Indigo Koalak Haren",t:54,d:"Deze haren zijn bedekt met Blop pollen, welke hun een verrukkelijke smaak geeft, maar een walgelijke geur.",ep:20,g:659,l:1,wd:true,fm:true,w:1,p:10};
I.u[8063] = {n:"Bloederige Koalak Staart",t:65,d:"Deze belachelijk kleine staart kon van jou zijn geweest aangezien je zo onbeduidend bent. Maar dit is niet het geval, prijs jezelf gelukkig hierom!",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8064] = {n:"Bloederige Koalak Boomerang",t:15,d:"Dit vreemd gevormde stuk hout reisde een lange tijd door de lucht tussen vijanden klassen voordat het brak. Het gerucht gaat dat het altijd terug zal vliegen naar zijn eigenaar, maar zelden in diens handen..",ep:20,g:721,l:1,wd:true,fm:true,w:1,p:10};
I.u[8065] = {n:"Bruine Warko Baard Haren",t:54,d:"Deze haren zijn onmisbaar om van simpele Bruine Warko kussen een wapen voor massale vernietiging te maken. Erg onmisbaar inderdaad.",ep:20,g:657,l:1,wd:true,fm:true,w:1,p:10};
I.u[8066] = {n:"Paarse Warko Baard Haren",t:54,d:"Deze haren zijn onmisbaar om  van deze baard een wapen te maken die meer verwoestbaar is als de adem van de Bwork, als we het kunnen vergelijken. Erg schokkend!",ep:20,g:658,l:1,wd:true,fm:true,w:1,p:10};
I.u[8067] = {n:"Kampioens Laarzen",t:11,d:"Bepaalde avonturiers vertellen dat je met deze laarzen in valstrikken kunt trappen zonder ze af te laten gaan. Pas op, misschien is het een valstrik...",ep:1,g:72,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8068] = {n:"Kampioens Cape",t:17,d:"Deze prachtige cape beschikt over geïntegreerde schoudervullingen om je een indrukwekkender voorkomen te geven zodat je eindelijk op een echte kampioen lijkt.",ep:1,g:96,l:1,wd:false,fm:true,w:10,s:45,p:10};
