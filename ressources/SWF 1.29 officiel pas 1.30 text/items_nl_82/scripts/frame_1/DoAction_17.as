I.u[7685] = {n:"Voerbak van Vergulde Bamboe",t:93,d:"Met deze trog zal je rijdier niet van de honger omkomen, of alle lekkernijen die je hem hebt gegeven, uitbraken. Door deze trog krijgt je rijdier weer energie als hij tekenen van verzwakking vertoont.",ep:18,g:93,l:1,wd:true,fm:true,w:10,ut:true,p:1};
