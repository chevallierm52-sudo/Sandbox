I.u[7691] = {n:"Drakobil van Leer van de Veelvraat Oorlogs Chef",t:93,d:"Met behulp van dit mechanische achterwerk, bedekt met leer, raakt het meest onverschillige mannelijke rijdier opgewonden. Hiermee worden bovendien bepaalde moederinstincten opgeroepen bij vrouwelijke rijdieren. Het lijkt tevens zeer goed te werken bij Iops.",ep:3,g:78,l:1,wd:true,fm:true,w:10,ut:true,p:1};
