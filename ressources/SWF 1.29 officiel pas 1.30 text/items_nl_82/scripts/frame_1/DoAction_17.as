I.u[7626] = {n:"Slapper in Kastanje",t:93,d:"Deze mechanische machine is gemaakt om je rijdieren om hun gezicht te slaan als ze het verdienen. Het werd gebruikt op scholen om jonge Iops tot 5 te leren tellen.",ep:12,g:5,l:1,wd:true,fm:true,w:10,ut:true,p:1};
