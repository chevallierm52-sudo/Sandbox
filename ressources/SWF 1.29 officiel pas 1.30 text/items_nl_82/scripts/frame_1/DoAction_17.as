I.u[7651] = {n:"Misthoorn",t:94,d:"Deze misthoorn is speciaal gemaakt je rijdier te roepen wanneer je die nodig hebt.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7652] = {n:"Herinneringsdrankje",t:12,d:"Met dit drankje kun je een deel van het extract van een wezen stelen, zodat je een onvergetelijke herinnering aan hem hebt. Erg praktisch voor het markeren van je territorium en je goederen. Het wordt ook regelmatig gebruikt voor het maken van handtekeningsrunen.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
