I.u[7703] = {n:"Lelijke Kleine Raaf",t:18,d:"Dit donkere gevogelte is vooral bekend vanwege zijn voorliefde voor kerkhoven en blanke avonturiers. Hij schept er een bijzonder plezier in met zijn grote bek de botten, die hij in de graven vindt, te verbrijzelen.",ep:3,g:18,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:8,p:1};
I.u[7704] = {n:"Schadelijke Eekhoorn",t:18,d:"Deze eekhoorn is een echte eikel verwringer. Hij kan je apenoten een minuutje kietelen en vervolgens breken. Het gekke is dat hij enkel zaden eet.",ep:3,g:16,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7705] = {n:"Leopardo",t:18,d:"Dit geweldige beest is op een of andere manier verbonden aan de beroemde Lenalds van Wabbit Eiland. Hij is echter veel onbesuisder en vrijgevochtener en zal je in strijd helpen en bewijst ongelooflijke oneerlijkheid als je hem niet goed behandelt. Dit beest eet alleen maar vlees.",ep:3,g:27,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7706] = {n:"Bilby",t:18,d:"Bilby, kort voor Bilbiblabaloo, is een klein gelei op zoek naar avonturen. Nauwkeurig aangehecht aan Vald heeft hij wonderbaarlijke krachten voor zijn grootte dankzij zijn strikte bloemendieet.",ep:3,g:43,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7707] = {n:"Jong Wild Zwijn",t:18,d:"De snuit van dit kleine wilde varkentje is totaal uit vorm in vergelijking met de rest van zijn lichaam. Hij is vooral goed voor het vinden van grote eikels. Hij heeft jou in elk geval gevonden. Deze ziel eter is boos over Armzalig Zwijn overblijfselen, Varkens en Zwijnen.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7708] = {n:"Blauwe Piwin",t:18,d:"Deze kleine Piwin is niet zoals de anderen. Je hoeft maar naar de kleur te kijken en het is duidelijk. Hoe dan ook, hij lijkt wel dezelfde onverklaarbare drang te hebben om billen te pikken. Wees niet verrast als ik je vertel dat er mensen zijn die het fijn vinden om aangevallen te worden door de kleine beestjes. Dit huisdier eet enkel zaden.",ep:1,g:19,l:1,wd:true,fm:true,w:10,p:1};
