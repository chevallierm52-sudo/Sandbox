I.u[7622] = {n:"Aaimachine van Tofu Veren",t:93,d:"Deze verrassende machine is in staat de rijdieren die er dichtbij komen met de haren mee te aaien, zodat ze minder agressief worden.",ep:1,g:30,l:1,wd:true,fm:true,w:10,ut:true,p:1};
