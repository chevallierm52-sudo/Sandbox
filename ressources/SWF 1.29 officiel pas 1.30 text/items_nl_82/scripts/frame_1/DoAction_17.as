I.u[7714] = {n:"Atooin",t:18,d:"Het gerucht gaat dat deze schildpad opgevoed is door een Martial Arts Meester die op een Grossewer Rat leek. Als je hem vis geeft zal hij aardig tegen je zijn en je helpen om gewonde avonturiers te helpen. Als je hem vlees geeft wordt hij agressief en helpt hij je jouw vijanden te verslaan.",ep:2,g:17,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:9,p:1};
I.u[7721] = {n:"Lelijke Kleine Raaf Geest",t:90,d:"Deze geest heeft de wereld der levenden nog niet verlaten, hij wacht op jou om hem weer tot leven te brengen of om hem eens en voor altijd lafhartig achter te laten.",ep:3,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[7722] = {n:"Schadelijke Eekhoorn Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:3,g:39,l:1,wd:true,fm:true,w:1,p:1};
