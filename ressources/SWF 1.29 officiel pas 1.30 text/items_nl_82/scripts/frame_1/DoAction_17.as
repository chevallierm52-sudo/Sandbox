I.u[7999] = {n:"Capananas",t:17,d:"Sommige avonturiers vertellen dat deze cape net zo ruw is als de huid van een Crocodyl, en anderen vertellen zelfs dat hij nog ruwer is dan de huid van de billen van een vrouwtjes Bwork. Hoe het ook zij, let op dat je hem aan de goede kant draagt als je niet ook zulke ruwe billen wilt krijgen.",ep:1,g:94,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8000] = {n:"Bworky",t:18,d:"Dit kleine wezen is een Bwork die gedurende tientallen jaren opgesloten heeft gezeten in een kom. Hij heeft de vorm van de kom aangekomen en zal zijn hele leven klein blijven. Zijn goede humeur en zijn legendarisch gevoel voor humor maakt hem tot ideaal gezelschap in Torens waarvan je weet dat je die niet alleen kunt veroveren of voor duivelse mondaine feesten. Let op, hij is liefhebber van aperitiefjes en hij kan alleen maar tegen noten en hazelnoten, ook al lust hij graag van tijd tot tijd een eikeltje.",ep:3,g:31,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8001] = {n:"Koalak Krijger Verband",t:15,d:"Dit verband zit normaal om de armen van de Koalak Krijger gewikkeld. Op deze manier kan hij zijn neus snuiten zonder zakdoeken te gebruiken. Als dit verband oud en versleten is kun je hem hergebruiken door hem aan je plafond te hangen om Moskitos aan te trekken.",ep:20,g:719,l:70,wd:true,fm:true,w:5,p:100};
I.u[8002] = {n:"Dok Alako weefsel",t:55,d:"Dit weefsel is gedrenkt in eeuwenoude magie die nogal onvoorspelbaar en ongecontroleerd is: nog een overeenkomst met je geliefde.",ep:20,g:720,l:40,wd:true,fm:true,w:5,p:1};
I.u[8003] = {n:"Koalak Amulet",t:1,d:"Dit amulet lijkt op geen ander amulet, gewoon omdat geen enkel ander amulet erop lijkt.",ep:20,g:94,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8004] = {n:"Koalak Ring",t:9,d:"Deze prachtige ring is gedragen door de meest roekelozen van de Koalaks... degenen die het in Astrub hebben gestolen.",ep:20,g:99,l:53,wd:true,fm:true,w:10,s:46,p:7375};
I.u[8005] = {n:"Koalak Boog",t:2,d:"Deze boog laat je het leven van je tegenstanders stelen, en soms steelt het zelfs je tegenstanders van het leven. (Probeer niet te lang om het te begrijpen, dat betekent niets.)",ep:20,g:52,l:61,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,4,50,50,false,true],s:46,p:9775};
I.u[8006] = {n:"Koalak Laarzen",t:11,d:"Deze laarzen zijn eigenlijk echte Koalak voeten die wreed van hun eigenaar zijn afgetrokken, daarna geleegd zijn om vervolgens gevuld te worden met Koalak haren. Zowel angstaanjagend als aantrekkelijk, deze laten maken je de terreur van Astrub.",ep:20,g:71,l:60,wd:true,fm:true,w:10,s:46,p:9600};
I.u[8007] = {n:"Koalak Mantel",t:17,d:"Deze mantel beschermt je tegen de meeste aanvallen maar niet tegen belachelijk zijn.",ep:20,g:95,l:61,wd:true,fm:true,w:10,s:46,p:9675};
I.u[8008] = {n:"Koalak Riem",t:10,d:"Deze riem gemaakt van Kaliptus blaadjes verspreidt een plezierige verrukkelijke geur, die andere geuren kan verbergen. Bovendien is deze riem perfect om je molligheid te verbergen.",ep:20,g:87,l:60,wd:true,fm:true,w:10,s:46,p:9508};
I.u[8009] = {n:"Koalak Hoofddeksel",t:16,d:"Dit hoofddeksel is versierd met enorme Koalak horen die geluiden versterken door uitgestraald worden door omringende beesten. Wees voorzichtig, het kan je trommelvliezen verwoesten als je vrienden fans zijn van panische winden.",ep:20,g:125,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8010] = {n:"Ontmantelaar",t:93,d:"Hiermee kan je een uitrusting die binnen een omheining ligt weer terugkrijgen.",ep:1,g:96,l:1,wd:false,fm:true,w:10,ut:true,p:1};
I.u[8011] = {n:"De Profeten, de culten, het Geloof",t:25,d:"Enkele mooie cultverhalen die basismystici zullen verrukken.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8012] = {n:"Wederopstandingspoeder",t:48,d:"Met dit poeder kan je de geest van een huisdier weer tot leven wekken, op voorwaarde dat je weet hoe je een huisdierengeest moet voeden.",ep:20,g:51,l:1,wd:true,fm:true,w:1,p:100};
I.u[8013] = {n:"Bow Meow Geest Transformatie",t:27,d:"Je bent veranderd in een geest om de Huisdieren Begraafplaats op te kunnen komen.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8016] = {n:"Bloederige Koalak Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:3,g:43,l:1,wd:true,fm:true,w:1,p:1};
I.u[8017] = {n:"Bworky Geest",t:90,d:"Deze Geest heeft de wereld der levenden nog niet verlaten en wacht op jou om hem weer te doen herleven of om hem eens en voor altijd lafhartig achter de laten.",ep:3,g:31,l:1,wd:true,fm:true,w:1,p:1};
I.u[8020] = {n:"Atooin Geest",t:90,d:"Deze geest heeft de levende wereld nog niet verlaten. Zul jij een manier vinden om hem te laten herrijzen of verlaat je hem voorgoed?",ep:2,g:42,l:1,wd:true,fm:true,w:1,p:1};
