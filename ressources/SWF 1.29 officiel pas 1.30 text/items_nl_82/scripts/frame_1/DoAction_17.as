I.u[7879] = {n:"Hyrkuls Advent",t:25,d:"De Kolossale, Immorale en niet Banale Analen van Domen geven je de rillingen over je rug. Te lezen in te respecteren voorgeschreven doseringen. Bijwerkingen: koud zweet en nachtelijke incontinentie.",ep:16,g:19,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[7880] = {n:"Vraatcoul Amulet",t:1,d:"Dit amulet werd vroeger gedragen door alle avonturiers die liever liefde verspreidden dan oorlog voerden. Ieder het zijne.",ep:20,g:93,l:20,wd:true,fm:true,w:5,s:43,p:1300};
I.u[7881] = {n:"Vraatcoul Ring",t:9,d:"Met deze ring doe je je kinderen nog meer pijn als je ze slaat.",ep:20,g:98,l:38,wd:true,fm:true,w:5,s:43,p:4000};
I.u[7882] = {n:"Vraatcoul Hamer",t:7,d:"Deze hamer is ideaal om je pacifistische mening over te brengen op de schedel van je tegenstanders.",ep:20,g:54,l:41,wd:true,fm:true,w:10,an:15,e:[5,5,1,1,40,40,false,false],s:43,p:4520};
I.u[7883] = {n:"Vraatcoul Laarzen",t:11,d:"Dit zijn geweldige laarzen, gevoerd met Vraatcoulwol. Licht en warm tijdens het koude seizoen en luchtig tijdens het warme seizoen, weten ze de meest onverschillige avontiers tevreden te stellen.",ep:20,g:66,l:38,wd:true,fm:true,w:15,s:43,p:3925};
I.u[7884] = {n:"Vraatcoul Cape",t:17,d:"Als je het leven licht opneemt, is deze cape absoluut voor jou gemaakt. Hij is zo dik en comfortable dat hij kan dienen als een geïmproviseerd bed zodra je je moe voelt worden. Met zijn geur van gebrande Kaliptus verdrijft hij insecten, ongewenste wezens en zelfs schoonmoeders.",ep:20,g:93,l:55,wd:true,fm:true,w:15,s:43,p:8030};
I.u[7885] = {n:"Vraatcoul Riem",t:10,d:"Met deze riem om je heupen kun je doorgaan voor een pacifistische avonturier en zo je tegenstanders verrassen door hen een zwaard in de rug steken.",ep:20,g:84,l:37,wd:true,fm:true,w:10,s:43,p:3800};
I.u[7886] = {n:"Vraatcoul Muts",t:16,d:"Met deze muts op je hoofd, zie je er niet veel slimmer uit, dat is zeker. Daarentegen, zie je er \"cooler\" uit en dat is ten slotte wat telt.",ep:20,g:119,l:47,wd:true,fm:true,w:15,s:43,p:6000};
I.u[7887] = {n:"Koolich Hoofddeksel",t:16,d:"Dit hoofddeksel behoorde ooit toe aan de beroemde Koolich die bekend stond om zijn voeten van klei en zijn legendarische goede humeur.",ep:20,g:122,l:82,wd:true,fm:true,w:10,s:44,p:18375};
I.u[7888] = {n:"Koolich Tas",t:81,d:"De Koolich gebruiken deze tas om hun Kaliptus blaadjes vers te houden of om Koalaks die te ondernemend zijn te verstikken.",ep:20,g:2,l:69,wd:false,fm:true,w:10,s:44,p:12278};
I.u[7889] = {n:"Koolich Laarzen",t:11,d:"Deze laarzen behoorden aan de Koolich toe – zelfs als je het niet kunt zien, kun je het ruiken! Deze laarzen zijn zo comfortabel dat je bijna zou vergeten hoe triest je bestaan is.",ep:20,g:69,l:73,wd:true,fm:true,w:10,s:44,p:13775};
I.u[7890] = {n:"Koolich Staf",t:4,d:"Deze staf is eigenlijk het geleegde bot van een van de Koolich\'s voorouders.",ep:20,g:62,l:75,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,20,50,false,false],s:44,p:14675};
I.u[7891] = {n:"Mini Wa",t:18,d:"Deze kleine Wabbit is in werkelijkheid een verborgen zoon van de op trieste wijze beroemde Wa Wabbit. Misschien komt hij op een dag op zijn beurt op de troon.",ep:3,g:28,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7892] = {n:"Willy Peninzias",t:18,d:"Willy Peninzias  is een echt kwaadaardig wezen. Het schijnt dat hij een zeer moeilijke jeugd heeft gehad. Hij volgt je overal en jaagt je vrienden op die manier weg.",ep:3,g:29,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7893] = {n:"Geest van Mini Wa",t:90,d:"Deze Geest heeft de wereld van de levenden nog niet verlaten, het hangt van jou af om een manier te vinden om hem weer tot leven te wekken, of hem voor eens en voor altijd lafhartig in de steek te laten.",ep:3,g:18,l:1,wd:true,fm:true,w:1,p:1};
I.u[7894] = {n:"Geest van Willy le Relou",t:90,d:"Deze Geest heeft de wereld der levenden nog niet verlaten, alleen jij kan een manier vinden om hem te doen herleven, of je kunt hem voor eens en voor altijd in de steek te laten.",ep:3,g:17,l:1,wd:true,fm:true,w:1,p:1};
I.u[7895] = {n:"Certificaat van Plaatsing in Kennel: Mini Wa",t:77,d:"Dit certificaat beschrijft de eigenschappen van de Mini Wa die je in de kennel hebt geplaatst.",ep:3,g:34,l:1,wd:false,fm:true,w:1,p:100};
I.u[7896] = {n:"Certificaat van Plaatsing in Kennel: Willy Penizias",t:77,d:"Dit certificaat beschrijft de eigenschappen van Willy Peninzias die je in de kennel hebt ondergebracht.",ep:3,g:29,l:1,wd:false,fm:true,w:1,p:100};
I.u[7897] = {n:"Mini Wa Cadeau",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden, voedsel en Eniripsapoeder om het te verzorgen.\n(ATTENTIE, dit cadeau bevat zware voorwerpen, je loopt het risico te zwaar beladen te raken als je het opent, denk eraan je te ontdoen van zware voorwerpen of je door een vriend te laten helpen.)",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7898] = {n:"Cadeau Willy Peninzias",t:89,d:"Door je oor op dit cadeau te leggen of door het flink te schudden zul je misschien vreemde geluiden horen die je de aanwezigheid van een nog levend wezen onthullen. Verlies geen enkele seconde, open het snel, je zult er een geweldig huisdier in aantreffen, met een boek dat je uitlegt hoe het op te voeden, voedsel en Eniripsapoeder om het te verzorgen.\n(ATTENTIE, dit cadeau bevat zware voorwerpen, je loopt het risico te zwaar beladen te raken als je het opent, denk eraan je te ontdoen van zware voorwerpen of je door een vriend te laten helpen.)",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7899] = {n:"De Mini Wa : Hoe fok je je favoriete huisdier",t:25,d:"Dit boek, geschreven door Oshimo Diklip legt uit hoe je het beste een Mini Wa opvoedt.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7900] = {n:"Willy Peninzias: Hoe fok je je favoriete huisdier",t:25,d:"Dit boek, geschreven door Oshimo Diklip, legt uit hoe je een Willy Peninzias moet fokken.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7902] = {n:"Riem van een Gouden Vrouw",t:10,d:"Een oude legende uit het fameuse toverboek \"De gehele waarheid over vrouwen\", vertelt dat deze riem zou zijn geweest van een gouden vrouw, meer geïnteresseerd in rijkdom dan in macht. In de ongecensureerde versie van het toverboek kan men tevens lezen dat ze vooral bekend was om haar uitgesproken smaak voor schunnige moppen. Uiteindelijk bleek ze dus toch niet zoveel te verschillen van de andere vrouwen...",ep:2,g:86,l:71,wd:true,fm:true,w:5,p:13300};
I.u[7903] = {n:"Kaliptusblaadje",t:36,d:"Voorzichtig in de neusgaten ingebracht, maken deze blaadjes iedere verstopte neus vrij. Volgens sommige stamlegendes zou deze techniek ook bij andere openingen werken.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7904] = {n:"Kaliptus Bloem",t:35,d:"Eenmaal gebrand verspreidt deze bloem een dikke rook met hallucinerende eigenschappen. Als je erop kauwt heeft ze de neiging je onmachtig te maken. Geconsumeerd als kruidenthee kan ze grote laxerende effecten hebben. De beste oplossing is er maar gewoon af te blijven.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7905] = {n:"GobKool Wol",t:57,d:"Deze wol lijkt op Gobball wol, maar dat is het niet. Inderdaad, deze wol ruikt niet.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7906] = {n:"Gobkool Hoorn",t:47,d:"Volgens een oude legende heeft dit poeder afrodisische krachten als je de hoorn in poeder vermaalt. Dezelfde legende vertelt ook van de bijwerkingen. Nog een reden om het uit te proberen!",ep:20,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[7907] = {n:"Gobkool Leder",t:56,d:"Dit multi gekleurde leder is perfect om multikleuren lederen ondergoed te maken. De meest blasé Chafers zullen er jaloers op zijn.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7908] = {n:"Koolich Grot Sleutel",t:84,d:"Deze sleutel gemaakt van een bot geeft je toegang tot de Koolich grot, zelfs als je niet uitgenodigd bent.",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[7911] = {n:"Bloederige Koalak",t:18,d:"Deze kleine Koalak ziet er onschuldig uit, maar dat is niet waar! Toen hij klein was is hij gemarteld, meestal door zijn gezicht met boomerangs te raken. Hij haat boomerangs. Hij eet ze zelfs op zodat hij er niet naar hoeft te kijken.",ep:3,g:30,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:46,p:1};
I.u[7913] = {n:"De Verdeler (MJ)",t:9,d:"Dit mysterieuze voorwerp, door iedereen vergeten, was van een groot magiër... Hiermee kon hij naar het schijnt met bepaalde dieren praten...",ep:1,g:22,l:1,wd:false,fm:true,w:1,p:1};
I.u[7917] = {n:"Compensatiecadeau",t:89,d:"Het Ankama-team biedt je dit cadeaupakket aan om zich te verontschuldigen voor de problemen die je hebt ondervonden met de verbinding: \n- 5 Compensatiesnoepjes van de Wijsheid\n- 5 Compensatiesnoepjes van de Bofkont\n- 10 Compensatiesnoepjes van Energie\n- 10 Eniripsapoeders",ep:1,g:32,l:1,wd:true,fm:true,w:1,c:"PO!7801&PO!7800",u:true,p:1};
I.u[7918] = {n:"Sleutel van de Tofu Toren",t:84,d:"Deze sleutel gemaakt van een veer van de Tofu kan het binnenste van sommige sloten kietelen... Daarbij kun je er ook mee in het Tofuhok van Farle Ingalsse komen.",ep:1,g:6,l:1,wd:true,fm:true,w:1,p:100};
I.u[7919] = {n:"Fiche van de Spelleider",t:15,d:"Dit prachtige fiche moet je absoluut op de Trool Kermis  inruilen voor een kostbaar cadeau.",ep:1,g:737,l:1,wd:true,fm:true,w:1,p:100};
I.u[7920] = {n:"Toernooistok (MJ)",t:3,d:"Met deze bescheiden stok kunnen Spel Meesters avonturiers teleporteren in een zone die voor toernooien is gereserveerd.",ep:1,g:8,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],u:true,p:100};
I.u[7921] = {n:"Kroon van de Koninklijke Tofu",t:16,d:"Deze kroon is nogal moeilijk te verkrijgen, hij glipt door je vingers. Geen twijfel, het is inderdaad de Kroon van de Koninklijke Tofu. Daarentegen lijkt hij totaal niet bij je kleine hoofd te passen, laat staan dat van een Iop!",ep:13,g:154,l:128,wd:true,fm:true,w:10,p:42625};
I.u[7922] = {n:"Knuffelbeest van de Sacrier Dopple",t:61,d:"Dit knuffelbeest is gemaakt voor de jonge Sacriers, hij is perfect voor het afsponzen van hun bloed en is gemakkelijk op iedere temperatuur schoon te maken.",ep:0,g:1,l:1,wd:true,fm:true,w:10,p:1};
I.u[7923] = {n:"Knuffelbeest van Pandawa Dopple",t:61,d:"Dit knuffelbeest ruikt naar alcohol en natte Pandawavacht, net als mama.",ep:1,g:2,l:1,wd:true,fm:true,w:10,p:1};
I.u[7924] = {n:"Minotoror Doolhof Sleutel",t:84,d:"Deze geweldige sleutel geeft je toegang tot de Minotoror Doolhof. Hij zal je echter niet de uitgang wijzen.",ep:13,g:7,l:1,wd:true,fm:true,w:1,p:100};
I.u[7925] = {n:"Kaliptushout",t:38,d:"Met dit geparfumeerde hout kan je lekker geurende huizen bouwen, zelfs als hun bewoners slecht rieken. Helaas is dit hout niet soepel genoeg voor het maken van ondergoed.",ep:20,g:1,l:50,wd:true,fm:true,w:2,p:0};
I.u[7926] = {n:"Heer Kraai Grot Sleutel",t:84,d:"Met deze sleutel krijg je de kans om Heer Kraai zelf te ontmoeten. Als je geluk hebt, nodigt hij je uit om een stuk kaas te delen in zijn gezelschap.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[7927] = {n:"Crackler Grot Sleutel",t:84,d:"Deze sleutel is bijna onbreekbaar maar hij is een beetje versleten door het openen van zoveel deuren. Hij lijkt gemaakt te zijn van de intieme delen van een Crackler. Schokkend!",ep:1,g:9,l:1,wd:true,fm:true,w:1,p:100};
I.u[7929] = {n:"Handboek van de Astrub Huurling",t:25,d:"Het Handboek van de Astrub Huurling is geschreven door de beroemde Igor Ant, Chef Huurling van Astrub. Dit is het favoriete boek van iedereen die zich aan de wet wil houden of... juist niet.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7930] = {n:"Vrienden maken en behouden",t:25,d:"Raadgevingen en handigheidjes om goede en loyale vrienden te krijgen door Acidrik Scheurbuik",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7931] = {n:"Het Draken Tijdperk - Teruggevonden Fragmenten III",t:25,d:"Deel III van de Fragmenten van de Geschiedenis van de Wereld, teruggevonden door de erudiete Acidrik Scheurbuik, en door hem herschreven.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:50};
I.u[7932] = {n:"Miss Astrub Schriftrol",t:25,d:"De weelderige Miss Astrub van dit jaar onthult ons de charmes waarmee ze de jury heeft verleid.",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[7933] = {n:"Schriftrol van de Kruimeldieven van Amygdale",t:25,d:"Deze dansers zonder weerga vrolijken de meest trendy feesten van de omgeving op.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:69};
I.u[7934] = {n:"Reizen zonder ooit het Noorden te verliezen",t:25,d:"Arpagnagrobis heeft dit werk geschreven voor alle avonturiers die geen idee hebben hoe ze hun kompas en zaaps moeten gebruiken.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
