I.u[1844] = {n:"Forel",t:41,d:"De forel is een vis die vrij gemakkelijk te vangen is en ervaren vissers halen ze dan ook met drie tegelijk op. Ze beslissen meestal ter plekke of ze rauw of gekookt gegeten zullen worden. Vanwaar hun perfecte uitspraak.",ep:1,g:394,l:1,wd:true,fm:true,w:3,p:0};
I.u[1845] = {n:"Schoongemaakte Forel",t:62,d:"Deze forel kan nu worden gebruikt als ingrediënt.",ep:1,g:396,l:1,wd:true,fm:true,w:2,p:1};
I.u[1846] = {n:"Oer Forel",t:41,d:"Een van de oudste forellen ter wereld. Als ze met de tijd wijzer zouden worden, zou deze forel de wijze onder de wijzen moeten zijn... Maar er bestaat twijfel.",ep:1,g:398,l:1,wd:true,fm:true,w:3,p:1};
I.u[1847] = {n:"Snoek",t:41,d:"Deze zoetwatervis van gemiddelde grootte is de vriend van de vissersbarbecue.",ep:2,g:400,l:10,wd:true,fm:true,w:3,p:1};
