I.u[1557] = {n:"Rune Ga Pa",t:78,d:"Deze rune is zo krachtig dat hij verboden zou moeten worden door de Goden. Hij heeft het vermogen een wapen zo makkelijk in het gebruik te maken, dat je het kan hanteren en tegelijkertijd aan een kopje koffie kan nippen.",ep:1,g:55,l:50,wd:true,fm:true,w:1,p:10};
I.u[1558] = {n:"Rune Ga Pme",t:78,d:"Deze rune is zo sterk dat hij verboden zou moeten worden door de Goden. Hij heeft het vermogen een wapen zo licht en makkelijk weg te bergen te maken, dat je het kan gebruiken en de volgende seconde naar de herberg kan gaan.",ep:1,g:56,l:50,wd:true,fm:true,w:1,p:10};
I.u[1559] = {n:"Boomring",t:9,d:"Deze ring is eigenlijk een knoest van de Slappe Eik, losgerukt door een storm. Nu is het aan jou, maar vermijd om dichterbij te komen dan zijn meester. Hij zou kunnen besluiten om zich tegen je te keren.",ep:9,g:11,l:46,wd:true,fm:true,w:3,p:7775};
