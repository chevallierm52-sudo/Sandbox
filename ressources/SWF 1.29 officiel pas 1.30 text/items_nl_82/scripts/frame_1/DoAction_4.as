I.u[1463] = {n:"Elementen Flesje",t:71,d:"Dit flesje is heel vanzelfsprekend bedoeld om basisaroma gevangen te houden.",ep:1,g:57,l:1,wd:true,fm:true,w:1,p:50};
I.u[1464] = {n:"Antenne van het blauwe Scarablad",t:15,d:"Niemand weet waartoe de antennes van het Scarablad dienen. De enige zekerheid is dat ze niet lekker ruiken.",ep:3,g:216,l:32,wd:true,fm:true,w:1,p:100};
I.u[1465] = {n:"Voelspriet van het Rode Scarablad",t:15,d:"Niemand weet waar de voelsprieten van een Scarablad toe dienen. De enige zekerheid die men heeft is dat ze niet erg lekker ruiken.",ep:3,g:217,l:32,wd:true,fm:true,w:1,p:1};
I.u[1466] = {n:"Voelspriet van het Groene Scarablad",t:15,d:"Niemand weet waar de voelsprieten van het Scarablad toe dienen. Het enige wat zeker is, is dat ze stinken.",ep:3,g:218,l:32,wd:true,fm:true,w:1,p:100};
I.u[1467] = {n:"Voelspriet van het witte Scarablad",t:15,d:"Niemand weet waar de voelsprieten van een Scarablad toe dienen. De enige zekerheid die men heeft is dat ze niet erg lekker ruiken.",ep:3,g:219,l:32,wd:true,fm:true,w:1,p:100};
I.u[1468] = {n:"Kom",t:71,d:"Deze kom kan voor vele doeleinden worden gebruikt, zoals bijvoorbeeld het maken van een toverdrank of om vis te verdrinken.",ep:1,g:58,l:1,wd:true,fm:true,w:1,p:100};
I.u[1469] = {n:"Aanbevelings Schriftrol",t:24,d:"Deze schriftrol heb je van Siub Reegaer gekregen. Hij beveelt je warm aan alchemist te worden.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1470] = {n:"Aanbevelings Schriftrol",t:24,d:"Deze schriftrol heb je van Siub Reegaer gekregen. Hij beveelt je warm aan alchemist te worden. Tnok Fob heeft een kleine notitie toegevoegd.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1471] = {n:"Aanbevelings en Bloem Schriftrol",t:24,d:"Deze schriftrol heb je van Siub Reegaer gekregen. Hij beveelt je warm aan alchemist te worden. Tnok Fob heeft een kleine notitie toegevoegd. Als er een bloem aangehecht is, bewijst dat dat je de eerste les geleerd hebt.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1472] = {n:"Examenaanvraag Schriftrol",t:24,d:"Deze schriftrol geeft aan dat je je opleiding tot alchemist hebt afgerond en dat je op kunt gaan voor het examen.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1473] = {n:"Groene Handen",t:20,d:"Met deze handschoenen kan je gemakkelijk en zonder risico welke plant of bloem dan ook plukken.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:100};
I.u[1474] = {n:"Amulet van Xélor",t:1,d:"Dit superkrachtige amulet is het resultaat van de tijdbeheersing door een zeer oude Xelor.",ep:1,g:28,l:52,wd:true,fm:true,w:10,p:7300};
I.u[1475] = {n:"Het Sgone Lemmet",t:6,d:"De Sgone Lemmet is gemaakt door de beroemde smid Dave-LoL voordat hij stierf, voor het leukste Iopmeisje van het koninkrijk. Men zegt dat dit lemmet net zo mooi is als zijn drager.",ep:4,g:15,l:60,wd:true,fm:true,w:30,an:14,e:[10,4,1,1,30,50,false,false],c:"CS>100&CV>50",p:3000};
I.u[1476] = {n:"Krakler Amulet",t:1,d:"Dit krachtige amulet bevat het hele leven van de Krakler. Namelijk alle voorwerpen die hij heeft verzameld voordat ie stierf tijdens gevechten met avonturiers die op zijn rijkdom uit waren.",ep:2,g:25,l:47,wd:true,fm:true,w:5,p:5800};
I.u[1477] = {n:"Geluks a Mulette",t:1,d:"Mulette was een kleine Ecaflippin die nooit veel geluk had in haar leven, tot de dag waarop haar grootmoeder haar dit amulet gaf.",ep:1,g:26,l:44,wd:true,fm:true,w:5,p:5000};
I.u[1478] = {n:"Harmonie",t:1,d:"Met deze hanger ben je weer in harmonie met je omgeving.",ep:1,g:122,l:47,wd:true,fm:true,w:1,p:6000};
I.u[1479] = {n:"Kartonnen Twot",t:7,d:"Deze legendarische hamer heeft zijn diensten al bewezen in Amakna en is van de krachtige Kartonnen Twot, die er niet voor terugdeinsde om hem te gebruiken om zijn tegenstanders in papier-mâché en confetti te veranderen.",ep:13,g:6,l:46,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>50&CV>30",p:5600};
I.u[1480] = {n:"Harmonie",t:1,d:"Met deze hanger ben je weer in harmonie met je omgeving.",ep:1,g:121,l:38,wd:true,fm:true,w:1,p:4000};
I.u[1481] = {n:"Overeenstemming",t:1,d:"Met deze hanger ben je weer in harmonie met je omgeving.",ep:1,g:11,l:26,wd:true,fm:true,w:1,p:2000};
I.u[1482] = {n:"Bleek Embleem",t:1,d:"Dit amulet is erg nuttig, maar zijn drager wordt er lijkbleek van, zoals een Veelvraat.",ep:1,g:32,l:41,wd:true,fm:true,w:2,p:4500};
I.u[1483] = {n:"Kabala",t:1,d:"Mysterieus symbool van een mysterieus organisme. Trouwens hij bestaat niet en je hebt er ook nooit van gehoord!",ep:11,g:13,l:29,wd:true,fm:true,w:2,p:2500};
I.u[1484] = {n:"Aangepast Itby Amulet",t:1,d:"Uitstekend werk van de leerling-edelsmid Polma Kartnez, deze kopie overtreft het origineel.",ep:1,g:31,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1485] = {n:"De Reinette",t:1,d:"Dit amulet is een verbeterde versie van het Vergulde Lot. Vreemd genoeg hebben ze niets met elkaar gemeen, behalve hun belachelijke uiterlijk, dat kun je wel zeggen.",ep:1,g:27,l:22,wd:true,fm:true,w:5,c:"CC>10",p:1500};
I.u[1486] = {n:"Holy Medaille",t:1,d:"Holy was een Iop discipel die had gezworen het kwaad waar dan ook de kop in te drukken. Ze was altijd vreselijk kalm, maar werd kwaad als men haar vergeleek met een zeker Oly.",ep:1,g:23,l:31,wd:true,fm:true,w:3,p:2800};
I.u[1487] = {n:"De Adelus",t:10,d:"Behalve dat je erg elegant gekleed gaat met deze riem, heeft hij voor zijn drager een bijzonder aangenaam masserend effect. De gelukkige eigenaar is daardoor, minder gestresst, beter in staat tot nadenken.",ep:1,g:12,l:48,wd:true,fm:true,w:30,p:6075};
I.u[1488] = {n:"Plimclik",t:1,d:"Onder deze vreemde naam verbergt zich een net zo vreemd voorwerp, afkomstig uit voorgaande amuletten, alleen weet men niet precies hoe. Men weet niets van de omstandigheden waaronder hij is ontdekt.",ep:11,g:123,l:130,wd:true,fm:true,w:24,p:1000};
I.u[1489] = {n:"Kegel van Mhete",t:1,d:"Met deze bijna-perfecte kegel zul je de wijsheid van een Ierse zalm hebben. Het is geweldig voor groepstherapie sessies met vrienden. Vergeet niet om kleenex mee te nemen, want het kan emotioneel worden!",ep:11,g:15,l:28,wd:true,fm:true,w:1,p:2300};
I.u[1490] = {n:"Nhanor Kibrill Ketting",t:1,d:"Zijn maker, een zekere Ken Aton, was erg bekend om zijn vreemde gewoonten. Hij bracht zijn dagen door met het jagen op de Minotoror om een borsttapijt voor zichzelf te maken.",ep:1,g:12,l:13,wd:true,fm:true,w:2,p:650};
I.u[1491] = {n:"Liche Ketting",t:1,d:"De Liche was een onguur wezen, die zich bij groepen dappere krijgers aansloot om een deel van hun oorlogsbuit te ontfutselen. Op een dag werd zijn spelletje ontdekt en hij moest toen snel de benen nemen.",ep:13,g:12,l:45,wd:true,fm:true,w:2,p:5400};
I.u[1493] = {n:"Sacrier Verwonding",t:9,d:"Men zegt dat deze ring voortkomt uit een van de vele verwondingen die een Sacrier opliep.",ep:1,g:13,l:15,wd:true,fm:true,w:2,p:800};
I.u[1494] = {n:"De Ringer",t:9,d:"Deze leuke ring had als eerste doel de Osamodas in staat te stellen hun tofu te herkennen in de gevechten.",ep:1,g:14,l:15,wd:true,fm:true,w:4,p:800};
I.u[1495] = {n:"Ano Din Ring",t:9,d:"Deze kleine ring die er niet uitziet, is gemaakt door Degun. Deze juwelier was bekender vanwege zijn gevloek naar iedereen en zijn wrede aversie tegen de Liche, dan vanwege zijn creativiteit met betrekking tot de edelsmidkunst.",ep:1,g:37,l:36,wd:true,fm:true,w:3,p:3575};
I.u[1496] = {n:"Ecaflip Geluk",t:9,d:"Deze ring is gemaakt om het geluk van zijn drager tijdens het kaarten te verhogen.",ep:1,g:32,l:20,wd:true,fm:true,w:4,p:1300};
I.u[1497] = {n:"Xelor\'s verleden",t:9,d:"Deze ringen zijn ontstaan tijdens de tijdreizen van Xelor.",ep:1,g:16,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1498] = {n:"Enutrof Souvenir",t:9,d:"Ringen gemaakt van de tranen van een Enutrof die zijn schep verloren heeft. Dat geeft een idee hoe wanhopig de goede man was.",ep:1,g:15,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1499] = {n:"De Enutrofion",t:9,d:"Deze ring is alleen bestemd voor Enutrofs. Hun god heeft hem betoverd zodat alleen zijn discipelen hem kunnen  dragen. Met deze ring kan elke zichzelf respecterende Enutrof heel veel geluk hebben bij het ontdekken van schatten.",ep:1,g:39,l:59,wd:true,fm:true,w:1,c:"PG=3",p:10000};
I.u[1500] = {n:"Tappijt",t:17,d:"Deze geweldige cape, geweven van allerlei vezelelementen is een zeldzaam stuk vanwege zijn kleur en schittering.",ep:8,g:8,l:43,wd:true,fm:true,w:16,p:5000};
I.u[1501] = {n:"Trouwring",t:9,d:"Deze trouwring symboliseert de verbintenis van twee hevig verliefde zielen. Jullie hoeven je niet meer te verstoppen achter een bosje, dit keer is het ernst, jullie kunnen je nu zonder enig bezwaar samen in het openbaar vertonen.",ep:2,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[1503] = {n:"Gekke Vuur Stok",t:3,d:"Men zegt dat je, om dit lugubere stokje te maken, het in het lijf van een vers kadaver moet stoppen en kort daana moet begraven. Maar niemand durft zich voor te stellen hoe dat zou moeten.",ep:3,g:14,l:20,wd:true,fm:true,w:15,an:11,e:[5,3,2,3,30,50,false,true],c:"CI>30",p:1000};
I.u[1504] = {n:"Dolk O\'Bert",t:5,d:"Roodnek O\'Bert was beroemd op het platteland. Hij werd onthoofd toen hij luidkeels zong. Vandaar zijn bijnaam. De schuldige dolk werd gevonden, maar niemand zocht naar zijn eigenaar. O\'Bert zong echt heel vals.",ep:1,g:1,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1505] = {n:"Fluit",t:20,d:"Deze zeer zeldzame fluit van hout van de Boomchnid stelt je in staat je vrienden af te leiden en te ontroeren.",ep:1,g:6,l:1,wd:true,fm:true,w:1,an:4,e:[0,5,1,1,0,0,false,false],p:50000};
I.u[1506] = {n:"Symbool van het vreemde",t:15,d:"Deze speelkaart stelt ... iets voor. Eigenlijk weten we niet precies wat, maar men is ervan overtuigd dat het belangrijk is.",ep:1,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[1507] = {n:"Bon voor 1000 Kek",t:15,d:"Een kleine slogan is op dit stukje papier geschreven:\n \"Bravo, je hebt in je bezit een KeK bon, bewijs dat je een bewonderenswaardig persoon bent, kom naar ons toe om hem te gebruiken, we verwachten je!\" Gevolgd door de plattegrond coördinaten -1,-2.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1508] = {n:"Bon voor 2000 Kek",t:15,d:"Een kleine slogan is op dit stukje papier geschreven:\n \"Bravo, je hebt in je bezit een KeK bon, bewijs dat je een bewonderenswaardig persoon bent, kom naar ons toe om hem te gebruiken, we verwachten je!\" Gevolgd door de plattegrond coördinaten -1,-2.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1509] = {n:"Bon voor 5000 Kek",t:15,d:"Een kleine slogan is op dit stukje papier geschreven:\n \"Bravo, je hebt in je bezit een KeK bon, bewijs dat je een bewonderenswaardig persoon bent, kom naar ons toe om hem te gebruiken, we verwachten je!\" Gevolgd door de plattegrond coördinaten -1,-2.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1510] = {n:"Bon voor 10000 Kek",t:15,d:"Een kleine slogan is op dit stukje papier geschreven:\n \"Bravo, je hebt in je bezit een KeK bon, bewijs dat je een bewonderenswaardig persoon bent, kom naar ons toe om hem te gebruiken, we verwachten je!\" Gevolgd door de plattegrond coördinaten -1,-2.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1511] = {n:"Negen Staarten",t:6,d:"Volgens de legende die het Dantesque gevecht beschrijft, waarna hij een promotie tot God kreeg, gebruikten de Ecaflip een wapen gemaakt met het volgende principe: “een staart voor een leven”.  Deze serie zwaarden is gesmeedt als eerbetoon aan hem.",ep:13,g:19,l:80,wd:true,fm:true,w:20,an:14,e:[9,9,1,1,20,20,false,false],c:"CS>99&CA>99&CV>99",p:20000};
I.u[1512] = {n:"De Legende van de Crocoburio",t:25,d:"Dit boek traceert de geschiedenis van de op trieste wijze beroemde Crocoburio.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1514] = {n:"Vergeetdrankje: \'Weerslag\'",t:43,d:"Met behulp van dit drankje kan je een niveau van de betovering van de Ecaflip afleren: \'Weerslag\'.",ep:2,g:27,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1515] = {n:"Vuur Bwak Ei",t:72,d:"Een ei gelegd door een Wind Kwak staat op het punt om uit te komen... Het broedsel in van het begin af aan meteen agressief, de ouders zijn de enige beesten die een Bwak nooit aanvalt.",ep:1,g:59,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[1516] = {n:"Aarde Bwak Ei",t:72,d:"Een ei gelegd door een Aarde Kwak staat op het punt om uit te komen... Het broedsel in van het begin af aan meteen agressief, de ouders zijn de enige beesten die een Bwak nooit aanvalt.",ep:1,g:60,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[1517] = {n:"Wind Bwak Ei",t:72,d:"Een ei gelegd door een Wind Kwak staat op het punt om uit te komen... Het broedsel in van het begin af aan meteen agressief, de ouders zijn de enige beesten die een Bwak nooit aanvalt.",ep:1,g:61,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[1518] = {n:"Ijs Bwak Ei",t:72,d:"En ei gelegd door een Ijs Kwak staat op het punt om uit te komen... Het broedsel is vanaf het begin af aan agressief, zijn ouders zijn het enige beest wat een Bwak nooit aanvalt.",ep:1,g:62,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[1519] = {n:"Rune Fo",t:78,d:"Deze kleine rune heeft het vermogen het scherpste mes nog scherper te maken.",ep:1,g:43,l:10,wd:true,fm:true,w:1,p:10};
I.u[1520] = {n:"Dolk Smitmagus Hamer",t:7,d:"Deze hamer gedrenkt in magische olie is essnetieel om magische items te creëren.",ep:2,g:22,l:1,wd:true,fm:true,w:15,an:15,e:[5,6,1,1,40,40,false,false],c:"PJ=43",p:1000};
I.u[1521] = {n:"Rune Sa",t:78,d:"Deze kleine rune bezit het vermogen het oudste lemmet nog ouder te maken.",ep:1,g:49,l:10,wd:true,fm:true,w:1,p:10};
I.u[1522] = {n:"Rune Ine",t:78,d:"Deze kleine rune bezit het vermogen het schitterendste wapen nog schitterender te maken.",ep:1,g:37,l:10,wd:true,fm:true,w:1,p:10};
I.u[1523] = {n:"Rune Vi",t:78,d:"Deze rune bezit het vermogen het sterkste wapen nog sterker te maken.",ep:1,g:52,l:10,wd:true,fm:true,w:1,p:10};
I.u[1524] = {n:"Rune Leeftijd",t:78,d:"Deze kleine rune bezit het vermogen het lichtste wapen nog lichter te maken.",ep:1,g:46,l:10,wd:true,fm:true,w:1,p:10};
I.u[1525] = {n:"Rune Cha",t:78,d:"Deze kleine rune bezit de eigenschap het aantrekkelijkste wapen nog aantrekkelijker te maken.",ep:1,g:40,l:10,wd:true,fm:true,w:1,p:10};
I.u[1526] = {n:"Rode Metaria",t:66,d:"Deze vreemde bol lijkt in zijn kern een miniatuur vlam te bevatten.",ep:3,g:241,l:5,wd:true,fm:true,w:1,p:1};
I.u[1527] = {n:"Blauwe Metaria",t:66,d:"Deze vreemde bol lijkt in zijn kern een miniatuur plas te bevatten.",ep:3,g:244,l:5,wd:true,fm:true,w:1,p:1};
I.u[1528] = {n:"Gele Metaria",t:66,d:"Deze vreemde bol lijkt in zijn hart hoopjes miniatuuraarde te bevatten.",ep:3,g:247,l:5,wd:true,fm:true,w:1,p:1};
I.u[1529] = {n:"Groene Metaria",t:66,d:"In deze vreemde bol schijnt een miniatuur briesje te zitten.",ep:3,g:250,l:5,wd:true,fm:true,w:1,p:1};
I.u[1531] = {n:"Blauw Metaria Triam",t:66,d:"Deze vreemde bol schijnt binnenin een miniatuurmeer te bevatten.",ep:9,g:245,l:25,wd:true,fm:true,w:1,p:25};
I.u[1532] = {n:"Groene Metaria Triam",t:66,d:"In deze vreemde bol schijnt een miniatuur windstoot te zitten.",ep:9,g:248,l:25,wd:true,fm:true,w:1,p:25};
I.u[1533] = {n:"Rood Metaria Triam",t:66,d:"Deze vreemde bol schijnt binnenin een miniatuurhaard te bevatten.",ep:9,g:242,l:25,wd:true,fm:true,w:1,p:25};
I.u[1534] = {n:"Gele Triame Metaria",t:66,d:"Deze vreemde bol kan in zijn binnenste een kleine aarden heuvel bevatten.",ep:9,g:251,l:25,wd:true,fm:true,w:1,p:25};
I.u[1535] = {n:"Rode Mage Metaria",t:66,d:"Deze vreemd-uitziende omgeving lijkt een kleine explosie in het midden te bevatten.",ep:4,g:243,l:50,wd:true,fm:true,w:1,p:50};
I.u[1536] = {n:"Blauwe Mage Metaria",t:66,d:"Deze vreemd-uitziende omgeving lijkt een kleine zee in het midden te bevatten.",ep:4,g:246,l:50,wd:true,fm:true,w:1,p:50};
I.u[1537] = {n:"Groene Mage Metaria",t:66,d:"Deze vreemd uitziende bol lijkt een kleine cycloon te bevatten in het midden.",ep:4,g:252,l:50,wd:true,fm:true,w:1,p:50};
I.u[1538] = {n:"Gele Mage Metaria",t:66,d:"Deze vreemd-uitziende omgeving lijkt een kleine explosie in het midden te bevatten.",ep:4,g:249,l:50,wd:true,fm:true,w:1,p:50};
I.u[1539] = {n:"Zwaard Forgemage\'s Hamer",t:7,d:"Hamer gedrenkt in magische olie, essentieel om magische items te creeëren.",ep:2,g:22,l:1,wd:true,fm:true,w:15,an:15,e:[5,6,1,1,40,40,false,false],c:"PJ=44",p:1000};
I.u[1542] = {n:"Beroepsvergeetdrankje: \'Dolksmid\'",t:44,d:"Door dit drankje vergeet je het beroep van Dolksmid",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[1543] = {n:"Fragment van de sokkel van De Crocobur",t:24,d:"Dit fragment komt van de sokkel waarin De Crocobur, het triest beroemde zwaard van Crocoburio heeft geslapen en waar het misschien nog eeuwen zal slapen, ondertussen de steen beetje bij beetje doordrenkend van zijn magische krachten.",ep:1,g:28,l:1,wd:true,fm:true,w:0,p:1};
I.u[1545] = {n:"Rune Pa Fo",t:78,d:"Deze krachtige rune bezit het vermogen het scherpste lemmet nog scherper te maken.",ep:1,g:44,l:20,wd:true,fm:true,w:1,p:10};
I.u[1546] = {n:"Rune Pa Sa",t:78,d:"Deze krachtige rune bezit het vermogen het oudste lemmet nog ouder te maken.",ep:1,g:50,l:20,wd:true,fm:true,w:1,p:10};
I.u[1547] = {n:"Rune Pa Ine",t:78,d:"Deze krachtige rune bezit het vermogen het schitterendste wapen nog schitterender te maken.",ep:1,g:38,l:20,wd:true,fm:true,w:1,p:10};
I.u[1548] = {n:"Rune Pa Vi",t:78,d:"Deze sterke rune heeft het vermogen nog sterker te maken.",ep:1,g:53,l:20,wd:true,fm:true,w:1,p:10};
I.u[1549] = {n:"Rune Pa Leeftijd",t:78,d:"Deze krachtige rune bezit het vermogen het lichtste wapen nog lichter te maken.",ep:1,g:47,l:20,wd:true,fm:true,w:1,p:10};
