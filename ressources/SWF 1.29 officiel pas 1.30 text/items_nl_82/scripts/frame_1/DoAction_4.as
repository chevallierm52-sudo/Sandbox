I.u[1619] = {n:"De Boomu",t:1,d:"De Boomu is een erg elegant amulet. Als je van plan bent dit amulet te dragen, raden we je aan om het naakt te dragen, om het goed te laten uitkomen. Je zult zien, de dames kunnen er geen weerstand tegen bieden.",ep:9,g:16,l:46,wd:true,fm:true,w:2,p:5700};
I.u[1620] = {n:"Boomchboog",t:2,d:"Deze boog is nog levendig en kan bijna helemaal zelf pijlen schieten, net als een echte boog. Hij zou ideaal geweest zijn voor mensen met twee linkerhanden, maar helaas, je moet toch de pijl altijd in de goede richting plaatsen.",ep:9,g:24,l:39,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,50,30,false,true],p:4200};
I.u[1621] = {n:"Beheers Laarzen",t:11,d:"De Beheers Laarzen vergroten de behendigheid en intelligentie van hun werper in ruil voor kracht en geluk. In tegenstelling tot wat men zou kunnen denken, kun je niet je tegenstanders ermee bedwingen.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1622] = {n:"Kracht Laarzen",t:11,d:"De Kracht Laarzen vergroten de behendigheid en intelligentie van hun werper in ruil voor kracht en geluk. In tegenstelling tot wat met zou kunnen denken, kun je niet je tegenstanders ermee bedwingen.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1623] = {n:"Anticipatie Laarzen",t:11,d:"De Anticipatielaarzen vergroten de kracht en de behendigheid van degene die ze werpt, maar dat gaat ten koste van de intelligentie en geluk. In tegenstelling tot wat men zou denken, stellen ze je niet staat de acties van de tegenstanders te voorzien.",ep:4,g:15,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1624] = {n:"Nexus Laarzen",t:11,d:"Deze laarzen waren ooit van Nexus, een voor altijd verstard groot ridder.",ep:3,g:16,l:17,wd:true,fm:true,w:5,p:1000};
