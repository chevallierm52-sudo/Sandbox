I.u[1803] = {n:"Kitten Baars",t:41,d:"Het uiterlijk van zijn vader, de mensenschuwheid van zijn moeder. Deze vis is bijna het moeilijkst te vangen ter wereld. Hij is ook de zeldzaamste... Gezien het feit dat het paren van een Kitten Vis en een Rivierbaars-Vis uitzonderlijk is.",ep:1,g:315,l:70,wd:true,fm:true,w:3,p:50};
I.u[1804] = {n:"Schoongemaakte Kitten Baars",t:62,d:"Deze kittenbaars kan nu worden gebruikt als ingrediënt.",ep:1,g:316,l:70,wd:true,fm:true,w:2,p:50};
