I.u[1849] = {n:"Tupe-Halett Snoek",t:41,d:"Ontstaan door het kruisen van verschillende soorten snoeken door de geleerden Halett en Tupe, wordt deze soort geacht over magische attributen te beschikken. Bestemd voor experimenten, zijn twee exemplaren ontsnapt tijdens een heftige discussie tussen de twee geleerden.",ep:1,g:402,l:10,wd:true,fm:true,w:3,p:1};
I.u[1851] = {n:"Schoongemaakte Tupe-Halett Snoek",t:62,d:"Deze Tupe-Halett snoek kan nu gebruikt worden als ingrediënt.",ep:1,g:403,l:10,wd:true,fm:true,w:2,p:1};
