I.u[1646] = {n:"Beroepsvergeetdrankje: \'Magische Schepsmid\'",t:44,d:"Door dit drankje vergeet je het beroep van Magische Schepsmid",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[1647] = {n:"Beroepsvergeetdrankje: \'Magische Boog Snijder\'",t:44,d:"Door dit drankje vergeet je het beroep van Magische Boog Snijder",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[1648] = {n:"Beroepsvergeetdrankje: Magische Stoksnijder",t:44,d:"Dit drankje doet je je beroep van magische stoksnijder vergeten.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[1649] = {n:"Beroepsvergeetdrankje: \'Magische Staf Snijder\'",t:44,d:"Door dit drankje vergeet je het beroep van Magische Staf Snijder",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[1650] = {n:"De Grote Cutter",t:6,d:"Dit zwaard is bijzonder geschikt om kleine mensen aan te vallen. Snel, handzaam en vooral bijzonder scherp. Daarom is hij al sinds lange tijd uit de handel gehaald. Maar heden wordt hij getolereerd als anti-Bworkverdediging.",ep:14,g:23,l:58,wd:true,fm:true,w:12,an:14,e:[10,5,1,1,30,50,false,false],p:5200};
I.u[1651] = {n:"De Bloederige Cutter",t:6,d:"Dit zwaard is uitstekend geschikt om aardige personen aan te vallen. Snel, goed hanteerbaar en vooral bijzonder scherp. Daarom is hij al sinds lange tijd uit de handel genomen, maar wordt vandaag de dag getolereerd als anti-bwork wapen.",ep:14,g:23,l:64,wd:true,fm:true,w:12,an:14,e:[10,5,1,1,30,50,false,false],p:5200};
I.u[1652] = {n:"Volwassen Arachnee Poot",t:103,d:"Heel fijn, maar zeer behaard pootje. Het werd vroeger gebruikt bij het maken van bezems en pruiken met een wat exotisch karakter.",ep:1,g:246,l:39,wd:true,fm:true,w:1,p:1};
I.u[1653] = {n:"Geloof van Don Rouann",t:24,d:"Deze ring symboliseert het feit dat je op zoek bent naar het geheim van Don Rouann. Je hebt nu moed geleerd.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1654] = {n:"Geloof van Don Rouann",t:24,d:"Deze ring symboliseert het feit dat je op zoek bent naar het geheim van Don Rouann. Je hebt nu moed en communicatie geleerd en moet nu geduldig zijn.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1655] = {n:"Geloof van Don Rouann",t:24,d:"Deze ring symboliseert het feit dat je op zoek bent naar het geheim van Don Rouann.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1656] = {n:"Magus Fecalisateur",t:9,d:"Deze ring is in staat zijn drager te beschermen tegen kleine magische aanvallen en dus in het verlengde daarvan, tegen monstertjes die magie gebruiken om slim te doen en zichzelf interessant te maken.",ep:1,g:40,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1657] = {n:"Oorlogs Fecalisator",t:9,d:"Deze ring is in staat zijn drager te beschermen tegen kleine fysieke aanvallen en ook tegen aanvallen van kleine monsters die je met hun uiterlijk vertoon proberen te verrassen.",ep:1,g:41,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1658] = {n:"Klaasse",t:22,d:"Met deze zeis heb je overduidelijk \"klasse\", je kan je zelfs voordoen als de Boer met de meeste \"klasse\" ter wereld. Pas echter op, je houdt de monsters niet voor de gek, zij zullen je uitlachen als je \"klasse\" en koketterie met elkaar verwart.",ep:0,g:1,l:31,wd:true,fm:true,w:15,e:[10,5,1,1,50,45,false,false],c:"CA>40&CV>20",p:2670};
I.u[1659] = {n:"Mack Kormick Zeis",t:22,d:"Sinds de nacht der tijden scheert Mack Kormick de maaier, hele graanvelden en alle monsters die zich daar bevinden, met deze zeis. Vandaag de dag is het aan jou te tonen dat je het gebruik van deze zeis waardig bent, dus aan ´t werk!",ep:0,g:1,l:56,wd:false,fm:true,w:15,an:12,e:[10,5,1,1,45,50,false,false],c:"CC>80&CA>40&CI>20",p:8345};
I.u[1660] = {n:"Duistere Boomchnid Barnsteen",t:50,d:"Deze prachtige barnsteen bevat een gemeen beestje gevangen in het sap van zijn meester. Een sarcofage toverspreuk, waarmee de Duistere Boomchnid goede herinneringen behoudt aan zijn bezweringen als deze eenmaal dood zijn.",ep:9,g:638,l:78,wd:true,fm:true,w:2,p:6000};
I.u[1661] = {n:"Moskito Ambramulet",t:1,d:"Met het om je nek dragen van een Moskito gevangen in een barnsteen, toon je je tegenstanders dat je een beduchte jager van ... Moskitos bent. Waarmee je je belachelijk maakt buiten de Bakermat.",ep:1,g:17,l:40,wd:true,fm:true,w:5,p:4400};
I.u[1662] = {n:"Arachnee Ambamulet",t:1,d:"Het dragen van een amber Arachnee rond je nek als je één van zijn zusters aanvalt kan genoeg zijn om hem in verlegenheid te brengen. Arm insect, dat is wat we “het noodlot tarten” noemen.",ep:1,g:18,l:34,wd:true,fm:true,w:5,p:3225};
I.u[1663] = {n:"Crocodyle Schub",t:59,d:"Deze schub van de Crocodyl vormt een kleine jachttrofee voor elke beginnende jager die zichzelf respecteert. Aarzel niet om het te laten zien aan de dronkaards in de herberg, zij zullen overduidelijk onder de indruk zijn en zullen je een drankje aanbieden.",ep:4,g:233,l:36,wd:true,fm:true,w:5,p:50};
I.u[1664] = {n:"Crocodyle Tand",t:47,d:"Als een Crocodyl een tand tegen je heeft, is de beste oplossing die tand te trekken met kracht en vastberadenheid, zoals een strenge tandarts.",ep:4,g:234,l:36,wd:true,fm:true,w:1,p:50};
I.u[1665] = {n:"Scholings Laarzen",t:11,d:"Deze nogal vreemde laarzen werden gebruikt voor de jonge, qua intelligentie wat beperkte discipelen, zodat ze hun achterstand konden inhalen. Ze zijn in het bijzonder geschikt voor Iops.",ep:4,g:68,l:50,wd:true,fm:true,w:10,p:6675};
I.u[1666] = {n:"Laarzen van de Leerling Bezweerder",t:11,d:"Deze laarzen zijn speciaal gemaakt voor degenen die ervan houden om hun wezens  al het werk te laten doen tijdens de gevechten.",ep:12,g:14,l:51,wd:true,fm:true,w:10,p:7000};
I.u[1667] = {n:"Tutelutu Riem",t:10,d:"Deze riem draagt de belachelijke naam van zijn maker, Tutelutu, een schoenmaker die veel minder bekend is dan Bowisse, maar toch nog erg creatief, ondanks zijn leeftijd.",ep:8,g:13,l:50,wd:true,fm:true,w:10,p:6700};
I.u[1668] = {n:"Trillende Dodu Riem",t:10,d:"De Dodu was een Sadida, die graag zijn vijanden bang maakte. Hij vroeg aan Bowisse om een riem te maken die bij de kleur van z\'n haar paste... want de Dodu was niet alleen een pestkop, hij was ook een charmeur.",ep:4,g:14,l:55,wd:true,fm:true,w:8,p:8000};
I.u[1669] = {n:"Wind Riem",t:10,d:"Deze riem is ontworpen door de meest populaire Craette, die tijd noch moeite spaarde om diverse feesten en buitengewone evenementen te organiseren om het volk te vermaken tussen twee strijkwerkzaamheden van de Leren Onderbroek van Kapitein Chafer door.",ep:8,g:15,l:84,wd:true,fm:true,w:10,p:18300};
I.u[1670] = {n:"Puntige Wind Kwak Veer",t:53,d:"Soms beschikt een Wind Kwak over een puntige veer die anders is dan alle andere, hij is over het algemeen magisch en kan gebruikt worden om zich te vermommen als indianen opperhoofd.",ep:5,g:393,l:24,wd:true,fm:true,w:10,p:100};
I.u[1671] = {n:"Magische Haver",t:34,d:"Dit strootje van Magische Haver komt van een bescheiden boer die betoverd is door een leerling Bwork Magus, die zijn boek ondersteboven hield.",ep:1,g:550,l:20,wd:true,fm:true,w:10,p:0};
I.u[1672] = {n:"Darits Haar",t:54,d:"Deze haren vormen de laatste resten van Darit, een jonge zeer verwaande tovenaar, die vergeten was na te gaan wat de Prespic gebruikt had (en hij had Tegen gebruikt) alvorens zijn betovering Verscheurende Bliksem te gebruiken.",ep:1,g:555,l:18,wd:true,fm:true,w:1,p:100};
I.u[1673] = {n:"Magische Arachnee Poot",t:103,d:"Dit Arachneepootje is niet als alle andere, het beweegt uit zichzelf en lijkt vol leven, zelfs als het eenmaal van zijn eigenaresse is afgerukt. Een nieuw leven zou voor dit pootje kunnen beginnen, dat aangetrokken lijkt door het modevak.",ep:1,g:392,l:2,wd:true,fm:true,w:10,p:100};
I.u[1674] = {n:"Luidegît Champignon",t:15,d:"Deze held is betoverd door de Slappe Eik, maar door de wat onzekere magie van deze laatste is hij in een champignon veranderd. Omdat de Champs nogal stom zijn, vereerden ze hem en beschermden ze hem tot aan de dood.",ep:1,g:390,l:46,wd:true,fm:true,w:10,p:100};
I.u[1675] = {n:"Verrassingsbot van de Chafer Infanterist",t:47,d:"Met dit magische Bot kunnen de infanteristen chafers verrassende dingen doen, zoals hun onderbroek uitdoen en op hun hoofd doen, zonder handen, midden in het gevecht en ondertussen slagen met hun ontwijkende worpen. Je krijgt nooit genoeg van deze prestatie.",ep:3,g:15,l:35,wd:true,fm:true,w:1,p:100};
I.u[1676] = {n:"Betoverde Teenwilg",t:15,d:"Met dit stukje betoverde Teenwilg zou je een geweldig mandje magisch fruit moeten kunnen maken, dat elegantie en macht combineert, totaal het tegenovergestelde van een kwaadaardige Doornhaai.",ep:2,g:123,l:69,wd:true,fm:true,w:10,p:100};
I.u[1677] = {n:"Dantegoulesque Drankje",t:12,d:"Dit toverdrankje is het enige dat de gevlochten Leren Onderbroeken van Kapitein Chafer magisch kan maken, nou, dat zegt veel over de kracht van zo\'n drankje.",ep:2,g:139,l:50,wd:true,fm:true,w:10,p:1000};
I.u[1678] = {n:"Getraumatiseerde Kokokonoot",t:46,d:"Deze Kokokonoot is in zijn kindertijd getraumatiseerd. Haat was het motief om zo krachtig als mogelijk te worden...",ep:12,g:552,l:42,wd:true,fm:true,w:2,p:100};
I.u[1679] = {n:"Kristalbol Steen",t:50,d:"Met een beetje geduld en wat moeite kan deze edelsteen mooi rond en schitterend worden als een kwastje op een magische hoed. Door zijn vorm kan hij bovendien bijna overal naartoe glijden.",ep:4,g:240,l:16,wd:true,fm:true,w:10,p:100};
I.u[1680] = {n:"Minotoror Verbrande Hoorn",t:47,d:"Deze Minotoror hoorn is een magisch artefact van keuze aangezien hij verbrand was door een zeer krachtige magie. Helaas, zoals zoveel dingen, zijn ze efficiënter als je er twee van hebt.",ep:2,g:245,l:125,wd:true,fm:true,w:10,p:100};
I.u[1681] = {n:"Magische Groene Larve Huid",t:59,d:"Vergis je niet, achter zijn kleverige verschijning schuilt een kunstvoorwerp, dat als je het dicht bij je hoofd draagt, je net zoveel geluk brengt als een bedrogen Chafer.",ep:1,g:391,l:7,wd:true,fm:true,w:10,p:100};
I.u[1682] = {n:"Schors van Prak Sis",t:96,d:"Dit stuk schors is afkomstig van een boom op de open plek die betoverd is door Prak Sis.\nDit stuk liet los toen Brouce Bolgour, de houthakker, zijn Bolgourd brak, toen hij een betoverde boom probeerde om te hakken.",ep:9,g:542,l:78,wd:true,fm:true,w:1,p:100};
I.u[1683] = {n:"Tas voor Geschilde Aardapelen",t:15,d:"Met deze magische tas kon een gewiekste Sadida een ongelofelijke hoeveelheid geschilde aardappelen vervoeren om ze te verkopen aan de gevangenen. Toen hij was overleden, werd de tas van de ene Gladjanus op de andere Gladjanus overgedragen als een soort ritueel.",ep:1,g:243,l:12,wd:true,fm:true,w:10,p:100};
I.u[1684] = {n:"Tas voor Duistere Aardappelen",t:15,d:"Dit is zo\'n beetje dezelfde zak als de Zak met Geschilde Aardappelen, al is deze ondergedompeld in sap van de Duistere Boomchnid, waardoor hij extra krachten heeft gekregen.",ep:1,g:244,l:12,wd:true,fm:true,w:10,p:100};
I.u[1685] = {n:"Veer van het Laatste Kuken",t:53,d:"Pas op, je hebt in je bezit de laatste veer die van het achterwerk van het laatste Kuken in heel Amakna is geplukt. Deze veer vormt een heel mooi cadeau voor je Kleermakersvrienden, of voor de Kuken-fanatici, waarvan er in de loop der tijd meer en meer zijn gekomen.",ep:3,g:247,l:32,wd:true,fm:true,w:1,p:100};
I.u[1686] = {n:"Rode Magische Verf",t:70,d:"Met dit magische drankje krijg je een prachtige rode kleur haar. In tweede instantie zou het enkele magische effecten schijnen te bevatten.",ep:7,g:63,l:10,wd:true,fm:true,w:1,p:500};
I.u[1687] = {n:"Groenachtige Magische Verf",t:70,d:"Dit magische drankje geeft een schitterende groene kleur aan alle vachten waarop het wordt aangebracht. Bovendien schijnt het enige magische effecten te hebben.",ep:1,g:64,l:10,wd:true,fm:true,w:1,p:500};
I.u[1688] = {n:"Blauwachtige Magische Verf",t:70,d:"Dit magische drankje geeft een schitterende blauwe kleur aan alle vachten waarop het wordt aangebracht. Bovendien schijnt het enige magische effecten te hebben.",ep:5,g:65,l:10,wd:true,fm:true,w:1,p:500};
I.u[1689] = {n:"Oranje Magische Verf",t:70,d:"Dit magische drankje geeft een schitterende oranje kleur aan alle vachten waarop het wordt aangebracht. Bovendien schijnt het enige magische effecten te hebben.",ep:1,g:66,l:10,wd:true,fm:true,w:1,p:500};
I.u[1690] = {n:"Miliboowolf Haar",t:54,d:"Deze haren lijken op die van de Boowolf, een beetje korter, minder sterk, maar zachter. Helaas is de geur hetzelfde.",ep:1,g:554,l:22,wd:true,fm:true,w:1,p:1};
I.u[1691] = {n:"Moowolf Haar",t:54,d:"Weinig avonturiers zullen de kans krijgen deze haren in levende lijve te kunnen aanraken. Maar dat wil nog niet zeggen dat je dan een held bent.",ep:2,g:553,l:198,wd:true,fm:true,w:10,p:200};
I.u[1692] = {n:"Duistere Magische Verf",t:70,d:"Dit magische drankje geeft een schitterende zwarte kleur aan alle vachten waarop het wordt aangebracht. Bovendien schijnt het enige magische effecten te hebben.",ep:1,g:67,l:10,wd:true,fm:true,w:1,p:500};
I.u[1693] = {n:"Jules Yanos Cape",t:17,d:"Jules Yanos, een beroemd kleermaker, was vooral beroemd omdat hij zijn vrouw had geruild voor een magische vingerhoed. Zo zie je maar, er zijn nog mensen met gevoel voor zaken.",ep:8,g:8,l:54,wd:true,fm:true,w:1,p:7800};
I.u[1694] = {n:"Woedende Trool Wol",t:57,d:"Dit stukje wol is afkomstig van de gevaarlijkste Trool van Amakna, die veranderd zou zijn in een sprei, door een kleermaker zonder scrupules, dezelfde die zogenaamd zijn vrouw zou hebben geruild voor een magische vingerhoed. Het blijft een groot mysterie.",ep:4,g:27,l:115,wd:true,fm:true,w:10,p:1};
I.u[1695] = {n:"Elya Wood Cape",t:17,d:"Men zegt dat Kapitein Chafer heeft geprobeerd deze cape te stelen ter vervanging van zijn beroemde leren ondergoed. Maar hij vond hem niets, want hij straalde niet genoeg perversiteit en valsheid uit voor hem.",ep:8,g:9,l:80,wd:true,fm:true,w:10,s:39,p:16500};
I.u[1696] = {n:"Moowolf Stof",t:55,d:"Kleermakers hebben lichtjaren geleden een manier gevonden om de waarde van een stof vast te stellen, hoe meer de stof stinkt, hoe krachtiger hij is. Deze stinkt meer dan een voetbad van Enutrofs waarin een Chafer zijn onderbroek heeft gewassen.",ep:2,g:14,l:198,wd:true,fm:true,w:20,p:300};
I.u[1697] = {n:"Kleine Vreetzakjes Tas",t:81,d:"Met deze kleine tas zul je geen beroemdheid worden, maar je kunt er wel je spullen in opbergen.",ep:1,g:25,l:1,wd:true,fm:true,w:5,p:100};
I.u[1698] = {n:"Kleine Verzamelaars Tas",t:81,d:"Deze zak is speciaal bedacht om enkele verzamelmaterialen te bevatten.\nAlleen echte verzamelaars zijn in staat hem te dragen. (verzamelniveau 20 vereist).",ep:1,g:26,l:5,wd:true,fm:true,w:5,c:"PJ>2,20|PJ>24,20|PJ>36,20|PJ>28,20|PJ>26,20|PJ>41,20",p:2000};
I.u[1699] = {n:"Tas van de Kleine Avonturier",t:81,d:"Deze tas is bestemd voor hen die niet al te ver van huis gaan en niet erg belangrijke dingen willen meenemen, zoals bijvoorbeeld essenhouten planken.",ep:1,g:27,l:10,wd:true,fm:true,w:5,p:3000};
I.u[1700] = {n:"Snelheidsriem",t:10,d:"Deze aerodynamische riem gemaakt door Tengra Reufrus maakt je lenig als lucht, en vrij als een Tofu. Tenzij het omgekeerde het geval is.",ep:4,g:17,l:27,wd:true,fm:true,w:15,p:2000};
I.u[1701] = {n:"Zak Riem",t:10,d:"Deze riem heeft zakjes waardoor je meer voorwerpen in je inventaris kunt opbergen.",ep:1,g:16,l:20,wd:true,fm:true,w:10,p:1300};
I.u[1702] = {n:"Verzamel Tas",t:81,d:"Deze tas is speciaal bedacht om te verzamelen voorwerpen in te doen. Alleen de echte verzamelaars kunnen hem dragen (niveau 40 verzamelaar is vereist.)",ep:8,g:28,l:15,wd:true,fm:true,w:10,c:"PJ>2,40|PJ>24,40|PJ>36,40|PJ>28,40|PJ>26,40|PJ>41,40",p:3000};
I.u[1703] = {n:"Grote Oogster Tas",t:81,d:"Deze tas is speciaal bedacht om te verzamelen voorwerpen in te doen. Alleen de echte verzamelaars kunnen hem dragen (level 60 oogster is vereist).",ep:8,g:29,l:20,wd:true,fm:true,w:10,c:"PJ>2,60|PJ>24,60|PJ>36,60|PJ>28,60|PJ>26,60|PJ>41,60",p:2000};
I.u[1704] = {n:"Staca Noviste Tas",t:81,d:"Men zegt dat Staca Noviste, een beroemde Mijnwerker in staat was om zonder pauze gedurende maanden in 4 verschillende mijnen tegelijkertijd te delven. Uiteraard gaat het om een door het gilde van de Hamer en Sikkel bedachte legende om hun mijnwerkers te stimuleren meer te delven.",ep:8,g:30,l:20,wd:true,fm:true,w:10,c:"PJ>2,90|PJ>24,90|PJ>36,90|PJ>28,90|PJ>26,90|PJ>41,90",p:10000};
I.u[1705] = {n:"Avonturiers Tas",t:81,d:"Dit is een ideale tas om je brood en drankjes in te dragen als je voor langere tijd vertrekt, bijvoorbeeld naar het labyrint.",ep:8,g:31,l:40,wd:true,fm:true,w:4,p:4000};
I.u[1707] = {n:"Tas van de grote avonturier",t:81,d:"Dit is de ideale tas om al je broden en toverdrankjes in te bewaren als je op reis gaat naar exotische bestemmingen, zoals het Moon eiland.",ep:13,g:32,l:60,wd:true,fm:true,w:5,p:6000};
I.u[1709] = {n:"Botje",t:47,d:"\"En wie is mammies lieve wafwaf?\" Dat waren de laatste woorden van een Enutrof die een moowolf voor haar huisdier aanzag.",ep:1,g:15,l:1,wd:true,fm:true,w:2,p:1};
I.u[1710] = {n:"Wassende Maan",t:1,d:"De oorsprong van dit amulet, die een maankwartier voorstelt, is bij niemand bekend... of bijna niemand. Wie weet welke geheimen dit sieraad herbergt...",ep:1,g:19,l:1,wd:false,fm:true,w:10,p:1000};
I.u[1711] = {n:"Wafwaf",t:18,d:"Met deze kleine wafwaf, proef je de geneugten van kleine plasjeswandelingen. Wegens zijn sterke wilde wortels, wordt het afgeraden hem te eten te geven, op straffe van het verliezen van een hand.\n(DIT HUISDIER HOUDT VAN GEEN ENKEL BESTAANSMIDDEL)",ep:1,g:6,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1712] = {n:"Pauwe Raide Drankje",t:12,d:"Met deze toverdrank kun je enkele health points terugverdienen.",ep:1,g:140,l:20,wd:true,fm:true,w:1,u:true,p:50};
I.u[1713] = {n:"Raide Boule Drankje",t:12,d:"Met deze drank kun je enkele health points terugverdienen.",ep:1,g:141,l:40,wd:true,fm:true,w:1,u:true,p:100};
I.u[1715] = {n:"Het Kwest Cadeau",t:25,d:"Bestseller van het eind van het jaar 634, dit boek moet gelezen worden. Een klassieker!",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1716] = {n:"De familie DuCiel",t:25,d:"Dit boek, op één na beste verkoop in de winter van 634, is nu al een naslagwerk.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1717] = {n:"Eerste Kerst",t:25,d:"De outsider van het begin van het jaar 635. Dit boek verdient  werkelijk je aandacht.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1718] = {n:"Crocoburio Kracht",t:9,d:"Deze ring werd betoverd door de zwarte adem van Grougalorasalar, wat hem een immense kracht gaf, tegenwoordig helaas afgezwakt. Dit relikwie was bestemd voor Crocoburio omdat hij de enige was die deze ring kon dragen zonder gebukt te gaan onder zijn dominantie.",ep:4,g:38,l:40,wd:true,fm:true,w:2,c:"CS>59",p:4000};
I.u[1719] = {n:"Geest van Crocoburio",t:11,d:"Dit paar laarzen zou aan Crocoburio toebehoren. De weinige personen die ze kunnen dragen, worden ineens overmand door machiavellistische en ingenieuze gedachten. Deze hekserij is, volgens de legende, te danken aan de duizenden schedels die ze hebben vermorzeld.",ep:4,g:12,l:42,wd:true,fm:true,w:10,c:"CI>49",p:5000};
I.u[1720] = {n:"Crocoburio Kracht",t:10,d:"Grougalorasalar bewaarde graag botten van de sterkste vijanden die hij had verslagen. Zijn genegenheid voor Crocoburio bracht hem ertoe diens botten te gebruiken om deze superkrachtige riem te maken.",ep:4,g:18,l:34,wd:true,fm:true,w:15,c:"CV>119",p:3000};
I.u[1721] = {n:"Vergeetdrankje: \'Klok\'",t:43,d:"Met behulp van dit drankje kan je een niveau van de betovering van de Xelor afleren: \'Klok\'.",ep:2,g:37,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1722] = {n:"Transformatie Boomchnid",t:27,d:"De vloek van de Slappe Eik heeft je in een boomchnid veranderd.\nOm deze betovering te doorbreken moet je een in het bos van de Boomchnids een verdwaalde avonturier overmeesteren.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1723] = {n:"Ultra-krachtig Rood Snoepje",t:28,d:"Dit snoepje geeft je tijdelijk een opkikker.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1724] = {n:"Guts",t:29,d:"Deze zegening verhoogt je Sterkte gedurende de komende gevechten.",ep:18,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1725] = {n:"Ontmoedigd",t:30,d:"Deze vloek ontneemt je de Kracht voor het eerstvolgende gevecht.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1726] = {n:"Tarche Haarlok",t:24,d:"Deze pluk haar bewijst je overwinning op Tarche. Wat een prestatie!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1727] = {n:"Dreigbrief",t:24,d:"Een dreigbrief gericht aan Dame Cloude.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1728] = {n:"MiauwMiauw",t:18,d:"Dit guitige en aanhalig bolletje haren weet de vrouwen van alle klassen en standen te vertederen. Het is een dus een geducht beestje.",ep:1,g:1,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1729] = {n:"Homur Ring",t:9,d:"Deze ring was van Mer, de grootste nietsnut van de hele Amakna-streek. Hij wijdde een godsdienst aan donuts, maar ook aan ribkoteletten.",ep:7,g:28,l:25,wd:true,fm:true,w:25,c:"CI<100&CC<100",p:1900};
I.u[1730] = {n:"Hoeveelheid zout",t:48,d:"Deze hoeveelheid zout is de ideale dosis voor het kruiden van vele heerlijke gerechten. Het is onmisbaar voor een geslaagd maal.",ep:1,g:261,l:1,wd:true,fm:true,w:1,p:1};
I.u[1731] = {n:"Dosis smaakvol sap",t:15,d:"Dit sap zal je de basissmaken leveren voor een smaakvol gerecht.",ep:1,g:262,l:1,wd:true,fm:true,w:1,p:4};
I.u[1732] = {n:"Kom",t:15,d:"Niets zo praktisch als een kom om netjes soep te drinken, hoewel netjes drinken de smaak niet verandert. Tenzij je vingers erg vies zijn.",ep:16,g:263,l:1,wd:true,fm:true,w:1,p:6};
I.u[1733] = {n:"Pâté",t:15,d:"\"Pâté, dat is een vleesgerecht, dat is gezond, waar het ook doorheen gaat. Leve de pâté, leve de pâté!!\" (Fragment uit de hymne van de slager couplet 4)",ep:16,g:264,l:1,wd:true,fm:true,w:1,p:6};
I.u[1734] = {n:"Kers",t:46,d:"Deze vrucht lijkt als twee druppels water op een paar enorme stuiterende ballen.",ep:1,g:265,l:1,wd:true,fm:true,w:1,p:1};
I.u[1735] = {n:"Certificaat van Plaatsing in Kennel: MiauwMiauw",t:77,d:"Dit certificaat beschrijft de eigenschappen van de MiauwMiauw die je in de kennel hebt geplaatst.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[1736] = {n:"Citroen",t:46,d:"Dit fruitsap is perfect om de bedorven geur van rottend vlees te verbergen. Een must-have als je opnieuw verhitte vis aan je gasten serveert.",ep:1,g:266,l:1,wd:true,fm:true,w:1,p:2};
I.u[1737] = {n:"Veld Brood",t:33,d:"In je zak of in je strot blijkt dit brood erg zwaar. Maar je moet toegeven dat zijn smaak het een rustiek tintje geeft, iets wat je van lekker brood mag verwachten.",ep:1,g:68,l:40,wd:true,fm:true,w:3,u:true,ut:true,p:1};
I.u[1738] = {n:"Stads Brood",t:33,d:"Zonder enige twijfel kan van dit brood gezegd worden dat het water je in de mond loopt bij de gedachte aan een lekker tussendoortje. Het verzadigt bijna onmiddellijk.",ep:1,g:69,l:10,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[1739] = {n:"Vurig Stok",t:3,d:"Dit stokje heeft vreemde eigenschappen: als je het aanraakt, brand je je. Maar het meest mysterieuze is zijn asgeur, waardoor je zou denken dat het hout van dit stokje een bosbrand overleefd zou hebben.",ep:13,g:24,l:80,wd:true,fm:true,w:1,an:11,e:[5,4,2,3,40,50,false,true],c:"CI>60&CV>40",p:1};
I.u[1740] = {n:"Transformatie Crocoburio",t:27,d:"De Crocobur omsluit de essentie van Corcoburio en kan slechts gestolen worden van zijn meester door deze van het leven te beroven.",ep:4,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1741] = {n:"Phenixbloed",t:14,d:"Met dit phenixbloed kan een geest weer tot leven gewekt worden en enkele health points terugkrijgen.",ep:18,g:3,l:10,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:1000};
I.u[1742] = {n:"Bloed van de Phenix Grand Cru",t:14,d:"Met dit phenixbloed kan een geest weer tot leven gewekt worden en veel energie krijgen.",ep:18,g:3,l:50,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:2500};
I.u[1744] = {n:"Torche Haarlok",t:24,d:"Deze pluk haar bewijst je overwinning op Torche. In alle schoonheid.",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1745] = {n:"Injectienaald van veearts",t:24,d:"Puntig uiteinde, reservoir, geen twijfel, het is een injectienaald...Je bent nu gewaarschuwd.",ep:1,g:31,l:1,wd:true,fm:true,w:0,p:1};
I.u[1746] = {n:"Wabbit GM Bloed",t:24,d:"Wie zou hebben kunnen bedenken om bij de wabbits aan te komen zetten met een spuit om bloed af te nemen bij het meest genetisch gemanipuleerde wezen van het eiland? Jij klaarblijkelijk.",ep:8,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[1747] = {n:"Analyse van bloed van Wabbit GM",t:24,d:"De analyse is formeel, het onderzochte bloed is afkomstig van het achterwerk van een Wabbit GM. De tests gingen zelfs zo ver dat de alchemist je kon zeggen in welke bil geprikt is, in dit geval de rechter.",ep:5,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[1748] = {n:"Wabbit",t:18,d:"Deze kleine Wabbit is tam gemaakt en zal je niet bijten. Of dat ook voor vreemdelingen geldt...",ep:8,g:7,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:11,p:1};
I.u[1749] = {n:"Trool Kermis Munt",t:15,d:"Je hebt deze munt gekocht van Leonzi Trool die ervan droomt om op een dag een voor ieder toegankelijke amusementshal te openen (Vlakte van Cania).",ep:13,g:737,l:1,wd:true,fm:true,w:1,p:1};
I.u[1750] = {n:"Visstick",t:41,d:"Deze kubusvormige vis is bekend vanwege zijn uitgesproken vierkante kop. Hij is zelfs ronduit stom, waardoor hij makkelijk te vissen is.",ep:2,g:269,l:1,wd:true,fm:true,w:3,p:10};
I.u[1751] = {n:"Schoongemaakte Visstick",t:62,d:"Deze visstick kan nu als ingrediënt gebruikt worden.",ep:2,g:270,l:1,wd:true,fm:true,w:2,p:1};
I.u[1752] = {n:"Gefrituurde Visstick **",t:49,d:"Deze smakelijke visstick is gemaakt van de beste vetvrije stukken vierkante vis. Kinderen zijn er dol op, maar zijn voedingswaarde is niet groot.",ep:2,g:71,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:60};
I.u[1753] = {n:"Gefrituurde Visstick ***",t:49,d:"Deze smakelijke visstick is gemaakt van de beste vetvrije stukken vierkante vis. Kinderen zijn er dol op, maar zijn voedingswaarde is niet groot.",ep:2,g:72,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1754] = {n:"Igloo Vis",t:41,d:"Deze zeldzame visstick leeft gewoonlijk in de ijswateren van het Hoge Noorden, vanwaar zijn naam. Vanwege zijn polaire voedsel, is zijn vel rijk aan vezels.",ep:1,g:271,l:1,wd:true,fm:true,w:3,p:100};
I.u[1755] = {n:"Schoongemaakte Igloovis",t:62,d:"Deze Igloovis kan nu als ingrediënt gebruikt worden.",ep:1,g:272,l:1,wd:true,fm:true,w:2,p:100};
I.u[1756] = {n:"Gefrituurde Visstick ****",t:49,d:"Deze gefrituurde Igloovis is niet alleen heel lekker, maar heeft ook een hoge voedingswaarde.",ep:1,g:73,l:1,wd:true,fm:true,w:1,c:"Ci<10",u:true,ut:true,p:10000};
I.u[1757] = {n:"Surimi Krab",t:41,d:"Deze krab, met een zo bijzondere vorm, wordt zeer gewaardeerd voor zijn grote hoeveelheid vlees. Hij is ook de enige krab waarop met een hengel gevist kan worden, want hij bezit het instinct lijnen door te knippen met zijn scharen... die zelf niet knippen.",ep:2,g:273,l:1,wd:true,fm:true,w:3,p:1};
I.u[1758] = {n:"Schoongemaakte Surimi Krab",t:62,d:"Deze surimi krab kan nu worden gebruikt als ingrediënt.",ep:2,g:274,l:1,wd:true,fm:true,w:2,p:1};
I.u[1759] = {n:"Exotische Surimi Krab",t:41,d:"Deze neef van de surimi krab is wel veel intelligenter. Dat verklaart zijn zeldzaamheid. Toch gebeurt het soms, na avondjes waarbij de drank rijkelijk gevloeid heeft, dat hij zeer weer door zijn instinct laat leiden.",ep:1,g:275,l:1,wd:true,fm:true,w:3,p:20};
I.u[1760] = {n:"Schoongemaakte exotische Surimikrab",t:62,d:"Deze exotische Surimikrab kan nu worden gebruikt als ingerdiënt.",ep:1,g:276,l:1,wd:true,fm:true,w:2,p:20};
I.u[1761] = {n:"Schoongemaakte Kitten Vis",t:62,d:"Deze Kittenvis kan nu worden gebruikt als ingrediënt.",ep:1,g:278,l:1,wd:true,fm:true,w:1,p:1};
I.u[1762] = {n:"Tijgervis",t:41,d:"Deze vis lijkt op een Kitten Vis, maar dan veel en veel gevaarlijker.",ep:1,g:279,l:1,wd:true,fm:true,w:3,p:30};
I.u[1763] = {n:"Schoongemaakte Tijgervis",t:62,d:"Deze Tijgervis kan nu als ingrediënt gebruikt worden.",ep:1,g:280,l:1,wd:true,fm:true,w:2,p:30};
I.u[1764] = {n:"Krabstick **",t:49,d:"Dit mag je met je handen eten. Maar let op dat je er niet teveel van eet.",ep:2,g:74,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:30};
I.u[1765] = {n:"Krabstick ***",t:49,d:"Langzaam, heel langzaam proeven, met een sausje.",ep:2,g:75,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:60};
I.u[1766] = {n:"Krabstick ****",t:49,d:"Gemaakt van exotische krabsurimi smaakt dit krabstaafje eenvoudigweg vies. Daarentegen is hij erg voedzaam.",ep:1,g:76,l:1,wd:true,fm:true,w:1,c:"Ci<30",u:true,ut:true,p:30000};
I.u[1767] = {n:"Gerookte Kittenvis **",t:49,d:"Lekker gerookt, deze kittenvis zorgt voor een fantastische maaltijd. Maar wees voorzichtig, de geur ervan zal tientallen jaren in je kleren blijven hangen.",ep:1,g:78,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:60};
I.u[1768] = {n:"Gerookte Kittenvis ***",t:49,d:"Lekker gerookt, deze kittenvis zorgt voor een fantastische maaltijd. Maar wees voorzichtig, de geur ervan zal tientallen jaren in je kleren blijven hangen.",ep:1,g:79,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:90};
I.u[1769] = {n:"Gerookte Tijger Vis ****",t:49,d:"De gerookte tijgervis is steviger en verfijnder dan de gerookte kittenvis en is daardoor nog meer een verrukking voor liefhebbers van de fijne keuken.",ep:1,g:77,l:1,wd:true,fm:true,w:1,c:"Cw<40",u:true,ut:true,p:40000};
I.u[1770] = {n:"Stukje Kokosblop",t:15,d:"Dit blop-extract ruikt sterk naar kokos. Hoe kan het afval van monsters zo ruiken?",ep:5,g:281,l:34,wd:true,fm:true,w:1,p:1};
I.u[1771] = {n:"Groene Muis",t:15,d:"“Kleine groene muis,                                                         Kleine groene muis,                                                           Waar ben je geweest?                                                       Ik ben geweest in heel het huis                                           Zei de kleine groene muis.”                                                Heb je het dan niet bij de staart gevangen?",ep:13,g:282,l:1,wd:true,fm:true,w:2,p:1};
I.u[1772] = {n:"Kokos Blop Bloem",t:35,d:"Zeg het met kokosbloemen of hou je mond!",ep:2,g:283,l:34,wd:true,fm:true,w:2,p:1};
I.u[1773] = {n:"Stukje Blop Reinette",t:15,d:"Moeilijk te zien.",ep:5,g:284,l:34,wd:true,fm:true,w:1,p:1};
I.u[1774] = {n:"Blop Reinette Bloem",t:35,d:"Zeg het met bloemen en houd je mond !",ep:5,g:285,l:34,wd:true,fm:true,w:1,p:1};
I.u[1775] = {n:"Stuk Morel Blop",t:15,d:"Een flink stuk Blop.",ep:5,g:286,l:34,wd:true,fm:true,w:1,p:1};
I.u[1776] = {n:"Donkere Kersen Blop Bloem",t:35,d:"Zeg het met kersenbloemen of zeg helemaal niets!",ep:5,g:287,l:34,wd:true,fm:true,w:1,p:1};
I.u[1777] = {n:"Uiteinde van de Indigo Blop",t:15,d:"Moeilijk het einde te zien.",ep:5,g:288,l:34,wd:true,fm:true,w:1,p:1};
I.u[1778] = {n:"Indigo Blop Bloem",t:35,d:"Zeg het met indigobloemen of hou je mond!",ep:5,g:289,l:34,wd:true,fm:true,w:1,p:1};
I.u[1779] = {n:"Zee Baars",t:41,d:"Deze vis kom je het meest tegen in de meren en stromen die van gletsjers komen. Zijn formaat en zijn frisse huid maken hem een door vissers zeer gewaarderd dier.",ep:2,g:290,l:40,wd:true,fm:true,w:3,p:1};
I.u[1780] = {n:"Schoongemaakte Zee Baars",t:62,d:"Deze Zee Baars kan nu als ingrediënt gebruikt worden.",ep:2,g:291,l:40,wd:true,fm:true,w:2,p:1};
I.u[1781] = {n:"Schoongemaakt Kar-naal",t:62,d:"Deze kar-naal kan nu als ingrediënt gebruikt worden.",ep:1,g:293,l:1,wd:true,fm:true,w:1,p:1};
I.u[1782] = {n:"Grondeling",t:41,d:"Op de grondeling, klein zoetwatervisje, wordt het meest gevist door kinderen en beginnende vissers. Maar hij zal ons gezin niet voeden.",ep:1,g:294,l:1,wd:true,fm:true,w:3,p:1};
I.u[1783] = {n:"Schoongemaakte Grondeling",t:62,d:"Deze grondeling kan nu worden gebruikt als ingrediënt.",ep:1,g:295,l:1,wd:true,fm:true,w:2,p:1};
I.u[1784] = {n:"Blauwe Rog",t:41,d:"De Blauwe Rog domineert de zeebodem waar hij zijn tijd vult met het graven van minuscule gaatjes. Niemand weet nog waarom. Hij komt eens in de zoveel tijd naar de oppervlakte. Net vaak genoeg om in je netten te belanden.",ep:2,g:296,l:50,wd:true,fm:true,w:3,p:1};
I.u[1785] = {n:"Schoongemaakte blauwe rog",t:62,d:"Deze blauwe rog kan nu als ingrediënt gebruikt worden.",ep:2,g:297,l:50,wd:true,fm:true,w:2,p:1};
I.u[1786] = {n:"Gruwel Kar-naal",t:41,d:"Deze zeer zeldzame soort gemuteerde kar-naal heeft de eigenschap gruwelijke geluiden voort te brengen als hij zijn lichaam golvend beweegt.",ep:1,g:298,l:1,wd:true,fm:true,w:3,p:100};
I.u[1787] = {n:"Schoongemaakte Gruwel Kar-naal",t:62,d:"Deze gruwel kar-naal kan nu worden gebruikt als ingrediënt.",ep:1,g:299,l:1,wd:true,fm:true,w:2,p:100};
I.u[1788] = {n:"Farle Rog",t:41,d:"Deze roggensoort is voor het eerst ontdekt door Farle Ingalsse in eigen persoon tijdens één van zijn grote avonturen. Deze rog zou het vermogen hebben alle diepte-vissen te betoveren door zijn unieke lage schreeuw.",ep:1,g:300,l:50,wd:true,fm:true,w:3,p:20};
I.u[1789] = {n:"Schoongemaakte Farle-rog",t:62,d:"Deze Farle-rog kan nu als ingrediënt gebruikt worden.",ep:1,g:301,l:50,wd:true,fm:true,w:2,p:20};
I.u[1790] = {n:"Kiye Grondeling",t:41,d:"Deze zeldzame grondeling komt regelrecht van het eiland Kiye, gelegen ter hoogte van het Moon Eiland Hoewel hij erg gewend is aan de warme golfstroom, migreert hij toch één keer per jaar.",ep:1,g:302,l:1,wd:true,fm:true,w:3,p:1};
I.u[1791] = {n:"Schoongemaakte Kiye Grondel",t:62,d:"Deze Kiye grondel kan nu als ingrediënt gebruikt worden.",ep:1,g:321,l:1,wd:true,fm:true,w:2,p:1};
I.u[1792] = {n:"Iton Baars",t:41,d:"De Iton Baars, Neef van de Zee Baars, dreigt  tegenwoordig te verdwijnen. Hij werd grotendeels gedecimeerd door een stom gerucht dat men een mooie stem zou krijgen door hem te eten.",ep:1,g:303,l:70,wd:true,fm:true,w:3,p:30};
I.u[1793] = {n:"Schoongemaakte Iton Zeebaars",t:62,d:"Deze Iton Zeebaars kan nu als ingrediënt gebruikt worden.",ep:1,g:304,l:40,wd:true,fm:true,w:2,p:30};
I.u[1794] = {n:"Karper Diem",t:41,d:"Deze vis wordt beschouwd als de meest wijze van alle zoetwatervissen. Hij zal nooit in je aas bijten tenzij hij niet meer wil leven.",ep:2,g:305,l:40,wd:true,fm:true,w:3,p:1};
I.u[1795] = {n:"Schoongemaakte Karper Diem",t:62,d:"Deze karper diem kan nu als ingrediënt gebruikt worden.",ep:2,g:306,l:10,wd:true,fm:true,w:2,p:1};
I.u[1796] = {n:"Zandkarpertje",t:41,d:"Dit karpertje heeft een op zand lijkende kleur. Een evolutie van de natuur die het hem in theorie mogelijk maakt onzichtbaar te zijn voor de ogen van roofdieren. Jammer dat er geen zand ligt op de bodem van de meren...",ep:1,g:307,l:40,wd:true,fm:true,w:3,p:1};
I.u[1797] = {n:"Schoongemaakte kleine zandkarper",t:62,d:"Deze kleine zandkarper kan nu worden gebruikt als ingrediënt.",ep:1,g:308,l:10,wd:true,fm:true,w:2,p:1};
I.u[1798] = {n:"Schoongemaakte Krakamor",t:62,d:"Deze krakamor kan nu als ingrediënt gebruikt worden.",ep:2,g:310,l:20,wd:true,fm:true,w:1,p:1};
I.u[1799] = {n:"Unieke Krakamor",t:41,d:"Deze krakamor kiest slechts één partner voor zijn hele leven. Uitzonderlijk zeldzaam als je de zeden van de krakamor kent.",ep:1,g:311,l:20,wd:true,fm:true,w:3,p:30};
I.u[1800] = {n:"Schoongemaakte Unieke Krakamor",t:62,d:"Deze unieke Krakamor kan nu worden gebruikt als ingrediënt.",ep:1,g:312,l:20,wd:true,fm:true,w:2,p:30};
I.u[1801] = {n:"Rivierbaars",t:41,d:"Onder een dom uiterlijk zit de slimste en snelste vis verborgen. Maar zijn onvergelijkbare en unieke smaak zijn zeker de moeite waard.",ep:3,g:313,l:70,wd:true,fm:true,w:3,p:1};
