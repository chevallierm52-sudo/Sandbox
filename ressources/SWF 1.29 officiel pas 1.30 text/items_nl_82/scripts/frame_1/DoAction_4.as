I.u[1853] = {n:"Vrijemarkthaai",t:41,d:"Neef van de Hamer en Sikkel Haai, maar nog wreder en veel minder georganiseerd. Er een te vangen is de droom van ieder visser, of liever gezegd, er een te vangen en nog steeds in leven te zijn.",ep:1,g:324,l:80,wd:true,fm:true,w:4,p:1};
I.u[1854] = {n:"Schoongemaakte vrijemarkthaai",t:62,d:"Deze vrijemarkthaai kan nu als ingrediënt gebruikt worden.",ep:1,g:325,l:80,wd:true,fm:true,w:3,p:1};
I.u[1855] = {n:"Tandbaars",t:41,d:"Van nature nogal lui, slaapt deze vis de hele tijd. Moeilijk om er in die omstandigheden een te vangen.",ep:1,g:0,l:1,wd:true,fm:true,w:2,p:1};
I.u[1856] = {n:"Schoongemaakte Tandbaars",t:62,d:"Deze tandbaars kan nu als ingredient worden gebruikt.",ep:1,g:0,l:1,wd:true,fm:true,w:2,p:1};
I.u[1859] = {n:"Kralove ****",t:49,d:"Deze gegrilde Kralove ruikt geweldig.. Een waarlijk genot!",ep:1,g:91,l:1,wd:true,fm:true,w:1,c:"Ci<50",u:true,ut:true,p:50000};
I.u[1860] = {n:"Harpoen Hengel",t:20,d:"Deze supersterke vishengel heeft een vishaak in de vorm van een harpoen die speciaal ontwikkeld is voor het vissen op haaien.",ep:1,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1861] = {n:"De Grote Rivierbaars",t:20,d:"Deze vishengel is speciaal bestudeerd om er de levendige rivierbaars mee te vangen.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1862] = {n:"De Liefdes Staf",t:20,d:"Het hout van deze hengel scheidt een geurend hars af dat in de draad en de vishaak doordringt. Deze verrukkelijke geur moet lijken op het parfum van een Krakamorette want alle Krakamors komen erop af.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1863] = {n:"Chô-hengel",t:20,d:"Chô was de beroemdste kok van de ronde tafel. Zijn bijzonderheid was dat hij de verse voedingsmiddelen voor de ogen van de klanten opspoorde. Met deze hengel viste hij op de voor zijn vermaarde gerecht van karpers à la Chô onmisbare vissen.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1864] = {n:"Breinaald",t:20,d:"De draad van deze vishengel is exclusief gemaakt van wol waarvan de bol het aas vervangt. Slechts weinig katjes-vissen kunnen deze verleiding weerstaan.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1865] = {n:"Kubusvormige Hengel",t:20,d:"Deze hengel is speciaal ontworpen om zich aan te passen aan de zo... bijzondere vormgeving van vissticks.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1866] = {n:"Standaard Vishengel",t:20,d:"Met deze hengel van middelmatige makelij kan de jonge visser op bijna alles vissen, als hij de moeite neemt geduldig genoeg te zijn.",ep:2,g:8,l:1,wd:true,fm:true,w:3,an:18,e:[1,4,1,3,100,100,false,false],c:"PJ>36,9",p:1000};
I.u[1867] = {n:"Grote Vishengel",t:20,d:"Deze hengel is bestemd voor professionele vissers. Hiermee kunnen ze hun lijn heel ver uitgooien. Maar je moet hem weten te beheersen om iets te kunnen vangen.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,5,100,100,false,false],c:"PJ>36,39",p:2000};
I.u[1868] = {n:"Telescopische Vishengel",t:20,d:"Deze vishengel kan een verbijsterende lengte bereiken. Alleen de meestervissers weten hun potentieel te gebruiken.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,7,100,100,false,false],c:"PJ>36,69",p:4000};
I.u[1869] = {n:"Tanden Trekker",t:24,d:"Deze Tandentrekker werkt voornamelijk op de Veelvraat, maar als je een rotte kies hebt, kun je proberen hem te trekken als je daar zin in hebt.",ep:2,g:34,l:1,wd:true,fm:true,w:0,p:1};
I.u[1870] = {n:"Veelvraat Tand",t:24,d:"Deze tand van een Veelvraat lijkt als twee druppels water op een menselijke tand.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[1871] = {n:"Ketting",t:24,d:"De ketting die de dochter van de burgemeester is verloren. Helaas is hij in trieste staat na in de maag van de Raaf vertoeft te hebben...",ep:2,g:36,l:1,wd:true,fm:true,w:0,p:1};
I.u[1872] = {n:"Kanonspoeder",t:24,d:"Kanonspoeder, een etiket herinnert je aan het gebruik ervan, dat zo simpel is als wat:\nPoeder + Vlam = Explosie",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[1873] = {n:"Stuk steen",t:24,d:"Een stuk Krakler-van-de-Vlaktes-steen dat lijkt op die waarmee de versterkingen van de Bonta zijn gebouwd.",ep:2,g:38,l:1,wd:true,fm:true,w:0,p:1};
I.u[1874] = {n:"Scheurbuik Gif",t:24,d:"Scheurbuikgif moet niet iedereen in handen krijgen.",ep:2,g:39,l:1,wd:true,fm:true,w:2,p:1};
