I.u[1426] = {n:"Thart Schep",t:8,d:"Thart\', de maker van deze schep, was een Iop discipel. Een voorbestemde naam, voor een Iop, niet waar?",ep:3,g:8,l:24,wd:true,fm:true,w:24,an:16,e:[5,5,1,1,50,50,false,true],p:1800};
I.u[1427] = {n:"Zeboe Schep",t:8,d:"Deze schep wordt gebruikt door de Kanniboul grootpriesters  van het eiland Moon om Zeboe aan te roepen, een van hun goden, vaak afgebeeld als een rund. Alleen gemene  personages kunnen dit wapen gebruiken.",ep:1,g:40,l:55,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,50,20,false,true],c:"Ps=2&CC>50",p:8000};
I.u[1428] = {n:"Strobloem",t:36,d:"Dit vreemde plantje groeit in een droge omgeving, en verspreidt een kerrie-geur om zich heen. Het is taai en schijnt de tand des tijds niet te verdragen... Konden we dat maar van alle vrouwen zeggen...",ep:2,g:54,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1429] = {n:"Kleine Mechba Schep",t:8,d:"Deze schep wordt door de Enutrofs gebruikt om vruchten van de bomen te plukken, maar hij kan ook een geducht strijdwapen blijken te zijn. Zoals zijn maker, Mechba, zou zeggen: \'zje ish mooi, mijn schep\'.",ep:1,g:19,l:30,wd:true,fm:true,w:15,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>10&CI>10",p:1500};
I.u[1430] = {n:"Mechba Schep",t:8,d:"Deze schep wordt door de Enutrofs gebruikt om vruchten van de bomen te plukken, maar hij kan ook een geducht strijdwapen blijken te zijn. Zoals zijn maker, Mechba, zou zeggen: \'zje ish mooi, mijn schep\'.",ep:1,g:19,l:45,wd:true,fm:true,w:23,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>15&CI>15",p:2300};
I.u[1431] = {n:"Grote Mechba Schep",t:8,d:"Deze schep wordt door de Enutrofs gebruikt om vruchten van de bomen te plukken, maar hij kan ook een geducht strijdwapen blijken te zijn. Zoals zijn maker, Mechba, zou zeggen: \'zje ish mooi, mijn schep\'.",ep:1,g:19,l:60,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>25&CI>25",p:3000};
I.u[1432] = {n:"Gras Mat Schep",t:8,d:"Gras Mat, tuinier en Enutrof discipel, had de neiging te vaak misbruik te maken van de planten. Dit wapen is daarvan het bewijs: krachtig en met de neiging om je een lelijke poets te bakken en je intelligentie op de proef te stellen.",ep:1,g:17,l:21,wd:true,fm:true,w:21,an:16,e:[2,4,1,1,50,50,false,true],c:"CC>27&CW<100&CS>10",p:2100};
I.u[1433] = {n:"Veiligheids Schep",t:8,d:"Deze schep werd het zelfverdedigingswapen bij uitstek van een kleine groep Enutrofettes. Eenmaal in het bezit van dit krachtige instrument, veranderden deze dames totaal en probeerden ze de wereld te veroveren.",ep:7,g:4,l:60,wd:true,fm:true,w:30,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>60&CS>30&CA>10",p:6500};
