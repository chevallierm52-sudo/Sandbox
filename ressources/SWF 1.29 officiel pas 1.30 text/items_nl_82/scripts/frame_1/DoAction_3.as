I.u[1461] = {n:"Kokend Gif",t:15,d:"Dit gif is gemaakt van arachneepoten waardoor je je verstand verliest. Zowel letterlijk als figuurlijk, want na een periode van krankzinnigheid explodeert je schedel door de bloeddruk.",ep:1,g:189,l:20,wd:true,fm:true,w:1,p:100};
