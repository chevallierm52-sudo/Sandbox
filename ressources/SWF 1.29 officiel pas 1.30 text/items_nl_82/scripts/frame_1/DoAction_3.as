I.u[1403] = {n:"Wiets Hamer",t:7,d:"Deze hamer heeft toebehoord aan Wiets, een jonge discipel van Osamodas die zijn tijd verdeed met het vertellen van stomme moppen. Net als hij, maakt deze hamer je niet intelligent, maar kan soms wel de sfeer opvrolijken...",ep:1,g:3,l:23,wd:true,fm:true,w:20,an:15,e:[4,4,1,1,30,30,false,true],c:"CA>20",p:1700};
I.u[1404] = {n:"Toh\'Lo Hamer",t:7,d:"Houd je van dieren? Toh\'Lo ook. Hij had zelfs zijn leven aan hen opgedragen. Deze hamer vertelt een beetje zijn geschiedenis : Een grote eensgezindheid met de beesten, net zo behendig als een manke Veelvraat met slechts 2 tenen.",ep:5,g:15,l:35,wd:true,fm:true,w:35,an:15,e:[6,4,1,1,30,30,false,true],c:"CI>80&CW>30",p:3400};
I.u[1405] = {n:"Toverwater Drankje",t:12,d:"Dit toverdrankje heeft dezelfde helende krachten als het bloed van een Eniripsa. Dus het is niet meer nodig om z\'n bloed af te tappen.",ep:3,g:41,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1406] = {n:"Eenhoorn Bloed",t:12,d:"Dit drankje heeft dezelfde effecten als het Eenhorndrankje, behalve onsterfelijkheid. Drink het en je bent genezen!",ep:3,g:40,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
