I.u[1030] = {n:"Kittenstaarten",t:5,d:"Dit stel dolken is eigenlijk een magisch spel, oorspronkelijk gemaakt om de jonge Ecaflips te vermaken. De productie ervan werd verboden nadat een kind, volgeling van Sram, deelnam aan dit spel.",ep:14,g:20,l:25,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>40&CS>20&CV>20",p:1800};
I.u[1031] = {n:"Wrede dolken van Elorie Entuwan",t:5,d:"Deze prachtige dolken zouden hebben toebehoord aan de meest wrede Sramette die Amakna ooit heeft gekend. Eigenlijk een van de wreedste... Net een beetje wreder dan de anderen, in ieder geval net zo wreed als de anderen, en dat is al heel wat !",ep:1,g:7,l:40,wd:true,fm:true,w:1,an:13,e:[12,3,1,1,30,50,false,false],c:"CA>40",p:4000};
