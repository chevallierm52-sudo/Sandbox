I.u[1439] = {n:"Slechte Houweel",t:21,d:"Deze houweel heeft de neiging het boze oog aan te trekken. Toch schijnt het dat er weinig voor nodig is om er een echte houweel van te maken.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,6,1,1,50,10,false,true],p:250};
