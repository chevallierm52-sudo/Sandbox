I.u[1041] = {n:"Gebroken Zwaard van de Pechridder",t:5,d:"Dit zwaard werd aan de jonge Iop Souze Schel gegeven tijdens zijn ridderslag. Ongelukkigerwijs gleed hij tijdens zijn eerste missie als ridder over een steen, die een krakler bleek te zijn...",ep:1,g:43,l:35,wd:true,fm:true,w:20,an:13,e:[5,5,1,1,30,50,false,false],c:"CS>20",p:3000};
