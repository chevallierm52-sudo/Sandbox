I.u[1399] = {n:"Speikr Hamer",t:7,d:"Net als de amulette met dezelfde naam, heeft de Speikr Hamer de eigenaardige gewoonte om je levensenergie om te zetten in kracht. Gebruik hem met mate..",ep:1,g:12,l:15,wd:true,fm:true,w:15,an:15,e:[5,5,1,1,40,40,false,true],p:1500};
