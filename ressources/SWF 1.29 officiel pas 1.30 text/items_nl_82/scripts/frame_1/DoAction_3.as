I.u[1011] = {n:"Geel Schild",t:24,d:"Het schild van een gestoorde schildpad die ongetwijfeld gevaarlijke stoffen had misbruikt.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Rood Schild",t:24,d:"Het schild van een gestoorde schildpad die tomaten en kaas op warm brood at.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Blauw Schild",t:24,d:"Het schild van een gestoorde schildpad die Zowwo, de gemaskerde Wenard, wilde immiteren.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Groen Masker",t:24,d:"Dit Masker van de lachende Kannibool heeft de afbeelding van Sla, element voor het kruiden van vlees.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Geel Masker",t:24,d:"Masker van de huilende kannibool, met een plaatje van een Bliksemschicht, element dat vaak het jonge vlees laat schrikken.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Rood Masker",t:24,d:"Dit Masker van de opvliegende Kannibool heeft de afbeelding van Vuur, element voor het braden van vlees.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Blauw Masker",t:24,d:"Masker van een verraste Kannibool, met een afbeelding van Water, dorstlessend element tussen twee happen vlees.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Glu",t:15,d:"Deze pot met roze gelei ruikt misschien goed... Maar je moet het nooit proeven want dan zul je nooit meer praten. Het is een uitstekend fixeermiddel.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Helm",t:16,d:"Met deze helm krijg je een unieke look... Tussen het belachelijke en het komische in.",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Gebroken Helm",t:15,d:"Deze helm heeft jouw leven gered, maar is er niet in geslaagd het zijne te redden.",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Houten Vleugels",t:17,d:"Voor iedereen die er altijd van gedroomd heeft als een Kwak te kunnen vliegen, ga maar weer lekker slapen, want deze vleugels maken je alleen maar een openbaar gevaar en een idioot.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Gebroken Vleugels",t:104,d:"Deze gebroken vleugels die je er onophoudelijk aan herinneren dat je toch echt weer naar bed had moeten gaan.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Fles met rum",t:15,d:"Op het etiket staat “10 jaar oude rum” maar het is onmogelijk om na te gaan of het waar is. Drink niet overmatig veel onderweg als je bang bent zeeziek te worden.",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
