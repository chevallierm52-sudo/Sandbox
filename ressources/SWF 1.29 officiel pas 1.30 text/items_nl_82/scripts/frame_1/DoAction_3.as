I.u[1383] = {n:"Sgil Pat Hamer",t:7,d:"Deze hamer is gedurende jaren en jaren gesmeed door een tiental smeden. Uiteindelijk heeft men dan een schitterend wapen dat helaas het idee van snelheid heeft geërfd van zijn makers.",ep:1,g:5,l:55,wd:true,fm:true,w:20,an:15,tw:true,e:[8,4,1,1,50,50,false,false],p:8000};
