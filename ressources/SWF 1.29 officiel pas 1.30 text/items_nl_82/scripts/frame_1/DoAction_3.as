I.u[1393] = {n:"De Matronome",t:7,d:"Deze hamer is gemaakt van een horloge, het befaamde horloge dat de Crocodyl had ingeslikt toen hij de hand van Kapitein Brochet had verslonden. Men heeft het horloge weer terug weten te vinden, maar daarentegen weet men niet wat er met de hand gebeurd is...",ep:5,g:21,l:54,wd:true,fm:true,w:20,an:15,e:[8,6,1,1,40,40,false,true],c:"CI>62&CW>22",p:9700};
