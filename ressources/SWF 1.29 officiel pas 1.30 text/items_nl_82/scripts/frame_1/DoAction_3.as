I.u[1054] = {n:"Wrede Troffel Schep",t:8,d:"Dit is een kruising tussen een schep en een troffel en heeft zijn nuttige eigenschappen verloren en is verandert in een onontbeerlijk wapen. Makkelijk te hanteren en op te bergen dankzij z\'n grootte. Hét ideale voorwerp voor elke Enutrof die van alcohol houdt.",ep:13,g:15,l:53,wd:true,fm:true,w:20,an:16,e:[5,3,1,1,40,40,false,false],c:"CC>47",p:5000};
