I.u[1435] = {n:"Vette Schep",t:8,d:"Een zeer zware schep en dus gereserveerd voor gr... zware avonturiers.",ep:9,g:11,l:80,wd:true,fm:true,w:150,an:16,e:[10,6,1,1,50,50,false,true],c:"CS>100",p:40000};
I.u[1436] = {n:"Ikan Scheppel",t:8,d:"Ikan was het visje van de krijger Chourros. Het is belangrijk te benadrukken dat de naam van deze schep niets te maken heeft met deze vis, maar eerder met zijn lucht...",ep:7,g:8,l:50,wd:true,fm:true,w:50,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>30&CA>10",p:7800};
