I.u[1324] = {n:"Kattekruid",t:36,d:"Deze plant doet elke Ecaflip kwijlen.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1325] = {n:"Note Dop",t:46,d:"Deze van nature stevige dop kan tegen iedere soort agressie en is een goed vertegenwoordiger van de ideologie van Feca.",ep:2,g:52,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1326] = {n:"Bloedige Vuursteen",t:51,d:"Deze steen, die even sterk als scherp is, lijkt te zijn gebruikt tegen iets of iemand. Dit brute en gevaarlijke aspect lijkt de definitie van een Iop perfect te illustreren.",ep:2,g:47,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1327] = {n:"Bewerkt bot",t:47,d:"Dit voorwerp afkomstig van een dode wordt geducht zodra het bewerkt is, net zoals bij een Sram.",ep:2,g:48,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1328] = {n:"Mysterieuze kama",t:15,d:"Deze kama is versierd met een tofu-hoofd waarop een vreemde hoed prijkt.",ep:1,g:182,l:1,wd:true,fm:true,w:10,p:1};
I.u[1329] = {n:"Elastisch Hout",t:38,d:"Deze grote houten tak doet, door zijn elasticiteit en zijn kromlijnige vorm, meteen aan een Crâ denken.",ep:2,g:49,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1330] = {n:"Itby Amulet",t:1,d:"Deze originele creatie van de goudsmid John Len Nonnes is tegenwoordig één van de meest klassieke sieraden.",ep:1,g:31,l:10,wd:true,fm:true,w:5,p:500};
I.u[1331] = {n:"Medaille Oly",t:1,d:"Oly was een vrouwelijke Iop discipel die maar één talent had: ze kon goed koken. Men zegt dat Iop zelf haar deze medaille zou hebben gegeven, om haar zwakheid tijdens gevechten te compenseren. Alleen zuivere harten kunnen hem dragen.",ep:7,g:23,l:51,wd:true,fm:true,w:10,c:"Ps=1&Pa>10",p:7000};
I.u[1332] = {n:"Oud Klavertje Vier",t:36,d:"Klavertjes vier zijn veel zeldzamer dan de klavertjes vijf. Als je er één vindt, is het raadzaam hem te drogen tussen twee toverschriftrollen.",ep:2,g:50,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1333] = {n:"Vonkendrankje",t:26,d:"Dit verwarmende drankje, dankzij de kleine hoeveelheid vuurmagie die het bevat, wordt normaal gesproken gebruikt om allerlei soorten voorwerpen te betoveren.",ep:3,g:1,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1334] = {n:"Zwavelzakje",t:48,d:"Dit zakje vol met zwavel verspreidt een niet te verdragen geur... Dezelfde als die van de Osamadas.",ep:2,g:51,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1335] = {n:"Motregen Drankje",t:26,d:"Dankzij het zwak magische water dat het bevat wordt dit rillende drankje normaal gesproken gebruikt om allerlei soorten voorwerpen te betoveren.",ep:3,g:2,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1336] = {n:"Brandnetels",t:36,d:"Door deze plant stevig tegen je huid te wrijven, lijd je als een martelaar. Toch is de daardoor ontstane stimulans heilzaam, precies de filosofie van de Sacriers.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1337] = {n:"Lucht Drankje",t:26,d:"Dit met een zwakke magie van lucht gevulde zuchtende drankje wordt vaak gebruikt om allerlei soorten voorwerpen te betoveren.",ep:3,g:3,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1338] = {n:"Bibber Drankje",t:26,d:"Deze trillende toverdrank, met een zwakke aardmagie, wordt over het algemeen gebruikt om allerlei soorten voorwerpen te betoveren.",ep:3,g:4,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1339] = {n:"Klokjes",t:35,d:"Deze lelietjes-van-dalen zijn echt heel klein, breekbaar en schattig. Men zegt dat ze de geest kunnen kalmeren en bepaalde pijntjes kunnen genezen. Ze zijn zeker bedacht door een goddelijkheid die een plant wenste te maken met het evenbeeld van de Eniripsas.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1340] = {n:"Verpletterdrankje",t:26,d:"Dankzij de aardse magie die het bevat, wordt dit trillende drankje over het algemeen gebruikt om allerlei soorten voorwerpen correct te betoveren.",ep:9,g:4,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1341] = {n:"Regen Drankje",t:26,d:"Dankzij het magische water wordt deze kabbelende toverdrank gewoonlijk gebruikt om allerlei soorten voorwerpen te betoveren.",ep:9,g:2,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1342] = {n:"Rukwind Drankje",t:26,d:"Dankzij de magische lucht die het bevat, wordt deze fluitende toverdrank gewoonlijk gebruikt om allerlei soorten voorwerpen op de juiste manier te betoveren.",ep:9,g:3,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1343] = {n:"Flambeer Drankje",t:26,d:"Dit knetterende drankje wordt, dankzij de vuurmagie die het bevat, over het algemeen gebruikt voor het op juiste wijze betoveren van allerlei soorten voorwerpen.",ep:9,g:1,l:25,wd:true,fm:true,w:1,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1344] = {n:"IJzerkruid",t:36,d:"Deze speciale plant doet iedereen makkelijker slapen. Dat moet waarschijnlijk het embleem van de Sadida zijn.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1345] = {n:"Vuur Drankje",t:26,d:"Dankzij de krachtige vuurmagie die het bezit wordt dit knallende drankje gebruikt om allerlei items krachtig te beheksen.",ep:4,g:1,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1346] = {n:"Tsunami Drankje",t:26,d:"Dankzij de krachtige water magie van die het bevat, wordt dit brul drankje gebruikt om krachtig allerlei items te beheksen.",ep:4,g:2,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1347] = {n:"Tornado Drankje",t:26,d:"Dankzij de krachtige lucht magie van die het bevat, wordt dit brul drankje gebruikt om krachtig allerlei items te beheksen.",ep:4,g:3,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1348] = {n:"Aardbeving Drankje",t:26,d:"Dankzij de krachtige aardemagie die het bezit wordt dit klevende drankje gebruikt om allerlei items krachtig te beheksen.",ep:4,g:4,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1350] = {n:"Alcoho Boog",t:2,d:"Deze boog is gemaakt door een tovenaar die van de fles hield. Om zijn probleem op te lossen, vond hij deze waterboog uit.",ep:3,g:4,l:15,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,3,6,30,50,false,true],p:250};
I.u[1351] = {n:"Xueluom Boog",t:2,d:"\"Met een boog, gaat het of breekt het\", luidt het spreekwoord. De wijzen vermijden deze boog, want hij zou het zogenaamde boze oog dragen...",ep:1,g:51,l:30,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,10,10,false,true],c:"CC>30",p:1600};
I.u[1352] = {n:"Booboog",t:2,d:"Deze boog verkrijgt zijn kracht zowel uit aarde als uit water. Pech voor degenen die noch de één noch het ander beheersen...",ep:2,g:6,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],p:5000};
I.u[1353] = {n:"Gezaagde Katrol Boog",t:2,d:"Deze boog, waarvan de katrollen zijn gezaagd, was heel lang geleden het symbool van de strijd van het goed tegen het kwaad. Ook vandaag nog kun je de vlam van de vroegere rechtvoltrekkers ruiken.",ep:12,g:10,l:41,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"Ps=1&Pa>10&CI>30&CW>30",p:200};
I.u[1354] = {n:"Hick Boog",t:2,d:"Hick was een vervloekte Cra : hij kon nooit van zijn hik afkomen. Tot hij op een dag zijn boog in het vuur wierp en verving door een zwaard. Toen bleek zijn kwaal op mysterieuze wijze te zijn verdwenen...",ep:13,g:11,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,6,40,40,false,true],p:1000};
I.u[1355] = {n:"Hidsad Boog",t:2,d:"De maker van deze boog, een zekere Marc Hidsad, heeft nooit geweten hoe je er precies mee moest omgaan. Hij kon zowel zijn vijanden als zichzelf ermee ernstig verwonden.",ep:14,g:12,l:40,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,7,30,50,false,true],p:4000};
I.u[1356] = {n:"Half Stok",t:3,d:"Rika Zarouil de bakkersvrouw stond bekend als de kleinste Eniripsa van de hele Amakna wereld. Zij bakte het brood in kleine kartonnen ovens en ze kon vechten met halve stokken.",ep:1,g:13,l:11,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,30,50,false,true],p:1000};
I.u[1357] = {n:"Dolkje",t:3,d:"Een houtsnijder die wel van een grapje hield, wilde deze stokjes door laten gaan voor dolken. Zijn list had geen succes maar de stokjes daarentegen wel.",ep:7,g:17,l:35,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,40,40,false,true],c:"CI>25",p:3500};
I.u[1359] = {n:"Doaheen Stok",t:3,d:"De oorsprong van deze stok blijft onduidelijk.Daarentegen heeft het stokje zijn gelukkige bezitters altijd de minst drukke wegen van Amakna gewezen, wat handig kan zijn op drukke dagen in het domein van de koninklijke Veelvraat.gewezen",ep:9,g:12,l:59,wd:true,fm:true,w:10,an:11,e:[7,3,2,3,30,50,false,true],c:"CI>70&CS>30",p:5000};
I.u[1360] = {n:"De Hyldegarde",t:3,d:"Deze stok werd vele jaren geleden gemaakt in de smidse van de Dying Ard. Bij dit wapen moet je altijd water bij de hand hebben om zijn innerlijke vuur te beheersen...",ep:13,g:8,l:48,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],p:4800};
I.u[1361] = {n:"Sylvien Stok",t:3,d:"De Sylvien Stok geeft aan degene die hem draagt een scherp zicht. Aan jou om dan behendig genoeg te zijn om het gevaar te ontvluchten.",ep:1,g:15,l:43,wd:true,fm:true,w:10,an:11,e:[4,5,2,2,40,40,false,true],c:"CA>80",p:4000};
I.u[1362] = {n:"Vampirische Paal",t:3,d:"De vampirische paal is eigenlijk een stokje van een reeds lang geleden uit het sociale leven en zijn slagerij teruggetrokken vampier. Dit vreemde stuk hout heeft echter enkele van zijn vroegere meester\'s voordelen bewaard...",ep:7,g:14,l:65,wd:true,fm:true,w:10,an:11,e:[5,6,2,3,50,20,false,true],c:"CA>30&CW<60",p:4000};
I.u[1363] = {n:"Tont\'Ata Staf",t:4,d:"Behalve zijn onverdraaglijke naam, heeft deze staf andere middelen om zijn eigenaar helemaal gek te maken.",ep:1,g:5,l:40,wd:true,fm:true,w:10,an:12,e:[5,5,1,1,5,5,false,true],c:"CI<100",p:5000};
I.u[1364] = {n:"Vergeetstaf",t:4,d:"Deze staf zorgt ervoor dat zijn eigenaar alle zorgen en slechte gedachten vergeet. Helaas verliest hij soms ook een gedeelte van zijn geheugen en wordt steeds vaker slachtoffer van verlies van concentratie. Slechts voorbehouden aan de wijzen...",ep:13,g:11,l:30,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,true],c:"CW>50",p:3000};
I.u[1365] = {n:"Woed Stok",t:4,d:"Woed was echt een gevreesde strijder met zijn staf. Hij was zo doeltreffend, dat men beweerde dat zijn staf betoverd was en vuurspuugde...",ep:1,g:68,l:20,wd:true,fm:true,w:15,an:12,e:[8,5,1,1,50,40,false,true],p:2000};
I.u[1366] = {n:"Vreterd Staf",t:4,d:"Deze staf wordt regelmatig gebruikt door de Vreterds tijdens het verplaatsen van het vee naar hogere weilanden. De Bworks eten deze Veelvraatkuddes het liefst in dun gesneden plakken als aperitief (het hoofdgerecht bestaat dan uit de Vreterd zelf).",ep:9,g:9,l:12,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,true],p:1200};
I.u[1367] = {n:"Dina Mythe Staf",t:4,d:"Deze staf heeft toebehoord aan de zeer mooie Dina \'Mythe\', die vooral bekend was om haar ronde vormen en haar explosieve karakter... Het was een echte seks....bom.",ep:13,g:6,l:40,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,30,50,false,true],c:"CI>50&CA>40",p:4000};
I.u[1368] = {n:"De lans van een \'110\'",t:4,d:"De 110\' is de bijnaam, gegeven aan de 110 waardevolle Amakna brandweermannen, die met name het vuur van een Drakinnetje bestreden hebben bij gebrek aan sterke gevoelens. Dit vereist moed en kracht.",ep:1,g:18,l:29,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,true],c:"CC>10",p:2500};
I.u[1369] = {n:"Tafel Lemmets",t:5,d:"Deze messen waren oorspronkelijk bedoeld voor een luxe restaurant. Maar gezien hun ...  vreemde verschijning, gaf de restauranteigenaar er de voorkeur aan ze te verkopen aan een rondtrekkende messenwerper.",ep:1,g:13,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>55&CC>5",p:3000};
I.u[1370] = {n:"De Ergot Mina",t:5,d:"Het handvat van dit wapen is vet en glibberig, maar het heeft een vet coole look.",ep:1,g:14,l:20,wd:true,fm:true,w:10,an:13,e:[8,3,1,1,50,50,false,true],p:2000};
I.u[1371] = {n:"Eulasse Dolken",t:5,d:"Eulasse was een vreterd uit het noorden van Amakna die op een dag, midden tussen de mest van zijn veelvraten een paar licht bevuilde dolken vond. Wee degene die \'m draagt: het heft is glad, je kan gemakkelijk je slag missen.",ep:1,g:10,l:40,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>40",p:4000};
I.u[1372] = {n:"Don\'dr Toc Hop Dolken",t:5,d:"Wie kent niet Don\'dr Toc Hop, de hermiet, legendarische discipel van Sram die zijn hele leven elk contact met anderen weigerde. Bij zijn dood, vond men zijn lievelings dolken naast zijn lichaam en alleen de meest behendigen wisten ze te temmen.",ep:9,g:19,l:44,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5300};
I.u[1373] = {n:"Hels Scheermes",t:5,d:"Krys Nieschere was een oude Enutrof discipel met een baard, zoals alle Enutrof discipelen. Toen zijn vrouw  mevrouw Nieschere hem een scheermes gaf, besloot hij dat hij het liever gebruikte als wapen...",ep:1,g:17,l:30,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1374] = {n:"Typo Dolken",t:5,d:"Typo was een klerk in Amakna, die eeuwen geleden leefde. Hij had de eigenaardigheid zijn stenen schriften niet te bewerken met beitels maar met dolken. Wat ons van hem rest is deze prachtige dolk, met een indrukwekkende schokbestendigheid.",ep:1,g:12,l:30,wd:true,fm:true,w:13,an:13,e:[10,3,1,1,30,50,false,false],c:"CS>50",p:3000};
I.u[1375] = {n:"Boddi Bilders Bijl",t:19,d:"Boddi Bilders was een Iop discipel die indrukwekkende massa\'s kon optillen. Maar helaas voor hem, net als alle te gespierde Iops, was intelligentie niet zijn sterkste punt...",ep:1,g:14,l:15,wd:true,fm:true,w:25,an:17,e:[10,5,1,1,50,50,false,true],c:"CS>70&CI<10",p:800};
I.u[1376] = {n:"Afmaak Bijl",t:19,d:"Deze soms zwaar te hanteren bijl is perfect om Trools te vloeren;\r\n            hij bevat magische runes die de vijand kunnen verbranden.",ep:7,g:15,l:35,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,50,false,true],c:"CS>50",p:3000};
I.u[1377] = {n:"Hure Bijl",t:19,d:"Hure was een jonge priester die er niet voor terugdeinsde om geweld te gebruiken voor het verspreiden van het geloof. Zijn lievelingswapen was een bijl waarop hij vele strepen had gekerfd. De betekenis ervan is voor altijd verloren gegaan...",ep:1,g:16,l:22,wd:true,fm:true,w:22,an:17,e:[10,5,1,1,50,50,false,true],c:"CW>30",p:2200};
I.u[1378] = {n:"Gil Bijl",t:19,d:"Zoals zijn naam al aangeeft heeft deze voor jonge strijders bestemde gevechtsbijl de eigenschap een onaangenaam schril geluid te produceren als hij met een ander wapen in botsing komt.",ep:1,g:17,l:28,wd:true,fm:true,w:22,an:17,e:[8,5,1,1,40,40,false,true],c:"CA>30",p:2300};
I.u[1379] = {n:"De Scrounnchhh",t:7,d:"Volgens de legende dankt deze hamer zijn naam aan het geluid dat hij maakt als hij op de schedel van een vijand terechtkomt. Helaas kan geen één vijand dit bevestigen.",ep:7,g:9,l:35,wd:true,fm:true,w:35,an:15,e:[8,5,1,1,30,40,false,true],c:"CS>50&CA>20",p:35000};
