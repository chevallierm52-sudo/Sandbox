I.u[408] = {n:"Kunstgebit van de Elite Chafer",t:47,d:"De elite Chafer heeft beschimmelde tanden door de acohol en daarom heeft hij een kunstgebit. Dit kunstgebit kost een fortuin, want de tanden zijn van goud en de stinkende adem van de elite Chafer heeft onvoorspelbare krachten.",ep:9,g:129,l:43,wd:true,fm:true,w:1,p:50};
I.u[409] = {n:"Bwork Magus Baardharen",t:54,d:"Om nog onduidelijke reden, stinken deze haren erg als het regent. Echter, de Bworks Magus schijnen gedeeltelijk hun magische krachten te ontlenen aan deze baardharen, hetgeen sommige alchemisten zal interesseren.",ep:4,g:131,l:23,wd:true,fm:true,w:1,p:20};
I.u[410] = {n:"Bwork Magus Boek",t:25,d:"Dit boek is een echt collectors-item, hieruit put de Bwork Magus al zijn inspiratie en kracht. Iedere pagina van dit boek bevat vele geheimen met betrekking tot de anatomie van bepaalde wezens in Amakna.",ep:4,g:130,l:1,wd:true,fm:true,w:1,p:100};
I.u[411] = {n:"IJs Kwak Snavel",t:47,d:"Met deze bijzonder stevige snavel kan de IJskwak gaten in het ijs maken, alleen voor de gein gaten in het ijs te maken. De IJskwaks zijn beslist erg vreemd...",ep:1,g:133,l:24,wd:true,fm:true,w:1,p:20};
I.u[412] = {n:"Vuur Kwak Snavel",t:47,d:"Met deze bijzonder stevige snavel kan de Vuur Kwak gloeiende kooltjes in zijn snavel doven, alleen om het plezier gloeiende kooltjes in zijn snavel te doven. De Vuur Kwaks zijn beslist erg vreemd...",ep:5,g:132,l:24,wd:true,fm:true,w:1,p:20};
I.u[413] = {n:"Wind Kwak Snavel",t:47,d:"Deze bijzonder solide snavel stelt de Wind Kwak in staat zonder te haperen te bevriezen, alleen maar voor de lol om te bevriezen zonder te haperen. De Wind Kwaks zijn beslist erg vreemd...",ep:5,g:110,l:24,wd:true,fm:true,w:1,p:20};
I.u[414] = {n:"IJs Kwak Veer",t:53,d:"Deze veer heeft de bijzondere eigenschap rijp te weerstaan. Daarom zul je nooit een met rijp bedekte IJs Kwak tegenkomen.",ep:1,g:112,l:24,wd:true,fm:true,w:1,p:20};
I.u[415] = {n:"Vuur Kwak Veer",t:53,d:"Deze veer heeft de bijzondere eigenschap tegen vlammen bestand te zijn. Daarom zul je nooit een brandende Vuur Kwak tegenkomen.",ep:5,g:111,l:24,wd:true,fm:true,w:1,p:20};
I.u[416] = {n:"Wind Kwak Veer",t:53,d:"Deze veer heeft de bijzonder eigenschap windstoten te weerstaan. Daarom kan de Wind Kwak vele winden dag na dag incasseren zonder dat ooit zijn moraal of zijn enthousiasme verzwakken.",ep:5,g:113,l:24,wd:true,fm:true,w:1,p:20};
I.u[417] = {n:"Boomodr",t:15,d:"De Boo is heel agressief, het bestaat uit stukjes modder met de eindjes aan elkaar, de enige manier om er een eind aan te maken is het te drogen, maar het is zo vochtig dat het eind voorlopig niet in zicht is.",ep:2,g:116,l:17,wd:true,fm:true,w:1,p:1};
I.u[418] = {n:"Baardharen van Groot Vader Wabbit",t:54,d:"De Groot Vader Wabbit heeft een valse baard, die stinkt. Zo\'n beetje als die van Vadertje Kwest, maar dan erger. Omdat hij voortdurend kwijlt voor Groot Moeder Wabbit kunnen zijn baardharen het kwijl met miskende krachten niet meer opnemen.",ep:8,g:114,l:39,wd:true,fm:true,w:1,p:100};
I.u[419] = {n:"Oor van Groot Vader Wabbit",t:106,d:"De oren van Groot Vader Wabbit zijn puntig en stijf, maar ze zijn bedekt met een gestreepte vacht, wat een heel mooi effect geeft. Het is ongetwijfeld een van de meest gewilde vachten, al was het omdat hij nergens naar ruikt.",ep:8,g:115,l:39,wd:true,fm:true,w:1,p:1};
I.u[420] = {n:"Vlas Touw",t:15,d:"Vlastouw is erg sterk, je kunt er goed sterke naden mee naaien of je vrienden ermee vastbinden om te laten zien wie gildebaas is.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[421] = {n:"Vlas Bloem",t:35,d:"De Vlasbloem kan blauw of wit zijn, afhankelijk van het jaargetijde waarin het zaad geplant is. Een aftreksel of thee ervan geeft een ongekend gevoel van welbehagen.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:0};
I.u[422] = {n:"Lijn Zaad",t:58,d:"Dit kleine zaadje bevat enorm veel goede stoffen.De Kwakjagers weten dat de Kwaks er dol op zijn en aarzelen niet om de Kwaks in hun val te lokken met deze glimmende zaden.",ep:1,g:119,l:1,wd:true,fm:true,w:2,p:1};
I.u[423] = {n:"Vlas",t:34,d:"De Vlasstengel heeft niets bijzonders, behalve dat hij in staat is 7 keer weer op te komen na geplet te zijn door stormen. Het komt ongetwijfeld daardoor dat zijn vezel zo soepel is.",ep:1,g:122,l:40,wd:true,fm:true,w:2,p:0};
I.u[424] = {n:"Vlasvezel",t:55,d:"Dit is de Vezel die ze gebruiken om de fijnste kleding te maken... Het zeldzame spul is duur, maar altijd populair onder de wevers.",ep:13,g:120,l:46,wd:true,fm:true,w:1,p:1};
I.u[425] = {n:"Hennep",t:34,d:"De Hennep Stengel kan gebruikt worden bij onderzoek naar hallucinatie-effecten, maar ook door wevers die hun vezels voor totaal andere redenen exploiteren.",ep:1,g:121,l:70,wd:true,fm:true,w:2,p:0};
I.u[426] = {n:"Hemp Vezel",t:55,d:"Deze vezel is minder mooi dan stevig maar kan gesmokt worden in je stille momenten van introspectie.",ep:13,g:123,l:46,wd:true,fm:true,w:1,p:1};
I.u[427] = {n:"Hennep Zaad",t:58,d:"Hennep Zaad wordt veel gebruikt om de Tabiskuddes in bronsttijd te kalmeren, je hoeft er maar een paar te geven en ze worden gelijk minder wild.",ep:1,g:157,l:10,wd:true,fm:true,w:1,p:10};
I.u[428] = {n:"Hennepbloem",t:35,d:"Met deze bloem kan je drankjes maken met onverwachte effecten, die kunnen gaan van totale verlamming tot ongevoeligheid voor Wabbitgas.",ep:1,g:156,l:10,wd:true,fm:true,w:1,p:0};
I.u[429] = {n:"Pijlpunt van de Bwork Boogschutter",t:15,d:"Deze roestige pijlpunt is gemaakt van een zeldzaam metaal, dat men alleen op pijlpunten vindt.",ep:4,g:125,l:24,wd:true,fm:true,w:1,p:1};
I.u[430] = {n:"Onzichtbaar Bot van de Onzichtbare Chafer",t:47,d:"Dit bot is onzichtbaar, dankzij de magische eigenschappen die eraan zijn toevertrouwd. Het kan absoluut gebruikt worden voor toverdranken...",ep:1,g:126,l:23,wd:true,fm:true,w:1,p:20};
I.u[431] = {n:"Krakler Steen",t:51,d:"Deze steen is bijna levend, hij haalt zijn levenskracht uit de edelstenen die hem omringen. Hij is praktisch onbreekbaar, behalve door een Krakler. Er is geen betere om een mooie grote stenen te maken.",ep:2,g:127,l:31,wd:true,fm:true,w:5,p:1};
I.u[432] = {n:"Rib Koteletten",t:47,d:"Ribkoteletten zijn heerlijk als ze gegrild worden, ook al zit er niet zoveel vlees aan, maar het is zo lekker dat je er niet vanaf kunt blijven.",ep:3,g:158,l:33,wd:true,fm:true,w:1,p:100};
I.u[433] = {n:"Chafer Boogschutter Dijbeen",t:47,d:"Dit is een vreemde steen, hij is bijzonder bros en verspreidt een verschaalde kerriegeur als hij wordt verbrand, dat zou sommige koks die het niet zo nauw nemen wel goed uit kunnen komen.",ep:1,g:101,l:34,wd:true,fm:true,w:1,p:100};
I.u[434] = {n:"Boomchnid-schors",t:96,d:"Dit stukje schors is ruw, gebarsten, bedekt met kleine uitsteeksels en ruikt vreemd genoeg lekker, een beetje als de huid van de voeten van een Enutrof.",ep:1,g:103,l:32,wd:true,fm:true,w:1,p:1};
I.u[435] = {n:"Boomchnid Wortel",t:98,d:"Dit stukje wortel heeft verschillende voedingsgronden gekend wegens het vergezellen van de Boomchnid tijdens wandelingen in het onderhout. Maar dat verklaart niet waarom dit stukje wortel toverkracht heeft.",ep:1,g:102,l:32,wd:true,fm:true,w:1,p:1};
I.u[436] = {n:"Boomchnid Wortel Staf",t:4,d:"Deze staf werd gemaakt van een dikke Boomchnidwortel is erg doeltreffend in het lijf-aan-lijfgevecht, maar laat hem niet in contact komen met water, want dan gaat hij weer wortel schieten en keert zich dan tegen zijn meester.",ep:1,g:1,l:30,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,20,50,false,false],c:"CI>30&CC>5",p:2650};
I.u[437] = {n:"Boomchnid Knop",t:108,d:"Tijdens de puberteit bedekken de Boomchnids zich met kwade knoppen die overlopen van plantensap dat rijk is aan vitamines. Later bevallen deze knoppen van nieuwe scheuten die zelf weer bevallen van knoppen.",ep:1,g:104,l:32,wd:true,fm:true,w:1,p:1};
I.u[438] = {n:"Boowolf Staart",t:65,d:"De staart van de Boowolf lijkt verbluffend veel op een enorme harige boomstam, en toch is hij dat totaal niet, vergis je niet.",ep:1,g:105,l:70,wd:true,fm:true,w:1,p:50};
I.u[439] = {n:"Hoektand van de Boowolf",t:47,d:"Deze scherpe hoektand is vooral gewild als geluksbrenger, maar toch brengt hij zijn drager alleen een slechte geur.",ep:1,g:106,l:70,wd:true,fm:true,w:1,p:1};
I.u[440] = {n:"Boowolf Klauw",t:15,d:"Met deze erg vieze klauw kunnen geduchte wapens gemaakt worden.",ep:1,g:107,l:70,wd:true,fm:true,w:1,p:1};
I.u[441] = {n:"Koper",t:39,d:"Koper is een metaal dat erg handig is voor het maken van goedkope wapens, het is bijna een vervanging voor goud als je alle kwaliteiten van goud buiten beschouwing laat.",ep:1,g:108,l:10,wd:true,fm:true,w:5,p:0};
I.u[442] = {n:"Brons",t:39,d:"Dit metaal wordt vaak gebruikt bij het maken van ornamenten, om je wapens tegen lage kosten mooier te maken, is dit het ideale metaal.",ep:1,g:109,l:20,wd:true,fm:true,w:5,p:0};
I.u[443] = {n:"Kobalt",t:39,d:"De naam \"Kobalt\" betekent \"koper van de duivel\" in oud-Sadida\'s, het is een metaal dat goed past bij het smeden van lichte en elegante, maar vooral dodelijke, wapens.",ep:1,g:77,l:30,wd:true,fm:true,w:5,p:0};
I.u[444] = {n:"Tin",t:39,d:"Tin is een zacht en zwaar metaal, een beetje als de Wo Wabbit, maar dan erger.",ep:1,g:78,l:50,wd:true,fm:true,w:5,p:0};
I.u[445] = {n:"Mangaan",t:39,d:"In tegenstelling tot wat iedereen denkt, dient dit metaal niet voor het maken van dakgoten, maar eerder voor het maken van afschrikwekkende wapens, zoals het gevreesde \'Manganese Mes\', dat meer dan één Tofu in elkaar heeft geslagen tijdens de feesten van de Bolgour.",ep:1,g:397,l:40,wd:true,fm:true,w:5,p:0};
I.u[446] = {n:"Bauxiet",t:39,d:"Dit metaal wordt erg gewaardeerd om zijn zilveren kleur en om zijn scherpte als het op de huiste manier geslepen is.",ep:1,g:76,l:70,wd:true,fm:true,w:5,p:0};
I.u[447] = {n:"Steenkool",t:39,d:"Steenkool bezit geen enkele bijzondere magische eigenschap, in tegenstelling tot wat je zou kunnen denken. Het heeft evenwel een boze neiging de bliksem aan te trekken, vast te houden, en op het verkeerde moment los te laten.",ep:5,g:75,l:1,wd:true,fm:true,w:5,p:0};
I.u[448] = {n:"Vuursteen",t:51,d:"Deze steen is bijzonder scherp, hij heeft al meet dan één onvoorzichtige mol de hals doorgesneden.",ep:1,g:74,l:22,wd:true,fm:true,w:5,p:1};
I.u[449] = {n:"Ebbenhout",t:38,d:"Dit hout dankt zijn naam aan een misverstand, lang geleden was er één man die wist waar deze bomen stonden en hij heette Eppie, daarom had men het overal over \"Eppehout\", en zie hier wat er gebeurt als men zomaar een schrijfwijze hanteert.",ep:7,g:73,l:70,wd:true,fm:true,w:5,p:0};
I.u[450] = {n:"Graniet Steen",t:51,d:"Dit mineraal slijt bijna niet, maar is ook erg zwaar, wat het gebruik ervan bij het smeden van wapens beperkt. Als je het lang bewerkt, kan je er soms edelstenen uithalen.",ep:1,g:1,l:30,wd:true,fm:true,w:20,p:1};
I.u[454] = {n:"Houthakkers Bijl",t:19,d:"Deze bijl is onontbeerlijk voor een houthakker die zijn beroep goed wil uitoefenen. Hij kan je ook tegen monsters beschermen.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:150};
I.u[455] = {n:"Dageraads Hamer",t:7,d:"Deze belachelijk kleine hamer was ooit van de boer Zokrim, die hem gebruikte om bij dageraad zijn omheiningspaaltjes in de grond te slaan . Niemand weet waarom Zokrim deze paaltjes bij dageraad plantte, maar de legende vertelt dat hij daar een goede reden voor had.",ep:1,g:2,l:26,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CS>10&CI>16",p:2000};
I.u[456] = {n:"Eiken Doder",t:19,d:"Met deze bijl kun je makkelijk bomen hakken, zelfs de grootste. Hij wordt voornamelijk gewaardeerd om zijn enorme gewicht, waarmee je makkelijk een Bwork in drieën kunt hakken, op voorwaarde dat zijn bezitter hem weet op te tillen.",ep:7,g:2,l:33,wd:true,fm:true,w:50,an:17,e:[5,4,1,1,40,40,false,false],c:"CS>66&CA>10",p:3150};
I.u[458] = {n:"Chafer Amulet",t:1,d:"De Chafer is een gevoelig en gedistingeerd persoon, hij heeft altijd een amulet bij zich die gemaakt is van de schedels van zijn in de strijd omgekomen neven. Het vreemste is dat de Chafer nooit neven gehad heeft.",ep:1,g:3,l:19,wd:true,fm:true,w:4,p:1200};
I.u[459] = {n:"Essenhouten Plank",t:95,d:"Met deze essenhouten plank kunnen doe-het-zelvers houten dingen maken zoals bijvoorbeeld een doodskist.",ep:1,g:93,l:1,wd:true,fm:true,w:10,p:10};
I.u[460] = {n:"Eikenhout",t:38,d:"Dit hout van uitzonderlijke kwaliteit heeft een hele hoge weerstand, je kan er bijna alles van maken, knuppels, huizen of zelfs boten, maar de beste manier om dit hout te gebruiken is er bierpullen van te maken (Hik!)",ep:1,g:92,l:30,wd:true,fm:true,w:5,p:0};
I.u[461] = {n:"Taxushout",t:38,d:"Dit bijzonder buigzame hout breekt nooit, waardoor het eerste klas hout is voor het maken van bogen. Het is daarentegen moeilijk te vinden, omdat de boeren van Amakna de neiging hebben de jonge taxusscheuten te doden omdat hun Veelvraten er ziek van worden.",ep:1,g:94,l:50,wd:true,fm:true,w:5,p:0};
I.u[462] = {n:"Boomchnid Wortel Boog",t:2,d:"Boomchnid hout leeft nog steeds ook al is het gekapt, deze boog is daarom moeilijk te bedienen. Echter, er is geen betere manier om een Boomchnid belachelijk te maken dan hem te doden met een boog die is gemaakt van de wortels van zijn eigen broers.",ep:1,g:1,l:28,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,30,50,false,true],c:"CS>10&CA>28",p:2250};
I.u[463] = {n:"Barnsteen",t:50,d:"Deze prachtige edelsteen bestaat uit hars van versteende bomen. Soms zit er een al eeuwen gevangen Moskito in, wat alleen maar meer waarde aan deze steen geeft.",ep:1,g:96,l:32,wd:true,fm:true,w:4,p:20};
I.u[464] = {n:"Barnsteen van Boomchnid",t:50,d:"Deze fantastische edelsteen bestaat uit gefossiliseerde Boomchnid-hars. Somt vind je er binnenin een Arachnee die lichtjaren geleden in de val gelopen is in het sap van zijn Meester. Dat is een welverdiende dood voor zo\'n Monster.",ep:1,g:97,l:32,wd:true,fm:true,w:5,p:40};
I.u[465] = {n:"Kristal",t:50,d:"Kristal is doorschijnend en prachtig, maar erg broos. Zo is het leven, niks is perfect, zelfs niet bij kostbare stenen.",ep:1,g:98,l:50,wd:true,fm:true,w:20,p:5000};
I.u[466] = {n:"Saffier",t:50,d:"Deze kostbare blauwe steen is goed bewerkt om magische wapens te maken. Waarom blauw? Misschien omdat de luie dwazen die dit spel gemaakt hebben een muntje hebben opgegooid en deze kleur hebben bedacht...",ep:1,g:99,l:50,wd:true,fm:true,w:20,p:5000};
I.u[467] = {n:"Robijn",t:50,d:"De glinsterende gloed van deze kostbare steen roeps Vuur Kwak veren op. Maar hij is zo koud als de Ijs Kwak sneeuwballen.",ep:1,g:100,l:50,wd:true,fm:true,w:20,p:5000};
I.u[468] = {n:"Amakna Brood",t:33,d:"Met dit heerlijke warme broodje, zacht van binnen en met gouden korst, kan je health points terugwinnen die je tijdens gevechten bent kwijtgeraakt. Het is het populairste brood, want over het algemeen is het goedkoper.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[469] = {n:"Boomchnid Wortel Stok",t:3,d:"Deze stok gebruikt de magische eigenschappen van de Boomchnid Wortel, die nog levend is, pas op voor de fatale effecten van deze stok, het gebeurt soms dat hij zich tegen zijn meester richt.",ep:1,g:3,l:33,wd:true,fm:true,w:20,an:11,e:[5,4,2,2,50,40,false,true],c:"CI>33&CW>10",p:3100};
I.u[470] = {n:"Iepenhout",t:38,d:"Iepenhout is één van de meest gewilde houtsoorden, vroeger gangbaar, maar eeuwen geleden gedecimeerd door de Grafioze, een soort vreselijke betovering uitgesproken door een Machtige Bwork Magus van de Cavernes van het ergste soort.",ep:3,g:140,l:90,wd:true,fm:true,w:5,p:0};
I.u[471] = {n:"Esdoornhout",t:38,d:"Met de bladeren van een Esdoorn hebben mensen met weinig fantasie een originele vlag gemaakt, de stroop heeft smaak gegeven aan pannenkoeken. Men zoekt nog waar het hout voor kan dienen.",ep:1,g:153,l:40,wd:true,fm:true,w:5,p:0};
I.u[472] = {n:"Kersenhout",t:38,d:"Het Beukenhout heeft zijn naam te danken aan de Sadidas, die altijd onder de Beuken paren, om redenen die slechts onthuld worden in het Magische Bwork boek.",ep:1,g:138,l:80,wd:true,fm:true,w:5,p:0};
I.u[473] = {n:"Kastanjehout",t:38,d:"De geur van kastanjehout verjaagt vliegen, behalve degene die van kastanje houden en degene die hun reukvermogen kwijt zijn, wat verklaart waarom de geur van kastanjehout in feite geen enkele vlieg verjaagt.",ep:1,g:86,l:10,wd:true,fm:true,w:5,p:0};
I.u[474] = {n:"Kersenhout",t:38,d:"Dit hout is gewild voor meubels vanwege zijn compacte samenstelling en zijn roodbruinige kleur die het in de loop der tijd verkrijgt.",ep:1,g:139,l:60,wd:true,fm:true,w:5,p:0};
I.u[476] = {n:"Notenhout",t:38,d:"Notenhout wordt vaak gebruikt voor het maken van meubels. Om duistere redenen weigeren bepaalde timmerlieden het voor hun boten te gebruiken.",ep:1,g:95,l:20,wd:true,fm:true,w:5,p:0};
I.u[477] = {n:"Draak Varken Bloed",t:15,d:"Deze veldfles is vol met bloed welke kwaadaardige krachten verleende aan het Draak Varken. Om gematigd te drinken of gebruikt als ingrediënt in de Draak Varken zwarte pudding, als je van dat soort dingen houdt!",ep:2,g:544,l:70,wd:true,fm:true,w:10,p:100};
I.u[478] = {n:"Beuken Snoeischaar",t:19,d:"Deze bijl dankt zijn naam aan Woedie de Houthakster, die haar charmes gebruikte om andere houthakkers af te leiden en zo de plaats van de zeldzame beuken, die ze in stand wilde houden, geheim te houden.",ep:7,g:3,l:47,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,40,40,false,false],c:"CW>20&CI>20&CC>20",p:5900};
I.u[479] = {n:"Ivoor",t:47,d:"Ivoor is erg gewild door de verzamelaars, voor zijn legendarische witheid, en door de Smeden vanwege zijn vermogen wapens dodelijk te maken. Wat zeker is, is Ivoor in Amakna erg geliefd is.",ep:1,g:88,l:40,wd:true,fm:true,w:10,p:100};
I.u[480] = {n:"Vreemd Mineraal",t:39,d:"Dit Mineraal is onttrokken uit een mysterieuze onbekende steengroeve. In tegenstelling tot alle vreemde voorwerpen van Amakna is deze helemaal niet magisch.",ep:1,g:90,l:24,wd:true,fm:true,w:5,p:100};
I.u[481] = {n:"Draak Varken schedel",t:47,d:"Ondanks zijn kleine capaciteit is deze schedel een echt verzamelings item. Zijn gelijkenis met de schedel van een Iops volgeling stond meerdere medische studenten toe om de origine van de intellectuele zwakheden van de Iop\'s soort uit te leggen.",ep:2,g:91,l:70,wd:true,fm:true,w:50,p:100};
I.u[482] = {n:"Graaf Schep",t:8,d:"Na een met drank overgoten avond in de herberg, die uitmondde in een knokpartij, kwam een Enutrof er achter dat deze schep, eigenlijk bedoeld voor grote bouwwerken, een uitstekend wapen was.",ep:1,g:8,l:27,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>7&CC>20",p:2200};
I.u[483] = {n:"Grote Graaf Schep",t:8,d:"Na een met drank overgoten avond in de herberg, die uitmondde in een knokpartij, kwam een Enutrof erachter dat deze schep, eigenlijk bedoeld voor grote bouwwerken, een uitstekend wapen was.",ep:1,g:8,l:29,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>9&CC>20",p:2500};
I.u[484] = {n:"Krachtige Graaf Schep",t:8,d:"Na een drankovergoten avond in de herberg die eindigde in een gevecht, ontdekte een Enutrof dat deze van oorsprong voor bouwwerken gemaakte schep ook uitstekend als wapen gebruikt kan worden.",ep:1,g:8,l:31,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>11&CC>20",p:2800};
I.u[485] = {n:"Leren Onderbroek van de Chafer Lansier",t:56,d:"Als de winter komt, gaat de Lansier Chafer nooit naar buiten zonder zijn leren onderbroek, waarmee hij zijn gewrichten wam kan houden of zo nodig zijn tegenstanders af kan leiden.",ep:1,g:152,l:44,wd:true,fm:true,w:10,p:100};
I.u[486] = {n:"Everzwijnleer",t:56,d:"Dit leer is bijzonder sterk, maar ruikt naar een mannelijk bronstig Everzwijn, wat verklaart waarom lokale boeren het gebruiken om vrouwtjes-Everzwijnen in de val te lokken, die te stom zijn om een zo bedrieglijke list te ontmaskeren.",ep:1,g:16,l:14,wd:true,fm:true,w:10,p:1};
I.u[487] = {n:"Draak Varken Leder",t:56,d:"Deze nutteloze dromer van een beest verbrandde al zijn haren nadat hij zichzelf probeerde te veranderen in een draak. Het leder stinkt.",ep:2,g:142,l:70,wd:true,fm:true,w:10,p:6000};
I.u[489] = {n:"Loep",t:20,d:"Met de loep kan je aandachtig de elementen van de omgeving bekijken om er schatten in te ontdekken.",ep:1,g:3,l:1,wd:true,fm:true,w:10,an:3,e:[1,6,1,1,100,10,false,false],p:10};
I.u[490] = {n:"Flesje",t:20,d:"Met dit flesje, van levensbelang voor elke zichzelf respecterende alchemist, kan men de beste drankjes maken.",ep:1,g:2,l:1,wd:true,fm:true,w:3,an:4,e:[1,6,1,1,200,2,false,false],p:10};
I.u[491] = {n:"Zetter",t:5,d:"Met dit voorwerp kan de Juwelier zijn juwelen bewerken.",ep:1,g:16,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[492] = {n:"Kneedmachine",t:20,d:"Onmisbaar werktuig als je het beroep van banketbakker wil uitoefenen.",ep:1,g:1,l:1,wd:true,fm:true,w:8,an:4,tw:true,e:[50,6,1,1,500,10,false,false],p:10};
I.u[493] = {n:"Hamersmid Hamer",t:7,d:"Onmisbaar gereedschap bij het maken van hamers.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[494] = {n:"Zwaardsmid Hamer",t:7,d:"Onontbeerlijk gereedschap voor het maken van zwaarden.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[495] = {n:"Dolksmid",t:7,d:"Onmisbaar werktuig bij het maken van dolken.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[496] = {n:"Schepsmid Hamer",t:7,d:"Onmisbaar gereedschap voor het maken van scheppen.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[497] = {n:"Mijnwerkers Houweel",t:21,d:"Onmisbaar gereedschap om mineralen te delven.",ep:1,g:1,l:1,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[498] = {n:"Stafsnijder",t:5,d:"Onmisbaar gereedschap bij het maken van staffen.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[499] = {n:"Stoksnijder",t:5,d:"Dit gereedschap is onontbeerlijk voor het maken van stokken.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[500] = {n:"Boogsnijder",t:5,d:"Onmisbaar gereedschap voor het maken van bogen.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[501] = {n:"Gemodificeerd Boomchnid Sap",t:15,d:"Dit stroperige plantensap is weer bewerkt door een gerenommeerde Alchemist, zodat hij de Boomchnidwortels weer tot leven kon wekken. Het is duidelijk dat dit soort plantensap slechts door ervaren handen bewerkt moet worden.",ep:2,g:162,l:30,wd:true,fm:true,w:2,p:50};
I.u[502] = {n:"Taxus Kliever",t:19,d:"Dit is de een van de weinige bijlen die betoverde bomen kan vellen, en dientengevolge kan hierbij worden bevestigd dat hij alles wat betoverd is kan vellen, dood of levend.",ep:1,g:4,l:17,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,50,false,false],c:"CS>10&CI>35",p:950};
I.u[515] = {n:"Boulgourde van de Open Plekken",t:19,d:"Deze bijl behoorde aan de beroemde Houthakker Brouce Boulgoure, die ooit getrouwd was met Kassiopee Baine, dochter van een andere grote Houthakker. Hij heeft zich meermalen kunnen verdedigen met dit wapen als hij \'s nachts vertrok om hele bossen te kappen.",ep:7,g:5,l:62,wd:true,fm:true,w:60,an:17,tw:true,e:[15,6,1,1,50,40,false,false],c:"CI>124&CC>30&CV>10",p:10100};
I.u[519] = {n:"Kwakzalverspoeder",t:48,d:"Zoals de naam al aangeeft, is dit poeder gemaakt van een Kwak Zalf. Maar dat verklaart nog niet waarom dit toverpoeder is.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[520] = {n:"Maan Zaad Brood",t:33,d:"De bereiding van dit brood is gevaarlijk, want de bakkers die de lucht opsnuiven tijdens het bakken, worden het slachtoffer van vreemde symptomen en beginnen rondom hun bakkerij te dansen.",ep:1,g:10,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[521] = {n:"Sesam Zaad Brood",t:33,d:"De meest slimme Kwaks deinzen er niet voor terug zich te verkleden als bakker om Sesamzaden achter over te drukken, maar dit bedrog werkt nooit, behalve bij de Iop Bakkers.",ep:1,g:11,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[522] = {n:"Lijnzaad Brood",t:33,d:"Dit brood is rijk aan proteïne, maar smaakt niet lekker. Tja, het leven is altijd een kwestie van keuzes maken.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[524] = {n:"Hazelnoot Brood",t:33,d:"Dit brood met een fijne smaak is gegarandeerd zonder kleurstoffen of conserveermiddelen, in tegenstelling tot de Koninklijke Gelei.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[526] = {n:"Meergranen Brood",t:33,d:"Dit brood met een variëteit aan granen, is rijk genoeg aan proteïnen om een Chafer weer tot leven te wekken.",ep:1,g:6,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[527] = {n:"Noten Brood",t:33,d:"Dit brood is gebakken met Notenhout en de noten zijn geroosterd voordat ze in het deeg gestopt worden.",ep:4,g:8,l:40,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[528] = {n:"Volkoren Brood",t:33,d:"Dit brood is verrijkt met volkoren, waardoor het een kwaliteitsbrood is voor veeleisende mensen.",ep:1,g:7,l:20,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[529] = {n:"Gerste Meel",t:52,d:"Dit meel kan je bij de molen maken, door gerstekorrels te pletten, het geeft een luchtigheid zonder weerga aan het brooddeeg, als je ten minste, uiteraard, een geheime magie gebruikt tijdens het bakken van je brood.",ep:1,g:256,l:1,wd:true,fm:true,w:2,p:0};
I.u[530] = {n:"Rogge Meel",t:52,d:"Dit meel bevat alle goede eigenschappen van Rogge. Volgens de legende wordt Rogge dat in de dageraad ontkiemt, nooit rijp. Daarom maken sommige boeren hun kinderen in de vroege ochtend, in de hoop dat ze nooit oud zullen worden.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[531] = {n:"Haver Meel",t:52,d:"Dit meel rijst niet tijdens het bakken, zodat je er werkelijk stevig brood mee kunt maken, heel handig als je brood aan monsters moet uitdelen.",ep:1,g:250,l:1,wd:true,fm:true,w:2,p:0};
I.u[532] = {n:"Rogge",t:34,d:"Deze Duistere graansoort heeft het vermogen in moeilijke omstandigheden te groeien, het is één van de weinige granen die grote droogteperioden kan overleven.",ep:1,g:82,l:50,wd:true,fm:true,w:2,p:0};
I.u[533] = {n:"Haver",t:34,d:"Dit graan wordt gebruikt als voedsel voor jonge Tabis, zolang ze nog geen voldoende stevige tanden hebben om te herkauwen. De boeren letten evenwel goed op omdat haver soms teveel gasvorming veroorzaakt bij gevoelig vee.",ep:1,g:154,l:20,wd:true,fm:true,w:2,p:0};
I.u[534] = {n:"Mout Meel",t:52,d:"Dit witte meel wordt verkregen van geplette gekiemde gerstezaden, wat een licht zure smaak geeft aan brood, en in het beste geval, de smaak van bier. Handig voor het geleidelijk afkicken van bierdrinkers. Eenmaal gebakken, helpt dit meel om beter tegen drank te kunnen. ",ep:1,g:255,l:1,wd:true,fm:true,w:2,p:0};
I.u[535] = {n:"Hop Meel",t:52,d:"Met dit meel kan je brood een heerlijke biersmaak geven, zonder bier te hoeven gebruiken om het brood te maken. Soms moet je toegeven dat de natuur goed in elkaar zit.",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[536] = {n:"Havervlokken Brood",t:33,d:"Dit brood is bijzonder luchtig en is ideaal voor mensen die door Moeder Natuur begiftigd zijn met een kleine maag.",ep:1,g:5,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[537] = {n:"Aardappel",t:68,d:"In zijn algemeenheid is het als je over dit voorwerp struikelt zo, dat je je òf in een veld bevindt, òf in een gevangenis.",ep:1,g:135,l:1,wd:true,fm:true,w:20,p:10};
I.u[538] = {n:"Geschilde Aardappelen",t:68,d:"Deze aardappel is ontdaan van zijn schil, waardoor hij een eetbaar voedingsmiddel is geworden.",ep:1,g:136,l:1,wd:true,fm:true,w:20,p:10};
I.u[539] = {n:"Rogge Brood",t:33,d:"Dit brood is gemaakt op basis van roggemeel, wat aan het deeg een aparte bruine kleur geeft, maar vooral een licht zoete smaak.",ep:1,g:9,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[543] = {n:"Diamant Steen",t:51,d:"Indien op juiste wijze geslepen, wordt deze steen een prachtige Diamant.",ep:1,g:144,l:30,wd:true,fm:true,w:20,p:15};
I.u[544] = {n:"Smaragd Steen",t:51,d:"Op de juiste manier gepolijst, kan deze steen een schitterende Smaragd geven.",ep:1,g:145,l:30,wd:true,fm:true,w:20,p:15};
I.u[545] = {n:"Kristal Steen",t:51,d:"Indien op juiste wijze geslepen, wordt deze steen een prachtige Kristal.",ep:1,g:141,l:30,wd:true,fm:true,w:20,p:15};
I.u[546] = {n:"Saffier Steen",t:51,d:"Indien goed geslepen, wordt deze steen een prachtige Saffier.",ep:1,g:151,l:30,wd:true,fm:true,w:20,p:15};
I.u[547] = {n:"Robijn Steen",t:51,d:"Indien op juiste wijze geslepen, wordt deze steen een prachtige Robijn.",ep:1,g:150,l:30,wd:true,fm:true,w:20,p:15};
I.u[548] = {n:"Terugkeerdrankje",t:12,d:"Met dit drankje kan je terugkeren naar het laatste veilige punt.",ep:1,g:17,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[577] = {n:"Boeren Zeis",t:22,d:"Deze zeis is niet erg scherp en vooral een beetje roestig, waardoor hij een weinig gevaarlijk wapen is. Daarentegen is het voor maaien het ideale werktuig.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[578] = {n:"Slijp Steen",t:51,d:"Ik zal deze steen nooit als eerste gooien...",ep:2,g:127,l:1,wd:true,fm:true,w:20,p:1};
I.u[579] = {n:"Leer Schaar",t:5,d:"Onmisbaar gereedschap bij het maken van schoenen en riemen.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[580] = {n:"Ghetto Raide Drankje",t:12,d:"Met dit drankje kan je enkele health points terugvinden.",ep:1,g:18,l:10,wd:true,fm:true,w:1,u:true,p:20};
I.u[582] = {n:"Wit Meel",t:52,d:"Er zijn meerdere graansoorten voor nodig om dit meel te maken en men bakt er het liefste brood van. Op het eerste gezicht zie je geen verschil tussen dit meel en het klassieke meel.",ep:1,g:7,l:1,wd:true,fm:true,w:2,p:0};
I.u[583] = {n:"Kus Meel",t:52,d:"Dit bijna witte meel draagt de naam van de uitvindster ervan, een leuke boerin die graag zoende met haar wangen vol meel. Wat een guitige dame.",ep:1,g:7,l:20,wd:true,fm:true,w:2,p:0};
I.u[586] = {n:"Boerinnen Meel",t:52,d:"Door de vrouw van Brouce Boulgoure te tarten en te slaan met zakken meel is Shika Ingalsse op het idee gekomen dit populair geworden meel te maken. De gevechten van vrouwen brengen soms veel meer dan alleen afleiding voor het plebs.",ep:1,g:258,l:30,wd:true,fm:true,w:2,p:0};
I.u[587] = {n:"Volkoren Meel",t:52,d:"Dit meel is gemaakt van een veel soorten granen, waardoor het een meergranenmeel is, zeer nuttig voor meergranenbrood.",ep:1,g:259,l:40,wd:true,fm:true,w:2,p:0};
I.u[592] = {n:"Ivan Nowe Koord",t:2,d:"Deze boog was ooit van Ivan Nowe, een roekeloze Cra, die meer dan één verdwaalde Tofu heeft bestreden. Deze boog heeft de eigenschap om verrassende slagen uit te delen die zijn vijanden perplex en stervend achterlaat.",ep:7,g:1,l:36,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,15,50,false,true],c:"CS>30&CA>36",p:3600};
I.u[593] = {n:"Freyesque Orchidee",t:35,d:"Deze bloem is van onvoorstelbare zeldzaamheid en schoonheid, maar ze is bijna onvindbaar. De Padden hebben feitelijk de neiging ze mee te nemen naar hun kamp om hun nageslacht te voeden.",ep:1,g:192,l:40,wd:true,fm:true,w:1,p:0};
I.u[594] = {n:"Edelweiss",t:35,d:"Deze bloem is zeer zeldzaam en van een ongelooflijke schoonheid, maar is bijna niet te vinden. En niet zonder reden, haar magie is zo krachtig dat ze in staat is sommige doden weer te doen herleven.",ep:1,g:191,l:50,wd:true,fm:true,w:1,p:0};
I.u[595] = {n:"Schaaf van de Timmerman",t:20,d:"Met dit gereedschap kan de Timmerman boomstammen schaven om er planken of balken van de maken, zie hier een beroep dat vooral boeiend is voor mensen die van houten huizen houden.",ep:1,g:19,l:1,wd:false,fm:true,w:1,e:[1,4,1,1,100,100,false,false],p:10};
I.u[596] = {n:"Korte Vishengel",t:20,d:"Dit kleine vishengeltje is ideaal om je mee te vermaken bij het vangen van visjes in waterplassen.",ep:1,g:8,l:1,wd:true,fm:true,w:1,an:18,e:[1,4,1,1,100,100,false,false],p:200};
I.u[597] = {n:"Enkelvoudig Vangnet",t:99,d:"Met dit zeer sterke net kan je de wildste rijdieren vangen, op voorwaarde dat je erin geslaagd bent hem iets daarvoor te hypnotiseren of af te leiden.",ep:20,g:1,l:1,wd:true,fm:true,w:1,an:0,p:10};
I.u[598] = {n:"Kar-Naal",t:41,d:"De Kar-Nalen worden gewaardeerd wegens hun rose kleur en hun fijne smaak. Ze worden evenwel gehaat voor hun legendarische slechte karakter en hun met gel ingesmeerde voelsprieten.",ep:1,g:292,l:1,wd:true,fm:true,w:1,p:10};
I.u[600] = {n:"Krakamor",t:41,d:"De Krakamor is een grote romanticus, door zijn ogen van een kleine Tofu ziet hij er een beetje simpel uit, maar vergis je niet, de Krakamor is erg agressief tegenover vreemdelingen.",ep:2,g:309,l:20,wd:true,fm:true,w:1,p:10};
I.u[602] = {n:"Hamer-en-Sikkel-Haai",t:41,d:"Deze rode Haai is een militante haai, met kuddegeest, het individu bestaat niet binnen de groep, zelfs al is hun chef, de Haai Stakanoviou, tot idool benoemd.",ep:2,g:322,l:80,wd:true,fm:true,w:2,p:1};
I.u[603] = {n:"Kitten Vis",t:41,d:"Deze vis heeft de eigenaardigheid een snor te hebben en onder water te spinnen, wat op zijn beurt de Vliegende Vissen weer bang maakt.",ep:1,g:277,l:1,wd:true,fm:true,w:1,p:50};
I.u[607] = {n:"Modderige Forel",t:41,d:"De Modderige Forel is een verre neef van de agressieve Zalm van het eiland Moon. Deze forel is even lekker gebakken als rauw, snap je dat nou?",ep:1,g:395,l:1,wd:true,fm:true,w:1,p:50};
I.u[610] = {n:"Krab Amulet",t:1,d:"Dit witachtige amulet is gemaakt met Krab, waardoor hij heel breekbaar is maar ook heel origineel.",ep:1,g:30,l:24,wd:true,fm:true,w:2,p:1800};
I.u[616] = {n:"Zeemans Amulet",t:1,d:"Dit met vissenschubben bezette amulet wordt geacht geluk te brengen aan zijn eigenaar als deze op stormachtige dagen de zee op gaat.",ep:1,g:29,l:22,wd:true,fm:true,w:2,p:2000};
I.u[617] = {n:"Piraat Amulet",t:1,d:"Dit verschrikkelijke amulet heeft op menig zeeman indruk gemaakt, alleen al het dragen ervan maakt je een gevreesd persoon.",ep:1,g:20,l:41,wd:true,fm:true,w:2,p:4500};
I.u[619] = {n:"Meester Veelvraat Staf",t:4,d:"Met deze staf kon Farle Ingalsse, Veelvraatfokker, makkelijk Tofus bezweren die de kuddes bewaakten. In de loop der tijd bleek dit een ideaal wapen.",ep:7,g:6,l:85,wd:true,fm:true,w:20,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>60&CW>20&CA>40",p:10000};
I.u[620] = {n:"Krakamor Zwaard",t:6,d:"Met dit zwaard was de beroemde zeeman Mobby Diqueriveurse in staat de tentakels van de vermaarde Reuzen Krakamor van het eiland Moon in stukken te hakken. Hij was beroemd door het verstikken van dronken zeelui en het verdrinken van verstikte zeelui.",ep:1,g:8,l:61,wd:true,fm:true,w:50,an:14,e:[10,7,1,1,50,50,false,false],c:"CV>60&CW>60",p:9900};
I.u[629] = {n:"Punt Muts",t:16,d:"Met deze prachtige hoed kan jouw held de mooiste zijn op het gemaskerde bal.",ep:5,g:1,l:21,wd:true,fm:true,w:5,p:1400};
I.u[638] = {n:"Somoon Vissers Amulet",t:1,d:"Het vangen van een Somoon is een krachttoer, maar met dit  amulet in je bezit is niets onmogelijk.",ep:12,g:24,l:35,wd:true,fm:true,w:5,p:2500};
I.u[639] = {n:"Amulet van de Diepten",t:1,d:"Dit amulet is teruggevonden in het gestrande wrak van de beroemde Krakamor-visser, Moby Diqueriveruse, die eveneens populair was wegens zijn suffe grappen in de piratenbar.",ep:14,g:22,l:47,wd:true,fm:true,w:5,p:6000};
I.u[640] = {n:"Oever Boog",t:2,d:"Met deze boog kunnen de vissers de oevers van ongedierte ontdoen zonder op te staan van hun stoel en vanuit het raam van de piratenbar.",ep:14,g:38,l:46,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,10,30,45,false,true],c:"CA>46",p:5600};
I.u[641] = {n:"Oer Katoen",t:15,d:"Deze Katoen is net zo zacht als de huid van een jonge Ecaflippin, wit als een voorjaarswolk, maar teer als een Tofu veer.",ep:1,g:657,l:6,wd:true,fm:true,w:1,p:500};
I.u[642] = {n:"Zijderups Cocon",t:15,d:"Van deze enorme witachtige cocon kan je een prachtige zijden draad maken. De avonturier Harry Hane zou hem hebben gebruikt om uit het labyrint van Dark Vlad te ontsnappen.",ep:1,g:489,l:6,wd:true,fm:true,w:1,p:100};
I.u[643] = {n:"Zijden Reeks",t:15,d:"De delicatesse en soepelheid van deze string is moeilijk te verslaan. Zijde is het weefsel die voorkeur heeft bij de Chafers voor hun gevechts ondergoed.",ep:1,g:486,l:5,wd:true,fm:true,w:1,p:100};
I.u[646] = {n:"Zwarte Tiwabbit Haren",t:54,d:"Dit gitzwarte haar heeft het voordeel dat het niet vies wordt, wat niet uit maakt voor helden die weinig op hebben met hygiëne. Maar let op, dit haar heeft de neiging te verkleuren zodra het in contact komt met overmatig en bijtend zweet.",ep:8,g:195,l:11,wd:true,fm:true,w:1,p:50};
I.u[648] = {n:"Wabbit Haren",t:54,d:"Dit haar wordt niet erg hoog aangeslagen door ervaren Kleermakers, die meer een voorkeur hebben voor het haar van andere Wabbits. Maar het wordt wel graag gebruikt om Moskito\'s te verjagen vanwege zijn Wilde Citroengeur.",ep:8,g:196,l:18,wd:true,fm:true,w:1,p:1};
I.u[649] = {n:"Wo Wabbit Haren",t:54,d:"Dit haar is zo vet, dat je het kan gebruiken om stoffen waterdicht te maken voor weer en wind.",ep:8,g:197,l:39,wd:true,fm:true,w:1,p:40};
I.u[650] = {n:"Haren van Grootvader Wabbit",t:54,d:"Dit slechtriekende haar is perfect om mee te naaien, omdat het de neiging heeft te krullen als het in contact komt met Wottelsap.",ep:8,g:198,l:39,wd:true,fm:true,w:1,p:50};
I.u[651] = {n:"Boowolf Stof",t:55,d:"Deze stof van Boowolfhaar is heel zeldzaam, maar zijn samenstelling stelt hem in staat alle vormen van fysieke en soms zelfs magische agressie te weerstaan.",ep:1,g:199,l:70,wd:true,fm:true,w:1,p:100};
I.u[652] = {n:"Everzwijn Stof",t:55,d:"Deze stof gemaakt van Everzwijnenvacht is ruw en stinkt, maar het beschermt je goed tegen lichamelijke aanvallen.",ep:1,g:220,l:13,wd:true,fm:true,w:1,p:50};
I.u[653] = {n:"Prespic Stof",t:55,d:"Onder zijn stekels beschikt de Prespic over een heel zacht rossig bontje, dat een onaangename geur verspreidt als het regent. Gelukkig voor jou regent het nooit in Amakna, maar maak van deze stof geen zwembroek.",ep:1,g:661,l:17,wd:true,fm:true,w:1,p:100};
I.u[654] = {n:"Wabbit Stof",t:55,d:"Deze stof van Baard Haren van Groot Vader Wabbit is zeer dik, maar irriteert net zo erg, zoiets als een grote prikkende rups.",ep:8,g:15,l:18,wd:true,fm:true,w:1,p:100};
I.u[657] = {n:"Meester Tofus Staf",t:4,d:"Met deze stok kon Shika Ingalsse, Tofufokster, makkelijker de hulp inroepen van Tofusherders. In de loop der tijd, bleek deze stok ook een uitstekend gevechtswapen te zijn.",ep:7,g:6,l:56,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>40&CW>10&CS>30",p:5600};
I.u[658] = {n:"Tabi Meester Staf",t:4,d:"Met deze staf kon Gramine Ingalsse, fokker van Tabis, makkelijker Tofus herders bezweren. In de loop der tijd bleek deze staf een uitstekend gevechtswapen te zijn.",ep:7,g:6,l:34,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>20&CW>5",p:3400};
I.u[666] = {n:"",t:15,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:0};
I.u[670] = {n:"Agrame",t:22,d:"Deze zeis heeft toebehoord aan Gramine Ingalsse, één van de beste graanmaaisters van heel Amakna, haar legendarische heupzwaai stelde haar in staat de benen van meer dan één onvoorzichtig persoon af te hakken.",ep:0,g:1,l:36,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,35,45,false,false],c:"CS>10",p:3600};
I.u[671] = {n:"Fergussonne",t:22,d:"De Fergussonne is een legendarische zeis, gesmeed door Masse Fergussonne, de oudtante van Farle Ingalsse, die slechts zwoer bij zeisen met houten handvat, veel aangenamer in de hand.",ep:0,g:1,l:40,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,45,45,false,false],c:"CS>20&CV>20",p:4400};
I.u[672] = {n:"Gierst Maaier",t:22,d:"Deze zeis was oorspronkelijk bedoeld om Gierst te maaien, maar de boeren kwamen er al snel achter dat hij zo scherp was, dat hij voor het maaien van van alles en nog wat gebruikt kon worden.",ep:0,g:1,l:18,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,45,45,false,false],c:"CS>5",p:1100};
I.u[673] = {n:"Kastanje Vreetster",t:19,d:"Deze bijl heeft niet bijzonders, behalve z\'n natuurlijke lichte gewicht dankzij het Kastanje Hout. Daardoor is het heft zo licht als een veer van de jonge Boze Tofu.",ep:1,g:6,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>8&CA>3",p:400};
I.u[674] = {n:"Kersenhouten Kliever",t:19,d:"\"Deze bijl heeft alles om in de smaak te vallen\" luidde de slogan van Brouce Boulgoure, de beroemde houthakker. Inderdaad, zijn kersenhouten heft vangt de trillingen op tijdens het hakken van bomen of van bworks met een sterke schedel.",ep:1,g:7,l:32,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>40",p:2900};
I.u[675] = {n:"Notenhout Kliever",t:19,d:"Deze primitief uitziende bijl is toch heel erg doeltreffend. Met dit gereedschap heeft Brouce Boulgoure de Houthakker het \"dwerg Bworks snijconcours\" gewonnen. Dat zegt genoeg over de doeltreffendheid van deze bijl.",ep:1,g:8,l:21,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>30",p:1350};
I.u[676] = {n:"Stroop Vreetster",t:19,d:"Deze bijl heeft de bijzondere eigenschap nooit te roesten. Hierdoor kom je niet voor de onaangename verrassing te staan als de gulzige Houthakkers de stroop van het lemmet willen likken na een vermoeiende dag van het hakken van esdoorns.",ep:1,g:10,l:25,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CA>30",p:1850};
I.u[677] = {n:"Piraten Cape",t:17,d:"Deze cape is van een oude piraat geweest, Zokrim genaamd. Hij zou nogal een pechvogel geweest zijn...",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:1};
I.u[678] = {n:"Ivoren Schriftrol",t:13,d:"(Dubbelklik om ervaring te verkrijgen)\nMet deze schriftrol kan je zonder risico ervaring opdoen.",ep:1,g:3,l:25,wd:true,fm:true,w:1,u:true,p:1};
I.u[679] = {n:"Witte Schriftrol",t:13,d:"(Dubbelklik om ervaring te winnen)\nDeze schriftol stelt je in staat ervaring te winnen zonder enig risico te lopen.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[680] = {n:"Vergulde Schriftrol",t:13,d:"(Dubbelklik om experience te winnen)\nMet deze schriftrol kun je zonder enige risico experience winnen.",ep:1,g:3,l:50,wd:true,fm:true,w:1,u:true,p:1};
I.u[682] = {n:"Rogge Maaier",t:22,d:"Deze zeis was oorspronkelijk bedoeld om Rogge te maaien, maar de boeren kwamen er al snel achter dat hij zo scherp was, dat hij voor het maaien van van alles en nog wat gebruikt kon worden.",ep:0,g:1,l:1,wd:true,fm:true,w:1,an:17,e:[1,1,1,1,1,1,false,false],p:1};
I.u[683] = {n:"Kleine Kracht Schriftrol",t:76,d:"(Dubbelklik om kracht te winnen)\nMet deze schriftrol kun je zonder risico en definitief kracht winnen.\nLet echter op, je kunt hem alleen gebruiken als je kracht minder dan 25 is.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<25",u:true,p:1000};
I.u[684] = {n:"Toverschriftrol",t:76,d:"(Dubbelklik om Betoveringspunten te verkrijgen)\nMet deze schriftrol kan je op definitieve wijze Betoveringspunten winnen zonder risico te nemen.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:15000};
I.u[686] = {n:"Klein Intelligentie Schriftrol",t:76,d:"(Dubbelklik om Intelligentie Punten te verdienen)\nMet deze schriftrol kan je zonder risico te nemen definitieve Intelligentie Punten winnen.\nPas evenwel op, je kan het alleen gebruiken als je intelligentie minder dan 25 bedraagt.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<25",u:true,p:1000};
I.u[690] = {n:"Lijn Meel",t:52,d:"Dit is raar meel, want het is niet gemaakt van één graansoort. Daardoor lijkt het op geen enkel ander meel.",ep:1,g:254,l:1,wd:true,fm:true,w:2,p:0};
I.u[691] = {n:"Tover Gist",t:48,d:"Met dit gist kan zelfs dat wat niet kan rijzen in één keer rijzen, en vervolgens kunnen zelfs niet magische levensmiddelen magisch worden. Het spreekt voor zich dat dit niet zomaar in ieders handen moet komen.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:50};
I.u[692] = {n:"Stevig Brood",t:33,d:"Dit brood is gemaakt van lijnmeel, reden waarom het zo vet is en waarom het kruim zo bruin is. Erg rijk aan essentiële oliën. Helaas is de smaak niet zo lekker.",ep:1,g:12,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[694] = {n:"Crimson Dofus",t:23,d:"Ignemikhal, de Vuur Draak creëerde de Crimson Dofus. Ik zou zeggen dat hij naar zwavel stinkt... maar hij stinkt ook naar zoveel andere dingen.",ep:1,g:1,l:6,wd:true,fm:true,w:5,p:500000};
I.u[695] = {n:"Houthakker Schriftrol",t:13,d:"(Dubbelklik om Experience Points te winnen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[696] = {n:"Slons Hoed",t:16,d:"Behalve dat hij een \'has been\' look heeft, is de Slons Hoed zeer efficiënt tijdens gevechten, tenminste voor een simpele strohoed dan.",ep:1,g:2,l:20,wd:true,fm:true,w:4,p:1300};
I.u[697] = {n:"Mijkorst",t:16,d:"Mijkorst is een heel aanhankelijke hond... Het probleem is dat, als hij een nieuwe vriend vindt, hij die niet meer loslaat... Zo moet hij al 30 miljoen vrienden gemaakt hebben...",ep:2,g:3,l:6,wd:true,fm:true,w:6,p:30000};
I.u[698] = {n:"Pun Toet",t:16,d:"De Pun Toet komt van een hoge school voor tovenaars. Dit levende wezen heeft de grootste tovenaars van onze tijd ontmoet, zoals mevrouw Magoa AlaGale, de heer Doublegore en de beroemde Remy Krokeur.",ep:1,g:4,l:33,wd:true,fm:true,w:6,p:3000};
I.u[699] = {n:"De Troma",t:16,d:"De Troma is net zo vaag als een Gomkop gemaakt van Bituft haar.  (Als je niet weet hoe een Gomkop gemaakt van Bituft haar eruit ziet, kijk dan in het grote boek van Hen Pens).",ep:1,g:5,l:22,wd:true,fm:true,w:10,p:1525};
I.u[700] = {n:"Pandawa",t:16,d:"Ach, de Pandawa, wat heeft hij toch een praatjes. Net als zijn makker Mijkorst verdrijft hij de tijd op het hoofd van zijn meester. Hij heeft geen enkele reden zich te verplaatsen en  als hij gemotiveerd is, lukt het hem zelfs het voedsel van zijn drager te jatten.",ep:2,g:6,l:6,wd:true,fm:true,w:10,c:"PG!10",p:12000};
I.u[701] = {n:"De Oiram",t:16,d:"De Oiram heeft vele aanhangers over de hele wereld, vanwege zijn zeer chique kant... Deze hoed is lange tijd gedragen door een loodgieter die de hele tijd sprong en rende...",ep:1,g:7,l:22,wd:true,fm:true,w:12,c:"PG!10",p:1525};
I.u[702] = {n:"Kritter",t:16,d:"Deze uit verschillende en uiteenlopende stukken bot gereconstrueerde duivelsschedel maakt de drager ervan sierlijk en elegant... Je vrienden zullen jaloers op je zijn...",ep:1,g:8,l:30,wd:true,fm:true,w:9,c:"PG!10",p:2600};
I.u[703] = {n:"Dora",t:16,d:"Deze hoed, in de vorm van een omgekeerde rieten fruitmand is in realiteit een omgekeerde magische fruitmand. Daarmee kun je je omgeving versteld doen staan, vooral als die bestaat uit leerling Bwork Tovenaars.",ep:2,g:9,l:36,wd:true,fm:true,w:20,p:3550};
I.u[704] = {n:"Dantgoule",t:16,d:"Deze hoed, gemaakt van gevlochten leren onderbroeken van de Chafer Lansier, zal je zeker onweerstaanbaar maken bij de Bwork Magusvrouwtjes, vermaard om hun overstelpende vrouwelijkheid, wat benadrukt wordt door hun rode baard.",ep:2,g:10,l:36,wd:true,fm:true,w:10,p:3550};
I.u[705] = {n:"Tromatiserend Masker",t:16,d:"Als je getraumatiseerd wilt raken, dan moet je echt deze prachtige lekke kokosnoot hebben. Wij herinneren de gebruiker eraan dat deze uitgerust is met een rietje en frisdrankjes.",ep:12,g:11,l:47,wd:true,fm:true,w:10,p:6000};
I.u[706] = {n:"Kristal O\'Bol",t:16,d:"Hugne \"De Geheugenloze\" bezat een prachtige kristallen bol die hij had gekregen van zijn grootvader. Vastbesloten deze zijn hele leven te bewaren, zette hij hem op zijn hoed, die hij altijd op had... Hij is aan uitputting gestorven, omdat hij altijd ernaar op zoek was.",ep:4,g:12,l:24,wd:true,fm:true,w:12,s:38,p:1775};
I.u[707] = {n:"Minotohorno",t:16,d:"Deze hoed van Minotororhoorn is erg doeltreffend om indruk te maken op je tegenstanders. Deze list werkt alleen maar goed op wat simpele tegenstanders, zoals een Iop of een Tofu.",ep:2,g:13,l:33,wd:true,fm:true,w:10,s:54,p:3000};
I.u[708] = {n:"Houde",t:16,d:"Deze hoed van magisch groen larvenleer geeft zijn drager een vrolijk voorkomen, maar ook een beetje dom. Je kan niet alles hebben in het leven, zijn drager is daarvan een goed voorbeeld.",ep:1,g:14,l:30,wd:true,fm:true,w:8,p:2525};
I.u[709] = {n:"Lorko Kasko",t:16,d:"Deze hoed van betoverde schors was ooit van Lorko, een vermaard Houthakker. Hij daagde de beroemde Brouce Boulgour uit voor een duel om een Iepenboom met blote handen te ontwortelen op de open plek van Liroye Merline.",ep:9,g:15,l:37,wd:true,fm:true,w:9,c:"PG!10",p:3825};
I.u[710] = {n:"Korko Klako",t:16,d:"De Korko Klako is een helo mooio hoeto. Een mooio esthetiko, en wordo alleeno gedrago door de meesto knappo Sadidas.",ep:1,g:16,l:17,wd:true,fm:true,w:9,c:"PG=10",p:1000};
I.u[711] = {n:"Jouik Krampe",t:16,d:"Dit prachtige leren masker behoorde toe aan Jouik Krampe, neef van Zeurg. Beiden waren gek op strakke leren kleding. Een beetje zoals Kapitein Chafer, maar dan minder pervers.",ep:8,g:17,l:26,wd:true,fm:true,w:15,c:"PG=10",p:2025};
I.u[712] = {n:"Gulliver",t:16,d:"Deze originele hoed, gemaakt van aan elkaar genaaide oren, geven je een unieke uitstraling. Men zegt dat hij ooit Rakmar Bilgout in staat stelde de Veelvraat Koningin te verleiden om haar daarna makkelijker de keel te kunnen doorsnijden.",ep:13,g:18,l:33,wd:true,fm:true,w:10,p:3075};
I.u[713] = {n:"Zwaardsmid Schriftrol",t:13,d:"(Dubbelklik om XP te winnen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[714] = {n:"Dolksmid Schriftrol",t:13,d:"(Dubbelklik om XP te winnen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[715] = {n:"Boog Snijder Schriftrol",t:13,d:"(Dubbelklik om XP te winnen)",ep:4,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[716] = {n:"Staf Snijder Schriftrol",t:13,d:"(Dubbelklik om XP te winnen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[717] = {n:"Stok Snijder Schriftrol",t:13,d:"(Dubbelklik om Experience Points te verdienen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[718] = {n:"Flamiche Toverschriftrol",t:75,d:"(Dubbelklik om de betovering te leren)\nMet deze schriftrol kan je de elementaire betovering Flamiche leren.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[719] = {n:"Bevrijdings Toverschriftrol",t:75,d:"(Dubbelklik om de betovering te leren)\nMet deze schriftrol kan je de betovering Bevrijding leren.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[720] = {n:"Bliksem Toverschriftrol",t:75,d:"(Dubbel klik om deze betovering te leren)\nDeze schriftrol stelt je in staat de eenvoudige betovering Bliksem te leren.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[721] = {n:"Rol voor Spreuk \'Bezwering van Arachnee\'",t:75,d:"(Dubbelklikken om deze spreuk te leren)                            Deze rol leert je de spreuk \'Bezwering van Arachnee\'.",ep:16,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[724] = {n:"Toverspreuk Beheersing Staf",t:73,d:"(Dubbelklik om de betovering te leren)\nMet deze schriftrol kan je meer schade toebrengen bij het gebruik van een staf.",ep:1,g:2,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[725] = {n:"Betovering Beheersing Zwaard",t:73,d:"(Dubbelklik om deze betovering te leren)\nMet deze schriftrol kun je meer schade aanrichten bij gebruik van een zwaard.",ep:3,g:1,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[726] = {n:"Betovering Beheersing Boog",t:73,d:"(Dubbelklik om de betovering te leren)\nMet deze schriftrol kan je meer schade toebrengen bij het gebruik van een boog.",ep:4,g:3,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[727] = {n:"Toverspreuk Beheersing Hamer",t:73,d:"(Dubbelklik om de betovering te leren)\nMet deze schriftrol kan je meer schade aanrichten als je een hamer gebruikt",ep:1,g:4,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[728] = {n:"Spreuk \'Wand Vaardigheid\'",t:73,d:"(Dubbelklikken om deze spreuk te leren)                            Deze rol leert je hoe je meer schade kan toebrengen als je deze wand gebruikt.\'.",ep:1,g:5,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[729] = {n:"Betovering Beheersing Dolk",t:73,d:"(Dubbelklik om de betovering te leren)\nDeze schriftrol stelt je in staat meer schade aan te richten als je een dolk gebruikt.",ep:2,g:6,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[730] = {n:"Betovering Beheersing van de Schep",t:73,d:"(Dubbelklik om de spreuk te leren)\nMet deze schriftrol kun je meer schade toebrengen door een schep te gebruiken.",ep:7,g:7,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[731] = {n:"Speciale Brokle Toverschriftrol",t:75,d:"(Dubbelklik om de betovering te leren).\nMet deze schriftrol kun je de Brokkel betovering leren... alleen voorbehouden aan de Iop.",ep:2,g:4,l:1,wd:true,fm:true,w:1,c:"PG=8",u:true,p:10000};
I.u[732] = {n:"Silimelles Trouwring",t:9,d:"Deze schitterende trouwring is gestolen van Silimelle de Bierbrouwster, tijdens een met drank overladen avond in de herberg. Dat heb je er nou van als je rondjes uitdeelt aan onbekenden...",ep:1,g:30,l:26,wd:true,fm:true,w:1,p:2000};
I.u[733] = {n:"Ragalde Laarzen",t:11,d:"Ragalde was stellig een van de meest roekeloze Iop Strijders. Met deze magische laarzen heeft hij een groot aantal ongewensten een kopje kleiner weten te maken.",ep:1,g:7,l:49,wd:true,fm:true,w:1,p:5000};
I.u[734] = {n:"Veiligheids Riem",t:10,d:"Met deze riem konden de bewakers van het Amakna Kasteel opstandjes in bedwang houden of andere uitbarstingen tijdens volksfeesten.",ep:1,g:7,l:17,wd:true,fm:true,w:10,p:1000};
I.u[737] = {n:"Smaragd Dofus",t:23,d:"De Smaragd Dofus, groener dan een zieke Tofu, is gelegd door Aerafal, de Draak van de Lucht. Om zoiets groens te leggen, moet je wel de luchtziekte hebben. Te maf, hè?",ep:1,g:2,l:6,wd:true,fm:true,w:5,p:500000};
I.u[739] = {n:"Turquoise Dofus",t:23,d:"De Turquoise Dofus was gemaakt door Aguabrial, de Draak van het Water. Als je erover nadenkt, is het raar, dat een Draak dat met water heeft kunnen maken...",ep:1,g:3,l:6,wd:true,fm:true,w:5,p:500000};
I.u[742] = {n:"Gehoornde Staf",t:4,d:"\"Wat zou deze staf moeten doen, om alle oorlogen te doorstaan?\" Dat waren de laatste woorden gezongen door Moco Prostato, de bekende Bijlsmid Minstreel, voordat hij zijn ogen sloot toen hij door een Ei van een Reuzen Tofu geplet werd.",ep:1,g:1,l:29,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,200,false,false],c:"CC>20&CI>30",p:2350};
I.u[743] = {n:"Gouden Broodje",t:33,d:"Het recept van dit Broodje is uitgewerkt door Xavier de Bakker persoonlijk die er een tegelijkertijd heerlijk en licht Broodje van wilde maken. Met stelligheid kun je zeggen dat hij daarin geslaagd is.",ep:1,g:8,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[744] = {n:"Bowisse Cape",t:17,d:"Deze cape is net als zijn drager, uniek in zijn soort en te vaak ondergewaardeerd. Hij is gemaakt van het samengestelde groene larvenleer, waardoor hij er lekker stoer uitziet.",ep:1,g:1,l:20,wd:true,fm:true,w:10,p:1275};
I.u[745] = {n:"Baar Goud",t:40,d:"Deze baar is gemaakt door Goud in ruwe staat te smelten.",ep:1,g:241,l:10,wd:true,fm:true,w:1,p:0};
I.u[746] = {n:"Eboniet",t:40,d:"Deze zeer zeldzame legering stelt je in staat zeer zeldzame  en vaak dodelijke voorwerpen te maken. Inderdaad, Eboniet is een metaal dat, als het eenmaal verroest is, verandert in een echt gif.",ep:1,g:658,l:20,wd:true,fm:true,w:20,p:0};
I.u[747] = {n:"Aluminite",t:40,d:"Deze legering is van een indrukwekkende luchtigheid wardoor het uitstekend geschikt is om kleine dolken en korte zwaarden van te maken.",ep:1,g:660,l:10,wd:true,fm:true,w:10,p:0};
I.u[748] = {n:"Magnesiet",t:40,d:"Dit eigenaardige metaalmengsel is bijna magisch, het glanst en trilt \'s nachts, genoeg om een goedgelovige Bwork bang te maken.",ep:1,g:659,l:30,wd:true,fm:true,w:30,p:0};
I.u[749] = {n:"Bakeleliet",t:40,d:"Dit mengsel is niet erg sterk, maar indien goed geslepen, wordt het net zo scherp als het Lemmet van een Chafer.",ep:1,g:487,l:40,wd:true,fm:true,w:40,p:0};
I.u[750] = {n:"Kouartz",t:40,d:"Dit zeer vreemde metaalmengsel is in staat een indrukwekkende energie in zich op te slaan, die het erg instabiel maakt onder bepaalde omstandigheden. De beste Smeden zijn dol op dit metaalmengsel, dat hun in staat stelt wapens met bijna legendarische krachten te smeden.",ep:1,g:664,l:60,wd:true,fm:true,w:60,p:0};
I.u[752] = {n:"Vampierbloed",t:15,d:"Dit bloed is magisch, wat het een onmisbaar ingrediënt maakt voor de magische Zwarte Bloedworst. De neveneffecten zijn echter nog onbekend.",ep:2,g:89,l:15,wd:true,fm:true,w:1,p:100};
I.u[754] = {n:"Vampier Cape",t:17,d:"Deze bloedrode cape heeft jaren in bloed gelegen. Dit soort capes is erg gewild voor een Halowien Feest.",ep:7,g:17,l:29,wd:true,fm:true,w:13,p:2500};
I.u[756] = {n:"Nauwomsluitende Leren Onderbroek van de Vampier",t:56,d:"Om zich te beschermen tegen kritieke treffers op kritieke plaatsen, gebruikt de Vampier soms zijn Leren Onderbroek als hij op jacht gaat. Met deze Onderbroek kan hij eveneens de kritieke plekken beschermen tegen zonnebrand.",ep:3,g:622,l:15,wd:true,fm:true,w:1,p:100};
I.u[757] = {n:"Blauwige Gelei",t:110,d:"Deze gelei is heel erg plakkerig, zoiets als een razend Blokpopje. Vreemd genoeg kun je er bijzonder goed Tofus veren mee plakken. Men vraagt zich af waarvoor dat nou zou dienen...",ep:5,g:42,l:3,wd:true,fm:true,w:1,p:1};
I.u[758] = {n:"Rechtvoltrekkers Cape",t:17,d:"Deze cape kan alleen gedragen worden door de grote rechtsvoltrekkers van Amakna, dat wil dus zeggen door bijna niemand.",ep:1,g:2,l:30,wd:true,fm:true,w:10,c:"Ps=1&Pa>20",p:2550};
I.u[759] = {n:"Cape van het Laatste Kuken",t:17,d:"Deze prachtige cape is gemaakt met de veren van het laatste Kuken van Amakna. Absoluut zeldzaam, verzamelaars zouden hem graag in hun collectie hebben.",ep:8,g:3,l:33,wd:true,fm:true,w:4,p:5000};
I.u[760] = {n:"Kerriebrood zonder kerrie",t:33,d:"Een prototype van Kwaker Vans. De smaak en doeltreffendheid van dit brood blijft altijd een verrassing. Helaas blijft de geur altijd hetzelfde.",ep:2,g:12,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[761] = {n:"Muizenhaar",t:54,d:"Deze muizenharen zijn heel fijn en zacht, en zijn in feite zeer gewild voor het maken van mantels. De mantel van muizenhuid en -haar maakt furore in de upper class van Amakna, het schijnt dat het zeer chic is er één te dragen.",ep:1,g:549,l:1,wd:true,fm:true,w:1,p:1};
I.u[764] = {n:"Kleine Uilen Amulet",t:1,d:"Dit amuletje zal beginnende helden heel blij maken.",ep:1,g:1,l:1,wd:true,fm:true,w:2,p:50};
I.u[765] = {n:"Farle Ingalsse Zeis",t:22,d:"Deze zeis was van Farle Ingalsse zelf en is voldoende geslepen om elk type graan te maaien en elk soort monster te doden dat zich schuilhoudt in de graanakkers.",ep:3,g:1,l:13,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,50,false,false],c:"CC>10",p:650};
I.u[766] = {n:"Speikr Koliet",t:1,d:"Met deze amulet kunnen beginnende avonturiers meer schade aanrichten.",ep:1,g:34,l:1,wd:true,fm:true,w:1,p:20};
I.u[767] = {n:"Royal Gantie",t:9,d:"Ondanks zijn pompeuze naam word je met deze ring een beetje sterker en een beetje stommer.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[768] = {n:"Camahand",t:9,d:"Deze ring beïnvloedt je lot, hij geeft je meer weerstand, maar minder geluk. Je vergroot je kans om lang te leven in ruil voor geluk.",ep:1,g:33,l:1,wd:true,fm:true,w:1,p:100};
I.u[769] = {n:"Einekeineux",t:11,d:"Laarzen die geluk brengen. Het probleem is dat je minder weerstand hebt tijdens een gevecht.",ep:1,g:5,l:2,wd:true,fm:true,w:1,p:200};
I.u[770] = {n:"Fecaflip",t:11,d:"Dit prachtige paar laarzen zet een beetje van je kracht om in intelligentie.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[771] = {n:"Essenhout Vreetster",t:19,d:"Deze hamer heeft niets bijzonders, maar toch is hij zeer gewild bij beginnende Houthakkers, omdat hij zo makkelijk hanteerbaar is.",ep:1,g:9,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>10&CC>10",p:400};
I.u[772] = {n:"Bezwaarde Cape",t:17,d:"Men beweert dat deze legendarische cape je in staat stelt bijna onoverwinnelijk te worden als je hem combineert met het legendarische schermersdegen, de Dard Tagnan en de legendarische hoed van Six Rameaux de Bergers Rahks.",ep:7,g:4,l:22,wd:true,fm:true,w:10,p:1500};
I.u[773] = {n:"Ellinie Cape",t:17,d:"Deze cape komt uit het Patitaliaanse land, een plek waar men met de handen spreekt. Dat verklaart de grote bewegingsvrijheid van de cape. Bovendien is hij ook verbazingwekkend licht.",ep:1,g:5,l:14,wd:true,fm:true,w:1,p:775};
I.u[774] = {n:"Ulais Cape",t:17,d:"Deze cape, komend uit Bergendal of uit Berg-en-Dal, al naar gelang je het uitspreekt, heeft geleid tot de vergiftiging van zijn vroegere eigenaar, maar bizar genoeg verhoogt hij de weerstand van zijn drager.",ep:1,g:7,l:14,wd:true,fm:true,w:3,p:775};
I.u[775] = {n:"Abiliteit Cape",t:17,d:"Magisch en met zorg geweven.De drager van de Abiliteit Cape kan de zwakke plekken van zijn tegenstanders onderscheiden en hen zo verwoestende slagen toebrengen.",ep:5,g:9,l:17,wd:true,fm:true,w:10,p:1000};
I.u[776] = {n:"Sulcorpe Cape",t:17,d:"Deze cape was ooit van een zekere Mulba, die hem gebruikte om grote voorwerpen te dragen tijdens zijn missie van de Zeven Kristalkippen die van de sterren kwamen. Deze cape vergroot je kracht aanzienlijk.",ep:5,g:8,l:14,wd:true,fm:true,w:3,p:775};
I.u[777] = {n:"Goudhaantjes Cape",t:17,d:"De haan die zijn veren heeft gegeven voor de fabricage van deze cape heeft gedurende meerdere dagen en nachten tegengestribbeld, voordat ie uitgeput neerviel. Toen heeft de eigenaar, buiten adem maar tevreden, de waardevolle veren geplukt.",ep:5,g:10,l:44,wd:true,fm:true,w:10,p:5275};
I.u[778] = {n:"Mori Arty Cape",t:17,d:"Deze oorspronkelijk boosaardige cape is het bewijs dat je bij de duivelse bende van Mori Arty hoort. Er wordt gezegd dat zijn pech net zo groot was als zijn verbazingwekkende intelligentie. Alleen slechteriken kunnen het dragen.",ep:2,g:11,l:6,wd:true,fm:true,w:1,c:"Ps=2&Pa>30",p:20000};
I.u[779] = {n:"Maj\'Hic Cape",t:17,d:"Deze ogenschijnlijk gewone cape is helemaal niet zo gewoon. Hij maakt je onzichtbaar voor degene die er niet naar kijken. Indrukwekkend !",ep:8,g:12,l:34,wd:true,fm:true,w:15,p:3300};
I.u[781] = {n:"Itou Lasione Cape",t:17,d:"Deze prachtige cape was ooit van de Grote Oorlogsstrateeg. Deze beroemde oorlogsheer en bijzonder strateeg, belust op het veroveren van het universum, liet al zijn plannen varen toen hij eenmaal deze cape aantrok. Vreemd!",ep:8,g:7,l:21,wd:true,fm:true,w:10,p:1400};
I.u[782] = {n:"Agride",t:19,d:"Deze bijl is eigenlijk heel bijzonder en is in principe bestemd voor de beroepsopleiding tot Houthakker. Indien juist gebruikt, kun je er een enigzins zorgeloos jonge Abraknyde mee kappen, wat niet vaak zal voorkomen, moet ik toegeven.",ep:1,g:11,l:27,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CW>15",p:2200};
I.u[783] = {n:"Lumberjack Amulet",t:1,d:"Dit amulet, gemaakt van kostbaar hout, is erg hoog geprijsd en geliefd bij lumberjacks die normaliter hun talenten overdrijven om de kosten van de materialen te compenseren.",ep:1,g:9,l:22,wd:true,fm:true,w:2,p:1500};
I.u[784] = {n:"Laarzen van de Koppige Kat",t:11,d:"De Koppige Kat is de bijnaam die aan een beroemde Ecaflip werd gegeven. Er was geen enkele Ecaflip zo koppig als hij en tijdens een gevecht redde alleen zijn mazzel hem, bij gebrek aan welke vorm van intelligentie dan ook. \"Wie is er zo koppig als een steen?\", riep hij vaak.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[785] = {n:"Versterkende ring",t:9,d:"Deze ring werd van grootvader Enutrof op vader Enutrof overgedragen en geeft de drager ervan een geweldige kracht. Dit is slechts een middelmatige kopie, maar verzamelaars zijn er ook tevreden mee, of ze nu Enutrof zijn of niet.",ep:1,g:29,l:11,wd:true,fm:true,w:1,p:525};
I.u[786] = {n:"Miezerige Uilen Hanger",t:1,d:"Voortgekomen uit een verkeerde handeling van een juwelier, vergroot deze amulette de intelligentie van zijn drager. Daarentegen geeft hij een verschrikkelijke hoofdpijjn waardoor de fysieke conditie van zijn eigenaar verslechtert.",ep:1,g:1,l:2,wd:true,fm:true,w:1,p:200};
I.u[787] = {n:"Ano Rexik Ring",t:9,d:"Deze vreemde kleine ring vergroot de behendigheid van zijn drager in ruil voor gelukspunten.",ep:1,g:31,l:1,wd:true,fm:true,w:1,p:100};
I.u[789] = {n:"Koobers Riem",t:10,d:"Deze riem maakt furore bij de jonge bevolking van Amakna. Een Sadida couturier heeft hem bedacht. Bij de eerste verkoop riep hij uit: \"Het leven is kort, speel \'t hard!",ep:2,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[790] = {n:"Cape de Goede Hoop",t:17,d:"De magische effecten van deze cape worden vaak overschat, wat het verlies heeft veroorzaakt van vele avonturiers, en met name de zeer beroemde Minstreel Moco Prostato.",ep:8,g:5,l:30,wd:true,fm:true,w:8,p:2525};
I.u[791] = {n:"Boomchnidis Vivitus",t:4,d:"Dit is een staf van de wortel van nog levende Boomchnid. Let op, hij heeft de nare neiging om zich tegen zijn meester te richten. Hij kan zeer doeltreffend zijn als hij besluit hetzelfde doel als zijn meester aan te vallen.",ep:2,g:1,l:34,wd:true,fm:true,w:10,an:12,e:[5,2,1,1,50,30,false,false],c:"CC>30&CI>34&CW>15",p:3400};
I.u[792] = {n:"Boomchnidsap",t:15,d:"Dit stroperige sap dient nergens voor behalve als je bereid bent te wachten tot het tot Barnsteen versteent. Men zegt evenwel, dat een slimme en bijzonder verleidelijke Enutrofette een manier heeft gevonden om het proces te versnellen.",ep:1,g:162,l:45,wd:true,fm:true,w:2,p:50};
I.u[793] = {n:"Ouderdoms Drankje",t:12,d:"Met dit drankje kunnen bepaalde chemische processen versneld worden, zoals de vorming van bezinksel. Het lijkt een beetje op superkrachtige gist, maar het smaakt beter.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[795] = {n:"Rol van Sterkte",t:76,d:"(Dubbelklikken om sterkte te verschaffen)                           Met deze rol kun je veilig en permanent je sterkte verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je sterkte lager is dan 50.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<50",u:true,p:2500};
I.u[796] = {n:"Grote Rol van Sterkte",t:76,d:"(Dubbelklikken om sterkte te verschaffen)                           Met deze rol kun je veilig en permanent je sterkte verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je sterkte lager is dan 50.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<80",u:true,p:5000};
I.u[797] = {n:"Krachtige Krachtschriftrol",t:76,d:"(Dubbelklik om kracht te winnen)\nMet deze schriftrol kan je zonder risico te nemen definitieve kracht winnen.\nPas evenwel op, je kan het alleen gebruiken als je kracht minder dan 100 bedraagt.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<100",u:true,p:8000};
I.u[798] = {n:"Kleine Rol van Soepelheid",t:76,d:"(Dubbelklikken om soepelheid te verschaffen)                       Met deze rol kun je veilig en permanent je kans verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je kans lager is dan 25.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<25",u:true,p:1000};
I.u[799] = {n:"Rol van Soepelheid",t:76,d:"(Dubbelklikken om soepelheid te verschaffen)                       Met deze rol kun je veilig en permanent je kans verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je kans lager is dan 50.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<50",u:true,p:2500};
I.u[800] = {n:"Grote Behendigheid Schriftrol",t:76,d:"(Dubbelklik om behendigheid te verdienen)\nMet deze schriftrol kun op zonder enig risico en definitief behendigheid verdienen.\nLet wel op, je kunt het alleen gebruiken als je behendigheid minder dan 80 is.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<80",u:true,p:5000};
I.u[801] = {n:"Krachtige Behendigheids Schriftrol",t:76,d:"(Dubbelklik om behendigheid te winnen)\nMet deze schriftrol kun je zonder risico en definitief behendigheid winnen. \nLet echter op, je kunt ze slechts gebruiken als je minder dan 100 behendigheidspunten bezit.\n",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<100",u:true,p:8000};
I.u[802] = {n:"Kleine Wijsheid Schriftrol",t:76,d:"(Dubbelklik om wijsheid te winnen)\nMet deze schriftrol kun je zonder risico definitief wijsheid winnen. Pas echter op, je kunt het niet gebruiken als je minder dan 25 wijsheidspunten hebt.",ep:1,g:24,l:1,wd:true,fm:true,w:1,c:"Cw<25",u:true,p:1000};
I.u[803] = {n:"Rol van Wijsheid",t:76,d:"(Dubbelklikken om wijsheid te verschaffen)                           Met deze rol kun je veilig en permanent je wijsheid verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je wijsheid lager is dan 50.",ep:1,g:24,l:1,wd:true,fm:true,w:1,c:"Cw<50",u:true,p:2500};
I.u[804] = {n:"Grote Rol van Wijsheid",t:76,d:"(Dubbelklikken om wijsheid te verschaffen)                          Met deze rol kun je veilig en permanent je wijsheid verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je wijsheid lager is dan 80.",ep:2,g:24,l:1,wd:true,fm:true,w:1,c:"Cw<80",u:true,p:5000};
I.u[805] = {n:"Krachtige Wijsheids Schriftrol",t:76,d:"(Dubbelklik om wijsheid te winnen)\nMet deze schriftrol kun je zonder enige risico definitief wijsheid winnen.\nLet echter op, je kunt het alleen gebruiken als je wijsheid minder is dan 100.",ep:1,g:24,l:1,wd:true,fm:true,w:1,c:"Cw<100",u:true,p:8000};
I.u[806] = {n:"Klein Vitaliteits Schriftrol",t:76,d:"(Dubbelklik om vitaliteit te winnen)\nMet deze schriftrol kan je zonder risico te nemen definitieve vitaliteit winnen.\nPas evenwel op, je kan het alleen gebruiken als je vitaliteit minder dan 25 bedraagt.",ep:1,g:3,l:1,wd:true,fm:true,w:1,c:"Cv<25",u:true,p:1000};
I.u[807] = {n:"Vitaliteits Schriftrol",t:76,d:"(Dubbelklik om vitaliteit te winnen)\nMet deze schriftrol kun je zonder risico definitief vitaliteit winnen.\nLet echter op, je kunt het alleen maar gebruiken als je vitaliteit onder de 50 is.",ep:1,g:3,l:1,wd:true,fm:true,w:1,c:"Cv<50",u:true,p:2500};
I.u[808] = {n:"Grote Rol van Levenskracht",t:76,d:"(Dubbelklikken om levenskracht te verschaffen)                    Met deze rol kun je veilig en permanent je kans verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je levenskracht lager is dan 80.",ep:2,g:3,l:1,wd:true,fm:true,w:1,c:"Cv<80",u:true,p:5000};
I.u[809] = {n:"Kleine Geluks Schriftrol",t:76,d:"(Dubbelklik om Geluk te winnen)\nMet deze schriftrol kun je definitief en zonder enige risico Geluk winnen.\nLet echter op, je kunt hem alleen gebruiken als je geluk minder dan 25 is.",ep:1,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<25",u:true,p:1000};
I.u[810] = {n:"Krachtige Rol van Levenskracht",t:76,d:"(Dubbelklikken om levenskracht te verhogen)                       Met deze rol kun je veilig en permanent je levenskracht verhogen maar wees voorzichtig, je kunt het enkel gebruiken als je levenskracht lager is dan 100.",ep:1,g:3,l:1,wd:true,fm:true,w:1,c:"Cv<100",u:true,p:8000};
I.u[811] = {n:"Rol van Geluk",t:76,d:"(Dubbelklikken om kans te verschaffen)                           Met deze rol kun je veilig en permanent je kans verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je kans lager is dan 50.",ep:1,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<50",u:true,p:2500};
I.u[812] = {n:"Grote Rol van Kans",t:76,d:"(Dubbelklikken om kans te verschaffen)                          Met deze rol kun je veilig en permanent je kans verhogen maar wees voorzichtig, je kunt dit enkel gebruiken als je kans lager is dan 80.",ep:2,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<80",u:true,p:5000};
I.u[814] = {n:"Krachtige Geluks Schriftrol",t:76,d:"(Dubbelklik om geluk te winnen)\nMet deze schriftrol kun je zonder enig risico definitief geluk winnen.\nLet echter op, je kan het alleen gebruiken als je geluk minder dan 100 is.",ep:1,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<100",u:true,p:8000};
I.u[815] = {n:"Intelligentie Schriftrol",t:76,d:"(Dubbelklik om intelligentie te winnen)\nMet deze schriftrol kun je zonder risico te lopen definitief  intelligentie winnen.\nLet echter op, je kunt het slechts gerbuiken als je intelligentie minder dan 50 is.",ep:1,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<50",u:true,p:2500};
I.u[816] = {n:"Grote Intelligentie Schriftrol",t:76,d:"(Dubbelklik om intelligentie te verdienen)\nMet deze schriftrol kan je definitief intelligentie winnen zonder risico te nemen.\nMaar let op, je kan het alleen gebruiken als je intelligentie minder dan 80 is.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<80",u:true,p:5000};
I.u[817] = {n:"Krachtige Intelligentie Schriftrol",t:76,d:"(Dubbelklik om intelligentie te winnen)\nMet deze schriftrol kun je definitief en zonder risico Intelligentie winnen.\nMaar let op, je kunt hem alleen gebruiken als je Intelligentie minder dan 100 is.",ep:1,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<100",u:true,p:8000};
I.u[818] = {n:"Rots Sleutel van Ded Aléïcar",t:12,d:"Dit stenen sleuteltje opent de deur van de grot van Ded Aléïcar. Nu moet je hem alleen nog wel even vinden...",ep:4,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[819] = {n:"Heilig Zwaard",t:6,d:"Een heilig zwaard dat wordt uitgedeeld aan jonge strijders tijdens hun opleiding.",ep:1,g:1,l:15,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>30&CV>3",p:800};
I.u[820] = {n:"Groot Heilig Zwaard",t:6,d:"Een heilig zwaard dat wordt uitgedeeld aan jonge krijgers tijdens hun opleiding.",ep:1,g:1,l:16,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>32&CV>4",p:900};
I.u[821] = {n:"Krachtig Gewijd Zwaard",t:6,d:"Een heilig zwaard dat wordt uitgedeeld aan jonge krijgers tijdens hun opleiding.",ep:1,g:1,l:17,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>34&CV>5",p:1000};
I.u[822] = {n:"Ridder Zwaard",t:6,d:"Het Ridder Zwaard is een solide en doelmatig zwaard, goed gebruikt kan het aanzienlijke schade toebrengen aan je vijanden.",ep:7,g:9,l:23,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>46",p:1600};
I.u[823] = {n:"Grote Ridder Zwaard",t:6,d:"Het zwaard van de Grote Ridder is een sterk en doeltreffend wapen, als hij goed gebruikt wordt kan hij veel schade aan je vijanden toebrengen.",ep:7,g:9,l:24,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>48",p:1800};
I.u[824] = {n:"Machtige Ridder Zwaard",t:6,d:"Het zwaard van de Machtige Ridder is een stevig en doelmatig zwaard, goed gebruikt kan het grote schade aan je vijanden toebrengen.",ep:7,g:9,l:26,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>52",p:2000};
I.u[825] = {n:"Bwork Lemmet",t:6,d:"Dit ogenschijnlijk primitieve zwaard wordt zeer gewaardeerd door de meest debiele Bworks, die niet weten hoe ze een boog of een staf moeten hanteren. Sommige halen zelfs het heft en het lemmet door elkaar, waar hun tegenstanders onbedaarlijk om moeten lachen.",ep:1,g:13,l:23,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>46&CA>8",p:1600};
I.u[826] = {n:"Zwaard Grote Bwork",t:6,d:"Dit ogenschijnlijk primitieve zwaard wordt zeer gewaardeerd door de meest debiele Bworks, die niet weten hoe ze een boog of een staf moeten hanteren. Sommige halen zelfs het heft en het lemmet door elkaar, waar hun tegenstanders onbedaarlijk om moeten lachen.",ep:1,g:13,l:24,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>48&CA>14",p:1800};
I.u[827] = {n:"Krachtig Bwork Lemmet",t:6,d:"Dit ogenschijnlijk primitieve zwaard wordt zeer gewaardeerd door de meest debiele Bworks, die niet weten hoe ze een boog of een staf moeten hanteren. Sommige halen zelfs het heft en het lemmet door elkaar, waar hun tegenstanders onbedaarlijk om moeten lachen.",ep:1,g:13,l:26,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>52&CA>16",p:2000};
I.u[828] = {n:"Pijlsnelle Boog",t:2,d:"Deze boog schiet zijn pijlen zo snel dat je ze al van verre hoort aankomen. Als je discretie zoekt, zorg dan voor een geluidsdemper.",ep:1,g:15,l:11,wd:true,fm:true,w:10,an:10,tw:true,e:[5,3,2,6,30,40,false,true],c:"CA>11&CS>5",p:550};
I.u[829] = {n:"Boog Boog",t:2,d:"Deze boog is niet erg doeltreffend gezien zijn geringe reikwijdte, maar je kan er wel een vijand genoeg mee verzwakken alvorens hem met een ander wapen of toverkunstje af te maken.",ep:1,g:1,l:8,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,30,50,false,true],c:"CA>8",p:400};
I.u[830] = {n:"IntelligentieStok",t:3,d:"De drager van dit stokje kan hiermee zijn intelligentie verhogen.",ep:7,g:1,l:24,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>24",p:1700};
I.u[831] = {n:"Groot IntelligentieStok",t:3,d:"De drager van dit stokje kan hiermee zijn intelligentie verhogen.",ep:7,g:1,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>27",p:2100};
I.u[832] = {n:"Krachtige Intelligentie Stok",t:3,d:"Deze toverstok vergroot de intelligentie van de drager.",ep:7,g:1,l:29,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>29",p:2500};
I.u[833] = {n:"WijsheidStok",t:3,d:"Met dit stokje kan de drager ervan zijn wijsheid verhogen.",ep:1,g:4,l:23,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>23&CW>7",p:1600};
I.u[834] = {n:"Grote Wijsheid Stok",t:3,d:"Deze stok vergroot de wijsheid van zijn drager.",ep:1,g:4,l:25,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>25&CW>9",p:1900};
I.u[835] = {n:"Krachtige Wijsheids Stok",t:3,d:"Met deze toverstok kan zijn drager zijn wijsheid vergroten.",ep:1,g:4,l:27,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>27&CW>11",p:2200};
I.u[836] = {n:"Boomring",t:9,d:"Deze ring gemaakt van de schors van de Boomchnid bezit grote krachten en dit betekent dus ook grote verantwoordelijkheid. Maar, ondanks zijn waarde, gaat het gerucht dat er een vloek op rust.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:100};
I.u[837] = {n:"Kluh Laarzen",t:11,d:"Deze laarzen vergroten de kracht van degene die ze draagt, maar deze loopt de kans na verloop van tijd een beetje idoot te worden, of om zich te veranderen in een Iop bij regelmatig en langdurige gebruik.",ep:1,g:3,l:8,wd:true,fm:true,w:1,p:400};
I.u[838] = {n:"Oni Bloed",t:15,d:"Dit flesje Oni-bloed is zeer gewild bij ervaren alchemisten die bepaalde wapens van bijzonder afschrikwekkende eigenschappen willen voorzien.",ep:4,g:662,l:75,wd:true,fm:true,w:1,p:100};
I.u[840] = {n:"Minotoror Haren",t:54,d:"Deze haren ruiken verschrikkelijk maar zijn erg stevig. Iets dragen dat gemaakt is van Minotoror haar maakt een angstaanjagende strijder van je... veel op prijs gesteld door vliegen, daarbij.",ep:2,g:201,l:125,wd:true,fm:true,w:1,p:100};
I.u[841] = {n:"Tevreden Ring",t:9,d:"Met deze ring kan je held zijn AP verhogen, in ruil voor zijn kracht en intelligentie.",ep:1,g:12,l:8,wd:true,fm:true,w:1,p:10};
I.u[842] = {n:"Gouden Dreggon Schelp",t:111,d:"Deze schelp is bijna onbreekbaar maar als ze het generaties lang polijsten, kunnen de beste juweliers zijn magische krachten gebruiken om amuletten te maken met uitzonderlijke krachten,",ep:11,g:202,l:64,wd:true,fm:true,w:5,p:1};
I.u[843] = {n:"Zwarte Dreggon schelp",t:111,d:"Deze schelp is haast onbreek maar maar als ze hem generaties lang polijsten, kunnen goeie juweliers de magische eigenschappen ervan gebruiken om een amulet te maken met uitzonderlijke krachten.",ep:11,g:203,l:64,wd:true,fm:true,w:5,p:150};
I.u[844] = {n:"Saffieren Dreggon Ei",t:105,d:"Een schattige kleine Dreggon zal uit dit vreemde ei komen als een vrouwelijke Saffieren Dreggon erop zit. Probeer het zelf maar niet, want je weet maar nooit...",ep:11,g:204,l:74,wd:true,fm:true,w:20,p:100};
I.u[845] = {n:"Gouden Dreggon Ei",t:105,d:"Een schattige kleine Dreggon zal uit dit vreemde ei komen als een vrouwelijke Gouden Dreggon erop zit. Probeer het zelf maar niet, want je weet maar nooit...",ep:11,g:205,l:74,wd:true,fm:true,w:20,p:100};
I.u[846] = {n:"Zwarte Dreggon Ei",t:105,d:"Een schattige kleine Dreggon zal uit dit vreemde ei komen als een vrouwelijke Zwarte Dreggon erop zit. Probeer het zelf maar niet, want je weet maar nooit...",ep:11,g:206,l:74,wd:true,fm:true,w:20,p:100};
I.u[847] = {n:"Witte Dreggon Ei",t:105,d:"Een schattige kleine Dreggon zal uit dit vreemde ei komen als een Witte vrouwelijke Dreggon er op zit. Probeer het niet zelf warm te houden, je weet maar nooit...",ep:10,g:38,l:74,wd:true,fm:true,w:1,p:100};
I.u[848] = {n:"Oude Dreggon Bot",t:47,d:"Dit oude bot is magisch. Als je het correct gebruikt kun je krachtige items maken.",ep:11,g:15,l:70,wd:true,fm:true,w:20,p:100};
I.u[849] = {n:"Kracht Ring",t:9,d:"Deze kleine ring geeft Kracht aan zijn drager.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[850] = {n:"Behendigheids Ring",t:9,d:"Vreemd genoeg doen Amakne verzamelaars alles om deze ring te bezitten, terwijl hij geen snars waard is.",ep:1,g:1,l:1,wd:true,fm:true,w:1,p:50};
I.u[851] = {n:"Vitale Ring",t:9,d:"Deze kleine ring vergroot het leven van degene die hem draagt.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[852] = {n:"Kleine Magische Ring",t:9,d:"Deze kleine ring vergroot de intelligentie van zijn drager.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[853] = {n:"Ringetje van de Geluksvogel",t:9,d:"Deze kleine ring verhoogt het geluk van zijn drager.",ep:1,g:42,l:1,wd:true,fm:true,w:1,p:50};
I.u[854] = {n:"Kleine Beer Amulet",t:1,d:"Dit kleine amulet vergroot de kracht van zijn drager.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[855] = {n:"Louveteau Amulet",t:1,d:"Deze kleine amulet verhoogt het leven van zijn drager.",ep:0,g:6,l:1,wd:true,fm:true,w:1,p:50};
I.u[856] = {n:"Kikkertje",t:1,d:"Dit kleine amulet verhoogt de behendigheid van zijn drager.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[859] = {n:"Behendigheids Riem",t:10,d:"Deze bescheiden riem verhoogt de behendigheid van zijn drager.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:50};
I.u[860] = {n:"Geluks Riem",t:10,d:"Deze eenvoudige riem vergroot je geluk.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[861] = {n:"Kleine Kracht Laarzen",t:11,d:"Deze laarsjes vergroten de kracht van hun drager ten koste van zijn behendigheid. Daarmee wordt hij anders maar niet minder stom dan een Tofu",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[862] = {n:"Intelligente Sandalen",t:11,d:"Deze laarzen verhogen de intelligentie van hun drager, terwijl ze tegelijkertijd een hedendaags modieus stijlaccent aanbrengen dankzij hun notenhouten zool met een opvallende vaste wegligging.",ep:1,g:4,l:8,wd:true,fm:true,w:1,p:400};
I.u[863] = {n:"Behendigheids Laarzen",t:11,d:"Deze laarzen verhogen de behendigheid van de drager, zodat hij zich makkelijker een Tofu kan wanen, als hij de idioot uit wil hangen.",ep:1,g:5,l:8,wd:true,fm:true,w:1,p:400};
I.u[864] = {n:"Geluks Laarzen",t:11,d:"Deze laarzen vergroten het geluk van hun drager teneinde hem te helpen in het vinden van erg krachtige voorwerpen, zoals bijvoorbeeld Veelvraatkwijl.",ep:1,g:1,l:8,wd:true,fm:true,w:1,p:100};
I.u[867] = {n:"Drakolier",t:1,d:"Deze prachtige van Drakei-overblijfselen gemaakte amulet is indrukwekkend genoeg om het merendeel van de vijanden met een normaal gestel te laten terugdeinzen.",ep:11,g:9,l:32,wd:true,fm:true,w:2,p:4700};
I.u[878] = {n:"Bakkers Schriftrol",t:13,d:"(Dubbelklik om te gebruiken)\nMet behulp van deze schriftrol kun je XP verdienen in het beroep Bakker.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[879] = {n:"Schoenmaker Schriftrol",t:13,d:"(Dubbelklik om hem te gebruiken)\nMet deze schriftrol kun je als Schoenmaker XP winnen.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[880] = {n:"Koninklijke Veelvraat Wol",t:57,d:"Deze wol is koninklijk, zacht en licht, maar heeft de neiging de gevoelige huid te irriteren. Deze wol is daarentegen veel gebruikt, dus kwetsbaar, gezien de leeftijd van de Koninklijke Veelvraat.",ep:1,g:207,l:35,wd:true,fm:true,w:1,p:4000};
I.u[881] = {n:"Wit Vreetzakjeswol",t:57,d:"Deze wol is buitengewoon zacht, want ze komt van het dons van een Vreetzakje. Pas evenwel goed op, deze wol is nog doordrongen van een geur die de moeder van het Vreetzakje ertoe kan aanzetten je te likken als je in contact komt met deze wol.",ep:1,g:208,l:2,wd:true,fm:true,w:1,p:1};
I.u[882] = {n:"Veelvraat Oorlogs Chef Wol",t:57,d:"Deze wol stinkt erg, maar heeft toebehoord aan een Veelvraat Oorlogschef, wat het een grote sentimentele waarde geeft voor de strijders.",ep:1,g:209,l:19,wd:true,fm:true,w:1,p:1};
I.u[883] = {n:"Wit Vreetzakjesleer",t:56,d:"Dit erg gladde leer is in het bijzonder aangepast voor het maken van leren ondergoed, de Leren Slip van de Chafer is een treffend voorbeeld hiervan.",ep:1,g:534,l:2,wd:true,fm:true,w:1,p:1};
I.u[884] = {n:"Zwart Vreetzakjes Leer",t:56,d:"Deze glimmende leersoort is erg in trek bij Schoenmakers en Kleermakers voor het vervaardigen van kleine laarzen of hoeden.",ep:1,g:16,l:2,wd:true,fm:true,w:1,p:1};
I.u[885] = {n:"Zwart Vreetzakjes Wol",t:57,d:"Deze ruwe wol wordt niet veel door kleermakers gebruikt, maar wordt daarom des temeer gewaardeerd door de Enutrofs, die het gebruiken om hun beginnende kaalheid te verbergen.",ep:1,g:210,l:2,wd:true,fm:true,w:1,p:1};
I.u[886] = {n:"Koninklijk Veelvraat Leer",t:56,d:"Dit leer is koninklijk, het is van een buitengewone souplesse, en de scheuren zijn de getuigen van het lange leven van de Koninklijke Veelvraat. Er bestaat geen beter leer in de hele provincie van Amakna.",ep:1,g:535,l:35,wd:true,fm:true,w:1,p:4000};
I.u[887] = {n:"Veelvraat Oorlogs Chef Leer",t:56,d:"\"Dit leer moet alle oorlogen meegemaakt hebben, om vandaag de dag zo hard te kunnen zijn\" dat waren de woorden van de beroemde minstreel Francisque Kabroule, vlak voordat hij stierf door verstikking veroorzaakt door de geur van een Veelvraat Oorlogschef.",ep:1,g:534,l:19,wd:true,fm:true,w:1,p:1};
I.u[888] = {n:"Grote Concentratie Laarzen",t:11,d:"Deze laarzen zitten zo lekker dat de held die ze draagt zich makkelijker kan concentreren.",ep:1,g:6,l:26,wd:true,fm:true,w:15,p:1950};
I.u[889] = {n:"Krachtige Concentratielaarzen",t:11,d:"Deze laarzen zitten zo lekker, dat daardoor de held die zich ermee schoeit een betere concentratie heeft.",ep:1,g:6,l:27,wd:true,fm:true,w:15,p:2200};
I.u[890] = {n:"Veelvraat Laarzen",t:11,d:"Deze laarzen zijn gemaakt van Veelvraatleer en stellen de fokkers in staat makkelijker de Veelvraat te benaderen om ze, dankzij de geur die ervan afkomt, te doden.",ep:1,g:3,l:1,wd:true,fm:true,w:3,p:150};
I.u[891] = {n:"Laarzen van de Grote Veelvraat",t:11,d:"Deze laarzen zijn gemaakt van Veelvraatleer, hiermee kunnen de fokkers gemakkelijker de Veelvraten benaderen om hen te doden, dankzij de geur die ze afscheiden.",ep:1,g:3,l:2,wd:true,fm:true,w:4,p:200};
I.u[892] = {n:"Krachtige Veelvraat Laarzen",t:11,d:"Deze laarzen zijn gemaakt van Veelvraatleer en daarmee kunnen de fokkers makkelijker de Veelvraten benaderen om ze te doden, dankzij de geur ervan.",ep:1,g:3,l:4,wd:true,fm:true,w:5,p:250};
I.u[893] = {n:"Kleine Bos Dolken",t:5,d:"Deze dolken waren bijzonder geschikt voor het snijden van wortels en jonge scheuten, maar worden nu voor iets anders gebruikt en zijn bijna dodelijk wapens geworden.",ep:1,g:6,l:20,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>20&CI>5",p:1300};
I.u[894] = {n:"Bos Dolken",t:5,d:"Deze dolken waren bijzonder geschikt voor het snijden van wortels en jonge scheuten, maar worden nu voor iets anders gebruikt en zijn bijna dodelijk wapens geworden.",ep:1,g:6,l:23,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>23&CI>5",p:1600};
I.u[895] = {n:"Grote Bos Dolken",t:5,d:"Deze dolken waren bijzonder geschikt voor het snijden van wortels en jonge scheuten, maar worden nu voor iets anders gebruikt en zijn bijna dodelijk wapens geworden.",ep:1,g:6,l:25,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>25&CI>5",p:1900};
I.u[896] = {n:"Krachtige Bos Dolken",t:5,d:"Deze dolken waren oorspronkelijk bedoeld voor het snijden van jonge wortels en scheuten, maar toen besloot men om ze als bijna dodelijke wapens te gebruiken.",ep:1,g:6,l:27,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>27&CI>5",p:2200};
I.u[897] = {n:"Kleine Scherpe dolken",t:5,d:"Deze schijnbaar eenvoudige dolken zijn toch erg gevaarlijk. Bovendien kun je ze makkelijk verbergen, zodat het een goed wapen is voor moordenaars.",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
I.u[898] = {n:"Geslepen Dolken",t:5,d:"Deze schijnbaar eenvoudige dolken zijn toch erg gevaarlijk. Bovendien kun je ze makkelijk verbergen, zodat het een goed wapen is voor moordenaars.",ep:7,g:10,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>33&CW>5",p:3100};
I.u[899] = {n:"Grote Geslepen Dolken",t:5,d:"Deze schijnbaar eenvoudige dolken zijn toch erg gevaarlijk. Bovendien kun je ze makkelijk verbergen, zodat het een goed wapen is voor moordenaars.",ep:7,g:10,l:36,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>36&CW>5",p:3600};
I.u[900] = {n:"Krachtige Geslepen Dolken",t:5,d:"Deze schijnbaar eenvoudige dolken zijn toch erg gevaarlijk. Bovendien kun je ze makkelijk verbergen, zodat het een goed wapen is voor moordenaars.",ep:7,g:10,l:39,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>39&CW>5",p:4100};
I.u[901] = {n:"Leer van Speenvarken",t:56,d:"Dit heel gladde leer wordt met de tijd bijna oranje, maar gaat eveneens steeds meer stinken na verloop van tijd, een beetje als een Gatenkaas.",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Kleine Klime Laarzen",t:11,d:"De behendigheid die deze laarzen geven, stelden Klime de schoenmaker in staat makkelijk op de rug van welke Veelvraat dan ook te klimmen. Hij is gestorven omdat hij een Gelei aanzag voor een Veelvraat, na een met drank overgoten avond in de herberg..",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Klime Laarzen",t:11,d:"De behendigheid die deze laarzen verlenen, stelden Klime de schoenmaker in staat makkelijk op de rug van welke Veelvraat dan ook te klimmen. Hij is gestorven omdat hij een Gelei aanzag voor een Veelvraat, na een met drank overgoten avond in de herberg te hebben doorgebracht.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Grote Klime Laarzen",t:11,d:"De behendigheid die deze laarzen verlenen, stelden Klime de schoenmaker in staat makkelijk op de rug van welke Bouftou dan ook te klimmen. Hij is gestorven omdat hij een Gelée aanzag voor een Bouftou, na een met drank overgoten avond in de taveerne  te hebben doorgebracht.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Superkrachtige Klime Laarzen",t:11,d:"Volgens de legende werden deze laarzen verwisseld met andere kapotte maar superkrachtige laarzen, die waren gemaakt door een onhandige schoenmaker die aan slapeloosheid leed.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Kleine Achtervolgingslaarzen",t:11,d:"Met deze laarzen kon Hogmeiser de enige levende wezens achtervolgen die hij niet kon verdragen, te weten kinderen. Gelukkig voor de kinderen waren deze laarzen zo zwaar dat hij ze niet onder hun kont kon schoppen.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Achtervolgingslaarzen",t:11,d:"Met deze laarzen kon Hogmeiser de enige levende wezens achtervolgen die hij niet kon uitstaan, te weten kinderen. Gelukkig voor hen waren deze laarzen zo zwaar dat hij ze niet eens schop onder de kont kon geven.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Grote Achtervolgingslaarzen",t:11,d:"Met deze laarzen kon Hogmeiser de enige levende wezens achtervolgen die hij niet kon uitstaan, te weten kinderen. Gelukkig voor hen waren deze laarzen zo zwaar dat hij ze niet eens schop onder de kont kon geven.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Krachtige Achtervolgingslaarzen",t:11,d:"Met deze laarzen kon Hogmeiser de enige levende wezens achtervolgen die hij niet kon uitstaan, te weten kinderen. Gelukkig voor hen waren deze laarzen zo zwaar dat hij ze niet eens schop onder de kont kon geven.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Hogmeiser Laarzen",t:11,d:"Deze laarzen zijn jarenlang van Hogmeiser geweest, voordat hij ze verloor door een stomme weddenschap met Grizmine. De moraal van het verhaal is dat je nooit moet spelen met een Ecaflip.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Gebruikte Hogmeiser Laarzen",t:11,d:"Deze gebruikte laarzen hebben jarenlang aan Hogmeiser toebehoord, ze zijn zo versleten dat ze vooral hinderen. Een heel goede schoenmaker zou ze moeten kunnen maken, met een beetje geluk.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Vergulde Hogmeiser Laarzen",t:11,d:"Deze geweldige laarzen van Hogmeiser zijn bedekt met een fijne laag edelstenen om ze ongevoelig te maken tegen sommige magische aanvallen. Met deze laarzen heeft Brouce Boulgoure lang geleden het hoofd van de Veelvraat Koning verpletterd, om de opening van de Troolkermis op te vrolijken.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[916] = {n:"Silicaat Amulet",t:1,d:"Silicaat heeft dit amulet op een winterochtend gemaakt voor een beroemde avonturier genaamd Rimb Vardi, die een oude Bwork Magus achtervolgde, die verantwoordelijk was voor meerdere natuurrampen, ontketend door zijn te grof berekende magie.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"Herfstblad",t:1,d:"Deze broche werd gemaakt op een herfstochtend midden in een beuken- en iepenbos niet ver van het eiland Olag-lacustre. Hij wordt door menig houthakker beschouwd als een ware relikwie.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Oer Barnsteen",t:50,d:"Dit barnsteen komt van een Oer Boomchnid. Het heeft dus een onschatbare waarde en kan magische eigenschappen geven aan bepaalde voorwerpen als het door goede handen wordt gemaakt.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Oer Dolken",t:5,d:"Deze krachtige dolken, op ouderwetse wijze gesmeden van Oer Barnsteen, zijn gebruikt tijdens de kolonisatie van het Moon eiland, voordat het weer ongerept werd.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Oer Hout",t:38,d:"Dit hout komt van een Iep van het eiland van Olag-lacustre, die op een herfstochtend getroffen is door de bliksem, door een Bwork Magus die niet zo goed zijn elementaire betoveringen beheerste.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Bijlsmid Hamer",t:7,d:"Onmisbaar werktuig bij het maken van bijlen.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Boomchnid Kliever",t:19,d:"Deze oorlogsbijl werd gesmeden door Kademila Boulgoure, om de aangstaanjagende Boomchnids te bestrijden. Volgens de legende heeft dit wapen in een nacht meer Boomchnids gedood dan er bomen zijn in Amakna.",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Krachtige Klime Laarzen",t:11,d:"De behendigheid die deze laarzen verlenen, stelden Klime de schoenmaker in staat makkelijk op de rug van welke Veelvraat dan ook te klimmen. Hij is gestorven omdat hij een Gelei aanzag voor een Veelvraat, na een met drank overgoten avond in de herberg te hebben doorgebracht.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Betoverd Hout",t:38,d:"Dit hout is betoverd door een Boomchnid Magus, om leven te schenken aan een eenmaal in het water gedompelde Boomchnid. Het spreekt voor zich dat dit hout buitengewoon magisch is.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Oer Boomchnid Kliever",t:19,d:"Deze oorlogsbijl werd gesmeden door Kademlia Boulgoure, om de Oer Boomchnid te bestrijden. Alleen de beste strijders kunnen hem gebruiken.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Ogralimde Lemmet",t:6,d:"Ogralimde was een groot krijger die zijn kracht dankte aan zijn meester Adyol, een machtige Bwork Magus met een bovennatuurlijke intelligentie. Maar in tegenstelling tot de legende heeft de leerling zijn meester nooit verslagen.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristalliet",t:50,d:"Deze toversteen met zijn aparte naam moet niet in alle handen terechtkomen, gezien de kracht die hij kan toekennen aan wapens of aan sieraden.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Schatkaart van de Duistere Mijnwerkers",t:24,d:"Deze kaart geeft aan waar de schatkist van de Duistere Mijnwerkers zich bevindt:\n\"De schatkist bevindt zich op een eiland, je moet achter een gieterij langs om erbij te kunnen\".",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Schatkaart van de Duistere Bakkers",t:24,d:"Deze kaart geeft aan waar de schatkist van de Duistere Bakkers zich bevindt:\n\"De schatkist bevindt zich op een eiland ten zuiden van Amakna, je moet achter de rotsen langs tussen twee meertjes door\".",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Kleine Blozende Cape",t:17,d:"Deze cape verlengt het leven van de drager.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
I.u[933] = {n:"Rooie Cape",t:17,d:"Deze cape verhoogt het leven van zijn drager.",ep:1,g:13,l:13,wd:true,fm:true,w:5,p:650};
I.u[934] = {n:"Grote Bloos Cape",t:17,d:"Deze cape vergroot het leven van zijn drager.",ep:1,g:13,l:16,wd:true,fm:true,w:5,p:900};
I.u[935] = {n:"Kleine Blauwachtige Cape",t:17,d:"Deze cape vergroot de kans van de drager.",ep:1,g:18,l:1,wd:true,fm:true,w:5,p:560};
I.u[936] = {n:"Blauwachtige Cape",t:17,d:"Deze cape vergroot het geluk van zijn drager.",ep:1,g:18,l:3,wd:true,fm:true,w:5,p:1020};
I.u[937] = {n:"Grote Blauwige Cape",t:17,d:"Deze cape verhoogt het geluk van zijn drager.",ep:1,g:18,l:6,wd:true,fm:true,w:5,p:1560};
I.u[938] = {n:"Schatkaart van de Duistere Smeden",t:24,d:"Deze kaart geeft aan waar de schatkist van de Duistere Smeden zich bevindt:\n-- nog maken --",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Schatkaart van de Bworks",t:24,d:"Deze kaart geeft aan waar de schatkist van de Bworks zich bevindt:\n\"De toegang tot de schatkist is gelegen in een doodlopend steegje, in het zuid-oosten van het duistere bos. Hij zal ongetwijfeld beschermd worden door een groep Bworks\".",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Farter",t:16,d:"De Farter voorkomt fysieke schade.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Komintot Hoofdband",t:16,d:"De Komintot stelt zijn dragen in staat zijn wijsheid te vergroten.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Likker",t:16,d:"De likker voorkomt magische schade.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Vitaliteits Hoofdbandje",t:16,d:"De drager van deze band kan zijn vitaliteit verhogen.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Vitaliteits Hoofdband",t:16,d:"Deze Hoofdband verhoogt de vitaliteit van de drager.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
I.u[945] = {n:"Kleine Duistere Cape",t:17,d:"Deze cape vergroot de wijsheid van zijn drager.",ep:1,g:15,l:8,wd:true,fm:true,w:5,p:375};
I.u[946] = {n:"Duistere Cape",t:17,d:"Deze cape verhoogt de wijsheid van zijn drager.",ep:1,g:15,l:12,wd:true,fm:true,w:5,p:600};
I.u[947] = {n:"Grote Duistere Cape",t:17,d:"Deze cape verhoogt de wijsheid van zijn drager.",ep:1,g:15,l:19,wd:true,fm:true,w:5,p:1200};
I.u[948] = {n:"Boomccape",t:17,d:"Deze geweldige cape is een briljante mengeling van Boomchnid-extract en de goede Veelvraat-familie.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Grote Vitaliteitsband",t:16,d:"Deze Band stelt zijn drager in staat zijn vitaliteit te verhogen.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Naalden en Draad",t:20,d:"Met deze naalden en draad kan je het beroep van kleermaker uitoefenen.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Gekke Boowolf Cape",t:17,d:"Deze cape is gemaakt met de vacht en andere organische delen van verschillende Boowolven... Je zou kunnen zeggen dat hij kracht uitstraalt.",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Gekke Tofu Cape",t:17,d:"Met deze met de hand maakte cape van de Tofu veren, kan degene die hem draagt sneller rennen en makkelijker uit de tackle vluchten.",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"De Samoulaille",t:17,d:"De Samoulaille is een legendarische cape, geborduurd door kleermakers voor de krijgers die graag het lijf-aan-lijfgevecht aangaan.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Hillair Cape",t:17,d:"De cape Hillair is een erg gewilde cape onder de kappers. Ze vinden het heerlijk om zich erin te wikkelen en het geeft de drager ervan meer weerstand tegen schokken.",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Cape Rice",t:17,d:"Deze cape vergroot de actieradius van zijn drager, zodat hij zeer verre doelen kan raken of indruk kan maken op lichtelijk naïeve avonturiers.",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"Veelvratin",t:17,d:"De Veelvratin vergroot de schade en de vitaliteit van zijn drager. Zij verspreidt een sterke lucht en het gebeurt meer dan eens dat een Veelvraat je voor een van de zijnen aanziet.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofusteuse",t:17,d:"Deze cape is zeker een van de machtigste van deze wereld. Hij vergroot alle eigenschappen van zijn drager.",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Schatkaart 5",t:24,d:"-- nog doen --",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Wabbit Drankje",t:24,d:"Deze toverdrank is een remedie tegen myxomawose. Een slok van dit brouwsel stelt je in staat het eiland van de wabbits te bezoeken zonder voor je leven te vrezen.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Wabbit Sleutel",t:24,d:"Met één van de drie sleutels kun je de deur van het wabbit kasteel open maken.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Wabbit Sleutel",t:24,d:"Met één van de drie sleutels kun je de deur van het wabbit kasteel open maken.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
I.u[963] = {n:"Wabbit Sleutel",t:24,d:"Met één van de drie sleutels kun je de deur van het wabbit kasteel open maken.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Dopple Steen",t:50,d:"Deze steen komt van de Dopple wereld. Voor sommige bewoners van Amakna heeft hij een grote waarde.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Kleermakershandboek",t:25,d:"(Dubbelklik om het beroep van Kleermaker te leren)\nMet behulp van dit handboek kan je de fijne kneepjes van het Kleermakersvak leren. Voor degenen wier verbeelding ze in de steek laat, de eerste bladzijden bieden eenvoudige patronen om uit te knippen.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Flitsende Cape",t:17,d:"Deze fantastische cape verhoogt de actiepunten van zijn drager. Hij verhoogt eveneens zijn vitaliteit en wijsheid.",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
I.u[968] = {n:"Flitsende riem",t:10,d:"Deze prachtige riem verhoogt de action points van de drager. Bovendien verhoogt het zijn vitaliteit en zijn wijsheid.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Wa Wabbit Kroon",t:16,d:"Deze fantastische kroon was ooit treurig genoeg van de beroemde Wa Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Wa Wabbit Staf",t:4,d:"Deze staf was ooit van de beroemde betreurde Wa Wabbit",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Wa Wabbit Cape",t:17,d:"Deze cape was ooit van de beroemde betreurde Wa Wabbit. Hij is nog doordrenkt van zijn zweet, waardoor je dit geweldige gevecht voor de geest kunt halen, elke keer als je hem draagt.",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Wottel Dofus",t:23,d:"De Wottel Dofus verhoogt de wijsheid van zijn drager.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Arachnid Poot",t:24,d:"Een heel fijn, maar wel erg behaard, pootje. De beste Alchemisten lukt het krachtige toverdranken te maken met het sap dat de uit deze pootjes kunnen halen.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Hoofd van een Boer in nood",t:24,d:"Wat moest gebeuren is gebeurd, de Boer in nood heeft uiteindelijk zijn verstand verloren.",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Hoektand van de Gevangen Vampier",t:24,d:"Deze zeer puntige tand komt van een Vampier. Als je deze in je bezit hebt of hem om je hals draagt, kan je indruk maken op je vrienden door hun te laten geloven dat je een Vampierjager bent.",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Pwompwoen",t:16,d:"De Pwompwoen heeft de eigenschap de verstrooiing van magische deeltjes te verhinderen, dat maakt het een zeer goed magisch isolatiemateriaal. Dat is overigens waarom sommige strijders deze groente gebruiken als hoofddeksel.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Shygekax Citroen",t:42,d:"Vind de smaak en de magie van het suikergoed van vroeger weer terug... met dit op de ouderwetse manier gemaakte snoepje met citroensmaak.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Shigekax Aardbei",t:42,d:"Vind de smaak en de magie van het suikergoed van vroeger weer terug... met dit op de ouderwetse manier gemaakte snoepje met aarbeiensmaak.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Shigekax Mint",t:42,d:"Vind de smaak en de magie van het suikergoed van vroeger weer terug... met dit op de ouderwetse manier gemaakte snoepje met mintsmaak.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Shygekax Kersen",t:42,d:"Vind de smaak en de charme van het suikergoed van vroeger weer terug... met dit op de ouderwetse manier gemaakte snoepje met kersensmaak.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Groengely",t:42,d:"Bereid op basis van mint gelei, en heeft zelfs al meerdere vegetariërs afgeschrikt. Het blijft niettemin een van de specialiteiten van Amakna.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Roogely",t:42,d:"Bereid op basis van aardbeien gelei, en heeft zelfs al meerdere vegetariërs afgeschrikt. Het blijft niettemin een van de specialiteiten van Amakna.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Blaugely",t:42,d:"Bereid op basis van blauwe gelei, en heeft zelfs al meerdere vegetariërs afgeschrikt. Het blijft niettemin een van de specialiteiten van Amakna.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multygely",t:42,d:"De multygely mocht niet verkocht worden, want hij lokte de verdwijning van talloze kinderen uit.\nHet schijnt dat degene die het eet de meest vreselijke nachtmerries krijgt.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[997] = {n:"Kokokonut",t:46,d:"Zo rond als een kanonbal, de Kokokonoot heeft 3 gaten, waardoor het heel makkelijk is om hem weg te gooien.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Kapitein Piraat zijn Schattige Shorts",t:15,d:"De shorts van Kapitein Piraat zijn het bewijs bespotting echt iemand z\'n dood werd. Maar blijkbaar zijn het ook geluks shorts.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Niet Verleidelijk Doek",t:55,d:"Dit grote stuk canvas is slijmerig en stinkt maar van een tamelijk goede kwaliteit. Jammer dat er zoveel gaten in zitten!",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Leeg Vat",t:15,d:"Dit grote vat is lang geleden geleegd, maar we kunnen nog steeds raden wat er in zat: rum, Kamas, dronken piraten... alles wat je in een vat kunt vinden behalve water.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Kokoko Houten Plank",t:95,d:"Toekomstig boot onderdeel? Toekomstige houten vloer? Hoe dan ook, momenteel is het gewoon een plank.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"KoKonoot Palm Stam",t:38,d:"Net als alle andere stammen is de stam van de Kokospalm recht en sterk, maar een beetje kleiner dan de gemiddelde.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Balk van Kokokoshout",t:38,d:"Een stevige houten balk dit je niet in je oog moet doen.",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Essentiële Touw",t:15,d:"Geen enkele avonturier die zichzelf respecteert zou op pad gaan zonder dit Touw in zijn inventaris. Ze zouden je moeten adviseren om hetzelfde te doen, hoewel het een advies is die vaak niet ter harte genomen wordt!",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Ontvangstbewijs voor het vlot",t:24,d:"Een ontvangstbewijs getekend door Kib Roche, waarop staat dat je vlot over enige tijd klaar zal zijn.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Piraten Hoed",t:24,d:"Hoed met indrukwekkende vormen, teken van de dood op de voorkant geborduurd, voering om hem op te leuken, deze piratenhoed is een klassieker tussen de kapiteins.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Haak",t:24,d:"Onmisbaar accessoire voor piraten die geen geluk hebben. Deze haak is een gunstige vervanger van een hand. Zijn kleur geeft hem bovendien een nogal chique tintje.",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Vallende Kaak",t:24,d:"Deze gebroken kaak komt waarschijnlijk van de woede van een kapitein tegenover een matroos die te hard moest lachten toen hij de boxershort van zijn baas zag.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Piraten Schedel",t:24,d:"Deze met een bandana getooide schedel laat zien dat een piraat, zelfs als hij dood is, nog steeds zijn kaalheid kan verbergen.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Groen Schild",t:24,d:"Het schild van een gestoorde schildpad die dacht dat hij een ninja was.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
