I.u[9248] = {n:"Sleutel van de Blop Grot",t:84,d:"Deze sleutel geeft je toegang tot de Blop Grot",ep:5,g:248,l:1,wd:true,fm:true,w:1,p:1};
I.u[9249] = {n:"Kersen Sleutel Fragment",t:84,d:"Als je de andere stukken van deze sleutel vindt, moet je gewoon met de Regenboog Blop gaan vechten. Als je dat niet meer wil na dit te lezen, begrijp ik het.",ep:5,g:250,l:1,wd:true,fm:true,w:1,p:1};
I.u[9250] = {n:"Pippin Sleutel Fragment",t:84,d:"Als je de andere stukken van deze sleutel vindt, kun je de Regenboog Blop gaan bevechten. Als je niet meer naar de andere stukken wilt zoeken na dit te horen, begrijp ik het.",ep:5,g:251,l:1,wd:true,fm:true,w:1,p:1};
I.u[9251] = {n:"Coco Sleutel Fragment",t:84,d:"Als je de andere stukken van deze sleutel vindt, kun je de Regenboog Blop gaan bevechten. Als je niet meer naar de andere stukken wilt zoeken na dit te horen, begrijp ik het.",ep:5,g:252,l:1,wd:true,fm:true,w:1,p:1};
I.u[9252] = {n:"Indigo Sleutel Fragment",t:84,d:"Als je de andere stukjes van deze sleutel vindt, moet je gewoon met de Regenboog Blop gaan vechten. Als je die stukjes niet meer wilt zoeken nadat je dit hebt gehoord begrijp ik het ook.",ep:5,g:249,l:1,wd:true,fm:true,w:1,p:1};
I.u[9253] = {n:"Wilde Furie Drankje",t:24,d:"Domen heeft je dit drankje gegeven om Divad en Kaffra aan te sporen om nog één te vermoorden.",ep:16,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9254] = {n:"Sleutel van het Regenboog Blop Hol",t:84,d:"Deze sleutel geeft je toegang tot de Regenboog Blop Grot.",ep:5,g:253,l:1,wd:true,fm:true,w:1,p:1};
