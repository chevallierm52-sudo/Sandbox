I.u[9153] = {n:"Koninklijke Kersen Amublop",t:1,d:"Deze Amublop kost veel meer om te maken dan een gewone Amublop, maar bekijk het van de goeie kant... je kunt hem ook voor veel meer verkopen, vooral als je hem bij een Astrubiaan dumpt.",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
I.u[9154] = {n:"Koninklijke Pippin Amublop",t:1,d:"Deze Amublop kost veel meer om te maken dan een gewone Amublop, maar bekijk het van de goeie kant... je kunt hem ook voor veel meer verkopen, vooral als je hem bij een Astrubiaan dumpt.",ep:5,g:133,l:80,wd:true,fm:true,w:10,s:103,p:15800};
