I.u[9060] = {n:"Verscheurd stukje papier",t:24,d:"Gedeelte van een brief die iemand verscheurd heeft. Je kunt er op lezen: \'... zoals we geregeld hadden, ik zal zorgen dat het onderzoek naar deze koopman nergens toe leidt. Kom me het bedrag betalen waar we vaker ontmoeten... waar de vrouwen knap zijn...\'\nDe brief is getekend door X.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9061] = {n:"Exoram",t:32,d:"Exoram moet begeleid worden uit het goblin kamp en naar de Sram tempel.",ep:1,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9062] = {n:"Document over Xephires",t:24,d:"Dit document bevat een boel interessante informatie over een man genaamd Xephires. Wat het meest wonderbaarlijke is, is de tijd die hij in Astrub Tavern doorbracht.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9063] = {n:"Milone\'s Lijst",t:24,d:"Deze ongelofelijke lijst kreeg je van Milone de Juwelier. Het vertelt je de benodigde objecten om een beeldschoon juweel te maken.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9064] = {n:"Koninklijke Veelvraag Kwijl",t:24,d:"Is het echt anders dan normale kwijl? Het ziet er zeker niet anders uit.",ep:1,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9065] = {n:"Brief voor Milone",t:24,d:"Dit haastig geschreven briefje legt aan Milone uit dat het juweel in gevaar is... dus waarom lees je dit nog? Schiet op!!!",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9066] = {n:"Brief van de Hoofddief",t:24,d:"Dit is gevonden bij een van de inbrekers die je versloeg bij Milone\'s huis:\nMilone de juwelier heeft net een erg waardevol juweel gemaakt. Wat je er ook voor moet doen, steel het. Gelukkig gaf Milone een kopie, maar dat is niet dankzij jou.\nAan de achterkant van het bericht, is een gids van hoe je in hun schuilplaats kunt komen. Een vriendelijk bezoek? Natuurlijk! Maar je kunt beter niet alleen gaan.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9067] = {n:"Brief voor Xephires",t:24,d:"Deze brief van Oto Mustam legt aan Xephires het plan in detail uit.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9068] = {n:"Milon\'s Sieraad",t:24,d:"Jij en Milone de Juwelier werkten samen om dit sieraad te maken. Je kunt hem voor een fortuin verkopen... als je ooit iemand vindt die hem wil kopen.",ep:16,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9069] = {n:"Nieuwe brief voor Xephires",t:24,d:"Oto beschrijft de voorwaarden om Xephires corrupt te maken.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9070] = {n:"Vreemd Zwaard",t:24,d:"Dit zwaard is erg vreemd. Zoiets heb je nog nooit in Bonta gezien.",ep:1,g:718,l:1,wd:false,fm:true,w:0,p:1};
I.u[9071] = {n:"Kroeghouder Feubuk\'s notities",t:24,d:"Kroeghouder Feubuk ontving de Ecaflips die Loudac\'s naam noemden.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9072] = {n:"Kroeghouder Pinchaut\'s notities",t:24,d:"Kroeghouder Pinchaut hoorde wat wachters praten over hun problemen met een groep Ecaflips.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9073] = {n:"Embleem van de Bandiet Ecaflip",t:24,d:"Je hebt dit embleem gevonden op de Ecaflip Veld Bandieten rond Cania.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9074] = {n:"Amayiro\'s Sieraad",t:24,d:"Deze sieraad is perfect om het hoofd van de bandieten in je val te lokken.",ep:1,g:111,l:1,wd:false,fm:true,w:0,p:1};
I.u[9075] = {n:"Xelor\'s Brief",t:24,d:"Deze brief is aan je gegeven door Marge de Juwelier. Breng het juweel naar Ekysoy Kubnan in de Woodenglass Herberk. Het zal sneller zijn voor ons en winstgevender voor jou.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9076] = {n:"Amayiro\'s Sieraad (vals)",t:24,d:"Deze sieraad lijkt precies op degene die je van Anayiro moest halen.",ep:1,g:110,l:1,wd:false,fm:true,w:0,p:1};
I.u[9077] = {n:"Feca Schedel",t:47,d:"Deze Feca schedel zou een perfecte boekensteun zijn.",ep:1,g:34,l:1,wd:true,fm:false,w:1,p:1};
I.u[9078] = {n:"Osamodas Schedel",t:47,d:"Een Tofu hier, een Magus Bwork daar... Deze Osamodus volgeling heeft net z\'n hoofd verloren!",ep:1,g:33,l:1,wd:true,fm:false,w:2,p:1};
I.u[9079] = {n:"Enutrof Schedel",t:47,d:"Deze trofee was al oud voor hij een trofee werd.",ep:1,g:32,l:1,wd:true,fm:false,w:2,p:1};
I.u[9080] = {n:"Sram Schedel",t:47,d:"Deze trofee was al morbide voor hij een trofee werd.",ep:1,g:31,l:1,wd:true,fm:false,w:2,p:1};
I.u[9081] = {n:"Xelor Schedel",t:47,d:"Deze schedel wordt vaak verward met die van de beroemde mummy Tuthan Kamha. Laat je niet voor de gek houden, deze verbanden zijn niet gemaakt van gesmolten kamas, maar met papier-maché.",ep:1,g:30,l:1,wd:true,fm:false,w:2,p:1};
I.u[9082] = {n:"Ecaflip Schedel",t:47,d:"Dat is genoeg over hoofden en staarten. Wat dacht je van een bikkelspelletje?",ep:1,g:29,l:1,wd:true,fm:false,w:2,p:1};
I.u[9083] = {n:"Eniripsa Schedel",t:47,d:"Doe niet zo wreed... dit is niet een schedel van een mus!",ep:1,g:28,l:1,wd:true,fm:false,w:2,p:1};
I.u[9084] = {n:"Iop Schedel",t:47,d:"Deze trofee is nu net zo leeg als toen hij nog levend was..",ep:1,g:27,l:1,wd:true,fm:false,w:1,p:1};
I.u[9085] = {n:"Cra Schedel",t:47,d:"Deze schattige Cra schedel is kennelijk recentelijk bij archeologische opgegraven.",ep:1,g:26,l:1,wd:true,fm:false,w:2,p:1};
I.u[9086] = {n:"Sadida Schedel",t:47,d:"Wat? Er zit een schedel onder deze enorme bos haren?!",ep:1,g:25,l:1,wd:true,fm:false,w:2,p:1};
I.u[9087] = {n:"Sacrier Schedel",t:47,d:"Deze Sacrier kan nu niet meer stoer doen met zijn duizenden levenspunten.",ep:1,g:24,l:1,wd:true,fm:false,w:2,p:1};
I.u[9088] = {n:"Pandawa Schedel",t:47,d:"Er kan gedacht worden dat na zolang overgehangen te zijn, de Pandawa een plek in een kist op prijs zou stellen!",ep:1,g:23,l:1,wd:true,fm:false,w:2,p:1};
I.u[9089] = {n:"Vlag van de Bontariaanse Patrouille",t:24,d:"Je hebt deze vlag gevonden tijdens de (erg makkelijke) gevechten met Bontariaanse groepen.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9090] = {n:"Embleem van de Brakmariaanse Patrouille",t:24,d:"Je hebt dit embleem gevonden tijdens het gevecht tegen Brakmar.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9092] = {n:"",t:24,d:"",ep:16,g:86,l:1,wd:false,fm:true,w:0,p:1};
I.u[9094] = {n:"Bwork Vergif",t:24,d:"Dit spul lijkt meer op mint gelei dan op vergif. Bworks staan niet bekend om het maken van gelei dus...het moet wel vergif zijn.",ep:4,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9096] = {n:"Bontariaanse Tacticus",t:32,d:"",ep:16,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9097] = {n:"Badge van de Krachtige Militiaman",t:24,d:"Je hebt deze badge gevonden bij een erg enge militiaman die meerdere krijgers van Brakmar heeft verslagen. Zijn uitrusting ziet er nogal vreemd uit.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9098] = {n:"Nara\'s Hamer",t:24,d:"Deze hamer zal aan Oto bewijzen dat je de gehuurde smid van Bonta hebt overwonnen.",ep:16,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9099] = {n:"Aanvraag om hulp van Amayiro",t:24,d:"Deze brief, welke getekend is door Amayiro, is een officiele aanvraag om hulp.",ep:3,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9100] = {n:"Lenglad\'s Onderbroek",t:24,d:"Lenglad zal niet willen dat mensen te lang over hem roddelen.",ep:1,g:84,l:1,wd:false,fm:true,w:0,p:1};
I.u[9101] = {n:"Nara\'s Gereedschapskist",t:24,d:"In deze gereedschapskist ligt al het gereedschap dat Nara, de ijzersmid, vergeten is.",ep:3,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9103] = {n:"Plan van Aanval",t:24,d:"Deze brief van een week geleden, geeft de details over het plan om Bonta aan te vallen. Je zult toch voorzichtig moeten zijn, want een notitie aan het eind zegt dat het plan nog niet bevestigd is en in de komende dagen nog veranderd kan worden door officier Kapp Teinn. Hierdoor zal je er achter moeten komen wat er op het moment met het plan gebeurt.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9104] = {n:"Embleem van de Begraafplaats Patrouille",t:24,d:"Je hebt dit embleem gevonden bij een Brakmariaanse Patrouille die je aan hebt gevallen in het Kerkhof van de Martelaars.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
