I.u[9277] = {n:"Oog van de Mush Mish",t:109,d:"De Mush Mish heeft de irritante gewoonte om in zijn jeukende ogen te krabben. De gewoonte is een beetje meer dan irritant wanneer hij een puntig wapen in zijn hand heeft op dat moment.",ep:23,g:587,l:152,wd:true,fm:true,w:1,p:1};
I.u[9278] = {n:"Mush Tup\'s Lemmet",t:15,d:"De Mush Tup heeft twee armen, twee benen en twee hoofden. Dit alles betekent dat het twee keer dommer is dan je zou verwachten.",ep:23,g:766,l:144,wd:true,fm:true,w:1,p:1};
I.u[9279] = {n:"Mush Rhume Slobber",t:15,d:"Deze spit is heerlijk, al dan niet een beetje slijmerig. Het wordt dikwijls gebruikt om wapens in te vetten. Of krijgers als ze van naakt vechten houden.",ep:23,g:45,l:149,wd:true,fm:true,w:1,p:1};
I.u[9280] = {n:"Ougaad",t:15,d:"Dit beest heeft slechts vier stekels op zijn hoofd, maar wat voor stekels... zo scherp als een puntige stok!",ep:23,g:40,l:900,wd:true,fm:true,w:1,p:1};
I.u[9281] = {n:"Ougaat Fragment",t:15,d:"Ougaa heeft een adembenemend hoofddeksel, en je hebt er een stukje van in je handen.",ep:23,g:41,l:900,wd:true,fm:true,w:1,p:1};
I.u[9282] = {n:"Boek: Aanval van As\'Ruoy\'Dnim",t:24,d:"Dit boek vertelt het verhaal van de groei naar kracht van As\'Ruoy\'Dnim en zijn gevangenneming door Koning Allister. Er staat ook in dat zijn broer Fallanster de enige is die de sleutel van de boeien heeft.",ep:2,g:95,l:1,wd:false,fm:true,w:0,p:1};
