I.u[9479] = {n:"Poshoed",t:16,d:"De schroef in deze hoed zal een groot hoofd doen krimpen, als niet ook wat anders...",ep:1,g:232,l:45,wd:true,fm:true,w:23,s:123,p:1000};
I.u[9480] = {n:"Caposh",t:17,d:"Met zo\'n leuk doel op je cape genaaid hebben je vijanden geen enkel excuus om te missen.",ep:1,g:161,l:33,wd:true,fm:true,w:10,s:123,p:3000};
I.u[9481] = {n:"Poschild",t:82,d:"De spijker die in dit schild gehamerd zit kan gebruikt worden als een extra-dichtbij gevechtswapen en je vijanden vermoorden.",ep:1,g:36,l:1,wd:true,fm:true,w:1,s:123,p:1};
I.u[9482] = {n:"Schild Kada",t:82,d:"Als je je vrienden niet wilt afschrikken door je lelijke gezicht, kun je je achter dit leuke, verwelkomende schild verbergen.",ep:1,g:37,l:1,wd:true,fm:true,w:1,s:122,p:1};
I.u[9483] = {n:"Boh-Bihn Schild",t:82,d:"Als Iops sterren krijgen van hun leraren voor goed werk, plakken ze ze op dit schild. Van tijd tot tijd plakken ze ze over hun hele lichaam om op te scheppen tegenover hun schoolmaatjes.",ep:1,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[9484] = {n:"Gestreept Schild",t:82,d:"Dit schild geeft niet een volledige beschermings garantie voor de eigenaar, maar is geweldig om geesten achterna te zitten.",ep:1,g:39,l:1,wd:true,fm:true,w:1,p:1};
I.u[9485] = {n:"Cicapeda",t:17,d:"De drie kleine balletjes onder aan deze cape laten je geweldige kopstoten geven als je leert om rond te tollen.",ep:1,g:162,l:30,wd:true,fm:true,w:10,s:122,p:2500};
I.u[9486] = {n:"Cicad\'Hoed",t:16,d:"Met of zonder deze hoed, je ziet er hoe dan ook uit als een hansworst... Maar als je hem op hebt, heb je tenminste een excuus!",ep:1,g:233,l:33,wd:true,fm:true,w:10,s:122,p:3075};
I.u[9487] = {n:"Richtenconversie Certificaat",t:24,d:"Dit certificaat was aan jou gegeven door Morgan Faym\'n. Het bevat enkele details die je mogelijk interesseren en het getuigt van jouw bekering.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9488] = {n:"Het Bonta Register",t:24,d:"Dit register behoort toe aan Morgan Faym\'n en bevat vele documenten, van welke sommigen uitleggen hoe je een Bontariër kan worden. Binnenin zit een pagina die je zelf in moet vullen.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9489] = {n:"Het Brakmaarse Register",t:24,d:"Dit register behoort toe aan Morgan Faym\'n en bevat vele documenten, van welke sommigen uitleggen hoe je een Brakmaarse kan worden. Binnenin zit een pagina die je zelf in moet vullen.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9490] = {n:"Orde Certificaat No. 5",t:24,d:"Dit certificaat laat zien dat je lid bent van een orde. Als je naar een andere orde wilt, moet je zeven dagen wachten vanaf het moment dat je het certificaat hebt ontvangen. Zelfs krijgers veranderen af en toe van gedachten. Maak er geen gewoonte van!",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9491] = {n:"Vloek van de Chocrosis",t:30,d:"Je ziet het leven nou door rooskleurig glas en je bent zo blij als een klein kind...",ep:1,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
