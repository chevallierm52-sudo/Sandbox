I.u[9321] = {n:"De Gevangenneming van Jiva",t:24,d:"Dit boek verhaalt de verovering van Jiva door Djaul. De trotse beschermer zou niet er blij zijn als ze erachter komt dat haar oneervolle nederlaag in een boek beschreven is, daarom is het in een onbekende taal geschreven.",ep:9,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9322] = {n:"Bekoord Book van de Gevangenneming van Jiva",t:24,d:"Dit boek verhaalt de verovering van Jiva door Djaul. De trotse beschermer zou niet er blij zijn als ze erachter komt dat haar oneervolle nederlaag in een boek beschreven is, daarom is het in een onbekende taal geschreven. Een meester Xelor heeft een ontcijferende spreuk uitgesproken over het schrijven, maar je kunt het nog steeds niet lezen.",ep:9,g:95,l:1,wd:false,fm:true,w:0,p:1};
