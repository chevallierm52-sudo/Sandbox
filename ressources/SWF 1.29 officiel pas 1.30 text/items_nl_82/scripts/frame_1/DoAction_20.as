I.u[9263] = {n:"Bushnid Schors",t:96,d:"Een parasiet voelt zich nergens zo thuis als in een schors van een Mushnid. Van tijd tot tijd zal het beest zichzelf krabben, stukjes van zijn zieke huid afrukken welke in paddenstoelen kunnen veranderen als het op de juiste plek eraf valt. Deze paddenstoel zoekt dan de dichtstbijzijnde Mushnid om op te klaplopen...zoals het kwaadaardige cirkels betaamt, is deze nogal afzichtelijk.",ep:23,g:109,l:113,wd:true,fm:true,w:1,p:10};
I.u[9264] = {n:"",t:32,d:"",ep:1,g:28,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9265] = {n:"Grote Glazen Kom van Miteters",t:24,d:"Deze glazen kom is vol met miteters, die rare dingen die je soms op een ongewassen Crackler vindt.",ep:5,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9266] = {n:"Koninklijk Bessen Vet",t:24,d:"",ep:7,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9267] = {n:"Koffer van de Trumperelle",t:15,d:"Deze Trumpelle koffer heeft de giftige adem van zijn vorige eigenaar. Nou wordt het gebruikt als een vals muziekinstrument om hele publieken uit te moorden tijdens \' moordende concerten.\'",ep:23,g:764,l:125,wd:true,fm:true,w:1,p:10};
I.u[9268] = {n:"Lusteloze Hamer van Licht",t:24,d:"Deze hamer van het licht lijkt zijn geest van het licht die hem zijn kracht gaf verloren te zijn. Ineens lijkt het niet zoveel meer.",ep:3,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9269] = {n:"Tong van de Mushmunch",t:15,d:"De Mushmunch heeft een tong van ongelooflijke lengte en zachtheid vanwege het aflikken van spores van zijn metgezellen. Als ik het goed heb is dit het enige benijdenswaardige wat ze hebben.",ep:23,g:765,l:134,wd:true,fm:true,w:1,p:1};
I.u[9270] = {n:"",t:24,d:"",ep:1,g:680,l:1,wd:false,fm:true,w:0,p:1};
I.u[9271] = {n:"Maskara\'s Belofte",t:24,d:"Deze ring symboliseert de belofte van Maskara... ze zei dat ze met jou met poppen zou spelen wanneer je maar wilt, en vooral dat zij de pop zou zijn.",ep:1,g:730,l:1,wd:false,fm:true,w:0,p:1};
I.u[9272] = {n:"Notitie van Maskara",t:24,d:"Deze kleine notitie eist dat je dertig minuten wacht voor ze een gevuld speeltje maakt.",ep:1,g:44,l:1,wd:false,fm:true,w:0,p:1};
