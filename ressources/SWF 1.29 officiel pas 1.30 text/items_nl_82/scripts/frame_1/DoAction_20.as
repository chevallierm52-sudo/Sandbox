I.u[9326] = {n:"Missie voor het Konvooi",t:24,d:"Dit document schetst de missie voor het Bontaarse konvooi om Kapitein Ronan de Barbaar te vangen en hem naar Bonta te brengen. Ze hadden echter niet gedacht dat jij je ermee zou bemoeien.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
