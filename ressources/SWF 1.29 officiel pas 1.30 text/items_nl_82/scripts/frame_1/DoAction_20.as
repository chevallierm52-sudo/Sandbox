I.u[9525] = {n:"Gezonde Luvenby\'s Dag Kado",t:89,d:"Dit kado is een overlevingspakket die je mogelijk bij je wilt houden terwijl je op gevaarlijke liefdesmissies gaat.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9526] = {n:"Bericht over Dreigingen",t:24,d:"Je schreef iets op een stukje papier om te onthouden dat je nooit een Astrubiaan moet bedreigen als er bewapende wachters vlakbij zijn.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9527] = {n:"Geincarneerde Nagel Poeder",t:24,d:"Dit is oude nagel poeder dat ooit van de tenen van een Enutrof kwam. Veel jaren zijn voorbij gegaan sinds het gemalen is, maar de poeder stinkt nog steeds naar zweetvoeten.",ep:1,g:37,l:1,wd:false,fm:true,w:0,p:1};
I.u[9528] = {n:"Lear\'s Amulet",t:24,d:"Dit krachtige amulet was van Lear, de leider van een lang-vervlogen sekte. Blijkbaar communiceerde hij met extra-dimensionale wezen en kon hij zielen klonen. Het lukte hem ook zichzelf te herrijzen... wat behoorlijk handig moest zijn als er geen priesters in de buurt waren.",ep:9,g:48,l:1,wd:false,fm:true,w:0,p:1};
I.u[9529] = {n:"Geforceerde Ressurectie Drankje",t:24,d:"Soms kunnen of willen zielen zich niet reincarneren. Dit drankje is bruikbaar om ze te forceren hun originele vorm weer aan te nemen.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9530] = {n:"Betoverde Vis Hengel voor Snappers",t:24,d:"Met een beetje geluk vang je Gabby tongen in plaats van Snappers met deze hengel.",ep:0,g:739,l:1,wd:false,fm:true,w:0,p:1};
I.u[9531] = {n:"Gabby Tong",t:24,d:"Dit vreemde orgaan wordt soms gebruikt voor de Gabby Tong methode.\nDeze vuile methode betekend dat het slachtoffer een Gabby Tong moet inslikken, waardoor ze praten en als een gek om zich heen slaan, alsof ze aan het slamdancen zijn. Dit put ze erg snel uit, waarna de tweede effect begint - het slachtoffer valt in diepe vriendschap met iedereen die ze tegenkomen. In deze toestand is het simpel informatie van ze te krijgen.",ep:1,g:740,l:1,wd:false,fm:true,w:0,p:1};
I.u[9532] = {n:"Standbeeld van Sumens",t:24,d:"Dit is één van de twee standbeelden die door de Maimanes aan de Sumens gegeven is en het beeldt het goede en het kwade van de mensheid uit. De verschijning van het standbeeld",ep:14,g:738,l:1,wd:false,fm:true,w:0,p:1};
I.u[9533] = {n:"Cokezielsteen",t:24,d:"Deze zielsteen was betoverd door de meeste van de Orde van het Rottende Oog om zielen vrijwillig zich te laten vangen.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9534] = {n:"Terra Tibya\'s Zielsteen",t:24,d:"Deze zielsteen bevat de ziel van Terra Tibya, de Enutrof. Je moet er voorzichtig mee omgaan als je niet wilt dat je eigen ziel er in vast komt te zitten.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9535] = {n:"Transgenesis Drankje",t:24,d:"Als je het juist gebruikt, kan dit drankje de groei van planten versnellen door hun genen te veranderen. Niemand weet of er bijwerkingen zijn als de planten gegeten worden, maar shhhhh. Wat de klanten niet weten kan ze ook geen kwaad doen!\nJe zult twee boeren en twee alchemisten nodig hebben om de operatie te laten slagen.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9536] = {n:"Transgenesis Rol",t:24,d:"Deze rol activeert de effecten van het Transgenesis drankje als het op granen gegoten wordt.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9537] = {n:"Erzal\'s Zegening",t:24,d:"Dit boek bevat niet alleen verdraaide verhalen van lopende en pratende doden, het bevat ook de beschrijving van het ritueel waarmee je een ziel terug dwingt in zijn lichaam.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9538] = {n:"x",t:24,d:"",ep:0,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[9539] = {n:"Badge van de Renegade Baas",t:24,d:"Je hebt deze badge afgenomen van een Bontariaanse renegade die het niet verdiende.",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9540] = {n:"De Godfather\'s Cape",t:17,d:"Deze cape beschermt je nek tegen het winterweer en je achterkant tegen slagen van Iops...",ep:0,g:163,l:48,wd:true,fm:true,w:10,s:126,p:6200};
