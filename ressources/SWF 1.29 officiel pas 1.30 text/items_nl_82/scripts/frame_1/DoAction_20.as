I.u[9523] = {n:"Super `SRVT:MERCENARY_SHORT_NAME` Missie Beloning",t:14,d:"Deze super rol getuigt dat je een super beloning verdient voor je toewijding aan het completeren van de `SRVT:MERCENARY_SHORT_NAME` missie.",ep:0,g:6,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
