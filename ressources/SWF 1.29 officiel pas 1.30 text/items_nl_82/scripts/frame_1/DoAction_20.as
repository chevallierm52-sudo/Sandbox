I.u[9379] = {n:"Choc\' Box",t:42,d:"Je zou deze kleine doos aan degene moeten schenken van wie je houdt. Als je iemand bent die iedereen haat kun je hem net zo goed opeten!",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9380] = {n:"Hart-vormig Elfjeswerk",t:74,d:"Dit speciale Elfjeswerk zal wat liefde in de Wereld van de sterken verspreiden, maar zal je in de Wereld van liefde douchen met knuffels.",ep:1,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[9381] = {n:"Glutoblop Bloem",t:35,d:"De Glutoblop is zo hongerig dat hij bijna zijn eigen bloemen zou eten. Gelukkig komen zijn snibbige klauwen altijd net op tijd dwalende avonturiers tegen.",ep:5,g:7,l:50,wd:true,fm:true,w:1,p:1};
I.u[9382] = {n:"Blopshroom Bloem",t:35,d:"Deze bloem is van het hoofd van een Blopshroom geplukt. Maak je geen zorgen, de Blopshroom vond hem toch al niet mooi.",ep:5,g:8,l:40,wd:true,fm:true,w:1,p:1};
I.u[9383] = {n:"Trunkiblop Wortel",t:98,d:"De Trunkiblop heeft grote dikke wortels die alles aantrekken wat avonturiers op de grond gooien.",ep:5,g:1,l:40,wd:true,fm:true,w:1,p:1};
I.u[9384] = {n:"Koninklijke Kersen Blop Bloem",t:35,d:"Als deze bloem niet koninklijk was geweest, had je hem al lang weggegooid.",ep:5,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[9385] = {n:"Koninklijke Coco Blop Bloem",t:35,d:"Als deze bloem niet koninklijk was geweest, had je hem al lang weggegooid.",ep:5,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[9386] = {n:"Koninklijke Indigo Blop Bloem",t:35,d:"Als deze bloem niet koninklijk was geweest, had je hem allang weg gegooid.",ep:5,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[9387] = {n:"Koninklijke Pippin Blop Bloem",t:35,d:"Als deze bloem niet koninklijk was geweest, had je hem allang weg gegooid.",ep:5,g:10,l:100,wd:true,fm:true,w:1,p:1};
I.u[9388] = {n:"Koninklijke Blop Blad",t:36,d:"Als dit blad gedroogd, gerold en gerookt wordt, kan hij hallucinaties oproepen bij de zwakste avonturiers, net als een onverbiddelijke aandrang van... opluchting. Een overdosis kan een snelle dood veroorzaken.",ep:5,g:13,l:100,wd:true,fm:true,w:1,p:1};
I.u[9389] = {n:"Koninklijke Regenboog Blad",t:36,d:"Dit blad voedt zich met de grijze materie van de Koninklijke Regenboog Blop. Gelukkig is hij niet te gierig!",ep:5,g:14,l:150,wd:true,fm:true,w:1,p:1};
I.u[9390] = {n:"",t:113,d:"",ep:0,g:211,l:1,wd:false,fm:true,w:0,p:1};
I.u[9391] = {n:"Koninklijke Regenboog Blop Bloem",t:35,d:"Deze bloem was verborgen in de schedel doos van de Koninklijke Regenboog Blop. Het dichtte alle gaten in het geheugen van het beest.",ep:5,g:13,l:150,wd:true,fm:true,w:1,p:1};
I.u[9394] = {n:"Mitch Shroom",t:16,d:"Dit hoofddeksel geeft Mitcho-soort stijl aan een ieder die hem draagt. Het heeft wel een sterke geur van kreupelhout waar je vrienden ook prima zonder kunnen.",ep:22,g:222,l:152,wd:true,fm:true,w:15,p:45782};
I.u[9395] = {n:"Koninklijke Bloprown",t:16,d:"Dit hoofddeksel was een aantal jaren lang gedragen door Kuri zelf. Totdat ze besloot om te stoppen met het dragen van waardeloze hoofddeksels.",ep:22,g:223,l:161,wd:true,fm:true,w:10,p:47750};
I.u[9396] = {n:"Zawooin\'s Zegel",t:9,d:"Het gerucht gaat dat dit item, genaamd \'Zawooin Ling\' in de eeuwenoude taal van de Lenalds, gesmeed was in een vulkaan onder Vuur Pandala door Zeewon, een mysterieuze Wabbit.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PX=3|PX=5",p:1};
I.u[9398] = {n:"",t:24,d:"",ep:2,g:27,l:1,wd:false,fm:true,w:0,p:1};
I.u[9399] = {n:"",t:24,d:"",ep:16,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9400] = {n:"Kaart van Gisgoul Dorp",t:24,d:"Deze kaart is oud en gekreukeld... niet makkelijk om er iets vanaf te lezen, inclusief de locatie van het ritueel. Maar je bestudeert de kaart van dichterbij en denkt eindelijk te weten waar de viering plaats zal vinden: in het noorden van het geruïneerde Gisgoul Dorp, vlakbij de bergen.",ep:16,g:6,l:1,wd:false,fm:true,w:0,p:1};
I.u[9401] = {n:"Bworker Vel",t:59,d:"Deze huid heeft oorlogen doorstaan en is er ongedeerd uitgekomen. Het zou nou erg nuttig moeten zijn nou hij van zijn vorige eigenaar verwijderd is.",ep:14,g:9,l:400,wd:true,fm:true,w:10,p:1};
I.u[9402] = {n:"Bijers",t:11,d:"De kleine vleugels die verbonden zijn aan deze slapers geven de stinkende voeten wat lucht... Maar wees voorzichtig, gebruik ze niet om Gobbowl mee te spelen... Gobballs vinden het waarschijnlijk niet zo fijn om iets in hun achterkant gestoken te krijgen...",ep:1,g:128,l:34,wd:true,fm:true,w:5,s:112,p:3200};
I.u[9403] = {n:"Hamm\'Ornet",t:7,d:"De kleine vleugels die vastgemaakt zijn aan deze hamer maken hem lichter en makkelijker hanteerbaar... Hij kan zelfs uit zichzelf vliegen om jou om het hoofd te slaan terwijl je slaapt... wat een grappig klein ding!",ep:1,g:68,l:27,wd:true,fm:true,w:12,an:15,e:[10,4,1,1,45,50,false,false],c:"CI>17&CC>5",s:112,p:2100};
I.u[9404] = {n:"Bijachtige Cape",t:17,d:"De angel aan het einde van de cape voorkomt dat je vijanden je een trap op je achterste geven! Echter, je kunt ook niet gaan zitten zonder je pijn te doen...",ep:1,g:155,l:33,wd:true,fm:true,w:5,s:112,p:3000};
I.u[9405] = {n:"Bijen Hoed",t:16,d:"Met het dragen van deze hoed moet je je bewust zijn dat je slagen van een Moskitoverdelger riskeert...",ep:1,g:224,l:37,wd:true,fm:true,w:9,s:112,p:3825};
I.u[9406] = {n:"Piggibits",t:16,d:"Deze oren van Armzalig Zwijn zijn nog warm en essentieel om Armzalige Zwijnen die je passeren te verleiden. Niet lachen, je hebt nog niet uitgevonden hoe eenzaam je kunt worden op het Platteland van Amakna.",ep:1,g:225,l:36,wd:true,fm:true,w:2,s:113,p:3600};
I.u[9407] = {n:"Kurk Mantel",t:17,d:"Sommige mensen noemen deze cape “Mantel Trekker” en hebben een vreselijke hekel aan iedereen die hem anders noemt. Het maakt niet uit hoe je de cape noemt, één ding is zeker, je kunt er geen flessen mee openen!",ep:1,g:156,l:37,wd:true,fm:true,w:3,s:113,p:3800};
I.u[9408] = {n:"Armzalige Ring",t:9,d:"Deze ring verandert je in een Armzalig Zwijn, wat je beste vrienden zou moeten bevredigen.",ep:1,g:162,l:40,wd:true,fm:true,w:3,s:113,p:500};
I.u[9409] = {n:"Lardine Riem",t:10,d:"Deze kleine staart in de vorm van een kurkentrekker zal de mensen om je heen jaloers maken.",ep:1,g:149,l:39,wd:true,fm:true,w:1,s:113,p:4225};
I.u[9410] = {n:"Hoed van Oosters Hout",t:16,d:"Deze hoed, niet zo trendy als de Clint maar veel eleganter, laat anderen zien hoe mondain je bent.",ep:1,g:226,l:40,wd:true,fm:true,w:25,s:114,p:1000};
I.u[9411] = {n:"Cape van Oosters Hout",t:17,d:"Deze cape beschermt je rug tegen zonnebrand. Maar wees voorzichtig, hij komt niet bij elke avonturier tot de onderkant.",ep:1,g:157,l:36,wd:true,fm:true,w:10,s:114,p:6500};
I.u[9412] = {n:"Riem van Oosters Hout",t:10,d:"De draagband van deze riem zit er strak omheen gebonden... zo strak gebonden dat je hem niet af kunt krijgen. Het zal enkel snelwegjongens imponeren die je tegen komt.",ep:1,g:150,l:32,wd:true,fm:true,w:10,s:114,p:3000};
I.u[9413] = {n:"Laarzen van Oosters Hout",t:11,d:"De sporen op deze laarzen laten je jouw Dragokalkoen snijden als je beslist dat het tijd is om hem op te eten.",ep:1,g:129,l:30,wd:true,fm:true,w:10,s:114,p:2700};
I.u[9414] = {n:"Citroen Hoed",t:16,d:"Je hoofd past met gemak deze enorme geleegde citroen en de kleine pit daarbinnen zal zich thuis voelen!",ep:1,g:227,l:30,wd:true,fm:true,w:9,s:115,p:2600};
I.u[9415] = {n:"Citrus Cape",t:17,d:"Deze cape was van de schillen van veel verscheidene citrus vruchten gemaakt. Het is een mooie, verfrissende cape, maar helaas gloeit hij niet in het donker.",ep:1,g:158,l:30,wd:true,fm:true,w:8,s:115,p:2525};
I.u[9416] = {n:"Zest Ring",t:9,d:"Als je water smaakloos wordt, steek dan deze ring om je vinger, steek je vinger in het glas en roer het energiek tot hij van je hand afgaat. Hier! Een heerlijke bloedsinaasappel en citroen mix... En je vinger? Je kunt niet alles hebben hoor...",ep:1,g:163,l:20,wd:true,fm:true,w:4,s:115,p:1300};
I.u[9417] = {n:"Strawaff",t:4,d:"Heb je ooit gedroomd dat je het bloed van je vijand dronk terwijl je ze versloeg? Deze staf is voor jou perfect!",ep:1,g:81,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",s:115,p:2900};
I.u[9418] = {n:"Crist\'Hat\'Lin",t:16,d:"De volgende kapper die je haren knipt zal geluk hebben als hij zijn kam niet breekt.",ep:1,g:228,l:22,wd:false,fm:true,w:12,s:125,p:1525};
I.u[9451] = {n:"Cristalline Cape",t:17,d:"Dit grote stuk cristal kan gebruikt worden als een onbuigzame cape, maar het maakt je niet sterker. Echter, het volgende monster dat je komt verslinden zal hierdoor stikken.",ep:1,g:159,l:21,wd:false,fm:true,w:10,s:125,p:1400};
I.u[9452] = {n:"Cristall\'Ring",t:9,d:"Deze ring zal je vinger doen stralen.",ep:1,g:164,l:30,wd:false,fm:true,w:4,s:125,p:2600};
I.u[9453] = {n:"Cristalline Riem",t:10,d:"Met deze riem om zal niemand ooit je meer durven te knijpen, uit angst dat hun vingers afgesneden worden.",ep:1,g:151,l:48,wd:false,fm:true,w:30,s:125,p:6075};
I.u[9454] = {n:"Bobblamulet",t:1,d:"Dit amulet kan als slab gebruikt worden voor jong en oud.",ep:1,g:140,l:27,wd:false,fm:true,w:5,s:124,p:2200};
I.u[9455] = {n:"Bobblering",t:9,d:"Je kunt deze ring dragen als teenring als je je voetengeur moet doven.",ep:1,g:165,l:30,wd:false,fm:true,w:4,s:124,p:2600};
I.u[9456] = {n:"Bobblecape",t:17,d:"Als je vindt dat je achterkant nooit genoeg aandacht heeft gehad kun je deze cape dragen, die het mooi maakt en de aandacht van iedereen trekt.",ep:1,g:160,l:33,wd:false,fm:true,w:5,s:124,p:3075};
I.u[9457] = {n:"Bobbl\'Hat",t:16,d:"Deze hoed ruikt naar Demonische Rozen, waardoor je van je luizen af zult komen, en elke andere parasiet die op je hoofd zit.",ep:1,g:229,l:33,wd:false,fm:true,w:5,s:124,p:3000};
I.u[9458] = {n:"",t:24,d:"",ep:16,g:3,l:1,wd:false,fm:true,w:0,p:1};
I.u[9459] = {n:"Wens Lijst voor Santa Jaws",t:24,d:"Santa Jaws krijgt een verdraaide steek van plezier als hij de wenslijst van een kind die hij verslonden heeft leest.",ep:1,g:41,l:1,wd:false,fm:true,w:0,p:0};
I.u[9460] = {n:"Pik Appel",t:24,d:"Dit is een Pokipik die nooit het daglicht zal zien. Schaam je je niet?",ep:1,g:123,l:1,wd:false,fm:true,w:0,p:0};
I.u[9461] = {n:"De Kim",t:16,d:"Er wordt gezegd dat de Kimbo deze pruik draagt om eer te betonen aan een knappe, perfect gebruinde jonge man die hij op zijn eiland ontmoette. Hij had zo\'n prachtige lach! Hoe dan ook, hij verbergt de belachelijke pruik onder zijn coco.",ep:22,g:230,l:196,wd:true,fm:true,w:10,p:60000};
I.u[9462] = {n:"Beschadigd Schild van Dardonakal",t:24,d:"Dit schild is gemaakt van een schaal van Dardondakal de witte draak, maar hij is beschadigd en nog niet eens af! Hij is bijna net zo nutteloos als jij..",ep:5,g:807,l:1,wd:false,fm:true,w:0,p:1};
I.u[9463] = {n:"Amunita",t:1,d:"Dit sieraad is zo krachtig dat het een Moskito zou kunnen vermoorden van 30 stappen afstand, als hij niet zo rook dat niks er dichtbij komt.",ep:23,g:141,l:189,wd:true,fm:true,w:10,s:107,p:58000};
I.u[9464] = {n:"Kraloherenhuis",t:1,d:"Dit enge amulet was lang verborgen in een afgelegen herenhuis. Toen hij nog leefde, droomde hij over de wereld en alle plekken die hij kon zien. Uiteindelijk was de enige plek die hij zien kon jouw nek. Arm klein ding!",ep:22,g:142,l:194,wd:true,fm:true,w:30,s:97,p:58411};
I.u[9465] = {n:"",t:76,d:"",ep:0,g:20,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9466] = {n:"Onafgemaakte Demonische Dofus",t:24,d:"Je bent op tijd aangekomen om de creatie van Dofus te stoppen. Het is een prachtig voorwerp, maar erg nutteloos. En je dacht dat je het aan je collectie kon toevoegen.",ep:14,g:737,l:1,wd:false,fm:true,w:0,p:1};
I.u[9467] = {n:"Kenteken van een Brakmaarse Agent",t:24,d:"Dit kenteken was gevonden in de grot waar de beschermer Maimane was aangevallen.",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9468] = {n:"Schop Emlaka",t:8,d:"Deze gevaarlijke schop zal jouw levenskracht, je jeugd, het water uit jouw lichaam en je geliefde Troofles stelen.",ep:22,g:51,l:191,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,35,50,false,false],c:"CC>450",p:58401};
I.u[9469] = {n:"Zwaard Indinz",t:6,d:"Opgebouwd met paddestoelen, dit zwaard is perfect om de darmen van je tegenstanders te infecteren.",ep:23,g:85,l:184,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,50,50,false,false],c:"CC>300&CA>300",p:58456};
I.u[9471] = {n:"Gezonde Luvenby\'s Dag Hoed",t:16,d:"Voor alle Luvenbys die naar hun zielsverwant zoeken is deze elegante maar simpele hoed een teken van herkenning. Deze magische hoed kan enkel door ongehuwde avonturiers gedragen worden. Zo weet je hoe je iemands hart moet veroveren.",ep:1,g:231,l:1,wd:false,fm:true,w:1,c:"PR=0",p:1};
I.u[9472] = {n:"Passie Shigekax",t:42,d:"Dit zoete snoepje, bekend om zijn aphrodisische stevigheid, is het perfecte kado voor je geliefden.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9473] = {n:"",t:94,d:"",ep:0,g:14,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9474] = {n:"Sublieme Riskante Ziel Steen",t:83,d:"Deze rune geeft je een goede kans om ongelooflijk krachtige zielen te vangen.",ep:0,g:17,l:1,wd:false,fm:true,w:1,tw:true,p:23000};
I.u[9475] = {n:"Sublieme Ziel Steen",t:83,d:"Deze rune geeft je een goede kans om ongelooflijk krachtige zielen te vangen.",ep:0,g:16,l:1,wd:false,fm:true,w:1,tw:true,p:50000};
I.u[9476] = {n:"Sublieme Gelukkige Ziel Steen",t:83,d:"Deze rune geeft je een goede kans om ongelooflijk krachtige zielen te vangen.",ep:0,g:18,l:1,wd:false,fm:true,w:1,tw:true,p:75000};
