I.u[9209] = {n:"Donker Haagbeukhout",t:24,d:"Dit Haagbeuk Hout is vies gemaakt door de vuile aanraking van een Donkere Treechnid. Het kan nou gebruikt worden om demonische lemmets te maken of andere kwaadaardige wapens.",ep:9,g:176,l:1,wd:false,fm:true,w:0,p:1};
