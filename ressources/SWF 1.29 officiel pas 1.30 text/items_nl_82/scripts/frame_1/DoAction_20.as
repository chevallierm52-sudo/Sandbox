I.u[9122] = {n:"Kersen Blop Ring",t:9,d:"Wanneer het op de Bloppe manier zich om je vinger heen wikkelt, is het onmogelijk om je van deze ring te ontdoen.",ep:5,g:149,l:50,wd:true,fm:true,w:10,s:98,p:4000};
I.u[9123] = {n:"Pippin Blop Ring",t:9,d:"Wanneer het zich op de Blopse manier om je vinger wikkelt is het onmogelijk om van deze ring af te komen.",ep:5,g:150,l:50,wd:true,fm:true,w:10,s:99,p:1000};
I.u[9124] = {n:"Coco Blop Ring",t:9,d:"Wanneer het op de Bloppe manier zich om je vinger heen wikkelt, is het onmogelijk om je van deze ring te ontdoen.",ep:5,g:151,l:50,wd:true,fm:true,w:10,s:100,p:1000};
I.u[9125] = {n:"Indigo Blop Ring",t:9,d:"Wanneer het op de Bloppe manier zich om je vinger heen wikkelt, is het onmogelijk om je van deze ring te ontdoen.",ep:5,g:152,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9126] = {n:"Koninklijke Kersen Blop Ring",t:9,d:"Kroula had een plan. Hij wilde deze ring om zijn grote teen doen, om Blops aan zijn voeten te laten likken en zo liters Koninklijk Blop sap te verzamelen. Nou ja, de ring paste niet.",ep:5,g:153,l:80,wd:true,fm:true,w:10,s:102,p:15000};
I.u[9127] = {n:"Koninklijke Pippin Blop Ring",t:9,d:"Kroula had een plan. Hij zou deze ring om zijn grote teen doen zodat de Blop zijn voeten zouden likken en daarmee liters Koninklijke Blop sap verzamelen. Nou ja, de ring paste niet.",ep:5,g:154,l:80,wd:true,fm:true,w:10,s:103,p:15000};
I.u[9128] = {n:"Koninklijke Coco Blop Ring",t:9,d:"Kroula had een plan. Hij zou deze ring om zijn grote teen doen zodat de Blop zijn voeten zouden likken en daarmee liters Koninklijke Blop sap verzamelen. Nou ja, de ring paste niet.",ep:5,g:155,l:80,wd:true,fm:true,w:10,s:104,p:15000};
I.u[9129] = {n:"Koninklijke Indigo Blop Ring",t:9,d:"Kroula had een plan. Hij wilde deze ring om zijn grote teen doen, om Blops aan zijn voeten te laten likken en zo liters Koninklijk Blop sap te verzamelen. Nou ja, de ring paste niet.",ep:5,g:156,l:80,wd:true,fm:true,w:10,s:105,p:15000};
I.u[9130] = {n:"Ougaamulet",t:1,d:"Deze ruige kopie van de Grote Ougaa wordt om de nek gedragen... Een hongerige aanstaring en een goed onderhouden baard zijn essentieel.",ep:23,g:127,l:181,wd:true,fm:true,w:15,s:118,p:58000};
I.u[9131] = {n:"Colette Ring",t:9,d:"Een jonge Craette genaamd Colette verloor ooit haar hoofd in Eltneg Bos. De arme meid stond in de weg van Brouce Boulgoures bijl welke hij gooide toen hij dacht dat ze een gigantische varen was. Gelukkig overleefde ze het niet, ze zou dood zijn gegaan als ze hoorde dat ze er uit zag als een gigantische varen.",ep:23,g:146,l:188,wd:true,fm:true,w:10,s:119,p:57950};
I.u[9132] = {n:"Tash Ring",t:9,d:"Zijn je vingers te jong om bij de goeie verenigingen te kunnen horen? Zijn ze nerveus bij meisjes? Doe deze ring om, het voegt wat jaren aan ze toe en is wonderbaarlijk voor je zelfvertrouwen.",ep:23,g:147,l:180,wd:true,fm:true,w:10,s:121,p:57822};
I.u[9133] = {n:"Fungal Ring",t:9,d:"Zwaai met je vingers voor de neus van al je vijanden die allergisch zijn voor paddenstoelen. Basiselementen voor een snel gevecht.",ep:23,g:148,l:186,wd:true,fm:true,w:10,s:107,p:56000};
I.u[9134] = {n:"Beddy Boog",t:2,d:"Deze boog is gemaakt van scherpe, dunne en flexibele mesjes die vaker gebruikt worden om bedden te maken dan dodelijke wapens. Nu worden ze gebruikt om een soort permanente slaap te brengen. Wat een toeval.",ep:23,g:61,l:187,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>300&CI>300",p:58421};
I.u[9135] = {n:"Wanderelle",t:3,d:"Deze trompet-vormige fungal wand werd lang geleden gebruikt om de ronddolende minstreel te roepen. Lon Lemon  naar het toneel van het gevecht. Toen hij begon te zingen ging iedereen die zijn oren niet bedekt had dood ter plekke. Toen zijn ondraaglijke lied en dans man te populair werden blockten de goden de trompet en veranderden het in een relatief onschadelijke wand.",ep:23,g:66,l:184,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,45,50,false,true],c:"CI>300&CA>300",p:54284};
I.u[9136] = {n:"Mush Mishish Staf",t:4,d:"De drie punten van deze staf kunnen de delen van het Plasmogrine kado in de quadramentale bries aantrekken. Om dit te doen, moet je voorzichtig aan de punten van de stok likken, ze verbinden met de handen van een omgekeerde Xelor klok, tot zestig tellen (probeer zes als je een Iop bent) en druk je lagere wangen in. Je zult een fifty fifty kans hebben om een donder bout te maken... en om je vijanden in griezelige Kirballs te veranderen.",ep:23,g:80,l:191,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>200&CC>200&CI>100",p:55000};
I.u[9137] = {n:"Moes Knipeers",t:5,d:"Deze messen werden gebruikt om de voeten van koningen en koninginnen af te schrapen, om ze te verlichten van de wormen en fungi die aan iedereen met een beetje macht kleven.",ep:23,g:69,l:187,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,30,50,false,false],c:"CA>450",s:119,p:57000};
I.u[9138] = {n:"Kanni Lemmet",t:19,d:"De drie lemmets op deze bijl zijn vele jaren gebruikt om ham en kaas te snijden, drie keer sneller dan normaal. Als je een krijger rond ziet lopen met eentje, ren dan zo snel mogelijk weg... het is alsof je een kannibaal hebt gezien,",ep:23,g:51,l:176,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,50,50,false,false],c:"CC>450",s:120,p:54854};
I.u[9139] = {n:"Ta Laarzen",t:11,d:"Deze teenloze laarzen zijn perfect om mensen die over verboden dingen spreken een lesje te leren.",ep:23,g:115,l:175,wd:true,fm:true,w:10,s:120,p:54852};
I.u[9140] = {n:"Spore Laarzen",t:11,d:"In tegenstelling tot populaire misvattingen zijn de gaten in deze schoenen niet om  je voeten te laten ademen, maar om de groei van voetschimmels te laten ontsnappen om zo de voeten van andere avonturiers te infecteren.",ep:23,g:116,l:181,wd:true,fm:true,w:15,s:121,p:57000};
I.u[9141] = {n:"Ragoat",t:17,d:"Als deze doek niet zo vies was, zou het een geweldig tafelkleed zijn. Maak je geen zorgen, je kunt er altijd de vaat mee drogen als je gasten niet kijken.",ep:23,g:154,l:181,wd:true,fm:true,w:10,s:119,p:58000};
I.u[9142] = {n:"Dodelijke Nacht Cape",t:17,d:"Nog een glas voor onderweg? Nou ja, wegen zijn lang en nachten zijn kort, dus deze cape wordt normaliter gebruikt om de barvliegen warm te houden als ze klaar zijn met de oneindige rondes van nachtelijke sterke verhalen. Het zal hun dood worden uiteindelijk.",ep:23,g:150,l:190,wd:true,fm:true,w:10,s:107,p:60000};
I.u[9143] = {n:"Stringsecticide",t:10,d:"Zoals zijn naam suggereert, vermoordt deze string alle vliegen die te dicht bij je zoete plekjes komt. Een klein advies: trek hem nooit van een geliefde af met je tanden.",ep:23,g:132,l:192,wd:true,fm:true,w:20,s:107,p:48000};
I.u[9144] = {n:"Fungas Riem",t:10,d:"Hoe kun je kruis fungus ontwijken? Zorg er voor dat de fungus ergens waar het niet zo privé is komt... je heupen! Met deze riem los je niks op, je verplaatst het probleem alleen ergens anders heen.",ep:23,g:133,l:177,wd:true,fm:true,w:10,s:121,p:58444};
I.u[9145] = {n:"Plak van Kreupelhout",t:10,d:"Neem een Olm, trek de schors eraf, laat het een paar maanden trekken in een modderpoel, bedek het met fungal infecties, stop hem onder je bed voor een week terwijl je slaapt, bast hem regelmatig met Blop vet. Alles wat je moet weten om een Olm riem te maken die stinkt. Ben je nou blij?",ep:23,g:134,l:179,wd:true,fm:true,w:10,s:120,p:68420};
I.u[9146] = {n:"Ougaariem",t:10,d:"Het etiket op deze riem zegt... \'Sorry, maar als je een manier zoekt om Ougaa krachten te vinden, is deze riem niet voor jou.\' Geweldig, niet waar?",ep:23,g:135,l:185,wd:true,fm:true,w:10,s:118,p:56000};
I.u[9147] = {n:"Mush Ombrero",t:16,d:"Neem een Dora, bedek het met Gobball spuug en Iop zweet, laat het een paar weken smoren en je hebt een aardig idee van de bedwelmende effecten van de Mush Umbrero. Probeer weg te blijven van zwaar apparatuur terwijl je het draagt. Of eigenlijk, blijf maar bij alles wat zwaar is weg.",ep:23,g:221,l:185,wd:true,fm:true,w:10,s:119,p:48521};
I.u[9148] = {n:"Koninklijke Regenboog Blop Ring",t:9,d:"In plaats van het verminderen van onzuiver Blop sap ging Shika Ingalsse door met haar oogst in haar dronken bui. Op een dag, toen ze stommelend en struikelend door de gouden velden liep, landde Shika op deze ring. Wie zei dat onzuiver Blop sap gematigd moest worden?",ep:5,g:157,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9149] = {n:"Kersen Amublop",t:1,d:"Toen Lorkos begon aan zijn tocht naar de Minotorors Labyrinth was zijn Amublop omdoen het eerste wat hij deed. Niemand is ooit te weten gekomen waarom.",ep:5,g:128,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9150] = {n:"Pipin Amublop",t:1,d:"Toen Lorkos aan zijn reis naar Minotorors Labyrinth begon, was het eerste wat hij deed zijn Amublop om doen. Niemand heeft ooit ontdekt waarom/",ep:5,g:129,l:50,wd:true,fm:true,w:10,s:99,p:1000};
I.u[9151] = {n:"Coco Amublop",t:1,d:"Toen Lorkos aan zijn reis naar Minotorors Labyrinth begon, was het eerste wat hij deed zijn Amublop om doen. Niemand heeft ooit ontdekt waarom/",ep:5,g:130,l:50,wd:true,fm:true,w:10,s:100,p:1000};
