I.u[9166] = {n:"Koninklijke Regenboog Bloopts",t:11,d:"Sommige mensen laten het gras groeien onder hun voeten. Met deze laarzen heb je genoeg gebladerte voor vier bruiloften en een begrafenis",ep:5,g:125,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9167] = {n:"Kersen Blop Riem",t:10,d:"Achter de gekke naam zit een riem. Een riem waar we niet veel over weten. Zijn originele ontwerp en zijn magisch vermogen om de ergste love-handles bekend in de wetenschap te verbergen, garanderen dat dit een favoriet is bij zelfbewuste mannen van middelbare leeftijd.",ep:5,g:136,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9168] = {n:"Pippin Blop Riem",t:10,d:"Achter de gekke naam zit een riem. Een riem waar we niet veel over weten. Zijn originele ontwerp en zijn magisch vermogen om de ergste love-handles bekend in de wetenschap te verbergen, garanderen dat dit een favoriet is bij zelfbewuste mannen van middelbare leeftijd.",ep:5,g:137,l:50,wd:true,fm:true,w:10,s:99,p:1000};
