I.u[9365] = {n:"Slaap Rol",t:24,d:"Deze rol is krachtig genoeg om wat dan ook te laten slapen. Rip van Winkle zweerde hierbij.",ep:16,g:768,l:1,wd:false,fm:true,w:0,p:1};
I.u[9366] = {n:"Roze Tutu",t:10,d:"Deze roze tutu is ideaal om je kleine achterwerk te laten zien tijdens de Nieuwe Jaar\'s festivals. Gemaakt van voorouderlijk katoen en rekkend Spons Mob moes, zacht en comfortabel met een ristelende rok zou dit de eerste tutu uit een lange lijn van tutu\'s kunnen zijn voor een toekomstige ster danser.",ep:22,g:148,l:49,wd:true,fm:true,w:5,p:300};
I.u[9367] = {n:"Divad Ring",t:24,d:"Dit is de ring die je van Divad Dleifrepok hebt gestolen. Ze zeggen dat het zijn carrière als illusionist heeft geholpen... behoorlijk nutteloos voor jou dus.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9368] = {n:"Shush\'s Hangertje",t:24,d:"Dit is het hangertje die je van Shush Tercesasti hebt gestolen. Je hebt geen idee wat het nut ervan is.",ep:16,g:41,l:1,wd:false,fm:true,w:0,p:1};
