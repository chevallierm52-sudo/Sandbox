I.u[9043] = {n:"Mega Aanval Drankje",t:14,d:"Dit drankje maakt je zo kwaad dat je automatisch vijanden aanvalt die te dichtbij komen.",ep:0,g:35,l:1,wd:false,fm:true,w:1,c:"Pg>21,4",u:true,p:10};
I.u[9044] = {n:"Iop Vermommings Drankje",t:14,d:"Dit drankje maakt het mogelijk de gedaante van je keuze aan te nemen. Let op! Je moeder zou zo maar eens de politie kunnen bellen als ze je zo aantreft in je bed de volgende ochtend!",ep:0,g:43,l:1,wd:false,fm:true,w:1,c:"Pg>10,3",u:true,p:10};
