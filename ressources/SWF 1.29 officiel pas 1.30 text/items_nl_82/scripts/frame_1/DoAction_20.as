I.u[9162] = {n:"Koninklijke Kersen Bloopts",t:11,d:"Zeg het woord Bloopts tien keer snel terwijl je in cirkels ronddraait. Nu weet je hoe het voelt om een Iop te zijn.",ep:5,g:121,l:80,wd:true,fm:true,w:10,s:102,p:16000};
I.u[9163] = {n:"Koninklijke Pippin Bloopts",t:11,d:"Zeg het woord Bloopts tien keer snel terwijl je rondjes draait. Nu weet je hoe het voelt om een Iop te zijn.",ep:5,g:122,l:80,wd:true,fm:true,w:10,s:103,p:16000};
I.u[9164] = {n:"Koninklijke Coco Bloopts",t:11,d:"Zeg het woord Bloopts tien keer snel terwijl je in cirkels ronddraait. Nu weet je hoe het voelt om een Iop te zijn.",ep:5,g:123,l:80,wd:true,fm:true,w:10,s:104,p:16000};
