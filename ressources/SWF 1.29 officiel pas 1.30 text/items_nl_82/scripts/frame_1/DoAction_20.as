I.u[9156] = {n:"Koninklijk Indigo Amublop",t:1,d:"Deze Amublop kost veel meer om te maken dan een ordinaire Amublop, maar bekijk het rooskleurig... het zal ook meer opleveren als je het verkoopt, vooral als je dumpt bij een Astrubiaan.",ep:5,g:135,l:80,wd:true,fm:true,w:10,s:105,p:15800};
I.u[9157] = {n:"Koninklijke Regenboog Amublop",t:1,d:"Als ze geen hopen van toevoegingen en kunstmatige kleurstoffen hadden toegevoegd aan deze gelei, zou er geen smaak of kleur aan zitten. Hoe leuk zou dat zijn geweest?",ep:5,g:136,l:90,wd:true,fm:true,w:10,s:106,p:21000};
I.u[9158] = {n:"Kersen Bloopts",t:11,d:"Geeft het een raar gevoel aan je mond wanneer je de naam van dit voorwerp zegt? Laat me je dit vertellen, als je face to face staat met een straatweg overvaller die je om je \'Boot...Bloops...Bloo...\' vraagt, heb je net genoeg tijd om weg te vluchten terwijl hij nadenkt hoe hij het woord uit moet spreken. Stop dus met klagen.",ep:5,g:117,l:50,wd:true,fm:true,w:10,s:98,p:1000};
