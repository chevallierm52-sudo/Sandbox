I.u[9170] = {n:"Indigo Blop Belt",t:10,d:"Achter de gekke naam zit een riem. Een riem waar we niet veel over weten. Zijn originele ontwerp en zijn magisch vermogen om de ergste love-handles bekend in de wetenschap te verbergen, garanderen dat dit een favoriet is bij zelfbewuste mannen van middelbare leeftijd.",ep:5,g:139,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9171] = {n:"Koninklijke Kersen Blop Riem",t:10,d:"De kleinste bluesman op de wereld is de blues voor deze riem aan het spelen op de kleinste gitaar op de wereld. De gesp is verloren. Als riemen konden huilen, zou deze nooit ophouden met snotteren.",ep:5,g:140,l:80,wd:true,fm:true,w:10,s:102,p:16000};
I.u[9172] = {n:"Koninklijke Pippin Blop Riem",t:10,d:"De kleinste bluesman op de wereld is de blues voor deze riem aan het spelen op de kleinste gitaar op de wereld. De gesp is verloren. Als riemen konden huilen, zou deze nooit ophouden met snotteren.",ep:5,g:141,l:80,wd:true,fm:true,w:10,s:103,p:16000};
I.u[9173] = {n:"Koninklijke Coco Blop Riem",t:10,d:"De kleinste bluesman in de wereld speelt de blues voor zijn riem op de kleinste gitaar in de wereld. De gesp is verloren. Als riemen konden huilen, zou deze nooit ophouden met snotteren.",ep:5,g:142,l:80,wd:true,fm:true,w:10,s:104,p:16000};
I.u[9174] = {n:"Koninklijke Indigo Blop Riem",t:10,d:"De kleinste bluesman in de wereld speelt de blues voor zijn riem op de kleinste gitaar in de wereld. De gesp is verloren. Als riemen konden huilen, zou deze nooit ophouden met snotteren.",ep:5,g:143,l:80,wd:true,fm:true,w:10,s:105,p:16000};
I.u[9175] = {n:"Koninklijke Regenboog Blop Riem",t:10,d:"Als je deze riem compleet dichtmaakt, kun je je spijsverteringssysteem stoppen. Waarom je dat zou willen, is een andere vraag.",ep:5,g:144,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9176] = {n:"Day\'inda Mes",t:5,d:"Jon Lemon creëerde zijn laatste en beste lied toen hij verslagen werd door de Bworker en dit lemmet. Het gaat een beetje zo – \'Ik hoorde het nieuws vandaag oh boy, tienduizend gaten over mijn hele lijjjjf...\' Godzijdank dat de Bworker een goed verstand had om de woorden en muziek van het deuntje op te schrijven.",ep:22,g:70,l:182,wd:true,fm:true,w:10,an:13,e:[7,4,1,1,30,40,false,false],c:"CS>200&CI>150&CC>150&CA>150",s:108,p:58000};
I.u[9177] = {n:"Dikke-Buik Armband",t:9,d:"De drie punten van deze armband staan voor de drie grootste zwakheden van de Bworker: Dorst voor wraak, dorst voor overwinning, en, nou ja, dorst voor vocht.",ep:22,g:158,l:179,wd:true,fm:true,w:10,s:108,p:54000};
I.u[9178] = {n:"Neus Ring",t:9,d:"Deze ring is bedekt met kleine stukjes van neusvuil van de Bworker\'s shnoz. Het vieze beest gebruikt de scherpe punten om het perfecte peuteren te bereiken.",ep:22,g:159,l:179,wd:true,fm:true,w:10,s:109,p:54000};
I.u[9179] = {n:"Geheugen Amulet",t:1,d:"Toen een zekere Kapitein Chafer de Bworker voor de eerste keer ontmoette naam hij de vrijheid om te zeggen \'Wauw, is dat je achterkant of je gezicht?\' Sindsdien heeft niemand de goeie Kapitein of zijn beroemde ondergoed gezien. Dit amulet is ter gedachtenis aan hem gemaakt.",ep:22,g:137,l:184,wd:true,fm:true,w:10,s:108,p:52458};
I.u[9180] = {n:"Chee Cape",t:17,d:"Het verhaal gaat dat de Bworker deze cape naaide van Rushu\'s achterste huid. Het verhaal zou volkomen te geloven zijn als de Bworker zou weten hoe hij moest naaien.",ep:22,g:151,l:185,wd:true,fm:true,w:10,s:108,p:58000};
I.u[9181] = {n:"Batouta Helm",t:16,d:"In deze helm schuilen een behoorlijk aantal geheimen. Ooit was het een aardig, vriendelijk, rein beest, maar na zoveel jaren met gewelddadige avonturen met de Bworkers werd hij langzaam verbitterd en verdraaid. Toen ging hij dood.",ep:22,g:212,l:189,wd:true,fm:true,w:10,s:109,p:59000};
I.u[9182] = {n:"Doorboorde Laarzen",t:11,d:"Lang, lang geleden hield Danous Kwaide een grappen wedstrijd met de Bworker. Danous Kwaide begon. \'Wat is het verschil tussen jouw doorboorde laarzen en...\' Voor hij zijn zin kon eindigen had de Bworker een gat in het hoofd van Danous geboord.",ep:22,g:126,l:184,wd:true,fm:true,w:10,s:109,p:58000};
I.u[9183] = {n:"Biibl Riem",t:10,d:"Deze riem is gebruikt in het feest van de Dofus eieren welke het kado van zes eieren viert, zoals in de Biibl opgenomen, een oude tekst geschreven door een Bontaarse Meubelmaker. De meeste mensen verven gewone eieren om ze op Dofus eieren te laten lijken,geven ze aan iemand anders, maar sommigen gaan nog wat verder en dragen deze pijnlijke riem veertig nachten en dagen wat vooraf gaat aan het feest.",ep:22,g:145,l:181,wd:true,fm:true,w:10,s:109,p:58000};
I.u[9184] = {n:"Galgarion\'s Helm",t:16,d:"Ondanks verschijningen helpt deze helm je gehoor niet. Je kunt er wel verder mee kijken. Kijk uit voor sterke windvlagen, anders wordt je meegevoerd als een kleine veer.",ep:1,g:213,l:33,wd:true,fm:true,w:10,p:3000};
I.u[9185] = {n:"Goultard\'s Hoofddeksel",t:16,d:"Dit hoofddeksel zal je echt niet angstaanjagender maken en al helemaal niet krachtiger... En als je ook maar één moment denkt dat er naieve zielen zijn die jou voor Goultard aanzien, dan heb je het mis. Je vijanden kunnen je van mijlenver aan zien komen, dat is alles.",ep:1,g:214,l:30,wd:true,fm:true,w:10,p:2600};
I.u[9186] = {n:"Flash Gorgon\'s Riem",t:10,d:"Behalve zijn liefde voor porseleinen vazen weten we erg weinig van Flash Gorgone. De ene legende vertelt dat hij altijd zo\'n haast had dat hij zelfs een Tofu kon inhalen... Hij leerde zijn lesje toen hij op een morgen zo snel zijn bed uitklom dat zijn riem om zijn enkels gebonden zat. Zijn porselein collectie herinnert het zich als de dag van vandaag.",ep:1,g:146,l:48,wd:true,fm:true,w:30,p:6075};
I.u[9187] = {n:"Meester Zwarte Jack\'s Hoofddeksel",t:16,d:"Meester Zwarte Jack, de Eniripsa, was een toegewijde volgeling van mode. Zo veel zelfs dat hij na verloop van tijd zelfs steken kon geven aan echte mensen! Een vriend voor kleermakers, ze zeggen dat zijn inspiratie voor dit hoofddeksel een wrede kleermaker was die ooit een stam van Ouginaks genaamd de Macians uitroeide. Wat een geweldig verhaal.",ep:1,g:215,l:33,wd:true,fm:true,w:10,p:3075};
I.u[9188] = {n:"Pepitoo\'s Sombrero",t:16,d:"Deze sombrero is het laatste spoor dat is achterbleven van een donkere, heldhaftige Xelor die naar verluid ineens is verdwenen. Toen hij voor het laatst is gezien bracht hij een serenade aan zijn geliefde. Er wordt ook gezegd dat de broers van zijn verloofde meer van dit gebeuren af wisten. Er zijn nog steeds anderen die zeggen dat hij in een parallelle dimensie terecht is gekomen. Het mysterie lost zichzelf niet op.",ep:1,g:216,l:40,wd:true,fm:true,w:10,p:5000};
I.u[9189] = {n:"XVII\'s Hoorns",t:16,d:"Als je blijft proberen om de hoorns van je vijanden af te storen zul je degene zijn wiens hoofd op een zeef lijkt! XVII\'s hoorns hebben hetzelfde effect – ze zorgen ervoor dat je alles vergeet. Behalve etenstijd misschien.",ep:1,g:217,l:20,wd:true,fm:true,w:4,p:1300};
I.u[9190] = {n:"Cra\'s Verbrande Hoofddeksel",t:16,d:"Dit hoofddeksel is perfect voor Cra\'s die het niet erg vinden om er gemiddeld uit te zien. Wees voorzichtig, je zult er erg gek uit zien, stom zelfs. Normaal gesproken is dit hoofddeksel voor gepensioneerde strijders die een behoorlijk aantal hersencellen zijn verloren.",ep:1,g:218,l:35,wd:true,fm:true,w:5,p:10000};
I.u[9191] = {n:"Pym\'s Lemmet",t:6,d:"Dit lemmet was gestolen uit de etalage van een zwaardensmid winkel waar het enige jaren lag. Hopelijk is het nuttiger in jouw handen dan in de winkel, want we weten beide dat niemand er geld voor neer zal tellen.",ep:1,g:84,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[9192] = {n:"Fasstroïde Riem",t:10,d:"Hoe groter jouw liefdes handvaten zijn des te beter worden ze met deze aantrekkelijke en heerlijke riem.",ep:1,g:147,l:45,wd:true,fm:true,w:2,s:110,p:5600};
I.u[9193] = {n:"Tartamulet",t:1,d:"Dit amulet zal je doen herinneren aan de leuke tijden, de picknick dagen, de dagen voor je... hier eindigde.",ep:1,g:138,l:43,wd:true,fm:true,w:2,s:110,p:5000};
I.u[9194] = {n:"K Pet",t:16,d:"Luizen aten altijd je hoofd op. Niet meer, met deze nieuwe reeks van confectiehoofddeksels, hiermee onttrek je de gemene beesten van je hoofd. Nou zullen ze op je hoed grazen, net als een kudde kleine, witte koeien.",ep:1,g:219,l:44,wd:true,fm:true,w:2,s:110,p:5200};
I.u[9195] = {n:"K Cape",t:17,d:"Rol het op in fruitige jam, bedek het met gelei en weersta de verleiding om het te bespotten. Deze traktatie kun je het beste als zetpil gebruiken.",ep:1,g:152,l:45,wd:true,fm:true,w:2,s:110,p:5500};
I.u[9196] = {n:"Bonige Cape",t:17,d:"Deze cape, gemaakt van enorme koffiebonen, ruikt naar Pikoko\'s oksel. Het laat echt je bloed stromen voor een gevecht... en het is nog goedkoop ook.",ep:1,g:153,l:45,wd:true,fm:true,w:2,s:111,p:5500};
I.u[9197] = {n:"Bonige Hoed",t:16,d:"Gooi er twee suikerklontjes bij, verhit het snel en les je dorst met deze krachtgevende hoed.",ep:1,g:220,l:44,wd:true,fm:true,w:2,s:111,p:5200};
I.u[9198] = {n:"Bonige Ring",t:9,d:"Als je met smakeloos bier of koffie opgezadeld zit, probeer dan deze ring er een tijdje in te steken.",ep:1,g:160,l:45,wd:true,fm:true,w:2,s:111,p:5600};
I.u[9199] = {n:"Bonige Laarzen",t:11,d:"Kijk nou wat je hebt gedaan. Gewoon kijken. Koffiekoppen proberen stuk te maken met je laarzen... wat dacht je nou?",ep:1,g:127,l:43,wd:true,fm:true,w:2,s:111,p:5000};
I.u[9200] = {n:"Rol voor spreuk \'Bezwering van Chaferfu\'",t:75,d:"(Dubbelklikken om deze spreuk te leren)                            Deze rol leert je de spreuk \'Bezwering van Chaferfu\'.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[9201] = {n:"Wabbit Wol",t:75,d:"Deze Wol openbaawt 101 welbekende geheiwmen om jewzelf de wuige en gemawkelijke wegen van de Wa Wabbit te leren.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[9202] = {n:"Gore Meester\'s andere Ring",t:9,d:"De Gore Meester bleef, zelfs dood, items vervaardigen die in slechte staat waren met de kosmische ordes van het universum. Hij klaagde altijd dat hij zijn tweede ring te laat had gemaakt. Dat hij de hele wereld rond had kunnen reizen als hij hem maar eerder had gemaakt. Uiteindelijk heeft een demoon hem gestolen en verborg het in de dodelijke wereld voor zwakke avonturiers.",ep:1,g:9,l:1,wd:false,fm:true,w:1,p:0};
