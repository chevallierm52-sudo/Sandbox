I.u[10913] = {n:"Bevredigend Kwest cadeau",t:89,d:"Degene die dit cadeau inpakte, wist dat je dom genoeg zou zijn om te denken dat de inhoud ervan op een of andere manier beter zou zijn dan ze in werkelijkheid is.",ep:0,g:2,l:7,wd:false,fm:true,w:20,u:true,p:1};
I.u[10914] = {n:"Potentieel Overpowered Kwest cadeau",t:89,d:"Als je gelooft wat er is geschreven op dit etiket,heeft dit cadeau potentieel. Echter, zoals elke ervaren avonturier je zal zeggen - vertrouw nooit wat geschreven is op het etiket.",ep:0,g:2,l:8,wd:false,fm:true,w:30,u:true,p:1};
I.u[10915] = {n:"Harry Kwest\'s opdracht",t:24,d:"Harry Kwismas heeft de identiteitonthuld van een van de monsters die verantwoordelijk is voor de inbraak in de werkplaats van Vader Kwest. Als je niet in staat bent om het monster te verslaan binnen twee uur, kun je terugkeren naar Harry en krijg je een nieuwe opdracht.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10916] = {n:"Harry Kwest\'s felicitaties",t:24,d:"Harry Kwest waardeert uw overwinning. Kom terug over 24 uur, hij zal uw hulp opnieuw nodig hebben als alle dozen met cadeaus nog steeds niet zijn gevonden.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10917] = {n:"Klein cadeautje",t:24,d:"Deze kleine doos is afkomstig uit het atelier van Vader Kwest. Je wordt een echte held als je het terug naar hem brengt.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10918] = {n:"Cadeau",t:24,d:"Deze doos is afkomstig uit het atelier van Vader Kwest. Je wordt een echte held als je het terug naar hem brengt.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10919] = {n:"Groot cadeau",t:24,d:"Deze grote doos is afkomstig uit het atelier van Vader Kwest. Je wordt een echte held als je het terug naar hem brengt.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10920] = {n:"Kwest koekje",t:24,d:"Deze heerlijke, met de hand gemaakte koekjes werden gebakken met liefde. Het is jammer dat je ze niet kunt proeven.",ep:0,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[10921] = {n:"Minotoball\'s verzegelde cadeau",t:24,d:"Niemand weet wat dit cadeau bevat, Minotoball nam het geheim mee in zijn graf. Is het echt nodig om je eraan te herinneren dat dat jouw schuld was? Je moet er zeker doodziek van worden om het zo vaak te horen.",ep:0,g:715,l:1,wd:false,fm:true,w:0,p:1};
