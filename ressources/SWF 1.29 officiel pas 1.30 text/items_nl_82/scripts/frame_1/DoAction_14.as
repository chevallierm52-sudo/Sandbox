I.u[6436] = {n:"Ucibatev Bijl",t:19,d:"#1",ep:2,g:23,l:150,wd:false,fm:true,w:39,et:true,an:17,e:[6,6,1,1,40,30,false,true],c:"CS>120",p:151000};
I.u[6437] = {n:"Ikalugi Bijl",t:19,d:"#1",ep:2,g:21,l:150,wd:false,fm:true,w:21,et:true,an:17,e:[2,6,1,1,40,30,false,true],c:"CI>100&CW>7",p:151000};
I.u[6438] = {n:"Kreupele Stok",t:3,d:"Deze stok is gemaakt van zachte elementen, waardoor deze stok moeilijk te gebruiken is. Maar tijdens een gevecht bewijst deze stok zijn werkelijke kracht.",ep:5,g:33,l:85,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,70,false,true],c:"CI>85",p:8500};
I.u[6439] = {n:"Onechte Stok",t:3,d:"Deze onechte stok is het resultaat van een magische mix van bovennatuurlijke elementen. Dan weer angstaanjagend, dan weer kierewiet. Deze stok is typisch een symbool van instabiliteit.",ep:4,g:32,l:90,wd:true,fm:true,w:12,an:11,e:[10,4,2,3,20,20,false,false],c:"CI>90&CW>30",p:9000};
I.u[6440] = {n:"Harige Stok",t:3,d:"Deze stok is niet een platte hoop haren. Het hart van deze stok neemt magische olie op van verschillende bosjes en voegt ze samen. Hoe krankzinnig dit ook lijkt, het werkt !",ep:14,g:31,l:95,wd:true,fm:true,w:12,an:11,e:[5,3,2,5,40,40,false,true],c:"CW>40&CI>40",p:9500};
I.u[6441] = {n:"Maan Haren",t:54,d:"Deze haren voelen ongelooflijk zacht en warm als je ze aanraakt... net alsof ze nog in leven waren.",ep:12,g:656,l:200,wd:true,fm:true,w:2,p:10000};
I.u[6442] = {n:"Aga Dou Staf",t:4,d:"Altijd op zoek naar middelen om zijn vijanden de verrassen, zorgde de Sadida Aga Dou ervoor altijd een klein poppetje aan het uiteinde van zijn staf vast te maken. De jonge Iopettes storten zich erop om het poppetje te pakken te krijgen en sterven gespietst.",ep:14,g:31,l:81,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>80&CV>50",p:17000};
I.u[6443] = {n:"Vernieuwd Amulet",t:1,d:"Het is de beroemde en niet minder komische ambachtsman Yamato, onrechtvaardig veracht om zijn belachelijke boog, die als eerste het lef had om een amulet met zoveel effecten te betoveren, iets was sinds eeuwen voor onmogelijk werd gehouden.",ep:9,g:57,l:126,wd:true,fm:true,w:20,p:40000};
I.u[6444] = {n:"Turquois Amulet",t:1,d:"Dit amulet heeft dezelfde kleur als de beroemde Turquoise Dofus, en heeft geen enkel verband met de laatste, hetgeen het niet minder krachtig maakt. Zo zie je maar weer, uiterlijke schijn bedriegt niet altijd.",ep:9,g:58,l:63,wd:true,fm:true,w:10,p:10300};
I.u[6445] = {n:"Gebogen Boog",t:2,d:"Deze boog heeft een weloverwogen vorm, zijn ronding is werkelijk perfect. Men zegt dat de beeldhouwer van de boog als model de billen van een vrouwtjes Veelvraat heeft genomen.",ep:14,g:13,l:80,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>70&CC>50",p:16500};
I.u[6446] = {n:"Chiduc Boog",t:2,d:"Chiduc was een Bogen Snijder en stond bekend om zijn spraakprobleem. Hij was niet in staat de klank \"bo\" uit te spreken zonder er \"oge\" aan toe te voegen. Niettemin was hij een groot artiest.",ep:12,g:14,l:87,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,30,false,true],c:"CW>50&CA>80",p:19000};
I.u[6447] = {n:"Vergeetdrankje van Chaferfu",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de betovering voor het Bezwering van Chaferfu.",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6448] = {n:"Vergeetdrankje: \'Bezwering van Arachnee",t:43,d:"Met behulp van dit drankje vergeet je een niveau van de betovering voor de Bezwering van Arachnee.",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6449] = {n:"Raafcape",t:17,d:"Om op een schaduw te lijken, of je te vermommen als Meester Raaf om de meisjes te imponeren bij de uitgang van de Bakkerij voor het vallen van de nacht.",ep:1,g:54,l:45,wd:true,fm:true,w:26,s:8,p:1000};
I.u[6450] = {n:"Riem van de Geliefde van Ha",t:10,d:"De beroemde schoenmaakster Ha had een geliefde die erom bekend stond dat hij haar op het laatste moment in de steek liet. Maar verblind door de liefde, heeft ze hem toch deze schitterende riem gegeven als teken van hun geheime band.",ep:14,g:57,l:121,wd:true,fm:true,w:20,p:37255};
I.u[6451] = {n:"Engel Boog",t:2,d:"Voor wat betreft deze boog kun je je afvragen waarom hij zo\'n idiote naam heeft. Hetzelfde geldt voor jou.",ep:14,g:31,l:82,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>80&CS>50",p:17000};
I.u[6452] = {n:"Architect Boog",t:2,d:"Deze op het oog ingewikkelde boog is werkelijk een kunstwerk. De beeldhouwer die de boog heeft gemaakt is tevens beroemde vanwege zijn tentoonstelling van zijn meest omstreden modellen in de befaamde grot van Knul Ugh, sinds eeuwen verboden voor niet ter zake kundig publiek.",ep:9,g:30,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>200&CS>100&CI>30",p:37000};
I.u[6453] = {n:"Vissers Boog",t:2,d:"Voortgekomen uit een treffende verklaring (met de boog kun je vliegende vissen vangen), is deze boog voorzien van een ingebouwde hengel, waarmee je ook andere dingen kunt vangen dan alleen vliegende vissen.",ep:14,g:32,l:70,wd:true,fm:true,w:1,an:10,tw:true,e:[10,4,2,8,30,50,false,true],c:"CS>70&CA>70",p:13000};
I.u[6454] = {n:"Donkere Boomstaf",t:4,d:"Deze Donkere Treechnid tak is eigenlijk één van zijn armen. Ideaal voor armpje-drukken, en bovenal geschikt om je vijanden uit je jeugd te terroriseren of Trunknids te teisteren.",ep:13,g:23,l:87,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,50,false,false],c:"CV>150&CW>50",p:20000};
I.u[6455] = {n:"De Zeis van de Hemelse Oogst",t:22,d:"...",ep:0,g:1,l:100,wd:false,fm:true,w:1,e:[-1,-1,1,-1,-1,-1,false,false],p:1};
I.u[6457] = {n:"Kriptoniet",t:40,d:"Hier is een opvallend metaalmengsel, waarvan de oorsprong werkelijk ver lijkt. Als het niet nuttig kan zijn, kan het altijd nog dienen om de schoorsteen te versieren of om op de schedel van een Iop te timmeren, al was het alleen maar om je ervan te verzekeren dat die wel degelijk leeg zijn.",ep:1,g:706,l:80,wd:true,fm:true,w:80,p:0};
I.u[6458] = {n:"Kobaliet",t:40,d:"Van alle metaalmengsels die tot op heden ontdekt zijn, is Kobaliet één van de verrassendste. De vroegere mijnwerkers dachten het ideale metaalmengsel gevonden te hebben, tot de dag dat één van hen zich gewaar werd dat het in stof veranderde bij contact met Veelvraatkwijl.",ep:1,g:704,l:100,wd:true,fm:true,w:100,p:0};
I.u[6459] = {n:"Duistere Mijnwerkers Amulet",t:1,d:"De enige manier om te overleven in een mijn vol met Duistere mijnwerkers, is door goed te kunnen zien. Alleen als je hen een kaars kunt ontfutselen, draag dan dit geluksamulet.",ep:14,g:61,l:39,wd:true,fm:true,w:1,c:"CC>30",p:4200};
I.u[6460] = {n:"Winterblad",t:1,d:"Deze prachtige broche is een eerbetoon aan de beroemde verzetsbeweging van de mijnwerkers van de zilvermijn van Grimoth. Een hele winter lang streden ze tegen een Krakler van het ergste soort en uiteindelijk gingen ze allemaal dood. Vermoord door een oude verdwaalde Tofu.",ep:1,g:65,l:98,wd:true,fm:true,w:10,p:25000};
I.u[6461] = {n:"Voorjaarsblad",t:1,d:"Dit speciaal voor de oude Enutrofs gemaaket amulet, stelde Setag lang geleden in staat de mijn van Grimoth te ontdoen van als zijn concurrerende mijnwerkers. Een slechte methode, maar bijzonder effectief.",ep:7,g:62,l:123,wd:true,fm:true,w:10,p:40000};
I.u[6462] = {n:"Zomerblad",t:1,d:"Deze kleine broche is werkelijk charmant, in het begin was het bestemd voor de pechvogels die toch besloten om deel te nemen aan de kermisspelen. Men heeft al snel ontdekt, dat ze ook zeer geschikt is voor heldenjachten.",ep:13,g:63,l:45,wd:true,fm:true,w:4,p:5400};
I.u[6463] = {n:"Kermisring",t:9,d:"Deze ring is gemaakt door een beroemde kermisklant, waarvan niemand zich de naam kan herinneren. Hij is overleden tijdens een boogschutterswedstrijd, toen hij zijn hoofd als doel diende, met een Zaadje van de Wilde Zonnebloem op de plaats van de traditionele Pompoen. ",ep:1,g:50,l:44,wd:true,fm:true,w:5,p:5300};
I.u[6464] = {n:"Ring van de Tevreden Bezweerder",t:9,d:"Deze ring is een verbeterde versie van de beroemde Ring van Tevredenheid. Ideaal om je kleine beesten het gevecht voor jou te laten voeren, of simpelweg om slim te zijn door een leger Tofus aan te roepen.",ep:1,g:51,l:40,wd:true,fm:true,w:5,p:4000};
I.u[6465] = {n:"Knul Ugh Ring",t:9,d:"Knul Ugh heeft ooit aan een monster gevraagd die rond zijn grot rondspookte hoe je een dergelijke ring maakt, in ruil voor wat te verrichten diensten. Maar hij wist niet dat dit hem voor altijd zou veranderen. Gewaarschuwde mensen zullen u zeggen dat hij veel heeft verloren met deze ruil...",ep:5,g:52,l:80,wd:true,fm:true,w:10,p:16000};
I.u[6466] = {n:"Shika Amulet",t:1,d:"Dit amulet heeft Shika Ingalsse menig keer geholpen om te de rebellie van de Veelvraatskuddes te overleven, die vastbesloten waren haar het leven zuur te maken.",ep:14,g:60,l:29,wd:true,fm:true,w:10,p:2300};
I.u[6467] = {n:"Ano Nime Ring",t:9,d:"Niemand kent de eigenaar van deze ring, die zijn anonimiteit heeft weten te bewaren na een vernederend gevecht tegenover een aangeroepen Arachnee. Echter, het moet worden toegegeven dat deze laatste zojuist door een Iop was geraadpleegd.",ep:1,g:53,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6468] = {n:"Ring van de Jonge Vald",t:9,d:"In de tijd dat alle Iops van zijn leeftijd voor hun communie een Tabi horloge ontvingen of een houten Goultarde, kreeg Vald deze ring. Dat is minder leuk om mee te spelen met zijn kleine vriendjes, maar veel nuttiger tijdens een gevecht.",ep:1,g:54,l:59,wd:true,fm:true,w:10,p:9275};
I.u[6469] = {n:"Farle\'s Trouwring",t:9,d:"Deze trouwring is versleten door de wrijving met aren van wintergerst tijdens honderden oogsten. Het is bovendien een getuige van de vereniging tussen Farle en Shika toen zij trouwden in een akker met lentegerst.",ep:9,g:55,l:87,wd:true,fm:true,w:5,p:20000};
I.u[6470] = {n:"Laarzen van de Veelvraatsfokker",t:11,d:"Deze prachtige laarzen zijn uitstekend geschikt om de Veelvraten te dwingen van weiland te veranderen of om ze door het dorp te leiden door ze onder hun kont te schoppen. Dat geldt ook voor het dwingen van Iop kinderen om hun huiswerk te maken of om naar school te gaan.",ep:13,g:40,l:68,wd:true,fm:true,w:10,p:12000};
I.u[6471] = {n:"Patent Armzalige Everzwijn Schoenen",t:11,d:"Deze kleine schoenen zijn bewapend, gerepareerd en gedeodoriseerd. Ze worden vaak gebruikt om Mush-Mush te vangen aangezien het substraat wat het Armzalig Zwijn uitlaat smakelijk voor hen lijkt te zijn...",ep:13,g:41,l:30,wd:true,fm:true,w:10,p:2700};
I.u[6472] = {n:"Gouden Drakohoofddeksel",t:16,d:"Deze gevulde schaal van het Gouden Drakei maakt je zo goed als ongevoelig voor de magische bliksemschichten van de Bwork Magus. Daarentegen beschermt hij je totaal niet tegen echte bliksem...",ep:11,g:55,l:57,wd:true,fm:true,w:10,p:8500};
I.u[6473] = {n:"Saffieren Drakohoofddeksel",t:16,d:"Deze eierschaal van een Drakei van Saffier zal je erg goed staan, als je hem weet te dragen. Het dragen van een dergelijk hoofddeksel is niet voor iedereen weggelegd, want bewezen is, dat de Iops de neiging hebben hem binnenstebuiten te dragen.",ep:11,g:57,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6474] = {n:"Zwart Drakohoofddeksel",t:16,d:"Deze eierschaal van de Zwarte Drakei is ideaal om \'s nachts onopgemerkt te blijven, of om te beschermen tegen vallende stenen, hetgeen in bergachtige gebieden vaak voorkomt, of als men een Krakler uitdaagt tot het werpen van rotsen.",ep:11,g:56,l:93,wd:true,fm:true,w:20,p:22300};
I.u[6475] = {n:"Gebroken Chafer Helm",t:15,d:"In deze staat is deze helm onbruikbaar, je zou er hoofdpijn van kunnen krijgen. Een goede houwer zou hem kunnen maken en er een goede vulling in kunnen doen en ondertussen veel geld aan je kunnen verdienen.",ep:3,g:709,l:40,wd:true,fm:true,w:20,p:1000};
I.u[6476] = {n:"Magische Kaars van de Duistere Mijnwerker",t:15,d:"Deze kaars straalt zelfs als hij gedoofd is, en verspreidt geen warmte. Als je goed luistert, hoor je een licht geknisper, een beetje als het geluid van cornflakes in een bakje melk.",ep:1,g:701,l:40,wd:true,fm:true,w:10,p:10000};
I.u[6477] = {n:"Duistere Mijnwerkers Hoed",t:16,d:"Met deze weelderige hoed kan je duidelijk zien, zelfs als het al aardig helder is. Hij is ook heel handig om de beesten te verblinden, die in de ongunstig bekend staande mijnen rondwaren. Of gewoon om Iops wijs te maken dat je een licht bent.",ep:16,g:90,l:103,wd:true,fm:true,w:20,p:27000};
I.u[6478] = {n:"Verminkte Makrout",t:15,d:"Deze magische Makroute is in een slechte staat. Hij was niet opgewassen tegen het geweld van jouw aanvallen en zijn vacht is nou donker. Er zou een nieuw leven voor hem kunnen beginnen als je maar zou weten hoe je hem zou kunnen genezen...",ep:14,g:702,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6479] = {n:"Gemuteerde Beer",t:15,d:"Deze berenkop verkeert in zeer slechte staat. Met naald en draad, een stukje stof en wat vindingrijkheid kun je van dit afschuwelijke ding een opmerkelijk hoofddeksel maken.",ep:1,g:703,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6480] = {n:"Donkere Wicker",t:15,d:"Dit stukje wicker is net zo donker als de donkerste geest, net zo magisch als de meest magische geest en net zo stevig als de stevigste geest. Vergeet niet dat geesten niet bestaan.",ep:14,g:123,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6481] = {n:"Dora Bora",t:16,d:"Deze geweldige hoed was gecreeërd op Dora Bora Eiland, ten zuiden van Maan Eiland. Perfect bewerkt om te vechten, ook erg op prijs gesteld als fruitmand, voor Getraumatiseerde Kokokonoten bijvoorbeeld.",ep:12,g:61,l:120,wd:true,fm:true,w:20,p:40000};
I.u[6482] = {n:"Korko Kousto",t:16,d:"Nieuwe bewerkte versie van de Jouik Kramp, deze hoed was gemaakt van de beste bronnen die gevonden kunnen worden op Maan Eiland, en geeft het een landelijk karakter. Zelfs als je niet op een Kannibaal lijkt zul je geweldige kopstoten geven.",ep:12,g:59,l:73,wd:true,fm:true,w:10,c:"PG=10",p:14000};
I.u[6483] = {n:"Bronzen Bworkhelm",t:16,d:"Met deze verbazingwekkende helm verandert zijn eigenaar in een Bronzen Bwork, aldus de legende. Probeer hem meteen uit op grote dikke vijanden, daarna kun je hem opnieuw smelten en er een goede prijs voor krijgen.",ep:20,g:91,l:144,wd:true,fm:true,w:10,p:46625};
I.u[6484] = {n:"Sram Boogschutters Boog",t:2,d:"Als de dolken niet meer voldoen en de goden de spot met je drijven, moet je zelf je eigen vechtstijl zien te vinden. Sommige Srams hebben dat goed begrepen, andere hopen dat de goden hen te hulp zullen schieten.",ep:9,g:40,l:90,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>90&CA>90&CW>50",p:16000};
I.u[6485] = {n:"Chafer Boogschutter Boog",t:2,d:"De Chafer boogschutter zou nooit slim en behendig genoeg zijn geweest om een dergelijke boog te bedienen vanwege zijn trillende botten. Behalve het probleem van trillende botten, is het bijna zeker dat je je in dezelfde staat bevindt als die belachelijke Chafer.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CC>100&CS>100",p:36600};
I.u[6486] = {n:"Schors van de Slappe Eik",t:96,d:"Deze schors heeft meer weerstand dan welke schors ooit, hij straalt kracht uit. Daarentegen wijst niets erop dat het een valse Boomchnidschors is. Misschien wordt het tijd dat jij op jouw beurt een vriend oplicht.",ep:9,g:666,l:200,wd:true,fm:true,w:10,p:10};
I.u[6487] = {n:"Slappe Eik Knop",t:108,d:"Deze enorme knop, die volgestopt is met warme en stroperige kwijl, zou je toch moeten herinneren aan de tijd dat je nog aan de zuigfles zat, als je het waagt om de inhoud op te zuigen. In een tweede leven kom je misschien terug als dood blad.",ep:9,g:665,l:200,wd:true,fm:true,w:10,p:10};
I.u[6488] = {n:"Slappe Eik Wortel",t:98,d:"Sommigen proberen bier te maken van deze wortel. Dit wordt ten sterkste afgeraden. De Slappe Eik bevat totaal geen alcohol. Deze wortels worden heel instabiel als ze in contact komen met alleen al een druppel alcohol. Zoiets als een Sadida.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[6489] = {n:"Slap Eikenhout",t:38,d:"Dit hout heeft de Bijl van Brouce Boulgoure gezien, en van heel dichtbij. Het heeft ook andere mysterieuze en intrigerende dingen meegemaakt, die zelfs in het boek van de Magische Bwork niet worden onthuld. Je hebt het recht je het ergste voor te stellen.",ep:1,g:668,l:200,wd:true,fm:true,w:10,p:10};
I.u[6490] = {n:"Slappe Eik Barnsteen",t:50,d:"Deze barnsteen bevat een armzalig beestje dat gestold is in het hars. Dit juweel van de Slappe Eik is een verzamelobject, evenals de rode en gele sokken van de doperwten van de Chouque.",ep:9,g:669,l:200,wd:true,fm:true,w:10,p:10};
I.u[6491] = {n:"De Stamnydum",t:2,d:"Deze boog is het resultaat van een mislukte kruizing tussen een Stamchnid en een Boomchnid. Voor een Houthakker is dit een duidelijke mislukking, maar voor een Boogmaker is het echt een succes. Je ouders zouden graag hetzelfde over jou willen zeggen.",ep:9,g:41,l:57,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],p:8500};
I.u[6492] = {n:"Wobot Staff",t:4,d:"Het gat tussen beide einden van deze staf is identiek aan de ruimte tussen de ogen van de Lenalds... Wat zal de uiterste grens zijn voor de vewschwikkewijke Wabbits?",ep:2,g:37,l:60,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>60&CV>60",s:11,p:9400};
I.u[6493] = {n:"Wabbit Slippers",t:11,d:"Volg de \"Wottel attitude\" met deze wabbitslippers van de laatste collectie. Ze worden door alle klepper-experts aangeraden bij rituele dansen en de snelle Tango van Kapitein Chafer.",ep:8,g:39,l:60,wd:true,fm:true,w:10,s:11,p:9300};
I.u[6494] = {n:"Elya Wood Stok",t:3,d:"Gebruikt door de beroemde Eniripsas van Amakna, vormt deze toverstok het ideale wapen om een vloek over zijn tegenstanders uit te roepen of om zijn eigen vrienden intelligenter te maken. Zo kun je een Iop in een pompoen veranderen.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,50,50,false,true],c:"CI>300&CW>100",s:39,p:36800};
I.u[6495] = {n:"Zachte Eik Wand",t:3,d:"Deze wand, gemaakt van de overblijfselen van de Zachte Eik, is ultra krachtig. Zwaai het van links naar rechts volgens specifieke ritmische patronen en het triggert mogelijk regens van padden of je ziet er uit als een idioot.",ep:22,g:42,l:172,wd:true,fm:true,w:10,an:11,tw:true,e:[7,3,3,4,45,70,false,true],c:"CI>400&CC>250&CW>150",p:45000};
I.u[6496] = {n:"Wand in Donkere Boomchnid Wortel",t:3,d:"Deze wand kan zich soms tegenover zijn eigenaar opstellen. In dat geval kun je hem het beste aan een vijand geven, of aan een Iop volgeling – idioten zoals hen zullen zeker denken dat het een kado is.",ep:9,g:40,l:67,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>70&CW>70",p:12000};
I.u[6497] = {n:"Lichte Balgourde",t:3,d:"De vrouw van Brouce Boulgoure, een Eniripsa, kon het niet laten zijn beroemde bijl te stelen. Om een einde te maken aan deze streken, sneed hij haar een vleugel en een arm af en om zich daarvoor te excuseren, gaf hij haar dit stokje. Dat is nou een man die met vrouwen weet om te gaan.",ep:9,g:43,l:63,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,50,false,true],c:"CI>63&CW>30",p:10325};
I.u[6498] = {n:"Kangouwou Onderbroek van de Wabbit GM",t:10,d:"Deze fantastische onderbroek van respectabele omvang bevat nog de remsporen van zijn vorige eigenaar en wat vreemde haren. Aan de billen of op het hoofd zul je met deze onderbroek een gerespecteerde persoonlijkheid in heel Amakna zijn.",ep:8,g:58,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6499] = {n:"\"Wabbit Tanden\" Amulet",t:1,d:"De tanden van dit amulet hebben aan heel wat Wottels geknaagd, die Brouce Bolgour niet ontworteld heeftvan de bomen. Wees dus niet verbaasd als je naar Wottel ruikt en de Tiwabbits je zoeken om je in de nek te zoenen.",ep:8,g:59,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6500] = {n:"Wabbit Oren",t:16,d:"Met deze oren kun je niet beter horen, maar kunnen je vrienden je beter vinden in de menigte en je vijanden zich doodlachen. Een paar oren die op den duur echt onmisbaar zijn.",ep:8,g:52,l:60,wd:true,fm:true,w:10,s:11,p:9500};
I.u[6501] = {n:"Wottel-Tas",t:81,d:"Met deze tas om je schouders, kun je op avontuur gaan zonder je zorgen te maken over eventuele voedselproblemen. Zelfs als in feite de Wottel leeg is als een Iop schedel, groeien de blaadjes aan de bovenkant vanzelf weer aan, waarmee je goede kruidentheek van kan maken.",ep:8,g:57,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6503] = {n:"Polpoulette Hamer",t:7,d:"De Polpoulette is het resultaat van een kruizing tussen een agressieve Vuur Kwak en een ziekelijke Tofu. Sinds tijden wordt de jacht op de Polpoulette beschouwd als een onveranderlijk ritueel. De jacht op dit verschrikkelijk wezen is een waar plezier.",ep:13,g:35,l:57,wd:true,fm:true,w:20,an:15,e:[6,5,1,1,40,50,false,false],c:"CI>60&CS>20",p:8000};
I.u[6504] = {n:"Fantal Hamer",t:7,d:"Men kent alleen maar de troetelnaam van zijn maker, een zekere Fantal, maar men weet wel dat hij een zeer slechte smaak had. Hij hield er bijvoorbeeld van om zich in te smeren met koninginnehoning om zich vervolgens te bedekken met Koninklijke Tofuveren. En hij had bovendien een dure smaak.",ep:9,g:36,l:81,wd:true,fm:true,w:20,an:15,e:[10,5,1,1,50,50,false,false],c:"CS>80&CV>70",p:17000};
I.u[6505] = {n:"Rehadaure Hamer",t:7,d:"Deze hamer is ideaal om tegen gehoornde beesten te vechten. Maar er spijkers ergens mee inslaan of ander handmatig werk, dat is een ander verhaal...",ep:9,g:37,l:100,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CC>100&CW>40&CS>50",p:26000};
I.u[6506] = {n:"Ring van de Gegorifieerde Mijnwerker",t:9,d:"Bij de Enutrofs zegt men dat een mijnwerker gegorifieerd is als hij het daglicht niet meer verdraagt vanwege het werken in zijn mijn. Probeer nooit een kaars van zo\'n mijnwerker te benaderen, hij zal je in brons veranderen.",ep:1,g:40,l:84,wd:true,fm:true,w:10,c:"PG=3",p:18500};
I.u[6507] = {n:"Terps Hamer",t:7,d:"De Terps was een zeer lelijk wezen, net zo gevaarlijk en onbemind als de oude Liche. Vastbesloten deze rivale voorbij te streven, maakte ze deze hamer om de tenen van haar rivale te verpletteren, maar zij verpletterde voornamelijk de voeten. Dit was het begin van een grote love story.",ep:9,g:38,l:90,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,35,80,false,false],c:"CS>60&CI>60",p:19000};
I.u[6508] = {n:"Pinambour Hamer",t:7,d:"Een bijzondere hamer, bestemd voor het verzorgen van je lieve kleine Prespic, of je vijanden als je een discipel van Chafer Fu bent.",ep:9,g:39,l:50,wd:true,fm:true,w:20,an:15,e:[6,4,1,1,40,40,false,false],p:6000};
I.u[6509] = {n:"Nekramp Hamer",t:7,d:"Voor deze weelderige hamer zal menig Osamodas zijn hoofd omdraaien. Hij is zo krachtig, dat iedereen over zijn schouder kijkt als hij zijn drager tegenkomt. Deze hamer is sinds die tijd de oorzaak van een zeer vreemde kwaal.",ep:9,g:40,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>100&CI>150",p:36000};
I.u[6510] = {n:"Kahr Hamer",t:7,d:"Kahr ging helemaal uit zijn dak bij hamergevechten. Gelukkig voor hem, erfde hij deze pracht hamer, waardoor hij een gerespecteerd en benijd persoon werd. Zo zie je maar, succes komt op vele manieren.",ep:12,g:41,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>150&CI>150",p:36000};
I.u[6511] = {n:"Heehete Hamer",t:7,d:"Deze hamer is perfect voor warme momenten, je zult er in je omgeving enorm succes mee hebben als je er op juiste wijze mee weet om te gaan. Duidelijk een wapen dat niet voor iedereen weggelegd is...",ep:9,g:42,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,40,40,false,false],c:"CI>150&CS>100",p:36000};
I.u[6512] = {n:"Nitruhant Hamer",t:7,d:"Dit is het wapen waar elke een beetje rebelse en op sensatiebeluste Xelor van droomt. En dan voornamelijk om een oud minderwaardigheidscomplex te compenseren. Hun belachelijke grootte.",ep:14,g:43,l:82,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,40,50,false,false],c:"CI>50&CC>50",p:17000};
I.u[6513] = {n:"Brekende Hamer",t:7,d:"Deze hamer ontleent zijn kracht aan een subtiele betovering. Dat is op het eerste gezicht niet te zien, noch op het tweede. Daarom doet men moeite om het te nauwkeurig weer te geven, om zo de waarde van dit object in de ogen van een beetje naïeve kopers te vergroten.",ep:1,g:44,l:55,wd:true,fm:true,w:20,an:15,e:[6,4,1,1,50,50,false,false],p:9000};
I.u[6516] = {n:"R\'Hoh Dolken",t:5,d:"Geen enkele Sram kan de lust weerstaan om een vriend aan te vallen met deze schitterende dolken. Hun belangrijkste doel is om de onveiligheid in Amakna aanzienlijk te verminderen door één van de laatste overgebleven Srams uit de weg te ruimen.",ep:9,g:41,l:121,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>100&CV>100",p:38000};
I.u[6517] = {n:"Hischantes Dolken",t:5,d:"Elke kleine Srammette op zoek naar nieuwe ervaringen zou ervoor door de knieën gaan. Met zijn magische krachten kan hij de ergste listen uithalen zowel bij vrienden als bij vijanden. Kapitein Chafer zou er zijn lippen bij aflikken.",ep:7,g:42,l:80,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>80",p:8000};
I.u[6518] = {n:"Amrothiline",t:3,d:"Ontworpen door een beroemde Beeldhouwer, heeft dit stokje 13 keer het grote concours van de N\'hi Stokken gewonnen, die de oude Boulgourde modellen overtreffen, die vandaag de dag uit de handel zijn gehaald want veel te gevaarlijk voor de kleine Enirpsas.",ep:9,g:44,l:120,wd:true,fm:true,w:10,an:11,e:[6,4,2,4,50,50,false,true],c:"CI>300&CV>100",p:36000};
I.u[6519] = {n:"Kouartz Stok",t:3,d:"Het is een beroemde beeldhouwer, bekend om zijn gelijkenis met de naam van een van de meest waardevolle legeringen van Amakna, die als eerse het idee introduceerde om metalen in zijn scheppingen te verwerken. Gekte leidt soms tot succes.",ep:14,g:41,l:80,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>120&CW>40",p:17000};
I.u[6520] = {n:"De Migraine",t:3,d:"De houtsnijder van deze stok heeft verschillende keren een naamsverandering aangevraagd. De verantwoordelijken van het bevolkingsregister van Amakna plachtten hun dagen door te brengen in de Herberg en kregen hoofdpijn van al deze aanvragen. Deze stok is aan hen opgedragen.",ep:13,g:45,l:85,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150&CV>100",p:19000};
I.u[6521] = {n:"Kelinotak",t:4,d:"Men zegt dat deze staf een vrouwtjes Boomchnid kan laten blozen, of de intieme delen van een Slappe Eik kan kietelen om haar beter te verleiden. In ieder geval raden we je af om dat te proberen, de Slappe Eik is echt heel overheersend.",ep:9,g:38,l:129,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,40,false,false],c:"CS>250&CV>200",p:43000};
I.u[6522] = {n:"Cintati Wortel",t:4,d:"Volgens de legende is dit een plantenetende wortel : hij neigt zich snel te verspreiden onder dode bladeren en eet jonge scheuten. Erg indrukwekkend. Goed, behalve als je tegen de Paardenbloemen vecht, heeft dat geen enkel nut.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CI>200&CS>200&CV>150",p:37000};
I.u[6523] = {n:"Hagogue Wortel",t:4,d:"Met deze geboetseerde elegante en geraffineerde wortel wordt je een ervaren bezweerder. Niets om over op te scheppen, maar om de Sadidettes van Amakna het hoofd op hol te brengen, is er geen beter middel.",ep:9,g:40,l:120,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>200&CV>150",p:36000};
I.u[6524] = {n:"Wilde Wortel",t:4,d:"Een Sadida, die hevig verliefd was op een Wilde Sadidette heeft geprobeerd haar aandacht te trekken met deze toverwortel;\r\n            p hij heeft een honderden jaren gewacht. Maar ze is nooit komen opdagen. Sindsdien heeft men \'t over Wortel Schieten als je onderweg naar je date Wilde Wortels tegenkomt.",ep:14,g:41,l:54,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"PG=10",p:9000};
I.u[6525] = {n:"Feca Staf",t:4,d:"De bewoners van Amakna waren het beu de godganse dag de Feca Discipelen te horen klagen over hun wapenrusting. Zij maakten daarom een staf in de hoop ze over andere dingen te horen praten in de herberg.",ep:14,g:42,l:94,wd:true,fm:true,w:10,an:12,tw:true,e:[7,5,1,1,40,80,false,false],c:"PG=1",p:25600};
I.u[6526] = {n:"Hebuse Schep",t:8,d:"De smid die deze schep heeft gemaakt wilde anoniem blijven en bescheiden lijken, maar hij liet een aanwijzing achter in de naam van deze schep. Sommige ambachtslieden zijn reddeloos verloren...",ep:1,g:4,l:94,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>70&CW>50",p:23000};
I.u[6527] = {n:"Muzikale Schep",t:8,d:"Kes Tmis was een vermaarde zwaardsmid. Hij zong altijd iets over scheppen, hard en vals. Hij zong zo vals dat zijn vrouw erdoor voor het leven is getekend toen zij deze schep voor hem maakte.",ep:1,g:38,l:52,wd:true,fm:true,w:10,an:16,e:[10,5,1,1,20,20,false,false],c:"CC>80&CI>50",p:7100};
I.u[6528] = {n:"Zwerf Schep",t:8,d:"Deze schep heeft over vele continenten gereisd, en heeft de zon zien ondergaan op de top van de Mont Crakelour, de zon zien opkomen daar waar de Asse Zee en de horizon bij elkaar komen. En dan te weten dat je nooit verder bent geweest dan het Moon Eiland, zielig.",ep:12,g:4,l:88,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CI>80&CC>150&CW>40",p:20000};
I.u[6535] = {n:"Rooss Schep",t:8,d:"Deze vreemde multifunctionele schep werd gebruikt om de luizen van de jonge Iops te doden, om de roosschilfers te verwijderen, en om de beginselen van het rekenen weer in hun kop te stampen.",ep:9,g:36,l:121,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>300&CS>50&CV>100&CW>50",p:37000};
I.u[6536] = {n:"Duistere Mijnwerkers Schep",t:8,d:"De Duistere Mijnwerker gebruikt deze schep en is zo groot als de hand van de Krakler. Hij dient voornamelijk om meerdere Enirpsas in een klap te verpletteren. Het wordt aangeraden hetzelfde te doen, om niet idioot te sterven.",ep:9,g:34,l:120,wd:true,fm:true,w:10,an:16,e:[10,5,1,1,60,60,false,false],c:"CC>250&CV>100&CS>75",p:34000};
I.u[6537] = {n:"Sgoon Moe Schep",t:8,d:"Deze schep is werkelijk onsympatiek. Niemand weet eigenlijk waarom, maar de Mairhes Scheppen zijn altijd ondraaglijk. Gelukkig moeten ze ook goede eigenschappen hebben, ook al is men daar vandaag de dag nog naar aan het zoeken.",ep:12,g:37,l:88,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>100&CA>70",p:20000};
I.u[6538] = {n:"Uitsig Schep",t:8,d:"Met deze schep kunnen de Enutrofs veel verder kijken. De schep is zo gemaakt dat je hem in de grond kunt steken en erop kunt klimmen om de horizon af te turen en daarmee interessant te lijken. Ideaal om je huis terug te vinden als je verdwaald bent tussen twee varens.",ep:12,g:39,l:84,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>70",p:18200};
I.u[6539] = {n:"Bel Gieje Schep",t:8,d:"Deze schep is werkelijk anders dan de andere. Als je hem tijdens het gevecht gebruikt, zal men je uitlachen. Want de grapjes over de Gicque Schep zijn erg populair in de Herberg.",ep:9,g:35,l:71,wd:true,fm:true,w:10,an:16,tw:true,e:[10,4,1,1,25,60,false,false],c:"CS>30&CC>150",p:13000};
I.u[6540] = {n:"Bellebeest Schep",t:8,d:"Men zegt dat de smid van deze schep een echt beest was. Een soort kruising tussen Sadida en een Boowolf. Het schijnt dat zijn schep verliefd op hem werd. Wat een belachelijk verhaal.",ep:14,g:33,l:87,wd:true,fm:true,w:10,an:16,tw:true,e:[15,5,1,1,30,100,false,false],c:"CC>150&CV>80",p:20000};
