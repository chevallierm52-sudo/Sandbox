I.u[6601] = {n:"Ontstekings Poeder",t:48,d:"Als je gasten zich beginnen te vervelen, is de beste oplossing het beroemde Feewerk te gebruiken, zelf te maken op basis van dit poeder en diverse ingrediënten. Deze Fee zal je feest werkelijk explosief maken.",ep:16,g:670,l:1,wd:true,fm:true,w:1,p:100};
I.u[6602] = {n:"Bloed van Hyoactif rat",t:24,d:"Volgens de veiligheidsnormen van Bonta moet 100 poces afstand gehouden worden van iedere Hyoactieve substantie op straffe van een verdrievoudiging van de speeltijd.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[6603] = {n:"Gevulde gobball",t:61,d:"Deze Gevulde Gobball is de gelijkenis van een Gobball;\r\n            zijn makers waren vals genoeg om hem dezelfde geur te geven. Dus wees niet verbaasd als je verschrikkelijk stinkt wanneer je wakker wordt.",ep:13,g:671,l:1,wd:true,fm:true,w:10,p:1};
I.u[6604] = {n:"Kwa-Kwak",t:18,d:"Meer nog dan de Tofu, de Veelvraat of zelfs de Iop, excelleert de Kwa-Kwak in stompzinnigheid.",ep:1,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[6605] = {n:"Gevulde koninklijke gobball",t:61,d:"Deze Gevulde Gobball is geweldig, van de zoom tot de vulling, er is over alles nagedacht. Het is een uitmuntend kado voor verwende kinderen of rijke blagen.",ep:13,g:672,l:1,wd:true,fm:true,w:10,p:1};
I.u[6606] = {n:"Gevulde Sadida Dopple",t:61,d:"Deze Gevulde Sadida Dopple een een grote alarmklok in zijn vulling, erg handig voor Sadida\'s volgelingen als ze moeite hebben met wakker worden. Het wordt afgeraden om het onder de haagbeuk te zetten omdat je tijdens die momenten tijd nodig hebt.",ep:13,g:673,l:1,wd:true,fm:true,w:10,p:1};
I.u[6607] = {n:"Gevulde Ecaflip Dopple",t:61,d:"Deze gevulde Ecaflip Dopple amuseert Ecaflips van alle leeftijden.",ep:13,g:674,l:1,wd:true,fm:true,w:10,p:1};
I.u[6608] = {n:"Gevulde Iop Dopple",t:61,d:"Deze Gevulde Ecaflip Dopple lijkt op een echt Iop. Te dom voor woorden en zonder vulling in het hoofd.",ep:13,g:675,l:1,wd:true,fm:true,w:10,p:1};
I.u[6610] = {n:"Gevulde Sram Dopple",t:61,d:"Deze Gevulde Sram Dopple was gestolen van een jonge Sram die hem van één van zijn vrienden had gejat...",ep:13,g:677,l:1,wd:true,fm:true,w:10,p:1};
I.u[6611] = {n:"Gevulde Eniripsa Dopple",t:61,d:"Deze Gevulde Eniripsa Dopple kon bijna uit zichzelf vliegen maar zijn vleugels waren niet gedragen. Het is niet echt nieuw, maar een prachtig kado.",ep:13,g:678,l:1,wd:true,fm:true,w:10,p:1};
I.u[6612] = {n:"Gevulde Enutrof Dopple",t:61,d:"Wees voorzichtig, het is zwaar. Het is gevuld met Bauxiet Stenen en Gouden Klompjes.",ep:13,g:679,l:1,wd:true,fm:true,w:10,p:1};
I.u[6613] = {n:"Gevulde Feca Dopple",t:61,d:"Deze Gevulde Feca Dopple is bijna onbreekbaar, waardoor hij uitermate geschikt is voor jonge, onhandelbare en onverschillige volgelingen van Feca.",ep:13,g:680,l:1,wd:true,fm:true,w:10,p:1};
I.u[6614] = {n:"Gevulde Osamodas Dopple",t:61,d:"Er wordt gezegd dat deze Gevulde Osamodas Dopple andere zachte speeltjes kan bezweren als het goed onderhouden wordt. Eigenlijk is het een oude legende die voorkomt dat jonge volgelingen van Osamodas ze op eten.",ep:13,g:681,l:1,wd:true,fm:true,w:10,p:1};
I.u[6615] = {n:"Gevulde Cra Dopple",t:61,d:"Deze Gevulde Kra Dopple is gemaakt om naar je maten toegeslingerd te worden, als een soort boomerang die niet terug komt.",ep:13,g:682,l:1,wd:true,fm:true,w:10,p:1};
