D.q[1242] = "Nous vendons de tout et tout le temps, pour le plaisir de tout le monde. Je vous en prie prenez votre temps.";
D.q[3996] = "Qu\'attends tu de moi ? Que je serve un Wabbit ? Ils sont faibles, ne savent guère manier les armes et s\'expwiment bizawement !";
D.q[3867] = "Pnj(893) et Message(3865)";
