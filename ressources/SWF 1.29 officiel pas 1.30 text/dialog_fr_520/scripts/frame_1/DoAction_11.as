D.q[6147] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6155] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[5553] = "Alors tu n\'as rien à faire ici ! Cesse de bailler aux corneilles et trouve rapidement une solution.";
D.q[1479] = "Qu\'est ce que tu veux que ça me fasse ?! Va prendre un autre bâton et trouve-moi un Bontarien qui empeste la mort !";
D.q[4267] = "Alors comme ça tu penses qu\'un notable bontarien pourrait travailler pour nous ? Ca tombe bien, ça faisait un moment que j\'y pensais. Par contre j\'espère pour toi que ce Xephirès est bien la personne qui a signé ce document sinon ça va barder.";
D.q[6186] = "Alors raclure de bidet, tu viens voir ton idole ?";
D.q[1199] = "Bien, tu souhaites donc continuer sous ma tutelle, au sein de l\'Ordre du Coeur Vaillant. Choix judicieux que tu ne devrais pas regretter. \nToutefois, pour valider ton adhésion, il te faudra retrouver le greffier de l\'Ordre. Depuis que son chat de compagnie l\'a quitté, il écume les tavernes. Ramène-le ici et nous confirmerons ta demande.";
D.q[4159] = "Alors comme ça tu veux repartir sur cette île ?";
D.q[3590] = "Un bon paysan me dis-tu ? Et bien on va voir cela. On a une grosse commande de blé, il y a beaucoup de bouches à nourrir depuis quelques temps. Ca arrange mes affaires mais il faut trouver la main-d\'œuvre. Va faucher quelques ares de blé.";
D.q[2529] = "C\'est pour une libation à la déesse ?";
D.q[3052] = "Alors, bande de taulards, on se révolte ? Vous ne vous attendiez pas à ce que je revienne si vite, pas vrai ? Je n\'ai qu\'un mot à dire pour qualifier une attitude si vile, abjecte, et carrément pas sympa : Rahaayaa !";
D.q[2266] = "Alors, as-tu réussi à te procurer des ciseaux digne de ce nom ?";
D.q[2392] = "Alors Mercenaire, tu es en quête de proies et de kamas ? Ca tombe bien ! Lis les Avis de Recherche, ils te renseigneront sur les individus qu\'il faut nous ramener.";
D.q[3831] = "Alors, prêt à te lancer dans la grande aventure ?";
D.q[3843] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3837] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3836] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3835] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3834] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3833] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3842] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3841] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3840] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3839] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[4400] = "Alors, la pêche a été bonne ?";
D.q[3962] = "Alors, ce blopisier ?";
D.q[2545] = "Ah ! Le vieux sage t\'a parlé de cette vieille légende... et tu l\'as cru ! Même parmi le peuple Lénald, peu croient encore à cette histoire... Mais le sage Lénald en est convaincu : jadis les Lénalds protégeaient un oeuf de dragon... c\'était il y a longtemps... qui s\'en souvient ?";
D.q[2577] = "Ils sont beaux mes chapeaux, ils sont beaux ! Des couvre-chefs Pandawas presque tout neufs ! Approchez ! Y\'en aura pas pour tout le monde !";
D.q[3051] = "Alors, bande de taulards, on se révolte ? Vous ne vous attendiez pas à ce que je revienne si vite ! Rahaayaa !";
D.q[2117] = "Alors cette livraison ? Ca avance ?";
D.q[2251] = "Alors c\'est bon ? Tu m\'as ramené les quatre cuisses de mon pauvre Bouftou et les deux citrons que je t\'avais demandé ?";
D.q[3255] = "Tiens, tu veux d\'jà r\'partir ?";
D.q[1201] = "Bien, tu souhaites donc continuer sous ma tutelle, au sein de l\'Ordre de l\'Esprit Salvateur. Choix judicieux que tu ne devrais pas regretter. \nToutefois, pour valider ton adhésion, il te faudra retrouver la greffière de l\'Esprit Salvateur. Depuis que ses deux frères ont des états d\'âme, elle écume les tavernes pour les retrouver. Ramène-la ici et nous confirmerons ta demande.";
D.q[2116] = "Alors, ca y est ? Tu crois que tu peux me toucher maintenant ? Alors vas-y FRAPPE MOI !";
D.q[4155] = "Alors avez-vous trouvé mon petit wabbit ? Comment va-t-il ?";
D.q[4328] = "Alors ? Tu as trouvé un moyen pour faire passer le message ?";
D.q[3512] = "Alors ?";
D.q[3972] = "Koâ ? Tué Wabbit ? Pa inté, inté, pas drôol pour grand bwork kom moâ.";
D.q[4185] = "Alors, as-tu réduit en poussière les Pirates ?";
D.q[2129] = "D\'après toi, l\'homme Ours n\'a quasiment plus aucun pouvoir ?";
D.q[3864] = "Ah, je vois que tu viens t\'assurer que tout va bien au Château... Ne t\'inquiète pas, je veille sur le trône!";
D.q[3089] = "Je n\'ai point besoin de cela pour plaire à mon roi. Pour le ravir, il me suffit de pointer mon beau minois. Trouve quelqu\'un d\'autre qui n\'a pas mon charisme félin.";
D.q[3386] = "D\'bien beaux combats, pour sur ! Moi j\'ai plus rien à t\'donner. Bon vent à toi.";
D.q[2606] = "Très bien, reviens me voir si tu trouves quelque chose... Adieu, en somme!";
D.q[2666] = "Des innocents sont en danger au cimetière, moi Nergal, serviteur du dieu Iop, de la veuve et de l\'orphelin, je prie ta personne de me céder une rune de téléportation vers ce lieu afin de m\'y rendre le plus promptement possible !";
D.q[327] = "Parmi ceux qui iront, certains n\'en reviendront pas. Et même ceux qui en reviendront, ils n\'en reviendront pas. Et si vous en revenez tous, alors c\'est moi qui n\'en reviendrai pas.";
D.q[4116] = "Quel est le sexe de la personne qui n\'est ni ton frère ni ta soeur, mais qui est l\'enfant de tes parents ?";
D.q[2894] = "qu\'est ce que tu fais ici ? allez prend la clef et fuis vite fait";
D.q[6206] = "Un certain X ? Mouais, peut-être que je sais quelque chose, mais c\'est pas dans mes habitudes de dire des trucs au sujet des clients. Ils tiennent à leur discrétion, c\'est pour ça qu\'ils viennent dans cet établissement.";
D.q[3746] = "Certains récolteurs ne vendent pas le fruit de leur récolte et le conservent jusqu\'à ce qu\'ils connaissent un second métier.";
D.q[3105] = "Il ne me manque plus que mon être cher. Un familier doux et ronronnant fera l\'affaire. Je veux un Chacha tout blanc comme moi. Trouve-m\'en six que je choisisse le plus blanc.";
D.q[3515] = "Il manque une chose, c\'est un peu délicat, mais je crois que c\'est nécessaire, voire vital en fait !";
D.q[3673] = "D\'ici quelques temps, toi aussi tu iras braver les hordes démoniaques du maléfique Rushu. Il ne doit pas devenir le treizième dieu, sinon, ce sera l\'apocalypse !";
D.q[300] = "Victime...";
D.q[2115] = "Désolé mais j\'ai pas le temps de bavarder avec toi. J\'ai plein de bestioles à égorger... Tu veux que je te montre ? ";
D.q[2080] = "Désolé mais je suis un Crâ très occupé. Je n\'ai pas le temps de faire connaissance.";
D.q[6313] = "Désolé mon gars mais chuis pas encore assez bourré pour ça. *hips* Va faire un tour du côté du bois de Litneg, un trooll sera ravi de combler ton manque affectif.";
D.q[2821] = "Désolé, je ne peux vendre de trucs forts aux touristes comme toi.";
D.q[3463] = "J\'ai besoin de cette recette pour monter ma brasserie. Cherche plus en profondeur.";
D.q[756] = "Tu te souviens du prisonnier que tu as delivré ? \nIl est sur pied et désire pourfendre des squelettes avec toi !";
D.q[1626] = "Je suis désolée, mais je ne parle pas aux inconnus...";
D.q[1874] = "Désolée, mais je n\'ai pas le temps de bavarder avec toi. Mon père compte sur moi : je m\'occupe du troupeau de Bouftous familial. Il dit que c\'est une partie importante de ma formation. Bon je te laisse j\'en entends un qui mugit...";
D.q[301] = "Désolé, mais j\'ai pour mission d\'empêcher les jeunes inconscients dans votre genre d\'aller se faire éventrer en deux temps trois mouvements. Revenez lorsque vous vous serez entraîné. Je vous rends vos objets.";
D.q[2111] = "Ah désolé ! Trop occupé pour m\'occuper de toi maintenant !";
D.q[1608] = "Désolé vous n\'avez pas assez d\'argent.";
D.q[1932] = "Désolé, la maison ne fait plus crédit.";
D.q[164] = "Désolé, mais vous avez perdu. Vous aurez peut-être plus de chance la prochaine fois, n\'hésitez pas à retenter votre chance.";
D.q[2718] = "La déesse Pandawa garde toujours un oeil sur son verre, et un oeil sur toi, souviens-t\'en";
D.q[1750] = "Les Srams sont des personnages très agiles et forts, ils cherchent donc des équipements qui augmentent leur agilité et leur force.";
D.q[2698] = "Chut ! Ecoute... Tu entends ? Notre déesse te remercie par ma bouche : il est vrai que ce Dofus est très ressemblant ! Le Grandapan admire les précieux Dofus... Demande au Grandapan ce que tu veux...";
D.q[5487] = "Si vous aimez la flore, discutez donc avec Erty, c\'est un botaniste averti.";
D.q[4473] = "Commence par regarder dans les ateliers de forgerons et de mineurs. Pas ceux de Bonta, évidemment... ni ceux d\'ici.";
D.q[6738] = "Toujours pas de bandits en vue ? C\'est presque dommage, ce voyage est d\'un ennui... Vous voulez bien faire quelques bouffonneries pour me divertir ? Non ? Tant pis.";
D.q[2022] = "Arrête de me regarder comme ça !...Vas-y frappe MOI !  .. Frappe moi fort, ALLEZ !";
D.q[3644] = "Arrête de me faire perdre du temps en bavardant. Il se trouve à deux pas.";
D.q[4574] = "Des menaces proférer vous osez ? M\'attaquer vous pouvez, mais votre sécurité je ne pourrai alors assurer car pas mangé depuis longtemps je n\'ai.";
D.q[3929] = "Des choses étranges au château ? Non, j\'ai juste vu passer Allisteria récemment.";
D.q[3930] = "Des choses étranges au château ? Non, on a juste eu la visite de la petite Allisteria. Enfin, petite, elle est grande maintenant, en âge d\'être mariée!";
D.q[2153] = "Pas de sang ? Tu n\'as pas trouvé Radlu Minite Le Mineur Sombre ? Il paraît qu\'il passe son temps à goûter l\'eau de vie du Tavernier. Reviens me voir avec quelques gouttes de son sang.";
D.q[3926] = "Des choses étranges au château ? non, à part la visite d\'Allisteria. D\'habitude, elle ne quitte jamais ses bouftous.";
D.q[2537] = "L\'assistant de Surivitna va t\'y accompagner. Il est chargé de remercier la déesse de ses bienfaits. Notre déesse est TRES susceptible, tu sais... Même le Grandapan n\'oublie pas de la remercier dans ses prières, c\'est dire...";
D.q[4386] = "Pas d\'attaque ? Alors je n\'ai plus de doute. Quelqu\'un de haut placé ici renseigne les bandits. Nous avons quelqu\'un de corrompu dans nos rangs, c\'est certain. Il accepte probablement des pots-de-vin pour divulguer des renseignements secrets, et pour faire stopper nos enquêtes. Ça expliquerait également la réticence du conseil à mettre un terme aux agissements de ces bandits.";
D.q[2779] = "Hin ?";
D.q[2780] = "Dès que tu as fini ton entrainement, viens me voir, je t\'attends en dehors du Dojo. ";
D.q[2429] = "Le tailleur est toujours à la pointe de la mode. Les tailleurs créent des chapeaux et des capes magiques, qui, en plus de donner certains pouvoirs à leurs porteurs, leur donnent une apparence unique. Ce métier est très difficile, tant les premiers vêtements sont peu inspirés. Sans compter que les tailleurs jalousent leurs secrets et leurs enseignements sont plus rares que certaines de leurs créations.";
D.q[2230] = "Merci mon chou, tu es un peu en retard, mon précieux goûter a perdu un peu de sa fraîcheur. Je suis obliiigé de réduire un peu le coût de livraison.";
D.q[3530] = "Voici des Kamas, je vais le fourrer avec le gâtrooll et le cuire dans la gratrooll avant de le dévorer à pleine dents, puis je me nettoierais les babines dans cette cape à cause de tout ce bon gras qui tache.";
D.q[6454] = "Prends ça ! *Schlak* \nOn dirait que tu aimes ça.";
D.q[1229] = "Prends cette pince ! Pour retirer une dent à un bouftou, c\'est un jeu d\'enfant, tu mets un pied sur la bête, tu choisis une dent, et tu tires un coup sec avec la pince !";
D.q[480] = "Tenez, j\'ai noté sur ce parchemin la liste des parchemins que je dois expédier, n\'hésite pas à me demander des renseignements.";
D.q[2794] = "Ne dis rien ! Je sens la mort rôder prêt de toi... tu désires rentrer dans l\'obscurité de la forêt interdite... n\'est-ce pas ?";
D.q[6408] = "Je n\'y connais rien, je n\'avais jamais cuisiné avant d\'être capturée par Brâkmar. Vous feriez mieux d\'interroger Bout d\'chair, à l\'atelier des bouchers de la cité.";
D.q[2809] = "Trés bien ! Une dernière question : \nQui est l\'auteur du livre \"L\'art Pandawushu\" ?";
D.q[2813] = "Le Boufton est blanc avec une queue noire, alors que le Pandawa est noir avec... des bambous dans le dos ! Le chemin est long sur la voie de l\'illumination ! Un jour peut-être, petit Scarafeuille...";
D.q[3733] = "Fais ton choix.";
D.q[570] = "On dit que cette île est la création du dieu Moon. Pour la surveiller, il s\'est incarné dans un être de chair et de sang. Mais nul autre que ses adorateurs ne peut l\'approcher à moins de lui faire une offrande. Concrètement, pour s\'approcher de Moon, il faut posséder de nombreuses noix de Koko;\r\n            à chaque passage près d\'un totem Koko, un nombre égal à sa grandeur vous sera retiré automatiquement, simple non ohoh!";
D.q[2352] = "Voyons voir...Oh ! Vous souhaitez vraiment devenir alchimiste ? Oui je suis bien formateur. Très bien alors, écoutez bien : un alchimiste accompli doit savoir lire l\'intensité, en essence magique, de n\'importe quel objet, et pouvoir la manipuler à sa guise. Posez donc un regard nouveau sur tous les objets passés et futurs en votre possession. ";
D.q[2848] = "Bravo, je te nomme au grade de Sankwa !";
D.q[2235] = "Ha, merci pour ce gâteau, c\'est pour Oz. Avec ça, je peux faire de lui ce que je veux héhé... Délai tenu pour la livraison, tiens.";
D.q[3684] = "Tu diras à ce bon à rien de Disskray qu\'il y a plein de parasites dans les champs et ils détruisent mes récoltes, mais ça il doit déjà le savoir.";
D.q[3083] = "Merci pour ta discrétion. Si tu as un peu de temps devant toi, repasse me voir, j\'ai peut-être une livraison à te confier.";
D.q[3102] = "Merci de vouloir aider une pauvre courtisane. J\'aimerais tant habiter dans une jolie petite maison isolée loin de la cour. Gemfé Labelle m\'a parlé d\'une ancienne planque à lui. Tu devrais aller le voir pour lui demander si je peux y vivre.";
D.q[1185] = "Comme je disais : \'rien de plus fa... Ahem...\'. Bon courage pour ce métier. Ah n\'oubliez pas de vous procurer un hachoir à poisson, indispensable pour exercer votre métier. J\'en vends si vous le désirez.";
D.q[2119] = "Merci beaucoup, revenez me voir bientôt si cela vous dit. Vous êtes un bon travailleur !";
D.q[1322] = "Merci mille fois, je vais pouvoir finir le repas.";
D.q[1988] = "Merci beaucoup. \n*Yol se tourne vers Locette et lui fait boire la potion*";
D.q[1897] = "Merci beaucoup. Il faut faire vite, il ne me reste plus beaucoup de temps avant le premier rendez-vous.  Bon voyons...";
D.q[2720] = "On le dit. Ses chemins sont tortueux et les créatures qui la hantent sont peu amicales. Mais un certain Wally Elconom a réussi à en dresser la carte. Il serait utile que tu le rencontres. On le voit souvent du côté d\'Amakna.";
D.q[2922] = "Que me vaut la visite d\'un de mes apprentis ?";
D.q[6756] = "Je vous rappelle que c\'est vous qui devez partir en éclaireur, vous êtes payé pour ça. \nAh bon, on ne vous paye pas ? Vous vous faites av... je veux dire tant mieux, vous êtes une personne honnête, charitable et fidèle à sa cité et à ses principes.";
D.q[3311] = "Merci, notre bon roi Allister va pouvoir parader sur ces fières montures maintenant !";
D.q[2257] = "Merci pour l\'entraînement, ça m\'a fait du bien. J\'ai une dernière faveur à te demander. Après, je te laisserai continuer ta route... Avec tout ce remue-ménage, quelques-uns de nos Bouftous se sont échappés, et certains se sont égarés du côté des souterrains...";
D.q[294] = "J\'échange un pain au curry sans curry contre 5 fleurs de pissenlit diabolique. J\'en ai besoin pour masquer les odeurs de pain rassis.";
D.q[2938] = "Félicitations, vous avez réussi à me vaincre, mes sbires et moi. Acceptez ce cadeau en guise de reconnaissance.";
D.q[2949] = "Hmm";
D.q[1914] = "Je vous explique : il me faut quelqu\'un d\'assez fort pour tracter 1500 pods de pain, et qui sache courir vite - ce qui veut dire être agile... Cherchez une personne qui ressemble à ça, et parlez lui. Si vous pensez qu\'elle convient, remplissez cette fiche et posez la paume de sa main en bas. Vous saurez ainsi directement si votre choix est le bon...";
D.q[2945] = "Je pense que vous n\'avez rien à faire par ici.";
D.q[5573] = "Salutations. As-tu utilisé la potion sur les dépouilles des renégats ?";
D.q[3431] = "Merci, Merci beaucoup, allez parler à ma femme, Madame El.";
D.q[3098] = "Merci à toi, je suis prêt à affronter le requin maintenant !";
D.q[3903] = "Je vais doubler la sécurité... Puisque tu m\'as averti, je te prends à mon service. Si tu reviens plus tard, j\'aurai sans doute du travail pour toi.";
D.q[2963] = "<B> test </B> \n<I>test </I> \n<U>test </U>";
D.q[3054] = "Merci, voilà pour toi.";
D.q[5667] = "Merci. Quand tu en auras terminé avec le reste, nous irons à la salle du rituel.";
D.q[2966] = "Alors, tu es de retour ? Mais tu ne m\'as pas ramené des oeufs de Tofu ? Qu\'est-ce que tu attends ?";
D.q[3049] = "Attention, seuls les fantômes de familiers peuvent rentrer dans ce sanctuaire #1 !\nSi tu as avec toi ce genre de créature, tu peux tenter de la faire rentrer, mais attention, elle n\'a presque aucune chance de survivre seule, il faudrait qu\'elle soit accompagnée d\'autres fantômes de familiers pour espérer sortir de ce sanctuaire.\nSi ton fantôme de familier réussi à vaincre ceux d\'Oshima, il devrait avoir la chance de le rencontrer.\n\nEs-tu certain de vouloir faire rentrer dans ce sanctuaire un de tes fantômes de familiers ?";
D.q[2967] = "Bien le bonjour, aventurier, que puis-je pour ton service ?";
D.q[2979] = "Vivement le déluge !";
D.q[3121] = "Tu m\'as vaincu... Mais j\'ai vraiment apprécié... ce combat... \nC\'était terrible... La façon dont tu te déhanches... avec un style... incroyable... \nTu es vraiment trop... rapide... pour moi... \nTu as vraiment... un style... de combat... particulier... \nComme moi... tu es un original... \nJ\'espère... que tu sais prendre... la vie du bon côté...";
D.q[915] = "Merci #1, toujours aussi serviable. Je vais pouvoir entraîner mes gars sérieusement.";
D.q[1906] = "Merci beaucoup, voilà je vous donne une liste de personnes à livrer. Il faut qu\'ils aient reçu leurs gâteaux pour dans...environ 20 minutes. Les gâteaux sont déjà payés mais pas la livraison. Ce sera votre paye.";
D.q[1119] = "Merci beaucoup, avec ça mon Tabi devrait reprendre du poil de la bête.";
D.q[2569] = "Merci bien ! Les prières montent plus vite aux cieux lorsqu\'elles sont arrosées d\'une bonne Pandneken ! Tu peux te balader le temps que je finisse la Pandn...prière.";
D.q[6334] = "Merci à toi mais je préfère que tu gardes ton argent. C\'est un plaisir d\'offrir un exemplaire de la méthode d\'élevage canin à une chatte au si joli minois.";
D.q[1258] = "Merci ahahaha, je t\'ai bien eu. Comment une petite fille comme moi pourrait connaître la recette d\'un poison magique. ahahah !";
D.q[1920] = "Merci beaucoup. Va voir le tavernier Tek Abir, il commence à avoir l\'habitude.";
D.q[1855] = "Merci beaucoup. Tenez voici un peu d\'argent de poche, vous l\'avez bien mérité. Je me demande quand même ce que ces sousouris viennent faire ici. Je suis sure que c\'est à cause de toute cette pagaille dans les souterrains. Ca fait remonter les sousouris ça... Kwikwi est d\'accord avec moi !";
D.q[4147] = "Merci beaucoup, j\'ai désormais tout ce qu\'il me faut.";
D.q[6465] = "Merci, je te dois une fière chandelle. Je vais te donner une gelée de synthèse que j\'ai moi-même inventée et une recette pour que tu puisses l\'utiliser. Si tu n\'as pas les compétences requises, demande à un bricoleur de t\'aider. Je te préviens de suite, je ne te donnerai pas davantage de gelée, alors assure-toi que le bricoleur qui l\'utilise soit assez compétent pour ne pas la gâcher.";
D.q[1924] = "Merci beaucoup, tenez voici un échantillon de ce que nous pouvons faire, n\'hésitez pas à repasser. Ah tant que je vous tiens. Seriez vous intéressé pour un peu d\'argent facile ? Il me faudrait d\'autre éléments...";
D.q[2997] = "Alors ? Tu n\'as toujours pas trouvé de copie de mon livre ? Cherche dans Astrub, tu devrais pouvoir en trouver un exemplaire !";
D.q[5526] = "Merci, grâce à toi mon compte bancaire à Brâkmar va déborder. Bon courage pour la suite.";
D.q[2031] = "Vous êtes plutôt rapide, c\'est une bonne chose. Mais ce qui compte c\'est la force que vous mettrez dans vos attaques, et le courage d\'aller au bout de vos convictions. Et, par dessus tout, rester juste... Ce sont les maîtres mots de notre maison, ne l\'oubliez pas. Maintenant, donnez moi votre épée, pour que j\'y appose la marque qui scellera votre destin... *Rok utilise divers outils mais n\'a pas l\'air très habile de ses dix doigts si ce n\'est avec une epée*... Voilà, c\'est terminé !";
D.q[1219] = "Merci, et bienvenue à toi, frère !";
D.q[2846] = "Y\'a du soleil à PandaladirLAaAdaAada... Pardon ? Je suis occupée, désolée de ne pouvoir t\'aider.";
D.q[3012] = "Va voir Hugo Bélo, dans le temple de la déesse Féca. Il saura t\'en procurer.";
D.q[3205] = "C\'est très simple, il te faut une clef pour rentrer ! Autrefois, j\'étais le seul à en posséder une, mais les choses ont bien changé, et je crois avoir perdu mon trousseau de clefs sur cette île, mais je ne sais pas où. Une de ces satanées créatures a sûrement  dû me le subtiliser pendant mon sommeil.";
D.q[3709] = "Merci de tes conseils, tu as déjà l\'air d\'un vétéran. Je vais dormir un peu afin de rendre hommage à mon dieu. Sadida dit qu\'il faut toujours se reposer après un effort intellectuel.";
D.q[2254] = "Merci pour les cuisses... Il me manque encore les 2 citrons pour ma recette... Vite ! Dépêche toi ! J\'ai faim...";
D.q[3111] = "Merci pour la pelle. Pars remercier Rocco Fidelio pour ses sacs de patates. Dis lui qu\'ils devraient arrêter plus de monde pour redonner un peu de vie à cette belle prison au bord de l\'eau. Tu devrais rester avec moi, éplucher des patates, c\'est tout un art !";
D.q[1024] = "Merci pour cette poudre, les Brâkmariens n\'ont qu\'à bien se tenir. Hehe !";
D.q[2141] = "Tu as ta réponse ? Bon alors transmets la à ce vieux gripsou de Joe.";
D.q[584] = "Merci viande ! Toi pouvoir aller village, toi visiter et ensuite revenir ici pour être cuit ! Toi pas t\'éloigner trop !";
D.q[2126] = "Merci mon gars, tu seras toujours le bienvenu ici. Si jamais tu as un pépin d\'argent il y aura toujours un petit boulot pour toi.";
D.q[1104] = "Ah l\'air nauséabond, l\'obscurité permanente, les ombres sur les murs...Que cette triste ville de Brâkmar est belle.";
D.q[5256] = "J\'ai des entretiens sur cette affaire. Reviens me voir un peu plus tard.";
D.q[4167] = "Grâce à vous, je me sens revivre, mon envie de séduire Jeanne est désormais sans limite, nos petits jeux de séduction n\'ont jamais été aussi savoureux !";
D.q[1064] = "Merci mon gars. Tu as été efficace... mais bon, ce n\'est pas cela qui fera de toi le plus grand des étripeurs de Brâkmar.";
D.q[920] = "Merci mon gars, tu as été rapide. Tu m\'as l\'air vif et discipliné...";
D.q[3039] = "Tiens, je te donne ce manuel : à lire une fois que tu auras accompli cette mission ! Ouvre l\'oeil, et le bon !";
D.q[6169] = "Halte-là. Je surveille cette ville alors pas d\'embrouille sinon c\'est directement en prison sans passer par la case départ, compris ?";
D.q[1337] = "Je te remercie, grâce à toi nous pourrons assister à la cérémonie d\'honneur. Bon je vais pouvoir faire une sieste jusque ce soir, maintenant.";
D.q[2068] = "Merci à toi. Ah, j\'ai oublié de te dire. Si elle se met à courir, ne la lâche pas d\'une semelle. Je veux que tu sois toujours collé à elle. Comme ça je suis sûr qu\'elle ne fera pas de bêtises. Bon je pense que tout se passera bien... je te la confie. A tout de suite.";
D.q[3070] = "Manger avec ce gros ballot de Kartier Tremai ? T\'es pas le premier messager qu\'il m\'envoie. Le jour où il viendra lui-même, nous en reparlerons !";
D.q[2097] = "Merci, je savais que je pouvais compter sur vous.";
D.q[6238] = "Merci, je ne savais pas que les Brâkmariens étaient aussi sympas. Ce document doit être très important je suppose. Tu lui veux quoi au juste à Xephirès ? C\'est bizarre quand même que les Brâkmariens s\'intéressent à un Bontarien de si près.";
D.q[3485] = "Merci, c\'est parce que j\'ai mangé trop de Goblins Rouges pendant la bataille de Bworkdrift. J\'étais dans le camp des Goblins Blancs.";
D.q[3081] = "La vieille Verumacha me cherche des poux ? Ce n\'est pas la cheftaine des douanes pour rien. La vie de contrebandier est bien rude de nos jours. Donne lui ces 1000 Kamas. Cela la calmera peut être. Reviens me voir de suite, je te filerai un peu de marchandise interdite pour ce service. Fais vite, sinon je te retrouverai et te donnerai à manger aux vrais requins !";
D.q[2749] = "Je vois dans tes yeux que tu désires te rendre à la forêt maléfique, exact ?";
D.q[1427] = "Merci, voilà 200 kamas pour la course, n\'hésite pas à revenir me voir, je recherche régulièrement des ingrédients.";
D.q[4886] = "Si Amayiro a un plan contre Brâkmar, ce sera avec honneur que j\'y participerai.";
D.q[1282] = "Merci je vais étudier ça tranquillement, j\'espère que tu as profité de ta balade, les prochaines missions ne seront pas de tout repos...";
D.q[1622] = "Laisse-moi passer ! J\'ai perdu l\'inducto-réduleur de mon Bumper, du coup impossible de rentrer chez moi. Si seulement il me restait assez d\'energie Oclitique pour réparer mon modèle BZ4A...";
D.q[579] = "Ce serait vraaaiment gentillet *hic* sans lui mon gééénie s\'est tuuu *hic* Mais il m\'en faut un coomplet *hic* mon trésor sera alors mooon dû *hic*";
D.q[1055] = "Lui ? Ce bouffon a dû avoir du bol finalement. Enfin, pas merci pour ton travail. Je te donne l\'autorisation de faire ce que tu veux. Là, j\'ai pas le temps de m\'occuper de toi alors dégage !";
D.q[5623] = "Ca aura été rapide, tu ne trouves pas ? \nPuisque tu t\'en es bien sorti je pense que tu mérites ton titre d\'Adepte des Ecrits. \nQue Jiva veille sur tes pas.";
D.q[3107] = "Olalala, ce que tu peux être lent, mes prétendants auraient déjà finit cette petite chose que je te demande.";
D.q[2788] = "Je connais plus ou moins le chemin jusqu\'au garde du fond... Je l\'entends ronfler comme à son habitude. Observe calmement la pièce : si tu vois que je peux avancer un peu sans me faire repérer, donne un coup sur le sol.  \nLes gardes d\'ici sont assez méthodiques : observe les et tu devrais pouvoir me guider. Le lourdaud du fond dort plus ou moins profondément, écoute ses ronflements et dis-moi quand lui sauter dessus sans risque ! Si tu as tout compris on va faire un essai.";
D.q[4015] = "C\'est une somme correcte, je vous suis. Vous avez une tenue pour moi ?";
D.q[6359] = "C\'est un navire de guerre bontarien ça, non ? Je ne savais même pas qu\'il devait bientôt accoster. Tu devrais interroger Verumacha, elle devrait être au courant que les Bontariens vont se pointer dans son port même si ça m\'étonne que personne ne m\'en ait informé.";
D.q[2188] = "Alors le livreur est sauf ? Pas encore ? Courage j\'ai confiance en vous.";
D.q[4891] = "(Soudain, tout devient noir et vous tombez au sol. Attaquer Turorte n\'était peut-être pas une si bonne idée.)";
D.q[2474] = "Pour un pont, c\'est un beau pont ! On leur a apporté un sacré coup de main, aux Pandawas. Mais il faut qu\'on colmate ces brèches, sinon tout risque de s\'écrouler. Mouais... de l\'ambre, c\'est bien ça qu\'il nous faudrait.";
D.q[6566] = "C\'est bien, bon chienchien. Maintenant curez-vous le nez avec les orteils.";
D.q[6431] = "Nous avons récemment eu quelques problèmes avec des Ecaflips un peu éméchés. La situation s\'était tellement dégradée que nous avons failli en venir aux mains, jusqu\'à ce que leur chef leur fasse entendre raison en leur rappelant qu\'ils ne devaient pas se faire remarquer et qu\'ils avaient un travail à terminer. Tu parles, pour l\'occasion c\'était raté.";
D.q[634] = "Oubli d\'Herbe folle : 5 verveines, 10 Bois d\'orme, 40 tiges de pissenlit diabolique, 40 fers, 40 racines d\'abraknydes. \nFlèche d\'Expiation : 5 Bois élastiques, 5 surpuissants arc du roi des borins, 1 pierre à aiguiser, 10 sangs de vampire, 10 slips en cuir du Captain Chafer. \nOubli de Mot de prévention : 3 clochettes, 50 lisseurs, 50 louffeurs \nOubli d\'Attirance : 4 Orties, 10 célébrités, 10 anneaux de satisfaction, 2 capes du coq Hû";
D.q[3161] = "Approche, approche si tu n\'as pas peur ! Viens me voir en face, que je puisse lire la peur dans ton regard !";
D.q[3078] = "Voilà qui est mieux, je suis éreintée par toutes ces émotions. Va donc me chercher du lait de cochon de lait brave petit, je te donnerai des bonbons. C\'est mauvais pour mes dents.";
D.q[5604] = "C\'est une bonne nouvelle que tu m\'apportes là. Grâce à la croissance accélérée des céréales, nous n\'aurons plus de problème de nourriture pour les dragodindes. Nous pourrons sûrement faire la même chose avec les autres céréales pour nourrir les troupes. \nTe voilà donc Ecuyère.";
D.q[2585] = "Il ne suffit pas de l\'acheter, mon brave, il faut maintenant l\'utiliser... avant de le porter, renifle-le à plein nez comme tu le ferais d\'une fleur...";
D.q[2437] = "Toutes les activités relatives aux poissons se trouvent dans le bâtiment en forme de kralamour.";
D.q[3988] = "Peu me chaut ! Allons bon twain quéwir des suivants.";
D.q[307] = "Non ! C\'est pas ça !";
D.q[4653] = "Ah, très bien. Tu as respecté mes ordres. Tant pis pour l\'espion, il n\'avait qu\'à être plus doué en esquive !\nVoici ta paye.";
D.q[4089] = "Ce n\'est pas si simple, es-tu prêt à recommencer ?";
D.q[6329] = "Mais c\'est horrible ! Tu as un véritable coeur de pierre plus solide encore que celui d\'un craqueleur.";
D.q[6767] = "C\'est aussi ce que Sadida me disait quand nous discutions... enfin, c\'est surtout moi qui parlait, lui se contentait de m\'écouter avec grande attention en hochant parfois la tête de contentement. Mais bavarder ne règle pas le problème de votre présence en ces lieux. Vous voulez que je vous fasse sortir de là ?";
D.q[1188] = "L\'Oeil Attentif est chargé au sein de Bonta des missions nécessitant délicatesse et discrétion. Certains disent que nous faisons de l\'espionnage ou du sabotage, mais personnellement je préfère parler de prise d\'informations et de nettoyage à grande échelle...";
D.q[843] = "Les Bontariens sont vraiment trop calmes. Cela cache quelque chose. Un de nos espions a infiltré Bonta, il s\'appelle Trojen Tihpor. Il doit être actuellement de garde autour des remparts dans la cité. Va le voir discrètement et rapporte-moi un rapport des activités bontariennes.";
D.q[842] = "Les Bontariens sont bien calmes en ce moment. Il ne se passe plus grand chose à vrai dire. Tu peux en profiter pour te reposer.";
D.q[1706] = "Le temple Ecaflip se trouve pas trés loin d\'ici au nord du village d\'Amakna, adresse toi à Félénie Grismina pour commencer ta formation.";
D.q[1709] = "Le temple Cra se trouve pas trés loin d\'ici au sud du village d\'Amakna, adresse toi à Eluhise Valing pour commencer ta formation.";
D.q[3357] = "Le roi des Bouftous va bientôt recevoir de la visite.";
D.q[1641] = "Le temple Feca se trouve à l\'Est sur la côte d\'Asse, adresse toi à Hirpine Fécalamité pour continuer ta formation.";
D.q[1707] = "Le temple Eniripsa se trouve à l\'Est du village d\'Amakna, adresse toi à Limine Bryone pour commencer ta formation.";
D.q[3744] = "Un alchimiste peut créer moult breuvages qu\'il stocke dans des fioles. Il peut concocter des potions de soins, des potions de rappel à son point de sauvegarde, des potions d\'oubli de métier et bien d\'autres encore !";
D.q[1708] = "Le temple Iop se trouve au sud du village d\'Amakna, adresse toi à Tajide Ragalde pour commencer ta formation.";
D.q[3312] = "Le roi attend son haras. Ta tâche est royale, essaie d\'être plus prompt !";
D.q[3323] = "La montagne des Koalaks n\'a pas été bien cartographiée. J\'aimerais bien que de jeunes aventuriers curieux et téméraires me ramènent une description de cette lointaine contrée...";
D.q[2347] = "L\'alchimiste est un manipulateur d\'éléments, magiques ou non. Il transforme des matières en d\'autres. Mais surtout, ne voyez pas l\'alchimiste comme un rat de laboratoire. Un vrai alchimiste passe autant de temps dans son bureau qu\'à voyager à travers le monde à la recherche d\'ingrédients rares. Et je peux vous dire, par expérience, que lorsque notre réserve de poils de mulou est vide, il faut prendre son courage à deux mains!";
D.q[3522] = "Le sort Demâhût !";
D.q[2380] = "Etre forgeron cela demande beaucoup de temps, et pas mal de connaissances. Impossible d\'être forgeron sans connaître un bon mineur et un bon bûcheron pour les matières premières. Enfin il y a toujours l\'Hôtel de Vente pour récuperer tout ça à bon prix, mais moi j\'aime pas trop.";
D.q[3919] = "Le prince d\'Oy ? Oui, je crois qu\'il chasse au sud de Bonta, mais je ne sais pas où précisément. En plus, je crois qu\'il est parti seul, étrange pour un prince.";
D.q[3918] = "Le prince d\'Wa ? Oui, je crois qu\'il chasse au sud de Bonta, mais je ne sais pas où précisément. En plus, je crois qu\'il est parti seul, étrange pour un prince.";
D.q[2751] = "Le Shaman me semble être quelqu\'un de compétent en matière de certificat. Va le trouver.";
D.q[1710] = "Le temple Sadida se trouve au sud du village d\'Amakna, adresse toi à Silimote Fougaris pour commencer ta formation.";
D.q[4236] = "Nourrie tous les jours d\'une haine féroce pour ses geôliers, après avoir obtenu l\'immunité pendant si longtemps, la créature s\'est évadée. D\'elle, il ne reste rien, ou si peu, quelques poils de dos. Qui sait quels dégâts elle commettra demain.";
D.q[5376] = "Je ne serai pas retenu prisonnier longtemps. Mes frères brâkmariens me libèreront !";
D.q[1704] = "Le temple Sram se trouve pas trés loin au sud-est d\'ici, adresse toi à Sirmine Daguiero pour commencer ta formation.";
D.q[1187] = "Le Coeur Vaillant regroupe les plus valeureux guerriers de Bonta. Bravoure, courage et détermination sont nécessaires pour y entrer. \nNotre devise pourrait être : \'Frappons vite et fort, le Mal ne se relèvera pas\'";
D.q[3122] = "Je suis enfermé... dans ma propre caverne... depuis des lustres... \nComment... cela est-ce possible ? \nJe n\'en sais... rien... \nC\'est Skeunk... et ses fichues Sadidettes... Ils m\'on volé... mon précieux... mon dofus... le mien... celui que je chérissais tant... \nHum... tu n\'es pas le premier à venir ici... \nOshar Marif... à côté de moi... a lui aussi tenté de m\'affronter... mais... je l\'ai vaincu... et il est trop faible... pour repartir seul...";
D.q[3612] = "La belle Gobrose, esclave de Bworkcine. Peux-tu la libérer ?";
D.q[2799] = "L\'appel de la forêt, même maudite, te fait vibrer disciple.";
D.q[3938] = "Ah, ça bouge au château. Tu devrais demander à Guedin, c\'est lui qui leur porte des sacs.";
D.q[1485] = "C\'est simple, il suffit que vous trouviez l\'entrée de la grotte légendaire aux larves dorées. Selon la légende elle se trouverait un peu à l\'Ouest d\'Amakna. Les pouvoirs secrets de la larve dorée vous permettront d\'y rentrer. ";
D.q[1714] = "Le défi est simple, dans la cour de ce temple, tu as dû remarquer qu\'il y avait beaucoup d\'animaux. Parmi eux se trouve un Tofu de couleur noire et j\'aimerais que tu me rapportes une de ses plumes, pour me prouver ta valeur au combat.";
D.q[6728] = "Le conflit entre les deux grandes cités est parfois un peu mou. Il a besoin de dynamisme. Je suis là pour aider ceux qui pensent comme moi. J\'ai un don pour localiser les ennemis. Je désigne les cibles et la traque commence. Alléchant, non ?";
D.q[2015] = "Des fioles cristal de pâle Anthir, hummm... tu désires voir l\'avenir ? Tu me sembles un peu inexpérimenté pour cela. Enfin, fais bien attention, nombre de gens ont perdu la vue en usant de ces cristaux. Tiens, voilà pour toi.";
D.q[5575] = "Mais chut je te dis ! Ton livre se trouve ici, non, plus à droite, voilà. En silence ! Maintenant que tu l\'as, ouste !";
D.q[1135] = "Interressant. L\'heure approche où nous pourrons détruire Bonta, l\'usurpatrice. Les nouvelles que tu m\'apportes vont nous permettre d\'améliorer notre plan de bataille.";
D.q[2428] = "Le cordonnier fabrique à partir de cuir et d\'un peu de métal, des ceintures et des bottes de toute beauté. Associées aux bonnes ressources magiques, certaines ceintures prêtent à leurs porteurs de terrifiants pouvoirs.";
D.q[3408] = "Tu avances, mais la fin de la route semble de plus en plus loin, tout çela en vaut-il la peine?";
D.q[3896] = "Bonjour, loyal sujet ! Longue vie à notre Roi bien-aimé ! Puisse-t-il régner encore de nombreuses années !";
D.q[4418] = "La découverte de ce traître a laissé nos supérieurs très soupçonneux. Je préfère ne pas te donner de tâche pour l\'instant.";
D.q[962] = "Les quartiers de Bonta sont découpés en fonction des activités exercées par les différents artisans. Vous pouvez reconnaître l\'activité principale d\'un quartier par les ornements sur les façades des maisons et aussi par les mats dont les armoiries correspondent au corps de métier.";
D.q[1983] = "Le médecin ne connaît pas pareille maladie, mais il refuse d\'abandonner Locette à son triste sort;\r\n            il m\'a demandé s\'il pouvait essayer différents remèdes. J\'ai bien sûr accepté, mais il lui manque des ingrédients, il ne peut se déplacer et je n\'arrive pas à me résoudre à la laisser seule. Voudriez-vous m\'aider ?";
D.q[1373] = "Vous avez trouvé les échantillons que je vous ai demandés ?";
D.q[4300] = "As-tu récupéré les matériaux que je t\'ai demandés ou dois-je confier cette tâche à quelqu\'un de plus doué ?";
D.q[331] = "Vous n\'avez pas tout ce que je vous ai demandé ! Ne tentez pas de m\'escroquer, où j\'appelle mon ami Baracouilla afin qu\'il vous botte les fesses ! Au secouuuurs !";
D.q[4057] = "Un prince Wabbit, c\'est mieux que rien, avec un peu d\'ash... pardon, d\'astuce je devrais pouvoir arranger tout le monde. Laisse-moi étudier les préparatifs. Pendant ce temps, trouve ce prince et convaincs le d\'épouser la princesse.";
D.q[7466] = "Le premier pouvoir permet d\'oublier totalement tes caractéristiques, elles seront identiques à celles que tu avais lorsque tu es arrivé sur le Monde des Douze. Tout ce que tu auras appris grâce à des parchemins sera perdu. Tu pourras grâce à ce pouvoir, changer complètement ta façon de combattre et d\'utiliser tes sorts, en changeant tes éléments de prédilection.";
D.q[2287] = "Tout comme toi, toutes les créatures ici-bas sont résistantes ou sensibles aux quatre éléments primordiaux : air, terre, feu, eau. Apprends à reconnaître les forces et faiblesses de chacune (et les tiennes !). Et le Monde sera sûr pour toi. Ou presque.";
D.q[3751] = "La première chose à faire est d\'équiper son outil de travail. Ensuite choisis de moudre ton blé avec le concasseur. Deux mesures de blé sont suffisantes pour une mesure de farine. tu dois voir le résultat de ton travail avant de commencer à combiner les éléments.";
D.q[7066] = "Les pierres suivantes ... \n";
D.q[1672] = "OYEZ ! OYEZ ! METTEZ À L\'ÉPREUVE VOTRE MEMOIRE ! REVELEZ VOS CAPACITES CACHEES ! Vous, oui vous là ! Je sens votre potentiel ! Cela vous dit de les dévoiler au grand jour ? C\'est seulement 20 Kamas et cela peut rapporter de nombreux jetons !";
D.q[1470] = "(Mais qu\'est ce que tu fais là toi, c\'est pas fait pour un démon comme toi ici, et tu vas faire sauter ma couverture, allez, file ou j\'appelle la garde)";
D.q[2719] = "La déesse t\'a bien inspiré en guidant tes pas jusqu\'au Dojo. Je vais t\'enseigner de ce pas l\'art ultime et sublime que l\'on nomme Pandawushu... La cotisation s\'élève à 10000 kamas, payables d\'avance...";
D.q[4211] = "Hum, d\'après ta constitution, je peux déterminer qu\'il me faudra une relique du Corailleur Magistral, une relique de Gourlo le Terrible et une relique du Rasboul Majeur pour préparer ta potion. Une fois réduites en poudre, je pourrais en retirer toute la puissance magique dont j\'ai besoin.";
D.q[136] = "(Grizmine inscrit votre nom sur une grille, lance des dés à 37 faces en l\'air, les rattrape, fait des calculs étranges, se gratte les moustaches et réfléchit...)";
D.q[2233] = "Cool ! Reviens me voir dans 5 minutes. Je vais t\'faire un arc du tonnerre...";
D.q[3184] = "La dernière fois que j\'ai vu le Maître Corbac, il était dans la première salle de la bibliothèque, ou dans la deuxième, ou dans la cinquième, ou peut-être même dans la sixième, je ne m\'en souviens plus.";
D.q[1884] = "Tes informations sont intéressantes, mais il faudrait que j\'en sache davantage pour tirer des conclusions fiables. J\'ai une connaissance à Amakna, un certain Trois-Fleurs, demande lui de te faire découvrir la végétation de sa région, et ramène-moi un rapport quand tu repasseras à Astrub ! Aller va, jeune disciple, haha !";
D.q[825] = "Demande au garde qui est à l\'entrée si il a pas besoin d\'un coup de main, personnellement, je n\'ai rien à te donner.";
D.q[3047] = "Nous pouvons enfin nous rendre à nouveau dans le somptueux château d\'Allister.";
D.q[6729] = "As-tu besoin de quelque chose ?";
D.q[3185] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la première salle, ou la deuxième, ou la cinquième, ou peut-être la sixième, je ne m\'en souviens plus.";
D.q[3190] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la troisième salle, ou la quatrième, ou la septième, ou peut-être dans la huitième salle, je ne me souviens plus.";
D.q[3187] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la troisième salle, ou la quatrième, ou la septième, ou peut-être dans la huitième salle, je ne m\'en souviens plus.";
D.q[3196] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la neuvième salle, ou la dixième, ou la treizième, ou peut-être dans la quatorzième salle, je ne m\'en souviens plus.";
D.q[3189] = "La dernière fois que j\'ai vu le Maître Corbac, il se cachait dans la première salle, ou la deuxième, ou la cinquième, ou peut-être dans la sixième, je ne m\'en souviens plus.";
D.q[3186] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la troisième salle, ou la quatrième, ou la septième, ou peut-être dans la huitième salle, je ne m\'en souviens plus.";
D.q[3197] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la neuvième salle, ou la dixième, ou la treizième, ou peut-être dans la quatorzième salle, je ne m\'en souviens plus.";
D.q[3598] = "Bûcheron ? Bien, ça demande un œil avisé et l\'envie de voyager. Les bons arbres sont rares et il faut prendre garde à préserver les forêts. Ce métier est à la base de nombreux artisanats, qu\'est ce qui n\'est pas à base de bois ? Donc, nous sommes d\'accord, nous pouvons débuter ?";
D.q[2285] = "Nos contrées sont peuplées de créatures toutes plus fascinantes les unes que les autres. Rien de tel que d\'aller à la rencontre de la faune et de la flore locales pour parfaire tes connaissances zoologiques et botaniques. Un coeur léger, des intentions pures, ça suffit à les amadouer la plupart du temps.";
D.q[554] = "Les habitants de l\'île sont assez bourrus au premier abord. Mais ne croyez pas qu\'ils ont une dent contre vous ! Bien au contraire, ils adorent vraiment les touristes. Rien ne surpasse plus leur compagnie que leur chef lui-même. On dit de ce dernier qu\'il est l\'incarnation du Dieu de l\'île : Moon. Ne vous fiez pas à son apparence, il est vraiment très intelligent et drôle.";
D.q[571] = "Les habitants de l\'île? Ahahah ! Il y a bien quelques pirates qui traînent au Sud de la jungle. Ils sont assez froids envers les étrangers ohohoh. Ils étaient déjà là quand je suis arrivé et ils seront probablement là quand vous repartirez, à croire qu\'ils aiment bien cette île Ahaha !";
D.q[2113] = "Salut ! Reviens me voir lorsque tu seras plus vert !";
D.q[1652] = "Les habitants de ce village sont très ingénieux, mais ils n\'ont pas réussi pour autant à rendre leur village imprenable.  \n* frotte sa boule de cristal * \nLes troupes de Bonta contrôlent le village pour le moment, mais peut-être plus pour très longtemps...";
D.q[2972] = "Ahah ! Le coup classique ! On t\'a demandé de le faire, et toi, tu l\'as fais ! Tu pensais vraiment que j\'allais te croire ? En même temps... Un Pandawa, tu dis ? Ca se pourrait bien, ma foi ! Qui serait assez idiot pour se vanter de détenir un Dofawa ?";
D.q[4004] = "Oui, mais après ? Il faut que la paie soit bonne ! Je ne resterai pas cuisinière toute ma vie...";
D.q[368] = "Il nous faudrait 80 unités de Gelée Bleutée et 30 unités de Gelée Menthe.";
D.q[1955] = "La bière est livrée, merci beaucoup. Vous avez empêché celle-ci de se faire voler aujourd\'hui,mais demain ? Pourrez vous faire quelque chose ?";
D.q[173] = "Le Tavernier m\'a demandé de lui ramener du Houblon pour qu\'il le donne à ses associés brasseurs, mais je n\'ai pas le temps d\'aller en acheter à Farle Ingalsse le Paysan. \nSi vous me ramenez une unité de Houblon, je vous offrirai une Bière en échange.";
D.q[4340] = "Le marchand de vin du coin a disparu. Je soupçonne un enlèvement, mais il pourrait y avoir autre chose. Peux-tu te renseigner auprès du tavernier de la Bagrutte ? Le marchand avait pour habitude d\'aller chez lui.";
D.q[2260] = "La carte et ta géoposition te seront très utiles pour te déplacer dans le monde. Les lieux les plus importants y sont marqués par différentes icônes. Tu pourras aussi t\'en servir pour marquer une destination clé à l\'aide du drapeau bleu. Ta boussole indiquera alors ce lieu.";
D.q[2432] = "Le maître n\'est pas à la scierie en ce moment, il se trouve à l\'hôtel des ventes de bois.";
D.q[5720] = "Ton maître d\'Ordre m\'a prévenu qu\'il avait une mission pour toi alors ne reste pas planté là.";
D.q[2433] = "Le maître est parti à la mine, il est à l\'exterieur de la ville, à l\'entrée des mines au nord-est d\'ici.";
D.q[4222] = "Le mécanisme que nous utilisons pour ouvrir cette porte est assez complexe et gardé secret, nous ne voulons pas engraisser inutilement cette créature avec les badauds en quête d\'aventure. \nN\'oublie jamais que cette créature est extrêmement puissante et dangereuse, la carcasse de dragon que l\'on peut trouver dans la tourbière nous laisse penser qu\'il a été tué par cette créature.";
D.q[2466] = "Parle plutôt à mon frère Wilde. Il explique vachement bien et quand y parle on comprend tout c\'qui dit !";
D.q[4228] = "Cette île était là il y a très longtemps, avant même la construction de l\'Horloge de Xelor et la formation des continents ! Ce monstre est un dieu vivant, personne ne peut le vaincre ! Je ne sais même pas si vous êtes assez dignes pour ne serait-ce qu\'avoir le droit de le contempler !";
D.q[1054] = "Eul nom deuch tueur pour tin patro ? Mais bieeeeeeeeeen chur queu jeli conio. Tin echle note sur unt bou popié. Pra cha !";
D.q[4562] = "Cet objet pourrait nous donner le dessus contre Brâkmar.";
D.q[6218] = "La seule personne que je connaisse dont le nom commence par X et qui met les pieds à la tour de Bonta est Xephirès, un notable de la cité. Je ne le connais pas plus que ça, je l\'ai juste croisé quelques fois à la taverne de la Bagrutte.";
D.q[3641] = "Mais c\'est qu\'elle se moque de moi la débutante ! Je vais te dresser moi ! Tu vas filer droit je te le dis, tu vas cracher du sang et pleurer comme la petite fille que tu es !";
D.q[1288] = "Nous avons aménagé cette prison et sa luminosité en prenant Brâkmar comme modèle. J\'espère que vous vous y plairez. Hahaha !";
D.q[1898] = "Les cailloux que j\'ai récupérés sur le tapis proviennent sans nul doute de la grotte au nord-Est donc, Allons-y à deux, nous aurons plus de chance. Partez devant je vous rejoins...";
D.q[1659] = "Le prisme de cette zone n\'a pas encore été reconstruit, le territoire des Dopeuls est inattaquable pour le moment.";
D.q[3742] = "Le port de Madrestam est plein de jeunes pêcheurs, c\'est un bon coin de pêche.";
D.q[4269] = "Je préfère que d\'autres personnes t\'accompagnent, nous ignorons si les bandits sont nombreux et les ressources à leur disposition.";
D.q[4292] = "Alors ? Tu lui as parlé ?";
D.q[4343] = "Disparu !? C\'est pas vrai, c\'était un de mes meilleurs clients ! \nBen, après son passage ici il avait l\'habitude de rentrer chez lui, un peu plus vers l\'Est.";
D.q[4380] = "Alors, as-tu le bijou ?";
D.q[4363] = "J\'ai entendu parler d\'une bande de bandits qui sévit dans les plaines de Cania, pas loin de la foire. D\'après ton enquête, il est possible qu\'ils soient venus jusqu\'ici. \nJe voudrais que tu ailles enquêter là-bas. Reviens si tu trouves quelque chose. Mais si tu ne trouves vraiment rien, reviens quand même.";
D.q[1290] = "Bienvenue dans la noirceur de cette taverne. Je vous en prie, prenez donc place.";
D.q[415] = "La province d\'Amakna est paisible, mais parfois vous serez amené à combattre des monstres, à vous défendre d\'agresseurs, à châtier des agresseurs, ou à défier d\'autres personnes.";
D.q[3699] = "En dosant savamment les ingrédients, j\'obtiens des effets bien curieux. Je me demande si c\'est légal ce que je fais.";
D.q[3445] = "La recette de la Filtounga ? Et pourquoi devrai-je vous donner ce livre ?";
D.q[5616] = "Les âmes des renégats ont fini par réintégrer leur corps. Tu vas pouvoir aller les interroger. Je veux savoir quelles informations ils ont dévoilées aux Brâkmariens. Jiva ne peut tolérer une telle trahison.";
D.q[6721] = "La salle est située sous la Tour de Brâkmar. Tu peux y accéder par un petit passage entre deux étagères, dans la partie sud-ouest tout en bas de la tour.";
D.q[6167] = "Bonjour, adressez-vous à Otomaï. Il vous confiera quelques tâches à la mesure de vos compétences. Et peut être même certains de ses secrets ....";
D.q[2655] = "Le forgeur de bouclier t\'envoie ?  Très bien, équipe-toi de ton bouclier d\'entrainement, si tu es prêt, dis-le moi.";
D.q[6350] = "Le forgeron a refusé de t\'aider et tu l\'as éliminé ? Tu as bien fait. Si nous ne pouvons avoir ce forgeron, alors personne ne l\'aura. Ca fait très Brâkmarien tu ne trouves pas ? \nJ\'avais prévu de te donner quelque chose à faire une fois le forgeron dans notre camp mais comme il est mort ça tombe à l\'eau. Repasse me voir plus tard.";
D.q[2671] = "L\'état des Enutrofs que je soigne ici m\'inquiète, la plupart viennent des mines d\'Astrub, allez voir Gasdaure, c\'est elle qui m\'envoie tout ces malades. Si vous voulez m\'aider, aidez-la !";
D.q[4448] = "Le tacticien est dans la bibliothèque de Bonta. Fais attention aux Crocs Glands.";
D.q[3716] = "Tu peux aussi t\'assoir pour guérir. Repasse donc me voir plus tard, quand tu seras assez fort pour porter des seaux d\'eau.";
D.q[1655] = "Le territoire des Dopeuls, hmm, c\'est un lieu qui regorge de magie. Les créatures qui y résident prennent l\'apparence de tout ce qu\'ils rencontrent. \n* frotte sa boule de cristal * \nJe vois qu\'il y\'a des boulversements d\'alignement fréquent là bas, pour le moment ce sont les troupes de  \nBrâkmar qui contrôlent cette zone.";
D.q[4135] = "Le voyage était finalement assez court et plutôt calme, j\'ai su contourner tous les dangers, je n\'ai pas perdu la main avec l\'âge !";
D.q[2270] = "Les souterrains n\'sont pas sûrs ces temps-ci. Et les Tofus en reviennent malades, c\'est bizarre... Quelques-uns des nôtres sont partis patrouiller et voir c\'qui s\'y passe là-d\'dans.";
D.q[3238] = "Le village dans lequel tu te trouves, n\'est autre que l\'ancien village d\'Amakna. \nSes habitants y vécurent tranquillement pendant de longues années, jusqu\'à ce que de mystérieux Dragoeufs viennent dévaster ce village en dévorant et brûlant la majorité de ses habitants. Ceux qui ont survécu, se sont réfugiés il y a bien longtemps dans ce que nous appelons maintenant le château d\'Amakna.";
D.q[757] = "Pour montrer ton dévouement à la milice tu vas devoir trouver deux jeunes recrues, leurs donner ce coupon et leur dire de venir s\'inscrire à la milice, en venant me voir.";
D.q[611] = "Très bien, un marché est un marché, voilà ton caleçon. Au plaisir de faire d\'autres affaires avec toi.";
D.q[1510] = "Autrefois la guerre entre Bonta et Brâkmar était de nature divine, plus précisément une guerre entre les Gardiens des mois. Brâkmar était la ville construite afin d\'honorer Rushu et d\'assurer sa souveraineté sur Amakna. La guerre atteint un point culminant puis les deux villes disparurent d\'un coup. Depuis aucun gardien n\'a fait parler de lui.";
D.q[4038] = "La robe de la mariée ? Oui, elle est prête, mais pas le voile: l\'intendant a demandé un voile opaque, qui cache à la mariée son futur mari. Mais je n\'ai pas l\'étoffe pour cela... Je te prédis qu\'avec 10 étoffes de Wabbit, cette robe sera ma plus belle pièce !";
D.q[1098] = "Il en existe de nombreux types, mais tout est question de dosage. \nPour la milice je prépare de la poudre de Nocabregor. Elle à l\'avantage d\'être peu onéreuse, stable et de ne demander qu\'une faible quantité d\'énergie pour provoquer la combustion. \nPour les feux d\'artifice, j\'utilise une poudre avec très peu de salpêtre pour éviter les risques inutiles. \nJe fabrique aussi des mines, ou j\'utilise une grosse quantité de soufre. \nEnfin... la question est trop vaste pour en parler davantage.";
D.q[5777] = "Il y a trois règles bien précises pour jouer, le Bouftou ne doit pas être tué, si une équipe tue malencontreusement ou volontairement le joueur représentant le Bouftou ou l\'invocation de Bouftou, son équipe est éliminée. \nQuasiment tous les coups sont permis, mais un joueur qui tuerait un de ses adversaires est automatiquement exclu, il devra donc quitter la partie ! Des places sont réservées aux entraîneurs et aux éventuels remplaçant, il ne peut n\'y avoir que 5 joueurs de la même équipe dans l\'aire de jeu, mais un joueur peux évidemment laisser sa place à un autre joueur. \nLes gens hors de l\'aire de jeu n\'ont aucun droit de participer au match !";
D.q[4134] = "Voilà, le bateau est encore amoché, mais nous pouvons repartir. D\'après la carte, nous ne sommes plus très loin. Si tu veux, tu peux m\'attendre sur cette île quelques jours, et je reviendrai te chercher ensuite...";
D.q[6429] = "Il y en avait plusieurs, Shere Hacanon en faisait partie si je me souviens bien. Quand il travaille il est en poste à l\'entrée sud de la cité, tu n\'auras aucun mal à le trouver.";
D.q[827] = "Y\'a un loup enragé qui rôde autour de la ville dans la façade de Brâkmar, met lui une rouste, en espérant qu\'il ne revienne plus...";
D.q[2817] = "Tiens, retourne tout de suite faire ton offrande, avant que les bulles ne disparaissent.";
D.q[2355] = "Voilà j\'ai signée ce petit papier... C\'est officiel : tu es maintenant alchimiste. Retourne voir Nibé Lulle si tu as des questions.";
D.q[1262] = "Voilà, maintenant file voir ton maître. ";
D.q[2019] = "Voilà ! Le SABLIER DE XELOR est prêt ! C\'est mon support préféré pour la divination... Très bien, jetons-y un oeil... - Montrakwartz se concentre sur l\'écoulement de l\'Epyss, puis quelque chose la foudroie, elle laisse tomber le sablier qui se brise – Enfer ! Qu\'est-ce que c\'est que cette vision ?! Laissez-moi reprendre mes esprits... miséricorde, nous avons un problème !";
D.q[4541] = "Ces maudits Brâkmariens vont voir que nous savons nous défendre... et attaquer ! Parlez au commandant pour donner l\'assaut.";
D.q[1146] = "Oh! les terribles capes... J\'espère que mes gars ne manqueront pas de les déposer sur de la fourrure jaune. Tu peux partir inquiet #1... Yarrk Yark !";
D.q[2350] = "Y\'a du gros monstre par là-bas... Pire, c\'est des espèces inconnues de mon grand papy, et qui fileraient la pétoche à un Iop ! Et pis y\'a toutes ces vieilles légendes là...";
D.q[4332] = "C\'est VOUS qui avez été envoyé ? Je me doutais qu\'il y avait quelque chose de louche. Très bien, quel est cet échange très intéressant dont il était question dans la lettre ?";
D.q[3703] = "Ils attaquent ceux qui profanent la Nature. Cet orme est le dernier d\'Incarnam. Nul ne peut couper cet arbre sans connaitre le courroux de Sadida. Je crains que dans sa colère il détruise tout Incarnam. C\'est pourquoi, ma magie rejette les bucherons.";
D.q[2851] = "Tu te crois brave ? Va à Pandala et accomplis ce que tu dois !";
D.q[3692] = "Ce pont est solide, vous pouvez le franchir";
D.q[1539] = "Cette cervelle est pourrie, elle est bonne à jeter aux ordures, tu n\'as pas été assez rapide...";
D.q[2629] = "Oh et cette promesse n\'était pas quelque chose de vraiment sérieux, si vous m\'offrez 5000 Kamas on peut négocier.";
D.q[1645] = "Cette foire est une véritable réussite, les gens s\'y amusent, se rencontrent, les enfants rient. C\'est un endroit magique";
D.q[3416] = "On raconte que ce donjon était déjà construit bien avant que la première pierre des murailles du château d\'Amakna ne soit posée.\nC\'est une sorte de temple où s\'exerce un culte assez obscur.\nCet endroit est infesté de rats relativement dangereux, mais qui restent inoffensifs en comparaison à leur maître, Sphincter.";
D.q[3065] = "Nous allons nous régaler ! J\'ai pensé à un petit détail pour clôturer la soirée, pourrais-tu me trouver une bague de fiançailles ?";
D.q[2499] = "Une spécialité locale. Il y en a de nombreuses sur l\'île de Pandala : la Pandneken, la Panderbrau, la Pandaburg...  tu apprendras à les découvrir... (clin d\'oeil complice).";
D.q[2237] = "Ha oui, le gâteau que j\'avais commandé pour Oz... hélas il ne m\'est plus d\'aucune utilité, il vient de s\'empiffrer de pain...";
D.q[3597] = "C\'est exact, je montre les bases à tous nos ouvriers. Il y a beaucoup de choses à faire dans cette ferme. Dites moi, qu\'est ce qui vous intéresse ?";
D.q[4142] = "C\'est parfait, je vais essayer d\'aller soigner les Corailleurs rapidement. Je vais essayer de me retenir pour ne pas consommer moi-même cette délicieuse potion.";
D.q[2539] = "Ce n\'est pas une légende ! La déesse a dit au Grandapan que lorsque les Dofus seront réunis, l\'élu sera béni des dieux !";
D.q[2055] = "Etrange ce métal... N\'y aurait-il pas de la magie Xélor là-dessous ? Qui sait ! Je l\'ai transmuté, c\'est maintenant un métal noble et pur. Va voir le forgeron de ma part. Il forgera ta lame, elle sera légère et fera vibrer l\'air !";
D.q[2453] = "Celui-là restera bien calme désormais.";
D.q[1872] = "Ce morceau de tissu pourrait amener à une conclusion fort simple, un voleur aurait trouvé ma maison fort jolie et l\'aurait dérobé. Hum, un peu surréaliste, ils étaient peut être deux... ";
D.q[3251] = "Cette chambre est protégée, seuls quatre des plus vaillants Dragoss de ce sanctuaire ont reçu le pouvoir d\'utiliser cette porte magique. Ils portent en eux un objet, une relique, ou un artefact qui leur permet de franchir cette porte sans que les Dragons eux-mêmes ne les transportent dans leur chambre. Si tu trouves ces objets, tu devrais pouvoir accéder à cette fameuse chambre ! Mais il te faudra TOUS les trouver, les quatre vaillants Dragoss ne peuvent franchir la porte qu\'ensemble, car le pouvoir de ces objets ne semble s\'exprimer que lorsqu\'ils sont réunis.";
D.q[172] = "Cette Taverne est ici depuis que je suis toute petite, mon père m\'y emmenait régulièrement, et j\'ai fini par décider d\'y travailler comme serveuse.  \nLe tavernier, qui est propriétaire de cet endroit est un homme riche et apprécié pour sa générosité, n\'hésitez pas à lui parler si vous cherchez un peu de travail, il est souvent débordé.";
D.q[955] = "Cette tour se trouve dans la partie basse de la ville, sa bibliothèque est une véritable mine d\'or pour quiconque s\'intéresse à la magie.";
D.q[4224] = "Ce village situé sur la cime de cet arbre géant, est habité par les Zoths, un groupe d\'anciens touristes venus découvrir l\'île, et qui sont devenus un peu fous en buvant l\'eau de la tourbière nauséabonde. \nQuand on sait ce qu\'elle contenait, on peut aisément comprendre que quelque chose ne tourne plus très rond chez eux... \nIls vivent cependant en paix, de façon autarcique. Ils ont voulu s\'émanciper de la société à laquelle ils appartenaient. \nTant que personne ne les dérange, ils restent calmes et disciplinés.";
D.q[1965] = "Les temps sont durs l\'ami, surtout pour celui qui joue au malin...";
D.q[1381] = "Lik millik privik kik jik\'i pivik tik dinnik iki dik tik pirtigik mik pivik dik clirvinikik. Rippirtik mik quilikik chisik ii migik itk sik tik fik binik chisix tik iki clirviniki ispisik ink instik.";
D.q[2758] = "Pour passer le grade de Gokwa, tu devras battre un disciple du même grade que toi en défi singulier devant moi ! \nN\'oubliez pas de vous équiper de votre tenue !";
D.q[6586] = "A vrai dire je ne préfère pas en parler, surtout que l\'intendant Danathor a fait passer une loi qui rend passible d\'emprisonnement toute personne surprise à discuter de magie noire, rites obscurs ou tout autre sorcellerie associée aux démons.";
D.q[607] = "Pour construire un radeau il faut au minimum 6 flotteurs, 4 liens pour les attacher, 2 lattes pour faire un sol plat, une poutre, un tronc en guise de mât, une voile en BON état, et au moins 10 pots de Kole pour fixer tout ça.";
D.q[2332] = "Pour acheter des objets dans les hôtels de vente, vous devez d\'abord choisir quel type d\'objet puis la quantité d\'objets que vous recherchez. \nSi plusieurs objets identiques sont mis en vente, seul le moins cher vous est proposé.";
D.q[3315] = "Pour charger les Brâkmariens avec ma cavalerie, j\'ai besoin de Dragodindes véloces et résistantes !";
D.q[1193] = "Pour trouver sa tombe, il te suffit d\'aller jusqu\'à cet endroit que je viens de marquer sur ta carte. \nDevant sa tombe se trouvent des fleurs que j\'y ai déposées récemment, tu ne devrais pas la rater...";
D.q[2005] = "Pour de l\'extrait de Dizbi, la première chose à savoir, c\'est qu\'il faut une fleur de Dzibi...";
D.q[3214] = "Pour rentrer il te faudra une clef, et je suis le seul à en posséder, et je ne suis pas prêt de la passer aux touristes, tu devras donc te débrouiller seul ! Cependant, je pense qu\'un Bricoleur expérimenté devrait pouvoir t\'aider à confectionner une clef pour rentrer dans ce labyrinthe, en utilisant les ressources des créatures locales... \nMais attention, une terrible malédiction sévit dans ce labyrinthe, tous ceux qui y entrent subissent des pertes de mémoire et oublient généralement leur point de sauvegarde. Une potion de rappel ne te permettra donc pas de sortir d\'ici, mais ne t\'en fais pas, je serai ton guide pendant tout ce voyage et si jamais tu te perds, je pourrai t\'aider à retrouver la sortie !";
D.q[361] = "Pour faire un lot de sucettes, il me faut 60 unités de Gelée Bleutée, 30 unités de Gelée Fraise, 25 unités de Gelée Menthe, 1 unité de Gelée Bleutée Royale et 1 unité Gelée Fraise Royale. Si tu me trouves tout ça, je te donnerai un truc cool.";
D.q[1216] = "Pour rejoindre notre Ordre, montre nous un minimum ta valeur en rapportant 1 Os de Chafer";
D.q[4111] = "Pour te fabriquer cette clef j\'ai besoin de :  \t1 Fragment de Coquille d\'Aerohouctor le Guerrier, 1 Fragment de Coquille de Terrakoubiak le Guerrier, 1 Fragment de Coquille d\'Ignelicrobur le Guerrier, 1 Fragment de Coquille d\'Aquabralak le Guerrier et 1 Oeuf de Dragoeuf Blanc.";
D.q[170] = "Pour faire du pain, il faut de la Farine, de l\'Eau et parfois de la Levure de Boulanger. En général, les meilleurs pains sont ceux composés de multiples farines, mais ils sont également beaucoup plus complexes à cuire.";
D.q[2833] = "Pour quitter notre ordre il te faudra faire don d\'une guildalogemme à la cité.";
D.q[2973] = "Pour éviter de te méprendre à l\'avenir, écoute bien mes paroles. Il y a une manière simple de reconnaître un Dofawa : la magie qui les imprègne est faible... Pour t\'en assurer, consulte ton inventaire : clique sur le Dofawa. Si ses effets sont nuls ou proches de 1, tu te trouves en face d\'un Dofus contrefait ! Pour ta gouverne, sache qu\'un Dofus est un oeuf de Dragon. Tu n\'imagines pas comme ces oeufs sont puissants !";
D.q[580] = "Pour remeeercier l\'aventuurier *hic* voici mon trésor incooongru *hic* ce pot qui m\'a fait déébuter *hic* ma carrière de peeintre-poête disparu *hoc*";
D.q[2684] = "Triple chope ! Les amateurs de boissons fermentées, je les reconnais à cent pas ! Que puis-je te servir ?";
D.q[3502] = "Gâtrooll et gratrooll contre pleins (remue ses doigts et ses orteils crasseux) de pisse Bwork !";
D.q[6445] = "Pas de familiarité entre nous ou je te fouette. Et pour toi ce sera oui maîtresse, compris ?";
D.q[3794] = "La véritable amitié, c\'est comme la santé... tu n\'en connais la valeur que lorsque tu l\'as perdue.";
D.q[3954] = "Ah, Uba Tessé t\'envoie ? Tu lui passeras le bonjour de ma part, et ce parchemin.";
D.q[3956] = "Uba t\'envoie, hein? Je te donne ce parchemin de bon coeur alors.";
D.q[6447] = "Beurk, tu me dégoûtes ! Finalement je crois que je punirais le Bouftou si je le laissais t\'approcher, et je ne tiens pas à ce que mon futur repas lèche des endroits peu recommandables de ton anatomie. Va me trouver ce Sram et à l\'avenir garde tes troubles du comportement pour toi, t\'imaginer avec un Bouftou est répugnant, beurk.";
D.q[2096] = "Contrairement à nous Feca, l\'intelligence n\'est pas le point fort de ces sacrées bestioles. Il nous manque un Bouftou. Pourriez-vous aller à sa recherche ? Je crois qu\'il est du côté des souterrains.";
D.q[1442] = "Trrès bieen. Jee prééfèère uun déémon fraanc, quii aassuume laa défaaite et reespeectueeuux de cees ancieens quee lees eceervelléés d\'auujouurd\'huii. Voous pouuveez diispooser.";
D.q[3387] = "Ca c\'est bien ! Tiens, v\'la la clef pour la suite. Vas-y vite.";
D.q[3383] = "Ca c\'est bien ! Tiens, v\'la la clef pour la suite. Vas-y vite.";
D.q[3384] = "Ca c\'est bien ! Tiens, v\'la la clef pour la suite. Vas-y vite.";
D.q[3382] = "Ca c\'est bien ! Tiens, v\'la la clef pour la suite. Vas-y vite.";
D.q[203] = "Impressionnant ! Cet ongle est sans doute l\'un des plus vieux qu\'il m\'ait été donné de voir et sentir.. (Lanseuft hume l\'ongle à plein nez) Usé et malodorant à souhait ! \n \nTrès bien, tu peux passer si tu n\'as pas peur.";
D.q[2388] = "Très bien, te voilà mon apprenti. Pour pratiquer ton métier tu dois acheter un sertisseur, j\'en vends à bas prix si cela t\'interesse. Equipe le et tu pourras utiliser les tables de travail conçues spécialement pour les bijoutiers. Tu les reconnaitras vite, il y a toujours quelques joyaux qui trainent dessus. Comme dans cette salle d\'ailleurs.";
D.q[2663] = "Trés bien ! Grâce à ce Kouartz on devrait pouvoir réaliser une B.E.T.A. (une Balade dans l\'Espace et le Temps d\'Amakna). \nJe vais t\'envoyer dans le village d\'Amakna durant l\'année 633, avant que tout cette agitation ne se produise. Comme je n\'ai confiance qu\'en moi-même, tu devras simplement me donner cette lettre... enfin... la donner au \"moi\" du passé... \n \nTu es prêt ?";
D.q[2774] = "Trés bien, tu es désormais apte à t\'entraîner au Dojo. Sache juste que tu peux venir pratiquer chaque jour de la semaine, mais que le Samedi est réservé aux passages de grade !";
D.q[1633] = "Trés bien tu as payé pour ton crime, un garde va maintenant te ramener à la frontière.";
D.q[3354] = "Visite un peu la zone autour de toi. C\'est pas très grand, mais tu y trouveras des merveilles!";
D.q[2250] = "Voilà ! Regarde, il est pas beau comme ca ? Allisteria n\'aura besoin que des quatres cuisses. J\'ai l\'habitude de garder le reste.";
D.q[968] = "Ola, y\'en a pour 500 pods par caisse, j\'te conseille de te décharger un peu avant...";
D.q[3439] = "Tu joues avec moi ?";
D.q[4039] = "Attends, il ne me faut que quelques instants, et mon chef-d\'oeuvre sera complet!";
D.q[3818] = "Parcourir les donjons une épée et un livre de sorts à la main est sûrement l\'une des choses les plus trépidantes que connaissent les aventuriers. ";
D.q[7468] = "Attention, avec ce pouvoir toutes tes caractéristiques vont être réinitialisées. \nTu vas perdre tous les points de caractéristiques que tu as gagnés grâce à des parchemins. \nTu pourras ensuite répartir à nouveau tes points de caractéristiques. \nEs-tu certain de vouloir continuer ? \n";
D.q[5596] = "C\'est pas toi que j\'ai envoyé à Bonta pour savoir ce qui s\'y tramait ?";
D.q[4395] = "Rigal a-t-il été utile ?";
D.q[710] = "Alerte ! Un démon est entré dans Bonta ! Mais que fait la milice ?.... J\'oubliais, c\'est moi la milice.";
D.q[6215] = "Nous autres Xélors sommes la race la plus puissante du Monde des Douze. Personne ne peut rivaliser avec nous, pas même le Bworker a qui j\'ai pelé le postérieur pour me faire cette cape.";
D.q[2490] = "QuooOooOOoooiii ? J\'ai l\'air d\'une GrenooOOouille ? Je vais acheter une paire de booOOoottines pour te boOotter les fesses jusqu\'à Pandala, nom de moOoi ! C\'est de l\'autre côôOOôôté de la ville hein ! A coup de pied là où tu sais, ça risque de faire loOong !";
D.q[4266] = "Nous sommes en train de finaliser un nouveau plan contre Bonta. Je vais bientôt demander à nouveau tes services.";
D.q[4478] = "Nous ne pouvons pas le laisser aider Bonta. Tu dois trouver ce forgeron dans le territoire Porcos et le convaincre de travailler pour nous... par n\'importe quel moyen.";
D.q[3029] = "Nous avons encore battu Bonta la dernière fois, les braves s\'engagent tous chez Brâkmar !";
D.q[3293] = "Nous être ici ! \nDonjon des Rats de Bonta, grand donjon rempli de rats très puissants. \nNous manger Bontariens à tous les repas. \nNous pas capables de faire différence entre Bontarien et pas Bontarien.";
D.q[1816] = "Nous avons retrouvé Heltan, malheureusement, il a fortement vieilli. Il nous a demandé à tous de lui ramener de la boue pour faire des bains. Et comme il le dit si bien \"On ne peut pas compter sur la charité des Xélors, tu n\'as qu\'à demander un seau de boue du Boo avant chaque combat contre un dopeul.\"...";
D.q[290] = "On manque de tout ici. Pas de voisins, pas d\'eau courante, rien pour se distraire, même pas un supermarché à proximité ! Je n\'ai plus rien à manger depuis 9 ans, 11 mois et 26 jours. Croyez-moi, sucer des cailloux ça va bien un moment, mais on s\'en lasse vite. Si vous pouviez me ramener des côtes de Rib, j\'en rêve depuis au moins dix ans ! Haaa... des côtes de Riiib. J\'offre des graines de sésame en échange.";
D.q[2653] = "Nous avons intégré les écoles de combat les plus célèbres : griffe joueuse d\'Ecaflip, magie naturelle des Sadidas...Nous excellons donc en duel contre ces derniers, mais quand il s\'agit de combattre un adversaire moins connu...Notre école est en pleine évolution, et nul doute que bientôt notre art englobera la connaissance de tout les styles de combat existant, et donc sera universellement efficace.";
D.q[814] = "Nous avons subi une dure défaite aujourd\'hui, tous les hommes sont fatigués et souffrants. \nHummm, tout compte fait  tu pourrais peut-être me servir... \nVa chercher des potions Pahoa Raide à un alchimiste, y\'en a trois qui risquent de ne pas passer la nuit sinon.";
D.q[2109] = "Je vais bientôt faire passer l\'épreuve d\'initiation à mes apprentis, et il me faut un stock massif de bave de bouftous. Pourriez vous m\'en apporter une dizaine ?";
D.q[6351] = "Nous faisons une halte car Néforun et Arlette Ba sont encore en train de se disputer au sujet de la couleur des cheveux blancs d\'Amayiro.";
D.q[2272] = "Hééééé... Alors, on veut en savoir plus sur les créatures qui rôdent dans les parages, heiiiin ? C\'est pas très compliqué ouaiiisss... Plus tu t\'enfonces loin vers le Nord ou vers le Sud, plus les créatures que tu rencontres sont dangereuses, et moins t\'as de chance de rentrer vivant. \nAlentours, et jusqu\'à Amakna, tu trouves rien de bien féroce... Encore que dans les coins sombres d\'Astrub, c\'est devenu peu sûr ces derniers temps... ";
D.q[1049] = "Oueeeehhhh La pu\'d biar el Korgno. A pu\'d ziou na plou, meu la kor \'vi dbouaaaaaaaaaar !";
D.q[7081] = "Depuis quelques temps, nous ouvrons les portes de notre temple aux représentants des autres divinités.";
D.q[2843] = "Bienvenue dans la chocolaterie Bonnawa ! Vous ne trouverez pas de meilleurs chocolats ailleurs, il est même fort possible que vous n\'en trouviez pas d\'autres ! \nN\'hésitez pas à vous faire plaisir en achetant quelques produits dans mon magasin, car comme le dit la devise de la maison : \"Ce qui fait du bien au palais, ne fait pas de mal à l\'âme... \" !";
D.q[6444] = "Bienvenue à la Taverne de la Bagrutte. Ici c\'est moi qui donne les ordres au client, compris ?";
D.q[1680] = "Bienvenue dans l\'arène de Gladiatrooll ! Cette attraction est fermée pour le moment, mais prochainement, ici se déroulera le plus grand combat de monstres de tous les temps !";
D.q[1685] = "Bienvenue dans l\'arène de Gladiatrooll ! Venez tester votre endurance dans une série de combats contre des monstres terrifiants! \nIci, les Kamas ne sont pas acceptés, pour jouer il vous faudra dépenser 100 jetons de la foire du trool ! \n \nLes règles sont simples, il suffit de survivre et essayer d\'aller le plus loin possible, après chaque combat vous avez la possibilité de vous arrêter, ou de continuer. \nAttention, pour que ce ne soit pas trop facile, avant chaque combat vous aurez une malédiction magique qui réduira vos capacités...";
D.q[932] = "Bienvenue à la taverne du Feubuk, que puis-je faire pour vous jeune étranger ?";
D.q[1276] = "Bienvenue à la taverne de la Tabasse, qu\'est-ce que je peux faire pour toi #1 ? \nDésolé pour la dernière fois, parfois j\'ai des trous de mémoire...";
D.q[2844] = "Bienvenu à la taverne du Pandawa Ivre, que puis-je vous servir ?";
D.q[1903] = "Bienvenue à la boulangerie Croa, ici nous fabriquons du pain à l\'ancienne ! Chaque pain fabriqué ici est fait en respectant l\'ancienne tradition ! Vous le sentirez tout de suite au goût, je vous le dit...";
D.q[4565] = "Bienvenue au temple. Profite de ton séjour pour te renseigner sur nos us et coutumes, et pourquoi pas, affronter l\'un de nos dopeuls.";
D.q[1013] = "Bon travail #1. Ce sanglier des plaines devrait nous laisser tranquille pendant un moment.";
D.q[2267] = "Je t\'ai déjà dit : je n\'ai pas de bois d\'Arash.\nJ\'ai bien ce magnifique bois d\'orme, regarde-moi cette belle pièce : ca vaut bien mieux que de l\'Arash !";
D.q[3041] = "Bien joué aventurier ! Tu m\'as l\'air téméraire, et le combat ne te fais pas peur. Du côté de la prison, tu verras des avis de recherche placardés sur des poteaux. Si tu veux te faire des kamas, il y a quelques hors-la-loi à retrouver de part le vaste Monde. Bonne route et longue vie à toi ! Avant de partir, n\'oublie pas de jeter un oeil au livre que je viens de te donner!";
D.q[1045] = "Bien ! Un peu long quand même. Bon tu vaux un peu plus qu\'un amas de calcium pourrissant. Je te descends au rang de larbin. Un immense privilège si tu veux mon avis. \nJ\'ai même un premier travail à te confier...";
D.q[3872] = "Bien joué ! Tu as prouvé ta loyauté envers notre Roi. Mais quant même... c\'est bizarre que les Roublards ne se cachent pas plus que ça, étant donné les événements récents... Cela dit, ça ne doit pas être donné à tout le monde d\'entrer là-dedans !";
D.q[2458] = "Bien joué. Tu as compris comment te servir de ta boussole. Maintenant il faut que tu saches que tu peux t\'asseoir à tout moment si tu as besoin de soigner des blessures légères après un combat.";
D.q[3793] = "Bien joué, tu apprendras facilement comment retirer un personnage de cette liste ou te servir de la liste des gens que tu apprécies moins.";
D.q[3605] = "Bon travail, tu es un ouvrier prometteur, voici ta paie.";
D.q[3908] = "Tiens un visiteur... Tu es perspicace pour avoir trouvé cette cachette... Pour la peine, je te remets ceci.";
D.q[3823] = "Tiens, tiens, un aventurier. Tu sais ce qui t\'attend au-delà de cette grotte ?";
D.q[1117] = "Quoi qu\'est-ce que tu veux ? T\'es pas jouasse ? Je te prends quand tu veux ! Attends, je vais chercher mes potes et on va te casser en deux !... T\'as de la chance que mes 50 ne soient pas là, sinon t\'avais plus de tête. Va-t\'en ! Bon, c\'est moi qui m\'en vais.";
D.q[5509] = "Tiens, un Bontarien. Qu\'est-ce que je dois faire dans ces cas-là, déjà ? Bah, peu importe... de toute façon c\'est aux sous-fifres de s\'en occuper, pas au capitaine.";
D.q[3259] = "Bien, j\'espère que tu as un bon cache-oreilles !\nEuh au fait...\nJe pose la question juste pour la forme, mais tu n\'es pas un mioche déguisé en adulte n\'est-ce pas ?\nTes parents veulent bien que tu viennes ?\nParce que le dernier moutard que j\'ai emmené, il est pas r\'venu...\nA tous les coups il a pas voulu quitter mon île, mais sa mère elle me poursuit partout depuis...\n\n*regarde par dessus son épaule*\n\nBon, hum... Dépêches-toi, moi j\' me sauve ! ";
D.q[3332] = "Bon, je vais vous la faire courte: j\'ai besoin de morceaux de Kaliptus et de Koalaks.";
