G = new Object();
G[1] = {sn:"Féca",ln:"Fécas Schild",ep:1,d:"Anhänger dieser Charakterklasse sind loyale Beschützer. Darum werden sie meist in jeder Abenteurergruppe geschätzt und geehrt. Doch haben sie nicht nur mächtige Schutzzauber zu ihrer Verfügung, sondern sind auch Meister im Umgang mit dem Kampfstecken. Generationen von Fécas dienten bereits als loyale Beschützer für die mächtigsten und seltensten Gegenstände, die ihnen von den Weisen Amaknas anvertraut wurden.",sd:"Spieler dieser Klasse sind Beschützer. Mit ihren Schutzzaubern senken sie den Schaden von Gegnern bei sich und Verbündeten.",s:[3,17,6,4,2,1,9,18,20,14,19,5,16,8,12,11,10,7,15,13,1901],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[2] = {sn:"Osamodas",ln:"Osamodas Peitsche",ep:1,d:"Osamodas Anhänger sind die geborenen Beschwörer! Sie züchten und dressieren Kreaturen, damit diese für sie kämpfen. Einem Gerücht nach, soll ihre Kleidung aus der Haut besiegter Gegner bestehen. Doch fragt sie besser nicht, ob das wirklich stimmt, sonst werdet ihr am Ende noch als Mütze enden, oder gar als Socken.",sd:"Spieler dieser Klasse sind Beschwörer. Dank beschworener Kreaturen können sie aus sicherer Entfernung kämpfen.",s:[23,34,21,26,22,35,28,37,30,27,24,33,25,38,36,32,29,39,40,31,1902],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[3] = {sn:"Enutrof",ln:"Enutrofs Finger",ep:1,d:"Die Anhänger Enutrofs sind erfahrene Schatzjäger, die sich für alle mächtigsten Gegenstände im Universum von Amakna interessieren. Andere Abenteurer werden von ihnen mit einem einzigen Blick taxiert, der ihnen alles über Ausrüstung, Waffen und Kamas erzählt. Denn in den Augen dieser Schatzsuchern sind alle anderen Kreaturen nichts anderes als eine Kamaquelle auf Beinen.",sd:"Spieler dieser Klasse sind Schatzsucher. Das Entzaubern anderer und das Verlangsamen von Freunden zählen zu ihren Fähigkeiten.",s:[51,41,43,49,42,47,48,45,53,46,52,44,50,54,55,56,58,59,57,60,1903],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[150,3],[230,4],[330,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[60,3],[100,4],[150,5]]};
G[4] = {sn:"Sram",ln:"Srams Schatten",ep:1,d:"Sram Anhänger sind finstere Meuchelmörder, die prall gefüllte Geldbörsen lieben. Den Saum einer Kleidung aufzuschlitzen, die Tiefen der Taschen auszuloten, ihre Fingerfertigkeit beweisen, bis sie letztendlich die heißbegehrten Edelsteine ertasten und dann schnell eine tödliche Falle legen, um die Flucht zu decken... all dies gehört zu den Freuden des Lebens eines Srams.",sd:"Spieler dieser Klasse sind Räuber. Dank ihrer Unsichtbarkeit und Fallen haben sie oft den Überraschungsvorteil auf ihrer Seite.",s:[65,72,61,66,68,63,74,64,79,78,71,62,69,77,73,67,70,75,76,80,1904],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[100,2],[200,3],[300,4],[400,5]],b15:[[0,2],[50,3],[150,4],[250,5]]};
G[5] = {sn:"Xélor",ln:"Xélors Sanduhr",ep:1,d:"Anhänger Xélors sind mächtige Meister der Zeit und aller mechanischen Zeitgeber: Wecker, Standuhren und Pendel gehorschen ihnen auf Fingerzeig und Augenblick. Xélors können daher Feinde verlangsamen oder sich direkt an Orte ihrer Wahl teleportieren.",sd:"Spieler dieser Klasse sind Zauberer. Mit ihren Zaubern können sie Feinde verlangsamen und sie am Spielen hindern.",s:[81,83,82,84,100,92,88,93,85,96,98,86,89,90,87,94,99,95,91,97,1905],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[6] = {sn:"Ecaflip",ln:"Ecaflips Münze",ep:1,d:"Anhänger dieser Klasse sind die kriegerische Spieler, die überall dort anzutreffen sind, wo es viel zu gewinnen (oder zu verlieren) gibt... Ecaflips spielen pausenlos und zwar meist um Alles oder Nichts! Sie sind dazu fähig, eines blossen Spieles willens ihr Leben zu riskieren...dieses also im wahrsten Sinne des Wortes „auf\'s Spiel zu setzen“.",sd:"Spieler dieser Klasse sind Glücksritter. Ihre Angriffe sind oft stark vom Zufall abhängig.",s:[102,103,105,109,113,111,104,119,101,107,116,106,117,108,115,118,110,112,114,120,1906],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[7] = {sn:"Eniripsa",ln:"Eniripsas Hände",ep:1,d:"Die Zaubersprüche dieser Heiler beruhen auf Silben, Worten und Gebeten. Doch können sie nicht nur Verbündete mit ihren Worten heilen, sondern auch Feinde in Hörreichweite verwunden. Manche Worte sind eben sehr schmerzhaft anzuhören!",sd:"Spieler dieser Klasse sind Heiler. Dank ihrer Heilzauber sind sie gern gesehene Verbündete.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[8] = {sn:"Iop",ln:"Iops Herz",ep:1,d:"Iop, Gott der Macht und der Herrschaft verachtet die Schwachen. Seine Anhänger sind daher immer tapfere und tugendhafte Krieger! Mindestens einmal pro Tag das Blut ihrer Gegner zu vergießen, ist für sie ein Zeichen guter Gesundheit. Mit ihrem unberechenbaren Temperament sind Iops zu Allem in der Lage, zum Besten, wie auch zum Schlimmsten!",sd:"Spieler dieser Klasse sind Krieger. Mit ihren Offensivzaubern können sie großen Schaden anrichten.",s:[142,143,141,144,145,146,147,148,154,150,151,155,152,153,149,156,157,158,160,159,1908],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[9] = {sn:"Crâ",ln:"Die Weiten von Crâ",ep:1,d:"Crâs sind stolze und zielsichere Bogenschützen. Das macht sie zu wertvollen Verbündeten gegen reine Nahkämpfer. Aus der Ferne können sie dann ihre Pfeile durch die kleinsten Lücken in der Panzerung der Gegner hindurchjagen, um großen Schaden anzurichten!",sd:"Spieler dieser Klasse sind Bogenschützen. Damit sind sie Spezialisten des Fernkampfes.",s:[169,164,161,163,165,172,167,168,162,170,171,166,173,174,176,175,178,177,179,180,1909],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[50,2],[150,3],[250,4],[350,5]]};
G[10] = {sn:"Sadida",ln:"Das Schuhwerk von Sadida",ep:1,d:"Sadidas Anhänger können über die Kräfte der Natur befehlen und verfügen über wirksames Gift. Doch damit nicht genug. Sie sind zusätzlich auch noch in der Lage, Ranken auf ihre Gegner zu hetzen oder mörderische Puppen zu beschwören.",sd:"Spieler dieser Klasse sind Zauberer. Sie nutzen Puppen für den Kampf und um Feinde zu verzaubern.",s:[193,183,200,198,195,182,192,197,189,181,199,191,186,196,190,194,185,184,188,187,1910],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[250,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[11] = {sn:"Sacrieur",ln:"Sacrieurs Blut",ep:1,d:"Anhänger der Göttin Sacrieur sind wahre Berserker, die ihre Kräfte vervielfältigen, sobald sie verletzt werden! Darum fürchten sie auch nie getroffen zu werden und sind meist dort anzutreffen, wo es im Kampf am Gefährlichsten zugeht. Daher werden Sacrieurs von allen Verbündeten sehr geschätzt und das macht sie zum idealen Gefährten für lange, kampflastige Abenteuer.",sd:"Spieler dieser Klasse sind Beschützer. Sie halten viel aus und stecken oft Schläge für Verbündete ein.",s:[431,432,434,444,449,436,437,439,433,443,440,442,441,445,438,446,447,448,435,450,1911],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,3],[100,4],[150,5]],b11:[[0,1,2]],b12:[[0,3]],b13:[[0,3],[100,4],[150,5]],b14:[[0,3],[100,4],[150,5]],b15:[[0,3],[100,4],[150,5]]};
G[12] = {sn:"Pandawa",ln:"Pandawas Maßkrug",ep:18,d:"Pandawas Anhänger sind mächtig starke Krieger, die mit ihrem Körper erstaunliche Dinge anstellen können! Nicht bloß mit ihrem Körper, sondern auch mit dem von anderen... Pandawas können im Kampf Verbündete auf den Schultern tragen, um sie zu schützen, oder aber ihre Gegner durch die Luft schleudern, um sie zu verletzen!",sd:"Spieler dieser Klasse sind Krieger, die andere tragen können. Getränke machen sie stärker und sie können auch Verbündete schützen.",s:[686,692,687,689,690,691,688,693,694,695,696,697,698,699,700,701,702,703,704,705,1912],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[200,3]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[50,2],[200,3]],b14:[[0,1],[50,2],[200,3]],b15:[[0,1],[50,2],[200,3]]};
