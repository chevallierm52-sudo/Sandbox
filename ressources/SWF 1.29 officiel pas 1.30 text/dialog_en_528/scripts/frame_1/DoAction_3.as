D.q[859] = "49";
D.q[1838] = "...hmmm, but everything matches up, this old manuscript is very precise on the subject...\nOh, Sorry! I didn\'t notice you there, how can I help you? Or rather, how can you help me?";
D.q[777] = "67";
D.q[779] = "69";
