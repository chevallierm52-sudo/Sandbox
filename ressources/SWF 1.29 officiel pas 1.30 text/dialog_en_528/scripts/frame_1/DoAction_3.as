D.q[7948] = "Do you want to take the Bow Wows to Alma\'s Cradle? That will cost you 5000 Kamas.";
D.q[766] = "56";
D.q[683] = "3 steps, you\'ll have to clear\nLike many subjects of meditation.\nThe first one is a proof of your motivation,\nCourage that will prevent you from fleeing.";
D.q[769] = "59";
D.q[7949] = "Hurry up and get me a pack of Snow Bow Wows. I\'m sure the pirate ghosts are after my treasure.";
D.q[6632] = "";
D.q[771] = "61";
D.q[6631] = "";
