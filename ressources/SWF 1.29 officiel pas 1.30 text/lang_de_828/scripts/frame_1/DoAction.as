SRV_MSG_0 = "Zuviel Spam!";
SRV_MSG_1 = "Du bist zu lange untätig geblieben!";
SRV_MSG_10 = "Du brauchst mindestens %1 Kamas, um auf dein Bankfach zugreifen zu können.";
SRV_MSG_11 = "Dein Energiewert ist gefährlich niedrig!\n Nur noch %1 Punkt(e)!";
SRV_MSG_12 = "Du bist soeben deinen Verletzungen erlegen.\nDu musst entweder warten, bis dich ein Priester wiedererweckt, oder du kannst deine Seele befreien, um als Geist den nächsten Wiederbelebungspunkt aufzusuchen.";
SRV_MSG_13 = "Der Server wird derzeit gewartet. \nVielen Dank für eurer Verständnis! \n \n<u><a href=\"http://ankama-games.com/game.php?lang=de\" target=\"_blank\"><font color=\"#0000FF\">Nimm dir doch einfach etwas Zeit, um dich über die anderen Spiele von Ankama Games zu informieren!</font></a></u>";
SRV_MSG_14 = "Diese Klasse ist Abonnenten vorbehalten.";
SRV_MSG_15 = "Willkommen in der Welt der Geister!\nWenn du wieder in die Welt der Lebenden zurückkehren möchtest, benötigst du entweder einen Priester oder musst eine Phönix-Statue aufsuchen.\nIn Zukunft solltest du immer daran denken, deine Energie aufzufüllen, indem du dich in den Tavernen, Tempeln oder Häusern ausloggst, oder Energie-Tränke zu dir nimmst.";
SRV_MSG_16 = "Verbindung vorübergehend nicht möglich. Der Verbindungsserver erhält zu viele gleichzeitige Anfragen. Bitte versucht es in ein paar Minuten wieder!";
SRV_MSG_17 = "Eine eurer Koppeln wurde soeben für %1 Kamas von der Gilde %2 erworben. Die Summe wurde eurem Bankkonto gutgeschrieben.";
SRV_MSG_18 = "Du bist von %1.%2 gekickt worden.";
SRV_MSG_19 = "Der Zugriff auf diesen Server ist einer bestimmten Spielergemeinschaft vorbehalten.";
SRV_MSG_2 = "Der Charakter hat die derzeitige Maximalstufe erreicht.";
SRV_MSG_20 = "Der Zugriff auf diesen Server ist einer bestimmten Spielergemeinschaft bzw. abonnierten Spielern vorbehalten. Wenn ihr keine dieser beiden Bedingungen erfüllt, ist leider kein Zugriff möglich.";
SRV_MSG_21 = "Es wurden neue Gegenstände in eurem Bankfach deponiert.";
SRV_MSG_22 = "Um diesen Gegenstand erfolgreich herstellen zu können, musst deine Berufsstufe noch ein wenig verbessern. Um diesen Gegenstand der %1. Stufe erfolgreich zu bearbeiten, musst du Stufe %2 als Handwerksmeister erreicht haben.";
SRV_MSG_23 = "Da die Auswirkungen des Zauberspruches %1 geändert wurden, musste er von deinem Charakter \'vergessen\' werden. Die %2 vor dir verteilten Zauberspruchpunkte wurden dir zurückerstattet.";
SRV_MSG_24 = "Der Server hat anormale Daten bei %1 deiner accountgebundenen Vertrauten festgestellt, welche nun ausgetauscht werden. Der Austausch wird morgen stattfinden.";
SRV_MSG_25 = "Der Server hat anormale Fütterungsdaten bei einem deiner Vertrauten festgestellt. Dieses abgemagerte Exemplar hat nun von einer Express-Behandlung mit Nahrungsmitteln, Vitaminen und Mineralstoffen profitiert und wurde wiederhergstellt. Nun sieht es wieder glücklich und zufrieden aus.";
SRV_MSG_26 = "Du bist soeben deinen Verletzungen erlegen.";
SRV_MSG_27 = "Dieser Server ist vollständig ausgelastet. Eine Verbindung wird nur hergestellt, wenn bereits ein Charakter auf diesem Server erstellt, oder von jemandem auf diesem Server geworben wurde.";
SRV_MSG_28 = "Es ist nicht möglich, heute noch weitere Charaktere zu löschen!";
SRV_MSG_29 = "Verbindung zurückgewiesen.\nBei eurer Internetverbindung ist eine Sicherheitslücke aufgetreten: eure öffentliche IP-Adresse hat sich geändert. Darum war es nicht möglich, die Verbindung zu authentifizieren. Wenn das Problem bestehen bleibt, dann kontaktiert bitte euren Netzwerkadministrator oder euren Internetprovider. IP-\"Wechsel\" treten hauptsächlich bei großen Betreibern auf, die mehrere Internetschnittstellen parallel betreiben und bei eingehenden Netzwerkverbindungen Load-Balancing zwischen verschiedenen Access-Points betreiben. Bei dynamischen IP-Adressen die sich während einer Session nicht ändern, tritt das Problem nicht auf.";
SRV_MSG_3 = "Der Server wird in wenigen Minuten für eine Wartung vom Netz genommen.";
SRV_MSG_30 = "Verbindung zurückgewiesen. \nDer Spielserver konnte euch aufgrund einer zu langsamen Verbindung nicht authentifizieren. \nBitte schließt alle Downloads, sowie eventuelles Audio- oder Videostreaming, um die Verbindungsqualität zu verbessern und versucht es erneut.";
SRV_MSG_31 = "Verbindung zurückgewiesen. \nDer Spielserver hat nach eurem Login keine Authentifizierungsdaten bekommen. \nBitte versucht es erneut. Wenn das Problem bestehen bleibt, dann kontaktiert bitte euren Netzwerkadministrator oder euren Internetprovider. Es handelt sich dann vermutlich um ein fehlerhaftes Weiterleiten aufgrund falscher DNS-Einstellungen.";
SRV_MSG_32 = "Damit andere Spieler nicht behindert werden, bitte %1 Sekunden vor einem erneuten Einloggen warten.";
SRV_MSG_33 = "Dieser Server ist bestimmten Sprachen oder Spielergemeinden vorbehalten was einen kostenlosen Zugang angeht. Ihr solltet also auf dem Spielserver einer anderen Spielergemeinde spielen, welcher mehr eurem Land entspricht. Bitte erstellt einen DOFUS-Account mit der Spielergemeinde, welche eurem Land entspricht und verwendet die Spielserver der passenden Spielergemeinde.";
SRV_MSG_34 = "Verbindung nicht möglich \n%1 Accounts sind bereits von Ihrer IP %2 eingeloggt. Mehrere anormale Aktivitäten wurden festgestellt, deshalb wurden einige IP-Bereiche Ihres Providers mit Einschränkungen belegt. Dies bedeutet, dass die Anzahl der Accounts, mit denen man sich gleichzeitig einloggen kann, beschränkt ist. Accounts von Abonnenten unterliegen weniger starken Einschränkungen. \nSie können den Support <a href=\"http://support.ankama.com/de/faq/718\"><u>hier</u></a> kontaktieren.";
SRV_MSG_35 = "Dieser Server ist nur für Spieler einer bestimmten Spielergemeinde zugänglich. Sie haben keinen Zugang. \nManche Länder erkennen nicht die Spielergemeinde, die mit dem Account in Verbindung steht und leiten zu einer Spielergemeinde um, die in Zusammenhang mit der geographischen Position des Logins steht. \nSie können dazu den Support <a href=\"http://support.ankama.com/de/faq/716\"><u>hier</u></a> befragen.";
SRV_MSG_36 = "Die Auswirkungen mehrerer eurer Zauber wurden verändert. Alle eure Zauberspruchpunkte wurden euch zurück gegeben.";
SRV_MSG_37 = "Spielzeit abgelaufen.\nDamit alle Spieler die Möglichkeit erhalten, das Spiel probieren zu können, ist die Spielzeit vor Ort limitiert. Euer Account wird in einigen Stunden wieder von der Messe aus zugänglich sein.\nIm Falle eines Turniers müsst ihr jemanden des Teams bitten, das Zeitlimit für die Dauer des Turniers aufzuheben.";
SRV_MSG_38 = "Ihr habt euch nicht an die für den Account eingestellte Sicherheitsstufe gehalten. Der eingeschränkte Spielmodus wird aktiviert, sobald ihr euch im Spiel einloggt. Bitte überprüft die <a href=\'URL FAQ SUPPORT\'>F.A.Q zum Thema Sicherheitseinstellungen </a> um mehr darüber zu erfahren.";
