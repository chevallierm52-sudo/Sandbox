HELP = "Hilfe";
HELP_ACTIONPOINTS = "Aktionspunkte (AP) ermöglichen es dir, im Kampf Zaubersprüche zu wirken oder mit Waffen anzugreifen. Jedes Mal, wenn du einen Spruch wirkst oder angreifst, wird eine bestimmte Anzahl an AP ausgegeben. Die AP werden jedoch zu Beginn jeder neuen Runde wieder auf den Höchststand gebracht.";
HELP_AGILITY = "Durch Flinkheit erhöht sich die Wahrscheinlichkeit, aus einem Gedränge zu entkommen, sowie die Wahrscheinlichkeit, kritische Treffer zu verursachen. Auch wird der Luft-Schaden erhöht";
HELP_BONUSPOINTS = "Mit den Attributspunkten kannst du die Attribute deines Charakters steigern. Je nachdem, wie du sie verteilst, kannst du die Wirksamkeit bestimmter Zaubersprüche, das Ausweichen, das Finden von Gegenständen uvw. steigern. Die Verteilung der Attributspunkte ist also maßgeblich für die Entwicklung deines Charakters!";
HELP_CHANCE = "Glück geht im Verhältnis 10/1 ins Filzen ein (d.h. 10 Punkte Glück erhöhen den Filzwert um 1 Punkt). Zudem erhöht sich der angerichtete Wasserschaden.";
HELP_DISCERNMENT = "Der Filzwert bestimmt die Wahrscheinlichkeit, dass ein Charakter und seine Verbündeten am Ende des Kampfes sowohl mehr, als auch seltenere Gegenstände erhalten.";
HELP_ENERGY = "Energiepunkte sind ein Maß für den allgemeinen Zustand deines Charakters. Wenn der Wert auf Null fällt, verwandelt sich dein Charakter in einen Geist. Immer, wenn ein Kampf verloren wird, gehen auch Energiepunkte verloren.";
HELP_FORCE = "Stärke erhöht das maximal tragbare Gewicht, sowie den verursachten neutralen und Erd-Schaden";
HELP_HOW_DEFEND_TAX = "Auf ein freies Feld klicken, um den angegriffenen Perzeptaurus zu verteidigen";
HELP_INITIATIVE = "Die Initiative bestimmt die Reihenfolge, in der die Charaktere innerhalb einer Kampfrunde an die Reihe kommen. Je höher der Wert, desto höher die Wahrscheinlichkeit, als Erster in einer Runde am Zuge zu sein. Der Initiative-Wert des Charakters hängt von seinen Lebenspunkten und von den Initiative-Boni von Gegenständen ab. 1 Punkt für Stärke, Intelligenz, Glück oder Flinkheit ergeben einen Punkt für Inititative. Verletzungen können die Initiative eures Charakters beeinflussen, deshalb ist es besser, einen Kampf mit allen Lebenspunkten zu beginnen.";
HELP_INTELLIGENCE = "Erhöht Heilung sowie angerichteten Feuerschaden";
HELP_LEVEL = "Charaktere haben eine Stufe zwischen 1 und 200. Bei Erreichen jeder neuen Stufe erhält der Charakter 5 Attributspunkte und 1 Zauberspruchpunkt zur freien Verteilung. Setze diese in Abhängigkeit von der gewählten Lieblingsstrategie des Charakters ein.  \nAchtung! Manche Monster können Stufe 200 überschreiten!";
HELP_LIFE = "Lebenspunkte stehen für die Gesundheit des Charakters. Bei Erreichen jeder Erfahrungsstufe erhält der Charakter 5 zusätzliche Lebenspunkte.";
HELP_ME = "Hilfe!!!";
HELP_MOVEPOINTS = "Bewegungspunkte (BP) ermöglichen es deinem Charakter, sich im Kampf zu bewegen. Mit jeder Bewegung wird eine entsprechende Anzahl an BP abgezogen. Die BP werden jedoch zu Beginn jeder neuen Runde wieder auf den Höchststand gebracht.";
