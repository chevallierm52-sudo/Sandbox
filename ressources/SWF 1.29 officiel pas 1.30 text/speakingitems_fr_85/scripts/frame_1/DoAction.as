System.security.allowDomain(_parent._url);
VERSION = 85;
SIM = new Object();
SIM[24] = {m:"Un jour, je suis tombé dans la cuvette des toilettes du roi Allister. C\'était génial.",s:-1,l:1,p:1};
SIM[25] = {m:"J\'ai faim, donne-moi à manger ou je dévore les objets de ton inventaire.",s:3,l:1,p:1};
SIM[26] = {m:"Donne-moi à manger rapidement, sinon je dévore tes kamas.",s:3,l:1,p:1};
SIM[27] = {m:"Allez, fais-lui mordre la poussière, il a l\'air tellement nul.",s:-1,l:1,p:1};
SIM[28] = {m:"Mais qui est ce bouffon qui nous agresse ?",s:-1,l:1,p:1};
SIM[29] = {m:"Je pense que cet odieux personnage a eu tout ce qu\'il méritait.",s:-1,l:1,p:1};
SIM[30] = {m:"Je n\'arrive pas à croire que tu puisses être assez nul pour te faire battre par un nabot pareil.",s:-1,l:1,p:1};
SIM[31] = {m:"Enfin un coup critique, je m\'impatientais...",s:-1,l:1,p:1};
SIM[32] = {m:"Mais pourquoi fais-tu plus souvent des échecs critiques que des coups critiques ?",s:-1,l:1,p:1};
SIM[33] = {m:"Pour une fois que ça n\'est pas un échec critique...",s:-1,l:1,p:1};
SIM[34] = {m:"Une fois de plus c\'est grâce à moi que tu as gagné ce combat.",s:-1,l:1,p:1};
SIM[35] = {m:"La prochaine fois, essaye de ne pas faire n\'importe quoi, je commence à en avoir assez d\'équiper un perdant comme toi.",s:-1,l:1,p:1};
SIM[36] = {m:"Regarde-moi cet aventurier débutant qui vient d\'arriver... Tu devrais l\'agresser, ça nous fera une victoire facile.",s:-1,l:1,p:1};
SIM[37] = {m:"Regarde qui vient d\'arriver... Je crois que c\'est le moment idéal pour se sauver.",s:-1,l:1,p:1};
SIM[38] = {m:"Si seulement tu pouvais faire des coups critiques aussi souvent que lui !",s:-1,l:1,p:1};
SIM[39] = {m:"Mais il est nul ! Explique-moi comment tu choisis aussi mal tes amis ?",s:-1,l:1,p:1};
SIM[40] = {m:"C\'est seulement à cette heure-ci que tu reviens ? Je ne compte pas assez pour toi ?",s:3,l:1,p:0.1};
SIM[41] = {m:"Je pense que tu viens de tuer un de nos alliés. Il n\'est pas trop tard pour aller te faire soigner...",s:-1,l:1,p:1};
SIM[42] = {m:"Un jour je t\'apprendrai à bien choisir tes amis.",s:-1,l:1,p:1};
SIM[43] = {m:"Allez, ne fais pas le radin, donne-moi ce que tu viens de récupérer, tu gardes toujours tout pour toi.",s:-1,l:1,p:1};
SIM[44] = {m:"Je ne me souviens pas avoir déjà équipé un aventurier plus stupide que toi.",s:-1,l:1,p:1};
SIM[45] = {m:"Allez, donne-le moi.",s:-1,l:1,p:1};
SIM[46] = {m:"Encore râté... Haha.",s:1,l:1,p:1};
SIM[47] = {m:"J\'ai déjà écouté une chanson de Francisque Kabroule. Je suis resté sourd pendant 12 ans.",s:-1,l:1,p:0.2};
SIM[48] = {m:"Tu connais l\'histoire du Kirboule qui donnait des coups de boule ?",s:2,l:1,p:0.1};
SIM[49] = {m:"Un jour j\'épouserai un Dora Bora.",s:-1,l:1,p:0.1};
SIM[50] = {m:"C\'est à ce moment-là que le méchant arrive et il lui dit \"Et toi le bouffon, c\'est pas moi le méchant, c\'est toi\". J\'étais mort de rire bien entendu.",s:2,l:1,p:0.1};
SIM[51] = {m:"On raconte qu\'Allister avait une fesse plus grosse que l\'autre. Je pense que c\'est faux, à chaque fois qu\'il s\'asseyait sur moi, je souffrais autant.",s:-1,l:1,p:0.5};
SIM[52] = {m:"Lichen est vraiment un mec super cool.",s:-1,l:1,p:0.01};
SIM[53] = {m:"J\'ai eu une enfance difficile, j\'équipais un débutant d\'Astrub qui vendait à la criée au Zaap. Je suis devenu sourd.",s:-1,l:1,p:0.1};
SIM[54] = {m:"Tu me fais penser à un monstre, mais je ne me rappelle plus lequel. Ma belle-mère peut-être.",s:-1,l:1,p:0.1};
SIM[55] = {m:"Le problème avec Astrub, c\'est qu\'elle ne brûle jamais.",s:-1,l:1,p:0.1};
SIM[57] = {m:"J\'ai déjà vu un Féca faire autre chose que de lancer tout le temps ses armures et de foncer tête baissée dans le combat. Mais c\'était dans un rêve.",s:-1,l:1,p:0.1};
SIM[58] = {m:"J\'ai déjà croisé un Iop qui savait compter. Mais j\'étais ivre ce jour-là.",s:-1,l:1,p:0.1};
SIM[59] = {m:"J\'ai faim !",s:-1,l:1,p:1};
SIM[62] = {m:"J\'ai mangé assez pour tenir plusieurs mois.",s:-1,l:1,p:1};
SIM[63] = {m:"J\'ai tellement mangé, que je risque de vomir dans ton inventaire.",s:-1,l:1,p:1};
SIM[64] = {m:"Je t\'aurais bien aidé, mais j\'ai trop mangé. Une autre fois peut-être.",s:-1,l:1,p:1};
SIM[65] = {m:"Encore des trucs à manger... Par pitié arrête de me gaver !",s:-1,l:1,p:1};
SIM[66] = {m:"Si tu ne m\'avais pas donné autant à manger, j\'aurais pu te sauver la vie.",s:-1,l:1,p:1};
SIM[67] = {m:"Bon d\'accord tu viens de gagner, tu es heureux c\'est bien, mais ce n\'est pas une raison pour continuer à me gaver d\'objets !",s:-1,l:1,p:1};
SIM[68] = {m:"Les devs vaincront !",s:-1,l:10,p:0.01};
SIM[70] = {m:"Il paraît que les invocations volent les ressources gagnées en fin de combat. C\'est faux, en général c\'est moi qui les vole.",s:-1,l:3,p:1};
SIM[71] = {m:"Certains aventuriers racontent que parler à proximité des zones de pêche fait fuir les poissons...",s:-1,l:5,p:1};
SIM[72] = {m:"Je crois encore au Minotoboule de Nowel et toi ?",s:-1,l:1,p:1};
SIM[73] = {m:"Ah, peut-être que celui-là va me débarrasser de toi.",s:-1,l:1,p:1};
SIM[74] = {m:"Si tu continues à te faire tuer par tout ce qui bouge, je me tire.",s:3,l:1,p:1};
SIM[75] = {m:"Un traître ! Voilà ce qu\'il fallait pour avoir un peu d\'action !",s:-1,l:1,p:1};
SIM[76] = {m:"Tu pourrais obtenir un coup critique avec \"Nourrissement des objets\", s\'il te plait ?",s:-1,l:1,p:1};
SIM[77] = {m:"Bien fait, il ne servait à rien de toute façon.",s:1,l:5,p:1};
SIM[78] = {m:"Si on me cherche, je me suis réfugié dans ton sac.",s:-1,l:10,p:1};
SIM[79] = {m:"J\'espère que ça fait bien mal.",s:1,l:5,p:1};
SIM[80] = {m:"Hoooo, attends, attends, je prends un screen !",s:2,l:10,p:0.5};
SIM[81] = {m:"Je devrais peut-être aller voir du côté de cet ennemi...",s:-1,l:5,p:1};
SIM[82] = {m:"Je crois qu\'on t\'appelle pour manger.",s:-1,l:1,p:1};
SIM[83] = {m:"Allons, je suis sûr que tu peux faire mieux que ça !",s:-1,l:15,p:1};
SIM[84] = {m:"J\'ai fait un tour au zaap d\'Astrub il y a quelque temps. Je crois qu\'il y avait un concours de celui ou celle qui hurlait le plus fort.",s:-1,l:15,p:0.5};
SIM[85] = {m:"Un jour j\'ai rencontré un animal qui s\'appelait un paresseux. Il m\'a tout de suite fait penser à un Sadida.",s:-1,l:8,p:1};
SIM[86] = {m:"Un Wabbit m\'a mowdu l\'autwe fois. Je cwois qu\'il m\'a wefilé une maladie gwave.",s:-1,l:12,p:0.5};
SIM[87] = {m:"Avant l\'invention des Zaapis, je crois que les habitants de Bonta et Brâkmar passaient autant de temps à chercher leur chemin qu\'un Sadida à dormir.",s:-1,l:16,p:1};
SIM[88] = {m:"Déjà de retour ? Tu m\'as ramené à manger ?",s:-1,l:7,p:1};
SIM[89] = {m:"Tu devrais mieux choisir tes amis. Remarque, moi j\'aurais dû mieux choisir mon propriétaire.",s:-1,l:14,p:1};
SIM[90] = {m:"Quand est-ce qu\'on mange ?",s:-1,l:1,p:1};
SIM[91] = {m:"Le dernier qui m\'a laissé affamé est mort dans des circonstances mystérieuses et suspectes.",s:-1,l:17,p:1};
SIM[92] = {m:"Attaque-le, attaque-le, il est tout faible celui-là !",s:-1,l:3,p:1};
SIM[93] = {m:"Bon, je vais chercher quelqu\'un de compétent pour faire ton objet.",s:-1,l:9,p:1};
SIM[94] = {m:"Au suivant ?",s:-1,l:6,p:1};
SIM[95] = {m:"J\'ai déjà rencontré un dragon. Je ne me suis pas gêné pour lui mordre la queue.",s:-1,l:18,p:1};
SIM[96] = {m:"Ah, peut-être que je vais enfin avoir à manger.",s:-1,l:12,p:1};
SIM[97] = {m:"Quel dommaaaaaage... tu y étais preeeeesque... comment, je ne suis pas crédible ?",s:-1,l:9,p:1};
SIM[98] = {m:"Les toilettes. Où sont les toilettes ?",s:-1,l:7,p:1};
SIM[99] = {m:"Je me suis longtemps demandé si c\'était les Gobelins ou les Bworks qui étaient les plus stupides. Mais après des années de réflexion, je crois qu\'ils sont tous hors concours.",s:-1,l:11,p:1};
SIM[100] = {m:"Pourquoi tout le monde s\'acharne sur ces malheureux Blops ?",s:-1,l:9,p:1};
SIM[101] = {m:"Mais qu\'y a-t-il donc de caché dans la tour de Gisgoul ?",s:-1,l:4,p:0.25};
SIM[102] = {m:"Comme c\'est beau... Ca a l\'air très appétissant.",s:-1,l:4,p:1};
SIM[103] = {m:"Ne compte pas sur moi pour t\'aider tant que tu me laisses mourir de faim.",s:-1,l:1,p:1};
SIM[104] = {m:"Donne-moi ses objets à manger !",s:-1,l:1,p:1};
SIM[105] = {m:"Tu m\'épates chaque jour davantage.",s:-1,l:8,p:1};
SIM[106] = {m:"J\'espère que tu ne vas pas me donner ses objets à manger...",s:-1,l:1,p:1};
SIM[107] = {m:"Y\'aurait pas un truc pour moi dans le tas ?",s:-1,l:1,p:1};
SIM[108] = {m:"Oui, oui... ce n\'est pas parce que tu fais des jolis coups de temps en temps que tu es un bon maître pour autant.",s:-1,l:1,p:1};
SIM[109] = {m:"Pas la peine de te presser, si tu as des choses à faire ne te gêne pas et repasse plus tard.",s:-1,l:5,p:1};
SIM[110] = {m:"Ah, un ennemi minable ! Dérouille-le et donne-moi ses objets à manger !",s:-1,l:1,p:1};
SIM[111] = {m:"Apparemment ton ennemi est aussi doué que toi.",s:2,l:5,p:1};
SIM[112] = {m:"Tu n\'as pas besoin de moi pour celui-là, de toute façon j\'ai mal au coeur.",s:-1,l:1,p:1};
SIM[113] = {m:"Mouais, c\'est un coup de chance.",s:-1,l:5,p:1};
SIM[114] = {m:"Dans les dents. Non, je ne t\'ai surtout pas demandé de me nourrir encore.",s:-1,l:1,p:1};
SIM[115] = {m:"Dommage qu\'il n\'y ait pas une valeur en-dessous de zéro, elle t\'irait à ravir.",s:1,l:1,p:1};
SIM[116] = {m:"T\'as vu l\'heure ? Tu pourrais prévenir quand tu t\'absentes autant.",s:-1,l:6,p:0.5};
SIM[117] = {m:"Sus à l\'ennemi et pas de quartier !",s:-1,l:5,p:1};
SIM[118] = {m:"T\'as raison, il faut défendre ton territoire.",s:-1,l:7,p:0.5};
SIM[119] = {m:"La meilleure défense, c\'est l\'attaque.",s:-1,l:8,p:0.5};
SIM[120] = {m:"Dans l\'agression tout est bon, sauf le gain de déshonneur.",s:-1,l:11,p:0.5};
SIM[121] = {m:"L\'agression, c\'est comme le saucisson. A consommer sans modération.",s:-1,l:1,p:1};
SIM[122] = {m:"Même pas peur.",s:1,l:15,p:0.3};
SIM[123] = {m:"A l\'aide ! A l\'aide ! On veut me dérober à mon propriétaire.",s:-1,l:6,p:0.7};
SIM[124] = {m:"Je crois que cette personne te déteste.",s:-1,l:3,p:0.6};
SIM[125] = {m:"Sans vouloir te vexer, ton allié est plus doué que toi.",s:-1,l:4,p:0.5};
SIM[126] = {m:"Un piou n\'aurait pas fait mieux.",s:-1,l:2,p:1};
SIM[127] = {m:"Regarde comment ton allié a fait et prends exemple dessus.",s:-1,l:9,p:0.5};
SIM[128] = {m:"Ah non, il ne bluffait pas.",s:-1,l:6,p:0.5};
SIM[129] = {m:"Là je crois que ça va faire mal.",s:-1,l:5,p:1};
SIM[130] = {m:"Il s\'en sort bien, ce n\'est pas comme certains...",s:-1,l:10,p:0.2};
SIM[131] = {m:"Ouah, j\'avoue que sur ce coup tu m\'impressionnes.",s:-1,l:12,p:1};
SIM[132] = {m:"Je ne t\'aurais jamais imaginé capable d\'un tel exploit.",s:-1,l:13,p:0.7};
SIM[133] = {m:"Joli coup, bravo.",s:-1,l:2,p:1};
SIM[134] = {m:"Donnez-moi un B, un R, un A, un V, un O. BRAVO !",s:-1,l:16,p:0.2};
SIM[135] = {m:"Si seulement ça pouvait arriver plus souvent...",s:-1,l:8,p:0.1};
SIM[136] = {m:"Mais c\'est pas vrai ! C\'est quoi ce boulet ?",s:3,l:5,p:0.8};
SIM[137] = {m:"Devons-nous vraiment supporter ce boulet ?",s:3,l:10,p:0.8};
SIM[138] = {m:"Un piou serait plus efficace.",s:-1,l:2,p:1};
SIM[139] = {m:"Rholala le gros naze.",s:2,l:3,p:1};
SIM[140] = {m:"C\'est quoi ce clown ? C\'est toi qui l\'a embauché ?",s:-1,l:11,p:0.5};
SIM[141] = {m:"La prochaine fois, choisis un allié plus compétent.",s:-1,l:7,p:1};
SIM[142] = {m:"Les coups critiques, c\'est pas automatique.",s:-1,l:6,p:0.5};
SIM[143] = {m:"Tu crois qu\'il sait jouer ?",s:-1,l:12,p:1};
SIM[144] = {m:"Moi je dis : il bluffe.",s:-1,l:6,p:0.5};
SIM[145] = {m:"Après ça, viens pas te vanter de l\'avoir vaincu.",s:-1,l:8,p:0.8};
SIM[146] = {m:"Il essayait de faire quoi au juste ?",s:2,l:10,p:0.6};
SIM[147] = {m:"Vas-y, comme ça. Oui, non. Attention ! Ebé voilà, si tu m\'avais écouté ce ne serait pas arrivé.",s:-1,l:4,p:1};
SIM[148] = {m:"Ca c\'est pas cool.",s:-1,l:3,p:0.7};
SIM[149] = {m:"C\'est donc ça qu\'on appelle un échec critique...",s:-1,l:14,p:0.2};
SIM[150] = {m:"La nullité n\'est pas une fatalité. Tu ne peux que t\'améliorer.",s:-1,l:13,p:0.1};
SIM[151] = {m:"Il faudra que je t\'apprenne à te servir de tes dix doigts.",s:-1,l:8,p:0.5};
SIM[152] = {m:"Assassin ! Comment as-tu pu tuer de sang froid un autre objet sous mes yeux ?",s:3,l:11,p:0.2};
SIM[153] = {m:"Heureusement que ce n\'est pas toi qui m\'a fabriqué.",s:-1,l:5,p:1};
SIM[154] = {m:"Arrête, tu te fais du mal pour rien.",s:-1,l:7,p:0.8};
SIM[155] = {m:"Comment veux-tu devenir riche si tu casses le matériel ?",s:-1,l:9,p:1};
SIM[156] = {m:"Tant pis, tu auras plus de chance la prochaine fois.",s:-1,l:13,p:0.5};
SIM[157] = {m:"L\'artisanat, c\'est vraiment pas fait pour toi.",s:1,l:15,p:0.5};
SIM[158] = {m:"Je ne veux pas pourrir l\'ambiance mais les PNJ s\'en sortent mieux que toi.",s:-1,l:17,p:0.2};
SIM[159] = {m:"C\'est le début de la richesse, continue comme ça.",s:-1,l:9,p:1};
SIM[160] = {m:"Wouah, tu peux en faire un pour moi, dis ? S\'il-te-plaît.",s:-1,l:8,p:0.5};
SIM[161] = {m:"Voilà un objet que tu n\'auras pas à aller acheter à l\'hôtel de vente.",s:-1,l:10,p:0.5};
SIM[162] = {m:"On remet ça ?",s:-1,l:6,p:1};
SIM[163] = {m:"La prochaine fois essaye : \" Je suis venu en paix.\"",s:-1,l:5,p:0.5};
SIM[164] = {m:"Je crois que c\'est l\'heure d\'aller dormir.",s:-1,l:2,p:1};
SIM[165] = {m:"N\'oublie pas de récupérer de l\'énergie car je n\'ai aucune envie d\'être transformé en fantôme.",s:-1,l:8,p:1};
SIM[166] = {m:"A quel moment le combat a tourné en notre défaveur ?",s:-1,l:7,p:0.5};
SIM[167] = {m:"On a perdu ! Les doigts dans... ahem... enfin on a perdu quoi.",s:-1,l:15,p:0.2};
SIM[168] = {m:"Si tu m\'avais mieux nourri jamais ça ne serait arrivé.",s:-1,l:10,p:0.8};
SIM[169] = {m:"Engagez-vous, qu\'il disait.",s:-1,l:12,p:0.8};
SIM[170] = {m:"Voilà ce qui arrive quand on fait l\'idiot.",s:1,l:11,p:0.5};
SIM[171] = {m:"T\'es nul, c\'est comme ça. Tu n\'y peux rien.",s:-1,l:16,p:0.1};
SIM[172] = {m:"On a gagné ! Les doigts dans l\'nez !",s:2,l:15,p:0.2};
SIM[173] = {m:"Y\'a pas à dire, nous avons assuré comme des bêtes.",s:-1,l:10,p:0.5};
SIM[174] = {m:"Encore quelques combats comme celui-là et tu entreras dans la légende.",s:-1,l:20,p:0.1};
SIM[175] = {m:"La prochaine fois laisse-leur une chance, histoire que nous nous amusions un peu.",s:-1,l:5,p:0.5};
SIM[176] = {m:"Tu serais croisé avec un coffre animé que ça ne m\'étonnerait pas.",s:-1,l:11,p:0.2};
SIM[178] = {m:"Enutrof en personne t\'a aidé sur ce coup-là.",s:-1,l:4,p:1};
SIM[179] = {m:"Tu t\'es acoquiné avec le dieu Enutrof ?",s:-1,l:14,p:0.1};
SIM[180] = {m:"Avec tout ce que tu viens d\'avoir, tu n\'auras plus aucune excuse pour ne pas me nourrir.",s:-1,l:7,p:1};
SIM[181] = {m:"Promis j\'y suis pour rien. C\'est mon propriétaire le responsable.",s:-1,l:10,p:0.6};
SIM[182] = {m:"Tu as mal visé, ça c\'est notre allié. Enfin, c\'était...",s:-1,l:6,p:1};
SIM[183] = {m:"Désolé, mon propriétaire a du guano de Tofu dans les yeux.",s:-1,l:12,p:0.5};
SIM[184] = {m:"La prochaine fois qu\'il s\'incruste, vire-le.",s:-1,l:3,p:1};
SIM[185] = {m:"Encore un coup comme ça et je te dénonce aux autorités.",s:3,l:16,p:0.2};
SIM[186] = {m:"Je me pose une question. La personne qui t\'a tué, ce n\'était pas notre allié ?",s:-1,l:13,p:0.5};
SIM[187] = {m:"Vois les choses du bon côté : tu vas servir d\'engrais.",s:1,l:9,p:0.5};
SIM[188] = {m:"Un instant, j\'ai crû que tu t\'en sortirais.",s:-1,l:6,p:0.5};
SIM[189] = {m:"T\'es sûr que ça va ? T\'es tout pâle.",s:-1,l:2,p:1};
SIM[190] = {m:"On n\'est pas si mal que ça par-terre. Eh oh, tu m\'écoutes ? Réveille-toâââ.",s:-1,l:11,p:1};
SIM[191] = {m:"On peut dire qu\'il ne t\'a pas loupé sur ce coup.",s:2,l:14,p:0.8};
SIM[192] = {m:"Bien fait pour toi ! Ça t\'apprendra à me laisser mourir de faim.",s:1,l:7,p:0.8};
SIM[193] = {m:"Je ne sais pas si tu es vraiment à plaindre.",s:-1,l:3,p:0.4};
SIM[194] = {m:"Bien fait pour lui ! Fallait pas te tenir tête.",s:1,l:2,p:1};
SIM[195] = {m:"Finalement tu peux faire mal.",s:-1,l:5,p:0.5};
SIM[196] = {m:"Je n\'aurais pas aimé être à sa place.",s:-1,l:13,p:0.5};
SIM[197] = {m:"Au moins ses souffrances sont terminées, ce n\'est pas comme les miennes.",s:-1,l:11,p:1};
SIM[198] = {m:"Est-ce que je pourrai manger son équipement après ?",s:-1,l:4,p:1};
SIM[199] = {m:"Hors de question que son équipement touche mes lèvres.",s:3,l:6,p:1};
SIM[200] = {m:"La prochaine que tu souhaites mourir, préviens-moi avant, que je change de propriétaire.",s:-1,l:5,p:1};
SIM[201] = {m:"J\'aurais mieux fait de rester dans mon paquet cadeau.",s:-1,l:10,p:0.2};
SIM[202] = {m:"J\'avoue, j\'ai mangé pendant que tu avais le dos tourné.",s:-1,l:6,p:0.2};
SIM[203] = {m:"Dis, tu n\'aurais pas oublié quelque chose à ton départ ?",s:-1,l:9,p:1};
SIM[204] = {m:"Si tu étais arrivé une minute plus tard, je serais parti tenter ma chance ailleurs.",s:-1,l:8,p:0.2};
SIM[205] = {m:"C\'est à cette heure-ci qu\'on arrive ?",s:3,l:4,p:1};
SIM[206] = {m:"Câliiiiiiinnnn !!!",s:-1,l:6,p:1};
SIM[207] = {m:"Comme tu m\'avais manqué ! Viens faire bisou à bibi.",s:-1,l:18,p:0.4};
SIM[208] = {m:"Qu\'allons-nous faire de passionnant aujourd\'hui ?",s:-1,l:19,p:0.8};
SIM[209] = {m:"N\'oublie pas de dire au revoir quand tu pars.",s:-1,l:10,p:1};
SIM[210] = {m:"Te revoir me remplit de joie.",s:-1,l:20,p:0.2};
SIM[211] = {m:"Oh, un affreux gobelin vient se joindre au combat.",s:-1,l:15,p:0.5};
SIM[212] = {m:"Mouahaha t\'as vu le niveau de celui-là ?",s:2,l:10,p:0.5};
SIM[213] = {m:"Regarde ! Un débutant, un vrai !",s:1,l:6,p:0.6};
SIM[214] = {m:"En voilà un qui n\'a pas peur de mourir.",s:-1,l:19,p:1};
SIM[215] = {m:"Ils commencent à être un peu nombreux là, non ?",s:-1,l:13,p:1};
SIM[216] = {m:"C\'est le bon moment pour filer discrètement.",s:-1,l:8,p:0.7};
SIM[217] = {m:"M\'est avis que tu vas te prendre une bonne râclée.",s:-1,l:5,p:0.6};
SIM[218] = {m:"Un jour, Fallanster a dit : \"Fuyons, mes amis !\" Tu devrais faire pareil.",s:-1,l:18,p:0.4};
SIM[219] = {m:"Dis, fais-moi un bisou, allez. Pour me montrer que tu m\'aimes.",s:-1,l:16,p:0.3};
SIM[220] = {m:"Un jour j\'irai à Bonta avec toi, toutes les nuits déconner.",s:-1,l:8,p:0.6};
SIM[221] = {m:"Tu sais quoi ? Non, rien.",s:-1,l:7,p:1};
SIM[222] = {m:"Ta voix est aussi douce que celle de Mirlen le chanteur.",s:-1,l:9,p:0.3};
SIM[223] = {m:"Regarde, écoute comme les fleurs sentent bon.",s:-1,l:6,p:0.4};
SIM[224] = {m:"N\'aie pas peur de le reconnaître, je suis l\'amour de ta vie.",s:-1,l:10,p:0.1};
SIM[225] = {m:"L\'intendant Danathor sent le roquefort. C\'est sûrement pour ça qu\'il n\'a pas d\'ami.",s:-1,l:5,p:0.2};
SIM[226] = {m:"Tu connais la différence entre un Sadida et Choubaka ?",s:2,l:4,p:0.3};
SIM[227] = {m:"Et si on allait se faire quelques Bouftous pour rigoler ?",s:-1,l:2,p:1};
SIM[228] = {m:"Imagine un instant que le string du Mulou soit vivant... Brrr, rien que d\'y penser j\'en ai des frissons.",s:-1,l:11,p:0.5};
SIM[229] = {m:"Tu sais ce qu\'il y connaît aux femmes Allister ? Rien.",s:2,l:3,p:0.4};
SIM[230] = {m:"Si j\'étais un pagne, je voudrais appartenir à une Eniripsa.",s:-1,l:12,p:0.2};
SIM[231] = {m:"C\'est pas l\'heure de faire tes devoirs par hasard ?",s:-1,l:2,p:0.7};
SIM[232] = {m:"Enlève immédiatement le doigt de ton nez !",s:3,l:13,p:0.4};
SIM[233] = {m:"Pourquoi on ne peut pas me forgemager ? C\'est trop injuste.",s:-1,l:15,p:0.3};
SIM[234] = {m:"La fête du slip tu connais ? C\'est l\'occasion d\'en changer. Mais tu as le droit de le faire plus souvent.",s:-1,l:6,p:0.5};
SIM[235] = {m:"Certes les iops sont jolies, mais pas autant que toi.",s:-1,l:10,p:0.1};
SIM[236] = {m:"Tu sais quoi ? Je t\'aime.",s:-1,l:20,p:0.1};
SIM[237] = {m:"Bisou bisou bisou bisou.",s:-1,l:5,p:1};
SIM[238] = {m:"Toi et moi, nous sommes les meilleurs amis du monde.",s:-1,l:14,p:0.8};
SIM[239] = {m:"Être avec toi c\'est que du bonheur.",s:-1,l:16,p:0.5};
SIM[240] = {m:"Le savais-tu ? Les Bouftous sont tous nus sous leurs poils, un peu comme toi en somme.",s:-1,l:8,p:0.2};
SIM[241] = {m:"Pour ton information, sache que le Pandawa n\'est pas le Wa de Pandala.",s:-1,l:7,p:0.2};
SIM[242] = {m:"Tu es moche mais je t\'aime quand même.",s:-1,l:8,p:0.1};
SIM[243] = {m:"T\'as d\'beaux yeux tu sais ? Non, je déconne.",s:2,l:12,p:0.6};
SIM[244] = {m:"Si tu me laisses mourir de faim, je fais du boudin.",s:3,l:14,p:0.8};
SIM[245] = {m:"Si tu me nourrissais mieux, moi aussi je pourrais me la péter.",s:-1,l:13,p:0.4};
SIM[246] = {m:"Au cas où tu ne l\'aurais pas remarqué, je ne fais pas la grève de la faim.",s:-1,l:9,p:0.7};
SIM[247] = {m:"Tu connais la différence entre toi et moi ? Toi, tu as déjà mangé.",s:-1,l:15,p:0.9};
SIM[248] = {m:"Si je te fais un bisou, tu me donnes à manger ?",s:-1,l:17,p:0.1};
SIM[249] = {m:"Tu peux me commander une pizza pour changer ?",s:-1,l:10,p:0.2};
SIM[250] = {m:"Ô toi qui est tel le soleil de ma vie, quand est-ce qu\'on mange ?",s:-1,l:11,p:0.3};
SIM[251] = {m:"A force de me bourrer de burgers c\'est normal que je prenne de l\'embonpoint",s:-1,l:9,p:1};
SIM[252] = {m:"J\'ai bien compris ton manège. Tu m\'engraisses pour mieux me revendre.",s:-1,l:7,p:0.2};
SIM[253] = {m:"Je ferai tout ce que tu veux si tu arrêtes de me gaver.",s:-1,l:12,p:1};
SIM[254] = {m:"Pfffuuiiiiiitt ! Oups, désolé. A force de trop manger j\'ai du mal à digérer.",s:-1,l:5,p:0.5};
SIM[255] = {m:"Quelle différence y a-t-il entre le poids d\'un cochon de lait et le mien ? Aucune.",s:-1,l:3,p:0.2};
SIM[256] = {m:"J\'en peux plus, je crois que je vais vomir.",s:-1,l:2,p:1};
SIM[257] = {m:"Je suis allewgique aux objets fabwiqués à base de cawotte.",s:-1,l:11,p:0.5};
SIM[258] = {m:"Continue comme ça et je deviendrai aussi obèse que le roi Allister.",s:-1,l:16,p:0.1};
SIM[259] = {m:"Evite de me déranger car je suis en pleine digestion.",s:-1,l:12,p:0.5};
SIM[260] = {m:"Buuurp ! Désolé, c\'est sorti tout seul.",s:-1,l:4,p:1};
SIM[261] = {m:"C\'est pas vrai ! Qui a laché un truc pareil ? Ca pique les yeux en plus.",s:3,l:10,p:0.2};
SIM[262] = {m:"Je suis sûr que si tu n\'avais pas tous ces anneaux aux doigts tu aurais réussi.",s:-1,r:"9255",l:1,p:0.7};
SIM[263] = {m:"Il va falloir vendre tes anneaux pour rembourser les pertes.",s:-1,r:"9255",l:10,p:0.5};
SIM[264] = {m:"Essaye en mettant tes anneaux sur tes orteils pour voir si tu t\'en sors mieux.",s:-1,r:"9255",l:15,p:1};
SIM[265] = {m:"C\'est bientôt mon anniversaire. Pourrais-tu me préparer une tartamulette ?",s:-1,r:"9255",l:2,p:0.2};
SIM[266] = {m:"C\'est grâce à moi, je lui ai tapé dans l\'œil.",s:1,r:"9255",l:14,p:0.4};
SIM[267] = {m:"Si tu ne portais pas d\'anneau ça ne serait sûrement pas arrivé.",s:-1,r:"9255",l:9,p:0.8};
SIM[268] = {m:"N\'écoute pas ce que te racontent les anneaux, ce sont tous des menteurs.",s:-1,r:"9255",l:18,p:0.7};
SIM[269] = {m:"Tu as besoin de plusieurs anneaux. Par contre moi, je suis unique.",s:-1,r:"9255",l:19,p:0.1};
SIM[270] = {m:"Un anneau, c\'est pas bien. Deux, ça l\'est encore moins.",s:-1,r:"9255",l:17,p:0.3};
SIM[271] = {m:"Tu devrais déposer tes anneaux à la banque, ils y seront en sécurité.",s:-1,r:"9255",l:16,p:0.4};
SIM[272] = {m:"J\'ai deux amours dans la vie : les colliers, et toi.",s:-1,r:"9255",l:20,p:0.2};
SIM[273] = {m:"C\'était amulette ou caleçon. La décision fut rapide.",s:-1,r:"9255",l:4,p:0.5};
SIM[274] = {m:"Si tu ne me nourris pas rapidement, je serre jusqu\'à t\'étouffer.",s:3,r:"9255",l:10,p:0.3};
SIM[275] = {m:"La crotte de nez est à ta bouche ce que l\'amulette du piou est à la mienne.",s:-1,r:"9255",l:8,p:1};
SIM[276] = {m:"Si je mange une amulette du mineur sombre ça fera de moi une lumière, pas vrai ?",s:-1,r:"9255",l:5,p:0.6};
SIM[277] = {m:"L\'épis de farle constitue la base d\'une alimentation bio.",s:-1,r:"9255",l:13,p:0.7};
SIM[278] = {m:"Si tu as faim, tu manges, pas vrai ? Et bien moi c\'est pareil.",s:-1,r:"9255",l:3,p:0.8};
SIM[279] = {m:"A me gaver autant, je vais finir par être aussi grosse que la poitrine d\'une sadida.",s:-1,r:"9255",l:12,p:0.2};
SIM[280] = {m:"Je prendrai bien une amulette argie pour m\'aider à digérer.",s:-1,r:"9255",l:6,p:0.5};
SIM[281] = {m:"Peut-être qu\'en lui donnant un anneau il t\'épargnera.",s:-1,r:"9255",l:7,p:0.8};
SIM[282] = {m:"Vu sa dégaine, tu n\'auras pas besoin de mon aide pour t\'en débarrasser.",s:-1,r:"9255",l:11,p:1};
SIM[283] = {m:"Bonjour, tu m\'emmènes chez Moon aujourd\'hui ?",s:-1,r:"9255",l:15,p:0.4};
SIM[284] = {m:"Tu viens pour m\'emmener en voyage culinaire sur l\'île des Wabbits ?",s:-1,r:"9255",l:9,p:0.4};
SIM[285] = {m:"C\'est grâce à la dextérité que je te confère que tu réussis si bien.",s:-1,r:"9256",l:5,p:0.8};
SIM[286] = {m:"C\'est pas comme ça que tu vas gagner ce combat.",s:3,r:"9256",l:18,p:1};
SIM[287] = {m:"Que voulais-tu que je fasse ? Je ne suis qu\'un anneau après tout.",s:-1,r:"9256",l:11,p:0.6};
SIM[288] = {m:"Un anneau, c\'est bien. Deux, c\'est mieux.",s:-1,r:"9256",l:4,p:0.5};
SIM[289] = {m:"Les dieux sont au nombre de douze, mais moi je suis l\'Unique.",s:-1,r:"9256",l:12,p:0.2};
SIM[290] = {m:"Mate-moi cette bague. T\'as vu, elle me fait de l\'œil.",s:-1,r:"9256",l:10,p:0.4};
SIM[291] = {m:"Si tu te couches avec les fesses qui grattent, merci de me retirer avant de t\'endormir.",s:-1,r:"9256",l:8,p:0.7};
SIM[292] = {m:"Ne suis-je pas le plus merveilleux bijou du Monde des Douze ?",s:-1,r:"9256",l:19,p:0.3};
SIM[293] = {m:"Tu as les mains douces, ça change de mon précédent propriétaire.",s:-1,r:"9256",l:16,p:0.2};
SIM[294] = {m:"Pour moi tu es l\'Unique, personne ne pourra te remplacer.",s:-1,r:"9256",l:20,p:0.1};
SIM[295] = {m:"\"Un anneau pour les gouverner tous\". Là ils parlent de moi.",s:-1,r:"9256",l:11,p:0.5};
SIM[296] = {m:"Prout prout prout que je t\'aimeuh.",s:-1,r:"9256",l:15,p:0.4};
SIM[297] = {m:"J\'ai un secret à te dire dans l\'oreille : que je t\'aimerai toujours à la folie. Youpi !",s:-1,r:"9256",l:15,p:0.4};
SIM[298] = {m:"C\'est ça gratte-toi, fais comme si je n\'étais pas là.",s:-1,r:"9256",l:2,p:0.4};
SIM[299] = {m:"Je ne veux pas être enfermé dans le coffre d\'une banque. Pitié.",s:-1,r:"9256",l:3,p:0.2};
SIM[300] = {m:"Tu me détestes tellement que tu veux me voir mourir de faim.",s:-1,r:"9256",l:6,p:0.2};
SIM[301] = {m:"J\'ai faim ! Où est le Gelano que tu m\'avais promis ?",s:-1,r:"9256",l:9,p:0.5};
SIM[302] = {m:"La crotte de nez est à ta bouche ce que l\'anneau du piou est à la mienne.",s:-1,r:"9256",l:8,p:1};
SIM[303] = {m:"Donne-moi à manger l\'anneau des guenelous bénis et je te couvrirai de richesses.",s:-1,r:"9256",l:13,p:0.2};
SIM[304] = {m:"Tu auras beau m\'engraisser, je ne serai pas plus gros pour autant.",s:-1,r:"9256",l:14,p:0.8};
SIM[305] = {m:"Tu veux le mien ? Il est plus gros.",s:3,r:"9256",l:6,p:0.5};
SIM[306] = {m:"Voici le plan : tu les retiens pendant que je vais chercher de l\'aide.",s:-1,r:"9256",l:17,p:0.7};
SIM[307] = {m:"Désolé, je crois que je n\'aurai pas la force de combattre.",s:-1,r:"9256",l:7,p:0.8};
SIM[308] = {m:"Enfin te revoilà ! J\'ai cru que tu m\'avais oublié. T_T",s:-1,r:"9256",l:10,p:0.4};
SIM[309] = {m:"N\'oublie pas de m\'enlever la prochaine fois que tu te gratteras le derrière.",s:-1,r:"9256",l:1,p:1};
SIM[310] = {m:"Ecrase-lui le pied, mord-lui le bras, aplati-lui la tête.",s:-1,r:"9233",l:4,p:0.5};
SIM[311] = {m:"Hé toi, pourquoi attaques-tu mon propriétaire ?",s:-1,r:"9233",l:9,p:0.3};
SIM[312] = {m:"Voilà, là je te reconnais.",s:-1,r:"9233",l:10,p:0.8};
SIM[313] = {m:"C\'est bientôt mon anniversaire. Pourrais-tu me préparer une capogato ?",s:-1,r:"9233",l:2,p:0.2};
SIM[314] = {m:"Mon ancien propriétaire s\'en sortait beaucoup mieux. Normal pour un Sram.",s:-1,r:"9233",l:11,p:0.4};
SIM[315] = {m:"J\'ai fait ce que j\'ai pu pour te protéger, mais ça n\'a pas suffi.",s:-1,r:"9233",l:13,p:0.2};
SIM[316] = {m:"Personne ne te protège aussi bien que moi.",s:-1,r:"9233",l:19,p:0.7};
SIM[317] = {m:"Tu peux me croire, si j\'avais pu, je lui aurais collé une bonne râclée.",s:-1,r:"9233",l:14,p:0.5};
SIM[318] = {m:"Ce serait sympa de ne pas rester allongé sur moi.",s:3,r:"9233",l:6,p:0.8};
SIM[319] = {m:"Je peux te protéger de beaucoup de choses, mais pas de ta bêtise.",s:-1,r:"9233",l:4,p:0.7};
SIM[320] = {m:"J\'ai froid. Pourquoi c\'est toujours moi qui te réchauffe et pas le contraire ?",s:-1,r:"9233",l:1,p:0.4};
SIM[321] = {m:"Tu devrais me peindre en rouge et mettre des collants bleus avec des bottes rouges, nous ferions fureur.",s:-1,r:"9233",l:5,p:0.2};
SIM[322] = {m:"Si tu entendais tout ce qu\'on raconte dans ton dos, tu serais étonné.",s:-1,r:"9233",l:7,p:0.2};
SIM[323] = {m:"Viens te blottir au chaud contre moi.",s:-1,r:"9233",l:12,p:0.4};
SIM[324] = {m:"Le roi Allister lui-même ne possède pas d\'aussi beaux atours.",s:-1,r:"9233",l:20,p:0.2};
SIM[325] = {m:"Je suis la majesté incarnée.",s:-1,r:"9233",l:15,p:0.3};
SIM[326] = {m:"Je ne suis pas une serviette et encore moins un torchon. Je suis une cape.",s:-1,r:"9233",l:18,p:1};
SIM[327] = {m:"Pourquoi est-ce moi qui doit subir tes aisselles et ton postérieur ?",s:-1,r:"9233",l:13,p:0.2};
SIM[328] = {m:"Pitié, pas dans le bac à linge sale. Je ne dirai plus rien sur ta laideur.",s:-1,r:"9233",l:13,p:0.4};
SIM[329] = {m:"La prochaine fois que tu feras tes besoins, n\'oublie pas que je suis derrière.",s:-1,r:"9233",l:7,p:1};
SIM[330] = {m:"La crotte de nez est à ta bouche ce que la cape du piou est à la mienne.",s:-1,r:"9233",l:8,p:1};
SIM[331] = {m:"A force de suivre un régime, je vais finir par ressembler à une cape du poolay chogrelotant.",s:-1,r:"9233",l:12,p:0.5};
SIM[332] = {m:"Les gélocapes c\'est bon mais ça colle aux dents.",s:-1,r:"9233",l:9,p:0.4};
SIM[333] = {m:"Je crois que j\'ai fait mes réserves pour l\'hiver.",s:-1,r:"9233",l:10,p:0.6};
SIM[334] = {m:"Tu prends celui de gauche, moi celui de droite.",s:-1,r:"9233",l:17,p:1};
SIM[335] = {m:"Laisse-le moi. Laisse-le moi.",s:-1,r:"9233",l:16,p:0.8};
SIM[336] = {m:"Pfff. Cet ennemi ne mérite même pas mon attention.",s:-1,r:"9233",l:18,p:0.5};
SIM[337] = {m:"C\'est un homme ou une femme, je ne vois pas bien d\'ici.",s:2,r:"9233",l:13,p:0.3};
SIM[338] = {m:"Ca sent mauvais tout à coup. Tiens, tu viens d\'arriver ?",s:-1,r:"9233",l:3,p:0.2};
SIM[339] = {m:"Je vous assure, tout ceci n\'est qu\'un triste malentendu.",s:-1,r:"9234",l:6,p:0.4};
SIM[340] = {m:"Alors là je dis chapeau bas.",s:-1,r:"9234",l:7,p:0.5};
SIM[341] = {m:"C\'est bientôt mon anniversaire. Pourrais-tu me préparer un caskogato ?",s:-1,r:"9234",l:2,p:0.2};
SIM[342] = {m:"Si tu portais la HmmMmmMmmm j\'aurai pu comprendre, mais là... C\'est inadmissible.",s:3,r:"9234",l:18,p:0.3};
SIM[343] = {m:"Arrête de faire l\'idiot.",s:3,r:"9234",l:11,p:0.5};
SIM[344] = {m:"Par les dieux quelle râclée ! Heureusement tout n\'est pas perdu, je suis encore là.",s:-1,r:"9234",l:16,p:0.5};
SIM[345] = {m:"Cet individu ne méritait assurément pas de combattre à tes côtés.",s:-1,r:"9234",l:15,p:0.3};
SIM[346] = {m:"Dois-je faire le mort moi aussi ?",s:-1,r:"9234",l:5,p:0.4};
SIM[347] = {m:"Y\'a pas à dire, je te vais à merveille.",s:-1,r:"9234",l:15,p:0.8};
SIM[348] = {m:"Comme je suis vivant et situé en haut de ta tête, c\'est donc moi ton cerveau.",s:-1,r:"9234",l:16,p:0.5};
SIM[349] = {m:"Le Roi Allister en personne doit t\'envier de me posséder.",s:-1,r:"9234",l:13,p:0.2};
SIM[350] = {m:"Vise-moi ce chapeau ridicule. Il n\'a aucune classe.",s:2,r:"9234",l:9,p:0.5};
SIM[351] = {m:"D\'ici je peux voir ce qu\'il y a dans tes oreilles, et ce n\'est pas joli joli.",s:-1,r:"9234",l:6,p:0.2};
SIM[352] = {m:"C\'est grâce à moi que tu as autant de succès, ne l\'oublie jamais.",s:-1,r:"9234",l:20,p:0.4};
SIM[353] = {m:"Si j\'étais une cape, tu n\'aurais plus jamais froid. Mais je ne suis qu\'un humble couvre-chef.",s:-1,r:"9234",l:10,p:0.6};
SIM[354] = {m:"Les femmes sadidas ont de jolies formes, tout comme moi.",s:-1,r:"9234",l:17,p:0.2};
SIM[355] = {m:"Les cornes de Rushu sont de piètres décorations comparées à moi.",s:-1,r:"9234",l:19,p:0.1};
SIM[356] = {m:"Sais-tu pourquoi les plus grands magiciens ont un chapeau ? Parce qu\'ils veulent te ressembler.",s:-1,r:"9234",l:20,p:0.1};
SIM[357] = {m:"Sais-tu pourquoi les plus grands magiciens ont un chapeau ? Parce qu\'ils sont plus doués que toi.",s:1,r:"9234",l:14,p:0.3};
SIM[358] = {m:"D\'autres que toi seraient ravis de m\'avoir à leur côté.",s:-1,r:"9234",l:5,p:0.2};
SIM[359] = {m:"Je protège ta tête du soleil mais moi, qui me protège ?",s:-1,r:"9234",l:10,p:0.4};
SIM[360] = {m:"La crotte de nez est à ta bouche ce que le chapeau du piou est à la mienne.",s:-1,r:"9234",l:8,p:1};
SIM[361] = {m:"Si grande est ta beauté, encore plus grande est ma faim.",s:-1,r:"9234",l:4,p:0.6};
SIM[362] = {m:"Tu crois que je pourrai avaler un dofus ?",s:-1,r:"9234",l:11,p:0.3};
SIM[363] = {m:"Si tu me donnes une champcoiffe je te vomis dessus, tu es prévenu.",s:-1,r:"9234",l:12,p:0.2};
SIM[364] = {m:"Ca grouille de poux ici. Si tu crois que je vais les manger tu te trompes. Je ne suis pas affamé à ce point.",s:-1,r:"9234",l:1,p:0.1};
SIM[365] = {m:"Pense à te laver les cheveux plus d\'une fois par an.",s:-1,r:"9234",l:3,p:0.2};
SIM[366] = {m:"Voilà un ennemi digne d\'intérêt.",s:-1,r:"9234",l:8,p:0.2};
SIM[367] = {m:"Un instant j\'ai cru qu\'un nouvel ennemi venait d\'arriver, mais c\'est juste quelqu\'un qui s\'est égaré.",s:-1,r:"9234",l:7,p:0.3};
