I.u[8300] = {n:"Bâton de Shika",t:4,d:"Ce bâton taillé sur mesure, permettait à Shika de créer les meules de foin les plus hautes de tout Amakna. La légende raconte que leur taille était si importante, que les marins s\'en servaient de points de repères pour savoir s\'ils approchaient ou non de la côte d\'Amakna.",ep:20,g:69,l:80,wd:true,fm:true,w:10,an:12,e:[10,5,1,1,45,45,false,false],s:53,p:16500};
I.u[8301] = {n:"Sabots de Shika",t:11,d:"Ces sabots ont été conçus pour permettre à Shika de ne jamais écraser les semis, lorsqu\'elle ensemençait les plaines de Snossios. Elle y fit rajouter des talons hauts, pour qu\'elle puisse courir librement le matin dans les éteules, sans remplir ses sabots de rosée, ou sans abîmer ses chevilles fragiles.",ep:21,g:91,l:80,wd:true,fm:true,w:10,s:53,p:16600};
I.u[8302] = {n:"Cape de Shika",t:17,d:"Des fleurs des moissons ont été cousues sur cette cape confectionnée à partir de céréales magiques tissées entre elles. Elle est animée d\'une magie si puissante, que Shika s\'en servait de protection contre la foudre, les soirs d\'orage.",ep:20,g:120,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8303] = {n:"Shikature",t:10,d:"Cette ceinture en cuir protégeait les cuisses de Shika, lorsqu\'elle traversait des champs de blé en courant pour rattraper les Bouftous égarés de son troupeau. Recouverte de pollen de céréales magiques, on raconte qu\'elle brillait au clair de lune, et permettait à Farle de ne pas sectionner les jambes de sa propre femme lorsqu\'il fauchait des champs entiers de céréales une fois la nuit tombée.",ep:21,g:107,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8304] = {n:"Shikacoiffe",t:16,d:"Recouverte d\'une multitude de fleurs des moissons, cette coiffe donnait une allure guillerette à Shika, lorsqu\'elle partait au petit matin, labourer les collines Koln.",ep:20,g:156,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8305] = {n:"Relique du Mominotor",t:24,d:"Cette étrange relique est indispensable pour pouvoir rencontrer le Minotoror.",ep:21,g:119,l:1,wd:false,fm:true,w:0,p:1};
I.u[8306] = {n:"Relique du Déminoboule",t:24,d:"Cette étrange relique est indispensable pour pouvoir rencontrer le Minotoror.",ep:21,g:120,l:1,wd:false,fm:true,w:0,p:1};
I.u[8307] = {n:"Clef de la salle du Minotot",t:84,d:"Cette clef construite à partir de diverses ressources, vous permettra de rencontrer l\'incroyable Minotot. Une rencontre qui vous marquera à vie, lorsque le Minotot vous aura envoyé quelques coups de sabots dans le derrière.",ep:13,g:15,l:1,wd:true,fm:true,w:1,p:10};
I.u[8308] = {n:"Carapace de Scaratos",t:107,d:"Cette petite carapace luisante est très pratique pour créer de beaux bijoux à moindre frais, que vous revendrez une fortune, une fois que vous aurez persuadé un Astrubien, que c\'est une puissante relique qui permet de voler dans les airs en se rendant invisible.",ep:21,g:735,l:1,wd:true,fm:true,w:1,p:10};
I.u[8309] = {n:"Plume du Serpiplume",t:53,d:"Cette plume est recouverte de poussière de pierre magique, ce qui explique qu\'une unité de plume de Serpiplume, pèse plus lourd que trois unités de plume de Tofu. Tout est une question de logique.",ep:21,g:4,l:1,wd:true,fm:true,w:10,p:1};
I.u[8310] = {n:"Gelée de Dégelée",t:110,d:"Ce pot de gelée contient une substance à l\'odeur repoussante et au goût épouvantable, et pourtant, vous rêvez tous les jours secrètement de vous enduire de cette substance. Un autre trouble de votre comportement, qui doit en cacher d\'autres...",ep:21,g:736,l:1,wd:true,fm:true,w:1,p:1};
I.u[8311] = {n:"Poil de Gamino",t:54,d:"Ce poil semble recouvert d\'une sorte de gomina à base de musc de Bitouf à poils ras, et de graisse de Kirboule des cavernes. On aurait presque envie de les manger.",ep:21,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[8312] = {n:"Peau de Minoskito",t:59,d:"Cette peau usée par le sable fin et le sel de mer est fine comme une vieille chaussette usée par le sable fin et le sel de mer. De là à dire que le Minoskito ressemble à une vieille chaussette, il n\'y a qu\'un pas, que vous ne franchirez pas.",ep:21,g:604,l:1,wd:true,fm:true,w:1,p:1};
I.u[8313] = {n:"Fémur du Minotoror",t:47,d:"Cet os est assez solide pour servir de poutrelle, ou pour casser des briques par lots de dix. Très pratique pour détruire la maison de ses voisins, mais complètement inutile pour les personnes saines d\'esprit.",ep:2,g:644,l:1,wd:true,fm:true,w:1,p:1};
I.u[8314] = {n:"Peau de Kraméléhon",t:59,d:"Cette peau brûlée protège efficacement les peaux sensibles, des rayons du soleil. A porter très près du corps.",ep:21,g:603,l:1,wd:true,fm:true,w:1,p:1};
I.u[8315] = {n:"Peau de Mandrine",t:59,d:"Cette peau tachetée a la réputation d\'être recouverte d\'un poison capable de transformer n\'importe qui en Karaboule desséché. Inquiétant, mais tout de même tentant.",ep:21,g:602,l:1,wd:true,fm:true,w:1,p:1};
I.u[8316] = {n:"Le Tifoux : Bien l\'élever",t:25,d:"Ce livre écrit par Oshimo Li\'kross Babine explique comment élever un Tifoux.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8317] = {n:"El Scarador : Bien l\'élever",t:25,d:"Ce livre écrit par Oshimo Li\'kross Babine explique comment élever El Scarador.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8318] = {n:"Abra Kadabra : Bien l\'élever",t:25,d:"Ce livre écrit par Oshimo Li\'kross Babine explique comment élever Abra Kadabra.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8319] = {n:"Bouloute : Bien l\'élever",t:25,d:"Ce livre écrit par Oshimo Li\'kross Babine explique comment élever Bouloute.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8320] = {n:"Clef de l\'antre du Dragon Cochon",t:84,d:"Après être entré et vous être perdu dans le labyrinthe du Dragon Cochon, vous vous êtes aperçu que vous aviez oublié de prendre vos clefs de l\'antre du Dragon Cochon. Heureusement, vos amis les Porcos avaient un double des clefs sur eux.",ep:15,g:16,l:1,wd:true,fm:true,w:1,p:100};
I.u[8321] = {n:"Poil de Déminoboule",t:54,d:"Inutile d\'insister, ces poils ne sont pas comestibles.",ep:21,g:664,l:100,wd:true,fm:true,w:1,p:10};
I.u[8322] = {n:"Poil de Mominotor",t:54,d:"Sous ses bandelettes, le Mominotor cache un duvet très doux qui rendrait jalouse la plus coquette des princesses.",ep:21,g:663,l:100,wd:true,fm:true,w:1,p:10};
I.u[8323] = {n:"Cuir de Déminoboule",t:56,d:"Craquelé et rugueux, ce cuir vous rappellera les joues de votre dulcinée.",ep:21,g:657,l:100,wd:true,fm:true,w:1,p:10};
I.u[8324] = {n:"Cuir de Mominotor",t:56,d:"Le Mominotor a toujours eu la peau très fragile, c\'est pour cela qu\'il doit se recouvrir de nombreuses bandelettes. Les mauvaises langues racontent que c\'est pour cacher d\'autres choses assez surprenantes...",ep:21,g:656,l:100,wd:true,fm:true,w:1,p:10};
I.u[8325] = {n:"Coiffe du Mominotor",t:16,d:"Si vous voulez préserver votre visage des affres du temps, nous vous conseillons cette coiffe. Attention, elle est totalement inefficace pour vous protéger des pertes de mémoire.",ep:0,g:157,l:110,wd:false,fm:true,w:10,s:59,p:100};
I.u[8326] = {n:"Bandelette du Mominotor",t:15,d:"Enroulée autour des cornes, mais surtout des parties intimes du Mominotor, ces bandelettes se sont imprégnées pendant de longues années de toute la magie du Mominotor. À la fois malodorantes et terrifiantes, ces bandelettes ont leur place dans les collections de tous les archéologues de renom.",ep:21,g:734,l:100,wd:true,fm:true,w:1,p:10};
I.u[8327] = {n:"Corne de Déminoboule",t:47,d:"Cette corne impressionnante n\'est à première vue d\'aucune utilité, et même en y regardant de plus près, elle se révèle bien peu utile.  Un peu comme une armée de tiques par exemple.",ep:21,g:643,l:100,wd:true,fm:true,w:1,p:10};
I.u[8328] = {n:"Corne de Mominotor",t:47,d:"Enroulée dans des bandelettes magiques, cette corne doit de toute évidence valoir très cher, être très précieuse, sentir très mauvais, et être maudite. Un peu comme une momie.",ep:21,g:642,l:100,wd:true,fm:true,w:1,p:10};
I.u[8330] = {n:"Coiffe du Dragoeuf volant",t:16,d:"Cette petite coiffe permet au Dragoeuf volant de se jeter sur ses ennemis sans risquer de se faire de jolies bosses sur le crâne. Utilisée depuis longtemps sur les grands chantiers d\'Amakna, cette coiffe a connu un regain de popularité après l\'invasion d\'Astrub par l\'illustre troupe des Meulous débridés de la montagne de Kruup. Il n\'y a aucune logique dans cette histoire, mais quelle importance ?",ep:13,g:152,l:72,wd:true,fm:true,w:10,p:16000};
I.u[8331] = {n:"Coiffe de la Dragueuse",t:16,d:"Equipé de cette coiffe, vous pourrez sans peine vous travestir et séduire le premier Astrubien un peu trop crédule que vous voudrez arnaquer, en lui proposant une folle nuit d\'amour derrière un grand orme, pour 100 kamas seulement.",ep:18,g:153,l:95,wd:true,fm:true,w:10,p:23000};
I.u[8333] = {n:"Cape du Papa Nowel",t:17,d:"Cette mystérieuse cape fait son apparition lors des saisons froides, et permet aux imposteurs de se faire passer pour un vieillard généreux.",ep:1,g:119,l:19,wd:true,fm:true,w:10,p:1205};
I.u[8334] = {n:"Chapeau du Papa Nowel",t:16,d:"Ce chapeau vous permettra de cacher les cicatrices que vous avez sur le crâne. Vous pourrez enfin plaire aux enfants.",ep:1,g:155,l:22,wd:true,fm:true,w:10,p:1478};
I.u[8335] = {n:"Tout petit cadeau de Nowel",t:89,d:"L\'équipe d\'Ankama vous souhaite de joyeuses et agréables fêtes. Ce cadeau vous rendra heureux comme vous ne l\'avez jamais été.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8336] = {n:"Petit cadeau de Nowel",t:89,d:"L\'équipe d\'Ankama vous souhaite de joyeuses et agréables fêtes. Ce cadeau vous rendra heureux comme vous ne l\'avez jamais été.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8337] = {n:"Cadeau de Nowel",t:89,d:"L\'équipe d\'Ankama vous souhaite de joyeuses et agréables fêtes. Ce cadeau vous rendra heureux comme vous ne l\'avez jamais été.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8338] = {n:"Epée de Nowel",t:6,d:"Cette étrange épée ne vous rendra pas invincible, mais vous pourrez peut-être vous en servir pour tuer des boules de neige.",ep:1,g:69,l:1,wd:false,fm:true,w:1,an:14,e:[1,1,1,1,2,2,false,true],p:1};
I.u[8339] = {n:"Grand cadeau de Nowel",t:89,d:"L\'équipe d\'Ankama vous souhaite de joyeuses et agréables fêtes. Ce cadeau vous rendra heureux comme vous ne l\'avez jamais été.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8340] = {n:"Incroyable cadeau de Nowel",t:89,d:"L\'équipe d\'Ankama vous souhaite de joyeuses et agréables fêtes. Ce cadeau vous rendra heureux comme vous ne l\'avez jamais été.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8341] = {n:"Bottananas",t:11,d:"Ces bottes sentent le jus d\'ananas macéré dans du substrat de chaussette trouée. L\'avantage, c\'est qu\'on ne vous demandera jamais de les enlever lorsque vous irez chez un ami.",ep:1,g:90,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8342] = {n:"Clef du Sanctuaire des Dragoeufs",t:84,d:"Cette clef confectionnée à base de coquilles de Dragoeufs vous permettra d\'accéder au terrible Sanctuaire des Dragoeufs, réputé pour ses habitants peu loquaces.",ep:10,g:18,l:1,wd:true,fm:true,w:1,p:100};
I.u[8343] = {n:"Clef du Donjon des Dragoeufs",t:84,d:"Vous pensiez être arrivé au bout de vos peines en rentrant dans le Sanctuaire des Dragoeufs, mais vous vous êtes lamentablement trompé. Cette clef vous mènera peut-être vers une mort certaine.",ep:10,g:17,l:1,wd:true,fm:true,w:1,p:100};
I.u[8344] = {n:"Corne de Dragoss Noir",t:47,d:"Moins pointue qu\'une aiguille de Xélor, mais plus solide, cette corne permet aux Dragoss de transformer un botte-fesses, en perce-fesses.",ep:11,g:648,l:50,wd:true,fm:true,w:1,p:10};
I.u[8345] = {n:"Corne de Dragoss de Saphire",t:47,d:"Moins pointue qu\'une aiguille de Xélor, mais plus solide, cette corne permet aux Dragoss de transformer un botte-fesses, en perce-fesses.",ep:11,g:647,l:50,wd:true,fm:true,w:1,p:10};
I.u[8346] = {n:"Corne de Dragoss Blanc",t:47,d:"Moins pointue qu\'une aiguille de Xélor, mais plus solide, cette corne permet aux Dragoss de transformer un botte-fesses, en perce-fesses.",ep:11,g:646,l:50,wd:true,fm:true,w:1,p:10};
I.u[8347] = {n:"Corne de Dragoss Doré",t:47,d:"Moins pointue qu\'une aiguille de Xélor, mais plus solide, cette corne permet aux Dragoss de transformer un botte-fesses, en perce-fesses.",ep:11,g:645,l:50,wd:true,fm:true,w:1,p:10};
I.u[8348] = {n:"Coquille de Dragoss Noir",t:111,d:"Cette coquille peut éventuellement servir à protéger ce que vous avez de plus précieux.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Coquille de Dragoss de Saphir",t:111,d:"Cette coquille peut éventuellement servir à protéger ce que vous avez de plus précieux.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
I.u[8350] = {n:"Coquille de Dragoss Blanc",t:111,d:"Cette coquille peut éventuellement servir à protéger ce que vous avez de plus précieux.",ep:11,g:740,l:50,wd:true,fm:true,w:1,p:10};
I.u[8351] = {n:"Coquille de Dragoss Doré",t:111,d:"Cette coquille peut éventuellement servir à protéger ce que vous avez de plus précieux.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Ecaille de Dragoss Noir",t:59,d:"Cette écaille de Dragoss pourrait servir à confectionner de belles bottines, ou des sous-vêtements de combat.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Ecaille de Dragoss de Saphire",t:59,d:"Cette écaille de Dragoss pourrait servir à confectionner de belles bottines, ou des sous-vêtements de combat.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"Ecaille de Dragoss Blanc",t:59,d:"Cette écaille de Dragoss pourrait servir à confectionner de belles bottines, ou des sous-vêtements de combat.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Ecaille de Dragoss Doré",t:59,d:"Cette écaille de Dragoss pourrait servir à confectionner de belles bottines, ou des sous-vêtements de combat.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Peau de Dragueuse",t:59,d:"Lisse et parfumée avec du sang de jeunes aventuriers, cette peau rend de toute évidence les Dragueuses irrésistibles. Utilisée pour des bottes, ou des ceintures, cette peau a l\'avantage d\'être lavable en machine, à n\'importe quelle température.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Corne de Dragueuse",t:47,d:"La Dragueuse dispose de deux petites cornes à l\'arrière de son crâne, qui lui permettent de capter plus facilement les ondes amoureuses émises par les autres Dragoeufs pendant la saison des amours, qui rappelons-le, ne s\'arrête jamais chez les Dragoeufs.",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Protection de la Dragueuse",t:111,d:"Cette paire de coquilles de Dragoeuf permet à la Dragueuse de se protéger de ses propres coups de foudre. Cette protection est également utilisable par les mâles, si elle est portée sous la ceinture.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Aile de Dragoeuf Volant",t:104,d:"Même abimée, déchirée et brûlée, cette aile permet au Dragoeuf Volant de se mouvoir librement au dessus du vide, comme un jeune Moskito insouciant.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Peau de Dragoeuf Volant",t:59,d:"Cette peau sombre est recouverte d\'une multitude de petites écailles censées améliorer l\'aérodynamisme du Dragoeuf Volant. En réalité, elles servent juste à impressionner les badauds.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Corne de Dragoeuf Volant",t:47,d:"Cette corne sert de viseur au Dragoeuf Volant afin de ne pas râter ses cibles, lorsqu\'il vole en état d\'ébriété.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Peau de Dragoeuf Guerrier",t:59,d:"Assez solide pour résister aux coups de sa propre lame, la peau du Dragoeuf Guerrier est surtout réputée pour être comestible, une fois bouillie pendant plusieurs années.",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Corne de Dragoeuf Guerrier",t:47,d:"Le Dragoeuf Guerrier dispose de trois cornes différentes, deux derrières la tête, et une sur le bout du museau. Généralement, après une attaque, une corne se retrouve plantée dans le derrière de ses victimes, et les deux dernières enfoncées profondément dans les narines d\'un imprudent. Mais parfois le Dragoeuf Guerrier confond le derrière et les narines de ses victimes, ce qui pour le coup, leur cause beaucoup plus de tort.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Lanière en cuir du Dragoeuf Guerrier",t:15,d:"Cette lanière en cuir permet au Dragoeuf Guerrier d\'accrocher son épaulette, ou de remplacer vos bretelles.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Corne brisée de Crocabulia",t:47,d:"Crocabulia a cassé sa propre corne lors d\'un terrible combat dans lequel elle tentait de protéger l\'oeuf qui donna naissance 15 années plus tard, au Crocoburio.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Cape du Petit Chapon Rouge",t:17,d:"Cette cape appartenait à un célèbre Chapon, ancien volatile aux longues plumes qui aimait se pavoiser devant le Zaap de Bonta devant sa basse-cour composée de volailles crédules et de poulardes immatures.",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Peau de Crocabulia",t:59,d:"Cette peau rouge vous permettra peut-être de confectionner une cape du petit Chapon Rouge, si vous ne redoutez pas les railleries de vos alliés.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Dent de Crocabulia",t:47,d:"Cette énorme dent a été arrachée in extremis avant que Crocabulia ne referme sa gueule pour toujours.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Fragment de Coquille de Terrakoubiak le Guerrier",t:111,d:"Ce fragment de coquille appartenant à Terrakoubiak le Guerrier, devrait vous aider à fabriquer une clef pour le sanctuaire des Dragoeufs.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Fragment de Coquille d\'Ignelicrobur le Guerrier",t:111,d:"Ce fragment de coquille appartenant à Ignelicrobur le Guerrier, devrait vous aider à fabriquer une clef pour le sanctuaire des Dragoeufs.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Fragment de Coquille d\'Aerohouctor le Guerrier",t:111,d:"Ce fragment de coquille appartenant à Aerohouctor le Guerrier, devrait vous aider à fabriquer une clef pour le sanctuaire des Dragoeufs.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Fragment de Coquille d\'Aquabralak le Guerrier",t:111,d:"Ce fragment de coquille appartenant à Aquabralak le Guerrier, devrait vous aider à fabriquer une clef pour le sanctuaire des Dragoeufs.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Pierre d\'Ignerkocropos l\'Affamé",t:51,d:"Cette pierre, si elle est combinée avec les trois autres manquantes, devrait libérer une onde magique assez puissante pour activer et ouvrir une porte magique.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Pierre d\'Aqualikros l\'Impitoyable",t:51,d:"Cette pierre, si elle est combinée avec les trois autres manquantes, devrait libérer une onde magique assez puissante pour activer et ouvrir une porte magique.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Pierre de Terraburkal le Perfide",t:51,d:"Cette pierre, si elle est combinée avec les trois autres manquantes, devrait libérer une onde magique assez puissante pour activer et ouvrir une porte magique.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Pierre d\'Aerotrugobur le Malveillant",t:51,d:"Cette pierre, si elle est combinée avec les trois autres manquantes, devrait libérer une onde magique assez puissante pour activer et ouvrir une porte magique.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Rune de Bricoleur",t:88,d:"Cette pierre magique permet aux Bricoleurs de donner leur position aux clients.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Fragment Magique",t:88,d:"Ce fragment magique, contient une partie de la magie autrefois contenue dans un objet. Avec un peu de chance, vous devriez pouvoir récupérer quelques runes magiques.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Rune Vie",t:78,d:"Cette petite rune a le pouvoir de rendre plus résistant.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Etoffe de Péki",t:55,d:"Cette étoffe recouvrait les fesses poilues du Péki avant que vous ne décidiez de le caresser à rebrousse-poils.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Queue Magique du Péki",t:65,d:"Cette queue est si magique, qu\'elle frétille encore, même après avoir été coupée, séchée, et empaillée. En cherchant bien, vous pourrez lui trouver une utilité autre que décorative.",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Peau de Moon",t:59,d:"Privé de sa petite peau douce, le pauvre petit Moon s\'est retrouvé bien au dépourvu et à préféré fuir lâchement dans la jungle en hurlant de douleur. Une scène réjouissante que vous ne manquerez pas de raconter à vos enfants le soir, pour les aider à trouver le sommeil.",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Etoffe Magique de Moon",t:55,d:"Cette étoffe ressemble à une étoffe magique, et vous avez du mal à l\'accepter. Pourtant il faudra bien que vous reconnaissiez un jour ou l\'autre, que vous êtes trop stupide pour déterminer vous-même ce qui est magique ou non. Ne suivez pas votre instinct de pourfendeur d\'Astrubiens, faites confiance aux descriptions.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Peau de Shin Larve",t:59,d:"Cette peau de Shin Larve est encore plus gluante et collante que vous ne l\'imaginiez. Elle vous rappelle la dernière princesse que vous avez délivrée.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Dent de Shin Larve",t:47,d:"Personne n\'aurait pu croire qu\'une Shin Larve avait la bouche remplie de dents. C\'est peut-être parce que la Shin Larve ne dispose que d\'une seule dent.",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Plume Vibrante du Tofu Royal",t:53,d:"Plus royale que la plume du Tofu Royal, plus vibrante que la plume d\'un Kirboule Vibreur des mines de Kruup, cette plume saura chatouiller qui vous voudrez, et où vous voudrez. Il est expliqué sur la notice, que son entretien est relativement simple.",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Peau de Bworkette",t:59,d:"La Bworkette vous a laissé lui arracher un morceau de peau en échange de votre clémence. Mais elle a oublié de vous dire qu\'elle a prévenu son grand frère le Bworker, qui se fera un plaisir de vous arracher la votre.",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Poil de Bworkette",t:54,d:"La Bworkette a la peau lisse, sauf sous les aisselles. Il faut bien que les gâteaux qu\'elle roule sous ses aisselles soient assaisonnés de temps en temps.",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Peau de Cochon de Farle",t:59,d:"Farle était le plus grand éleveur de cochons et peut-être même de cochonnes, d\'après les éleveurs qui jalousaient Shika. Ce qui est certain, c\'est qu\'il est à l\'origine des Cochons de Farle, à qui il a donné son nom, car ils les avaient créés à son image.",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"Peau de Don Dorgan",t:59,d:"Le Don Dorgan a été une fois de plus très généreux avec vous, malgré son terrible caractère. Il vous a fait don de sa peau avant de partir en grognant comme un gros Porkass. Quel culot !",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"Peau de Don Duss Ang",t:59,d:"Le Don Duss Ang que vous avez dû peler avec une râpe à fromage pour obtenir cette peau très fine, s\'en souviendra toute sa vie. On peut supposer qu\'il vous en voudra longtemps. Ne comptez plus sur lui pour vous indiquer le bon chemin la prochaine fois que vous vous égarerez dans son labyrinthe.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Poil de Dragon Cochon",t:54,d:"Vous avez beau chercher, vous n\'arrivez pas à trouver la partie du corps du Dragon Cochon sur laquelle ce poil était planté. Cherchez-mieux, l\'anatomie du Dragon Cochon semble révéler de nombreuses surprises...",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Méga Pierre du Craqueleur Légendaire",t:51,d:"Cette énorme pierre ressemble à une pierre du Craqueleur Légendaire, et pourtant il n\'en n\'est rien, c\'est bien plus encore.",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Mojo du Mulou ",t:15,d:"Cette petite fiole contient toute la puissance virile du Mulou. Attention, son contenu n\'est pas comestible.",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Poil du Wa Wabbit",t:54,d:"Le Wa Wabbit est en règle générale assez avare et rechigne à partager ses poils. Exceptionnellement, pour récompenser votre bravoure (ou acheter votre clémence), il a décidé de vous faire don d\'une partie de son corps. Touchant.",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Etoffe du Wa Wabbit",t:55,d:"Personne ne sait réellement d\'où le Wa Wabbit a sorti cette étoffe, et il semblerait que personne ne cherche à savoir également. À la fois inquiétante et troublante, l\'origine de cette étoffe reste un des plus grands mystères de tout Amakna.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Poil de Maître Pandore",t:54,d:"Une fois de plus le Maître Pandore a voulu faire le malin, et s\'est pris une bonne leçon qu\'il n\'oubliera pas de si tôt. Il aurait mieux fait de rester au fond de sa boîte.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Etoffe de Maître Pandore",t:55,d:"Protégeant tantôt sa nuque, tantôt son arrière train, cette étoffe a sauvé la vie du Maître Pandore plus d\'une fois. Mais pas cette fois-ci.",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Peau de Maître Pandore",t:59,d:"Usée par les attaques magiques, desséchée par le vent de l\'île de Pandala, cette peau est désormais d\'une piètre qualité, et pourtant vous semblez vous y attacher, comme si vous cherchiez à garder un précieux souvenir de ce brave Maître Pandore, qui a tout de même failli vous ôter la vie plusieurs fois sans aucun remord. C\'est dans ce genre de situations que l\'on reconnaît un véritable monstre d\'une petite nature.",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Pierre du Koulosse",t:51,d:"Le Koulosse a beau être généreux, il ne vous a pas donné sa grosse pierre de gaieté de cœur, et on peut le comprendre lorsque l\'on sait ce que vous allez en faire.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
I.u[8403] = {n:"Tresse du Koulosse",t:15,d:"Cette énorme tresse a été confectionnée par le Koulosse en personne il y a plusieurs centaines d\'années. Elle est devenue avec le temps, presque aussi rigide qu\'un bloc de pierre. Elle est cependant encore gorgée d\'un liquide gluant et nauséabond qui attire de temps en temps les Moskitos. Le plus surprenant dans tout cela c\'est que cette tresse allait très bien au Koulosse. Comme un gros Ploukosse, vous avez eu l\'idée saugrenue de la lui voler.",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Peau de Skeunk",t:59,d:"Ce morceau de peau semble provenir des talons de Skeunk, ce qui explique sa couleur jaunâtre du plus bel effet. A défaut de vous confectionner des vêtements à la mode avec cette vieille peau, vous pourrez vous confectionner des vêtements d\'une autre époque, et adopter une apparence \"rétro\" qui fera fureur auprès des plus jeunes.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Poil de Skeunk ",t:54,d:"Qui à part vous, aurait pu croire que Skeunk ne s\'épilait pas entièrement le corps depuis sa tendre enfance ?",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Laine du Minotot",t:57,d:"Cette laine a la particularité d\'être très fine, et permet au Minotot de ne pas avoir de bouclettes le long du corps. Personne ne sait à quoi cela lui sert, vous devriez peut-être essayer de vous confectionner des implants pilaires avec cette laine, vous pourrez ainsi arborer une imposante toison de poils bruns sur votre torse. Même les rêves d\'enfance peuvent se réaliser.",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Cuir du Minotot",t:56,d:"A peine plus rare que le cuir de Bouftou, ce cuir est idéal pour les créations qui nécessitent des coutures souples, comme les masques en cuir par exemple.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Sabot du Minotot",t:47,d:"Ce sabot a foulé énormément d\'aventuriers, mais aussi de grosses bouses égarées dans le labyrinthe du Minotoror. À la décharge du Minotot, il faut reconnaître qu\'il n\'est parfois pas évident de faire la différence au premier coup d\'œil.",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
I.u[8409] = {n:"Corne du Minotot",t:47,d:"Cette corne ressemble de loin à une corne de Bouftou géante et extrêmement magique. Fait surprenant, de près, elle ressemble à une corne de Minotot.",ep:21,g:655,l:400,wd:true,fm:true,w:1,p:10};
I.u[8410] = {n:"Fémur du Minotot",t:47,d:"Cet os imposant a réussi à supporter pendant plusieurs siècles, la surcharge pondérale du Minotot. Un exploit qui méritait d\'être signalé.",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8411] = {n:"Amulette du Mominotor",t:1,d:"Cette amulette maudite recouverte de bandelettes vous permettra peut-être de survivre à la malédiction du labyrinthe du Minotoror. Mais rien n\'est moins sûr, peut-être n\'est-ce qu\'un bibelot destiné à épater les touristes.",ep:0,g:114,l:111,wd:false,fm:true,w:5,s:59,p:31300};
I.u[8412] = {n:"Anneau du Mominotor",t:9,d:"Cet anneau confectionné à partir de bandelettes de Mominotor enroulées sur elles-mêmes, sent plutôt mauvais,  et est assez laid, mais fera un très bon pansement lorsque vous vous coincerez un doigt dans une des portes du labyrinthe du Minotoror.",ep:0,g:119,l:111,wd:false,fm:true,w:10,s:59,p:31525};
I.u[8413] = {n:"Marteau du Mominotor",t:7,d:"Le bloc de pierre à l\'extrémité de ce marteau, est enroulé dans des bandelettes du Mominotor afin d\'absorber les fluides qui s\'échapperont des créatures que vous écraserez, ou tout simplement leur faire moins mal, et ne pas les tuer trop rapidement.",ep:0,g:60,l:112,wd:false,fm:true,w:10,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>100&CI>200&CW>150",s:59,p:100};
I.u[8414] = {n:"Dagues du Dragoeuf",t:5,d:"Ces dagues sont idéales pour découper le haut d\'un oeuf de Dragoeuf cuit à la coque. Elles sont aussi très légères, ce qui permet de courir vite lorsque le reste de la communauté des Dragoeufs s\'en aperçoit.",ep:20,g:58,l:128,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CS>150&CI>150&CA>100",p:39854};
I.u[8415] = {n:"Bottes du Mominotor",t:11,d:"Rembourrées et décorées avec des bandelettes de Mominotor, ces bottes sont à la fois très confortables et très chaudes. Elles vous rappellent peut-être quelqu\'un.",ep:0,g:92,l:110,wd:false,fm:true,w:10,s:59,p:31255};
I.u[8416] = {n:"Cape du Mominotor",t:17,d:"Confectionnée à partir de bandelettes du Mominotor tressées entre elles, cette cape vous donnera un style tout droit sorti d\'outre-tombe. Vos ennemis risquent de crever de jalousie.",ep:0,g:122,l:111,wd:false,fm:true,w:10,s:59,p:31780};
I.u[8417] = {n:"Pelle à Gâteau",t:8,d:"Cette petite pelle a été offerte a un jeune Enutrof, il y est resté si attaché qu\'il l\'utilisait encore juste avant sa mort.",ep:20,g:43,l:131,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CC>250&CA>100",p:42514};
I.u[8418] = {n:"Ceinture du Mominotor",t:10,d:"Cette grosse bandelette de Mominotor possède une valeur ajoutée extraordinaire, dont l\'origine reste cependant méconnue. Mais qu\'importe, elle se vendra cher, et sa malédiction accélèrera la putréfaction des hanches des amis à qui vous offrirez cette ceinture, ce qui est il faut bien l\'avouer, tout simplement inestimable.",ep:0,g:108,l:112,wd:false,fm:true,w:10,s:59,p:32255};
I.u[8419] = {n:"Pelle Moh",t:8,d:"Avec cette pelle, Le capitaine Machab a éventré Grobill Dick, le grand Kralamoure Blanc.",ep:20,g:42,l:115,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>200",p:33653};
I.u[8420] = {n:"Pelle Dragoeuf",t:8,d:"Les Dragoeufs aiment creuser des galeries, mais ne se servent pas de pelles, la communauté Enutrof a longtemps étudié l\'énigme de celle-ci, et a fini par conclure qu\'il était moins important de savoir d\'où elle venait que de taper avec.",ep:20,g:45,l:127,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,40,40,false,true],c:"CC>200&CS>100",p:42154};
I.u[8421] = {n:"Certificat de Mise en Chanil : Vilain Petit Corbac",t:77,d:"Ce certificat décrit les caractéristiques du Vilain Petit Corbac que vous avez placé au chanil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8424] = {n:"Cadeau de compensation de l\'éleveur",t:89,d:"Ce cadeau destiné aux éleveurs, contient de quoi remplir un enclos avec d\'excellentes machines d\'élevage. \n(Attention, les objets contenus dans ce cadeau sont très lourds, vous risquez d\'être en surcharge lorsque vous l\'ouvrirez).",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8425] = {n:"Bourse de 10000 Kamas",t:100,d:"Cette bourse est très lourde, elle contient sûrement une vraie fortune. Un marchand sera ravi de vous l\'échanger contre sa valeur en Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:100000};
I.u[8428] = {n:"Potion d\'invisibilité Nébuleuse",t:12,d:"Cette potion permet de s\'évaporer pour revenir au dernier point de sauvegarde sans laisser de trace.",ep:0,g:26,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,ut:true,p:1};
I.u[8430] = {n:"Ballon Jaune Magique",t:94,d:"Contrairement aux contrefaçons que l\'on trouve à la foire du Trool, ce ballon-ci sait au moins s\'envoler avec grâce et aisance. Confectionné à la main comme autrefois, en véritable plume de Tofu selon la traditionnelle recette du grand mage Vahy Nez.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8431] = {n:"Potion fumigène Cyclonique",t:12,d:"Cette potion fumigène crée un tourbillonnant écran de fumée qui camoufle vos actions avec style.",ep:0,g:29,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,p:1};
I.u[8435] = {n:"Ballon Rouge Magique",t:94,d:"Contrairement aux contrefaçons que l\'on trouve à la foire du Trool, ce ballon-ci sait au moins s\'envoler avec grâce et aisance. Confectionné à la main comme autrefois, en véritable paupière de Gelée Fraise selon la traditionnelle recette du grand mage Vahy Nez.",ep:1,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8436] = {n:"Clef du Donjon du Chêne Mou",t:84,d:"Cette clef vous permettra d\'accéder aux parties les plus intimes de l\'anatomie du Chêne Mou, sans pour autant comprendre où vous allez. À la fois perturbant et excitant, ce voyage vers l\'infini et l\'au-delà ne vous laissera pas indifférent.",ep:1,g:236,l:1,wd:true,fm:true,w:1,p:100};
I.u[8437] = {n:"Clef du Donjon Ensablé",t:84,d:"Cette clef confectionnée à partir de détritus marins et de coquillages vous permettra d\'accéder à la plage qui dispose du sable le plus fin de toute la côte de la Mer d\'Asse.",ep:1,g:237,l:1,wd:true,fm:true,w:1,p:100};
I.u[8438] = {n:"Clef du Donjon des Rats de Brâkmar",t:84,d:"Cette clef vous permettra d\'accéder au donjon des Rats situé dans les égouts de Brâkmar. Inutile de vous déguiser, vous passerez inaperçu, même si vous n\'êtes pas Brâkmarien.",ep:1,g:238,l:1,wd:true,fm:true,w:1,p:100};
I.u[8439] = {n:"Clef du Donjon des Rats de Bonta",t:84,d:"Cette clef vous permettra d\'accéder au donjon des Rats situé dans les égouts de Bonta. Inutile de vous déguiser, vous passerez inaperçu, même si vous n\'êtes pas Bontarien.",ep:1,g:239,l:1,wd:true,fm:true,w:1,p:100};
I.u[8441] = {n:"Billréole",t:16,d:"Bill voulait une auréole. Il cria si fort et fit si grand caprice qu\'on la lui accorda. Un vrai petit diable.",ep:22,g:159,l:100,wd:true,fm:true,w:1,p:25540};
I.u[8442] = {n:"Masque du Rat Noir",t:16,d:"Ce masque a servi à Brouce Boulgoure lorsqu\'il infiltra subtilement un repaire de rats d\'Egoûtants afin de couper un orme en commençant par les racines. Il finit tout de même par massacrer tous les rats du repaire, parce qu\'il n\'était en réalité pas très discret, avec ses gros sabots en bois.",ep:2,g:158,l:102,wd:true,fm:true,w:1,s:68,p:17222};
I.u[8443] = {n:"Cape du Rat Noir",t:17,d:"Cette cape peut être confectionnée avec n\'importe quels poils, à condition qu\'ils soient les plus sales possibles. Ils sont tressés entre eux puis fixés à l\'aide de sécrétions diverses. L\'odeur n\'est pas en option.",ep:13,g:123,l:105,wd:true,fm:true,w:5,s:68,p:18356};
I.u[8444] = {n:"Dagues du Rat Noir",t:5,d:"À la fois tranchantes et abîmées, les lames de ces dagues permettent de trancher les membres de vos adversaires avec une facilité déconcertante, tout en s\'assurant que vous leur retirerez une quantité impressionnante de lambeaux de chair. Dommage qu\'elles ne soient pas rouillées, chauffées à blanc et empoisonnées lorsque vous les utilisez.",ep:8,g:59,l:108,wd:true,fm:true,w:5,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CW>100&CV>300",s:68,p:19358};
I.u[8445] = {n:"Collier du Rat Noir",t:1,d:"Le rat qui possédait ce collier pensait devenir le chef de son clan. Il s\'est fait manger par un Lenald enragé.",ep:18,g:115,l:103,wd:true,fm:true,w:5,s:68,p:17650};
I.u[8446] = {n:"Bottes du Rat Noir",t:11,d:"Attention en enfilant ces bottes, il n\'est pas rare qu\'elles contiennent encore un ou deux pieds du propriétaire précédent.",ep:13,g:93,l:101,wd:true,fm:true,w:10,s:68,p:18700};
I.u[8447] = {n:"Ceinture du Rat Noir",t:10,d:"Contrairement à son cousin blanc bontarien, le Rat Noir aime faire dans la discrétion, et porte donc une simple ceinture d\'étoffe. Mais il aime aussi emporter un maximum d\'armes avec lui, qui font un bruit d\'enfer en s\'entrechoquant à chaque pas.",ep:13,g:109,l:101,wd:true,fm:true,w:5,s:68,p:18934};
I.u[8448] = {n:"Anneau du Rat Noir",t:9,d:"Tournez cet anneau vers la droite si vous devez serrer la main d\'un ennemi, et vers la gauche si vous devez serrer celle d\'un ami. Dans tous les cas, on vous déconseille d\'applaudir avec cet anneau.",ep:20,g:120,l:98,wd:true,fm:true,w:5,s:68,p:16980};
I.u[8449] = {n:"Transformation du Donjon Abraknyde",t:27,d:"Un Abraknyde vous a mordu et vous a transmis une étrange malédiction.",ep:9,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8450] = {n:"Epée du Rat Blanc",t:6,d:"Cette Arme est le symbole du Rat Blanc. Elle est réputée pour être capable de trancher ennemis et alliés avec la même facilité.",ep:16,g:71,l:109,wd:true,fm:true,w:10,an:14,tw:true,e:[5,5,1,1,40,50,false,false],c:"CA>150&CS>100",s:67,p:17542};
I.u[8451] = {n:"Coiffe du Rat Blanc",t:16,d:"Avec cette coiffe, le Rat Blanc ressemble à un vrai Rat Blanc de Bonta. Sans cette coiffe, il ressemble à un vrai Rat Blanc de Bonta sans coiffe.",ep:13,g:160,l:105,wd:true,fm:true,w:10,s:67,p:18451};
I.u[8452] = {n:"Cape du Rat Blanc",t:17,d:"Cette cape est le symbole identifiant un rat blanc du réseau d\'égoûts de Bonta, elle lui est remise après un examen long et difficile, et il la porte fièrement jusqu\'à sa mort, c\'est à dire jamais longtemps.",ep:14,g:124,l:102,wd:true,fm:true,w:5,s:67,p:17025};
I.u[8453] = {n:"Collier du Rat Blanc",t:1,d:"Si vous le portez comme un collier, il vous protègera des émanations toxiques provenant des égoûts. En revanche, si vous le portez comme une ceinture, ce sont vos alliés qui seront protégés de vos émanations toxiques.",ep:18,g:116,l:103,wd:true,fm:true,w:5,s:67,p:18900};
I.u[8454] = {n:"Gantelet du Rat Blanc",t:9,d:"Ce gantelet appartenait à Marie Thé, cuisinière du palais de Bonta. Elle s\'en servait pour assommer les Bouftous qui refusaient de se faire égorger, les plantes sauvages qui ne voulaient pas aller dans le saladier, et les clients qui ne voulaient pas les manger.",ep:18,g:121,l:101,wd:true,fm:true,w:5,s:67,p:17150};
I.u[8455] = {n:"Ceinture du Rat Blanc",t:10,d:"Contrairement à ce que pense son cousin noir brâkmarien, le rat blanc aime également faire dans la discrétion. Les raccords métalliques de cette ceinture sont doublés de goudron et ne font aucun bruit, sauf quand son porteur tombe lamentablement, c\'est à dire souvent puisqu\'elle pèse plusieurs tonnes.",ep:16,g:110,l:102,wd:true,fm:true,w:150,s:67,p:18850};
I.u[8456] = {n:"Bottes du Rat Blanc",t:11,d:"Avec ces bottes, votre équilibre est parfait, même par grand vent vous ne bougerez plus d\'un pouce.",ep:3,g:94,l:99,wd:true,fm:true,w:10,s:67,p:17650};
I.u[8457] = {n:"Coiffe Cérémoniale du Seigneur des Rats",t:16,d:"Cette coiffe n\'a rien à voir avec un Dora... Absolument rien on vous dit ! Il est donc inutile de répandre de fausses rumeurs à propos du manque d\'inspiration ou de la fainéantise de son concepteur . En revanche elle est très jolie.",ep:13,g:173,l:133,wd:true,fm:true,w:10,s:64,p:43300};
I.u[8458] = {n:"Cape Cérémoniale du Seigneur des Rats",t:17,d:"Cette cape colorée fait de vous une cible privilégiée. Seuls les aventuriers vifs et agiles ont su la porter longtemps.",ep:14,g:125,l:130,wd:true,fm:true,w:10,s:64,p:42030};
I.u[8459] = {n:"Collier Cérémonial du Seigneur des Rats",t:1,d:"Afin d\'éviter qu\'on le lui vole, ce collier est glissé autour du cou de l\'héritier du Seigneur des rats à sa naissance. Ainsi, à l\'âge adulte, le seul moyen de le lui enlever est de lui couper la tête. On le lui vole tout de même.",ep:18,g:117,l:134,wd:true,fm:true,w:5,s:64,p:45842};
I.u[8460] = {n:"Anneau Cérémonial du Seigneur des Rats",t:9,d:"Cet anneau a été conçu à une époque où le seigneur des rats s\'était mutilé et n\'avait plus qu\'un doigt. Les malheureux seigneurs suivants avaient encore tous les leurs.",ep:20,g:122,l:131,wd:true,fm:true,w:5,s:64,p:42542};
I.u[8461] = {n:"Ceinture Cérémoniale du Seigneur des Rats",t:10,d:"Les motifs sur cette ceinture donnent l\'impression que vous avez le feu au fondement. Le trompe l\'oeil est si bon que la plupart des porteurs y croient eux-mêmes et courent partout en hurlant. Ce qui correspond exactement au rituel de la cérémonie.",ep:16,g:111,l:133,wd:true,fm:true,w:10,s:64,p:43358};
I.u[8462] = {n:"Bottes Cérémoniales du Seigneur des Rats",t:11,d:"Le tout premier Seigneur des rats est mort en marchant par inadvertance dans une flaque de lave en fusion. Ces bottes sont portées en hommage par ses seigneurs. Attention, elles ne sont pas ignifugées.",ep:13,g:95,l:134,wd:true,fm:true,w:10,s:64,p:43541};
I.u[8463] = {n:"Abracaska Ancestral",t:16,d:"Cette Coiffe fut créée pour Jicé Aouaire car il a la tête plate, aucun soucis d\'équilibre pour l\'arborer donc. \nIl l\'a faite faire après avoir vaincu l\'Abraknyde Ancestral en brisant ses noisettes entre ses fesses, mais il s\'en vante moins.",ep:9,g:174,l:114,wd:true,fm:true,w:10,s:65,p:33150};
I.u[8464] = {n:"Abracapa Ancestrale",t:17,d:"En été, l\'Abraknyde Ancestral aime se dorer au soleil, mais son bois habitué aux forêts sombres le supporte mal. Cette cape est confectionnée avec les pelures de son écorce.",ep:18,g:126,l:114,wd:true,fm:true,w:5,s:65,p:33524};
I.u[8465] = {n:"Torque Ancestral",t:1,d:"Autour du cou, ce torque met en valeur votre barbe. Si vous n\'avez pas de barbe, vous ne pouvez vous en prendre qu\'à vous-même.",ep:20,g:118,l:110,wd:true,fm:true,w:10,s:65,p:31542};
I.u[8466] = {n:"Anneau Ancestral",t:9,d:"Les soirs où vous aurez trop bu, vous verrez peut-être le Moskito pris dans cet anneau vous faire un clin d\'oeil. Mais évitez d\'en parler à vos amis, il fait seulement semblant.",ep:9,g:123,l:113,wd:true,fm:true,w:5,s:65,p:33241};
I.u[8467] = {n:"Protège-Tibias Ancestraux",t:11,d:"Avec ces protège-tibias en bois massif, vos jambes ne craignent plus rien. Ils sont en revanche incompatibles avec le port de bottes . Vous pourrez les utiliser  pour vous protéger lors des compétitions de Boufball, mais vous ne pourrez plus faire de pointu avec vos bottes coquées.",ep:20,g:96,l:110,wd:false,fm:true,w:10,s:65,p:31524};
I.u[8468] = {n:"Abrature Ancestrale",t:10,d:"Cette ceinture est censée vous donner la virilité ancestrale. Que ce soit vrai ou pas, l\'effet est périmé.",ep:9,g:112,l:111,wd:true,fm:true,w:10,s:65,p:32101};
I.u[8469] = {n:"Talisman du Chêne Mou",t:1,d:"Cette pièce de bois prélevée au coeur du Chêne mou renferme un grand pouvoir, comme celui de mettre le Chêne Mou en colère.",ep:20,g:119,l:138,wd:true,fm:true,w:10,s:66,p:44521};
I.u[8470] = {n:"Anneau du Chêne Mou",t:9,d:"Cet anneau est un excrément du Chêne Mou, en bois, mais l\'odeur est la même.",ep:9,g:124,l:139,wd:true,fm:true,w:5,s:66,p:43014};
I.u[8471] = {n:"Tongues du dimanche du Chêne Mou",t:11,d:"Le dimanche, le Chêne Mou fait la sieste, et lorsqu\'il se réveille, il aime qu\'un Tronknyde obéissant lui apporte ses tongues sans qu\'il les demande. Il n\'a malheureusement pas de pieds, elles sont donc encore neuves.",ep:20,g:97,l:136,wd:true,fm:true,w:5,s:66,p:43521};
I.u[8472] = {n:"Cape Usée du Chêne Mou",t:17,d:"Il y a plus de 200 ans, une étoffe d\'un tissu anodin s\'est prise dans les branches du Chêne Mou. L\'arbre a poussé autour et au travers, l\'imprégnant ainsi de sa magie. Elle est désormais indissociable de ce gros morceau de bois ce qui la rend peu pratique et inflammable, mais sa puissance est indéniable.",ep:18,g:127,l:142,wd:true,fm:true,w:10,s:66,p:44578};
I.u[8473] = {n:"String Automnal du Chêne Mou",t:10,d:"En automne, le Chêne Mou porte son string pour protéger ses précieux glands. En été, il les trimballe à l\'air.",ep:9,g:113,l:141,wd:true,fm:true,w:10,s:66,p:44514};
I.u[8474] = {n:"Coiffe du Chêne Mou",t:16,d:"Vous pouvez porter cette coiffe dans n\'importe quel sens, on aura toujours l\'impression qu\'elle n\'est pas droite.",ep:9,g:166,l:145,wd:true,fm:true,w:10,s:66,p:45241};
I.u[8476] = {n:"Première clef du Donjon de Sphincter",t:24,d:"Cette clef ne vous suffira pas pour pénétrer dans le donjon de Sphincter, il vous faut l\'autre clef !",ep:1,g:502,l:1,wd:false,fm:true,w:0,p:100};
I.u[8477] = {n:"Deuxième clef du Donjon de Sphincter",t:24,d:"Cette clef ne vous suffira pas pour pénétrer dans le donjon de Sphincter, il vous faut l\'autre clef !",ep:1,g:503,l:1,wd:false,fm:true,w:0,p:100};
I.u[8478] = {n:"Potion de lèche-bottes",t:12,d:"Cette potion hautement illégale est redoutée par les plus grands. Une simple gorgée et la personne n\'a qu\'une obsession, lécher les bottes les plus proches. Certains disent que des variantes qui ciblent d\'autres endroits existent. Le malheureux buveur aura alors mauvaise haleine.",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:10};
I.u[8480] = {n:"Potion de lèche-bottes",t:24,d:"Cette potion hautement illégale est redoutée même des plus grand. En effet, une petite gorgée et le buveur n\'a plus qu\'une obsession : celle de lécher les bottes les plus proches. Des rumeurs parlent d\'une version alternative qui cible autre chose. Le seul indice quant à cet endroit est la mauvaise haleine des buveurs malchanceux.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:10};
I.u[8481] = {n:"Poil de Rat d\'Egoutant",t:54,d:"Ce poil est sale et malodorant, il a trainé dans les égoûts les plus insalubres de la région. Et pourtant il brille encore.",ep:2,g:670,l:42,wd:true,fm:true,w:1,p:10};
I.u[8482] = {n:"Peau de Rat d\'Egoutant",t:59,d:"Cette peau est recouverte de petites cicatrices qui témoignent de l\'enfance difficile qu\'a connue le Rat d\'Egoutant. Vous pourriez au moins avoir un peu de pitié pour lui !",ep:2,g:621,l:42,wd:true,fm:true,w:1,p:10};
I.u[8483] = {n:"Peau de Chaman d\'Egoutant",t:59,d:"Une fois lavée, cette peau pourra faire office de tapis de sol, ou de paillasson.",ep:2,g:622,l:40,wd:true,fm:true,w:1,p:10};
I.u[8484] = {n:"Poil de Chaman d\'Egoutant",t:54,d:"Utilisé autrefois pour les moustaches postiches, ce type de poil convient également parfaitement pour les poils d\'aisselle postiches.",ep:2,g:671,l:40,wd:true,fm:true,w:1,p:10};
I.u[8485] = {n:"Etoffe du Rat Noir",t:55,d:"Enroulée autour d\'une lamelle de bois tendre, cette étoffe pourra servir d\'éponge, ou même de gratte-fesses. Il en faut pour tous les goûts.",ep:2,g:725,l:100,wd:true,fm:true,w:1,p:10};
I.u[8486] = {n:"Etoffe du Rat Blanc",t:55,d:"Cette étoffe aussi grasse qu\'un poil de Wabbit trempé dans la graisse de Blop, protège efficacement du froid, surtout si vous y mettez le feu.",ep:2,g:726,l:100,wd:true,fm:true,w:1,p:10};
I.u[8487] = {n:"Etoffe de Sphincter Cell",t:55,d:"Cette Etoffe semble recouverte d\'un produit chimique étrange aux effets secondaires inconnus. Mieux vaut ne pas garder cette Etoffe trop longtemps entre les mains, un gros poil pourrait y pousser.",ep:2,g:727,l:200,wd:true,fm:true,w:10,p:100};
I.u[8488] = {n:"Cubitus du Rat Noir",t:47,d:"Cet os de rat peut être vidé, percé et taillé pour ensuite servir d\'instrument de musique, ou de sarbacane si vous n\'avez pas l\'oreille musicale.",ep:2,g:658,l:100,wd:true,fm:true,w:10,p:10};
I.u[8489] = {n:"Dent de Rat Blanc",t:47,d:"Cette dent est en réalité un horrible croc qui permettait au Rat Blanc de transmettre une multitude de maladies à ses victimes lorsqu\'il les mordait. Une façon comme une autre de s\'assurer de la mort de ses victimes, même s\'il ne parvenait pas à les achever. Tous les moyens sont bons lorsque l\'on veut se faire respecter.",ep:2,g:659,l:100,wd:true,fm:true,w:10,p:10};
I.u[8490] = {n:"Fémur de Sphincter Cell",t:47,d:"Sphincter n\'était pas du genre à plaisanter avec les os, il les brisait en deux, puis en trois, puis en quatre, et parfois même en cinq, lorsqu\'il fallait ragaillardir les foules endormies pas un combat lassant.",ep:2,g:657,l:200,wd:true,fm:true,w:10,p:10};
I.u[8491] = {n:"Peau du Rat Noir",t:59,d:"Le Rat Noir était réputé pour sa mauvaise haleine, mais aussi pour la peau rugueuse de son postérieur. Très pratique pour ne pas glisser sur la cuvette des toilettes. Malheureusement, le Rat Noir ne prenait jamais la peine d\'aller jusqu\'aux toilettes, puisqu\'il vivait directement dans les égouts.",ep:2,g:623,l:100,wd:true,fm:true,w:1,p:10};
I.u[8492] = {n:"Peau de Rat Blanc",t:59,d:"Le Rat Blanc prenait un malin plaisir à se morfondre au fond de ses égouts, et à attendre qu\'une personne bien attentionnée vienne le réconforter. Il profitait ensuite de la naïveté et de la crédulité de ses victimes, pour les dépecer vivantes, et les rôtir en les ayant au préalable fourrées avec des noix de cajou. Pauvres noix de cajou.",ep:2,g:624,l:100,wd:true,fm:true,w:1,p:10};
I.u[8493] = {n:"Peau de Sphincter Cell",t:59,d:"Qui aurait pu croire que vous seriez un jour capable de tenir entre vos mains, la peau du célèbre Sphincter ? Certainement pas Sphincter. Sa trop grande confiance en lui aura causé sa propre perte.",ep:2,g:625,l:200,wd:true,fm:true,w:10,p:100};
I.u[8494] = {n:"Ecorce d\'Abraknyde Ancestral",t:96,d:"Cette écorce s\'est détachée de l\'Abraknyde Ancestral, sans que vous n\'ayez eu besoin de la lui arracher avec les dents.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[8495] = {n:"Bourgeon de l\'Abraknyde Ancestral",t:108,d:"Ce bourgeon desséché a été jadis entièrement vidé de sa sève par une créature affamée. Si vous le plongez dans l\'eau, vous pourrez le voir reprendre sa forme initiale, gonfler, puis si vous attendez très longtemps, pourrir.",ep:9,g:755,l:200,wd:true,fm:true,w:1,p:10};
I.u[8496] = {n:"Racine d\'Abraknyde Ancestral",t:98,d:"Même arrachée à son propriétaire, cette racine peut vous fouetter les fesses ou vous tordre les chevilles. Sale bête !",ep:9,g:668,l:200,wd:true,fm:true,w:1,p:10};
I.u[8497] = {n:"La recette de la filtounga",t:24,d:"Ce livre renferme les secrets de la filtounga, le plat mythique imaginé par Mouss Bouff.",ep:16,g:95,l:1,wd:true,fm:true,w:0,u:true,p:10};
I.u[8498] = {n:"Viande de Kanigrou",t:63,d:"Cette viande est aussi tendre qu\'un cerveau de Boue.",ep:13,g:375,l:80,wd:true,fm:true,w:1,p:1};
I.u[8499] = {n:"Viande de Koalak",t:63,d:"La viande de Koalak est en règle générale assez ferme. Il suffit simplement de l\'attendrir en la frappant avec un tronc de Kaliptus. Comme pour les enfants indisciplinés.",ep:20,g:376,l:60,wd:true,fm:true,w:1,p:1};
I.u[8500] = {n:"Viande de Crocodaille",t:63,d:"Cette viande insipide peut être conservée dans la vase pendant plusieurs années, avant de pourrir et de commencer à avoir du goût.",ep:4,g:377,l:70,wd:true,fm:true,w:1,p:1};
I.u[8501] = {n:"Viande de Kanigrou Conservée",t:64,d:"Cette viande de Kanigrou peut maintenant être conservée plusieurs jours avant d\'être utilisée pour un plat.",ep:13,g:387,l:80,wd:true,fm:true,w:1,p:10};
I.u[8502] = {n:"Viande de Koalak Conservée",t:64,d:"Cette viande Koalak peut maintenant être conservée plusieurs jours avant d\'être utilisée pour un plat.",ep:20,g:388,l:120,wd:true,fm:true,w:1,p:10};
I.u[8503] = {n:"Viande de Crocodaille Conservée",t:64,d:"Cette viande de Crocodaille peut maintenant être conservée plusieurs jours avant d\'être utilisée pour un plat.",ep:4,g:389,l:70,wd:true,fm:true,w:1,p:10};
I.u[8504] = {n:"Entrecôte de Kanigrou",t:69,d:"A manger chaude ou froide, cette entrecôte saura rassasier les appétits les plus voraces.",ep:13,g:132,l:80,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8505] = {n:"Filet de Koalak",t:69,d:"Ce morceau de viande remplira même les estomacs sans fond.",ep:20,g:133,l:120,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8506] = {n:"Entrecôte de Crocodaille",t:69,d:"Cette part de viande imposante est de toute évidence, très difficile à digérer. Mais la gourmandise l\'emporte toujours sur la raison.",ep:4,g:134,l:70,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8507] = {n:"Plat de Filtounga",t:69,d:"La Filtounga est une plat unique. Grâce aux ingrédients qui le composent, il garde une saveur ... unique. Servir tiède.",ep:1,g:136,l:100,wd:true,fm:true,w:1,c:"Cv<100",u:true,ut:true,p:1};
I.u[8508] = {n:"Plat de Filtounga",t:24,d:"Ce plat est pour Paindep la sorcière.",ep:1,g:120,l:1,wd:true,fm:true,w:0,p:1};
I.u[8509] = {n:"La recette de la bière Bwork",t:25,d:"Le grand mage Bworknroll dévoile ici la recette sacrée de la bière Bwork. Il n\'épargne aucun secret de fabrication. Il va même jusqu\'à donner la meilleure manière de la déguster. Un régal pour les amateurs, un cauchemar pour ceux qui ont déjà bu de cette bière sans la connaître.",ep:1,g:130,l:10,wd:false,fm:true,w:5,u:true,p:500};
I.u[8511] = {n:"Arbalète de Surpuissance Ténébreuse de la Mort qui Tue",t:102,d:"....",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:10,tw:true,e:[20,7,4,12,50,30,true,true],p:1};
I.u[8513] = {n:"Scalpel de Bworknroll",t:5,d:"Pour récolter des « morceaux » de créature, rien ne vaut le scalpel de Bworknroll qui préserve la vitalité des membres arrachés. Il faut l\'utiliser au combat pour récupérer les parties désirées.",ep:1,g:60,l:40,wd:true,fm:true,w:10,an:13,e:[10,4,1,1,30,50,false,false],c:"Qa=166",p:100};
I.u[8514] = {n:"Cervelle de vampire",t:15,d:"Surchargée de globules frais en permanence, la cervelle d\'un vampire aspire vers lui toutes les globules rouges disponibles. C\'est ce qui donne  aux vampires un teint pâle. Chez les Iop, ce sont plutôt les pieds qui attirent leur sang, d\'où leur adresse à bondir au lieu de réfléchir...",ep:3,g:492,l:20,wd:true,fm:true,w:2,u:true,p:10};
I.u[8515] = {n:"Os de Trooll",t:47,d:"Lorsque l\'on constate la solidité et le poids d\'un os de Trooll, on comprend mieux pourquoi leurs claques font si mal lors d\'une partie de jeu Trooll.",ep:4,g:640,l:5,wd:true,fm:true,w:50,p:50};
I.u[8516] = {n:"Coeur de Bworkcelhaine",t:15,d:"Cette Bworkette sans coeur qui a jeté son fils Krazybwork dans une fosse a été maudite par Bworknroll à qui elle a refusé son amour. Enfermée dans une cave, elle se nourrit de son propre coeur chaque jour. Toutes les nuits, il repousse et bat à nouveau de mille feux.",ep:4,g:518,l:33,wd:true,fm:true,w:33,p:33};
I.u[8517] = {n:"Moumoule",t:15,d:"Cette belle Moumoule fraîche sert aux Bwork esseulés lors qu\'ils partent en rapines loin de leurs compagnes.",ep:3,g:756,l:1,wd:true,fm:true,w:3,p:21};
I.u[8518] = {n:"Moumoules frites",t:69,d:"Dans les profondeurs de la Mer d\'Asse, les Moumoules récoltent du varech qu\'elles roulent sous leurs aisselles. Une fois la matière formée en frites, elles se hissent sur la plage pour les faire dorer au soleil avant de les ingérer.",ep:3,g:135,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:30};
I.u[8519] = {n:"Gâtrool",t:69,d:"Cette galette rituelle fourrée aux krottes de Trool est une vieille recette bwork. Seul un Bwork qui a vaincu un Trool à mains nues a le droit d\'en manger. S\'il a survécu à ce combat, il est prêt à avaler n\'importe quoi !",ep:1,g:136,l:5,wd:true,fm:true,w:20,u:true,p:200};
I.u[8520] = {n:"Gratrooll",t:60,d:"Cette graisse épaisse et nutritive permet de cuire la plupart des aliments dans de vieilles marmites sans accrocher le plat. Certains adeptes Osamodas s\'en servent aussi pour glisser des Tofus dans des endroits que la morale Iop réprouve.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[8521] = {n:"La cape rouge",t:17,d:"La cape rouge est l\'artefact préféré des mégalomanes. Une fois posée sur leurs frêles épaules, ils ont l\'impression d\'incarner Superman ou un magicien surpuissant jusqu\'à ce qu\'ils croisent un Minotoror.",ep:1,g:128,l:9,wd:false,fm:true,w:1,p:200};
I.u[8522] = {n:"Lanceur d\'effet Magique",t:74,d:"Cet objet surprenant renferme un concentré de magie obscure plutôt instable. Personne ne peut prédire ce qu\'il renferme, mais il est déconseillé de trop attendre avant de l\'utiliser.",ep:1,g:31,l:1,wd:false,fm:true,w:0,ut:true,p:1};
I.u[8523] = {n:"La relique des Robill",t:24,d:"Cet objet familial suinte d\'un flux magique extrêmement puissant. Transmis de génération en génération entre les membres de cette famille, il n\'a rien perdu de son pouvoir. Il n\'existe que peu d\'artéfacts d\'où émane une telle force. Il a peut-être été en contact avec un Dofus...",ep:1,g:714,l:200,wd:true,fm:true,w:0,p:1};
I.u[8524] = {n:"Fantôme Walk",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:3,g:45,l:1,wd:true,fm:true,w:1,p:1};
I.u[8525] = {n:"Oeuf de piou",t:69,d:"Les œufs de pious sont un vrai régal pour les amateurs de friandises. Cependant, ils éclosent très vite lorsqu\'ils sont proches d\'une source de chaleur. C\'est pourquoi, il faut éviter de les laisser traîner dans sa poche ou dans sa bouche car au bout de quelques minutes un mini piou peut sortir de sa coquille. Avoir un piou affamé coincé entre vos dents ou se faufilant dans vos vêtements peut vous chatouiller le palais ou d\'autres parties plus intimes de votre anatomie.",ep:4,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[8526] = {n:"Certificat de Mise en Chanil : Koalak Sanguin",t:77,d:"Ce certificat décrit les caractéristiques du Koalak Sanguin que vous avez placé au chanil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8527] = {n:"Gobtroteur",t:11,d:"Ces bottes en peaux de gobelins ont été créées par Planbworksek afin de charger l\'ennemi (si possible dans le dos) avec une grande vélocité. En chaussant ces bottes, il a sauvé plus d\'un camarade Bwork dans la panade.",ep:4,g:98,l:14,wd:true,fm:true,w:20,p:400};
I.u[8528] = {n:"La recette des crêpes",t:25,d:"Grâce à Pol Bokuz, vous saurez enfin réussir votre pâte à crêpe pour nourrir vos petits enfants et les envoyer rapidement à la sieste. Le secret de cette recette nourrissante et soporifique : la poudre de perlinpainpain bien sûr !",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[8529] = {n:"Le marteau à Zaap",t:24,d:"Rien ne vaut un bon coup de marteau pour réparer un Zaap déréglé !",ep:1,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[8530] = {n:"Ruskauffe",t:16,d:"Cette coiffe tient chaud aux oreilles, et absorbe les effluves d\'alcool qui s\'échappent de votre haleine. Que demander de plus ?",ep:22,g:167,l:151,wd:true,fm:true,w:10,p:46280};
I.u[8531] = {n:"Lapinocoiffe",t:16,d:"Qui oserait porter une coiffe aussi ridicule ? Personne excepté vous.",ep:1,g:168,l:33,wd:true,fm:true,w:6,p:3000};
I.u[8532] = {n:"Cape du Lapino Blasé",t:17,d:"Avec cette cape sur les épaules, vous pourrez enfin montrer aux personnes à qui vous tournez le dos, que vous êtes blasé par leur stupidité.",ep:1,g:129,l:14,wd:true,fm:true,w:1,p:775};
I.u[8533] = {n:"Le Floude",t:16,d:"Le Floude n\'est pas réellement un chapeau mais un parasite se développant sur le crâne des personnes trop volubiles, excessivement bruyantes, ou simplement verbalement agressives. Son aspect repoussant fait fuir les gens, ce qui pousse son porteur à crier encore plus fort pour se faire entendre, sans succès évidement, puisqu\'il n\'a rien à dire de toute façon.",ep:1,g:169,l:1,wd:true,fm:true,w:1,s:69,p:100};
I.u[8534] = {n:"La Cape S\'loque",t:17,d:"Cette cape molletonnée absorbe tous les bruits environnants, obligeant son porteur à hurler en permanence.",ep:1,g:130,l:1,wd:true,fm:true,w:10,s:69,p:100};
I.u[8535] = {n:"Les Incrustes",t:11,d:"Ces Getas sont si légères qu\'elles poussent leur propriétaire à courir dans tous les sens et à sauter partout lorsqu\'un combat commence. Les aventuriers expérimentés détestent ces getas, qui permettent aux premiers venus de prendre part à un combat auquel ils n\'ont pas été invités.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8536] = {n:"La Spamette",t:10,d:"Cette ceinture se porte si serrée qu\'elle force presque son porteur à bégayer, trembloter et faire n\'importe quoi, tant que c\'est en boucle.",ep:1,g:114,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8537] = {n:"Le Plussain",t:9,d:"Ce petit anneau ne sert à rien, sinon à être très voyant, histoire de montrer aux gens que vous existez.",ep:1,g:125,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8538] = {n:"Le S\'Mesme",t:1,d:"Après plusieurs nuits de dur labeur pour réaliser cette amulette, le plus grand bijoutier d\'Astrub, connu pour avoir été élevé par les Bworks s\'exclama devant une foule ébahie : \"C 1 pur amu tro bi1\". Même l\'illustre historien Champo Gnon ne parvint pas à déchiffrer ce que le bijoutier avait voulu dire.",ep:1,g:120,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8539] = {n:"Hache de l\'apprenti bûcheron",t:19,d:"Même si vous ne savez pas très bien manier la hache, vous ne risquez guère de vous couper avec celle-ci tant la lame est émoussée. Mais bon, en tapant suffisamment fort, vous arriverez bien à couper quelques arbres.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:0};
I.u[8540] = {n:"Faux de l\'apprenti paysan",t:22,d:"Cette faux est de qualité médiocre mais on vous l\'a offerte, vous n\'avez donc pas à vous plaindre. De plus, elle fauche correctement le blé et on ne lui en demande pas plus.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[8541] = {n:"Canne de l\'apprenti pêcheur",t:20,d:"Cette canne à pêche a connu des jours meilleurs, le fil n\'est plus très solide et l\'hameçon incertain. Parfaite pour la pêche au goujon.",ep:1,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,1,100,100,false,false],p:1};
I.u[8542] = {n:"Gants de l\'apprenti alchimiste",t:20,d:"Des gants d\'une qualité indiscutable, presque pas de trou, l\'odeur de sueur de l\'ancien propriétaire est tout juste perceptible, des doigts trop courts,  un maintien incertain... C\'est indiscutable, ces gants sont pourris.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:1};
I.u[8543] = {n:"Limonade d\'Incarnam",t:79,d:"Cette limonade fabriquée par les dieux est un mélange d\'eau, de bulles, et d\'extraits d\'animaux. Elle revigore les jeunes âmes venant justes de s\'incarner dans Incarnam. Pour les autres, c\'est de l\'eau gazeuse tout juste bonne à s\'entraîner pour les concours de rots.",ep:1,g:4,l:1,wd:true,fm:true,w:1,c:"PL<16",u:true,ut:true,p:1};
I.u[8544] = {n:"Certificat de Mise en Chanil : Walk",t:77,d:"Ce certificat décrit les caractéristiques du Walk que vous avez placé au chanil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8545] = {n:"Clef du Donjon d\'Incarnam",t:84,d:"Cette clef permet d\'entrer dans le donjon d\'Incarnam, habité par le terrible Milimilou.",ep:1,g:19,l:1,wd:true,fm:true,w:1,p:10};
I.u[8546] = {n:"Peau de Milimilou",t:59,d:"De légères bouclettes font de cette peau une belle descente de lit. Il est certain que quelqu\'un sur Incarnam est prêt à troquer contre cette peau. Reste à trouver qui ...",ep:1,g:3,l:1,wd:true,fm:true,w:10,p:1};
I.u[8547] = {n:"Trinsfirmitik ik Nikiril",t:31,d:"Lik nisittik miditik sint mivisik pir lik sintik.",ep:1,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8548] = {n:"Twansfowmation en Tiwabbit",t:31,d:"Les cawottes maudites sont mauwaises pouw la santé.",ep:8,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8557] = {n:"Plume du Batofu",t:53,d:"Cette plume directement arrachée des aisselles du Batofu diffuse une odeur de Doubitchou ancestral mariné.",ep:3,g:120,l:20,wd:true,fm:true,w:1,p:10};
I.u[8558] = {n:"Chapeau du Lapino",t:16,d:"Si vous envisagez de dialoguer avec les Wabbits, c\'est peut-être la coiffe qu\'il vous faut. Si vous cherchez à séduire, posez cette coiffe sur la tête de vos rivaux.",ep:1,g:170,l:6,wd:true,fm:true,w:10,p:12000};
I.u[8559] = {n:"La HmmMmmMmmm",t:16,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:2,g:171,l:42,wd:true,fm:true,w:1,p:420};
I.u[8561] = {n:"Bébé Pandawa",t:18,d:"Cet adorable bébé Pandawa adorera vous suivre partout pour découvrir le monde de ses grands yeux ronds. Ce familier apprivoisé mange du riz, mais accepte également les noisettes.",ep:3,g:42,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8563] = {n:"Titi Gobelait",t:32,d:"Titi doit rencontrer son futur professeur de magie.",ep:1,g:18,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[8564] = {n:"Certificat de Mise en Chanil : Bébé Pandawa",t:77,d:"Ce certificat décrit les caractéristiques du Bébé Pandawa que vous avez placé au chanil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8565] = {n:"Fantôme Bébé Pandawa",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:3,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[8566] = {n:"Transformation Walk",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans le sanctuaire des familiers.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8567] = {n:"Transformation Fantôme Bébé Pandawa",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans le sanctuaire des familiers.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8568] = {n:"Cadeau Bébé Pandawa",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8569] = {n:"Doro le Blak",t:16,d:"Cette coiffe appartenait à une petite Xélorette, qui prenait un malin plaisir à dérégler l\'écoulement du temps. La légende raconte qu\'elle parvint à voler plusieurs jours aux habitants d\'Amakna. Elle ne s\'est soustraite à la colère de la population qu\'en distribuant de nombreuses friandises.",ep:22,g:172,l:129,wd:true,fm:true,w:10,p:42512};
I.u[8570] = {n:"Poil de Rat Bontarien",t:54,d:"Ce poil appartenait aux rats des égouts de Bonta, les seuls qui possèdent des touffes de poils assorties aux couleurs des murailles de leur cité.",ep:2,g:672,l:40,wd:true,fm:true,w:1,p:10};
I.u[8571] = {n:"Poil de Rat Brâkmarien",t:54,d:"Ce poil appartenait aux rats des égouts de Brâkmar, les seuls qui possèdent des touffes de poils assorties aux couleurs des murailles de leur cité.",ep:2,g:673,l:40,wd:true,fm:true,w:1,p:10};
I.u[8572] = {n:"Potion d\'oubli : \'Apprivoisement de monture\'",t:43,d:"Cette potion d\'oubli permet d\'oublier un niveau du sort \"Apprivoisement de monture\".",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8573] = {n:"Potion d\'oubli : \'Boomerang perfide\'",t:43,d:"Cette potion d\'oubli permet d\'oublier un niveau du sort \'Boomerang perfide\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8574] = {n:"Dofus vinaigrette",t:23,d:"Avec ou sans lardons, ce Dofus est toujours aussi bon.",ep:0,g:13,l:1,wd:false,fm:true,w:1,p:1};
I.u[8575] = {n:"Le Ramboton",t:4,d:"Un célèbre guerrier Féca qui vivait dans la jungle de Pandala disait souvent \"Pour gagner la guerre, il faut devenir la guerre\".",ep:1,g:71,l:200,wd:false,fm:true,w:20,an:12,tw:true,e:[7,3,1,2,42,42,false,true],c:"PN~xxramboplxx",p:100000};
I.u[8576] = {n:"Parchemin de recommandation d\'Yse Vewybad",t:24,d:"Ce parchemin vous a été remis par Yse Vewybad pour services rendus.",ep:2,g:26,l:20,wd:false,fm:true,w:0,p:1};
I.u[8588] = {n:"Insigne Roublard",t:24,d:"Cet insigne, donné par un roublard, sera peut-être la clef pour rentrer dans le repaire de ces derniers.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[8590] = {n:"Contrat entre Vil Smisse et Yse Vewybad",t:24,d:"Ce contrat prouve la félonie d\'Yse Vewybad. Il ne reste plus qu\'à le porter à qui de droit.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[8593] = {n:"Potion de transformation en Wa Wabbit",t:27,d:"Cette potion vous a été remise par Uba Tessé. Elle va vous transformer en Wabbit et devrait vous permettre de vous faire passer pour le prétendant d\'Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8594] = {n:"Potion de twansfowmation en Wa Wabbit",t:27,d:"Cette potion vous a été remise par Uba Tessé. Elle va vous transformer en Wabbit et devrait vous permettre de vous faire passer pour le prétendant d\'Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8595] = {n:"Oeuf de Tofu Obèse",t:24,d:"Cet oeuf renferme un tofu obèse, peut-être le futur vainqueur du pwince d\'Wa.",ep:1,g:122,l:1,wd:true,fm:false,w:0,p:1};
I.u[8596] = {n:"Griffe Pourpre",t:6,d:"Cette épée acérée a pris cette teinte pourpre si élégante après avoir éviscéré des milliers de Bworks. Alors qu\'avant, elle n\'était que violet foncé.",ep:22,g:72,l:145,wd:true,fm:true,w:15,an:14,tw:true,e:[8,6,1,1,45,100,false,false],c:"CS>350&CV>400",p:52000};
I.u[8597] = {n:"Potion de Gavage",t:24,d:"Cette potion va permettre à Vil Smisse d\'engraisser le tofu obèse que vous lui avez ramené.",ep:3,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[8598] = {n:"Dagues Ruyère",t:5,d:"Ces dagues sont perforées tout au long de la lame, afin d\'émettre un joli sifflement quand on les manie rapidement. Les trous sont également très efficaces pour entraîner les viscères de ses ennemis.",ep:22,g:61,l:67,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CA>100",p:10654};
I.u[8599] = {n:"Griffettes",t:5,d:"Ces dagues ont été forgées pour une écaflipette maniaque de la manucure. Elle trouvait que les lourdes épées s\'accordaient mal à ses jolies griffes vernies.",ep:22,g:62,l:69,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,30,false,true],c:"CA>100&CS>100",p:11254};
I.u[8600] = {n:"La flemme de monter les escaliers",t:30,d:"Vous avez attrapé un gros coup de fatigue à force de crier à tous vents, et vous ne vous sentez plus capable de grimper autant de marches avant au moins 6 minutes ...",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8603] = {n:"Livrée de valet du Prince Wabbit.",t:24,d:"Avec ça, le valet du prince Wabbit sera à la dernière mode.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8604] = {n:"Epée Doncule",t:6,d:"Cette épée brillante est idéale pour cueillir des fleurs, même si elles se défendent. Elle est même parfaite pour cueillir des arbres.",ep:22,g:73,l:100,wd:true,fm:true,w:10,an:14,e:[15,8,1,1,40,50,false,false],c:"CS>250&CI<1",p:25654};
I.u[8605] = {n:"Epée Zervatif",t:6,d:"Cette lame est lubrifiée afin de glisser plus facilement dans son fourreau. En revanche elle est impossible à nettoyer et doit être jetée après utilisation, surtout si elle est recouverte de sang. N\'oubliez pas qu\'elle sert avant tout à se protéger.",ep:22,g:74,l:73,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,40,50,false,true],c:"CS>80&CI>80&CA>80",p:14000};
I.u[8606] = {n:"Robe de la mariée",t:24,d:"La robe de la mariée est soigneusement emballée dans ce beau paquet. Il ne reste plus qu\'à l\'apporter à l\'intendant San Lavalss.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8607] = {n:"Le Bâton Cloutay",t:4,d:"C\'est un gros bâton, avec des clous plantés dedans. N\'y cherchez pas autre chose, c\'est la simplicité même, et pourtant, il est diablement efficace pour déchausser les dents de vos adversaires.",ep:22,g:72,l:107,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,50,false,true],c:"CA>150&CI>150",p:29856};
I.u[8608] = {n:"La Bastonneuze",t:4,d:"On raconte qu\'un disciple de Sadida du nom de Fraye a utilisé ce bâton pour défendre sa femme et son fils face à un troupeau de Bouftous enragés. Il est regrettable qu\'il ait confondu sa famille avec les monstres pendant l\'échauffourée.",ep:22,g:73,l:85,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,35,40,false,true],c:"CW>150&CV>200",p:20000};
I.u[8609] = {n:"Geish\'Arc",t:2,d:"Cet Arc est léger, fin, élégant, et sent bon la fleur de cerisier. Il est également meurtrier si l\'on s\'en sert pour autre chose que se pavaner.",ep:22,g:56,l:81,wd:true,fm:true,w:15,an:10,tw:true,e:[5,4,3,7,30,50,false,true],c:"CA>200",p:16900};
I.u[8610] = {n:"Le Kikoularc",t:2,d:"Si vous tenez cet arc bien haut et prononcez avec entrain le mot \"Pampulilu !\", vous aurez vraiment l\'air ridicule.",ep:22,g:57,l:79,wd:true,fm:true,w:10,an:10,tw:true,e:[7,5,4,7,30,50,false,true],c:"CI>150&CC>150",p:15320};
I.u[8611] = {n:"Bagdette Café",t:3,d:"Cette baguette appartient au célèbre Grinegau, qui fait du très bon café, mais qui ne vendra pas son échelle.",ep:22,g:61,l:72,wd:true,fm:true,w:15,an:11,e:[5,3,2,4,15,50,false,true],c:"CI>100&CC>100",p:16500};
I.u[8612] = {n:"La Bidjiz",t:3,d:"Avec la Bidjiz, vous resterez vivant, sûrement parce que vos adversaires se mettront à danser en voyant les multiples facettes de la boule qui orne cette baguette.",ep:22,g:62,l:79,wd:true,fm:true,w:10,an:11,tw:true,e:[10,4,2,5,40,50,false,true],c:"CA>150",p:18000};
I.u[8613] = {n:"Pelle Minstère",t:8,d:"Créée comme une œuvre d\'art de la forgemagie, cette pelle creuse très mal, sauf dans la tête de vos adversaires.",ep:22,g:46,l:70,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,30,50,false,false],c:"CC>100",p:13540};
I.u[8614] = {n:"Pelle Ripe",t:8,d:"Magnifique invention, cette pelle deux-en-un permet de creuser une tombe et de la laisser comme croix. À condition de ne perdre qu\'un compagnon à la fois, sous peine de creuser les tombes suivantes avec les mains.",ep:22,g:47,l:66,wd:true,fm:true,w:1,an:16,tw:true,e:[5,4,1,1,20,30,false,false],c:"CI>100&CC>50",p:1};
I.u[8615] = {n:"Marteau Mato",t:7,d:"Ce marteau réduit si facilement les crânes en bouillie qu\'il a pris une élégante teinte rouge tomate.",ep:22,g:61,l:83,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100&CV>100",p:17560};
I.u[8616] = {n:"Marteau Minokers",t:7,d:"Ce marteau a été créé à l\'époque du Roi Stéphane, qui a terrorisé des millions de gens.",ep:22,g:62,l:178,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,40,50,false,true],c:"CI>350&CW>180",p:10000};
I.u[8617] = {n:"Hache Ebbah",t:19,d:"Pour dire je t\'aime.",ep:22,g:45,l:62,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,20,30,false,false],c:"CV>150",p:10200};
I.u[8618] = {n:"Hache Eulouh",t:19,d:"Cette étrange hache est profilée de façon à décapiter plus facilement les Bworks. L\'aisance avec laquelle elle décapite aussi les habitants d\'Astrub indique clairement qu\'il existe un lien entre ces deux populations. Mais personne n\'a encore trouvé lequel.",ep:22,g:46,l:80,wd:true,fm:true,w:10,an:17,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>120&CA>60",p:16700};
I.u[8619] = {n:"Casque Keutumedi",t:16,d:"Grâce à cette coiffe guerrière, les Iops ont vraiment fière allure. Le seul problème est qu\'elle leur cache une partie de leur champ de vision et les empêche d\'entendre correctement les paroles de leurs adversaires. Le casque Keutumedi est vraiment fait pour les gens qui aiment frapper avant de réfléchir.",ep:22,g:175,l:40,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8621] = {n:"Cawotte Maudite",t:94,d:"Cette appétissante cawotte à l\'aiw owdinaiwe mais elle sent le maléfice à plein museau. Wésistewez-vous à la tentation de la cwoquew à pleines dents ?",ep:8,g:6,l:21,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[8624] = {n:"Ballon Bleu Magique",t:94,d:"Contrairement aux contrefaçons que l\'on trouve à la foire du Trool, ce ballon-ci sait au moins s\'envoler avec grâce et aisance. Il est confectionné à partir d\'une larve bleue, vidée encore remuante, puis gonflée par un Trool, selon la traditionnelle recette du grand mage Vahy Nez.",ep:1,g:7,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8625] = {n:"Ballon Vert Magique",t:94,d:"Ce ballon vert est le résultat assez étrange qui se produit lorsqu\'une larve verte mange un champignon Luidegît. Notez qu\'après ce repas les yeux de la larve sortent généralement de leur orbite et roulent au sol. Ils sont alors souvent ramassés par les bworks des environs, friands de ces mets pour leur apéritif. Ce ballon a inspiré ses célèbres recettes au grand mage Vahy Nez.",ep:1,g:8,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8626] = {n:"Nisitik Miditik",t:94,d:"Cittik ippitissintik nisitik ii ik\'ik irdinirik mis illik sik lik milificik ii plinik misik. Risistirik-vis ik lik tintitinik dik lik grinitik ii plinik dints ?",ep:6,g:9,l:21,wd:false,fm:true,w:1,u:true,ut:true,p:100};
I.u[8627] = {n:"Flûte de Sarr Ys",t:3,d:"Confrère et ami du célèbre Guy-guy (proche parent du Chêne Mou), Sarr Ys est un troubadour dont les notes enchanteresses ont gravées leurs empruntes dans la mémoire d\'Amakna. Malheureusement, ce brillant artiste est décédé tragiquement dans un accident de Koin Koin, lors d\'une beuverie estivale.",ep:1,g:63,l:1,wd:false,fm:true,w:10,an:11,e:[10,6,2,3,100,30,false,true],p:1};
I.u[8628] = {n:"Chapeau Leufère",t:16,d:"Cette coiffe procure assurance et témérité à celui qui la porte. Grâce à elle vous irez toujours de l\'avant, en pensant être capable de réaliser tous les exploits. Pensez toutefois à l\'enlever de temps en temps, sinon elle vous entraînera dans des situations inextricables !",ep:22,g:185,l:40,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8629] = {n:"Chapeau Grave",t:16,d:"À cause de cette coiffe, les adversaires deviennent souvent muets comme une tombe. On n\'ose demander à quoi est censé ressembler ce couvre-chef, on ne peut plus atypique. Mais ce n\'est pas très grave. Les Srams ne sont guère susceptibles.",ep:22,g:179,l:40,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8630] = {n:"Bonnet Nufar",t:16,d:"Cette coiffe ressemble beaucoup au Sulik et au Piruk. Mais comme elle est très confortable et que les Xélors ne la quittent jamais, même pour dormir, elle est communément nommée Bonnet Nufar. Elle dégage une agréable odeur de nymphéa qui contribue à l\'endormissement. En revanche, les ronflements qu\'elle provoque sont aussi insupportables que les chants de crapaud lors de la saison des amours.",ep:22,g:177,l:40,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8631] = {n:"Coiffe Fère",t:16,d:"Grâce à la Coiffe Fère, les Eniripsas savent toujours comment agir en cas d\'urgence. En effet, la liste des gestes de premiers secours y est discrètement inscrite dans la doublure. Ce couvre-chef leur donne un air doctoral, comme s\'ils venaient de recevoir leur diplôme, alors que personne n\'oserait arborer un chapeau aussi ridicule lors d\'une cérémonie scolaire !",ep:22,g:184,l:40,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8632] = {n:"Chapeau Tyron",t:16,d:"On aurait pu croire que cette coiffe possédait une jolie couleur orangée. C\'est pas du tout le cas. De plus, cet accessoire de mode tient plus du masque que du chapeau. Alors pourquoi ces créateurs l\'ont-ils nommé Chapeau Tyron ? Sûrement pour faire parler les bavards !",ep:22,g:178,l:40,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8633] = {n:"Bonnet Spairance",t:16,d:"Les pointes acérées qui sortent de ce bonnet permettent non seulement de blesser l\'adversaire mais aussi d\'avoir plus de chance de se prendre la foudre sur le crâne par temps d\'orage. Les Sacrieurs sont en effet une classe qui aime autant faire souffrir les autres qu\'eux-mêmes. Une bonne odeur de chair grillée : rien de tel pour commencer la journée !",ep:22,g:180,l:40,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8634] = {n:"Capuche Apin",t:16,d:"Grâce à cette coiffe, vous aurez vraiment l\'air d\'une bête à cornes. Nul doute que l\'on se retourne pour admirer la très grosse paire qui orne votre tête. Cette ample capuche permet aussi de conserver au frais des aliments comme le foin pour Bouftou ou le pain pour Tofu.",ep:22,g:181,l:40,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8635] = {n:"Chapeau Lithique",t:16,d:"Cette coiffe a la propriété de faire dire au porteur des promesses qu\'il oublie aussitôt. Est-ce parce qu\'elle exerce une pression sur les zones de la mémoire ou sur celle du langage ? Nul ne le sait précisément. L\'important est de ne prendre en compte que les paroles les moins extravagantes.",ep:22,g:176,l:40,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8636] = {n:"Coiffe de Robbie Capuche",t:16,d:"Robbie Capuche était un célèbre Crâ qui vivait dans les bois, d\'où la couleur verte de sa coiffe pour se fondre dans le paysage. Il se prenait pour un justicier et passait tout son temps à dérober l\'argent des riches au profit d\'une bonne cause : la sienne.",ep:22,g:186,l:40,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8637] = {n:"Bonnet Toual",t:16,d:"En revêtant cette coiffe, le Féca accroît sa chance et celle de ses alliés. Si votre groupe est guidé par un Féca portant un Bonnet Toual, vous êtes sûr d\'arriver à bon port et ce presque sans une égratignure. Mais l\'odeur est si nauséabonde que cela en fait l\'objet idéal pour se protéger de la veuve et de l\'orphelin.",ep:22,g:182,l:40,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8638] = {n:"Chapeau Taufeu",t:16,d:"Ce couvre-chef sert aussi bien de protection contre les intempéries que d\'accessoire de cuisine, pour mitonner des plats à la bonne température. L\'agitation du chapeau permet d\'apporter l\'afflux d\'air nécessaire à la bonne tenue du feu de cuisson. Et, comme tout le monde sait que le pot au feu est un plat qui se mijote pendant longtemps, on comprend mieux pourquoi les Enutrofs ont des poignets si musclés.",ep:22,g:183,l:40,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8639] = {n:"Cape Aurale",t:17,d:"La cape qui flotte au vent est indispensable pour vous procurer une aura de guerrier, surtout si vous tournez le dos à l\'adversaire. Certains pensent qu\'elle est renforcée par une plaque de métal qui permet de parer tous les coups sournois.",ep:22,g:131,l:80,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8640] = {n:"Cape Aillé",t:17,d:"Faite dans un tissu doux et résistant, cette cape donne aux Ecaflips l\'impression qu\'ils sont toujours des as, quoi qu\'il arrive. Lorsqu\'ils remportent la victoire, ils adorent se draper dans ce vêtement avant de réclamer leur récompense : « Et maintenant, t\'as qu\'à payer ! »",ep:22,g:133,l:80,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8641] = {n:"Cape Routh",t:17,d:"Cette cape est si légère et si fine qu\'elle s\'envole à la moindre brise de vent, de n\'importe quel vent. Pas toujours très pratique, surtout lorsque l\'on veut se faire discret, après un repas composé de légumineuses et de diverses boissons fermentées.",ep:22,g:140,l:80,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8642] = {n:"Cape Huchon",t:17,d:"La couleur sombre de cette cape lui permet d\'être en harmonie avec n\'importe quel vêtement, quel que soit son coloris. Comme elle est très ample, elle permet aussi de protéger la tête et le bout du nez.",ep:22,g:141,l:80,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8643] = {n:"Cape Sulhit",t:17,d:"La Cape Sulhit se met délicatement sur les épaules afin de protéger son porteur des tendinites et de l\'enraidissement des articulations. Vêtement aux vertus médicales, il est regardé avec envie par les Pandawas, qui passent beaucoup de temps à porter leur adversaire comme leur allié. Eux-aussi, ils aimeraient avoir un vêtement de ce type.",ep:22,g:134,l:80,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8644] = {n:"Cape Hitton",t:17,d:"Cet objet sert à cacher les surcharges pondérales des Sadidas. À force de dormir au lieu de faire de l\'exercice physique, les personnages de cette classe développent une tendance à l\'embonpoint. Si les Sadidettes possèdent des réserves anti-famine, avantageusement placées pour flatter les regards masculins, les Sadidas tentent plutôt de masquer les leurs grâce à cette cape.",ep:22,g:139,l:80,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8645] = {n:"Cape Ytale",t:17,d:"Ce vêtement joue un rôle primordial dans la prestance des Sacrieurs. Ils s\'en servent comme bandage pour panser les plaies, comme serpillière pour essuyer le sang, comme descente de lit pour ne pas avoir froid aux pieds. On ne dira jamais à quel point les personnages de cette classe redoutent les sols gelés !",ep:22,g:138,l:80,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8646] = {n:"Cape Lyne",t:17,d:"Cette douce cape est parfois employée par les Osamodettes coquettes en guise de couvre-chef aux larges bords. Les Osamodas mâles ne s\'en servent que comme pèlerine. Grâce au dessin qui orne cet habit, cette classe de personnages a hérité d\'une réputation de grande franchise. On ne les voit jamais rire sous cape car le rire est cousu dessus.",ep:22,g:137,l:80,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8647] = {n:"Cape Wéra",t:17,d:"Les Pandawas se servent de cette cape comme protection contre les intempéries et comme accessoire de danse. Ils la posent à terre, au centre d\'un cercle de danseurs éméchés. Puis, ils commencent leur chorégraphie improvisée sans que le pied touche le sol en dehors de la zone délimitée par ce vêtement.",ep:22,g:142,l:80,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8648] = {n:"Cape Hulco",t:17,d:"La cape Hulco tire son origine du nom d\'un Crâ atypique. Celui-ci possédait un sens de l\'orientation très particulier. Il était capable de se perdre chez lui. Et pourtant ce n\'était pas bien grand ! Son problème résidait dans une déformation des fonctions du cerveau : pour lui, tous les lieux ressemblent une vaste plage, entourée de cocotiers, baignée par la lumière chaude d\'un soleil couchant.",ep:22,g:132,l:80,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8649] = {n:"Cape Hadosse",t:17,d:"Les couleurs chaudes et réconfortantes de cette cape peuvent entraîner son porteur dans un voyage imaginaire, dans des contrées ensoleillées, pleines de canyons creusés par l\'érosion, et de décors rupestres taillées dans les roches et les falaises. C\'est extrêmement utile pour oublier le froid et la grisaille par temps de pluie.",ep:22,g:136,l:80,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8650] = {n:"Cape Haharnum",t:17,d:"Les Enutrofs ont pris l\'habitude de dessiner une carte sur leur cape, car ils vivent dans un tel foutoir qu\'il leur est difficile de retrouver le chemin des toilettes. Cela est très problématique, surtout lorsque l\'on est sujet à des envies aussi pressantes qu\'incontrôlables !",ep:22,g:135,l:80,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8651] = {n:"Sangle Hynère",t:10,d:"Cette magnifique sangle ajoute du prestige à la tenue des Iops. Certains prétendent que la croix centrale peut se transformer en une arme amovible, lorsque l\'épée n\'est pas à portée de main. C\'est bien sûr une légende, car seuls les Srams seraient assez fourbes pour ce genre de pratique.",ep:22,g:116,l:130,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8652] = {n:"Ceinture Buhlent",t:10,d:"Lorsqu\'un Ecaflip ne sait pas quoi faire, il dégaine son jeu de carte de sa ceinture et entame un solitaire. En combat, il se sert également de ses cartes en tant que projectiles. Il tire plus vite que son ombre et, après la victoire, il est toujours temps de faire une petite partie !",ep:22,g:117,l:130,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8653] = {n:"Sangle Glinglin",t:10,d:"L\'origine du nom de cette ceinture provient du bruit particulier qu\'elle produit. L\'entrechoc des os ornant la sangle empêche les Srams, même invisibles, de passer inaperçus. Aussi, on peut les entendre dire : « Surprendre quelqu\'un avec la Sangle Glinglin ? Tu peux toujours attendre ! ».",ep:22,g:118,l:130,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8654] = {n:"Ceinture Lupine",t:10,d:"Le tic-tac incessant du système d\'horlogerie de la Ceinture Lupine empêche les Xélors de s\'endormir lorsque les combats s\'éternisent. Il est donc vivement recommandé d\'enlever cette ceinture avant d\'aller se coucher.",ep:22,g:119,l:130,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8655] = {n:"Sangle Holon",t:10,d:"À défaut d\'enrayer les pleurs, la sangle Holon permet de transporter du matériel médical. Inutile de faire jouer les violons de l\'automne qui blessent les tympans d\'une langueur monotone. Les diverses potions utiles pour soigner les maux de gorge et autres affections ORL s\'y trouvent soigneusement rangées. En effet, un Eniripsa à la voix enrouée ne peut pas lancer correctement ses sorts. Lorsqu\'il est aphone, il est aussi utile qu\'une veste polaire en pleine canicule.",ep:22,g:120,l:130,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8656] = {n:"Ceinture Luthe",t:10,d:"Les raisons qui ont poussé les concepteurs de cet accessoire de mode à placer une tête de poupée près de l\'entrejambe restent mystérieuses. Bien des théories ont été avancées, mais chacun sait que tout ceci n\'est que du pipeau !",ep:22,g:121,l:130,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8657] = {n:"Sangle Hans",t:10,d:"Guerriers d\'une ancienne tribu réputée pour son goût du sang, les Hans seraient les premiers adorateurs de la déesse Sacrieur. Sous son apparence inoffensive, cette ceinture est en réalité un instrument de torture sophistiqué.",ep:22,g:122,l:130,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8658] = {n:"Ceinture Bodiézèle",t:10,d:"Les Osamodas ont la réputation d\'être un peu impulsif. Ils ont tendance à démarrer au quart de tour. Cette ceinture aux multiples boucles leur sert à refréner cette spontanéité : « Avant d\'allumer ta colère, et d\'avoir les yeux injectés de sang, touche toutes les cornes de ta Ceinture Bodiézèle ! »",ep:22,g:123,l:130,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8659] = {n:"Sangle Huée",t:10,d:"Cette ceinture aide les Pandawas à se tenir à peu près droit lorsqu\'ils sont saouls, ce qui leur arrive souvent. Dans ces moments-là, ils ont tendance à se sentir englués au sol, alors que la gravité n\'a aucun rapport avec cette sensation de pesanteur. Elle est bien trop occupée à assommer les scientifiques à coup de pommes.",ep:22,g:124,l:130,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8660] = {n:"Sangle Cible",t:10,d:"Ce ceinturon permet à la fois de retenir les vêtements tombants (pour ne pas effrayer les âmes sensibles) et d\'offrir une mire pour les jeunes Crâ en phase d\'apprentissage. En effet, on leur apprend à ne jamais tirer en dessous de la ceinture, mais juste au milieu.",ep:22,g:125,l:130,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8661] = {n:"Gaine Hage",t:10,d:"Prévoyants, les Fécas conservent des provisions de survie dans une petite sacoche. Celles-ci se composent essentiellement de pain en pierre de Craqueboule. C\'est pourquoi cette nourriture dure si longtemps. La Ceinture Deucékurité arrime fermement la sacoche à la taille, car le choc lié à la chute de ce sac de nourriture fait encore trop de blessés graves, par négligence ou inconscience.",ep:22,g:126,l:130,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8662] = {n:"Ceinture Gessant",t:10,d:"La Ceinture Gessant est un accessoire de mode très utile auprès les Enutrofs mâles. Grâce à la carte qui y est cousue, ils peuvent cacher certains accidents de parcours, lorsqu\'ils se sont perdus sur le chemin des toilettes.",ep:22,g:127,l:130,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8663] = {n:"Bottes Antrin",t:11,d:"Avec les bottes Antrin aux pieds, les Iops sont toujours les premiers à arriver sur le champ de bataille et à mettre de l\'ambiance. Il faut dire que cette classe de personnages adore amuser la galerie par ses exploits guerriers. Mais elle n\'est jamais prise au sérieux en raison de son intelligence inversement proportionnelle à sa force.",ep:22,g:100,l:100,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8664] = {n:"Charentaises à poils",t:11,d:"On dit que les Sadidas ne se sentent jamais seuls, car ils peuvent invoquer plein de poupées pour leur tenir compagnie. Vous aussi, vous ne souffrirez plus de solitude grâce à ces chaussures ! Non seulement vous pourrez prendre votre pied pour lui parler, mais en plus, grâce à ces charentaises à poils, personne ne pourra plus mettre votre jeu à nu. Une fois qu\'on les a enfilées, on se sent vraiment bien, même si on a un peu honte de sortir avec.",ep:22,g:105,l:100,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8665] = {n:"Bottes Hox",t:11,d:"Imprégnées d\'un produit repulpant à diffusion lente, ces bottes permettent d\'améliorer le galbe des jambes et de lutter contre le teint naturellement cadavérique des Srams. Cette crème a des effets spectaculaires sur la plastique des Srams femelles, mais semble totalement inefficace sur les mâles. Serait-ce un problème d\'hormone ?",ep:22,g:102,l:100,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8666] = {n:"Botte Hairo",t:11,d:"Créées par un artiste Xélor, ces bottes devaient lui permettre de peindre plus rapidement. C\'est le cas ! En revanche, elles ont tendance à déformer la vision et plus précisément le sens des distances. Avec ces bottes, tout paraît plus rond. Appréciés par les Sadidas, les tableaux de ce Xélor ont contribué à rendre populaires les courbes généreuses des femmes un peu fortes.",ep:22,g:103,l:100,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8667] = {n:"Botte Ulisme",t:11,d:"Grâce à ces mi-bottes, vous serez toujours protégés des toxines provenant du sol. On ne se méfie jamais assez des microbes et autres bestioles qui traînent. Selon certains observateurs, ces chaussures ressemblent plus à des pantoufles qu\'à des bottes. Pourtant, les Eniripsas les nomment bien ainsi. Est-ce à cause de leur petite taille qu\'ils voient les choses sous un angle si différent ?",ep:22,g:104,l:100,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8668] = {n:"Bottes Hanik",t:11,d:"L\'amour des plantes pousse les Sadidas à s\'équiper des seules chaussures à reconnaissance florale. Grâce à leur système de détection, elles permettent à son porteur d\'éviter d\'écraser les plantes rares. Par contre, elles ne vous empêchent pas de marcher sur des excréments divers et variés, si vous ne regardez pas où vous mettez les pieds.",ep:22,g:101,l:100,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8669] = {n:"Tong Aclou",t:11,d:"Contrairement aux autres classes, les Sacrieurs aiment vivre avec une épine dans le pied plutôt que de l\'enlever du talon. La douleur leur rappelle qu\'ils sont vivants et leur donne la rage de massacrer leur ennemi. De plus les traces de sang laissées en chemin permettent aux Sacrieurs de ne jamais se perdre. Ils sont toujours capables de retourner sur leur pas, ce qui n\'aurait pas été le cas s\'ils avaient des chaussures de mauvaises qualité.",ep:22,g:106,l:100,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8670] = {n:"Bottes Swana",t:11,d:"Ces chaussures permettent aux Osamodas d\'arpenter de longues distances à travers les continents, même les plus reculés. À part ça, on ne sait pas très bien à quoi elles peuvent servir. Certains estiment qu\'il est possible d\'en faire des nids à Tofus ou d\'élégants vases pour mettre en valeur les fleurs des champs. Tout cela n\'est guère convaincant. Bref, les Bottes Swana sont essentiellement des chaussures.",ep:22,g:107,l:100,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8671] = {n:"Relique du Corailleur Magistral",t:24,d:"Cette impressionnante relique vous permettra peut-être d\'oublier tous vos soucis.",ep:22,g:152,l:1,wd:true,fm:true,w:0,p:1};
I.u[8672] = {n:"Relique de Gourlo le Terrible",t:24,d:"Cette impressionnante relique vous permettra peut-être d\'oublier tous vos soucis.",ep:22,g:153,l:31,wd:true,fm:true,w:0,p:1};
I.u[8673] = {n:"Relique du Rasboul Majeur",t:24,d:"Cette impressionnante relique vous permettra peut-être d\'oublier tous vos soucis.",ep:22,g:154,l:61,wd:true,fm:true,w:0,p:1};
I.u[8674] = {n:"Relique du Tynril",t:24,d:"Cette impressionnante relique vous permettra peut-être d\'oublier tous vos soucis.",ep:22,g:155,l:101,wd:true,fm:true,w:0,p:1};
I.u[8675] = {n:"Relique du Kimbo",t:24,d:"Cette impressionnante relique vous permettra peut-être d\'oublier tous vos soucis.",ep:22,g:156,l:141,wd:true,fm:true,w:0,p:1};
I.u[8676] = {n:"Epée qui Pète",t:6,d:"Vlad était tombé amoureux de cette magnifique épée. Il a participé à la plus terrible des courses de Dragokart afin de pouvoir enfin l\'acheter. Malheureusement, il n\'avait pas compris que cette épée renfermait une terrible malédiction...",ep:1,g:75,l:95,wd:true,fm:true,w:1,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8677] = {n:"Ross",t:18,d:"Ce magnifique Lapino est le familier préféré du célèbre Maître Noir Jack. Ne vous fiez pas à son apparence, il peut se montrer redoutable en combat. Ce familier ne mange que des Cawottes et des plantes.",ep:3,g:44,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8678] = {n:"Chapeau de Satanusse",t:16,d:"Satanusse était jadis un patineur artistique traînant ses patins de Holiboul on Ice en patinoires de seconde zone. C\'est en tombant sur le coccyx qu\'il eut la vision qui allait changer sa vie : son destin était d\'être le conducteur de Dragokart le plus doué de sa génération ! Un petit choc provoque parfois un grand déclic.",ep:1,g:187,l:36,wd:true,fm:true,w:20,p:3550};
I.u[8679] = {n:"Fantôme Ross",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:3,g:46,l:1,wd:true,fm:true,w:1,p:1};
I.u[8680] = {n:"Ecaille poisseuse",t:59,d:"Cette écaille poisseuse et glissante permettait à son propriétaire de ne pas se faire attraper facilement par les aventuriers qui ont décidé de pêcher avec les dents. Malheureusement pour lui, elle ne le protégeait pas du tout contre un bon coup d\'épée rouillée.",ep:1,g:626,l:10,wd:true,fm:true,w:1,p:1};
I.u[8681] = {n:"Peau de Raul Mops",t:59,d:"La vraie faiblesse du Raul Mops, c\'est qu\'il aime se badigeonner d\'eau, de vin, ou même de vinaigre. Mais il aime avant tout se rouler dans des pots en verre autour d\'un oignon. Encore une créature aux moeurs mystérieuses.",ep:1,g:627,l:40,wd:true,fm:true,w:1,p:1};
I.u[8682] = {n:"Peau de Mob l\'Eponge",t:59,d:"Cette peau peut être utilisée des deux côtés, le premier est doux et permet de laver les surfaces fragiles, l\'autre côté est beaucoup plus rugueux, il permet par exemple de récurer les parties de son anatomie qui étaient restées inaccessibles.",ep:1,g:628,l:10,wd:true,fm:true,w:1,p:1};
I.u[8683] = {n:"Cadeau Walk",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8684] = {n:"Certificat de Mise en Chanil : Ross",t:77,d:"Ce certificat décrit les caractéristiques du familier Ross que vous avez placé au chanil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8685] = {n:"Certificat de Mise en Chanil : Bilby",t:77,d:"Ce certificat décrit les caractéristiques du familier Bilby que vous avez placé au chanil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8686] = {n:"Cadeau Ross",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8687] = {n:"Cadeau Bilby",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8688] = {n:"Transformation Fantôme Ross",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans le sanctuaire des familiers.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Marque de victoire.",t:24,d:"Vous avez vaincu le disciple aisément. Il vous a remis ce parchemin en attestant.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Formule de potion de transformation",t:24,d:"Ce recueil contient les théories de divers alchimistes sur la possibilité de se transformer en Wabbit. Comme quoi ils n\'ont vraiment rien à faire.",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Fëanor",t:18,d:"Grâce à ce familier, n\'importe quelle personne du sexe opposé vous fera les yeux doux. Un conseil : évitez de triompher. Bien vite, vous vous apercevrez qu\'en réalité, votre prétendant(e) est hypnotisé(e) par Fëanor. N\'espérez pas en profiter : désormais votre soupirant(e) mange du Pichon cru en se frottant contre vos jambes... Côté glamour, on a connu mieux, pas vrai ? Ce familier ne mange que du poisson.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Piment confit",t:42,d:"Ce piment confit est enrobé de bonbon rouge surpuissant fondu. Ce mélange explosif entre la confiserie et le piment a permis à la dragodinde Bruyère Blonde, de gagner une des plus célèbres courses de Dragokart. Vous pouvez l\'utiliser comme suppositoire si vous voulez avoir le feu aux fesses ou comme dragée si vous recherchez une haleine chargée.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"L\'Épée Nice",t:6,d:"Comme disait Brice : « Ce n\'est pas sa taille qui compte, mais la façon de s\'en servir. »",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
I.u[8699] = {n:"Coiffe du Tynril",t:16,d:"Avec cette coiffe sur le crâne, vous aurez toujours une tête en pétard, même si vous n\'êtes pas en colère. Il faut dire que les écorces de la chevelure du Tynril frisent lorsque le temps est humide, ce qui fait de cet animal l\'indicateur météorologique le plus sûr au monde. En revanche, il redoute le feu. Faites donc très attention aux flammes si vous ne voulez pas vous transformer en torche humaine.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Coquille Emeraude",t:16,d:"Cette coiffe semble avoir été fabriquée à partir d\'un Dofus Emeraude brisé. Le Dofus n\'est pas encore complètement vide, vous pourrez profiter de cette coiffe pour vous faire un shampooing aux oeufs.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Epée Choh",t:6,d:"Cette somptueuse épée appartenait à un illustre voleur, réputé pour se faire attraper à chaque fois qu\'il commettait un délit.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8704] = {n:"Le Nahitse",t:16,d:"Si vous agitez vos deux petits grelots rapidement, vous pourrez presque jouer de la musique.",ep:22,g:190,l:160,wd:true,fm:true,w:10,p:47625};
I.u[8706] = {n:"Fantôme Fëanor",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:3,g:48,l:1,wd:true,fm:true,w:1,p:1};
I.u[8707] = {n:"Certificat de Mise en Chanil : Fëanor",t:77,d:"Ce certificat décrit les caractéristiques du Fëanor que vous avez placé au chanil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8708] = {n:"Certificat de Mise en Chanil : Atouin",t:77,d:"Ce certificat décrit les caractéristiques d\'Atouin que vous avez placée au chanil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Transformation Fantôme Fëanor",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans le sanctuaire des familiers.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Cadeau Fëanor",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Bout de Goldemort",t:110,d:"Bravo ! Vous avez réussi à dépouiller le cadavre de Goldemort d\'une cuillerée de sa substance. Les vautours sont fiers de vous.",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Getas Bernacle",t:11,d:"Dans certaines contrées, il semble que les Getas Bernacle sont lancées en guise d\'insulte pour provoquer les duels. Même si cela peut prêter à sourire, ce n\'est finalement pas plus stupide que de frapper l\'adversaire avec une paire de gants. L\'avantage des Getas Bernacle est d\'ajouter une commotion olfactive au coup physique. Les Pandawas n\'ont jamais été réputés pour l\'hygiène de leurs pieds...",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Anneau Bhli",t:9,d:"Porter cet anneau est une marque honorifique. Cela signifie que vous êtes un digne fidèle de la déesse Crâ, la seule qui vous révèle comment bander plus vite afin de tirer efficacement.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Bague Houx",t:9,d:"La volubilité des Ecaflips est légendaire. Ils sont capables de vous sortir n\'importe quel baratin pour vous faire jouer. Cette bague célèbre cette loquacité sans faille. Accessoirement, elle peut servir de dé de rechange et elle est également très pratique pour se gratter... à peu près partout.",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Bague Héra",t:9,d:"Les Osamodettes adorent la bague Héra qui complète leur démarche féline d\'une touche de grâce. Il faut dire qu\'à force de côtoyer les monstres, elles finissent parfois par se comporter en vraies tigresses. Mais en réalité, elles sont aussi dévouées que des mères louves.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Bague Harre",t:9,d:"Les mauvaises langues prétendent que la bague Harre est l\'accessoire de mode le plus inutile au monde. Les ailes sur le côté sont fort embarrassantes quand vous voulez chercher des mouchoirs dans vos poches. Or, comme les Iops n\'ont ni mouchoir ni poche, tout va bien. De plus, elles permettent de déchiqueter un peu de chair à chaque fois qu\'elles frôlent l\'ennemi. C\'est à se demander si ce n\'est pas un bijou de Sacrieur.",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Anneau Tassion",t:9,d:"Les mini boucliers de l\'anneau Tassion servent de pense-bête aux Fécas qui peuvent y glisser des petits mots et des listes de choses à faire. Ce bijou est surnommé le bouclier anti-oubli. En revanche, il ne protège ni du bégaiement ni des lapsus.",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Anneau Stalgik",t:9,d:"Grâce à cet objet, les Enutrofs peuvent à tout moment se remémorer les instants heureux. Un doux parfum s\'en échappe. Il suffit pour cela de retirer la pelle qui y est fichée. Au préalable, il faut bien sûr y mettre l\'odeur que l\'on veut conserver en souvenir, et ce n\'est pas toujours facile.",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Anneau Zamour",t:9,d:"Cet objet a été donné par la déesse Eniripsa à ses fidèles en signe d\'alliance spirituelle lors de la séance d\'initiation aux sorts de la classe. Accessoirement, les Eniripsas peuvent aussi s\'en servir comme bracelet mousse pour éponger le sang des alliés.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Anneau Raille",t:9,d:"Ce bijou a tendance à rendre les Pandawas un peu moqueurs, surtout après la troisième bière. Ils peuvent même aller jusqu\'aux insultes. Mais ce n\'est pas très important car, comme le dit le célèbre proverbe Pandawa, « Ventre imbibé n\'a pas d\'oreille ».",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Anneau Hell",t:9,d:"Ce bijou à tête de mort était traditionnellement offert en cadeau, lors d\'une fête récompensant tous les enfants Sram pour leur fourberie et leurs coups bas. Les autres classes ont tendance à déconsidérer cette pratique, qui rend les gamins trop agités. Ils deviennent alors infernaux.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Anneau Tilus",t:9,d:"L\'anneau Tilus est le seul bijou qui donne l\'heure et qui est parfaitement résistant à l\'eau. Certains pensent qu\'en agrandissant les plans de cet objet et en les modifiant, on pourrait en faire un véhicule se déplaçant sous l\'eau. Où peuvent-ils aller chercher tout cela ?",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Anneau Pwal",t:9,d:"Contrairement à la rumeur, les Sadidas n\'ont pas de poils dans la main. Non ! Ceux-ci sont en fait ajustés autour d\'un superbe anneau, dont ils renforcent les effets bénéfiques : ils ne doivent en aucun cas être coupés. Grâce à l\'Anneau Pwal, vous serez toujours parfait !",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"Anneau Pitale",t:9,d:"Si vous voyez un personnage qui n\'est pas Sacrieur mettre un Anneau Pitale, emmenez-le d\'urgence en soins intensif. Ce bijou est en effet extrêmement blessant. En général, les gens perdent leur sang-froid devant le bain d\'hémoglobine provoqué par cet anneau.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Chaussures Lepon-Davignon",t:11,d:"Ces chaussures permettent à son porteur de danser jusqu\'au bout de la nuit, malgré les cors et les ampoules qu\'elles occasionnent ! Elles bougent toutes seules au bruit de la musique et font des « bip bip » lorsqu\'elles se trouvent à proximité de minerais précieux. C\'est pourquoi les Enutrofs sont souvent appelés les « beat-machines ».",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Bottes Antouche",t:11,d:"Lorsque les Fécas sont embarrassés et souhaitent détourner la discussion, ils évoquent toujours leurs bottes Antouche. Ils décrivent de quelle manière ces chaussures leur permettent d\'arpenter tous types de terrains. Lorsque leurs alliés sont en grosse difficulté lors de combats, le confort de ces bottes leur permet de se ressaisir pour détourner la menace.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Bottes Deuradi",t:11,d:"Les multiples sangles entourant ces chaussures peuvent servir de corde de remplacement, lorsque celle de l\'arc est rompue. Les jeunes femmes Crâ les emploient aussi pour faire des bottes de légumes en cuisine. Il faut croire qu\'elles n\'ont pas peur des odeurs de pieds.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Corail usé",t:51,d:"Se détachant du Corailleur par temps sec, le corail est bien joli à voir. Certains en font même des bijoux. D\'autres les mangent. Mais ils sont rares et ne le font que lorsqu\'ils le confondent avec des bâtons de crabes sourimis.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Coccyx du Corailleur",t:47,d:"Situé à un endroit stratégique, cet os permet au Corailleur de s\'installer dignement. Maintenant qu\'il est mort, vous pouvez toujours vous en servir pour asseoir votre autorité sur ses congénères.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Corail Magistral",t:51,d:"La seule différence entre le Corail usé et le Corail Magistral réside dans la taille et dans l\'usage que l\'on peut en faire. Mais, hélas, un amalgame de Coraux usés ne remplacera jamais un seul Corail Magistral.",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Corail Kouraçao",t:51,d:"La couleur remarquable de ce corail vient de l\'alimentation déréglée du Crustorail. Encore un qui a oublié de manger son quota de fruits et légumes !",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Corail Malibout",t:51,d:"La couleur remarquable de ce corail vient de l\'alimentation déréglée du Crustorail. Encore un qui a oublié de manger son quota de fruits et légumes !",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Corail Passaoh",t:51,d:"La couleur remarquable de ce corail vient de l\'alimentation déréglée du Crustorail. Encore un qui a oublié de manger son quota de fruits et légumes !",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Corail Morito",t:51,d:"La couleur remarquable de ce corail vient de l\'alimentation déréglée du Crustorail. Encore un qui a oublié de manger son quota de fruits et légumes !",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Coeur de pierre poli",t:51,d:"La seule chose qui distingue un cœur de Craqueleur de celui d\'un Craqueleur poli est la délicatesse avec laquelle l\'objet peut s\'écraser sur vos doigts de pieds quand vous vous y attendez le moins.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Boule polie",t:51,d:"De quelle partie de l\'anatomie du Craqueboule peut bien venir cette boule ? Et pourquoi est-ce qu\'on en retrouve souvent par paire ?",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Sacrum magistral",t:47,d:"Le Corailleur vous offrait un os de son postérieur. Le Corailleur Magistral vous permet de prendre possession d\'une autre partie de son anatomie, mais à peu près dans le même secteur.",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Humérus du Sparo",t:47,d:"Bien qu\'on le nomme Humérus, rien n\'indique que cet os vient vraiment du bras de Sparo. Comme tout son squelette a été broyé par les épées transperçant le tonneau, alors tout est un peu en miettes.",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Chicot du Flib",t:47,d:"À votre place, je ne ramasserai pas cet objet provenant d\'une bouche à l\'hygiène plus que douteuse. Mais bon, c\'est vous l\'aventurier !",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Bec du Kido",t:47,d:"Le bec du Kido est si peu solide que les disciples d\'Otomaï s\'en servaient pour faire des flèches d\'entraînement à la pointe émoussée pour ne pas faire de dégâts.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Pince de Crustorail",t:47,d:"Évitez de serrer la pince du Crustorail ! Vous risquez de perdre la main pour un simple geste de politesse.",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Pétale Kouraçao",t:35,d:"La couleur de ce pétale témoigne de sa provenance douteuse. L\'abus d\'alcool chez les disciples d\'Otomaï se perçoit même dans leurs créations.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Pétale Malibout",t:35,d:"La couleur de ce pétale témoigne de sa provenance douteuse. L\'abus d\'alcool chez les disciples d\'Otomaï se perçoit même dans leurs créations.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8747] = {n:"Pétale Passaoh",t:35,d:"La couleur de ce pétale témoigne de sa provenance douteuse. L\'abus d\'alcool chez les disciples d\'Otomaï se perçoit même dans leurs créations.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Pétale Morito",t:35,d:"La couleur de ce pétale témoigne de sa provenance douteuse. L\'abus d\'alcool chez les disciples d\'Otomaï se perçoit même dans leurs créations.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Bulbe Kouraçao",t:36,d:"Le Palmifleur ne naît pas d\'une graine mais d\'un bulbe que l\'on trempe dans l\'alcool. Pourquoi ? Parce que !",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Bulbe Malibout",t:36,d:"Le Palmifleur ne naît pas d\'une graine mais d\'un bulbe que l\'on trempe dans l\'alcool. Pourquoi ? Parce que !",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Bulbe Passaoh",t:36,d:"Le Palmifleur ne naît pas d\'une graine mais d\'un bulbe que l\'on trempe dans l\'alcool. Pourquoi ? Parce que !",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Bulbe Morito",t:36,d:"Le Palmifleur ne naît pas d\'une graine mais d\'un bulbe que l\'on trempe dans l\'alcool. Pourquoi ? Parce que !",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Crinière fleurie",t:36,d:"Hybridation improbable entre des poils et des pétales de fleurs, cette crinière est doublement allergène. Veillez à rester à distance si vous êtes sensibles à ces deux éléments sous peine d\'expulser votre cerveau en éternuant.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Barbe inexistante du Barbroussa",t:54,d:"Cette minuscule touffe de poils vous rappellera les vacances grâce à son odeur de sable, de produits solaires et d\'alcool. Dommage qu\'elle pue autant la poudre !",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Touffe rousse du Flib",t:54,d:"On n\'a jamais su si la couleur de cette touffe était naturelle ou si elle était liée à un feu de broussaille intempestif.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Duvet du Kilibriss",t:54,d:"En raison de sa légèreté, le duvet du Kilibris est très recherché pour la confection de matelas. C\'est pourquoi, en attendant la création d\'une espèce de matelas vivants que l\'on peut tuer lors de safari, les artisans chassent activement le Kilibris.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Maillot de corps de Barbroussa",t:15,d:"Besoin d\'un répulsif contre les insectes ? Adoptez le Maillot de corps de Barbroussa ! Mais renoncez aussi à toute tentative de fréquentation humaine !",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Morceau de caleçon de Gourlo",t:15,d:"Il n\'a jamais été possible de retrouver un caleçon de Gourlo intact. À force de jouer avec la poudre, il en vient toujours à y mettre le feu.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Coffret maudit du Flib",t:15,d:"Ce coffre a pris les formes de Flib, à moins que ce ne soit l\'inverse... Dans tous les cas, ça reste un coffre maudit.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Foulard du Sparo",t:15,d:"Accessoire de mode indispensable été comme hiver, ce foulard vous donnera un look original, mais un peu kitsch. Grâce à sa couleur éclatante, vous êtes sûr d\'exciter les bouftous mâles. Mais est-ce là votre intention ?",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Poudre explosive de Gourlo",t:48,d:"À défaut de se greffer un canon à la place du bras, Gourlo ne sort jamais sans son arme. Mais il n\'est pas capable de tirer son coup très vite, car il lui faut à chaque fois faire sécher sa poudre, signe de sa mauvaise qualité.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Fragment de cerveau poli",t:50,d:"Grâce à ce fragment de cerveau, vous allez enfin apprendre les bonnes manières à la façon des Craqueleurs : broyage de main en guise de bonjour.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Moustache du Mufafah",t:15,d:"Plus fournie que celle des poissons chatons, la moustache du Mufafah peut servir à faire des pinceaux pour le peintre Marylork.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Sourcil du Rasboul majeur",t:15,d:"Afin de prouver qu\'il est bien le Boss, le Rasboul majeur garde toujours les sourcils froncés. Même après la mort, ils le restent.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Bâton du Kilibriss",t:15,d:"Grâce à sa longueur, ce bâton va vous permettre d\'atteindre tous les endroits difficiles d\'accès et de vous gratter partout.",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Plume de fesse du Kido",t:53,d:"Cette ressource a servi à créer l\'une des plus grandes énigmes d\'Otomaï : qu\'est-ce qui est le plus lourd ? cent pods de plumes du Kido ou cent pods de Pyrute ?",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Aile du Bitouf des plaines",t:104,d:"Le Bitouf n\'a jamais été connu pour ses performances en vol. Vu les ailes qu\'il a, c\'est normal.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Oreille déchirée de Pumbaa",t:106,d:"En collant cette oreille à la vôtre, vous pourrez entendre le galop du sanglier des plaines à la place du bruit de la mer.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Coco du Bitouf des plaines",t:111,d:"Dans ce Coco du Bitouf, il n\'y a pas de lait, mais du jus de cerveau et parfois quelques neurones flottant en surface.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Ecorce du Tynril",t:96,d:"Cette écorce est curieusement recourbée, comme si on l\'avait obtenue par le biais d\'une râpe.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Ecorce de Floribonde",t:96,d:"Cette écorce est curieusement recourbée, comme si on l\'avait obtenue par le biais d\'une râpe.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Ecorce de Brouture",t:96,d:"Cette écorce est curieusement recourbée, comme si on l\'avait obtenue par le biais d\'une râpe.",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Ecorce de Nerbe",t:96,d:"Cette écorce est curieusement recourbée, comme si on l\'avait obtenue par le biais d\'une râpe.",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Ecorce de Fécorce",t:96,d:"Cette écorce est curieusement recourbée, comme si on l\'avait obtenue par le biais d\'une râpe.",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Ecorce de Chiendent",t:96,d:"Cette écorce est curieusement recourbée, comme si on l\'avait obtenue par le biais d\'une râpe.",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Coco du Bitouf sombre",t:111,d:"Dans ce Coco du Bitouf, il n\'y a pas de lait, mais du jus de cerveau et parfois quelques neurones flottant en surface.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Pistil du Tynril",t:36,d:"Les fleurs correspondent aux organes sexuels des plantes. Le pistil faisant partie de la fleur, à vous d\'en déduire ce que vous voulez.",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Etamine de Floribonde",t:36,d:"Une étamine est l\'organe mâle de la reproduction sexuée chez les végétaux. Eh oui, malgré les apparences, Floribonde serait de sexe masculin.",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Carpelle de Brouture",t:36,d:"Les fleurs correspondent aux organes sexuels des plantes. Le pistil faisant partie de la fleur, et la carpelle étant un élément du pistil, à vous d\'en déduire ce que vous voulez.",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Sépale de Nerbe",t:36,d:"Cette partie du corps de Nerbe reste toujours verte. Est-ce dû à l\'excès de chlorophylle ou à autre chose ?",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Calice de Fécorce",t:36,d:"Ce n\'est pas en utilisant le calice de Fécorce que vous arriverez à boire quoi que ce soit. Malgré sa forme en coupe, elle est percée.",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Bractée de Chiendent",t:36,d:"La Bractée de Chiendent correspond à une zone que la morale nous interdit de nommer.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Amygdales du Bitouf Sombre",t:15,d:"Une fois qu\'on lui a retiré les amygdales, le Bitouf sombre a moins les boules. C\'est normal, en général l\'opération conduit à sa mort.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Talon d\'achille de l\'Abrakleur sombre",t:15,d:"Ce n\'est pas en tirant une flèche dans son talon d\'Achille que vous vaincrez l\'Abrakleur sombre. Mais vous pouvez toujours essayer.",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Graine de l\'Abrakleur sombre",t:58,d:"Avec beaucoup de patience, de temps, d\'eau et d\'engrais, vous parviendrez à faire pousser un Abrakleur dans votre jardin pour le combattre en guise d\'entraînement. Mais il est plus simple d\'aller les décimer sur l\'île d\'Otomaï",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Tresse du Poolay",t:15,d:"Cette tignasse rêche et épaisse peut servir de serpillère à défaut de cacher la calvitie. Mais il faudra auparavant la laver à de nombreuses reprises",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Cloaque du Poolay",t:15,d:"Non ce n\'est pas répugnant, c\'est la nature !",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Croupion du Bitouf aérien",t:15,d:"Ce croupion vous permettra de créer des objets pour ne plus avoir le cul à l\'air.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Chaussette du Kimbo",t:15,d:"Malgré les apparences, Kimbo porte bien des chaussettes, mais pas aux pieds. Il préfère les rouler en boule et les placer à un endroit stratégique.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Rembourrage de Meupette",t:15,d:"La Nature ayant modestement pourvu la Meupette, celle-ci doit user d\'artifice pour paraître esthétique. Il arrive qu\'elle s\'en serve aussi pour améliorer le moelleux de son lit.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Etoffe de Meupette",t:55,d:"Cette étoffe a une texture bizarre mais elle habille en un rien de temps n\'importe quel monstre un peu pudique.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Coco du Bitouf aérien",t:111,d:"Dans ce Coco du Bitouf, il n\'y a pas de lait, mais du jus de cerveau et parfois quelques neurones flottant en surface.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Coquille du Kaskargo",t:111,d:"Ronde et luisante à la fois, cette coquille a été lustrée avec de la bave pendant plusieurs siècles. Chacun son truc.",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Perruque du Kimbo",t:54,d:"Pour masquer sa calvitie naissante, Kimbo met cette perruque ridicule. Heureusement que la noix de coco la cache en grande partie.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Noeud de l\'Abrakleur clair",t:38,d:"C\'est à cause de cette ressource que beaucoup de personnes surnomment l\'Abrakleur « tête de nœud ».",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Souche de l\'Abrakleur clair",t:38,d:"Une souche différente des autres souches. Et pourtant elle tourne !",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Queue emplumée du Rasboul Majeur",t:65,d:"Les plumes du Rasboul sont collées sur son appendice caudale, une à une, année après année. Plus la queue est touffue, plus le Rasboul est vieux.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Poil d\'aisselle de Pumbaa",t:54,d:"Même s\'il se les rase souvent, ses poils repoussent drus et gardent constamment une odeur rance. Comme quoi ce n\'est pas la sueur qui est en cause.",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Etoffe Zoth",t:55,d:"Faite dans une matière à la fois résistante et souple, cette étoffe s\'adapte parfaitement à la silhouette des Zoths pour en cacher l\'essentiel.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Etoffe de Ouassingue",t:55,d:"Cette étoffe comporte plus de trous qu\'un gruyère, mais elle est pourtant capable d\'absorber un maximum de déchets pour les régurgiter au moment le moins opportun.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Tibia du Guerrier Zoth",t:47,d:"Comme tous autres os du Guerrier Zoth, ce tibia a subi de multiples fractures. Il s\'est parfaitement ressoudé et il est devenu plus solide. Comme quoi, s\'il avait eu le don de la parole, lui aussi aurait pu dire : « Ce qui ne me tue pas, me rend plus fort ».",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Rotule du Disciple Zoth",t:47,d:"À force de donner des coups de genou, la rotule du Disciple Zoth est devenu très résistante et a pris du volume.  Bientôt, il sera possible d\'en faire des boules de pétanque.",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Braguette du Maître Zoth",t:15,d:"La braguette du Maître Zoth est remarquable, elle a été spécialement étudiée pour ne pas déchirer les chaires. Les aventuriers qui ont été un jour traumatisés par leur braguette comprendront.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Mouchoir de la Gamine Zoth",t:15,d:"La Gamine Zoth ne se sert pas de ce mouchoir pour faire des adieux larmoyants, mais pour essuyer le sang de ses ennemis.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Ecusson du Sergent Zoth",t:15,d:"Donné par sa mère et brodé sur une étoffe, cet écusson est un cuisant souvenir d\'enfance avant d\'être un insigne militaire.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Jus de Ouassingue",t:15,d:"À moins d\'être totalement saoul, impossible de confondre le jus de Ouassingue avec un quelconque liquide potable. L\'odeur nauséabonde dissuaderait même un aveugle d\'en prendre une gorgée.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
