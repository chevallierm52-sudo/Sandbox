I.u[7246] = {n:"Alliance Akwadala",t:9,d:"Cet alliance provient du village d\'Akwadala. Plus proche du porte-bonheur que de la relique magique, elle vous permettra tout de même de faire croire à vos amis que vous avez trouvé l\'âme soeur.",ep:1,g:80,l:37,wd:true,fm:true,w:2,s:34,p:3800};
