I.u[7254] = {n:"Bâton Akwadala",t:4,d:"Ce bâton servait à corriger les jeunes Pandawas un peu trop turbulents. Trois coups sur les doigts, quinze sur le derrière, soixante sur la tête, deux dans les yeux, et le tour était joué.",ep:18,g:61,l:43,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,false],c:"CC>50",s:34,p:5040};
I.u[7255] = {n:"Hache Terrdala",t:19,d:"Cette hache a été dès le début, pensée pour couper des êtres vivants. Attention, une seule erreur de manipulation de votre part, et vous pourriez vous retrouver diminué de moitié.",ep:18,g:32,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],s:36,p:17635};
I.u[7256] = {n:"Dagues Aerdala",t:5,d:"Aiguisées comme des griffes de Meulou, ces dagues feront de vous un excellent apprenti assassin.",ep:18,g:51,l:62,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>50",s:35,p:10105};
I.u[7257] = {n:"Sabre Feudala",t:6,d:"Ce sabre a été forgé par Hotari Honza en personne. Il parait que c\'est l\'une de ses dernières créations avant sa reconversation en cuisinier. Une véritable pièce de collection en tout cas.",ep:18,g:64,l:76,wd:true,fm:true,w:1,an:14,e:[5,6,1,1,50,50,false,false],c:"CI>200&CA>60",s:37,p:14900};
I.u[7258] = {n:"Poils de Pandikaze",t:54,d:"Ces poils très fins pourraient provenir de l\'arrière train d\'une Sadidette, mais ne vous y méprenez pas, il n\'en n\'est rien.",ep:16,g:556,l:40,wd:true,fm:true,w:1,p:10};
I.u[7259] = {n:"Etoffe de Pandikaze",t:55,d:"Cet amas de poils est presque intact malgré la punition que vous avez dû infliger au pauvre Pandikaze, pour la lui arracher.",ep:18,g:124,l:40,wd:true,fm:true,w:1,p:10};
I.u[7260] = {n:"Peau de Pandikaze",t:59,d:"Cette peau est encore recouverte d\'un léger duvet, aussi doux que le dessous des aisselles d\'une Eniripsa, mais sans l\'odeur de transpiration.",ep:18,g:40,l:40,wd:true,fm:true,w:2,p:10};
I.u[7261] = {n:"Bois de Bambou Magique",t:38,d:"Chose surprenante, ce morceau de Bambou est imprégné d\'une magie surprenante, à même de lui permettre de se déplacer. Une légende tribale raconte que toutes les nuits, il vient frapper aux portes des habitations dont les propriétaires auraient des activités libertines. Les Pandawas, prennent donc souvent la peine de l\'accrocher à une chaîne avant d\'aller se coucher, pour éviter les déconvenues.",ep:18,g:670,l:220,wd:true,fm:true,w:5,p:20};
I.u[7262] = {n:"Racine de Bulbiflore",t:98,d:"Cette racine de Bulbiflore n\'est pas comme les autres racines, elle peut être mâchée longuement sans vous faire perdre toutes vos dents. Attention, contrairement aux vraies sucreries, elle a très mauvais goût.",ep:18,g:142,l:26,wd:true,fm:true,w:2,p:20};
I.u[7263] = {n:"Racine de Bulbuisson",t:98,d:"Cette racine de Bulbuisson n\'est pas comme les autres racines, elle peut être mâchée longuement sans vous faire perdre toutes vos dents. Attention, contrairement aux vraies sucreries, elle a très mauvais goût.",ep:18,g:143,l:42,wd:true,fm:true,w:2,p:20};
I.u[7264] = {n:"Racine de Bulbambou",t:98,d:"Cette racine de Bulbambou n\'est pas comme les autres racines, elle peut être mâchée longuement sans vous faire perdre toutes vos dents. Attention, contrairement aux vraies sucreries, elle a très mauvais goût.",ep:18,g:145,l:67,wd:true,fm:true,w:2,p:20};
I.u[7265] = {n:"Racine de Bulbig",t:98,d:"Cette racine de Bulbig n\'est pas comme les autres racines, elle peut être mâchée longuement sans vous faire perdre toutes vos dents. Attention, contrairement aux vraies sucreries, elle a très mauvais goût.",ep:18,g:144,l:150,wd:true,fm:true,w:2,p:20};
I.u[7266] = {n:"Fleur de Bulbiflore",t:35,d:"Cette fleur ne pousse qu\'à un seul endroit, sur la tête du Bulbiflore, n\'essayez donc pas avec la vôtre, le substrat n\'est pas aussi riche.",ep:18,g:119,l:26,wd:true,fm:true,w:1,p:10};
I.u[7267] = {n:"Feuille de Bulbuisson",t:36,d:"Ces feuilles ne pousse qu\'à un seul endroit, sur la tête du Bulbuisson, n\'essayez donc pas de les faire pousser sur la vôtre, elles risqueraient de faner rapidement.",ep:18,g:55,l:42,wd:true,fm:true,w:2,p:10};
I.u[7268] = {n:"Pousses de Bulbambou",t:36,d:"Cette pousse ne vit qu\'à un seul endroit, sur la tête du Bulbambou, n\'essayez donc pas avec la vôtre, elle ne trouverait rien d\'intéressant à manger dessus.",ep:18,g:56,l:67,wd:true,fm:true,w:2,p:10};
I.u[7269] = {n:"Ecorce magique de Bulbig",t:96,d:"Cette écorce magique est aussi résistante qu\'un Bouclier du Captain Amakna, mais beaucoup moins belle tout de même.",ep:18,g:105,l:150,wd:true,fm:true,w:2,p:10};
I.u[7270] = {n:"Ecorce magique de Bulbiflore",t:96,d:"Cette écorce est si fine et fragile, qu\'elle pourrait servir dans la confection de dentelle ou de sous-vêtements coquins.",ep:18,g:106,l:26,wd:true,fm:true,w:2,p:10};
I.u[7271] = {n:"Ecorce magique de Bulbuisson",t:96,d:"Cette écorce rugueuse est parfaite pour la confection des semelles anti-dérapantes.",ep:18,g:107,l:42,wd:true,fm:true,w:2,p:10};
I.u[7272] = {n:"Ecorce magique de Bulbambou",t:96,d:"Cette écorce lisse est parfaite pour la confection des parquets ou des pistes de danse.",ep:18,g:108,l:67,wd:true,fm:true,w:2,p:10};
I.u[7273] = {n:"Peau de Cooleuvre",t:59,d:"Cette peau de Cooleuvre vous glissera entre les doigts comme aucune peau ne l\'avait fait auparavant. Évitez d\'en faire des chaussures, vous n\'arriveriez jamais à les retirer.",ep:18,g:41,l:67,wd:true,fm:true,w:2,p:10};
I.u[7274] = {n:"Dent magique de Cooleuvre",t:47,d:"Cette dent n\'est pas comme les autres, elle sent plus mauvais que les autres, comme si l\'horrible haleine de la Cooleuvre s\'y était incrustée.",ep:18,g:16,l:67,wd:true,fm:true,w:2,p:100};
I.u[7275] = {n:"Poils de Kitsou Nae",t:54,d:"Ces poils de Kitsou Nae sont doux comme la croupe d\'une femelle Trool. De quoi vous rappeler de bons souvenirs.",ep:16,g:560,l:29,wd:true,fm:true,w:1,p:10};
I.u[7276] = {n:"Poils de Kitsou Nufeu",t:54,d:"Ces poils de Kitsou Nufeu sont doux comme la croupe d\'une femelle Trool. De quoi vous rappeler de bons souvenirs.",ep:18,g:557,l:111,wd:true,fm:true,w:1,p:10};
