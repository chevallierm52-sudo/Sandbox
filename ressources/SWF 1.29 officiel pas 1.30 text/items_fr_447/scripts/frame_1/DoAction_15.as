I.u[6801] = {n:"Cape Hivernale",t:17,d:"Une jolie doublure très chaude et très odorante a été admirablement cousue sur une cape banale. \nSur votre dos, ou comme peau de bête devant la cheminée, cette cape aura enfin une vraie utilité.",ep:1,g:18,l:1,wd:true,fm:true,w:2,p:1};
I.u[6802] = {n:"Cache Oreilles",t:16,d:"Ce cache oreille très doux tiendra vos feuilles de choux au chaud.",ep:1,g:73,l:1,wd:true,fm:true,w:10,p:1};
I.u[6803] = {n:"Extrait de fleur de Dzibi",t:24,d:"Eviter d\'en boire... simplement !",ep:1,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[6804] = {n:"Amulette du Chef Bwork",t:1,d:"D\'apparence rudimentaire, cette amulette en forme de silex taillé est pourtant dotée d\'une magie très puissante capable de transformer un Bwork en princesse, ou l\'inverse, personne ne sait.",ep:1,g:66,l:100,wd:true,fm:true,w:1,s:19,p:25600};
I.u[6805] = {n:"Bracelet du Chef Bwork",t:9,d:"Muni de ce petit anneau, vous pourrez faire croire à votre entourage que vous avez épousé un grand Chef Bwork et qu\'il vous a offert ce bracelet comme cadeau de mariage. De quoi vous rendre intéressant lors des soirées animées à la Taverne si vous n\'avez pas beaucoup de conversation.",ep:1,g:58,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6806] = {n:"Fragment de bois",t:24,d:"Ce fragment de bois provient d\'une construction récente, vraisemblablement rouge.",ep:1,g:246,l:1,wd:false,fm:true,w:0,p:1};
I.u[6807] = {n:"Bottes du Chef Bwork",t:11,d:"De loin, ces bottes ressemblent à de classiques bottes de Bwork. De près aussi. Et pourtant, ce sont des bottes de Chef Bwork. Plus résistantes, plus puissantes, et plus malodorantes, elles sauront faire la différence dans un combat perdu d\'avance.",ep:1,g:44,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6808] = {n:"Morceau de tissu arraché",t:24,d:"Ce morceau de tissu blanc est à la fois très doux et très taché.",ep:1,g:247,l:1,wd:false,fm:true,w:0,p:1};
I.u[6809] = {n:"Description approximative",t:24,d:"Cette description décrit une petite fille habillée d\'une couleur foncée et les cheveux blonds.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6810] = {n:"Rapport d\'activité du quartier",t:24,d:"Ce rapport stipule qu\'aucun incident n\'a été constaté dans le quartier le jour du vol de la maison. \nHormis la vision d\'un roublard dans la nuit de l\'incident.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6811] = {n:"Cape du Chef Bwork",t:17,d:"Cette cape déchirée et pleine de trous vous fera passer pour un très grand guerrier Bwork. Elle est parfaite si vous voulez terroriser les vieux du village. En revanche, pour séduire l\'âme sœur, cela risque d\'être un peu plus difficile, à moins de la porter entièrement nu, ce qui vous permettra en plus, de continuer à faire peur aux vieux du village.",ep:1,g:60,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6812] = {n:"Slip du Chef Bwork",t:10,d:"Ce slip en cuir violet se suffit à lui-même, vous pouvez vous contenter de ne porter que ça, vous aurez tout de même fière allure, à condition qu\'il soit à votre taille et qu\'il ne vous tombe pas sur les genoux lors d\'une partie de corde à sauter un peu trop mouvementée.",ep:1,g:59,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6813] = {n:"Casque du Chef Bwork",t:16,d:"Si vous voulez réellement avoir une tête de gros débile, ce casque est fait pour vous. Avec un peu de chance, on ne verra même pas la différence lorsque vous l\'enlèverez.",ep:1,g:65,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6814] = {n:"Ensemble de bouts de bois",t:24,d:"Cet ensemble de bouts de bois forme un petit lit douillet, idéal pour un Piou.",ep:1,g:248,l:1,wd:false,fm:true,w:0,p:1};
I.u[6815] = {n:"Seringue de Nibé Lulle",t:24,d:"Nibé Lulle vous a donné cette seringue pour prélever un échantillon de sang de Radlu Minite le Mineur Sombre.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6816] = {n:"Echantillon de sang",t:24,d:"Vous avez enfin réussi à prélever un échantillon de sang sur Radlu Minite. Très appétissant.",ep:1,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[6817] = {n:"Amulette du Chef Crocodaille",t:1,d:"Cette surprenante amulette a en fait été confectionnée à partir d\'un Bouclier Reptilien dont on a détaché les multiples pierres précieuses. C\'est donc un bijou particulièrement lourd à porter mais vraiment très résistant. Votre cou sera parfaitement protégé des vampires, mais aussi des suçons des villageoises un peu trop entreprenantes.",ep:4,g:67,l:70,wd:true,fm:true,w:100,s:20,p:12700};
I.u[6818] = {n:"Rose démoniaque coupée",t:35,d:"Cette fleur, autrefois démoniaque, est à présent un cadeau angélique pour une personne. Cela dit, si vous n\'obtenez en retour qu\'un regard neutre, vous pourrez toujours en faire de la confiture.",ep:1,g:118,l:1,wd:false,fm:true,w:1,p:1};
I.u[6819] = {n:"Bracelet du Chef Crocodaille",t:9,d:"Ce bracelet ressemble étrangement à un gant et pourtant ce n\'est pas un gant mais bien un bracelet. Les apparences sont parfois trompeuses.",ep:4,g:59,l:70,wd:true,fm:true,w:20,s:20,p:12800};
I.u[6820] = {n:"Herbe curative",t:24,d:"Cette herbe est l\'ingrédient principal de vieux remèdes d\'alchimiste. Elle n\'est plus du tout utilisée de nos jours. On lui préfère le trèfle car ce dernier ne provoque pas de démangeaison faciale, ce qui, il faut l\'avouer, est un plus.",ep:1,g:103,l:1,wd:true,fm:true,w:0,p:1};
I.u[6821] = {n:"Lame du Chef Crocodaille",t:6,d:"Fabriquée à partir de débris trouvés sur un Chef Crocodaille, cette arme saura se révéler très efficace si vous êtes assez beau, habile, intelligent et fort pour la manier. Avec un peu de chance, vous finirez par trouver quelqu\'un qui acceptera de vous l\'échanger contre une épée de boisaille.",ep:4,g:49,l:70,wd:true,fm:true,w:100,an:14,e:[12,6,1,1,40,40,false,false],c:"CA>150&CC>150&CV>100",s:20,p:12800};
I.u[6822] = {n:"Piqûre de réveil",t:24,d:"Cette piqûre contient un remède si puissant qu\'il pourrait réveiller un mort. D\'ailleurs il parait que l\'illustre mort-vivant Hyrkul s\'en injectait régulièrement. On ne peut trouver meilleure preuve de son efficacité.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6823] = {n:"Potion à base de plantes",t:24,d:"Cette potion, à l\'odeur nauséabonde pourrait réveiller un sadida pendant sa sieste...Ou presque...Si le sadida est jeune et sur le point de se réveiller.",ep:1,g:500,l:1,wd:true,fm:true,w:0,p:1};
I.u[6824] = {n:"Pierre de Soin Fuyard",t:24,d:"Cette pierre de soin perd de son pouvoir très rapidement, il faut l\'entourer d\'un métal qui absorbe certaines radiations, afin de confiner l\'effet de la pierre et ainsi de préserver son efficacité. On lui préfère des amulettes standards presque aussi efficaces et surtout bien moins chères.",ep:1,g:104,l:1,wd:false,fm:true,w:0,p:1};
I.u[6825] = {n:"Pantoufles Crochues du Chef Crocodaille",t:11,d:"Ces magnifiques pantoufles en peau et en écailles de Chef Crocodaille sont munies de dents acérées à leurs extrémités. Méfiez-vous lorsque vous ferez du pied à votre dulcinée, vous pourriez lui déchirer ses petits bas en laine de Tabi.",ep:4,g:45,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6826] = {n:"Pierre de soin sertie",t:24,d:"Cette amulette est une pierre de soin fuyard joliement sertie par un morceau de métal rare. La tenir dans sa main procure une sensation de bien-être, la fatigue s\'en va et le cerveau est libéré. Et en plus on peut vous voir dans la nuit avec.",ep:1,g:105,l:1,wd:false,fm:true,w:0,p:1};
I.u[6827] = {n:"Lettre de Joe Pierlivet",t:24,d:"Joe t\'a confié cettre lettre afin que tu l\'amènes à un bon ami à lui, Howard le Simaisrien, un Iop euh ... comment dire ... un Iop quoi !",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6828] = {n:"Poignée d\'epée",t:24,d:"Cette poignée ne vous transformera pas en as du maniement d\'epée mais elle peut vous y aider.",ep:1,g:97,l:1,wd:false,fm:true,w:0,p:1};
I.u[6829] = {n:"Epée tout juste forgée",t:24,d:"Cette épée vient tout juste d\'être forgée.",ep:1,g:98,l:1,wd:false,fm:true,w:0,p:1};
I.u[6830] = {n:"Petit sac d\'écolier du Chef Crocodaille",t:81,d:"A Amakna aussi, la rentrée scolaire est une épreuve douloureuse pour les jeunes enfants. Surtout pour les jeunes Iops, pour qui la rentrée des classes est synonyme de véritable calvaire, parsemé d\'épreuves insurmontables. Réconfortez-les avec ce magnifique sac d\'écolier en peau et en écailles de Chef Crocodaille, et rembourré d\'une multitude de poils.",ep:14,g:58,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6831] = {n:"Ceinture du Chef Crocodaille",t:10,d:"Trop rigide pour servir de fouet, cette ceinture recouverte de minuscules pierres précieuses peut néanmoins être utilisée de manière plus conventionnelle, pour éviter que vos guêtres ne tombent sur vos genoux par exemple.",ep:4,g:60,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6832] = {n:"Livreur de Bière",t:32,d:"Le livreur de bière est aussi important qu\'un convoyeur de banque. A ceci près qu\'il est bien plus hargneux.",ep:1,g:15,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6833] = {n:"Bourse de Kamas douteuse",t:24,d:"Ces kamas semblent venir d\'un autre temps, il faudrait les fondre rapidement avant qu\'il ne décident de repartir d\'où ils sont venus.",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6834] = {n:"Coiffe du Chef Crocodaille",t:16,d:"Si vous avez toujours rêvé de ressembler à un Crocodaille sans pour autant vous transformer en Crocodaille, cette coiffe est faîte pour vous. N\'espérez pas pour autant utiliser cette coiffe pour faire croire à vos amis que vous avez un jour réussi à tuer vous-même un Crocodaille. Personne n\'y croira, à part vous peut-être.",ep:4,g:66,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6835] = {n:"Métal transmuté",t:24,d:"La bourse de kamas douteuse a été habilement transmutée par Nibé Lulle. Une épée est désormais prête à être créée avec ce métal ...",ep:1,g:241,l:1,wd:true,fm:true,w:0,p:1};
I.u[6836] = {n:"Epée grossière",t:24,d:"Voici une épée forgée des mains de Dedoiné, mais elle semble encore trop fragile pour vous. Nibé Lulle l\'Alchimiste devrait pouvoir y faire quelque chose",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6837] = {n:"Epée bondissante",t:24,d:"Une épée faîte pour vous, légère et redoutable. Mais il y manque une petite touche finale, quelque chose d\'Ecaflip ...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6838] = {n:"Epée de feu grossière",t:24,d:"L\'eau de lune semble avoir fait son effet. Cette épée est d\'une solidité à toute épreuve, mais il y manque quelque chose d\'Ecaflip ...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6839] = {n:"Epée de Yingnitié",t:6,d:"Cette arme estampillée par Meow Meow pourrait faire de vous un Ecaflip de légende, éventuellement ...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=0",p:1};
I.u[6840] = {n:"Epée de Yanguru",t:6,d:"Cet arme estampillée par Meow Meow pourrait faire de vous une Ecaflip de légende, éventuellement ...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=1",p:1};
I.u[6841] = {n:"Etoffe d\'Ours",t:55,d:"Cette étrange étoffe sent l\'Ours. De quoi faire craquer une partie non négligeable de la gente féminine.",ep:1,g:121,l:22,wd:true,fm:true,w:1,p:500};
I.u[6842] = {n:"Dent d\'Ours",t:47,d:"Cette étrange dent a appartenu à un vieil Ours. Ou plutôt, à une invocation d\'Ours, ce qui il faut bien le reconnaître, est totalement différent, puisque qu\'en réalité, vous avez entre vos mains, une dent invoquée. Très intéressant.",ep:1,g:432,l:22,wd:true,fm:true,w:1,p:500};
I.u[6843] = {n:"Os d\'Ours",t:47,d:"Cet os pointu s\'est cassé pendant un terrible combat contre un des Ours invoqués de l\'Homme Ours. Il était trop tard pour mettre un plâtre sur la patte de ce pauvre Ours agonisant et gémissant de douleur à cause de vos attaques répétées. Vous avez préféré l\'achever lentement en l\'étouffant avec de la bave de Bouftou, le dépecer et ensuite lui arracher cet os alors qu\'il était encore conscient. Pas de pitié pour les invocations.",ep:1,g:48,l:22,wd:true,fm:true,w:1,p:500};
I.u[6844] = {n:"Poils d\'Ours",t:54,d:"Parfois, l\'Homme Ours se décide à épiler une de ses invocations d\'Ours pour s\'amuser ou pour passer le temps. Il récupère ensuite les poils pour en faire des sous-vêtements de grande qualité, très prisés des chasseurs solitaires attirés par les sensations et les odeurs fortes.",ep:1,g:195,l:22,wd:true,fm:true,w:1,p:500};
I.u[6845] = {n:"Peau d\'Ours",t:59,d:"Cette peau rugueuse et dépourvue de poils est le fruit d\'un long travail d\'épilation intensive à l\'huile bouillante et au fer rouge. Ne vous étonnez donc pas si elle sent légèrement le roussi.",ep:1,g:35,l:22,wd:true,fm:true,w:1,p:500};
I.u[6846] = {n:"Fiole cristal de pâle Anthir",t:24,d:"Fiole banale au premier regard. Elle possède cependant un pouvoir que seul les Xelors savent exploiter.",ep:1,g:99,l:1,wd:false,fm:true,w:0,p:1};
I.u[6847] = {n:"Sac de grains d\'Epyss",t:24,d:"Grain assez rare, qui ne sert pas à grand chose. Qui à dit comme les Xélors ?",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6848] = {n:"Bois fiorituré",t:24,d:"Bois de moyenne facture.",ep:1,g:100,l:1,wd:false,fm:true,w:0,p:1};
I.u[6849] = {n:"Boîte de Suborhube",t:24,d:"Les seuls à connaître le mode d\'emploi sont les Enutrofs. Peut-être, simplement, parce qu\'on ne préfère pas savoir trop de choses sur leur secrets... Et quels secrets !!!",ep:1,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[6850] = {n:"Pizaille",t:24,d:"Une des spécialités culinaires d\'Astrub, la pizaille à l\'avantage de pouvoir être mangé n\'importe où et n\'importe quand, à l\'exception peut-être du quartier des bouchers car l\'odeur y est insupportable ...",ep:1,g:107,l:1,wd:false,fm:true,w:0,p:1};
I.u[6852] = {n:"Peluche de la foire",t:24,d:"La peluche que Pleur Nycheuz a gagnée à la foire du trool ...",ep:1,g:151,l:1,wd:true,fm:true,w:0,p:1};
I.u[6853] = {n:"Bois d\'Arash",t:24,d:"Ce bois a la particularité de pousser tout droit, comme un bâton. Pratique pour le stockage...",ep:1,g:100,l:1,wd:true,fm:true,w:0,p:1};
I.u[6854] = {n:"Peau de larve bleue",t:24,d:"Morceau de chair gluant arraché à une pauvre larve sans défense.",ep:1,g:101,l:1,wd:false,fm:true,w:0,p:1};
I.u[6855] = {n:"Petit arc d\'Enileda",t:24,d:"Fruit du travail de la célèbre tailleuse d\'arc Enileda, ce petit arc n\'est pas un modèle en soit.",ep:1,g:244,l:1,wd:true,fm:true,w:0,p:1};
I.u[6856] = {n:"Ciseaux à rose démoniaque",t:20,d:"La forme de ces ciseaux est spécialement étudiée pour couper la tige de n\'importe quelle rose démoniaque sans abîmer les pétales. Et ceci alors même qu\'elle vous mord le mollet.",ep:1,g:22,l:1,wd:true,fm:true,w:2,an:13,e:[5,3,1,1,20,20,false,false],p:1};
I.u[6857] = {n:"Bière d\'Astrub",t:37,d:"Une bière classique favorisant le développement de votre muscle abdominal, plus connu sous le nom de l\'Abdo kro.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:4};
I.u[6858] = {n:"Fiche remplie mais non valide",t:80,d:"Cette petite fiche possède, hélas, le nom d\'un candidat non valide pour être livreur du boulanger. La petite tâche rouge en bas indiquant qu\'il ne possédait soit pas assez de force, soit pas assez d\'agilité pour ce métier.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW<1500|CA<50",p:0};
I.u[6859] = {n:"Paire de ciseaux",t:24,d:"Une paire de ciseaux qui ne peigne pas de mine... elle aurait même plutôt tendance à couper qu\'à peigner, racontent certains coiffeurs...",ep:1,g:150,l:1,wd:true,fm:true,w:0,p:1};
I.u[6862] = {n:"Manuscrit de l\'Ours",t:24,d:"Cet étrange parchemin explique comment l\'Homme Ours a appris a invoquer des Ours. Incroyable.",ep:1,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[6863] = {n:"Casque des Mercenaires d\'Astrub",t:16,d:"Casque des Mercenaires d\'Astrub.",ep:1,g:72,l:1,wd:false,fm:true,w:10,p:1};
I.u[6864] = {n:"Fleur de rose Obscure",t:24,d:"Une fleur de rose si sombre que son ombre parait étincelante en comparaison.",ep:2,g:106,l:23,wd:true,fm:true,w:0,p:1};
I.u[6865] = {n:"Note",t:24,d:"\"Rendez-vous à l\'orée de la forêt pour la livraison\"",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6866] = {n:"Morceau de cape",t:24,d:"Un morceau de cape bleue de ceux qui vous ont agressé. Mine de rien vous les avez dérouillés.",ep:1,g:249,l:1,wd:false,fm:true,w:0,p:1};
I.u[6867] = {n:"Note de récolte",t:24,d:"Pour ne pas oublier l\'heure à laquelle vous devez récolter le Vhan, vous l\'avez noté sur ce papier.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6868] = {n:"Planche en Châtaignier",t:95,d:"Cette planche en Châtaignier est parfois utilisée pour construire des habitations, mais le plus souvent on l\'utilise pour faire des pièges à mouche...",ep:1,g:1,l:10,wd:true,fm:true,w:10,p:20};
I.u[6869] = {n:"Pleur Nycheuz",t:32,d:"Pleur Nycheuz ne sait plus où se trouve sa maison, il faut donc la raccompagner ...",ep:1,g:14,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6870] = {n:"Padgref Demoël",t:32,d:"Padgref Demoël est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison.",ep:13,g:8,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6871] = {n:"Frakacia Leukocytine",t:32,d:"Frakacia est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison",ep:1,g:11,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6872] = {n:"Nervoes Brakdoun",t:32,d:"Nervoes Brakdoun est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison",ep:1,g:10,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6873] = {n:"Qil Bil",t:32,d:"Qil Bil est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison",ep:14,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6874] = {n:"Brumen Tinctorias",t:32,d:"Brumen Tinctorias est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison",ep:14,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6875] = {n:"Fouduglen",t:32,d:"Fouduglen est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison",ep:1,g:12,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6876] = {n:"Ogivol Scarlarcin",t:32,d:"Ogivol est maintenant sous votre contrôle. À vous de l\'amener en sécurité à la prison",ep:16,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6884] = {n:"Clef du Donjon du Bworker",t:84,d:"Cette clef permet de rentrer dans le donjon du Bworker. Attention, elle sera détruite après utilisation.",ep:4,g:713,l:30,wd:true,fm:true,w:1,p:100};
I.u[6885] = {n:"Jeton du Bworker",t:15,d:"Idéal pour jouer à pile ou face ou pour tuer sur place votre ennemi lors d\'un lancer de pièce, ce jeton en or massif fera de vous un joueur heureux, mais peut-être malchanceux.",ep:13,g:90,l:100,wd:true,fm:true,w:1,p:100};
I.u[6886] = {n:"Cape des Mercenaires d\'Astrub",t:17,d:"Cape des Mercenaires d\'Astrub.",ep:1,g:59,l:1,wd:false,fm:true,w:10,p:1};
I.u[6887] = {n:"Pack Surprise Bwork",t:89,d:"L\'ouverture de ce pack requiert de la part de son possesseur, une grande sérinité, qui influencera directement la qualité de son contenu.",ep:1,g:42,l:1,wd:false,fm:true,w:4,u:true,p:100};
