I.u[7278] = {n:"Poils de Kitsou Nakwa",t:54,d:"Ces poils de Kitsou Nakwa sont doux comme la croupe d\'une femelle Trool. De quoi vous rappeler de bons souvenirs.",ep:1,g:559,l:60,wd:true,fm:true,w:1,p:10};
I.u[7279] = {n:"Peau de Kitsou Nae",t:59,d:"Cette peau de Kitsou Nae est d\'une qualité exceptionnelle, découpée en de multiples lanières, elle pourrait faire un excellent fouet. C\'est le cadeau idéal à offrir aux parents dont les enfants sont trop effrontés.",ep:18,g:46,l:19,wd:true,fm:true,w:2,p:10};
I.u[7280] = {n:"Peau de Kitsou Nufeu",t:59,d:"Cette peau de Kitsou Nufeu est d\'une qualité exceptionnelle, découpée en de multiples lanières, elle pourrait faire un excellent fouet. C\'est le cadeau idéal à offrir aux parents dont les enfants sont trop effrontés.",ep:18,g:44,l:111,wd:true,fm:true,w:2,p:10};
I.u[7281] = {n:"Peau de Kitsou Nere",t:59,d:"Cette peau de Kitsou Nere est d\'une qualité exceptionnelle, découpée en de multiples lanières, elle pourrait faire un excellent fouet. C\'est le cadeau idéal à offrir aux parents dont les enfants sont trop effrontés.",ep:18,g:45,l:80,wd:true,fm:true,w:2,p:10};
I.u[7282] = {n:"Peau de Kitsou Nakwa",t:59,d:"Cette peau de Kitsou Nakwa est d\'une qualité exceptionnelle, découpée en de multiples lanières, elle pourrait faire un excellent fouet. C\'est le cadeau idéal à offrir aux parents dont les enfants sont trop effrontés.",ep:1,g:43,l:60,wd:true,fm:true,w:2,p:10};
I.u[7283] = {n:"Peau de Tanukouï San",t:59,d:"Cette énorme peau distendue de Tanukouï San pourrait faire une excellente bourse pour ranger vos kamas.",ep:1,g:2,l:85,wd:true,fm:true,w:2,p:100};
I.u[7284] = {n:"Poils de Tanukouï San",t:54,d:"Ces poils de Tanukouï San ne sentent pas très bon, mais qu\'importe, ce sont tout de même des poils de Tanukouï San.",ep:1,g:3,l:85,wd:true,fm:true,w:2,p:100};
I.u[7285] = {n:"Patte d\'Araknawa",t:103,d:"Cette petite patte va continuer à frétiller encore longtemps. Glissez-là dans la culotte de vos ennemis, pour les déstabiliser en plein combat, vous gagnerez sans peine.",ep:18,g:716,l:43,wd:true,fm:true,w:2,p:100};
I.u[7286] = {n:"Bois de Bambouto",t:38,d:"Le bois de Bambouto vaut presque aussi cher que celui de Culbuto, et pourtant, il est beaucoup plus courant. C\'est à n\'y rien comprendre.",ep:18,g:675,l:47,wd:true,fm:true,w:2,p:100};
I.u[7287] = {n:"Feuille de Bambouto",t:36,d:"Les feuilles de Bambouto sont larges et épaisses, un peu comme les femelles Bwork, l\'agressivité en moins.",ep:18,g:69,l:47,wd:true,fm:true,w:2,p:1};
I.u[7288] = {n:"Feuille de Bambouto Sacré",t:36,d:"Cette grosse feuille est si dure et lourde, qu\'elle pourrait vous écraser vivant si vous vous endormiez sous un Bambouto Sacré en automne.",ep:18,g:68,l:120,wd:true,fm:true,w:2,p:100};
I.u[7289] = {n:"Bois de Bambouto Sacré",t:38,d:"Ce bois-là n\'est pas à mettre entre toutes les mains, mais personne ne sait encore pourquoi.",ep:18,g:674,l:120,wd:true,fm:true,w:10,p:100};
I.u[7290] = {n:"Racine Magique de Bambouto",t:98,d:"Cette racine permet au Bambouto de puiser toute sa magie dans le sol avant un combat.",ep:18,g:100,l:20,wd:true,fm:true,w:2,p:10};
I.u[7291] = {n:"Racine Magique de Bambouto Sacré",t:98,d:"Cette racine permet au Bambouto Sacré de puiser toute sa magie dans le sol avant un combat.",ep:18,g:99,l:87,wd:true,fm:true,w:2,p:100};
I.u[7292] = {n:"Poils de Maho Firefoux",t:54,d:"Ces poils proviennent d\'un Maho Firefoux, une terrible créature à l\'apparence chétive, mais qui possède en réalité de terribles pouvoirs magiques.",ep:18,g:202,l:150,wd:true,fm:true,w:2,p:1};
I.u[7293] = {n:"Poils de Soryo Firefoux",t:54,d:"Ces poils proviennent d\'une petite créature rousse bien malicieuse, comme tant d\'autres.",ep:18,g:203,l:130,wd:true,fm:true,w:10,p:1};
I.u[7294] = {n:"Poils de Yokai Firefoux",t:54,d:"Ces poils épais et malodorants ont été arrachés avec force et détermination du derrière d\'une horrible créature rousse.",ep:18,g:204,l:110,wd:true,fm:true,w:10,p:10};
I.u[7295] = {n:"Poils de Pandore",t:54,d:"Ces poils mystérieux permettent en général de tisser des capes ou des chapeaux magiques aux effets inattendus.",ep:18,g:2,l:200,wd:true,fm:true,w:10,p:200};
I.u[7297] = {n:"Poils de Pandule",t:54,d:"Ces poils magiques sont assez puissants pour redonner vie à une horloge cassée.",ep:18,g:206,l:150,wd:true,fm:true,w:1,p:1};
I.u[7298] = {n:"Peau de Maho Firefoux",t:59,d:"Cette peau lisse et fine offre une excellente protection face aux diverses attaques magiques que le Maho Firefoux rencontre lorsque ses sorts se retournent contre lui.",ep:18,g:42,l:150,wd:true,fm:true,w:1,p:100};
I.u[7299] = {n:"Peau de Soryo Firefoux",t:59,d:"Cette peau était autrefois utilisée pour coudre les slips des enfants à la peau sensible. Les slips en peau de Soyo Firefoux sont approuvés par la descendance du Captain Chafer.",ep:18,g:38,l:130,wd:true,fm:true,w:1,p:100};
I.u[7300] = {n:"Peau de Yokai Firefoux",t:59,d:"Cette peau épaisse offre une excellente protection face aux coups de Bambou.",ep:18,g:37,l:110,wd:true,fm:true,w:1,p:100};
