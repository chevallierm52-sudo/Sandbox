I.u[9808] = {n:"Cadeau Shushu de Rushu",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, et des poudres d\'Eniripsa pour le soigner.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
