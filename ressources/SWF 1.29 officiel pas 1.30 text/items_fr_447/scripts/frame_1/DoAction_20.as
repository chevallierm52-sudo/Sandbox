I.u[9457] = {n:"Pompocoiffe",t:16,d:"Cette coiffe dégage une odeur de rose démoniaque suffisamment forte pour faire fuir tous les poux qui vivent sur votre tête, et tous les parasites qui se font passer pour vos amis.",ep:1,g:229,l:33,wd:false,fm:true,w:5,s:124,p:3000};
I.u[9459] = {n:"Liste de jouets du papa Nowel",t:24,d:"Le papa Nowel prend toujours soin des listes de jouets qui sont amenées par les enfants qu\'il dévore.  \nVous n\'aviez pas encore écrit la vôtre, en voilà une.",ep:1,g:41,l:1,wd:false,fm:true,w:0,p:0};
I.u[9460] = {n:"Pomme de pik",t:24,d:"Voilà un Pokipik qui ne poussera jamais, vous n\'avez pas honte ?",ep:1,g:123,l:1,wd:false,fm:true,w:0,p:0};
I.u[9461] = {n:"Le Kim",t:16,d:"On dit que le Kimbo porte cette perruque en hommage à un bel éphèbe bronzé rencontré un jour sur son île, dont il appréciait le sourire aéré. Il la cache néanmoins sous sa coco parce qu\'il la trouve quand même ridicule.",ep:22,g:230,l:196,wd:true,fm:true,w:10,p:60000};
I.u[9463] = {n:"Amunite",t:1,d:"Ce bijou dégage une telle puissance qu\'elle tuerait un Moskito à 30 pas, si son odeur n\'empêchait pas ce dernier d\'approcher à moins d\'un kilomètre.",ep:23,g:141,l:189,wd:true,fm:true,w:10,s:107,p:58000};
I.u[9464] = {n:"Kralamansion",t:1,d:"Cette effrayante amulette est longtemps restée cachée dans un manoir perdu. Autrefois vivante, elle voulait conquérir le monde. Finalement elle n\'aura que votre cou. La pauvre.",ep:22,g:142,l:194,wd:true,fm:true,w:30,s:97,p:58411};
I.u[9468] = {n:"Pelle Emélaka",t:8,d:"Cette pelle est dangereuse, elle volera votre vitalité, votre jeunesse, l\'eau de votre corps et vos précieux gâtrools.",ep:22,g:51,l:191,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,35,50,false,false],c:"CC>450",p:58401};
I.u[9469] = {n:"Epée Loponèze",t:6,d:"Cette épée construite à partir de fragments de mycoses, parasitera à merveille les intestins de vos ennemis.",ep:23,g:85,l:184,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,50,50,false,false],c:"CC>300&CA>300",p:58456};
I.u[9471] = {n:"Chapeau de la Sain Ballotin",t:16,d:"Ballotins, Ballotines, vous qui cherchez l\'âme sœur, ce couvre-chef élégant et sobre sera votre signe de reconnaissance. En effet, ce chapeau magique ne peut être porté que par les aventuriers et les aventurières qui ne sont pas encore mariés. Vous pourrez ainsi facilement distinguer plus facilement celles et ceux dont le cœur n\'est pas encore pris.",ep:1,g:231,l:1,wd:false,fm:true,w:1,c:"PR=0",p:1};
I.u[9472] = {n:"Shigekax Passion",t:42,d:"Réputé pour ses vertus aphrodisiaques, ce bonbon doux et sucré est idéal comme cadeau à offrir à l\'être aimé.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9474] = {n:"Sublime Pierre d\'âme hasardeuse",t:83,d:"Cette rune offre une faible chance de capturer des âmes d\'une puissance tout simplement incroyable.",ep:0,g:17,l:1,wd:false,fm:true,w:1,tw:true,p:23000};
I.u[9475] = {n:"Sublime Pierre d\'âme",t:83,d:"Cette rune offre une chance correcte de capturer des âmes d\'une puissance tout simplement incroyable.",ep:0,g:16,l:1,wd:false,fm:true,w:1,tw:true,p:50000};
I.u[9476] = {n:"Sublime Pierre d\'âme heureuse",t:83,d:"Cette rune offre une bonne chance de capturer des âmes d\'une puissance tout simplement incroyable.",ep:0,g:18,l:1,wd:false,fm:true,w:1,tw:true,p:75000};
I.u[9479] = {n:"Poshocoiffe",t:16,d:"Le clou planté dans cette coiffe permet de dégonfler la tête de ceux qui l\'ont un peu trop grosse.",ep:1,g:232,l:45,wd:true,fm:true,w:23,s:123,p:1000};
I.u[9480] = {n:"Poshocape",t:17,d:"Avec cette jolie cible brodée sur votre cape, vos ennemis n\'auront aucune excuse s\'ils vous ratent.",ep:1,g:161,l:33,wd:true,fm:true,w:10,s:123,p:3000};
I.u[9481] = {n:"Poshoclier",t:82,d:"Le clou planté dans ce bouclier peut servir d\'arme de corps à corps si vous voulez crever votre adversaire pour qu\'il se dégonfle.",ep:1,g:36,l:1,wd:true,fm:true,w:1,s:123,p:1};
I.u[9482] = {n:"Cigaloclier",t:82,d:"Si vous avez peur d\'effrayer vos amis avec votre tête de monstre, vous pourrez toujours vous cacher derrière ce bouclier pour ressembler à quelqu\'un de sympathique.",ep:1,g:37,l:1,wd:true,fm:true,w:1,s:122,p:1};
I.u[9483] = {n:"Bouclier Boh-Bihn",t:82,d:"Ce bouclier était utilisé par les jeunes Iops qui y rangeaient les images offertes par leurs instituteurs pour les récompenser de leurs efforts. De temps en temps, ils s\'amusaient à les faire défiler rapidement pour épater leurs camarades de classe.",ep:1,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[9484] = {n:"Bouclier Tigré",t:82,d:"Ce bouclier ne protège pas totalement son propriétaire, mais il pourra vous défendre efficacement contre les fantômes.",ep:1,g:39,l:1,wd:true,fm:true,w:1,p:1};
I.u[9485] = {n:"Cigalocape",t:17,d:"Les trois petites boules qui ornent cette cape permettent de donner de jolis coups de boules si vous savez faire la toupie.",ep:1,g:162,l:30,wd:true,fm:true,w:10,s:122,p:2500};
I.u[9486] = {n:"Cigalocoiffe",t:16,d:"Avec ou sans cette coiffe, vous ressemblerez toujours à un bouffon, mais avec cette coiffe vous aurez au moins une bonne excuse.",ep:1,g:233,l:33,wd:true,fm:true,w:10,s:122,p:3075};
I.u[9487] = {n:"Certificat de changement d\'alignement",t:24,d:"Ce certificat vous a été remis par Morrie Gane. Il contient plusieurs informations vous concernant et atteste de votre changement d\'alignement.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9488] = {n:"Registre de Bonta",t:24,d:"Ce registre appartient à Morrie Gane et contient de nombreux documents dont comment devenir Bontarien. Il y a une page à remplir par vos soins.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9489] = {n:"Registre de Brâkmar",t:24,d:"Ce registre appartient à Morrie Gane et contient de nombreux documents dont comment devenir Brâkmarien. Il y a une page à remplir par vos soins.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9490] = {n:"Certificat des Ordres numéro 5",t:24,d:"Ce certificat atteste que vous appartenez à un ordre. Pour en changer, il vous faut attendre sept jours à compter de la date de remise de ce certificat. Vous avez en effet le droit de faire la girouette, mais il ne faut pas exagérer tout de même.",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9491] = {n:"Malédiction du Ballotin",t:30,d:"Vous voyez désormais la vie en rose, et vous êtes heureux.",ep:1,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9492] = {n:"Cadeau Pantoufrelons",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
