I.u[9549] = {n:"Caleçon à bretelles du Parrain",t:10,d:"Le slogan du couturier à l\'origine de cette merveille était : \"Même dans le feu de l\'action, ce caleçon restera solidement accroché à votre postérieur, grâce à ses bretelles en lin d\'une qualité supérieure\". Avant d\'être couturier, il était mauvais poète.",ep:0,g:152,l:48,wd:true,fm:true,w:10,s:126,p:6175};
I.u[9550] = {n:"Emplacement du champ",t:24,d:"Merlan vous a indiqué où le milicien va utiliser le sort de Transgénèse. Il faut vous dépêcher d\'arriver avant qu\'il ne soit trop tard.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9551] = {n:"Graine de scorbute modifiée",t:24,d:"Ces graines de scorbute ont été modifiées mais vous ne voyez pas la différence avec des graines de scorbute classiques. Le vrai problème est que par contre vous voyez clairement la différence entre ces graines et des graines de pavot. Seul un idiot pourrait se méprendre.",ep:0,g:405,l:1,wd:false,fm:true,w:0,p:1};
I.u[9552] = {n:"Cadeau Tourmenteur de Ténèbres",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
