I.u[9897] = {n:"Potion de libération",t:14,d:"Cette potion permet de libérer l\'âme d\'un ennemi pour le renvoyer directement dans son cimetière, sans lui permettre de pouvoir se faire ressusciter.",ep:0,g:68,l:1,wd:true,fm:true,w:1,c:"Pg>23,1",ut:true,p:10};
I.u[9898] = {n:"Potion de soin de masse",t:14,d:"Cette potion permet de soigner tous les alliés présents sur la carte.",ep:0,g:71,l:1,wd:true,fm:true,w:1,c:"Pg>23,2",u:true,p:10};
