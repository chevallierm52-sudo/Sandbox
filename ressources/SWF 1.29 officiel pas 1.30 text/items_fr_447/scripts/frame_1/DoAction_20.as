I.u[9760] = {n:"Fragment de force majeur",t:115,d:"Ce fragment d\'âme provient d\'un des Shushus de Rushu. Si vous disposez d\'une arme Shushette, vous pouvez utiliser ce fragment pour la rendre plus puissante. Si votre arme Shushette dépasse son potentiel maximum, les runes seront toutes retirées et placées dans votre inventaire. \n(Double clic pour placer ce fragment d\'âme sur une arme Shushette équipée)",ep:0,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9785] = {n:"Shushu de Rushu",t:18,d:"Ce démon mineur vous accompagnera durant toutes vos pérégrinations, du Zaap d\'Astrub au cimetière, voire même du cimetière au Zaap d\'Astrub. Cette créature est animée d\'une haine viscérale envers les Ouassingues. Une sombre histoire de ménage paraît-il... Attaquez des Ouassingues, et elle se repaîtra de leurs dépouilles.",ep:0,g:52,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9786] = {n:"Fantôme de Shushu de Rushu",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:49,l:1,wd:true,fm:true,w:1,p:1};
