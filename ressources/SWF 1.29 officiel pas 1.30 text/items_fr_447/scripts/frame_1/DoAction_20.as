I.u[9903] = {n:"Potion de renommage de guilde",t:12,d:"Permet de renommer une guilde.",ep:0,g:58,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[9904] = {n:"Pouflage",t:31,d:"Si vous ne bougez pas, peut-être que personne ne vous repérera.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
