I.u[9594] = {n:"Bouloute du Parrain",t:18,d:"Ce bouloute a l\'air tout à fait normal... Pourtant on dirait que sa laine vire au noir par endroits... Laissez-lui un peu de temps et vous pourriez bien avoir une surprise !",ep:0,g:46,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9595] = {n:"Fantôme Bouloute du Parrain",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[9596] = {n:"Cadeau Bouloute du Parrain",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9597] = {n:"Transformation Fantôme Bouloute du Parrain",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans le sanctuaire des familiers.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9598] = {n:"Certificat de mise en Chanil : Bouloute du Parrain",t:77,d:"Ce certificat décrit les caractéristiques du familier que vous avez placé au Chanil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[9616] = {n:"Fantôme Marcassin",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:40,l:1,wd:true,fm:true,w:1,p:1};
I.u[9617] = {n:"Chacha Angora",t:18,d:"Cette boule de poils est mieux protégée contre le froid que le Chacha classique, elle est plus douce, mais il paraît que son caractère est encore plus insupportable. Cette créature ne mange que de la viande et du poisson.",ep:0,g:50,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9618] = {n:"Cadeau Grosse Bagouze du Parrain",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9619] = {n:"Tiwabbit Kiafin",t:18,d:"Cette créature est un peu stupide, la seule façon de la faire avancer est de lui accrocher dans le dos un bâton soutenant une Cawotte. Heureusement, ce familier a été correctement dressé, et ne tentera pas d\'envoyer des vents de panique. Ce dévoreur d\'âmes se nourrit en mangeant les restes d\'autres Wabbits.",ep:0,g:51,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9620] = {n:"Miniminotot",t:18,d:"Cette créature est un Minimino élevé par le Minotot en personne. Il lui a malheureusement transmis son caractère, ainsi qu\'une partie de ses odeurs corporelles à force de le cajoler sous ses aisselles. Ce dévoreur d\'âmes mange les dépouilles des créatures de l\'île du Minotoror.",ep:0,g:49,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9621] = {n:"Cadeau venu d\'ailleurs",t:89,d:"Vous êtes sûr que ce sac n\'était pas là il y a encore deux minutes. Mais que peut-il bien contenir ? (DOUBLE-CLIC POUR UTILISER)",ep:0,g:32,l:1,wd:false,fm:false,w:1,u:true,p:0};
I.u[9622] = {n:"Pousse de Tanfouguite",t:36,d:"L\'existence de cette plante est aussi mystérieuse et improbable que son nom. À la fois ici et ici, mais pas maintenant, heureusement qu\'elle n\'est pas ailleurs, on n\'y comprendrait plus rien. Amenez-la au temple Xélor d\'Amakna (coordonnées 3,1) , seuls des illuminés comme eux peuvent tenter d\'y comprendre quelque chose.",ep:0,g:638,l:1,wd:false,fm:false,w:1,p:0};
I.u[9623] = {n:"Crocodaille",t:18,d:"Ne vous méprenez pas, les dents pointues de cette créature finiront un jour ou l\'autre par se planter dans votre postérieur. Ce familier ne mange que de la viande et du poisson.",ep:0,g:47,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9624] = {n:"Dragoune Noire",t:18,d:"Prenez une Dragoune Rose, teignez-la en noir, saupoudrez-la de poussière d\'or, trempez-la dans l\'huile, trempez-la dans l\'eau, et vous aurez une Dragoune Noire. Ce dévoreur d\'âmes ne mange que les dépouilles de dragoeufs.",ep:0,g:48,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9625] = {n:"Shigekax Amande",t:28,d:"Retrouvez la saveur, et tout le charme des sucreries d\'antan avec ce bonbon préparé de façon traditionnelle. Hmm... Ce Shigekax vous paraît particulièrement fondant sous la langue.",ep:0,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
