I.u[9654] = {n:"Cape Papayou",t:17,d:"Cette cape mettra en valeur les courbes de votre postérieur, ou celles de votre dos bossu.",ep:0,g:165,l:48,wd:true,fm:true,w:10,s:129,p:6105};
I.u[9655] = {n:"Sandales Papayou",t:11,d:"La semelle de ces sandales est renforcée afin de supporter le poids des Papayous les plus lourds.",ep:0,g:132,l:49,wd:true,fm:true,w:10,s:129,p:6475};
I.u[9656] = {n:"Les Sleumpettes",t:11,d:"Les roulettes présentes sur ces bottes permettent de descendre les escaliers sans efforts tout en augmentant considérablement vos chances de vous casser quelques os. À vous de choisir.",ep:0,g:133,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9657] = {n:"Bâton Poupinateur",t:4,d:"Qui a osé affubler ce bâton d\'un nom aussi ridicule ? Personne ne le saura jamais, mais vous devrez continuer de l\'appeler ainsi et d\'avoir l\'air ridicule lorsque l\'on vous demandera le nom de votre bâton.",ep:0,g:82,l:42,wd:true,fm:true,w:10,an:12,e:[1,3,1,1,10,40,false,false],c:"CV>60&CW>30",s:140,p:4200};
I.u[9658] = {n:"Amulette Papayou",t:1,d:"Cette amulette n\'est en réalité qu\'un assortiment de fleurs accrochées autour d\'un fil. Elle est censée diffuser un parfum magique à même de transformer un Papayou en Papayou Lélé.",ep:0,g:144,l:47,wd:true,fm:true,w:10,s:129,p:6000};
I.u[9659] = {n:"Collier Sleump",t:1,d:"Erala a porté cette amulette pendant toute son enfance. Personne ne sait exactement ce qu\'elle renferme.",ep:0,g:143,l:43,wd:true,fm:true,w:10,s:140,p:5025};
