I.u[1324] = {n:"Herbe à chat",t:36,d:"Cette plante fait saliver n\'importe quel Ecaflip.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1325] = {n:"Coque de Noix",t:46,d:"Cette coque, naturellement solide, résiste à tout type d\'agression et représente bien l\'idéologie Féca.",ep:2,g:52,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1326] = {n:"Silex Sanglant",t:51,d:"Cette pierre aussi résistante que coupante semble avoir été utilisé contre quelque chose ou quelqu\'un. Cet aspect brut et dangereux semble illustrer parfaitement la définition d\'un Iop.",ep:2,g:47,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1327] = {n:"Os taillé",t:47,d:"Cet objet de mort devient redoutable une fois travaillé, exactement comme un Sram.",ep:2,g:48,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1328] = {n:"Kama énigmatique",t:15,d:"Ce Kama est orné d\'une tête de tofu coiffé d\'un chapeau étrange.",ep:1,g:182,l:1,wd:true,fm:true,w:10,p:1};
I.u[1329] = {n:"Bois élastique",t:38,d:"Cette grande branche de bois, par son retour élastique et sa forme curviligne, fait immédiatement penser aux Crâ.",ep:2,g:49,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1330] = {n:"Amulette Itby",t:1,d:"Création originale de l\'orfèvre John Les Nonnes, c\'est aujourd\'hui un des bijoux les plus classiques.",ep:1,g:31,l:10,wd:true,fm:true,w:5,p:500};
I.u[1331] = {n:"Médaille Oly",t:1,d:"Oly était une disciple de Iop dont le seul talent était la cuisine. On rapporte que Iop en personne lui aurait donné cette médaille, pour compenser ses trop grandes faiblesses en combat. Cependant seuls les coeurs purs peuvent la porter.",ep:7,g:23,l:51,wd:true,fm:true,w:10,c:"Ps=1&Pa>10",p:7000};
I.u[1332] = {n:"Vieux Trèfle à 4 feuilles",t:36,d:"Les trèfles à quatre feuilles sont bien plus rares que ceux à cinq feuilles. Lorsque vous en trouvez-un, il est conseillé de le faire sécher entre deux parchemins de sorts.",ep:2,g:50,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1333] = {n:"Potion d\'Etincelle",t:26,d:"Cette potion chauffante, grâce à la faible magie de feu qu\'elle emprisonne, est généralement utilisée pour enchanter un peu toutes sortes d\'objets.",ep:3,g:1,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1334] = {n:"Blague de Soufre",t:48,d:"Cette petite poche pleine de soufre dégage une odeur insupportable... La même que celle des Osamodas.",ep:2,g:51,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1335] = {n:"Potion de Crachin",t:26,d:"Cette potion frémissante, grâce à la faible magie d\'eau qu\'elle emprisonne, est généralement utilisée pour enchanter un peu toutes sortes d\'objets.",ep:3,g:2,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1336] = {n:"Orties",t:36,d:"En frottant vivement cette plante contre votre peau, vous souffrirez le martyr. Pourtant, la stimulation provoquée est bénéfique, exactement la philosophie des Sacrieurs",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1337] = {n:"Potion de Courant d\'Air",t:26,d:"Cette potion soupirante, grâce à la faible magie d\'air qu\'elle emprisonne, est généralement utilisée pour enchanter un peu toutes sortes d\'objets.",ep:3,g:3,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1338] = {n:"Potion de Secousse",t:26,d:"Cette potion vibrante, grâce à la faible magie de terre qu\'elle emprisonne, est généralement utilisée pour enchanter un peu toutes sortes d\'objets.",ep:3,g:4,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1339] = {n:"Clochettes",t:35,d:"Ces fleurs de muguet sont vraiment toutes petites, fragiles et mignonnes. On dit de plus qu\'elles ont le pouvoir de calmer l\'esprit et de guérir certains maux. Elles ont sûrement été conçues par une divinité qui souhaitait voir une plante à l\'image des Eniripsas.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1340] = {n:"Potion d\'Eboulement",t:26,d:"Cette potion tremblante, grâce à la magie de terre qu\'elle emprisonne, est généralement utilisée pour enchanter correctement toutes sortes d\'objets.",ep:9,g:4,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1341] = {n:"Potion d\'Averse",t:26,d:"Cette potion clapotante, grâce à la magie d\'eau qu\'elle emprisonne, est généralement utilisée pour enchanter correctement toutes sortes d\'objets.",ep:9,g:2,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1342] = {n:"Potion de Rafale",t:26,d:"Cette potion sifflante, grâce à la magie d\'air qu\'elle emprisonne, est généralement utilisée pour enchanter correctement toutes sortes d\'objets.",ep:9,g:3,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1343] = {n:"Potion de Flambée",t:26,d:"Cette potion crépitante, grâce à la magie de feu qu\'elle emprisonne, est généralement utilisée pour enchanter correctement toutes sortes d\'objets.",ep:9,g:1,l:25,wd:true,fm:true,w:1,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1344] = {n:"Verveine",t:36,d:"Cette plante spéciale permet de faire dormir n\'importe qui bien plus facilement. Cela doit probablement être l\'emblême des Sadida.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1345] = {n:"Potion d\'Incendie",t:26,d:"Cette potion fulminante, grâce à la puissante magie de feu qu\'elle emprisonne, est généralement utilisée pour enchanter puissamment toutes sortes d\'objets.",ep:4,g:1,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1346] = {n:"Potion de Tsunami",t:26,d:"Cette potion inondante, grâce à la puissante magie d\'eau qu\'elle emprisonne, est généralement utilisée pour enchanter puissamment toutes sortes d\'objets.",ep:4,g:2,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1347] = {n:"Potion d\'Ouragan",t:26,d:"Cette potion hurlante, grâce à la puissante magie d\'air qu\'elle emprisonne, est généralement utilisée pour enchanter puissamment toutes sortes d\'objets.",ep:4,g:3,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1348] = {n:"Potion de Séisme",t:26,d:"Cette potion embourbante, grâce à la puissante magie de terre qu\'elle emprisonne, est généralement utilisée pour enchanter puissamment toutes sortes d\'objets.",ep:4,g:4,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1350] = {n:"Arc Holic",t:2,d:"Cet arc a été créé par un magicien porté sur la bouteille. Afin de résoudre son problème, il a inventé cet arc spécialisé dans l\'eau.",ep:3,g:4,l:15,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,3,6,30,50,false,true],p:250};
I.u[1351] = {n:"Arc du Xueluom",t:2,d:"\"Avec un arc, ça passe ou ça casse\", dit le proverbe. Les sages éviteront cet arc, il serait soi-disant porteur du mauvais oeil...",ep:1,g:51,l:30,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,10,10,false,true],c:"CC>30",p:1600};
I.u[1352] = {n:"Arc de Boo",t:2,d:"Cet arc prend sa force aussi bien de la terre que de l\'eau. Malheur à ceux qui ne maîtrisent ni l\'un ni l\'autre...",ep:2,g:6,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],p:5000};
I.u[1353] = {n:"Arc à Poulie Sciée",t:2,d:"Cet arc, dont toutes les poulies ont été sciées, était, il y a fort longtemps, le symbole de la lutte du bien contre le mal. \nEncore aujourd\'hui, on peut sentir en lui la flamme des anciens justiciers.",ep:12,g:10,l:41,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"Ps=1&Pa>10&CI>30&CW>30",p:200};
I.u[1354] = {n:"L\'Arc à Hick",t:2,d:"Hick était un Crâ maudit : il n\'arrivait jamais à se débarrasser de son hoquet. Cependant, il finit un jour par jeter son arc au feu pour le remplacer par une épée, et son mal disparu mystérieusement...",ep:13,g:11,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,6,40,40,false,true],p:1000};
I.u[1355] = {n:"Arc Hidsad",t:2,d:"Le créateur de cet arc, un certain Marc Hidsad, n\'a jamais très bien su s\'en servir. Il pouvait tout autant infliger de sévères blessures à ses ennemis que de se blesser lui-même.",ep:14,g:12,l:40,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,7,30,50,false,true],p:4000};
I.u[1356] = {n:"Demi-Baguette",t:3,d:"Rika Zarouil la boulangère fut connue pour avoir été l\'eniripsa la plus petite de la contrée. Elle faisait son pain dans des petits-fours en carton et se battait avec des demi-baguettes.",ep:1,g:13,l:11,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,30,50,false,true],p:1000};
I.u[1357] = {n:"Daguette",t:3,d:"Un sculpteur un peu farceur tenta de faire passer ses baguettes pour des dagues. Son stratagème n\'eu aucun succès mais ses baguettes, elles, en eurent.",ep:7,g:17,l:35,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,40,40,false,true],c:"CI>25",p:3500};
I.u[1359] = {n:"Le Tison Fûté",t:3,d:"Les origines de cette baguette restent obscures. Cependant, elle a toujours aidé ses heureux possesseurs à trouver les chemins les moins encombrés d\'Amakna, ce qui peut servir les jours de grande influence sur le domaine du bouftou royal.",ep:9,g:12,l:59,wd:true,fm:true,w:10,an:11,e:[7,3,2,3,30,50,false,true],c:"CI>70&CS>30",p:5000};
I.u[1360] = {n:"L\'Hyldegarde",t:3,d:"Cette baguette fut créée il y a de nombreuses années dans les flammes de la forge de Mort Dur. Cette arme nécessite d\'avoir toujours de l\'eau à côté de soi pour pouvoir maitriser son feu intérieur...",ep:13,g:8,l:48,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],p:4800};
I.u[1361] = {n:"Baguette Sylvien",t:3,d:"La Baguette Sylvien a l\'étrange pouvoir de conférer une vue perçante à son porteur. Charge ensuite à celui ci d\'être suffisamment agile pour pouvoir fuir le danger.",ep:1,g:15,l:43,wd:true,fm:true,w:10,an:11,e:[4,5,2,2,40,40,false,true],c:"CA>80",p:4000};
I.u[1362] = {n:"Pieu Vampirique",t:3,d:"Le pieu vampirique est en fait la baguette d\'un vampire depuis longtemps retiré de la vie sociale et de la boucherie. Cet étrange bout de bois a cependant gardé quelques uns des avantages de son ancien maître...",ep:7,g:14,l:65,wd:true,fm:true,w:10,an:11,e:[5,6,2,3,50,20,false,true],c:"CA>30&CW<60",p:4000};
I.u[1363] = {n:"Bâton Tont\'Ata",t:4,d:"Outre son nom insupportable, ce bâton possède bien d\'autres moyens de rendre son propriétaire fou de rage.",ep:1,g:5,l:40,wd:true,fm:true,w:10,an:12,e:[5,5,1,1,5,5,false,true],c:"CI<100",p:5000};
I.u[1364] = {n:"Bâton d\'Oubli",t:4,d:"Ce bâton fait oublier tous les soucis et les mauvaises pensées de son propriétaire. Malheureusement, il perd aussi parfois une partie de sa mémoire et devient sujet à des pertes de concentration de plus en plus fréquentes. À réserver aux sages...",ep:13,g:11,l:30,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,true],c:"CW>50",p:3000};
I.u[1365] = {n:"La Canne Hête",t:4,d:"Hète était vraiment un guerrier redoutable avec son bâton. Il était tellement efficace qu\'on prétendait que son bâton était magique et qu\'il lançait des flammes...",ep:1,g:68,l:20,wd:true,fm:true,w:15,an:12,e:[8,5,1,1,50,40,false,true],p:2000};
I.u[1366] = {n:"Bâton de Bouftier",t:4,d:"Bâton couramment utilisé lors de la transhumance par les bouftiers. Les bworks aiment déguster ces troupeaux de bouftous en fines tranches lors de l\'apéritif (le plat principal étant constitué du bouftier lui-même).",ep:9,g:9,l:12,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,true],p:1200};
I.u[1367] = {n:"Bâton de Dina, dit \'le Mythe\'",t:4,d:"Ce bâton a appartenu à la très belle Dina \'Mythe\', qui était surtout connue pour ses formes avantageuses et son caractère explosif... Bref c\'était une vraie bombe.",ep:13,g:6,l:40,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,30,50,false,true],c:"CI>50&CA>40",p:4000};
I.u[1368] = {n:"La Lance à un \"110\"",t:4,d:"\"Les 110\" est le surnom donné aux 110 valeureux pompiers Amakniens, qui ont notamment combattu le feu d\'un Dragonnet en mal de sensations fortes. Cette lance aurait appartenu à l\'un d\'eux. S\'en servir demande courage et force.",ep:1,g:18,l:29,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,true],c:"CC>10",p:2500};
I.u[1369] = {n:"Les Lames en Table",t:5,d:"Ces couteaux étaient à l\'origine censés servir dans un restaurant de luxe. Mais devant leur look plutôt... étrange, le patron du restaurant a préféré les revendre à un lanceur de couteaux ambulant.",ep:1,g:13,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>55&CC>5",p:3000};
I.u[1370] = {n:"L\'Ergot Mina",t:5,d:"La poignée de cette arme est grasse et glissante, mais elle a vraiment un look génial.",ep:1,g:14,l:20,wd:true,fm:true,w:10,an:13,e:[8,3,1,1,50,50,false,true],p:2000};
I.u[1371] = {n:"Dagues Eulasse",t:5,d:"Eulasse était un bouftier du nord d\'Amakna qui trouva un jour, au milieu du fumier de ses bouftous, une paire de dagues légèrement salies. \nQue celui qui les porte fasse attention : le manche glisse, il est facile de manquer son coup.",ep:1,g:10,l:40,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>40",p:4000};
I.u[1372] = {n:"Dagues Aj\'Deh\'Là",t:5,d:"Qui ne connait pas Aj\'Deh\'Là, l\'ermite, légendaire disciple de Sram qui avait passé sa vie à refuser tout contact avec les autres. À sa mort, on retrouva ses dagues fétiches à côté de son corps, et seuls les plus agiles purent les apprivoiser.",ep:9,g:19,l:44,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5300};
I.u[1373] = {n:"Le Rasoir Infernal",t:5,d:"Krys Razepa était un vieux disciple d\'Enutrof qui portait la barbe, comme tous les disciples d\'Enutrof dignes de ce nom. Lorsque madame Razepa, sa femme, lui offrit un rasoir, il préféra l\'utiliser pour combattre...",ep:1,g:17,l:30,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1374] = {n:"Dagues Tylo",t:5,d:"Tylo était un scribe amaknéen qui vécut il y a des siècles de cela. Il avait la particularité de graver ses cahiers de pierre non pas avec des burins mais avec des dagues. Nous reste de lui cette superbe dague, impressionnante de résistance aux chocs.",ep:1,g:12,l:30,wd:true,fm:true,w:13,an:13,e:[10,3,1,1,30,50,false,false],c:"CS>50",p:3000};
I.u[1375] = {n:"Hache Térophyle",t:19,d:"Térophyle était un disciple de Iop capable de soulever des masses impressionnantes. Mais malheureusement pour lui, comme tous les Iop trop musclés, l\'intelligence n\'était pas son fort...",ep:1,g:14,l:15,wd:true,fm:true,w:25,an:17,e:[10,5,1,1,50,50,false,true],c:"CS>70&CI<10",p:800};
I.u[1376] = {n:"Hache Heuvante",t:19,d:"Cette hache, parfois lourde à manier, est parfaite pour terrasser les Trools : les runes magiques qu\'elle contient permettent en effet de brûler les ennemis.",ep:7,g:15,l:35,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,50,false,true],c:"CS>50",p:3000};
I.u[1377] = {n:"Hache Huré",t:19,d:"Huré était un jeune prêtre qui ne reculait pas devant les armes pour faire progresser la foi. Son arme de prédilection était une hache sur laquelle il avait dessiné de nombreux traits, dont la signification est perdue à jamais...",ep:1,g:16,l:22,wd:true,fm:true,w:22,an:17,e:[10,5,1,1,50,50,false,true],c:"CW>30",p:2200};
I.u[1378] = {n:"Francisque à Brêles",t:19,d:"Cette hache de combat, réservée aux jeunes guerriers, comme son nom l\'indique, a la particularité de produire un son strident particulièrement désagréable lorsqu\'elle entrechoque une autre arme.",ep:1,g:17,l:28,wd:true,fm:true,w:22,an:17,e:[8,5,1,1,40,40,false,true],c:"CA>30",p:2300};
I.u[1379] = {n:"Le Scrounnchhh",t:7,d:"D\'après la légende, ce marteau tirerait son nom du son qu\'il produit lorsqu\'il s\'écrase sur un crâne ennemi. Malheureusement, nul ennemi n\'est là pour confirmer ces dires.",ep:7,g:9,l:35,wd:true,fm:true,w:35,an:15,e:[8,5,1,1,30,40,false,true],c:"CS>50&CA>20",p:35000};
