I.u[1455] = {n:"Ailes de Scarafeuille bleu",t:104,d:"Ces ailes de Scarafeuille ont des particularités magiques et permettent de fabriquer des potions élémentaires d\'eau.",ep:3,g:212,l:32,wd:true,fm:true,w:2,p:100};
I.u[1456] = {n:"Ailes de Scarafeuille blanc",t:104,d:"Ces ailes de Scarafeuille ont des particularités magiques et permettent de fabriquer des potions élémentaires d\'air.",ep:3,g:213,l:32,wd:true,fm:true,w:2,p:100};
I.u[1457] = {n:"Ailes de Scarafeuille rouge",t:104,d:"Ces ailes de Scarafeuille ont des particularités magiques et permettent de fabriquer des potions élémentaires de feu.",ep:3,g:214,l:32,wd:true,fm:true,w:2,p:100};
I.u[1458] = {n:"Ailes de Scarafeuille vert",t:104,d:"Ces ailes de Scarafeuille ont des particularités magiques et permettent de fabriquer des potions élémentaires de terre.",ep:3,g:215,l:32,wd:true,fm:true,w:2,p:100};
I.u[1459] = {n:"Tube longiforme",t:71,d:"Ce tube est spécialement étudié pour pouvoir être débouché d\'une seule main.",ep:1,g:55,l:1,wd:true,fm:true,w:1,p:5};
I.u[1460] = {n:"Grande fiole",t:71,d:"Cette fiole est spécialement étudiée pour pouvoir être débouchée simplement même sans les mains.",ep:3,g:56,l:1,wd:true,fm:true,w:1,p:10};
I.u[1461] = {n:"Poison cinglant",t:15,d:"Ce poison à base de pattes d\'araknes vous fera perdre la tête. Au propre comme au figuré puisque qu\'après une période de folie la boîte crânienne explose sous la pression sanguine.",ep:1,g:189,l:20,wd:true,fm:true,w:1,p:100};
I.u[1462] = {n:"Liquide vampiresque",t:15,d:"Ce liquide fait d\'un croisement de plusieurs sangs a la mauvaise habitude de sauter au cou.",ep:2,g:188,l:30,wd:true,fm:true,w:1,p:100};
I.u[1463] = {n:"Fiole à élément",t:71,d:"Cette fiole est tout naturellement destinée à emprisonner de l\'essence élémentaire.",ep:1,g:57,l:1,wd:true,fm:true,w:1,p:50};
I.u[1464] = {n:"Antenne du Scarafeuille bleu",t:15,d:"Nul ne sait à quoi servent les antennes d\'un Scarafeuille. La seule certitude que l\'on ait c\'est qu\'elles ne sentent pas très bon.",ep:3,g:216,l:32,wd:true,fm:true,w:1,p:100};
I.u[1465] = {n:"Antenne du Scarafeuille rouge",t:15,d:"Nul ne sait à quoi servent les antennes d\'un Scarafeuille. La seule certitude que l\'on ait c\'est qu\'elles ne sentent pas très bon.",ep:3,g:217,l:32,wd:true,fm:true,w:1,p:1};
I.u[1466] = {n:"Antenne du Scarafeuille vert",t:15,d:"Nul ne sait à quoi servent les antennes d\'un Scarafeuille. La seule certitude que l\'on ait c\'est qu\'elles ne sentent pas très bon.",ep:3,g:218,l:32,wd:true,fm:true,w:1,p:100};
I.u[1467] = {n:"Antenne du Scarafeuille blanc",t:15,d:"Nul ne sait à quoi servent les antennes d\'un Scarafeuille. La seule certitude que l\'on ait c\'est qu\'elles ne sentent pas très bon.",ep:3,g:219,l:32,wd:true,fm:true,w:1,p:100};
I.u[1468] = {n:"Bocal",t:71,d:"Ce bocal peut servir à tout, de la fabrication de potion, à la noyade de poisson.",ep:1,g:58,l:1,wd:true,fm:true,w:1,p:100};
I.u[1469] = {n:"Parchemin de recommandation",t:24,d:"Ce parchemin vous a été remis par Uba Tessé. Il vous recommande chaudement pour devenir alchimiste.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1470] = {n:"Parchemin de recommandation",t:24,d:"Ce parchemin vous a été remis par Uba Tessé. Il vous recommande chaudement pour devenir alchimiste. Une petite note a été ajouté par Boff Chalon.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1471] = {n:"Parchemin de recommandation et fleur",t:24,d:"Ce parchemin vous a été remis par Uba Tessé. Il vous recommande chaudement pour devenir alchimiste. Une petite note a été ajoutée par Boff Chalon. Une fleur attachée prouve que vous avez appris la première leçon.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1472] = {n:"Parchemin de demande d\'examen",t:24,d:"Ce parchemin indique que vous avez passé votre formation d\'alchimiste et que vous êtes apte à tenter l\'examen.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1473] = {n:"Mains Vertes",t:20,d:"Avec ces gants, vous pourrez facilement et sans risque cueillir n\'importe quelle plante ou fleur.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:100};
I.u[1474] = {n:"Amulette de Xélor",t:1,d:"Cette amulette surpuissante est le fruit du travail sur la maîtrise du temps d\'un très vieux Xélor.",ep:1,g:28,l:52,wd:true,fm:true,w:10,p:7300};
I.u[1475] = {n:"La Zulie Lame",t:6,d:"La Zulie Lame a été forgée par le célèbre forgeron Dave-Lol avant de mourir, pour la plus jolie des iopettes du royaume. On dit que cette lame n\'a d\'égal que la beauté de son porteur.",ep:4,g:15,l:60,wd:true,fm:true,w:30,an:14,e:[10,4,1,1,30,50,false,false],c:"CS>100&CV>50",p:3000};
I.u[1476] = {n:"Amulette du Craqueleur",t:1,d:"Cette puissante amulette contient toute la vie du Craqueleur, tous les objets qu\'il a récoltés avant de mourir sous les coups de butoir d\'aventuriers attirés par ses richesses.",ep:2,g:25,l:47,wd:true,fm:true,w:5,p:5800};
I.u[1477] = {n:"Chance à Mulette",t:1,d:"Mulette était une petite Ecaflipette qui n\'a jamais eu de chance dans sa vie, jusqu\'au jour où sa grand-mère lui offrit cette amulette.",ep:1,g:26,l:44,wd:true,fm:true,w:5,p:5000};
I.u[1478] = {n:"Harmonie",t:1,d:"Ce pendentif aide son porteur à se retrouver en paix avec le monde qui l\'entoure.",ep:1,g:122,l:47,wd:true,fm:true,w:1,p:6000};
I.u[1479] = {n:"Le Twote en Carton",t:7,d:"Ce marteau légendaire a déjà fait ses preuves en Amakna, appartenant au puissant Twote en Carton, qui n\'hésita jamais à s\'en servir, pour réduire ses adversaires en patte à mâcher et confettis.",ep:13,g:6,l:46,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>50&CV>30",p:5600};
I.u[1480] = {n:"Accord",t:1,d:"Ce pendentif aide son porteur à se retrouver en paix avec le monde qui l\'entoure.",ep:1,g:121,l:38,wd:true,fm:true,w:1,p:4000};
I.u[1481] = {n:"Entente",t:1,d:"Ce pendentif aide son porteur à se retrouver en paix avec le monde qui l\'entoure.",ep:1,g:11,l:26,wd:true,fm:true,w:1,p:2000};
I.u[1482] = {n:"Emblème Livide",t:1,d:"Cette amulette est extrêmement utile, mais rend son porteur blanc comme un bouftou.",ep:1,g:32,l:41,wd:true,fm:true,w:2,p:4500};
I.u[1483] = {n:"Kabale",t:1,d:"Symbole mystérieux d\'un organisme mystérieux. D\'ailleurs il n\'existe pas, et vous n\'en avez jamais entendu parler !",ep:11,g:13,l:29,wd:true,fm:true,w:2,p:2500};
I.u[1484] = {n:"Amulette Itby remaniée",t:1,d:"Excellent travail de l\'apprenti-orfèvre Polma Kartnez, cette copie surpasse l\'originale.",ep:1,g:31,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1485] = {n:"La Reinette",t:1,d:"Cette amulette, est une amélioration de La Destinée Dorée. Étrangement, elles n\'ont rien en commun, excepté leur aspect assez ridicule, il faut le reconnaître.",ep:1,g:27,l:22,wd:true,fm:true,w:5,c:"CC>10",p:1500};
I.u[1486] = {n:"Médaille Holy",t:1,d:"Holy était une disciple de Iop qui avait juré de terrasser le mal où qu\'il soit. D\'un calme redoutable, elle ne s\'énervait jamais sauf quand on la comparait à une certaine Oly.",ep:1,g:23,l:31,wd:true,fm:true,w:3,p:2800};
I.u[1487] = {n:"L\'Adelus",t:10,d:"Cette ceinture, en plus d\'habiller d\'une manière élégante, procure à son porteur un effet massant vraiment agréable. L\'heureux propriétaire, moins stressé, est alors plus apte à réfléchir.",ep:1,g:12,l:48,wd:true,fm:true,w:30,p:6075};
I.u[1488] = {n:"Plimclik",t:1,d:"Sous ce nom étrange se cache un objet tout aussi étrange, né on ne sait trop comment de précédentes amulettes. On ignore tout des circonstances dans lesquelles elle a été découverte.",ep:11,g:123,l:130,wd:true,fm:true,w:24,p:1000};
I.u[1489] = {n:"La Broche Hète",t:1,d:"Hète était l\'un des plus grands guerriers d\'Amakna. La légende dit qu\'il tirait sa sagesse de la broche qu\'il portait toujours sur lui.",ep:11,g:15,l:28,wd:true,fm:true,w:1,p:2300};
I.u[1490] = {n:"La Chaîne Nhanor Kibrill",t:1,d:"Son créateur, un certain Ken Aton, était très célèbre pour ses habitudes assez étranges. Il passait ses journées à chasser le Minotoror pour se fabriquer une moquette pectorale.",ep:1,g:12,l:13,wd:true,fm:true,w:2,p:650};
I.u[1491] = {n:"Chaîne de la Liche",t:1,d:"La Liche était une sale créature connue pour s\'incruster dans les groupes de valeureux guerriers afin de subtiliser une part du butin. Un jour, son petit manège fut découvert et elle dut prendre la fuite.",ep:13,g:12,l:45,wd:true,fm:true,w:2,p:5400};
I.u[1493] = {n:"Blessure du Sacrieur",t:9,d:"On dit que cet anneau serait issu d\'une des nombreuses blessures reçues par un Sacrieur.",ep:1,g:13,l:15,wd:true,fm:true,w:2,p:800};
I.u[1494] = {n:"Le Bagueur",t:9,d:"Ce joli anneau avait comme fonction première de permettre aux Osamodas de reconnaître leur tofu dans les combats.",ep:1,g:14,l:15,wd:true,fm:true,w:4,p:800};
I.u[1495] = {n:"L\'Anneau Dhyn",t:9,d:"Ce petit anneau qui ne paye pas de mine a été crée par Degun. Ce bijoutier était plus connu pour ses coups de gueule envers tout le monde et sa cruelle aversion pour la Liche, que pour sa créativité en matière d\'orfévrerie.",ep:1,g:37,l:36,wd:true,fm:true,w:3,p:3575};
I.u[1496] = {n:"Chance d\'Ecaflip",t:9,d:"Cet anneau a été créé pour augmenter la chance de son porteur lors de parties de cartes.",ep:1,g:32,l:20,wd:true,fm:true,w:4,p:1300};
I.u[1497] = {n:"Passé de Xélor",t:9,d:"Anneaux engendrés lors des voyages temporels de Xélor.",ep:1,g:16,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1498] = {n:"Souvenir d\'Enutrof",t:9,d:"Anneaux créés à partir de larmes d\'Enutrof ayant perdu sa pelle. Cela donne une idée du désespoir dans lequel peut être plongé le bonhomme.",ep:1,g:15,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1499] = {n:"L\'Enutrofion",t:9,d:"Cet anneau est destiné aux seuls Enutrofs. Leur dieu l\'a enchanté pour qu\'il ne soit porté que par ses disciples. Il permettra à tout Enutrof qui se respecte, d\'avoir beaucoup plus de chance pour découvrir des trésors.",ep:1,g:39,l:59,wd:true,fm:true,w:1,c:"PG=3",p:10000};
