I.u[1040] = {n:"Lames Sanglantes D\'Ortimus Contrari",t:5,d:"Ortimus Contrari est une légende parmi les assassins. Il exécute toujours ses contrats d\'une manière totalement opposée aux méthodes traditionnelles. N\'en demandez pas plus, vous pourriez mourir dans l\'instant.",ep:9,g:19,l:80,wd:true,fm:true,w:15,an:13,e:[15,3,1,1,20,50,false,false],c:"CA>79&CS>40",p:10000};
