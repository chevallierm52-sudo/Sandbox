I.u[1426] = {n:"Pelle à Thart\'",t:8,d:"Thart\', le créateur de cette pelle, était un disciple de Iop. Un nom prédestiné, pour un Iop, n\'est-ce pas ?",ep:3,g:8,l:24,wd:true,fm:true,w:24,an:16,e:[5,5,1,1,50,50,false,true],p:1800};
I.u[1427] = {n:"Pelle Zébuth",t:8,d:"Cette pelle est utilisée par les grands prêtres Kannibouls de l\'île de Moon pour invoquer Zébuth, une de leurs divinités souvent représentée sous une forme bovine. Seuls les personnages vils peuvent utiliser cette arme.",ep:1,g:40,l:55,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,50,20,false,true],c:"Ps=2&CC>50",p:8000};
I.u[1428] = {n:"Immortelle",t:36,d:"Cette étrange petite plante pousse dans les milieux arides, et répand une odeur de curry aux alentours. Coriace, elle ne semble pas subir les assauts du temps... Si seulement l\'on pouvait en dire autant de toutes les femmes...",ep:2,g:54,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1429] = {n:"Petite Pelle Mechba",t:8,d:"Cette pelle est utilisée par les Enutrof pour cueillir des fruits dans les arbres, mais elle peut s\'avérer une arme de combat redoutable. Comme dirait son créateur, Mechba : \'eche est beche, ma pelle\'.",ep:1,g:19,l:30,wd:true,fm:true,w:15,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>10&CI>10",p:1500};
I.u[1430] = {n:"Pelle Mechba",t:8,d:"Cette pelle est utilisée par les Enutrof pour cueillir des fruits dans les arbres, mais elle peut s\'avérer une arme de combat redoutable. Comme dirait son créateur, Mechba : \'eche est beche, ma pelle\'.",ep:1,g:19,l:45,wd:true,fm:true,w:23,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>15&CI>15",p:2300};
I.u[1431] = {n:"Grande Pelle Mechba",t:8,d:"Cette pelle est utilisée par les Enutrof pour cueillir des fruits dans les arbres, mais elle peut s\'avérer une arme de combat redoutable. Comme dirait son créateur, Mechba : \'eche est beche, ma pelle\'.",ep:1,g:19,l:60,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>25&CI>25",p:3000};
I.u[1432] = {n:"Pelle Houze",t:8,d:"Gaston Houze, jardinier disciple d\'Enutrof, avait tendance à toujours trop abuser des plantes. Cette arme en est la preuve : puissante, elle aura tendance à vous jouer des tours et à mettre à mal votre intelligence.",ep:1,g:17,l:21,wd:true,fm:true,w:21,an:16,e:[2,4,1,1,50,50,false,true],c:"CC>27&CW<100&CS>10",p:2100};
I.u[1433] = {n:"Pelle Sécutrice",t:8,d:"Cette pelle fut l\'arme d\'autodéfense d\'un petit groupe d\'Enutrofettes. Ces dames, une fois l\'instrument de puissance entre leurs mains, changèrent du tout au tout et tentèrent de conquérir le monde.",ep:7,g:4,l:60,wd:true,fm:true,w:30,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>60&CS>30&CA>10",p:6500};
