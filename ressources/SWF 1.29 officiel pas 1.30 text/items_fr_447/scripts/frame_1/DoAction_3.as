I.u[1399] = {n:"Maillet Aclou",t:7,d:"Tout comme l\'amulette du même nom, le Maillet Aclou a la particularité de transformer votre énergie vitale en puissance. À consommer avec modération...",ep:1,g:12,l:15,wd:true,fm:true,w:15,an:15,e:[5,5,1,1,40,40,false,true],p:1500};
