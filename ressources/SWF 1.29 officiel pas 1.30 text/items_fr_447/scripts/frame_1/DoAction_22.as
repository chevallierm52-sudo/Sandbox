I.u[11100] = {n:"Cadeau Extrait des origines de Goultard",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11102] = {n:"Perce-Neige",t:35,d:"Endurcie au climat de Frigost, cette superbe fleur est plus résistante que son aspect fragile le suppose. Sa récolte est toutefois délicate pour en préserver toutes les propriétés alchimiques.",ep:0,g:635,l:100,wd:false,fm:true,w:1,p:0};
I.u[11103] = {n:"Sac de Perce-Neige",t:100,d:"Cet énorme sac contient une quantité impressionnante de Perce-Neiges.",ep:0,g:57,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11104] = {n:"Kouin-Kouin amélioré",t:18,d:"Au delà du Tofu, du Bouftou où encore du Iop, le Kouin-kouin excelle dans la crétinerie.",ep:0,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[11105] = {n:"Fantôme de Kouin-Kouin amélioré",t:90,d:"Ce Kouin-Kouin n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[11106] = {n:"Poisskaille",t:41,d:"Des arêtes acérées comme les lames du Bworker, des écailles épaisses comme l\'écorce du Chêne Mou, et des yeux noirs comme les plumes d\'un Corbac. Ce poisson a un aspect vraiment redoutable, mais pas dans l\'assiette où il est tout simplement succulent.",ep:0,g:403,l:100,wd:false,fm:true,w:1,p:100};
I.u[11107] = {n:"Bois de Tremble",t:38,d:"Cette essence de bois semble frissonner sous vos doigts. Après tous les coups de hache que vous lui avez assénés, il est normal qu\'elle ait peur de vous.",ep:0,g:677,l:100,wd:false,fm:true,w:5,p:100};
I.u[11109] = {n:"Frostiz",t:34,d:"Cette céréale est surprenante, en plus de résister au climat extrême de Frigost, elle donne un goût de chocolat au lailait dans lequel elle est plongée.",ep:0,g:552,l:100,wd:false,fm:true,w:1,p:100};
I.u[11110] = {n:"Obsidienne",t:39,d:"Assez dure pour rayer le verre et assez sombre pour vous saper le moral, cette roche a tout perdu de la chaleur de la lave dont elle est issue. En tout cas, elle sera parfaite pour une pierre tombale, tant que ce n\'est pas la vôtre.",ep:0,g:90,l:100,wd:false,fm:true,w:5,p:0};
I.u[11111] = {n:"Sac de Poisskaille",t:100,d:"Cet énorme sac contient une quantité impressionnante de Poisskaille.",ep:0,g:59,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11112] = {n:"Sac de Tremble",t:100,d:"Cet énorme sac contient une quantité impressionnante de Tremble.",ep:0,g:58,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11113] = {n:"Sac de Frostiz",t:100,d:"Cet énorme sac contient une quantité impressionnante de Frostiz.",ep:0,g:60,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11114] = {n:"Sac d\'Obsidienne",t:100,d:"Cet énorme sac contient une quantité impressionnante d\'Obsidienne.",ep:0,g:34,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11115] = {n:"Pichon d\'Aperirel",t:30,d:"On sent le printemps revenir. On le sent même un peu trop fort, avec cet Úridnac pas frais dans votre dos.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[11116] = {n:"Úridnac",t:94,d:"Ce petit poisson aime tellement les gens qu\'il s\'y attache facilement.  \nCependant son rythme biologique est particulier : il n\'est actif qu\'au mois d\'Aperirel, quand Silouate réchauffe les eaux douces où ce poisson prospère.",ep:0,g:19,l:1,wd:false,fm:false,w:1,c:"SG=3&POX11115",u:true,ut:true,p:0};
I.u[11117] = {n:"Laine de Boufmouth",t:57,d:"Les Boufmouths doivent être tondus une fois par an, comme les aisselles des Bitoufs.",ep:0,g:211,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11118] = {n:"Clavicule de Boufmouth",t:47,d:"Inutile d\'essayer de la ronger, il n\'y a plus la moindre trace de viande comestible dessus.",ep:0,g:660,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11119] = {n:"Oreille de Bouftonmouth",t:106,d:"Les Frigostiens la consomment généralement avec de la vinaigrette car elle n\'a pas bon goût et qu\'ils adorent la vinaigrette.",ep:0,g:624,l:96,wd:false,fm:true,w:10,p:1};
I.u[11120] = {n:"Cuir de Bouftonmouth",t:56,d:"Bouilli 8 fois dans l\'eau, il paraît que ce cuir devient comestible. C\'est ce que racontent les Frigostiens qui veulent vous faire une bonne blague.",ep:0,g:534,l:96,wd:false,fm:true,w:10,p:1};
I.u[11121] = {n:"Oeil de Boufmouth de guerre",t:109,d:"Cet œil a dû voir de nombreux postérieurs de femelles Boufmouths. Désormais il ne verra plus que le fond de votre poche. Le pauvre !",ep:0,g:590,l:112,wd:false,fm:true,w:10,p:1};
I.u[11122] = {n:"Corne de Boufmouth de guerre",t:47,d:"Les Boufmouths de guerre sont utilisés pendant leur sommeil comme des jouets par les Frigostiens les plus téméraires. Ces derniers tentent de lancer trois anneaux métalliques autour de chaque corne sans les réveiller. Fait surprenant, personne n\'a encore réussi à terminer ce jeu vivant.",ep:0,g:661,l:112,wd:false,fm:true,w:10,p:1};
I.u[11123] = {n:"Dent de sagesse de Boufmouth",t:24,d:"Vous avez arraché cette dent à un Boufmouth encore vivant. Mais qu\'est-ce qui vous est passé par la tête ?",ep:0,g:822,l:1,wd:false,fm:true,w:0,p:1};
I.u[11124] = {n:"Viscères congelés",t:24,d:"Ces viscères se sont congelés dès que vous les avez extraits de leur cavité corporelle.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11125] = {n:"Pied de Mansot",t:24,d:"Déjà qu\'il n\'était pas doué de ses bras, que va-t-il advenir du mansot à qui vous avez arraché ce pied ?",ep:0,g:823,l:1,wd:false,fm:true,w:0,p:1};
I.u[11126] = {n:"Crâne éthéré",t:24,d:"Comment un crâne peut-il être éthéré ? A bien y réfléchir, vous vous moquez éperdument de la réponse à cette question.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11127] = {n:"Larme au Rikain",t:24,d:"Cette larme, sans aucun rapport avec le Bar Rikain, symbolise l\'irréductibilité face à l\'oppression.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11128] = {n:"Larme magmatique",t:24,d:"A défaut de mouiller, cette larme brûle toute matière combustible avec laquelle elle entre en contact. Ainsi, aucun risque de voir dégouliner votre maquillage lorsque votre petit ami vous quittera pour sa dragodinde.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11129] = {n:"Givranchy",t:24,d:"Cet extrait de musc de Givrefoux fait fureur auprès de la gente féminine des Givrefoux. C\'est un excellent cadeau à offrir à vos prétendants ou rivaux.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11131] = {n:"Objet bizarre",t:24,d:"Il faut vraiment être un gros blaireau pour ne pas comprendre l\'utilité d\'un tel objet.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11132] = {n:"Cuillère",t:24,d:"Puisqu\'il n\'a plus sa cuillère, l\'ours va être obligé de manger avec les doigts et tout ça, par votre faute.",ep:0,g:824,l:1,wd:false,fm:true,w:0,p:1};
I.u[11133] = {n:"Plume Vibrante de mansot",t:94,d:"A l\'instar du Tofu Royal, certains mansots ont aussi une plume vibrante fortement imprégnée de magie. Quant à savoir son utilité...",ep:0,g:20,l:50,wd:false,fm:false,w:1,c:"Qc=555&Qa!555",u:true,p:500};
I.u[11134] = {n:"Apéwicube",t:94,d:"Un objet est emprisonné dans ce cube de glace découpé dans le lac gelé de Frigost. Pour découvrir de quoi il s\'agit, vous avez deux choix : attendre que la glace fonde ou, comme tout bon petit garnement impatient qui se respecte, taper dessus pour la briser.",ep:0,g:21,l:50,wd:false,fm:true,w:1,u:true,p:500};
I.u[11135] = {n:"Queue du Boufmouth légendaire",t:65,d:"Cette petite queue poilue légendaire était bien cachée sous la laine épaisse du Boufmouth légendaire. Ça ne vous a pas empêché de la trouver et de la lui arracher.",ep:0,g:752,l:118,wd:false,fm:true,w:10,p:1};
I.u[11136] = {n:"Laine de Boufmouth légendaire",t:57,d:"Elle est sale mais elle est légendaire. Elle vous rappelle quelqu\'un.",ep:0,g:212,l:118,wd:false,fm:true,w:10,p:1};
I.u[11137] = {n:"Morceau de Rat Bougri délavé",t:24,d:"C\'est tout ce qui reste des rats bougris de la cave de Grand-père. Vous n\'y êtes pas allé de main morte.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11138] = {n:"Graine de Pois",t:24,d:"Non, ce n\'est pas une cervelle de boufmouth que vous tenez dans votre main, mais une petite graine de pois. La différence est pourtant évidente : la graine de pois est froide au toucher.",ep:0,g:828,l:1,wd:false,fm:true,w:0,p:1};
I.u[11139] = {n:"Graine d\'Engrain",t:24,d:"Voici une version archaïque de la graine de blé utilisée couramment en Amakna. A croire que le temps s\'est arrêté sur l\'île de Frigost.",ep:0,g:829,l:1,wd:false,fm:true,w:0,p:1};
I.u[11140] = {n:"Graine Ola",t:24,d:"Autrefois utilisée dans de la farine pour biscuit, la culture de cette graine avait été interdite suite à un pari stupide. En effet, l\'ancien maire de Frigost avait parié avec un Ecaflip qu\'il ne mangerait qu\'un seul biscuit à base de farine de Graine Ola. Il a perdu son pari, et sa fortune avec.",ep:0,g:830,l:1,wd:false,fm:true,w:0,p:1};
I.u[11141] = {n:"Graine Deupin",t:24,d:"Cette petite graine provient d\'une Pomdeupin arrivée à maturité.",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11142] = {n:"Graine de Lentille",t:24,d:"En appliquant une graine de ce type sur chacun de vos yeux, vous n\'y verrez pas mieux. Par contre, vous aurez l\'air encore plus bête que d\'habitude lorsque quelqu\'un vous verra.",ep:0,g:832,l:1,wd:false,fm:true,w:0,p:1};
I.u[11143] = {n:"Grain de Sel",t:24,d:"C\'est en mettant son grain de sel partout que le Sparo a fini empalé dans un tonneau. Vous voilà prévenu.",ep:0,g:833,l:1,wd:false,fm:true,w:0,p:1};
I.u[11144] = {n:"Graine Hade",t:24,d:"Arracher la queue, compter deux secondes et jeter au loin. Si la Graine Hade touche un Atomystique, il laissera exploser sa colère. C\'est ainsi que les jeunes miliciens s\'entraînent au lancer de Graine Hade.",ep:0,g:834,l:1,wd:false,fm:true,w:0,p:1};
I.u[11145] = {n:"Graine Haye",t:24,d:"Cette graine est surtout utilisée par les jeunes des bas-quartiers pour agresser les gens civilisés. Vous vous demandez sans doute comment cela est possible ? Mieux vaut ne pas le savoir, vraiment.",ep:0,g:835,l:1,wd:false,fm:true,w:0,p:1};
I.u[11146] = {n:"Graine de Basalte",t:24,d:"Cette graine a survécu à un réchauffement suivi d\'un refroidissement extrême, ce qui l\'a rendu cassante et fragile.",ep:0,g:836,l:1,wd:false,fm:true,w:0,p:1};
I.u[11147] = {n:"Graine Houille",t:24,d:"Cette graine possède une haute teneur en carbone et coasse les nuits de pleine lune. Il faut être sacrément idiot ou un Iop pour croire à de telles sornettes.",ep:0,g:837,l:1,wd:false,fm:true,w:0,p:1};
I.u[11148] = {n:"Grain de Malice",t:24,d:"Une vieille légende raconte que la farine issue de cette graine était utilisée pour la fabrication des pains de paninis au steak de démon, plat préféré du seigneur démon Rushu. Aujourd\'hui encore, les Frigostiens s\'en méfient.",ep:0,g:838,l:1,wd:false,fm:true,w:0,p:1};
I.u[11149] = {n:"Graine de Star",t:24,d:"Si vous aussi, vous voulez ressembler à Pioufe la Maquillée, cette graine est faite pour vous. Grâce à elle, vous pourrez vous trémousser en beuglant sous les applaudissements. Attention cependant, son effet est très éphémère.",ep:0,g:839,l:1,wd:false,fm:true,w:0,p:1};
I.u[11156] = {n:"Yucca Lélé",t:24,d:"Cette fleur a été popularisée par le crieur public Julien Dobé. Depuis, tous les crieurs publics l\'aborent.",ep:0,g:841,l:1,wd:false,fm:true,w:0,p:1};
I.u[11157] = {n:"Tulipe Ossucion",t:24,d:"Réduite en poudre et bouillie, cette tulipe est préconisée dans les régimes pour perdre du poids rapidement. L\'inconvénient, c\'est que le poids de vos kamas diminue d\'autant.",ep:0,g:842,l:1,wd:false,fm:true,w:0,p:1};
I.u[11158] = {n:"Rose Nelson",t:24,d:"Découverte par le célèbre botaniste Yosef, cette rose dégage un doux parfum de crotte de fricochère arômatisée à la sueur. De quoi vous rappeler des souvenirs intimes.",ep:0,g:843,l:1,wd:false,fm:true,w:0,p:1};
I.u[11159] = {n:"Mime Osamodas",t:24,d:"L\'ombre de cette fleur rappelle la silhouette des Osamodas.",ep:0,g:844,l:1,wd:false,fm:true,w:0,p:1};
I.u[11160] = {n:"Rhubarbe à papa",t:24,d:"C\'est le seul souvenir qu\'il vous reste de votre père. Vous auriez préféré un manoir et beaucoup de kamas, mais la vie est trop injuste.",ep:0,g:845,l:1,wd:false,fm:true,w:0,p:1};
I.u[11161] = {n:"Saule en si",t:24,d:"Une association de lutte contre les maladies frigostiennes a fait de cette fleur son emblème. Son slogan : sortez couvert.",ep:0,g:846,l:1,wd:false,fm:true,w:0,p:1};
I.u[11162] = {n:"Rose à lys Cullen",t:24,d:"Un seigneur du temps Xélor a découvert cette superbe fleur, dont il fut obligé de se séparer à regret.",ep:0,g:847,l:1,wd:false,fm:true,w:0,p:1};
I.u[11163] = {n:"Rose Delima",t:24,d:"On dit de cette rose qu\'elle est bénie par les dieux, ce qui n\'est pas votre cas.",ep:0,g:848,l:1,wd:false,fm:true,w:0,p:1};
I.u[11164] = {n:"Ellébore d\'Hel",t:24,d:"Cette fleur est utilisée par les gens de petite vertu pour se reconnaître entre eux. Les autres les reconnaissent également.",ep:0,g:849,l:1,wd:false,fm:true,w:0,p:1};
I.u[11165] = {n:"Bétoine Agayne",t:24,d:"Fut un temps, mâcher cette fleur était à la mode dans les milieux Iops branchés. Ils pensaient que ça leur donnait l\'air intelligent. C\'aurait pu être vrai, si les Iops eussent été capables de penser.",ep:0,g:850,l:1,wd:false,fm:true,w:0,p:1};
I.u[11166] = {n:"Lys Ander",t:24,d:"Le nom de cette fleur fait hommage à Ander, célèbre commandant de la flotte militaire de Frigost, qui mourut en frappant sa tête contre le mur de la maison de son rival Al Hiartus.",ep:0,g:851,l:1,wd:false,fm:true,w:0,p:1};
I.u[11167] = {n:"Lys Onbobet",t:24,d:"Le boulanger de cinq mains utilisait cette fleur pour parfumer ses pains. C\'est grâce à elle qu\'il remporta trois fois le tour des boulangers de Frigost, entre 583 et 585.",ep:0,g:852,l:1,wd:false,fm:true,w:0,p:1};
I.u[11174] = {n:"Clef du Donjon des Boufmouths",t:84,d:"Cette clef permet d\'entrer dans la serre où se terre le Royalmouth.",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[11175] = {n:"La clef mansot",t:84,d:"Cette clef à forte teneur en amiante flotte très bien sur l\'eau et sur la vinaigrette. Elle permet aussi d\'entrer dans le donjon des mansots.",ep:0,g:255,l:1,wd:false,fm:true,w:1,p:1};
I.u[11182] = {n:"Moumoute du Royalmouth",t:24,d:"Une chose est sûre : sans sa moumoute, l\'autorité du royalmouth va prendre un sacré coup.",ep:0,g:826,l:1,wd:false,fm:true,w:0,p:1};
I.u[11183] = {n:"Poisskaille royal",t:24,d:"Le Mansot Royal en personne s\'est servi de ce poisskaille contre vous. Qu\'importe son origine, il finira en grillade comme un vulgaire poisskaille.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11184] = {n:"OBJET QUETE BOSS DONJON 3",t:24,d:"OBJET QUETE BOSS DONJON 3",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11185] = {n:"OBJET QUETE BOSS DONJON 4",t:24,d:"OBJET QUETE BOSS DONJON 4",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11186] = {n:"OBJET QUETE BOSS DONJON 5",t:24,d:"OBJET QUETE BOSS DONJON 5",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11187] = {n:"OBJET QUETE BOSS DONJON 6",t:24,d:"OBJET QUETE BOSS DONJON 6",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11188] = {n:"OBJET QUETE BOSS DONJON 7",t:24,d:"OBJET QUETE BOSS DONJON 7",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11189] = {n:"OBJET QUETE BOSS DONJON 8",t:24,d:"OBJET QUETE BOSS DONJON 8",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11190] = {n:"Cadeau Amulette du YeCh\'Ti",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11191] = {n:"Bottes du Nettoyeur de donjon",t:11,d:"Leurs semelles sont usées mais elles sont très confortables. Elles ont foulé le sol des donjons les plus dangereux ainsi que la tête des monstres les plus hargneux.",ep:0,g:162,l:73,wd:true,fm:true,w:10,an:0,p:13700};
I.u[11192] = {n:"Cadeau Nettoyeur de donjon",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11193] = {n:"Planche en Tremble",t:95,d:"Cette planche permet aux bricoleurs de construire des trucs en bois, comme un cercueil en planches par exemple.",ep:0,g:23,l:100,wd:false,fm:true,w:10,p:10};
I.u[11194] = {n:"Farine de Frostiz",t:52,d:"Cette farine a la particularité de se dissoudre dans le lailait pour lui donner un goût chocolaté. Les habitants d\'une île disparue, adeptes des desserts à base de gelée, préféraient la dissoudre dans de l\'eau.",ep:0,g:260,l:100,wd:false,fm:true,w:1,p:1};
I.u[11195] = {n:"Le rube",t:30,d:"Vous devriez vous faire soigner avant que votre état ne s\'aggrave.",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11196] = {n:"Kama de glace",t:24,d:"Ne pouvant frapper de nouvelle monnaie faute de métal, les Frigostiens ont taillé des kamas dans la glace dont ils se servent pour troquer divers objets locaux. Cette monnaie n\'a aucune valeur à l\'extérieur de l\'île.",ep:0,g:825,l:1,wd:false,fm:true,w:0,p:1};
I.u[11197] = {n:"La Zinuzide",t:30,d:"La campagne de vaccination contre cette maladie a déjà coûté à la bourgade de Frigost la modique somme de 2 milliards de Kamas et n\'a eu aucun résultat significatif. A croire que les Frigostiens aiment jeter leurs kamas par les fenêtres.",ep:0,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11198] = {n:"Vaccin contre le rube",t:24,d:"Ce vaccin protège efficacement contre le rube, mais ses effets se dissipent très vite. Il faut donc le renouveler toutes les semaines.",ep:0,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[11199] = {n:"Graine de Frostiz",t:58,d:"Cette graine, froide au toucher, dégage une forte odeur de cacao.",ep:0,g:0,l:100,wd:false,fm:true,w:1,p:1};
I.u[11200] = {n:"Cadeau Bouclier hispanique",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[11201] = {n:"Echantillon de sang de Boufmouth",t:24,d:"Vous avez prélevé cet échantillon de sang sur un boufmouth atteint du rube.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11202] = {n:"Eau de mer isotonique",t:24,d:"Albert Paisse a besoin de cette eau pour ses recherches d\'un vaccin contre le rube.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[11203] = {n:"Armoise",t:24,d:"Cette mauvaise herbe est très prisée des alchimistes, des Eniripsas, et des alchimistes Eniripsa. Une plante analogue à cette dernière sert à la confection d\'une puissante liqueur très appréciée des marins, des Enutrofs, et des marins Enutrofs.",ep:0,g:103,l:1,wd:false,fm:true,w:0,p:1};
I.u[11204] = {n:"Echantillon de sang de La Bête",t:24,d:"Vous avez prélevé cet échantillon de sang non sans mal. Espérons que son utilité se montrera à la hauteur de vos efforts.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11205] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 1H et avant 4H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11206] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 4H et avant 7H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11207] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 7H et avant 10H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11208] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 10H et avant 13H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11209] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 13H et avant 16H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11210] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 16H et avant 19H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11211] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 19H et avant 22H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11212] = {n:"Horaires de rendez-vous",t:24,d:"Vous avez rendez-vous à la taverne avec le Capitaine Gneux à partir de 22H et avant 1H.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11213] = {n:"Tiques de Boufmouth",t:24,d:"Plus résistantes qu\'un slip en kriptonite du Captain Chafer et plus agressives qu\'un troupeau de traqueurs astrubiens, ces tiques sont un véritables fléau pour leur hôte.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[11214] = {n:"Sang de Boufmouth parasité",t:24,d:"Cet échantillon de sang a été prélevé sur un Boufmouth parasité par des tiques.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11215] = {n:"Sang de Boufmouth de guerre parasité",t:24,d:"Cet échantillon de sang a été prélevé sur un Boufmouth de guerre parasité par des tiques.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11216] = {n:"Sang de Boufmouth légendaire parasité",t:24,d:"Cet échantillon de sang a été prélevé sur un Boufmouth légendaire parasité par des tiques.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11217] = {n:"Sang de Bouftonmouth parasité",t:24,d:"Cet échantillon de sang a été prélevé sur un Bouftonmouth parasité par des tiques.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11218] = {n:"Enveloppe pour Otomaï",t:24,d:"Wogew l\'hewmite vous a chargé de remettre cette enveloppe à Otomaï. Elle contient divers documents utiles sur les tiques qui parasitent les boufmouths mais aussi les wabbits.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[11219] = {n:"Queue du Royalmouth",t:65,d:"En été, cette queue permet au Royalmouth de faire fuir les Moskitos. Le reste de l\'année elle ne lui sert à rien et il lui arrive d\'oublier qu\'elle existe.",ep:0,g:755,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11221] = {n:"Laine du Royalmouth",t:57,d:"Personne ne sait réellement quand les Boufmouths sont arrivés sur Frigost. Ce qui est certain c\'est qu\'ils sont là depuis longtemps, car l\'on retrouve encore des sous-vêtements en laine de Boufmouth ayant servi à plusieurs générations de Frigostiens.",ep:0,g:213,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11222] = {n:"Bec du Timansot",t:47,d:"Quand il n\'est pas accroché fermement à la tête du Timansot, ce bec est planté fermement dans vos fesses.",ep:0,g:662,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11223] = {n:"Plume du Timansot",t:53,d:"Les Timansots ne venaient autrefois sur l\'île de Frigost que l\'hiver pendant quelques jours. Maintenant que l\'île est glacée, ils ont décidé de rester. Voilà une bonne occasion de leur voler dans les plumes tout au long de l\'année.",ep:0,g:646,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11224] = {n:"Aile de Mansobèse",t:104,d:"Les Frigostiens se sont souvent demandé à quoi pouvaient servir ces ailes ridicules qui ne permettent même pas au Mansobèse de pouvoir espérer décoller.",ep:0,g:216,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11225] = {n:"Peau de Mansobèse",t:59,d:"Elle est très grasse, rarement lavée et elle brille. Il ne s\'agit pas de votre perruque mais bien de la peau du Mansobèse.",ep:0,g:49,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11226] = {n:"Huile de Mamansot",t:60,d:"Cette huile est extraite d\'une Mamansot. Vous essayez désespérément de ne pas vous rappeler de la façon dont vous l\'avez obtenue.",ep:0,g:72,l:125,wd:false,fm:true,w:10,an:0,p:10};
