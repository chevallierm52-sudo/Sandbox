I.u[10955] = {n:"Anneau du Corbeau Noir",t:9,d:"Quoi de plus normal pour un volatile que d\'être bagué !",ep:0,g:188,l:33,wd:false,fm:true,w:10,s:155,p:3150};
I.u[10956] = {n:"Bottes du Corbeau Noir",t:11,d:"Cette paire de bottes, comme tout le reste de la panoplie du Corbeau Noir, est passée de pied en pied à travers les âges. Ce qui explique sa forte odeur de Clakoss...",ep:0,g:158,l:32,wd:false,fm:true,w:10,s:155,p:2850};
I.u[10957] = {n:"Cape du Corbeau Noir",t:17,d:"Du fil, une aiguille, quelques plumes prélevées sur des dépouilles de Corbacs en décomposition, et vous voilà en possession de la plus chic des capes !",ep:0,g:174,l:35,wd:false,fm:true,w:10,s:155,p:3400};
I.u[10958] = {n:"Casque du Corbeau Noir",t:16,d:"Inutile de vous cacher ! On vous a démasqué, c\'est donc vous, le Corbeau Noir !",ep:0,g:259,l:32,wd:false,fm:true,w:10,s:155,p:2900};
I.u[10959] = {n:"Pik Epik du Corbeau Noir",t:6,d:"Vous y avez laissé des plumes, mais la voilà enfin entre vos mains ! L\'épée du Corbeau Noir...",ep:0,g:98,l:39,wd:false,fm:true,w:10,an:14,e:[13,5,1,1,40,50,false,false],c:"CA>60&CV>60",s:155,p:4400};
I.u[10960] = {n:"Cadeau Anneau du Corbeau Noir",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10961] = {n:"Cadeau Pik Epik du Corbeau Noir",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10962] = {n:"Bâton de Rapine",t:4,d:"Rien de tel que ce bâton usé pour curer les égouts ou le nez de vos adversaires tombés au sol et incapables de boucher leurs narines. Cette arme est encore imprégnée de la magie de Rapine. Vous pourrez peut-être réussir à l\'incarner en utilisant cette arme.",ep:0,g:92,l:30,wd:false,fm:false,w:10,an:12,e:[6,3,1,1,50,50,false,false],c:"CV>30",s:156,p:2650};
I.u[10963] = {n:"Bottes de Rapine",t:11,d:"La semelle de ces bottes est spongieuse, elle permet d\'absorber la boue des égouts et de la diffuser à chaque pas. Vous pourrez ainsi facilement revenir sur vos pas.",ep:0,g:156,l:32,wd:false,fm:true,w:10,s:156,p:2900};
I.u[10964] = {n:"Ceinture de Rapine",t:10,d:"Cette ceinture permettait à Rapine d\'y accrocher son butin. On peut apercevoir sur la face intérieure une petite valve qui permet de la gonfler et de la transformer en bouée. Indispensable pour toutes les sorties dans les égouts.",ep:0,g:172,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10965] = {n:"Amulette de Rapine",t:1,d:"Cette amulette a été spécialement conçue pour ne pas se coincer dans les poils du cou de Rapine. Vous pourrez donc la porter sans crainte sur vos aisselles ou même la garder dans votre main.",ep:0,g:160,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10966] = {n:"Transformation en larve",t:31,d:"Les mauvaises langues insinueraient que cela révèle votre nature profonde. Ont-elles vraiment tort ?",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=21",p:0};
I.u[10967] = {n:"Cervelle de larve",t:69,d:"Il faut vraiment être désespéré pour manger ça. Non, ne faites pas ça !",ep:0,g:113,l:1,wd:false,fm:true,w:0,c:"Sc=21",u:true,ut:true,p:1};
I.u[10968] = {n:"Transformation en wabbit",t:31,d:"Étonnamment, vous n\'avez pas envie de cawottes.",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=22",p:0};
I.u[10969] = {n:"Potion de Fwaîchew",t:12,d:"La douceur d\'une cawotte, la fraîcheur d\'une dragodinde marathonienne. Rien de tel pour vous remettre d\'aplomb. Santé !",ep:0,g:141,l:20,wd:false,fm:true,w:1,c:"Sc=22",u:true,ut:true,p:1};
I.u[10970] = {n:"Sueur de dragodinde",t:15,d:"Mais comment avez vous fait pour récupérer ça ? Et pourquoi ? Vous êtes vraiment bizarre.",ep:0,g:773,l:1,wd:false,fm:true,w:1,p:1};
I.u[10971] = {n:"Sac ripant",t:81,d:"Équipé de ce sac, vous pourrez faire les quatre cents coups. Et toujours avec le sourire, petit galopin va !",ep:0,g:25,l:20,wd:false,fm:true,w:10,c:"Sc=23",p:1};
I.u[10972] = {n:"Corbac suiveur",t:31,d:"Bien que très affectueux, vous soupçonnez ce volatile de fuir à tire-d\'ailes au premier signe de danger.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,c:"Sc=24",p:0};
I.u[10973] = {n:"Potion de destination inconnue",t:12,d:"Votre instinct vous dicte de ne pas avaler le contenu de ce bocal. En fait, c\'est surtout votre nez : cette mixture empeste comme les aisselles d\'un Bwork centenaire.",ep:0,g:189,l:20,wd:false,fm:true,w:1,c:"Sc=25",u:true,p:10};
I.u[10974] = {n:"Fée d\'artifice festive",t:74,d:"C\'est la fêêêêteuuuh, la fêêêêteuhh !",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"Sc=26",ut:true,p:1};
I.u[10975] = {n:"Epée de Phong Huss",t:6,d:"Elle sent le vieux Champmane mais sa poignée est en mousse. Cette arme est encore imprégnée de la magie de Phong Huss. Vous pourrez peut-être réussir à l\'incarner en utilisant cette arme.",ep:0,g:97,l:33,wd:false,fm:false,w:10,an:14,e:[12,6,1,1,40,60,false,false],c:"CS>50",s:157,p:3100};
I.u[10976] = {n:"Anneau de Phong Huss",t:9,d:"Les champignons portent généralement des collerettes, mais Phong Huss préférait les anneaux. Peut-être parce qu\'il voulait se vanter d\'avoir des doigts.",ep:0,g:185,l:33,wd:false,fm:true,w:10,s:157,p:3150};
I.u[10977] = {n:"Ceinture de Phong Huss",t:10,d:"Phong Huss portait cette ceinture n\'importe comment, il essayait de la porter en bandoulière pour y coincer l\'étui de son sabre. Cette ceinture lui pinça les tétons à de multiples reprises, mais elle n\'eut pas d\'autre utilité significative.",ep:0,g:170,l:30,wd:false,fm:true,w:10,s:157,p:2650};
I.u[10978] = {n:"Bottes de Phong Huss",t:11,d:"Les pieds des champignons sont rarement très propres, ils sont souvent recouverts de mycélium. Ceux de Phong Huss n\'échappaient pas à cette règle et il prenait soin de les cacher avec ses bottes. Elles ne sentent pas très bon, mais elles sont particulièrement adaptées à la culture des champignons. Qui de votre estomac ou de votre nez l\'emportera ?",ep:0,g:153,l:32,wd:false,fm:true,w:10,s:157,p:2900};
I.u[10979] = {n:"Marteau d\'Hectaupe",t:7,d:"Hectaupe prenait un malin plaisir à traîner cette arme derrière-lui. On le savait fainéant comme un Bouftou, mais il voulait avant tout prévenir ses adversaires de son arrivée fracassante. Cette arme est encore imprégnée de la magie d\'Hectaupe. Vous pourrez peut-être réussir à l\'incarner en utilisant cette arme.",ep:0,g:74,l:30,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,50,50,false,false],c:"CA>50",s:158,p:2800};
I.u[10980] = {n:"Amulette d\'Hectaupe",t:1,d:"L\'amulette de ce fantôme ne peut être qu\'un objet magique très puissant, si l\'on fait confiance aux légendes sur les fantômes.",ep:0,g:159,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10981] = {n:"Anneau d\'Hectaupe",t:9,d:"C\'est bien connu, les véritables fantômes n\'ont pas de doigts. Alors comment explique-t-on qu\'ils puissent porter des anneaux ?",ep:0,g:186,l:32,wd:false,fm:true,w:10,s:158,p:2970};
I.u[10982] = {n:"Ceinture d\'Hectaupe",t:10,d:"Le Kapitaine Kradoc a jadis rencontré Hectaupe en sortant d\'une soirée un peu arrosée à la taverne du Ripate. \"Ectoplasme à roulettes\" s\'exclama-t-il en hurlant. Pauvre Kapitaine Kradoc, l\'alcool lui jouait de mauvais tours, Hectaupe n\'a jamais eu de roulettes.",ep:0,g:171,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10984] = {n:"Amulette du YeCh\'Ti",t:1,d:"En la posant sur votre torse imberbe, vous pourrez faire croire à vos ennemis que vous êtes aussi poilu que le YeCh\'Ti, ce qui ne manquera pas de les effrayer.",ep:0,g:162,l:66,wd:false,fm:false,w:10,an:0,p:11500};
I.u[10985] = {n:"Chacha des Glaces",t:18,d:"Ce Chacha a connu l\'hiver du grand nord, même s\'il n\'a jamais vu le grand nord. Personne ne sait comment il a pu arriver en Amakna, les anciens prétendent qu\'il aurait été importé de l\'île de Frigost pour lutter contre la prolifération des Wabbits. Ce familier dévoreur d\'âmes ne mange que les Wabbits.",ep:0,g:62,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10986] = {n:"Fantôme de Chacha des Glaces",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[10987] = {n:"Givrature",t:10,d:"Elle refroidit les hanches, les organes situés à proximité et les ardeurs de tous ceux qui osent la porter. A offrir à vos courtisans un peu trop entêtés.",ep:0,g:173,l:35,wd:false,fm:true,w:10,s:141,p:3500};
I.u[10988] = {n:"Givracoiffe",t:16,d:"Pour garder la tête froide et les idées fraîches, cette coiffe est idéale. Pour ressembler à autre chose qu\'un vulgaire glaçon, vous devrez en trouver une autre.",ep:0,g:260,l:35,wd:false,fm:true,w:10,s:141,p:3450};
I.u[10989] = {n:"Givracape",t:17,d:"Francisque Kabroule portait une cape similaire lors de son fameux concert dans la clairière de Brouce Boulgoure. Ceux qui n\'ont pas fini sourds se souviennent encore de l\'apothéose de ce concert, lorsque Francisque Kabroule s\'arrêta de chanter après avoir été pris dans la glace à cause de sa propre cape.",ep:0,g:175,l:33,wd:false,fm:true,w:10,s:141,p:3150};
I.u[10990] = {n:"Givrabottes",t:11,d:"Lourdes et rigides, ces bottes ne semblent pas très intéressantes. Mais leur semelle de glace vous permettra de faire du patin à glace sans glace. À condition de trouver une surface recouverte de lames de patins à glace.",ep:0,g:159,l:33,wd:false,fm:true,w:10,s:141,p:3000};
I.u[10991] = {n:"Cadeau Chacha des Glaces",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
