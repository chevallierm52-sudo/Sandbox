I.u[11070] = {n:"Hata Marie",t:32,d:"Prisonnière des Bworks, elle souhaite que vous l\'escortiez en dehors du village.",ep:0,g:30,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[11071] = {n:"Extrait des origines de Goultard.",t:25,d:"Tachés, maculés, froissés, ces quelques feuillets sont presque illisibles. Toutefois, derrière l\'épaisse crasse vous arrivez à lire quelques mots. Ces pages sont extraites d\'un ouvrage oublié traitant des origines de Goultard.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
