I.u[11077] = {n:"Marteau de Lonne",t:7,d:"Quand il s\'agit de sonner l\'adversaire, Lonne Jenone a plus d\'une corde à son violon. D\'ailleurs, il s\'en sert comme d\'un Marteau... Une chose est sûre : ça va barder !",ep:0,g:75,l:54,wd:false,fm:true,w:20,an:0,e:[6,5,1,1,42,50,false,false],c:"CA>20&CV>40",s:163,p:9700};
I.u[11078] = {n:"Cape de Lonne",t:17,d:"Cette cape en cuir, pourtant légère, vous accompagnera lors de vos chevauchées fantastiques à dos de Dragodinde...",ep:0,g:176,l:55,wd:false,fm:true,w:10,an:0,s:163,p:7900};
I.u[11079] = {n:"Chapeau de Lonne",t:16,d:"Avant d\'être porté par Lonne Jenone, ce chapeau appartenait à un certain Sergent Pépeur. Un type plutôt tranquille qui n\'était pas du genre à ramener son grain de sel.",ep:0,g:261,l:55,wd:false,fm:true,w:10,an:0,s:163,p:8050};
I.u[11080] = {n:"Bottes de Lonne",t:11,d:"Cette paire de bottes souple vous garantira une totale liberté de mouvement. C\'est d\'ailleurs pour cette raison que Lonne Jenone les porte lorsqu\'il danse avec les Mulous.",ep:0,g:160,l:55,wd:false,fm:false,w:10,an:0,s:163,p:7925};
I.u[11082] = {n:"Bottes de Boufbowl",t:11,d:"Ces bottes ont été spécialement conçues pour détruire les protèges-tibias de vos adversaires, puis leurs tibias et ensuite vos propres orteils.",ep:0,g:157,l:28,wd:false,fm:true,w:10,an:0,c:"Sc=11",p:2300};
I.u[11083] = {n:"Bague de Boufbowl",t:9,d:"Cette bague permet d\'éventrer la Boufballe lorsque vous voulez discrètement profiter d\'un arrêt de jeu.",ep:0,g:187,l:31,wd:false,fm:true,w:10,an:0,c:"Sc=12",p:2666};
I.u[11084] = {n:"Chapeau de Gadjète",t:16,d:"Gadjète était l\'un des bricoleurs les plus créatifs du Monde des 12. Malheureusement il était également l\'un des plus étourdis. On raconte qu\'il a confondu son enclume et la tête de sa femme plus d\'une fois et qu\'elle ne s\'en plaignait pas.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6400};
I.u[11085] = {n:"Ceinture de Gadjète",t:10,d:"En mettant cette ceinture à l\'envers et en la serrant suffisamment fort, vous pourrez peut-être activer le module intégré de rétromagie. Il n\'a jamais fonctionné, mais vous pourrez l\'activer tout de même. Vous pourrez donc la revendre à une personne aussi naïve que vous.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6358};
I.u[11086] = {n:"Cape de Gadjète",t:17,d:"Gadjète a fabriqué cette cape en espérant qu\'elle puisse lui permettre de voler et ainsi échapper plus facilement aux punitions administrées quotidiennement par sa femme.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6350};
I.u[11087] = {n:"Anneau de Gadjète",t:9,d:"Porté par plusieurs générations de Bricoleurs, cet anneau protège une phalange de vos coups de marteau. Malheureusement, il n\'est jamais vendu par lot de cinq.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6453};
I.u[11088] = {n:"Coiffe de Grilliane",t:16,d:"Grilliane était un très grand magicien, célèbre pour avoir réinventé la poudre d\'escampette, après avoir oublié comment la fabriquer.",ep:0,g:0,l:49,wd:false,fm:true,w:10,s:164,p:6325};
I.u[11089] = {n:"Cape de Grilliane",t:17,d:"Cette cape est censée protéger votre postérieur des morsures de monstroplantes.",ep:0,g:0,l:48,wd:false,fm:true,w:10,s:164,p:6250};
I.u[11090] = {n:"Avis de recherche.",t:24,d:"Cet avis de recherche cible Léthaline Sigibul.",ep:0,g:821,l:1,wd:false,fm:true,w:0,p:0};
I.u[11091] = {n:"Bottes de Grilliane",t:11,d:"Grilliane le magicien a échangé un anneau magique contre cette paire de bottes. Il semblerait qu\'il ait perdu au change puisqu\'elles ne sont même pas rembourrées.",ep:0,g:0,l:46,wd:false,fm:true,w:10,an:0,s:164,p:5600};
I.u[11092] = {n:"Amulette de Grilliane",t:1,d:"Grilliane portait cette amulette autour du coup lorsqu\'il... Lorsqu\'il... Quelle importance ? Il est mort et désormais cette amulette vous appartient.",ep:0,g:0,l:45,wd:false,fm:true,w:10,s:164,p:5450};
I.u[11093] = {n:"Cadeau Marteau de Lonne",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous. \nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
