I.u[11008] = {n:"Certificat de mise en Chanil : Chacha des Glaces",t:77,d:"Ce certificat décrit les caractéristiques du familier que vous avez placé au Chanil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[11009] = {n:"Hormone de Chacha des Glaces",t:48,d:"Cette hormone de croissance déshydratée peut être utilisée dans la confection d\'une puissante potion pour améliorer un familier.",ep:0,g:262,l:1,wd:true,fm:true,w:1,p:10};
I.u[11010] = {n:"Potion d\'amélioration de Chacha des Glaces",t:116,d:"En utilisant cette puissante potion, vous augmenterez les capacités de votre familier de façon définitive. Attention, une seule dose sera prise en compte par votre familier, plusieurs tentatives provoqueront des résultats décevants.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PO=10985",u:true,p:10};
I.u[11011] = {n:"Tifoux Tigré",t:18,d:"Plus fou que le Tifoux commun mais surtout beaucoup moins roux, ce familier peut être trempé dans l\'eau sans qu\'il ne soit nécessaire de se boucher le nez. Ce familier se nourrit des créatures qui vivent dans l\'Arbre Hakam.",ep:0,g:63,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11012] = {n:"Chienchien Tigré",t:18,d:"Ce n\'est pas parce qu\'il est tigré qu\'il ne cherchera pas à vous renifler le postérieur ou à se soulager sur votre tapis. Mais qu\'espériez-vous ? Ce familier adore chasser les créatures qui vivent dans les landes de Sidimote.",ep:0,g:64,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11013] = {n:"Kouin-Kouin Noir",t:18,d:"Ce vilain petit Kouin-Kouin Noir a été rejeté par sa propre famille car il était différent : il adorait écouter le chant du ménestrel Francisque Kabroule. Peut-être était-il tout simplement incompris...  Après une enfance difficile, il a décidé de se venger arbitrairement sur toutes les créatures de la famille des Corbacs. Il les dévore sans pitié.",ep:0,g:65,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11014] = {n:"Chauffe-souris Délavée",t:18,d:"Ce familier a dormi trop longtemps sous une pluie acide. Il ne brille pas la nuit, il n\'est pas magique, mais si vous en faites de la vinaigrette, elle sera très puissante. Ce familier se nourrit exclusivement de créatures de la famille des Gelées.",ep:0,g:66,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11015] = {n:"Gupin",t:18,d:"Cette étrange créature a traversé les océans sur un bloc de glace pour s\'échouer sur un port perdu. Elle semble désormais vous prendre pour un bloc de glace. Ce familier dévoreur d\'âmes ne mange que les monstres des plages.",ep:0,g:67,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[11016] = {n:"Fantôme de Tifoux Tigré",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
