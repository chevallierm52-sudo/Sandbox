I.u[11041] = {n:"Epée Hondbaz",t:6,d:"Lourde, peu maniable, émoussée et disgracieuse, comment Goultard a-t-il pu devenir un si redoutable combattant avec cette médiocre épée ? La manier ne vous rendra pas meilleur, juste ridicule.",ep:0,g:99,l:40,wd:false,fm:true,w:10,an:14,e:[6,4,1,1,40,40,false,false],s:159,p:4000};
I.u[11042] = {n:"Cordon Père au gnon",t:10,d:"Cadeau d\'un père pour son fils, cette ceinture fut remise à Goultard pour ses 5 ans. Bien que de simple facture, elle est solide et maintiendra votre pantalon sur vos hanches. Elle peut même servir de corde à linge ou de corde à sauter.",ep:0,g:175,l:40,wd:false,fm:true,w:10,s:159,p:4300};
I.u[11043] = {n:"Chapeau Kalipse",t:16,d:"Ce chapeau est tellement serré qu\'il compresse le crâne et provoque des hallucinations. Heureusement, Goultard le portait étant jeune et de plus, il a un crâne de petite taille. Cela trahit ses origines.",ep:0,g:265,l:41,wd:false,fm:true,w:10,s:159,p:4500};
I.u[11044] = {n:"Restes de la famille de Goultard",t:24,d:"Quelques ossements, des bijoux mortuaires, voilà votre funeste bagage.",ep:0,g:818,l:1,wd:false,fm:true,w:0,p:0};
I.u[11045] = {n:"Cape Stinence",t:17,d:"Goultard porta cette cape jusqu\'à ce qu\'il rencontre les trois sœurs. Il l\'oublia alors dans un vieux placard.",ep:0,g:179,l:43,wd:false,fm:true,w:10,s:159,p:5050};
I.u[11046] = {n:"Collier maudit de Cabotine.",t:24,d:"Vous arrivez à grand-peine à ne pas vous débarrassez de ce collier tant son aura maléfique est puissante.",ep:0,g:819,l:1,wd:false,fm:true,w:0,p:0};
I.u[11047] = {n:"Ze Rorc",t:32,d:"Ze rorc s\'est rendu, menez le prisonnier à Léthaline.",ep:0,g:29,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11048] = {n:"Indices pour Dark Vlad",t:24,d:"Un plan très simple et une potion d\'intelligence, avec ça, même Dark Vlad doit être en mesure de quitter son labyrinthe.",ep:0,g:820,l:1,wd:false,fm:true,w:0,p:0};
I.u[11049] = {n:"Clémentocoiffe",t:16,d:"Equipez cette coiffe, pelez-la pendant plusieurs heures, et vous trouverez sûrement un petit pépin.",ep:0,g:262,l:32,wd:false,fm:true,w:10,s:161,p:2900};
I.u[11050] = {n:"Clémentocape",t:17,d:"Cette cape diffuse une odeur d\'agrume autour de vous et vous transforme ainsi en un puissant piège à Moskitos.",ep:0,g:177,l:32,wd:false,fm:true,w:10,s:161,p:2850};
I.u[11051] = {n:"Clémentamulette",t:1,d:"En trempant cette amulette dans votre verre, votre eau insipide et se transformera en un délicieux breuvage arômatisé aux agrumes.",ep:0,g:161,l:32,wd:false,fm:true,w:10,s:161,p:2925};
I.u[11052] = {n:"Clémentobottes",t:11,d:"La semelle de ces bottes est confectionnée avec la peau rugueuse de fruits récoltés sur une île ensoleillée dont personne ne soupçonne l\'existence.",ep:0,g:161,l:34,wd:false,fm:true,w:10,an:0,s:161,p:3205};
I.u[11055] = {n:"Chapomdeupin",t:16,d:"Rembourrée en poils de Chacha et recouverte d\'écorce, cette coiffe est très inflammable. Il est déconseillé de s\'asseoir dessus si vous avez le feu aux fesses.",ep:0,g:263,l:41,wd:false,fm:true,w:10,an:0,s:162,p:4553};
I.u[11056] = {n:"Capomdeupin",t:17,d:"Lorsqu\'il fait chaud, les écailles de cette cape s\'écartent pour laisser s\'évaporer votre transpiration. Lorsqu\'il pleut, les écailles de cette cape s\'écartent pour laisser rentrer la pluie et vous rincer le postérieur.",ep:0,g:178,l:42,wd:false,fm:true,w:10,an:0,s:162,p:4875};
I.u[11057] = {n:"Ceinture Pomdeupin",t:10,d:"Cette ceinture est composée d\'écailles arrangées en spirale suivant la suite de Vibronacci.",ep:0,g:174,l:40,wd:false,fm:true,w:10,an:0,s:162,p:4305};
I.u[11058] = {n:"Anneau Pomdeupin",t:9,d:"Mais qui comptez-vous réussir à séduire avec un anneau pareil ?",ep:0,g:189,l:43,wd:false,fm:true,w:10,an:0,s:162,p:5100};
