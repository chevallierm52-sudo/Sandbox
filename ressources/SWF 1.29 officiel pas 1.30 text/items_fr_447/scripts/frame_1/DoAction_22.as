I.u[11036] = {n:"Potion d\'Amélioration de Tifoux Tigré",t:116,d:"En utilisant cette puissante potion, vous augmenterez les capacités de votre familier de façon définitive. Attention, une seule dose sera prise en compte par votre familier, plusieurs tentatives provoqueront des résultats décevants.",ep:0,g:63,l:1,wd:true,fm:true,w:1,c:"PO=11011",u:true,p:10};
