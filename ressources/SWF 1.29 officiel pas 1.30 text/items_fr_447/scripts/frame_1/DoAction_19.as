I.u[8808] = {n:"Etoffe du Roissingue",t:55,d:"Cette étoffe comporte plus de trous qu\'un gruyère, mais elle est pourtant capable d\'absorber un maximum de déchets. Là où cette étoffe passe, la crasse trépasse.",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"Culotte à l\'envers du Roissingue",t:15,d:"Depuis l\'habitude prise par le Roissingue Dagobert, tous les Roissingues portent la culotte à l\'envers. L\'important est que cette pratique ne leur retourne pas l\'estomac.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Tourbe séchée de Tourbassingue",t:15,d:"Faite à partir de végétaux en décomposition, cette tourbe possède un pouvoir absorbant étonnant. Les Mama Bworks s\'en servent pour régler un problème mensuel.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Faux menton du Bourbassingue",t:15,d:"Le Bourbassingue passe beaucoup de temps à prendre des bains de boue en espérant maigrir. Au lieu de perdre du poids, il a juste gagné un double menton pour harmoniser sa silhouette.",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Encre du Kralamoure géant",t:15,d:"Visqueuse et bien couvrante, l\'encre du Kralamoure peut servir à l\'écriture comme à la peinture des murs d\'une chambre de dépressif.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Ventouse du Kralamoure géant",t:15,d:"Vu la taille de cette ventouse, nul doute que l\'adhérence doit être bonne et, quand on la retire, le bruit de succion est tonitruant.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Bourse de 5000 Kamas",t:100,d:"Cette bourse est très lourde, elle contient sûrement une vraie fortune.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Bourse de 1000 Kamas",t:100,d:"Cette bourse est très lourde, elle contient sûrement une vraie fortune. Un marchand sera ravi de vous l\'échanger contre sa valeur en Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Cadeau Epée qui Pète",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Cadeau Chapeau Satanusse",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"Cape Souveraine du Roissingue",t:17,d:"Constituée d\'une étoffe de Roissingue, cette cape comporte des micro trous permettant une meilleure évacuation de la sueur en cas d\'effort intense, comme lors de mêlées belliqueuses en zone marécageuse. Cette cape laisse passer l\'humidité mais garde la chaleur. Ainsi, vous restez sec quelle que soit la situation. Dommage que l\'odeur persistante de moisissure soit inaltérable.",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Cape de la Ouassingue",t:17,d:"Moins performante que la Cape du Roissingue, cette cape présente néanmoins les mêmes avantages quant à l\'évacuation de la sueur. Avec elle, vous allez pouvoir faire face à toutes les situations... Si vous arrivez à combattre en apnée, car vu l\'odeur, il est vraiment impossible de ne pas défaillir.",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Masque du Sergent Zoth",t:16,d:"Grâce à ce masque, vous affronterez tous les dangers sans aucune crainte ! C\'est normal vu qu\'il obstrue tout le champ de vision.",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Coiffe du Disciple Zoth",t:16,d:"De loin, cette coiffe ressemble à un abat-jour avec deux trous pour les yeux. De près, aussi.",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Masque de l\'Abrakleur clair",t:16,d:"Ce masque ne permet ni de prévenir ni de guérir la gueule de bois, mais il vous donne au moins l\'occasion de la dissimuler de façon élégante.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Masque de l\'Abrakleur sombre",t:16,d:"Ce masque ne permet ni de prévenir ni de guérir la gueule de bois, mais il vous permet au moins de la dissimuler de façon élégante. La nuance sombre indique juste que vous êtes de mauvaise humeur et qu\'il ne faut pas vous chauffer longtemps pour que vous lanciez à tout le monde une volée de bois vert.",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Kaskargo",t:16,d:"Avec ça sur le crâne, vous aurez l\'air d\'un Kaskargo. Certes vous serez protégé des coups à la tête, mais est-ce une raison pour baver ainsi ? Vous n\'avez pourtant pas besoin de ça pour vous déplacer !",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Masse du Corailleur Magistral",t:7,d:"Plus grande, plus lourde, plus puissante, cette masse s\'abat plus bruyamment sur les ennemis. Mais curieusement, elle est plus légère et d\'une prise en main plus agréable. Le Corailleur dont on s\'est servi pour la confectionner n\'était pas magistral pour rien.",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Marteau de la Gamine Zoth",t:7,d:"Malgré sa petite taille, la Gamine Zoth arbore un immense marteau. C\'est une façon comme une autre de renforcer la musculature. Pas besoin de mettre des poids aux pieds ou aux poignets pour augmenter la force : traîner le marteau est bien suffisant !",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Hache du Guerrier Zoth",t:19,d:"Le Guerrier Zoth a pris l\'habitude de porter deux haches, car il est incapable de toucher le flanc gauche de son ennemi avec sa main droite. Problème de schéma corporel ou maladresse congénitale ? Difficile de se prononcer là-dessus. Mais avec ses deux haches, il fait feu de tout bois à défaut de s\'en servir pour couper des rondins.",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Perruque du Poolay",t:16,d:"Le Poolay est un volatile malhabile qui a autant de vivacité qu\'une poule atteinte de grippe aviaire et une intelligence comparable à celle du Tofu. Autant dire qu\'il était mal parti pour survivre. Pourtant certains semblent adorer sa curieuse chevelure évoquant une serpillère tressée en nattes par une ménagère teutonne. La nature humaine est décidément bien étrange.",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Chapeau de Barbroussa",t:16,d:"Ce chapeau était suffisamment large pour dissimuler la tête et la barbe ridiculement peu fournie de Barbroussa. Mais il n\'est pas capable de couvrir le crâne de quelqu\'un ayant la grosse tête.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8832] = {n:"Bave du Kaskargo",t:15,d:"La bave du Kaskargo ne peut jamais atteindre le plumage du Bitouf, mais elle peut vous engluer au sol.",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Masse du Corailleur",t:7,d:"Ce marteau tire sa jolie couleur des morceaux de Corailleur qui le composent. Contrairement à ce que l\'on pourrait croire, il ne servait pas initialement à écrabouiller les Iops ou les ennemis. En réalité, il s\'agit d\'un objet d\'artisanat laissé par une ancienne civilisation. Cette masse servait de heurtoir pour que les personnes ayant des problèmes d\'audition puissent comprendre que quelqu\'un frappe à la porte.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Branche de l\'Abrakleur sombre",t:3,d:"Cette branche servait à racler certaines parties du corps inaccessibles autrement. Mais rassurez-vous, la couleur sombre est d\'origine. Aucun rapport avec les dépôts contenus dans les cavités les plus inaccessibles de l\'Abrakleur.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Branche de l\'Abrakleur clair",t:3,d:"Cette branche servait à racler certaines parties du corps inaccessibles autrement. Ceci explique peut-être l\'odeur étrange de cette branche.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Tige du Brouture",t:4,d:"Les Broutures se servent de leur tige pour se nettoyer les oreilles. Les sculpteurs de bâton préfèrent les employer comme arme. Comme quoi, les goûts et les couleurs, ça ne discute pas.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Bâton du Maître Zoth",t:4,d:"Le Maître Zoth est capable de vaincre n\'importe qui avec son bâton. Aucun adversaire ne lui fait peur ! Et c\'est bien normal. Vu qu\'avec sa coiffe il ne voit rien, il ne peut pas être terrorisé par son ennemi. Cette technique bien pratique au combat est toutefois problématique lorsqu\'il s\'agit de prendre les repas. Ayant un champ de vision limité, le Maître Zoth a toujours eu quelques problèmes pour manger sans en mettre partout.",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Rhizome du Tynril",t:4,d:"Telle la mauvaise herbe, le Tynril est capable de se reproduire à l\'infini grâce à un simple bout de rhizome. C\'est à partir de cette constatation que certains sculpteurs ont créé un bâton à base de Tynril. Ils espéraient pouvoir le reproduire facilement et à moindre frais pour le revendre au plus offrant. C\'est raté.",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Masque Vaudou Thierry",t:16,d:"Ce masque Vaudou sert essentiellement à masquer le visage des Kannibouls qui aiment la fronde (comme Thierry), mais qui ratent souvent leur cible. C\'est pourquoi, ils sont toujours un peu verts de rage.",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Masque Vaudou Jav",t:16,d:"Les Kannibouls Jav ont souvent le \"blues\" et peignent leur coiffe en bleu. Est-ce lié à un chagrin d\'amour ou à une autre raison ? Difficile de connaître le fin mot de cette histoire. Mais ce serait bien qu\'ils se contentent de porter le masque et qu\'ils arrêtent de chanter leur mélancolie.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Masque Vaudou Sarbak",t:16,d:"À force de rire jaune car ils loupent leur objectif, certains Kanniboules ont peint leur masque de cette couleur. Ainsi, même lorsqu\'ils rient de bon cœur, on a l\'impression qu\'ils se forcent.",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Masque Vaudou Archer",t:16,d:"Les Kannibouls Archer n\'arrivaient pas à se concentrer et à bien viser sauf lorsqu\'ils étaient très en colère. Ainsi, pour être toujours sur de voir rouge, ils ont peint leur masque dans cette couleur.",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Chapeau de Crocodaille Dandi",t:16,d:"Avec ce chapeau sur le crâne, le Crocodaille pense être à la pointe de la mode. Il faudrait que celle-ci soit vraiment bien émoussée pour ce que cela soit possible. Mais il vaut mieux éviter de lui faire remarquer son côté ridicule. Le Crocodaille est très susceptible...",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"Capuche Souveraine du Roissingue",t:16,d:"Coiffe royale, cette capuche possède les mêmes vertus que la Cape du Roissingue. Ses micro-aérations contribuent à une meilleure évacuation de la sueur pour toujours garder la tête froide. Hélas, elle possède également les défauts de la cape : son odeur nauséabonde est si présente qu\'on pourrait presque la découper au couteau.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Capuche de la Ouassingue",t:16,d:"Moins efficace que la Coiffe royale, cette capuche permet toutefois une très bonne évacuation de la sueur. Un peu trop bonne, en fait. Du coup, que l\'on porte la capuche ou qu\'on ne la porte pas ne fait aucune différence.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Chapeau de la Gamine Zoth",t:16,d:"Le Chapeau de la Gamine Zoth a la particularité de lui faire voir les choses en double. Ainsi, lorsqu\'elle voit une personne de sa tribu, elle zoth zoth.",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Casque du Guerrier Zoth",t:16,d:"Ce casque a les mêmes avantages que les autres coiffes Zoth : il protège des coups de soleil même en plein cagnard, il amortit les coups portés à la tête, et il empêche de prendre conscience du danger en restreignant le champ de vision de celui qui le porte. Bref, ceci est le couvre-chef idéal du guerrier.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Coiffe du Maître Zoth",t:16,d:"La coiffe du Maître Zoth possède l\'immense avantage de restreindre le champ de vision de manière encore plus importante que les autres casques. C\'est grâce à lui que l\'on peut accéder à la fameuse technique de combat dite « de la fouine ». En gros, il suffit de frapper n\'importe où en utilisant toutes ses forces. Étant ainsi totalement imprévisible, vous êtes sûr de vaincre l\'adversaire (ou du moins le surprendre suffisamment pour lui donner des coups bien placés).",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Racine de Fécorce",t:4,d:"Ce bâton est très branché auprès des femmes troncs. Mais si vous préférez séduire d\'autres types de femmes, cela est aussi possible (même si cela risque d\'être moins efficace).",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Racine de Floribonde",t:4,d:"Si vous êtes superstitieux et que vous avez toujours besoin de toucher du bois, choisissez cette Racine de Floribonde ! D\'un autre côté, vous pouvez aussi essayer d\'être prudent, de ne pas scier la branche sur laquelle vous êtes assis et de ne surtout pas mettre le doigt entre l\'arbre et l\'écorce.",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"Worn Treasure Map",t:24,d:"Event Shika",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"Crack Sparrow\'s Own Withered Hat",t:16,d:"Event Shika",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"Bouclier Fi\'Squale",t:82,d:"Certes ce bouclier, vous assure une protection effective mais ne rêvez pas, il ne durera pas.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Ceinture Rasboulaire du Rasboul",t:10,d:"Lorsque le Rasboul a les boules, il porte sa ceinture Rasboulaire pour envoyer bouler tous les casse-boules.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Bottes Horchons",t:11,d:"Ces Bottes émettent un immonde bruit de succion à chaque pas, ce qui n\'est pas sans vous rappeler le chant d\'amour des Trools en rut. Un souvenir douloureux dont vous vous seriez bien passé.",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"Sceau Souverain du Roissingue",t:9,d:"Ce sceau désigne son possesseur comme étant le souverain incontesté de la Tourbière sans fond de l\'île d\'Otomaï. Difficile d\'imaginer un royaume plus bucolique.",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Alliance de Corail",t:9,d:"Cet anneau a été arraché au doigt encore chaud d\'un jeune Corailleur fraichement massacré. Sa mère l\'attendait pour le repas, jusqu\'à ce qu\'elle s\'aperçoive que son rejeton venait d\'être transformé en pierre tombale.  Même le corail a un coeur, et pas forcément de pierre.",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Sandales Circulaires du Kimbo",t:11,d:"Seul le Kimbo et ses pieds totalement loufoques peuvent se sentir à l\'aise dans ces sandales. En revanche il n\'est pas le seul à pouvoir profiter de leur puissance. Attention tout de même de ne pas vous tromper de sens en les enfilant.",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Ceinture Bitoufale de Prosper Youpla",t:10,d:"Prosper Youpla était persuadé de pouvoir voler grâce à cette ceinture ornée d\'ailes de Bitouf. Ignorant que très peu de Bitoufs savent voler, il s\'élançait du haut de l\'arbre Hakam et s\'écrasait systématiquement au sol, tant et si bien qu\'il fût surnommé \"Boum\".",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothulette",t:1,d:"Cette amulette est un vulgaire morceau de bois et de tissu déchiré, mais les Zoths croient dur comme fer à ses pouvoirs. Les pauvres fous !",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Kask\'Arc Go",t:2,d:"La corde de cet arc est faite de bave de Kaskargo, plus ou moins sèche, son élasticité est sans pareille, sa texture gluante et visqueuse en revanche rappelle... On ne sait pas trop ce que ça rappelle mais ça n\'est pas agréable.",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Anneau Skargo",t:9,d:"Sculpté dans une carapace de Kaskargo, cet anneau résiste à n\'importe quoi ou n\'importe qui.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Puissante Cape Fulgurante",t:17,d:"Tissée dans des étoffes de Zoths, cette cape possède un pouvoir extraordinaire dont l\'origine reste encore inconnue.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Cape de la Meupette",t:17,d:"En portant cette cape, vous serez pris d\'une furieuse envie de vinaigrette.",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Poolache",t:19,d:"Le fait qu\'un bec de Poolay orne cette arme ne sert absolument à rien, voire handicape l\'utilisateur. Heureusement qu\'elle est puissante.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Bottines en bois d\'abrakleur",t:11,d:"Ces bottes sont si lourdes qu\'elles seraient plutôt à classer dans la catégorie des armes tellement les coups de pieds deviennent meurtriers.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Ceinture sombre en Abrakleur",t:10,d:"Taillée dans un Abrakleur sombre, cette ceinture n\'est pas assez flexible pour permettre de bouger librement, mais au moins, elle protège bien.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Ceinture Claire en Abrakleur",t:10,d:"Taillée dans un Abrakleur clair, cette ceinture ne protège pas bien, mais au moins, elle est assez flexible pour bouger librement.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Palmano",t:9,d:"Ce bijou n\'est pas très précieux, mais il a la taille idéale pour servir à doser le mourgale dans un bon belgrouth à la glaviouze.",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Krustoture",t:10,d:"Enfin une bonne excuse de sentir la marée !",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Ouassulette",t:1,d:"Ce bijou essaye parfois de vous voler des aliments au passage pendant votre repas, ne le laissez pas pendre trop bas.",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Voile d\'encre",t:17,d:"Cette cape étrange semble faite d\'encre noire, mais étrangement, elle se comporte comme une étoffe et ne coule pas. En revanche elle tâche. Votre arrière train n\'aura jamais été aussi sale.",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Kralano",t:9,d:"Une fois enfilé, vous ne pourrez plus jamais l\'enlever tellement ses ventouses sont efficaces.",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kidorteau",t:7,d:"Ce marteau n\'est pas pratique, pas spécialement beau, pas très ergonomique, pas puissant, pas assez lourd, trop fragile, mal équilibré, il brille trop et sent mauvais. \nMais il est coloré ! Enfin, un peu de couleurs dans ce monde de brutes.",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
I.u[8879] = {n:"Anneau Poli",t:9,d:"Cet anneau n\'est malheureusement poli qu\'à l\'extérieur. On y enfile le doigt par un trou orné d\'éclats de roche acérés. Recommandé pour les Sacrieurs.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Amufafah",t:1,d:"Ce collier donne une furieuse envie de rugir à son possesseur, simplement parce que les moustaches du Mufafah qui l\'ornent lui chatouillent les tétons.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Anneau Solo",t:9,d:"Solo était un gentil vaurien, d\'ailleurs il le disait lui-même. Ça ne l\'a pas empêché de mourir pendu sur la place du village après avoir dérobé une petite culotte à la femme du chef. Solo n\'était vraiment pas futé, mais gentil quand-même...",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Potion de Foyer de Guilde",t:12,d:"Cette potion vous permet de retourner dans votre foyer de guilde.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Fantôme Chacha Tigré",t:90,d:"Ce Chacha Tigré n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Transformation Fantôme Chacha Tigré",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans le sanctuaire des familiers.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8887] = {n:"Certificat de Mise en Chanil : Chacha Tigré",t:77,d:"Ce certificat décrit les caractéristiques du Chacha Tigré que vous avez placé au chanil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8888] = {n:"Certificat de Mise en Chanil : Ecureuil Chenapan",t:77,d:"Ce certificat décrit les caractéristiques de l\'Ecureuil Chenapan que vous avez placé au chanil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8889] = {n:"Certificat de Mise en Chanil : Léopardo",t:77,d:"Ce certificat décrit les caractéristiques du Léopardo que vous avez placé au chanil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8890] = {n:"Cadeau Chacha Tigré",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8891] = {n:"Cadeau Ecureuil Chenapan",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
