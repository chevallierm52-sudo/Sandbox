I.u[8952] = {n:"Shigekax Pomme",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon à la pomme préparé de façon traditionnelle.",ep:1,g:19,l:1,wd:true,fm:true,w:1,c:"PO!8939",u:true,p:1};
I.u[8953] = {n:"Shigekax Chocolat",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon au chocolat préparé de façon traditionnelle.",ep:1,g:23,l:1,wd:true,fm:true,w:1,c:"PO!8944",u:true,p:1};
I.u[8954] = {n:"Shigekax Vanille",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon à la vanille préparé de façon traditionnelle. Hmm... Ce Shigekax vous parait particulièrement fondant sous la langue.",ep:1,g:23,l:1,wd:true,fm:true,w:1,c:"PO!8946",u:true,p:1};
I.u[8955] = {n:"Shigekax Melon",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon au melon préparé de façon traditionnelle. Wow ! Ce Shigekax est certainement le meilleur que vous ayez goûté de votre vie.",ep:1,g:19,l:1,wd:true,fm:true,w:1,c:"PO!8947",u:true,p:1};
