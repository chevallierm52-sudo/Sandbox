I.u[8958] = {n:"Patte d\'Ecaflip",t:6,d:"Le Dieu Ecaflip vous a tendu sa patte, mais vous n\'avez pu saisir qu\'une griffe...  Et encore, elle ne coupait pas aussi bien que vous auriez pu le croire à première vue. En fait, ce n\'était peut-être pas le Dieu Ecaflip, finalement...",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
