I.u[9060] = {n:"Morceau de papier déchiré",t:24,d:"C\'est une partie de lettre que quelqu\'un a déchirée. On peut encore y lire : \'... Comme convenu, je m\'arrangerai pour que l\'enquête sur ce marchand n\'aboutisse pas. Venez me verser la somme prévue à l\'endroit habituel où les femmes sont de charmante compagnie.\' \nLa lettre est signée X.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9061] = {n:"Exoram",t:32,d:"Exoram doit être escorté hors du camp gobelin et jusqu\'au temple Sram.",ep:1,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9062] = {n:"Document sur Xephirès",t:24,d:"Ce document contient de nombreuses informations intéressantes sur l\'individu nommé Xephirès. Notamment, on y apprend qu\'il passe beaucoup de temps à la taverne du Pandawa Ivre.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9063] = {n:"Liste de Milone",t:24,d:"Cette liste absolument impressionnante vous a été remise par Milone le bijoutier. Elle décrit les objets nécessaires pour confectionner un somptueux joyaux.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9064] = {n:"Bave du Bouftou Royal",t:24,d:"Est-elle vraiment différente d\'une bave ordinaire ? En tout cas, ça n\'en a pas l\'air.",ep:1,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9065] = {n:"Lettre pour Milone",t:24,d:"Cette lettre, écrite à la hâte, explique à Milone que le bijou est en danger. D\'ailleurs, pourquoi perdez-vous du temps à la lire au lieu de vous précipiter chez lui ?",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9066] = {n:"Lettre du chef des voleurs",t:24,d:"Retrouvée sur un des voleurs que vous avez vaincus chez Milone : \nMilone Corichel le bijoutier vient de créer un joyau de grande valeur. Dérobez-le par tous les moyens possibles. \nVisiblement, les voleurs ont échoué et en plus au dos du message se trouve l\'emplacement de leur repaire. Une petite visite de courtoisie s\'impose, mais mieux vaut s\'y rendre accompagné.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9067] = {n:"Lettre pour Xephirès",t:24,d:"Cette lettre d\'Oto Mustam explique en détails le plan pour Xephirès.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9068] = {n:"Joyau de Milone",t:24,d:"Ce joyau est le résultat de vos efforts et de ceux de Milone le bijoutier. Il vaut assurément une petite fortune... pour ceux que ça peut intéresser.",ep:16,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9069] = {n:"Nouvelle lettre pour Xephirès",t:24,d:"Oto y décrit ses conditions pour la corruption de Xephirès.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9070] = {n:"Epée étrange",t:24,d:"Cette épée est vraiment inhabituelle. Vous n\'en avez jamais vu de telle dans Bonta.",ep:1,g:718,l:1,wd:false,fm:true,w:0,p:1};
I.u[9071] = {n:"Notes du tavernier Feubuk",t:24,d:"Le tavernier Feubuk a reçu des Ecaflips louches qui ont prononcé le nom de Loudac.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9072] = {n:"Notes du tavernier Pinchaut",t:24,d:"Le tavernier Pinchaut a entendu des gardes parler de leurs problèmes avec une bande d\'Ecaflips.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9073] = {n:"Insigne de Bandit Ecaflip",t:24,d:"Vous avez récupéré cet insigne sur les bandits Ecaflips des plaines de Cania.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9074] = {n:"Bijou d\'Amayiro",t:24,d:"Ce bijou servira à appâter le chef des bandits afin de le capturer.",ep:1,g:111,l:1,wd:false,fm:true,w:0,p:1};
I.u[9075] = {n:"Lettre du Xélor",t:24,d:"Cette lettre vous a été remise par l\'intermédiaire de Marge la bijoutière : \nAmenez le bijou à Ekusoyk Ubnan à la Taverne de la Chopenbois. Ce sera plus rapide pour nous et beaucoup plus lucratif pour vous.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9076] = {n:"Bijou d\'Amayiro (faux)",t:24,d:"Ce bijou ressemble à s\'y méprendre à celui qu\'Amayiro vous a envoyé chercher. D\'ailleurs, il vaudrait mieux qu\'il s\'y méprenne, sinon...",ep:1,g:110,l:1,wd:false,fm:true,w:0,p:1};
I.u[9077] = {n:"Crâne de Feca",t:47,d:"Le crâne de Feca fait un excellent presse-livres.",ep:1,g:34,l:1,wd:true,fm:false,w:1,p:1};
I.u[9078] = {n:"Crâne d\'Osamodas",t:47,d:"Un Tofu par-ci, un Bwork mage par-là : ce disciple d\'Osamodas en a perdu la tête.",ep:1,g:33,l:1,wd:true,fm:false,w:2,p:1};
I.u[9079] = {n:"Crâne d\'Enutrof",t:47,d:"Ce trophée était déjà vieux avant de devenir un trophée.",ep:1,g:32,l:1,wd:true,fm:false,w:2,p:1};
I.u[9080] = {n:"Crâne de Sram",t:47,d:"Ce trophée était déjà morbide avant de devenir un trophée.",ep:1,g:31,l:1,wd:true,fm:false,w:2,p:1};
I.u[9081] = {n:"Crâne de Xélor",t:47,d:"Ce crâne est souvent confondu avec celui de la célèbre momie de Tut Enkarthon. Ne vous y trompez pas : ces bandelettes-ci ne sont pas en carton, mais en papier mâché.",ep:1,g:30,l:1,wd:true,fm:false,w:2,p:1};
I.u[9082] = {n:"Crâne d\'Ecaflip",t:47,d:"À défaut de jouer à pile ou face, on pourra jouer aux osselets.",ep:1,g:29,l:1,wd:true,fm:false,w:2,p:1};
I.u[9083] = {n:"Crâne d\'Eniripsa",t:47,d:"Ne soyez pas mauvaise langue : Non, Il ne s\'agit pas d\'un crâne de Piaf !",ep:1,g:28,l:1,wd:true,fm:false,w:2,p:1};
I.u[9084] = {n:"Crâne de Iop",t:47,d:"Ce trophée sonne aussi creux que lorsqu\'il était plein.",ep:1,g:27,l:1,wd:true,fm:false,w:1,p:1};
I.u[9085] = {n:"Crâne de Crâ",t:47,d:"On pourrait le croire sorti d\'une fouille archéologique, ce crâne de Crâ mignon !",ep:1,g:26,l:1,wd:true,fm:false,w:2,p:1};
I.u[9086] = {n:"Crâne de Sadida",t:47,d:"Qui eût cru qu\'il y eut un crâne sous la touffe de cheveux ?",ep:1,g:25,l:1,wd:true,fm:false,w:2,p:1};
I.u[9087] = {n:"Crâne de Sacrieur",t:47,d:"Ce sacrieur fait moins le fier sans ses milliers de points de vie.",ep:1,g:24,l:1,wd:true,fm:false,w:2,p:1};
I.u[9088] = {n:"Crâne de Pandawa",t:47,d:"On aurait pu croire qu\'après la mise en bière le Pandawa aurait une gueule de bois.",ep:1,g:23,l:1,wd:true,fm:false,w:2,p:1};
I.u[9089] = {n:"Insigne de la patrouille de Bonta",t:24,d:"Vous avez récupéré cet insigne lors de la (très facile) bataille d\'escarmouche contre Bonta.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9090] = {n:"Insigne de la patrouille de Brâkmar",t:24,d:"Vous avez récupéré cet insigne à grand peine lors de la bataille d\'escarmouche contre Brâkmar.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9094] = {n:"Poison Bwork",t:24,d:"Ca ressemble davantage à de la gelée de menthe qu\'à du poison. Les Bworks ne sont assurément pas très doués pour ça : ce qui est plus inquiétant, c\'est que les espions de Brâkmar non plus, apparemment.",ep:4,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9096] = {n:"Tacticien",t:32,d:"Le tacticien a accepté de vous suivre jusqu\'à votre chef.",ep:16,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9097] = {n:"Badge du puissant milicien",t:24,d:"Vous avez trouvé ce badge sur le milicien particulièrement redoutable qui a vaincu plusieurs guerriers de Brâkmar. Son équipement semblait très particulier.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9098] = {n:"Marteau de Nara",t:24,d:"Ce marteau indiquera à Oto que vous avez vaincu le forgeron mercenaire de Bonta.",ep:16,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9099] = {n:"Demande d\'aide d\'Amayiro",t:24,d:"Cette lettre, signée par Amayiro, est une demande d\'aide officielle.",ep:3,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9100] = {n:"Caleçon de Lenglad",t:24,d:"Là, c\'est sûr : Lenglad ne fera plus parler de lui avant un moment.",ep:1,g:84,l:1,wd:false,fm:true,w:0,p:1};
I.u[9101] = {n:"Caisse d\'outils de Nara",t:24,d:"Cette caisse contient les outils que Nara le forgeron a oubliés.",ep:3,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9103] = {n:"Plan d\'attaque",t:24,d:"Cette lettre, datée d\'il y a une semaine, explique en détails le plan d\'attaque contre Bonta. Il faut toutefois se méfier, car une note en fin de page indique que ce plan n\'est pas encore confirmé et sujet à modification dans les prochains jours par l\'officier Kapi Taigne. Par conséquent, vous devez découvrir ce qu\'il en est à l\'heure actuelle.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9104] = {n:"Insigne de la patrouille du Cimetière",t:24,d:"Vous avez récupéré cet insigne sur la patrouille brâkmarienne que vous avez attaquée au Cimetière des Torturés.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9105] = {n:"Lettre de Danathor",t:24,d:"Quelqu\'un a glissé cette lettre dans votre sac pendant qu\'Amayiro vous donnait la mission : \nRécupérez les documents, mais apportez-les moi plutôt qu\'à Amayiro. Vous serez récompensé. Danathor",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9106] = {n:"Documents secrets de Bonta",t:24,d:"Ces documents contiennent un bon nombre d\'informations concernant les défenses et le système de Bonta. Mais à qui allez-vous les donner ?",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9107] = {n:"Consignes pour l\'espion de Bonta",t:24,d:"Pénètre dans la tour de Brâkmar à minuit et récupère tous les documents que tu trouveras au deuxième étage. Reviens ensuite à Bonta en passant par l\'Est de la route. \nNon, ce n\'est pas VOUS qui devez le faire, c\'était la consigne pour l\'espion que vous devez sauver.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9108] = {n:"Documents brâkmariens secrets",t:24,d:"Ces documents contiennent de nombreuses informations sur la Corne Edfrit.",ep:14,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9109] = {n:"Bandana Troué",t:24,d:"Ce bandana en mauvais état est couvert de glaire, comme s\'il avait servi de mouchoir à plusieurs générations de Wabbits. Il a sans nul doute appartenu à Turorte, en témoigne son odeur de hareng pourri subtilement camouflée par une odeur de cawotte. Pour sentir aussi mauvais après toutes ces années, il est indubitablement imprégné d\'une puissante magie.",ep:8,g:748,l:1,wd:false,fm:true,w:0,p:1};
I.u[9110] = {n:"Corne Edfrit",t:24,d:"Vous avez déjà essayé de souffler dedans, mais il ne se passe rien de spécial...",ep:16,g:720,l:1,wd:false,fm:true,w:0,p:1};
I.u[9112] = {n:"Consigne pour l\'espion brâkmarien",t:24,d:"Pénètre dans la tour de Bonta à minuit, égorge tous ceux qui sont sur ton chemin, et récupère tous les documents que tu trouveras au premier étage. Reviens ensuite à Brâkmar passant par la route. \nNon, ce n\'est pas VOUS qui devez le faire, c\'était la consigne pour l\'espion que vous devez retrouver.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9113] = {n:"Documents secrets volés",t:24,d:"Les documents que l\'espion blessé a récupéré dans la tour de Bonta.",ep:13,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9114] = {n:"Documents secrets froissés",t:24,d:"Les documents que l\'espion blessé a récupéré dans la tour de Bonta. Ils ont été un peu abimés pendant votre combat contre les forces de Bonta.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9115] = {n:"Salace fourrée au pollen",t:24,d:"Cette salace a été préparée dans le chaudron primordial ce qui lui confère des vertus particulières. Pour savoir lesquelles, il faudrait pouvoir y goûter, malheureusement c\'est à Turorte qu\'elle est destinée. La vie est parfois injuste.",ep:12,g:719,l:1,wd:false,fm:true,w:0,p:1};
I.u[9116] = {n:"Caisse d\'équipement",t:24,d:"Une arme, un casque, un bouclier : cette caisse contient un équipement rudimentaire mais efficace pour les guerriers.",ep:16,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9117] = {n:"Ougarteau",t:7,d:"Ougah a la tête dure, plus dure que n\'importe qui, c\'est pourquoi un marteau créé avec son crâne est idéal pour fracasser celui des autres.",ep:23,g:67,l:180,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,50,50,false,false],c:"CV>1200",s:118,p:50000};
I.u[9118] = {n:"Cadeau Event Shika",t:89,d:"(cadeau offert aux joueurs de Shika pour l\'event, ne pas traduire)",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[9119] = {n:"Cadeau Shika",t:89,d:"(cadeau pour les joueurs abonnés de Shika, ne pas traduire)",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[9120] = {n:"Chapeau Shika",t:16,d:"(Chapeau pour les abonnés du serveur Shika, ne pas traduire)",ep:0,g:210,l:30,wd:false,fm:true,w:10,p:3000};
I.u[9121] = {n:"Cape Shika",t:17,d:"(cape destinée aux joueurs abonnés du serveur Shika, ne pas traduire)",ep:0,g:148,l:30,wd:false,fm:true,w:10,p:3000};
I.u[9122] = {n:"Blopanneau Griotte",t:9,d:"Une fois enfilé au bout d\'un doigt, il n\'est plus possible de se débarrasser de cet anneau. Plus vous y pensez, et plus il vous rappelle quelqu\'un.",ep:5,g:149,l:50,wd:true,fm:true,w:10,s:98,p:4000};
I.u[9123] = {n:"Blopanneau Reinette",t:9,d:"Une fois enfilé au bout d\'un doigt, il n\'est plus possible de se débarrasser de cet anneau. Plus vous y pensez, et plus il vous rappelle quelqu\'un.",ep:5,g:150,l:50,wd:true,fm:true,w:10,s:99,p:1000};
I.u[9124] = {n:"Blopanneau Coco",t:9,d:"Une fois enfilé au bout d\'un doigt, il n\'est plus possible de se débarrasser de cet anneau. Plus vous y pensez, et plus il vous rappelle quelqu\'un.",ep:5,g:151,l:50,wd:true,fm:true,w:10,s:100,p:1000};
I.u[9125] = {n:"Blopanneau Indigo",t:9,d:"Une fois enfilé au bout d\'un doigt, il n\'est plus possible de se débarrasser de cet anneau. Plus vous y pensez, et plus il vous rappelle quelqu\'un.",ep:5,g:152,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9126] = {n:"Blopanneau Griotte Royal",t:9,d:"Kroula avait jadis tenté d\'enfiler cet anneau autour de son gros orteil. Il espérait ainsi que ses ennemis daigneraient lui lécher les pieds dans l\'espoir de récupérer quelques gouttes de jus de Blop Royal.",ep:5,g:153,l:80,wd:true,fm:true,w:10,s:102,p:15000};
I.u[9127] = {n:"Blopanneau Reinette Royal",t:9,d:"Kroula avait jadis tenté d\'enfiler cet anneau autour de son gros orteil. Il espérait ainsi que ses ennemis daigneraient lui lécher les pieds dans l\'espoir de récupérer quelques gouttes de jus de Blop Royal.",ep:5,g:154,l:80,wd:true,fm:true,w:10,s:103,p:15000};
I.u[9128] = {n:"Blopanneau Coco Royal",t:9,d:"Kroula avait jadis tenté d\'enfiler cet anneau autour de son gros orteil. Il espérait ainsi que ses ennemis daigneraient lui lécher les pieds dans l\'espoir de récupérer quelques gouttes de jus de Blop Royal.",ep:5,g:155,l:80,wd:true,fm:true,w:10,s:104,p:15000};
I.u[9129] = {n:"Blopanneau Indigo Royal",t:9,d:"Kroula avait jadis tenté d\'enfiler cet anneau autour de son gros orteil. Il espérait ainsi que ses ennemis daigneraient lui lécher les pieds dans l\'espoir de récupérer quelques gouttes de jus de Blop Royal.",ep:5,g:156,l:80,wd:true,fm:true,w:10,s:105,p:15000};
I.u[9130] = {n:"Ougamulette",t:1,d:"Cette réplique approximative du grand Ougah se porte autour du cou, avec un regard noir et une barbe correctement entretenue.",ep:23,g:127,l:181,wd:true,fm:true,w:15,s:118,p:58000};
I.u[9131] = {n:"Anneau Colerette",t:9,d:"Colerette la jeune Crâette, a perdu la tête dans les bois de Litneg. La pauvre fille a reçu une hache lancée par Brouce Boulgoure, qui l\'avait prise par méprise pour une fougère géante. Etre une belle plante ne paie pas toujours.",ep:23,g:146,l:188,wd:true,fm:true,w:10,s:119,p:57950};
I.u[9132] = {n:"Anneau Chevelu",t:9,d:"Avec cet anneau, en plus d\'avoir un cheveu sur la langue et un poil dans la main, vous pourrez vous vanter d\'avoir des cheveux autour des doigts.",ep:23,g:147,l:180,wd:true,fm:true,w:10,s:121,p:57822};
I.u[9133] = {n:"Alliance Boletée",t:9,d:"Si vos ennemis sont allergiques aux champignons, laissez-les vous croquer les doigts.",ep:23,g:148,l:186,wd:true,fm:true,w:10,s:107,p:56000};
I.u[9134] = {n:"Arc à Lamelles",t:2,d:"Construit à la base pour servir de lattes pour les sommiers de lits, ces lamelles ont fini par être utilisées dans la fabrication de cet arc, qui vous permettra d\'endormir vos ennemis pour l\'éternité.",ep:23,g:61,l:187,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>300&CI>300",p:58421};
I.u[9135] = {n:"Baguetterelle",t:3,d:"A l\'origine, il suffisait de souffler très fort dans cette trompette fongique, pour faire arriver le ménestrel Francisque Kabroule. Ce dernier se mettait alors à chanter, et tous les monstres mourraient sur place. Bon comme c\'était un peu trop facile comme technique pour tuer les monstres, les dieux ont décidé de la boucher et de la transformer en une vulgaire baguette.",ep:23,g:66,l:184,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,45,50,false,true],c:"CI>300&CA>300",p:54284};
I.u[9136] = {n:"Bâton Champmanique",t:4,d:"Les trois pointes de ce bâton permettent de concentrer les résidus de plasmogrine présents dans la brise quadramentale. Mettez un peu de salive sur les pointes, orientez le bâton dans le sens des aiguilles d\'une montre Xélor inversée, comptez jusqu\'à soixante, ou essayez jusqu\'à six si vous êtes Iop. Restez concentré, serrez les fesses, voilà vous avez une chance sur deux de vous prendre un coup de tonnerre, ou de transformer vos ennemis en Kirboules hirsutes.",ep:23,g:80,l:191,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>200&CC>200&CI>100",p:55000};
I.u[9137] = {n:"Couteaux à Champignons",t:5,d:"Ces couteaux étaient autrefois utilisés pour retirer les mycoses qui parasitaient les pieds des aventuriers. On leur coupait les pieds juste au niveau du genou.",ep:23,g:69,l:187,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,30,50,false,false],c:"CA>450",s:119,p:57000};
I.u[9138] = {n:"Hache à Lamelles",t:19,d:"Les différentes lamelles de cette hache permettent de couper très rapidement le saucisson. Un seul coup de hache permet de couper trois tranches. Pour tuer les ennemis, c\'est un peu moins utile, sauf si vous avez l\'habitude de les manger en tranches.",ep:23,g:51,l:176,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,50,50,false,false],c:"CC>450",s:120,p:54854};
I.u[9139] = {n:"Bottines des sous-bois",t:11,d:"Ces bottines sont parfaites pour marcher dans les sous-bois, sans écraser les feuilles mortes. Attention cependant, leurs origines végétales les poussent inexorablement à écraser tout ce qui s\'apparente de près ou de loin à du fumier.",ep:23,g:115,l:175,wd:true,fm:true,w:10,s:120,p:54852};
I.u[9140] = {n:"Chaussons Pignons",t:11,d:"Ces chaussons sont recouverts de petites aérations qui contrairement aux idées reçues, ne permettent pas à vos pieds de mieux s\'aérer, mais plutôt aux spores des champignons installés sur vos pieds, de s\'enfuir rapidement pour aller parasiter d\'autres aventuriers plus facilement.",ep:23,g:116,l:181,wd:true,fm:true,w:15,s:121,p:57000};
I.u[9141] = {n:"Caprin",t:17,d:"Si cette cape n\'était pas recouverte de moisissure, elle pourrait servir de nappe. Ce n\'est pas grave, elle pourra toujours vous servir de linceul.",ep:23,g:154,l:181,wd:true,fm:true,w:10,s:119,p:58000};
I.u[9142] = {n:"Capignon",t:17,d:"Cette cape était autrefois réservée aux meilleurs grimpeurs, aux aventuriers qui étaient les plus rapides pour escalader la montagne des Craqueleurs. Aujourd\'hui elle sert surtout à se faire remarquer dans les soirées mondaines.",ep:23,g:150,l:190,wd:true,fm:true,w:10,s:107,p:60000};
I.u[9143] = {n:"String Tue-Mouche",t:10,d:"Comme son nom l\'indique, ce string est particulièrement efficace pour tuer les mouches un peu trop intéressées par votre anatomie. Il est déconseillé de l\'arracher avec les dents, même si vous appréciez cela.",ep:23,g:132,l:192,wd:true,fm:true,w:20,s:107,p:48000};
I.u[9144] = {n:"Ceinture Mycosine",t:10,d:"La meilleure façon de ne pas avoir de champignons dans l\'entrejambe, c\'est de les attirer ailleurs. Comme il n\'y avait déjà plus de place dans vos chaussures pour loger d\'autres champignons, vous pourrez utiliser cette ceinture, véritable substrat pour tout bon champignon digne de ce nom.",ep:23,g:133,l:177,wd:true,fm:true,w:10,s:121,p:58444};
I.u[9145] = {n:"Tranche des Sous-bois",t:10,d:"Prenez un Orme, retirez-lui son écorce, laissez-la tremper dans une flaque, enfouissez-la dans la vase pendant plusieurs mois, recouvrez-là de spores de champignons, mettez-là sous votre lit pendant une semaine en la badigeonnant de graisse de Blop tous les soirs, et voilà vous avez une ceinture en écorce qui sent très mauvais. Alors heureux ?",ep:23,g:134,l:179,wd:true,fm:true,w:10,s:120,p:68420};
I.u[9146] = {n:"Ougature",t:10,d:"Sur l\'étiquette de cette ceinture, on peut lire : \"Nous sommes désolés mais ce n\'est pas en portant cette ceinture que vous aurez le déhanchement légendaire d\'Ougah\". Et alors ?",ep:23,g:135,l:185,wd:true,fm:true,w:10,s:118,p:56000};
I.u[9147] = {n:"Chapignon",t:16,d:"Prenez un Dora, recouvrez-le de bave de Bouftou et de la sueur de Iop. Laissez le tout moisir pendant quelques semaines, et voilà vous avec une réplique de Chapignon. Attention, ce chapeau donne parfois des hallucinations.",ep:23,g:221,l:185,wd:true,fm:true,w:10,s:119,p:48521};
I.u[9148] = {n:"Blopanneau Multicolore Royal",t:9,d:"Plutôt que de réduire sa consommation de jus de Blop frelaté, Shika Ingalsse préféra continuer de faucher en état d\'ébriété. C\'est en titubant dans les champs qu\'elle tomba sur cet étrange anneau. Malheureusement, cette histoire ne comporte qu\'une seule chute.",ep:5,g:157,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9149] = {n:"Amublop Griotte",t:1,d:"Quand Lorkos voulut pénétrer dans le Labyrinthe du Minotoror, il n\'hésita pas une seconde à équiper son Amublop. Personne n\'a jamais su pourquoi.",ep:5,g:128,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9150] = {n:"Amublop Reinette",t:1,d:"Quand Lorkos voulut pénétrer dans le Labyrinthe du Minotoror, il n\'hésita pas une seconde à équiper son Amublop. Personne n\'a jamais su pourquoi.",ep:5,g:129,l:50,wd:true,fm:true,w:10,s:99,p:1000};
