I.u[9042] = {n:"Puissante potion d\'agression",t:14,d:"Cette potion vous permet d\'entrer dans une telle rage que vous attaquez automatiquement les ennemis qui s\'approcheront trop près de vous.",ep:0,g:36,l:1,wd:false,fm:true,w:1,c:"Pg>21,3",u:true,p:10};
I.u[9043] = {n:"Impressionnante potion d\'agression",t:14,d:"Cette potion vous permet d\'entrer dans une telle rage que vous attaquez automatiquement les ennemis qui s\'approcheront trop près de vous.",ep:0,g:35,l:1,wd:false,fm:true,w:1,c:"Pg>21,4",u:true,p:10};
