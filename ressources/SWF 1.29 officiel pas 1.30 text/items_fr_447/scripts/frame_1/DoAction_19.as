I.u[8961] = {n:"Patte d\'Ecaflip",t:6,d:"Certains superstitieux prétendent que les pattes de lapin apportent chance et fortune. Grâce à cette légendaire épée, vous pourrez briller à leurs yeux. Par ailleurs, son tranchant est très affuté et sa coupe vous rappelle légèrement celle d\'une épée que vous avez déjà connue.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8962] = {n:"Patte d\'Ecaflip",t:6,d:"Certains superstitieux prétendent que les pattes de lapin apportent chance et fortune. Grâce à cette légendaire épée, vous pourrez briller à leurs yeux. Par ailleurs, son tranchant est très affuté et sa coupe vous rappelle légèrement celle d\'une épée que vous avez déjà connue.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8963] = {n:"Patte d\'Ecaflip",t:6,d:"Certains superstitieux prétendent que les pattes de lapin apportent chance et fortune. Grâce à cette légendaire épée, vous pourrez briller à leurs yeux. Par ailleurs, son tranchant est très affuté et sa coupe vous rappelle légèrement celle d\'une épée que vous avez déjà connue.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8964] = {n:"Patte d\'Ecaflip",t:6,d:"\"La chance sourit aux audacieux !\" soufflent les adeptes du Dieu Ecaflip. Vous voilà armé comme un as de pique, vous allez pouvoir abattre votre jeu. Cette épée de prestige est d\'une rareté et d\'une pureté exceptionnelle.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8965] = {n:"Patte d\'Ecaflip",t:6,d:"\"La chance sourit aux audacieux !\" soufflent les adeptes du Dieu Ecaflip. Vous voilà armé comme un as de pique, vous allez pouvoir abattre votre jeu. Cette épée de prestige est d\'une rareté et d\'une pureté exceptionnelle.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8966] = {n:"Patte d\'Ecaflip Parfaite",t:6,d:"Cette épée constitue l\'incarnation même de la chance du Dieu Ecaflip. Vous tenez entre vos mains la plus pure version de la Patte d\'Ecaflip, qui témoigne de votre chance aussi incroyable qu\'insolente (et donc de votre célibat définitif).",ep:1,g:81,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8969] = {n:"Cadeau Griffe d\'Ecaflip",t:89,d:"Ce paquet irradie d\'une aura d\'importance et de sainteté. Peut-être devriez-vous réfléchir à deux fois avant de l\'ouvrir.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
