I.u[9153] = {n:"Amublop Griotte Royale",t:1,d:"Cette amulette coûte beaucoup plus cher à fabriquer qu\'une Amublop classique. Mais il faut voir le bon côté des choses, elle peut aussi se revendre plus cher, surtout si vous arnaquez un habitant d\'Astrub.",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
I.u[9154] = {n:"Amublop Reinette Royale",t:1,d:"Cette amulette coûte beaucoup plus cher à fabriquer qu\'une Amublop classique. Mais il faut voir le bon côté des choses, elle peut aussi se revendre plus cher, surtout si vous arnaquez un habitant d\'Astrub.",ep:5,g:133,l:80,wd:true,fm:true,w:10,s:103,p:15800};
