I.u[2998] = {n:"Laine du Minotoror",t:57,d:"Cette laine exceptionnelle a vécu de grands moments, comme la terrible rencontre avec Vald. Les poils qui la composent sont si drus, qu\'elle lui permet de se protéger mêmes des coups les plus fourbes.",ep:2,g:654,l:125,wd:true,fm:true,w:30,p:12500};
I.u[2999] = {n:"Cuir de Minotoror",t:56,d:"Ce cuir est aussi résistant que les fortifications de Brâkmar. Ses propriétés intrinsèques plutôt méconnues, lui permettent d\'être facilement travaillé pour réaliser les objets les plus prestigieux.",ep:2,g:655,l:125,wd:true,fm:true,w:30,p:12500};
I.u[3000] = {n:"Casque cassé de Bwork",t:15,d:"Dans la tribu Bwork, ce sont les Bworks Mages qui s\'occupent de la forge. Travail de grande qualité, le casque est donné à la naissance pour le protéger très vite des chutes diverses et des coups de marteaux.",ep:4,g:646,l:43,wd:true,fm:true,w:10,p:1};
I.u[3001] = {n:"Epaulette de Bwork",t:15,d:"L\'Epaulette est principale pour l\'éducation, bien que chez eux, ce terme n\'est pas approprié. Ce serait plutôt de l\'entraînement.",ep:4,g:647,l:43,wd:true,fm:true,w:10,p:1};
I.u[3002] = {n:"Botte trouée de Bwork",t:15,d:"Cette botte est inutilisable dans cet état. Une fois correctement rapiécée par un cordonnier expérimenté, vous pourrez peut-être lui trouver une utilité. En attendant, son odeur peut vous servir à repousser les avances des gens un peu trop entreprenants.",ep:4,g:648,l:43,wd:true,fm:true,w:10,p:1};
