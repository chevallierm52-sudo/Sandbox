I.u[2481] = {n:"Groin de Porkass",t:15,d:"Ce Groin, rose comme des fesses des nourrissons Osamodas, doit sûrement être utile pour une recette culinaire. Ou alors un joli collier de Groin, mais il faut quand même être courageux pour le porter et assumer les regards amusés des voisins.",ep:13,g:509,l:18,wd:true,fm:true,w:1,p:1};
I.u[2482] = {n:"Soulier de Porkass",t:15,d:"Autrefois, un Soulier similaire avait été trouvé sur les marches d\'un grand palais royal. Des rumeurs raconteraient que ce Soulier fut perdu suite au départ pour le moins hâtif d\'une porkassette, qui eut peur de rentrer après les douze coups de minuit.",ep:13,g:510,l:18,wd:true,fm:true,w:2,p:1};
I.u[2483] = {n:"Dentier de Porkass",t:47,d:"Certains Porkass naissent sans dents. D\'autres, après s\'être tapés une bonne tranche, se réveillent édentés, sans se souvenir de quoi que ce soit.",ep:13,g:511,l:30,wd:true,fm:true,w:1,p:1};
I.u[2484] = {n:"Trident Cassé",t:15,d:"Voici un petit souvenir de votre ami Porkass. En espérant qu\'il ne vous en tienne pas rigueur au point de vous traquer à travers la Province. Caractériel comme un cochon, il en est bien capable, méfiez-vous.",ep:13,g:512,l:18,wd:true,fm:true,w:2,p:1};
I.u[2485] = {n:"Végacoiffe",t:16,d:"Le top du top de la mode, mais uniquement au nord-est d\'Amakna.",ep:1,g:45,l:40,wd:true,fm:true,w:25,s:10,p:4500};
I.u[2486] = {n:"Oreille de Porkass",t:106,d:"Cette Oreille est un bon moyen de se faire respecter, elle fait office de trophée et prouve que vous domptez les Porkass à la baguette. Attention toutefois à ne pas vous la raconter auprès d\'autres Porkass, ils ne vous acclameront sûrement pas, eux.",ep:13,g:513,l:18,wd:true,fm:true,w:1,p:1};
I.u[2487] = {n:"Carapace de Scorbute",t:107,d:"Idéal pour confectionner de lourdes armures, le Scorbute était chassé jadis par la Milice de Brâkmar, car leur taux de reproduction faisait exploser tous les records. Même les Gelées n\'arrivaient pas à se reproduire aussi vite.",ep:14,g:514,l:36,wd:true,fm:true,w:1,p:1};
I.u[2488] = {n:"Viscères de Scorbute",t:15,d:"Au premier abord, il est certain que ces viscères ne sont pas très appétissants. Et vous avez bien raison, les viscères de Scorbute sont infâmes, même cuisinés avec amour.",ep:14,g:445,l:36,wd:true,fm:true,w:1,p:1};
I.u[2489] = {n:"Vegacape",t:17,d:"Une cape élégante qui vous rendra irrésistible auprès des amateurs de belles plantes.",ep:1,g:49,l:58,wd:true,fm:true,w:15,s:10,p:1000};
I.u[2490] = {n:"Patte de Scorbute",t:103,d:"Il est peu commun de pouvoir récupérer une Patte de Scorbute dans un état aussi correct. En espérant que vous vous en servirez à bon escient, et non, pour crocheter des portes. Quoique...",ep:14,g:515,l:36,wd:true,fm:true,w:1,p:1};
I.u[2491] = {n:"Oeil d\'Ouginak",t:109,d:"Inquiétant, mais palpitant, cet Oeil d\'Ouginak ne reflète pas vraiment ce que l\'on attend. Par exemple, au lieu de vous voir dedans, vous voyez votre homologue Dopeul. Allez comprendre.",ep:14,g:516,l:51,wd:true,fm:true,w:1,p:1};
I.u[2492] = {n:"Chaîne de l\'Ouginak",t:15,d:"Cette chienne de Chaîne provient évidemment d\'un Ouginak. Avant qu\'elle ne soit brisée, elle servait probablement à attacher l\'Ouginak pour éviter qu\'il s\'échappe.",ep:14,g:517,l:51,wd:true,fm:true,w:2,p:1};
I.u[2493] = {n:"Coeur d\'Ouginak",t:15,d:"Ce coeur vous restera fidèle. Tant que vous ne le vendrez, ni ne l\'échangerez, il restera avec vous dans le fond de votre sac. Quelle délicate attention.",ep:14,g:518,l:51,wd:true,fm:true,w:1,p:1};
I.u[2494] = {n:"Pommeau d\'Epée",t:15,d:"Il a sûrement fallu un coup surpuissant pour venir à bout de cette Épée mythique. En effet, l\'Épée d\'un Ouginak procure à celui qui l\'utilise, une envie de hurler de joie. Wa-hooooo !",ep:14,g:519,l:51,wd:true,fm:true,w:2,p:1};
I.u[2495] = {n:"Oeil de Kolérat",t:109,d:"Cet Oeil brille la nuit, même une fois arraché à son propriétaire. De quoi s\'éclairer à moindre frais.",ep:2,g:520,l:9,wd:true,fm:true,w:1,p:1};
I.u[2496] = {n:"Queue de Kolérat",t:65,d:"Tranchée convenablement, la Queue de Kolérat a le goût de saucisson. Ce qui est étrange, c\'est que si vous coupez de trop grosses tranches, le goût de saucisson disparaît totalement. Encore une énigme culinaire de plus dans ce monde.",ep:2,g:521,l:9,wd:true,fm:true,w:1,p:1};
I.u[2497] = {n:"Oreille de Kolérat",t:106,d:"Portez-la à votre oreille, et vous entendrez la mer, parait-il.",ep:2,g:522,l:9,wd:true,fm:true,w:1,p:1};
I.u[2498] = {n:"Vegamu",t:1,d:"La Vegamu a parfois tendance à attirer les Moskitos, qui de loin la prennent pour une copine. Ils sont souvent déçus une fois qu\'ils tombent sur le porteur de l\'amulette.",ep:1,g:53,l:40,wd:true,fm:true,w:20,s:10,p:1000};
I.u[2499] = {n:"Museau de Kolérat",t:15,d:"Le Kolérat possède un flair hors du commun. Il n\'arrive pas à la cheville de l\'Ouginak, mais arrive à sentir celui-ci à trois cents mètres à la ronde. Et ça, c\'est vraiment très pratique pour éviter ses prédateurs.",ep:2,g:523,l:9,wd:true,fm:true,w:1,p:1};
I.u[2500] = {n:"Kolérat Mort",t:15,d:"Vous avez bien fait de le ramasser, il est intact. Mort, mais intact.",ep:2,g:524,l:9,wd:true,fm:true,w:10,p:1};
I.u[2501] = {n:"Queue de Croc Gland",t:65,d:"Le Dieu Osamodas ne supporte pas que l\'on touche aux animaux sauvages : \"Ils sont si mignons\" hurle-t-il constamment. Il est marrant, ça se voit qu\'il n\'a jamais subi une ablation de la part du \"mignon\".",ep:1,g:525,l:19,wd:true,fm:true,w:1,p:1};
I.u[2502] = {n:"Papatte de Croc Gland",t:103,d:"Les Papattes de Croc Gland sont assez prisées par les gastronomes du coin. Elle possède des vertus magiques, comme celle de porter chance à son possesseur. C\'est déjà pas mal.",ep:1,g:526,l:19,wd:true,fm:true,w:1,p:1};
I.u[2503] = {n:"Etoffe de Croc Gland",t:55,d:"Avec ceci, vous pourrez être aussi espiègle que le Croc Gland. Si vos rêves étaient d\'arborer une Étoffe sur votre tête et de vous déplacer de manière féline, eh bien, vous faites de biens drôles de rêves, soit dit entre nous.",ep:1,g:200,l:19,wd:true,fm:true,w:1,p:1};
I.u[2504] = {n:"Langue de Croc Gland",t:15,d:"Cette Langue a dû traîner dans pas mal d\'endroits avant de se retrouver dans votre sac.",ep:1,g:527,l:19,wd:true,fm:true,w:1,p:1};
I.u[2505] = {n:"Croquette",t:15,d:"Pour attirer un Croc Gland dans les mailles de la domestication, lancez-lui une Croquette, ils en raffolent. Il ne vous l\'avouera pas, mais vous vous serez fait un ami pour la vie.",ep:1,g:528,l:19,wd:true,fm:true,w:1,p:1};
I.u[2506] = {n:"Grelot",t:15,d:"Muni d\'un Grelot, le Serpentin s\'entend à des Kilomètres à la ronde. Heureusement d\'ailleurs, car à deux mètres, on pourrait le manquer à cause de la végétation luxuriante des Plaines de Cania.",ep:13,g:529,l:10,wd:true,fm:true,w:1,p:1};
I.u[2507] = {n:"Langue Fourchue",t:15,d:"Armé de cette Langue, vous pourrez fouetter vos amis. Ce sont vos collègues Osamodas et Sacrieurs qui vont être contents.",ep:13,g:530,l:10,wd:true,fm:true,w:1,p:1};
I.u[2508] = {n:"Venin de Serpentin",t:15,d:"Redoutable, ce Venin peut venir à bout d\'une armada de Bouftous enragés. Ils servaient d\'ailleurs autrefois à maîtriser les troupeaux, on en mettait un peu sur un bâton, et le tour était joué.",ep:13,g:531,l:10,wd:true,fm:true,w:1,p:1};
I.u[2509] = {n:"Dent de Serpentin",t:47,d:"Cette Dent appartenait à un Serpentin, cela ne fait aucun doute. On peut le constater en observant de près le bout de la Dent qui s\'avère être on ne peut plus pointu.",ep:13,g:432,l:10,wd:true,fm:true,w:1,p:1};
I.u[2510] = {n:"Estomac de Sanglier des Plaines",t:15,d:"Cet Estomac peut contenir des choses affolantes, une Iopette serait heureuse de voir toutes les Épées qu\'elle pourrait ranger dedans.",ep:13,g:532,l:44,wd:true,fm:true,w:1,p:1};
I.u[2511] = {n:"Cuir de Sanglier des Plaines",t:56,d:"Avec les propriétés de ce Cuir, les artisans cordonniers ont beaucoup hésité avant de confectionner des ceintures et des bottes. Le problème crucial était que ce Cuir ne sentait rien. Bon nombre de clients pensaient avoir affaire à du faux Cuir.",ep:2,g:410,l:44,wd:true,fm:true,w:10,p:1};
I.u[2512] = {n:"Queue de Sanglier des Plaines",t:65,d:"Pas mal de braconniers Brâkmariens collectionnent ce trophé poilu. Encore aujourd\'hui, les raisons de ce pillage restent inconnues.",ep:13,g:536,l:44,wd:true,fm:true,w:1,p:1};
I.u[2513] = {n:"Etoffe de Sanglier des Plaines",t:55,d:"Contrairement à son Cuir, l\'Etoffe du Sanglier des Plaines dispose d\'un fumet radical contre le nez bouché. Pour preuve, cette odeur permettrait même, selon la légende, de réveiller un Sadida en hibernation.",ep:13,g:537,l:44,wd:true,fm:true,w:1,p:1};
I.u[2514] = {n:"Sabot de Sanglier des Plaines",t:47,d:"Généralement, les Sabots de Sanglier sont couverts de boue ou de terre, mais par moment, il ne faut pas s\'étonner d\'y dénicher des Biblops de toutes les couleurs. Oui, comme vous, le Sanglier des Plaines n\'aime pas les Biblops.",ep:13,g:539,l:44,wd:true,fm:true,w:1,p:1};
I.u[2515] = {n:"Groin de Sanglier des Plaines",t:15,d:"À première vue, ce Groin n\'est pas de toute fraîcheur. Et bien détrompez-vous, celui-ci est de loin le plus frais et tendre de tous les groins.",ep:13,g:540,l:44,wd:true,fm:true,w:1,p:1};
I.u[2516] = {n:"Défense de Sanglier des Plaines",t:47,d:"Cette défense vous rappellera que le Sanglier des Plaines est le plus antipathique des Sangliers. En effet, elle est aussi usée qu\'une Dent de Wabbit abîmée par les Cawottes.",ep:13,g:541,l:44,wd:true,fm:true,w:1,p:1};
I.u[2517] = {n:"Mégacape",t:17,d:"Cette cape appartenait à un célèbre héros, connu pour avoir combattu le terrible docteur Wily qui voulait envahir et dominer le monde des douze avec ses propres invocations. Le docteur Wily mourut avant que toutes ses invocations n\'eurent le temps d\'attaquer.",ep:1,g:50,l:45,wd:true,fm:true,w:2,s:76,p:5500};
I.u[2518] = {n:"Cape Vioutifoule",t:17,d:"Silvia de Jodaw a cousu elle-même cette surprenante cape à partir de vieux rideaux. Heureusement, ça ne se voit pas trop, puisqu\'elle ressemble à s\'y méprendre à une serpillière bouillie dans du sang de Porkass.",ep:1,g:51,l:45,wd:true,fm:true,w:2,s:75,p:5500};
I.u[2519] = {n:"Mégacoiffe",t:16,d:"Pour assurer dans les situations les plus extrêmes, et briller en société, cette coiffe devrait faire l\'affaire.",ep:1,g:46,l:44,wd:true,fm:true,w:2,s:76,p:5200};
I.u[2520] = {n:"Casque Vioutifoule",t:16,d:"Ce casque a appartenu au bon vieux Jojo, célèbre héros de l\'ancien temps. Connu pour ses divers exploits, on a tout de même du mal à comprendre la passion qui anime ses fans.",ep:1,g:47,l:44,wd:true,fm:true,w:2,s:75,p:5200};
I.u[2521] = {n:"Mégabottes",t:11,d:"Roll, la gentille sœur du propriétaire de ces bottes, était spécialisée en taxidermie astrale. Jadis, personne n\'était capable de comprendre la différence entre la taxidermie, et la taxidermie astrale. Mais on peut sans peine, imaginer de nos jours, que la taxidermie astrale permet de confectionner des créatures empaillées astrales. Si ça vous paraît évident maintenant, c\'est peut-être parce que vos ancêtres étaient stupides.",ep:1,g:33,l:43,wd:true,fm:true,w:2,s:76,p:5000};
I.u[2522] = {n:"Bottes Vioutifoule",t:11,d:"Ces bottes permettaient au célèbre Jojo d\'augmenter la puissance de son célèbre coup de pied rotatif, également connu sous le nom de \"coup rouge et chaud\". On se demande toujours pourquoi il était appelé ainsi, puisque ses bottes étaient blanches.",ep:1,g:34,l:43,wd:true,fm:true,w:2,s:75,p:5000};
I.u[2523] = {n:"Mégature",t:10,d:"Cette ceinture a été spécialement conçue pour protéger les hanches des héros. Elle ne vous sera donc d\'aucune utilité.",ep:1,g:34,l:45,wd:true,fm:true,w:2,s:76,p:5600};
I.u[2524] = {n:"Ceinture Vioutifoule",t:10,d:"On raconte que cette ceinture aurait été fabriquée par le capitaine Bloue en personne. A peine croyable, et pourtant vous y croyez tout de même.",ep:1,g:35,l:46,wd:true,fm:true,w:2,s:75,p:5600};
I.u[2525] = {n:"Coeur du Maitre Corbac",t:15,d:"Sans son Coeur, son ramage va en prendre un coup. Mais surtout ne lui dites pas, car le Maître Corbac est très susceptible.",ep:13,g:328,l:160,wd:true,fm:true,w:1,p:1};
I.u[2526] = {n:"Faux du Maitre Corbac",t:15,d:"Cette faux était destinée à la base au fauchage du Iop, mais le Maître Corbac s\'est vite aperçu qu\'elle était si aiguisée, qu\'elle pouvait être utilisée pour faucher tout et n\'importe qui.",ep:1,g:557,l:160,wd:true,fm:true,w:10,p:1};
I.u[2527] = {n:"Clakoss",t:15,d:"Le Maître est plein de surprises, dans sa poche se tenait un Clakoss, célèbre fromage royal. Le fait qu\'il soit entamé prouve que le Maître Corbac l\'adore. Au niveau de l\'odeur, on ne peut que vous conseiller de ne pas le garder sur vous.",ep:13,g:558,l:160,wd:true,fm:true,w:1,p:1};
I.u[2528] = {n:"Ongle de Kanigrou",t:47,d:"Il faut être puissant et rapide pour récupérer un Ongle sur un Kanigrou. Puissant pour l\'extraire et rapide pour ne pas se prendre une baffe géante par l\'animal.",ep:13,g:559,l:70,wd:true,fm:true,w:1,p:1};
I.u[2529] = {n:"Potion de métal liquide",t:26,d:"Cette potion permet de redonner un peu de réalité à une lame éthérée.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2530] = {n:"Carabottes",t:11,d:"Elles sont un peu lourdes, mais ces charmantes Carabottes feront de vous la reine de la nuit.",ep:12,g:35,l:60,wd:true,fm:true,w:50,s:9,p:1000};
I.u[2531] = {n:"Caracoiffe",t:16,d:"Comme vous, la tortue a vraiment une toute petite tête. Ca tombe bien, ce chapeau est spécialement prévu pour ça.",ep:12,g:48,l:60,wd:true,fm:true,w:24,s:9,p:10000};
I.u[2532] = {n:"Caracape",t:17,d:"Une cape pratique et résistante, qui ne fera pas de vous une célébrité, mais comme vous n\'en étiez pas une jusqu\'à maintenant, où est le problème ?",ep:12,g:52,l:60,wd:true,fm:true,w:15,s:9,p:10000};
I.u[2534] = {n:"Kwape de Glace",t:17,d:"Idéale pour se rafraîchir sur l\'île de Moon pendant la saison chaude, et parfaite pour refroidir les ardeurs de vos amis les plus entreprenants, cette cape saura répondre aux attentes de l\'aventurier des temps modernes.",ep:8,g:53,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2535] = {n:"Kwakoiffe de Glace",t:16,d:"Cette Kwakoiffe de Glace vous permettra de toujours avoir des idées fraîches, même lorsque vous serez à court d\'idées. Elle n\'est cependant pas assez puissante pour un Iop.",ep:13,g:49,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2537] = {n:"Kwakture de Glace",t:10,d:"Idéale pour vous raffermir les hanches, cette ceinture vous permettra de garder bien au frais ce que vous avez en dessous de la ceinture.",ep:12,g:36,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2538] = {n:"Potion de métal lourd liquide",t:26,d:"Cette potion permet de redonner de la réalité à une lame éthérée.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2539] = {n:"Potion de Copeaux de Bois",t:26,d:"Cette potion permet de redonner un peu de réalité à une oeuvre sculptée étherée.",ep:1,g:16,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2540] = {n:"Potion de Copeaux de Bois Solides",t:26,d:"Cette potion permet de redonner de la réalité à une oeuvre sculptée étherée.",ep:1,g:17,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2541] = {n:"Potion de métal précieux liquide",t:26,d:"Cette potion permet de redonner une grande part de réalité à une lame éthérée.",ep:2,g:15,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2542] = {n:"Potion de Foyer",t:12,d:"Cette Potion permet de retourner à n\'importe quel moment dans votre foyer.",ep:1,g:142,l:1,wd:true,fm:true,w:2,u:true,p:100};
I.u[2543] = {n:"Potion de Copeaux de Bois Rares",t:26,d:"Cette potion permet de redonner une grande part de réalité à une oeuvre sculptée étherée.",ep:9,g:18,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2544] = {n:"Corbalame",t:6,d:"Terriblement tranchante et incroyablement classe, cette lame risque de faire des jaloux parmi votre entourage de Corbacs.",ep:1,g:32,l:45,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,20,50,false,false],s:8,p:4500};
I.u[2545] = {n:"Corbottes",t:11,d:"Ces bottes donnent à leur porteur une impression d\'incroyable légèreté, mais aussi un air stupide.",ep:1,g:37,l:45,wd:true,fm:true,w:1,s:8,p:1000};
I.u[2546] = {n:"Corbacoiffe",t:16,d:"Grâce à cette magnifique coiffe, vous aurez au moins autant de classe que le tristement célèbre Maître Corbac.",ep:1,g:50,l:45,wd:true,fm:true,w:23,s:8,p:1000};
I.u[2547] = {n:"Corbacape Mastralis",t:17,d:"Les meilleurs tailleurs d\'Amakna se sont associés jadis pour utiliser les restes de la dépouille du Maître Corbac afin d\'en faire une cape somptueuse. Avec une telle cape sur les épaules, le maître c\'est vous.",ep:13,g:56,l:127,wd:true,fm:true,w:30,p:41000};
I.u[2549] = {n:"Boîte de Kanigrou",t:15,d:"Cette conserve contient du Kanigrou en morceaux, préalablement découpé puis mis en boîte. Très pratique à transporter, le Kanigrou en morceaux est vraiment le meilleur ami de l\'homme.",ep:13,g:560,l:70,wd:true,fm:true,w:1,p:1};
I.u[2550] = {n:"Etoffe de Kanigrou",t:55,d:"Avec cette Étoffe, vous pourrez faire un substitut capillaire de toute beauté. On peut même dire que l\'on vous remarquera de loin, très loin.",ep:13,g:561,l:70,wd:true,fm:true,w:1,p:1};
I.u[2551] = {n:"Oreille de Kanigrou",t:106,d:"Voici le plat préféré de l\'Ouginak: Oreille de Kanigrou sauce nature. Mais traditionnellement, on la cuisine avec beaucoup de menthe sauvage et quelques Ongles pour le goût.",ep:13,g:562,l:70,wd:true,fm:true,w:1,p:1};
I.u[2552] = {n:"Oeil de Kanigrou",t:109,d:"L\'oeil de Kanigrou est devenu un phénomène de mode, il est très courant de voir se promener des aventuriers avec l\'Oeil autour du cou.",ep:13,g:563,l:70,wd:true,fm:true,w:1,p:1};
I.u[2553] = {n:"Gros Boulet",t:15,d:"Voici un véritable Boulet. Lourd à souhait, il ne cessera jamais de vous perforer le crâne quand bon lui semble. Rien de plus ennuyeux qu\'un gros Boulet en quelque sorte.",ep:1,g:564,l:40,wd:true,fm:true,w:500,p:1};
I.u[2554] = {n:"Côtes de Porkass",t:47,d:"Les Côtes de Porkass ont une saveur particulière. Certaines personnes en raffolent avec un jus épicé, d\'autres les préfèrent crues. Le Porkass quant à lui, préfèrera les vôtres. A chacun sa recette.",ep:13,g:159,l:40,wd:true,fm:true,w:1,p:1};
I.u[2555] = {n:"Selle en Cuir",t:56,d:"À croire que le Porkass est douillet et qu\'il ne l\'assume pas, car sous ses fesses, était cachée une selle munie d\'un rembourrage de qualité. Une fois retravaillée, on pourrait faire de cette selle, d\'excellentes pantoufles.",ep:13,g:565,l:40,wd:true,fm:true,w:5,p:1};
I.u[2556] = {n:"Pollen de Blop",t:15,d:"Voici la source de toutes les allergies bénignes de ce monde. Le seul souci, c\'est que toutes les allergies mortelles commencent par une allergie bénigne. En gros, ne traînez pas avec ce Pollen dans vos poches si vous n\'en avez pas besoin.",ep:5,g:566,l:34,wd:true,fm:true,w:1,p:1};
I.u[2557] = {n:"Pétale de Blop",t:35,d:"Aussi étrange que cela puisse paraître, les Pétales de Blops ne sont pas comestibles, aussi bien cuits que crus. Qui l\'eut cru ?",ep:5,g:567,l:34,wd:true,fm:true,w:1,p:1};
I.u[2558] = {n:"Blop Mort",t:15,d:"Vous avez bien fait de le ramasser, il est intact. Mort, mais intact.",ep:5,g:568,l:34,wd:true,fm:true,w:10,p:1};
I.u[2559] = {n:"Crinière de Trool",t:15,d:"Une Crinière comme celle-ci, ça ne court pas les rues. Seuls les Enutrofs les plus riches peuvent se permettre de s\'en faire un substitut capillaire.",ep:4,g:569,l:115,wd:true,fm:true,w:1,p:1};
I.u[2560] = {n:"Epaulette de Trool",t:15,d:"Il vaut mieux observer cette Épaulette dans ces conditions que de l\'admirer encore accroché sur l\'épaule du Trool. Manquerait plus qu\'il vous fasse un défilé !",ep:4,g:570,l:115,wd:true,fm:true,w:5,p:1};
I.u[2561] = {n:"Bracelet de Force de Trool",t:15,d:"Comme si le Trool avait besoin d\'un Bracelet de Force... Cette incroyable machine à broyer les os en possède un à chaque poignet.",ep:4,g:571,l:115,wd:true,fm:true,w:5,p:1};
I.u[2562] = {n:"Slip de Trool",t:56,d:"À voir l\'état de son Slip, le Trool s\'assoit un peu n\'importe où. C\'est aussi grâce à ce Slip que l\'on peut déterminer l\'âge de son propriétaire. A vu de nez, bien sûr...",ep:4,g:572,l:115,wd:true,fm:true,w:1,p:1};
I.u[2563] = {n:"Cale en bois du Tronknyde",t:38,d:"Pour le Tronknyde, cette Cale sert de pied, car le pied sert de Cale, malheureusement, le Tronknyde est toujours à la recherche d\'un cale-pied.",ep:9,g:573,l:35,wd:true,fm:true,w:2,p:1};
I.u[2564] = {n:"Sourcils de Tronknyde",t:38,d:"Vous vouliez connaître la technique du Tronknyde pour effrayer les visiteurs imprudents ? Et bien,vous l\'avez dans les mains : une bonne grosse paire de Sourcils bien épais.",ep:9,g:574,l:35,wd:true,fm:true,w:2,p:1};
I.u[2565] = {n:"Tranche de Tronknyde",t:15,d:"Après vous être taillé une bonne Tranche de ce Tronknyde, il doit bien tirer la tronche à présent.",ep:9,g:575,l:35,wd:true,fm:true,w:2,p:1};
I.u[2566] = {n:"Tranche Magique de Tronknyde",t:15,d:"Cette Tranche à l\'air différente des autres Tranches de Tronknyde. Au moment ou elle fut coupée, une lumière aveuglante a jailli du Tronknyde et a ensuite disparu, ne laissant au sol que la Tranche.",ep:9,g:576,l:35,wd:true,fm:true,w:2,p:1};
I.u[2567] = {n:"Anticipation",t:29,d:"Cette bénédiction permet d\'être plus vif pour les prochains combats.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2568] = {n:"Reflexes Soushumains",t:30,d:"Cette malédiction vous plonge dans un état de semi-conscience et vos réflexes en sont amoindris pour le prochain combat",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2569] = {n:"Parchemin de Reflexes Surhumain",t:14,d:"Ce Parchemin permet d\'être plus vif pour le prochain combat.",ep:1,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2570] = {n:"Parchemin de Reflexes Soushumains",t:14,d:"Ce Parchemin permet d\'être un brin inerte pour le prochain combat.",ep:1,g:29,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2571] = {n:"Patte de Prespic",t:103,d:"Comment un Prespic, et vous devez vous poser sûrement la même question, fait-il pour être aussi agile avec ces deux malheureux doigts de patte? Le mystère reste entier.",ep:1,g:577,l:18,wd:true,fm:true,w:1,p:1};
I.u[2572] = {n:"Estomac de Prespic",t:15,d:"\"À force de manger la même chose, tu vas finir par ressembler à ce que tu manges\". Tel était la sage parole du cuisinier Bontarien Jon-kierre Poff. Voilà qui explique pourquoi le Prespic a l\'estomac verdi par le gazon ingéré.",ep:1,g:578,l:18,wd:true,fm:true,w:1,p:1};
I.u[2573] = {n:"Queue de Prespic",t:65,d:"Le Prespic fait usage de sa queue très rarement, et fort heureusement d\'ailleurs, car la puissance qui réside dans celle-ci se révèle surprenante. Certains bûcherons ont même vu des Prespic en pleine nuit trimbaler des rondins de Bois avec leurs queues.",ep:1,g:579,l:18,wd:true,fm:true,w:1,p:1};
I.u[2574] = {n:"Crinière de Prespic",t:15,d:"Pour les soirées dites \"Vie-Ail-Pie\", cette Crinière sera du plus bel effet. Emmenez un ami Osamodas et on vous prendra pour son invocation.",ep:1,g:580,l:18,wd:true,fm:true,w:1,p:1};
I.u[2575] = {n:"Scalp de Mulou",t:15,d:"À votre arrivée, le Mulou avait certainement la même intention que vous, c\'est-à-dire de vous extraire avec plus ou moins de diplomatie votre Scalp. Le voilà pris de vitesse.",ep:1,g:581,l:70,wd:true,fm:true,w:1,p:1};
I.u[2576] = {n:"Scalp de Milimulou",t:15,d:"À votre arrivée, le Milimulou avait certainement la même intention que vous, c\'est-à-dire de vous extraire avec plus ou moins de délicatesse votre Scalp. Le voilà bien malin sans le haut de son crâne.",ep:1,g:582,l:22,wd:true,fm:true,w:1,p:1};
I.u[2577] = {n:"Scalp de Meulou",t:15,d:"À votre arrivée, le Meulou avait certainement la même intention que vous, c\'est-à-dire de vous extraire avec plus ou moins de tact votre Scalp. Le voilà prêt à attraper un rhume du cerveau.",ep:2,g:583,l:198,wd:true,fm:true,w:1,p:1};
I.u[2578] = {n:"Oeil de Mulou",t:109,d:"Même arraché, le regard du Mulou reste porté sur vous. Et si vous regardez attentivement, vous aurez tendance à penser qu\'il vous suit des yeux, ou plutôt de l\'oeil.",ep:1,g:584,l:70,wd:true,fm:true,w:1,p:1};
I.u[2579] = {n:"Oeil du Milimulou",t:109,d:"Même arraché, le regard du Milimulou reste porté sur vous. Et si vous regardez attentivement, l\'oeil cligne encore des paupières. Quelle vitalité ce Milimulou.",ep:1,g:585,l:22,wd:true,fm:true,w:1,p:1};
I.u[2580] = {n:"Oeil de Meulou",t:109,d:"Même arraché, le regard du Meulou reste porté sur vous. Et si vous regardez attentivement, il fronce les sourcils quand vous le pointez du doigt. Décidément, le Meulou n\'est pas la pour la boutade.",ep:2,g:586,l:198,wd:true,fm:true,w:1,p:1};
I.u[2581] = {n:"Dents de Meulou",t:47,d:"Dans la famille des Mulous, si vous cherchez celui qui a les plus grandes dents, vous venez de faire bonne pioche. C\'est pour mieux vous baver dessus mes enfants.",ep:2,g:587,l:198,wd:true,fm:true,w:1,p:1};
I.u[2582] = {n:"Testicules de Meulou",t:15,d:"Si le prix des Testicules de Mulou est scandaleux, vous comprendrez que ce que vous avez en main vaut au bas mot une sacrée paire... de lingots.",ep:2,g:588,l:198,wd:true,fm:true,w:20,p:1};
I.u[2583] = {n:"Oeil de Crabe",t:109,d:"Les marins d\'eau douce sont assez friands de cet Oeil de Crabe, car on peut en capturer sur la terre ferme.",ep:1,g:589,l:4,wd:true,fm:true,w:1,p:1};
I.u[2584] = {n:"Main de Boo",t:15,d:"Cette Main de Boo est recouverte de boue. À moins qu\'il n\'y ait rien sous cette boue, même pas la Main du Boo.",ep:2,g:590,l:19,wd:true,fm:true,w:1,p:1};
I.u[2585] = {n:"Coeur de Boue du Boo",t:15,d:"Muni de son Coeur de Boue, le Boo est dur à classer dans la chaîne alimentaire. En réfléchissant un peu, le Boo viendrait sûrement au bout de la chaîne.",ep:2,g:591,l:19,wd:true,fm:true,w:1,p:1};
I.u[2586] = {n:"Aile de Dragodinde Rousse Sauvage",t:104,d:"Cette Aile sent le soufre. Tout bon éleveur de Dragodindes vous dira que c\'est la partie la plus tendre pour un barbeulcu. Assaisonnez tout de même la viande, car l\'Aile est la partie la plus fade.",ep:2,g:592,l:29,wd:true,fm:true,w:1,p:1};
I.u[2587] = {n:"Hachette de Bûcheron",t:19,d:"Cette hachette est l\'outil indispensable à tout bûcheron. Non pas qu\'elle soit réellement utile, impossible de couper un arbre avec, mais sa présence à la ceinture les calme et les rassure.",ep:1,g:6,l:3,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,30,30,false,false],c:"CV>2",p:20};
I.u[2588] = {n:"Aile de Dragodinde",t:104,d:"On peut dire que la Dragodinde domestique est bien meilleure que sa cousine sauvage. Déjà, elle n\'a pas un arrière-goût de soufre, mais la chair est goûteuse à souhait, ce qui en fait le plat favori de tous les petits.",ep:2,g:593,l:29,wd:true,fm:true,w:1,p:1};
I.u[2589] = {n:"Hachette Hévlalav",t:19,d:"Cette petite hache ne sait pas couper les arbres, mais peut servir à se défendre contre certains petits monstres. Par contre il vous faudra toujours courir si c\'est un Minotoror.",ep:1,g:7,l:6,wd:true,fm:true,w:10,an:17,e:[10,4,1,1,40,40,false,false],p:60};
I.u[2590] = {n:"Hache Vôr\'Om",t:19,d:"Cette série de haches fut conçue par un bwork apprenti forgeur. Elle est bien équilibrée et relativement puissante. Ce bwork venait de créer LA hache de guerre pour jeune aventurier.",ep:1,g:13,l:12,wd:true,fm:true,w:15,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>10",p:120};
I.u[2591] = {n:"Queue de Dragodinde Rousse Sauvage",t:65,d:"L\'intérêt de cette queue est simple: posez-la sur un rocher rond et faites tourner la Queue. Quand la Queue s\'arrête, suivez la direction indiquée par la pointe. Telle était la façon de se déplacer des Sadida pendant des millénaires.",ep:2,g:594,l:27,wd:true,fm:true,w:1,p:1};
I.u[2592] = {n:"Coupeuse de Bombu",t:19,d:"Très légère et maniable, cette hache facilite les gestes amples nécessaires afin de couper le Bombu en toute sécurité.",ep:13,g:15,l:39,wd:true,fm:true,w:1,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>20&CW>20",p:390};
I.u[2593] = {n:"Elagueuse d\'Oliviolet",t:19,d:"Cette hache, faite d\'Oliviolet, est la hache la plus à même à résister aux ondes violettes de l\'Oliviolet. Combattre le mal par le mal en quelque sorte.",ep:14,g:14,l:42,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>60",p:420};
I.u[2594] = {n:"Queue de Dragodinde",t:65,d:"Étrangement, la Queue de Dragodinde n\'a aucun pouvoir magique. A l\'instar d\'un Crocodaille, la Queue repousse rapidement. Une légende raconte aussi qu\'une Dragodinde avait poussé au bout de la Queue. Vous voilà prévenu.",ep:2,g:595,l:17,wd:true,fm:true,w:1,p:1};
I.u[2595] = {n:"Hache de Pierre",t:19,d:"Cette hache, très primitive, n\'en reste pas moins efficace. Un peu comme certains vieillards.",ep:5,g:2,l:51,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>50&CV>60",p:510};
I.u[2596] = {n:"Lait de Dragodinde",t:15,d:"Les éleveurs apprécient le fait de pouvoir traire leurs Dragodindes. Le seul problème, c\'est que ce Lait ne se vend pas, car il est infect. Il sert donc juste à nourrir les Dragodindonettes.",ep:2,g:424,l:29,wd:true,fm:true,w:1,p:1};
I.u[2597] = {n:"Hache de Brèche",t:19,d:"Cette longue hache se faufile dans les moindres interstices des arbres pour mieux les fendre en deux. Son utilité en combat est la même, l\'adversaire ayant toujours un interstice ou deux à exploiter.",ep:14,g:16,l:54,wd:true,fm:true,w:20,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>70",p:540};
I.u[2598] = {n:"Pic de Dragodinde Rousse Sauvage",t:47,d:"Ce Pic n\'est autre qu\'une protubérance osseuse. La Dragodinde s\'en sert tellement peu, que l\'on se demandait comment faisait-elle pour les abîmer autant. Depuis que les Biologistes l\'ont vu se frotter aux Trools, on comprend mieux.",ep:2,g:596,l:29,wd:true,fm:true,w:1,p:1};
I.u[2599] = {n:"Pic de Dragodinde",t:47,d:"Situé sur le dos de la Dragodinde, ce Pic pourra peut-être vous servir à vous gratter l\'entrejambe, si vous parvenez à monter une Dragodinde.",ep:2,g:597,l:29,wd:true,fm:true,w:1,p:1};
I.u[2600] = {n:"Coupeuse de Sifflet",t:19,d:"Cette grosse hache fait un bruit monstrueux lorsqu\'elle s\'abat sur quelque chose, ce qui a souvent pour effet de provoquer le silence autour de soi. C\'est toujours ça de pris.",ep:14,g:17,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>30&CV>30&CA>30",p:660};
I.u[2601] = {n:"Hache Darsson",t:19,d:"Darsson était un vaillant Enutrof adroit comme ses pieds. Faisant souvent tomber sa pelle en combat, il eût l\'ingénieuse idée d\'attacher une hache de rechange à sa ceinture. Cela lui sauva la vie plusieurs fois, jusqu\'à ce qu\'il fasse tomber sa hache...",ep:14,g:18,l:57,wd:true,fm:true,w:15,an:17,e:[12,4,1,1,30,30,false,false],c:"CC>20&CA>20&CV>20",p:570};
I.u[2602] = {n:"Pétale de Trukikol",t:35,d:"Pas plus gros qu\'un Oeil de Crabe, le Pétale de Trukikol est constitué de plusieurs bulles collantes et spongieuses au toucher. Il sert le plus souvent à colmater les trous dans les toits après les rigoureuses tempêtes de fin d\'année.",ep:12,g:598,l:12,wd:true,fm:true,w:1,p:1};
I.u[2603] = {n:"Trancheuse de Partie",t:19,d:"Cette hache est très utile pour séparer certaines parties récalcitrantes d\'un arbre, notamment les petites boursoufflures du tronc, ceci dans le but d\'avoir un arbre parfaitement lisse et rond.",ep:13,g:2,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CS>30",p:660};
I.u[2604] = {n:"Bardiche du Milicien",t:19,d:"Cette bardiche est principalement employée par les miliciens d\'Amakna. Sa longueur et son efficacité doit probablement compenser d\'autres choses.",ep:13,g:3,l:78,wd:true,fm:true,w:30,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>30&CS>30&CW>30&CC>5",p:780};
I.u[2605] = {n:"Peau de Trukikol",t:59,d:"Ne soyez pas étonné si l\'on vous dit que la Peau de Trukikol colle. Grâce à elle, on arrive à tout faire tenir au plafond. Il faut avouer que c\'est aussi grâce au paysan qui a breveté l\'idée : un dénommé Roulio de Scautche.",ep:12,g:599,l:12,wd:true,fm:true,w:1,p:1};
I.u[2606] = {n:"Hachette Savante",t:19,d:"Sur cette grosse hachette, de multiples inscriptions gravées rappellent des notions Amakniennes de base. Son inventeur Claus Ansipedi désirait donner un semblant de culture aux brûtasses finies...peine perdue, il est mort le crâne fendu.",ep:4,g:4,l:81,wd:true,fm:true,w:30,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CA>50&CI>50",p:810};
I.u[2607] = {n:"Trukikol Mort",t:15,d:"Vous avez bien fait de le ramasser, il est intact. Mort, mais intact.",ep:12,g:600,l:14,wd:true,fm:true,w:10,p:1};
I.u[2608] = {n:"Francique Basquaise",t:19,d:"Cette hache fait souvent le tour du monde en commençant par le bas. Et pour cause c\'est dans le sud d\'Amakna que ce type de hache est forgée, par une petite guilde de chasseurs de trésors réputée pour leur efficacité.",ep:18,g:1,l:84,wd:true,fm:true,w:18,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>100&CS>50",p:840};
I.u[2609] = {n:"Carapace Verte Vide",t:107,d:"Mais où se cache le propriétaire ? Il a dû sortir s\'acheter du pain avec de la tomate dessus.",ep:7,g:601,l:24,wd:true,fm:true,w:2,p:1};
I.u[2610] = {n:"Carapace Rouge Vide",t:107,d:"Mais ou se cache le propriétaire? il a dû déménager depuis peu.",ep:7,g:602,l:24,wd:true,fm:true,w:2,p:1};
I.u[2611] = {n:"Carapace Jaune Vide",t:107,d:"Mais ou se cache le propriétaire ? il fait peut-être une sieste à l\'intérieur.",ep:7,g:603,l:24,wd:true,fm:true,w:2,p:1};
I.u[2612] = {n:"Vouge à Poisson",t:19,d:"Cette longue hache est utilisée par les marins experts pour affronter les poissons géants qui attaquent leurs navires. On imagine assez bien les dégâts qu\'elle peut faire contre des monstres plus petits.",ep:14,g:4,l:87,wd:true,fm:true,w:32,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>50&CA>50",p:870};
I.u[2613] = {n:"Carapace Bleue Vide",t:107,d:"Mais où se cache le propriétaire ? il doit être sous la douche.",ep:7,g:604,l:24,wd:true,fm:true,w:2,p:1};
I.u[2614] = {n:"Hache de Dame Oise",t:19,d:"La Dame Oise était une ravissante princesse qui respirait la candeur et la fraîcheur. Tout le monde fut bien surpris lorsque, lors d\'un raid Bwork sur sa cité, elle sortit cette hache et fracassa à elle seule la moitié de l\'armée adverse.",ep:18,g:5,l:90,wd:true,fm:true,w:28,an:17,tw:true,e:[10,4,1,1,40,40,false,false],c:"CV>150&CW>50&CS>250",p:900};
I.u[2615] = {n:"Hache de Lookabeer",t:19,d:"Cette hache est réputée pour son efficacité à terminer définitivement et très rapidement une querelle entre Enutrofs ivres.",ep:18,g:8,l:96,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>120",p:960};
I.u[2616] = {n:"Halle de Barde",t:19,d:"Cette hache tire son nom du test qui fut utilisé pour prouver sa terrible efficacité : une hache géante, un mythophobiaque et une halle remplie de bardes.",ep:14,g:7,l:99,wd:true,fm:true,w:40,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>100&CS>100",p:990};
I.u[2617] = {n:"Tranche de Nodkoko",t:15,d:"Haaa... Enfin un élément qui vous fait penser aux vacances. Cette Agence de Voyages ne paie rien pour attendre.",ep:12,g:605,l:14,wd:true,fm:true,w:1,p:1};
I.u[2618] = {n:"Kokopaille",t:15,d:"Pour siroter quelque chose de frais, rien de mieux qu\'une paille colorée. Il n\'y a plus qu\'à trouver un trou dans la Nodkoko.",ep:12,g:433,l:14,wd:true,fm:true,w:1,p:1};
I.u[2619] = {n:"Kokolait",t:15,d:"En voilà une bonne idée: avoir du Kokolait en bouteille, ça permet d\'en boire quand on veut et où que l\'on soit.",ep:12,g:423,l:14,wd:true,fm:true,w:1,p:1};
I.u[2620] = {n:"Rhum de Qualité",t:15,d:"Ce Rhum doit sortir d\'une cave très prisée. À moins qu\'il soit resté dans une poche pendant de bonnes générations.",ep:12,g:177,l:94,wd:true,fm:true,w:1,p:1};
I.u[2621] = {n:"Barbe du Chouque",t:15,d:"Vous venez d\'extraire du menton du Chouque sa Barbe. Bizarrement, les Dents sont venues avec. C\'est ça d\'être mort depuis longtemps, on perd des bouts.",ep:12,g:606,l:94,wd:true,fm:true,w:1,p:1};
I.u[2622] = {n:"Boucle du Chouque",t:15,d:"Du bout de cette Boucle, sept générations de pirates vous contemplent.",ep:12,g:607,l:94,wd:true,fm:true,w:2,p:1};
I.u[2623] = {n:"Bwak Squelettique",t:15,d:"Les éleveurs ont toujours cru que les Bwaks s\'envolaient très loin à la fin de leur vie. Toutefois, ce Bwak est une exception à la règle.",ep:12,g:608,l:94,wd:true,fm:true,w:1,p:1};
I.u[2624] = {n:"Feuille de Kokoko",t:36,d:"De hardis chasseurs veulent coûte que coûte et quoiqu\'il en coûte, récupérer en guise de souvenirs une Feuille de Kokoko, pour ensuite ne jamais revenir sur cette île maudite. Pourquoi pas ?",ep:12,g:609,l:42,wd:true,fm:true,w:1,p:1};
I.u[2625] = {n:"Poupée Vaudou Thierry",t:15,d:"Une force se dégage de cette Poupée, mais vous avez l\'étrange sensation qu\'elle appelle quelqu\'un.",ep:12,g:610,l:51,wd:true,fm:true,w:2,p:1};
I.u[2626] = {n:"Poupée Vaudou Jav",t:15,d:"Une force se dégage de cette Poupée, mais vous avez l\'étrange sensation qu\'elle cherche quelqu\'un.",ep:12,g:611,l:51,wd:true,fm:true,w:2,p:1};
I.u[2627] = {n:"Poupée Vaudou Sarbak",t:15,d:"Une force se dégage de cette Poupée, mais vous avez l\'étrange sensation qu\'elle écoute quelqu\'un.",ep:12,g:612,l:51,wd:true,fm:true,w:2,p:1};
I.u[2628] = {n:"Poupée Vaudou Archer",t:15,d:"Une force se dégage de cette Poupée, mais vous avez l\'étrange sensation qu\'elle attend quelqu\'un.",ep:12,g:613,l:51,wd:true,fm:true,w:2,p:1};
I.u[2629] = {n:"Caracape Minotoris",t:17,d:"Cette cape, d\'allure royale, constitue pourtant une incroyable protection. C\'est ce modèle qui a fait la réputation d\'une célèbre tailleuse, juste avant de mourir de son succès, écrasée par la foule.",ep:13,g:55,l:121,wd:true,fm:true,w:10,p:38500};
I.u[2630] = {n:"Pot de Gloutovore",t:15,d:"À la base, le Gloutovore n\'est pas très généreux. Avec ce Pot rempli à raz bord, vous voila bien chanceux. Reste plus qu\'à lui trouver une utilité.",ep:12,g:614,l:44,wd:true,fm:true,w:1,p:1};
I.u[2631] = {n:"Estomac de Gloutovore",t:15,d:"Voici l\'estomac le plus résistant que vous puissiez voir. Extensible à souhait, vous pourriez même vous cacher dedans si vous le souhaitiez.",ep:12,g:615,l:44,wd:true,fm:true,w:1,p:1};
I.u[2632] = {n:"Glouto Rhum",t:15,d:"Cette Bouteille a été laissée à l\'abandon à l\'intérieur d\'un Gloutovore. Quel gâchis ! Par contre, il a l\'air d\'avoir bien vieilli, il a gagné en arôme. Si les Paysans savaient ça, il y aurait des entrepôts remplis de Gloutovore.",ep:12,g:177,l:44,wd:true,fm:true,w:1,p:1};
I.u[2633] = {n:"Rhum Fourbe",t:15,d:"Alors là, c\'est le piège. La Fourbasse est tellement fourbe qu\'elle a rempli une bouteille de Rhum avec du... bah oui du Rhum, mais il a une odeur repérable à dix mille lieues : le Trukikol séché.",ep:12,g:177,l:24,wd:true,fm:true,w:1,p:1};
I.u[2634] = {n:"Lance Cassée",t:15,d:"Sans sa Lance, la Fourbasse fera moins la maligne. Reste à savoir ce que vous allez en faire.",ep:12,g:616,l:24,wd:true,fm:true,w:2,p:1};
I.u[2635] = {n:"Pain Gre",t:33,d:"Cette recette a été élaborée par un rival de Xavier le Boulanger, à savoir Danioul Garnioul le Boulanger. Son nom était si stupide que ses clients ne cessaient de se moquer de lui, il se vengeait en pétrissant avec ses pieds.",ep:1,g:13,l:80,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2636] = {n:"Pain Tahde",t:33,d:"Ce pain renferme de délicieuses lichettes de viande, qui ont la saveur et l\'apparence de volaille, mais méfiance il n\'en n\'est rien. En y regardant de plus près, on peut sentir une légère odeur de Tofu.",ep:1,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2637] = {n:"La Griffe",t:6,d:"Cette lame recourbée, faite d\'os, de cartilage et de corne, est aussi tranchante qu\'une griffe d\'Ecaflip. En un peu plus gros et plus propre.",ep:13,g:33,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[2638] = {n:"La Griffe Aiguisée",t:6,d:"Cent pour cent naturelle, cette épée est comme une sixième griffe pour une main Ecaflip. A ce propos, faites attention à ne pas vous grattouiller le museau avec cette griffe là !",ep:14,g:34,l:68,wd:true,fm:true,w:12,an:14,e:[12,4,1,1,30,50,false,false],c:"CV>30&CA>30&CS>30",p:6800};
I.u[2639] = {n:"Fausse Griffe de Ceangal",t:6,d:"Une forgeuse écaflipette eut l\'idée de forger cette épée après son échec à maitriser la technique ancestrale du même nom. Elle se disait qu\'au moins cette griffe ne lui ferait pas faux bond.",ep:14,g:35,l:95,wd:true,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[2640] = {n:"Bâton Carnivore",t:4,d:"Etrangement sculpté, ce Bâton ne provient pas du coin. Il sent les vieux endroits humides et sombres de Brâkmar.",ep:1,g:24,l:30,wd:true,fm:true,w:56,an:12,e:[3,5,1,1,20,50,false,false],s:7,p:1000};
I.u[2641] = {n:"Toady",t:16,d:"Rouge, blanc et surtout somptueusement classe, ce chapeau vous permettra d\'assurer un max lors des soirées de l\'ambassadeur qui sont toujours une réussite.",ep:1,g:51,l:30,wd:true,fm:true,w:10,s:7,p:2700};
I.u[2642] = {n:"Mâchoire de Rib",t:47,d:"Déjà que le Rib est un tantinet maigrelet, alors s\'il lui manque sa Mâchoire, il va se retrouver aussi offensif qu\'une armée de tiques en hibernation.",ep:3,g:617,l:33,wd:true,fm:true,w:1,p:1};
I.u[2643] = {n:"Défense de Dragon Cochon",t:47,d:"Cette défense appartient à l\'un des plus célèbres prédateurs des montagnes d\'Amakna: le Dragon Cochon. Des chasseurs seraient prêts à revendre leur famille entière pour posséder ce que vous avez en main. C\'est pour vous l\'occasion rêvée d\'acheter une famille à moindre frais.",ep:2,g:618,l:70,wd:true,fm:true,w:1,p:1};
I.u[2644] = {n:"Queue de Dragon Cochon",t:65,d:"Un régal que ce gros morceau de Queue de Dragon Cochon. Faites le sauter à la poële avec un peu de Graine de Sésame, le tout avec une Sauce hisson, et vos invités ne partiront plus de chez vous. N\'est-ce pas super chouette ? Non ? Bon...",ep:2,g:619,l:70,wd:true,fm:true,w:1,p:1};
I.u[2645] = {n:"Groin de Dragon Cochon",t:15,d:"À vue de Groin, le Dragon Cochon n\'a pas senti le coup venir. C\'est dommage pour lui.",ep:2,g:620,l:70,wd:true,fm:true,w:1,p:1};
I.u[2646] = {n:"Slip en cuir de Cochon de Lait",t:56,d:"Ce slip bien large va à ravir au Cochon de Lait, les coutures sont élastiques et renforcées, pour une plus grande efficacité lors des combats rapprochés. Comme l\'exige la tradition, ce slip ne doit jamais être lavé, sous peine de perdre ses propriétés intrinsèques encore inconnues et redoutées de nos jours.",ep:1,g:621,l:20,wd:true,fm:true,w:1,p:1};
I.u[2647] = {n:"Oreille de Cochon de Lait",t:106,d:"Le Cochon de Lait n\'est pas chassé généralement pour ses Oreilles, mais plutôt pour son ivoire. Mais bon, à défaut d\'Ivoire....",ep:1,g:623,l:20,wd:true,fm:true,w:1,p:1};
I.u[2648] = {n:"Griffes de Kwak",t:15,d:"Le Kwak n\'a rien d\'un charognard, mais il possède tout de même d\'étranges dépôts sous ses griffes qu\'il ne vaut mieux pas décrire.",ep:1,g:624,l:30,wd:true,fm:true,w:1,p:1};
I.u[2649] = {n:"Ver de Terre",t:15,d:"Ce Ver est le plat préféré des Kwaks sauvages. Ce qui est plus étrange, c\'est qu\'il est resté vivant alors qu\'il a été extrait de l\'Estomac du Kwak.",ep:5,g:625,l:30,wd:true,fm:true,w:1,p:1};
I.u[2650] = {n:"Ver d\'Eau",t:15,d:"Ce Ver est le plat préféré des Kwaks sauvages. Ce qui est plus étrange, c\'est qu\'il est resté vivant alors qu\'il a été extrait de l\'estomac du Kwak.",ep:1,g:626,l:30,wd:true,fm:true,w:1,p:1};
I.u[2651] = {n:"Ver de Feu",t:15,d:"Ce Ver est le plat préféré des Kwaks sauvages. Ce qui est plus étrange, c\'est qu\'il est resté vivant alors qu\'il a été extrait de l\'Estomac du Kwak.",ep:5,g:627,l:30,wd:true,fm:true,w:1,p:1};
I.u[2652] = {n:"Ver d\'Air",t:15,d:"Ce Ver est le plat préféré des Kwaks sauvages. Ce qui est plus étrange, c\'est qu\'il est resté vivant alors qu\'il a été extrait de l\'Estomac du Kwak.",ep:5,g:628,l:30,wd:true,fm:true,w:1,p:1};
I.u[2653] = {n:"Arakne Majeure Morte",t:15,d:"Vous avez bien fait de la ramasser, elle est intacte. Morte, mais intacte.",ep:1,g:629,l:43,wd:true,fm:true,w:10,p:1};
I.u[2654] = {n:"Oeuf d\'Arakne Majeure",t:105,d:"Le problème avec les Araknes, c\'est que l\'on peut se retrouver avec plusieurs générations en quelques jours avec la chaleur. Donc si le temps est caniculaire, ne vous promenez pas trop dans la Forêt des Abraknydes.",ep:1,g:630,l:43,wd:true,fm:true,w:1,p:1};
I.u[2655] = {n:"Ceinture Corbaquiale",t:10,d:"Cette ceinture a été confectionnée à partir des restes du Maître Corbac, soigneusement cousus entre eux. Vous devriez vous sentir respecté une fois équipé de celle-ci. Le Chouque a même accepté de prêter sa boucle pour l\'occasion.",ep:13,g:56,l:120,wd:true,fm:true,w:10,p:36938};
I.u[2656] = {n:"Fil Résistant",t:15,d:"Si les Cordonniers ainsi que les Tailleurs connaissaient l\'existence de ce Fil Résistant, il y aurait la Semaine du Fil Résistant, la Foire du Fil Résistant ainsi que le jour saint du Fil Résistant.",ep:1,g:631,l:43,wd:true,fm:true,w:1,p:1};
I.u[2659] = {n:"Pétale de Tournesol Sauvage",t:35,d:"Ce Pétale bouge. Oui, il bouge en fonction du soleil. Mettez le dans votre poche droite le matin, il sera dans votre poche gauche le soir venu.",ep:1,g:632,l:12,wd:true,fm:true,w:1,p:1};
I.u[2661] = {n:"Feuille de Tournesol Sauvage",t:36,d:"Cette partie du Tournesol n\'est pas que la Feuille de la plante, c\'est aussi sa voûte plantaire. Ne vous étonnez donc pas si elle sent des pieds.",ep:1,g:633,l:12,wd:true,fm:true,w:1,p:1};
I.u[2662] = {n:"Bave de Rose Démoniaque",t:15,d:"Une Rose enragée a la fâcheuse habitude de baver sur quiconque ose s\'approcher. Mais il paraît que c\'est un signe d\'affection. Une Rose Démoniaque enragée et affective qui plus est, on aura tout vu.",ep:1,g:634,l:8,wd:true,fm:true,w:1,p:1};
I.u[2663] = {n:"Engrais",t:15,d:"Toute belle plante a besoin d\'Engrais. Les Enutrofettes sur le déclin peuvent donc s\'en passer.",ep:1,g:635,l:8,wd:true,fm:true,w:1,p:1};
I.u[2664] = {n:"Os de Crocodaille",t:47,d:"Cet os verdâtre et pour le moins étrange, provient d\'une patte de Crocodaille. Ce dernier a sûrement dû verser des larmes de Crocodaille quand il a compris qu\'il avait une patte en moins.",ep:4,g:636,l:36,wd:true,fm:true,w:2,p:100};
I.u[2665] = {n:"Herbe Folle",t:36,d:"Voici le genre d\'Herbe que l\'on met dans les enclos pour Bouftous. Cette Herbe est folle car de temps à autres, elle se lève et s\'échappe de l\'enclos, ce qui n\'est pas commun pour une touffe d\'herbe.",ep:1,g:637,l:9,wd:true,fm:true,w:1,p:1};
I.u[2666] = {n:"Sabot du Minotoror",t:47,d:"Il a dû écraser pas mal d\'aventuriers avec ce Sabot. Maintenant, il doit moins faire le malin à danser sur une seule patte. Quoique cela va lui donner une démarche encore plus inquiétante qu\'avant.",ep:2,g:800,l:125,wd:true,fm:true,w:1,p:1};
I.u[2667] = {n:"Queue de Minotoror",t:65,d:"Cela relève tout de même de l\'exploit de voir une Queue de Minotoror, sans le Minotoror qui va avec. Le pauvre doit chercher partout après. A moins qu\'il ne s\'en soit toujours pas rendu compte, ce qui n\'est pas impossible.",ep:2,g:640,l:125,wd:true,fm:true,w:1,p:1};
I.u[2669] = {n:"Chauve souris",t:15,d:"Parfois, les Vampires se transforment en Chauve Souris, pour mieux fuir. Mais ils se sentent obligés de lâcher un petit rire avant de s\'échapper. Ca donne à peu près ceci : \"niap nioop niap niap\". Ce rire peut mettre en déroute une armée... de tiques.",ep:3,g:641,l:21,wd:true,fm:true,w:1,p:1};
I.u[2673] = {n:"Oeuf pourri",t:105,d:"C\'est tout simplement honteux. Comment peut-on pondre un Oeuf de Tofu en décomposition? Il faut vraiment être Maléfique pour avoir des idées pareilles.",ep:1,g:642,l:3,wd:true,fm:true,w:1,p:1};
I.u[2674] = {n:"Citrouillette",t:46,d:"La citrouillette est délicieuse en cette saison. Pas trop petite pour avoir du goût, mais pas trop grosse non plus pour ne pas se transformer en Citwouille, succulente et remboursée par le sec Huh.",ep:4,g:643,l:15,wd:true,fm:true,w:1,p:1};
I.u[2675] = {n:"Plume de Tofu Maléfique",t:53,d:"Le Tofu Maléfique n\'a vraiment plus beaucoup de Plumes, il va finir par attraper un rhume carabiné, il ne faudra donc pas s\'étonner si vous l\'entendez éternuer la nuit.",ep:1,g:644,l:3,wd:true,fm:true,w:1,p:1};
I.u[2676] = {n:"Noeul Mort",t:15,d:"Vous avez bien fait de le ramasser, il est intact. Mort, mais intact.",ep:4,g:645,l:274,wd:true,fm:true,w:10,p:1};
I.u[2677] = {n:"Ceinture Chouqueuse",t:10,d:"Cette ceinture a été confectionnée à partir des éléments les plus puissants du Chouque, notamment son célèbre caleçon. De quoi mettre en émoi toutes les flibustières du bar des pirates.",ep:12,g:41,l:98,wd:true,fm:true,w:10,p:25000};
I.u[2678] = {n:"Ceinture Kokokette",t:10,d:"Cette ceinture ressemble presque à un pagne, elle conviendra parfaitement si vous voulez vous camoufler parmi les Kokokos de l\'île de Moon, ou tout simplement si vous désirez courtiser un Kokoko.",ep:12,g:40,l:42,wd:true,fm:true,w:10,p:4800};
I.u[2681] = {n:"Ceinture Tortue Jaune",t:10,d:"Cette petite ceinture est idéale pour protéger les parties sensibles, des coups critiques. \nVérifiez tout de même que le cordonnier a bien retiré le propriétaire de la carapace avant que vous ne l\'essayez.",ep:7,g:43,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2683] = {n:"Ceinture Tortue Bleue",t:10,d:"Cette petite ceinture est idéale pour protéger les parties sensibles, des coups critiques. \nVérifiez tout de même que le cordonnier a bien retiré le propriétaire de la carapace avant que vous ne l\'essayez.",ep:7,g:44,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2685] = {n:"Ceinture Tortue Verte",t:10,d:"Cette petite ceinture est idéale pour protéger les parties sensibles, des coups critiques. \nVérifiez tout de même que le cordonnier a bien retiré le propriétaire de la carapace avant que vous ne l\'essayez.",ep:7,g:42,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2687] = {n:"Ceinture Tortue Rouge",t:10,d:"Cette petite ceinture est idéale pour protéger les parties sensibles, des coups critiques. \nVérifiez tout de même que le cordonnier a bien retiré le propriétaire de la carapace avant que vous ne l\'essayez.",ep:7,g:45,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2688] = {n:"Ceinture Kolante",t:10,d:"Le moins que l\'on puisse dire, c\'est qu\'une fois enfilée, vous ne risquez plus de perdre cette ceinture. Elle fera le bonheur des étourdis et des victimes récurrentes de vols.",ep:12,g:46,l:50,wd:true,fm:true,w:10,p:6600};
I.u[2689] = {n:"Ceinture Banisation",t:10,d:"Le cordonnier qui a créé cette ceinture avec les restes d\'un Dragodinde devait vraiment manquer d\'imagination, pour lui donner un nom aussi stupide.",ep:2,g:47,l:29,wd:true,fm:true,w:10,p:2400};
I.u[2710] = {n:"Ceinture Banisation Sauvage",t:10,d:"Comportant des renforts en fer, c\'est une version améliorée de la classique Ceinture Banisation, elle a été spécialement conçue pour chasser les Dragodindes Sauvages dans les contrées sauvages.",ep:2,g:48,l:32,wd:true,fm:true,w:10,p:3000};
