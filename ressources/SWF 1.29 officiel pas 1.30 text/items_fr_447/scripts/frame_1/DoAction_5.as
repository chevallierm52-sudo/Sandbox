I.u[2150] = {n:"Graine de scorbute",t:58,d:"Ces graines ont été fabriquées à partir de venin de scorbute. En avaler une seule est mortel. En avaler deux l\'est doublement.",ep:14,g:405,l:36,wd:true,fm:true,w:1,p:1};
I.u[2151] = {n:"Blopisier empoisonné",t:33,d:"Ce gâteau est très bon, quand on y a pas ajouté des graines de scorbute...",ep:3,g:406,l:30,wd:true,fm:true,w:5,p:1};
I.u[2152] = {n:"Colonel Lyeno",t:32,d:"Amener le Colonel Lyeno à Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
