I.u[2157] = {n:"Clint",t:16,d:"Le Clint est un chapeau sobre mais qui en jette pas mal. La dernière version de ce chapeau convient aussi bien aux aventurières coquettes qu\'aux aventuriers virils. Sûrement un gage de qualité.",ep:1,g:38,l:50,wd:true,fm:true,w:10,c:"Ps=3",p:1};
I.u[2158] = {n:"Lettre d\'Oto Mustam pour Sbab",t:24,d:"Cette lettre, pleine d\'ironie, a pour unique but de dénigrer Sbab.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2159] = {n:"Parchemin de Courage",t:14,d:"Ce parchemin vous permet d\'améliorer votre Force, ce qui peut servir quand un Kanigrou enragé vous fonce dessus.",ep:1,g:2,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2160] = {n:"Parchemin Décourageant",t:14,d:"Ce parchemin vous permet de réduire la Force d\'une cible unique, ce qui peut servir quand un Kanigrou enragé fonce sur votre ennemi juré.",ep:1,g:4,l:1,wd:true,fm:true,w:1,ut:true,p:300};
