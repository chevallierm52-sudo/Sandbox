I.u[2018] = {n:"Blé d\'Or",t:34,d:"Ce blé recèle des pouvoirs magiques puissants.",ep:1,g:474,l:1,wd:true,fm:true,w:2,p:0};
I.u[2019] = {n:"Farine de Blé Magique",t:52,d:"Cette farine fut préparée avec un épi de blé d\'Or. Impressionnant.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[2020] = {n:"Pain Doré",t:33,d:"Ce pain fut pétri à la farine de blé magique. Celui qui en vend le plus se retrouve plus riche qu\'auparavant.",ep:1,g:69,l:10,wd:true,fm:true,w:2,c:"Cv<10",u:true,ut:true,p:1};
I.u[2021] = {n:"Houblon Brillant",t:34,d:"Ce houblon possède une aura brillante très discrète, révélant la magie que la terre mère lui a prêtée.",ep:1,g:475,l:30,wd:true,fm:true,w:2,p:0};
I.u[2022] = {n:"Farine de Houblon Magique",t:52,d:"Cette farine fut fabriquée en utilisant un houblon brillant. Nul doute qu\'elle renferme des capacités magiques.",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[2024] = {n:"Briochette",t:33,d:"Cette petite brioche est fabriquée à partir de houblon. Ce qui explique l\'impression d\'afflux d\'énergie quand on la mange.",ep:1,g:8,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2025] = {n:"Briochette magique",t:33,d:"Cette petite brioche est fabriquée à partir de houblon magique. Ce qui explique l\'impression d\'un énorme afflux d\'énergie quand on la mange",ep:1,g:8,l:20,wd:true,fm:true,w:1,c:"Cv<20",u:true,p:1};
I.u[2026] = {n:"Lin Tempête",t:34,d:"Ce Lin a subi les pires tempêtes, et s\'est relevé plus de sept fois, ce qui en soi est assez extraordinaire pour du lin, il faut le rappeler. Après avoir rouï à la rosée magique des champs du Grand Pahti pendant plus de 148 années, sa fibre finira avec un peu de chance par être enfin utilisable.",ep:1,g:476,l:40,wd:true,fm:true,w:1,p:0};
I.u[2027] = {n:"Farine de Lin magique",t:52,d:"Cette farine a été préparée avec du Lin tempête. Elle possède probablement les mêmes vertus de résistance.",ep:1,g:254,l:1,wd:true,fm:true,w:1,p:0};
I.u[2028] = {n:"Pain consistant magique",t:33,d:"Ce pain est fait à partir de Farine de Lin Tempête, ce qui explique pourquoi il n\'est pas gras et a bon goût.",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"Cv<30",u:true,ut:true,p:1};
I.u[2029] = {n:"Seigle Résistant",t:34,d:"Cette céréale sombre a réussi à pousser dans des conditions impossibles.",ep:1,g:477,l:50,wd:true,fm:true,w:2,p:0};
I.u[2030] = {n:"Farine de Seigle Magique",t:52,d:"Cette farine hérite de tous les bienfaits du Seigle Résistant. Elle provoque donc d\'importants effets laxatifs en cas de consommation excessive.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[2031] = {n:"Pain de Seigle Résistant",t:33,d:"Ce pain est fait à partir de farine de Seigle Résistant, ce qui lui donne une saveur exécrable, mais possède des qualités nutritionnelles uniques.",ep:1,g:9,l:10,wd:true,fm:true,w:1,c:"Cv<40",u:true,ut:true,p:1};
I.u[2032] = {n:"Orge en Sucre",t:34,d:"Cette Orge très rare, a absorbé de l\'eau de pluie sucrée lors de sa germination, ce qui lui a conféré des propriétés magiques inestimables.",ep:1,g:477,l:10,wd:true,fm:true,w:2,p:0};
I.u[2033] = {n:"Farine d\'Orge en Sucre",t:52,d:"Cette farine a été obtenue avec de l\'Orge en Sucre, elle permet de donner un pain si léger qu\'il pourrait s\'envoler à la moindre bourrasque de vent. Ce n\'est pas une raison pour en manger plus que de raison.",ep:1,g:256,l:1,wd:true,fm:true,w:1,p:0};
I.u[2034] = {n:"Sucre d\'Orge",t:42,d:"En extrayant le sucre de la farine d\'orge sucré on parvient à créer ce bonbon unique au goût magique.",ep:1,g:128,l:1,wd:true,fm:true,w:1,c:"Cv<50",u:true,p:50000};
I.u[2035] = {n:"Chanvre Euphorique",t:34,d:"Cette tige de chanvre semble avoir des effets inhibant extrêmement puissants. Manipulée par un spécialiste, elle pourrait révéler un certain intérêt.",ep:1,g:478,l:70,wd:true,fm:true,w:1,p:0};
I.u[2036] = {n:"Avoine Aurifère",t:34,d:"Quand on regarde cette avoine, on a l\'impression qu\'elle pleure de l\'Or, signe de la grande puissance magique qu\'elle a emmagasinée pendant sa pousse.",ep:1,g:551,l:20,wd:true,fm:true,w:2,p:0};
I.u[2037] = {n:"Farine d\'Avoine Aurifère",t:52,d:"Cette farine a été obtenue avec de l\'avoine aurifère, ce qui lui donne une douce couleur dorée et un pouvoir magique indéniable. Elle ne fera cependant pas de vous un pâtissier magicien.",ep:1,g:250,l:1,wd:true,fm:true,w:1,p:0};
I.u[2038] = {n:"Pain aux Flocons d\'Avoine Aurifère",t:33,d:"Ce pain à la mie ultra légère est tout simplement parfait.",ep:1,g:5,l:10,wd:true,fm:true,w:2,c:"Cv<70",u:true,ut:true,p:1};
I.u[2039] = {n:"Marque de test du chasseur",t:24,d:"Vous avez essayé de passer le test pour devenir chasseur.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2040] = {n:"Coffre caché de Tsog",t:24,d:"Vous avez retrouvé le coffre de Tsog dans une petite boîte. C\'est étrange comme cette boîte sent la même chose que Tsog, une odeur indescriptible.",ep:2,g:56,l:1,wd:true,fm:true,w:0,p:1};
I.u[2041] = {n:"Cuisse malodorante de Bouftou",t:24,d:"Cette cuisse pue la mort bien que cela ne soit pas lié avec le décès prématuré de son propriétaire.",ep:1,g:64,l:20,wd:true,fm:true,w:0,p:1};
I.u[2042] = {n:"Os de Mak Gahan",t:24,d:"Vous avez pris cet os après avoir éparpillé le corps de Mak Gahan le chafer dans les quatre coins de la pièce.",ep:1,g:57,l:1,wd:true,fm:true,w:0,p:1};
I.u[2043] = {n:"Nom de l\'assassin griffoné",t:24,d:"Sur ce bout de papier gluant et puant se trouve le nom de l\'assassin du tenancier du Chabrulé.",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2044] = {n:"Bière du Chabrulé",t:37,d:"Cette bière ressemble trop à de la pisse de chat... Ou pas assez.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:6};
I.u[2045] = {n:"Reçu de caisse",t:24,d:"Ce document prouve que vous avez rapporté une caisse.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2046] = {n:"Clef de Brâkmar",t:24,d:"Cette clef a été volée par un écureuil pour d\'obscures raisons.",ep:2,g:61,l:1,wd:true,fm:true,w:0,p:1};
I.u[2047] = {n:"Liste des soldats prenant leur pause",t:24,d:"Cette liste vous a été donnée par le milicien dans la taverne. Les noms suivants y apparaissent : \nBrank Thoof, Haco Norss, Jack Rottance, Kad Maxy",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2048] = {n:"Liste des soldats prenant leur pause",t:24,d:"Cette liste vous a été donnée par le milicien dans la taverne. Les noms suivants y apparaissent : \nHaco Norss, Tink Berval, Brank Thoof, Kad Maxy, Seta Bnamron",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2049] = {n:"Aveux du Guerrier Xale DuGros",t:24,d:"Xale DuGros avoue ne pas aller à la taverne, cependant il prend des pauses régulièrement.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2050] = {n:"Aveux de Guerrier Nager Nacmeil",t:24,d:"Le guerrier Nager Nacmeil avoue ne pas prendre de pause, car il ne va pas très bien en ce moment.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2051] = {n:"Aveux Bishom Pot",t:24,d:"Bishom Pot avoue tout, son comportement est impardonnable.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2052] = {n:"Permission signée et datée",t:24,d:"Ce document indique que vous avez une journée de libre.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2053] = {n:"Badge de milicien Allen Tokar",t:24,d:"Badge du milicien Allen Tokar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2054] = {n:"Badge de milicien Tek Apout",t:24,d:"Badge du milicien Tek Apout.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2055] = {n:"Badge de milicien Bill Iédebar",t:24,d:"Badge du milicien Bill Iédebar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2056] = {n:"Oeil de Corbac",t:109,d:"Un oeil de corbac est toujours utile, mais attention à ce que le mauvais oeil ne tombe pas sur vous.",ep:1,g:326,l:20,wd:true,fm:true,w:1,p:100};
I.u[2058] = {n:"Coeur de Brandon",t:15,d:"Ce coeur humain vient sûrement du célèbre Lhi, qui était passionné par les corbacs.",ep:1,g:328,l:20,wd:true,fm:true,w:5,p:500};
I.u[2059] = {n:"Corbac Mort",t:15,d:"Vous avez bien fait de le ramasser, il est intact. Mort, mais intact.",ep:1,g:329,l:20,wd:true,fm:true,w:10,p:100};
I.u[2060] = {n:"Patte de Corbac",t:103,d:"Pas de quoi casser une patte à un corbac. Surtout qu\'à l\'inverse de la patte de wabbit, la patte de corbac risque de vous porter malheur.",ep:1,g:330,l:20,wd:true,fm:true,w:1,p:10};
I.u[2061] = {n:"Cape du Corbac",t:17,d:"Cette cape, pas très jolie au premier abord est pourtant très efficace, une fois que l\'on s\'habitue à son odeur de Corbac en décomposition.",ep:1,g:15,l:45,wd:true,fm:true,w:5,p:5600};
I.u[2062] = {n:"Camouflage",t:31,d:"Vous êtes camouflé au sein du décor, jusqu\'à ce que vous rentriez en combat.",ep:1,g:1,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2063] = {n:"Bottes Volatiles",t:11,d:"Ces bottes, confectionnées avec de nombreuses parties de cadavre de Corbac, donnent à leur porteur une étrange sensation de légèreté, comparable à celle apportée par la consommation de Bolets grillés.",ep:1,g:17,l:41,wd:true,fm:true,w:15,p:4500};
I.u[2064] = {n:"Parchemin de Camouflage",t:14,d:"Ce parchemin vous permet de vous camoufler au sein du décor, jusqu\'à ce que vous rentriez en combat. Évitez les mouvements brusques et les bruits suspects si vous ne voulez pas être découvert...",ep:16,g:1,l:10,wd:true,fm:true,w:1,c:"Pg=10&PM=B",u:true,p:250};
I.u[2065] = {n:"Casque de chafer d\'élite",t:24,d:"Ce casque de Chafer est endommagé, mais toujours aussi efficace lorsque l\'on veut faire partie de l\'élite.",ep:2,g:59,l:1,wd:false,fm:true,w:0,p:1};
I.u[2066] = {n:"Bâton du Kanigrou",t:4,d:"Ce bâton, est une réplique approximative de celui d\'un Kanigrou. Il réserve quelques surprises, mais pas uniquement de bonnes surprises...",ep:13,g:22,l:54,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,50,false,false],c:"CS>50&CA>40&CC>30",p:5400};
I.u[2067] = {n:"Potion d\'oubli : Flamiche",t:43,d:"Cette potion permet d\'oublier un niveau du sort élémentaire \'Flamiche\'",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2068] = {n:"Potion d\'oubli : Cawotte",t:43,d:"Cette potion permet d\'oublier un niveau du sort élémentaire \'Cawotte\'",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2069] = {n:"Potion d\'oubli: \'Marteau de Moon\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort élémentaire \'Marteau de Moon\'",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2070] = {n:"Shako",t:16,d:"Ce casque en os a longtemps séjourné dans les poches d\'un Kanigrou. Usé, rayé, il garde tout de même de belles propriétés.",ep:9,g:58,l:34,wd:true,fm:true,w:15,p:3200};
I.u[2071] = {n:"Potion d\'oubli : \'Libération\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort élémentaire \'Libération\'",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2072] = {n:"Potion d \'oubli : \'Foudroiement\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort élémentaire \'Foudroiement\'",ep:5,g:36,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[2073] = {n:"Potion d\'oubli : \'Brokle\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort spécial \'Brokle\'",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2074] = {n:"Bwak de Feu",t:18,d:"Ce mignon petit bwak deviendra, plus tard, un affreux kwak. Jusque là n\'ayez pas peur de le garder à vos cotés.",ep:1,g:3,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:2,p:1};
I.u[2075] = {n:"Bwak d\'Eau",t:18,d:"Ce mignon petit bwak deviendra, plus tard, un affreux kwak. Jusque là n\'ayez pas peur de le garder à vos cotés.",ep:1,g:2,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:13,p:1};
I.u[2076] = {n:"Bwak d\'Air",t:18,d:"Ce mignon petit bwak deviendra, plus tard, un affreux kwak. Jusque là n\'ayez pas peur de le garder à vos cotés.",ep:1,g:4,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:15,p:1};
I.u[2077] = {n:"Bwak de Terre",t:18,d:"Ce mignon petit bwak deviendra, plus tard, un affreux kwak. Jusque là n\'ayez pas peur de le garder à vos cotés.",ep:1,g:5,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:14,p:1};
I.u[2078] = {n:"Testament d\'Ixa Mustam",t:24,d:"Le testament du père d\'Oto Mustam, il est écrit en ancien Brâkmarien, dommage pour vous, votre connaissance dans cette langue ce résume au mot : \"Guo\'rhalys !\" .",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2079] = {n:"Vin de Gloutovore",t:24,d:"Il paraît qu\'il faut 20 ans pour arriver à distiller du jus de Gloutovore sans créer un vin toxique.",ep:2,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[2080] = {n:"Jus de Gloutovore",t:24,d:"Le jus de Gloutovore est aussi toxique que du jus de scorbute. Mais bien distillé il donne un vin au goût incomparable. Cela dit rare sont gens sachant distiller ce jus. Et la plupart du temps se sont des pirates.",ep:2,g:63,l:1,wd:true,fm:true,w:1,p:1};
I.u[2081] = {n:"Rapport de Finche Aticus",t:24,d:"Le rapport de l\'espion Finche Aticus indique une liste exhaustive des armes de Bonta et de ses effectifs.",ep:2,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[2082] = {n:"Marcassin",t:32,d:"Lorsqu\'un jeune marcassin voit ses parents mourir sous ses yeux, il suit l\'assassin pour que ce dernier s\'occupe de lui.",ep:13,g:1,l:1,wd:true,fm:true,w:0,m:true,p:10};
I.u[2083] = {n:"Lettre d\'Oto Mustam",t:24,d:"Une lettre de votre maître adressée à Vil Smisse. Elle est écrite dans un dialecte inconnu pour éviter que les curieux dans votre genre y jettent un oeil.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2084] = {n:"Réponse de Vil Smisse",t:24,d:"Une réponse de Vil Smisse à Oto Mustam, complètement incompréhensible pour le commun des mortels.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2085] = {n:"Bière de la Tabasse",t:37,d:"Non seulement elle n\'a aucun goût, mais en plus cette bière est hors de prix. Encore un point commun avec la gente féminine.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2086] = {n:"Bière du Alakarte",t:37,d:"Cette bière aromatisée au Blop Griotte est aussi parfois appelée Manoca.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,p:3};
I.u[2087] = {n:"Bière de la Bagrutte",t:37,d:"Cette bière vous rend plus vaillant l\'espace d\'un instant... attention cependant à la chute, car l\'instant est vraiment très bref.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2088] = {n:"Bière de la Chopenbois",t:37,d:"Une bière classique, mais la choppe en revanche est superbement sculptée. Pour une fois, le contenant a plus de valeur et d\'importance que le contenu. Une caractéristique partagée avec le crâne des Iops et la presse populaire.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2089] = {n:"Bière du Pinchaut",t:37,d:"Cette bière est chaude ce qui la rend difficilement buvable en été. En revanche, elle dégage une agréable odeur de pain grillé, ce qui en fait une bière parfaite pour les petits déjeuners sans pain.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2090] = {n:"Bière du Ferayeur",t:37,d:"Cette bière a un arrière-goût de ferraille très désagréable, mais est fortement revitalisante, ce qui n\'est pas sans rappeler les bisous de la Momie Nova.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:7};
I.u[2091] = {n:"Le Bwak : Bien l\'élever",t:25,d:"Ce livre explique comment élever un Bwak.",ep:3,g:4,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2092] = {n:"Le Chacha : Bien l\'élever",t:25,d:"Ce livre explique comment élever un Chacha.",ep:3,g:3,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2093] = {n:"Le Wabbit : Bien l\'élever",t:25,d:"Ce livre explique comment élever un Wabbit.",ep:3,g:5,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2094] = {n:"Makroute Sombre",t:16,d:"Le Makroute Sombre est un chapeau qui provient d\'un Makroute Déchiqueté recousu à la main et sans anesthésie. \nMaintenant, il n\'obéit plus qu\'à son maître et adore mordre les inconnus.",ep:14,g:33,l:50,wd:true,fm:true,w:5,p:6600};
I.u[2095] = {n:"Le Ours",t:16,d:"Le Ours est un chapeau confectionné dans la tête d\'un ours mort. Il a cependant gardé un poil soyeux. Le tailleur qui l\'a confectionné devait être très habile pour avoir réussi a garder l\'expression de mécontentement de l\'ours d\'origine.",ep:14,g:34,l:35,wd:true,fm:true,w:5,p:10000};
I.u[2096] = {n:"Dora Sombre de Brave",t:16,d:"C\'est le fantôme Brave qui le premier comprit comment utiliser correctement de l\'Osier Sombre à des fins autres que gastronomiques.",ep:14,g:35,l:37,wd:true,fm:true,w:5,p:3800};
I.u[2097] = {n:"Champo",t:16,d:"Le Champo appartenait à l\'un des plus grands Maîtres Bolet d\'Amakna. Vaillant et brillant, Gnion le Bolet était le seul de sa race à avoir réussi à se faire respecter des êtres humains.",ep:1,g:36,l:43,wd:true,fm:true,w:25,p:5000};
I.u[2098] = {n:"Certificat de Mise en Chanil : Bwak de Terre",t:77,d:"Ce certificat décrit les caractéristiques du Bwak de Terre que vous avez placé au chanil.",ep:3,g:21,l:1,wd:false,fm:true,w:1,p:100};
I.u[2099] = {n:"Certificat de Mise en Chanil : Bwak de Feu",t:77,d:"Ce certificat décrit les caractéristiques du Bwak de Feu que vous avez placé au chanil.",ep:3,g:23,l:1,wd:false,fm:true,w:1,p:100};
I.u[2100] = {n:"Certificat de Mise en Chanil : Bwak d\'Eau",t:77,d:"Ce certificat décrit les caractéristiques du Bwak d\'Eau que vous avez placé au chanil.",ep:3,g:22,l:1,wd:false,fm:true,w:1,p:100};
I.u[2101] = {n:"Certificat de Mise en Chanil : Bwak d\'Air",t:77,d:"Ce certificat décrit les caractéristiques du Bwak d\'Air que vous avez placé au chanil.",ep:3,g:20,l:1,wd:false,fm:true,w:1,p:100};
I.u[2102] = {n:"Certificat de Mise en Chanil : Wabbit",t:77,d:"Ce certificat décrit les caractéristiques du Wabbit que vous avez placé au chanil.",ep:3,g:25,l:1,wd:false,fm:true,w:1,p:100};
I.u[2103] = {n:"Formulaire de Welloy Cab",t:24,d:"Écrit à la patte par Welloy Cab, ce rapport ravira tous les amateurs de chiffres et de phrases creuses.",ep:1,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2104] = {n:"Kraignosse",t:16,d:"Le Kraignosse est un casque inquiétant confectionné à partir de restes d\'Ouginak et de divers détritus. Longtemps porté par Gourlo le Terrible, le Kraignosse fût l\'image de la désolation.",ep:14,g:37,l:48,wd:true,fm:true,w:30,p:6000};
I.u[2105] = {n:"Formulaire de rapport vierge",t:24,d:"Formulaire de rapport vide de toute annotation. \nPrêt à être rempli par Welloy Cab",ep:1,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2106] = {n:"Liste d\'Appâts pour pêcheur",t:24,d:"Vous devez aller chercher les appâts le plus rapidement possible.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2107] = {n:"Appâts spéciaux",t:24,d:"Cette boîte d\'appâts spéciaux ressemble à une vulgaire boîte de Chabon.",ep:1,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[2108] = {n:"Badge de Tabach",t:24,d:"Badge de Tabach, Greffier de l\'Ordre du Coeur Vaillant.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2109] = {n:"Badge de Ybaul",t:24,d:"Badge de Ybaul, Greffière de l\'Ordre de l\'Esprit Salvateur.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2110] = {n:"Badge d\'Aigurraf",t:24,d:"Badge d\'Aigurraf, Greffier de l\'Ordre de l\'Oeil Attentif",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2111] = {n:"L\'âme du pêcheur",t:25,d:"Ce livre explique les ficelles pour devenir un bon pêcheur",ep:2,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2112] = {n:"L\'âme du chasseur",t:25,d:"Ce livre explique les ficelles pour devenir un bon chasseur",ep:3,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2114] = {n:"Aliment inconnu",t:15,d:"Cet aliment est inconnu.",ep:1,g:0,l:1,wd:true,fm:true,w:10,p:1};
I.u[2116] = {n:"Recette de la Nocabregor",t:24,d:"Pour créer de la poudre Nocabregor, il faut 3 mesures de poudre de Perlinpainpain et 1 huile de Koode. \nSeul un artificier ou un enchanteur est capable de réaliser cette recette à l\'aide d\'un Silex ...",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2117] = {n:"Dent de Croc Gland enragé",t:24,d:"Cette dent a été arraché avec bravoure à un loup enragé.",ep:2,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2118] = {n:"Cape Brâkmarienne",t:17,d:"Cette cape permet de passer incognito dans un cimetière, ou de se déguiser en Chafeuse lorsque le besoin d\'extrême perversité se fait sentir.",ep:1,g:20,l:1,wd:true,fm:true,w:7,c:"Ps=2",p:800};
I.u[2119] = {n:"Cape Bontarienne",t:17,d:"Cette cape vous donne des ailes. La fumée qui s\'en dégage lorsqu\'elle brûle, pourra même vous faire planer.",ep:5,g:34,l:1,wd:true,fm:true,w:3,c:"Ps=1",p:800};
I.u[2120] = {n:"Paroles d\'Ixa Mustam",t:24,d:"\"Mon testament se trouve au phare d\'Amakna, équipe toi d\'une petite Pelle de Boisaille pour le déterrer. Et donne une claque à mon fils de ma part !\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2121] = {n:"Paroles de Tsog",t:24,d:"\"J\'ai caché un coffre à la pointe Est de Sufokia, dans un tunnel, sous des tonneaux de vin. Je te conseille de t\'équiper d\'une petite Pelle de Boisaille pour le déterrer.\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2122] = {n:"Lettre d\'invitation pour la cérémonie",t:24,d:"Cette lettre est cachetée et l\'ouvrir serait malpoli.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2123] = {n:"Recette du Sonacixem",t:24,d:"Cette recette permet de fabriquer du sonacixem, qui semble être un poison magique redoutable.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2124] = {n:"Formulaire d\'inspection rempli",t:24,d:"Un formulaire d\'inspection n°243 rempli par Leonzi Trool, à première vue il n\'en est pas ...",ep:2,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2127] = {n:"Lettre de Zeurg",t:24,d:"Cette lettre indique un sortilège capable de détruire les Holbaïds.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2128] = {n:"Clairvoyance",t:31,d:"Vous avez un pouvoir de clairvoyance, jusqu\'à ce que vous rentriez en combat.",ep:6,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2129] = {n:"Touffe de cheveux de Dike Tarak",t:24,d:"Cette touffe de cheveux de Dike Tarak montre à quel point vous avez malmené ce pauvre garcon ...",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2130] = {n:"Colonel Lyeno",t:32,d:"Escorter le Colonel Lyeno à un mage de Bonta pour briser l\'enchantement du chêne mou.",ep:9,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2131] = {n:"Decret de la taxe 51-11b",t:24,d:"Cette lettre annonce avec effronterie que tout les possesseurs de boissons alcoolisées doivent payer un impôt aux militaires. Sous pretexte de la pause obligatoire.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2132] = {n:"Houé Dapyus",t:32,d:"Escorter Houé Dapyus en dehors de la prison de Brâkmar et l\'amener à Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
