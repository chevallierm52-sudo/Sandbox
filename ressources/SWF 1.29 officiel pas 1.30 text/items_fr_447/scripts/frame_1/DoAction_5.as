I.u[2166] = {n:"Echantillon de lave",t:24,d:"Cet échantillon a été trouvé près de la mine",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2167] = {n:"Echantillon de lave",t:24,d:"Cet échantillon a été trouvé au Sud de la mine",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2168] = {n:"Debut de rapport",t:24,d:"Ce rapport commence à decrire d\'inquietants changements dans la masse magmatique brâkmarienne.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2169] = {n:"Raaga",t:32,d:"Amener Raaga dans une caverne magmatique.",ep:14,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2170] = {n:"Epée de Mercenaire",t:6,d:"Cette longue épée est lourde et peu maniable mais découpe à merveille, un peu comme une longue épée lourde et peu maniable.",ep:1,g:25,l:1,wd:true,fm:true,w:1,an:14,tw:true,e:[30,5,1,1,25,50,false,false],p:1};
I.u[2171] = {n:"Rapport de Raaga",t:24,d:"Ce rapport décrit les changements chaotiques des activités volcaniques de Brâkmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2172] = {n:"Liste d\'échantillons à trouver",t:24,d:"Raaga vous a noté vite fait les indications à suivre pour trouver de bons échantillons de lave : \nChercher sur un périmètre de 5 lieux. Chercher des petits pics.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2173] = {n:"Les secrets du langage écureuil",t:25,d:"Ce dictionnaire vous apprend à dialoguer avec un écureuil, ou tout du moins essayer ...",ep:2,g:6,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[2174] = {n:"Laisser-Passer Quartiers d\'interrogation",t:24,d:"Ce bout de papier permet d\'entrer librement dans les petits quartiers d\'interrogation de la prison.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2175] = {n:"Menace de l\'intendant",t:24,d:"Une menace écrite de Danathor, pour ne pas oublier de surveiller ses arrières à l\'avenir.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2176] = {n:"Adresse de Rimaraf",t:24,d:"Rimaraf habite une maison en brique rouge au 13 Ruelle de la Découpe dans le quartier de la Boucherie.",ep:2,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[2177] = {n:"Broche de Danathor",t:24,d:"Cette petite broche vous a été donnée par Danathor.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2178] = {n:"Formulaire d\'enquête n°36",t:80,d:"Ce formulaire permet d\'identifier d\'éventuels suspects dans des actes criminels. \n(Cliquer sur le parchemin, et puis sur quelqu\'un pour l\'utiliser)",ep:16,g:6,l:1,wd:true,fm:true,w:1,c:"PO!2181&PO!2177&Ps=1&Pa=27",ut:true,p:100};
I.u[2179] = {n:"Dent de Dragodinde",t:47,d:"Cette Dent paraît bien tranchante. Elle pourrait devenir une arme redoutable entre les mains de n\'importe qui. Heureusement que le dragodinde ne s\'en sert que pour mâcher de la salade.",ep:2,g:419,l:20,wd:true,fm:true,w:2,p:1};
I.u[2180] = {n:"Compte-rendu interrogatoire",t:24,d:"L\'alibi de cette personne semble irréprochable...",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2181] = {n:"Compte-rendu interrogatoire",t:24,d:"Cette personne est suspecte, son alibi ne tient pas debout.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2182] = {n:"Carte d\'un enqueteur",t:24,d:"Un enquêteur de la milice vous surveille et vous suspecte du meurtre de Rimaraf. \nIl vous a laissé sa carte lors de l\'interrogatoire ...",ep:2,g:71,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2183] = {n:"Potion d\'oubli de métier : Pêcheur",t:44,d:"Cette potion vous fera oublier le métier de Pêcheur",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2184] = {n:"Potion d\'oubli de métier : Poissonnier",t:44,d:"Cette potion vous fera oublier le métier de Poissonnier",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2185] = {n:"Potion d\'oubli de métier : Chasseur",t:44,d:"Cette potion vous fera oublier le métier de Chasseur",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2186] = {n:"Potion d\'oubli de métier : Boucher",t:44,d:"Cette potion vous fera oublier le métier de Boucher",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2187] = {n:"Pichon Eud\'Compet",t:41,d:"Ce poisson, pêchable uniquement dans la pichine de Sufokia, est un croisement entre tout plein d\'autres poissons.",ep:7,g:400,l:1,wd:true,fm:true,w:20,p:1};
I.u[2188] = {n:"Canne à Pichon",t:20,d:"Seule cette canne permet de pêcher les pichons de la pichine de Sufokia.",ep:7,g:8,l:1,wd:true,fm:true,w:2,an:18,e:[1,5,1,5,10,10,false,true],p:50};
I.u[2189] = {n:"Certificat de bon vote",t:24,d:"Ce petit bout de papier signé par Satirev Refibrom prouve que vous avez voté lors d\'un jugement... Et que vous avez bien voté.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2190] = {n:"Formulaire d\'enquête n°33",t:80,d:"Ce formulaire permet habituellement de faire avouer un suspect dans des affaires criminels. Il ne reste plus qu\'à le remplir vous-même pour créer un faux interrogatoire de \'Oni Tnec\'. \n(L\'utiliser sur vous pour l\'utiliser)",ep:16,g:6,l:1,wd:true,fm:false,w:1,c:"PO=2177&Ps=1&Pa=27",u:true,p:100};
I.u[2191] = {n:"Certificat de mauvais vote",t:24,d:"Ce petit bout de papier signé par Satirev Refibrom prouve que vous avez voté lors d\'un jugement... Et que vous avez menti.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2192] = {n:"Documents volés",t:24,d:"Ces documents top secret sont scellés par une glyphe de mort. Si vous l\'ouvrez vous ne pourrez pas les lire.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2193] = {n:"Touffe de cheveux de Puja",t:24,d:"Vous avez mis une raclée au fils d\'Oto Mustam. Il n\'appréciera sans-doute pas.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2194] = {n:"Pense-bête",t:24,d:"Ramener 10 écorces d\'abraknyde.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2195] = {n:"Dent",t:24,d:"Cette dent doit probablement vous appartenir vu la raclé que Oto Mustam vous a mis. \nIl serait peut-être sage d\'attendre qu\'il se calme avant de lui reparler à moins que vous ne vouliez vous faire massacrer à nouveau.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2196] = {n:"Connaissance",t:29,d:"Cette bénédiction permet de gagner de l\'Intelligence pour les prochains combats.",ep:18,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2197] = {n:"La Force Divorce",t:14,d:"Ces anneaux permettent de briser les liens sacrés du mariage.",ep:1,g:13,l:1,wd:true,fm:true,w:0,ut:true,p:1};
I.u[2198] = {n:"Parchemin de Connaissance",t:14,d:"Ce parchemin vous permet d\'améliorer votre Intelligence, ce qui peut servir pour garder son calme face à deux Bworks.",ep:1,g:7,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2199] = {n:"Parchemin de Stupidité",t:14,d:"Ce parchemin vous permet de réduire l\'Intelligence d\'une cible unique, ce qui peut servir quand votre ennemi est prêt à paniquer à l\'approche de deux Bworks.",ep:1,g:8,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2200] = {n:"Menace de Satirev Refibrom",t:24,d:"Le grand juge de Brâkmar ne veut plus vous voir. Il semble qu\'il ne vous porte pas du tout dans son coeur...enfin il n\'en a pas de toute façon.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2201] = {n:"Sérénité",t:29,d:"Cette bénédiction permet de gagner de la Sagesse pour les prochains combats.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2202] = {n:"Sénilité",t:30,d:"Cette malédiction vous enlève de la Sagesse pour le prochain combat.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2203] = {n:"Parchemin de Modération",t:14,d:"Ce parchemin vous permet d\'améliorer votre Sagesse, ce qui peut servir pour arriver plus rapidement à la cheville de Dark Vlad.",ep:1,g:9,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2204] = {n:"Parchemin de Sénilité",t:14,d:"Ce parchemin vous permet de réduire la Sagesse d\'une cible unique, ce qui peut servir quand votre ennemi essaye d\'arriver plus rapidement à la cheville de Dark Vlad.",ep:1,g:10,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2205] = {n:"Changement d\'ordre",t:24,d:"Ce papier indique que vous avez déjà effectué un changement d\'ordre.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2206] = {n:"Aubaine",t:29,d:"Cette bénédiction permet de gagner de la Chance pour les prochains combats.",ep:18,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2207] = {n:"Papier de détention",t:24,d:"Sur ce papier est indiqué les crimes que vous avez commis, ainsi que la date à laquelle vous avez été incarcéré...",ep:2,g:73,l:1,wd:true,fm:true,w:0,p:1};
I.u[2208] = {n:"Guigne",t:30,d:"Cette malédiction vous enlève de la Chance pour le prochain combat.",ep:1,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2209] = {n:"Parchemin d\'Aubaine",t:14,d:"Ce parchemin vous permet d\'améliorer votre Chance, ce qui peut servir pour trouver plus facilement un tofu dans une botte de foin.",ep:1,g:11,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2210] = {n:"Parchemin de Guigne",t:14,d:"Ce parchemin vous permet de réduire la Chance d\'une cible unique, ce qui peut servir quand votre ennemi tente de faire fortune.",ep:1,g:12,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2211] = {n:"Costume Iopesque",t:14,d:"Grâce à cet accoutrement, vous allez briller dans les bals mondains. Le seul souci, c\'est que l\'on va souvent vous dire que vous êtes malin comme un Iop.",ep:1,g:14,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2212] = {n:"Costume Xeloresque",t:14,d:"Muni de ce chapeau et de quelques ustensiles fournis, la ressemblance est flagrante. Vous êtes un Xelor, cela ne fait aucun doute.",ep:1,g:15,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2213] = {n:"Costume Sadidesque",t:14,d:"Il suffit de très peu de choses pour ressembler à un sadida: une descente de lit, avoir le regard dans le brouillard et la tête coincée dans le rectum. Effet garanti.",ep:1,g:16,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2214] = {n:"Iop attitude",t:31,d:"Vous avez la Iop attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:4,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2215] = {n:"Xélor attitude",t:31,d:"Vous avez la Xélor attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:5,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2216] = {n:"Sadida attitude",t:31,d:"Vous avez la Sadida attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:6,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2217] = {n:"Costume Fecaesque",t:14,d:"Cette moumoute sort tout droit d\'un vieux placard, cela se voit à l\'aspect un tantinet \"rétro\" de cette coiffe. Par contre, c\'est affolant ce que vous pouvez ressemblez à un féca en la mettant sur votre tête (parce que vous le voulez bien).",ep:1,g:17,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2218] = {n:"Féca attitude",t:31,d:"Vous avez la Féca attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:7,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2219] = {n:"Costume Eniripsesque",t:14,d:"Ces ailes d\'eniripsa ne vous permettent pas de voler. Ne faites donc pas le fanfaron devant vos camarades avec cet accoutrement, vous risquez d\'avoir l\'air ridicule à l\'atterrissage.",ep:1,g:18,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2220] = {n:"Eniripsa attitude",t:31,d:"Vous avez l\'Eniripsa attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:8,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2221] = {n:"Costume Enutrofesque",t:14,d:"Cette fausse barbe vous fait ressembler à un Enutrof, certes, mais elle vous donne aussi une haleine digne d\'un Enu de sortie le samedi soir. De quoi donner une sacré fièvre.",ep:1,g:19,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2222] = {n:"Enutrof attitude",t:31,d:"Vous avez l\'Enutrof attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:9,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2223] = {n:"Costume Sacriesque",t:14,d:"Un peu de sang de tofu ainsi que de fausses cicatrices, un regard de pirate psychotique et le tour est joué. Vous pourrez participer aux réunions de sacrieurs en vous faisant passer pour l\'un d\'eux sans être suspecté.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2224] = {n:"Sacrieur attitude",t:31,d:"Vous avez la Sacrieur attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:10,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2225] = {n:"Costume Sramesque",t:14,d:"Un Kwane, une cape sur la tête, l\'illusion est parfaite. Si vous portez ce costume, vous aurez l\'air d\'un affreux et abject personnage sortant du fin fond d\'un cimetière: un Sram, tout simplement.",ep:1,g:21,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2226] = {n:"Sram attitude",t:31,d:"Vous avez la Sram attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:11,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2227] = {n:"Costume Osamodesque",t:14,d:"N\'en déplaise à certains, vous pouvez vous munir de cette queue fourchue et de ces cornes. Une fois équipé, ce costume vous ira comme un gant et vous serez prêt à vous inviter parmis les fêtes très connues \"vie-ail-pie\" que font les Osamodas en cachette.",ep:1,g:22,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2228] = {n:"Osamodas attitude",t:31,d:"Vous avez l\'Osamodas attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:12,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2229] = {n:"Costume Ecaflipesque",t:14,d:"On peut y trouver des oreilles en poil de wabbit très doux, une queue tigrée et une boîte de puces excitées. Pas de doute, quand vous refilerez ces sales petites bêtes à vos voisins, on ne pourra pas douter de vos talents de transformiste.",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2230] = {n:"Ecaflip attitude",t:31,d:"Vous avez l\'Ecaflip attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:13,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2231] = {n:"Costume Craesque",t:14,d:"Le Cra, vous l\'aurez remarqué, se promène souvent avec son carquois. Pas étonnant que muni de celui-ci, les gens vous prennent pour un des leurs. Mais ce n\'est qu\'un leurre, quel bonheur de les berner à toute heure.",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2232] = {n:"Crâ attitude",t:31,d:"Vous avez la Crâ attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:14,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2233] = {n:"La Croqueuse",t:10,d:"Cette ceinture fut créée par Xof le Lenald, il eut la bonne idée de ramasser toutes les dents qu\'il pouvait trouver sur un champ de bataille Wabbit. Depuis ce jour, ce geste est devenu une habitude.",ep:8,g:20,l:28,wd:true,fm:true,w:20,c:"CS<40&CI>80",p:2400};
I.u[2234] = {n:"Bonta Attitude",t:31,d:"Vous avez La Bonta attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:15,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2235] = {n:"Brâkmar Attitude",t:31,d:"Vous avez La Brâkmar attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:16,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2236] = {n:"Costume Bontesque",t:14,d:"Avec cet accoutrement, un bon nombre de voyageurs vous salueront et vous demanderont leurs chemins.",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2237] = {n:"Costume Brâkmaresque",t:14,d:"Muni de ces affaires, vous serez redouté de tous.",ep:1,g:26,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2239] = {n:"Poudre d\'Eniripsa",t:48,d:"Cette poudre est produite en petite quantité à partir d\'ailes d\'Eniripsas. Elle semble avoir des vertus curatives sur les familiers.",ep:3,g:260,l:1,wd:true,fm:true,w:1,p:1000};
I.u[2240] = {n:"Petite Fée d\'Artifice Rouge",t:74,d:"Idéal pour les petites fêtes de mariage, parfait pour la fête du Slip du Captain Chafer.",ep:16,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:350};
I.u[2241] = {n:"Gelée Menthe Royale",t:110,d:"La Gelée Royale a détroussé plus d\'un aventurier un peu trop entreprenant, la voila enfin anéantie. Attention, il est déconseillé de la  consommer comme une vulgaire Gelée Menthe.",ep:7,g:408,l:100,wd:true,fm:true,w:1,p:100};
I.u[2242] = {n:"Gelée Fraise Royale",t:110,d:"Du concentré de Gelée Fraise Royale peut transformer n\'importe quel tabi pacifiste en machine de guerre assoiffée de sang. Attention donc à ne pas en servir en apéritif à vos amis.",ep:7,g:409,l:150,wd:true,fm:true,w:1,p:100};
I.u[2245] = {n:"Pince de Scorbute",t:47,d:"Autrefois utilisée pour se gratter le bas du dos, elle est aussi très pratique une fois accrochée à un mur, pour y faire tenir des capes. Ça marche également si vous vous l\'accrochez dans le bas du dos quoique un poil plus douloureux.",ep:14,g:411,l:36,wd:true,fm:true,w:1,p:1};
I.u[2246] = {n:"Couronne Brisée du Tofu Royal",t:15,d:"Cette couronne a été brisée par de puissantes attaques magiques, ou par le dernier coup de boule que le Tofu Royal a tenté de vous assener.",ep:3,g:412,l:100,wd:true,fm:true,w:10,p:250};
I.u[2247] = {n:"Plume de Tofu Royal",t:53,d:"Il n\'y a qu\'un Iop pour ne pas se rendre compte que cette plume provient de la croupe d\'un Tofu Royal. Pourtant ça se voit, la plume est plus grosse.",ep:3,g:413,l:100,wd:true,fm:true,w:11,p:250};
I.u[2248] = {n:"Poil d\'Ouginak",t:54,d:"Ce Poil tient chaud, la preuve, votre main est moite depuis que vous l\'observez. À moins que ce ne soit la peur des représailles du prochain Ouginak qui vous verra avec ce poil dans la poche. De quoi aboyer de rage. \nWa-hoooo.",ep:14,g:414,l:51,wd:true,fm:true,w:1,p:1};
I.u[2249] = {n:"Feuille de Tronknyde",t:36,d:"Cette Feuille doit sûrement fournir au Tronknyde la force nécessaire pour se battre. Encore faut il savoir comment bien l\'utiliser. Ce qui vient tout de suite à l\'idée, c\'est de la hacher et de l\'incorporer à des haricots. Un régal.",ep:2,g:415,l:35,wd:true,fm:true,w:1,p:1};
I.u[2250] = {n:"Bois de Tronknyde",t:38,d:"Ce morceau de Bois sonne creux. La sève verte qui s\'en échappe vous signale que cette partie n\'était rien d\'autre que le nez du Tronknyde.",ep:9,g:416,l:35,wd:true,fm:true,w:1,p:100};
I.u[2251] = {n:"Méga Pierre du Craqueleur",t:51,d:"Je ne vous jette pas la Mégapierre Pierre !",ep:5,g:417,l:45,wd:true,fm:true,w:15,p:150};
I.u[2252] = {n:"Dent en Or du Craqueleur",t:47,d:"Vous venez d\'édenter sans scrupule le Craqueleur qui croisait votre chemin. Dommage qu\'il n\'en possédait qu\'une seule, un dentier aurait facilement couvert les frais de Zaap durant un bon mois.",ep:5,g:418,l:31,wd:true,fm:true,w:5,p:1};
I.u[2253] = {n:"Fleur de Gloutovore",t:35,d:"Cette Fleur facilite le transit intestinal. Elle est vivement recommandé après un séjour chez votre cuisinier favori.",ep:12,g:420,l:42,wd:true,fm:true,w:1,p:100};
I.u[2254] = {n:"Feuille de Fourbasse",t:36,d:"La feuille de Fourbasse a un goût très particulier, entre la noisette et la salace peu fraiche. Vos plats auront en tout cas un petit parfum de fourbasserie si vous souhaitez toutefois la goûter.",ep:2,g:421,l:22,wd:true,fm:true,w:1,p:1};
I.u[2255] = {n:"Rapport de l\'espion",t:24,d:"Aucune activité dangereuse en ce moment. L\'organisation des miliciens est perturbée par l\'assassinat de l\'un des leurs. Il semblerait que ce soit un bontarien qui ait fait le coup",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2256] = {n:"Carcasse de rat d\'égouts",t:24,d:"Ce rat n\'est plus que de la viande froide. Un de moins qui traîne dans l\'entrée des égouts.",ep:2,g:121,l:1,wd:true,fm:true,w:0,p:1};
I.u[2257] = {n:"Morceau de mur d\'égout",t:24,d:"Ce morceau de mur d\'égout a été retrouvé dans l\'estomac d\'un bidule",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2259] = {n:"Dent de Karne",t:47,d:"Vous avez dans la main le jeu le plus ancien de la contrée d\'Amakna. les règles sont simples: lancez une Dent et tentez de la ratrapper avec la même main, tout en récupérant une deuxième Dent de Karne au sol.",ep:4,g:13,l:16,wd:true,fm:true,w:1,p:20};
I.u[2260] = {n:"Carte d\'un brâkmarien",t:24,d:"Quelqu\'un a glissé cette carte de visite dans votre équipement. Il semble que ce soit un brâkmarien. Cette carte annonce que les Guerriers sont intéressés par vos talents d\'assassinat et vous propose de rejoindre la folle aventure brâkmarienne.",ep:2,g:72,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2261] = {n:"Esprit Renifleur",t:30,d:"Un esprit renifleur vous hante. Il se nourrit de votre odeur et de votre vitalité.",ep:1,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2262] = {n:"Description de l\'assassin",t:24,d:"Vous avez trouvé un Bontarien qui empestait l\'odeur du sang. Toutes les informations que vous avez pu rassembler sur ce personnage sont inscrites sur cette feuille de papier.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2263] = {n:"Bâton renifleur de Sang",t:80,d:"Ce bâton est possédé par un esprit renifleur. On peut libérer cet esprit qui foncera alors tout droit jusqu\'à croiser un objet possédant l\'odeur qu\'il aime. Il hantera alors cette personne quelques temps avant de repartir aux pays des esprits.",ep:16,g:25,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[2264] = {n:"Peau de Gobelin",t:59,d:"Un Gobelin est souvent moqueur et sournois, mais si vous le dépecez, il fera moins le malin ce satané Gobelin.",ep:4,g:422,l:16,wd:true,fm:true,w:1,p:1};
I.u[2265] = {n:"Description d\'un Bontarien",t:24,d:"Vous avez libéré un esprit renifleur mais il ne s\'est pas fixé sur la personne visée. Vous avez noté quelques informations de la personne sur ce bout de papier afin de vous en souvenir",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2266] = {n:"Lait de Cochon de Lait",t:15,d:"Ce Lait de Cochon provient d\'un Cochon de Lait. On sait jamais, au cas ou vous pensiez l\'avoir trouvé sur un Tofu, il n\'en est rien.",ep:1,g:423,l:18,wd:true,fm:true,w:1,p:1};
I.u[2267] = {n:"Dragolait",t:15,d:"Ce Dragolait est une denrée rare, car personne dans la contrée n\'a encore vu un Dragon Cochon se laisser traire. On imagine aisément qu\'il faut au minimum sept personnes pour tenir la bestiole tandis que la huitième doit traire très très rapidement.",ep:2,g:424,l:70,wd:true,fm:true,w:2,p:1};
I.u[2268] = {n:"Scalp de Bwork Archer",t:15,d:"Voici un Scalp qui pourrait lancer une nouvelle mode chez les Enutrofs : le poustiche. Un peu de produit anti-poux et vous serez prêt à concourir pour l\'Enutrof le plus classe du monde.",ep:4,g:425,l:24,wd:true,fm:true,w:1,p:1};
I.u[2269] = {n:"Oeil de Larve bleue",t:24,d:"Vous venez de récupèrer cet Oeil intact. Bien préparé, des yeux brouillés sont un régal pour un petit déjeuner. Cet oeil de larve prouvera à Oto que vous avez bien tué une larve bleue.",ep:1,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2270] = {n:"Grappe d\'Oeufs de larve",t:24,d:"Cette grappe d\'œufs ressemble à une grosse grappe de raisin. Mais il vaut mieux éviter de la manger.",ep:1,g:83,l:1,wd:true,fm:true,w:0,p:1};
I.u[2271] = {n:"Cuir Violet de Bwork",t:56,d:"Beaucoup de mystères planent encore autour de cet artisanat Bwork. Certains aventuriers pensent que la teinte violacée proviendrait des Gobelins, mais le cuir a une origine inconnue. Bizarre.",ep:4,g:426,l:31,wd:true,fm:true,w:1,p:1};
I.u[2272] = {n:"Larve Dorée",t:32,d:"Cette larve vient de naître d\'un oeuf. Son premier regard s\'étant posé sur vous, elle vous considère comme sa mère.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[2273] = {n:"Tissu Pourpre",t:55,d:"Léger et doux au toucher, voila ce que l\'on peut dire de cet étrange Tissu Pourpre. Il est écrit sur une étiquette à l\'intérieur \"made in taille one\".",ep:2,g:427,l:23,wd:true,fm:true,w:1,p:1};
I.u[2274] = {n:"Bougie du Mineur Sombre",t:15,d:"Prenez un Enutrof. Quand il fait noir dans les mines, on ne le voit plus. Le Mineur Sombre, lorsqu\'il est dans le noir, on ne le voit pas non plus, puisque maintenant vous avez sa bougie.",ep:1,g:428,l:24,wd:true,fm:true,w:10,p:10000};
I.u[2275] = {n:"Cuir de Porkass",t:56,d:"Le Porkass a failli disparaître de la chaîne alimentaire. Il a fallut accoupler des Sangliers et des Cochons de Lait pour à nouveau retrouver les Plaines de Cania remplies de Porkass. Depuis, celui-ci en veut à la terre entière. Quel caractère de porc.",ep:2,g:429,l:40,wd:true,fm:true,w:10,p:1};
I.u[2277] = {n:"Linceul",t:55,d:"Pour gagner en crédibilité, les fantômes s\'enrobent d\'un Linceul leur permettant de terroriser les aventuriers perdus.",ep:14,g:430,l:65,wd:true,fm:true,w:1,p:1000};
I.u[2278] = {n:"Tissu Invisible",t:55,d:"Ce tissu servit à Harry Taupeur, chasseur de taupe. Il s\'enroulait dedans afin de piéger les Taupes qui infestaient son jardin. C\'est le charismatique Captain Chafer qui se l\'est approprié avant de disparaître dans des circonstances bien étranges...",ep:1,g:431,l:23,wd:true,fm:true,w:1,p:1};
I.u[2279] = {n:"Dent Pointue",t:47,d:"Cette Dent appartenait à un Vampire, cela ne fait aucun doute. On peut le constater en observant de près le bout de la Dent qui s\'avère être on ne peut plus pointue.",ep:3,g:432,l:15,wd:true,fm:true,w:1,p:1};
I.u[2280] = {n:"Paille Vampiresque",t:15,d:"Ne sous-estimez jamais un Vampire surtout avec une paille dans la main, il pourrait vous sucer le sang jusqu\' à plus soif.",ep:3,g:433,l:22,wd:true,fm:true,w:1,p:1};
I.u[2281] = {n:"Tissu Sanguin",t:55,d:"Ce tissu a l\'air vivant, les Vampires s\'en servent souvent pour défiler dans de jolies accoutrements lors des bals costumés.",ep:3,g:434,l:15,wd:true,fm:true,w:1,p:1};
I.u[2282] = {n:"Touffe de Cheveux Blancs",t:15,d:"Voici la preuve que certains monstres se font beaucoup de soucis.",ep:1,g:435,l:24,wd:true,fm:true,w:1,p:1};
I.u[2283] = {n:"Oeil de Kwoan",t:109,d:"Cet oeil de Kwoan a des effets hypnotiques surprenants, autant dire qu\'il faut toujours garder un oeil sur vous quand vous le manipulez.",ep:3,g:436,l:8,wd:true,fm:true,w:1,p:1};
I.u[2284] = {n:"Note de Harry Stote",t:24,d:"L\'entrée de la grotte légendaire aux larves dorées se trouve un peu à l\'ouest d\'Amakna. Les pouvoirs latents de la larve dorée te permettront d\'y rentrer. Attention si ta petite larve se prend des dégâts elle se précipitera dans les bras de son père.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2285] = {n:"Tissu Sombre",t:55,d:"La particularité de ce Tissu n\'est plus sujet à controverse. Cela dit, il est très irritant au toucher, sûrement parce qu\'un Ouginak s\'est dans le meilleur des cas, mouché dessus pendant des années.",ep:3,g:437,l:50,wd:true,fm:true,w:1,p:1};
I.u[2286] = {n:"Bandelettes",t:15,d:"Ces bandelettes sont révolutionnaires : triple épaisseur, parfumées à la violette, ultra résistantes. C\'est vraiment un produit de qualité.",ep:2,g:438,l:51,wd:true,fm:true,w:1,p:1};
I.u[2287] = {n:"Cuir Noir",t:56,d:"Ce cuir est déjà traité, sa provenance n\'est pas certaine mais la couleur provient probablement d\'une teinture spéciale.",ep:1,g:439,l:74,wd:true,fm:true,w:1,p:1};
I.u[2288] = {n:"Patte de Wabbit",t:103,d:"Bon nombres de touristes vont sur l\'île de Wabbits essentiellement pour se munir d\'une Patte de Wabbit car elle porte bonheur. Malheureusement, ça n\'est pas le cas, mais il ne faut pas le dire, le tourisme en serait fort pénalisé.",ep:8,g:440,l:18,wd:true,fm:true,w:1,p:1};
I.u[2290] = {n:"Carapace de Scarafeuille Blanc",t:107,d:"Il ne faut pas grand chose pour avoir un bel abat-jour chez soi. Soit dit en passant, cette carapace doit avoir tout de même une autre utilité. Enfin espérons-le.",ep:3,g:441,l:32,wd:true,fm:true,w:1,p:1};
I.u[2291] = {n:"Carapace de Scarafeuille Bleu",t:107,d:"Il ne faut pas grand chose pour avoir un bel abat-jour chez soi. Soit dit en passant, cette carapace doit avoir tout de même une autre utilité. Enfin espérons-le.",ep:3,g:442,l:32,wd:true,fm:true,w:1,p:1};
I.u[2292] = {n:"Carapace de Scarafeuille Rouge",t:107,d:"Il ne faut pas grand chose pour avoir un bel abat-jour chez soi. Soit dit en passant, cette carapace doit avoir tout de même une autre utilité. Enfin espérons-le.",ep:3,g:443,l:32,wd:true,fm:true,w:1,p:1};
I.u[2293] = {n:"Carapace de Scarafeuille Vert",t:107,d:"Il ne faut pas grand chose pour avoir un bel abat-jour chez soi. Soit dit en passant, cette carapace doit avoir tout de même une autre utilité. Enfin espérons-le.",ep:3,g:444,l:32,wd:true,fm:true,w:1,p:1};
I.u[2294] = {n:"Viscères de Scarafeuille",t:15,d:"Au premier abord, ces viscères ne semblent pas très appétissants. Et pourtant, hâchés avec de fines herbes séchées au soleil, un peu de menthe sauvage, et cuits à l\'étouffée dans un vieux chaudron rouillé, ces viscères combleront de joie le plus gourmet des Chafers.",ep:3,g:445,l:32,wd:true,fm:true,w:1,p:1};
I.u[2295] = {n:"Fragment d\'Epée Reptilienne",t:15,d:"Avec ce Fragment d\'Epée accroché à votre cheminée, vous pourrez vous vanter de dompter le Crocodaille tel l\'excentrique Mikoule, plus connu sous le nom de Crocodaille Dandi.",ep:4,g:446,l:69,wd:true,fm:true,w:10,p:1};
I.u[2296] = {n:"Bouclier Reptilien",t:15,d:"À quoi pourrait bien vous servir ce magnifique bouclier orné de pierres précieuses ? En attendant que vous ne trouviez la réponse, il peut déjà vous servir de plateau pour apporter le thé à vos amis.",ep:4,g:447,l:69,wd:true,fm:true,w:15,p:1};
I.u[2297] = {n:"Carreau d\'Arbalète",t:15,d:"Ce Carreau peut vous servir à confectionner une arme courte mais tranchante. Elle peut aussi faire office de cure-dents, à vous de voir.",ep:1,g:125,l:34,wd:true,fm:true,w:1,p:1};
I.u[2299] = {n:"Epaulette du Dark Vlad",t:15,d:"Cette épaulette a dû essuyer plus d\'une bataille. Même si d\'apparence elle ne semble pas très résistante, mieux vaux ne pas frapper le Dark Vlad à l\'épaule si vous tenez à votre arme.",ep:2,g:449,l:120,wd:true,fm:true,w:5,p:80};
I.u[2300] = {n:"Fragment d\'Os",t:47,d:"Ce Fragment d\'Os provient soit d\'un reste de Chafer datant du néotilique, soit d\'un repas de Meulou. Mais il y a de grandes chances pour que ce ne soit aucun des deux.",ep:9,g:450,l:43,wd:true,fm:true,w:1,p:1};
I.u[2301] = {n:"Moustache de Kolérat",t:15,d:"Peu résistant, la Moustache pourra vous servir à faire le mariol devant vos amis. Ressembler par exemple à Salve et Torh Bali, Grands peintres Brâkmarien.",ep:2,g:451,l:9,wd:true,fm:true,w:1,p:1};
I.u[2302] = {n:"Langue de Crabe",t:15,d:"Les têtes pensantes d\'Amakna se demandent encore quelle est l\'utilité de cette langue pour le crabe. Ils seraient probablement offusqués s\'ils connaissaient la réponse.",ep:1,g:452,l:4,wd:true,fm:true,w:1,p:1};
I.u[2303] = {n:"Carapace vide de Crabe",t:107,d:"Correctement vidée, cette Carapace de Crabe peut contenir divers objets. Toutefois, les objets en question garderont éternellement une odeur de Crabe plus ou moins troublante.",ep:1,g:453,l:4,wd:true,fm:true,w:2,p:1};
I.u[2304] = {n:"Fragment de Pierre Polie",t:51,d:"Ce Fragment provient de la fesse gauche d\'un Craqueleur des Plaines. Pour éclater une Arakne, il n\'y a pas mieux, à part le Craqueleur en personne peut-être.",ep:5,g:454,l:45,wd:true,fm:true,w:5,p:1};
I.u[2305] = {n:"Fragment de Pierre Pointue",t:51,d:"Ce Fragment provient de l\'omoplate droit d\'un Craqueleur des Plaines. A moins que ce ne soit une partie du bas ventre. Dans tous les cas, cette pierre n\'est pas à placer n\'importe où.",ep:5,g:455,l:45,wd:true,fm:true,w:5,p:1};
I.u[2306] = {n:"Coeur de Craqueleur",t:51,d:"Coeur de pierre, ne vois tu pas en moi l\'amour que je te porte. Si tu continues, je te laisse par terre, je ne vais pas me laisser saouler de la sorte.",ep:5,g:456,l:45,wd:true,fm:true,w:5,p:1};
I.u[2307] = {n:"Bouclier de Chafer Lancier",t:24,d:"...",ep:2,g:75,l:1,wd:true,fm:true,w:0,p:1};
I.u[2308] = {n:"Badge Brâkmarien",t:24,d:"Ce badge permet d\'identifier un guerrier lorsqu\'il périt sur un champ de bataille. Il paraît que certains en font collection, à Bonta.",ep:2,g:76,l:1,wd:true,fm:true,w:0,p:1};
I.u[2309] = {n:"Bougie Rouge",t:24,d:"Une bougie rouge pas comme les autres...",ep:1,g:77,l:1,wd:true,fm:true,w:0,p:1};
I.u[2310] = {n:"Bougie Verte",t:24,d:"...",ep:2,g:78,l:1,wd:true,fm:true,w:0,p:1};
I.u[2311] = {n:"Bougie Bleue",t:24,d:"...",ep:2,g:79,l:1,wd:true,fm:true,w:0,p:1};
I.u[2312] = {n:"Poudre de Sang",t:24,d:"...",ep:2,g:80,l:1,wd:true,fm:true,w:0,p:1};
I.u[2313] = {n:"Respirateur Aquatique",t:24,d:"...",ep:2,g:81,l:1,wd:true,fm:true,w:0,p:1};
I.u[2314] = {n:"Fioles de Jiva",t:24,d:"...",ep:2,g:82,l:1,wd:true,fm:true,w:0,p:1};
I.u[2315] = {n:"Poils de Crocs Glands",t:54,d:"Broujitte Fardot lança une interdiction jadis, sur l\'abattage des jeunes Crocs Glands. Depuis son exil, la chasse a repris et les tailleurs se remplissent à nouveau les poches.",ep:1,g:196,l:19,wd:true,fm:true,w:1,p:1};
I.u[2316] = {n:"Croc Jaune",t:47,d:"Le Croc Jaune de Croc Gland apporte une peur bleue à tous ceux qui sous estimeraient son pouvoir.",ep:1,g:458,l:19,wd:true,fm:true,w:1,p:1};
I.u[2317] = {n:"Oreilles de Loup",t:106,d:"C\'est en observant de près que l\'on se demande comment un Croc Gland entend quelquechose avec toutes les bêtes et autres crasses qu\'il possède dans ses Oreilles.",ep:1,g:459,l:19,wd:true,fm:true,w:1,p:1};
I.u[2318] = {n:"Patte d\'ours",t:103,d:"Certains gobelins portent une patte d\'ours autour du cou. Une superstition dont tout le monde a oublié l\'origine et la signification.",ep:1,g:460,l:12,wd:true,fm:true,w:1,p:1};
I.u[2320] = {n:"Collier Cassé d\'Ouginak",t:15,d:"Comme tout bon Ouginak, son Collier donne des informations. Il est écrit: \"je suis perdu, mon quartier se trouve sur le sentier des Landes de Sidimote, merci de me ramener à mes maîtres Brâkmariens, ils vous offriront des baffes en remerciements.\"",ep:14,g:462,l:51,wd:true,fm:true,w:5,p:1};
I.u[2321] = {n:"Babines d\'Ouginak",t:15,d:"Vous avez l\'impression que ces Babines d\'Ouginak pourraient suinter de la bave indéfiniment. Peut-être parce que cet animal est réputé pour sa gourmandise éternelle.",ep:14,g:463,l:51,wd:true,fm:true,w:1,p:1};
I.u[2322] = {n:"Crocs de Rats",t:47,d:"Ne vous-y méprenez pas, ces petites quenottes sont en fait de vrais crocs aiguisés, malodorants et usés. Ils servent parfois à remplacer les dents en or des Enutrofs un peu trop avares.",ep:1,g:464,l:50,wd:true,fm:true,w:1,p:1};
I.u[2323] = {n:"Colonne Vertebrale",t:47,d:"Voici une Colonne Vertébrale de bonne facture. Ce n\'est pas une raison pour vous éclater le dos non plus.",ep:1,g:465,l:34,wd:true,fm:true,w:2,p:1};
I.u[2324] = {n:"Pastèque",t:46,d:"...",ep:1,g:466,l:1,wd:true,fm:true,w:2,p:1};
I.u[2325] = {n:"Banane",t:46,d:"Le célèbre ménestrel Geror Lendorman composa jadis une ode en l\'honneur de ce fruit : \"La banane des gens heureux\".",ep:1,g:467,l:1,wd:true,fm:true,w:1,p:1};
I.u[2326] = {n:"Orange",t:46,d:"...",ep:1,g:468,l:1,wd:true,fm:true,w:1,p:1};
I.u[2327] = {n:"Pomme",t:46,d:"...",ep:1,g:469,l:1,wd:true,fm:true,w:1,p:1};
I.u[2328] = {n:"Petite Perle Dorée",t:15,d:"Cette perle dorée est un cadeau de la petite larve que vous avez accompagnée. Elle est donc pour vous d\'une grande valeur sentimentale. Sa douceur et sa couleur en font un cadeau parfait pour une personne un tant soit peu féminine.",ep:5,g:483,l:1,wd:true,fm:true,w:1,p:1};
I.u[2329] = {n:"Poire",t:46,d:"...",ep:1,g:470,l:1,wd:true,fm:true,w:1,p:1};
I.u[2330] = {n:"Capsule Explosive",t:15,d:"Cette capsule contient des extraits d\'agrumes magiques. Il est conseillé de l\'agiter avant de l\'utiliser pour que la pulpe ne reste pas dans le fond.",ep:4,g:711,l:23,wd:true,fm:true,w:1,p:1};
I.u[2331] = {n:"Aubergine",t:46,d:"Pas réellement nutritive, certains accompagnent l\'aubergine avec toutes sortes de condiments. Ce légume fruit a mauvaise réputation mais il est pourtant bénéfique pour la santé. Sauf pour celle des Bworks mais personne ne sait pourquoi.",ep:1,g:472,l:1,wd:true,fm:true,w:1,p:10};
I.u[2332] = {n:"Bonbon de Consolation",t:42,d:"Ce bonbon vous a permis de ne pas pleurer.",ep:13,g:135,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2333] = {n:"Bonbon Rouge Surpuissant",t:42,d:"Ce bonbon, augmentera votre attention lors des combats, pas de chance, il a vraiment un goût immonde. (DOUBLE CLIC POUR UTILISER, bonus de 20 en sagesse et de 10 en Prospection pour les 30 prochains combats).",ep:1,g:136,l:1,wd:true,fm:false,w:1,c:"PO!1723",u:true,p:1};
I.u[2336] = {n:"Crâne de chafer",t:47,d:"Ce crâne-là ne cliquettera plus jamais... quoique.",ep:1,g:480,l:16,wd:true,fm:true,w:1,p:1};
I.u[2337] = {n:"Livre Magique",t:25,d:"Ce livre semble magique. Très étrange.",ep:1,g:7,l:1,wd:true,fm:true,w:1,p:50};
I.u[2338] = {n:"Vieux Bouquin",t:25,d:"...",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[2339] = {n:"Liste d\'equipements standards",t:24,d:"Un guerrier de valeur moyenne se doit de porter autre chose que des haillons ou, au contraire, des choses clinquantes, il préfèrera donc: \n-Un camaieu au majeur \n-Un bandeau et une ceinture de vitalité \n-Des bottes de Kluh \n-Une cape brâkmarienne",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2340] = {n:"Caleçon de milicien",t:24,d:"Ceci est bien un caleçon de milicien. Vous devez être un sacré fétichiste pour posséder ceci. Ou bien quelqu\'un veut rire de vous.",ep:2,g:84,l:1,wd:true,fm:true,w:0,p:1};
I.u[2341] = {n:"Arc de Mech Riorraw",t:2,d:"Cet arc a été conçu par Mech Riorraw, il est calibré pour pouvoir traverser la rivière de lave et atteindre le haut des murailles de Brâkmar, ni plus, ni moins.",ep:16,g:8,l:10,wd:true,fm:true,w:100,an:10,tw:true,e:[0,6,20,21,0,30,false,true],c:"Ps=1",p:0};
I.u[2342] = {n:"Bague d\'allégeance",t:24,d:"Cette bague vous a été donnée par Domen. Lui rendre signifie que vous êtes pour la destruction de toute chose. Ce qui vous place du coté des adorateurs de Djaul.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[2343] = {n:"Bracelet de Djaul",t:24,d:"Ce bracelet vous a été donné par Djaul. Le porter signifie que vous agréez ses propos.",ep:2,g:85,l:1,wd:true,fm:true,w:0,p:1};
I.u[2344] = {n:"Lettre pour Oto",t:24,d:"Cette lettre vous a été remise par Domen pour Oto.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2345] = {n:"Oeil de tortue",t:24,d:"Cette tortue ne fera plus la maligne maintenant.",ep:2,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2346] = {n:"Costume Roublardesque",t:14,d:"Non, ce n\'est pas le fameux costume du dragovamp, la célèbre chauve-souris volante. Ceci est l\'accoutrement d\'un habitant du cimetière, un Roublard en quelques sortes.",ep:1,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[2347] = {n:"Compte-rendu de mission",t:24,d:"Ce compte-rendu explique comment s\'est passé l\'assaut de Brâkmar par la muraille Est.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2348] = {n:"Roublard Attitude",t:31,d:"Vous avez La Roublard attitude, jusqu\'à ce que vous rentriez en combat.",ep:1,g:17,l:1,wd:true,fm:false,w:0,m:true,u:true,p:1};
I.u[2349] = {n:"Lettre pour Oto",t:24,d:"Cette lettre vous a été remise par Domen pour Oto. Mais vous avez oublié de la lui donner.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2350] = {n:"Touffe de cheveux",t:24,d:"Il semble que cette touffe de cheveux ait appartenu à l\'un de vos ennemis.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2351] = {n:"Pain du Pinchaut",t:33,d:"Dans ce pain, il y a à boire et à manger, en l\'essorant bien, il est possible de remplir une chopine de bière.",ep:16,g:13,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[2352] = {n:"Lettre de Danathor",t:24,d:"\"J\'ai à te parler, viens me voir dès que tu as un moment de libre, à bientôt mon jeune ami.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2353] = {n:"Lettre de Larry Poller",t:24,d:"\"Bonjour, je suis Larry Poller, nous nous sommes rencontrés lors de la libération du Colonel Lyeno. J\'ai un service à vous demander. Venez me voir quand vous aurez un moment. A bientôt.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2354] = {n:"Cervelle de tortue",t:24,d:"Cette cervelle de tortue, si elle est bien préparé, devient un plat succulent.",ep:2,g:89,l:1,wd:true,fm:true,w:0,p:1};
I.u[2355] = {n:"Poussière d\'Oni",t:24,d:"Cette poussière bleutée est un catalyseur magique très puissant.",ep:2,g:88,l:1,wd:true,fm:true,w:0,p:1};
I.u[2356] = {n:"Miracle",t:31,d:"Vous avez un pouvoir miraculeux, jusqu\'à ce que vous rentriez en combat.",ep:13,g:19,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2357] = {n:"Bois d\'Oliviolet",t:38,d:"Ce Bois a l\'air de résister à toutes les températures. En effet, n\'essayez pas de faire un feu pour vous réchauffer, vous risqueriez de mourir de froid avant que le Bois ne prenne.",ep:14,g:481,l:50,wd:true,fm:true,w:5,p:0};
I.u[2358] = {n:"Bois de Bombu",t:38,d:"Ce Bois est le plus tendre de tous. Il est maléable à souhait et procure de réels plaisirs à travailler.",ep:13,g:482,l:50,wd:true,fm:true,w:5,p:0};
I.u[2359] = {n:"Broche de Heticili Ufot",t:24,d:"Cette petite broche vous a été donné par Heticili Ufot.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2360] = {n:"Acte de propriété",t:24,d:"Cet acte de propriété est celui de la maison de Heticili Ufot.",ep:2,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[2361] = {n:"Arc de Mulic Bere",t:2,d:"Cet arc est une invention du génial Mulic Bere. Sa portée maximum est tout bonnement incroyable. Le problème c\'est que la portée minimum est presque aussi grande.",ep:16,g:10,l:10,wd:true,fm:false,w:100,an:10,tw:true,e:[0,6,17,23,0,30,false,true],p:0};
I.u[2362] = {n:"Prédiction de Paro Cabanne",t:24,d:"La prédiction que Paro Cabanne a donné sur les prochaines éléctions.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2365] = {n:"Feuille de ronce d\'Hestia",t:36,d:"Cette feuille de ronce, d\'apparence anodine, est une plante indispensable pour certaines recettes étranges.",ep:16,g:415,l:1,wd:true,fm:true,w:1,p:1};
I.u[2366] = {n:"Canne à Kralamour",t:20,d:"Cette canne, de métal et de diamant, est la seule canne capable de soutenir le poids du kralamour. Elle est aussi imprégné de l\'odeur de kralamourette afin d\'avoir une petite chance de pêcher ce monstre.",ep:1,g:8,l:1,wd:false,fm:true,w:10,an:18,e:[2,6,1,9,30,30,false,false],p:1};
I.u[2367] = {n:"L\'Ami Léhunui",t:10,d:"Léhunui savait se faire des amis, il conviait souvent ses camarades à de grandes soirées costumées. Il avait aussi pour réputation de mettre toujours les petits plats dans les grands et d\'offrir de somptueux bijoux pour vous remercier de venir chez lui.",ep:8,g:21,l:37,wd:true,fm:true,w:20,c:"CW>49&Ps=1",p:3700};
I.u[2368] = {n:"Ramoume l\'Eternelle",t:10,d:"Ramoume était un ancien ami d\'enfance de Nova, ils se sont perdus de vue quand Ramoume décida de faire une sieste éternelle.",ep:2,g:22,l:37,wd:true,fm:true,w:50,c:"CW>49&Ps=2",p:1000};
I.u[2369] = {n:"Puissante Ceinture Fulgurante",t:10,d:"Cette magnifique ceinture a été confectionnée suite à un pari fou. Le défi était d\'améliorer une des plus belles ceintures conçue sur Amakna : la ceinture Fulgurante. Le pari fut réussi par Pakape Prométhé.",ep:2,g:26,l:80,wd:true,fm:true,w:150,p:300000};
I.u[2370] = {n:"La Végète Hâtif",t:10,d:"Equipement d\'une légèreté incompararable, la Végéte Hâtif vous apporte quelques grammes de finesses dans ce monde de Bwork en rût.",ep:2,g:23,l:41,wd:true,fm:true,w:5,c:"CA>50",p:4575};
I.u[2371] = {n:"La Mouthmou",t:10,d:"Cette ceinture vous est conseillée par Jiva en personne, pour les nuits froides et rigoureuses. En cas de tâches, elle se lave avec du Rimennelle.",ep:13,g:24,l:27,wd:true,fm:true,w:30,p:2775};
I.u[2372] = {n:"Bottes de Lymphe a Tik",t:11,d:"Ces bottes donnent l\'impression de marcher constamment dans l\'herbe fraîche. Elles sont donc idéales pour ceux dont l\'odeur des pieds se rapproche plus du Clakoss, que de la Gelée Menthe.",ep:5,g:18,l:39,wd:true,fm:true,w:5,c:"CC>50",p:4100};
I.u[2373] = {n:"Moon Boots",t:11,d:"Le poil de Moon, nécessaire pour cette paire de bottes, est sans aucun doute le poil le plus chaud pour les pieds, même si porter ses bottes en souvenir de Moon vous fera chaud au coeur.",ep:14,g:19,l:62,wd:true,fm:true,w:30,p:10000};
I.u[2374] = {n:"Bottes Tarsy",t:11,d:"Tarsy était un ermite qui n\'appréciait pas trop les visites. Pour preuve, il recevait ses invités en leur montrant de très près la pointure de ses Bottes.",ep:4,g:20,l:38,wd:true,fm:true,w:40,p:4000};
I.u[2375] = {n:"Bottes Orino",t:11,d:"Grâce à ces bottes, vous serez à même d\'entendre le vent dans les voiles d\'un bateau situé en pleine Mer d\'Asse, ou d\'entendre les gémissements d\'un Chafer Lancier, perdu dans les tréfonds du labyrinthe.",ep:13,g:21,l:77,wd:true,fm:true,w:40,p:15500};
I.u[2376] = {n:"Hache Hémal",t:19,d:"Cette hache est la seule capable de résister aux pouvoirs du Kaerlier et, donc, la seule à pouvoir le couper.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,6,1,1,45,45,false,false],c:"PJ>2,79",p:1};
I.u[2379] = {n:"Bois de Kaerlier",t:38,d:"Ce bois provient du très rare Kaerlier. Ses propriétés sont plutôt...étonnantes.",ep:14,g:140,l:40,wd:true,fm:true,w:5,p:20};
I.u[2380] = {n:"Cape de Bou",t:17,d:"Cette Cape est bien étrange, elle est faite de bouts de boue du Boo, mais elle tient tout de même debout. Une fois sur vos épaules, elle pourra même faire de vous un boute-en-train.",ep:13,g:35,l:41,wd:true,fm:true,w:10,p:4500};
I.u[2381] = {n:"Cape Flotteuse",t:17,d:"Cette Cape fut découpée dans un fanion, anciennement situé sur la plus haute tour du chateau d\'Amakna. C\'est sûrement pour cela qu\'elle sent le linge séché au grand air.",ep:5,g:36,l:61,wd:true,fm:true,w:10,c:"CI>90",p:9500};
I.u[2382] = {n:"Cape Maimpa",t:17,d:"Maimpa était un Ecaflip qui se moquait du vide, prétextant qu\'il retomberait toujours sur ses pattes. Mais un jour, il atterrit sur un Trool affamé. Il fût enterré le jour même à l\'endroit où l\'on a trouvé ses restes. Un peu partout en quelques sortes.",ep:14,g:37,l:36,wd:true,fm:true,w:10,p:6500};
I.u[2383] = {n:"Cape Sanguine",t:17,d:"A base de tissu sanguin, la Cape Sanguine a un aspect cartonneux au toucher, comme si la teinture rougeâtre avait coagulé.",ep:7,g:38,l:50,wd:true,fm:true,w:10,c:"CS>90",p:6000};
I.u[2384] = {n:"Bottes Animales",t:11,d:"On peut le dire, ces Bottes ont un côté comment dire... Hmmm... Bestial. Ne vous étonnez donc pas si un Mulou tombe amoureux de vos Bottes. C\'est peut-être la pire chose qui puisse vous arriver.",ep:14,g:22,l:94,wd:true,fm:true,w:40,p:23000};
I.u[2385] = {n:"La Brouteuse",t:17,d:"Idéale pour le jardin, la Brouteuse peut aussi servir de paillasson pour votre entrée de maison. Conçue à la base pour les Sadidas, elle n\'abîme pas les poils, même les plus fragiles. Certains vont même jusqu\'à dire qu\'elle ralentit leur chute.",ep:12,g:39,l:88,wd:true,fm:true,w:10,p:20000};
I.u[2386] = {n:"La Guenille",t:17,d:"Cette étrange Cape puise toute sa force dans son aspect vétuste. Plus elle sera sale, et plus elle vous servira.",ep:13,g:40,l:53,wd:true,fm:true,w:10,p:7000};
I.u[2387] = {n:"La Poilue",t:17,d:"Il faut avouer que cette Cape possède une forte odeur très désagréable. En essayant de mettre des mots sur cette infection, on peut dire que c\'est tout simplement un mélange de poils de monstres divers qui créent ce magnifique pot pourri.",ep:14,g:41,l:63,wd:true,fm:true,w:10,c:"CW>30&CV>50",p:10500};
I.u[2388] = {n:"L\'Amulette du Puzzle de la Griffe",t:1,d:"Autrefois, un Ecaflip nommé Dodge, éclata en mille morceaux une carte au trésor gravée sur une pierre. Croyant réussir à reformer la carte, il garda la plus grosse partie pour en faire une Amulette mystérieuse. Nul ne sait ce que le trésor est devenu.",ep:14,g:36,l:44,wd:true,fm:true,w:5,p:4000};
I.u[2389] = {n:"Amulette du Badoul",t:1,d:"Dodge adorait exploser tout ce qui avait de la valeur à ses yeux. Il disait que c\'était la preuve qu\'il existait. Chacun son truc.",ep:14,g:37,l:32,wd:true,fm:true,w:5,p:3200};
I.u[2390] = {n:"Amulette de la Boule",t:1,d:"Cette Amulette est presque parfaite, elle accroît considérablement la sagesse de celui qui la porte autour du cou. Très utile pour paraître plus sage auprès de vos amis, ou vous faire passer pour un écolier modèle.",ep:5,g:38,l:49,wd:true,fm:true,w:1,p:6400};
I.u[2391] = {n:"Amulette de la Bouboule",t:1,d:"Un vieux dicton de Sufokia dit: de la Boule un jour, de la Bouboule peut-être un autre jour. Vous pourrez constatez que, plus le dicton est vieux, plus il s\'avère ridicule.",ep:5,g:39,l:98,wd:true,fm:true,w:1,p:24400};
I.u[2392] = {n:"Dragolyre Remaniée",t:1,d:"Grâce aux multiples talents des artisans d\'Amakna, la Dragolyre Remaniée excelle dans la perfection.",ep:11,g:25,l:42,wd:true,fm:true,w:1,p:5000};
I.u[2393] = {n:"Omelette Amulette",t:1,d:"L\'osamodas Onehaieuf Bek cherchait absolument à gagner du mérite devant les membres de sa guilde, et décida alors de faire une Amulette révolutionnaire. Il y parvint en préparant un petit déjeuner à ses amis. Étrange.",ep:1,g:40,l:17,wd:true,fm:true,w:10,p:1000};
I.u[2394] = {n:"La Bourgeonette",t:1,d:"Gorgée de soleil, la Bourgeonette réchauffe les coeurs en plus de procurer une sensation d\'invulnérabilité face à la terre. Elle est aussi tellement légère qu\'on oublie souvent de l\'enlever à l\'heure du coucher.",ep:9,g:41,l:32,wd:true,fm:true,w:1,p:3000};
I.u[2395] = {n:"Le foulard du Lard Fou",t:1,d:"Le Lard Fou était un petit démon bien vil qui ne pouvait s\'empêcher de rester planté devant les gens sans bouger. Il était aussi résistant à la magie, ce qui imposait le respect à l\'époque. Depuis, le Lard Fou se terre quelque part et attend.",ep:8,g:42,l:42,wd:true,fm:true,w:15,p:5000};
I.u[2396] = {n:"La Lou Ptiote",t:1,d:"Sylveline n\'était pas très futée. Sa mère, Lou, lui offrit cette lanterne en disant \"Tiens! Au moins tu seras une lumière !\". Elle non plus n\'était pas une lanterne. Ce qui ne l\'a pas empêchée d\'avoir un éclair de génie qui illumina la vie de sa fille.",ep:7,g:43,l:15,wd:true,fm:true,w:5,p:1500};
I.u[2397] = {n:"La Bibelaw",t:1,d:"Law-bibe était un vieillard qui adorait assembler n\'importe quoi pour en faire un objet. Un jour, il créa ce médaillon aux formes intrigantes. Une fois autour du cou, il ressentit une étrange sensation. Bien étrange sensation même...",ep:13,g:44,l:30,wd:true,fm:true,w:10,p:3000};
I.u[2398] = {n:"L\'Oeil de Kanigrou",t:1,d:"Offert à Melyonen par le célèbre Kanigrou  Rook Y Balboua, pour la remercier de lui avoir présenté celle qui est maintenant sa femme, Ar d\'rieeeeeeeeeneuh comme il aime à l\'appeler.",ep:13,g:45,l:52,wd:true,fm:true,w:1,p:7000};
I.u[2399] = {n:"La Veaux Doux",t:1,d:"Jozébo Vez était un berger de Veaux, lointains cousins des Bouftous. Dans son troupeau, quelques bêtes possédaient une fourrure plus douce que les autres. Elle se revendait bien plus cher et pour différencier ses bêtes, il attachait ce collier à leur cou.",ep:13,g:46,l:15,wd:true,fm:true,w:1,p:1};
I.u[2400] = {n:"Bottes Animales Sombres",t:11,d:"On peut le dire, ces Bottes ont un côté comment dire, .....hmmm.... Sombre. Ne vous étonnez donc pas si un Vampire tombe en amour devant vous et vos Bottes. C\'est peut-être la pire chose qui puisse vous arriver.",ep:14,g:23,l:122,wd:true,fm:true,w:35,p:38000};
I.u[2401] = {n:"Carte de Kwelsh",t:15,d:"Cette carte est liée au maître Kwelsh. C\'est tout ce que vous savez et que vous devez savoir.",ep:16,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[2402] = {n:"Epée de Sériane-Kerm",t:6,d:"Cette épée est un cadeau honorifique que l\'on donne uniquement aux mercenaires accomplis. Mais elle coupe très bien aussi.",ep:1,g:25,l:30,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[2403] = {n:"Chtévu",t:10,d:"Autrefois utilisée pour les libertés conditionnelles, la Chtévu possède paraît-il un pouvoir supplémentaire par rapport aux autres ceintures. Mais personne n\'a encore trouvé. Mieux vaut donc garder un oeil sur cette ceinture.",ep:13,g:25,l:49,wd:true,fm:true,w:10,p:6100};
I.u[2404] = {n:"Ceinture du Rat",t:10,d:"Cette ceinture a appartenu à un Rat d\'Egoût, elle lui allait à merveille, bien moulante au niveau des hanches, elle lui permettait de cacher ses poignées d\'amour.",ep:2,g:27,l:55,wd:true,fm:true,w:10,p:8100};
I.u[2409] = {n:"Kwakoiffe de Flammes",t:16,d:"La Kwakoiffe de Flammes vous donne réellement une allure de tombeur, ce qui est très pratique pour mettre à terre vos adversaires, lorsque ceux-ci n\'arrivent plus à tenir debout tellement ils rigolent, en vous voyant affublé de cette coiffe.",ep:13,g:39,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2410] = {n:"Abracaska",t:16,d:"L\'Abracaska permet d\'éviter les gueules de bois.",ep:1,g:40,l:45,wd:true,fm:true,w:50,s:3,p:5500};
I.u[2411] = {n:"Coiffe du Bouftou",t:16,d:"Ce superbe chapeau permet à son porteur de gagner force et intelligence si ce dernier parvient à s\'accommoder de l\'odeur.",ep:1,g:41,l:10,wd:true,fm:true,w:15,s:1,p:2050};
I.u[2412] = {n:"Kwape de Flammes",t:17,d:"Très peu irritante, mais un peu quand même il faut l\'avouer, cette cape ne pourra pas hélas vous faire voler, ni même planer. Même en y cousant un grand \"M\" dessus, ça ne marchera pas, certains y croyaient pourtant dur comme fer. Dommage.",ep:8,g:42,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2413] = {n:"Abracapa",t:17,d:"Vêtu de Feuilles d\'Abraknydes, vous pourrez vous pavaner au beau milieu de la forêt sans que l\'on vous reconnaisse vraiment. Attention toutefois aux Abraknydes en quête de bourgeonnements printaniers.",ep:1,g:43,l:45,wd:true,fm:true,w:17,s:3,p:5500};
I.u[2414] = {n:"Cape Bouffante",t:17,d:"Cette cape a tout pour plaire : sa résistance, son confort, sa couleur, sa rareté... En revanche son odeur est redoutable pour les parois nasales. Mais bon, on ne peut pas tout avoir non plus.",ep:1,g:44,l:10,wd:true,fm:true,w:30,s:1,p:2780};
I.u[2415] = {n:"Kwaklame de Flammes",t:6,d:"La Kwaklame de Flammes est une arme vraiment stylée. A défaut de faire peur à votre adversaire, elle vous servira à l\'impressionner, pour ensuite mieux le surprendre par une vieille ruse de fourbe.",ep:5,g:52,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CI>50&CV>50",s:2,p:4600};
I.u[2416] = {n:"Marteau du Bouftou",t:7,d:"Le manuel de l\'utilisateur explique que ce surprenant marteau est capable de libérer une énergie colossale lorsqu\'il est correctement manié. Encore un manuel Osamodas traduit en Sadida...",ep:1,g:23,l:10,wd:true,fm:true,w:25,an:15,e:[5,5,1,1,40,40,false,true],s:1,p:845};
I.u[2417] = {n:"Abraton",t:4,d:"Ce bâton a gardé toute l\'agressivité de l\'Abraknyde, mais n\'a pas conservé l\'odeur de bois moisi qui caractérise souvent les vieux Abraknydes.",ep:1,g:23,l:45,wd:true,fm:true,w:10,an:12,tw:true,e:[3,4,1,1,30,50,false,false],s:3,p:5500};
I.u[2418] = {n:"Kwakanneau de Flammes",t:9,d:"Grâce à cet anneau, si vous vous perdez en allant délivrer un message, votre maître pourra peut-être vous retrouver.",ep:5,g:43,l:42,wd:true,fm:true,w:2,s:2,p:4900};
I.u[2419] = {n:"Anneau de Bouze le Clerc",t:9,d:"Cet anneau provient du fameux Bouze le Clerc, sauveur des temps modernes. Sa phrase culte parlait d\'un fin Eni et d\'au-delà.",ep:1,g:44,l:10,wd:true,fm:true,w:10,s:1,p:775};
I.u[2420] = {n:"Anobra",t:9,d:"Travailler la Branche d\'Abraknyde n\'est pas chose aisée. Mais avec de la persévérance, on peut finir par obtenir un anneau à la fois sobre, élégant et raffiné. Tout le contraire d\'un Sadida dans une taverne.",ep:1,g:45,l:40,wd:true,fm:true,w:10,s:3,p:4500};
I.u[2421] = {n:"Kwakobottes de Flammes",t:11,d:"Muni de ces ergots de Kwak de Feu, il ne vous reste plus qu\'à marcher sur des oeufs pour ne pas vous les faire voler par un Sram mal intentionné.",ep:5,g:25,l:40,wd:true,fm:true,w:5,s:2,p:4400};
I.u[2422] = {n:"Boufbottes",t:11,d:"Ces Bottes sont d\'un confort inégalé, l\'intérieur a l\'air d\'être doublé en laine de Bouftou, mais on peut ressentir également comme un liquide circulant entre les orteils. Reste à savoir si c\'est de la Bave ou du Sang de Bouftou. Peu importe.",ep:1,g:26,l:10,wd:true,fm:true,w:15,s:1,p:1700};
I.u[2423] = {n:"Abrabottes",t:11,d:"Les effets de cette paire de Bottes peuvent aussi parfaitement être retrouvés en se rendant dans une taverne. Il faut ensuite consommer un peu, voire beaucoup pour un effet optimum. Le lendemain vous aurez des jambes aussi lourdes que ces bottes.",ep:1,g:27,l:45,wd:true,fm:true,w:20,s:3,p:4500};
I.u[2424] = {n:"Amukwak de Flammes",t:1,d:"Avec toutes ces plumes autour du cou, vous ressemblerez à Aldo Rado, grand Sacrieur aventurier en quête d\'une cité d\'or.",ep:5,g:47,l:42,wd:true,fm:true,w:3,s:2,p:4900};
I.u[2425] = {n:"Amulette du Bouftou",t:1,d:"Une bonne Corne de Bouftou, c\'est une Corne qui procure calme et sagesse. Un Bon pendentif de Bouftou vous procurera donc sagesse et calme. Ou l\'inverse. Ou autre chose. Ou alors rien.",ep:1,g:48,l:3,wd:true,fm:true,w:10,s:1,p:550};
I.u[2426] = {n:"L\'Araknamu",t:1,d:"Cette petite Arakne est la preuve vivante que l\'on est pas obligé d\'empailler un animal pour en faire une Amulette. Elle vous chatouillera le cou, et tissera peut-être une toile devant votre bouche, si vous baillez trop souvent, ou si vous avez trop mauvaise haleine.",ep:1,g:49,l:20,wd:true,fm:true,w:10,s:3,p:1300};
I.u[2427] = {n:"Kwakture de Flammes",t:10,d:"Pour parader comme un Kwak de Flammes pendant la saison des amours, cette ceinture sera parfaite, à condition de ne porter que ça.",ep:12,g:28,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2428] = {n:"Ceinture du Bouftou",t:10,d:"Rapide à équiper, cette ceinture s\'avère tout de même assez légère pour sa taille. La laine donne l\'impression d\'être neuve. Normal, il a fallu selon la légende, dépecer une centaine de bouftons pour avoir cet aspect lisse et soyeux.",ep:1,g:29,l:20,wd:true,fm:true,w:10,s:1,p:1253};
I.u[2429] = {n:"Abrature",t:10,d:"Cette ceinture vous apportera assurance et abdominaux en bois. Un traitement anti-Arakne est néanmoins recommandé tous les ans. Un peu comme la coiffure d\'un Sadida, avec heureusement trois fois moins d\'anti-parasites.",ep:1,g:30,l:45,wd:true,fm:true,w:25,s:3,p:4500};
I.u[2430] = {n:"Flaque de Gelée Bleue",t:24,d:"Tu as été une vraie brute envers cette Gelée Bleue. Un jour, qui sait, tu paieras pour ce crime.",ep:7,g:91,l:1,wd:true,fm:true,w:0,p:1};
I.u[2431] = {n:"Flaque de Gelée Citron",t:24,d:"Tu as été une vraie brute envers cette Gelée Citron. Un jour, qui sait, tu te feras aplatir comme elle.",ep:7,g:90,l:1,wd:true,fm:true,w:0,p:1};
I.u[2432] = {n:"Flaque de Gelée Fraise",t:24,d:"Tu as été une vraie brute envers cette Gelée Fraise. Un jour, qui sait, tu ressembleras à une grosse tâche difforme comme elle.",ep:7,g:92,l:1,wd:true,fm:true,w:0,p:1};
I.u[2433] = {n:"Flaque de Gelée Menthe",t:24,d:"Tu as été une vraie brute envers cette Gelée Menthe. Un jour, qui sait, il ne restera de toi que des restes, comme elle.",ep:7,g:93,l:1,wd:true,fm:true,w:0,p:1};
I.u[2435] = {n:"L\'Eni Kère",t:11,d:"Kère fut le seul Eniripsa à remporter devant les Ecaflips, le grand Marathon d\'Amakna. C\'est grâce à ses bottes artisanales qu\'il traversa la Mèr d\'Asse et distança tous les écaflips médusés de voir un Eni courir sur l\'eau. La classe.",ep:5,g:29,l:45,wd:true,fm:true,w:5,p:4800};
I.u[2436] = {n:"Gelée Citron",t:110,d:"Ce pot de Gelée Citron a une apparence étrange. Selon Elrik Ola, cette gelée proviendrait de chez lui. Plus précisément, de l\'autre coin de la galaxie. Autant dire que ce n\'est pas la porte à côté.",ep:7,g:490,l:45,wd:true,fm:true,w:1,p:1};
I.u[2437] = {n:"Gelée Citron Royale",t:110,d:"Selon certaines rumeurs, la Gelée Citron Royale est bien meilleure que les autres gelées. Peut-être parce que le citron cache le goût de la gelée.",ep:7,g:491,l:200,wd:true,fm:true,w:1,p:100};
I.u[2438] = {n:"Boufcoiffe Royale",t:16,d:"La Boufcoiffe Royale est un objet indémodable. Elégante, elle procure à son porteur force et intelligence.",ep:1,g:42,l:50,wd:true,fm:true,w:45,s:4,p:100};
I.u[2440] = {n:"Epée Royale du Bouftou",t:6,d:"Cette épée ne sait pas trop sur quel sabot danser... Elle inflige des dégâts de chaque élément.",ep:1,g:30,l:70,wd:true,fm:true,w:65,an:14,e:[4,4,1,1,30,50,false,false],s:4,p:30000};
I.u[2441] = {n:"Anneau Royal du Bouftou",t:9,d:"Cet anneau augmente la vie de son porteur, tout comme l\'odeur de la femelle du Bouftou Royal augmente son charme.",ep:1,g:46,l:30,wd:true,fm:true,w:5,s:4,p:100};
I.u[2442] = {n:"Boufbottes Royales",t:11,d:"Elles brillent, elles respirent la puissance, ces bottes sont en tous points royales.",ep:1,g:30,l:50,wd:true,fm:true,w:50,s:4,p:6600};
I.u[2443] = {n:"Amulette Royale du Bouftou",t:1,d:"Cette amulette augmente la force et l\'intelligence de son porteur.",ep:1,g:50,l:50,wd:true,fm:true,w:10,s:4,p:5000};
I.u[2444] = {n:"Ceinture Royale du Bouftou",t:10,d:"Cette magnifique ceinture augmente la vitalité de son porteur et lui permet de porter plus facilement ses objets. Elle si douce qu\'elle permet même de ligoter sa dulcinée lorsque celle-ci refuse de rester à la maison.",ep:1,g:31,l:52,wd:true,fm:true,w:10,s:4,p:7000};
I.u[2445] = {n:"Cape Bouffante Royale",t:17,d:"Cette cape portée par le grand Bouftou Royal confère, en plus d\'un style fabuleux, une force hors du commun.",ep:1,g:46,l:50,wd:true,fm:true,w:60,s:4,p:50000};
I.u[2446] = {n:"Gelocape",t:17,d:"Dépourvue de fils et de poils, cette Cape reste un mystère pour les têtes pensantes d\'Amakna, ce qui ne doit pas représenter plus d\'une dizaine de personnes.",ep:7,g:47,l:60,wd:true,fm:true,w:10,s:6,p:1000};
I.u[2447] = {n:"Gelocoiffe",t:16,d:"Avec cette coiffe sur la tête, vous pouvez être certain que vos amis rêveront enfin de vous lécher. Voilà un chapeau qui aurait comblé le Captain Chafer à la grande époque.",ep:5,g:43,l:60,wd:true,fm:true,w:23,s:6,p:9500};
I.u[2448] = {n:"Cervelle de Bouftou",t:15,d:"Aucun doute, cette Cervelle provient bien du Bouftou. Bien cuisiné, ce plat est le préféré de tous les petits Iops qui veulent devenir grands et forts. Ça rend aussi intelligent, mais si on le disait aux enfants Iops, ils en mangeraient beaucoup moins.",ep:1,g:492,l:9,wd:true,fm:true,w:1,p:1};
I.u[2449] = {n:"Armée de Tiques",t:15,d:"Selon les chasseurs, une Armée de Tiques affamées pourrait dévorer toute la Laine d\'un Bouftou en une nuit. Quelques piliers de bar certifient même qu\'elle peut venir à bout de la magnifique crinière d\'un Sadida.",ep:1,g:493,l:9,wd:true,fm:true,w:1,p:1};
I.u[2451] = {n:"Sabot de Bouftou",t:47,d:"Autrefois utilisé comme sous-verre, certains alchimistes Eniripsas, assez coquets admettons le, recyclent le Sabot de Bouftou pour en faire des Bols. De quoi donner du goût à leurs céréales préférées.",ep:1,g:495,l:9,wd:true,fm:true,w:1,p:1};
I.u[2453] = {n:"Oeil de Bouftou",t:109,d:"Autrefois, on faisait de cet Oeil une soupe extra. Succulente à un point que l\'on a dû bannir la recette des livres, car bon nombre de chasseurs n\'allaient récupérer que les yeux et laissaient fumante la carcasse du pauvre Bouftou.",ep:1,g:497,l:9,wd:true,fm:true,w:1,p:1};
I.u[2454] = {n:"Estomac de Bouftou",t:15,d:"Un Estomac de ce genre possède des qualités élastiques efficaces. Par contre, ne vous étonnez pas s\'il reste à l\'intérieur une bouillie de Trèfles, au contraire, réjouissez-vous Mesdemoiselles, cette bouillie est très bonne pour la peau.",ep:1,g:498,l:9,wd:true,fm:true,w:1,p:1};
I.u[2455] = {n:"Sang de Bouftou",t:15,d:"Impossible d\'aller chasser sans se passer de ce Sang de Bouftou tellement son odeur attire les Bouftous les plus gros. Il attire aussi très efficacement les Moskitos sans que l\'on sache encore pourquoi.",ep:1,g:499,l:9,wd:true,fm:true,w:1,p:1};
I.u[2460] = {n:"Oeil de Boufton",t:109,d:"Ce n\'est pas que ce Boufton garde un Oeil sur vous, mais vous avez quand même l\'impression qu\'il vous en veut.",ep:1,g:500,l:2,wd:true,fm:true,w:1,p:1};
I.u[2462] = {n:"Cervelle de Chef de Guerre Bouftou",t:15,d:"Forcément, le Chef de Guerre Bouftou dont vous venez d\'extraire la Cervelle, va marcher beaucoup moins bien.",ep:1,g:501,l:19,wd:true,fm:true,w:1,p:1};
I.u[2463] = {n:"Dent de Chef de Guerre Bouftou",t:47,d:"Extraire une Dent de Chef de Guerre n\'est pas donnée à tout le monde, il faut l\'avouer. Notez que cette Dent a beaucoup plus de valeur si elle est abîmée. N\'allez pas me demander pourquoi, il paraît que c\'est une histoire d\'équilibre économique.",ep:1,g:502,l:19,wd:true,fm:true,w:1,p:1};
I.u[2464] = {n:"Queue de Chef de Guerre Bouftou",t:65,d:"Restez terré dans les Bois, observez patiemment, sans faire de bruit, et là, peut-être, vous verrez un Chef de Guerre Bouftou frétiller de la queue. Mais ce petit geste anodin n\'a lieu que pendant la période d\'accouplement.",ep:1,g:503,l:19,wd:true,fm:true,w:1,p:1};
I.u[2465] = {n:"Corne de Chef de Guerre Bouftou",t:47,d:"Moins doux que son congénère, le Chef de Guerre Bouftou a plus de facilité pour embrocher les Srams et autres races téméraires. On peut souvent trouver des bouts de tissus attachés à leurs cornes, un peu comme une sorte de trophée.",ep:1,g:504,l:19,wd:true,fm:true,w:1,p:1};
I.u[2466] = {n:"Langue de Chef de Guerre Bouftou",t:15,d:"L\'expression \"avoir une haleine chargée\" tombe à pic pour le Chef de Guerre Bouftou. En effet, on a toujours le sentiment qu\'il a mangé un Trool pas frais.",ep:1,g:505,l:19,wd:true,fm:true,w:1,p:1};
I.u[2467] = {n:"Sabot de Chef de Guerre Bouftou",t:47,d:"Selon les cordonniers, ce Sabot est l\'un des plus résistants et le plus malléable de la Province. Reste à savoir ce qu\'ils entendent par \"malléable \". À trop les écouter, on pourrait comprendre qu\'ils peuvent confectionner des bottes à l\'aide de ce Sabot.",ep:1,g:538,l:18,wd:true,fm:true,w:1,p:1};
I.u[2468] = {n:"Estomac de Chef de Guerre Bouftou",t:15,d:"À l\'intérieur de cet Estomac se cache une surprise. Petit doigt d\'Enutrof, bout de nez d\'Osamodas... On pourrait quasiment se reconstruire un Héros avec tous ces morceaux.",ep:1,g:506,l:19,wd:true,fm:true,w:1,p:1};
I.u[2469] = {n:"Gelano",t:9,d:"Inutile de vous ronger les ongles avec cet anneau, léchez-vous les doigts !",ep:7,g:47,l:60,wd:true,fm:true,w:5,s:6,p:10000};
I.u[2470] = {n:"Gelobottes",t:11,d:"Ces bottes sont très confortables en été, car elles libèrent une odeur de fraise des bois, couvrant facilement l\'odeur de transpiration qui pourrait se dégager des orteils d\'un vieux Sadida aux pieds poilus.",ep:5,g:31,l:60,wd:true,fm:true,w:50,s:6,p:1000};
I.u[2471] = {n:"Geloture",t:10,d:"Le plus dur avec cette Geloture, c\'est qu\'en cas de fringale, on est vite tenté de croquer dedans.",ep:7,g:32,l:60,wd:true,fm:true,w:15,s:6,p:1000};
I.u[2472] = {n:"Gelamu",t:1,d:"Voilà une amulette, qui trahira votre goût prononcé pour les orgies de Gelée. On peut trouver mieux pour se mettre en valeur ou briller en société, mais il faut assumer jusqu\'au bout votre faible pour la gelée.",ep:5,g:51,l:60,wd:true,fm:true,w:4,s:6,p:1000};
I.u[2473] = {n:"Cape de l\'Aventurier",t:17,d:"Classe mais peu performante, cette cape comblera tout de même les jeunes aventuriers.",ep:1,g:48,l:1,wd:true,fm:true,w:7,s:5,p:100};
I.u[2474] = {n:"Chapeau de l\'Aventurier",t:16,d:"À part faire fuir les nanas, ce chapeau n\'a pas vraiment grande utilité.",ep:1,g:44,l:1,wd:true,fm:true,w:12,s:5,p:100};
I.u[2475] = {n:"Anneau de l\'Aventurier",t:9,d:"Un petit anneau sympathique pour les débutants, et qui amusera les jeunes enfants, ou les Ecaflips.",ep:1,g:48,l:1,wd:true,fm:true,w:5,s:5,p:10};
I.u[2476] = {n:"Bottes de l\'Aventurier",t:11,d:"Bottes de simple facture mais idéales pour les jeunes se lançant sur le dur chemin de l\'aventure.",ep:1,g:32,l:1,wd:true,fm:true,w:15,s:5,p:10};
I.u[2477] = {n:"Ceinture de l\'aventurier",t:10,d:"Une petite ceinture pour les aventuriers en herbe.",ep:1,g:33,l:1,wd:true,fm:true,w:6,s:5,p:10};
I.u[2478] = {n:"Amulette de l\'Aventurier",t:1,d:"Pas très classe, pas très efficace, mais sympathique lorsque l\'on possède la panoplie.",ep:1,g:52,l:1,wd:true,fm:true,w:2,s:5,p:10};
I.u[2479] = {n:"Crête de Porkass",t:15,d:"Cette coiffure est signe de maturité chez le Porkass. C\'est pour cela que l\'on voit de temps en temps de jeunes Eniripsas en quête de puberté, se promener avec une crête en ville. Par contre, ils n\'osent pas vraiment aller dans les Plaines Rocheuses avec.",ep:13,g:507,l:18,wd:true,fm:true,w:1,p:1};
I.u[2480] = {n:"Slip en cuir de Porkass",t:56,d:"\"Un Porkass sans Slip est un Porkass Mort\", telle était l\'expression favorite de Dame Harre, Féca adepte du voyeurisme et du bizutage. Son passe-temps préféré était d\'obliger ses \"amis\" à enfiler sur la tête le Slip pas très propre du Porkass.",ep:13,g:508,l:18,wd:true,fm:true,w:1,p:1};
