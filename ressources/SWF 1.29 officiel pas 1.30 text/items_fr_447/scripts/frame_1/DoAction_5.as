I.u[2012] = {n:"Sang de Scorbute",t:15,d:"Ce sang très sirupeux ne contient pas de poison contrairement aux idées reçues. Au contraire, il permet de faire de puissant conservateur et de jolis masques de beauté.",ep:1,g:389,l:36,wd:true,fm:true,w:1,p:5};
I.u[2013] = {n:"Nuggets ****",t:69,d:"Ces petits carrés d\'oiseau frit sont un véritable bonheur pour les papilles, mais un grand malheur pour le ventre.",ep:13,g:117,l:1,wd:true,fm:true,w:1,c:"Cs<20",u:true,ut:true,p:20000};
