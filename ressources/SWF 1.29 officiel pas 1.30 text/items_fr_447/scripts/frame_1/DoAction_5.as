I.u[2140] = {n:"Enveloppe",t:24,d:"...",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2141] = {n:"Poumon de la plaine",t:24,d:"Ce collier orné d\'un énorme diamant vert est tellement voyant, que l\'on ne regarde plus que lui et pas la personne qui le porte...Ce qui s\'avère très pratique dans certaines situations.",ep:1,g:66,l:1,wd:true,fm:true,w:0,p:1};
I.u[2143] = {n:"Clé des Mercenaires",t:15,d:"Vous avez entre les mains l\'une des clés qui pourra vous faire entrer chez les Mercenaires.",ep:1,g:404,l:1,wd:true,fm:true,w:0,p:1};
I.u[2144] = {n:"Champo Banal",t:24,d:"Ce Champo n\'est pas de trés bonne facture, mais il a le mérite de protéger du soleil.",ep:2,g:68,l:1,wd:false,fm:true,w:0,p:1};
I.u[2145] = {n:"Broche de Sbab",t:24,d:"Cette petite broche vous a été donné par Sbab par respect pour votre honneur de démon.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2146] = {n:"Aveux d\'Oni Tnec",t:24,d:"Les aveux d\'Oni Tnec où il décrit de quelle façon atroce il a tué Rimaraf.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2147] = {n:"Poison de scorbute",t:24,d:"Du poison de scorbute avec la facture au nom d\'Oni Tnec.",ep:2,g:39,l:1,wd:true,fm:true,w:0,p:1};
