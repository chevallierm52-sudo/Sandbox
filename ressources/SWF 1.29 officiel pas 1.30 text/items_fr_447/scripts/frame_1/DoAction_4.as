I.u[1610] = {n:"Ecorce d\'Abraknyde Sombre",t:96,d:"Cette écorce provient du cadavre d\'un Abraknyde Sombre.",ep:9,g:231,l:78,wd:true,fm:true,w:1,p:50};
I.u[1611] = {n:"Bourgeon d\'Abraknyde Sombre",t:108,d:"Ce bourgeon provient du cadavre d\'un Abraknyde sombre.",ep:9,g:230,l:78,wd:true,fm:true,w:1,p:50};
I.u[1612] = {n:"Racine d\'Abraknyde Sombre",t:98,d:"Cette racine provient du cadavre d\'un Abraknyde sombre.",ep:9,g:232,l:78,wd:true,fm:true,w:1,p:50};
I.u[1613] = {n:"Ecaille de Chef Crocodaille",t:59,d:"Ce fragment de carapace servira certainement à créer de belles bottes.",ep:4,g:547,l:69,wd:true,fm:true,w:5,p:100};
I.u[1614] = {n:"Dents de Chef Crocodaille",t:47,d:"Ces dents arrachées avec peine de la gueule d\'un Crocodaille doivent bien avoir une utilité.",ep:4,g:548,l:69,wd:true,fm:true,w:1,p:100};
I.u[1619] = {n:"L\'Abramu",t:1,d:"L\'Abramu est une amulette très élégante. Si vous avez l\'intention de la porter nous vous conseillons de vous promener nu afin de bien mettre en valeur ce précieux bijoux. Vous verrez, les dames n\'y résistent pas.",ep:9,g:16,l:46,wd:true,fm:true,w:2,p:5700};
I.u[1620] = {n:"Abrarc",t:2,d:"Cet arc semble encore vivant et peut presque tirer des flèches tout seul, comme un grand. Il aurait pu être l\'arc idéal des personnes dotées de deux mains gauches, mais malheureusement, il faut toujours encocher la flèche dans le bon sens.",ep:9,g:24,l:39,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,50,30,false,true],p:4200};
I.u[1621] = {n:"Bottes de Maîtrise",t:11,d:"Les bottes de Maîtrise augmentent l\'agilité et l\'intelligence de leur lanceur au détriment de la force et de la chance. Contrairement à ce que l\'on pourrait croire, elle ne vous permettent pas de maitriser votre adversaire.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1622] = {n:"Bottes de Puissance",t:11,d:"Les bottes de puissance augmentent la force et la chance de leur lanceur au détriment de l\'intelligence et de l\'agilité. Contrairement à ce que l\'on pourrait croire, elle ne confèrent pas à leur porteur, une puissance démente.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1623] = {n:"Bottes d\'Anticipation",t:11,d:"Les bottes d\'Anticipation augmentent la force et l\'agilité de leur lanceur au détriment de l\'intelligence et de la chance. Contrairement à ce que l\'on pourrait croire, elles ne vous permettent pas d\'anticiper les actions de vos adversaires.",ep:4,g:15,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1624] = {n:"Bottes de Nexus",t:11,d:"Ces bottes ont appartenu à Nexus, grand chevalier figé à jamais.",ep:3,g:16,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1625] = {n:"La légende du Croqueur",t:25,d:"Ce livre retrace le parcours du dernier être humain à avoir été en contact avec le Croqueur.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1626] = {n:"Encyclopédie d\'Alchimie Annexe A : Métiers",t:25,d:"Cette encyclopédie regroupe les recettes d\'alchimie pour l\'oubli de métier",ep:1,g:2,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1628] = {n:"Artefact Feu",t:9,d:"Cet Artefact doit son histoire à une très ancienne légende, mais aujourd\'hui, nul ne connaît son pouvoir.",ep:1,g:18,l:1,wd:true,fm:true,w:0,p:1};
