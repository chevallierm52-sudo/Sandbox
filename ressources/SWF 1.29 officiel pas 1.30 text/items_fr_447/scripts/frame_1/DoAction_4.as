I.u[1847] = {n:"Brochet",t:41,d:"Ce poisson d\'eau douce de taille moyenne est l\'ami du barbecue du pêcheur.",ep:2,g:400,l:10,wd:true,fm:true,w:3,p:1};
I.u[1848] = {n:"Brochet vidé",t:62,d:"Ce brochet peut maintenant être utilisé comme ingrédient.",ep:2,g:401,l:10,wd:true,fm:true,w:2,p:1};
I.u[1849] = {n:"Brochet Tupe-Halett",t:41,d:"Issue du croisement entre divers brochets par les scientifiques Halett et Tupe, cette espèce est censée disposer d\'attributs magiques. Destiné à l\'expérimentation, deux spécimens s\'échappèrent lors d\'une violente dispute entre les deux savants.",ep:1,g:402,l:10,wd:true,fm:true,w:3,p:1};
I.u[1851] = {n:"Brochet Tupe-Halett vidé",t:62,d:"Ce brochet Tupe-Halett peut maintenant être utilisé comme ingrédient.",ep:1,g:403,l:10,wd:true,fm:true,w:2,p:1};
I.u[1852] = {n:"Requin marteau-faucille vidé",t:62,d:"Ce requin marteau-faucille peut maintenant être utilisé comme ingrédient.",ep:2,g:323,l:80,wd:true,fm:true,w:2,p:1};
I.u[1853] = {n:"Requin Marché-Libre",t:41,d:"Cousin du requin Marteau-Faucille, mais en plus féroce et beaucoup moins organisé. En attraper un est le rêve de tous les pêcheurs ou plutôt, en attraper un et être toujours en vie.",ep:1,g:324,l:80,wd:true,fm:true,w:4,p:1};
I.u[1854] = {n:"Requin marché-libre vidé",t:62,d:"Ce requin marché-libre peut maintenant être utilisé comme ingrédient.",ep:1,g:325,l:80,wd:true,fm:true,w:3,p:1};
I.u[1859] = {n:"Kralamoure grillé ****",t:49,d:"Une bonne odeur se dégage de ce kralamoure grillé, celui qui le mangera va se régaler.",ep:1,g:91,l:1,wd:true,fm:true,w:1,c:"Ci<50",u:true,ut:true,p:50000};
I.u[1860] = {n:"Canne Harpon",t:20,d:"Cette canne à pêche, ultra resistante, possède un hameçon en forme de harpon spécialement étudié pour la pêche au requin.",ep:1,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1861] = {n:"La Grande Perche",t:20,d:"Cette canne à pêche a été étudiée spécialement pour attraper les vives perches.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1862] = {n:"Le Bâton d\'Amour",t:20,d:"Le bois de cette canne dégage une résine odorante qui imprègne le fil et l\'hameçon. Cette odeur suave doit ressembler au parfum d\'une Kralamourette car tous les Kralamoures viennent s\'y coller.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1863] = {n:"Canne à Chô",t:20,d:"Chô était le plus fameux cuisinier de la table ronde. Sa particularité était de dénicher les aliments frais en face du client. Cette canne lui permettait de pêcher les poissons indispensables pour son cèlebre plat de carpes à Chô.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1864] = {n:"L\'aiguille à Tricoter",t:20,d:"Le fil de cette canne à pêche est exclusivement composé de laine dont la pelote remplace l\'appât. Très peu de poisson-chaton arrivent à y résister.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1865] = {n:"Canne Cubique",t:20,d:"Cette canne est spécialement conçue pour s\'adapter à la morphologie si...particulière des poissons panés.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1866] = {n:"Canne à Pêche Standard",t:20,d:"Cette canne, de moyenne facture, permettra au jeune pêcheur de pêcher presque n\'importe quoi, s\'il prend la peine d\'être suffisamment patient.",ep:2,g:8,l:1,wd:true,fm:true,w:3,an:18,e:[1,4,1,3,100,100,false,false],c:"PJ>36,9",p:1000};
I.u[1867] = {n:"Grande Canne à Pêche",t:20,d:"Cette canne à pêche est destinée aux pêcheurs professionnels. Elle leur permettra de lancer leur ligne très loin. Mais il faut savoir la maîtriser pour pêcher quelque chose.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,5,100,100,false,false],c:"PJ>36,39",p:2000};
I.u[1868] = {n:"Canne à Pêche Téléscopique",t:20,d:"Cette canne a pêche peut atteindre des longueurs effarantes. Seul les maîtres pêcheurs savent utiliser leur potentiel.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,7,100,100,false,false],c:"PJ>36,69",p:4000};
I.u[1869] = {n:"Arracheur de Dents",t:24,d:"Cet arracheur de Dents marche principalement sur les bouftous, mais vous pouvez toujours essayer de vous enlever une carie si le coeur vous en dit.",ep:2,g:34,l:1,wd:true,fm:true,w:0,p:1};
I.u[1870] = {n:"Dent de bouftou",t:24,d:"Cette dent de bouftou ressemble à s\'y méprendre à une dent humaine.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[1871] = {n:"Collier",t:24,d:"Le collier que la fille du maire a perdu. Malheureusement, il est en piteux état après avoir séjourné dans l\'estomac d\'un Corbac ...",ep:2,g:36,l:1,wd:true,fm:true,w:0,p:1};
I.u[1872] = {n:"Poudre à canon",t:24,d:"De la poudre à canon, une étiquette rappelle son utilisation qui est on ne peut plus simple : \nPoudre + Flamme = Explosion",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[1873] = {n:"Bloc de pierre",t:24,d:"Un bloc de pierre de Craqueleur des Plaines semblable à ceux qui ont permis de construire les fortifications de Bonta.",ep:2,g:38,l:1,wd:true,fm:true,w:0,p:1};
I.u[1874] = {n:"Venin de scorbute",t:24,d:"Du venin de scorbute à ne pas mettre entre toutes les mains.",ep:2,g:39,l:1,wd:true,fm:true,w:2,p:1};
I.u[1875] = {n:"Faux du Maître Corbac",t:24,d:"Pourquoi couper du blé avec cette faux, quand on peut couper du granit ?",ep:2,g:40,l:1,wd:true,fm:true,w:0,p:1};
I.u[1876] = {n:"Formulaire d\'inspection",t:24,d:"Ce formulaire d\'inspection d\'acte Brâkmarien n° 243 permet de déceler si un homme en est un ou pas ...",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[1877] = {n:"Hood troué",t:24,d:"L\'ancien propriétaire de ce chapeau a certainement subi des coups, c\'est ce qui arrive quand on se rebelle contre l\'autorité de Bonta ...",ep:1,g:42,l:1,wd:true,fm:true,w:0,p:1};
I.u[1878] = {n:"Carte spéciale",t:24,d:"Cette carte à jouer a un aspect particulier, elle est dans un état proche de la perfection. Tout porte à croire qu\'elle est destinée à une collection.",ep:2,g:43,l:1,wd:true,fm:true,w:0,p:1};
I.u[1879] = {n:"Caisse d\'armes blanches",t:24,d:"Une caisse d\'armes blanches, remplie d\'objets contondants en tout genre.",ep:2,g:44,l:1,wd:true,fm:true,w:500,p:1};
I.u[1880] = {n:"Boîte de Chabon",t:24,d:"Hmm... du chabon, c\'est votre Kanigrou qui va être content.",ep:2,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[1881] = {n:"Boue",t:24,d:"Voila, ça, c\'est fait.",ep:2,g:46,l:1,wd:true,fm:true,w:2,p:1};
I.u[1882] = {n:"Fleurs de Blop concassé",t:24,d:"Vous avez récupéré une bien belle bouillie.",ep:2,g:47,l:1,wd:true,fm:true,w:0,p:1};
I.u[1883] = {n:"Collier réparé",t:24,d:"Le collier que la fille du maire a perdu, presque comme neuf...",ep:2,g:48,l:1,wd:true,fm:true,w:0,p:1};
I.u[1889] = {n:"Plume de Corbac",t:53,d:"Autrefois utilisée pour l\'écriture, cette plume est désormais essentiellement utilisée en haute couture. En effet, les Corbacs sont de moins en moins généreux et n\'offrent plus leurs plumes au premier venu. Tout se perd décidément.",ep:1,g:327,l:20,wd:true,fm:true,w:1,p:1};
I.u[1890] = {n:"Poil de Kanigrou",t:54,d:"Le poil de Kanigrou réfléchit la lumière du soleil d\'une manière assez étrange, comme si il en absorbait une partie avant de la renvoyer.",ep:13,g:359,l:70,wd:true,fm:true,w:1,p:1};
I.u[1891] = {n:"Peau de serpentin",t:59,d:"N\'avez-vous jamais rêvé d\'un magnifique petit sac en peau de Serpentin ? Non ? Vous avez bien raison, car sa résistance laisse à désirer.",ep:2,g:361,l:10,wd:true,fm:true,w:1,p:1};
I.u[1892] = {n:"Plume du Maître Corbac",t:53,d:"Pris de panique, le Maître Corbac ouvrit de larges ailes et laissa tomber cette plume. Pas de quoi casser trois pattes à un Koin-koin, et pourtant...",ep:13,g:362,l:160,wd:true,fm:true,w:1,p:1};
I.u[1893] = {n:"Queue de scorbute",t:65,d:"Un formidable trophée, dommage qu\'il suinte un liquide nauséabond.",ep:14,g:363,l:36,wd:true,fm:true,w:1,p:1};
I.u[1894] = {n:"Poil de Sanglier des Plaines",t:54,d:"Ce poil est vraiment répugnant. En regardant de plus près, il y a tout un microcosme qui vit dedans. Quelle chance vous avez.",ep:13,g:364,l:44,wd:true,fm:true,w:1,p:1};
I.u[1895] = {n:"Bière du Feubuk",t:37,d:"Cette bière fortement alcoolisée vous permettra de restaurer vos points de vie.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:4};
I.u[1896] = {n:"Viande d\'Oiseau",t:63,d:"Cette cuisse de tofu prouve que les chasseurs savent faire dans la finesse de temps en temps.",ep:1,g:348,l:1,wd:true,fm:true,w:2,p:1};
I.u[1897] = {n:"Viande d\'Oiseau **",t:63,d:"Des mini cuisses de kwak pour un maxi goût.",ep:1,g:349,l:40,wd:true,fm:true,w:2,p:1};
I.u[1898] = {n:"Chair de Larve",t:63,d:"Cet amas jaune nauséabond représente la vraie nature de la Larve. On comprend maintenant pourquoi leur peau est si résistante.",ep:1,g:354,l:1,wd:true,fm:true,w:2,p:1};
I.u[1899] = {n:"Chair de Larve **",t:63,d:"Cet amas jaune nauséabond représente la vraie nature de la Larve. On comprend maintenant pourquoi leur peau est si résistante.",ep:1,g:354,l:9,wd:true,fm:true,w:2,p:1};
I.u[1900] = {n:"Chair de Larve ***",t:63,d:"Cet amas jaune nauséabond représente la vraie nature de la Larve. On comprend maintenant pourquoi leur peau est si résistante.",ep:1,g:354,l:10,wd:true,fm:true,w:2,p:1};
I.u[1901] = {n:"Cuisse de Wabbit ****",t:63,d:"Cette cuisse est simplement parfaite, on ne peut s\'empêcher de la dévorer des yeux, puis de la bouche.",ep:2,g:368,l:80,wd:true,fm:true,w:2,p:1};
I.u[1902] = {n:"Cuisse de Wabbit",t:63,d:"Cette cuisse de Wabbit semble être parfumée à la cawotte. Idéal pour les pot-au-feu.",ep:8,g:365,l:20,wd:true,fm:true,w:2,p:1};
I.u[1903] = {n:"Cuisse de Wabbit **",t:63,d:"De la bonne cuisse bien musclée qui promet d\'être un régal.",ep:8,g:366,l:40,wd:true,fm:true,w:2,p:1};
I.u[1904] = {n:"Dragocoiffe Blanche",t:16,d:"Une coquille de Dragoeuf Blanc rembourrée de cuir et de laine, rien de tel pour se protéger des attaques classiques et des éclairs d\'un Bwork Mage ivre. En revanche, vous avez l\'air de sortir de l\'oeuf avec un pareil chapeau.",ep:11,g:28,l:39,wd:true,fm:true,w:50,p:4200};
I.u[1905] = {n:"Cuisse de Wabbit ***",t:63,d:"Une cuisse bien grosse qui devrait remplir la plupart des estomacs.",ep:8,g:367,l:60,wd:true,fm:true,w:2,p:1};
I.u[1907] = {n:"Oreilles de Lapineupe",t:16,d:"Ces oreilles mettront en valeur votre sourire éclatant, tout en vous permettant d\'amplifier les ragots et rumeurs qui circuleront dans votre dos.",ep:1,g:30,l:30,wd:true,fm:true,w:9,p:2600};
I.u[1908] = {n:"Casque du Chafer",t:16,d:"Même Spartapine le grand moissonneur, n\'eut pas la chance de porter un tel casque, qui doit sa résistance aux métaux et pierres de qualité utilisés pour sa confection.",ep:13,g:31,l:50,wd:true,fm:true,w:18,p:6500};
I.u[1910] = {n:"Cape Ouginak",t:17,d:"Cette cape provient d\'un Ouginak, elle sent encore l\'odeur de sa truffe, chaude et humide, un peu comme les mamelles d\'une femelle Bouftou en rût.",ep:14,g:33,l:50,wd:true,fm:true,w:10,p:6650};
I.u[1911] = {n:"Cuisse de Boufton",t:63,d:"L\'odeur de cette petite cuisse disparaît à la cuisson.",ep:1,g:334,l:10,wd:true,fm:true,w:2,p:1};
I.u[1912] = {n:"Cuisse de Bouftou **",t:63,d:"Cette cuisse pue la mort bien que cela ne soit pas lié avec le décès prématuré de son propriétaire.",ep:1,g:335,l:20,wd:true,fm:true,w:2,p:1};
I.u[1913] = {n:"Cuisse de Bouftou ***",t:63,d:"Cette cuisse provient d\'un chef de guerre bouftou, dure comme un craqueleur elle pourrait être une massue très puissante s\'il n\'y avait pas l\'odeur.",ep:1,g:336,l:40,wd:true,fm:true,w:2,p:1};
I.u[1914] = {n:"Cuisse de Bouftou ****",t:63,d:"Tendre, mais ferme, pas trop grasse ni trop sèche, cette cuisse est comme un bon vin qui s\'est enrichi et affiné au court de toutes ces années.",ep:1,g:337,l:50,wd:true,fm:true,w:2,p:1};
I.u[1915] = {n:"Chair d\'Insecte",t:63,d:"Il ne faut pas sous-estimer la valeur nutritionnelle de cette chair gluante et asphyxiante.",ep:1,g:370,l:1,wd:true,fm:true,w:2,p:1};
I.u[1916] = {n:"Chair d\'Insecte **",t:63,d:"Une chair identique à celle des mosquitos, mais en quantité 10 fois supérieure. Heureusement que certains aiment.",ep:3,g:370,l:50,wd:true,fm:true,w:4,p:1};
I.u[1917] = {n:"Carré de Porc",t:63,d:"Ce morceau de choix de sanglier est un peu sanguinolent pour le moment, mais promet de bons moments.",ep:1,g:331,l:30,wd:true,fm:true,w:3,p:1};
I.u[1918] = {n:"Carré de Porc **",t:63,d:"Un peu plus gros pour un peu plus de bonheur, ce découpage improvisé de Sanglier des plaines ravira tous les carnivores.",ep:13,g:331,l:50,wd:true,fm:true,w:3,p:1};
I.u[1919] = {n:"Carré de Porc ****",t:63,d:"Ce morceau de DragonCochon est si doux et si moelleux qu\'on pourrait en faire un coussin royal. Mais on préfère le manger.",ep:2,g:331,l:80,wd:true,fm:true,w:4,p:1};
I.u[1920] = {n:"Badge Bontarien",t:24,d:"Ce badge permet d\'identifier un milicien lorsqu\'il périt sur un champ de bataille. Il paraît que certains en font collection, à Brâkmar.",ep:2,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[1921] = {n:"Carré de Porc ***",t:63,d:"Ferme à souhait, le cochon, à qui appartenait ce morceau, devait faire beaucoup d\'exercice.",ep:1,g:331,l:60,wd:true,fm:true,w:3,p:1};
I.u[1922] = {n:"DragoViande",t:63,d:"Viande rare de qualité supérieure, elle garde la chaleur de nombreuses heures après sa cuisson, faisant d\'elle une viande particulièrement pratique pour les voyages.",ep:2,g:371,l:40,wd:true,fm:true,w:2,p:1};
I.u[1923] = {n:"DragoViande **",t:63,d:"Cette dragoviande, en plus de ses qualités thermiques, possède un petit goût naturel de fumé.",ep:2,g:371,l:60,wd:true,fm:true,w:2,p:1};
I.u[1924] = {n:"DragoViande ***",t:63,d:"La dragoviande de dragoeuf est un peu dure à macher, mais bien plus nourrissante que la Dragoviande traditionnelle. Certains pensent même qu\'elle aurait des vertus magiques.",ep:11,g:371,l:70,wd:true,fm:true,w:2,p:1};
I.u[1925] = {n:"Permission de 24 heures",t:24,d:"Cette permission de la milice indique que vous avez quartier libre pendant une journée.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[1926] = {n:"DragoViande ****",t:63,d:"Cette viande issue des parties dragoniques du dragoncochon (que personne n\'a envie de localiser précisément) \nest un cadeau du ciel. Ce qui est plutôt logique puisque le dragoncochon vole.",ep:2,g:371,l:80,wd:true,fm:true,w:2,p:1};
I.u[1927] = {n:"Museau",t:63,d:"Ce museau de milimulou, avec ses petites babines fermes, accompagnera avec plaisir toutes vos chalades.",ep:1,g:372,l:30,wd:true,fm:true,w:1,p:1};
I.u[1928] = {n:"Défense de sanglier agressif",t:24,d:"Une bonne dextérité a dû être nécessaire pour extraire cette défense à un Sanglier des plaines.",ep:2,g:51,l:1,wd:true,fm:true,w:0,p:1};
I.u[1929] = {n:"Museau **",t:63,d:"Ce museau au goût délicat vous rendra placide. À consommer sans modération.",ep:1,g:373,l:50,wd:true,fm:true,w:2,p:1};
I.u[1930] = {n:"Museau ***",t:63,d:"Cette viande est délicieuse, mais attention à ne pas en abuser. Ce n\'est pas pour rien que le Meulou pue de la gueule.",ep:2,g:374,l:70,wd:true,fm:true,w:2,p:1};
I.u[1931] = {n:"Katana ébréché",t:24,d:"C\'est l\'arme de Amayiro. Elle a une prise en main étonnante, mais elle semble être légèrement fendue.",ep:2,g:52,l:1,wd:true,fm:true,w:0,p:1};
I.u[1932] = {n:"Katana rénové",t:24,d:"Cette arme, autrefois ébréchée, est à nouveau prête à couper n\'importe quoi. Amayiro ne sera pas déçu.",ep:2,g:53,l:1,wd:true,fm:true,w:0,p:1};
I.u[1933] = {n:"Viande d\'Oiseau ****",t:63,d:"Ce petit morceau de corbac est imprégné d\'une magie puissante, probablement celle appliquée par le maître corbac lui-même.",ep:13,g:350,l:30,wd:true,fm:true,w:2,p:1};
I.u[1934] = {n:"Couteau de Chasse",t:20,d:"Ce couteau est la marque typique de reconnaissance des chasseurs. Plus il est gros, coupant, et brillant plus ils se trouvent beaux, du moins selon leurs critères.",ep:1,g:14,l:1,wd:true,fm:true,w:2,an:13,e:[10,3,1,1,25,30,false,false],c:"PJ>41,0",p:1};
I.u[1935] = {n:"Chèque de 100000 kamas",t:24,d:"Qui paye ses dettes s\'enrichit, mais c\'est tout de même une sacrée somme. Mieux vaut éviter les dettes de cette taille, votre porte-feuille vous remerciera.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[1936] = {n:"Hache de chasse",t:20,d:"Cette hache est particulièrement adaptée pour trancher rapidement et précisément n\'importe quelle partie d\'un animal même encore vivant.",ep:1,g:15,l:1,wd:true,fm:true,w:5,an:17,e:[10,4,1,1,30,40,false,false],c:"PJ>41,9",p:1000};
I.u[1937] = {n:"Rapport d\'espionnage",t:24,d:"Ce rapport de Bishom Pot doit contenir pas mal de faits et gestes sur les habitants de Brâkmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[1938] = {n:"Lame de chasse",t:20,d:"Cette lame, au nom controversé, fut conçue pour la chasse exclusivement. Un peu délicate à manier, elle sera cependant d\'un grand secours au chasseur habile.",ep:3,g:16,l:1,wd:true,fm:true,w:2,an:14,e:[5,4,1,1,40,40,false,false],c:"PJ>41,29",p:5000};
I.u[1939] = {n:"Lance de Chasse",t:20,d:"Pratique contre les groupes de monstres, cette lance demande un certain talent pour être maniée avec dextérité.",ep:3,g:17,l:1,wd:true,fm:true,w:2,an:12,e:[7,5,1,1,30,50,false,false],c:"PJ>41,49",p:10000};
I.u[1940] = {n:"Marteau de chasse",t:20,d:"Ce marteau n\'a pas une conception classique, il est équilibré de telle sorte qu\'il assome plutôt qu\'il n\'écrase. Très pratique pour chasser, pas du tout pour survivre.",ep:1,g:18,l:1,wd:true,fm:true,w:2,an:15,e:[5,6,1,1,50,50,false,false],c:"PJ>41,69",p:20000};
I.u[1941] = {n:"Pelle Chasseuse",t:20,d:"Cette pelle est particulièrement indiquée pour faucher du monstre sans l\'abîmer. Un accessoire pour chasseur confirmé uniquement.",ep:3,g:9,l:1,wd:true,fm:true,w:2,an:16,e:[7,4,1,1,30,50,false,false],c:"PJ>41,29",p:5000};
