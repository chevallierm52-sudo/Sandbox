I.u[1634] = {n:"Sphère à Metarias",t:66,d:"Cette sphère est une imitation parfaite de la membrane isolante d\'une metaria.",ep:9,g:240,l:1,wd:true,fm:true,w:1,p:100};
I.u[1635] = {n:"Parchemin Vent de panique",t:25,d:"(Double clic pour apprendre cette emote) \nCe parchemin vous permet d\'apprendre à \"lâcher les gaz\", mais attention à ne pas trop en abuser... cela peut être dangereux pour votre santé et celle de vos amis.",ep:4,g:9,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[1636] = {n:"Petite Etoile du Soir",t:6,d:"La créatrice de cette épée aux charmes certains, à voulu retranscrire toute sa beauté gracieuse auréolée d\'un caractère piquant. Le résultat est bien plus parlant que des mots.",ep:1,g:22,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>35&CV>35&CS>11",p:4000};
