I.u[1796] = {n:"Carpette des sables",t:41,d:"Cette petite carpe a une coloration semblable au sable. Une évolution de la nature qui lui permet d\'être théoriquement invisible aux yeux des prédateurs. Dommage qu\'il n\'y ait pas de sable dans les fonds des lacs...",ep:1,g:307,l:40,wd:true,fm:true,w:3,p:1};
