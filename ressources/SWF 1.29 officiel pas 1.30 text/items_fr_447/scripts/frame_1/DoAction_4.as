I.u[1790] = {n:"Goujon Kiye",t:41,d:"Ce goujon rare vient tout droit de l\'île de Kiye, située au large de l\'île de Moon. Habitué au courant très chaud, il effectue cependant une migration une fois par an.",ep:1,g:302,l:1,wd:true,fm:true,w:3,p:1};
