I.u[1602] = {n:"Abranneau Sombre",t:9,d:"Cet anneau, permet à l\'Abraknyde Sombre, de sortir en soirée tout en étant vraiment très chic. Et comme la vie est bien faite, c\'est toujours la soirée dans la Forêt Sombre.",ep:9,g:17,l:48,wd:true,fm:true,w:1,p:6200};
