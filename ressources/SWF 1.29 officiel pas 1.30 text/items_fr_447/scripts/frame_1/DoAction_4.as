I.u[1784] = {n:"Raie Bleue",t:41,d:"La Raie Bleue domine les sols marins où elle passe son temps à creuser de minuscules trous. Nul ne sait encore pourquoi. Elle remonte à la surface une fois de temps en temps. Juste assez souvent pour la prendre dans vos filets.",ep:2,g:296,l:50,wd:true,fm:true,w:3,p:1};
