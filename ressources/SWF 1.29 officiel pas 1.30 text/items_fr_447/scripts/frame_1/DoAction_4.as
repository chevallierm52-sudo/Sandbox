I.u[1792] = {n:"Bar Iton",t:41,d:"Cousin du Bar Rikain, le Bar Iton a tendance à disparaître de nos jours. Il fut en grande partie décimé à cause d\'une rumeur stupide stipulant qu\'en manger donnait une belle voix.",ep:1,g:303,l:70,wd:true,fm:true,w:3,p:30};
