I.u[1782] = {n:"Goujon",t:41,d:"Petit poisson rapide d\'eau douce, le goujon est le plus souvent pêché par les enfants et par les pêcheurs débutants. Mais il ne nourrira pas votre famille.",ep:1,g:294,l:1,wd:true,fm:true,w:3,p:1};
