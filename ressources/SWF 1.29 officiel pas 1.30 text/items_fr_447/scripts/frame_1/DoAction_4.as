I.u[1786] = {n:"Greu-vette Horreur",t:41,d:"Mutation de la greu-vette, cette espèce très rare a la particularité d\'émettre d\'horribles sons lorsqu\'elle ondule son corps.",ep:1,g:298,l:1,wd:true,fm:true,w:3,p:100};
