I.u[1779] = {n:"Bar Rikain",t:41,d:"On rencontre ce poisson le plus souvent dans les lacs et cours d\'eau qui descendent des glaciers. Sa grosseur et sa chaire fraîche en font un animal très apprécié des pêcheurs.",ep:2,g:290,l:40,wd:true,fm:true,w:3,p:1};
