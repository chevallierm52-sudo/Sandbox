I.u[10036] = {n:"Fée lanceuse de Griffe Joueuse",t:74,d:"Alors qu\'elle vivait dans la Tour Enfer Mâle, Mylaise avait commandé à un fameux artisan un grand nombre de fées d\'artifices pour animer ses soirées. Aujourd\'hui encore, elle en distribue parfois quand elle est de bon poil.",ep:0,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10042] = {n:"Fée lanceuse de Langue Rapeuse",t:74,d:"Alors qu\'elle vivait dans la Tour Enfer Mâle, Mylaise avait commandé à un fameux artisan un grand nombre de fées d\'artifices pour animer ses soirées. Aujourd\'hui encore, elle en distribue parfois quand elle est de bon poil.",ep:0,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10043] = {n:"Le désir d\'être belle",t:30,d:"Une lotion de beauté très puissante vous a donné cette apparence... Vous voilà prête à faire fondre tous les matous ! Meow !",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10044] = {n:"Lotion de beauté de Mylaise",t:12,d:"Mylaise s\'applique chaque jour cette lotion sur le corps pour rester jeune et belle... Essayez, vous verrez ! Cependant, le moindre effort en combat vous rendra votre allure décharnée et vos traits tirés... Ce n\'est pas la lotion qui fait la Prêtresse de l\'Amour.",ep:0,g:40,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10052] = {n:"Potion d\'oubli : \'Laisse spirituelle\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort spécial \'Laisse spirituelle\'",ep:0,g:31,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[10054] = {n:"Anneau du Vampyre",t:9,d:"Cet anneau a trempé pendant trois ans dans de la fiente de chauve-souris. Mais il est magique.",ep:0,g:171,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4703};
I.u[10055] = {n:"Amulette du Vampyre",t:1,d:"Cette amulette est censée prévenir les Vampyres qui voudraient vous mordre dans le cou, qu\'il est tout simplement inutile d\'essayer de vous sucer le sang, puisque vous êtes vous-même un Vampyre.",ep:0,g:146,l:45,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:5500};
I.u[10056] = {n:"Ceinture du Vampyre",t:10,d:"Sur le slogan publicitaire de cette ceinture vous pouvez lire \"Et en plus elle brille la nuit !\". Oui mais en plus de quoi ?",ep:0,g:156,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4805};
I.u[10057] = {n:"Rune de chasse",t:78,d:"Souvenez-vous de ce que disait le très connu Lézain : \"Bon, le mauvais chasseur, il a un arc... Il voit un truc qui bouge y tire ! Et le bon chasseur, il a un arc aussi, y voit un truc, y tire mais bon... C\'est un bon chasseur...\". Vous pourrez vérifier cela avec n\'importe laquelle de vos armes grâce à cette rune.",ep:0,g:60,l:10,wd:false,fm:true,w:1,p:10};
I.u[10058] = {n:"Cape du Vampyre",t:17,d:"Bram avait raison, il faut toujours se méfier des personnes aux dents longues, surtout lorsqu\'elles portent la cape du Vampyre.",ep:0,g:168,l:41,wd:true,fm:true,w:5,c:"PO!10119",s:130,p:4550};
I.u[10061] = {n:"Bottes du Vampyre",t:11,d:"On raconte qu\'Elizabeth Bythora en personne a porté ces bottes. Ça vous fait une belle jambe.",ep:0,g:139,l:41,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4550};
I.u[10063] = {n:"Le désir d\'être belle",t:31,d:"Une lotion de beauté très puissante vous a donné cette apparence... Vous voilà prête à faire fondre tous les matous ! Meow !",ep:0,g:13,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10073] = {n:"Bouclier hispanique",t:82,d:"Le mythique Dal-Uk-Wet, unificateur des royaumes de HispaÑia, avait un bouclier magique. Son arrière petit-fils, Sir-Dal, en fit forger quelques reproductions pour récompenser les meilleurs guerriers de HispaÑia. Ce bouclier est l\'une de ces rares copies.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[10074] = {n:"Lettre du chef des voleurs",t:24,d:"Retrouvée lors du combat contre les voleurs chez Milone : \nMilone Corichel le bijoutier vient de créer un joyau de grande valeur. Dérobez-le par tous les moyens possibles. \nHeureusement, Milone leur a remis un faux, et ce n\'est pas grâce à vous. \nPar contre, au dos du message se trouve l\'emplacement de leur repaire. Une revanche s\'impose, mais mieux vaut y aller accompagné.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10075] = {n:"Bouillie infâme",t:24,d:"Cette bouillie infâme est apparue comme par enchantement dans votre poche.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[10076] = {n:"Bouclier hispanique unique",t:82,d:"Le mythique Dal-Uk-Wet, unificateur du royaume de HispaÑia, concentrait tout son pouvoir dans son bouclier, au grand dam de ses adversaires. Des années plus tard, Sir-Dal, son arrière petit-fils, en fit forger quelques reproductions pour récompenser les meilleurs guerriers de HispaÑia, mais celui-ci est l\'original, l\'unique, le plus puissant de tous !",ep:0,g:40,l:1,wd:false,fm:true,w:30,c:"PP>9",p:63200};
I.u[10077] = {n:"Terra Cogita",t:32,d:"Vous devez escorter Terra Cogita à plusieurs endroits avant de le présenter à Jerhyn Gholein.",ep:0,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10078] = {n:"Eni Hoube",t:32,d:"Vous devez escorter et protéger l\'eni Hoube. Depuis qu\'il vous accompagne, on dirait que le destin s\'acharne contre vous.",ep:0,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10079] = {n:"Pain Trépide",t:33,d:"Très prisé par les Iops, ce pain rend courageux et téméraire à la fois, ce qui a déjà provoqué la mort prématurée de nombreux aventuriers. Xavier le Boulanger cessa d\'en préparer lorsqu\'une compagnie entière de troubadours chargea une meute de mulous enragés.",ep:0,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[10080] = {n:"Message des renégats",t:24,d:"Ce message donne rendez-vous aux renégats à proximité du Donjon des Scarafeuilles. Vous devriez vous y rendre pour en savoir plus.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10081] = {n:"Message du chef des renégats",t:24,d:"Dans ce message, le chef des renégats leur demande de le rejoindre au sud du territoire des bandits. C\'est pour vous l\'occasion d\'éliminer ce traître.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10082] = {n:"Cocktail Moritov",t:24,d:"Qu\'obtient-on en pressant un pétale morito ? De la sève alcoolisée à base de nombreux cocktails, dont les disciples d\'Otomaï se délectent lors des fêtes estivales. En effet, ce cocktail détonant saura mettre le feu à vos soirées, au propre comme au figuré.",ep:0,g:762,l:1,wd:false,fm:true,w:0,p:1};
I.u[10083] = {n:"Salace de poissons",t:49,d:"Comme le dit le dicton : une odeur peut en cacher une autre. En effet, le parfum dégagé par cette salace de poissons cache une forte odeur de pieds. A ne pas consommer en présence de Porkass en rut, sauf si vous êtes une cochonne.",ep:0,g:80,l:1,wd:false,fm:true,w:3,u:true,ut:true,p:1};
I.u[10084] = {n:"Sifflet d\'appel",t:24,d:"Ce sifflet, conçu d\'après la méthode d\'élevage canin de Riyou Tchevlakouk, permet d\'appeler les crocs glands domptés. En revanche, il ne permet pas de se faire passer pour le maître d\'un croc gland qui ne vous appartient pas. Il marche aussi très bien avec les crocs glands sauvages.",ep:0,g:755,l:1,wd:false,fm:true,w:0,p:1};
I.u[10085] = {n:"Ordre d\'exécution.",t:87,d:"Les ordres sont clairs et nets, pas comme les caleçons du Minotot. Trouvez et abattez la cible désignée.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:0};
I.u[10086] = {n:"Canine de bandit des plaines",t:24,d:"La violence du combat contre les bandits des plaines était telle que l\'un d\'entre eux a perdu une canine.",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:1};
I.u[10087] = {n:"Rendez-vous de Xarthan",t:24,d:"Ce papier rédigé par un Brâkmarien donne rendez-vous à Xarthan dans la Tour de Bonta après sa prochaine réunion. Cela signifie que le rendez-vous est peut-être déjà en cours.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10088] = {n:"Mouchoir usé",t:24,d:"Vous avez ramassé ce mouchoir lors de votre combat contre Xephirès. Ca vous fait un petit souvenir utile et agréable, surtout si vous avez le nez bouché ou êtes allergique aux poils de chacha.",ep:0,g:756,l:1,wd:false,fm:true,w:0,p:1};
I.u[10089] = {n:"Caisse de marchandises",t:24,d:"Xephirès vous a demandé de livrer cette caisse de marchandises au conseiller Boyowa, chez le Grandapan, en guise de bonne foi. Vous ignorez son contenu exact mais il s\'agit sûrement d\'objets de valeur.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10090] = {n:"Liste de fournitures de Nara",t:24,d:"Nara vous a fait une liste de ce dont il a besoin pour son nouvel atelier de forgeron : 20 Bois de Chêne, 1 Blague de Soufre, 30 Fers, 1 Kouartz, 5 Bakélélites et 10 Cuirs de Sanglier des Plaines.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10091] = {n:"Notes sur La malédiction d\'Erazal",t:24,d:"La malédiction d\'Erazal indique comment ressusciter une âme contre sa volonté. Il vous faut 1 Sang de Phénix, 5 Poudres de Perlinpainpain et 1 Amulette de Lear, obtenue sur les cadavres des abraknes et des abraknes sombres.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10092] = {n:"Ordre d\'annulation.",t:24,d:"Cette lettre, datée d\'il y a quelques heures seulement, indique que l\'assaut sur Bonta a été annulé en raison de l\'amélioration en équipement que leurs miliciens ont reçu, et de la capture du traître Xephirès.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10102] = {n:"Masque du Vampyre",t:16,d:"Ce masque vous protégera des rayons du soleil à défaut d\'autre chose.",ep:0,g:244,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4725};
I.u[10103] = {n:"Lettre pour Fidji Merline",t:24,d:"Ebru Of El vous a confié cette lettre à remettre à Fidji Merline. Apparemment, il faudra suivre les instructions de la bricoleuse de Brâkmar.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[10104] = {n:"Mangeoire trafiquée",t:24,d:"Cette mangeoire a été trafiquée pour cacher des aubergines et mieux vaut ne pas traverser Brâkmar sur une monture s\'étant rassasiée dans cette mangeoire. En effet, les flatulences engendrées par la consommation excessive d\'aubergines pourraient provoquer un incident détonant.",ep:0,g:759,l:1,wd:false,fm:true,w:0,p:1};
I.u[10105] = {n:"Patte couverte de poils",t:24,d:"Cette patte d\'arakne couverte de poils d\'arakne et de chacha est une arme redoutable si l\'on doit faire face à Ledrob Terceséc.",ep:0,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[10106] = {n:"Vampyrette",t:18,d:"Cette terrible créature prendra un malin plaisir à sucer le sang de vos amis, ou celui de vos chevilles si elles sont un peu trop grosses. Mais cela ne suffira pas à la divertir pour autant, elle aime par dessus tout que vous affrontiez avec elle des squelettes pour se repaître de leurs dépouilles. On vous avait bien dit qu\'elle était terrible.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10107] = {n:"Chauffe-souris",t:18,d:"Ce familier a eu une enfance très difficile, il a hérité d\'un nom franchement stupide. C\'est peut-être ce qui explique pourquoi il est devenu un peu fou et n\'a plus qu\'une seule obsession dans la vie, tuer toutes les Ouassingues qu\'il rencontre pour se nourrir de leurs dépouilles.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10108] = {n:"Fantôme de Vampyrette",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10109] = {n:"Fantôme de Chauffe-souris",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10118] = {n:"Croc Gland fraichement dompté",t:32,d:"Ce Croc Gland a été dressé selon la méthode d\'élevage canin mise au point par le célèbre dresseur de chachas Riyou Tchevlakouk.",ep:0,g:23,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10119] = {n:"Goulyfié",t:30,d:"Vous vous sentez différent...",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,c:"POX10055&POX10054&POX10056&POX10061&POX10058&POX10102",p:0};
I.u[10121] = {n:"Petit caillou",t:51,d:"Ce petit caillou sert à activer la magie des dalles pour atteindre l\'esprit de l\'eau. Son utilisation est des plus simples : il suffit de le poser sur une dalle et la magie opère d\'elle-même. Simple et efficace. Même un Iop peut y arriver, s\'il ne trouve aucun ennemi sur qui jeter le petit caillou avant.",ep:0,g:267,l:1,wd:false,fm:true,w:1,p:1};
I.u[10122] = {n:"Liste de Norb",t:24,d:"Norb vous a fait une liste des ressources à apporter à Nara. Il faut 2 Bakélélites, 10 Manganèses, 20 Bauxites, 15 Dolomites et 20 Bois d\'Oliviolet.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10125] = {n:"Arc du bandit archer",t:2,d:"Cet arc appartenait à un ancien bandit archer qui s\'en servait pour achever ses victimes à distance, afin de ne pas se salir. Il est imprégné d\'une magie si puissante que vous risquez de vous transformer en bandit archer si vous l\'équipez...",ep:0,g:67,l:30,wd:true,fm:false,w:10,an:10,tw:true,e:[2,6,3,5,40,40,false,true],p:3000};
I.u[10126] = {n:"Epée du bandit fine-lame",t:6,d:"Cette épée appartenait à un ancien bandit fine-lame, qui ne supportait pas de devoir poursuivre ses adversaires. Il commençait par leur couper les deux jambes et posait ses questions ensuite. Elle est imprégnée d\'une magie si puissante que vous risquez de vous transformer en bandit fine-lame si vous l\'équipez...",ep:0,g:92,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,40,40,false,false],p:3000};
I.u[10127] = {n:"Bâton du bandit baroudeur",t:4,d:"Ce bâton appartenait à un ancien bandit baroudeur, constamment ivre, il était incapable de faire les poches de ses victimes sans s\'écrouler. Ce bâton lui permettait de tenir debout le temps qu\'il termine son office. Il est imprégné d\'une magie si puissante que vous risquez de vous transformer en bandit baroudeur si vous l\'équipez.",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:12,e:[5,6,1,1,40,40,false,false],p:3000};
I.u[10131] = {n:"Cadeau Vampyrette",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature prête à vous sauter au cou. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10132] = {n:"Cadeau Chauffe-souris",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révèleront la présence d\'une créature prête à vous sauter au cou. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10133] = {n:"Baguette du bandit ensorceleur",t:3,d:"Cette baguette appartenait à un ancien bandit ensorceleur, qui s\'en servait pour réduire en cendres les ennemis qu\'il voulait fumer. Elle est imprégnée d\'une magie si puissante que vous risquez de vous transformer en bandit ensorceleur si vous l\'équipez...",ep:0,g:72,l:30,wd:true,fm:false,w:10,an:11,tw:true,e:[2,5,2,4,40,40,false,true],p:3000};
I.u[10134] = {n:"Certificat de mise en chanil : Vampyrette",t:77,d:"Ce certificat décrit les caractéristiques du familier que vous avez placé au Chanil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10135] = {n:"Certificat de mise en chanil : Chauffe-souris",t:77,d:"Ce certificat décrit les caractéristiques du familier que vous avez placé au Chanil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10140] = {n:"Cadeau Anneau du Vampyre",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
