I.u[10168] = {n:"Chispottes",t:11,d:"Ponch cirait ses bottes tous les matins avant de partir en mission sur sa Dragodinde pour sauver la veuve et l\'orphelin, mais surtout la veuve... Un sacré charmeur ce Ponch.",ep:0,g:141,l:42,wd:true,fm:true,w:10,s:138,p:4850};
I.u[10169] = {n:"Chispouclier",t:82,d:"Ponch portait fièrement ce bouclier sur sa dragodinde lorsqu\'il veillait à la sécurité des ruelles de Bonta.",ep:0,g:41,l:1,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10170] = {n:"Chispocasque",t:16,d:"Ce casque permet de se protéger très efficacement des chutes de dragodindes ou de passer pour un idiot sans en être un.",ep:0,g:246,l:40,wd:true,fm:true,w:10,s:138,p:4400};
I.u[10171] = {n:"Mitaines de Chisp",t:9,d:"Ces mitaines en cuir sont parfaites pour donner des fessées déculottées.",ep:0,g:173,l:44,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10172] = {n:"Collertue",t:1,d:"Cette amulette peut nourrir une limace vorpale pendant deux jours, ou trois jours si elle l\'accompagne d\'une purée de votre tête.",ep:0,g:148,l:42,wd:true,fm:true,w:10,s:137,p:4900};
I.u[10173] = {n:"Libottes",t:11,d:"La semelle de ces bottes est recouverte d\'une bave collante et l\'intérieur est rempli d\'une bave glissante. A moins que ça ne soit l\'inverse.",ep:0,g:142,l:39,wd:true,fm:true,w:10,s:137,p:4105};
I.u[10174] = {n:"Limape",t:17,d:"Une bave gluante sort des pores de cette cape. Prenez un peu d\'élan, allongez-vous sur le dos et laissez-vous glisser.",ep:0,g:169,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10175] = {n:"Limasque",t:16,d:"Ce masque gluant et baveux alimentera votre cuir chevelu en gomina de façon continue. Les deux yeux accrochés au masque peuvent être connectés à votre crâne si vous acceptez d\'insérer les terminaisons nerveuses dans vos oreilles.",ep:0,g:247,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10180] = {n:"L\'Esteban",t:1,d:"Ce médaillon est censé servir de clé pour accéder à une mystérieuse cité oubliée.",ep:0,g:149,l:42,wd:true,fm:true,w:10,s:136,p:4800};
I.u[10181] = {n:"Anneau solaire",t:9,d:"Cet anneau a été retrouvé dans une mystérieuse cité dont personne ne soupçonnait réellement l\'existence jusqu\'à ce que l\'on commence à soupçonner son existence.",ep:0,g:174,l:41,wd:true,fm:true,w:10,s:136,p:4600};
I.u[10182] = {n:"Bouclier solaire",t:82,d:"Ce bouclier absorbe les rayons du soleil et les renvoie directement dans le visage de vos adversaires. A défaut de les éblouir avec votre intelligence, vous les aveuglerez temporairement grâce à ce bouclier.",ep:0,g:42,l:1,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10183] = {n:"Masque solaire",t:16,d:"Ce masque captera les rayons de soleil et les concentrera sur votre visage pour que vous puissiez rester bronzé toute l\'année, même si vous habitez au nord d\'Amakna.",ep:0,g:248,l:42,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10184] = {n:"Masque de Noké",t:16,d:"Noké aimait beaucoup revêtir ce masque et se cacher dans les bois pour effrayer les promeneurs égarés. Il est mort de peur il y a bien longtemps en se regardant dans une flaque d\'eau.",ep:0,g:249,l:42,wd:true,fm:true,w:10,s:135,p:4700};
I.u[10185] = {n:"Cape de Noké",t:17,d:"Noké rêvait d\'être un grand méchant loup. Même avec cette cape sur les épaules, il ne ressemblait qu\'à un petit méchant.",ep:0,g:170,l:41,wd:true,fm:true,w:10,s:135,p:4600};
I.u[10186] = {n:"Collier de Noké",t:1,d:"Cette amulette en dents de sanglier effraiera les sangliers et par extension votre belle-mère.",ep:0,g:150,l:41,wd:true,fm:true,w:10,s:135,p:4525};
I.u[10187] = {n:"Dagues de Noké",t:5,d:"Ces dagues ont servi jadis à dépecer un sanglier belliqueux qui rêvait d\'être un cerf.",ep:0,g:76,l:41,wd:true,fm:true,w:10,an:13,tw:true,e:[12,3,1,1,30,45,false,false],c:"CS>50&CW>50&CV>80",s:135,p:4000};
I.u[10188] = {n:"Coiffe de la Denrée",t:16,d:"Cette coiffe fera de vous un excellent Wobot de protocole grâce à son dispositif unique qui permet de traduire à la volée les discussions des choux. C\'est également un excellent casque insonorisant.",ep:0,g:250,l:43,wd:true,fm:true,w:10,s:133,p:5075};
I.u[10189] = {n:"Oxano",t:9,d:"Cet anneau appartenait à un sabotier connu sous le surnom de \"Le Glaude\", dont il avait hérité après avoir fait un long voyage en trottant. Ses proches l\'avaient surnommé \"Le Glaude trotteur\".",ep:0,g:175,l:37,wd:true,fm:true,w:10,s:133,p:3875};
I.u[10190] = {n:"Bottines de la Denrée",t:11,d:"Si vous décidez de planter des choux, à la mode de chez nous, pensez à équiper ces bottines conçues pour ne pas écraser les choux. N\'essayez pas de les utiliser pour danser avec votre partenaire, elles ne permettent pas d\'éviter les écrasements de pieds.",ep:0,g:143,l:38,wd:true,fm:true,w:10,s:133,p:3925};
I.u[10191] = {n:"L\'oxolature",t:10,d:"Cette ceinture permet de contenir vos ballonnements après une indigestion de soupe aux choux.",ep:0,g:158,l:37,wd:true,fm:true,w:10,s:133,p:373};
I.u[10192] = {n:"Cadeau Cape Siks Won Naïne",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10193] = {n:"Cadeau Masque Siks Won Naïne",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10194] = {n:"Cadeau Ceinture Siks Won Naïne",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10195] = {n:"Cadeau Bottes Siks Won Naïne",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10207] = {n:"Trousseau de clefs",t:24,d:"On le dit doté de longs pênes très agiles. Cependant, ils s\'épuisent vite et leurs magies ne se rechargent qu\'au bout d\'une semaine. Qu\'elles soient à gorges ou à pompes, vous pourrez forcer toutes les serrures des donjons.",ep:0,g:774,l:1,wd:false,fm:true,w:0,p:0};
I.u[10208] = {n:"Elixir Pandawa",t:12,d:"Une bonne lampée et vous êtes téléporté au temple de votre classe. Effets secondaires connus : coliques, apparition de belle-mère, chute de cheveux, haleine de chacal, lacets défaits, feux rouges successifs.",ep:0,g:153,l:1,wd:true,fm:true,w:1,c:"PG=12",u:true,p:0};
