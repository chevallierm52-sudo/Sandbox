I.u[10657] = {n:"Chercheur d\'Ogrines",t:18,d:"Cet étrange familier est issu du croisement des meilleurs chercheurs de truffes de tout Amakna. Son énorme groin lui permet de repérer l\'Ogrine, même lorsqu\'elle est cachée sous l\'eau. Otomaï aurait mis plusieurs années à obtenir cette espèce et l\'on raconte qu\'il l\'utiliserait pour réparer une de ses erreurs, retrouver ce qu\'il aurait égaré ou laissé s\'enfuir. Personne ne sait... La recherche d\'Ogrine implique un processus physiologique si complexe et coûteux en énergie, que cette créature est obligée de consommer les âmes des monstres pour grandir. Elle a été élevée sur les plages de l\'île d\'Otomaï et ne dévore que les âmes des créatures qui y vivent.",ep:0,g:56,l:1,wd:true,fm:true,w:10,p:1};
I.u[10658] = {n:"Fantôme de Chercheur d\'Ogrines",t:90,d:"Ce Fantôme n\'a pas encore quitté le monde des vivants, il ne tient qu\'à vous de trouver une façon de le ressusciter, ou de l\'abandonner lâchement une bonne fois pour toutes.",ep:0,g:56,l:1,wd:true,fm:true,w:1,p:1};
I.u[10659] = {n:"Oeuf du Chercheur d\'Ogrines",t:72,d:"Cet œuf étrange contient une petite créature magique. Gardez-le au chaud, il finira sûrement par éclore.",ep:0,g:206,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10660] = {n:"Cadeau Oeuf de Chercheur d\'Ogrines",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10661] = {n:"Certificat de mise en chanil : Chercheur d\'Ogrines",t:77,d:"Ce certificat décrit les caractéristiques du familier que vous avez placé au Chanil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10662] = {n:"Rune Pa Prospe",t:78,d:"Cette rune permet d\'avoir plus de chance de trouver des objets rares.",ep:0,g:36,l:20,wd:true,fm:true,w:1,p:10};
I.u[10663] = {n:"Brioche à la viande de bouftou",t:33,d:"Il faut avoir l\'estomac bien accroché pour avaler cette brioche. La viande de bouftou utilisée, pas toujours de première fraîcheur, donne une saveur proche des huîtres au chocolat. Un délice pour Bwork.",ep:0,g:71,l:20,wd:true,fm:true,w:1,c:"Sc=1",u:true,ut:true,p:1};
I.u[10664] = {n:"Abragland",t:94,d:"Très délicat comme tous les glands, il suffit de le frotter légèrement pour qu\'il expulse l\'abraknyde emprisonné en son sein.",ep:0,g:15,l:1,wd:true,fm:true,w:0,c:"Sc=2&(PB=4|PB=22|PB=33|PB=169|PB=170|PB=486|PB=168)",u:true,p:0};
I.u[10665] = {n:"Coffre de Jorbak",t:94,d:"Jorbak ayant perdu toute sa fortune, que peut bien contenir ce coffre étrange ? Ouvrez-le pour le découvrir.",ep:0,g:16,l:1,wd:true,fm:true,w:1,u:true,p:0};
I.u[10667] = {n:"Empreinte de Jorbak",t:24,d:"Vous avez réussi à noter quand sera visible l\'esprit de Jorbak. Inutile de se précipiter.",ep:0,g:251,l:1,wd:true,fm:true,w:0,p:0};
I.u[10668] = {n:"Bonne fortune de Jorbak",t:28,d:"Pendant quelques temps, vous bénéficierez de la chance de Jorbak.",ep:0,g:16,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10669] = {n:"Potion de crapaud-mufle",t:12,d:"Ça vous apprendra à boire n\'importe quoi !",ep:0,g:18,l:1,wd:true,fm:true,w:1,c:"Sc=4",u:true,p:0};
I.u[10670] = {n:"Parchemin de Percimol",t:94,d:"Simples à suivre comme une recette de cuisine Wabbit, les indications de ce parchemin révèlent un secret envoutant.",ep:0,g:17,l:1,wd:true,fm:true,w:1,c:"Sc=5",u:true,p:0};
I.u[10673] = {n:"Potion de HmmMmmMmmm",t:12,d:"HmmMmmMmmm.",ep:0,g:191,l:1,wd:true,fm:false,w:1,c:"Sc=7",u:true,ut:true,p:1};
I.u[10674] = {n:"Mmmmm",t:28,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:0,g:18,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10675] = {n:"Cadeau Dofusien",t:89,d:"Pas moyen de vous révéler le contenu de ce cadeau, mais sachez qu\'il vous permettra à la fois de vous éclater et de faire la foire. Lorsque c\'est jour de fête, il faut bien ça.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10676] = {n:"Double effet Kill Coos",t:28,d:"Votre prospection et votre sagesse sont augmentées pendant plusieurs combats.",ep:0,g:19,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10677] = {n:"Shigekax Kill Coos",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan, avec ce bonbon préparé de façon traditionnelle \n(Ce bonbon augmente la prospection et la sagesse de 100 points pendant 20 combats).",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"PO!10676",u:true,p:1};
I.u[10678] = {n:"Voyager sans jamais perdre le Nord",t:25,d:"Arpagnagrobis a écrit cet ouvrage pour tous les aventuriers ne sachant point se servir de leur boussole et des zaaps.",ep:0,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10680] = {n:"Souvenir sanglant du Goultarminator",t:24,d:"Vous avez arraché ce coeur à l\'Essence Maléfique de Goultard. Vous pourrez le poser sur votre bureau en guise de souvenir.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10681] = {n:"Transformation en Crapaud-mufle",t:31,d:"Bien fait !",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[10682] = {n:"Le secret de Percimol",t:29,d:"Chance et bonheur vont de paire.",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10685] = {n:"Casque du Roks Or",t:16,d:"Équipée de ce casque en or, votre tête sera rapidement mise à prix et vaudra son pesant d\'or.",ep:0,g:254,l:52,wd:false,fm:true,w:10,s:151,p:7325};
I.u[10686] = {n:"Cape du Roks Or",t:17,d:"Cette cape en tissu, recouverte d\'une fine couche d\'or est magique. Elle attire les regards et renvoie la lumière directement dans les pupilles des fourbes qui tenteraient de vous poignarder par derrière. Indispensable si vous avez des amis Srams.",ep:0,g:171,l:54,wd:false,fm:true,w:10,s:151,p:7750};
I.u[10687] = {n:"Anneau du Roks Or",t:9,d:"Cet anneau est si lourd qu\'il augmente considérablement l\'inertie de votre poing quand vous distribuez des claques à vos adversaires. Lorsque vous aurez commencé à punir les manants, il vous sera quasiment impossible de vous arrêter.",ep:0,g:182,l:51,wd:false,fm:true,w:10,s:151,p:6862};
I.u[10688] = {n:"Ceinture du Roks Or",t:10,d:"Cette ceinture est parfaite pour accrocher vos lingots d\'or autour de votre taille, ils passeront inaperçus.",ep:0,g:166,l:53,wd:false,fm:true,w:10,s:151,p:7525};
