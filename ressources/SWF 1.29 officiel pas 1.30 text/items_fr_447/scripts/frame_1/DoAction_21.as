I.u[10155] = {n:"Yugolette",t:1,d:"Cette amulette est censée vous protéger des décapitations aléatoires, et des oblitérations épilatoires.",ep:0,g:147,l:43,wd:true,fm:true,w:10,s:134,p:5030};
I.u[10156] = {n:"Yugoufle",t:11,d:"Ces pantoufles sont plus confortables que des pantoufles ordinaires, mais vous ne saurez jamais exactement pourquoi. Peut-être que les milliers d\'acariens masseurs qui y vivent y sont pour quelque chose.",ep:0,g:140,l:41,wd:true,fm:true,w:10,s:134,p:4575};
I.u[10157] = {n:"Yugure",t:10,d:"Cette ceinture a été fabriquée à partir de chutes de ficelles de lin. Elle doit pouvoir servir à fermer les sacs poubelles.",ep:0,g:157,l:43,wd:true,fm:true,w:10,s:134,p:5025};
I.u[10158] = {n:"Bouclier trophée du Dark Vlad",t:82,d:"Brandissez-le haut et fort, car même après votre mort, c\'est le seul souvenir qui témoignera de tous vos efforts.",ep:0,g:43,l:1,wd:true,fm:true,w:1,p:1};
