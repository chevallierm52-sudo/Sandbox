I.u[10287] = {n:"Formule magique des quatre frères bandits",t:24,d:"Cette formule magique a été mise au point par les quatre frères bandits, Boueglione, Leauyal, Pindair et Flamar. Elle permet de détrousser un ennemi ou un jeune fan admiratif comme pas deux ! \nUne fois la formule prononcée, ses effets s\'étendront à tout le Monde des Douze... avant de se dissiper.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:0};
