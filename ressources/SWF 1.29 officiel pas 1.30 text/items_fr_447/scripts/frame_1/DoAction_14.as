I.u[6706] = {n:"Bandelette de la Momie Nova",t:15,d:"Ces bandelettes sont aussi vieilles que son propriétaire, lui-même aussi vieux que ses bandelettes. Au fil du temps, elles se sont imprégnées des pouvoirs magiques de la Momie Nova, mais également de son odeur de chaire en décomposition.",ep:1,g:712,l:150,wd:true,fm:true,w:1,p:1000};
I.u[6707] = {n:"Cape de la Momie Nova",t:17,d:"Cette cape malodorante est faîte à partir des bandelettes malodorantes de la Momie Nova. De quoi exciter tous les habitants des cimetières alentours.",ep:14,g:63,l:75,wd:false,fm:true,w:10,p:14600};
I.u[6708] = {n:"Certificat Dopeul",t:24,d:"Ce certificat indique la date de votre dernière victoire sur un dopeul.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6712] = {n:"Cape Hucine",t:17,d:"Cette magnifique cape sent la fleur des bois. Pas de quoi rendre folle de vous une Craêtte, mais suffisant pour couvrir les odeurs d\'un Sadida qui se néglige.",ep:1,g:82,l:71,wd:true,fm:true,w:10,p:13100};
I.u[6713] = {n:"Lorsotheuses",t:5,d:"Imprégnées du sang du terrible Lordsoth, ces dagues lui ont permis de terrasser le roi des Chafers lors du célèbre concours de lancer de dagues de la foire du Trool. Le roi des Chafers n\'a plus jamais osé depuis ce jour, montrer le bout de son slip en cuir, et s\'est exilé avec l\'illustre Captain Chafer dans les environs du cimetière de Pandala.",ep:1,g:34,l:100,wd:false,fm:true,w:10,an:13,e:[10,3,1,1,30,30,false,false],c:"PN~Lordsoth",p:1};
I.u[6716] = {n:"Nomoon",t:18,d:"Ce petit singe chapardeur semble s\'être attaché à vous maintenant. Très docile, il est cependant très exigeant sur le plan alimentaire et n\'accepte que les végétaux qui poussent sur son île.",ep:3,g:11,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6717] = {n:"Chienchien Noir",t:18,d:"Avec ce petit toutou, vous goûterez aux joies des petites promenades pipi. Fort de ses racines sauvages, il est déconseillé de lui donner à manger, sous peine de perdre une main.  \n(CE FAMILIER LEGENDAIRE N\'A PAS BESOIN DE MANGER)",ep:1,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6718] = {n:"Chacha Blanc",t:18,d:"Cette petite boule de poil friponne et câline fait craquer la gent féminine toutes classes confondues. Un animal redoutable donc. \n(CE FAMILIER LÉGENDAIRE N\'A PAS BESOIN DE MANGER)",ep:1,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6719] = {n:"Coiffe de l\'Homme Ours",t:16,d:"Cette étrange coiffe a appartenu au tristement célèbre Homme Ours. Cousue à partir des restes de la tête d\'un ours en décomposition, cette coiffe vous permettra de ne pas passer inaperçu, et surtout, de laisser grâce à son odeur originale, une trace de votre passage.",ep:1,g:64,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6720] = {n:"Cape de l\'Homme Ours",t:17,d:"Cette jolie cape a été portée pendant des années par le célèbre Homme Ours. Elle ne fera pas de vous un ours, mais vous pourrez rivaliser avec les plus grands.",ep:8,g:58,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6721] = {n:"Bottes de l\'Homme Ours",t:11,d:"Ces bottes sont rembourrées avec de la fourrure d\'ours. De quoi garder les pieds au chaud même pour ceux qui ont le sang froid.",ep:2,g:51,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6722] = {n:"Alliance de l\'Homme Ours",t:9,d:"L\'Homme Ours n\'a jamais quitté cette alliance, bien que sa femme fût dévorée sous ses yeux, par un des ours qu\'il venait d\'invoquer, et cela pour impressionner sa dulcinée. Elle a effectivement été très impressionnée.",ep:1,g:66,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6723] = {n:"Amulette de l\'Homme Ours",t:1,d:"L\'Homme Ours portait cette amulette autour du cou, lorsqu\'il a affronté les brigandins de la tanière de Bimdhoul. La légende raconte qu\'elle lui a sauvé la vie, mais quand on la regarde de près, on s\'aperçoit qu\'il s\'agit bien d\'une légende.",ep:1,g:74,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6724] = {n:"Ceinture de l\'Homme Ours",t:10,d:"Cette petite ceinture recouverte de poils d\'ours, est idéale pour cacher vos poignées d\'amour. Il est donc conseillé de ne jamais l\'enlever, pour ne pas décevoir l\'élu de votre coeur.",ep:1,g:66,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6725] = {n:"Bâton de l\'Homme Ours",t:4,d:"L\'Homme Ours utilisait ce bâton pour dresser ses invocations d\'ours, et parfois pour frapper les doigts de ses enfants, lorsque ces derniers ne faisaient pas leurs devoirs en revenant de l\'école. Voilà un homme qui avait tout compris à l\'éducation des enfants.",ep:14,g:46,l:20,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CA>50&CV>50",s:12,p:1300};
I.u[6731] = {n:"Amukwak de Glace",t:1,d:"Avec cette amulette autour du cou, vous pourriez tenter de faire croire à votre entourage que vous avez une haleine fraîche. Laissez tomber, c\'est peine perdue.",ep:1,g:71,l:42,wd:true,fm:true,w:3,s:13,p:4900};
I.u[6732] = {n:"Kwakanneau de Glace",t:9,d:"Ce petit anneau était jadis très convoité par les Enutrofettes qui préféraient s\'en servir pour décorer leurs orteils. Une excellente façon de cacher leurs verrues.",ep:1,g:63,l:42,wd:true,fm:true,w:2,s:13,p:4900};
I.u[6735] = {n:"Racine de Fourbasse",t:98,d:"Cette minuscule racine incarne parfaitement la fourberie. Personne ne sait pourquoi, mais tout le monde le sait.",ep:12,g:96,l:22,wd:true,fm:true,w:5,p:200};
I.u[6736] = {n:"Bourgeon de Fourbasse",t:108,d:"Ce petit bourgeon de Fourbasse contient une sève sirupeuse et collante. Si vous avez le malheur de marcher sur une vieille Fourbasse tapie dans les herbes hautes, vous risquez de restez accrochée à celle-ci jusqu\'à ce qu\'elle vous dévore entièrement vos bottes. En revanche, si vous arrivez à prélever un bourgeon de Fourbasse intact, vous pourrez faire taire le plus râleur des Fécas, en le lui offrant en guise de pâte à mâcher.",ep:12,g:97,l:22,wd:true,fm:true,w:5,p:1};
I.u[6737] = {n:"Ecorce de Fourbasse",t:96,d:"La Fourbasse n\'a pas réellement de vraies branches comme tout arbre qui se respecte, elle a cependant une fine écorce assez résistante et recouverte d\'une multitude d\'aspérités. Très pratique pour créer des manches d\'outils qui ne glissent pas entre les mains, ou pour donner des coups de bâtons qui arrachent la peau du derrière des enfants les plus effrontés. Dans les deux cas, la satisfaction est maximale. Pour celui qui tient le manche.",ep:12,g:98,l:22,wd:true,fm:true,w:5,p:200};
I.u[6738] = {n:"Crâne de Chef Crocodaille",t:47,d:"Cet énorme crâne témoigne de l\'hygiène dentaire déplorable du Chef Crocodaille. Chose amusante, il semble encore animé d\'une certaine magie, l\'âme du Chef Crocodaille l\'habitant encore. Il lui arrive même parfois de verser de grosses larmes de Crocodaille si vous êtes méchant avec lui.",ep:4,g:637,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6739] = {n:"Peau de Crocodaille",t:59,d:"Réussir à avoir un morceau complet de peau de Crocodaille est presque un miracle, bien souvent, les braconniers ne récupèrent que quelques écailles. Idéale pour faire un sac, cette vieille peau saura également contenter les tailleurs de sous-vêtements de combat.",ep:4,g:601,l:36,wd:true,fm:true,w:10,p:1000};
I.u[6740] = {n:"Peau de Chef Crocodaille",t:59,d:"Cette peau constituée d\'une multitude d\'écailles, est en tout point supérieure à une classique peau de Crocodaille. En effet, la face extérieure de la peau du Chef Crocodaille est plus résistante et recouverte d\'écailles acérées très coupantes, alors que la face intérieure est particulièrement douce. On raconte que certains vieux tailleurs confondent les deux faces lors de la confection de sous-vêtements. L\'histoire ne raconte pas si cela leur apporte plus ou moins de clientèle...",ep:4,g:600,l:69,wd:true,fm:true,w:10,p:1000};
I.u[6742] = {n:"Fourbamulette",t:1,d:"Cette amulette est constituée d\'un mélange de feuilles de Fourbasse et de détritus de l\'île de Moon. Elle ressemble plus à un collier de fleurs qu\'à une véritable amulette, mais elle vous permettra de séduire sans trop d\'efforts la faune locale de l\'île de Moon, composée presque exclusivement d\'abominables créatures. Ainsi, plus aucune Fourbasse ne saura vous résister, elles vous sauteront toutes au cou pour vous faire des suçons. Les plus malchanceux en amour sauront s\'en contenter.",ep:12,g:69,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6743] = {n:"Fourballiance",t:9,d:"Prenez des feuilles de Fourbasse, empilez-les, laissez-les macérer dans de l\'alcool éventé, perforez-les, buvez le reste d\'alcool, collez les feuilles autour d\'un morceau d\'écorce, fixez des morceaux de feuille de Kokoko avec une matière gluante, et voilà, vous avez une magnifique Fourballiance. Elle sent très mauvais, et vous sera particulièrement utile pour justifier et cacher l\'odeur de vos doigts surtout si vous avez tendance à les mettre n\'importe où. Surtout là où il ne faut pas.",ep:12,g:60,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6744] = {n:"Fourbabottes",t:11,d:"Une fois que vous aurez essayé ces bottes, vous ne serez plus capable de vous en défaire. Non pas parce qu\'elles sont exceptionnelles, mais car elles sont incroyablement collantes. Une caractéristique trop souvent partagée avec les femelles Fourbasses.",ep:12,g:47,l:34,wd:true,fm:true,w:5,s:16,p:3200};
I.u[6745] = {n:"Ceinture Fourbissante",t:10,d:"Remarquable création artisanale à base de restes de Fourbasses et de détritus ramassés le long des plages de Moon, au milieu de l\'écume nauséabonde, cette ceinture si elle est portée toute seule, vous donnera une allure vraiment surprenante. De quoi décontenancer vos adversaires ou surprendre l\'être aimé, pour mieux tirer partie de cet instant où pour une fois c\'est vous qui aurez le dessus.",ep:12,g:62,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6746] = {n:"Amukwak de Terre",t:1,d:"Jadis portée par Oto Mustam, chef des guerriers de Brâkmar, cette petite amulette ne lui servait qu\'à se faire beau lors des orgies organisées à Brâkmar. Tout un programme.",ep:5,g:72,l:42,wd:true,fm:true,w:3,s:14,p:4900};
I.u[6747] = {n:"Amukwak du Vent",t:1,d:"Lorsque le vent souffle dans ses plumes, le Kwak du Vent se sent libre comme l\'air, et se laisse planer tel une vieille feuille morte emportée par une bourrasque. Contrairement aux idées reçues, c\'est assez impressionnant.",ep:5,g:70,l:42,wd:true,fm:true,w:3,s:15,p:4900};
I.u[6748] = {n:"Kwakanneau de Terre",t:9,d:"Judicieusement porté, cet anneau vous permettra d\'embellir vos doigts boudinés. Malheureusement pour certains, il n\'est efficace que sur les doigts.",ep:5,g:64,l:42,wd:true,fm:true,w:2,s:14,p:4900};
I.u[6749] = {n:"Kwakanneau de Vent",t:9,d:"Cet anneau est si léger, qu\'il pourrait s\'envoler au premier coup de vent. Mais ne rêvez pas, si cela se produit, vous ne vous envolerez pas avec lui. On se moquera de vous dans le meilleur des cas.",ep:5,g:62,l:42,wd:true,fm:true,w:2,s:15,p:4900};
I.u[6750] = {n:"Kwaklame de Glace",t:6,d:"Lame froide et tranchante, elle réveillera les instincts les plus primitifs de ceux qui l\'utilisent.",ep:1,g:51,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CC>50&CV>50",s:13,p:4600};
I.u[6751] = {n:"Kwaklame de Terre",t:6,d:"\"Cette lame aiguisée mais pas déguisée, conviendra parfaitement aux aventuriers déjà expérimentés en quête de nouvelles sensations\". Voici ce que l\'on peut lire sur le manuel de cette épée. Les manuels ne sont plus ce qu\'ils étaient décidément.",ep:5,g:53,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>50&CV>50",s:14,p:4600};
I.u[6752] = {n:"Kwaklame du Vent",t:6,d:"Idéale pour couper les nuages, cette lame pourra également vous servir à faire du vent si vous l\'agitez comme un éventail. Une excellente technique pour décimer les Moskitos ou défigurer vos amis.",ep:5,g:50,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CA>50&CV>50",s:15,p:4600};
I.u[6753] = {n:"Kwakobottes de Glace",t:11,d:"Idéales comme patins à glace sur les lacs gelés, ces bottes sont également très utiles pour garder les pieds au frais, ou pour y stocker votre goûter durant les journées de forte chaleur. Il est cependant déconseillé de les faire sécher au coin du feu, sous peine de ne plus jamais les revoir.",ep:2,g:36,l:40,wd:true,fm:true,w:5,s:13,p:4400};
I.u[6754] = {n:"Kwakobottes de Terre",t:11,d:"\"Rien de mieux que les Kwakobottes de Terre pour marcher dans la terre\", telles étaient les paroles de Rola Ingalsse la célèbre laboureuse, juste avant de devenir aveugle, en recevant une motte de terre géante dans les yeux.",ep:5,g:49,l:40,wd:true,fm:true,w:5,s:14,p:4400};
I.u[6755] = {n:"Kwakobottes du Vent",t:11,d:"Rudimentaires mais efficaces, ces bottes d\'une légéreté surprenante sont parfois utilisées après avoir été retravaillées, comme manche à air pour indiquer la direction et la force du vent. Il est alors conseillé de se placer du bon côté de la manche à air, pour ne pas mourir asphyxié.",ep:5,g:48,l:40,wd:true,fm:true,w:5,s:15,p:4400};
I.u[6756] = {n:"Kwape de Terre",t:17,d:"Idéale pour se camoufler en motte de terre géante, cette cape vous permettra d\'attaquer par surprise les laboureurs et leur voler leurs richesses. Elle est donc avant tout réservée aux collectionneurs de silex.",ep:8,g:64,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6757] = {n:"Kwape du Vent",t:17,d:"Légère et raffinée, cette création peut accessoirement servir de rideau pour les plus dépourvus. Elle était jadis très convoitée par la Momie Nova en personne, qui désirait être correctement habillée pour sortir le soir. Un exemple à suivre pour certains.",ep:8,g:62,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6758] = {n:"Kwakture de Terre",t:10,d:"Le Kwak de Terre n\'est pas très social et surtout très chassé pour ses plumes, c\'est bien connu. En portant cette ceinture autour des hanches, vous vous exposez donc à de multiples fourberies de la part des chasseurs de Kwaks de Terre, qui vous prendront de loin pour un vieux Kwak grabataire sur le déclin. Les apparences ne sont finalement pas toujours trompeuses.",ep:12,g:65,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6759] = {n:"Kwakture de Vent",t:10,d:"\"La seule façon d\'attraper un vieux mâle Kwak du Vent contrarié, c\'est de se déguiser en femelle Kwak du Vent contrariée. Dès lors, le mâle tentera de comprendre pourquoi la femelle est contrariée et tentera avec tous les moyens dont il dispose, de satisfaire la femelle. Une fois le mâle satisfait de sa prestation, il faut profiter de sa béatitude pour le plumer.\" Voici ce que l\'on peut lire dans la section douze du tome trois sur la chasse aux Kwaks du Vent. Il y est en outre clairement indiqué, que cette ceinture est un élément indispensable pour se faire passer pour une femelle Kwak du Vent. Vous savez ce qu\'il vous reste à faire.",ep:12,g:63,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6760] = {n:"Kwakoiffe de Terre",t:16,d:"Cette Kwakoiffe de Terre est tellement lourde qu\'elle vous permettra de garder en permanence les pieds sur terre, mais vous fera également parfois tomber par terre. On ne peut pas tout avoir.",ep:13,g:71,l:41,wd:true,fm:true,w:25,s:14,p:4600};
I.u[6761] = {n:"Kwakoiffe du Vent",t:16,d:"Pour garder les cheveux au vent même une fois équipé d\'une coiffe, rien ne vaut cette sympathique Kwakoiffe du Vent, qui vous permettra sans aucun doute de laisser libre court à votre expression capillaire dans la plupart des circonstances. C\'est suffisant pour réussir à interloquer le plus blasé des Chafers.",ep:13,g:69,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6762] = {n:"Fourbasse-Ton",t:4,d:"\"Pour la baston, rien ne vaut un Fourbasse-Ton\". Voici ce que l\'on pouvait lire sur le dépliant publicitaire de l\'Agence Touristes, qui proposait de reconstruire soi-même ce bâton à partir de diverses ressources cachées un peu partout sur l\'île de Moon. Une sorte de jeu de piste, mais avec aucune piste.",ep:12,g:44,l:32,wd:true,fm:true,w:5,e:[15,4,1,1,20,70,false,false],s:16,p:2900};
I.u[6763] = {n:"Fourbacapa",t:17,d:"On raconte que les Fourbasses mortes sont très confortables une fois qu\'elles ont pris le temps de se décomposer au soleil. En effet, avec le temps elles deviennent beaucoup plus souples et douces. Beaucoup d\'aventuriers aimeraient pouvoir en dire autant de leur dulcinée.",ep:12,g:61,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6764] = {n:"Fourbacoiffe",t:16,d:"Avec cette coiffe sur la tête, vous n\'avez vraiment pas l\'air très futé. Mais plus que sans la coiffe, donc autant la garder.",ep:12,g:68,l:31,wd:true,fm:true,w:5,s:16,p:2800};
I.u[6765] = {n:"Lailait",t:79,d:"Attention, il est bien précisé sur l\'emballage de ne pas donner ce lait à un jeune Chacha, il risquerait de faire quelques tâches dans votre demeure.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:4};
I.u[6766] = {n:"Epis de Farle",t:1,d:"Cette amulette d\'apparence rudimentaire a été confectionnée à partir de trois épis de Blé magiques, recouverts de poussière de pierre précieuse, et fauchés dans les plaines de Snossios pendant la treizième moisson d\'Istrabraq. Elle confère un courage hors du commun à son porteur, désormais à même de faucher plaines et vallées sans jamais faillir.",ep:1,g:68,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6767] = {n:"Bracelet Magique de Farle",t:9,d:"Ce bracelet en pierres précieuses a été recouvert d\'une toile de Chanvre par Shika, pour éviter d\'attirer l\'attention des Corbacs, lorsque Farle semait son orge.",ep:13,g:61,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6768] = {n:"Soki",t:32,d:"Vous emmenez ce chacha malheureux afin de le distraire.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[6769] = {n:"Bâton de Farle",t:4,d:"Ce splendide bâton est muni de très belles dents à son extrémité, ce qui en fait un excellent fourcher. Farle s\'en servait pour créer d\'immenses meules de foin, plus hautes que le plus grand des Ormes qui poussait jadis en forêt de Litneg. On raconte que c\'est Brouce Boulgoure en personne qui aurait coupé le bois nécessaire à la fabrication de ce bâton, en échange des  monstrueuses rations quotidiennes de flocons d\'avoine offertes par Shika Ingalsse, qu\'il engouffrait avant de partir raser des forêts complètes.",ep:14,g:43,l:80,wd:true,fm:true,w:10,an:12,tw:true,e:[10,5,1,1,45,45,false,true],c:"CS>100&CV>100",s:17,p:16500};
I.u[6770] = {n:"Sousouris",t:15,d:"Cette Sousouris a été dénichée à coup de balai, de la maison de Grand-mère.",ep:1,g:282,l:1,wd:true,fm:true,w:10,p:1};
I.u[6771] = {n:"Anneau Thé",t:9,d:"Cet anneau n\'a pas encore fait ses preuves. Il s\'agit d\'une confection unique faite par un apprenti bijoutier à l\'occasion d\'un test important. Il est fabriqué à partir d\'un anneau de fer classique plongé dans une solution de Thé magique.",ep:1,g:1,l:4,wd:false,fm:true,w:1,p:50};
I.u[6773] = {n:"Amulette Tude",t:1,d:"Cette amulette est construite de façon Tude, d\'où son nom. C\'est l\'une des premières méthodes de création, car l\'une des plus simples, que l\'on enseigne aux apprentis bijoutiers. Certes le produit n\'est pas puissant mais il ne faut pas en demander trop non plus.",ep:1,g:19,l:1,wd:false,fm:true,w:1,p:25};
I.u[6774] = {n:"Sabots de Farle",t:11,d:"Ces sabots ont été taillés dans des bois rares, renforcés avec des pièces de cuirs d\'une valeur inestimable, et rembourrés avec des céréales magiques. À la fois légère, élégante, et confortable, cette paire de sabots saura résister aux affres du temps. Beaucoup d\'aventuriers un peu trop misogynes aimeraient pouvoir en dire autant de leur dulcinée.",ep:9,g:46,l:80,wd:true,fm:true,w:10,s:17,p:16600};
I.u[6775] = {n:"Cape de Farle",t:17,d:"Cette cape en tissu et en peaux permettait à Farle Ingalsse d\'ensemencer des champs entiers pendant une saison complète sans jamais devoir s\'arrêter. En effet, une fois repliée et utilisée comme une besace, sa capacité semble presque illimitée. Personne ne connaît réellement le tailleur à l\'origine de cette merveille, la légende raconte seulement, qu\'il s\'est retiré de la profession lorsque ses clients ont commencé à confondre ses capes avec des serpillères. Quel triste départ en retraite !",ep:13,g:70,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6776] = {n:"Farlature",t:10,d:"Cette ceinture servait également de tablier de boucher à Farle Ingalsse lorsqu\'il devait égorger ses troupeaux de Bouftous. Une tâche ingrate et cruelle, dont il s\'affranchissait pourtant avec un plaisir non dissimulé.",ep:4,g:61,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6778] = {n:"Farlacoiffe",t:16,d:"Ce chapeau de paille a été confectionné à l\'aide d\'une multitude d\'épis magiques tressés entre eux, puis l\'intérieur a été rembourré avec divers poils et étoffes cousues à la main par Shika Ingalsse, femme de Farle. Plus classe que le Ploukosse, et plus stylé que le Kraignosse, ce chapeau vous protègera du cagnard comme il l\'a fait pour Farle pendant des centaines de moissons, tout en vous donnant une allure guillerette et vraiment \"cool\". Suffisant pour s\'improviser roi ou reine des champs.",ep:13,g:67,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6779] = {n:"Rapport de l\'espion Sram.",t:24,d:"Rapport de l\'espion Ztiv Oztin, récupéré avec une certaine difficulté des mains de Joe Pierlivet.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
