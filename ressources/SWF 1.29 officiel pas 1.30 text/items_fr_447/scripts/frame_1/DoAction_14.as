I.u[6787] = {n:"Fiche remplie valide",t:80,d:"Cette petite fiche possède le nom d\'un potentiel candidat pour être livreur du boulanger",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW>1499&CA>49",p:0};
I.u[6788] = {n:"Gâteaux",t:24,d:"Ces gâteaux viennent juste d\'être sortis du four. Il faut les livrer tant qu\'ils sont chauds. Pensez-vous vraiment que vous avez du temps à perdre pour les examiner ainsi ?",ep:1,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[6789] = {n:"Amulette des Champs",t:1,d:"Cette petite amulette fleurit au printemps, mais se dessèche en été, se fane en automne, et pourrit en hiver. \nL\'occasion rêvée pour changer de look au fil des saisons.",ep:1,g:73,l:10,wd:false,fm:true,w:5,s:18,p:500};
I.u[6790] = {n:"Fiche à remplir",t:80,d:"Cette fiche ressemble à une feuille toute simple, cependant au contact de la peau d\'un individu celle ci affiche tout de suite si la personne convient aux critères fournis dans l\'entête.",ep:1,g:6,l:1,wd:false,fm:true,w:0,ut:true,p:0};
I.u[6791] = {n:"Anneau Champêtre",t:9,d:"Avec ce petit anneau autour du doigt, vous pourrez presque essayer de passer inaperçu au milieu des champs.",ep:1,g:65,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6792] = {n:"La Plantouze des Champs",t:4,d:"Ce bâton en forme de fleur a été confectionné à partir des restes de fleurs champêtres ayant succombé durant d\'horribles et cruels combats. Toute la rage et la haine de ces pauvres plantes est contenue dans ce ridicule petit bâton. Cette arme est utilisée par les Srams les plus fourbes, qui tentent de persuader les ignorantes qu\'ils comptent leur offrir un bouquet de fleurs. Une fois à portée, l\'imprudente se retrouve souvent assenée de coups sur la tête bien mérités.",ep:1,g:45,l:10,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,45,50,false,false],c:"CV>20",s:18,p:500};
I.u[6793] = {n:"Anneau Thé",t:9,d:"Cet anneau a fait ses preuves, une petite marque à l\'intérieur le prouve. Il s\'agit d\'une confection unique faite par un apprenti bijoutier à l\'occasion d\'un test important. Il est fabriqué à partir d\'un anneau de fer classique plongé dans une solution de Thé magique.",ep:1,g:1,l:4,wd:true,fm:true,w:1,p:50};
I.u[6794] = {n:"Bottes Champêtres",t:11,d:"Rien de mieux que d\'utiliser des bottes confectionnées à partir de restes de fleurs champêtres, pour écraser ces misérables fleurs qui poussent dans vos champs. De plus, ces bottes permettront à vos pieds de dégager une délicieuse odeur de fleur. Dommage qu\'il n\'existe pas un équivalent à ces bottes pour les caleçons.",ep:1,g:50,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6795] = {n:"Capouze des Champs",t:17,d:"Si vous voulez être la plus belle ce soir pour aller danser, c\'est la cape qu\'il vous faut.",ep:1,g:65,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6796] = {n:"Ceinture Fleurie",t:10,d:"Avec cette ceinture décorée de petits pétales autour de la taille, vous pourrez sans problème vous faire passer pour une danseuse étoile au milieu d\'un combat perdu d\'avance. De quoi décontenancer une armée de Chafers, pour retourner la situation à votre avantage.",ep:1,g:64,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6797] = {n:"Coiffe Champêtre",t:16,d:"Si vous avez toujours rêvé d\'être fleuriste et d\'avoir une haleine parfumée à l\'eau de rose, c\'est le moment d\'adopter cette étrange coiffe.",ep:1,g:70,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6798] = {n:"Fleur de Dzibi",t:24,d:"Son parfum est léger, subtil, enivrant ... Mais seuls les Sadidas et les Eniripsas connaissent le secret de ces fleurs.",ep:1,g:117,l:1,wd:false,fm:true,w:0,p:1};
I.u[6799] = {n:"Lame du Chef Bwork",t:6,d:"Tranchante comme une lame de Bwork, cette lame du Chef Bwork a l\'avantage de peser beaucoup plus lourd. Elle est certes moins maniable, mais il suffit de la laisser tomber sur son adversaire pour le trancher en deux, telle une vulgaire tranche de Tronknyde. Si votre ennemi ne meurt pas de douleur, il mourra de honte, et vous de rire.",ep:1,g:48,l:100,wd:true,fm:true,w:100,an:14,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>200&CA>200&CV>200",s:19,p:25000};
I.u[6800] = {n:"Cape Banale",t:17,d:"Cette cape est faîte de laine de Boufton. Elle ne vous sera guère utile si ce n\'est pour avoir l\'air classe... Et encore...",ep:1,g:15,l:1,wd:true,fm:true,w:1,p:1};
