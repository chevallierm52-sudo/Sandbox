I.u[6652] = {n:"Boule à neige foire du trooll",t:15,d:"cette jolie boule à neige donnera toute sa splendeur sur un rebord de cheminée",ep:13,g:694,l:1,wd:true,fm:true,w:1,p:15};
I.u[6653] = {n:"Ticket de la foire du Trool",t:24,d:"Ce ticket vous permet de rentrer dans la foire.",ep:13,g:94,l:1,wd:true,fm:true,w:0,p:1};
I.u[6654] = {n:"Bottes du Gardien des Egoûts",t:11,d:"Comble de l\'ironie, le gardien des égoûts s\'est fait dévorer par la Gardienne des Egoûts. Il a été digéré pendant plus de cent ans avant de finir par mourir. Heureusement, ses bottes étaient plus résistantes que lui et sont encore en excellent état.",ep:16,g:28,l:83,wd:true,fm:true,w:10,p:17800};
I.u[6655] = {n:"Sac Surprise du Chanceux",t:89,d:"Les personnes qui ont déposé ça dans votre banque sont vraiment généreuses, et ont voulu vous témoigner leur amitié. (DOUBLE CLIC POUR OUVRIR LE SAC)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
