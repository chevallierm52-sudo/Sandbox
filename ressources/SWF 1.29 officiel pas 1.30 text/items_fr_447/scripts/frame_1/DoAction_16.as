I.u[7753] = {n:"La Baguette Huve",t:3,d:"Cette baguette sort directement des profondeurs les plus chaudes des entrailles de la terre. Attention à celui qui la manipulera, il risque de prendre un retour de flammes violent.",ep:1,g:131,l:229,wd:false,fm:true,w:15,an:11,e:[10,2,5,5,20,60,false,false],c:"CI>1000&CA>250",p:57000};
I.u[7754] = {n:"Dofus Ocre",t:23,d:"Créé par Terrakourial, le Dragon de la Terre, ce Dofus concentre de grands pouvoirs à ne pas mettre entre toutes les mains... Ni entre tous les pieds d\'ailleurs.",ep:1,g:12,l:6,wd:true,fm:true,w:10,p:50000};
