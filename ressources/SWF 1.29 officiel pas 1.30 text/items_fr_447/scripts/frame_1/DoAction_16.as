I.u[7493] = {n:"Sertisseur du Joaillomage",t:5,d:"Ce sertisseur permet de rendre plus éblouissants, les bijoux que vous avez confectionnés.",ep:2,g:52,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=63",p:1000};
I.u[7494] = {n:"Aiguille du Costumage",t:20,d:"Cette aiguille magique vous permettra d\'améliorer considérablement la qualité de vos créations.",ep:9,g:23,l:1,wd:false,fm:true,w:1,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=64",p:1000};
I.u[7495] = {n:"Coupe Cuir du Cordomage",t:5,d:"Ce Coupe Cuir magique permet de mieux découper le cuir et gratter les peaux. C\'est l\'outil idéal pour améliorer les vieilles bottes et ceintures.",ep:2,g:53,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=62",p:1000};
I.u[7496] = {n:"Potion de résurrection de masse",t:14,d:"Cette potion permet de ressusciter tous les alliés présents autour de vous.",ep:0,g:60,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7497] = {n:"Potion de libération de masse",t:14,d:"Cette potion permet de libérer les âmes de vos ennemis pour les renvoyer directement dans leur cimetière, sans leur permettre de pouvoir se faire ressusciter.",ep:0,g:59,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7498] = {n:"Petite potion de soin de masse",t:14,d:"Cette potion permet de soigner tous les alliés présents sur la carte.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"Pg>23,2",u:true,p:10};
I.u[7499] = {n:"Potion de Village des Kwaks de Glace",t:12,d:"Cette potion vous permet de vous téléporter dans le village des Kwaks de Glace, si ce dernier vous appartient.",ep:0,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7500] = {n:"Potion du Village des Kwaks de Feu",t:12,d:"Cette potion vous permet de vous téléporter dans le village des Kwaks de Feu, si ce dernier vous appartient.",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7501] = {n:"Potion du Village des Kwaks de Vent",t:12,d:"Cette potion vous permet de vous téléporter dans le village des Kwaks de Vent, si ce dernier vous appartient.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7502] = {n:"Potion de Ralliement",t:12,d:"Cette potion permet de créer un point de ralliement, pour permettre aux aventuriers alignés de vous rejoindre, pour organiser une attaque ou une défense de village par exemple. Cette potion magique permet également de sauvegarder la position des personnes qui vous rejoignent, pour leur permettre de repartir rapidement jusqu\'à leur point de départ initial.",ep:0,g:21,l:1,wd:false,fm:true,w:1,p:1};
I.u[7505] = {n:"Potion d\'oubli de métier : Costumage",t:44,d:"Cette potion vous fera oublier le métier de Costumage.",ep:9,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7506] = {n:"Potion d\'oubli de métier : Joaillomage",t:44,d:"Cette potion vous fera oublier le métier de Joaillomage.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7507] = {n:"Potion d\'oubli de métier : Cordomage",t:44,d:"Cette potion vous fera oublier le métier de Cordomage.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7508] = {n:"Rune de Signature",t:50,d:"Cette rune permet aux artisans les plus doués, de signer leurs créations. \n(à utiliser lors de la fabrication de l\'objet en plus des ingrédients)",ep:18,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[7509] = {n:"Première partie de la clef du labyrinthe du Dragon Cochon",t:84,d:"Si ce groin ne vous dit rien, alors ne cherchez pas à en faire quelque chose, sous peine de recevoir une claque mortelle, surtout si vous êtes un peu étourdi.",ep:13,g:1,l:1,wd:true,fm:true,w:1,p:100};
I.u[7510] = {n:"Deuxième partie de la clef du labyrinthe du Dragon Cochon",t:84,d:"Ce morceau est peut-être une partie de la clef qui ouvre le coffre au trésor dont vous avez toujours rêvé. A moins que ce ne soit la clef de votre tombeau.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[7511] = {n:"Clef du labyrinthe du Dragon Cochon",t:84,d:"Si vous espérez rencontrer beaucoup de grosses cochonnes avec cette clef vous vous fourrez le doigt dans l\'oeil. Elle ne vous permettra que d\'ouvrir le labyrinthe du Dragon Cochon. Attention, elle sera détruite après utilisation.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:100};
I.u[7513] = {n:"Sandales Titude",t:11,d:"Titude était un modeste Enutrof cordonnier, plus petit encore qu\'un Xélor. On raconte qu\'il aurait confectionné ces sandales pour enfin réussir à embrasser sa dulcinée, une Eniripsa cul-de-jatte, mais que cela ne suffit point, et qu\'il dut se résoudre à ne pas l\'embrasser debout.",ep:20,g:67,l:122,wd:true,fm:true,w:10,p:37800};
I.u[7514] = {n:"Bottes Harry",t:11,d:"Harry était un vieux sage, qui passait ses journées à pêcher sur les quais de Sufokia. Sa grande moustache lui donnait un air de Danous Kouaide, célèbre acteur d\'une troupe de théatre qui se produisait régulièrement à la taverne d\'Amakna en guise de prélude à d\'incroyables orgies à base de bière et de Bougnette.",ep:20,g:70,l:123,wd:true,fm:true,w:10,p:37850};
I.u[7515] = {n:"Cape Itaineflam",t:17,d:"Cette cape ne vient pas de votre galaxie et pourtant,  elle semble assortie à la couleur de vos bas résille en laine de Boufton.",ep:20,g:92,l:148,wd:true,fm:true,w:10,p:47925};
I.u[7516] = {n:"Coiffe du Bimd\'Oule",t:16,d:"C\'est un vieil Enutrof, connu sous le nom de Dhy-Ah-Mhanhd, aigri et rongé par des siècles de malchance qui fit le premier, la découverte de cette terrible coiffe, cachée au fond d\'une alcôve dans les grottes de Bimd\'Oule. Plus tard, l\'Enutrof s\'exila loin des terres d\'Amakna pour tenter d\'échapper à l\'ennui et découvrir de nouveaux horizons. La légende raconte qu\'il revient sur ses terres natales une fois par siècle, pour se moquer de ses anciens amis, mais surtout par nostalgie.",ep:20,g:121,l:110,wd:true,fm:true,w:10,p:31675};
I.u[7517] = {n:"Bière du Ripate",t:37,d:"Cette bière est si acide, que la chope dans laquelle elle est servie a une espérance de vie digne d\'un Moskito.",ep:7,g:4,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7518] = {n:"Fotome",t:18,d:"Cette surprenante créature vient de l\'au-delà et n\'est pas prête d\'y retourner, sauf si malencontreusement, vous deviez l\'y accompagner...",ep:3,g:13,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7519] = {n:"Dragoune Rose",t:18,d:"Ce petit dragon a la peau aussi rose que les fesses d\'une femelle Bwork. Un bon moyen de vous faire fantasmer à moindre frais et sans risques, ou tout simplement de vous rappeler de bons souvenirs. Heureusement pour lui, ce dragon n\'est pas uniquement l\'objet de vos fantasmes, mais avant tout une créature très puissante et sage. Attention tout de même, sa voracité n\'a d\'égal que la perversité d\'un Chafer les soirs de pleine lune, et il ne se nourrit que d\'autres familiers.",ep:3,g:14,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7520] = {n:"Croum",t:18,d:"Ancien soldat de plomb retraité, cette créature en métal est devenue vivante. Elle vous suivra partout et fera tout pour vous défendre au péril de sa vie, si vous prenez la peine de lui donner à manger régulièrement. Mais n\'espérez pas qu\'elle prenne pour autant les coups à votre place, elle ne remplacera donc pas les aventuriers débutants d\'Astrub.",ep:3,g:15,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7521] = {n:"Cadeau Fotome",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, un livre vous expliquant comment l\'élever, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7522] = {n:"Minimino",t:18,d:"Ce bébé Minotoror apprivoisé et nettoyé peut être approché et caressé, sans risquer de perdre une main. Cependant, restez prudents, la nature reprend parfois ses droits et il se pourrait que l\'instinct destructeur de cette créature refasse surface à un moment où vous comptiez sur lui. Pour éviter les mauvaises surprises, élevez-le comme vos propres enfants, avec des coups de bâtons.",ep:3,g:21,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7523] = {n:"Chachate Rousse",t:18,d:"Cette adorable créature rousse est capable de faire craquer tous les matous, même les plus blasés. \n(CE FAMILIER LÉGENDAIRE N\'A PAS BESOIN DE MANGER)",ep:1,g:40,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7524] = {n:"Chacha Tigré",t:18,d:"Cette surprenante créature résulte du croisement entre un Chacha blanc et un Chacha noir. Elle ne mange que du poisson.",ep:3,g:41,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7525] = {n:"Cadeau Dragoune Rose",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, un livre vous expliquant comment l\'élever, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7526] = {n:"Cadeau Croum",t:89,d:"En posant votre oreille sur ce cadeau ou en le secouant vigoureusement, vous entendrez peut-être d\'étranges bruits qui vous révéleront la présence d\'une créature encore vivante. Ne perdez pas une seule seconde, ouvrez-le vite, vous y trouverez un superbe familier, un livre vous expliquant comment l\'élever, des ressources pour le nourrir et des poudres d\'Eniripsa pour le soigner. \n(ATTENTION, ce cadeau contient des objets très lourds, vous risquez d\'être en surcharge lorsque vous l\'ouvrirez, pensez à vous délester de vos objets lourds ou à vous faire aider d\'un ami.)",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
