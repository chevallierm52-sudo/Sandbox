I.u[7650] = {n:"Marteau du Bricoleur",t:7,d:"Ce marteau permet au Bricoleur de réaliser une multitude d\'objets différents.",ep:7,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:100};
I.u[7651] = {n:"Corne de Brume",t:94,d:"Cette corne de brume permet d\'appeler votre monture à la rescousse lorsque vous avez besoin d\'elle.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7652] = {n:"Potion de Souvenir",t:12,d:"Cette potion permet de voler une partie de l\'essence d\'un être afin de garder un souvenir impérissable de ce dernier. Très pratique pour marquer votre territoire ou vos biens, cette potion est régulièrement utilisée dans la fabrication de runes de signature.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
