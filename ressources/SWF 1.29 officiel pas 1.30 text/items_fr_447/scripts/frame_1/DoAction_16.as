I.u[7385] = {n:"Etoffe de Fantôme Tanukouï San",t:55,d:"Cette étoffe provient directement des aisselles du Fantôme Tanukouï San, réputées pour leur douceur, mais aussi pour leur odeur, proche dans le meilleur des cas, de celle que dégage la viande de Corbac en putréfaction.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7386] = {n:"Testicules du Tanukouï San",t:15,d:"Ces énormes testicules sont recouverts d\'un très doux duvet qui prévient à merveille les attaques magiques, mais aussi des coups d\'échasses que le Tanukouï San se donne lorsqu\'il ne fait pas attention, ou lorsqu\'il entre en transe lors de l\'invocation d\'une femelle Tanuki Chan. Dans tous les cas, vous n\'avez pas n\'importe quoi entre les mains.",ep:1,g:2,l:120,wd:true,fm:true,w:200,p:10};
I.u[7387] = {n:"Le clan des Mercenaires",t:25,d:"Tout, tout, tout vous saurez tout sur les Mercenaires ! Un ouvrage écrit par le fondateur et Grand-Maître du Clan.",ep:1,g:19,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7388] = {n:"Potion d\'oubli de Maîtrise : Haches",t:45,d:"Cette potion vous permettra d\'oublier un peu votre maîtrise des Haches.",ep:3,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7389] = {n:"Potion d\'oubli : \'Furie\'",t:43,d:"Cette potion permet de désapprendre un niveau du sort des Sacrieurs : \'Furie\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7390] = {n:"Potion d\'oubli : \'Epée Volante\'",t:43,d:"Cette potion permet de désapprendre un niveau du sort des Sacrieurs : \'Epée volante\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7391] = {n:"Potion d\'oubli : \'Coagulation\'",t:43,d:"Cette potion permet de désapprendre un niveau du sort des Sacrieurs : \'Coagulation\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7392] = {n:"Potion d\'oubli : \'Folie sanguinaire\'",t:43,d:"Cette potion permet de désapprendre un niveau du sort des Sacrieurs : \'Folie sanguinaire\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7393] = {n:"Etoffe de Fantôme Pandore",t:55,d:"Cette étoffe est encore imprégnée de la sueur du Pandore, ce qui lui confère une valeur ajoutée non négligeable.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7394] = {n:"Potion d\'oubli : \'Félintion\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort spécial \'Félintion\'",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7395] = {n:"Potion d\'oubli : \'Capture d\'âmes\'",t:43,d:"Cette potion permet d\'oublier un niveau du sort spécial \'Capture d\'âmes\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7396] = {n:"Prospérité",t:29,d:"Cette bénédiction permet de gagner de la résistance à l\'Eau pour les prochains combats.",ep:18,g:10,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7397] = {n:"Perspicacité",t:29,d:"Cette bénédiction permet de gagner de la résistance au Feu pour les prochains combats.",ep:18,g:9,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7398] = {n:"Elasticité",t:29,d:"Cette bénédiction permet de gagner de la résistance à l\'Air pour les prochains combats.",ep:18,g:8,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7399] = {n:"Coriacité",t:29,d:"Cette bénédiction permet de gagner de la résistance à la Terre pour les prochains combat.",ep:18,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7400] = {n:"Parchemin lié",t:87,d:"Ce parchemin permet de localiser sa cible afin de la traquer.",ep:1,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:1};
I.u[7401] = {n:"Parchemin vierge",t:87,d:"Ce parchemin permet de \"marquer\" une cible pour ensuite pouvoir la traquer.",ep:16,g:1,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,ut:true,p:100};
I.u[7402] = {n:"Lot de dix parchemins vierges",t:87,d:"Ce lot permet de \"marquer\" <b>une seule cible</b> pour ensuite pouvoir la traquer plusieurs fois.",ep:16,g:3,l:10,wd:false,fm:true,w:10,c:"Ps!0&PP>0",u:true,ut:true,p:500};
I.u[7403] = {n:"Os de Fantôme Léopardo",t:47,d:"Ce petit os pointu était autrefois utilisé par les Brigandins pour décorer leurs narines. Une façon élégante de mettre en valeur un nez crochu par exemple.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7404] = {n:"Os de Fantôme Maho Firefoux",t:47,d:"Cet os est encore imprégné d\'une magie que l\'on peut qualifier d\'artisanale, ne vous étonnez donc pas, si cet os reprend vie et cherche à retrouver les restes de son propriétaire.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7405] = {n:"Os de Fantôme Pandikaze",t:47,d:"Cet os est tout ce qu\'il reste du fantôme que vous venez d\'exterminer. Pas de chance pour vous, aucune magie ne semble l\'habiter.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7406] = {n:"Os de Fantôme Pandore",t:47,d:"Cet os ne sort pas de la boîte du Pandore et pourtant, tout porte à croire que si.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7407] = {n:"Os de Fantôme Pandule",t:47,d:"Finement taillé, cet os peut sans problème, servir d\'aiguille pour une horloge géante. Tout simplement indispensable.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7408] = {n:"Os de Fantôme Soryo Firefoux",t:47,d:"La première fois que le Soryo Firefoux s\'est cassé un os, il a tenté de se venger sur le premier venu. Au même moment, Francisque Kabroule, ménestrel de son état, se promenait en chantant et croisait le Soryo Firefoux. La suite de l\'histoire, personne ne la connaît, tout ce que l\'on sait, c\'est qu\'après ça, sa voix était devenue encore plus aiguë.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7410] = {n:"Os de Fantôme Tanukouï San",t:47,d:"A force de supporter le poids incommensurable de ses énormes testicules, les os du Tanukouï San ont fini par devenir incroyablement résistants.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7411] = {n:"Os de Fantôme Yokai Firefoux",t:47,d:"Cet os aurait pu servir de massue pour fendre les crânes des aventuriers insolents, ou même de marteau pour enfoncer les Enutrofs dans le sol comme de vulgaire asperges. Mais depuis qu\'il est entre vos mains, il semblerait que son destin soit différent...",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7412] = {n:"Lot de cent parchemins vierges",t:87,d:"Ce lot permet de \"marquer\" <b>une seule cible</b> pour ensuite pouvoir la traquer plusieurs fois.",ep:16,g:3,l:10,wd:false,fm:true,w:100,c:"Ps!0&PP>0",u:true,ut:true,p:3500};
I.u[7413] = {n:"Parchemin \"Pointer du doigt\"",t:25,d:"(Double clic pour apprendre cette emote) \nCe parchemin vous permet d\'apprendre l\'attitude \"Pointer du doigt\", pour indiquer une direction ou dénoncer ouvertement les tricheurs.",ep:18,g:9,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7414] = {n:"Petit Chacha Blanc",t:18,d:"Cette petite boule de poils griffe, mord et pince même la main qui la nourrit. C\'est donc une créature terrifiante, mais tout de même irrésistiblement attachante et fascinante. Toute ressemblance avec des personnes de la gent féminine ne serait pas fortuite. Attention, cette créature en plus de son caractère irascible est très difficile sur le plan alimentaire, puisqu\'elle ne consomme que de la viande issue de créatures chassées.",ep:3,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7415] = {n:"Petit Chienchien Noir",t:18,d:"Cette étrange petite créature ne se nourrit que de poissons fraîchement pêchés. Mais ne vous inquiétez pas, sa compagnie agréable compense largement son haleine de poisson déshydraté.",ep:3,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7417] = {n:"Certificat de Mise en Chanil : Peki Peki",t:77,d:"Ce certificat décrit les caractéristiques du Peki Peki que vous avez placé au chanil.",ep:3,g:26,l:1,wd:false,fm:true,w:1,p:100};
I.u[7418] = {n:"Certificat de Mise en Chanil : Petit Chacha Blanc",t:77,d:"Ce certificat décrit les caractéristiques du Petit Chacha Blanc que vous avez placé au chanil.",ep:3,g:27,l:1,wd:false,fm:true,w:1,p:100};
I.u[7419] = {n:"Certificat de Mise en Chanil : Petit Chienchien Noir",t:77,d:"Ce certificat décrit les caractéristiques du Petit Chienchien Noir que vous avez placé au chanil.",ep:3,g:28,l:1,wd:false,fm:true,w:1,p:100};
I.u[7420] = {n:"Certificat de Mise en Chanil : Nomoon",t:77,d:"Ce certificat décrit les caractéristiques du Nomoon que vous avez placé au chanil.",ep:3,g:35,l:1,wd:false,fm:true,w:1,p:100};
I.u[7421] = {n:"Potion d\'oubli de métier : Forgeur de Bouclier",t:44,d:"Cette potion vous fera oublier le métier de Forgeur de Bouclier.",ep:18,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7422] = {n:"Maskananas",t:16,d:"Ce masque en forme de fruit exotique est une véritable pièce de collection. Il ne sert à rien, si ce n\'est vous rendre véritablement original et appétissant. C\'est déjà beaucoup.",ep:1,g:117,l:1,wd:true,fm:true,w:1,s:74,p:10};
I.u[7423] = {n:"Oeuf de Larve Dorée",t:12,d:"Aussi étrange que cela puisse paraître, les oeufs de Larves Dorées ne sont pas pondus par des Larves Dorées, mais par des larves plus communes, de couleur verte, orange ou encore bleue. La nature est décidément pleine de mystères.",ep:1,g:715,l:10,wd:true,fm:true,w:1,u:true,p:1};
I.u[7425] = {n:"Petite Larve Dorée",t:32,d:"Cette larve vient de naître d\'un oeuf. Son premier regard s\'étant posé sur vous, elle vous considère comme sa mère.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
