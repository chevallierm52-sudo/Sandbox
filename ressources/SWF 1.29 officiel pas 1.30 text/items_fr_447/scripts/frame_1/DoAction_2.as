I.u[897] = {n:"Petites Dagues Eguisées",t:5,d:"Ces dagues d\'apparence modeste sont cependant très dangereuses. Elles sont de plus facilement dissimulables, ce qui en fait une arme de choix pour les assassins.",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
I.u[898] = {n:"Dagues Eguisées",t:5,d:"Ces dagues d\'apparence modeste sont cependant très dangereuses. Elles sont de plus facilement dissimulables, ce qui en fait une arme de choix pour les assassins.",ep:7,g:10,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>33&CW>5",p:3100};
I.u[899] = {n:"Grandes Dagues Eguisées",t:5,d:"Ces dagues d\'apparence modeste sont cependant très dangereuses. Elles sont de plus facilement dissimulables, ce qui en fait une arme de choix pour les assassins.",ep:7,g:10,l:36,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>36&CW>5",p:3600};
I.u[900] = {n:"Puissantes Dagues Eguisées",t:5,d:"Ces dagues d\'apparence modeste sont cependant très dangereuses. Elles sont de plus facilement dissimulables, ce qui en fait une arme de choix pour les assassins.",ep:7,g:10,l:39,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>39&CW>5",p:4100};
I.u[901] = {n:"Cuir du Cochon de Lait",t:56,d:"Ce cuir tout lisse devient presque orange avec l\'âge, mais sent également de plus en plus mauvais au fil du temps, un peu comme la mimolette.",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Petites Bottes de Klime",t:11,d:"L\'agilité que confère ces bottes permettait à Klime le cordonnier de monter facilement sur le dos de n\'importe quel Bouftou. Il est mort en confondant un Bouftou avec une Gelée, après une soirée trop arrosée passée à la taverne.",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Bottes de Klime",t:11,d:"L\'agilité que confère ces bottes permettait à Klime le cordonnier de monter facilement sur le dos de n\'importe quel Bouftou. Il est mort en confondant un Bouftou avec une Gelée, après une soirée trop arrosée passée à la taverne.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Grandes Bottes de Klime",t:11,d:"L\'agilité que confère ces bottes permettait à Klime le cordonnier de monter facilement sur le dos de n\'importe quel Bouftou. Il est mort en confondant un Bouftou avec une Gelée, après une soirée trop arrosée passée à la taverne.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Surpuissantes Bottes de Klime",t:11,d:"La légende raconte que ces bottes ont été échangées contre d\'autres bottes, défectueuses mais surpuissantes, qui avaient été fabriquées par un cordonnier maladroit manquant de sommeil.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Petites Bottes de Poursuite",t:11,d:"Ces bottes permettaient à Hogmeiser de poursuivre les seuls êtres vivants qu\'il ne supportait pas, les enfants. Heureusement pour eux, la lourdeur de ces bottes l\'empêchait de leur botter le derrière.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Bottes de Poursuite",t:11,d:"Ces bottes permettaient à Hogmeiser de poursuivre les seuls êtres vivants qu\'il ne supportait pas, les enfants. Heureusement pour eux, la lourdeur de ces bottes l\'empêchait de leur botter le derrière.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Grandes Bottes de Poursuite",t:11,d:"Ces bottes permettaient à Hogmeiser de poursuivre les seuls êtres vivants qu\'il ne supportait pas, les enfants. Heureusement pour eux, la lourdeur de ces bottes l\'empêchait de leur botter le derrière.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Puissantes Bottes de Poursuite",t:11,d:"Ces bottes permettaient à Hogmeiser de poursuivre les seuls êtres vivants qu\'il ne supportait pas, les enfants. Heureusement pour eux, la lourdeur de ces bottes l\'empêchait de leur botter le derrière.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Bottes d\'Hogmeiser",t:11,d:"Ces bottes ont appartenu à Hogmeiser pendant des années, avant qu\'il ne les perdent lors d\'un pari stupide avec Grizmine. La morale de l\'histoire, c\'est qu\'il ne faut jamais jouer avec un Ecaflip.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Bottes Usées d\'Hogmeiser",t:11,d:"Ces bottes usées ont appartenu à Hogmeiser pendant des années, elles sont tellement usées, qu\'elles sont surtout handicapantes. Un très bon Cordonnier devrait pouvoir les réparer avec de la chance.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Bottes Dorées d\'Hogmeiser",t:11,d:"Ces magnifiques bottes d\'Hogmeiser sont recouvertes d\'une fine couche de pierres précieuses, pour les rendre insensibles à certaines attaques magiques. C\'est avec ces bottes que Brouce Boulgoure a écrasé la tête du Roi des Abraknydes il y a très longtemps, pour animer l\'ouverture de la foire du Trool.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[916] = {n:"Amulette de Silicate",t:1,d:"Silicate a confectionné cette Amulette un matin d\'hiver, pour un célèbre aventurier du nom de Rimb Vardi, qui pourchassait un vieux Bwork Mage, responsable de plusieurs catastrophes naturelles déclenchées par sa magie trop approximative.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"La Feuille d\'Automne",t:1,d:"Cette Broche a été confectionnée un matin d\'automne au milieu d\'une forêt de Hêtres et d\'Ormes non loin de l\'île d\'Olag-lacustre. Elle est considérée par nombre de bûcherons comme une véritable relique.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Ambre Ancestrale",t:50,d:"Cette ambre provient d\'un Abraknyde Ancestral, elle a donc une valeur inestimable, et peut conférer des propriétés magiques à certains objets si elle est travaillée par des mains habiles.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Dagues Ancestrales",t:5,d:"Ces puissantes dagues, forgées à l\'ancienne à partir d\'Ambre Ancestrale, ont servi pendant la colonisation de l\'île de Moon, avant que cette dernière ne redevienne sauvage.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Bois Ancestral",t:38,d:"Ce bois provient d\'un Orme de l\'île d\'Olag-lacustre, qui a été foudroyé un matin d\'automne, par un Bwork Mage qui maîtrisait assez mal ses sorts élémentaires.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Marteau du Forgeur de Haches",t:7,d:"Outil indispensable à la création de haches.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Fendeuse d\'Abraknyde",t:19,d:"Cette hache de guerre a été forgée par Kademlia Boulgoure, pour combattre les plus terrifiants Abraknydes. La légende raconte que cette arme légendaire a tué en une nuit plus d\'Abraknydes qu\'il n\'existe d\'arbres en Amakna.",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Puissantes Bottes de Klime",t:11,d:"L\'agilité que confère ces bottes permettait à Klime le cordonnier de monter facilement sur le dos de n\'importe quel Bouftou. Il est mort en confondant un Bouftou avec une Gelée, après une soirée trop arrosée passée à la taverne.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Bois Envoûté",t:38,d:"Ce bois a été envoûté par un Mage Abraknyde, pour donner vie à un petit Abraknyde une fois trempé dans l\'eau. Il va de soi que ce bois est extrêmement magique.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Fendeuse d\'Abraknyde Ancestral",t:19,d:"Cette hache de guerre a été forgée par Kademlia Boulgoure, pour combattre l\'Abraknyde Ancestral. Seuls les meilleurs guerriers sont à même de pouvoir l\'utiliser.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Lame d\'Ogralimde",t:6,d:"Ogralimde était un grand guerrier qui devait sa force à Adyol son maître, un puissant Bwork Mage d\'une intelligence surprenante. Mais l\'élève n\'a jamais dépassé le maître, contrairement à ce que raconte la légende.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristalite",t:50,d:"Cette pierre magique au nom particulier n\'est pas à mettre en toutes les mains étant donné la puissance qu\'elle peut conférer aux armes ou aux bijoux.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Carte au trésor des Mineurs Sombres",t:24,d:"Cette carte indique l\'emplacement du coffre des Mineurs Sombres : \n\"Le coffre est situé sur une île, il faut passer derrière une fonderie pour y accéder\".",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Carte au trésor des Boulangers Sombres",t:24,d:"Cette carte indique l\'emplacement du coffre des Boulangers Sombres: \n\"Le coffre est situé sur une île au sud d\'Amakna, il faut passer derrière des rochers entre deux petits étangs\".",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Petite Cape de Rougeur",t:17,d:"Cette cape augmente la vie de son porteur.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
I.u[933] = {n:"Cape de Rougeur",t:17,d:"Cette cape augmente la vie de son porteur.",ep:1,g:13,l:13,wd:true,fm:true,w:5,p:650};
I.u[934] = {n:"Grande Cape de Rougeur",t:17,d:"Cette cape augmente la vie de son porteur.",ep:1,g:13,l:16,wd:true,fm:true,w:5,p:900};
I.u[935] = {n:"Petite Cape Bleutée",t:17,d:"Cette cape augmente la chance de son porteur.",ep:1,g:18,l:1,wd:true,fm:true,w:5,p:560};
I.u[936] = {n:"Cape Bleutée",t:17,d:"Cette cape augmente la chance de son porteur.",ep:1,g:18,l:3,wd:true,fm:true,w:5,p:1020};
I.u[937] = {n:"Grande Cape Bleutée",t:17,d:"Cette cape augmente la chance de son porteur.",ep:1,g:18,l:6,wd:true,fm:true,w:5,p:1560};
I.u[938] = {n:"Carte au trésor des Forgerons Sombres",t:24,d:"Cette carte indique l\'emplacement du coffre des Forgerons Sombres: \n-- a faire --",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Carte au trésor des Bworks",t:24,d:"Cette carte indique l\'emplacement du coffre des Bworks : \n\"L\'accès au coffre est situé dans une impasse, dans le Sud-Est de la forêt sombre. Il sera certainement protégé par un groupe de Bworks\".",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Louffeur",t:16,d:"Le Louffeur prévient des dégâts physiques.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Bandeau Komintot",t:16,d:"Le Komintot permet d\'augmenter la sagesse de son porteur.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Lisseur",t:16,d:"Le Lisseur prévient des dégâts magiques.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Petit Bandeau de Vitalité",t:16,d:"Ce Bandeau permet d\'augmenter la vitalité de son porteur.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Bandeau de Vitalité",t:16,d:"Ce Bandeau permet d\'augmenter la vitalité de son porteur.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
I.u[945] = {n:"Petite Cape Sombre",t:17,d:"Cette cape augmente la sagesse de son porteur.",ep:1,g:15,l:8,wd:true,fm:true,w:5,p:375};
I.u[946] = {n:"Cape Sombre",t:17,d:"Cette cape augmente la sagesse de son porteur.",ep:1,g:15,l:12,wd:true,fm:true,w:5,p:600};
I.u[947] = {n:"Grande Cape Sombre",t:17,d:"Cette cape augmente la sagesse de son porteur.",ep:1,g:15,l:19,wd:true,fm:true,w:5,p:1200};
I.u[948] = {n:"Abracape",t:17,d:"Cette magnifique cape est un brillant mélange entre l\'essence d\'Abraknyde et le bon Bouftou des familles.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Grand Bandeau de Vitalité",t:16,d:"Ce Bandeau permet d\'augmenter la vitalité de son porteur.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Aiguilles et Fil",t:20,d:"Ces aiguilles et ce fil vous permettront d\'exercer le métier de tailleur.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Cape du Mulou Fou",t:17,d:"Cette cape a été confectionné grâce à des poils et autres élèments organiques de diverses Mulous... On peut dire qu\'elle respire la puissance.",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Cape du Tofu Fou",t:17,d:"Cette cape, cousue main avec des plumes de Tofus, permet au héros qui la porte de courir plus vite et de s\'échapper plus facilement des zones de tacle.",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"La Samoulaille",t:17,d:"La Samoulaille est une cape légendaire, brodée par les tailleurs pour les guerriers préférant les combats au corps à corps.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Cape Hilère",t:17,d:"La cape Hilère est un type de cape très demandée par les coiffeurs. Ils adorent se rouler dedans. Elle rend les cheveux de son porteur plus résistants aux chocs.",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Cape Rice",t:17,d:"Cette cape augmente la portée de son porteur, lui permettant d\'atteindre des cibles très éloignées, ou d\'impressionner les aventuriers un peu naïfs.",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"La Boufteuse",t:17,d:"La Boufteuse augmente les dégâts et la vitalité de son porteur. Cependant elle dégage une forte odeur, et il n\'est pas rare qu\'un bouftou vous prenne pour l\'un des siens.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofusteuse",t:17,d:"Cette cape est certainement l\'une des plus puissantes au monde. Elle augmente toutes les caractéristiques de son porteur.",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Carte au trésor 5",t:24,d:"-- a faire --",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Potion Wabbit",t:24,d:"Cette potion est un remède contre la myxomawose. Une gorgée de ce breuvage vous permet de visiter l\'île des wabbits sans craindre pour votre vie.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Clé Wabbit",t:24,d:"Une des trois clés permettant d\'ouvrir la porte du château wabbit.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Clé Wabbit",t:24,d:"Une des trois clés permettant d\'ouvrir la porte du château wabbit.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
I.u[963] = {n:"Clé Wabbit",t:24,d:"Une des trois clés permettant d\'ouvrir la porte du château wabbit.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Pierre de Dopeul",t:50,d:"Cette pierre vient du monde des Dopeuls. Elle a une très grande valeur auprès de certains habitants d\'Amakna.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Manuel du Tailleur",t:25,d:"(Double clic pour apprendre le métier de Tailleur) \nCe manuel de tailleur vous permet d\'apprendre les ficelles du métier. Pour ceux dont l\'imagination ferait défaut, les premières pages proposent des patrons simples à découper.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Cape Fulgurante",t:17,d:"Cette magnifique cape augmente les points d\'action de son porteur. Elle augmente également sa vitalité et sa sagesse.",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
I.u[968] = {n:"Ceinture Fulgurante",t:10,d:"Cette magnifique ceinture augmente les points d\'action de son porteur. Elle augmente également sa vitalité et sa sagesse.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Couronne du Wa Wabbit",t:16,d:"Cette magnifique couronne a appartenu au tristement célèbre Wa Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Bâton du Wa Wabbit",t:4,d:"Ce bâton appartenait au tristement célèbre Wa Wabbit.",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Cape du Wa Wabbit",t:17,d:"Cette cape appartenait au tristement célèbre Wa Wabbit. Elle est encore imprégnée de sa transpiration, ce qui vous permettra de vous remémorer ce magnifique combat à chaque fois que vous la porterez.",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Dofus Cawotte",t:23,d:"Le Dofus Cawotte augmente la sagesse de son porteur.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Patte d\'Araknelle",t:24,d:"Une patte très fine, mais très poilue. Les meilleurs Alchimistes arrivent à créer de puissants poisons avec le jus qu\'ils arrivent à extraire de ces pattes.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Tête du Paysan en détresse",t:24,d:"Ce qui devait arriver est arrivé, le Paysan en détresse a fini par perdre la tête.",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Canine du Vampire Captif",t:24,d:"Cette dent très pointue, provient d\'un Vampire. La posséder dans son inventaire ou la porter autour du cou vous permettra d\'impressionner vos amis en leur faisant croire que vous êtes un chasseur de Vampires.",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Citwouille",t:16,d:"La citwouille a la particularité d\'empêcher la dispersion des particules de magie, cela en fait un très bon isolant magique. C\'est d\'ailleurs pour cela que certains guerriers se servent de ce légume comme couvre-chef.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Shigekax Citron",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon au citron préparé de façon traditionnelle.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Shigekax Fraise",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon à la fraise préparé de façon traditionnelle.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Shigekax Menthe",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon à la menthe préparé de façon traditionnelle.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Shigekax Cerise",t:42,d:"Retrouvez la saveur et tout le charme des sucreries d\'antan... avec ce bonbon à la cerise préparé de façon traditionnelle.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Vertgely",t:42,d:"Préparé à base de gelée menthe, même si il a rebuté plus d\'un végétarien, il n\'en reste pas moins une des spécialités d\'Amakna.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Rougely",t:42,d:"Préparé à base de gelée à la fraise, même si il a rebuté plus d\'un végétarien, il n\'en reste pas moins une des spécialités d\'Amakna.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Blugely",t:42,d:"Préparé à base de gelée bleue, même s\'il a rebuté plus d\'un végétarien, il n\'en reste pas moins une des spécialités d\'Amakna.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multygely",t:42,d:"La multygely a été interdite à la vente, car elle a provoqué la disparition de nombreux enfants. \nIl parait qu\'elle envoie la personne qui la mange dans ses pires cauchemars.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[997] = {n:"Noix de Kokoko",t:46,d:"Aussi ronde qu\'un boulet de canon, cette noix possède en plus 3 trous très pratiques pour la soulever et la lancer au loin.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Caleçon Mignon du Capitaine Pirate",t:15,d:"Le caleçon du Capitaine Pirate vérifie que le ridicule tue quand même de temps en temps. Mais il semblerait pourtant qu\'il porte chance.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Toile peu ragoutante",t:55,d:"Gluant et malodorant, ce large tissu n\'en reste pas moins de qualité. Dommage qu\'il soit percé.",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Tonneau vide",t:15,d:"Ce gros tonneau est vide depuis fort longtemps, on peut quand même deviner tout ce qu\'il a contenu : rhum, kamas, pirates ivres... un peu de tout, mais vraisemblablement jamais d\'eau.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Planche en bois de Kokoko",t:95,d:"Futur fragment de bateau ? Futur sol de maison ? Dans tous les cas, ça n\'est pour l\'instant qu\'une planche comme les autres.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"Tronc de Kokoko",t:38,d:"Comme tous les troncs, celui du Kokotier est droit et solide, mais un peu plus fin que la moyenne.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Poutre en Bois de Kokoko",t:38,d:"Une poutre de bois solide à ne pas mettre dans l\'oeil.",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Indispensable Corde",t:15,d:"Tous les aventuriers savent qu\'il faut toujours avoir une corde comme celle-ci sur soi... Pourtant, personne n\'en emporte jamais.",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Reçu pour le radeau",t:24,d:"Un reçu signé de la main de Kib Roche, indiquant que votre radeau sera prêt d\'ici quelque temps.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Chapeau Pirate",t:24,d:"Chapeau aux formes imposantes, insigne de mort brodé sur le devant, fourrure pour faire joli, ce chapeau de pirate est un classique parmi les capitaines.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Crochet",t:24,d:"Accessoire indispensable aux pirates en manque de chance, ce crochet remplace avantageusement une main. Sa couleur lui donne en plus un aspect assez chic.",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Mâchoire tombante",t:24,d:"Cette mâchoire en collier provient certainement d\'une colère d\'un capitaine envers un matelot trop hilare à la vue du caleçon de son chef.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Crâne de pirate",t:24,d:"Ce crâne coiffé d\'un bandeau montre bien qu\'un pirate, même mort, peut encore se cacher d\'être chauve.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Carapace verte",t:24,d:"La carapace d\'une tortue folle qui se prenait pour un ninja.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1011] = {n:"Carapace jaune",t:24,d:"La carapace d\'une tortue folle qui avait abusé sans doute de substances dangereuses.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Carapace Rouge",t:24,d:"La carapace d\'une tortue folle qui mangeait des tomates et du fromage sur du pain chaud.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Carapace Bleue",t:24,d:"La carapace d\'une tortue folle qui voulait imiter Zowwo, le Wenard masqué.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Masque Vert",t:24,d:"Masque de Kanniboul rieur, à l\'image de la Verdure, élément d\'assaisonnement de la viande.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Masque Jaune",t:24,d:"Masque de kanniboul pleureur, à l\'image de la Foudre, élément qui effraye souvent la jeune viande.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Masque Rouge",t:24,d:"Masque de kanniboul colérique, à l\'image du Feu, élément de cuisson de la viande.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Masque Bleu",t:24,d:"Masque de Kanniboul surpris, à l\'image de l\'Eau, élément désaltérant entre deux bouchées de viande.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Kole",t:15,d:"Ce pot de gelée rose à la bonne odeur ne doit surtout pas être goûté. Sinon vous ne pourriez plus jamais parler tant ce liquide est fixant.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Casque",t:16,d:"Porter ce casque signifie adopter un look unique... À mi-chemin entre le ridicule et le comique.",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Casque cassé",t:15,d:"Ce casque vous a sauvé la vie, mais n\'a pas réussi à sauver la sienne.",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Ailes en bois",t:17,d:"Pour ceux qui ont toujours rêvé de voler comme un Kwak, allez vous recoucher, car ces ailes ne feront de vous qu\'un danger public doublé d\'un idiot.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Ailes cassées",t:104,d:"Ces ailes cassées vous rappellent sans cesse que vous auriez vraiment dû vous recoucher.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Bouteille de rhum",t:15,d:"L\'étiquette annonce un \"rhum 10 ans d\'age\", mais impossible à vérifier. Une annotation précise aussi de ne pas en abuser sur les routes sous peine de mal de mer.",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
I.u[1026] = {n:"Petit couteau à Stek",t:5,d:"L\'illustre fou Stek Dardar aurait commandé ces couteaux étranges et redoutables. Nul n\'en connaissait l\'utilité jusqu\'à ce qu\'il tente d\'offrir à manger à son dieu.",ep:1,g:13,l:32,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>32&CS>10",p:3000};
I.u[1027] = {n:"Couteau à Stek",t:5,d:"L\'illustre fou Stek Dardar aurait commandé ces couteaux étranges et redoutables. Nul n\'en connaissait l\'utilité jusqu\'à ce qu\'il tente d\'offrir à manger à son dieu.",ep:1,g:13,l:35,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>35&CS>12",p:3400};
