I.u[419] = {n:"Oreille du Grand Pa Wabbit",t:106,d:"Les oreilles du Grand Pa Wabbit sont pointues et rigides, mais sont recouvertes d\'une épaisse fourrure zébrée du plus bel effet. C\'est sans conteste une des fourrures les plus recherchées, ne serait-ce que parce qu\'elle ne sent absolument rien.",ep:8,g:115,l:39,wd:true,fm:true,w:1,p:1};
I.u[420] = {n:"Ficelle en Lin",t:15,d:"La ficelle de lin est très solide, elle permet de faire de jolies coutures bien solides ou alors de ligoter ses amis pour leur montrer qui est réellement le chef de la guilde.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[421] = {n:"Fleur de Lin",t:35,d:"La Fleur de Lin peut être bleue ou blanche, suivant la période de l\'année à laquelle la graine a été semée. En décoction ou en infusion, elle procure une sensation de bien-être peu commune.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:0};
I.u[422] = {n:"Graine de Lin",t:58,d:"Cette toute petite graine contient énormément de bonnes choses. Les chasseurs de Kwaks savent que ces derniers en sont friands et n\'hésitent pas à les attirer dans leurs pièges avec ces graines luisantes.",ep:1,g:119,l:1,wd:true,fm:true,w:2,p:1};
I.u[423] = {n:"Lin",t:34,d:"La tige de Lin n\'a rien de spécial, si ce n\'est qu\'elle est capable de se redresser 7 fois après avoir été pliée par les tempêtes. C\'est sûrement pour cela que sa fibre est si souple.",ep:1,g:122,l:40,wd:true,fm:true,w:2,p:0};
I.u[424] = {n:"Fibre de Lin",t:55,d:"C\'est la fibre idéale pour confectionner les plus belles étoffes, elle est rare et chère mais tellement supérieure aux fibres classiques qu\'aucun tisserand ne pourrait s\'en passer.",ep:13,g:120,l:46,wd:true,fm:true,w:1,p:1};
I.u[425] = {n:"Chanvre",t:34,d:"La Tige de Chanvre peut être utilisée lors de la recherche d\'effets hallucinogènes, mais également par les tisserands qui exploitent leurs fibres pour des raisons toutes autres.",ep:1,g:121,l:70,wd:true,fm:true,w:2,p:0};
I.u[426] = {n:"Fibre de Chanvre",t:55,d:"Cette fibre n\'est pas très belle, mais elle est particulièrement résistante. De plus, dans des moments d\'introspection sur soi-même, il est toujours possible de la fumer.",ep:13,g:123,l:46,wd:true,fm:true,w:1,p:1};
I.u[427] = {n:"Graine de Chanvre",t:58,d:"La Graine de Chanvre est très utilisée pour calmer les troupeaux de Tabis en rut, il suffit de leur en administrer quelques-unes et ces derniers deviennent soudainement moins farouches.",ep:1,g:157,l:10,wd:true,fm:true,w:1,p:10};
I.u[428] = {n:"Fleur de Chanvre",t:35,d:"Cette fleur permet de faire des potions aux effets aléatoires, qui peuvent aller de la paralysie totale à l\'invulnérabilité aux gaz de Wabbits.",ep:1,g:156,l:10,wd:true,fm:true,w:1,p:0};
I.u[429] = {n:"Pointe de Flèche du Bwork Archer",t:15,d:"Cette pointe de flèche rouillée est faite à partir d\'un métal rare, qu\'on ne trouve que sur ces pointes de flèche.",ep:4,g:125,l:24,wd:true,fm:true,w:1,p:1};
I.u[430] = {n:"Os Invisible du Chafer Invisible",t:47,d:"Cet os est invisible, grâce aux propriétés magiques qui lui ont été conférées. Il doit sûrement pouvoir être utilisé pour des potions magiques...",ep:1,g:126,l:23,wd:true,fm:true,w:1,p:20};
I.u[431] = {n:"Pierre du Craqueleur",t:51,d:"Cette pierre est presque vivante, elle tire sa vie des pierres précieuses qu\'elle renferme. Elle est quasiment incassable, sauf par un Craqueleur. Il n\'y a pas mieux pour se faire un bon gros marteau en pierre.",ep:2,g:127,l:31,wd:true,fm:true,w:5,p:1};
I.u[432] = {n:"Côtes du Rib",t:47,d:"Les côtes du Rib sont vraiment très bonnes une fois grillées, il n\'y a pas beaucoup à manger autour, mais c\'est tellement fin, que ça se mange sans fin.",ep:3,g:158,l:33,wd:true,fm:true,w:1,p:100};
I.u[433] = {n:"Fémur du Chafer Archer",t:47,d:"Voilà un os bien étrange, il est particulièrement friable, et dégage une odeur de curry éventé lorsqu\'il est brûlé, voilà qui pourrait bien arranger certains cuisiniers peu scrupuleux.",ep:1,g:101,l:34,wd:true,fm:true,w:1,p:100};
I.u[434] = {n:"Ecorce d\'Abraknyde",t:96,d:"Ce morceau d\'écorce est rugueux, crevassé, recouvert de petites aspérités et sent étrangement bon, un peu comme la peau des pieds d\'un Enutrof.",ep:1,g:103,l:32,wd:true,fm:true,w:1,p:1};
I.u[435] = {n:"Racine d\'Abraknyde",t:98,d:"Ce morceau de racine a connu divers substrats à force d\'accompagner l\'Abraknyde lors de promenades dans les sous-bois. Mais ça n\'explique pas pourquoi ce morceau de racine est magique.",ep:1,g:102,l:32,wd:true,fm:true,w:1,p:1};
I.u[436] = {n:"Bâton en Racine d\'Abraknyde",t:4,d:"Ce bâton taillé dans une grosse racine d\'Abraknyde est très efficace au corps à corps, attention à ne pas le laisser au contact de l\'eau, il pourrait reprendre racines et se retourner contre son maître.",ep:1,g:1,l:30,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,20,50,false,false],c:"CI>30&CC>5",p:2650};
I.u[437] = {n:"Bourgeon d\'Abraknyde",t:108,d:"Lors de la puberté, les Abraknydes se recouvrent de vilains bourgeons gorgés de sève juteuse riche en vitamines. Plus tard, ces bourgeons donnent naissance à de nouvelles pousses qui elles-mêmes donneront naissance à des bourgeons.",ep:1,g:104,l:32,wd:true,fm:true,w:1,p:1};
I.u[438] = {n:"Queue du Mulou",t:65,d:"La queue du Mulou ressemble à s\'y méprendre à une énorme bûche velue, et pourtant, il n\'en est rien, ne vous méprenez pas.",ep:1,g:105,l:70,wd:true,fm:true,w:1,p:50};
I.u[439] = {n:"Canine du Mulou",t:47,d:"Cette canine tranchante est surtout recherchée en tant que porte bonheur, pourtant, elle n\'apporte à son porteur que des mauvaises odeurs.",ep:1,g:106,l:70,wd:true,fm:true,w:1,p:1};
I.u[440] = {n:"Griffe du Mulou",t:15,d:"Cette griffe bien sale permet de faire des armes redoutables.",ep:1,g:107,l:70,wd:true,fm:true,w:1,p:1};
I.u[441] = {n:"Cuivre",t:39,d:"Le Cuivre est un métal très utile pour confectionner les armes bon marché, c\'est presque un ersatz de l\'or si on fait abstraction de toutes les qualités de l\'or.",ep:1,g:108,l:10,wd:true,fm:true,w:5,p:0};
I.u[442] = {n:"Bronze",t:39,d:"Ce métal entre souvent dans la fabrication d\'articles ornementaux, pour embellir vos armes à moindre frais, c\'est le métal idéal.",ep:1,g:109,l:20,wd:true,fm:true,w:5,p:0};
I.u[443] = {n:"Kobalte",t:39,d:"Le nom « Kobalte » signifie « cuivre du diable » en Sadida ancien, c\'est un métal adapté à la forge d\'armes légères et élégantes, mais avant tout mortelles.",ep:1,g:77,l:30,wd:true,fm:true,w:5,p:0};
I.u[444] = {n:"Etain",t:39,d:"L\'Etain est un métal mou et lourd, un peu comme le Wo Wabbit, mais en pire.",ep:1,g:78,l:50,wd:true,fm:true,w:5,p:0};
I.u[445] = {n:"Manganèse",t:39,d:"Contrairement à ce que tout le monde pense, ce métal ne sert pas à faire des gouttières, mais plutôt à faire des armes terrifiantes, comme le redoutable \"Tranchant Manganésien\" qui a estourbi plus d\'un Tofu lors des fêtes du Boulgour.",ep:1,g:397,l:40,wd:true,fm:true,w:5,p:0};
I.u[446] = {n:"Bauxite",t:39,d:"Ce métal est très apprécié pour sa couleur argentée et pour son tranchant lorsqu\'il est correctement aiguisé.",ep:1,g:76,l:70,wd:true,fm:true,w:5,p:0};
I.u[447] = {n:"Charbon",t:39,d:"Le Charbon ne dispose d\'aucune propriété magique particulière, contrairement à ce que l\'on pourrait croire. Cependant, il a une fâcheuse tendance à attirer la foudre, à la contenir, et à la libérer au mauvais moment.",ep:5,g:75,l:1,wd:true,fm:true,w:5,p:0};
I.u[448] = {n:"Silex",t:51,d:"Ce caillou est particulièrement tranchant, il a égorgé plus d\'une taupe imprudente.",ep:1,g:74,l:22,wd:true,fm:true,w:5,p:1};
I.u[449] = {n:"Bois d\'Ebène",t:38,d:"Ce bois tient son nom d\'un malentendu, il y a bien longtemps, la seule famille de Bûcherons qui savait où se trouvaient ces arbres, s\'appelait Baine, et partout, on parlait du \"Bois des Baine\", à force d\'écrire n\'importe comment voici ce qui arrive.",ep:7,g:73,l:70,wd:true,fm:true,w:5,p:0};
I.u[450] = {n:"Pierre de Granit",t:51,d:"Ce minéral est presque inusable, mais aussi très lourd, ce qui limite son utilisation dans la forge d\'armes. En le travaillant longtemps, on peut parfois en extraire des pierres précieuses.",ep:1,g:1,l:30,wd:true,fm:true,w:20,p:1};
I.u[454] = {n:"Hache de Bûcheron",t:19,d:"Cette hache est indispensable au bûcheron s\'il veut correctement exercer son métier. Le cas échéant, elle peut également lui permettre de se débarrasser de quelques monstres...",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:150};
I.u[455] = {n:"Marteau de l\'Aurore",t:7,d:"Ce ridicule petit marteau servait à Zokrim le paysan, qui s\'en servait pour planter ses piquets de clôtures à l\'aurore. Personne ne sait pourquoi Zokrim plantait ses piquets à l\'aurore, mais la légende raconte qu\'il avait de bonnes raisons.",ep:1,g:2,l:26,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CS>10&CI>16",p:2000};
I.u[456] = {n:"Tueuse de Chênes",t:19,d:"Cette hache permet de couper facilement les arbres, même les plus gros. Elle est surtout appréciée pour son poids important qui lui permet de couper un Bwork en trois facilement, pour peu que son porteur soit capable de la soulever.",ep:7,g:2,l:33,wd:true,fm:true,w:50,an:17,e:[5,4,1,1,40,40,false,false],c:"CS>66&CA>10",p:3150};
I.u[458] = {n:"Amulette du Chafer",t:1,d:"Le Chafer est quelqu\'un de sensible et distingué, il garde toujours avec lui une amulette faite des crânes de ses cousins tombés au combat. Le plus étrange, c\'est que le Chafer n\'a jamais eu de cousins.",ep:1,g:3,l:19,wd:true,fm:true,w:4,p:1200};
I.u[459] = {n:"Planche en Frêne",t:95,d:"Cette planche en Frêne permet aux bricoleurs de construire des trucs en bois, comme un cercueil en planches par exemple.",ep:1,g:93,l:1,wd:true,fm:true,w:10,p:10};
I.u[460] = {n:"Bois de Chêne",t:38,d:"Ce bois d\'excellente qualité est particulièrement résistant, il permet de faire presque tout, des gourdins, des maisons ou encore des bateaux, mais la meilleure façon d\'utiliser ce bois reste d\'en faire des fûts à bière (Hips !).",ep:1,g:92,l:30,wd:true,fm:true,w:5,p:0};
I.u[461] = {n:"Bois d\'If",t:38,d:"Ce bois particulièrement souple ne casse jamais, ce qui en fait un bois de choix pour la réalisation d\'arcs. Il est en revanche difficile à trouver, les paysans d\'Amakna ayant tendance à tuer les jeunes pousses d\'If qui rendent malades leurs Bouftous.",ep:1,g:94,l:50,wd:true,fm:true,w:5,p:0};
I.u[462] = {n:"Arc en Racine d\'Abraknyde",t:2,d:"Le bois d\'Abraknyde étant toujours vivant une fois coupé, cet arc est très difficile à utiliser. Cependant, il n\'y a pas mieux pour ridiculiser un Abraknyde, que de le tuer avec un arc issu des racines de ses propres frères.",ep:1,g:1,l:28,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,30,50,false,true],c:"CS>10&CA>28",p:2250};
I.u[463] = {n:"Ambre",t:50,d:"Cette magnifique pierre précieuse est constituée de résine d\'arbre fossilisée. On y trouve parfois à l\'intérieur, un petit Moskito pris au piège il y a des lustres, ce qui ne manque pas de rajouter de la valeur à cette pierre.",ep:1,g:96,l:32,wd:true,fm:true,w:4,p:20};
I.u[464] = {n:"Ambre d\'Abraknyde",t:50,d:"Cette magnifique pierre précieuse est constituée de résine d\'Abraknyde fossilisée. On y trouve parfois à l\'intérieur, une Arakne prise au piège il y a des lustres dans la sève de son Maître. Voilà une mort bien méritée pour ce genre de Monstre.",ep:1,g:97,l:32,wd:true,fm:true,w:5,p:40};
I.u[465] = {n:"Cristal",t:50,d:"Le Cristal est une pierre translucide, mais très cassante. Et oui, même chez les pierres précieuses, rien n\'est parfait.",ep:1,g:98,l:50,wd:true,fm:true,w:20,p:5000};
I.u[466] = {n:"Saphir",t:50,d:"Cette pierre précieuse toute bleue est bien adaptée à la fabrication d\'armes aux effets magiques, peut-être parce que les créateurs de jeu en mal d\'inspiration utilisent toujours le bleu pour représenter le mana.",ep:1,g:99,l:50,wd:true,fm:true,w:20,p:5000};
I.u[467] = {n:"Rubis",t:50,d:"Cette pierre précieuse aux couleurs rougeoyantes comme les plumes du Kwak de Flammes est froide au toucher comme les plumes du Kwak de Glace.",ep:1,g:100,l:50,wd:true,fm:true,w:20,p:5000};
I.u[468] = {n:"Pain d\'Amakna",t:33,d:"Ce petit pain tout chaud à la mie bien molle et à la croûte dorée permet de regagner des points de vie perdus au combat. C\'est le pain le plus populaire, car généralement le moins cher.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[469] = {n:"Baguette en Racine d\'Abraknyde",t:3,d:"Cette baguette utilise les propriétés magiques de la Racine d\'Abraknyde qui est encore vivante, méfiez-vous des effets néfastes de cette baguette, il lui arrive parfois de se retourner contre son maître.",ep:1,g:3,l:33,wd:true,fm:true,w:20,an:11,e:[5,4,2,2,50,40,false,true],c:"CI>33&CW>10",p:3100};
I.u[470] = {n:"Bois d\'Orme",t:38,d:"Le Bois d\'Orme est un des bois les plus recherchés, courant autrefois, il a été décimé il y a des lustres par la Grafioze, une sorte d\'envoûtement terrible lancé par un Puissant Bwork Mage des Cavernes de la pire espèce.",ep:3,g:140,l:90,wd:true,fm:true,w:5,p:0};
I.u[471] = {n:"Bois d\'Erable",t:38,d:"Les feuilles d\'Erable ont permis à des gens peu inspirés de se faire un drapeau original, le sirop d\'Erable a permis de donner du goût aux crêpes. Quant à son bois, on cherche encore à quoi il peut bien servir.",ep:1,g:153,l:40,wd:true,fm:true,w:5,p:0};
I.u[472] = {n:"Bois de Charme",t:38,d:"Le Bois de Charme doit son nom aux Sadidas, qui s\'accouplent toujours sous les Charmes, pour des raisons qui ne sont révélées que dans le livre du Bwork Mage.",ep:1,g:138,l:80,wd:true,fm:true,w:5,p:0};
I.u[473] = {n:"Bois de Châtaignier",t:38,d:"L\'odeur du Bois de Châtaignier repousse les mouches, sauf celles qui aiment les châtaignes et celles qui ont perdu l\'odorat, ce qui explique pourquoi l\'odeur du bois de Châtaignier ne repousse en fait aucune mouche.",ep:1,g:86,l:10,wd:true,fm:true,w:5,p:0};
I.u[474] = {n:"Bois de Merisier",t:38,d:"Ce bois est recherché en ébénisterie du fait de sa texture compacte et de sa couleur brun rougeâtre qu\'il acquiert avec le temps.",ep:1,g:139,l:60,wd:true,fm:true,w:5,p:0};
I.u[476] = {n:"Bois de Noyer",t:38,d:"Le Bois de Noyer est très utilisé pour confectionner des meubles. Pour des raisons obscures, certains charpentiers se refusent à l\'utiliser pour leurs bateaux.",ep:1,g:95,l:20,wd:true,fm:true,w:5,p:0};
I.u[477] = {n:"Sang de Dragon Cochon",t:15,d:"Cette fiole est remplie d\'un sang qui conférait au Dragon Cochon des pouvoirs diaboliques. À consommer avec modération, ou à faire cuire si vous aimez le boudin noir de Dragon Cochon.",ep:2,g:544,l:70,wd:true,fm:true,w:10,p:100};
I.u[478] = {n:"Elagueuse de Charme",t:19,d:"Cette hache doit son nom à Woodee la Bûcheronne, qui savait user de ses charmes pour détourner l\'attention des autres Bûcherons et ainsi garder secret l\'emplacement des rares Charmes dont elle voulait préserver l\'existence.",ep:7,g:3,l:47,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,40,40,false,false],c:"CW>20&CI>20&CC>20",p:5900};
I.u[479] = {n:"Ivoire",t:47,d:"L\'Ivoire est très recherché par les collectionneurs, pour sa blancheur légendaire, et par les Forgerons, pour sa capacité à rendre les armes mortelles. Ce qui est certain, c\'est que dans la région d\'Amakna, l\'Ivoire a vraiment la côte.",ep:1,g:88,l:40,wd:true,fm:true,w:10,p:100};
I.u[480] = {n:"Minerai Etrange",t:39,d:"Ce Minerai a été extrait d\'une mystérieuse carrière inconnue. Contrairement à tous les objets étranges d\'Amakna, celui-ci n\'est pas magique du tout.",ep:1,g:90,l:24,wd:true,fm:true,w:5,p:100};
I.u[481] = {n:"Crâne du Dragon Cochon",t:47,d:"Malgrès sa faible contenance, ce crâne est une vraie pièce de collection, sa relative ressemblance avec un crâne de Iop, a permis à de nombreux étudiants en médecine d\'expliquer l\'origine des faiblesses intellectuelles de certains Iop.",ep:2,g:91,l:70,wd:true,fm:true,w:50,p:100};
I.u[482] = {n:"Pelle Teuze",t:8,d:"Après une soirée un peu trop arrosée à la taverne qui a débouché sur une bagarre, un Enutrof s\'est aperçu que cette pelle conçue à l\'origine pour les grands travaux de construction était une excellente arme.",ep:1,g:8,l:27,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>7&CC>20",p:2200};
I.u[483] = {n:"Grande Pelle Teuze",t:8,d:"Après une soirée un peu trop arrosée à la taverne qui a débouché sur une bagarre, un Enutrof s\'est aperçu que cette pelle conçue à l\'origine pour les grands travaux de construction était une excellente arme.",ep:1,g:8,l:29,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>9&CC>20",p:2500};
I.u[484] = {n:"Puissante Pelle Teuze",t:8,d:"Après une soirée un peu trop arrosée à la taverne qui a débouché sur une bagarre, un Enutrof s\'est aperçu que cette pelle conçue à l\'origine pour les grands travaux de construction était une excellente arme.",ep:1,g:8,l:31,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>11&CC>20",p:2800};
I.u[485] = {n:"Slip en cuir du Chafer Lancier",t:56,d:"Lorsque vient l\'hiver, le Chafer Lancier ne sort jamais sans son slip en cuir, qui lui permet de garder ses articulations bien au chaud ou de distraire ses adversaires le cas échéant.",ep:1,g:152,l:44,wd:true,fm:true,w:10,p:100};
I.u[486] = {n:"Cuir de Sanglier",t:56,d:"Ce cuir est particulièrement résistant, mais sent le sanglier mâle en rût, ce qui explique pourquoi les paysans locaux s\'en servent pour piéger les femelles sangliers, qui sont trop stupides pour déjouer un stratagème si fourbe.",ep:1,g:16,l:14,wd:true,fm:true,w:10,p:1};
I.u[487] = {n:"Cuir du Dragon Cochon",t:56,d:"À force de se prendre pour un Dragon, le Dragon Cochon s\'est brûlé les poils de la couenne, ce qui explique en partie l\'odeur de cochon grillé que dégage ce cuir.",ep:2,g:142,l:70,wd:true,fm:true,w:10,p:6000};
I.u[489] = {n:"Loupe",t:20,d:"La loupe permet d\'examiner avec attention les éléments du décor pour y déceler des trésors.",ep:1,g:3,l:1,wd:true,fm:true,w:10,an:3,e:[1,6,1,1,100,10,false,false],p:10};
I.u[491] = {n:"Sertisseur",t:5,d:"Cet objet permet au Bijoutier de travailler ses joailleries.",ep:1,g:16,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[492] = {n:"Le Pétrisseur",t:20,d:"Outil indispensable si vous voulez exercer le métier de boulanger-pâtissier.",ep:1,g:1,l:1,wd:true,fm:true,w:8,an:4,tw:true,e:[50,6,1,1,500,10,false,false],p:10};
I.u[493] = {n:"Marteau de Forgeur de Marteaux",t:7,d:"Outil indispensable à la création de marteaux.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[494] = {n:"Marteau de Forgeur d\'Epées",t:7,d:"Outil indispensable à la création d\'épées.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[495] = {n:"Marteau de Forgeur de Dagues",t:7,d:"Outil indispensable à la création de dagues.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[496] = {n:"Marteau de Forgeur de Pelles",t:7,d:"Outil indispensable à la création de pelles.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[497] = {n:"Pioche du Mineur",t:21,d:"Outil indispensable à la collecte des minerais.",ep:1,g:1,l:1,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[498] = {n:"Tailladeuse de Bâton",t:5,d:"Outil indispensable à la création des bâtons.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[499] = {n:"Tailladeuse de Baguette",t:5,d:"Outil indispensable à la création des baguettes.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[500] = {n:"Tailladeuse d\'Arc",t:5,d:"Outil indispensable à la création des arcs.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[501] = {n:"Sève d\'Abraknyde Retravaillée",t:15,d:"Cette sève sirupeuse a été retravaillée par un Alchimiste de renom, pour lui permettre de redonner vie aux Racines d\'Abraknydes. De toute évidence, ce genre de sève ne doit être manipulée que par des mains expertes.",ep:2,g:162,l:30,wd:true,fm:true,w:2,p:50};
I.u[502] = {n:"Trancheuse d\'If",t:19,d:"Cette hache est une des seules à pouvoir couper des arbres envoûtés, on peut donc par extension, affirmer qu\'elle peut trancher tout ce qui est envoûté, vivant ou non.",ep:1,g:4,l:17,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,50,false,false],c:"CS>10&CI>35",p:950};
I.u[515] = {n:"Boulgourde des Clairières",t:19,d:"Cette hache a appartenu à Brouce Boulgoure le fameux Bûcheron, marié jadis avec Kassiopée Baine, fille d\'un autre grand Bûcheron. Cette arme lui permit de se défendre maintes fois lorsqu\'il partait la nuit couper des forêts entières.",ep:7,g:5,l:62,wd:true,fm:true,w:60,an:17,tw:true,e:[15,6,1,1,50,40,false,false],c:"CI>124&CC>30&CV>10",p:10100};
I.u[519] = {n:"Poudre de Perlinpainpain",t:48,d:"Comme son nom l\'indique cette poudre est faite à partir de graines de Lin et de Pain. Mais ça n\'explique pas pourquoi cette poudre est magique.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[520] = {n:"Pain aux Graines de Pavot",t:33,d:"La confection de ce pain est délicate, car les boulangers qui en respirent les fumées lors de la cuisson, sont victimes de symptômes étranges et se mettent à danser autour de leur boulangerie.",ep:1,g:10,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[521] = {n:"Pain aux Graines de Sésame",t:33,d:"Les Kwaks les plus audacieux n\'hésitent pas à se déguiser en boulanger pour subtiliser les Graines de Sésame, mais cette supercherie ne fonctionne jamais sauf chez les Iop Boulangers.",ep:1,g:11,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[522] = {n:"Pain aux Graines de Lin",t:33,d:"Ce pain est riche en protéines, mais pauvre en goût. Et oui, la vie est toujours une question de choix.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[524] = {n:"Pain aux Noisettes",t:33,d:"Ce pain au goût subtil est garanti sans colorants, ni conservateurs, tout le contraire de la Gelée Royale.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[526] = {n:"Pain aux Céréales",t:33,d:"Ce pain composé d\'une variété de céréales sans précédent, est suffisamment riche en protéines pour rendre la vie à un Chafer.",ep:1,g:6,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[527] = {n:"Pain aux Noix",t:33,d:"Ce pain est cuit avec du bois de Noyer et les noix sont grillées avant d\'être fourrées dans la mie.",ep:4,g:8,l:40,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[528] = {n:"Pain au Blé Complet",t:33,d:"Ce pain est enrichi en blé complet, ce qui en fait un pain de qualité pour les gens exigeants.",ep:1,g:7,l:20,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[529] = {n:"Farine d\'Orge",t:52,d:"Cette farine s\'obtient au moulin, en écrasant des grains d\'orge, elle permet de donner une légèreté à la mie de pain qui n\'a pas d\'équivalent, à moins, bien entendu, de faire emploi d\'une magie occulte lors de la cuisson de vos pains.",ep:1,g:256,l:1,wd:true,fm:true,w:2,p:0};
I.u[530] = {n:"Farine de Seigle",t:52,d:"Cette farine hérite de tous les bienfaits du Seigle. Selon la légende, le Seigle qui germe à l\'aurore, ne mûrit jamais. Par extension, certains paysans font leur enfants à l\'aurore en espérant qu\'ils ne vieillissent jamais.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[531] = {n:"Farine d\'Avoine",t:52,d:"Cette farine ne lève pas à la cuisson, ce qui permet de faire des pains vraiment denses, particulièrement utiles lorsqu\'il faut distribuer des pains aux monstres.",ep:1,g:250,l:1,wd:true,fm:true,w:2,p:0};
I.u[532] = {n:"Seigle",t:34,d:"Cette céréale sombre a la faculté de pousser dans des conditions difficiles, c\'est une des rares céréales à subsister après de fortes sécheresses.",ep:1,g:82,l:50,wd:true,fm:true,w:2,p:0};
I.u[533] = {n:"Avoine",t:34,d:"Cette céréale est utilisée pour nourrir les jeunes Tabis, lorsqu\'ils n\'ont pas encore les dents assez solides pour ruminer. Les paysans font tout de même attention dans la mesure où l\'avoine cause parfois des crises d\'aérophagie chez le bétail sensible.",ep:1,g:154,l:20,wd:true,fm:true,w:2,p:0};
I.u[534] = {n:"Farine de Malt",t:52,d:"Cette farine blanche est obtenue en écrasant des grains d\'Orge germés, ce qui donne un goût parfois acidulé au pain, et dans le meilleur des cas, un goût de bière éventée, utile pour les sevrages progressifs des amateurs de bière. Une fois cuite, cette farine permet en effet de mieux supporter les cuites.",ep:1,g:255,l:1,wd:true,fm:true,w:2,p:0};
I.u[535] = {n:"Farine de Houblon",t:52,d:"Cette farine permet de donner un délicieux goût de bière au pain, sans avoir à utiliser de la bière pour faire son pain. Il faut parfois reconnaître que la nature est bien faite.",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[536] = {n:"Pain aux Flocons d\'Avoine",t:33,d:"Ce pain à la mie particulièrement légère est parfait pour les personnes qui n\'ont pas été gâtées par Mère Nature, et qui n\'ont qu\'un tout petit estomac.",ep:1,g:5,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[537] = {n:"Pomme de Terre",t:68,d:"De manière générale, lorsque vous tombez sur cet objet, c\'est que vous êtes soit au milieu d\'un champ, soit au fond d\'un cachot.",ep:1,g:135,l:1,wd:true,fm:true,w:20,p:10};
I.u[538] = {n:"Pommes de Terre épluchées",t:68,d:"Cette Pomme de terre est dépourvue de sa pelure, ce qui en fait une denrée commestible.",ep:1,g:136,l:1,wd:true,fm:true,w:20,p:10};
I.u[539] = {n:"Pain de Seigle",t:33,d:"Ce pain est fait à partir de farine de Seigle, ce qui lui donne à la mie, une couleur brune particulière, mais surtout un léger goût sucré.",ep:1,g:9,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[543] = {n:"Pierre de Diamant",t:51,d:"Correctement polie, cette pierre peut donner un magnifique Diamant.",ep:1,g:144,l:30,wd:true,fm:true,w:20,p:15};
I.u[544] = {n:"Pierre d\'Emeraude",t:51,d:"Correctement polie, cette pierre peut donner une magnifique Emeraude.",ep:1,g:145,l:30,wd:true,fm:true,w:20,p:15};
I.u[545] = {n:"Pierre de Cristal",t:51,d:"Correctement polie, cette pierre peut donner un magnifique Cristal.",ep:1,g:141,l:30,wd:true,fm:true,w:20,p:15};
I.u[546] = {n:"Pierre de Saphir",t:51,d:"Correctement polie, cette pierre peut donner un magnifique Saphir",ep:1,g:151,l:30,wd:true,fm:true,w:20,p:15};
I.u[547] = {n:"Pierre de Rubis",t:51,d:"Correctement polie, cette pierre peut donner un magnifique Rubis.",ep:1,g:150,l:30,wd:true,fm:true,w:20,p:15};
I.u[548] = {n:"Potion de Rappel",t:12,d:"Cette potion permet de revenir au dernier point de sauvegarde.",ep:1,g:17,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[577] = {n:"Faux du Paysan",t:22,d:"Cette faux n\'est pas très aiguisée et surtout un peu rouillée, ce qui en fait une arme peu dangereuse. En revanche, pour faucher, c\'est l\'outil idéal.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[578] = {n:"Pierre à Aiguiser",t:51,d:"Je ne vous jette pas la pierre Pierre !",ep:2,g:127,l:1,wd:true,fm:true,w:20,p:1};
I.u[579] = {n:"Coupe Cuir",t:5,d:"Outil indispensable à la création de chaussures et de ceintures.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[580] = {n:"Potion Ghetto Raide",t:12,d:"Cette potion permet de retrouver quelques points d\'énergie.",ep:1,g:18,l:10,wd:true,fm:true,w:1,u:true,p:20};
I.u[582] = {n:"Farine Blanche",t:52,d:"Cette farine nécessite plusieurs céréales pour être obtenue, elle est cependant très appréciée pour sa qualité panifiable. Et pourtant au premier regard, rien ne la distingue d\'une farine classique.",ep:1,g:7,l:1,wd:true,fm:true,w:2,p:0};
I.u[583] = {n:"Farine Bise",t:52,d:"Cette farine mi-blanche tire son nom de son inventeur, une jolie paysanne qui aimait faire des bises, les joues pleines de farine. Quelle coquine.",ep:1,g:7,l:20,wd:true,fm:true,w:2,p:0};
I.u[586] = {n:"Farine Paysanne",t:52,d:"C\'est en affrontant la femme de Brouce Boulgoure à coups de sacs de farine, que Shika Ingalsse a eu l\'idée de créer cette farine devenue populaire. Les combats de femmes apportent parfois beaucoup plus que de la distraction pour la plèbe.",ep:1,g:258,l:30,wd:true,fm:true,w:2,p:0};
I.u[587] = {n:"Farine Complète",t:52,d:"Cette farine est issue d\'une multitude de céréales, ce qui en fait une farine particulièrement complète, très utile pour les pains complets.",ep:1,g:259,l:40,wd:true,fm:true,w:2,p:0};
I.u[592] = {n:"Corde d\'Ivan Nowé",t:2,d:"Cet arc a appartenu à Ivan Nowé, un Crâ téméraire, qui a pourfendu plus d\'un Tofu égaré. Cet arc a la particularité de faire des coups pour le moins surprenants qui laissent perplexes puis agonisants les ennemis.",ep:7,g:1,l:36,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,15,50,false,true],c:"CS>30&CA>36",p:3600};
I.u[593] = {n:"Orchidée Freyesque",t:35,d:"Cette fleur est d\'une rareté et d\'une beauté inimaginable, mais elle est presque introuvable. En effet, les Crapauds ont tendance à les ramener dans leur campement pour nourrir leur progéniture.",ep:1,g:192,l:40,wd:true,fm:true,w:1,p:0};
I.u[594] = {n:"Edelweiss",t:35,d:"Cette fleur est d\'une rareté et d\'une beauté inimaginable, mais elle est presque introuvable. Pour cause, sa magie est si puissante qu\'elle serait capable de faire revivre certains morts.",ep:1,g:191,l:50,wd:true,fm:true,w:1,p:0};
I.u[596] = {n:"Canne à Pêche Courte",t:20,d:"Cette petite canne à pêche est idéale pour s\'amuser à pêcher les petits poissons dans les mares d\'eau.",ep:1,g:8,l:1,wd:true,fm:true,w:1,an:18,e:[1,4,1,1,100,100,false,false],p:200};
I.u[597] = {n:"Filet simple de capture",t:99,d:"Ce filet très résistant permet de capturer la plus sauvage des montures, à condition d\'avoir réussi à l\'hypnotiser ou à la distraire un peu avant.",ep:20,g:1,l:1,wd:true,fm:true,w:1,an:0,p:10};
I.u[598] = {n:"Greu-Vette",t:41,d:"Les Greu-Vettes sont appréciées pour leur couleur rose et leur goût raffiné. Elles sont cependant détestées pour leur mauvais caractère légendaire et leurs antennes gominées.",ep:1,g:292,l:1,wd:true,fm:true,w:1,p:10};
I.u[600] = {n:"Kralamoure",t:41,d:"Le Kralamoure est un grand romantique, ses yeux de petit Tofu lui donnent un air un peu niais, mais ne vous y méprenez pas, le Kralamoure est très agressif envers les étrangers.",ep:2,g:309,l:20,wd:true,fm:true,w:1,p:10};
I.u[602] = {n:"Requin Marteau-Faucille",t:41,d:"Ce Requin rouge est un requin militant, d\'instinct grégaire, l\'individu n\'existe pas au sein du groupe, même si leur chef, le Requin Stakanoviou est porté au rang d\'idole.",ep:2,g:322,l:80,wd:true,fm:true,w:2,p:1};
I.u[603] = {n:"Poisson Chaton",t:41,d:"Ce poisson a la particularité d\'avoir des moustaches et de ronronner sous l\'eau, ce qui ne manque pas de faire peur aux Poissons Volants.",ep:1,g:277,l:1,wd:true,fm:true,w:1,p:50};
I.u[607] = {n:"Truite Vaseuse",t:41,d:"La Truite Vaseuse est une cousine éloignée du Saumoon agressif de l\'île de Moon. Cette truite est aussi bonne cuite que crue, qui l\'eut cru ?",ep:1,g:395,l:1,wd:true,fm:true,w:1,p:50};
I.u[610] = {n:"Amulette en Crabe",t:1,d:"Cette amulette blanchâtre est confectionnée avec du Crabe, ce qui en fait une amulette très fragile mais originale.",ep:1,g:30,l:24,wd:true,fm:true,w:2,p:1800};
I.u[616] = {n:"Amulette du Marin",t:1,d:"Cette amulette, sertie d\'écailles de poisson, est censée porter chance à son propriétaire lorsqu\'il part en mer les jours de tempête.",ep:1,g:29,l:22,wd:true,fm:true,w:2,p:2000};
I.u[617] = {n:"Amulette du Pirate",t:1,d:"Cette amulette terrifiante a impressionné plus d\'un marin, la porter sur soi suffit à faire de vous une personne redoutée.",ep:1,g:20,l:41,wd:true,fm:true,w:2,p:4500};
I.u[619] = {n:"Bâton du Maître des Bouftous",t:4,d:"Ce bâton permettait à Farle Ingalsse, éleveur de Bouftous, d\'invoquer plus facilement des Tofus gardiens de troupeaux. Au fil du temps, ce bâton s\'est révélé être une excellente arme de combat.",ep:7,g:6,l:85,wd:true,fm:true,w:20,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>60&CW>20&CA>40",p:10000};
I.u[620] = {n:"Découpeuse de Kralamoure",t:6,d:"Cette épée a permis au célèbre marin Mobby Diqueriveurse, de découper en tranches, les tentacules du célèbre Kralamoure Géant de l\'île de Moon, réputé pour étouffer les marins saouls et saouler les marins étouffés.",ep:1,g:8,l:61,wd:true,fm:true,w:50,an:14,e:[10,7,1,1,50,50,false,false],c:"CV>60&CW>60",p:9900};
I.u[629] = {n:"Chapeau Pointu",t:16,d:"Ce magnifique chapeau permettra à votre héros d\'être la plus belle pour aller danser au bal masqué (hohé hohé).",ep:5,g:1,l:21,wd:true,fm:true,w:5,p:1400};
I.u[638] = {n:"Amulette du Pêcheur de Somoon",t:1,d:"Pêcher un Somoon relève de l\'exploit, mais avec cette amulette sur soi, plus rien n\'est impossible.",ep:12,g:24,l:35,wd:true,fm:true,w:5,p:2500};
I.u[639] = {n:"Amulette des Abîmes",t:1,d:"Cette amulette a été retrouvée dans l\'épave échouée du célèbre pêcheur de Kralamoure, Moby Diqueriveurse, qui était également populaire pour ses boutades vaseuses au bar des pirates.",ep:14,g:22,l:47,wd:true,fm:true,w:5,p:6000};
I.u[640] = {n:"Arc des Rivages",t:2,d:"Cet arc permettait aux pêcheurs de nettoyer les rivages de toute la vermine environnante sans avoir à se lever de leur siège, et cela depuis la fenêtre du bar des pirates.",ep:14,g:38,l:46,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,10,30,45,false,true],c:"CA>46",p:5600};
I.u[641] = {n:"Coton Ancestral",t:15,d:"Ce Coton est doux comme le pelage d\'une jeune Ecaflipette, blanc comme un nuage de printemps, mais fragile comme une plume de Tofu.",ep:1,g:657,l:6,wd:true,fm:true,w:1,p:500};
I.u[642] = {n:"Cocon de Ver à Soie",t:15,d:"Cet énorme cocon blanchâtre, peut être déroulé pour obtenir un magnifique fil de soie. \nL\'aventurier Harry Hane l\'aurait même utilisé pour pouvoir sortir du labyrinthe du Dark Vlad.",ep:1,g:489,l:6,wd:true,fm:true,w:1,p:100};
I.u[643] = {n:"Fil de Soie",t:15,d:"Ce fil est d\'une finesse et d\'une souplesse sans équivalent. C\'est de loin la matière préférée du Chafer dès qu\'il s\'agit de s\'équiper en sous-vêtements de combat.",ep:1,g:486,l:5,wd:true,fm:true,w:1,p:100};
I.u[646] = {n:"Poils de Black Tiwabbit",t:54,d:"Ce poil tout noir à l\'avantage ne de pas être salissant, ce qui ne manquera pas d\'intéresser les héros peu portés sur l\'hygiène et la coquetterie. Attention cependant, ce poil a tendance à déteindre au contact d\'une sueur abondante et corrosive.",ep:8,g:195,l:11,wd:true,fm:true,w:1,p:50};
I.u[648] = {n:"Poils de Wabbit",t:54,d:"Ce poil n\'est pas très prisé par les Tailleurs expérimentés qui lui préfèrent le poil des autres Wabbits, mais il a le mérite de faire fuir les Moskitos à cause de son odeur de Citronnelle Sauvage.",ep:8,g:196,l:18,wd:true,fm:true,w:1,p:1};
I.u[649] = {n:"Poils de Wo Wabbit",t:54,d:"Ce poil est si gras, qu\'il permet de garder les étoffes imperméables aux intempéries.",ep:8,g:197,l:39,wd:true,fm:true,w:1,p:40};
I.u[650] = {n:"Poils de Grand Pa Wabbit",t:54,d:"Ce poil malodorant est délicat à utiliser en couture à cause de sa tendance à friser au contact du jus de Cawotte.",ep:8,g:198,l:39,wd:true,fm:true,w:1,p:50};
I.u[651] = {n:"Etoffe du Mulou",t:55,d:"Cette étoffe en Poils de Mulou est très rare, mais sa constitution lui permet de résister à toutes formes d\'agressions physiques et parfois même magiques.",ep:1,g:199,l:70,wd:true,fm:true,w:1,p:100};
I.u[652] = {n:"Etoffe du Sanglier",t:55,d:"Cette étoffe en Poils de Sanglier est rugueuse et malodorante, mais protège efficacement des attaques physiques.",ep:1,g:220,l:13,wd:true,fm:true,w:1,p:50};
I.u[653] = {n:"Etoffe du Prespic",t:55,d:"Sous ses pics, le Prespic dispose d\'une fourrure rousse très douce, qui dégage une odeur désagréable lorsqu\'il pleut. Heureusement pour vous, il ne pleut jamais en Amakna, mais évitez d\'utiliser cette étoffe pour vous confectionner un caleçon de bain.",ep:1,g:661,l:17,wd:true,fm:true,w:1,p:100};
I.u[654] = {n:"Etoffe du Wabbit",t:55,d:"Cette étoffe en Poils de Barbe du Grand Pa Wabbit est très touffue, mais également irritante, un peu comme une grosse chenille urticante.",ep:8,g:15,l:18,wd:true,fm:true,w:1,p:100};
I.u[657] = {n:"Bâton du Maître des Tofus",t:4,d:"Ce bâton permettait à Shika Ingalsse, éleveuse de Tofus, d\'invoquer plus facilement des Tofus gardiens de troupeaux. Au fil du temps, ce bâton s\'est révélé être une excellente arme de combat.",ep:7,g:6,l:56,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>40&CW>10&CS>30",p:5600};
I.u[658] = {n:"Bâton du Maître des Tabis",t:4,d:"Ce bâton permettait à Gramine Ingalsse, éleveuse de Tabis, d\'invoquer plus facilement des Tofus gardiens de troupeaux. Au fil du temps, ce bâton s\'est révélé être une excellente arme de combat.",ep:7,g:6,l:34,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>20&CW>5",p:3400};
I.u[666] = {n:"Purée pique-fêle",t:15,d:"A l\'origine synonyme de l\'échec culinaire, ce plat est donné dès qu\'une erreur se fait sentir, quelle que soit son origine.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:0};
I.u[673] = {n:"Mangeuse de Châtaignier",t:19,d:"Cette hache n\'a rien de particulier si ce n\'est que la légèreté naturelle du Bois de Châtaignier, permet à cette hache d\'avoir un manche aussi léger qu\'une plume de jeune Tofu Maléfique.",ep:1,g:6,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>8&CA>3",p:400};
I.u[674] = {n:"Fendeuse de Merisier",t:19,d:"\"Cette hache a tout pour plaire\" disait le fameux slogan de Brouce Boulgoure le célèbre bûcheron. En effet, son manche en Bois de Merisier permet d\'amortir les vibrations lors de l\'abattage des arbres ou des bworks au crâne un peu trop solide.",ep:1,g:7,l:32,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>40",p:2900};
I.u[675] = {n:"Trancheuse de Noyer",t:19,d:"Cette hache à l\'aspect rudimentaire, n\'en est pas moins efficace. C\'est avec cet outil que Brouce Boulgoure le Bûcheron a gagné le concours de tranchage de Bworks nains. Voilà qui en dit long sur l\'efficacité de cette hache.",ep:1,g:8,l:21,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>30",p:1350};
I.u[676] = {n:"Mangeuse d\'Erable",t:19,d:"Cette hache a la particularité de ne jamais rouiller, pour éviter de désagréables surprises lorsque les Bûcherons gourmands décident de lécher le sirop d\'érable sur la lame après une éprouvante journée d\'abattage d\'érables.",ep:1,g:10,l:25,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CA>30",p:1850};
I.u[677] = {n:"Cape du Pirate",t:17,d:"Cette cape a appartenu à un vieux pirate du nom de Zokrim. Il devait être plutôt malchanceux...",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:1};
I.u[678] = {n:"Parchemin d\'Ivoire",t:13,d:"(Double clic pour gagner de l\'expérience) \nCe parchemin permet de gagner de l\'expérience sans prendre de risques.",ep:1,g:3,l:25,wd:true,fm:true,w:1,u:true,p:1};
I.u[679] = {n:"Parchemin Blanc",t:13,d:"(Double clic pour gagner de l\'expérience) \nCe parchemin permet de gagner de l\'expérience sans prendre de risques.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[680] = {n:"Parchemin Doré",t:13,d:"(Double clic pour gagner de l\'expérience) \nCe parchemin permet de gagner de l\'expérience sans prendre de risques.",ep:1,g:3,l:50,wd:true,fm:true,w:1,u:true,p:1};
I.u[683] = {n:"Petit Parchemin de Force",t:76,d:"(Double clic pour gagner de la force) \nCe parchemin permet de gagner de la force de manière définitive sans prendre de risque. \nAttention cependant, vous ne pourrez l\'utiliser que si votre force est inférieure à 25.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<25",u:true,p:1000};
I.u[684] = {n:"Parchemin de Sorts",t:76,d:"(Double clic pour gagner des Points de Sorts) \nCe parchemin permet de gagner des Points de Sorts de manière définitive sans prendre de risques.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:15000};
I.u[686] = {n:"Petit Parchemin d\'Intelligence",t:76,d:"(Double clic pour gagner des Points d\'Intelligence) \nCe parchemin permet de gagner des Points d\'Intelligence de manière définitive sans prendre de risques. \nAttention cependant, vous ne pourrez l\'utiliser que si votre intelligence est inférieure à 25.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<25",u:true,p:1000};
I.u[690] = {n:"Farine de Lin",t:52,d:"Cette farine est très étrange, car elle est n\'est pas issue d\'une céréale, ce qui explique pourquoi elle ne ressemble à aucune autre farine.",ep:1,g:254,l:1,wd:true,fm:true,w:2,p:0};
I.u[692] = {n:"Pain Consistant",t:33,d:"Ce pain est fait à partir de Farine de Lin, ce qui explique pourquoi il est si gras, et pourquoi sa mie est brune. Très riche en huiles essentielles, il faut cependant avouer qu\'il a très mauvais goût.",ep:1,g:12,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[694] = {n:"Dofus Pourpre",t:23,d:"C\'est le Dragon du Feu Ignemikhal qui créa le Dofus Pourpre, un Œuf dont le moins qu\'on puisse dire, c\'est qu\'il sent le soufre - mais il sent bien d\'autres choses encore...",ep:1,g:1,l:6,wd:true,fm:true,w:5,p:500000};
I.u[695] = {n:"Parchemin de Bûcheron",t:13,d:"(Double clic pour gagner des Points d\'expérience)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[696] = {n:"La Coiffe du Ploukosse",t:16,d:"La Coiffe du Ploukosse, sous ses dehors \"has been\", est très efficace lors des combats pour un simple chapeau de paille.",ep:1,g:2,l:20,wd:true,fm:true,w:4,p:1300};
I.u[697] = {n:"Makroute",t:16,d:"Makroute est un chien très affectueux... Le problème, c\'est que lorsqu\'il trouve un nouveau copain, il ne le lâche plus... Il a bien dû se faire 30 millions d\'amis de cette façon...",ep:2,g:3,l:6,wd:true,fm:true,w:6,p:30000};
I.u[698] = {n:"Choipo Podlard",t:16,d:"Le Choipo Podlard vient d\'une grande école de magie. Créature vivante, il a rencontré les plus grands magiciens de notre temps, tels que Mme Magoa AlaGale, Mr Doublegore et le célèbre Remy Krokeur.",ep:1,g:4,l:33,wd:true,fm:true,w:6,p:3000};
I.u[699] = {n:"Le Troma",t:16,d:"Le Troma est aussi craignos qu\'un Rasboul en poil de Bitouf. (Pour ceux qui ne savent pas ce qu\'est un Rasboul en poil de bitouf, référez-vous aux grands livres des Craps à Poules).",ep:1,g:5,l:22,wd:true,fm:true,w:10,p:1525};
I.u[700] = {n:"Pandawa",t:16,d:"Ah le Pandawa, vraiment quelle grosse tête il a. Comme son pote Makroute, il passe son temps sur la tête de son maître. Nul besoin de se déplacer, lorsqu\'il est motivé, il arrive même à subtiliser la nourriture de son porteur.",ep:2,g:6,l:6,wd:true,fm:true,w:10,c:"PG!10",p:12000};
I.u[701] = {n:"Le Oiram",t:16,d:"Le Oiram a fait de nombreux adeptes de part le monde, du fait de son côté très classieux... Ce chapeau a longtemps été porté par un plombier qui passait son temps à sauter et courir...",ep:1,g:7,l:22,wd:true,fm:true,w:12,c:"PG!10",p:1525};
I.u[702] = {n:"Kritter",t:16,d:"Ce crâne de démon reconstruit à partir d\'ossements divers et variés apporte grâce et élégance à son porteur... Vos amies vont vous jalouser...",ep:1,g:8,l:30,wd:true,fm:true,w:9,c:"PG!10",p:2600};
I.u[703] = {n:"Dora",t:16,d:"Ce chapeau, en forme de corbeille à fruits en osier renversée, est en fait une corbeille à fruits renversée magique. Ce qui ne manquera pas d\'impressionner votre entourage, surtout s\'il est composé d\'apprentis Bworks Mages.",ep:2,g:9,l:36,wd:true,fm:true,w:20,p:3550};
I.u[704] = {n:"Dantgoule",t:16,d:"Ce chapeau, confectionné à partir de Slips en cuir de Chafer Lancier tressés entre eux, vous rendra de toute évidence irrésistible auprès des femelles Bwork Mages, réputées pour leur féminité débordante, accentuée par leur barbe rousse.",ep:2,g:10,l:36,wd:true,fm:true,w:10,p:3550};
I.u[705] = {n:"Masque Tromatisant",t:16,d:"Si vous voulez être traumatisé, il vous faut absolument cette magnifique noix de coco trouée. Nous rappelons à l\'utilisateur que l\'intérieur est équipé d\'une paille et de boissons rafraîchissantes.",ep:12,g:11,l:47,wd:true,fm:true,w:10,p:6000};
I.u[706] = {n:"Crystal O\'Boul",t:16,d:"Hugne \"le sans mémoire\" possédait une magnifique boule de crystal que lui avait donné son pépé. Bien décidé à la conserver toute sa vie, il la plaça sur son chapeau, qu\'il ne quittait jamais... Il est mort de fatigue, en essayant de la retrouver.",ep:4,g:12,l:24,wd:true,fm:true,w:12,s:38,p:1775};
I.u[707] = {n:"Minotokorno",t:16,d:"Ce chapeau en Corne de Minotoror est très efficace pour impressionner ses adversaires en se faisant passer pour un Minotoror. Cette ruse ne semble fonctionner que sur les adversaires simplets. Un Iop ou un Tofu devrait faire l\'affaire.",ep:2,g:13,l:33,wd:true,fm:true,w:10,s:54,p:3000};
I.u[708] = {n:"Houde",t:16,d:"Ce chapeau en peau de larve verte magique donne à son porteur une allure guillerette, mais également un peu stupide. On ne peut pas tout avoir dans la vie, le porteur de ce chapeau en est d\'ailleurs un excellent exemple.",ep:1,g:14,l:30,wd:true,fm:true,w:8,p:2525};
I.u[709] = {n:"Lorko Kasko",t:16,d:"Ce chapeau en écorce enchantée appartenait à Lorko, un Bûcheron réputé qui n\'a pas hésité à défier le célèbre Bûcheron Brouce Boulgoure, lors d\'un fameux duel de déracinage d\'Orme à mains nues dans la clairière de Liroye Merline.",ep:9,g:15,l:37,wd:true,fm:true,w:9,c:"PG!10",p:3825};
I.u[710] = {n:"Korko Klako",t:16,d:"Lo Korko Klako ost ouno chapo kilo bo. Tros ostotiko, tros bolo, il so porto par los plus bo dos Sadida.",ep:1,g:16,l:17,wd:true,fm:true,w:9,c:"PG=10",p:1000};
I.u[711] = {n:"Jouik Krampe",t:16,d:"Ce magnifique masque en cuir appartenait à Jouik Krampe, cousin de Zeurg. Tous deux étaient très portés sur les vêtements en cuir moulant. Un peu comme le Captain Chafer, la perversité en moins.",ep:8,g:17,l:26,wd:true,fm:true,w:15,c:"PG=10",p:2025};
I.u[712] = {n:"Gulliver",t:16,d:"Ce chapeau confectionné à partir d\'oreilles cousues entre elles, vous rendra tout simplement unique tant il est original. On raconte qu\'il a jadis permis à Rakmar Bilgout de séduire la reine des Bouftous, pour ensuite l\'égorger plus facilement.",ep:13,g:18,l:33,wd:true,fm:true,w:10,p:3075};
I.u[713] = {n:"Parchemin de Forgeur d\'épée",t:13,d:"(Double clic pour gagner des Points d\'expérience)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[714] = {n:"Parchemin de Forgeur de dagues",t:13,d:"(Double clic pour gagner des Points d\'expérience)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[715] = {n:"Parchemin de Sculpteur d\'arcs",t:13,d:"(Double clic pour gagner des Points d\'expérience)",ep:4,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[716] = {n:"Parchemin de Sculpteur de bâtons",t:13,d:"(Double clic pour gagner des Points d\'expérience)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[717] = {n:"Parchemin de Sculpteur de baguettes",t:13,d:"(Double clic pour gagner des Points d\'expérience)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[718] = {n:"Parchemin de Sort Flamiche",t:75,d:"(Double click pour apprendre le sort) \nCe parchemin vous permettra d\'apprendre le sort élémentaire Flamiche.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[719] = {n:"Parchemin de Sort Libération",t:75,d:"(Double click pour apprendre le sort) \nCe parchemin vous permettra d\'apprendre le sort élémentaire Libération.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[720] = {n:"Parchemin de Sort Foudroiement",t:75,d:"(Double click pour apprendre le sort) \nCe parchemin vous permettra d\'apprendre le sort élémentaire Foudroiement.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[721] = {n:"Parchemin de Sort Invocation d\'Arakne",t:75,d:"(Double click pour apprendre le sort) \nCe parchemin vous permettra d\'apprendre le sort d\'invocation d\'Arakne.",ep:16,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[724] = {n:"Sort Maîtrise du Bâton",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant un bâton.",ep:1,g:2,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[725] = {n:"Sort Maîtrise de l\'Epée",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant une épée.",ep:3,g:1,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[726] = {n:"Sort Maîtrise de l\'Arc",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant un arc.",ep:4,g:3,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[727] = {n:"Sort Maîtrise du Marteau",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant un marteau.",ep:1,g:4,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[728] = {n:"Sort Maîtrise de la Baguette",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant une baguette.",ep:1,g:5,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[729] = {n:"Sort Maîtrise des Dagues",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant une dague.",ep:2,g:6,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[730] = {n:"Sort Maîtrise de la Pelle",t:73,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permettra de faire plus de dégâts en utilisant une pelle.",ep:7,g:7,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[731] = {n:"Parchemin de Sort Spécial Brokle",t:75,d:"(Double clic pour apprendre le sort) \nCe parchemin vous permet d\'apprendre le sort Brokle... Réservé aux Iops uniquement.",ep:2,g:4,l:1,wd:true,fm:true,w:1,c:"PG=8",u:true,p:10000};
I.u[732] = {n:"Alliance de Silimelle",t:9,d:"Cette magnifique alliance a été volée à Silimelle la Brasseuse de Bière, lors d\'une soirée un peu trop arrosée à la taverne. Voilà ce qui arrive lorsque l\'on paie des coups à des inconnus...",ep:1,g:30,l:26,wd:true,fm:true,w:1,p:2000};
I.u[733] = {n:"Bottes de Ragalde",t:11,d:"Ragalde était sûrement un des Guerriers Iop les plus téméraires, ces bottes magiques lui ont permis d\'occire bon nombre d\'indésirables.",ep:1,g:7,l:49,wd:true,fm:true,w:1,p:5000};
I.u[734] = {n:"Ceinture de Sécurité",t:10,d:"Cette ceinture permettait aux gardes du Château d\'Amakna de contenir les émeutes et autres débordements lors des fêtes populaires.",ep:1,g:7,l:17,wd:true,fm:true,w:10,p:1000};
I.u[737] = {n:"Dofus Emeraude",t:23,d:"Plus vert qu\'un Tofu malade, le Dofus Emeraude fut créé par Aerafal, le Dragon de l\'Air. Pour créer quelque chose d\'aussi vert, il devait avoir le mal de l\'air. Un comble, non ?",ep:1,g:2,l:6,wd:true,fm:true,w:5,p:500000};
I.u[739] = {n:"Dofus Turquoise",t:23,d:"Le Dofus Turquoise fut créé par Aguabrial, le Dragon de l\'Eau. Quand on y pense, c\'est fou ce qu\'un Dragon peut faire avec de l\'eau...",ep:1,g:3,l:6,wd:true,fm:true,w:5,p:500000};
I.u[742] = {n:"Bâton Cornu",t:4,d:"\"Ce bâton a dû faire, toutes les guerres, pour être aussi fort aujourd\'hui\" tels ont été les derniers mots de Francisque Kabroule, le célèbre Ménestrel Forgeur de Haches, avant de périr écrasé par un œuf de Tofu géant.",ep:1,g:1,l:29,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,200,false,false],c:"CC>20&CI>30",p:2350};
I.u[743] = {n:"Brioche Dorée",t:33,d:"La recette de cette Brioche a été élaborée par Xavier le Boulanger en personne qui voulait en faire une brioche délicieuse et légère à la fois. On peut sans se tromper, dire qu\'il a réussi.",ep:1,g:8,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[744] = {n:"Cape de Bowisse",t:17,d:"Cette cape est comme son porteur, unique en son genre et trop souvent sous-estimée. \nElle est constituée d\'un assemblage de peaux de larves vertes, ce qui lui donne un aspect rugueux des plus sympathique.",ep:1,g:1,l:20,wd:true,fm:true,w:10,p:1275};
I.u[745] = {n:"Lingot d\'Or",t:40,d:"Ce lingot est obtenu en faisant fondre de l\'Or à l\'état brut.",ep:1,g:241,l:10,wd:true,fm:true,w:1,p:0};
I.u[746] = {n:"Ebonite",t:40,d:"Cet alliage très rare permet de fabriquer des objets très rares et souvent mortels. En effet, l\'Ebonite est un métal qui une fois rouillé, devient un véritable poison.",ep:1,g:658,l:20,wd:true,fm:true,w:20,p:0};
I.u[747] = {n:"Aluminite",t:40,d:"Cet alliage est d\'une légèreté impressionnante, ce qui en fait un métal de choix pour les petites dagues ou les épées courtes.",ep:1,g:660,l:10,wd:true,fm:true,w:10,p:0};
I.u[748] = {n:"Magnésite",t:40,d:"Cet alliage original est presque magique, il brille et vibre la nuit, ce qui peut être suffisant pour effrayer un Bwork un peu trop crédule.",ep:1,g:659,l:30,wd:true,fm:true,w:30,p:0};
I.u[749] = {n:"Bakélélite",t:40,d:"Cet alliage n\'est pas des plus solide, mais correctement aiguisé, il devient aussi tranchant que la Lame d\'un Chafer.",ep:1,g:487,l:40,wd:true,fm:true,w:40,p:0};
I.u[750] = {n:"Kouartz",t:40,d:"Cet alliage très étrange est capable de renfermer une énergie impressionnante, le rendant très instable dans certaines conditions. Les meilleurs Forgerons raffolent de cet alliage, qui leur permet de forger des armes aux pouvoirs presque légendaires.",ep:1,g:664,l:60,wd:true,fm:true,w:60,p:0};
I.u[752] = {n:"Sang du Vampire",t:15,d:"Ce sang est magique, ce qui en fait un ingrédient indispensable pour le Boudin Noir magique. Les effets secondaires sont cependant encore inconnus.",ep:2,g:89,l:15,wd:true,fm:true,w:1,p:100};
I.u[754] = {n:"Cape du Vampire",t:17,d:"Cette cape rouge sang a baigné dans le sang pendant des années. Ce type de cape est très prisée lors des Fêtes Dalouhines.",ep:7,g:17,l:29,wd:true,fm:true,w:13,p:2500};
I.u[756] = {n:"Slip en Cuir Moulant du Vampire",t:56,d:"Pour se protéger des coups critiques aux endroits critiques, le Vampire utilise parfois son Slip en Cuir lorsqu\'il doit partir en chasse. Ce Slip lui permet également de protéger les endroits critiques des coups de soleil.",ep:3,g:622,l:15,wd:true,fm:true,w:1,p:100};
I.u[757] = {n:"Gelée Bleutée",t:110,d:"Cette gelée est particulièrement collante, un peu comme une Bloqueuse enragée. Étrangement, elle colle particulièrement bien les plumes de Tofus. On se demande bien à quoi cela peut bien servir...",ep:5,g:42,l:3,wd:true,fm:true,w:1,p:1};
I.u[758] = {n:"Cape du Justicier",t:17,d:"Cette cape ne peut être portée que par les grands justiciers d\'Amakna, c\'est à dire presque personne.",ep:1,g:2,l:30,wd:true,fm:true,w:10,c:"Ps=1&Pa>20",p:2550};
I.u[759] = {n:"Cape du Poolay Chogrelotant",t:17,d:"Cette magnifique cape a été confectionnée avec les plumes du dernier Poolay d\'Amakna. Véritable rareté, les collectionneurs rêvent de l\'avoir dans leur collection.",ep:8,g:3,l:33,wd:true,fm:true,w:4,p:5000};
I.u[760] = {n:"Pain au curry sans curry",t:33,d:"Un prototype de Kwaker Vans, son goût et son efficacité sont toujours une surprise, malheureusement l\'odeur, elle, est toujours la même.",ep:2,g:12,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[761] = {n:"Poils de souris",t:54,d:"Ces poils de souris sont très fins et doux, et sont de ce fait très recherchés pour la confection de manteaux. Le manteau en peau et poils de souris fait fureur dans la haute société d\'Amakna, il paraît que ça fait classe d\'en porter.",ep:1,g:549,l:1,wd:true,fm:true,w:1,p:1};
I.u[764] = {n:"Amulette du Petit Hibou",t:1,d:"Cette petite amulette ravira les héros débutants.",ep:1,g:1,l:1,wd:true,fm:true,w:2,p:50};
I.u[765] = {n:"Faux de Farle Ingalsse",t:22,d:"Cette Faux a appartenu à Farle Ingalsse en personne, elle est suffisamment aiguisée pour faucher tous les types de céréales et tous les types de monstres qui se cachent dans les champs de céréales.",ep:3,g:1,l:13,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,50,false,false],c:"CC>10",p:650};
I.u[766] = {n:"Koliet Aclou",t:1,d:"Cette amulette permet d\'occasionner plus de dégâts pour les aventuriers qui débutent.",ep:1,g:34,l:1,wd:true,fm:true,w:1,p:20};
I.u[767] = {n:"Gantie Royal",t:9,d:"Malgré un nom pompeux, cet anneau rend juste un peu plus fort, et un peu plus bête.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[768] = {n:"Camaïneux",t:9,d:"Cet anneau influe sur le cours de votre destinée, il vous rend plus résistant, mais moins chanceux. Vous augmentez vos chances de vivre longtemps en diminuant vos chances de vivre heureux.",ep:1,g:33,l:1,wd:true,fm:true,w:1,p:100};
I.u[769] = {n:"Einekeineux",t:11,d:"Les bottes qui portent chance. Le problème c\'est qu\'elles vous rendent moins résistant en combat.",ep:1,g:5,l:2,wd:true,fm:true,w:1,p:200};
I.u[770] = {n:"Fecaflip",t:11,d:"Cette magnifique paire de bottes convertit un peu de votre force en intelligence.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[771] = {n:"Mangeuse de Frêne",t:19,d:"Cette hache n\'a rien d\'exceptionnel, mais elle reste tout de même appréciée des Bûcherons débutants, qui l\'aiment pour sa simplicité d\'utilisation .",ep:1,g:9,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>10&CC>10",p:400};
I.u[772] = {n:"Cape Edépée",t:17,d:"On prétend que cette cape légendaire permet de devenir presque invincible si on la combine à l\'épée légendaire des escrimeurs, le Dard Tagnan et au chapeau légendaire des Six Rameaux de Bergers Rahks.",ep:7,g:4,l:22,wd:true,fm:true,w:10,p:1500};
I.u[773] = {n:"Cape Ellinie",t:17,d:"Cette cape vient du pays des Patitaliennes, un endroit où l\'on parle avec les mains. Cela explique la grande liberté de mouvement laissée par celle-ci. Elle est en outre d\'une légèreté surprenante.",ep:1,g:5,l:14,wd:true,fm:true,w:1,p:775};
I.u[774] = {n:"Cape Ulais",t:17,d:"Venant du Mont Taigüe ou du monde Aigüe selon la manière dont vous le prononcez, cette cape a conduit à l\'empoisonnement de son ancienne propriétaire, mais bizarrement elle augmente la résistance de son porteur.",ep:1,g:7,l:14,wd:true,fm:true,w:3,p:775};
I.u[775] = {n:"Cape Abilité",t:17,d:"Tissée magiquement avec un soin infini, la Cape Abilité permet à son porteur de discerner les points faibles de ses adversaires pour leur porter des coups destructeurs.",ep:5,g:9,l:17,wd:true,fm:true,w:10,p:1000};
I.u[776] = {n:"Cape Sulcorpe",t:17,d:"Ayant appartenu à une certaine Mulba, qui s\'en servait pour transporter des objets encombrants dans sa quête des Sept Poules de Cristal venues des étoiles, cette cape augmente considérablement la force.",ep:5,g:8,l:14,wd:true,fm:true,w:3,p:775};
I.u[777] = {n:"Cape du Coq Hû",t:17,d:"Le Coq ayant donné ses plumes pour la confection de cette cape s\'est débattu pendant plusieurs jours et plusieurs nuits avant de finalement tomber à bout de force et de se laisser déplumer. \"Hû !\" s\'exclama son propriétaire, lui aussi à bout de souffle.",ep:5,g:10,l:44,wd:true,fm:true,w:10,p:5275};
I.u[778] = {n:"Cape de Mori Arty",t:17,d:"Cette authentique cape de méchant est une preuve de votre appartenance à la bande du diaboliquement génial Mori Arty, dont on raconte que seule sa malchance égalait sa stupéfiante intelligence. Ne peut être portée que par les plus grands méchants.",ep:2,g:11,l:6,wd:true,fm:true,w:1,c:"Ps=2&Pa>30",p:20000};
I.u[779] = {n:"Cape Maj\'Hic",t:17,d:"Cette cape d\'apparence quelconque n\'est en fait pas tout à fait quelconque. Elle rendrait invisible son porteur aux yeux de ceux qui ne le regardent pas. Impressionnant !",ep:8,g:12,l:34,wd:true,fm:true,w:15,p:3300};
I.u[781] = {n:"Cape Itou Lascione",t:17,d:"Cette superbe cape a appartenu au Grand Stratéquerre. Ce célèbre seigneur de guerre et fin stratège, avide de conquête de l\'univers, a bien vite abandonné tous ses projets après avoir revêtu cette cape. Étrange !",ep:8,g:7,l:21,wd:true,fm:true,w:10,p:1400};
I.u[782] = {n:"Agride",t:19,d:"Cette hache est assez particulière, elle est à la base destinée à l\'apprentissage du métier de Bûcheron. Correctement utilisée, elle peut sectionner en deux un jeune Abraknyde trop insouciant, ce qui avouons-le, est très rare.",ep:1,g:11,l:27,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CW>15",p:2200};
I.u[783] = {n:"Amulette du Bûcheron",t:1,d:"Cette amulette, exclusivement fabriquée à partir de bois précieux, est très prisée des Bûcherons qui lui attribuent bien souvent des pouvoirs qu\'elle n\'a pas.",ep:1,g:9,l:22,wd:true,fm:true,w:2,p:1500};
I.u[784] = {n:"Bottes du Chat Buté",t:11,d:"Le Chat Buté est le surnom donné à un célèbre Ecaflip. Aucun Ecaflip n\'aura été plus têtu que lui, et en combat seule sa chance le sauvait de son inexistante intelligence.  \n\"Qui qu\'c\'est qu\'y\'est buté comme un caillou ?\", s\'exclamait-il souvent.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[785] = {n:"Anneau Fortifiant",t:9,d:"Cet anneau, transmis de Grand père Enutrof en Père Enutrof, procure à son porteur une formidable force. Celui-ci n\'en est qu\'une pâle copie, mais il saura tout de même satisfaire les collectionneurs, qu\'ils soient Enutrof ou non.",ep:1,g:29,l:11,wd:true,fm:true,w:1,p:525};
I.u[786] = {n:"Pendentif du Hibou Chétif",t:1,d:"Née d\'une erreur de manipulation d\'un bijoutier, cette amulette augmente l\'intelligence de son porteur. En revanche, elle donne généralement un puissant mal de crâne qui a pour effet d\'amoindrir la condition physique de son propriétaire.",ep:1,g:1,l:2,wd:true,fm:true,w:1,p:200};
I.u[787] = {n:"Anneau Rexik",t:9,d:"Cet étrange petit anneau a la faculté d\'augmenter l\'agilité de son porteur, pourtant étrangement frappé d\'un manque de chance.",ep:1,g:31,l:1,wd:true,fm:true,w:1,p:100};
I.u[789] = {n:"Ceinture du Kobeer",t:10,d:"Cette ceinture fait fureur auprès de la jeune population d\'Amakna. Un couturier Sadida en est à l\'origine. Lors de sa première vente, il s\'exclama : \"La vie est courte, jouez durement !\".",ep:2,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[790] = {n:"Cape de Bonne Espérance",t:17,d:"Les effets magiques de cette cape sont souvent surestimés, ce qui a causé la perte de nombreux aventuriers, notamment, le tristement célèbre Ménestrel Francisque Kabroule.",ep:8,g:5,l:30,wd:true,fm:true,w:8,p:2525};
I.u[791] = {n:"Abraknydi Vivitus",t:4,d:"C\'est un Bâton en racines d\'Abraknyde encore vivantes. Attention, ce dernier a une fâcheuse tendance à se retourner contre son maître. Il peut être très efficace lorsqu\'il décide de s\'attaquer à la même cible que celle de son maître.",ep:2,g:1,l:34,wd:true,fm:true,w:10,an:12,e:[5,2,1,1,50,30,false,false],c:"CC>30&CI>34&CW>15",p:3400};
I.u[792] = {n:"Sève d\'Abraknyde",t:15,d:"Cette sève sirupeuse ne sert à rien sauf si vous être prêt à attendre qu\'elle se fossilise en Ambre. On raconte cependant, qu\'une Enutrofette astucieuse et particulièrement séduisante a trouvé un moyen pour accélérer ce processus.",ep:1,g:162,l:45,wd:true,fm:true,w:2,p:50};
I.u[793] = {n:"Potion de Vieillesse",t:12,d:"Cette potion permet d\'accélérer certains processus chimiques, comme la formation de précipités. C\'est un peu comme une levure surpuissante, le mauvais goût en moins.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[795] = {n:"Parchemin de Force",t:76,d:"(Double click pour gagner de la force) \nCe parchemin permet de gagner de la force de manière définitive sans prendre de risques. \nAttention cependant, vous ne pourrez l\'utiliser que si votre force est inférieure à 50.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<50",u:true,p:2500};
