I.u[825] = {n:"Lame du Bwork",t:6,d:"Cette épée d\'apparence rudimentaire est très appréciée des Bworks les plus débiles, qui ne savent pas se servir d\'un arc ou d\'un bâton, certains confondent même la lame et le manche ce qui ne manque pas de faire rire leurs adversaires.",ep:1,g:13,l:23,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>46&CA>8",p:1600};
I.u[826] = {n:"Lame du Grand Bwork",t:6,d:"Cette épée d\'apparence rudimentaire est très appréciée des Bworks les plus débiles, qui ne savent pas se servir d\'un arc ou d\'un bâton, certains confondent même la lame et le manche ce qui ne manque pas de faire rire leurs adversaires.",ep:1,g:13,l:24,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>48&CA>14",p:1800};
I.u[827] = {n:"Lame du Puissant Bwork",t:6,d:"Cette épée d\'apparence rudimentaire est très appréciée des Bworks les plus débiles, qui ne savent pas se servir d\'un arc ou d\'un bâton, certains confondent même la lame et le manche ce qui ne manque pas de faire rire leurs adversaires.",ep:1,g:13,l:26,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>52&CA>16",p:2000};
I.u[828] = {n:"Arc Sifflant",t:2,d:"Cet arc tire si rapidement ses flèches, que l\'on entend ces dernières partir de très loin. Pensez donc à l\'équiper d\'un silencieux, si c\'est la discrétion que vous recherchez.",ep:1,g:15,l:11,wd:true,fm:true,w:10,an:10,tw:true,e:[5,3,2,6,30,40,false,true],c:"CA>11&CS>5",p:550};
I.u[829] = {n:"Arc Hade",t:2,d:"À cause de sa faible portée, cet arc n\'est pas très efficace, mais il permet tout de même d\'affaiblir suffisamment l\'ennemi avant de l\'achever avec une autre arme ou magie.",ep:1,g:1,l:8,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,30,50,false,true],c:"CA>8",p:400};
