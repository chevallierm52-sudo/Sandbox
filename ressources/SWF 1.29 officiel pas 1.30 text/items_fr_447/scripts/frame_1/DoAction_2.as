I.u[836] = {n:"Abranneau",t:9,d:"Cet anneau, forgé dans de l\'écorce d\'Abraknyde possède de grands pouvoirs et implique donc de grandes responsabilités. Cependant, malgré sa valeur, des rumeurs laissent entendre qu\'il est maudit.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:100};
I.u[837] = {n:"Bottes de Kluh",t:11,d:"Ces bottes augmentent la force de leur porteur, mais risquent de le rendre un peu idiot au bout d\'un certain temps, voire de le transformer en Iop en cas d\'utilisation régulière et prolongée",ep:1,g:3,l:8,wd:true,fm:true,w:1,p:400};
I.u[838] = {n:"Sang d\'Oni",t:15,d:"Cette fiole de sang d\'Oni est très recherchée par les alchimistes expérimentés qui désirent donner à certaines armes, des propriétés particulièrement effrayantes.",ep:4,g:662,l:75,wd:true,fm:true,w:1,p:100};
I.u[840] = {n:"Poils du Minotoror",t:54,d:"Ces poils sentent très mauvais, mais sont d\'une résistance à toute épreuve, porter sur soi une étoffe en poils de Minotoror fera de vous une personne redoutée de vos adversaires, et appréciée des mouches.",ep:2,g:201,l:125,wd:true,fm:true,w:1,p:100};
I.u[841] = {n:"Anneau de Satisfaction",t:9,d:"Cet anneau permettra a votre héros d\'augmenter ses PA, en contrepartie de sa force et de son intelligence.",ep:1,g:12,l:8,wd:true,fm:true,w:1,p:10};
I.u[842] = {n:"Coquille de Dragoeuf Doré",t:111,d:"Cette coquille est presque incassable, cependant, en la polissant pendant des générations, les meilleurs Bijoutiers peuvent utiliser ses facultés magiques pour confectionner des amulettes aux pouvoirs exceptionnels.",ep:11,g:202,l:64,wd:true,fm:true,w:5,p:1};
I.u[843] = {n:"Coquille de Dragoeuf Noir",t:111,d:"Cette coquille est presque incassable, cependant, en la polissant pendant des générations, les meilleurs Bijoutiers peuvent utiliser ses facultés magiques pour confectionner des amulettes aux pouvoirs exceptionnels.",ep:11,g:203,l:64,wd:true,fm:true,w:5,p:150};
I.u[844] = {n:"Oeuf de Dragoeuf de Saphir",t:105,d:"Cet oeuf étrange donnera naissance à un joli petit Dragoeuf une fois qu\'il sera couvé par une Femelle Dragoeuf de Saphir. En attendant, évitez de le tenir au chaud contre vous, on ne sait pas ce qu\'il pourrait arriver...",ep:11,g:204,l:74,wd:true,fm:true,w:20,p:100};
I.u[845] = {n:"Oeuf de Dragoeuf Doré",t:105,d:"Cet oeuf étrange donnera naissance à un joli petit Dragoeuf une fois qu\'il sera couvé par une Femelle Dragoeuf Doré. En attendant, évitez de le tenir au chaud contre vous, on ne sait pas ce qui pourrait arriver...",ep:11,g:205,l:74,wd:true,fm:true,w:20,p:100};
I.u[846] = {n:"Oeuf de Dragoeuf Noir",t:105,d:"Cet oeuf étrange donnera naissance à un joli petit Dragoeuf une fois qu\'il sera couvé par une Femelle Dragoeuf Noir. En attendant, évitez de le tenir au chaud contre vous, on ne sait pas ce qu\'il pourrait arriver...",ep:11,g:206,l:74,wd:true,fm:true,w:20,p:100};
I.u[847] = {n:"Oeuf de Dragoeuf Blanc",t:105,d:"Cet oeuf étrange donnera naissance à un joli petit Dragoeuf une fois qu\'il sera couvé par une Femelle Dragoeuf Blanc. En attendant, évitez de le tenir au chaud contre vous, on ne sait pas ce qu\'il pourrait arriver...",ep:10,g:38,l:74,wd:true,fm:true,w:1,p:100};
I.u[848] = {n:"Vieil Os de Dragoeuf",t:47,d:"Ce vieil os est magique, correctement utilisé, il devrait permettre de confectionner des objets très puissants.",ep:11,g:15,l:70,wd:true,fm:true,w:20,p:100};
I.u[849] = {n:"Anneau Forcesque",t:9,d:"Ce petit anneau donne de la Force à son porteur.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[850] = {n:"Anneau Agilesque",t:9,d:"Étrangement, les collectionneurs Amaknéens s\'arrachent cet anneau alors qu\'il ne vaut pas tripette.",ep:1,g:1,l:1,wd:true,fm:true,w:1,p:50};
I.u[851] = {n:"Anneau Vitalesque",t:9,d:"Ce petit anneau augmente la vie de son porteur.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[852] = {n:"Petit Anneau Magique",t:9,d:"Ce petit anneau augmente l\'intelligence de son porteur.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[853] = {n:"Petit Anneau du Chanceux",t:9,d:"Ce petit anneau augmente la chance de son porteur.",ep:1,g:42,l:1,wd:true,fm:true,w:1,p:50};
I.u[854] = {n:"Amulette du Petit Ours",t:1,d:"Cette petite amulette augmente la force de son porteur",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[856] = {n:"Grenouillette",t:1,d:"Cette petite amulette augmente l\'agilité de son porteur.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[859] = {n:"Ceinture d\'Agilité",t:10,d:"Cette modeste ceinture augmente l\'agilité de son porteur.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:50};
I.u[860] = {n:"Ceinture de Chance",t:10,d:"Cette modeste ceinture augmente la chance de son porteur.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[861] = {n:"Petites Bottes de Force",t:11,d:"Ces bottes augmentent la force de leur porteur au détriment de son agilité, ce qui tend à le rendre différent d\'un Tofu, sans pour autant le rendre moins idiot.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[862] = {n:"Sandales d\'Intelligence",t:11,d:"Ces bottes permettent d\'augmenter l\'intelligence de leur porteur, tout en lui conférant un style vraiment à la mode par les temps qui courent grâce à leur semelle en Bois de Noyer qui offre une adhérence remarquable.",ep:1,g:4,l:8,wd:true,fm:true,w:1,p:400};
I.u[863] = {n:"Bottes Agilesques",t:11,d:"Ces bottes permettent d\'augmenter l\'agilité de leur porteur, afin qu\'il puisse se prendre pour un Tofu plus facilement, lorsque l\'envie lui prend de faire l\'idiot.",ep:1,g:5,l:8,wd:true,fm:true,w:1,p:400};
I.u[864] = {n:"Bottes de Chance",t:11,d:"Ces bottes augmentent la chance de leur porteur afin de l\'aider à trouver des objets très puissants, comme de la bave de Bouftou par exemple.",ep:1,g:1,l:8,wd:true,fm:true,w:1,p:100};
I.u[867] = {n:"Dragolyre",t:1,d:"Cette splendide amulette confectionnée à partir de restes de Dragoeuf, est suffisamment impressionnante pour faire battre en retrait la majorité des ennemis normalement constitués.",ep:11,g:9,l:32,wd:true,fm:true,w:2,p:4700};
I.u[878] = {n:"Parchemin de Boulanger",t:13,d:"(Double clic pour utiliser) \nCe parchemin permet de gagner des points d\'expérience dans le métier de Boulanger.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[879] = {n:"Parchemin de Cordonnier",t:13,d:"(Double clic pour utiliser) \nCe parchemin permet de gagner des points d\'expérience dans le métier de Cordonnier.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[880] = {n:"Laine de Bouftou Royal",t:57,d:"Cette laine est royale, elle est douce et légère, mais a tendance à démanger les peaux sensibles. Cette laine est en revanche très usée donc très fragile, étant donné l\'âge du Bouftou Royal.",ep:1,g:207,l:35,wd:true,fm:true,w:1,p:4000};
I.u[881] = {n:"Laine de Boufton Blanc",t:57,d:"Cette laine est extrêmement douce, car elle provient du duvet d\'un Boufton. Attention tout de même, cette laine est encore imprégnée d\'une odeur qui pourrait inciter la mère du Boufton à vous lécher si vous entrez en contact avec cette laine.",ep:1,g:208,l:2,wd:true,fm:true,w:1,p:1};
I.u[882] = {n:"Laine du Chef de Guerre Bouftou",t:57,d:"Cette laine sent très mauvais, mais elle a appartenu à un Chef de Guerre Bouftou, ce qui lui confère une grande valeur sentimentale auprès des guerriers.",ep:1,g:209,l:19,wd:true,fm:true,w:1,p:1};
I.u[883] = {n:"Cuir de Boufton Blanc",t:56,d:"Ce cuir très lisse est particulièrement adapté à la confection de sous-vêtements en cuir, le Slip en Cuir du Chafer en est un exemple frappant.",ep:1,g:534,l:2,wd:true,fm:true,w:1,p:1};
I.u[884] = {n:"Cuir de Boufton Noir",t:56,d:"Ce cuir luisant est très apprécié des Cordonniers et des tailleurs, pour la confection de petites bottes ou de chapeaux.",ep:1,g:16,l:2,wd:true,fm:true,w:1,p:1};
I.u[885] = {n:"Laine de Boufton Noir",t:57,d:"Cette laine rugueuse n\'est pas très utilisée par les tailleurs, elle est en revanche très appréciée des Enutrofs, qui s\'en servent pour cacher leur calvitie naissante.",ep:1,g:210,l:2,wd:true,fm:true,w:1,p:1};
I.u[886] = {n:"Cuir de Bouftou Royal",t:56,d:"Ce cuir est royal, il est d\'une souplesse extraordinaire, et les crevasses qu\'il arbore, sont les témoins de la longue vie du Bouftou Royal. Il n\'existe pas meilleur cuir dans toute la province d\'Amakna.",ep:1,g:535,l:35,wd:true,fm:true,w:1,p:4000};
I.u[887] = {n:"Cuir du Chef de Guerre Bouftou",t:56,d:"\"Ce cuir a du faire toutes les guerres, pour être aussi dur aujourd\'hui\" telles étaient les paroles du célèbre Ménestrel Francisque Kabroule, juste avant de mourir asphyxié par l\'odeur d\'un Chef de Guerre Bouftou.",ep:1,g:534,l:19,wd:true,fm:true,w:1,p:1};
I.u[888] = {n:"Grandes Bottes de Concentration",t:11,d:"Ces bottes sont si confortables qu\'elles permettent au héros qui les chausse d\'accroître sa concentration.",ep:1,g:6,l:26,wd:true,fm:true,w:15,p:1950};
I.u[889] = {n:"Puissantes Bottes de Concentration",t:11,d:"Ces bottes sont si confortables qu\'elles permettent au héros qui les chausse d\'accroître sa concentration.",ep:1,g:6,l:27,wd:true,fm:true,w:15,p:2200};
I.u[890] = {n:"Bottes du Bouftou",t:11,d:"Ces bottes sont confectionnées en cuir de Bouftou, elles permettent aux éleveurs de s\'approcher plus facilement des Bouftous pour les tuer, grâce à l\'odeur qu\'elles dégagent.",ep:1,g:3,l:1,wd:true,fm:true,w:3,p:150};
I.u[891] = {n:"Bottes du Grand Bouftou",t:11,d:"Ces bottes sont confectionnées en cuir de Bouftou, elles permettent aux éleveurs de s\'approcher plus facilement des Bouftous pour les tuer, grâce à l\'odeur qu\'elles dégagent.",ep:1,g:3,l:2,wd:true,fm:true,w:4,p:200};
I.u[892] = {n:"Bottes du Puissant Bouftou",t:11,d:"Ces bottes sont confectionnées en cuir de Bouftou, elles permettent aux éleveurs de s\'approcher plus facilement des Bouftous pour les tuer, grâce à l\'odeur qu\'elles dégagent.",ep:1,g:3,l:4,wd:true,fm:true,w:5,p:250};
I.u[893] = {n:"Petites Dagues Sylvestres",t:5,d:"Ces dagues étaient particulièrement bien adaptées pour couper les racines ou les jeunes pousses, elles ont été détournées de leur usage pour en faire des armes presque mortelles.",ep:1,g:6,l:20,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>20&CI>5",p:1300};
I.u[894] = {n:"Dagues Sylvestres",t:5,d:"Ces dagues étaient particulièrement bien adaptées pour couper les racines ou les jeunes pousses, elles ont été détournées de leur usage pour en faire des armes presque mortelles.",ep:1,g:6,l:23,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>23&CI>5",p:1600};
I.u[895] = {n:"Grandes Dagues Sylvestres",t:5,d:"Ces dagues étaient particulièrement bien adaptées pour couper les racines ou les jeunes pousses, elles ont été détournées de leur usage pour en faire des armes presque mortelles.",ep:1,g:6,l:25,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>25&CI>5",p:1900};
