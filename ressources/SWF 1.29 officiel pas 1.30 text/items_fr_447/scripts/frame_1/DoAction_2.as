I.u[818] = {n:"Clé en Roche de Ded Aléïcar",t:12,d:"Cette petite clé en roche vous ouvrira la porte de la grotte de Ded Aléïcar. Mais encore faut-il la trouver...",ep:4,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[819] = {n:"Epée Sacrée",t:6,d:"Une épée sainte distribuée aux jeunes guerriers durant leur formation.",ep:1,g:1,l:15,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>30&CV>3",p:800};
