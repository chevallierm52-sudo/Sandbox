I.u[822] = {n:"Epée du Chevalier",t:6,d:"L\'épée du Chevalier est une épée solide et efficace, bien utilisée elle peut causer de gros dommages à vos ennemis.",ep:7,g:9,l:23,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>46",p:1600};
