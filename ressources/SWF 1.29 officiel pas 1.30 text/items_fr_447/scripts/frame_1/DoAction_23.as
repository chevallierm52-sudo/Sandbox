I.u[11227] = {n:"Duvet de Mamansot",t:54,d:"Sur Frigost, tout le monde adore rembourrer ses sous-vêtements avec du duvet de Mamansot. Certains prétendent que c\'est pour avoir moins froid. Seuls les Iops y croient encore.",ep:0,g:675,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11228] = {n:"Arête géante du Shamansot",t:47,d:"Sur Frigost, beaucoup de questions n\'ont pas de réponses et beaucoup de réponses n\'ont pas de questions, ce qui est beaucoup plus inquiétant. Vous ne saurez jamais où le Shamansot a trouvé cette arête géante.",ep:0,g:663,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11229] = {n:"Poil de barbe du Shamansot",t:54,d:"La barbe du Shamansot sent le poisson et l\'hafteur chèvre. Ce délicieux mélange est utilisé par les Frigostiens courageux comme un parfum répulsif contre les Boufmouths et les amis.",ep:0,g:674,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11230] = {n:"Queue du Fu Mansot",t:65,d:"Ne vous fiez pas à sa taille modeste, elle trouve toujours son chemin.",ep:0,g:753,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11231] = {n:"Oreille du Fu Mansot",t:106,d:"Généralement cachées par un poisson en décomposition, les oreilles du Fu Mansot n\'entendent qu\'une seule chose, les appels des partenaires disponibles lors des périodes de reproduction. Vous pouvez donc vous moquer des Fu Mansots sans risque tant que vous ne ressemblez pas à un partenaire potentiel.",ep:0,g:625,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11232] = {n:"Plume du Mansot Royal",t:53,d:"Le Mansot Royal est très respecté par les Frigostiens, qui voient en lui une bestiole avec un titre important et une occasion de tuer quelque chose d\'important.",ep:0,g:647,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11233] = {n:"Oeuf du Mansot Royal",t:105,d:"Inutile de feindre la surprise, cet énorme oeuf est bien sorti de quelque part.",ep:0,g:643,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11234] = {n:"Richard Rouge",t:32,d:"Rescapé de la forêt des pins perdus, à escorter jusqu\'au Chef Rhonté.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11235] = {n:"Staurme Sioux",t:32,d:"Rescapée de la forêt des pins perdus, à escorter jusqu\'au Chef Rhonté.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11236] = {n:"Staurme Jauni",t:32,d:"Rescapé de la forêt des pins perdus, à escorter jusqu\'au Chef Rhonté.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11237] = {n:"Grimebène",t:32,d:"Rescapé de la forêt des pins perdus, à escorter jusqu\'au Chef Rhonté.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11238] = {n:"Queue d\'Ecumouth",t:65,d:"L\'Ecumouth se sert de sa queue pour garder l\'équilibre lorsqu\'il se déplace en roulant sur son gland. Cet animal semble immunisé contre le ridicule.",ep:0,g:754,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11239] = {n:"Gland de l\'Ecumouth",t:58,d:"L\'Ecumouth passe les premières années de sa vie à chercher le meilleur gland possible. Il passe le restant de sa vie à essayer de se souvenir où il l\'a caché.",ep:0,g:68,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11240] = {n:"Dent de Smilomouth",t:47,d:"Des études scientifiques très poussées et sérieuses démontrent que les dents du Smilomouth sont la première source de perforation de postérieurs chez les Frigostiens.",ep:0,g:664,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11241] = {n:"Poil de Smilomouth",t:54,d:"Les poils du Smilomouth étaient autrefois utilisés pour confectionner des édredons. Certains Frigostiens aimaient avoir une bonne excuse pour justifier leur odeur de fauve au réveil.",ep:0,g:676,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11242] = {n:"Défense du Sanglacier",t:47,d:"Elle porte l\'odeur d\'un caleçon mais pas celle du vôtre.",ep:0,g:665,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11243] = {n:"Cuir du Sanglacier",t:56,d:"Ce cuir arrondit les angles de la silhouette du Sanglacier pour mettre en valeur ses rondeurs.",ep:0,g:16,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11244] = {n:"Message de Gérard",t:24,d:"J\'ai suivi une mamansot cendrée et elle m\'a conduit jusqu\'à son repaire, où se cachent des centaines d\'autres mamansots. C\'est une aubaine à ne pas rater. Je vais entrer et tirer sur tout ce qui bouge, ça fera assez de viande pour la prochaine décennie. \nGérard.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[11245] = {n:"Bijoux de famille de Gérard",t:24,d:"Contrairement à ceux du Meulou, ces bijoux de famille n\'ont aucune valeur et ne sont pas prêts de servir.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11246] = {n:"Oeil torve de Fricochère",t:109,d:"Avant de rejoindre le sanctuaire des Fricochères morts au combat, celui que vous avez tenté de tuer vous a lancé un dernier regard à vous glacer le sang. Comme s\'il ne faisait pas déjà assez froid sur Frigost...",ep:0,g:591,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11247] = {n:"Oreille percée du Fricochère",t:106,d:"Les oreilles du Fricochère sont toutes percées. Est-ce à cause de leur attirance pour les boucles d\'oreilles ou des chants de Francisque Kabroule qui peuvent être entendus depuis Frigost ?",ep:0,g:626,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11248] = {n:"Oreille de Kaniglou",t:106,d:"Cette oreille vous rappelle une des chansons les plus célèbres chez les jeunes Frigostiens : \"Kaniglou glou glou, Gloutovore vore vore tadada tzum tzum\". Elle a le mérite d\'être assez courte pour être mémorisée par un Iop.",ep:0,g:627,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11249] = {n:"Etoffe de Kaniglou",t:55,d:"Cette étoffe vous rappelle le deuxième couplet d\'une des chansons les plus populaires chez les jeunes Frigostiens : \"Fricochère chère chère...\". Malheureusement vous avez oublié la suite.",ep:0,g:730,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11250] = {n:"Poil de Chachachovage",t:54,d:"Lorsqu\'ils étaient encore vivants, les opposant politiques du Maire de Frigost expliquaient à qui voulait bien l\'entendre, qu\'elle utilisait de la lingerie en poil de Chachachovage.",ep:0,g:677,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11251] = {n:"Sternum de Chachachovage",t:47,d:"Tout le monde se demande ce qu\'il est possible de faire avec un sternum de Chachachovage. Un Chachachovage empaillé peut-être.",ep:0,g:666,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11252] = {n:"Patte de Rat Bougri",t:103,d:"Les jeunes écoliers de Frigost ont un jeu appelé \"chachasse\" qui consiste à couper la patte d\'un Rat Bougri et l\'utiliser pour simuler des traces de pas dans la neige. Ils attirent ainsi les Chachas des glaces en quête de proie vers une embuscade. Une fois le Chacha des glaces attrapé, ils le tondent et le transforment en moufles. Les enfants sont formidables.",ep:0,g:36,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11253] = {n:"Etoffe de Rat Bougri",t:55,d:"Avant la glaciation de Frigost, les Rats Bougris étaient  chassés pour leurs étoffes de poils qui étaient ensuite exportées sur le continent d\'Amakna et vendues sous l\'appellation \"Peau de Kitsou exotique\".",ep:0,g:731,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11254] = {n:"Pince de Crabe Hijacob",t:47,d:"Les Crabes Hijacob sont chassés par les pêcheurs de Frigost pour deux raisons, leur mauvaise humeur permanente et leur tendance à faire des blagues aux pêcheurs en coupant leurs filets. Les pêcheurs se vengent en faisant à leur tour des blagues aux crabes en leur coupant les pinces.",ep:0,g:668,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11255] = {n:"Oeil de Crabe Hijacob",t:109,d:"Cet oeil contient un liquide vitreux utilisé dans les recettes de cuisines frigostiennes ancestrales, qui permet de remplacer le vinaigre. Mais uniquement si vous laissez fermenter l\'oeil suffisamment longtemps.",ep:0,g:592,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11256] = {n:"Bec de Gélikan",t:47,d:"Le Gélikan est une créature plutôt stupide et mal élevée, on retrouve son guano un peu partout sur le port de Frigost et elle a tendance à voler le poisson des pêcheurs. Mais bien dressée, elle est capable de dérober et cacher dans son bec les effets personnels des touristes distraits.",ep:0,g:667,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11257] = {n:"Plume de Gélikan",t:53,d:"Ces plumes sont très utilisées par les écoliers de Frigost qui s\'en servent pour écrire. Les mamans Gélikans expliquent donc toujours à leur progéniture qu\'il faut accélérer lorsqu\'ils passent devant une école.",ep:0,g:648,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11258] = {n:"Reçu du Chef Rhonté",t:24,d:"La date de réception des pins est indiqué sur ce reçu. Montrez-le à Gormor l\'Equarisseur pour toucher votre paie.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[11259] = {n:"Troncs de Pin",t:24,d:"Le Chef Rhonté a besoin de ces troncs pour alimenter le chauffage du système de tuyauterie.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11260] = {n:"Graisse de mansot",t:24,d:"Cette graisse, épaisse et poisseuse, fait un excellent combustible qui brûle longtemps, très longtemps. Ceci explique pourquoi les mansots n\'ont jamais froid.",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[11261] = {n:"Liste de fournitures de Damar",t:24,d:"Cette liste répertorie les pièces manquantes dont les pêcheurs du lac gelé ont besoin pour réparer leur matériel.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[11262] = {n:"Alliance de Damar",t:24,d:"Alliance promise par Damar à Valy Domidat il y a trente ans.",ep:0,g:27,l:1,wd:false,fm:true,w:0,p:1};
I.u[11263] = {n:"Fée d\'artifice Térik",t:74,d:"Cette fée d\'artifice produit un agréable effet pyrotechnique pendant quelques secondes et vous brûle la rétine pour le restant de votre vie.",ep:0,g:0,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[11264] = {n:"Peau déchiquetée de Mansot",t:24,d:"Cette peau de mansot est en très mauvais état. Impossible de s\'en servir dans la fabrication de nouveaux sous-vêtements pour la fête du Captain Chafer.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11265] = {n:"Mansobèse apprivoisé",t:32,d:"Ce mansobèse a été spécialement dressé pour être capable de régurgiter d\'énormes quantités de poisskailles en les laissant intacts. Seul inconvénient : sa digestion commence au bout de trente minutes.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11266] = {n:"Cervelle de mansobèse apprivoisé",t:24,d:"Pendant que vous combattiez, votre mansobèse a été dévoré. C\'est tout ce qui reste de lui.",ep:0,g:89,l:1,wd:false,fm:true,w:0,p:1};
I.u[11267] = {n:"Bon de réduction",t:24,d:"Ce bon de réduction sera valable sur la location d\'une chambre dans le futur hôtel de glace.",ep:0,g:72,l:1,wd:false,fm:true,w:0,p:1};
I.u[11268] = {n:"Vieille peluche Féca",t:24,d:"Cette vieille peluche doit bien appartenir à quelqu\'un, mais qui ? \nDouble-cliquer pour utiliser.",ep:0,g:680,l:1,wd:false,fm:true,w:0,c:"Qc=599",u:true,p:1};
I.u[11269] = {n:"Gomme à mâcher",t:24,d:"Cette gomme à mâcher ne vous est d\'aucune utilité car votre haleine est bien trop chargée. Le Xélor Mac Givré, par contre, lui trouvera une fonction insoupçonnée.",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=600",u:true,p:1};
I.u[11270] = {n:"Coffre familial",t:24,d:"Ce coffre contient de nombreux bijoux de famille. A défaut de connaître un receleur, vous pourrez toucher une récompense auprès de son propriétaire. \nDouble-cliquer pour utiliser.",ep:0,g:44,l:1,wd:false,fm:true,w:0,c:"Qc=601",u:true,p:1};
I.u[11271] = {n:"Livre scellé",t:24,d:"Ce livre scellé est en mauvais état. Forcer son ouverture pour lire son contenu risque de le rendre inutilisable. Vous feriez mieux de le confier à un professionnel, mais lequel ? \nDouble-cliquer pour utiliser.",ep:0,g:95,l:1,wd:false,fm:true,w:0,c:"Qc=602",u:true,p:1};
I.u[11277] = {n:"Timansot chenapan",t:32,d:"Ce timansot n\'aime pas l\'adoption et s\'enfuira à la première occasion. En attendant, vous pouvez le montrer à vos amis pour qu\'ils le maltraitent.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11278] = {n:"Ecumouth",t:30,d:"Vous avez vaincu un Ecumouth mais malheureusement, il a décidé de vous suivre partout. Vous pourrez ainsi vérifier par vous-même que sa malchance n\'est pas une légende.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11279] = {n:"Scie à glace",t:15,d:"Cette scie sert à découper des blocs de glace. Elle découpe aussi très bien les membres gelés à amputer.",ep:0,g:0,l:100,wd:false,fm:false,w:5,an:0,p:1};
I.u[11280] = {n:"Plaque d\'acier",t:40,d:"Cette plaque d\'acier est très populaire chez les Frigostiens, qui s\'en servent pour fabriquer des machines et des tuyaux en acier.",ep:0,g:0,l:100,wd:false,fm:true,w:50,an:0,p:1};
I.u[11281] = {n:"Masque de protection",t:15,d:"Ce masque est utilisé par les ouvriers pour protéger leurs visages lors des travaux dangereux. Il protège aussi très bien des gifles et de la vaisselle si vous avez encore oublié l\'anniversaire de votre femme.",ep:0,g:0,l:100,wd:false,fm:true,w:5,an:0,p:1};
I.u[11282] = {n:"Gants de protection",t:15,d:"Ces gants protègent les objets de vos sales pattes. Certains Srams les utilisent aussi pour protéger leur identité en cachant leurs empreintes digitales.",ep:0,g:0,l:100,wd:false,fm:true,w:2,an:0,p:1};
I.u[11283] = {n:"Recette de la Scie de glace",t:24,d:"Un forgeur d\'épées peut créer une scie de glace avec : \n- 2 * Cuir du Sanglacier. \n- 1 * Huile de Mamansot. \n- 2 * Plume de Gélikan. \n- 1 * Bec du Timansot. \n- 1 * Kriptonite. \n- 1 * Bois de Tremble. \n- 5 * Laine de Boufmouth. \n- 10 * Pierre à Aiguiser.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11284] = {n:"Recette de la Plaque d\'acier",t:24,d:"Un Mineur peut fondre cette plaque avec : \n- 5 * Charbon. \n- 25 * Fer. \n- 10 * Etain. \n- 10 * Manganèse. \n- 5 * Kobalte. \n- 1 * Aluminite. \n- 1 * Blague de Soufre. \n- 1 * Nacre.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11285] = {n:"Recette du Masque de protection",t:24,d:"Un tailleur peut fabriquer ce chapeau avec : \n- 5 * Duvet de Mamansot. \n- 5 * Laine de Boufmouth légendaire. \n- 2 * Oreille de Kaniglou. \n- 2 * Cuir du Sanglacier. \n- 2 * Bec de Timansot. \n- 1 * Charbon. \n- 5 * Fer. \n- 5 * Etain.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11286] = {n:"Recette des Gants de protection",t:24,d:"Un Bijoutier peut fabriquer cet anneau avec : \n- 4 * Plume du Timansot. \n- 2 * Aile de Mansobèse. \n- 10 * Poil de barbe du Shamansot. \n- 10 * Poil de Smilomouth. \n- 2 * Queue d\'Ecumouth. \n- 4 * Cuir de Bouftonmouth. \n- 2 * Pince de Crabe Hijacob. \n- 10 * Poil de Chachachovage.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11287] = {n:"Zobie la mousse",t:32,d:"Vous devez l\'escorter jusqu\'à Mac Givré.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11288] = {n:"Plan de l\'Abreuvoir frigostien en Charme",t:24,d:"Ce plan indique comment bricoler un prototype d\'abreuvoir en assemblant : \n- 1 * Abreuvoir en Charme. \n- 2 * Oreille du Fu Mansot. \n- 10 * Duvet de Mamansot. \n- 2 * Etoffe de Kaniglou. \n- 10 * Cuir du Sanglacier. \n- 2 * Œil de Crabe Hijacob. \n- 10 * Etoffe de Rat Bougri. \n- 2 * Œil torve de Fricochère.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11289] = {n:"Plan de la Mangeoire frigostienne en Charme",t:24,d:"Ce plan indique comment bricoler un prototype de mangeoire en assemblant : \n- 1 * Mangeoire en Charme. \n- 2 * Huile de Mamansot. \n- 10 * Poil de barbe du Shamansot. \n- 2 * Gland de l\'Ecumouth. \n- 10 * Oreille percée du Fricochère. \n- 2 * Bec de Gélikan. \n- 10 * Pince de Crabe Hijacob. \n- 10 * Poil de Smilomouth.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11290] = {n:"Plan du Foudroyeur frigostien en Charme",t:24,d:"Ce plan indique comment bricoler un prototype de foudroyeur en assemblant : \n- 1 * Foudroyeur en Charme. \n- 2 * Arête géante du Shamansot. \n- 10 * Plume du Timansot. \n- 2 * Défense du Sanglacier. \n- 10 * Oreille de Kaniglou. \n- 2 * Sternum de Chachachovage. \n- 10 * Plume de Gélikan. \n- 2 * Bec du Timansot.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11291] = {n:"Plan du Baffeur frigostien en Charme",t:24,d:"Ce plan indique comment bricoler un prototype de baffeur en assemblant : \n- 1 * Baffeur en Charme. \n- 2 * Aile de Mansobèse. \n- 10 * Queue du Fu Mansot. \n- 2 * Dent de Smilomouth. \n- 10 * Queue d\'Ecumouth. \n- 2 * Patte de Rat Bougri. \n- 10 * Poil de Chachachovage. \n- 10 * Peau de Mansobèse.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11292] = {n:"Prototype d\'Abreuvoir frigostien en Charme",t:93,d:"Ce prototype d\'objet d\'élevage nécessite encore quelques réglages avant d\'être parfaitement fonctionnel.",ep:0,g:0,l:100,wd:false,fm:true,w:10,an:0,p:1};
I.u[11293] = {n:"Prototype de Mangeoire frigostienne en Charme",t:93,d:"Ce prototype d\'objet d\'élevage nécessite encore quelques réglages avant d\'être parfaitement fonctionnel.",ep:0,g:0,l:100,wd:false,fm:true,w:10,an:0,p:1};
I.u[11294] = {n:"Prototype de Foudroyeur frigostien en Charme",t:93,d:"Ce prototype d\'objet d\'élevage nécessite encore quelques réglages avant d\'être parfaitement fonctionnel.",ep:0,g:0,l:100,wd:false,fm:true,w:10,an:0,p:1};
I.u[11295] = {n:"Prototype de Baffeur frigostien en Charme",t:93,d:"Ce prototype d\'objet d\'élevage nécessite encore quelques réglages avant d\'être parfaitement fonctionnel.",ep:0,g:0,l:100,wd:false,fm:true,w:10,an:0,p:1};
I.u[11296] = {n:"Dose de vaccin contre le rube",t:24,d:"Voici une dose de vaccin contre le rube.",ep:0,g:31,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11297] = {n:"Lettre de Lafairé Danlsak",t:24,d:"Germain, si tu lis cette lettre, ça signifie que je suis mort. Tu es probablement à la recherche de mon butin, alors sache que jamais je ne te dirai où il est caché. \nSalut !",ep:0,g:55,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11299] = {n:"Monsieur Pingouin",t:32,d:"Monsieur Pingouin est maintenant sous votre contrôle. A vous de l\'amener en sécurité à la milice de la Bourgade.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11301] = {n:"Fantômayte",t:32,d:"Fantômayte est maintenant sous votre contrôle. A vous de l\'amener en sécurité à la milice de la Bourgade.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11302] = {n:"Vengeuse Masquée",t:32,d:"La Vengeuse Masquée est maintenant sous votre contrôle. A vous de l\'amener en sécurité à la milice de la Bourgade.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11303] = {n:"YeCh\'Ti",t:32,d:"Le YeCh\'Ti est maintenant sous votre contrôle. A vous de l\'amener en sécurité à la milice de la Bourgade.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11306] = {n:"Epée Tillante",t:6,d:"Vous pouvez lire gravé sur son pommeau : \"Elle vole la vie des pauvres pour la redistribuer aux riches\". Dommage que vous soyez pauvre.",ep:0,g:0,l:49,wd:false,fm:true,w:10,e:[5,5,1,1,45,50,false,false],p:4900};
I.u[11307] = {n:"Trésor maudit d\'Az le Tech",t:94,d:"Az le Tech voulait échanger ce trésor à l\'Enutrof conquérant Sétroc contre sa liberté. Une fois en sa possession, Sétroc ne tint pas sa parole et fit exécuter Az le Tech. En mourant, il lança une malédiction qui s\'abattra sur tous les possesseurs du trésor.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,u:true,p:1};
I.u[11308] = {n:"Malédiction d\'Az le Tech",t:30,d:"Vosu avez dérobé une partie du trésor d\'Az Le Tech. Voilà ce qui arrive aux gens cupides.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11309] = {n:"Pince du Fancrôme",t:47,d:"Très pratique pour pincer les fesses de ses adversaires ou saisir les cornichons coincés au fond du bocal, cette pince fait la fierté du Fancrôme.",ep:0,g:0,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11310] = {n:"Corde du Fancrôme",t:15,d:"Difficile de dire à quoi cette corde pouvait bien servir aux Fancrômes, car tout le monde sait qu\'ils ne savent pas faire de noeuds.",ep:0,g:0,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11311] = {n:"Bouée de Fantomalamère",t:15,d:"Certaines pirates ne savent pas nager et ont besoin d\'une bouée. Ils finissent parfois par échouer sur les plages de sable noir du Berceau d\'Alma après avoir flotté pendant plusieurs années au large. Une fois qu\'ils peuvent de nouveau toucher la terre ferme, ils ont généralement soif de vengeance. Mais comme il ne peuvent pas se venger sur la mer, ils se vengent sur les faibles, les touristes, ou les touristes faibles.",ep:0,g:0,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11312] = {n:"Queue de Fantomalamère",t:65,d:"Difficile d\'appeler cela une queue, et pourtant il s\'agit de l\'extrémité d\'un Fantomalamère.",ep:0,g:0,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11313] = {n:"Huile de Fantimonier",t:60,d:"Le Fantimonier garde toujours avec lui un peu d\'huile afin de s\'assurer que sa barre tourne correctement. Il tente désespérément de la boire depuis que tout ne tourne plus rond dans sa tête.",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11314] = {n:"Coquille de Fantimonier",t:111,d:"Cette coquille protégeait le Fantimonier des projections d\'écume et de guano lorsqu\'il pilotait des navires. Désormais elle lui sert à protéger ses pupilles délicates des tempêtes de sable noir du Berceau d\'Alma.",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11315] = {n:"Mât de Fantômat",t:38,d:"Les ignorants pourraient penser qu\'il s\'agit d\'une queue de malet ou d\'un bout-dehors, alors que n\'importe quel Frigostien vous dira qu\'il s\'agit d\'un espar vertical et donc d\'un mât. Et cela même après avoir passé la nuit dans une taverne à boire de la vinasse qui démâte.",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11316] = {n:"Dent de Fantômat",t:47,d:"Mêmes les plus grands chercheurs Frigostiens n\'ont pas su expliquer l\'utilité des dents pour un fantôme, surtout s\'il est accroché à un mât. Peut-être pour ronger les cordages.",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11317] = {n:"Coquille de Harpirate",t:111,d:"Le Harpirate a volé sa coquille à un mollusque impuissant. Ca ne l\'a pas rendu plus puissant pour autant.",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11318] = {n:"Ecaille de Harpirate",t:59,d:"Cette écaille appartient à ce qui semblait être un ancien Frigostien devenu pirate et transformé en fantôme car sa mère lui avait fait boire trop souvent la tasse. Voilà ce qui arrive lorsque l\'on ingère une alimentation trop salée !",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11319] = {n:"Etoffe de la Vigie pirate",t:55,d:"En retournant cette étoffe de tissu, vous pouvez lire un plan incroyable : \"Si vous voyez un ennemi, volez-lui son trésor, cachez-le sur une île déserte et placez une croix sur une carte pour vous souvenir de son emplacement. Pensez à ne pas cacher la carte avec le trésor\".",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11320] = {n:"Oeil de Vigie pirate",t:109,d:"La Vigie pirate a été sélectionnée pour ses facultés visuelles hors-normes. Elle est capable de discerner un thon d\'une sirène en pleine tempête, de nuit, avec un poulpe sur les yeux, du guano sur les paupières et les chants de Francisque Kabroule en fond sonore.",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11321] = {n:"Poil de Ben le Ripate",t:54,d:"Egalement connu sous les noms de \"La rouste rousse\", \"L\'entourmitoufleur\", \"Benny l\'embrouille qui fout la trouille\", ou encore \"Ben à ordures\", ce pirate a navigué sur toutes les mers, de long en large, et a fini par les traverser en passant par le fond. Les marées ont décidé pour lui qu\'il finirait ses jours sur les plages de sable noir du Berceau d\'Alma.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11322] = {n:"Scapula de Ben le Ripate",t:47,d:"Cassé deux fois par des boulets de canon, trois fois en glissant sur de l\'écume, et quatre fois en tombant sur du guano séché, cet os a rendu riche le médecin de bord, jusqu\'à ce qu\'il finisse jeté aux requins pour de sombres histoires de jeux d\'argent, de femmes, d\'alcool, d\'insubordination, de provocations en duel, de vols de trésors, de sabordages et de mutineries. Une succession de broutilles qui ont causé sa perte. On ne plaisante pas avec Ben le Ripate.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11323] = {n:"Pierre d\'Atomystique",t:51,d:"Cette pierre lévitait autour d\'un Atomystique jusqu\'à ce que vous tentiez de l\'éviter ou de léviter, vous ne savez plus exactement ce qu\'il s\'est passé, mais vous avez mal au crâne et vous êtes recouvert de boue fumante.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11324] = {n:"Téphra d\'Atomystique",t:51,d:"Ce fragment de lave a été éjecté à très grande vitesse d\'un orifice insoupçonné de l\'Atomystique que vous avez désespérément tenté d\'achever à coups de rateau rouillé. Vous avez eu de la chance de ne pas être sur sa trajectoire lorsqu\'il est parti se planter dans le postérieur d\'un touriste local.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11325] = {n:"Résidu de Solfataré",t:51,d:"Comment une créature vaporeuse peut-elle donner naissance à des résidus solides ? Cette question a été posée il y a 74 ans lors de l\'épreuve du célèbre Concours Frigostien pour la Promotion des Jeunes Géologues Gradeutète. Cette année-là, aucun participant ne fut admis et la question reste aujourd\'hui encore un des mystères les plus terrifiants de l\'île de Frigost.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11326] = {n:"Ulna de Solfataré",t:47,d:"Cet os vaporeux se déforme en fonction de l\'humeur du Solfataré, réputé pour être un peu dérangé à cause de toutes les vapeurs qui lui montent au cerveau.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11327] = {n:"Coeur de Crapeur",t:51,d:"Ce coeur de pierre se rempli de vapeurlorsque le Crapeur rencontre un partenaire. Cette particularité vous permet de déterminer rapidement si vous venez de tuer un Crapeur célibataire, il suffit de vérifier si son coeur flotte.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11328] = {n:"Oeuf de Crapeur",t:105,d:"Le Crapeur est assimilable à un Craqueleur de vapeur qui aurait décidé d\'en découdre avec tout ce qui ne ressemble pas de près ou de loin, voir même de très loin à de la vapeur. Fait surprenant, il pond des oeufs remplis de vapeur.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11329] = {n:"Pierre de Fumrirolle",t:51,d:"Le Fumrirolle agitait cette énorme pierre au bout de ce qui semble lui servir de queue. Il espérait vous intimider, jusqu\'à ce que vous trouviez son point faible. Malheureusement votre tête de linotte n\'a pas réussi à le mémoriser.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11330] = {n:"Artefact de Fumrirolle",t:50,d:"Cet artefact vaporeux sent l\'oeuf pourri mélangé à la guanocamole. La simple évocation de ce mélange vous donne faim.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11331] = {n:"Pierre de Mofette",t:51,d:"La Mofette tient directement son nom d\'une structure géologique assez courante dans la zone des Larmes d\'Ouronigride. Cette pierre ressemble à un de ses organes, son rein peut-être.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11332] = {n:"Tuf de Mofette",t:51,d:"Derrière ce nom étrange se cache une roche à structure vacuolaire. Mais vous pouvez vous contenter de l\'assimiler à un morceau de la Mofette géante que vous venez de sauvagement découper.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11333] = {n:"Scorie de Magmarmiton",t:51,d:"De toute évidence c\'est un déchet, même pour le Magmarmiton lui-même. A ne pas mettre dans toutes les poches, surtout celles qui ne sont pas ignifugées.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11334] = {n:"Vertèbre de Magmarmiton",t:47,d:"Cette vertèbre contient une moelle osseuse déjà cuite et prête à être consommée. Vous avez sous les yeux et entre les mains les prémices de la cuisine instantanée.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11335] = {n:"Patte de Maho Givrefoux",t:103,d:"Après l\'avoir prise plusieurs fois en pleine face, vous avez enfin le droit de la garder dans votre sac comme porte bonheur.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11336] = {n:"Oreille de Maho Givrefoux",t:106,d:"On ne sait pas comment les Givrefoux sont arrivés sur Frigost, mais on sait que leurs lointains cousins viennent de Pandala. Cette information permet de mieux comprendre l\'origine des résidus gelés de Pandrista dans lesquels vous avez dormis la nuit passée.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11337] = {n:"Cuir du Soryo Givrefoux",t:56,d:"Ce cuir est assez épais pour permettre au Soryo Givrefoux de résister aux températures les plus basses et de faire de la luge sur les fesses sans se faire mal. Ce constat vous rend particulièrement jaloux.",ep:0,g:0,l:190,wd:false,fm:true,w:10,an:0,p:10};
I.u[11338] = {n:"Laine de Soryo Givrefoux ",t:57,d:"Longtemps utilisée pour rembourrer les sous-vêtements des Frigostiens complexés, cette laine est désormais connue pour donner des boutons à ceux qui s\'y frottent. Vous avez désormais trouvé un excellent prétexte pour justifier vos pustules.",ep:0,g:0,l:190,wd:false,fm:true,w:10,an:0,p:10};
I.u[11339] = {n:"Laine de Yokaï Givrefoux",t:57,d:"Difficile de faire plus stupide que la progéniture des Yokaï Givrefoux. Et pourtant certains parents semblent avoir réussi... Vous cherchez un lien avec cette laine de Givrefoux, mais vous n\'en voyez aucun, même en plissant les yeux et en serrant les poings.",ep:0,g:0,l:195,wd:false,fm:true,w:10,an:0,p:10};
I.u[11340] = {n:"Crâne de Yokaï Givrefoux",t:47,d:"La boîte crânienne du Yokaï Givrefoux pourrait à peine contenir un flocon de neige évaporé puis passé dans un éteau. Mais comme la bêtise fait peur, tous les Frigostiens restent terrorisés par cette créature presque incapable d\'aligner une patte devant l\'autre.",ep:0,g:0,l:195,wd:false,fm:true,w:10,an:0,p:10};
I.u[11367] = {n:"Seringue de vaccin contre le rube",t:24,d:"Cette seringue contient une unique dose de vaccin contre le rube. Testée et certifiée par Rose Line.",ep:0,g:31,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11368] = {n:"Mamansot",t:32,d:"Cette mamansot vous suit car elle n\'a pas le choix, mais elle s\'enfuira à la première occasion.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11369] = {n:"Graine de Panoramist",t:24,d:"Cette graine vous a été confiée par Panoramist pour repeupler la forêt des pins perdus.",ep:0,g:831,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11370] = {n:"Friswein",t:79,d:"Cette boisson très sucrée a la particularité d\'être faite à partir de raisins vendangés gelés. Ceci explique sa rareté et son goût raffiné unique.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,p:2};
I.u[11371] = {n:"Frigrowka",t:79,d:"Aussi appelée la boisson à l\'herbe de boufmouth, la Frigrowka est réputée pour faciliter les contacts humains et aborder les sujets difficiles. Quant aux Frigostiens, ils en boivent surtout parce qu\'ils aiment boire.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,p:2};
I.u[11372] = {n:"Capapier",t:17,d:"Cette cape est assez longue pour que vous puissiez vous permettre de laisser des interlignes entre chaque antisèche.",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:166,p:9175};
I.u[11373] = {n:"Chapapier",t:16,d:"Le tailleur qui a confectionné ce chapeau a dû utiliser 12 puissants parchemins en papier. Ou 12 feuilles de papier toilette.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:166,p:9400};
I.u[11374] = {n:"Amupapier",t:1,d:"Il reste assez de place pour qu\'un de vos amis écrive votre nom sur cette amulette en papier. C\'est ce que font les éleveurs pour reconnaître leurs Bouftous.",ep:0,g:0,l:62,wd:false,fm:true,w:10,an:0,s:166,p:10100};
I.u[11375] = {n:"Slipapier",t:1,d:"Ce sous-vêtement solide et rigide n\'est pas très confortable, mais il a été réalisé avec du papier mâché. Avoir la salive d\'un inconnu sur les fesses ne semble pas déranger tous les aventuriers.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:166,p:9900};
I.u[11376] = {n:"Caplume",t:17,d:"Cette énorme plume accentue votre silhouette d\'édredon.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:167,p:8428};
I.u[11377] = {n:"Chaplume",t:16,d:"Chez certaines tribus, la sagesse du chef se mesure au nombre de plumes sur son chapeau. Le vôtre n\'en possède qu\'une. Elle est de surcroît petite et usée.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:167,p:9380};
I.u[11378] = {n:"Plumodales",t:11,d:"Plus légères que des sandales classiques, elles n\'ont qu\'un seul véritable inconvénient, elles ne conviennent pas du tout aux chatouilleux.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:167,p:8230};
I.u[11379] = {n:"Plumamulette",t:1,d:"Elle chatouille le cou et fera sortir les chats coincés dans votre gorge.",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:167,p:9250};
I.u[11380] = {n:"Chasseur blessé",t:32,d:"Ce chasseur blessé a besoin des soins d\'Albert Paisse. Au moindre combat, il se réfugiera là où vous l\'avez trouvé.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11381] = {n:"Demande d\'attelage",t:24,d:"Demande rédigée par Djauns pour un attelage de chienchiens des neiges. Avant sa signature, il vous rappelle de vous dépêcher car le temps est compté.",ep:0,g:55,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11382] = {n:"Capoppinz",t:17,d:"La dernière personne qui a essayé d\'utiliser cette cape pour descendre d\'un nuage, s\'est écrasée sur une banque.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:168,p:8300};
I.u[11383] = {n:"Chapoppinz",t:16,d:"Ce chapeau ne supporte pas l\'humidité et vous obligera à vous déplacer en permanence avec un parapluie ridicule.",ep:0,g:0,l:53,wd:false,fm:true,w:10,an:0,s:168,p:7503};
I.u[11384] = {n:"Anoppinz",t:9,d:"Accrochez cet anneau autour du cou des enfants que vous devez surveiller, reliez l\'anneau à une corde que vous accrochez à un arbre. Et voilà vous êtes tranquille et les enfants ne se sauveront pas.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:168,p:8895};
I.u[11385] = {n:"Fourrure intacte de Givrefoux",t:24,d:"Récupérer cette fourrure sans trop l\'abîmer relève de l\'exploit quand on sait de quelle manière vous avez combattu son ancien propriétaire.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11386] = {n:"Bottoppinz",t:11,d:"Elles sont parfaites pour donner des fessées avec vos pieds sans vous salir les mains. Les enfants vont vous adorer !",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:168,p:9275};
I.u[11387] = {n:"Gaston",t:32,d:"Vous devez l\'escorter jusqu\'à Larry Tutthe pour en faire son nouvel assistant.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11388] = {n:"Caisse de matériel",t:24,d:"Cette caisse contient tout ce dont Larry Tutthe a besoin.",ep:0,g:44,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11389] = {n:"Prélèvement d\'eau",t:24,d:"Cette eau a été prélevée dans les larmes d\'Ouronigride pour Ogivol Victor.",ep:0,g:764,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11390] = {n:"Créature d\'eau",t:24,d:"[WIP_FG]Vous avez prélevé cette petite créature dans un bassin d\'eau minérale des larmes d\'Ouronigride. Vous ramassez vraiment n\'importe quoi. \nGFX : reprendre celui de la metaria bleue (item_id 1527, gfx 244/66244)",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11391] = {n:"Créature d\'eau modifiée",t:24,d:"Les effets de la croissance accélérée sur cette créature sautent aux yeux. Vous feriez mieux de vous dépêcher avant de ne plus pouvoir la porter.",ep:0,g:760,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11392] = {n:"Restes de givrefoux",t:24,d:"Vous avez fièrement combattu les givrefoux. Ces restes sont la preuve de votre victoire.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11393] = {n:"Caprisonnier",t:17,d:"Cette cape rayée a appartenu à un prisonnier célèbre pour son dilemme.",ep:0,g:0,l:51,wd:false,fm:true,w:10,an:0,s:169,p:7003};
I.u[11394] = {n:"Chaprisonnier",t:16,d:"Ce chapeau rayé est assez grand pour cacher un boulet. Mais pas forcément celui que vous avez accroché autour du pied.",ep:0,g:0,l:55,wd:false,fm:true,w:10,an:0,s:169,p:7900};
I.u[11395] = {n:"Amusonnier",t:1,d:"Cette petite chaîne pourrait passer pour une amulette si elle n\'avait pas un embout dédié à l\'accroche des boulets et des cadenas.",ep:0,g:0,l:54,wd:false,fm:true,w:10,an:0,s:169,p:7825};
I.u[11396] = {n:"Ceintusonnier",t:1,d:"L\'homme qui a donné un nom aussi stupide à cette ceinture est activement recherché, les années qu\'il aurait passées en prison ne justifiant pas du tout un tel manque de créativité.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:169,p:8750};
I.u[11397] = {n:"Capauffe-souris",t:17,d:"Cette cape au nom ridicule mais néanmoins intriguant appartenait à un justicier qui clamait vouloir nettoyer les rues de Brâkmar. Personne ne sait s\'il s\'agissait d\'un justicier ou d\'un éboueur.",ep:0,g:0,l:54,wd:false,fm:true,w:10,an:0,s:170,p:7703};
I.u[11398] = {n:"Chapauffe-souris",t:16,d:"Ce chapeau vous donnera l\'allure d\'une Chauffe-souris. Vous risquez de rester célibataire encore longtemps...",ep:0,g:0,l:57,wd:false,fm:true,w:10,an:0,s:170,p:8575};
I.u[11399] = {n:"Anauffe-souris",t:9,d:"Vous pouvez lire sur l\'emballage : \"A réserver aux justiciers qui n\'ont pas froid aux yeux\". Et vous qui pensiez l\'utiliser...",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:170,p:9187};
I.u[11400] = {n:"Bottauffe-souris",t:11,d:"Le cordonnier qui a conçu ces bottes les a munies d\'ailes de Chauffe-souris pour permettre à son propriétaire de voler. C\'est en tout cas ce que vous a expliqué le marchand ambulant à qui vous les avez achetées et qui hurlait en boucle au zaap d\'Astrub un discours presque inaudible.",ep:0,g:0,l:57,wd:false,fm:true,w:10,an:0,s:170,p:8500};
I.u[11401] = {n:"Capinokio",t:17,d:"Cette cape en bois s\'allonge quand vous mentez. Vous risquez de marcher régulièrement dessus.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:171,p:9428};
I.u[11402] = {n:"Chapinokio",t:16,d:"Ce chapeau peut également servir de cône de signalisation si vous avez un accident de Dragodinde.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:171,p:9875};
I.u[11403] = {n:"Mal de mer",t:24,d:"Vous transformer en esprit de pirate ne vous a pas réussi, vous n\'avez décidément pas le pied marin. Ca devrait passer d\'ici 24h.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11404] = {n:"Transformation en Fantôme de Pirate",t:27,d:"Vous avez été transformé en fantôme afin de pouvoir pénétrer dans l\'épave de l\'esprit rebelle.",ep:0,g:3,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11406] = {n:"Sérum de Mansot",t:24,d:"Seul les gens cultivés connaissent l\'utilité de ce sérum,ce qui explique pourquoi vous l\'ignorez.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11407] = {n:"Guano de Gélikan cristallisé",t:24,d:"Ce glaçon donne un goût particulier aux boissons dans lesquelles il est plongé pour les rafraîchir.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11408] = {n:"Sérum de vérité",t:24,d:"Jurez-vous de dire la vérité, toute la vérité, rien que la vérité ?",ep:0,g:2,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11409] = {n:"Bourse de kamas",t:24,d:"Cette bourse contient assez de kamas pour vous permettre d\'acheter une tenue décente. Etant donné la difficulté de la tâche, autant vous dire que ça représente une véritable fortune. Hélas, vous ne pouvez pas vous en servir pour autre chose.",ep:0,g:243,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11410] = {n:"Tenue d\'Adam",t:24,d:"Portée lors de la fête du slip du Captain Chafer, cette tenue fera des envieux et surtout des envieuses pressées de goûter le fruit défendu.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11411] = {n:"Tenue d\'Eve",t:24,d:"Portée lors de la fête du slip du Captain Chafer, cette tenue fera tourner la tête de vos prétendants et provoquera de nombreux torticolis. Votre kinésithérapeute vous en sera reconnaissant.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11412] = {n:"Copie du dossier de la famille Santho",t:24,d:"Ces documents sont une copie des droits de succession, titres de propriétés et autres documents administratifs de la famille Santho. Ils indiquent, entre autre, l\'achat et l\'héritage de centaines d\'hectares de terrain agricole au sud de Bonta. Les achats se sont étalés entre 551 et 555, soit juste après la glaciation de Frigost. Ils ont été rendus possibles grâce à l\'immense fortune d\'Edmond Santho, fortune faite en vendant d\'énormes quantités de céréales d\'origine frigostienne.\nActuellement, seul un champ n\'appartient pas à Raymond Santho : celui de Robin Marmoni.",ep:0,g:33,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11413] = {n:"Clef de la cellule d\'Heike Holo",t:24,d:"La clef de la cellule d\'Heike Holo.",ep:0,g:790,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11414] = {n:"Heike Holo",t:32,d:"Heike Holo veut s\'enfuir, vous devez l\'escorter jusqu\'au bâteau en partance pour l\'île des wabbits.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11415] = {n:"Documents sur les vols",t:24,d:"Ces documents parlent des vols effectués sur des chargement de céréales en provenance de Frigost. Les bateaux de la famille Montay y sont mentionnés.",ep:0,g:26,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11416] = {n:"Bottinokio",t:11,d:"Cette paire de bottines a été sculptée dans un tronc d\'arbre. A moins que ça ne soit l\'inverse.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:171,p:8800};
I.u[11417] = {n:"Anokio",t:9,d:"Cet anneau a été confectionné à partir de sciure de bois et de quelque chose de très collant. Il est préférable ne pas en savoir plus.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:171,p:9825};
I.u[11418] = {n:"Cape de Kabroule",t:17,d:"Francisque Kabroule aime cette cape à mourir. Ce qui explique pourquoi il la porte à chacun de ses enterrements.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:172,p:9858};
I.u[11419] = {n:"Bottes de Kabroule",t:11,d:"Une paire de bottes que Francisque Kabroule n\'oublie jamais d\'enfiler quand il va faire sa petite commission... dans sa cabane, au fond du jardin.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:172,p:8950};
I.u[11420] = {n:"Chapeau de Kabroule",t:16,d:"Ce chapeau un peu vieillot frise le ridicule. Il a valu à Francisque Kabroule le surnom de \"grand-mère à moustache\". Ce qui a tendance à le mettre de mauvais poil...",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:172,p:8980};
I.u[11421] = {n:"Sarbacane de Kabroule",t:4,d:"Francisque Kabroule n\'aurait jamais dû utiliser cette sarbacane juste après avoir mangé. Depuis, il est obligé de s\'en servir comme un simple bâton et comme il le répète si souvent, \"c\'était mieux avant\".",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:12,e:[7,3,1,1,35,55,false,false],c:"CI>70&CV>50&CA>25",s:172,p:8050};
I.u[11422] = {n:"Cadeau Bottes de Kabroule",t:89,d:"En secouant vigoureusement ce cadeau, vous comprenez qu\'il n\'est pas vide. Peut-être que pour une fois, les dieux ne se sont pas moqués de vous.\nAttention, ce cadeau ne peut-être ouvert que sur DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,an:0,c:"Sc=997",u:true,p:1};
