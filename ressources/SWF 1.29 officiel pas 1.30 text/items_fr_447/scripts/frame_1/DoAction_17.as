I.u[8237] = {n:"Ceinture du Piou Rouge",t:10,d:"Cette petite ceinture mettra vos hanches en valeur l\'espace d\'un combat. Elle servira ensuite à contenir vos tripes lorsqu\'un sanglier des plaines un peu énervé vous aura éventré au fin fond des bois.",ep:1,g:96,l:1,wd:true,fm:true,w:1,s:60,p:1};
