I.u[8225] = {n:"Sandales du Piou Rouge",t:11,d:"Parfaites pour protéger votre petite voûte plantaire, ces sandales sont en outre parfaites pour écraser les petites créatures qui rampent entre les brins d\'herbe, comme les Xélors ou les Eniripsas par exemple.",ep:1,g:78,l:1,wd:true,fm:true,w:1,s:60,p:1};
