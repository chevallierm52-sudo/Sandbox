I.u[8231] = {n:"Cape du Piou Rouge",t:17,d:"Si vous êtes suffisamment petit, cette cape confectionnée à partir de quelques plumes de Piou, cachera vos fesses. Une protection assez modeste, mais qui a le mérite d\'attirer l\'attention des passants sur autre chose que vos cheveux gras ou vos grosses verrues.",ep:1,g:103,l:1,wd:true,fm:true,w:10,s:60,p:100};
