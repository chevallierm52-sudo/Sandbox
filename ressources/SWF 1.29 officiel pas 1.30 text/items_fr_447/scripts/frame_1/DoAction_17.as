I.u[7805] = {n:"Les Dragodindes : Bien les élever",t:25,d:"Ce livre imposant vous expliquera comment capturer, élever et monter des Dragodindes. Il a été écrit par Oshar Marif en personne. Un gage de qualité.",ep:16,g:19,l:1,wd:false,fm:true,w:1,u:true,p:500};
I.u[7806] = {n:"Certificat de Monture",t:97,d:"Ce certificat vous permet d\'aller reprendre votre monture dans une étable. \nAttention, ce certificat n\'est valide que 20 jours, une fois ce délai dépassé, votre monture sera relâchée dans la nature et votre certificat ne sera plus valide, vous ne pourrez plus récupérer votre monture. Pensez à laisser votre monture dans une étable si vous devez vous absenter longtemps.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
