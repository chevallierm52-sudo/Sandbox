I.u[8242] = {n:"Ceinture du Piou Rose",t:10,d:"Cette petite ceinture mettra vos hanches en valeur l\'espace d\'un combat. Elle servira ensuite à contenir vos tripes lorsqu\'un sanglier des plaines un peu énervé vous aura éventré au fin fond des bois.",ep:1,g:101,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8243] = {n:"Chapeau du Piou Rouge",t:16,d:"Muni de ce petit chapeau sur la tête, vous aurez l\'air bien ridicule, mais aussi terriblement irrésistible. La vie est une question de choix.",ep:1,g:137,l:1,wd:true,fm:true,w:1,s:60,p:1};
I.u[8244] = {n:"Chapeau du Piou Bleu",t:16,d:"Muni de ce petit chapeau sur la tête, vous aurez l\'air bien ridicule, mais aussi terriblement irrésistible. La vie est une question de choix.",ep:1,g:138,l:1,wd:true,fm:true,w:1,s:61,p:1};
I.u[8245] = {n:"Chapeau du Piou Violet",t:16,d:"Muni de ce petit chapeau sur la tête, vous aurez l\'air bien ridicule, mais aussi terriblement irrésistible. La vie est une question de choix.",ep:1,g:139,l:1,wd:true,fm:true,w:1,s:62,p:1};
I.u[8246] = {n:"Chapeau du Piou Vert",t:16,d:"Muni de ce petit chapeau sur la tête, vous aurez l\'air bien ridicule, mais aussi terriblement irrésistible. La vie est une question de choix.",ep:1,g:140,l:1,wd:true,fm:true,w:1,s:71,p:1};
I.u[8247] = {n:"Chapeau du Piou Jaune",t:16,d:"Muni de ce petit chapeau sur la tête, vous aurez l\'air bien ridicule, mais aussi terriblement irrésistible. La vie est une question de choix.",ep:1,g:141,l:1,wd:false,fm:true,w:1,s:72,p:1};
I.u[8248] = {n:"Chapeau du Piou Rose",t:16,d:"Muni de ce petit chapeau sur la tête, vous aurez l\'air bien ridicule, mais aussi terriblement irrésistible. La vie est une question de choix.",ep:1,g:142,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8249] = {n:"Plume de Buveur",t:53,d:"Cette plume usée et imbibée d\'alcool fort, est très inflammable. Très pratique pour cuisiner un Buveur rôti.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[8250] = {n:"Poil de Renarbo",t:54,d:"Le Renarbo adore se travestir en Corbac, personne ne sait réellement pourquoi, même si les esprits les plus mal tournés ont leur avis sur la question...",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[8251] = {n:"Poil de Péki",t:54,d:"Qui aurait pu croire que le Péki accepterait de se délester d\'une touffe de poils pour vos beaux yeux ? Personne, à part Joche Banette, célèbre idiot du village d\'Amakna, réputé pour son affection maladive pour les Pékis empaillés.",ep:18,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[8252] = {n:"Plume de Corbac Apprivoisé",t:53,d:"Cette plume bien grasse est celle d\'un Corbac Apprivoisé, qui a passé la majeure partie de son existence, enfermé, et gavé jusqu\'à ce qu\'il occupe totalement l\'espace de sa cage.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[8253] = {n:"Amulette en Mousse",t:1,d:"Cette amulette est souvent confondue avec un jouet à trouver dans des pochettes surprises, alors qu\'en fait elle se gagne au stand de tir.",ep:1,g:106,l:11,wd:true,fm:true,w:2,s:63,p:525};
I.u[8254] = {n:"Anneau en Mousse",t:9,d:"Offert en alliance, cet anneau permet de faire passer deux messages à l\'être aimé : \"Je t\'aime\" et \"Va faire la vaisselle\". Idéal pour ne pas perdre son temps en répétant tous les soirs la même chose.",ep:1,g:112,l:10,wd:true,fm:true,w:2,s:63,p:500};
I.u[8255] = {n:"Pelle en Mousse",t:8,d:"Cette arme terriblement puissante contre les mottes de terre, a marqué plus d\'un aventurier débutant. Une fois mouillée, elle devient molle et peut être roulée, mais il faut généralement être à deux pour y arriver.",ep:1,g:44,l:10,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,true],s:63,p:500};
I.u[8256] = {n:"Bottes en Mousse",t:11,d:"Avec ces bottes, un Eniripsa peut marcher sur l\'eau, ce qui ne sert à rien puisqu\'il peut voler, mais ça impressionne toujours les foules. Les autres pourront toujours se servir de ces bottes pour se gratter les pieds en marchant, ou tout simplement pour les nettoyer.",ep:1,g:84,l:11,wd:true,fm:true,w:5,s:63,p:525};
I.u[8257] = {n:"Ceinture en Mousse",t:10,d:"Cette ceinture permettait à Vald de prendre son bain sans danger car aucun Iop n\'a encore réussi à apprendre à nager.",ep:1,g:102,l:10,wd:true,fm:true,w:5,s:63,p:500};
I.u[8258] = {n:"Cape en Mousse",t:17,d:"Cette cape est idéale pour le camouflage en milieu naturel, mais uniquement s\'il n\'y a personne pour vous voir.",ep:1,g:109,l:10,wd:true,fm:true,w:1,s:63,p:505};
I.u[8259] = {n:"Coiffe en Mousse",t:16,d:"Sur la notice de cette coiffe, on peut lire :\"Offrez cette coiffe à votre mari, accrochez-la solidement sur sa tête et traînez-le par les pieds dans votre cuisine. Voilà le sol est propre désormais\". Cela résume un peu la conception moderne du ménage et de la répartition des tâches ménagères au sein des couples épanouïs et qui s\'assument.",ep:1,g:143,l:11,wd:true,fm:true,w:10,s:63,p:525};
I.u[8260] = {n:"Bandeau Kaliptus",t:16,d:"Avec ce bandeau, les Iops n\'auront jamais été aussi séduisants !",ep:20,g:124,l:133,wd:true,fm:true,w:10,p:43500};
I.u[8262] = {n:"La Meulette",t:1,d:"La Meulette renferme une étrange substance trouvée dans les entrailles du Meulou, d\'aucuns prétendent qu\'il s\'agit de l\'essence du monstre, d\'autres pensent qu\'il avait juste dévoré un Kirboule pas très frais.",ep:20,g:107,l:143,wd:true,fm:true,w:1,s:55,p:44850};
I.u[8263] = {n:"Anneau du Meulou",t:9,d:"Attention, cet anneau rendra votre doigt particulièrement malodorant. Une odeur qui risque d\'en couvrir une autre. C\'est peut-être pour votre doigt et votre entourage une très bonne chose...",ep:20,g:113,l:126,wd:true,fm:true,w:10,s:55,p:40190};
I.u[8264] = {n:"Bottes du Meulou",t:11,d:"Ces bottes sont encore animées d\'une partie de l\'appétit vorace du Meulou. Si vos pieds sentent le Clakoss, elles risquent de vous les mordre.",ep:18,g:85,l:131,wd:true,fm:true,w:20,s:55,p:42840};
I.u[8265] = {n:"Cape du Meulou",t:17,d:"Le Meulou a la queue si belle et si longue qu\'elle traîne au sol. Certains aventuriers jaloux la lui ont arrachée et la portent, espérant sûrement y gagner en virilité.",ep:20,g:110,l:139,wd:true,fm:true,w:10,s:55,p:44500};
I.u[8266] = {n:"Ceinture du Meulou",t:10,d:"Cette ceinture colorée est dotée d\'une superbe touffe violacée sur le devant, vous pouvez également la porter à l\'envers pour vous travestir en Wabbit.",ep:20,g:103,l:125,wd:true,fm:true,w:1,s:55,p:1};
I.u[8267] = {n:"Coiffe du Meulou",t:16,d:"En dépeçant le Meulou, des chasseurs se sont aperçus qu\'il ne possède qu\'une seule grosse corne qui traverse son crâne de part en part, ce qui ne gène nullement les Iops qui la portent avec enthousiasme non dissimulé.",ep:4,g:144,l:141,wd:true,fm:true,w:10,s:55,p:44600};
I.u[8268] = {n:"Collier du Minotoror",t:1,d:"Ce collier permettait au Minotoror de ne pas avoir de puces, de tiques, ou même de poux. De toute évidence, vous en aviez besoin.",ep:18,g:112,l:111,wd:true,fm:true,w:1,s:54,p:31260};
I.u[8269] = {n:"Anneau du Minotoror",t:9,d:"Contrairement à ce que certains aventuriers rapportent, cet anneau n\'a jamais été porté par le Minotoror, incapable d\'enfiler un tel anneau autour de ses sabots.",ep:21,g:117,l:105,wd:true,fm:true,w:1,s:54,p:28010};
I.u[8270] = {n:"Bracelet du Minotot",t:9,d:"Ce bracelet permet de protéger entièrement le bras d\'un Eniripsa, mais triple son poids.",ep:21,g:116,l:151,wd:true,fm:true,w:10,s:57,p:45425};
I.u[8271] = {n:"Anneau du Dragon Cochon",t:9,d:"Cet anneau en cuir et en ivoire permet de stimuler plus facilement vos partenaires.",ep:18,g:115,l:108,wd:true,fm:true,w:1,s:58,p:29600};
I.u[8272] = {n:"Collier du Minotot",t:1,d:"Ce collier permettait aux Minotot, de protéger ses cervicales et d\'éviter de périr à cause d\'un stupide coup du Wabbit.",ep:21,g:111,l:158,wd:true,fm:true,w:20,s:57,p:47800};
I.u[8273] = {n:"Collier du Dragon Cochon",t:1,d:"Ce collier dispose d\'une petite boucle, qui permettait d\'accrocher une laisse au cou du Dragon Cochon, lorsque son propriétaire voulait l\'emmener faire une petite promenade nocturne.",ep:21,g:110,l:100,wd:true,fm:true,w:1,s:58,p:25470};
I.u[8274] = {n:"Hache du Minotoror",t:19,d:"Cette hache a permis de trancher la tête d\'un des plus dangereux Minotorors que la province d\'Amakna ait connu. Le plus incroyable dans cette histoire c\'est qu\'elle semble vous laisser indifférent.",ep:21,g:44,l:109,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,40,50,false,true],s:54,p:30110};
I.u[8275] = {n:"Sceptre du Minotot",t:4,d:"Ce Sceptre orné à son extrémité d\'une tête de Serpentin en pierres précieuses, permet d\'effrayer les jeunes aventuriers, afin de les faire fuir, et de botter leurs petites fesses toutes roses.",ep:21,g:67,l:151,wd:true,fm:true,w:50,an:12,tw:true,e:[5,4,1,1,40,50,false,false],s:57,p:46200};
I.u[8276] = {n:"Bottes du Minotoror",t:11,d:"De toute évidence, ces terribles bottes en poils et en cuir de Minotoror, sont bien trop lourdes pour vous faire gagner la légendaire course à pieds de la baie d\'Amakna. Cependant, elles devraient vous permettre d\'écraser facilement les pieds des autres concurrents sur la ligne de départ.",ep:21,g:89,l:113,wd:true,fm:true,w:40,s:54,p:32290};
I.u[8277] = {n:"Sandales du Minotot",t:11,d:"Ces incroyables sandales vous permettront de vous baigner dans les eaux les plus dangereuses, sans risquer de vous abîmer les pieds. Attention cependant, elles ont la réputation de rayer le fond des baignoires.",ep:21,g:88,l:163,wd:true,fm:true,w:20,s:57,p:48400};
I.u[8278] = {n:"Mules du Dragon Cochon",t:11,d:"Une bonne paire de mules et vous vous sentez de suite plus fort, plus puissant, plus performant. Alors que ce ne sont que des mules.",ep:20,g:87,l:93,wd:true,fm:true,w:5,s:58,p:22800};
I.u[8279] = {n:"Cape du Minotoror",t:17,d:"Prenez un Minotoror, attachez-le fermement, prenez un rabot géant, et pelez-lui (en un seul passage) le dos. Voilà, c\'est fait, vous avez désormais entre les mains, une cape du Minotoror.",ep:21,g:117,l:109,wd:true,fm:true,w:10,s:54,p:30500};
I.u[8280] = {n:"Cape du Minotot",t:17,d:"Pour sortir en soirée, ou séduire au bal masqué du Captain Chafer, c\'est la cape qu\'il vous faut.",ep:21,g:116,l:156,wd:true,fm:true,w:40,s:57,p:48850};
I.u[8281] = {n:"Cape du Dragon Cochon",t:17,d:"Cette cape ne fera pas de vous un petit Cochon de Lait, mais elle vous permettra peut-être de vous travestir l\'espace d\'une soirée, afin de séduire une belle Cochonne.",ep:20,g:118,l:103,wd:true,fm:true,w:10,s:58,p:27500};
I.u[8282] = {n:"Ceinture du Minotoror",t:10,d:"Cette ceinture est si souple, qu\'elle peut servir à fouetter les fesses des enfants trop turbulents. Avec un peu de chance, ses ferrures permettront d\'arracher quelques lambeaux de chair, et les terribles garnements qui vous servent de marmaille auront compris une bonne fois pour toute la leçon.",ep:21,g:106,l:111,wd:true,fm:true,w:1,s:54,p:1};
I.u[8283] = {n:"Ceinture du Minotot",t:10,d:"Cette ceinture rigide, permettait au Minotot, de contenir son énorme bedaine, afin de ne pas basculer en avant au moindre courant d\'air.",ep:21,g:105,l:149,wd:true,fm:true,w:30,s:57,p:49950};
I.u[8284] = {n:"Coiffe du Minotot",t:16,d:"Cette coiffe se transmet dans la famille du Minotot, de génération en génération. Ce qui explique en partie son odeur de pellicules en décomposition.",ep:21,g:151,l:157,wd:true,fm:true,w:20,s:57,p:47652};
I.u[8285] = {n:"Coiffe du Dragon Cochon",t:16,d:"Affublé de cet énorme crâne, vous aurez l\'air d\'un Grizboule à poils durs, mais sans poils. De quoi laisser sans voix vos admiratrices.",ep:20,g:150,l:98,wd:true,fm:true,w:10,s:58,p:24500};
I.u[8286] = {n:"Cape Dragoeuf",t:17,d:"Cette cape recouverte d\'écailles vous protègera d\'après la légende, de la foudre, des haricots, et surtout des femmes fatales.",ep:11,g:115,l:127,wd:true,fm:true,w:10,s:56,p:41000};
I.u[8287] = {n:"Casque Dragoeuf",t:16,d:"Ce casque absolument terrifiant et d\'une taille démesurée ferait passer un petit chérubin comme vous, pour un impitoyable guerrier venu de l\'au delà. Cloué sur un mur, il fera un excellent porte manteau.",ep:11,g:149,l:128,wd:true,fm:true,w:10,s:56,p:41500};
I.u[8288] = {n:"Ceinture du Dragoeuf",t:10,d:"Les esprits les plus pervertis d\'Amakna, racontent que cette ceinture pouvait servir de prothèse. Personne ne comprend pourquoi, et heureusement il n\'en n\'est rien, ce n\'est qu\'une banale ceinture du Dragoeuf.",ep:20,g:104,l:124,wd:true,fm:true,w:1,s:56,p:1};
I.u[8289] = {n:"Anneau du Dragoeuf",t:9,d:"Cet anneau directement taillé dans une écaille géante de Dragoeuf protègera une petite partie d\'une de vos phalanges. Sûrement la plus importante.",ep:20,g:114,l:128,wd:true,fm:true,w:10,s:56,p:41468};
I.u[8290] = {n:"Amulette du Dragoeuf",t:1,d:"Confectionnée à partir d\'écailles de Dragoeufs, cette amulette protégera efficacement votre pomme d\'Adam, ou vos amygdales.  De quoi faire la différence sur un champ de bataille.",ep:11,g:108,l:124,wd:true,fm:true,w:1,s:56,p:38930};
I.u[8291] = {n:"Bottes du Dragoeuf",t:11,d:"Ces bottes sont parfaites pour tuer le Bouftou lors d\'une partie de Boufball ou pour faire souffrir un peu plus vos ennemis lors d\'un botte-fesses.",ep:20,g:86,l:129,wd:true,fm:true,w:20,s:56,p:41500};
I.u[8292] = {n:"Epée du Dragoeuf",t:6,d:"Aiguisée comme le rasoir du soir, cette lame vous permettra tout de même de vous raser le matin, mais uniquement les aisselles.",ep:11,g:68,l:127,wd:true,fm:true,w:30,an:14,e:[8,5,1,1,40,50,false,true],c:"CS>200&CA>200",p:41025};
I.u[8293] = {n:"Hache du Dragoeuf",t:19,d:"Cette hache fend le beurre aussi facilement que les crânes, à moins que ça ne soit l\'inverse.",ep:20,g:43,l:126,wd:true,fm:true,w:20,an:17,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>180&CW>80",p:40854};
I.u[8294] = {n:"Marteau du Dragoeuf",t:7,d:"Plus lourd qu\'un crâne vide de Krokeur, mais moins solide qu\'un fémur de Kirboule des cavernes, ce marteau reste néanmoins une arme redoutable.",ep:20,g:59,l:123,wd:true,fm:true,w:30,an:15,e:[10,5,1,1,45,50,false,true],c:"CI>200&CC>100",p:38542};
I.u[8295] = {n:"Arc du Dragoeuf",t:2,d:"Cet arc est si puissant qu\'il permet d\'envoyer des oeufs pourris de Dragoeufs au dessus des murailles de Brâkmar. Quel beau gâchis !",ep:20,g:55,l:122,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,8,40,50,false,true],c:"CS>300&CV>250",p:38015};
I.u[8296] = {n:"Baguette du Dragoeuf",t:3,d:"Cette baguette semble plus efficace lorsqu\'elle est utilisée comme un gourdin ou comme une tapette à Moskitos.",ep:21,g:60,l:124,wd:true,fm:true,w:10,an:11,e:[5,3,2,5,30,30,false,true],c:"CI>100&CA>200",p:37884};
I.u[8297] = {n:"Bâton du Dragoeuf",t:4,d:"Ce bâton est muni à son extrémité, d\'une grosse pointe dont personne ne connaît l\'origine. En revanche, les aventuriers avertis connaissent sa destination...",ep:20,g:66,l:124,wd:true,fm:true,w:30,an:12,tw:true,e:[5,5,1,1,30,50,false,true],c:"CS>300&CA>150&CV>300",p:39800};
I.u[8298] = {n:"Epis de Shika",t:1,d:"Shika assistait Farle lors des moissons, en récupérant les épis magiques qui tombaient sous sa faux. Elle prit l\'habitude au fil des moissons, de les accrocher autour de son cou. Privés de leurs racines et du reste de leur tige, ces épis magiques continuent tout de même de mûrir chaque année à la même période.",ep:18,g:113,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8299] = {n:"Bracelet Magique de Shika",t:9,d:"Ce bracelet couvrait les bras de Shika, la protégeant des coups de soleil, et des coups de bec des Corbacs attirés par sa beauté rayonnante. Ils sont encore imprégnés de sa sueur suave.",ep:21,g:118,l:80,wd:true,fm:true,w:5,s:53,p:16500};
