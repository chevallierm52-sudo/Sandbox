I.u[7799] = {n:"Le Saut Sifflard",t:94,d:"Faîtes une pause en pleine nature, sortez votre Saut Sifflard et votre monture arrivera aussi rapidement qu\'un Wabbit en manque de Cawottes.",ep:20,g:1,l:60,wd:true,fm:true,w:1,u:true,p:1000};
