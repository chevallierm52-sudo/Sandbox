I.u[233] = {n:"Kaiser",t:7,d:"Kaiser est le nom d\'un Dragon Cochon qui jadis dévasta le village de Bounkaïda. Lorsque la milice eut enfin raison du monstre, les forgerons créèrent de nombreuses armes à partir des restes de la bête. Ce marteau en fait partie.",ep:2,g:10,l:82,wd:true,fm:true,w:20,an:15,e:[20,4,1,1,30,200,false,false],c:"CS>80&CI>80&CA>50",s:58,p:10000};
