I.u[270] = {n:"Xaveur",t:2,d:"Le Xaveur est un arc efficace. Il appartenait au grand Xavier le Boulanger. Entre deux fournées, il partait distribuer des pains aux monstres entourant sa boulangerie.",ep:7,g:5,l:60,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,9,30,100,false,true],c:"CA>60&CV>15",p:9050};
I.u[271] = {n:"Le Marteau du Chafer",t:7,d:"Une belle arme étrange et fascinante, elle vous permettra de vous battre au corps à corps comme le ferait le meilleur des Chafers.",ep:1,g:9,l:21,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,40,30,false,false],c:"CS>10&CI>11",p:1350};
I.u[272] = {n:"Nomoon",t:2,d:"Cet arc est assez puissant pour envoyer une flèche sur la lune.",ep:7,g:9,l:28,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,12,30,50,false,true],c:"CA>28&CV>5",p:2350};
I.u[273] = {n:"La Corde de Yamato",t:2,d:"La Corde de Yamato a fait vibrer plus d\'un coeur de monstre. Arme fine, elle est capable de diriger sa flèche dans les endroits les plus cachés.",ep:7,g:10,l:33,wd:true,fm:true,w:18,an:10,tw:true,e:[10,4,2,7,30,50,false,false],c:"CA>33&CS>10",p:3000};
I.u[274] = {n:"Pièce du Puzzle de la Griffe",t:51,d:"Une pièce très rare du trésor de Dodge, l\'un des plus grands Ecaflip d\'Amakna.",ep:1,g:267,l:12,wd:true,fm:true,w:1,p:100};
I.u[276] = {n:"Pièce du Trésor du Badoul",t:15,d:"Une pièce très rare d\'un trésor caché par le célèbre Dodge, l\'un des plus grands guerriers Ecaflip d\'Amakna.",ep:1,g:268,l:12,wd:true,fm:true,w:1,p:100};
I.u[278] = {n:"Anneau des Rocheuses",t:9,d:"Anneau serti d\'une pierre rare. Il doit son nom aux différentes pierres nécessaires à sa confection.",ep:1,g:4,l:15,wd:true,fm:true,w:4,p:800};
I.u[279] = {n:"La Larme du Bouftou",t:1,d:"Selon un illustre aventurier, cette amulette contient une larme de Bouftou, à l\'odeur et aux propriétés semblables à celles des décoctions de cuir de bouftou.",ep:1,g:7,l:2,wd:true,fm:true,w:5,p:200};
I.u[280] = {n:"Collier de l\'Arc en Ciel",t:1,d:"Ce collier est recherché par les collectionneurs, vous en tirerez un bon prix.",ep:1,g:11,l:6,wd:true,fm:true,w:6,p:300};
I.u[281] = {n:"Pomme",t:42,d:"Cette pomme restaure quelques points de vie perdus. Posée sur la tête d\'un ami, elle pourra vous servir de cible.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[282] = {n:"Fiole de Soin supérieure",t:12,d:"Cette fiole restaure quelques points de vie perdus.",ep:1,g:39,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[283] = {n:"Fiole de Soin",t:12,d:"Cette fiole restaure quelques points de vie perdus.",ep:1,g:3,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[284] = {n:"Sel",t:48,d:"Le sel est un minéral, moulu, il vous permet de donner du goût à vos pains.",ep:2,g:260,l:1,wd:true,fm:true,w:1,p:10};
I.u[285] = {n:"Farine de Blé",t:52,d:"La farine s\'obtient en écrasant des grains de blé, elle est très utile pour faire du pain, des crêpes, des gaufres et de délicieux gâteaux, mais surtout pour enfariner vos ennemis d\'enfance.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[286] = {n:"Levure de Boulanger",t:48,d:"C\'est un ingrédient indispensable pour la fermentation du pain.",ep:1,g:137,l:1,wd:true,fm:true,w:1,p:1};
I.u[287] = {n:"Graine de Sésame",t:58,d:"Cette graine extrêmement riche en protéines permet de réaliser de délicieux pains, mais la culture du sésame est délicate sous le climat d\'Amakna, ce qui en fait une graine rare et chère.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[288] = {n:"Graine de Tournesol sauvage",t:58,d:"Cette graine riche en protéines permet de donner une saveur très particulière aux pains. La seule façon d\'en trouver c\'est de tuer un Tournesol sauvage ou de l\'acheter !",ep:1,g:6,l:12,wd:true,fm:true,w:1,p:10};
I.u[289] = {n:"Blé",t:34,d:"Le Blé est depuis la nuit des temps un ingrédient indispensable dans l\'alimentation des habitants d\'Amakna et des Tofus.",ep:1,g:9,l:1,wd:true,fm:true,w:2,p:0};
I.u[290] = {n:"Champignon",t:15,d:"Avec ou sans crème, les champignons sont toujours aussi bons. La manière la plus simple de s\'en procurer reste de tuer un Champ-Champ.",ep:1,g:1,l:5,wd:true,fm:true,w:1,p:10};
I.u[291] = {n:"Poils du Mulou",t:54,d:"Ces poils ne sont pas comme tous les poils, ils disposent de propriétés particulières qui les rendent très appréciés des alchimistes.",ep:1,g:8,l:70,wd:true,fm:true,w:1,p:1};
I.u[292] = {n:"Testicules du Mulou",t:15,d:"Ces énormes testicules sont recouverts d\'un étrange duvet particulièrement doux et chaud. Il est presque impossible de les récupérer intacts après un combat face à un Mulou, ce qui explique en partie leur prix scandaleux.",ep:1,g:10,l:70,wd:true,fm:true,w:20,p:50};
I.u[293] = {n:"Petite Pelle du Craqueleur",t:8,d:"La seule chose qui soit aussi solide qu\'un Craqueleur, c\'est un Craqueleur, voilà pourquoi cette pelle, destinée à la chasse aux craqueleurs, est en Pierre de Craqueleur.",ep:1,g:7,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1200};
I.u[294] = {n:"Pelle du Craqueleur",t:8,d:"La seule chose qui soit aussi solide qu\'un Craqueleur, c\'est un Craqueleur, voilà pourquoi cette pelle destinée à la chasse aux craqueleurs est en Pierre de Craqueleur.",ep:1,g:7,l:23,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>8&CC>15",p:1600};
I.u[295] = {n:"Grande Pelle du Craqueleur",t:8,d:"La seule chose qui soit aussi solide qu\'un Craqueleur, c\'est un Craqueleur, voilà pourquoi cette pelle destinée à la chasse aux craqueleurs est en Pierre de Craqueleur.",ep:1,g:7,l:26,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>11&CC>15",p:2000};
I.u[296] = {n:"Puissante Pelle du craqueleur",t:8,d:"La seule chose qui soit aussi solide qu\'un Craqueleur, c\'est un Craqueleur, voilà pourquoi cette pelle destinée à la chasse aux craqueleurs est en Pierre de Craqueleur.",ep:1,g:7,l:29,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>14&CC>15",p:2400};
I.u[297] = {n:"Bottes du Petit Bouftou",t:11,d:"Ces bottes sont confectionnées en cuir de Bouftou, elles permettent aux éleveurs de s\'approcher plus facilement des Bouftous pour les tuer, grâce à l\'odeur qu\'elles dégagent.",ep:1,g:3,l:1,wd:true,fm:true,w:2,p:100};
I.u[298] = {n:"Sandales Tofuesques",t:11,d:"Ces sandales sont faites à partir de plumes de Tofu bouilli, et la semelle est en Bec de Tofu inusable. Pour des raisons encore inexpliquées, elles rendent parfois leur porteur un peu débile...comme un Tofu.",ep:1,g:4,l:1,wd:true,fm:true,w:7,p:100};
I.u[299] = {n:"Bottes de Faillete",t:11,d:"La meilleure défense c\'est l\'attaque, ces bottes anti-agression vous permettront d\'exterminer un groupe d\'agresseurs sans aucune difficulté.",ep:1,g:8,l:24,wd:true,fm:true,w:30,p:1800};
I.u[300] = {n:"Graine de Pavot",t:58,d:"Cette graine confère des vertus hallucinogènes aux pains prisés des aventuriers qui désirent se reposer après un combat difficile.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:1};
I.u[301] = {n:"Plumes de Tofu",t:53,d:"Les plumes de Tofu sont très utilisées en couture pour les rembourrages divers. Et surtout, n\'oubliez pas, un kilo de plumes de Tofu pèse autant qu\'un kilo de plomb.",ep:1,g:14,l:4,wd:true,fm:true,w:1,p:10};
I.u[302] = {n:"Citrouille",t:68,d:"Les citrouilles poussent dans les champs, à peine plus grosses que les testicules de mulou, elles ont en revanche bien meilleur goût.",ep:4,g:12,l:15,wd:true,fm:true,w:5,p:10};
I.u[303] = {n:"Bois de Frêne",t:38,d:"Le Bois de Frêne n\'est pas un bois de qualité, mais il est abondant et pousse relativement vite. Attention tout de même à ne pas le stocker près d\'une forte source de chaleur, il est inflammable.",ep:1,g:17,l:1,wd:true,fm:true,w:5,p:0};
I.u[304] = {n:"Cuir de Bouftou",t:56,d:"Ce cuir très résistant constitue la principale ressource des tanneurs qui en font des bottes, des ceintures et même des lanières de fouet. Son seul inconvénient, c\'est d\'avoir l\'odeur de la sueur de Bouftou en rut... ce qui ne favorise pas les rencontres.",ep:1,g:16,l:9,wd:true,fm:true,w:2,p:1};
I.u[305] = {n:"Dent de Wabbit",t:47,d:"Abîmées à force de ronger des cawottes, les dents de Wabbit sont tout de même très utiles lors de la confection de potions grâce à leurs propriétés revigorantes.",ep:8,g:13,l:20,wd:true,fm:true,w:1,p:1};
I.u[306] = {n:"Fleur de Pissenlit Diabolique",t:35,d:"Correctement bouillie puis séchée, cette fleur perd ses propriétés toxiques et peut se consommer en tisane, mais la fleur de Pissenlit Diabolique est surtout utilisée pour amuser la jeunesse en quête de romantisme. En effet, qui n\'a jamais soufflé sur une fleur de Pissenlit Diabolique pour envoyer dans le cou de l\'être tant convoité, ces magnifiques graines, douces comme la caresse d\'une éclaircie sur les feuilles d\'un charme encore imprégnées de rosée ? Peut-être les Iops, qui au lieu de souffler, ont tendance à aspirer les graines et à s\'étouffer lamentablement dans d\'atroces convulsions.",ep:1,g:18,l:5,wd:true,fm:true,w:1,p:10};
I.u[307] = {n:"Ailes de Moskito",t:104,d:"Ces ailes très fines ont la particularité de favoriser la réflexion des personnes qui osent les mâcher. Leur goût est assez proche des oeufs de Kwak pourris, c\'est pour cela qu\'elles sont essentiellement utilisées pour les potions de sagesse.",ep:1,g:19,l:2,wd:true,fm:true,w:1,p:1};
I.u[308] = {n:"Coquille de Dragoeuf Blanc",t:111,d:"Cette coquille est presque incassable, cependant, en la polissant pendant des générations, les meilleurs Bijoutiers peuvent utiliser ses facultés magiques pour confectionner des amulettes aux pouvoirs exceptionnels.",ep:11,g:21,l:64,wd:true,fm:true,w:5,p:1};
I.u[309] = {n:"Pétale de Rose Démoniaque",t:35,d:"Ces pétales ont des vertus aphrodisiaques très puissantes, ce qui en fait le cadeau idéal pour conquérir l\'élu(e) de votre coeur. Éviter de les consommer en infusion est une sage décision dans la mesure où leurs effets se retrouvent être inversés.",ep:1,g:20,l:6,wd:true,fm:true,w:1,p:10};
I.u[310] = {n:"Os de Chafer",t:47,d:"Cet os est presque incassable, mais au contact de l\'eau, il devient tout mou, ce qui facilite son utilisation par les alchimistes.",ep:1,g:15,l:34,wd:true,fm:true,w:5,p:1};
I.u[311] = {n:"Eau",t:15,d:"L\'eau est utile pour de nombreuses choses, et plus elle est trouble, plus elle donnera de goût à la bière (méfiez-vous tout de même, l\'eau bue explose).",ep:1,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[312] = {n:"Fer",t:39,d:"Le fer est très utile pour les forgerons et pour ceux qui utilisent du métal, certains s\'en servent même pour repasser.",ep:1,g:24,l:1,wd:true,fm:true,w:5,p:0};
I.u[313] = {n:"Or",t:39,d:"L\'or est un métal rare et précieux, ses qualités intrinsèques en font un métal de choix pour la conception d\'armes ou d\'objets particulièrement puissants et d\'esthétique raffinée.",ep:1,g:22,l:80,wd:true,fm:true,w:5,p:0};
I.u[315] = {n:"Diamant",t:50,d:"Tous les bijoutiers d\'Amakna raffolent de cette pierre qui demande une excellente dextérité pour être travaillée. Il faut souvent s\'aventurer dans de dangereuses mines pour les trouver, mais heureusement, les diamants sont éternels.",ep:1,g:25,l:50,wd:true,fm:true,w:10,p:5000};
I.u[316] = {n:"Emeraude",t:50,d:"Avec son vert intense, cette magnifique pierre précieuse peut facilement transformer un thon en princesse, sans l\'utilisation d\'une quelconque magie occulte.",ep:1,g:23,l:50,wd:true,fm:true,w:10,p:5000};
I.u[317] = {n:"Bâton du Petit Tabi",t:4,d:"Ce bâton servait à l\'origine aux éleveurs d\'Amakna qui voulaient contrôler plus facilement leurs troupeaux de Tabis, ce bâton est en effet si léger, qu\'il permet à son porteur de courir après les Tabis égarés sans se fatiguer.",ep:7,g:6,l:30,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:2650};
I.u[318] = {n:"Bâton du Tabi",t:4,d:"Ce bâton servait à l\'origine aux éleveurs d\'Amakna qui voulaient contrôler plus facilement leurs troupeaux de Tabis, ce bâton est en effet si léger, qu\'il permet à son porteur de courir après les Tabis égarés sans se fatiguer.",ep:7,g:6,l:34,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:3200};
I.u[319] = {n:"Bâton du Grand Tabi",t:4,d:"Ce bâton servait à l\'origine aux éleveurs d\'Amakna qui voulaient contrôler plus facilement leurs troupeaux de Tabis, ce bâton est en effet si léger, qu\'il permet à son porteur de courir après les Tabis égarés sans se fatiguer.",ep:7,g:6,l:37,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>25",p:3750};
I.u[320] = {n:"Bâton du Puissant Tabi",t:4,d:"Ce bâton servait à l\'origine aux éleveurs d\'Amakna qui voulaient contrôler plus facilement leurs troupeaux de Tabis, ce bâton est en effet si léger, qu\'il permet à son porteur de courir après les Tabis égarés sans se fatiguer.",ep:7,g:6,l:40,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>30",p:4300};
I.u[323] = {n:"Amulette du Kam Assutra",t:1,d:"Cette amulette donne des facultés très particulières à son porteur, en effet ce dernier se voit comme transporté par une aura mystérieuse parcourant son corps, ce qui généralement a pour effet de décupler ses capacités physiques.",ep:1,g:4,l:43,wd:true,fm:true,w:5,p:5000};
I.u[324] = {n:"Amulette de Krokette",t:1,d:"Cette amulette a la faculté de devenir rose les jours où son porteur est d\'humeur guillerette. On raconte qu\'elle décuple également vos chances de trouver de bons objets.",ep:1,g:7,l:6,wd:true,fm:true,w:5,p:300};
I.u[325] = {n:"Amulette du Sram",t:1,d:"Cette amulette confectionnée à partir de petits crânes taillés dans de l\'os, par un des plus grands bijoutiers Sram, est unique en son genre. Elle permet à son porteur de s\'évader plus facilement lors des situations périlleuses.",ep:1,g:3,l:2,wd:true,fm:true,w:5,p:200};
I.u[326] = {n:"Amulette Deulegarnoulle",t:1,d:"Cette amulette provient des régions nordiques, elle confère a son porteur la capacité d\'invoquer plus facilement des créatures.",ep:1,g:2,l:33,wd:true,fm:true,w:4,p:3000};
I.u[327] = {n:"Lame du Chevaucheur de Karne",t:6,d:"Cette lame forgée à l\'origine pour les Chevaucheurs de Karne, était en fait bien trop lourde pour ces faibles gobelins. Elle n\'en reste pas moins très légère pour un individu normal, ce qui lui permet de frapper très vite.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,50,20,false,false],c:"CS>32",p:900};
I.u[328] = {n:"Koupe-koupe",t:6,d:"Cette lame double à la forme bien étrange servait à l\'origine à élaguer les arbres pour progresser dans les forêts denses. Les bûcherons se sont vite aperçus qu\'elle constituait une arme de choix pour exterminer toute forme de menace.",ep:1,g:4,l:18,wd:true,fm:true,w:28,an:14,e:[6,5,1,1,20,60,false,false],c:"CS>36",p:1050};
I.u[329] = {n:"Arc de Triomphe",t:2,d:"Comme son nom l\'indique, cet arc permet de gagner facilement un combat. Un grand architecte Crâ sans imagination a même utilisé le nom de cet arc pour nommer une de ses constructions.",ep:7,g:11,l:30,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,10,30,50,false,true],c:"CA>30&CC>5&CS>10",p:1950};
I.u[331] = {n:"Arc Hancihaile",t:2,d:"C\'est l\'arc le plus recherché de tout Amakna, on raconte que là où ses flèches retombent, on peut trouver un trésor. Étrangement, il ne semble être efficace que lorsque pluie et rayons de soleil se mêlent.",ep:7,g:16,l:22,wd:true,fm:true,w:19,an:10,tw:true,e:[10,5,2,11,30,50,false,true],c:"CA>22&CC>15",p:1500};
I.u[332] = {n:"Arc de Jeanne",t:2,d:"Jeanne était un peu folle, elle entendait des Tabis roter dans sa tête. Pour éviter qu\'elle ne se blesse avec son arc, il lui a été confisqué et on a décidé de la brûler vive pour réchauffer l\'ambiance lors de l\'inauguration de la taverne.",ep:7,g:15,l:30,wd:true,fm:true,w:23,an:10,tw:true,e:[10,4,2,9,30,50,false,true],c:"CS>10&CA>30",p:2550};
I.u[333] = {n:"Baguette Deuh-Pain",t:3,d:"À l\'origine destinée à être mangée, cette baguette est devenue une arme redoutée. En effet, Xavier le Boulanger l\'a oubliée dans son four pendant 234 ans alors qu\'il était parti distribuer des pains aux monstres autour de sa boulangerie.",ep:3,g:9,l:50,wd:true,fm:true,w:1,an:11,e:[5,3,3,5,50,50,false,true],c:"CW>40&CI>100",p:6650};
I.u[334] = {n:"Baguette de Liriel",t:3,d:"Cette baguette appartenait à l\'Eniripsa Liriel qui mourût d\'une overdose de fraises dans d\'atroces souffrances, perdant ses ailes dans un râle de douleur à vous glacer le sang. Les collectionneurs s\'arrachent cette baguette réputée maudite.",ep:7,g:5,l:20,wd:true,fm:true,w:13,an:11,e:[5,5,2,3,50,50,false,true],c:"CI>40",p:1300};
I.u[335] = {n:"Bâton du Bwork Mage",t:4,d:"Sans leur bâton, les Bwork Mages sont aussi inoffensifs que les Tofus sans leur Bécos. Voilà qui en dit long sur la puissance de ce bâton.",ep:7,g:1,l:58,wd:true,fm:true,w:28,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>58&CA>20",p:8900};
I.u[336] = {n:"Bâton du Grand Pa Wabbit",t:4,d:"Ce bâton a la faculté de pouvoir faire léviter les Cawottes, on se demande bien à quoi cela peut servir en combat.",ep:8,g:1,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",p:2900};
I.u[337] = {n:"Arc du Bwork Archer",t:2,d:"C\'est un arc très simple à utiliser, il a été conçu pour s\'adapter à l\'intelligence d\'un Bwork Archer, ce qui le rend presque utilisable par un Tofu. En revanche, il nécessite une force de Craqueleur pour être bandé.",ep:7,g:4,l:20,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>20&CA>20",p:1300};
I.u[338] = {n:"Lame du Petit Bwork",t:6,d:"Cette épée d\'apparence rudimentaire est très appréciée des Bworks les plus débiles, qui ne savent pas se servir d\'un arc ou d\'un bâton, certains confondent même la lame et le manche ce qui ne manque pas de faire rire leurs adversaires.",ep:1,g:13,l:21,wd:true,fm:true,w:30,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>42",p:1400};
I.u[339] = {n:"Lame du Chafer",t:6,d:"Cette lame appartenait à Metzger le boucher, elle avait été forgée pour découper les os. Le Chafer a cependant réussi à lui dérober son outil, devenu maintenant une arme très redoutée qui est à l\'origine de nombreuses amputations.",ep:1,g:5,l:27,wd:true,fm:true,w:20,an:14,e:[20,6,1,1,15,60,false,false],c:"CS>54&CC>10",p:2100};
I.u[340] = {n:"Leurnettes",t:5,d:"Ces dagues permettent selon la légende de voler tout et n\'importe quoi, mais surtout n\'importe quoi à n\'importe qui, où l\'inverse, mais plus personne ne se souvient de la légende avec exactitude.",ep:1,g:9,l:12,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>12",p:600};
I.u[341] = {n:"Dagues Eurfolles",t:5,d:"Ces dagues légendaires constituent de vraies pièces de collection pour tout Sram qui se respecte, elles sont tellement vénérées, que certains Srams se refusent à les voler.",ep:7,g:10,l:46,wd:true,fm:true,w:10,an:13,e:[10,2,1,1,30,50,false,false],c:"CA>46",p:5600};
I.u[342] = {n:"Marteau Pickeur",t:7,d:"Ce marteau très particulier a été confectionné à partir de becs de Kwaks, ce qui explique pourquoi il pique très fort lorsque l\'on se prend un coup de ce marteau.",ep:5,g:12,l:18,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>12&CS>6",p:1100};
I.u[345] = {n:"Petite Pelle Teuze",t:8,d:"Après une soirée un peu trop arrosée à la taverne qui a débouché sur une bagarre, un Enutrof s\'est aperçu que cette pelle conçue à l\'origine pour les grands travaux de construction était une excellente arme.",ep:1,g:8,l:25,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>5&CC>20",p:1900};
I.u[346] = {n:"Anneau Rak",t:9,d:"Selon certaines légendes, cet anneau protège son porteur des intempéries. Mais ceci n\'a jamais encore pu être prouvé, puisqu\'il ne pleut jamais en Amakna.",ep:1,g:34,l:17,wd:true,fm:true,w:4,p:1000};
I.u[347] = {n:"Rhizome Doré",t:8,d:"Cette pelle de jardinier est particulièrement efficace pour couper les rhizomes, des mauvaises herbes. C\'est également une excellente arme dès qu\'il s\'agit de couper autre chose que des rhizomes.",ep:1,g:10,l:40,wd:true,fm:true,w:30,an:16,e:[10,4,1,1,50,50,false,false],c:"CS>10&CC>30",p:4400};
I.u[348] = {n:"Bottes de Céleri-Thé",t:11,d:"Ces bottes appartenaient à un cuisinier très pressé, qui allait chercher son céleri et son thé à toute vitesse à travers la campagne d\'Amakna.",ep:2,g:5,l:53,wd:true,fm:true,w:20,p:6700};
I.u[350] = {n:"Argent",t:39,d:"L\'argent est un métal brillant très apprécié des bijoutiers, contrairement à ce que certaines personnes essaient de vous faire croire, il n\'a aucun effet particulier sur les vampires.",ep:1,g:28,l:60,wd:true,fm:true,w:5,p:0};
I.u[351] = {n:"Bière d\'Amakna",t:37,d:"Cette bière vous permettra de restaurer vos points de vie. Et comme le dit un brillant dicton paternel : \"Il vaut mieux la bière dans le corps que le corps dans la bière\".",ep:2,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[352] = {n:"Petite Epée Sacrée",t:6,d:"Une épée sainte distribuée aux jeunes guerriers durant leur formation.",ep:1,g:1,l:13,wd:true,fm:true,w:30,e:[5,4,1,1,50,50,false,false],c:"CS>26&CV>5",p:700};
I.u[353] = {n:"Epée du Petit Chevalier",t:6,d:"L\'épée du  Petit Chevalier est une épée solide et efficace, bien utilisée elle peut causer de gros dommages à vos ennemis.",ep:7,g:9,l:21,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>42",p:1400};
I.u[354] = {n:"La Klebik",t:6,d:"Ce type d\'épée était forgé pour les gardes d\'un commerçant aussi riche que réputé. Plutôt destinée à effrayer les voleurs, elle n\'en reste pas moins redoutable pour achever les voleurs ou les clients honnêtes, mais un peu usants.",ep:1,g:11,l:25,wd:true,fm:true,w:20,e:[12,4,1,1,30,60,false,false],c:"CS>50&CW>5",p:1850};
I.u[355] = {n:"L\'Anneau de Valeur",t:9,d:"Cet anneau apporte force et courage à son porteur.",ep:1,g:7,l:12,wd:true,fm:true,w:4,p:600};
I.u[356] = {n:"Ceinture d\'Endurance",t:10,d:"Cette ceinture rend son porteur plus résistant et endurant.",ep:1,g:3,l:27,wd:true,fm:true,w:16,p:2200};
I.u[357] = {n:"La Queue",t:6,d:"Epée symbolisant la partie de leur corps dont les Ecaflips sont le plus fier. Cette épée résume bien la façon de faire des joueurs.",ep:1,g:18,l:13,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>26&CA>10",p:650};
I.u[358] = {n:"La Queue Infernale",t:6,d:"La Queue Infernale est vraiment infernale... De quoi rendre votre adversaire ou vos coéquipiers complètement fous, et surtout de transformer vos coéquipiers en adversaires si vous vous y prenez mal. En revanche, le cas inverse ne semble jamais se produire.",ep:1,g:18,l:21,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>42&CA>10",p:1400};
I.u[359] = {n:"L\'Ecaliseur",t:9,d:"Cet anneau a été offert il y bien longtemps à Isidor, un chat malin, par le roi Allister, qui reconnu l\'agilité inégalable de cet Ecaflip.",ep:1,g:35,l:29,wd:true,fm:true,w:3,p:2400};
I.u[360] = {n:"Oreilles du Tiwabbit",t:106,d:"Ces petites oreilles recouvertes de poils bruns sentent le mulou mort une fois bouillies. Elles sont en revanche très appréciées lorsqu\'elles sont fourrées avec de la gelée royale.",ep:8,g:30,l:11,wd:true,fm:true,w:1,p:10};
I.u[361] = {n:"Cawotte",t:68,d:"C\'est l\'unique nourriture du Tiwabbit Kiafin, ce qui explique peut-être l\'origine de sa débilité profonde.",ep:2,g:31,l:20,wd:true,fm:true,w:1,p:2};
I.u[362] = {n:"Peau de Larve Bleue",t:59,d:"Cette peau toute lisse constitue un très bon ingrédient pour les potions magiques.",ep:1,g:32,l:2,wd:true,fm:true,w:1,p:2};
I.u[363] = {n:"Peau de Larve Orange",t:59,d:"Cette peau toute lisse constitue un excellent ingrédient pour les potions magiques.",ep:1,g:33,l:9,wd:true,fm:true,w:1,p:2};
I.u[364] = {n:"Peau de Larve Verte",t:59,d:"Cette peau toute lisse constitue un excellent ingrédient pour les potions magiques.",ep:1,g:34,l:7,wd:true,fm:true,w:1,p:100};
I.u[365] = {n:"Patte d\'Arakne",t:103,d:"Une patte très fine, mais très poilue. Très prisée des alchimistes pour ses propriétés euphorisantes, c\'est la petite faiblesse qui les perdra.",ep:1,g:35,l:2,wd:true,fm:true,w:1,p:10};
I.u[366] = {n:"Bec du Tofu",t:47,d:"Ce ridicule petit bec de Tofu, d\'apparence anodine, est cependant très aiguisé. Les archers d\'Amakna les utilisent depuis des lustres comme pointes de flèches.",ep:1,g:37,l:4,wd:true,fm:true,w:1,p:2};
I.u[367] = {n:"Oeuf de Tofu",t:105,d:"Cet oeuf a la particularité de sentir l\'oeuf pourri même lorsqu\'il n\'est pas pourri, imaginez un peu ce qu\'il sent lorsqu\'il est réellement pourri. Personne ne sait en revanche, qui du Tofu ou de l\'Oeuf de Tofu est arrivé en premier en Amakna.",ep:1,g:38,l:4,wd:true,fm:true,w:1,p:1};
I.u[368] = {n:"Gelée à la Fraise",t:110,d:"Cette délicieuse gelée à la fraise a rendu plus d\'un aventurier un peu trop gourmand malade. Comme le dit si bien le fameux dicton, \"tout est poison, rien n\'est poison, c\'est la dose qui compte\". Dans le cas de la gelée à la fraise, évitez l\'overdose.",ep:5,g:40,l:28,wd:true,fm:true,w:1,p:100};
I.u[369] = {n:"Gelée à la Menthe",t:110,d:"Cette délicieuse gelée à la menthe a rendu plus d\'un aventurier un peu trop gourmand malade. Elle a un effet apaisant sur le moral de toute votre équipe si vous la consommez en cas de mauvaise haleine.",ep:5,g:41,l:10,wd:true,fm:true,w:1,p:100};
I.u[370] = {n:"Gelée Bleutée Royale",t:110,d:"Cette délicieuse gelée est issue de la digestion et de la fermentation de miel par une Gelée Royale. Immangeable sous sa forme brute, cette gelée n\'en reste pas moins, un ingrédient de choix pour les confiseries.",ep:7,g:407,l:50,wd:true,fm:true,w:1,p:100};
I.u[371] = {n:"Sourcil de Moskito",t:15,d:"Le Moskito dispose de longs et fins sourcils qui mettent en valeur son regard de grand charmeur. La grande sensibilité du moskito fait que ses sourcils sont souvent imprégnés de larmes aux propriétés méconnues.",ep:1,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[372] = {n:"Bandeau du Black Tiwabbit",t:15,d:"Ce bandeau donne une allure de guerrier au Black Tiwabbit qui le porte. Cette tradition de porter un bandeau vient paraît-il du Wabbit Wambo.",ep:8,g:29,l:11,wd:true,fm:true,w:1,p:2};
I.u[373] = {n:"Tige de Pissenlit Diabolique",t:36,d:"Cette tige, souple comme le roseau, se plie, mais ne casse pas, ce qui en fait un composant de choix pour la réalisation des fouets et autres martinets, indispensables à l\'éducation d\'un enfant.",ep:1,g:45,l:6,wd:true,fm:true,w:1,p:10};
I.u[374] = {n:"Langue du Pissenlit Diabolique",t:36,d:"La couleur verte de cette langue provient de la consommation abusive de gelée à la menthe dont le Pissenlit Diabolique est friand.",ep:1,g:555,l:5,wd:true,fm:true,w:1,p:2};
I.u[375] = {n:"Dent du Tofu Maléfique",t:47,d:"Le Tofu Maléfique a troqué son ridicule petit bec de Tofu contre de ridicules grandes dents. Il est difficile de savoir ce qui est le plus dangereux sans tester soi-même.",ep:1,g:47,l:3,wd:true,fm:true,w:1,p:1};
I.u[376] = {n:"Aile du Tofu Maléfique",t:104,d:"Cette ridicule petite aile ne sert pas à grand-chose au Tofu Maléfique, si ce n\'est à brasser de l\'air pour déséquilibrer les Moskitos.",ep:1,g:48,l:3,wd:true,fm:true,w:1,p:1};
I.u[377] = {n:"Epine du Champ Champ",t:15,d:"Cette épine venimeuse protège le Champ Champ des attaques au corps à corps, mais l\'empêche en revanche de faire des câlins sans tuer ceux qu\'il aime. Heureusement pour lui, le Champ Champ utilise du Sporme qu\'il envoie à distance pour se reproduire.",ep:1,g:49,l:5,wd:true,fm:true,w:1,p:1};
I.u[378] = {n:"Sporme du Champ Champ",t:15,d:"Cette sporme est la \"petite graine\" qui permet au Champ Champ de disséminer ses petits un peu partout, et surtout n\'importe où. Attention, les spormes du Champ Champ sont attirées par les pieds malodorants et l\'odeur des Bottes du Bowisse.",ep:1,g:50,l:5,wd:true,fm:true,w:1,p:1};
I.u[379] = {n:"Pince du Crabe",t:47,d:"Cette pince de taille démesurée est presque creuse, elle permet juste au Crabe d\'épater la galerie et de se faire passer pour un boss. Elle est en revanche réputée incassable.",ep:1,g:51,l:4,wd:true,fm:true,w:1,p:1};
I.u[380] = {n:"Feuille de Menthe Sauvage",t:36,d:"C\'est l\'aliment de base de la Gelée Verte, si vous sentez une odeur de menthe, n\'en déduisez donc pas obligatoirement qu\'il y a de la menthe près de vous.",ep:1,g:52,l:30,wd:true,fm:true,w:1,p:0};
I.u[381] = {n:"Fraise",t:46,d:"C\'est l\'aliment de base de la Gelée à la fraise, si vous sentez une odeur de fraise, vous êtes peut-être sur son territoire de chasse.",ep:7,g:53,l:28,wd:true,fm:true,w:1,p:1};
I.u[382] = {n:"Ongle de Chevaucheur de Karne",t:47,d:"Cet ongle sale et usé a traîné n\'importe où, mais surtout dans des endroits peu recommandables. Il est donc préférable de ne pas à votre tour le mettre n\'importe où et encore moins dans des endroits peu recommandables.",ep:3,g:54,l:16,wd:true,fm:true,w:1,p:1};
I.u[383] = {n:"Corne de Bouftou",t:47,d:"Les Cornes de Bouftou sont luisantes et douces comme du cuir, pour des raisons inconnues, les Osamodas les affectionnent particulièrement.",ep:1,g:55,l:9,wd:true,fm:true,w:1,p:1};
I.u[384] = {n:"Laine de Bouftou",t:57,d:"Cette laine épaisse sent le Bwork qui se néglige, elle est cependant très chaude et surtout, elle ne démange pas les peaux sensibles, ce que les Eniripsa ne manquent pas d\'apprécier pour leurs sous-vêtements.",ep:1,g:56,l:9,wd:true,fm:true,w:1,p:1};
I.u[385] = {n:"Bave de Bouftou",t:15,d:"Cette bave purulente tire son odeur du fait que le Bouftou passe son temps à se lécher la laine, ce qui est également à l\'origine de l\'haleine exécrable du Bouftou.",ep:1,g:57,l:9,wd:true,fm:true,w:1,p:1};
I.u[386] = {n:"Groin du Sanglier",t:15,d:"Ce groin est un ustensile de choix pour débusquer les plus gros glands qui traînent dans les sous-bois. Contrairement au groin du Dragon Cochon, celui-ci est immangeable du fait de son odeur répugnante.",ep:1,g:58,l:14,wd:true,fm:true,w:1,p:1};
I.u[387] = {n:"Défense du Sanglier",t:47,d:"Cette défense permet au Sanglier de se défendre et accessoirement de curer son groin débusqueur de glands. N\'oubliez donc pas de les nettoyer à l\'eau vive avant d\'en faire de la poudre.",ep:1,g:59,l:14,wd:true,fm:true,w:1,p:1};
I.u[388] = {n:"Poils du Sanglier",t:54,d:"Ces poils particulièrement résistants sont utilisés entre autres pour la confection de pinceaux et de balais. Certaines personnes subissent d\'importantes allergies au contact de ces poils, il est donc recommandé de ne pas s\'y frotter avec vigueur.",ep:1,g:60,l:14,wd:true,fm:true,w:1,p:1};
I.u[389] = {n:"Huile de Tournesol Sauvage",t:60,d:"Cette huile est fortement recommandée par les diététiciens en raison de la forte proportion d\'acides gras essentiels qu\'elle contient. De plus, son contenu élevé en gras polyinsaturé et faible en gras saturé en fait un choix judicieux.",ep:1,g:61,l:12,wd:true,fm:true,w:1,p:100};
I.u[390] = {n:"Huile de Noix",t:60,d:"Huile au goût très fruité, utilisée en pâtisserie pour parfumer certains gâteaux. Cette huile faible en gras saturé se conserve peu de temps, même dans une bouteille qui n\'a pas été ouverte.",ep:4,g:62,l:32,wd:true,fm:true,w:1,p:100};
I.u[391] = {n:"Noix de Cajou",t:58,d:"Cette Noix de Cajou permet de faire de l\'huile si elle est récoltée encore verte. Une fois séchée, elle peut toujours servir de jouet pour les enfants de Iop un peu simplets.",ep:4,g:63,l:32,wd:true,fm:true,w:1,p:10};
I.u[392] = {n:"Noix de Pécan",t:58,d:"Cette Noix de Pécan permet de faire de l\'huile, mais il est préférable de la consommer séchée au regard des effets laxatifs de son huile.",ep:4,g:64,l:32,wd:true,fm:true,w:1,p:10};
I.u[393] = {n:"Gland",t:58,d:"Les sangliers adorent les glands, et tout le monde ou presque se demande bien pourquoi.",ep:1,g:65,l:14,wd:true,fm:true,w:1,p:10};
I.u[394] = {n:"Noisette",t:58,d:"Cette petite Noisette est délicieuse lorsqu\'elle est associée à une barre chocolatée. Dommage que le chocolat soit aussi cher en Amakna.",ep:1,g:66,l:14,wd:true,fm:true,w:1,p:1};
I.u[395] = {n:"Trèfle à 5 feuilles",t:36,d:"Ce trèfle constitue un élément essentiel de la nourriture des Tabis. Les éleveurs font tout de même attention dans la mesure où le Trèfle à 5 feuilles provoque des ballonnements chez les tabis.",ep:1,g:67,l:20,wd:true,fm:true,w:1,p:0};
I.u[396] = {n:"Huile de Palme",t:60,d:"De goût et parfum légers, cette huile convient bien pour tous les usages, de la friture à la préparation de vinaigrettes.",ep:3,g:68,l:32,wd:true,fm:true,w:1,p:100};
I.u[397] = {n:"Huile de Koode",t:60,d:"Cette huile très rare est un vrai élixir. Elle est si lubrifiante qu\'elle permet aux rouages et aux engrenages de ne jamais s\'user. Elle est issue d\'un savant mélange de diverses huiles.",ep:4,g:69,l:32,wd:true,fm:true,w:1,p:100};
I.u[398] = {n:"Fruit de Palme",t:46,d:"Ce fruit étrange permet d\'obtenir une huile raffinée une fois pressé. Dommage que ce fruit soit presque impressable à cause de sa coquille aussi dure que la semelle des bottes du Bowisse.",ep:3,g:81,l:32,wd:true,fm:true,w:1,p:10};
I.u[399] = {n:"Huile de Sésame",t:60,d:"Cette huile extraite des grains de sésame se distingue par son goût riche et délicat de noisettes grillées. Dommage que son odeur se rapproche plus de celle du Bouftou grillé que de la feuille de menthe sauvage.",ep:1,g:71,l:1,wd:true,fm:true,w:1,p:100};
I.u[400] = {n:"Orge",t:34,d:"L\'orge est une céréale utilisée pour la bière mais aussi pour le bétail et parfois pour les bétails buveurs de bière.",ep:1,g:82,l:10,wd:true,fm:true,w:2,p:0};
I.u[401] = {n:"Houblon",t:34,d:"La fleur du plant femelle de Houblon renferme les principes actifs utiles au brasseur, notamment les résines amères et les huiles essentielles. \"Cela me rappelle mes cours de Biologie, sauf que je n\'ai jamais suivi de cours de Biologie\". Tels étaient les mots de Gabrielle Naye à la vue de cette description, il faut bien l\'avouer légèrement romancée.",ep:1,g:80,l:30,wd:true,fm:true,w:2,p:0};
I.u[405] = {n:"Malt",t:34,d:"C\'est le nom donné à l\'Orge germée. C\'est un ingrédient de choix pour les bières de qualité. Attention cependant, le malt est vicieux et a tendance à absorber la bière lors de sa germination, un peu comme le Tot après une dure journée de chasse aux Tofus.",ep:1,g:83,l:60,wd:true,fm:true,w:2,p:0};
I.u[406] = {n:"Estomac de Wo Wabbit",t:15,d:"Cet estomac a la faculté de se dilater très facilement, ce qui simplifie grandement les digestions difficiles du Wo Wabbit qui a tendance à abuser des liqueurs de Cawottes fermentées.",ep:8,g:146,l:39,wd:true,fm:true,w:1,p:10};
I.u[407] = {n:"Pic du Prespic",t:47,d:"Pour se curer les dents ou se créer une nouvelle pointe de flèche, rien de mieux que le Pic du Prespic.",ep:1,g:134,l:18,wd:true,fm:true,w:1,p:50};
I.u[408] = {n:"Dentier du Chafer d\'élite",t:47,d:"Le Chafer d\'élite a les dents moisies par l\'alcool, c\'est pour cela qu\'il utilise un dentier. Ce dentier coûte une fortune car ses dents sont en or et l\'haleine fétide du Chafer d\'élite a doté ses dents de pouvoirs imprévisibles.",ep:9,g:129,l:43,wd:true,fm:true,w:1,p:50};
I.u[409] = {n:"Poils de Barbe du Bwork Mage",t:54,d:"Ces poils roux sentent très mauvais lorsqu\'il pleut, pour des raisons assez obscures. Cependant, les Bworks Mages semblent tirer une partie de leurs pouvoirs magiques de ces poils de barbe, ce qui pourrait intéresser certains alchimistes.",ep:4,g:131,l:23,wd:true,fm:true,w:1,p:20};
I.u[410] = {n:"Livre du Bwork Mage",t:25,d:"Ce livre est une vraie pièce de collection, c\'est de là que le Bwork Mage puise toute son inspiration et sa vigueur. Chaque page de ce livre recèle de nombreux secrets quant à l\'anatomie de certaines créatures d\'Amakna.",ep:4,g:130,l:1,wd:true,fm:true,w:1,p:100};
I.u[411] = {n:"Bec du Kwak de Glace",t:47,d:"Ce bec extraordinairement solide permet au Kwak de Glace de faire des trous dans la glace, juste pour le plaisir de faire des trous dans la glace. Les kwaks de Glace sont décidément bien étranges...",ep:1,g:133,l:24,wd:true,fm:true,w:1,p:20};
I.u[412] = {n:"Bec du Kwak de Flamme",t:47,d:"Ce bec extraordinairement solide permet au Kwak de Flamme d\'éteindre des braises entre son bec, juste pour le plaisir d\'éteindre des braises entre son bec. Les kwaks de Flamme sont décidément bien étranges...",ep:5,g:132,l:24,wd:true,fm:true,w:1,p:20};
I.u[413] = {n:"Bec du Kwak du Vent",t:47,d:"Ce bec extraordinairement solide permet au Kwak du Vent de se prendre des vents sans broncher, juste pour le plaisir de se prendre des vents sans broncher. Les kwaks du vent sont décidément bien étranges...",ep:5,g:110,l:24,wd:true,fm:true,w:1,p:20};
I.u[414] = {n:"Plume du Kwak de Glace",t:53,d:"Cette plume a la particularité de résister au givre. C\'est pour cela qu\'on ne rencontre jamais de Kwak de Glace givré.",ep:1,g:112,l:24,wd:true,fm:true,w:1,p:20};
I.u[415] = {n:"Plume du Kwak de Flamme",t:53,d:"Cette plume a la particularité de résister aux flammes. C\'est pour cela qu\'on ne rencontre jamais de Kwak de Flamme enflammés.",ep:5,g:111,l:24,wd:true,fm:true,w:1,p:20};
I.u[416] = {n:"Plume du Kwak de Vent",t:53,d:"Cette plume a la particularité de résister aux bourrasques de vent. C\'est pour cela que le Kwak de Vent peut encaisser de multiples vents jour après jour sans jamais voir son moral ni son ardeur affaiblis.",ep:5,g:113,l:24,wd:true,fm:true,w:1,p:20};
I.u[417] = {n:"Boue du Boo",t:15,d:"La Boo est très agressive, elle est constituée de morceaux de boue mis bout à bout, le seul moyen d\'en venir à bout c\'est de la dessécher, mais elle est tellement humide que vous n\'êtes pas près d\'en voir le bout.",ep:2,g:116,l:17,wd:true,fm:true,w:1,p:1};
I.u[418] = {n:"Poils de Barbe du Grand Pa Wabbit",t:54,d:"Le Grand Pa Wabbit possède une barbe postiche qui sent très mauvais, un peu comme le Père Nowel, mais en pire. À force de baver sans cesse devant les Grand Ma Wabbit, ses poils de barbe ont fini par s\'imprégner de sa bave aux pouvoirs méconnus.",ep:8,g:114,l:39,wd:true,fm:true,w:1,p:100};
