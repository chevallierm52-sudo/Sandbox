I.u[157] = {n:"La Gougnole",t:1,d:"La Gougnole a été créée dans de la pierre de lune ayant trempé 5000 ans dans un baril de bière. Inévitablement, cela lui a conféré de terribles pouvoirs.",ep:2,g:7,l:17,wd:true,fm:true,w:5,p:1000};
