I.u[264] = {n:"Petit Arc Déroutant",t:2,d:"L\'arc déroutant est un objet de base, mais son utilité n\'est pas à négliger.",ep:1,g:3,l:14,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>14&CS>4",p:750};
I.u[265] = {n:"Arc Déroutant",t:2,d:"L\'arc déroutant est un objet de base, mais son utilité n\'est pas à négliger.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>16&CS>6",p:900};
