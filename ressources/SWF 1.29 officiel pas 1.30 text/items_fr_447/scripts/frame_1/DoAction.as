I.u[159] = {n:"La Broche Céleste",t:1,d:"On dit que cette broche a été créée par l\'illustre forgeron Boulgur, qui a la réputation de forger les armes des dieux.",ep:1,g:8,l:40,wd:true,fm:true,w:5,p:2900};
I.u[160] = {n:"Le Flan des Étoiles",t:1,d:"Cet objet a été moulé à partir d\'un mélange d\'œufs célestes et de poussières d\'étoiles lactées. À conserver au frais.",ep:7,g:10,l:62,wd:true,fm:true,w:5,p:10000};
