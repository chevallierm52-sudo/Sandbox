I.u[250] = {n:"Ares",t:8,d:"Mi-hache, mi-pelle, Ares fut l\'une des sept armes utilisées par le démon Kajlir pour venir à bout de la Confrérie des Enutrofs collectionneurs de Dofus Pourpres.",ep:9,g:9,l:72,wd:true,fm:true,w:50,an:16,e:[10,4,1,1,50,50,false,false],c:"CC>200",p:14000};
I.u[251] = {n:"Barbe Grise",t:8,d:"Barbe Grise était l\'arme favorite du démon nain Assan Cehef, qui terrorisa de nombreux villageois, attaquant sans crier \"gare\", ni \"train\".",ep:1,g:11,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1250};
