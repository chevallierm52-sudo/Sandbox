Q.s[889] = {n:"An X Letter",d:"Find out the identity of this famous X. The letter refers to a place he used to go often. If you find this place, you\'ll surely get more information.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Back to Oto\'s",d:"You found an interesting piece of paper and must go back and show it to Oto.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"Search in the Tower",d:"You must find in Bonta a very important person who is said to be corrupt. Oto suggested you go search in the Tower.",r:[null,null,null,null,null,null]};
