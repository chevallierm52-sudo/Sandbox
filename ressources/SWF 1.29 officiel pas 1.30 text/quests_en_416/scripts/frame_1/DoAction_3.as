Q.s[713] = {n:"Fight... for a joke",d:"You must find Dike Tarak in the northern neighborhood, defy him and lose.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Find a Flaw",d:"Amayiro asked you to explore the Cemetery of the Tortured, east of Brakmar, and see if there\'s a flaw in their defensive techniques. You will certainly need specific material.",r:[19000,null,null,null,null,null]};
