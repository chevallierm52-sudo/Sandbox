Q.s[93] = {n:"Subosycold...",d:"Help your guild master to find a cure for the Tofus.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"First room",d:"Find out how to use the three Dofus.",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Second room",d:"Find the key",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"Tock Tick!",d:"...",r:[2500,20,null,null,null,null]};
