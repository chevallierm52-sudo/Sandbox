Q.s[170] = {n:"A message of wisdom",d:"A messenger bring a message, talk to him!",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Shield handling training for newbies",d:"To thank you for the delivery, the shield smith offers you a gift: a small training shield. Talk to the Dojo master for a training.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"A freaky accent",d:"Lenald the Wise asks you to go to Aerdala Village... or maybe Terrdala;\r\n            impossible to really understand with such a freaky accent! Once you will be there, talk to the Master Pandawushu.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"By the Shieldsmith",d:"At Terrdala, no one is available to bring the raw materials to the shieldsmith\'s workshop. Forging shield is essential for the Pandawa warriors. Fortunately you\'re here to do the job!",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Who is afraid of the Bow Meow",d:"Poochan is looking for her future husband but the only clues she has are that he leaves in Pandala and he is scared of Bow Meows. The easiest would be to turn herself into a Bow Meow and jump on everyone, wouldn\'t it?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Informal agreement",d:"Here, the tradition tells that the father decides who his son or his daughter will marry. You just have to persuade the father to let his son go. You will have to do your best to convince him.",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Conquest of the Dento",d:"In order to free Lanma from his duties you will have to break off the marriage promise he made to a girl of Dojo Dento.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"Reward ?",d:"Poochan awaits you.",r:[7000,null,null,null,null,null]};
