Q.s[750] = {n:"Humiliate Sbab",d:"Oto asked you to bring Sbab 10 Tiwabbits ears to scare her. But maybe there\'s a way to not do it if you don\'t want to...",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Kicking Bontarians",d:"Oto asks for Kikim Inn Beer. The thing is... it\'s in Bonta!",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Find the documents",d:"The spy didn\'t have the confidential documents with him. The Sidimote fauna probably laid their hands on them.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"The Revelation.",d:"Beneath the Alchemists\' Market is a cupboard. You need to stand in front of it to open the secret passage. Magus Ax is waiting for you there.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"Magus Ax.",d:"Amayiro has asked you to question Magus Ax to get a better understanding of how to invoke the Fogornleg Horn\'s powers.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"Return To The Fold.",d:"It\'s time to head back to Bonta and assess the situation with Amayiro.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"Common Knowledge",d:"Go and learn how to capture souls. The dungeon key must be on creatures of the region. ",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Chafer Helmets",d:"Oto wants 10 Chafer Helmets, well those you can find in the Cemetery of the Tortured.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Brakmarian Presence.",d:"You\'ve been attacked by a Brakmarian who was already there, but who didn\'t have the Fogornleg Horn. If Ecaflip is on your side, you should be able to find the Fogornleg Horn before the Brakmarians.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"Elturt\'s Decision.",d:"Convince Elturt to exchange the Fogornleg Horn for the Patched Bandana. You\'ll need an Ambusheadgear and a bottle of Greedoburg to make him appear.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Wolf Hunt",d:"Oto asked you to rid Brakmar off a lurking wolf.",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"Located Locating Location",d:"Amayiro will be interested by what Norb told you.",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Workshops",d:"You must find a skilled blacksmith who will agree to make the equipment for Bonta. Amayiro suggests that you go search in the workshops (either those of blacksmiths or miners).",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Another Innkeeper",d:"According to Oto, the innkeeper in Sufokia has information about a powerful magic horn.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"If you want something done properly...",d:"The information that the Ripate Inn Innkeeper revealed to you is not useful as things stand. A little chat with someone more learned could prove more fruitful.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, koko?",d:"You\'ve a rough idea what Oto Mustam might have planned for your next mission, and as such, it might be better to pave the way by picking up a few Kokonuts.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Shells",d:"The Keeper of the Ripate Inn asked you to bring him some turtle shells from Moon Island - one of each colour. But you could maybe do something a little easier and quicker...",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Defeat the lupus minimus.",d:"A battle that will put all your new skills to the test.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Unfinished mission",d:"The path is now free, although the goblins were quite harmless too. Exoram is finally going to be able to tell you what he knows which should make Oto Mustam happy.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"Treech-a-Booh",d:"Exoram feels unsafe. He heard weird noises and evil laughs to the north. If you could assure him that road is clear, he would give you precious information about Xephires.",r:[null,null,null,null,null,null]};
