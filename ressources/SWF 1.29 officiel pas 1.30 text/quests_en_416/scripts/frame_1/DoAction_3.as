Q.s[78] = {n:"Cratastrophe",d:"You\'ll now learn archery.",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Find the outlaw",d:"Frakacia Leukocytin has been seen near the One-armed Bandits village.                                                           She\'s wanted for stealing haemoglobin and has been sentenced to imprisonment in Astrub.",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Find the outlaw",d:"Nervoes Brakdoun has been seen near the Treechnid forest.                                                   Wanted for jewellery robbery.       Sentenced to imprisonment in Astrub.",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Find the outlaw",d:"He\'s been seen near the Sidimote Moors. He is wanted for going against the cosmic order. \nBrumen Tinctorias is sentenced to imprisonment in Astrub.",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Find the outlaw",d:"Akornadikt is wandering through the city in search of succulent acorns to sink his teeth into.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Find the outlaw",d:"Ogivol has been seen near Brâkmar. He\'s wanted for stealing a heaps of things, especially secret documents. He\'s been sentenced to imprisonment in Astrub.",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Escort of Mixture",d:"Tek Abir, the village innkeeper, is compelled to water down his beer because he\'s losing profits to thieves. Go up the road to the deliverer south-west and escort him on his way.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"Oppression brought to an end?",d:"Put an end to the beer robbery.",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Vision for a new you",d:"Gather various resources to help Kwartzwatch see into the future.",r:[600,null,null,null,null,null]};
