Q.s[133] = {n:"A nice pair...",d:"Raih Resserd needs a pair of forged scissors, she advises you to go and see the blacksmith at the market to buy some...",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Here Hair Here.",d:"Raih is trying to gather as many types of hair as she can from the different inhabitants of Astrub, so that she can make wigs with it.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"A start of a track",d:"The Enutrofs, who have gone in search of sniffallrats, probably got lost deep in the underpasses. The place is infested with grossewer milirats....",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"A bird in the hand is worth two rats in the bush",d:"Get rid of this Grossewer Rat...  It shouldn\'t be that difficult, I think it\'s sick... I\'d bring a few friends along all the same, though.",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"The beginning of wealth",d:"Collect ten Arachnee legs for Ant Emicheun. Or for yourself... whatever you like. In any case you\'ll make a tidy profit.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Sick Feathers",d:"You can make a nice feather duster with 20 feathers. Mind you, given the state of these pathetic things...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Deserved Reward",d:"Speak to grandma again and show her the Moumouse head.",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"The infested cellar",d:"Go to grandma\'s cellar and take care of the threat.",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Defeat the Militiaman",d:"Defeat Tarche the militiaman in the room right next to this one.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Give Breads",d:"You must bring Amayiro 20 wholemeal breads.",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"Gobball Teeth",d:"You must take out Gobball teeth - as many as you\'d need to make human dentures, and then bring them to Ned, south-west of the city.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"Bro\'s Shoe",d:"You must defeat Torche and bring evidence of your victory to Amayiro.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Find the Crow",d:"You must find the Crow who stole the necklace of the Mayor\'s daughter, defeat him and take the necklace. The crow is said to be close to the tower.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Boar Hunt",d:"You must find the Aggressive Boar south of Bonta and defeat him.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"Repair the Katana",d:"You must ask Kosuke the blacksmith to repair Amayiro\'s blade in exchange of a check.",r:[4600,null,null,null,null,null]};
