Q.s[724] = {n:"In the Gaol of Brakmar",d:"Amayiro asked you to free Atall Tramston from the prison of Brakmar, and bring him back to the Bontarian militia.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"McSheth on our doorstep!",d:"Find a travelling seller. Here, you\'ll be able to pay the McSheth levy. Do not hesitate to strongly insist, they may not admit it at first, but they like it really.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"Let the sun shine in Pandala!",d:"Upon your arrival in Pandala, you must put your papers in order with the administration. Plus, you\'ll have to pay the dreaded McSheth levy.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"My first Shaman party!",d:"Request help to the Shaman! Hurry!",r:[4700,null,null,null,null,null]};
