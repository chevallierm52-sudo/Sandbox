Q.s[452] = {n:"A temporary... failure",d:"Xephires rejected your offer, but all hope is not lost. You may get to what you want with a jewel. Go see the jeweller Milone, he can help you.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"Meeting",d:"Now that you\'ve discovered where Xephires is, you must go to the Drunken Pandawa Inn and make him an offer. He\'s there as of 4:00 pm.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"A Message to Pass on",d:"Oto wants you to pass his message on to Vil Smisse, in the Rogues\' Den - which is in the cemetery of Amakna.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"New Danger",d:"Several Brakmarian warriors fell and were left for dead on the road to Astrub. You must go investigate. Oto Mustam wants a Whitish Fang soul.",r:[140000,null,null,null,null,null]};
