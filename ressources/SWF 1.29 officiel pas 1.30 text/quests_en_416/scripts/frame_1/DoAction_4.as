Q.s[401] = {n:"After the recipe, let\'s get the ingredients!",d:"Now that Uba has the formula, he only needs the ingredients.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"A formula!",d:"You have to find alchemists dispersed in Amakna.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit Powa.",d:"Find a way to turn yourself into a Wabbit.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"Force-feeding",d:"You have the obese tofu egg but an egg will not harm the pwince... You have to find something to force-feed the unborn young bird.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Beg for an Egg",d:"Vil Smisse asked you to bring him an obese tofu egg. All you need to do is find the nest...",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"Hiring Hitmen",d:"Vil Smisse will not be able to use the poison Rasputin Cake. He then falls back on the direct attack. For that, he wants to hire assassins and he needs money.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"A poisoned chalice",d:"Vil Smisse chose to play the Rogue way: the slyness.",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Party Pooper",d:"The assassins didn\'t manage to kill the prince... Vil Smisse asks you to go and hire a Lenald to do the job.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"Death to the Tofu!",d:"You know where the pwince of Wa went to hunt. Well... somewhere South of Bonta. The pwince remains to be found.",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"Get Down to Work",d:"Go ask the foreman what you need to do.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Serving or Doing a Favor?",d:"The steward San Lavalss asked you to help to prepare the wedding.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"1st step",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"A Costume for Emeralda",d:"Emeralda is desperately looking for a Koalak set.",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Answer the Questionnaire",d:"The Death Bridge Keeper demands that you answer his questions correctly.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Get Ready for your Trip",d:"The Captain Haddock\'n\'roll asks you to bring several items so that you can board on his ship.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"Flib\'s Cursed Little Box",d:"The Captain Haddock\'n\'roll miserably beached on the Castaways\' Island. You must find the Flib\'s Cursed Chest and a few items to fix the ship.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"You Won\'t Get Through!",d:"The Black and Pink Knight won\'t let you through. It might be a good time to use strength to get what you want.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"A Potion for a Professor",d:"The Professor Kalkulus needs a Bulbish Potion to start working again.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Breeding Machines",d:"Polka Merer needs breeding machines for her creatures.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"A Flour Story",d:"Stella Stukup, the baker, wants to add up other cheaper flours to that of Xavier the baker. She had the idea, now you find the flours!",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"Looking for the Hidden Son",d:"The Doctor Nauh lost his son in a lab filled with wild terrible creatures. You must find him and make sure that he\'s still alive!",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"The Doctor\'s Feeling Morose",d:"Poor Doctor Morose lost his wife. Help him find her in the Dark Jungle and try to convince her to get back to her husband so that the latter can start his researches again.",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"Improved Equipment",d:"Speet Fyer is looking for an improved pilot helmet and cape. Only an experienced tailor will be able to help you out.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Two Dragoturkeys for Flip Flap",d:"Flip Flap would like you to bring her a certificate for a Ginger Dragoturkey and one for an Almond Dragoturkey.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Dark Jungle Hunting",d:"Crocodyl Dandy would like you to hunt a few creatures from the Dark Jungle.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Plain Hunting",d:"Crocodyl Dandy would like you to hunt several Plain creatures.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Beach Hunting",d:"Crocodyl Dandy would like you to kill some creatures on the Coral Beach.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Tree Keeholo Hunting",d:"Crocodyl Dandy would like you to hunt a few creatures from the Tree Keeholo.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Bottomless Peat Bog Hunting",d:"Crocodyl Dandy would like you to hunt a few creatures from the Bottomless Peat Bog.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"A Example for the Pirates",d:"Kito asked you to show Pirates what you can do. This should serve as an example for the others who would feel like throwing cannonballs.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"The Black and Pink Knight",d:"Miss Lousy Piggy would like you to confront the terrible Black and Pink Knight for her.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"The Cursed Exchange",d:"Farle Ingalsse is probably the only person in Amakna capable of fixing your cursed sword...",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"Quick! Quick!",d:"Milone\'s house is about to be broken into. Hurry and stop this!",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Bad bait?",d:"The journey went well. Bandits didn\'t attack. Amayiro is waiting for your report.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"Ecatraps",d:"Amayiro wants to set an ambush for the bandits. But he needs a valuable jewel to attract them.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Escort Cheeka",d:"Your mission if you accept it is to escort a group of Cheeka merchants to Astrub.",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"Hands, Bliks",d:"The convoy was attacked by Ecaflip bandits who looked a lot like the ones whose camp you discovered. Amayiro is waiting for your report so he can convince the council to take action.",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Rigal the Rogue",d:"In the Sram temple, Rigal Hookhand is well-known for having lots of information. Information has a price. You just have to figure out how much is your.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"Poi\'Zone",d:"You must find Brakmar\'s poison supplies and steal the client register from the Alchemists\' workshop. Bishom Pot may be able to help you.",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"Alchemy for dummies",d:"You have to steal the client register from the alchemists\' workshop in Brakmar and bring it to Rigal Hookhand.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Parting of the mudpuddle",d:"You\'ll need the help of a Sram or a qualified spy to help you get into Brakmar\'s poison reserves.",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Meeting at the Tower",d:"A meeting between a Brakmarian and a bribed Bontarian is about to take place in the Tower of Bonta. You must capture both of them if possible.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"Dammit, gambit",d:"You should find some militians to post at the Tower of Bonta.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"Bwork, what a smell!",d:"Either Epuop Tik doesn\'t know any more, or he doesn\'t want to say any more. Whatever the case, the Bwork Mages should be a little less reluctant to sell out one of their own.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Danathor is deceitful",d:"Danathor seems to have a new offer to put to you. But it\'s probably a shady one.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"The enchanted doll",d:"You have to find four Sadidas who are experienced enough to invoke Inflatables for a ritual involving the enchanted waters of the Koalak lakes.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Genialissimo",d:"If you remove the curse on Jibworknouille, he\'ll definitely tell you everything he knows to thank you. He also suggested you go to a library to find out more.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"In search of the forlorn Clerk",d:"Aigurraf, Clerk of the Order of the Sharp Eye, has been searching the taverns since his mouse disappeared. Bring him back to Ebru Of El.",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Prison Break",d:"You must free a warrior that was made prisoner by Bonta. He is in the basement of the Bontarian militia prison. ",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"The enemy with him",d:"Find and exterminate your enemy.",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Win the fight.",d:"Continue to attack your target to win the fight. Pass your turn using the {ui,banner,btn_skipTurn::end turn} button when you want to regain your {ui,banner,lbl_pa,2::AP} and your {ui,banner,lbl_pm,2::MP}.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Finish the fight.",d:"Defeat the monster. Be careful, turns now have a limited duration. The {ui,banner,tx_artwork,3::remaining time gauge} shows how much time you have left before your turn ends.",r:[null,null,null,null,null,null]};
Q.s[1042] = {n:"Position yourself on the map.",d:"Welcome to the guided tutorial. Left-click on the spaces around your character to position them. If you click far away from your character, they will run, otherwise they will walk.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Pass your turn.",d:"When you\'ve finished your turn, left-click on the {ui,banner,btn_skipTurn::end turn} button to speed up the fight and regain your {ui,banner,lbl_pa,2::AP} and your {ui,banner,lbl_pm,2::MP}.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Equip an item.",d:"Open your {ui,banner,btn_character,1::characteristics} menu. Select the {ui,storage,grid::Novice Ring} that you\'ve just won and then drag it by holding down your mouse\'s left button and drop it into the {ui,characterSheetUi,slot_2,2::ring slot} on your character display.\nYou can also equip it by double clicking your mouse\'s left button on the {ui,storage,grid::Novice Ring}.",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"Equip your items.",d:"Open the {ui,banner,btn_character,1::characteristics} menu and equip your character with the items that you\'ve won.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Position yourself during a fight.",d:"Your character uses {ui,banner,lbl_pm,2::Movement Points} (MP) to move. Moving 1 cell costs 1 MP. Move your character by left-clicking on a cell. \nYou\'ll get your {ui,banner,lbl_pm,2::MP} back at the start of your next turn.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Use a spell.",d:"Choose {ui,banner,gd_spellitemotes,0::a spell} and then left-click on a target. Some spells are cast on enemies, and others on allies or your character. The range of a spell is shown by the blue cells. Spells need {ui,banner,lbl_pa,2::action points} (AP) to be cast. You\'ll get your {ui,banner,lbl_pa,2::AP} back at the start of your next turn.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Choose your starting position.",d:"Left-click on one of the {cell,272::blue cells} to choose your starting position and then click on the {ui,banner,btn_ready::Ready button} to start the fight.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Change maps.",d:"To change maps, move your cursor to one of the {arrow,1280,520,0,0::edges of the screen} and left-click when the cursor changes into an arrow.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Defeat the monster.",d:"To continue your quest, start by heading into the {arrow,700,870,0,1::next room} and start a fight with {monster,2781::the monster}.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Finish your training.",d:"To complete your quest, you must talk to {npc,1222::Master Apro Simate}.",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Start a quest.",d:"Speak to {npc,1222::Master Apro Simate} to start a quest (NPC with a quest for you to carry out will have an exclamation mark above their heads).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Speak to a NPC.",d:"Left-click on {npc,1222::Master Apro Simate} and chose the \"Speak\" option to speak to him.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Start a fight.",d:"Left-click on the {monster,2785::Incarnam Scarecrow} to start a fight.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"A complicated life.",d:"You should have followed Het Dawa\'s advice and taken care. Now it seems your life is on the line. Alas, life is not as simple as one would think.",r:[null,null,null,null,null,null]};
Q.s[1058] = {n:"We will all succeed.",d:"With your help, Het Dawa should be able to eradicate the illness that has affected the Pandawan beverage market, provided an antidote can be found.",r:[3000,null,[[10818,1]],null,null,null]};
Q.s[1056] = {n:"The good life.",d:"You\'ve just arrived, and you\'ve already been offered a way to make your life easier and without much effort, either. What more could you want?",r:[null,null,null,null,null,null]};
Q.s[1091] = {n:"Toy factory.",d:"Abominable creatures have broken into Father Kwismas\' workshop. You must recover the boxes of presents they have stolen, with or without their consent, and take them to Harry Kwismas.",r:[null,1000,[[10920,1]],null,null,null]};
