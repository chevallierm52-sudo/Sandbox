Q.s[143] = {n:"Wild Hunt",d:"Some dark creatures are ruining Ant Emicheun\'s business. The answer would be to get rid of them.... at least until he can understand what they are doing here...",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"Are eggs able to swim?",d:"No more disease in the sick Tofu feathers. On the other hand their eggs would probably be useful to the Eniripsa. Another few Kamas to be earned!",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"The fur will fly!",d:"You suddenly feel the need to learn more about yourself and decide to go to a blood-drenched place.... The butcher\'s.",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"There\'s blood ahead!",d:"Your master heard that a worker at the mine was recently turned into a dark miner. He wants to know the whole story.",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"Stupid Enutrofs!",d:"A group of Enutrofs have made a discovery... They\'ll need your help to find out more.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Dizbi essence",d:"The flower won\'t do as it is, you must make tea with it!",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Express delivery",d:"You have to bring the tea to your guild master so that a staff can be made. If it\'s possible and if you have time, bring some tea to your florist as well, it will make them very happy.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Dizbi Flower",d:"You must find some Dizbi flowers if you want your class master to make a staff worthy of its name.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"We\'re starving!",d:"Allisteria\'s Gobballs are hungry. They need to be fed... all of them!",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Stewed Black Gobball Pudding",d:"Save the good Stewed Black Gobball Pudding tradition.",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Fight if you\'re a Feca",d:"The famous Fallanster asked you to train his daughter to be a fighter.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"It is forbidden to sell water to people under the age of...",d:"The water way consist in resisting by any means to any water absorption or submersion (partly or totally submerged), not drinking deliberately or washing yourself (except if extremely necessary). Find the master of the water way: he knows more than he seem to do.",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"Lenald the wise",d:"A Pandawaiian soft drink saleswoman advises you to talk to Lenald the Wise. According to her, he is the only one to know the truth about Pandala and its mysteries.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"The Statue of the Goddess",d:"Grandapan gladly accepted the Enutrofs\' gift. As an ardent admirer of the Dofus hunters, he gives you a warm welcome.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"Grandapan: A nice Pandawa",d:"The Enutrof having a cure by the Shaman advise you to visit Grandapan. He is really knowledgeable about the local folklore  and the Pandawaiians legends",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Libation to the Goddess",d:"Thanks to your help, the Shaman assistant can start the thank-you ritual to the Goddess. He will be ready right after you offer him a traditional padawaiian gift.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"At the King\'s service",d:"The King likes to ride, you must find him Dragoturkeys.",r:[75000,null,null,null,null,null]};
