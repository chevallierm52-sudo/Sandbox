Q.s[193] = {n:"Dofus receptacle.",d:"Grandapan gladly accepted the Enutrofs\' gift. As an ardent admirer of the Dofus hunters, he gives you a warm welcome. In order to satisfy your explorer\'s curiosity, he takes you to the Dofus receptacle.",r:[1500,null,null,null,null,null]};
