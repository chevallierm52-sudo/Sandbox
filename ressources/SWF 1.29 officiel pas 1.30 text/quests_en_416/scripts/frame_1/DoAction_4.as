Q.s[194] = {n:"A drink in hand is worth two in a bush",d:"The Water Way consists of resisting the intake of, or submersion in, water (either partially or totally) - by any means. Do not ever drink it. Only wash yourself in extreme need. Find the Master of the Water Way: he knows more than he\'s letting on.",r:[10000,null,null,null,null,null]};
