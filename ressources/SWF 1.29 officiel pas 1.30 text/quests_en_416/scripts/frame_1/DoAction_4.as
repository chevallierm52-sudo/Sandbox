Q.s[534] = {n:"The Choice",d:"You found the spy on time. But are you going to follow the orders, take the documents and leave him here?",r:[205000,null,null,null,null,null]};
Q.s[144] = {n:"... or Xelors\' fangs.",d:"The Xelors seem to be interested. According to Ant, they would like to put hands on their hourglass... well he\'s not really sure.",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Find the outlaw",d:"Qil Bil has been seen near the Sidimote plains.                 Qil Bil is wanted for pulling out human limbs.             Sentenced to imprisonment in Astrub.",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"Re-enlist, he said.",d:"Snori Nairb has promised to share his Kamas and his experience with you if you re-enlist in the Brakmarian militia.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"He who sows the wynd shall reap the Whirlwynd",d:"To test his theory about the emergence of carnivorous flowers, Trapchet wants you to sow some dark rose seeds and harvest the plants.",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"The good the bad and the flora",d:"Three-Flower, a friend of Trapchet, lives in Amakna and knows the flora of the area thoroughly. Go ask him for some information about the aggressive flowers in this area.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"The Epyss gets sucked down",d:"Erty Trapchet would like to study some dandelion seeds to compare them with some Epyss...",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"The waterman watering",d:"Erty Trapchet forgot to look after his plants, you have to go to his place and water them.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"What a weedy mess!",d:"For his research, Trapchet needs to study the geographical distribution of the flowers around Astrub.",r:[6500,500,null,null,null,null]};
