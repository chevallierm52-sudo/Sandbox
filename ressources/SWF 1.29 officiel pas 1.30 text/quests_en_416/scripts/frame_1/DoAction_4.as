Q.s[546] = {n:"Yet more intrigue.",d:"Kit Dingaround is accused of treason but Amayiro believes he is innocent. He asks you to talk to Kit, who is currently in prison, and get his version of events, and to confirm what he tells you.",r:[240000,null,null,null,null,null]};
Q.s[559] = {n:"The interrogation.",d:"Amayiro has asked you to question the witness who has accused Kit Dingaround of treason until they reveal something interesting. You\'ll probably find them at Atyu Servis\' Inn.",r:[null,null,null,null,null,null]};
