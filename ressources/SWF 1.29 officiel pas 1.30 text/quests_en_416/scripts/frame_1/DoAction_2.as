Q.s[686] = {n:"Track Down Drinkers",d:"You must Inn crawl in Bonta to find the militiamen who are not working and ask for their badges.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Terms of Exchange",d:"Telma made you a list of what she wants for her magic necklace.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"I\'m a Social Worker",d:"Qwizitor wants to know if any of the villagers have noticed anything unusual.",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Shaman connection",d:"The Shaman is a Pandawa who knows a lot about the schemes of some people...  It seems it\'s no bed of roses in Pandala!",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"Good health to the Goddess!",d:"Freshly arrived at Pandala, the Shaman assistant requests you to be a credit to your Goddess: a spiritual offertory would be really kind of you... Your initiation can start.",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Find a Job",d:"Postor Nhin probably has something for you to do.",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"A Recipe for Babblera",d:"Babblera is waiting for the Astrub pancake recipe so that she can prepare something for her grand children.",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"Cliff banger",d:"Get into the bandits\' hideout using a rope. And don\'t go alone!",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"Darkitty",d:"The bandits you met told you that Hersa Dark Claw knows more than what she pretends. Now go talk to her but stay away from her claws...",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"Find the Hideout",d:"Amayiro asked you to investigate in the plains of Cania to find the Bandits\' hideout. It\'s said to be close to the Trool Fair, to the west.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Pretty Nara",d:"Nara gave you a long list of materials he needs to make the equipment for the Bontarian militia. You have to bring them to him in the Porcos\' Mine.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Real Estate",d:"You have visited all the locations as Setag asked. Now you just have to convince Nara to move to one of them.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"House hunting.",d:"Nara has asked you to find him a quiet place where he can set up his forge and his equipment.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Box Transportation",d:"You must carry 4 boxes from Amayiro\'s to the south outpost of Bonta.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Prove Yourself",d:"As you\'re new in the area, you\'ll have to convince the locals you\'re worthy of their trust.",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"That hits the spot!",d:"You\'ve got the Incarnam Lemonade. When you give it to Brett, you should get all your strength back.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Lemon Aid",d:"Brett wants Incarnam Lemonade. Why doesn\'t he go get it by himself?",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"The Meeting",d:"You need to find out more about Elturt. An animal specialist should be able to help you. Oshimo, the owner of the Kennel, would be a good person to start with.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"The wabbit and the turtle.",d:"According to Oshimo, Elturt has an archnemesis. Herr Palp Itane signed a contract with some demons to increases his powers. He lives on Skeleton Wabbit Island.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Address Book",d:"Add a player to your friend list.",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"Whose puppie is it?",d:"Onmast\'her challenged you to defeat the monster hidden in the kennel.",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Trool-Playing Game",d:"Raxitik is terrorized. He knows that Bworks will bring him to the Trool to play a Trool-playing game with him. You must kill this Trool that threatens Raxitik\'s physical integrity.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"A Bloody Pilgrimage",d:"Confront the Dopple in each of the class temples.",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Annihilate Turtles",d:"Oto asked you to kill ten turtles from Moon Island. Pop their eyes out and keep them as proof. ",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Wine for Oto",d:"You must bring Oto Greedovore wine. But where can you find such thing?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"Interview",d:"A Brakmarian celebrity asked after you. Go and meet her in the basement of the tower of Brakmar. ",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Energizing Potions",d:"Oto Mustam needs three Pahoa Raid Potions.",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"Found Hideout",d:"The message of the thieves\' chief helped you find their hideout. Why don\'t you go and check it out before returning to the militia?",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"Buy the equipment",d:"You must buy and equip the equipment Oto asked you to get before visiting him again.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"32 Golden Teeth",d:"Bring Mak golden dentures. You\'ll find them on Elite Chafers, but the blacksmith in Brakmar can also provide you with some.",r:[28000,null,null,null,null,null]};
Q.s[487] = {n:"Enter the library",d:"The spies failed in their murderous mission, so you\'ll have to do it for them. The target is a tactician who lives in the library of Bonta.",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Murderer",d:"You can now enter the library to take care of the tactician.",r:[null,null,null,null,null,null]};
