Q.s[919] = {n:"Flip that Eca like a pancake",d:"Now you can make the keys and inspect the bandits\' hideout for clues. You\'ll need a climbing rope to get down there.",r:[80000,null,null,null,null,null]};
Q.s[916] = {n:"Close to the close",d:"You have to find the key to the hideout, which obviously means you have to get your hands on the bandit who has the key. Hersa\'s ex-lover could be the one.",r:[null,null,null,null,null,null]};
Q.s[917] = {n:"Don\'t break the mould",d:"Make copies of the key to the bandits\' hideout, then go in there in a group and take any documents that could relate to the investigation.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Illegal Activities",d:"Strange things have been going on in the Bakers\' district. Amayiro asked you to investigate.",r:[17000,null,null,null,null,null]};
Q.s[689] = {n:"Staff Training",d:"Amayiro asked you to bring him 20 Twiggy Staff to train his troops.",r:[4000,null,null,null,null,null]};
Q.s[718] = {n:"Danathor\'s Request",d:"Danathor wrote to you and asked for your help.",r:[11500,null,null,null,null,null]};
Q.s[719] = {n:"Larry Poller",d:"Larry Poller asked for your help. You can find him close to the Tower of Bonta.",r:[11500,null,null,null,null,null]};
Q.s[1035] = {n:"Uncover the statue\'s secret.",d:"Percimol has hidden his secret in the base of the statue. Get down on your hands and knees and look for it.",r:[null,null,null,null,null,null]};
Q.s[751] = {n:"Help Raaga",d:"Find Raaga in the mines up north and ask for his report. ",r:[13500,null,null,null,null,null]};
Q.s[738] = {n:"The Spy\'s Report",d:"Oto asked you to find the spy Finche Aticus, in Bonta, and to get his report.",r:[5200,null,null,null,null,null]};
Q.s[743] = {n:"Searching for Magic Poison",d:"You must find someone in Brakmar who knows how to make magic poison.",r:[8200,null,null,null,null,null]};
