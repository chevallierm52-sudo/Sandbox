Q.s[898] = {n:"The confirmation",d:"Pandalida escaped while we were fighting, she must have gone to hide in her house. You HAVE to convince her to deliver the letter to Xephires.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intimate intimidation",d:"Ransacking Pandalida\'s house should give her the willies. You\'ll need 3 Tra Khben Pastes, which is made by mixing and kneading 15 Boar Snouts, 5 Pots of Greedovore and 1 Quetsnakiatl Feather.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"Messenger",d:"You must find a way to pass the letter on to Xephires. He is often at the Drunken Pandawa Inn, but refuses to talk to you.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"The Take Over",d:"You must find the warrior Tink Berval and ask him to go and take over the warrior Brank Thoof.",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"A dish best served cold.",d:"What with Elturt being hungry, and your strong-arm tactics not working, you need to find a way of poisoning him instead. Someone living on the island must know what a turtle\'s favourite food is.",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Turning Turtle Upside Down",d:"Since asking nicely is not working, you\'ll have to act a little differently if you want to get this information...",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Transformation",d:"Poss\'Ybel wants you to provide him with a few resources you\'ve harvested yourself.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Transformation",d:"Poss\'Ybel wants a mini healing potion made out of a Flax flower and a bit of water.",r:[50,null,null,null,null,null]};
