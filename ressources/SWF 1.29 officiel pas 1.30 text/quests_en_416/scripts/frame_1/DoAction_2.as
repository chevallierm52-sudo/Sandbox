Q.s[1192] = {n:"Ginette, the worst a man can get.",d:"Ginette has been kidnapped by a Kanigloo. Gromeo has tried to save her, but in vain. He\'s begged you to free her.",r:[804000,25000,[[11196,2]],null,null,null]};
Q.s[1191] = {n:"Stormy reconciliation.",d:"The Capooays don\'t appear to have anything to do with the cereal theft, but something isn\'t right. You just need to find out what.",r:[null,null,null,null,null,null]};
Q.s[1190] = {n:"Out of the mouth of adults...",d:"Ginette has a plan to find out what exactly happened and it\'s up to you to carry it out.",r:[null,null,null,null,null,null]};
Q.s[1189] = {n:"An impossible love.",d:"Gromeo and Ginette can\'t get married because their families hate each other. They\'re begging you to find a solution.",r:[null,null,null,null,null,null]};
Q.s[1184] = {n:"Larry needs a hand.",d:"Larry Tutthe is overwhelmed and needs a helping hand.",r:[null,null,null,null,null,null]};
Q.s[1183] = {n:"Put on your boots.",d:"Tutthe Larry needs a new assistant and has put you in charge of recruitment.",r:[null,null,null,null,null,null]};
Q.s[488] = {n:"Back to Oto\'s",d:"You\'ve taken care of the tactician, so head back to Oto.",r:[null,null,null,null,null,null]};
Q.s[907] = {n:"Taming the beast, and the animal too.",d:"Oto Mustam wants to find out the secret to taming Whitish Fangs. Go back to the Bonta Library to find some clues.",r:[134000,null,null,null,null,null]};
Q.s[1021] = {n:"Murder the Tactician",d:"You\'ve chosen to use the most extreme solution. Well, the most Brakmarian one, shall we say.",r:[null,null,null,null,null,null]};
Q.s[1177] = {n:"Escorting the injured.",d:"You must escort an injured hunter to the village of Frigost, so that he can be tended by the physician Herr Peece.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1178] = {n:"Escorting the not particularly gifted.",d:"You must escort an injured hunter to the village of Frigost, so that he can be tended by the physician Herr Peece.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1179] = {n:"Escorting the evil hunter.",d:"You must escort an injured hunter to the village of Frigost, so that he can be tended by the physician Herr Peece.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1180] = {n:"A brisk pace.",d:"While Djauns watches over his treasure, you need to get a team of Snow Bow Meows together bring it to him. The clock is ticking.",r:[null,25000,[[11196,1]],null,null,null]};
Q.s[1186] = {n:"A new life is born.",d:"An alchemist can help you better understand the identity of the creature found in the Tears of Ouronigride.",r:[null,null,null,null,null,null]};
Q.s[1185] = {n:"Ogivol Victor\'s water brings us hope.",d:"Ogivol Victor needs your help to collect mineral water in order to analyse it and make it potable.",r:[null,null,null,null,null,null]};
Q.s[1181] = {n:"YeCh\'Ti Boohoohoo.",d:"The Frigostians have mounted a punitive expedition to get rid of the YeCh\'Ti. They need Intact Snowfoux Furs to deceive it.",r:[null,null,null,null,null,null]};
Q.s[1182] = {n:"The Horrible Snowmonster Contest.",d:"Little Nick and his friends are holding a competition and you are the judging panel. You must choose which of their snowmonsters is the most horrible.",r:[null,null,null,null,null,null]};
Q.s[1188] = {n:"Killed in cold blood.",d:"The Corpstive wants revenge on the farmer who killed him. He\'s asked you to be his weapon of vengeance.",r:[null,null,null,null,null,null]};
Q.s[1187] = {n:"Silly Snowfoux.",d:"Some crazy Snowfoux have been preying on travellers. You must defeat them.",r:[null,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[409] = {n:"Follow Me if You Love Me!",d:"The pwince of Wa asked you to set up a suite worthy of him... In view of his feats, his particular diet and his sense of estheticism, he needs at least four people to assist him.",r:[45000,null,null,null,null,null]};
Q.s[693] = {n:"Bring in the Powder",d:"You must bring 10 pods of gunpowder to Amayiro. You can buy them from Moob Tsinhcetoryp in Bonta.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"Unknown Summon",d:"Amayiro asked you to find Zeurg (master of the Osamodas class) and talk to him about an unknown summon employed by Brakmar.",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Find a Rift",d:"You must find an interesting rift in the mechanisms of the gate to Brakmar.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"One flew over the cuckoo\'s nest.",d:"Amayairo wants to set an ambush for the Brakmarians to test the new equipment and the cohesion of the militimen.",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Justified Paranoia",d:"A weapons convoy will pass the edge of the Treechnid Forest on its way to the Imps Village. Intercept it. Reinforcements are advisable.",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"Milone the jeweller",d:"According to Bishom Pot, Milone Corichel - Brakmar\'s jeweller- knows something.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"Bishom Pot Returns",d:"Amayiro suspects Brakmar to be the origin of Bonta\'s problems. As a militia spy in Brakmar, Bishom Pot might have learnt something.",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Harsh Underpass",d:"Only eight courageous adventurers will be able to get to the end of this underpass!",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Mysterious Underpass",d:"A slab set high up in the mountain and a hidden door... Volonteers will be needed to get to the end of this gallery...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"The Library basement",d:"Just like the basement of every library, it\'s full full of all kinds of books and arachnee cobwebs. However, in this one,  there\'s also some kind of special, mysterious atmosphere...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Dark underpass",d:"A hidden door in the mountain gives access to an underpass. But you still have to figure out how...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Impenetrable underpass",d:"Beware of Dreggon! You\'ll have to cross their territory to access this new cave...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Risky Underpass",d:"This underpass might drive you crazy!",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Visit to the Innkeeper",d:"You must get back Amayiro\'s map and a beer at the Feubuk Inn.",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"Hot Potato",d:"You must peel 200 pods of potatoes and bring them to the cook of the militia.",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"A Champo for Amayiro",d:"Amayiro asked you to bring him a Standard Champo. You can find them on Fungi Masters.",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Pinta Gone wants to read the recipe",d:"He already bought all the equipment to brew his beer. \nOnly the recipe is missing.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Find the Bwork Beer Recipe",d:"Pinta Gone is looking for the recipe of the famous Bwork beer. He believes that it\'s in a strange room on the Bwork territory.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Assault on Wa Castle.",d:"You must go and pick up the turtle bandana guarded by the Wobots in the Wa Wabbit Dungeon.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"High Risk Fashion.",d:"You must find a way of bringing the bandana back to its former glory. A tailor should be able to help.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Rough Recovery.",d:"You\'ve found the spy in time, but the Brakmarians aren\'t keen on you taking those documents. Get them to Amayiro at all costs.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"A little joke amongst enemies.",d:"The Brakmarians must take the documents to their superiors. You\'ve written up some false documents to replace them and send your enemies off on a wild goose chase.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Race against time.",d:"A Bontarian spy is escaping from Brakmar by the eastern road. You must find and escort him. Hurry, every second counts!",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Indecent reportal",d:"Someone has written a report criticizing you heavily. It\'s in the Bonta Tower of Orders. You should get your hands on it as soon as possible in order to prove your innocence.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"You need supplies to live",d:"Under the council\'s pressure, Amaryio deprived you of your investigation. You are in charge of supplies now.",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Towering indifference",d:"Find an accomplice to distract the guards while you steal the documents.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"Toy factory.",d:"Abominable creatures have broken into Father Kwismas\' workshop. You must recover the boxes of presents they have stolen, with or without their consent, and take them to Harry Kwismas.",r:[null,1000,[[10920,1]],null,null,null]};
