Q.s[365] = {n:"Key in between Teeth",d:"If you want the dungeon key, you must defeat a big aggressive Gobball.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"The Grafioze Grimoire.",d:"Danathor needs your services again to find the Bwork Mage spellbook said to contain the Grafioze curse.",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Bushwhacking.",d:"Touh Flowa showed you where the entrance to the vegetal prison was. He seemed to have his head in the clouds. You better pray he didn\'t leave anything out!",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"A Key on a Squirrel",d:"You must find a squirrel in Brakmar that stole a very important key. Bring the key back to Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Bring the Boxes",d:"You must bring the boxes of weapons to Oto, in the Tower of Brakmar.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Getas for Milone",d:"Since you couldn\'t stop the burglary at Milone\'s house, he asked you to bring him Feudala Getas.",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Boning Mak Again",d:"The Chafer Mak Gahan wants to take his revenge.",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Lenglad is in for a new session",d:"William Lenglad needs to be taught another lesson.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"A refreshing little lift.",d:"You must find a tactician and convince him to join Bonta\'s ranks.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Kaffra Keeper",d:"Oto wants to have Kaffra Keeper\'s opinion regarding his offense plan against Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Back to Oto\'s",d:"The fight is over. Oto Mustam is waiting for your report.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Skirmich",d:"A fight is taking place next to Cania Bay, right between Bonta and Brakmar. You must join in to help Brakmar win.",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Hammer Practice",d:"Oto needs 10 Twiggy Hammers to train his troops.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"The Dark Crystal",d:"You have to take the secret passage to the alchemists\' workshop with masters of the profession. You\'ll also need a Gust Potion, a Harmony and a Kobalite.",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"Crime doesn\'t pay",d:"The message was sent to Captain Starky. Go see if Sabine kept calm while you wait for a reply.",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"The ransom",d:"Sabine is well-guarded, so you\'ll have to find a way to contact Captain Starky in order to get a Kain Dharyn Crystal as ransom.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"Good behaviour",d:"Bring Sabine before Oto Mustam bu force. You\'ll have to make sure she doesn\'t get an opportunity to escape.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"Sabine\'s Kidnapping",d:"You must kidnap Sabine and put her somewhere she won\'t be able to escape from.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"Crime will pay, by Brakmar",d:"The Bontarians tried to save Sabine. You can\'t let them get away with that! Go show them who\'s boss.",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Challenge Puja",d:"You\'re supposed to lose the challenge that you launched against Puja Mustam, Oto\'s son. Are you really gonna let him kill you? That brat?",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"New Dentures",d:"You must take out Gobball teeth - as many as you\'d need to make human-like dentures.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"The Great Peeling",d:"You must peel potatoes for dinner. The kitchen is downstairs in the militia. ",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"Defeat the Manitou Zoth",d:"You must defeat the Manitou Zoth and take proof of your victory to Bob the Enutrof.",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Find the Turtle.",d:"You\'ll need to find a way to wheedle the Fogornleg Horn out of Elturt\'s hands. The residents of Moon Island should be able to help.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"Back to Oto\'s",d:"The tactician left town so you can easily make Oto believe that you killed him.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Taming the beast, and the animal too.",d:"Oto Mustam wants to find out the secret to taming Whitish Fangs. Go back to the Bonta Library to find some clues.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"Stabbing the haggis",d:"Oto Mustam was convinced that you were planning on tricking him. You have to find that jewel really soon to ensure that the rest of your life is worth living.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"Victory!",d:"Xephires accepts the conditions and is ready to betray Bonta when the moment comes. Oto will be delighted to hear the news.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"Interview",d:"Everything\'s ready. You just have to find Xephires in the Drunken Pandawa Inn, give him the letter and make an appointment for his answer.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Vengeance, mwahahaha.",d:"The bandits\' hideout is boobytrapped. You\'ll need to find someone to go with you and help you deactivate the devices protecting the bandit\'s treasure.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"Back to Justfa Lafs",d:"The fight is over. Justfa Lafs is waiting for your report.",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Skirmish",d:"There\'s a fight taking place near Cania Bay, on the road at the halfway point between Bonta and Brakmar. You must join in to help Bonta win.",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Job Offer",d:"Oto Mustam wants to know who murdered the owner of the Burnt Cat Inn.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"Blop Pulp",d:"You must bring Blop Pulp to Oto. He can give you the recipe.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Find the Will",d:"You must find Oto\'s will in his father\'s grave - which you can recognize in the cemetery thanks to the flowers around it. You must be a spirit to enter this cemetery.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"A-plundering we go!",d:"Thanks to Xephires, you now know that the Bontarian ship \'The Panta Maria\' is carrying many magical objects in her hold. Find the ship and plunder her wares.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Total recall (faulty parts)",d:"There\'s a Sram who owes Oto Mustam some money. She hasn\'t paid him back, so Oto has decided to eliminate her. She\'s probably in the illegal gambling room.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Equipping Warriors",d:"Oto fears an attack from Bonta and asked you to equip some of the Brakmarian warriors with specific equipment.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Cronyism",d:"Kosuke Ichazum was right - Latem Sa got the contract to equip the Bontarian Militia through cronyism and not for his skills as a smith.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Bring the Swords",d:"Investigate the supplier of the militia\'s equipment and put him to the test.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"Well of the whisp",d:"You have to find out where the Well of the Corrupted Souls is located so as to reveal the full power of the Corruptah Stones. Divad Dleifrepok, master of the Order of the Unsound Mind, can halp you.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Cruel alchemy",d:"You need to get some Corruptah Stones. Miners are the only ones who can make them using the unworked creations of wild alchemists.",r:[null,null,null,null,null,null]};
Q.s[903] = {n:"Seven souls or none at all",d:"You must capture the souls of seven bandits and take them to the Well of the Corrupted Souls. You\'ll need some Brakmarians who are so vile that they\'re ready to specialise.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Find the Spy",d:"You must quickly find the wounded spy on the road to Bonta and take the documents. The spy must now be closer to Bonta than Brakmar.",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Inn Crawl",d:"The Bandit who owned this sword probably visited one of the Inns. As a result, the Innkeepers must know something.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Important Investigation",d:"Check the activities of the Brakmarian guards and make a report on those who do not take a break.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Taming the beast, and the animal too.",d:"Oto Mustam wants to find out the secret to taming Whitish Fangs. Go back to the Bonta Library to find some clues.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Up to Brakmar",d:"The tactician agrees to follow you to Brakmar.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Another Report",d:"You must find Trojen Tihpor and ask for his report. He is around the ramparts of Bonta. ",r:[19000,null,null,null,null,null]};
