Q.s[956] = {n:"Order or counterorder?",d:"The current plan of attack has not been confirmed. Find out about any confirmation or change to the plan from Kapp Tenn and report back to Amayiro.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Plan of attack",d:"Amayiro is worried the Brakmarians may strike very soon. You must find their plan of attack, so Amayiro can prepare the welcoming party...",r:[null,null,null,null,null,null]};
