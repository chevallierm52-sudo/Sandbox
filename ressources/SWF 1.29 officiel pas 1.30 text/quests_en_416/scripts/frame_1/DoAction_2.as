Q.s[536] = {n:"Catch the Spy",d:"A Bontarian spy infiltrated the Tower and stole the documents. Use a Zaap and intercept him. He should be on the east road leading to Bonta, but still close to Brakmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Everything\'s fine for the Rogues.",d:"Now that you know exactly where the Rogues\' den is, you just have to check the information.",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"Tales from the Crypt.",d:"You must visit the five crypts in the cemetery of Amakna.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"For a Few More Rogues...",d:"You have to infiltrate the Rogues and speak with Vil Smisse.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"In Enemy Territory.",d:"Sneak into the Bontarian Militia and discover where your enemies are storing their weapons.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"My, what a lovely big crate.",d:"Distract the guardian and take his warehouse keys. Then, steal the crate of equipment and take it to Mulic Bere to assess.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"Brakmarian Cloaks",d:"Oto asks for 5 Brakmarian Cloaks. He can tell you how to make them.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Water Stories",d:"Danaida needs water for her nymphets.",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"Research about a Horn",d:"The so-called guardian of the Fogornleg Horn lives in the deep jungle of Moon Island. According to popular rumour, you need to wear an Ambusheadgear and have some Greedoburg to make him appear.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"Information about the Captain",d:"You must find a way to communicate with the passed away captain Tsog in order to get the information he wants to pass on. Captain Alrok knows where Tsog\'s grave is.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Find the Culprit",d:"Find the murderer Rimaraf and bring the form filled in to Amayiro.",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Fake Evidence",d:"Find a way to fool Amayiro by showing him fake evidence. Danathor may be able to help you.",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"Rat Blood",d:"Amayiro asked you to kill 4 Hyoactive Rats in the sewers of Bonta.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Trustworthy People.",d:"Amayiro needs trustworthy people to participate in the performance presenting the fake powers of the Fogornleg Horn.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"A Meticulous Performance.",d:"To complete the performance, Amayiro needs some Miteters, you\'ll find them on Cracklers. He also needs Royal Jelly Blubber (it doesn\'t matter what kind of Royal Jelly it comes from).",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"More collection...",d:"The Cras have taken their arrows out of the game. It seems sick Arachnee legs are used for making poison.... Oh well, business is business...",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"The call of the lunatic",d:"Eliof asks for a Twiggy Shovel to build his anti-apocalypse shelter.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"A loaf on your plank",d:"To build his indestructible shelter, Eilof asks for two chestnut tree planks and a few loaves of bread... that should keep him going for at least three days after the apocalypse!",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Ratatouille.",d:"You need to combine the necessary ingredients in the primordial cauldron: an item of each type, and an alchemist, a baker, a farmer, a butcher and a fishmonger.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"Searching Salad",d:"You must the ingredients listed on the paper Oto gave you.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Animals are our friends too.",d:"Amayiro wishes to know more about Elturt. Oshimo, the guardian of the Kennel, will surely have more information about the turtle.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Everybody loves lenald",d:"Elturt has rubbed shoulders with the Lenalds in the past. The Lenalds, to the south of Wabbit Island, might still remember him.",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Collect of Underpants",d:"You must defeat Bontarian militiamen and... collect their underpants. Oto needs 5 of them. ",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Hurry Wood",d:"Get some Hurry wood... by sacrificing nature, you will have the opportunity to create a bond with it.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Ritual",d:"Find the person who\'ll help you make your initiate staff.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Show your skills",d:"You\'re improving your skills but it will take more to convince everybody.",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"Back to Moon.",d:"The so-called guardian of the Fogornleg Horn is in the depths of the Moon Island jungle. According to the rumours, you need to be carrying an Ambusheadgear and some Greedoburg before he\'ll appear.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"Slobber for a Jewel",d:"You must gather certain ingredients to make a jewel including 5 Gold Ingot, 1 Royal Gobball Slobber and 1 Mother of Pearl. You can get Mother of Pearl by polishing 10 Raw Mothers of Pearl that can be found on shellfish and mollusks from Otomai Island.",r:[80000,null,null,null,null,null]};
Q.s[1063] = {n:"Toy factory.",d:"Abominable creatures have broken into Father Kwismas\' workshop. You must recover the boxes of presents they have stolen, with or without their consent, and take them to Harry Kwismas.",r:[null,1000,[[10920,1]],null,null,null]};
