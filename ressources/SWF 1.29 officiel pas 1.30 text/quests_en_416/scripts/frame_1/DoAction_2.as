Q.s[1093] = {n:"The untold story.",d:"The legend of Goultard does not recount his whole life. Follow his story from childhood to discover its secrets.",r:[null,null,null,null,null,null]};
Q.s[963] = {n:"A spanner in",d:"Oto Mustam wants to sabotage Bonta\'s equipment, so he\'s planning to replace the forgers\' tools with 5 Hurrian Hammers.",r:[null,null,null,null,null,null]};
Q.s[904] = {n:"A shove in",d:"Oto Mustam is happy with the smith who\'s supplying the Bontarian militia and wants you to make sure things continue this way.",r:[null,null,null,null,null,null]};
Q.s[905] = {n:"A hand in",d:"Latem Sa just got the ore and new tools. You should act quickly while he\'s gone. He\'ll be away between five and nine o\' clock in the evening, so you can sneak in, steal the ore and switch the tools.",r:[122000,null,null,null,null,null]};
Q.s[204] = {n:"Find the Outlaw",d:"Zatoïshwan was spotted near Terrdala.  \nHe\'s been sentenced to prison in Astrub.",r:[null,112500,null,null,null,null]};
