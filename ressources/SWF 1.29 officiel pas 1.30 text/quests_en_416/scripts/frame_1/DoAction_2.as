Q.s[704] = {n:"Saving Lyeno",d:"You must save the Colonel Lyeno. He disappeared in the eastern part of the Treechnid Forest.",r:[12800,null,null,null,null,null]};
Q.s[722] = {n:"Another Request from the Cook",d:"The cook of the militia needs your favors again.",r:[31000,null,null,null,null,null]};
