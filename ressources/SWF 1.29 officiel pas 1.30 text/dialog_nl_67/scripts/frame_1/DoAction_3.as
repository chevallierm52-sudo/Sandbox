D.q[6636] = "";
D.q[1162] = "Hè... wat is er? Kan er hier misschien nog wat geslapen worden? Nou, wat wil je, jongen?";
D.q[853] = "Een Bontarian huurmoordenaar... Ik was daar nooit op gekomen. Wat een perfecte dekmantel, een Bontarian die een andere Bontarian vermoord. Je moet Bontarians vinden met een onzuiver hart. Vraag Fryda de Middernacht Klauw voor een Sniffling Staf. Haar staven kunnen het minste bloed op mensen vinden, het zal bruikbaar zijn.";
D.q[6815] = "";
D.q[4655] = "Een Brakmariaan? Nu al? Pas op!\nOh, jij bent het! Kijk, ik geef mezelf over! Ik rot liever weg in een Brakmaarse gevangenis dan dood eindigen!";
D.q[7952] = "";
D.q[4597] = "Heb je besloten me de documten terug te geven?";
D.q[2532] = "Heb je die koopmannen geen afbeeldingen van de godin zien verkopen? Al die valse drakeneieren? De adviseurs hebben besloten de werkbanken van de Wereld te overspoelen met goedkope producten die gemaakt zijn in Pandala! In de tussentijd, gaan de oorspronkelijke Pandawa waarden en normen verloren!";
D.q[7352] = "";
D.q[7430] = "";
D.q[7953] = "";
D.q[7353] = "";
D.q[1209] = "Heeft Elviana je gestuurd? Ik wil wel met je mee gaan maar ik moet mijn twee broers vinden, Aigurraf en Tabach. Ze doen waarschijnlijk allemaal vreemde dingen vanwege hun bedroefde staat.\nJij ziet er uit als iemand die ik kan vertrouwen. Ik geef je mijn badge, toon die aan Elviana.";
D.q[797] = "87";
D.q[798] = "88";
D.q[799] = "89";
D.q[800] = "90";
D.q[4421] = "Er is een gevecht gaande op de vlaktes bij de weg tussen Bonta en Brakmar. Ik wil dat je er heen gaat en onze krijgers helpt te winnen!";
D.q[2054] = "Heeft Trapchet... je...gest... ? Fijn... zien... opgegeten door... een plant... de oen...\n\n*Drie-Bloem pakt een papiertje uit z\'n zak: \"Sorry, ik heb geen stem meer sinds gisteren\" staat erop geschreven.*\n\nIk heb... interessant... nieuws... een dui... vels... rozen... veld... van Ingalsse..., breng... één... bloem... van... deze roos... naar Trapchet...!\n\nEr sch...ijnen... vreem... de motieven te zijn... in... het... tarwe... veld... je her... kent ze... hieraan...";
D.q[7954] = "";
D.q[7955] = "";
D.q[1635] = "Heel goed, altruïsme is een zeldzame deugd tegenwoordig en het is altijd goed voor de bescherming van het land als je nieuwe krijgers hebt om onze steden te verdedigen.\n\nLaatste vraag: als een speler je uitlacht om de manier waarop je vecht of om hoe je eruit ziet, wat doe je dan?";
D.q[1198] = "Heel goed, Je herinnerd je nog steeds mijn eerste les: Denk eerst goed na voor je een keuze maakt. Kom terug als je helemaal zeker bent.";
D.q[802] = "92";
D.q[803] = "93";
