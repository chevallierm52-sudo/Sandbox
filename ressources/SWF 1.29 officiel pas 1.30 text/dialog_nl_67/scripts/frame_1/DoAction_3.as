D.q[7956] = "";
D.q[1634] = "Heel goed. Er zijn inderdaad gemene wezens in Amakna, die zonder gewetensbezwaar identiteiten aannemen om eerlijke burgers zoals jij te beroven. Vertrouw nooit iemand die geïnteresseerd lijkt te zijn in je rijkdom.\n\nVolgende vraag: als je een groot krijger bent en je komt een leerling tegen die om hulp vraagt, wat antwoord je dan?";
D.q[808] = "98";
D.q[809] = "99";
