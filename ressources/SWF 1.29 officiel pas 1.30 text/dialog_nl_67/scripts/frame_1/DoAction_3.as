D.q[869] = "59";
D.q[3261] = "... Wat een trutje!...\nJe hebt mazzel dat ik terug moet naar Madrestam.\nStap in.";
D.q[2829] = "...Hum... Terra Cogita heeft dit allemaal gemaakt voor maar één reden... Ik heb \'t! Het is om te voorkomen dat \'t weer gebeurd!.. Maimane had dus \'t dus al voorzien...\n\n*Wally pakt z\'n boekje en tekent*";
