D.q[645] = "Er zijn talloze goden in ons universum. Je hebt lang geleden gekozen voor je geloof, je kan al het een en ander, maar je moet je ontwikkelen. \n\nJe kunt je leven en carrière op diverse manieren invullen, ieder zijn vak.\n\nSommigen houden van vechten, anderen oefenen liever een beroep uit en anderen doen beide. Er zijn geen slechte manieren om je te ontwikkelen, je moet enkel keuzes maken.\n\nJe kunt informatie over je kenmerken krijgen door op het ronde symbool van de DNA in de interface onderin te klikken, rechtsboven je portret. Elke keer als je een level hoger komt, verdien je 5 kenmerkpunten die je kunt onderverdelen in wijsheid, vitaliteit, kracht, intelligentie, behendigheid en geluk.";
D.q[7897] = "";
D.q[4846] = "";
D.q[7903] = "";
D.q[2425] = "Er zijn verscheidene type smeden, één voor elk soort wapen zwaarden, dolken, schoppen, hamers, bijlen. In deze beroepen worden veel metalen gebruikt en soms wat hout. Zoals alle ambachtslieden, heb je een flinke som geld nodig en kennis om je vaardigheden te verbeteren. Maar iedereen is het er over een dat de beste wapens ter wereld gemaakt worden door professionele smeden.";
D.q[6660] = "Er zijn veel voordelen. Alle militiamannen in een stad hebben dezelfde alliantie en trekken er profijt uit: ze kunnen dorpen veroveren en toegang verkrijgen tot hun exclusieve grondstoffen. Ze zijn ook in staat Prisma\'s van verovering te plaatsen om gebieden te alliëren, dit kan hun winst vergroten gedurende gevechten en oogsten als ze besluiten actief deel te nemen aan de strijd tegen de andere alliantie. Ten slotte kunnen ze een specialisatie kiezen en nieuwe bekwaamheden krijgen. De specialisaties zijn krijger, spion en priester. Een alliantie kiezen heeft ook andere kleine voordelen, zoals de mogelijkheid hebben te reizen via prisma\'s, vijanden aanvallen etc. Je zult later meer er over horen maar ga eerst je sporen verdienen en kom terug als je wat meer ervaring hebt, ik heb misschien een tip voor je.";
D.q[7898] = "";
D.q[7904] = "";
D.q[3210] = "Woah! Echt waar, ik ben erg onder de indruk! Je hebt dit vreselijke wezen verslagen! Hoe gelukkig ben je! Ik kan niet geloven dat iemand als jij, die de weg kwijt kan raken in zo\'n simpel doolhof, een Minotoror kan verslaan.\nEchter, ik denk dat je nog geen minuut overleefd als je tegen de echte meester zou moeten vechten, dat is de Minotot! Dus, wat wil je dat ik voor je doe?";
D.q[4896] = "";
D.q[7905] = "";
D.q[1668] = "Erg simpel, 3 ballonnen, 3 zwaarden. Als je een zwaard bij een ballon hebt gezet, klik op het scherm om te gooien.\nKnap alle 3 ballonnen en je krijgt de jackpot!";
D.q[3159] = "Ga hier vandaan Grot Gobball! Hoe durf je mijn geweldige kapsel te verpesten voor dit gevecht? I hoop dat Silvosse je in een een Wilde Zonnenbloem of een ruwharig Kirball zaad.";
D.q[1735] = "Discipel, je moet nog veel dingen leren, wat wil je weten?";
D.q[4897] = "";
D.q[4998] = "Heb je iets gevonden?";
D.q[7906] = "";
D.q[6406] = "Je maakt een grapje zeker? De Cania Vlakte strekt zich uit tot in het oneindige, wat tegelijk ook betekend dat er oneindig veel kanigers zijn om te doden.";
D.q[4898] = "";
D.q[2052] = "Ga naar Eli Bel de Alchemist. Als het metaal omgezet is, wordt de Xelor magie vernietigd!";
D.q[7901] = "";
D.q[6252] = "Ga recht voor de Zaapi staan en vertel hem om recht voor mij te staan. Ik wil zeker weten dat het een rekruut is die goed genoeg is.";
D.q[500] = "Zwoek je de uitgwang?\nIk kan je twouens ook telepowtewen als je wilt...";
D.q[3118] = "Ik ben erg onder de indruk, kleine! Je hebt mijn huisdieren verslagen. Ik denk dat ik je nu weer tot leven zou moeten brengen. Ik zal een resurrectie poeder en je geestenvorm ruilen tegen een resurrectie, maar het zal alleen effectief zijn als je hier weg bent. Dan, zul je weer bij je meester zijn.";
D.q[5414] = "";
D.q[1688] = "Geef me 10 kamas en ik zal je een vishengel geven. Dan heb je een kans om een Quaquack te vangen. Als je het voor elkaar krijgt om er een te vangen, kom dan en geef het aan mij en ik geef je een prijs!";
D.q[6812] = "";
D.q[3654] = "Geen probleem... Als je een aanbeveling van mij wilt hebben, moet ik wel weten of je een kop op je schouders hebt";
D.q[4991] = "Hoe is het gevecht begonnen?";
D.q[1579] = "Gefeliciteerd! Je bent één van de eersten die me tien badges brengt!";
D.q[7902] = "";
D.q[2248] = "\"Strijkt haar hand door haar haar\" Ja? Kan ik je helpen?";
D.q[598] = "Gefeliciteerd, beste klant! Je hebt zojuist een reis direct naar de tropische eilanden gekocht! De zon, de zee en alles wat daarbij hoort, is voor jou. Je kunt vertrekken als je zover bent. Zet je helm op en doe je vleugels om. Maak een afspraak met je vrienden en spring in het kanon. Binnen een paar minuten ben je op de plaats van bestemming. Prettige reis en vakantie! Bedenk maar... als je wakker wordt in een andere tijd, op een andere plaats, kun je dan ook wakker worden als een ander persoon?";
D.q[7339] = "";
D.q[1684] = "Gefeliciteerd, je hebt het monster briljant verslagen, maar kun je hetzelfde doen bij de volgende? Nu moet je kiezen, ga en neem je prijs of ga door met het avontuur!";
D.q[7340] = "";
D.q[5450] = "";
D.q[4699] = "Zeker. Zo, het is gereed.";
D.q[7072] = "Gegroet #1! Ik zie dat je verbaasd bent dat je tegen een plant kunt praten. Ik neem aan dat je normaal wezens als ik negeerd. Nou, het is niet vaak dat je een strijder tegenkomt met een beetje lef. Zoals mijn Wortel vaak tegen me zegt - \"Er zit veel tussen wat we denken en wat we zeggen.\" Ik zeg niets over wat je doet, maar...";
D.q[3659] = "Dank je wel lieverd, maar ik heb alle ingedienten die ik nodig heb. Ik wilde alleen het recept hebben. Hier dit is voor jou.";
D.q[5428] = "";
D.q[623] = "Denk je dat je enkel met praatjes dit beroep kunt uitoefenen? Ik denk dat je de essentie van dit beroep niet hebt begrepen. Als je echt een alchemist wil worden, ga dan naar mijn collega-instructeur. Hij bestudeert gespikkelde stenen op drie plekken in het Noordwesten van de Kanodjeo Tempel.";
D.q[5451] = "";
D.q[5458] = "";
D.q[5690] = "";
D.q[1080] = "Hey jij, wat wil je?";
D.q[2839] = "Gegroet #1! Je ziet er zo stralend als een phoenix uit, jonge volgeling.\nWat kan ik voor je doen?";
D.q[3538] = "Gegroet Enutrof-vriend. Gevechten zijn niet je sterkste kant. Als je er rijp voor bent en de kracht hebt van je god, zul je gevreesd worden. Maar hier heb je een klusje dat je voor me kunt doen.";
D.q[4856] = "";
D.q[6183] = "Je lijkt me erg enthousiast, ik zal je van de taak ontheffen de nieuwe rekruten te bewapenen voor hun training. \nMaar, om de dingen meer officieel te maken, wil ik dat je naar de Amakna militie gaat en daar een Richtenconversie Certificaat haalt.";
D.q[6304] = "Gegroet, ik dacht dat ik je om een ziel van een Vampiermeester had gevraagd in ruil voor de informatie die je wilt.";
D.q[5391] = "";
D.q[3618] = "Met Piwi veren prop ik bier in mij!";
D.q[7648] = "";
D.q[7908] = "";
D.q[1844] = "*De Bow Meow ruikt de mimilk, likt wat op, en leeg is z\'n bakje\"\n*Dan begint ie klagelijk te jammeren*\nMiaaaaaauwwww";
D.q[1191] = "Laat eens kijken... Het ziet er naar uit dat je met de dappere Amayiro aan het trainen bent.\nHet is tijd voor je om een rode te kiezen en om je specialiseren in iets om Bonta te kunnen dienen!\n\nIk behoor zelf tot de Orde van de Moedige Hart. Als je meer wilt weten over een andere orde, raad ik je aan de andere verdiepingen van de toren te bezoeken.";
D.q[6276] = "Huh... niet veel voor mij.";
D.q[4906] = "";
D.q[7649] = "";
D.q[7909] = "";
D.q[4652] = "Pnj(183) et Message(4649)";
D.q[4249] = "Pnj(961) et Message(4247)";
D.q[1845] = "*Misschien heeft hij nu honger\"\n *Je moet weten wat een Bow Meow eet en hem het voer geven\"";
D.q[6998] = "";
D.q[4982] = "";
D.q[5943] = "";
D.q[7651] = "";
D.q[7910] = "";
D.q[4293] = "Geweigerd huh? Ik wist dat het niet zo makkelijk kon zijn. Maar ik weet zeker dat hij van gedachte zal veranderen als we iets kostbaars vinden om aan hem te laten zien. Ik ken zijn type - hij zal geen nee kunnen zeggen als hij het voorwerp echt onder zijn neus heeft. Een juweel zou voldoende moeten zijn. Ga naar de Brakmariaanse juwelier, Milone Corichel en vraag hem welke juwelen hij leuk vindt. Vraag Milone Corichel dan om er een te maken.";
D.q[7034] = "";
D.q[1212] = "Je moet wat meer oefenen.\nBezoek Oto Mustam opnieuw.";
D.q[1521] = "Weet je het zeker? Wens je enkel de dood van je vijand en niet die van iedereen?";
D.q[7652] = "";
D.q[7911] = "";
D.q[3986] = "Glowieus! Ik ben glowieus! Twouwens, ik was je vewgeten te vragen: wat bwengt je naaw dit vijandelijke land.";
D.q[4902] = "Als de Iop de waarheid vertelde, is het zeker de moeite waard. Ik kan mij herinneren dat een zielloze Hamer van het Licht rond de tombes zwierf op het Amakna kerkhof. Met een beetje geluk heeft niemand dat nog gezien. Ga kijken of het er nog steeds is.";
D.q[5439] = "";
D.q[3870] = "Pnj(893) et Message(3869)";
D.q[7653] = "";
D.q[7912] = "";
D.q[7654] = "";
D.q[4993] = "";
D.q[4916] = "";
D.q[1023] = "Goed gedaan! Binnenkort ken je Brakmar als je broekzak!";
D.q[5676] = "Goed werk. Ik hoop dat dat alle militiamannen tegenhoud over te lopen naar het vijandelijke kamp. Je hebt moed en doorzettingsvermogen laten zien. Vanaf nu ben je een Afvalligen Jager. Gefeliciteerd.";
D.q[5441] = "";
D.q[7913] = "";
D.q[6031] = "";
D.q[2598] = "Je weg was lang, discipel, maar je bent op de goede weg: deze voert naar het kwade bos... Voordat je daar op avontuur gaat, moet je praten met onze africhter van Dopples. Als je kunt, oefen dan met een van zijn beestjes: er is geen betere manier om je vechttechnieken te verbeteren! Je hebt kans dat je ze ooit nodig hebt daar: ze zeggen dat dit bos vergeten is door de goden...";
D.q[4921] = "";
D.q[7914] = "";
D.q[6045] = "";
D.q[6040] = "";
D.q[4873] = "";
D.q[304] = "Geen karwei te groot geen klus te zwaar...";
D.q[3142] = "Eindelijk je bent terug! Zo je hebt alle vier broches. Dit is genoeg bewijs dat je de steun van de vier zusters hebt. Bovendien, je zult niet durven om te belazeren of wel? Niemand belazerd de grote Frivolok niemand!";
D.q[3800] = "Aha...HA! Nipper is terug voor zijn pak slaag!?";
D.q[7915] = "";
D.q[4455] = "Aaaaargh!";
D.q[2590] = "Je weg was lang, discipel, maar je bent op de goede weg: deze voert naar het kwade bos... Voordat je daar op avontuur gaat, moet je praten met onze africhter van Dopples. Als je kunt, oefen dan met een van zijn beestjes: er is geen betere manier om je vechttechnieken te verbeteren! Je hebt kans dat je ze ooit nodig hebt daar: ze zeggen dat dit bos vergeten is door de goden...";
D.q[5200] = "";
D.q[7657] = "";
D.q[5482] = "Ik ben Lina, een trotse huurling van Astrub. Mensen hebben een verdachte grappige goblin in het gebied gemeld... ik ga er achteraan.";
D.q[5363] = "Zzz.. Neee... mijn geheim. MIJN! ... zzz...";
D.q[7916] = "";
D.q[5086] = "Hallo, is het gelukt je hand te leggen op die geel-gebuikte jonge rekruut?";
D.q[7917] = "";
D.q[4927] = "";
D.q[5183] = "";
D.q[7918] = "";
D.q[3776] = "Wil je terug naar je standbeeld, jongeling?";
D.q[4931] = "Ik heb geen tijd om met je te praten!";
D.q[4933] = "";
D.q[1594] = "Wat whil je, bhenhs? Hoe buhrf je beh te sthoruh bijdehs bhit sbhel?";
D.q[5003] = "Ahah! Ik dacht dat Fallanster een dochter had, maar ik wist niet dat hij er zo aan gehect was. Dus, weet je wat we doen? Ik ga wachten tot Fallanster weg is en ontvoer dan zijn kleine meisje... Ik geef haar alleen terug als ik een bepaald voorwerp heb...";
D.q[2596] = "Je weg was lang, discipel, maar je bent op de goede weg: deze voert naar het kwade bos... Voordat je daar op avontuur gaat, moet je praten met onze africhter van Dopples. Als je kunt, oefen dan met een van zijn beestjes: er is geen betere manier om je vechttechnieken te verbeteren! Je hebt kans dat je ze ooit nodig hebt daar: ze zeggen dat dit bos vergeten is door de goden...";
D.q[5467] = "Ha-ha! Jij vindt het ook grappig? Ik hou van grappige verhalen...\nMaar ik snap hem niet...\nKun je het uitleggen?";
D.q[5349] = "Hmm.. Zoek je Divad? Jammer- hij is naar het huis van de Rogues. Dat is op het kerkhof van Amakna.";
D.q[239] = "Haha! Ik wist het! Je bent verdwaald! De uitgang? Ik zou het niet weten. Ik zoek er al jaren naar. Genoeg nu! Haal die lach van je gezicht! Ik weet waar ik ben. Ik ben...uh... O nee, ik weet \'t niet.";
D.q[7919] = "";
D.q[7920] = "";
D.q[2486] = "\"Ga Barnsteen zoeken\" zei Manganèze. Tja, makkelijker gezegd dan gedaan. Waar kan ik in hemelsnaam barnsteen vinden? Op bomen, zeiden ze, maar welke bomen? Help me alsjeblieft, maat. Dan geef ik je een kleine Vitaliteitsschriftrol...";
D.q[2589] = "Je weg was lang, discipel, maar je bent op de goede weg: deze voert naar het kwade bos... Voordat je daar op avontuur gaat, moet je praten met onze africhter van Dopples. Als je kunt, oefen dan met een van zijn beestjes: er is geen betere manier om je vechttechnieken te verbeteren! Je hebt kans dat je ze ooit nodig hebt daar: ze zeggen dat dit bos vergeten is door de goden...";
D.q[6050] = "";
D.q[4962] = "";
D.q[191] = "De schuilplaats van het Gladjanus Gilde is goed verstopt en vooral goed beschermd. Hij is omgeven door water en de ingang ligt in een heel gevaarlijk gebied dat bewaakt wordt door de Gildeleden.\n\nAlleen de meest wrede personen mogen hopen dat ze hier binnen komen en de Meester van het Gladjanusgilde ontmoeten.";
D.q[746] = "Stoor me nu niet, ik ben in diepe meditatie.";
D.q[6049] = "";
D.q[7921] = "";
D.q[372] = "Eindelijk geen lafaard! Dus breng me 75 Prespic Stekels, 75 Krab Tangen, 45 Ribben en 30 Vuurstenen. Ik moet solide schilden maken met scherpe kanten zoals scheermesjes. Daarmee kun je jezelf prima beschermen, doeltreffend bij de aanval en makkelijk duur te verkopen... Gewoon perfect! In ruil geef ik je een Grote Krachtschriftrol.";
D.q[4926] = "";
D.q[7922] = "";
D.q[837] = "HA-HA-HA, Ik hoorde Sbab schreeuwen tot hier, ha-ha! Geweldig! Je bent het waard om aan mijn zijde te staan. Als je zo door blijft gaan, zou je zelfs beter kunnen worden dan mij, ha-ha-ha! Genoeg grapjes, ik heb nog niks gehoord van Raaga. Hij is een van onze beste soldaten en hij zou vandaag terug moeten komen uit de mijnen in het noorden om ons een rapport te brengen over de lava daar. Ga hem zoeken... maar bovendien, vind dat rapport.";
D.q[4559] = "Heb je mijn schelpen?";
D.q[5817] = "";
D.q[5379] = "";
D.q[5018] = "Een 639 Dwergbus? Ik kan er een maken, maar het kost je 10,000 Kamas.";
D.q[7923] = "";
D.q[374] = "Het nut van Ribben? Niet om schilden te maken;\r\n            gewoon om iets te eten te hebben tijdens mijn pauzes.";
D.q[5263] = "Er was een groot gevecht bij de Bwork herberg. De Bworks deden vrolijk mee, zoals je je voor kan stellen. Het is gewoonweg onacceptabel - ik wil dat je die Bwork herberghouder een goed lesje moet leren, om ervoor te zorgen dat dit niet meer gebeurd.";
D.q[3443] = "Uniek gerecht? Er zijn gehaktballen, maar niemand weet hoe je ze moet maken. Of anders, Filtounga, heel apart. Zelfs Greedovore niet klaar. Ik niet hebben recept.  Jij aan Schuim Vraat vragen. Hij recept hebben.";
D.q[5322] = "Ik ben de kapitein, dus ik moet een risico bonus krijgen. Dat is gewoon een van de voordelen van bij deze positie.";
D.q[445] = "Er zijn maar twee oplossingen, training en de krachtschriftrollen. Het probleem met de schriftrollen is dat je ze niet kunt gebruiken als je te sterk bent. Zoals ik. Als je wilt, kan ik een kleine krachtschriftrol met je ruilen tegen honderd Champ Champ Stekels.";
D.q[7925] = "";
D.q[4981] = "Het is te vroeg, ik heb gehoord over de problemen rond Amakna, het is onacceptabel! Hoe kon Brakmar zo roekeloos zijn? Een enkele Brakmariaanse soldaat heeft een gehele groep van Bontariaanse elite verslagen! Ik hou dit niet vol!";
D.q[6613] = "";
D.q[4976] = "";
D.q[4026] = "Een Wabbit transformatie drankje! Hey, jij bent de tweede persoon die dit aan me vraagt vandaag... De laatste persoon had wat onderzoek gedaan, maar het recept werkte niet, dus we moeten alles weer van voor af aan doen. Kan je mijn collega\'s in Amakna een bezoekje brengen?";
D.q[7926] = "";
D.q[6003] = "";
D.q[6615] = "";
D.q[6614] = "";
D.q[4989] = "Brakmar straffen? Dat is een geweldig idee! We zullen een Brakmariaan vermoorden! Ik heb vlinder in mijn buik.";
D.q[5008] = "Allisteria onvoeren... het zal zeker werken. Ik denk niet dat ik haar zal laten gaan, zelfs als ik de sleutels heb. Dat zal die familie leren niet met As\'Ruoy\'Dnim te spotten!";
D.q[3225] = "Ik kan je ook meer vertellen over de Porcos Rustos! Het zijn eigenwijze schoften en leven alleen om te eten, drinken en in de modder te rollen! Wat kan ik nog meer vertellen? Juist! Ze vertrouwen geen schepsels die geen snuit in het midden van hun gezicht hebben...";
D.q[7927] = "";
D.q[5392] = "Loufes de boeufs, loufes de boeufs, alsof bezweringsrollen schrijven voor jonge militaire beloftes mijn levenspassie was.";
D.q[4456] = "(Als je zo naar hem kijkt zal hij het einde van de week niet halen. Of de dag. Of zelfs het uur)";
D.q[7928] = "";
D.q[5422] = "";
D.q[5199] = "Hallo vreemdeling. Zoek je de sleutel voor Nilevaj\'s gevangenis. Laat me je iets vertellen.";
D.q[5290] = "";
D.q[7929] = "";
D.q[5201] = "";
D.q[5432] = "Shere Hacanon heeft eindelijk de waarheid verteld, dus hij heeft zijn baan terug.\nEn nu ik erover denk, Javelin de Centaur is naar je op zoek. Je weet waar je hem kunt vinden in de Toren van Bonta.";
D.q[6271] = "Wat doe je daar?";
D.q[138] = "(Izegrim doet de dobbelsteen in de bronzen bierkroes, beweegt snel de anderen dobbelstenen en het lijkt of de dobbelsteen van de ene bierkroes in de andere terecht is gekomen, zonder dat je in de gaten hebt hoe het mogelijk is)\n\nDus, in welke bierkroes bevindt zich de dobbelsteen, m\'n vriend?";
D.q[7930] = "";
D.q[4143] = "Hallo! Ik ben Polka Merer, één van Otomai\'s meest beroemde assistenten. Ik zorg ervoor dat de weides blijven draaien. Soms gebruiken we ze om het gedrag van schepsels te observeren als ze in gevangenschap leven. Helaas heb ik geen vrije broedmachine over en kan ik mijn onderzoek niet voortzetten.";
D.q[4576] = "Enig nieuws?";
D.q[5323] = "Hallo, heb je al die morrende honden hun bonus gegeven?";
D.q[7931] = "";
D.q[7428] = "";
D.q[632] = "Als je op zoek bent naar recepten, kun je beter naar de bibliotheek gaan.  Een alchemist heeft een encyclopedie gemaakt van meer dan 12 boeken over vreemde recepten.";
D.q[636] = "Als je recepten zoekt, moet je naar de bibliotheek gaan. Een alchemist heeft een encyclopedie gemaakt van meer dan 12 delen met allemaal zeldzame recepten.";
D.q[7934] = "";
D.q[4590] = "";
D.q[4586] = "";
D.q[6814] = "";
D.q[6004] = "";
D.q[6619] = "";
D.q[291] = "Hallo, hier staat een legende voor je. Ik ben Kwaker Vans. Die bedrieger Kelog Korflex heeft mijn plaats ingepikt als leider op de broodmarkt in Amakna. Maar ik ga in de tegenaanval: Het Curry Brood zonder curry!";
D.q[2715] = "Fout! Allemaal fout! Ik denk niet dat je hier kwam om een Pandikaze te worden.";
D.q[7932] = "";
D.q[7935] = "";
D.q[6620] = "";
D.q[7933] = "";
D.q[5251] = "(Je hebt de indruk dat Divad lichtelijk verontrust is als je hem de oorbel laat zien, en zelfs een beetje paniekerig. Of verbeeld je je dat nou?)                           Hmm, ik zie dat deze oorbellen toebehoren aan...aan...";
D.q[7936] = "";
D.q[3222] = "Ben je bang klein varkentje? Wees niet bang... stop met zeuren en ik haal je hier vandaan. Ik geef je zelfs een nieuwe opgeslagen positie omdat jij blijkbaar die van jou bent vergeten. Even kijken wat er mogelijk is... Weebblyz Head? Nee, dat is niet interessant voor je... je kont is te zacht! De Odgean Stables? Nee, te beangstigend... Gorgor\'s Den? Nee, veel te gevaarlijk...\nAch, ik kies voor je en het wordt...... de Zaap van de Castle of Amakna! Je zou je je daar thuis moeten voelen!";
D.q[1042] = "*Jingle* *Gle,Jingle* *Jingle*-*Jinjingle*, *JinJingle*";
D.q[1356] = "*Schaar*\nHelaas heb je verloren.";
D.q[1115] = "*Die man geeft je een ijzige blik en zegt niets*";
D.q[1848] = "\"De Bow Meow ziet er uitgeput uit. Hij zit, kijkt rond en miauwt weer\"\nMiaaauww";
D.q[1355] = "*Papier*\nHelaas, je hebt verloren...";
D.q[7937] = "";
D.q[4804] = "Hallo, ik hoorde dat je het verraad van Trev Pelsantery onderzocht. Het is vanzelfsprekend dat hij schuldig is. Ik zal je zelfs belonen als je dat tegen de rechtbank vertelt.";
D.q[345] = "Hallo, ik heb een schriftrol op de zolder van mijn grootmoeder gevonden... Ik weet niet waar het voor dient, maar hij komt misschien iemand wel van pas die slimmer is dan ik. Ik ruil \'m voor 120 Moskito-wenkbrauwen, want die verzamel ik. Die zijn zo handig...";
D.q[1426] = "Hoi #1! Wil je me helpen voor vanavond?\nIk heb een dozijn Tofu benen nodig. Probeer een jager te vinden die je er wel een paar wilt verkopen!";
D.q[2920] = "Gegroet, ik zag je niet eens aankomen. Je prestaties worden beter, dat is geweldig.\nWat kan ik voor je doen?";
D.q[5285] = "Hallo, je komt op het juiste moment. Ik heb hier een brief waarin wordt gevraagd om jou naar Jerhyn te sturen als ik je zou zien. Je weet wat je moet doen.";
D.q[330] = "O, fantastisch! Hiermee krijg ik nooit meer een kouwe kont! Bedankt! Wat een fantastisch cadeau! Goed, je kunt nu op avontuur in dit gezellige gat.";
D.q[2294] = "\"De Veelvraat slaat \'t bier en de kroes in één keer achterover\" Boer... Hik!";
D.q[7938] = "";
D.q[245] = "Oké, je wil blijkbaar dood. Het is jouw keus, of je het nou accepteert of niet. Voordat ik je erdoor laat, moet je me laten zien wat je waard bent. Breng me een nagel van de Karne Ruiter. Die lucht verjaagt ieder monster en beschermt me. Als je de nagel van een van deze trotse krijgers kunt uitrukken, dan weet ik dat ik je erdoor mag laten.";
D.q[5635] = "*Denkend* Ik denk zo hard na dat mensen mijn gedachtes kunnen lezen.";
D.q[2297] = "*zingt in zichzelf*\nIk knip haar, harig haar, lang of kort, ik knip alles...";
D.q[1461] = "Hoe lang?\nDe datum van hechtenis staat op het opsluitingsbevel die je krijgt als je aankomt. Je wordt een uur gevangen gehouden, reken het zelf maar uit!";
D.q[7939] = "";
D.q[2296] = "*neuriet*\nWe vangen een moowolf en een vos, en doen ze in een doos...";
D.q[6621] = "";
D.q[6622] = "";
D.q[5024] = "";
D.q[7940] = "";
D.q[6623] = "";
D.q[4225] = "Hallo, mijn naam is Scroll Tom, als je een perkament nodig hebt, ben ik je man.\nIk kan je ook vele drankjes om karakteristieken en spreuken te vergeten, aanbieden.";
D.q[3554] = "Bedankt, vrouwtjes zullen blij zijn.";
D.q[329] = "Ik zie dat je echt koppig bent. Oh, en als... nee... maar tenslotte... Ik kan niet... Maar oké. Breng me iets waarmee ik me kan verdedigen tegen dat smerige wezen die rondspookt in deze rare vochtige grot en dan mag je het gat in. Dus ik heb nodig: de testikels van de Boowolf, sperma van de Champ Champ en een leren slip van Kapitein Chafer. Ik denk dat ik daarmee z\'n vurigheid wel kan beteugelen.";
D.q[1331] = "JIJ WEER? GA WEG! IK WIL JE NIET ZIEN!";
D.q[5031] = "";
D.q[4800] = "";
D.q[6624] = "";
D.q[1029] = "...\nJe bent sterk achteruit gegaan in mijn aanzien, #1. Er is nog maar een ding wat je kunt doen: Vertel zijn familie van zijn dood. \nKom terug als je klaar bent, maar neem de tijd...";
D.q[2802] = "...Ga weg..";
D.q[5496] = "Hallo, we hebben weinig tijd. Ga naar het noorden van Gisgoul en vind de grot die de demonen gebruiken voor het ritueel. Neem wat andere soldaten met je mee en stop het ritueel op welke manier ook. Als je klaar bent, breng de Demonische Dofus naar Jiva. De toekomst van onze wereld ligt in jouw handen.";
D.q[7941] = "";
D.q[5212] = "";
D.q[7350] = "";
D.q[669] = "Twee mogelijkheden:\n-zoek de Metarias in natuurlijke staat in de ingewanden van een monster.\n-ze fabriceren met een compressor die ik uitgevonden heb en daarbij krachtige potentiële elementen gebruiken. En met een weerstandssfeer die ik verkoop tegen een spotprijsje. Alle recepten staan in een boek, dat ik je kan leveren.";
D.q[910] = "100";
D.q[626] = "Hallo,\nDeze kleine tempel is echt geweldig. Ik denk dat ik hier even blijf voordat ik richting mijn volgende bestemming ga.";
D.q[6625] = "";
D.q[672] = "Een fragment van de sokkel van het meest magische wapen dat ik ken. Het stenen uiteinde is enkel geïmpregneerd met het magische extract van het wapen en kan dus bestudeerd worden zonder het materiaal zelf te beïnvloeden. Je bent glansrijk geslaagd voor de proef, hier heb je een magisch gereedschap waarmee je je magische creaties kunt maken. En nog een boekje, een soort geheugensteuntje voor alle uitvinders van magische wapens.";
D.q[7942] = "";
D.q[3006] = "Het kost 100 kamas.";
