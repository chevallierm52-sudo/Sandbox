D.q[2255] = "Oh! Dus JIJ bent de versterking? Oké, daar moeten we \'t dan maar mee doen... Dit is het verhaal: de Osamodas hebben ons Tofus geleend om de gaslekken op te sporen. Zij waarschuwen ons als het te gevaarlijk wordt, snap je? We noemen ze \'snuffelratten\".";
D.q[2298] = "Meow!";
D.q[7683] = "";
D.q[3132] = "Dat is dat! Nu weet je hoe je een Dragoturkey moet hypnotizeren. Alles wat je nog moet doen is mijn beroemde boek kopen over Dragoturkey fokken om meer over het onderwerp te lezen. Je bent een aardig persoon, maar nu ik me weer goed voel heb ik je niet meer nodig. Trouwens, mensen hebben mijn kennis nodig. Dus laat me met rust.";
D.q[2229] = "Oh, dank je schatje! Deze snack is absoluut niet goed voor de lijn, maar je krijgt er wel een hoop energie van!";
D.q[3913] = "Een knappe nobele ridder vinden is niet iets makkelijker. Ik zou niet in je schoenen willen staan... succes.";
D.q[8072] = "";
D.q[3565] = "Mai weten, mai bieden aan jouw hoofd!";
D.q[2092] = "Goed, dan zie ik je hier weer.";
D.q[1057] = "Ah mooi. Net nieuwe gebitten. Mak zal blij zijn.";
D.q[8059] = "";
D.q[7420] = "";
D.q[8060] = "";
D.q[1370] = "Oh, een verslag over de veranderingen in de regionale vulkanische activiteiten! Ik was het compleet vergeten. Ik heb botten gevonden van primaire diabolische dieren bij de mijnen, welke dateren vanaf de eerste Goddelijke Oorlog...";
D.q[1316] = "Oh, heeft Amayiro eindelijk iemand gestuurd om me te helpen? Bevrijd me snel en help me te ontsnappen!";
D.q[4318] = "Een vreemd uitziende Ecaflip? Heb ik niet gezien. Maar je kunt het aan de dames vragen, ik denk dat Ecaline pas nog problemen met een Ecaflip had.";
D.q[3123] = "Ik voel alsof... alle jonge avonturiers... als jij, hier komen... om mijn dofus te stelen... die al gestolen is... trouwens...\nIk mag je... Je geest schijnt... stabiel te zijn, je bent kalm als een bevroren Dragoturkey... Mooi... als een geplette Piwi... Gul... als een kapotgesneden Gobball... Ik wil je mijn... favoriete voorwerpen... toevertrouwen... maar je moet mijn grot verlaten... en naar het dorp gaan... voordat andere Koalaks terug komen....";
D.q[8073] = "";
D.q[3179] = "Voordat ik begin, verbied ik je al om me niet belachelijk te maken! Ik kan er ook niets aan doen dat mijn ouders mij een naam van een huisdier gegeven hebben! Toen ik klein was, speelde ik dagelijks met de Scarabladeren. Ik trok aan hun vleugels of stak hun voelsprieten in de fik. In mijn tijd wist je je met niets bijzonders al te vermaken... Mijn ouders vonden het verantwoord om mijn zo\'n voornaam te geven. En nu kent iedereen mij dus onder deze naam... Oké, laat maar. Zeg dan meteen dat mijn leven je niet interesseert! Dus \'t enige wat je wil, is deze grot betreden? Goed, geef me eerst maar de sleutel, want ik zou ook wel naar binnen willen, want dan word ik sterker!";
D.q[8061] = "";
D.q[6831] = "";
D.q[3112] = "Zingend:\nAls ik een hamer had,  zou ik met spijkers slaan,\nAls ik een schep had, zou ik aardappels planten,\nAls ik een schiller had, zou ik aardappels schiller,\nLalalala";
D.q[3476] = "Breekt botten, zaait hersens, pulkt ogen uit en doodt doodt doodt Bworks!";
D.q[6990] = "";
D.q[8074] = "";
D.q[4797] = "";
