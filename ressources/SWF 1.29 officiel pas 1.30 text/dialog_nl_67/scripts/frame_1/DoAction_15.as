D.q[1242] = "We verkopen alles, altijd aan iedereen. Neem de tijd die je nodig hebt.";
D.q[3996] = "Wat verwacht je van me? Een Wabbit te dienen? Ze zijn zwak, ze weten niet hoe ze wapens moeten gebruiken en ze spweken ewg vweemd!";
D.q[3867] = "Pnj(893) et Message(3865)";
