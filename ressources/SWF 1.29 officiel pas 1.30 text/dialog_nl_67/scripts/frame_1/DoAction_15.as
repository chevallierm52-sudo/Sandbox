D.q[6126] = "En wat over die zielen waar ik je voor gevraagd had?";
D.q[6147] = "En wat over die zielen waar ik je voor gevraagd had?";
D.q[6155] = "En wat over die zielen waar ik je voor gevraagd had?";
D.q[5553] = "Dus wat doe je hier!? Stop met kijken hoe het gras groeit en vind hier een oplossing voor!";
D.q[1479] = "Dus? Ga en haal een andere staf en vind een Bontarian die stinkt naar dood!";
D.q[6114] = "Je bent gemotiveerd, dat is zeker. Je bent trouw aan Bonta en je hebt dat bewezen door risico\'s te nemen voor je Orde. Ik ben trots je welkom te heten tot de rang van Legendarische Helden. De Toren van Gisgoul staat nog steeds ondanks de grote aanval, maar dat is een ander verhaal.";
D.q[4267] = "Dus jij denkt dat een Bontariaan zo even voor ons kan komen werken? Nou, de tijd is rijp.... Ik heb daar de laatste tijd veel aan gedacht. Maar goed, ik hoop voor je dat deze Xephires echt degene is die dit document getekend heeft. Anders zullen de mensen gaan praten.";
D.q[6186] = "Dus rat, ben je hier om je idool te zien?";
D.q[1199] = "Dus je wilt onder mijn begeleiding blijven bij de Orde van het Moedige Hart. Een wijze beslissing van je. Maar, om je inschrijving te bevestigen moet je naar de clerk van de orde gaan. Hij bevindt zich in de kroegen sinds zijn kat dood ging. Breng hem hier en we zullen je aanvraag voltooien.";
D.q[4159] = "Dus je wilt terug naar het eiland?";
D.q[3590] = "Een goeie boer, zeg je? Dat gaan we dan \'s zien. We hebben een grote bestelling tarwe. Er moeten de laatste tijd veel monden gevoed worden. Dat is goed voor m\'n handel, maar je moet wel mankracht hebben. Ga enkele ares tarwe maaien.";
D.q[2529] = "Is dit voor de bevrijding van de godin?";
D.q[3052] = "Zo, bajesklanten, komen we in opstand? Jullie hadden niet verwacht dat ik zo snel terug zou komen, hè? Ik heb maar één woord voor zo\'n gemene, lage en ronduit onsympathieke houding: Rahaayaa!";
D.q[2266] = "En, heb je een behoorlijke schaar op de kop getikt?";
D.q[4697] = "Dus, heb je iets verdachts gevonden?";
D.q[2392] = "Zo huurling, ben je op jacht naar buit en kamas? Dat komt goed uit! Lees de opsporingsberichten, die geven je informatie over individuen die opgespoord moeten worden.";
D.q[5043] = "Heb je de mijnen van Amakna bezocht?";
D.q[3831] = "Dus, klaar voor het avontuur van je leven?";
D.q[3843] = "Dus, klaar voor het avontuur van je leven?";
D.q[3837] = "Dus, klaar voor het avontuur van je leven?";
D.q[3836] = "Zo, ben je klaar voor het avontuur van je leven?";
D.q[3835] = "Dus, klaar voor het avontuur van je leven?";
D.q[3834] = "Dus, klaar voor het avontuur van je leven?";
D.q[3833] = "Zo, ben je klaar voor het avontuur van je leven?";
D.q[3842] = "Dus, klaar voor het avontuur van je leven?";
D.q[3841] = "Zo, ben je klaar voor het avontuur van je leven?";
D.q[3840] = "Dus, klaar voor het avontuur van je leven?";
D.q[3839] = "Dus, klaar voor het avontuur van je leven?";
D.q[4400] = "Dus, die perzik?";
D.q[5203] = "Dus dit is de beroemde Ronan. Ik had me een iets... grotere man voorgesteld. We klaren dit klusje wel even...                                                Ah, we moeten ook naar Raaga. Ik moet nieuwe technieken leren voor hersenspoeling.. Ik denk dat dat Goblin er een aantal heeft. Ik denk dat Raaga in de bibliotheek is.";
D.q[3962] = "Dus, deze Rasputin taart?";
D.q[2545] = "Dus, de wijze vertelde je over deze oude legende... en jij geloofde hem?! Zelfs onder de Lenalds zijn er maar weinig die hier in geloven... Maar wijze Lenald is absoluut overtuigd. Lang lang geleden, zoals het verhaal gaat, beschermden de Lenalds draken eieren... Het is zo lang geleden...";
D.q[2577] = "Mijn hoeden zijn prachtig, absoluut prachtig! Mijn Pandawa hoofdtooi is bijna helemaal nieuw! Kom dichterbij! Er is niet genoeg voor iedereen!";
D.q[3051] = "Zo, bajesklanten, komen we in opstand? Jullie hadden niet verwacht dat ik zo snel terug zou komen! Rahaayaa!";
D.q[6006] = "Dus, zoetwater zeeman, wat brengt je hier?";
D.q[2117] = "En, hoe zit dat met deze levering? Schiet \'t al een beetje op?";
D.q[2251] = "Dus je hebt alles? Heb je die vier poten van mijn arme Veelvraat meegenomen en de twee citroenen?";
D.q[3255] = "Dus je wilt al weer terug?";
D.q[1201] = "Dus jij wenst verder te gaan onder mijn visie binnen de Orde van de Heilige Geest. Een slimme keuze waar je geen spijt van zult krijgen. Maar als je je lidmaatschap wilt verkrijgen, moet je de clerk van de orde vinden. Omdat haar broers ruzie hebben gaat ze van kroeg naar kroeg om ze te vinden. Breng haar terug en we kunnen je verzoek bevestigen.";
D.q[2116] = "Dus jij denkt dat je me nu kunt raken? Kom op dan, SLA DAN!";
D.q[4155] = "Dus? Heb je mijn lieve wabbit gevonden? Hoe gaat het met hem?";
D.q[4328] = "Dus? Heb je een manier gevonden om het bericht door te geven?";
D.q[3512] = "En?";
D.q[3972] = "Waaaat? Wabbit vermoord? Nee begraven, begraven, geen lol voor grote Bwork als ik.";
D.q[4185] = "Dus? Hebben die Piraten moeten stof happen?";
D.q[2129] = "Dus jij denkt dat de Beerman bijna geen krachten meer heeft?";
D.q[3864] = "Dus je komt hier om te kijken of alles goed gaat in het Kasteel... Komt goed, ik bewaak de troon!";
D.q[4866] = "Waaat? Wat is dat? Denk je dat ik dat ga drinken alleen maar omdat een vreemde mij dat heeft gevraagd?";
D.q[3089] = "Ik heb dat niet nodig om mijn Koning een plezier te doen. Mijn aanwezigheid alleen al is genoeg om hem in verrukking te brengen. Vind maar eens iemand anders die niet mijn katachtig charisma heeft.";
D.q[3386] = "Goeie gevechten, echt wel! Ik kan niet anders zeggen. Veel succes.";
D.q[2606] = "Heel goed, kom maar terug als je iets gevonden hebt... Vaarwel dus eigenlijk!";
D.q[2666] = "Onschuldigen zijn in gevaar op het kerkhof. Ik, Nergal, dienaar van de god Iop, van de weduwe en de wees, ik smeek je om één teleportatie-rune om daar zo snel mogelijk naar toe te gaan!";
D.q[5852] = "Een paar vissers zijn geslagen door krabben, welke normaal erg rustige beesten zijn. Het moeten die informers zijn behalve als een van de Koning\'s koks is aangevallen in de keuken.";
D.q[327] = "Van degenen die gaan, zullen enkele nooit meer terugkomen. En zelfs degenen die terugkomen, komen er niet meer overheen. En als jullie allemaal terugkomen, kom ik er niet overheen.";
D.q[4116] = "Welk geslacht heeft degene die niet je broer of je zus is, maar wel een kind van je ouders?";
D.q[5742] = "Wat doe je hier? Moet jij niet het Standbeeld beschermen voordat de Bontarianen aankomen?";
D.q[2894] = "Wat doe je hier? Neem de sleutel en ren weg.";
D.q[6206] = "Lemand genaamd X? Hmm, ja, misschien weet ik daar iets over, maar ik praat normaal niet over klanten. Ze weten dat ze hier in volle discretie kunnen komen.";
D.q[3746] = "Een paar wijze oogsters verkopen niet alles wat ze verzamelen. Ze houden wat totdat ze een tweede beroep kunnen leren en een paar Kamas kunnen besparen tijdens het proces.";
D.q[5235] = "Nog iets anders voor je diensten?";
D.q[3105] = "Ik mis alleen mijn geliefde. Een zacht spinnend huisdier zou wel helpen. Ik wil een witte MiauwMiauw, net zo wit als ik.";
D.q[3515] = "Er mist iets. Het is een beetje subtiel, maar volgens mij is het nodig, ja van levensbelang in feite!";
D.q[3673] = "Snel zul je tegen duivelse hordes van de slechte Rushu vechten. Hij mag de 13e god niet worden, als hij dat wel word, zal het einde van de wereld er snel zijn.";
D.q[300] = "Soms...";
D.q[2115] = "Sorry, maar ik heb geen tijd om met je te praten. Ik moet een heleboel wezens om zeep helpen... Wil je zien hoe?";
D.q[2080] = "Sorry, maar ik ben een zeer druk bezette Cra. Ik heb geen tijd om kennis met je te maken.";
D.q[6313] = "Sorry maatje, maar ik ben daar nog niet goed genoeg voor. *hik* Neem een kijken in Eltneg Bos. Daar zit vast een trool die je kan helpen.";
D.q[2821] = "Sorry, ik kan het zware spul niet verkopen aan een toerist zoals jij.";
D.q[3463] = "Ik heb dit recept nodig om mijn bierbrouwerij op te zetten. Zoek meer in de diepte.";
D.q[756] = "Weet je die gevangene nog die je afgeleverd hebt?\nHij is terug op zijn voeten en wil skeletten verslaan met jou!";
D.q[1626] = "Het spijt me, maar ik praat niet met vreemden...";
D.q[1874] = "Helaas, maar ik heb geen tijd om met je te kletsen. Mijn vader rekent erop dat ik voor de kudde Veelvraten zorg. Hij zegt dat dat een belangrijk deel is van mijn training. Ik moet nu gaan, ik hoor dat er eentje loeit...";
D.q[301] = "Sorry, maar mijn taak is om te voorkomen dat jonge dwazen zoals jij in een oogwenk verscheurd worden. Kom maar terug als je geoefend hebt. Neem je voorwerpen maar weer mee.";
