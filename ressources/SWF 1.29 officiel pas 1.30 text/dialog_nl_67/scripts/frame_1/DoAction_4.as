D.q[550] = "Hallo geachte gast! Welkom op het hemelse Moon eiland. Het agentschap heeft mij gestuurd om u te verwelkomen en u de verschillende activiteiten te laten zien die we hier aanbieden.";
D.q[4621] = "Gefeliciteerd met je overwinning op de Brakmarianen. Wanneer ik denk aan al de moeite die het heeft gekost om de Hoorn in handen te krijgen...Het heeft ons geleerd niet teveel geloof te hechten aan geruchten en legendes. Als het soms troost bied, je kan jezelf geruststellen met het feit dat dankzij de kracht in deze Hoorn, er minder jonge rekruten zijn die aardappelschil dienst hebben. Je hebt Bonta briljant gediend en je trouw is me meer waard dan een of ander magisch object.";
D.q[3616] = "Jij vindt Pinkgob.";
D.q[6508] = "ahahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!\nIk lach omdat je net 1000 kama hebt verloren.\nHahahhahaaahahaaahaha\nHARHARHAHARHARHAAHA!";
D.q[6509] = "ahahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!\nDe oude eigenaar van de Verbrande Kat Herberg had vroeger een speelkamer, en ondanks wat hij beweerd, is het nog steeds in gebruik.\nHahahhahaaahahaaahaha\nHARHARHAHARHARHAAHA!";
D.q[6255] = "Kapitein Starky is de baas van de Bontariaanse cavalerie. Hij is een heethoofd die ons meerdere malen gigantisch heeft aangevallen. Hij zou een uitmuntende Brakmariaanse soldaat zijn, als hij niet aan de kant van die sukkels was gaan staan. Ik denk dat ik hem een plaats aanbied in de militie als Bonta totaal verslagen is.";
D.q[1648] = "Hallo! Dit is de Trool Token Inwissel Kraam. Ik kan je waardevolle Trool tokens inwisselen voor verschillende dingen.";
D.q[4676] = "De Brakmarianen dienen de demonen. Gezegend is Jiva door ons te beschermen. Ervaring heeft me geleerd dat je moet oppassen voor die demonen, ze veranderen alles wat ze aanraken. Helaas zal moed en slimheid ze niet verslaan, dus moet ik de magische krachten van onze legers vergroten en ze meer spreuken geven. Aangezien ik zo gul ben, heb ik besloten dit idee met jou te delen zodat jij ook voordeel kunt hebben van het succes van deze missie.";
D.q[1657] = "Het prisma is een beetje stuk en het is nog steeds niet gerepareerd.";
D.q[1251] = "Brakmariaanse mantels? Elke kleermaker weet hoe je die moet maken. 1 Donkere verf, 1 Zwart Gobbly Wol, 1 Chafer Bot... En het is klaar!";
D.q[5609] = "";
D.q[573] = "Recentelijk, vloog een gids van je reisbureau over het strand, Hahaha! Een piraten leerling loopt rond in het zuiden van het eiland. Ik denk dat hij een manier zoekt om weg te gaan... Hahaha!";
D.q[1653] = "De bewoners van dit dorpje zijn erg handig, maar toch hebben ze het niet voor elkaar gekregen om hun dorpje onneembaar te maken. * Poetst haar kristallen bal* Brakmar\'s troepen besturen het dorpje op dit moment, maar misschien niet voor lang...";
D.q[3719] = "Ahh, dank je, dank je...de nymphettes zullen dankbaar zijn.";
D.q[6701] = "";
D.q[6385] = "Ew is een plek op het lichaam van Eltuwt waaw hij niet bij kan. Nee, niet daaw, ik heb het ovew zijn wug. Zijn awmen zijn te kowten zijn schild te gwoot om ewbij te komen en te kwabben, en telekinese wewkt niet. Ik weet niet wat je wilt van Eltuwt, maaw nu je dit weet ben je in het voowdeel.";
D.q[569] = "Hahaha! Dus jij bent een andere toerist voor het leven van dat nieuwe reisagentschap ohoh. Maar, om je bezig te houden, het eiland heeft enkele... speciale attracties... Hahaha! Waarom vraag je het de gids niet die zo\'n explosieve aankomst op het strand maakte, haha! Maar goed, je zult moeten betalen als je de diepten van dit eiland wilt bezoeken. Ohohoh!";
