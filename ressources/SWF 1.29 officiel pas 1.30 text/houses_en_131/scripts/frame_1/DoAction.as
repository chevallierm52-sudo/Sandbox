H.h[226] = {n:"Big Bontarian House",d:"This three-floored house is perfect for your organizing parties with your friends. But don\'t forget to warn your neighbours."};
H.h[227] = {n:"Tiny Bontarian House",d:"This charming one-room house is very cosy."};
H.h[228] = {n:"Big Bontarian House",d:"This three-floored house is perfect for your organizing parties with your friends. But don\'t forget to warn your neighbours."};
H.h[229] = {n:"Little Bontarian House",d:"This little Bontarian style house has a second floor which you can access through nice wooden stairs."};
