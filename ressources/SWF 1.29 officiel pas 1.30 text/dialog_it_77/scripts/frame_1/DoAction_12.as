D.q[644] = "Bisogna ammettere che il mondo di Dofus è un po\' speciale. \nVi accadono fatti strani e da un po\' di tempo creature malsane hanno invaso pianure, campi e montagne. Per ora soltanto i villaggi restano al sicuro dal male. \nPiù ti allontanerai dai villaggi, più rischierai di imbatterti in grossi pericoli... ma questo è il prezzo per la gloria. \n\nAd Amakna, tutta l\'economia è gestita da guerrieri e artigiani, e i primi hanno spesso bisogno dei secondi.  \nComportandoti male rischi di essere considerato come un ladrurbo (ali di demone) ed essere cacciato dai giustizieri (ali d\'angelo). Fai quindi la scelta giusta, o potresti finire in prigione!";
D.q[4938] = "";
D.q[1921] = "In questo momento ho bisogno di manodopera: ho sempre più apprendisti e le mie riserve di ingredienti si esauriscono. Ho ancora qualche materia prima grazie ai moltissimi Minatori e Taglialegna che mi aiutano, ma sono a corto di materie rare. Puoi procurarmene? Ti pagherò.";
D.q[3773] = "Se vuoi, puoi ricominciare ad allenarti.\nLo spaventapasseri si rigenera senza sosta grazie ai venti di Incarnam.";
D.q[2133] = "Se mi porti 5 lane di pappaton di ogni colore, farò un piccolo mantello apposta per te!";
D.q[2659] = "Effettivamente ho un favore da chiederti, mi piacerebbe che andassi al tempio Xelor, per consegnare questa lettera ad Amin e avvertirlo dei pericoli verso i quali ci stiamo dirigendo ineluttabilmente... nel mio piccolo, io continuo a cercare un modo per evitare l\'inevitabile...\n\nSe farai questa consegna per me, aggiungerò qualche minuto prezioso alla tua speranza di vita...";
D.q[3685] = "Nel tuo libro delle missioni, scrivi l\'obiettivo. Siccome la calamita è puntata su Arietta Fiala, la bussola ti indicherà la direzione giusta.";
D.q[2018] = "Ah eccoti! Hai portato tutto? Fantastico, l\'ora della rivincita è giunta! Bene, adesso assemblo tutto questo... *guarda il pezzo di legno, sembra incuriosita, poi continua a costruire l\'oggetto*...";
D.q[2286] = "Devi sapere una cosa però: se per sbaglio dovessi urtarne una, potrebbe arrabbiarsi... Oh, per carità, niente di grave, forse avrebbe solo voglia di saziarsi delle tue viscere! O può darsi che ti sbriciolerebbe le ossa... chissà... Allora direi che ti conviene ascoltarmi...";
D.q[4923] = "";
D.q[4326] = "";
D.q[248] = "Ma cosa ne puoi sapere te dell\'arte della frusta? Torna quando avrai la coda biforcuta e le corna!";
D.q[3299] = "Se non sai dov\'è la biblioteca, non esitare a chiedere indicazioni.";
D.q[2323] = "I nostri amici Ocra, hanno idee strane talvolta. Pensa che approfittano di un \"Agentis Infectofus\" contenuto nelle zampe di Arakne. Ci fanno delle frecce avvelenate! Strano... ma rende... e anche parecchio... Se vuoi farti un po\' di soldi, portami 20 zampe di Arakne. Qualcosa mi dice che devo buttare i miei panini... *sospiro*";
D.q[1610] = "Il nostro popolo si fa spazio poco a poco in questo Mondo. Da poco, la Dea ci ha svelato l\'arte ultima e sublime dei Sàcridi. Noi condividiamo tale sapere solo con i Sàcridi degni di conoscere queste tecniche di combattimento.";
D.q[6703] = "Il Captain Starky ti aspetta all\'interno.";
D.q[3306] = "Se non sai dov\'è la biblioteca, non esitare a chiedere indicazioni.";
D.q[5924] = "";
D.q[4633] = "Se vogliamo far parlare Garutar dobbiamo saperne di più su di lei. Ti incarico di questa missione non per la tua competenza,ma perchè i miei altri servi sono già in missione. Questa volta avrai interesse a compiere la missione perchè difficilmente tollero i ripetuti fallimenti. No,l\'incompetenza degli altri miliziani non è una scusa! Comincia a chiedere ad uno specialista di animali, per esempio quel fifone di Oshimo, che si occupa del Cianil.";
D.q[5912] = "";
D.q[3799] = "Ti ho concesso la vittoria perché abbiamo bisogno di valorosi guerrieri come te per distruggere i malefici disegni del demone Rushu.";
D.q[418] = "Alcuni guerrieri originari di Amakna hanno scelto di unirsi ai potenti ranghi di Bonta o Brakmar.\nPer diffondere la loro ideologia, arrivano addirittura ad attaccare gli abitanti della regione di Amakna, per incitarli ad unirsi ai ranghi. Fino a quando resterai in terra neutra la guarnigione di Amakna accorrerà in tuo soccorso, ma uscire da questa zona sarà a tuo rischio e pericolo.";
D.q[2276] = "Io e te ci siamo già incontrati da qualche parte, no? Lasciami riflettere... forse eravamo a caccia di Porkass verso le pianure di Cania? O durante la campagna dell\'isola di Moon!? Arrh, ti ricordi quelle maledette tartarughe!?";
D.q[2777] = "Se passi il test e ottieni abbastanza informazioni da Wally, vai subito a parlare con Lansoft, il guardiano della foresta maledetta. Digli che ci conosci e ti lascerà entrare. Ah, un ultimo consiglio: se conosci altri avventurieri, fatti accompagnare nella foresta... così un giorno ti rivedrò.";
D.q[3322] = "La montagna dei Koalaks non è stata ben cartografata. Mi piacerebbe che dei giovani avventurieri curiosi e temerari mi portino una descrizione di questa lontana regione...";
D.q[1892] = "Ho sempre sognato di avere un apprendista come te, sei di quelli che si possono mandare dall\'altra parte del mondo e che tornano sempre con il sorriso... Bé, adesso se vuoi essere un po\' operativo, vorrei che tu setacciassi i dintorni e che trovassi tre zone nei campi dove i fiori crescono più spesso. Vorrei fare una classificazione topografica delle specie più diffuse.";
D.q[581] = "Ma ne manca un pezzo *hic* senza non posso niente fare *hic* sarei come un Pappatutto *hic* senza corna e che non sa fiutare *hic*";
D.q[3175] = "Ma... mi sembra di conoscerti...\nSei te che di solito ti occupi di pulire il Tofullaio dagli escrementi!\nCapiti a proposito, c\'è molto lavoro per te in questo momento! Haha!";
D.q[3629] = "E così gira voce che tu sappia maneggiare un\'arma. Uno spadaccino può guadagnare onestamente da queste parti.";
D.q[4612] = "Che notizie ci sono?";
D.q[2351] = "Bene, conosci la storia, i Dofus, tutto... Io dico solo una cosa, per me le uova di Drago che danno poteri non si trovano così, in mezzo alla strada... E poi tutti questi avventurieri... è la corsa all\'uovo! Bé, non mi sembra un granché... ma ti auguro buon viaggio! E che le pietre siano morbide sotto i tuoi piedi!";
D.q[3606] = "Allora, hai portato qualche materiale? Vediamo cosa possiamo ricavarne. Sì, bene, bene. Benissimo, usa gli attrezzi per lavorare tutto questo.";
D.q[2101] = "Vai pure, parti! Non ci metterò molto a trovare altri giovani, anche più svegli di te!";
D.q[4673] = "Ma!? Chi sei? Perché stai frugando qui?";
D.q[5719] = "Ho parlato un po\' di te ai diversi maestri d\'Ordine e sono pronti a testare il tuo valore. Per convincerli devi recarti alla Torre degli Ordini di Brakmar e parlare con loro per scegliere la tua strada.\nEvita di affrettarti, passa prima alla taverna per bere qualcosa, detesto i miliziani troppo zelanti, soprattutto visto che non sei obbligato a scegliere subito una specialità.";
D.q[108] = "Che luogo stai cercando?";
D.q[5373] = "Non sono tranquillo sapendo che Tolevaj è ancora vivo e combatte per Bonta. Ho il sospetto che sia stato liberato per una ragione ben precisa. \nVai a vedere cosa combina Finch Aticus. È da un po\' che non ho più sue notizie: spero che non si sia fatto scoprire, non adesso.";
D.q[4403] = "Scherzo. Dimmi un po\', non sei ingrassato dall\'ultima volta che ci siamo visti?";
D.q[5925] = "";
D.q[5926] = "";
D.q[2912] = "A cosa devo la tua visita fedele Scudiero?\nNon dovresti allenarti con la milizia a quest\'ora?";
D.q[2075] = "Lo sapevo... non ti basta vero? Va bene, allora farò uno sforzo per ringraziarti. Ti insegnerò l\'arte degli Ocra! eh? Come? Non sembro un guerriero? Ma non è neanche di moda. Oggi chi ha stile porta la panoplia del Pappatutto, un vero acchiappafemmine... eheh... scusami, non c\'entra niente...";
D.q[6066] = "";
D.q[1974] = "Zì Zì tutto bene! Insomma, zento come un zegno di pala zulla faccia, ma non è quezto il problema! Ho delle informazioni zuper importanti, ma l\'Anutrof che mi ha attaccato mi ha prezo il rapporto, e ze lo uza, per me è la fine! Capizci?!";
D.q[127] = "Di solito la corda degli Archi è fatta di Filo di Lino intrecciato. Io passo molto tempo a fabbricare corde per i miei Archi, e le faccio robuste e morbide al tempo stesso.\nSe stai cercando del Filo di Lino intrecciato per la corda dei tuoi Archi, sono disposto a dartelo io in cambio di un\'unità di Lino.";
D.q[6210] = "Se fossi in te, ci penserei due volte. Numerosi miliziani pattugliano da queste parti e mi basta gridare per farli intervenire subito.\nSe hai voglia di sensazioni forti, perché non lavorare qui? Alcuni volponi apprezzano le donne con una forte personalità come te.";
D.q[6111] = "";
D.q[3670] = "Holàlà! Ma sei troppo forte per lavorare ad Incarnam, devi scendere ad Amakna.";
D.q[1886] = "Oh, faresti questo per me? Allora, ti spiego: questa sera avevo un appuntamento galante con donna Seria - era fissato da un mese. Ma la signorina Fita è tornata dal suo viaggio oggi stesso, e mi ha invitato da lei stasera! Lascerò donna Seria proprio all\'ora in cui dovrei essere dalla signorina Fita, ma i due luoghi sono troppo lontani...";
D.q[205] = "I Dabol sono esseri che per sopravvivere copiano le azioni degli altri. Non si sa da dove vengano. Un giorno sono arrivati in massa e hanno tentato di invadere la contrada. Da quando abbiamo vinto la guerra se ne vedono pochissimi.";
D.q[2063] = "Ciao! Ho mandato mia figlia a cercarti. Sai, è così vivace, così piena di energie... Come suo padre d\'altronde! Ahaha! Devo rappresentare gli Ocra al consiglio di Astrub, e ho bisogno di te.";
D.q[4960] = "Ti consiglio di parlarmi con più rispetto. Non sono certo due piccole manette che possono impedirmi di fulminarti vivo.";
D.q[1968] = "Bravo, anche se il combattimento era abbastanza noioso, sono io il capo, tu cosa vuoi?";
D.q[6120] = "";
D.q[4977] = "Se incroci Domen, digli che riuscirò a trovare il modo di ucciderlo una volta per tutte.";
D.q[5459] = "Quale rango vorresti avere nella Milizia ?";
D.q[2381] = "Hola! Non si diventa Forgiatori come me in un attimo. Devi scegliere quale arma vuoi forgiare, puoi forgiarne anche più di una, ma dovrai dedicarci per forza più tempo.";
D.q[2864] = "Ciao #1, la tua aura malefica diventa sempre più grande, sono fiero di te!\nCosa posso fare per te ?";
D.q[2982] = "Bene! Senza vantarmi troppo posso dire che sono un aruspice parecchio dotato! Leggerò il tuo futuro nelle viscere di un Pappatutto? O in quelle di un Bwak? Mmh, no, forse nel tuo caso sarebbe meglio la schiuma della birra. Chiedine una a Tek Abir, e mettila sul tuo conto, uhuhuh!";
D.q[701] = "Prima di uscire da questo tempio, vai da mio fratello Tarazed, ti insegnerà come guarire con la meditazione.\nSe non hai abbastanza pazienza, puoi sempre curarti con il pane venduto dai Panettieri, o con le pozioni fabbricate dagli Alchimisti.\nNon dimenticare, però, di conservare un po\' di kama per i tuoi acquisti.";
D.q[3642] = "Perfetto, fai il giro della città e chiedi agli abitanti se è tutto apposto. Aspetto il tuo rapporto!";
D.q[6578] = "Un attimo, sto pensando.";
D.q[2874] = "...";
D.q[5590] = "Bene, aspetteremo che si reincarni, poi potrai interrogarla. Ora vai a raggiungere i ranghi dei miei Apprendisti Oscuri.";
D.q[2362] = "Va bene, se ci tieni tanto... Devi sbrigarti ad uccidere un Pappatutto: ti do solo due minuti.\nDimostrami che ne sei capace e ti nominerò Cacciatore.";
D.q[457] = "Ciao, sono diverse settimane che cerco di ammansire questi dragacchini per poterli cavalcare. \nAvrei tanto voluto commerciarli...";
D.q[1930] = "Benvenuto #1! Haha! Come faccio a conoscere il tuo nome ? Facile, questo è il miglior ufficio informazioni della città, puoi imparare un sacco di cose sorseggiando una birra.";
D.q[2441] = "Il Macellaio prepara la carne che il Cacciatore gli porta. La prepara affinché si possa mangiare, e ogni tanto la cucina. È la gioia dei carnivori, e si dice che mangiare carne renda più forti, allora perché privarsene?";
D.q[2660] = "Mi dispiace, non ho tempo per te: l\'Orologio Divino è sfasato... sembra impossibile, ma uno spostamento della trama temporale può sopraggiungere in qualsiasi momento...! In quanto guardiano del tempo non posso distogliere lo sguardo dai questi orologi!\n\nNei 5 minuti che precedono ogni ora posso, in via del tutto eccezionale,  abbassare un po\' la vigilanza, torna da me in quel momento...";
D.q[4422] = "Allora?";
D.q[3426] = "Ho molto lavoro, è mia moglie che si occupa dei bambini.";
D.q[251] = "Permette di forgiare martelli di qualità a condizione di esercitare il mestiere corrispondente. Io ne vendo, ma se non hai i soldi possiamo aggiustarci lo stesso. Ho bisogno di Corni di Pappatutto, la loro forma e la loro grana sono perfette per... insomma, questo non ti riguarda.";
D.q[1893] = "Grazie mille, questo mi toglie una spina di rosa dal piede! Haha!";
D.q[2269] = "Grazie mille! Tieni, prendi queste forbici consumate, forse ne avrai bisogno!\n\nDurante la tua assenza, ho cercato di vendere una parrucca da Sadidina ad uno Yop, ma non sono riuscito a convincerlo! Saresti veramente gentile se tu mi aiutassi a catalogare tutti i tipi di capelli...";
D.q[6780] = "Se facessi scomparire l\'aria che respiri, ti sentiresti un pesce fuor d\'acqua. Apriresti la bocca così, gob gob, e non succederebbe niente, soffocheresti.";
D.q[4966] = "Uk\'Not\'Allag, gwande mastwo venewato. Ubbidiwe a Uk\'Not\'Allag. Costwuiwe tempio Uk\'Not\'Allag.";
D.q[1907] = "Grazie mille, potresti rendermi ancora un piccolo servigio già che ci sei? Ho saputo che il mio fattorino non è per niente malato... a quanto pare preferisce andare dietro alle donne piuttosto che lavorare. Vorrei che tu lo sorvegliassi per darmene conferma...";
D.q[7590] = "Buongiorno, credo che tu voglia entrare in questa magnifica casa, non è così?";
D.q[6555] = "Buongiorno, nobile soldato. Posso aiutarti?";
D.q[5938] = "";
D.q[7591] = "Il tuo nome figura sulla lista degli invitati, puoi entrare.";
D.q[2219] = "Oh, una Calanthe Triplicata Imbronciata, hmm, non avevo più visto un esemplare di questa pianta dopo il mio soggiorno sull\'isola di Moon... Questo giardino pubblico è proprio ricco di sorprese!";
D.q[1811] = "Se vuoi affrontare un Dabol, devi donare un po\' di Fiori di Lino al tempio...";
D.q[5477] = "Quale rango vorresti avere nella Milizia ?";
D.q[5939] = "";
D.q[7592] = "Vediamo, com\'è il tuo nome? Ah si, mi spiace ma non risulti sull\'elenco degli invitati. In altre parole, non posso farti entrare.\n(l\'accesso a questo luogo è strettamente riservato ai membri Premium)";
D.q[5945] = "";
D.q[5861] = "";
D.q[1812] = "Se vuoi affrontare un Dabol, devi donare un po\' di Orchidee Freyesche al tempio...";
D.q[5479] = "Quale rango vorresti avere nella Milizia ?";
D.q[1125] = "Ti avverto: sfiorami e incontrerai i tuoi antenati!";
D.q[7037] = "Possiedo delle pergamene per tutte le caratteristiche e di tutte le potenze. Di che potenza desideri che sia questa pergamena?";
D.q[1813] = "Se vuoi affrontare un Dabol, devi donare un po\' di Edelweiss al tempio...";
D.q[2136] = "Ancora te? Vai dagli Aniripsa ad avvertire Mon\'Hawt\'Wit\' prima che Joe perda la pazienza! Il tempo è denaro, e quanto piace il denaro a Joe! Allora, corri!";
D.q[6000] = "";
D.q[5989] = "";
D.q[7553] = "Buongiorno, sono lieta di vederti.\nHo bisogno di donne sveglie come te per aiutarmi nei miei affari. Posso proporti un lavoro facile e ben pagato, ma dovrai essere discreta e non fare domande.\nChe ne dici?";
D.q[3830] = "Te la sei cavata bene. Bravo, complimenti. Hai ben meritato la ricompensa che do a coloro che riescono.";
D.q[1656] = "I brigandini sono bravi nelle riparazioni, il loro nuovo prisma è già attivo, ma non lo sarà in eterno...";
D.q[2369] = "Benvenuto nella città di Astrub, nobile avventuriero.\nSe hai delle domande sulla città o sui dintorni, i mercenari faranno del loro meglio per risponderti con precisione.";
D.q[3801] = "Evidentemente siamo nel luogo più ventoso del pianeta. Sei stato fortunato ad esser così debole, se tu fossi stato più forte, ti avrei spedito dritto nel fosso delle anime per avermi fatto perdere tutto questo tempo.\nIo sfido solo coloro che hanno già portato a termine molte missioni. Fai il giro di Incarnam, dopo forse sarai degno di sfidarmi.";
D.q[1699] = "Oh, ma hai una fortuna incredibile tu! Hai appena pescato il vero e unico giocattolo Quaquà! Ti seguirà ovunque, se lo vuoi, ovviamente...";
D.q[5952] = "";
D.q[1789] = "Se vuoi affrontare un Dabol, devi donare un po\' di Pietre di Croccaroc al tempio...";
D.q[3333] = "Adoro fare affari con te. Torna quando vuoi!";
D.q[2964] = "In verità ti dico, la dea Pandawa mi ha parlato questa notte! Mi ha detto che un diluvio stava per abbattersi sul Mondo! Non un diluvio di birra, ma un diluvio d\'acqua... non sarà una cosa carina. E così, la dea mi ha chiesto di salvare due esemplari di ogni creatura di questo Mondo! Sono già riuscito a riunirne una buona parte, ma mi mancano le uova di Tofu... saresti molto gentile se me ne portassi un paio! Mi sembri un po\' stordito tu, no? Scrivitelo sul libro e non dimenticare di consultarlo per rivedere le missioni che devi portare a termine...";
D.q[5955] = "";
D.q[5994] = "";
D.q[5956] = "";
D.q[7556] = "Non mi piace molto parlare in pubblico.";
D.q[3927] = "Cose strane al castello? No, a parte la visita di Allisteria. Di solito, non lascia mai i suoi Pappatutto.\nAh sì, in più l\'intendente San Lavals ha strettamente vietato di cucinare wabbit al castello.";
D.q[4329] = "Perfetto. L\'ultima parte del piano può cominciare.";
D.q[2924] = "Ciao. La tua saggezza rende onore alla nostra dea Jiva.\nCome posso esserti d\'aiuto?";
D.q[456] = "I Taglialegna sono i principali appassionati di asce, perché hanno sempre bisogno di un attrezzo che possa servirgli anche da arma ogni volta che sono attaccati.\nPer forgiare un\'ascia bisogna trovare legno di qualità per fare un manico resistente, e metalli adatti per la lama.\nPosso insegnarti questo mestiere se vuoi.";
D.q[5097] = "";
D.q[385] = "Offro una Grande Pergamena di Forza a colui che mi porterà 70 Aculei di Prespic, 75 Chele di Granchio e 40 Costine di Rib. Con tutti questi trofei, potrei benissimo far credere a Penelope - la donna che amo - che ho vissuto un sacco di avventure, con la speranza di sedurla più facilmente.";
D.q[3003] = "Hai parlato con Magister? E ti ha detto che ho scritto un libro che ti interessa? Come? \"La scelta degli Dei\"? Sì, l\'ho scritto proprio io! Siccome vieni da parte di Magister, ti farò un bello sconto: te lo vendo meno caro che in biblioteca... 40 kama ed è tuo!";
D.q[2074] = "Come! Niente di meno che del Legno di Arash!? Sai almeno dove cresce? Be, neanch\'io. Sono i mercanti che passano ogni tanto di qua che ce lo portano. Da quello che raccontano è molto raro, te lo immagini eh? Che storia incredibile!";
D.q[1801] = "Se vuoi affrontare un Dabol, devi donare un po\' di Veleni Sferzanti al tempio...";
D.q[2027] = "Haha... Sei patetico... Non si può proprio cavare niente da te. Torna quando sarai degno di essere quello che sei...";
D.q[3356] = "Sei giovane e vigoroso, non ti prenderà molto tempo.";
D.q[5961] = "";
D.q[2408] = "Ah, ho capito, le esche di Kana Dapesc. Prendi e sbrigati, non ha molta pazienza.";
D.q[2822] = "Mi spiace, ma non ti posso vendere alcool, non sopravviveresti!";
D.q[1971] = "Non ho il tempo di trovare qualcuno che abbia esperienza, ci vai te in questi sotterranei! Prendi questa daga, potrebbe servirti in caso di colpi duri. A meno che non ti basti la tua leggendaria agilità! eheheh!\n*Crac*\nAhi, la mia lombaggine!";
D.q[491] = "Per ora non ho nessuna missione da affidarti. Vai altrove!";
D.q[3675] = "Al di là di questo ponte, c\'è la mongolfiera per Astrub o Pandala. Grandi avventure attendono colui che avrà il coraggio di andarci, da solo o in gruppo!";
D.q[2364] = "Sì, niente male... molto bene, e siccome lo desideri tanto ti nominerò Cacciatore. Dovrai comprarti un attrezzo da Cacciatore per strappare i pezzi delle tue prede.";
D.q[5875] = "";
D.q[5480] = "Quale rango vorresti avere nella Milizia ?";
D.q[2346] = "Forza, sparisci adesso!";
D.q[5057] = "Idioti di Wabbit. Ancora più idioti di te.";
D.q[5877] = "";
D.q[3847] = "Il nostro accordo è semplice: uccidi il milimilupo e ti darò la tua ricompensa. Ti aspetto all\'uscita.";
D.q[5878] = "";
D.q[2302] = "Oh ecco la mia pizzaya vegetariana! Ho dimenticato di nuovo la mia pergamena a punti, non riuscirò mai a prendere la pizzaya omaggio!\nSpero che la Lactuta Sativa sia più fresca questa volta...";
D.q[7572] = "Di quale tempio di classe ti servono le coordinate?";
D.q[7560] = "Vattene o mi scopriranno.";
D.q[1861] = "Un paraorecchie, ecco cosa ci vuole per te! No, le tue orecchie sono molto carine. Ma devi proteggerle dal freddo dell\'inverno! Nessuno ci dice che non tornerà l\'inverno del 22! Ti farò una creazione unica! Ma per questo, ho bisogno delle materie prime più rare...";
D.q[5490] = "Quale rango vorresti avere nella Milizia ?";
D.q[3984] = "Che magnifica contwada, sembwa dipinta dagli awtisti più bwillanti e più gwandi di tutti i tempi!";
D.q[5879] = "";
D.q[2012] = "Aarrgh! Che nervoso! Quei maledetti Ecaflip hanno ancora vinto la scommessa! Ma non mi lascerò fregare ancora una volta dalla loro fortuna nel gioco. E tu mi aiuterai, in cambio ti insegnerò potenti sortilegi!";
D.q[2911] = "Combattendo slealmente hai disonorato la tua città. Il tuo conto in banca sarà bloccato fin quando non riscatterai le tue cattive azioni.";
D.q[6533] = "Maledetti briganti! Ancora un carico saccheggiato! Dì ad Amayiro di fare il suo dovere e di proteggere gli onesti mercanti come me. Sono pronto a pagare per la mia protezione, se necessario. No, non gli dire quest\'ultima frase.";
D.q[4801] = "Trova questo Etram che puzza di pesce e portamelo vivo.";
D.q[5884] = "";
D.q[2417] = "Cerchi informazioni precise su questo mestiere? Vuoi sapere a quale categoria appartiene?";
D.q[1803] = "Se vuoi affrontare un Dabol, devi donare un po\' di Sangue di Vampiro al tempio...";
D.q[4460] = "Lo Stratega è morto?";
D.q[3748] = "Ottenere una pozione di mini cura è facile. Indossa i guanti e usa l\'alambicco. Mettici tre fiori di lino e un po\' d\'acqua. Attenzione: non più di 3 fiori e un solo secchio d\'acqua. Se hai messo la giusta quantità di ingredienti visualizzerai quello che hai ottenuto. A volte può capitare che anche con le quantità giuste la ricetta fallisca... a questo punto non ti resta che riprovare.";
D.q[3971] = "Cosa? Uccidere Wabbit? Non bello, non bello, non divertente per grande bwork come me.";
D.q[5893] = "";
D.q[1802] = "Se vuoi affrontare un Dabol, devi donare un po\' di Liquidi Vampireschi al tempio...";
D.q[7573] = "Di quale tempio di classe ti servono le coordinate?";
D.q[2333] = "Cosa vuoi tu? Se ci tieni alla vita, smamma! E mi raccomando, non hai visto niente... sennò...";
D.q[615] = "Cosa farò adesso? Il mio maestro è morto... ouhouhouuu...";
D.q[6070] = "";
D.q[7596] = "Ascolta, ecco cosa ti propongo.\nOra tu ti metterai a combattere una delle creature della mia collezione. Se vinci il combattimento ti offrirò un regalo.\nPuoi chiedere aiuto ai tuoi amici, poiché più tanti matti si è, più si ride.";
D.q[4045] = "Cosa ci fai ancora qui, sarebbe veramente meglio se tu adesso te ne andassi.";
D.q[7482] = "";
D.q[7597] = "Vedo che la motivazione non ti manca, molto bene.\nAh, un\'ultima precisazione: una volta che avrai sconfitto una creatura, non potrai mai più affrontarla.\nOra, dimmi quale creatura vuoi affrontare, e incaricati di offrirmi uno spettacolo degno di questo nome.";
D.q[4346] = "Cosa ci fa qui un Brakmariano? Non ti avvicinare o chiamo la guardia!";
D.q[5030] = "(Il simbolo di questo forziere è un Draguovo. Non è proprio quello che sta cercando Uk\'Not\'Allag, anche se c\'è sicuramente di peggio...)";
D.q[6752] = "Non mi piacciono i tipi come te, mi danno sui nervi. E quando sono nervoso ho solo voglia di rompere quello che non mi piace, capisci?";
D.q[7574] = "Di quale città ti servono le coordinate?";
D.q[5895] = "";
D.q[7483] = "";
D.q[3026] = "Incontrerai altri avventurieri nei pressi del Kanojedo di Amakna, si trova proprio al centro del Mondo. Laggiù potrai informarti sugli usi e costumi di Amakna. La taverna di Amakna è d\'altronde famosa per le sue serate...\nPer viaggiare alla velocità del pensiero, ti consiglio di usare uno Zaap. Questi archi magici sono molto pratici per attraversare il Mondo. Quando ne vedi uno, non dimenticarti di andarlo a toccare. Memorizzerai così il luogo dello Zaap, e potrai tornarci ulteriormente.\nBuon viaggio, ma prima di partire ti do questo libro! Lo troverai nel tuo inventario. Leggilo.";
D.q[2455] = "Lo credevo più grande!";
D.q[4711] = "Cosa ne sarà di me?\nSono innocente, mi sentite? IN-NO-CEN-TE!";
D.q[5408] = "Cosa posso fare per te?";
D.q[1133] = "Non disturbare mai il grande ZolTAN mentre è in piena meditazione transipnotica. Potrebbe arrabbiarsi.";
D.q[7599] = "Hai già vinto tutti i trofei che potevo proporti. Ripassa più tardi, ho bisogno di tempo per scegliere un nuovo avversario per te.";
D.q[7484] = "";
D.q[1928] = "Per attivare i poteri dell\'anello, devi sottoporlo a quelle che io chiamo: le \"onde magiche\". La cosa più semplice è di andare a cacciare un Alberagno nella foresta. Questa specie di albero è completamente mosso dalla magia: quando muore la magia che libera è impressionante, e sarà sufficiente per attivare l\'anello. \nAttenzione, gli Alberagni sono molto pericolosi... non esitare ad assoldare dei mercenari!";
D.q[5898] = "";
D.q[421] = "Ci vuole molta pratica per diventare Forgiatore. Bisogna anche saper lavorare i metalli e le diverse essenze di legno per forgiare le armi di base. Le armi più potenti, inoltre, hanno quasi sempre bisogno di pietre preziose o di metalli rari dalle proprietà magiche.";
D.q[5268] = "Che notizie ci sono dall\'avamposto?";
D.q[3352] = "Per segnalare un problema che hai constatato, puoi: \n\n - Cliccare sul bottone in alto a destra della finestra vicino al menù opzioni;\r\n            \n - Scrivere al supporto (http://support.dofus.com/) nella sezione server di test;\r\n            \n - Postare sul forum Server di test.\n\nNon esitare a contattare l\'equipe Ankama per ogni problema che riscontrerai.";
D.q[7600] = "In effetti è una cattiva idea. Non importa quale dei miei trofei farà un boccone di te, e anche se l\'idea di vedere il tuo corpo sparpagliato ai quattro angoli della stanza è divertente, vuol dire che ci sarà disordine, e non ho voglia di pulire.\nTorna da me quando avrai più esperienza.";
D.q[4698] = "Cosa vuoi da me?";
D.q[7485] = "";
D.q[3360] = "Eh no, furbetto.\nIl principio del server di test è il seguente: si testano le nuove funzionalità di Dofus in anteprima, per eliminare gli eventuali problemi. Ma non si testa il personaggio, proprio no, non è fatto per questo...";
D.q[5046] = "";
D.q[7486] = "";
D.q[3810] = "Un Pescatore pescava sotto un pesco ma il pesco impediva la pesca del Pescatore.";
D.q[7562] = "Conosco molte di queste persone, sono dei Mercanti di bevande dei diversi villaggi dell\'Isola di Pandala.\nFammi vedere questa cassa. Ti scoccia se la apro? No? Meglio così.\nCosa... Guarda tutte queste Fiale, hai un\'idea di cosa possano contenere?\nTerrò questa cassa mentre tu porterai una Fiala al Mago Ax. Lavora all\'atelier degli Alchimisti, lo troverai facilmente. Dagli la Fiala e chiedigli di analizzare il contenuto, poi portami i risultati dell\'analisi.";
D.q[7487] = "";
D.q[5094] = "Cosa? Speravo proprio di non rivederti così presto. Cosa vuoi?";
D.q[7577] = "Di quale altro luogo ti servono le coordinate?";
D.q[3829] = "Complimenti, sei ancora vivo! Ti teletrasporto all\'uscita o all\'albergo, così potrai raccontare le tue prodezze.";
D.q[4988] = "";
D.q[7563] = "Vuoi che io analizzi il contenuto di questa fiala perchè tu sei incapace di farlo da solo?\nVa bene per questa volta, ma che non diventi un\'abitudine, capito?";
D.q[5622] = "Pietà, confesserò tutto, ma fallo star zitto per favore.";
D.q[6065] = "";
D.q[7488] = "";
D.q[1487] = "Fare il Pescatore è soprattutto una questione di pazienza. Dovrai assolutamente comprare una canna da pesca per fare un po\' di esperienza. Buona fortuna!";
D.q[7578] = "";
D.q[7551] = "Buongiorno.\nSe vuoi posso darti dei falsi documenti per raggiungere la milizia di tua scelta.\nPerchè i documenti siano validi devi essere d\'allineamento neutro, o corrispondente alla città che hai scelto.\nA quale allineamento vuoi appartenere?";
D.q[7489] = "";
D.q[3849] = "I giovani hanno troppa fretta, non sanno apprezzare la tranquillità. Una birra, qualche amico, una cameriera carina, non c\'è niente di meglio per finire i propri giorni.";
D.q[4492] = "Sbrigati prima che la battaglia sia finita!";
D.q[7579] = "Continua la tua esplorazione, hai molto da scoprire.";
D.q[1788] = "Se vuoi affrontare un Dabol, devi donare un po\' di Code di Prespic al tempio...";
D.q[5545] = "Se vuoi scoprire la magnifica città di Astrub e l\'immensità di questo mondo, devi scaricare la versione completa di DOFUS sul sito ufficiale www.dofus.com";
D.q[1] = "Sono uno dei #5 Percettori della gilda #1.\nPosso portare fino a #2 pods di oggetti.\nLa mia prospezione di #3 mi permette di recuperare oggetti alla fine del combattimento, ovviamente dopo gli avventurieri.\nLa mia saggezza di #4 mi permette di fare evolvere la mia gilda.";
D.q[7566] = "Te lo posso preparare, ma sono a corto di petali appassiti di Rosa Demoniaca. Mentre tu li vai a cercare io preparo il resto dell\'antidoto.";
D.q[1767] = "Ho insegnato ai Dabol le tecniche di combattimento Ocra, così saranno degli ottimi avversari qualunque sia il tuo livello. Ma il mio obiettivo è quello di allenare un Dabol fino a farlo diventare potente come Leffe Legodas, il famoso Ocra che viene dalla terra di Biglux.";
D.q[3066] = "Non vedo l\'ora di esserci, potresti invitarla al mio posto? Si chiama Monabella, vive al castello di Allister e passeggia spesso al porto. Avvertimi appena è disponibile.";
D.q[4932] = "";
D.q[5584] = "Arrivano questi 20 semi di scorbuto?";
D.q[727] = "Se un giorno vorrai far parte dell\'élite della milizia, cerca di uccidere dei chafer scelti.\nI Brakmariani usano gli chafer durante gli assalti, ed è importantissimo conoscere le loro debolezze. \nPortami 15 elmi di chafer per provarmi il tuo valore.";
D.q[7040] = "Quale caratteristica deve modificare questa pergamena?";
D.q[2214] = "Ah! Sei tu i rinforzi?! Ah va bene lo stesso... Questo è lo scenario: gli Osamodas ci hanno prestato dei Tofu che sniffano le esalazioni di gas, e ci avvertono quando l\'ambiente diventa troppo pericoloso, hai capito no? Noi li chiamiamo gli \"sniffatutto\".\nCredo che non abbiano sniffato solo del gas...\nCerti sono tornati veramente malconci, e dubito che del Suborhube li possa rimettere in sesto. I nostri sono partiti alla ricerca degli altri Sniffatutto già da un po\'... Ho paura che si siano fatti catturare da quei maledetti ratti. Ritrovali, ti prego!";
D.q[3096] = "Vedo che sai dove trovare della buona birra. Mi piacerebbe veramente assaggiarne diversi tipi.";
D.q[5909] = "";
D.q[1856] = "Benvenuto caro cliente, oh che fisico da sooogno che hai, devi as-so-lu-ta-men-te comprare i miei vestiti! Metteranno in risalto tuuutte le tue curve. Ah scusa la maleducazione, mi chiamo Alit Elfmin, sono l\'unico Sarto di moooda del mooondo, o quasi...";
D.q[4476] = "Chi sei ? Che vuoi ? Non avvicinarti!";
D.q[2275] = "Impara a conoscere gli Aniripsa. Sono dei bravi guaritori. Ah sììì, è vero... c\'è un giovane maestro Feca a Est di Amakna... come si chiama già? Non mi ricordo più... Ma è un famoso allevatore di Pappatutto, più volte premiato alla Fiera del Trool. Ha delle Piccole Pergamene di Vitalità. Trovalo, e te ne dirà di più.";
D.q[4882] = "I miei amici hanno accettato di aiutarmi ?";
D.q[5192] = "";
D.q[409] = "Ho bisogno di fare un buon budino alle uova di Tofu per festeggiare il ritorno di mio cugino, ma mi manca l\'ingrediente principale: le Uova di Tofu! Se me ne porti uno ti darò in cambio il mio Tagliacuoio.";
D.q[4274] = "Chi? Ah, non è l\'ultimo campione del concorso di raccolta di Bava di Pappatutto? ... No? Beh, allora non lo conosco.";
D.q[2089] = "È la prima volta che gli Anutrof hanno bisogno di questo rimedio... Ho una specie di presentimento su ciò che sta accadendo là sotto. Mi faresti il piacere di andare a vedere e riferirmi tutto quello che ti sembra strano? Tieni, prendi questo martello, ti sarà utile.\nTi ho indicato la strada sulla tua mappa. Non ti resta che seguire la bussola.";
D.q[2341] = "Mi chiedo se gli Aniripsa troveranno qualcosa di strano in queste zampe di Arakne... non vorrei dovermi separare da tutto il mio stock... *sospiro*";
D.q[6297] = "Rieccoti finalmente! Mi chiedevo cosa stessi facendo. Spero per te che non stessi complottando alle mie spalle, se no rischi di pagarla cara, molto cara...";
D.q[4271] = "Xefires? No, non mi dice niente.";
D.q[2312] = "Ups! Non mi sembri tanto in forma tu... Sei sicuro che mangi abbastanza?! Dai, ti propongo un lavoretto, così potrai riempirti un po\' le tasche... e lo stomaco, eheh!";
D.q[4465] = "È sulla strada per Astrub.";
D.q[2335] = "Se cerchi una birra che ti riempa bene la panza... hai bussato alla porta giusta. La birra di Astrub non è certo conosciuta per la sua leggerezza. Hahaha... Dai, comprane un po\'!";
D.q[2064] = "Ciao amico! Sei venuto ad ascoltare i fiori crescere? O forse per altro? Ci avrei scommesso! Ma dovrai fermarti lo stesso ad ascoltare la natura, sei troppo stressato! La natura parla piano, ma è un pozzo di conoscenze millenarie!";
D.q[6711] = "Grazie a te farò molti kama, puoi dire al tuo datore di lavoro che sono l\'uomo per lui. Resto ad Astrub ancora molti giorni per affari, può contattarmi quando vuole.";
D.q[5015] = "";
D.q[3011] = "Va da Zeorg, nel tempio di Osamodas. Ha delle strane usanze, ma possiede delle pergamene di Saggezza, il che è ancora più strano!";
D.q[5386] = "Non vedi che sono occupato? Ho cose ben più importanti da fare che discutere con un turista.";
D.q[5260] = "I territori sono stati conquistati?";
D.q[5185] = "Individuato intruso. Individuato intruso.";
D.q[6278] = "Finché non si tratta del mio, mi va bene.";
D.q[2125] = "Dovresti andare a consegnare questo dolce alla nonna, non perdere tempo per strada e fai attenzione: sembra che intorno alla sua casa girino parecchi ratti. Non devono mangiare il dolce!";
D.q[7559] = "Cosa fai ancora qui? Dovresti già essere lontano!";
D.q[3939] = "";
D.q[7555] = "Perfetto, vedo che siamo sulla stessa lunghezza d\'onda.\nNon vorrei che si spargesse la voce che abbiamo avuto questa conversazione, quindi raggiungimi a casa. Si trova a Sud della Statua del dio Yop, vicino al mercatino dei Tuttofare.\nPreferisco non farti passare dalla porta principale. Utilizza piuttosto quella sul retro, è più discreta e nascosta da una catasta di casse.\nTi dirò di più quando mi avrai raggiunto.";
D.q[7554] = "Peccato, sono sicura che potremmo fare grandi cose insieme. Insomma...\nNon voglio forzarti la mano, ma se cambi idea, sai dove trovarmi.";
D.q[7048] = "";
D.q[1383] = "Se stai cercando il guerriero di Bonta, è fuggito verso Nord. Dovresti poterne seguire le tracce facilmente, chiedi alle sentinelle se l\'hanno visto.";
D.q[2148] = "Ma vedo che non hai armi... Tieni, con questa borsa piena di kama che Chronokwartz mi ha gentilmente offerto potrai procurartene una... Al tempo stesso, mi chiedo proprio se non mi abbia preso in giro. Questo metallo potrebbe scomparire presto se nessuno se ne occupa!";
D.q[7033] = "";
D.q[2026] = "Bim... Tzzz smettila di accarezzarmi. Non ho bisogno di coccole. Torna da me quando potrai ferire un Tofu...";
D.q[3284] = "Il Kralamore gigante mi ha ingoiato ma si è soffocato con i miei oggetti di spugna. Mi ha sputato fuori due mesi più tardi. Per sopravvivere ho mangiato del pesce predigerito nel suo stomaco.\nForse non mi crederai, ma era molto buono. Fu in quel momento che ebbi l\'idea di nuove ricette a base di pesce predigerito e fermentato all\'Olio di Gomto. Mi mancano solo i clienti e potrei aprire un nuovo franchising.\nMa sto divagando...";
D.q[5034] = "(Il simbolo di questo forziere è un demone. Uk\'Not\'Allag dovrebbe apprezzarlo.)";
D.q[6338] = "Non è facendo finta di allenarti nell\'edificio della milizia che ti troverai come per magia con un\'Anima di Canin Blando in tasca.";
D.q[6725] = "...\n............\n...................\n............................";
D.q[2192] = "Questo è proprio un bel pezzo! Non ci vorrà molto... Torna da me tra un istante.";
D.q[2244] = "Mi dispiace, non ho tempo per te... Sto allenando i miei Tofu a scendere sotto terra per aiutare gli Anutrof.";
D.q[2122] = "La pala... non buona... la terra... troppo dura... non scavare... ho bisogno di tavole! Due tavole di castagno...! Cibo! Sopravvivere, mi serve del pane... tre razioni di pane di Amakna!";
D.q[5920] = "";
D.q[3285] = "In seguito ho scoperto che c\'era un castello di sabbia abbastanza strano in quella calanca, mi ci sono avventurato, come un uomo valoroso in cerca di redenzione, o di digestione, non so più esattamente.\nHo sconfitto le creature più abiette che vivono sui fondali marini, creature che non avrebbero neanche paura a guardarti.\nIn quei luoghi, ho trovato i miei oggetti di spugna, facendo a pezzetti un\'enorme spugna di mare, una spugna marina, l\'illustrissima Mob la Spugna.";
D.q[6265] = "Prima di prendere la mia decisione voglio vedere il colore dei tuoi kama.";
D.q[2203] = "Ah sicuro! Devo riconoscere che la strada dell\'amministrazione non mi interessa molto! Ma neanche i Tofu d\'altronde... Non avresti voglia di occupartene tu? No... certo! Vabbé dai, buona giornata lo stesso!";
D.q[1900] = "Come fare per farlo smettere di pensare a quei due idioti...? Ho un\'idea ma rischio di rattristarlo, e di farlo arrabbiare se scopre che è colpa mia... Ah, com\'è difficile! *sospiro*";
D.q[5546] = "Cosa vuoi da me, sterco di Trooll? Sono un importante mercante Bontariano, non ho tempo da perdere con degli individui della tua specie.";
D.q[4284] = "Come vuoi, ma poi non dirmi che non ti avevo avvisato.";
D.q[5923] = "";
D.q[2283] = "Una storia stupida... Eravamo con dei mercenari Etram, e una trappola per Muulupi si è chiusa al momento sbagliato. Quest\'incidente mi è costato la metà dell\'orecchio, ma non mi lamento... invece mio fratello Kuy...";
D.q[2324] = "Di cosa? Ah sì i ratti d\'Isgustosi... *sospiro*... danneggiano seriamente i miei affari. Ce ne sono un sacco nelle profondità delle gallerie. Io non oso avvicinarmi, ma tu forse... tu potresti farmi questo piacere. Se ne uccidi almeno 14, a gruppi di uno, due o tre, gli altri avranno sicuramente paura e potrò riprendere i miei affari.";
D.q[2147] = "Eh sì! Chi vince una scommessa contro una Xelor è una persona astuta, vero? Si dice che leggano il futuro, ma penso che lei sia innamorata e che i suoi pensieri siano tutti occupati dall\'amore... altro che leggere il futuro...";
D.q[5928] = "";
D.q[6804] = "";
D.q[2213] = "Io... io non trovo più casa mia... tutto ciò che mi ricordo è che mia madre mi porta spesso al parco del villaggio, perché è molto vicino a dove abito.";
D.q[3281] = "Ciao, sono Iglut, il celebre capitano! Sicuramente hai già sentito parlare di me.\nPrima di essere capitano senza nave, ero cuoco. Sì, cuoco. Preparavo il pesce come nessun altro, prendevo i pesci vivi, sì vivi sior, hai capito bene!\nPoi, li schiacciavo mentre si dibattevano, aggiungevo sale ed erbe magiche, anch\'esse ancora vive!\nIl mio pesce, così preparato, permetteva a chi lo mangiava di respirare sott\'acqua se nuotava al contrario. Come, non mi credi! Ma te lo giuro, è tutto vero!";
D.q[6337] = "Prima di precipitarti in modo stupido mi porterai l\'Anima di un Canin Blando, ti spiegherò poi perché, se per caso non hai capito.";
D.q[5934] = "";
D.q[1466] = "Sinik inik scittilik ibbindinitik. Mik piciribbik ritrivirik mik mimmik mik cridik chik sik stitik cittiritik...";
D.q[5608] = "";
D.q[2268] = "Ma ma ma? Cosa ne hai fatto di quel foglio? L\'hai buttato? Adesso tira fuori 5 kama se ne vuoi un altro...";
D.q[5975] = "";
D.q[2238] = "Cosa aspetti? Vai subito da Oli Venders! Avrà sicuramente del legno di Arash da darti.";
D.q[5976] = "";
D.q[4805] = "";
D.q[6097] = "";
D.q[4481] = "Secondo la lettera di Xefires, il convoglio passerà per la strada che limita la Foresta degli Alberagni per raggiungere il Villaggio dei Brigandini. Intercettalo prima che arrivi al villaggio.";
D.q[2349] = "Non puoi vendere tutti gli oggetti che vuoi in una volta sola.\nDevi aspettare di averne venduti alcuni prima di metterne in vendita altri.\nDopo un certo tempo, se gli oggetti che hai messo in vendita non sono stati venduti, saranno ritirati dal mercatino e riappariranno direttamente nel tuo forziere in banca.";
D.q[2389] = "Ecco, stanno tornando i rinforzi! Allora, ne sei uscito vivo a quanto vedo! E i fratelli Pyrita anche... ma sono messi male poverini! Bah... l\'aria buona di Pandala li rimetterà in sesto! Dovresti andare a farci un giro, anche tu sei un po\' pallido... Vai da Surivitna, è lo Sciamano di Pandala!";
D.q[1584] = "Sik vik virimintik gidirik dik pitirik miricilisik, divik dirmik inik binik riginik ik inik ghindik.";
D.q[4469] = "Mi dispiace, non prendo nuovi ordini per il momento.";
D.q[4785] = "";
D.q[2914] = "La Torre si illumina ogni volta che vieni. Di cosa hai bisogno?";
D.q[6593] = "E come potresti aiutarmi? Come potresti scongiurare una maledizione lanciata dagli dei stessi? Perfino il mio Libro Magico non mi conforta molto in questa situazione. Ogni giorno è peggio del precedente, non so per quanto tempo potrò ancora tenere. Ho tentato di tapparmi il naso, ma se faccio così mi resta solo una mano per tenere il mio Libro magico e lanciare i sortilegi. Credimi, non è comodo per niente, senza contare i crampi che provoca.\nMa tu puoi uscire da qui e interrogare gli eruditi. Ho sentito dire che quelli del tuo popolo hanno accesso a grandi biblioteche, forse la soluzione si trova in uno di quei volumi.";
D.q[2303] = "Credo che papà sia tornato dalla riunione, è tornato vicino al lago.\nGrazie ancora per l\'arakne.";
D.q[6764] = "Datemi una B.\nDatemi una O.\nDatemi una N.\nDatemi una T.\nDatemi una A.";
D.q[2375] = "Sono un Intagliatrice di legno, esperta e specializzata in bacchette, bastoni e soprattutto archi, che mi piacciono particolarmente. \nIl mestiere di Intagliatore è abbastanza duro di per sé, la materia prima è abbastanza rara, e bisogna trovare un Taglialegna esperto per ben rifornirsi";
D.q[7031] = "";
D.q[410] = "Puoi depositare dei kama ma anche degli oggetti nel tuo forziere.\nPuoi avere solo un forziere.\nOgni accesso al forziere, anche solo per consultarlo, è a pagamento.\nIl prezzo da pagare per consultare il forziere dipende dal numero di oggetti che ci depositi.";
D.q[3534] = "Attenzione, stiamo per essere attaccati dai Minatori Oscuri, lo sento, ecco che arrivano, ci circondano! Muoviti a sbarazzarti di loro e risali sul carro!";
D.q[3456] = "È stato il mio bisnonno il primo a cominciare l\'installazione di una rete di rotaie all\'interno delle diverse miniere.\nHo lavorato per molto tempo alla loro manutenzione, e posso garantire che ci sono ancora un sacco di gallerie inesplorate...\nI miei antenati raccontavano persino che esisteva un villaggio nascosto sotto una delle montagne del continente, accessibile solo da una delle vecchie miniere e oggi purtroppo introvabile.\nMa non perdo la speranza, finirò per svelare questo mistero, a colpi di piccone se ce n\'è bisogno!";
D.q[2404] = "Fare il Ciabattino è difficile, devi avere molto tempo e molti soldi. Devi anche avere molte conoscenze per procurarti le materie prime necessarie alla confezione di cinture e stivali di buona qualità. Ma credimi, il gioco vale la candela!";
D.q[2290] = "Una creatura pelosa delle dimensioni di un Milibuulupo, che attacca i Pappatutto di notte? Hum, sembra proprio che ci sia lo zampino dell\'Uomo Orso... Conosciamo quest\'uomo che controlla gli Orsi, una capacità che ha acquisito da un vecchio manoscritto Osamodas.\nSe vuoi rubarglielo, e così fermare il massacro dei Pappatutto, dovrai attaccarlo con un bel gruppo di avventurieri, altrimenti non farà neanche lo sforzo di usare il libro in combattimento...\nMa prima di tutto, dovrai trovare la sua tana. Cerca di seguire la sua pista, di solito queste creature lasciano sempre delle tracce sul loro cammino...";
D.q[4270] = "Chi? Ah, non è l\'ultimo campione del concorso di raccolta di Bava di Pappatutto? ... No? Beh, allora non lo conosco.";
D.q[2370] = "Dimmi, quale mercatino stai cercando?";
D.q[1894] = "Per quanto mi riguarda, ho lucidato la mia spallina e ho tovato qualche traccia interessante: dei piccoli sassi... *riflette*... adesso però bisognerebbe scoprire da dove vengono questi sassi.";
D.q[4512] = "Impressionante! Con delle armi ed un equipaggiamento di questa qualità, i nostri miliziani non uguaglieranno i Brakmariani, li sorpasseranno! Hai fatto un ottimo lavoro, prendi queste pozioni che ti rimetteranno in forma.";
D.q[2978] = "Il prossimo che becco andare in giro con un falso Dofus in tasca, se ne pentirà!";
D.q[5665] = "Sto mettendo a punto un nuovo numero e non voglio essere disturbato.";
D.q[4402] = "Password?";
D.q[7614] = "Tu, che osi calpestare il suolo di quello che fu una volta un villaggio prospero, oggi distrutto dalla follia degli uomini, tu arrivi troppo tardi!";
D.q[4452] = "Me ne vado subito! Nel futuro eviterò d\'immischiarmi in questo tipo di conflitti...";
D.q[1879] = "Qua sei a casa mia, non fare stupidaggini altrimenti te la vedrai direttamente con me.";
D.q[2409] = "Cosa ne hai fatto del paio che ti ho dato? Anche se sono consumate, hanno un certo valore... se ne vuoi altre ti costeranno 50 kama...";
D.q[1871] = "I Ladrurbi, eh? Humm, quale interesse li avrebbe spinti a fare sparire casa mia?";
D.q[2021] = "Humm... La dea dei Sàcrido mi sussurra all\'orecchio che sei degno di essere tra noi, ma preferisco verificarlo da me. Ricorda, nella vita di un Sàcrido ci sono tre cose importanti:  farsi colpire per primi in combattimento, saper incassare il massimo di colpi, e l\'ultima... ops, l\'ultima l\'ho dimenticata...";
D.q[1873] = "Va bene, riflettici su e vai a cercare il colpevole, non tornare a mani vuote! Vai dall\'Alchimista se hai qualcosa da analizzare, e non esitare ad intimorire o a pagare le persone che interroghi, io VOGLIO sapere dov\'è finita CASA MIA!";
D.q[2264] = "Mi stupisci, è un peccato che tu non sia interessato al mio mestiere, avrei tanto voluto avere un assistente come te...";
D.q[4501] = "Ti avevo detto che preferivo non immischiarmi in queste storie.";
D.q[1912] = "Ho 3 appuntamenti allo stesso tempo. Come credi che stia? Io... Ah... sono malato... Oh, accidenti! Sto bene, sto bene... penso proprio che sia stato il Panettiere a mandarti... Dagli le mie dimissioni! Da ora in poi consegnerò solo cose pericolose! Mi annoio troppo sennò...";
D.q[3044] = "Il castello di Allister ha finalmente aperto le porte. Il re si stava annoiando nei suoi appartamenti durante i lavori. Ma adesso i giullari, gli addestratori di Trooll e i menestrelli torneranno ad affluire. Dovresti andare a visitare i nuovi locali del castello e del porto.";
D.q[2736] = "Noi Pandala cerchiamo di far fermentare cose diverse e varie. Troviamo sempre il modo di fare una grappa di prima qualità! Ma attento, non abusare di bevande troppo forti, potrebbero condurti ad attaccare i percettori e poi... a risparmiarli.";
D.q[1867] = "Vuoi aiutarmi? E va bene, per prima cosa vai a cercare il maggior numero di indizi. Ti ricompenserò per ogni indizio interessante. Vieni, ti indico la mia vecchia casa sulla mappa.";
D.q[358] = "In un pentolone, fai rosolare: 80 Ghiande, 80 Lingue di Dente di Leone Diabolico, 80 Petali di Rosa, e aggiungi al tutto una ventina di dosi di Sporma di Fun Fung. Otterrai una deliziosa zuppa vellutata.\nHo già l\'acquolina in bocca!";
D.q[2200] = "Sapevo che ti sarebbe piaciuto. Dai, diamo uno sguardo all\'avvenire, e per farlo... Come? Una truffa!?... Sappi, mio giovane amico, che gli Xelor non imbrogliano mai! Danno solo prova ogni tanto di anticipazione, un segno di intelligenza! Vabbé, ti stavo dicendo che per farlo mi serve qualche componente: due fiale di cristallo di pallido Anthir che potrai ottenere da Nibé Lulla l\'Alchimista, dei semi d\'Epyss che troverai nel magazzino delle derrate, e del legno dell\'atelier di Oli Venders, di semplice fattura, senza fioriture! Il legno determina la portata, e io non voglio guardare troppo lontano nel futuro. Ecco, ti ho indicato l\'atelier di Nibé Lulla. Non ti resta che seguire bussola.";
D.q[6510] = "ahahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!\nSei povero, non hai più un soldo in tasca e credi di poter sopravvivere a Brakmar?\nAhahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!";
D.q[4486] = "Non sapevo che l\'edificio della milizia di Brakmar fosse contiguo al porto di Madrestam. Cosa ci fai qui?";
D.q[1181] = "Vuoi diventare Macellaio? È semplicissimo amico mio. La tecnica iniziale poggia sulle stesse basi di quella ancestrale di taglio dei mostri. Una volta imparato il colpo, diventa solo una questione di esperienza.\nTi tenta ancora?";
D.q[6824] = "";
D.q[1869] = "E così gli uccelli mi avrebbero mangiato tutta la casa? Hum, è una pista da seguire... ora che ricordo l\'altro giorno uno di loro mi ha guardato male col suo occhio perverso.";
D.q[6720] = "Per far un incantesimo alla Pietra, ho bisogno dell\'assistenza di un Osamodas che conosca l\'Incantesimo di Resistenza Naturale e di un Alchimista capace di fabbricare del Sangue di Fenice.";
D.q[3705] = "Quando avrò 15 anni, me ne andrò via da questo paese e partirò all\'avventura in città lontane. So che mi aspetteranno molti pericoli, ma dopo essermi allenato tanti mesi a cacciare pappaton, sarò sicuramente capace di ucciderne uno a mani nude!";
D.q[3578] = "C\'è chi dubita del mio coraggio, eppure non mi sono mai tirato indietro davanti ad un combattimento. Sì, è vero che non ne ho fatti molti... però... è grazie al mio talento che sono arrivato fin qui... Me lo dice sempre anche il capitano delle guardie... che sono pieno di talento!";
D.q[4540] = "Vedo che stanno arrivando.\nAvanti! Per Bonta!";
D.q[3708] = "Laggiù, tutto è nuovo e tutto è selvaggio. La gloria e la ricchezza toccano ai più temerari e ai più valorosi. Non so se merito di andarci.";
D.q[3601] = "Sì, certo... ma non esaltiamoci troppo, prima di poter elaborare potenti pozioni, bisogna raccogliere gli ingredienti. Ti faccio vedere come si fa?";
D.q[3824] = "Va bene, non ti stancare troppo, tanto ho sempre le stesse risposte. E come sempre, sono io che devo spiegare cosa accade nel cuore di quelle grotte. Ci sono mostri, molti mostri. Ma questo lo immaginavi già. Poi, in fondo a questo dedalo, c\'è il loro capo. Una creatura ignobile capace di sviscerare anche il più forte degli avventurieri. Eccoti avvisato.\nSe vuoi proseguire sulla tua strada, trova dei compagni e mettetevi sulle PIETRE. La porta si aprirà.";
D.q[1881] = "Ecco il mio indirizzo a Sud della città, non puoi sbagliare, la casa è quella circondata dalla vegetazione! \nC\'è un pozzo un po\' a Ovest di casa mia, se per caso non sapessi dove cercare l\'acqua...";
D.q[3809] = "Un Cacciatore che caccia il maomao senza baubau di caccia è un buon Cacciatore.";
D.q[3792] = "Per ricordarti di un personaggio che consideri amico, ti basta cliccare su di lui e aggiungerlo ai tuoi amici, in seguito, apparirà nella tua lista di amici. Se hai capito bene, aggiungi un personaggio tra i tuoi amici.";
D.q[3771] = "Prima di proseguire ti consiglio di lanciare qualche incantesimo o dare qualche colpo a questo spaventapasseri. Conoscere bene i tuoi poteri ti sarà estremamente utile nel vasto mondo che stai per affrontare.";
D.q[4507] = "E allora, cosa vuoi che m\'interessi se Bonta è in difficoltà? Voglio solo che mi si lasci tranquillo!";
D.q[1744] = "Gli Ecaflip sono personaggi molto forti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro forza.";
D.q[2181] = "Ah, sei qua per Locetta, ho riflettuto sul suo caso. Ho pensato ad un rimedio ancestrale che potrebbe andare bene: una pozione così piccante e puzzolente da ravvivarle i sensi. \"Combattere il male con il male\", ecco il mio motto! Per questo mi serve una grande quantità di bava di pappatutto, e di spine di fun fung. Portami tutto ciò per favore!";
D.q[3542] = "Xelor, maestro del tempo e creatore del calendario di Amakna. Hai scelto una strada veramente difficile ma molto gratificante per coloro che ci provano. Ti aiuterò e ti darò qualcosa per allenare le tue recenti capacità.";
D.q[6538] = "Amayiro mi ha chiesto d\'aiutarti. Tuttavia con l\'aumento degli attacchi ai convogli, non posso separarmi dai miei uomini. Forse hai degli amici che possono aiutarti. Se no, sarai solo.";
D.q[3666] = "Finalmente un martello nuovo per riparare questo zaap!";
D.q[4338] = "Accetto le tue condizioni. Non restare qui, potrebbero sorprenderci!";
D.q[4342] = "Salve. Cosa ti conduce qui?";
D.q[6325] = "Eh, cosa? Ma che... Ahia!";
D.q[1943] = "Dell\'estratto di Dzibi, sì certo! Sei un nuovo apprendista? Di chi? Di Nepra? ...aah... Nepra... hummm... carina, vero? Mi ricordo quando anch\'io ero suo allievo, passavo ore a... *sospiro*";
D.q[6440] = "Nonostante le informazioni che mi ha portato, il consiglio rifiuta ancora di mandare delle truppe nelle Pianure Rocciose col pretesto che Bonta non può fare a meno di così tanti uomini in caso d\'attacco da parte di Brakmar. Questa spiegazione è ancora più sorprendente visto che le spie non hanno constatato nessun movimento significativo di truppe a Brakmar. Non m\'interessa mandarti nella tana del lupo, quindi ti affido un\'altra missione che forse è legata a questi banditi.";
D.q[3607] = "Come funziona? Ma santo cielo, è semplicissimo! Vai nell\'atelier giusto portando con te i materiali. Quando ne hai a sufficienza per poter ottenere qualcosa, il monitor te lo indica. Non devi fare altro che abbassare la leva per mescolarli. Nota: se non hai in mano il tuo attrezzo di lavoro non potrai usare l\'atelier.";
D.q[3789] = "Cos\'è questa storia di una luce accecante alla fine di un tunnel?";
D.q[3681] = "Perfetto, fai la ronda in città e chiedi agli abitanti se tutto va bene. Aspetto il tuo rapporto!";
D.q[3729] = "Laura è un po\' troppo appassionata, ma è molto simpatica. Siediti, ti racconterò questo mito.";
D.q[6176] = "Come aspetti che reagisca visto che un idiota mi ha mandato un incompetente? Brakmar non ha bisogno di te, almeno per ora.";
D.q[2000] = "Cosa vuoi dire con questo?! Vabbé! Te lo preparo subito... Va bene, te lo spedirò in fretta! ...Ecco, e buona fortuna! *grmbl...*";
D.q[4381] = "Uno Xelor ha provato a comprarti il gioiello e hai rifiutato? Sapevo di potermi fidare di te. Ecco 1000 kama per ricompensarti della tua integrità.\nDimmi quando il convoglio potrà partire. Farai parte della scorta.";
D.q[2348] = "Credi veramente che basti parlare per poter fare questo mestiere? Vuol dire che non hai ben capito l\'essenza stessa del mestiere. Se vuoi veramente diventare Alchimista vai ad Amakna dal capo degli istruttori, ti faccio vedere dove si trova sulla tua mappa... se vuoi.";
D.q[3697] = "C\'è sempre un artigiano che ha bisogno delle risorse dei raccoglitori, è un modo eccellente per farsi qualche kama ben meritato.";
D.q[5647] = "Bene, vedo che sei ambizioso. Metteremo le mani sulle Statuette simbolo dei beni e dei mali dell\'umanità. Quando ce l\'avremo fatta, il mondo cadrà nella disperazione, il che renderà più facile la sua conquista.\nVisto che Divad Dleifrepok è riuscito a scoprire la posizione delle Statuette, andrai laggiù per eliminare i guardiani, appropriarti delle Statuette e portarmele. Tuttavia puoi farti accompagnare perché più pazzi ci sono, più emoglobina sarà sparsa sui muri.  \nLe Statuette dovrebbero essere nascoste in una vecchia miniera abbandonata vicino al tempio Anutrof. Setag ne ha bloccato l\'accesso, ma il sistema d\'apertura dovrebbe trovarsi vicino l\'entrata. Cerca per bene.";
D.q[3760] = "Con la tua forza, rischi di uccidere uno spaventapasseri in un solo colpo! Cerca di non rovinarli troppo, perché sono io che devo imbottirli ogni volta!";
D.q[911] = "Diamine, un angelo a Brakmar! Acchiappalo!";
D.q[7602] = "Fatti da parte, insetto.";
D.q[3649] = "... allora mangiavo un piatto crudo che si rivelò... la proprietaria mi servì altra birra... decisi di cambiarmi i vestiti... la foresta era piena di alberi... l\'uomo aveva un brufolo sul naso... la principessa aveva dei problemi di tubatura...";
D.q[6468] = "Questa volta non ti darò più filo da torcere.";
D.q[3286] = "Eh sì... ti stai chiedendo come sono riuscito a soffocare il Kralamaro Gigante dell\'Isola di Moon con gli oggetti di spugna che però ho ottenuto solo dopo aver spezzettato Mob la Spugna!\nBravo ragazzino, vedo che segui con attenzione le mie parole. Effettivamente, molto tempo fa, prima di inventare gli Zaap, ho inventato una macchina per viaggiare nel tempo.\nE sì, l\'ho costruita quando sono naufragato sulla famosa isola di Otomai.";
D.q[7603] = "È terribile, veramente terribile...";
D.q[3663] = "Non ti preoccupare per questo, te ne servono pochi. Ne troverai sulle creature che hai battuto. Ma più andrai lontano, più ne avrai bisogno. Vuoi conoscere la storia dell\'origine di queste porte magiche?";
D.q[4608] = "Torna da me quando avrai delle novità.";
D.q[5658] = "Salve, spero che Terra Tibya non ti martirizzi troppo. Ahahah.";
D.q[5829] = "";
D.q[3695] = "Un buon raccoglitore fa attenzione al suo inventario. Deve sempre controllare di avere spazio a sufficienza per metterci i raccolti.";
D.q[3844] = "Tuu me porti ingredienti por l\'aguerelo. Tuu es amico, tuu es artisto.";
D.q[5834] = "";
D.q[3717] = "Quando andrai nel gran mondo, dovrai nutrirti per poterti curare. Le ninfe non possono più aiutarti. Sei troppo potente adesso.";
D.q[5627] = "Incarnam è l\'area migliore in cui progredire. Non ho ancora capito perché la maggior parte delle anime finiscono per lasciare quel luogo paradisiaco.";
D.q[4767] = "L\'ultimo sta per arrivare. Preparati.";
D.q[6055] = "";
D.q[7606] = "Ecco, ti ho indicato quale mostro ha partecipato al furto. Non dimenticare di portare la cassa dei regali appena l\'avrai recuperata. Se malgrado tutti i tuoi sforzi non riesci a recuperarla ripassa a trovarmi tra due ore.";
D.q[7607] = "Ti riconosco, sei una delle persone a cui ho chiesto di recuperare una cassa rubata. Come va la missione?";
D.q[4670] = "Eheh, qual buon vento ti porta fino qua giovanotto? Scommetto che vuoi passare dall\'altra parte! Ero proprio come te prima, un po\' pazzo, sfacciato, e spesso stordito. Ma gli anni passano e mi sono attaccato alla bottiglia. Sì, insomma, a molte bottiglie. Ma ogni volta l\'ho fatto per una buona causa sai, per uccidere i microbi che si nascondono nella mia testa. Dovevo affogarli e non potevo farlo con l\'acqua. Quei poverini non se lo meritavano. Boh, hai intenzione di rompermi le scatole ancora molto con le tue storie?";
D.q[3688] = "Ma non è possibile, non è poi così complicato trovare qualcuno nei dintorni! Datti da fare! Ti aspetto!";
D.q[2067] = "Il legno di Arash è molto raro, ma qualsiasi altro legno poteva andare bene... Comunque sia, il mio aiutante è pronto ad occuparsene. In questo momento, io sono sfinito, è più di un\'ora che ascolto la natura... *sbadiglia*";
D.q[4133] = "Incredibile, hai trovato tutto ciò di cui avevo bisogno per riparare la nostra nave. Sono sorpreso che il Forziere Maledetto del Flib ti abbia dato il suo cofanetto, allora non doveva avercela troppo con me.\nPosso infine mettermi al lavoro dissetandomi con questo delizioso succo di Kokoko, ancora qualche sforzo e finalmente potremo lasciare quest\'isola.";
D.q[4940] = "";
D.q[7608] = "È così tanto difficile o non ci hai nemmeno provato? Vediamo quale mostro ha ancora delle casse rubate...";
D.q[6178] = "Ti manda Snori Nairb? Allora suppongo che tu venga ad arruolarti nella milizia della nostra bella città, non è vero?";
D.q[7142] = "Buongiorno giovane avventuriero. Non so se lo sai, ma il nostro Tempio si è modernizzato. Offre numerosi servizi che sarebbe stupido ignorare. Sembra perfino che nuovi Dabol siano stati catturati per gli allenamenti di combattimento. Vai pure a dare un\'occhiata.";
D.q[7609] = "Vedo che hai il tuo mazzo di chiavi, passamele un istante. \n...\nOra potrai fare il dongione una volta senza aver bisogno della chiave.";
D.q[7610] = "Grazie mille. Grazie a te tanti bambini buoni riceveranno i loro giochi di Nawal. Per ringraziarti della tua generosità ti ho preparato qualche regalo. Se pensi che i regali siano troppo piccoli, mia moglie può scambiarteli volentieri con dei regali più grandi. E Buon Nawal!";
D.q[1411] = "In effeeetti corrispooonde aaalle testiiiimooonianzee deelle sentiineeelle. \nGraaazie peer il tuoo aiuuuto. Preeendi queesto piiiiccolo regaaalo coome ricompeeensa deel tuooo valooore demoniiiaco.";
D.q[7038] = "Quale caratteristica deve modificare questa pergamena?";
D.q[7043] = "Non possiedi abbastanza pivittoni per realizzare questo scambio.";
D.q[5156] = "Salve, in cosa posso aiutarti ?";
D.q[5159] = "Come va con Elviana Tirips?";
D.q[5232] = "Interessante! Ne farò parlare nella mia taverna.";
D.q[6182] = "Le nostre truppe sono attualmente più numerose di quelle di Brakmar, non abbiamo bisogno di nuove reclute al momento.";
D.q[3206] = "D\'accordo, ti aiuterò ad uscire di qui. Puoi conservare la Chiave, ti servirà nel caso volessi tornare qui. Ma prima di andare, ti devo dare un nuovo punto di registrazione della posizione, la Maledizione del Minotoror sembra averti fatto dimenticare certe cose. Allora... lasciami scegliere al posto tuo... hum, la camera delle sorelle Korkule... troppo pericolosa... Il fosso del Bimd\'Ulo... troppo profondo... La vescica gigante di Sarlack... troppo umida... Va bene, allora ti darò come punto di registrazione quello che avevi prima del tuo arrivo. E considerati fortunato... ora ti accompagno all\'uscita.";
D.q[3204] = "Ah! Sono sicuro che hai voglia di entrare in questo labirinto e sapere quali tesori racchiude! Io so quali creature vi si nascondono perché sono uno dei migliori archeologi dell\'isola. C\'è chi dice che io sia il solo, ma non è del tutto vero! Se sono l\'unico è perché gli altri si sono persi in questo labirinto troppo difficile. Hahaha. Vabbé, che vuoi sapere?";
D.q[4521] = "Non dire nulla, immagino che Nara abbia dimenticato qualche strumento. È proprio fortunato ad avere qualcuno che possa portarglieli!";
D.q[5157] = "Se Amayiro ha un piano per far finire Brakmar nel caos vi parteciperò con onore.";
D.q[7612] = "Attendo notizie dagli altri avventurieri per sapere se tutte le casse sono state recuperate. Ripassa a trovarmi più tardi in caso in cui ne mancasse ancora qualcuna.";
D.q[3762] = "Yop ha lasciato la sua spada ad Incarnam per ricordarci tutta la sua potenza.";
D.q[6490] = "Uhuhuheheheh HIARHIARHIARHAHAHA! \nPuzzi da cento metri di distanza e osi chiedermi un favore?\nUhuhuheheheh HIARHIARHIARHAHAHA! \nDammi uno zaffiro e ti dirò dove si trovano le riserve, se nel frattempo non ho cambiato idea.\nUhuhuheheheh  HIARHIARHIARHAHAHA!";
D.q[5810] = "";
D.q[5652] = "Non so di cosa tu stia parlando. E poi non si parla così ad un anziano. Non mi sembra che abbiamo passato la vita ad allevare insieme i Pappaton.";
D.q[6722] = "L\'Alchimista e l\'Osamodas devono sistemarsi ognuno su una lastra nera. Quando saranno sistemati, mettiti sulla lastra bianca e nera, così potremo creare la Pietra.";
D.q[1753] = "Gli Yop sono personaggi forti e a volte agili o intelligenti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro forza, e a volte la loro agilità o la loro intelligenza.";
D.q[4445] = "Cosa ci fai ancora qui? Sparisci prima che ci trovino!";
D.q[6344] = "Cosa vuoi sapere ancora? Ti aspetti forse che faccia il lavoro al posto tuo?";
