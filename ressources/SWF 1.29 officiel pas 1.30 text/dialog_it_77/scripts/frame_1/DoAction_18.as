D.q[3215] = "Hai l\'aria un po\' frastornata, e invece è semplicissimo! Ho l\'impressione di aver beccato ancora un turista deficiente! Devi sapere che se ti senti perso, posso portarti al punto di partenza in qualsiasi momento. \nE soprattutto, uno dei tuoi compagni di squadra dovrebbe visitare il cimitero di questo dongione per fare progredire il resto del gruppo...";
D.q[6438] = "Non bisogna essere così timidi, soprattutto con un visetto così carino. Non hai mai pensato ad entrare nel mondo degli affari? Credimi, ho dell\'esperienza, guadagnerai molto di più che rischiando la vita ai quattro angoli del mondo.";
D.q[3297] = "Dovresti andare a visitare la nuova biblioteca di Bonta, ci troverai sicuramente un sacco di libri interessanti su diversi argomenti, dalla genesi del nostro pianeta all\'utilizzo di una cavalcatura.";
D.q[5178] = "";
D.q[2767] = "Ti resta ancora molto da imparare, vuoi fare un allenamento con me, #1?";
D.q[5713] = "";
D.q[1555] = "Vuoi ancora aiutarmi? Sei veramente gentile, ma non ho bisogno di niente per adesso. Se vuoi fare ancora prova di altruismo, Grace Malcin è venuta da me stamattina perché il suo tabi è malato, ma purtroppo io non avevo il rimedio adatto. Grace si trova a Ovest di Bonta.";
D.q[3334] = "Non dovresti perdere tempo ad Astrub. Vai a Koalak e portami le risorse che mi servono.";
D.q[5905] = "";
D.q[2757] = "Vuoi arrivare al grado Yonkwa? Lascia che ti faccia qualche domandina strategica...";
D.q[3553] = "Te troppo debole, te non potere scuoiare goblin!";
D.q[6254] = "Credi che ti lasci fare senza muovere un dito? Mio zio il Captain Starky mi ha insegnato a difendermi, vedrai di cosa sono capace!";
D.q[5582] = "Credi che non abbia altro da fare che ascoltare i tuoi piagnistei? Parla e dimmi perché sei qui.";
D.q[2792] = "Proprio tu? Tu vuoi domare i mostri della foresta maledetta!";
D.q[2567] = "Hai capito: il Dofus non ha mai lasciato Pandala in tutto questo tempo... È ancora sull\'isola: un Dofus bianco, immacolato, che nessun essere ha mai toccato da secoli... L\'ho nascosto nel dongione della penisola, a Nord-Est di Pandala!";
D.q[3621] = "Te volere Gobrosa? Te goblofilo?";
D.q[3982] = "Vuoi un tofu? Ebbene, in effetti uno dei miei tofu è scappato dal tofullaio... credo che abbia fatto il nido in quella balla di fieno, laggiù, davanti a te.";
D.q[1441] = "Vuoi un badge da miliziano per una missione segreta col nome di \"Oni Tnec\"?\nHumm! D\'accordo, ma ti costerà 1000 kama, la prossima volta chiedi ad Amayiro un certificato di missione, non vorrei che ricadesse tutto su di me...";
D.q[3493] = "Te volere ancora prendere una lezione? Baaastoonee!";
D.q[1178] = "Vuoi essere Macellaio? Bé, dopotutto il mestiere è molto semplice, prendi un grande coltello, un pezzo di carne e tagli. È come nelle battaglie. Il movimento di polso è solo un po\' più morbido. Vuoi veramente che ti faccia vedere?";
D.q[1542] = "Vuoi conosere il tuo futuro, molto bene, allora sgancia 50 kama.";
D.q[2247] = "Vuoi fare una scommessa con me? *Lancia una moneta* Dai, tenta la fortuna!";
D.q[6285] = "Vuoi farmi cantare? Non andrà così. Jeisy, occupati di questi parassiti e raggiungimi a casa quando avrai finito.";
D.q[5088] = "Vuoi sapere se ho assoldato un assassino per eliminare Amayiro? Per chi mi prendi? Non farei mai una cosa simile, ovvio. Ad essere onesto, effettivamente conosco il ladrurbo di cui mi hai parlato, volevo mandarlo come assassino a Brakmar, ma non sapevo che lavorasse già per la concorrenza.\nPer dimostrare la mia buona fede ad Amayiro, sappi che ho appuntamento proprio con questo ladrurbo alla Taverna del Pinchot. Puoi andarci al mio posto.";
D.q[6574] = "Vuoi mettermi alla prova, non ti fidi di me? Se non pensi che sappia fabbricare un buon equipaggiamento perché mi hai assunto?\nPer il dolore fabbricherò una lama così potente che non riuscirai a maneggiarla correttemente, ahahah.";
D.q[3472] = "Te debole, te non potere aiutare Raxitiko, me diventare kaka di Trooll...";
D.q[3995] = "Specie di mezza cartuccia! Ti faccio vedere io!";
D.q[928] = "Lo troverai nel quartiere degli Orefici, si occupa della sicurezza di quel settore.";
D.q[5577] = "Non è usando un tono melenso e facendo una faccia da baubau abbandonato che otterrai qualcosa da me!";
D.q[612] = "Vorresti derubarmi? A me? Che bella barzelletta, torna quando sarai disposto a pagare la piccola somma che ti ho chiesto.";
D.q[5629] = "Per caso conosci un avventuriero molto esperto che possa portarmi in qualche dongione?";
D.q[1661] = "Tu! Sono sicuro che sei abbastanza agile da riuscire a prendere una paperella, te lo giuro, non è cara e puoi vincere un sacco di premi. Dai, prova! Niente \"ma\", prova! Farà divertire i tuoi bambini... sì, anche se non ne hai... anche se tu stesso sei un bambino. Dammi dei kama e prova!";
D.q[1408] = "Ma bisogna veramente essere idioti per non vedere il vero colpevole!";
D.q[6554] = "Mi hai portato il materiale per fabbricarti un\'arma? Nessun problema, potrò provarti la mia abilità.\n...\nEcco il lavoro. Impressionante, no?\nSe non ti sembra un vero capolavoro, vatti a lamentare con Danathor, è lui che si occupa delle questioni d\'equipaggiamento della milizia.";
D.q[4648] = "Lo farai? Grazie! Aaaahhhh, sento i Bontariani che arrivano! Farò quel che posso per aiutarti nel combattimento.";
D.q[1253] = "Puoi trovare il Capitano Koda e i suoi uomini nel dormitorio principale della milizia, hanno proprio meritato un po\' di riposo.";
D.q[2551] = "Lo troverai nel villaggio Pandala.";
D.q[4544] = "Troverai il comandante all\'entrata del Cimitero dei Torturati.";
D.q[3720] = "Troverai l\'acqua nei pozzi.";
D.q[1269] = "Sei un Cacciatore di lvl 30+ e impugni la tua arma.";
D.q[4858] = "Sei un pessimo oratore e per colpa tua un traditore è stato riabilitato. Torna da Amayiro, siete proprio una bella coppia di molluschi.";
D.q[6293] = "Sei uno curioso, tu. Xefires ha una buona posizione a Bonta, ci permetterà di saperne di più sulle transazioni e i convogli di merce dei nostri nemici. Così potremo intercettarli e approvvigionarci sulle spalle di questi stupidi Bontariani. Che ironia farsi pagare l\'approvvigionamento dai propri nemici, non trovi?";
D.q[1171] = "Sei rapido come il vento che soffia dietro le colline. Mi hai fatto guadagnare tempo, quindi te ne darò un po\' del mio per insegnarti il mestiere di Pescatore.";
D.q[2402] = "Ora sei apprendista Minatore! Ah, hai bisogno di un piccone per lavorare, è indispensabile. Te ne posso vendere a buon prezzo se vuoi. E quando avrai il tuo piccone non ti resterà che scalfire la roccia. Comincia con dei giacimenti facili, te li annoto sul tuo libro da Minatore. Se provi subito dei giacimenti più duri o più preziosi, rischi serie perdite.";
D.q[1592] = "Sei uno boriaceo, eh? Ba io e i miei bratelli di bidurremo in boltiglia!";
D.q[5917] = "";
D.q[2034] = "Eccoti di ritorno! Molto bene, fammi vedere! Perfetto... Procediamo all\'assemblaggio finale!... Ecco! Una spada superba, abbastanza semplice ma... la spada non fa il guerriero dopotutto! Buona fortuna, e fai attenzione alle dita! *Duedita sembra pensieroso su queste ultime parole.*";
D.q[2056] = "Ti manda il mio vecchio amico Duedita? Gli piacerebbe conoscere i miei segreti, sai? La mia acqua di luna è conosciuta fino a Bonta, haha! Presto detto, presto fatto: riprendi la tua spada giovane Ecaflip! L\'elemento fuoco scorre ormai nella tua lama!";
D.q[2086] = "Ah sicuro! Devo riconoscere che la strada dell\'amministrazione non mi interessa molto! Ma neanche i Tofu d\'altronde... Non avresti voglia di occupartene tu? No... certo! Vabbé dai, buona giornata lo stesso!";
D.q[4775] = "Devi trovare colui che ha accusato Bast Konliskerz di tradimento ed interrogarlo. Con un po\' di fortuna lo troverai alla Taverna Sulmenù.";
D.q[2559] = "Eccoti libero! Grazie a te, noi ne sappiamo abbastanza... Il saggio Volpo ti aspetta! Corri verso la verità!";
D.q[6442] = "Scorterai la carovana fino ad Astrub, ti aspetta all\'uscita Sud. Dei miliziani travestiti da mercanti t\'accompagneranno. Buon viaggio.";
D.q[5986] = "";
D.q[2201] = "Ti manda sicuramente il caro Setsinbol...\nAnche tu vuoi della lana di Pappatutto, vero? Sei fortunato me ne resta un po\'. Tieni, prendila, te la do.";
D.q[6323] = "Sei stato fortunato in questo caso. Continua a portarmi regolarmente buone notizie e andrà tutto bene, forse ti affiderò delle missioni più importanti. Nel frattempo, sloggia, non ho ancora digerito le altre notizie.";
D.q[3265] = "Sei proprio come tutti gli altri...\nPazienza, lo troverò da sola!";
D.q[2046] = "Scommetto 10 kama che sei venuto a cercare avventura! Tra Ecaflip ci si capisce, vero? Pensa che ho appena alleggerito Chronokwartz, la sacerdotessa Xelor, di 1000 kama!";
D.q[2130] = "Cerchi del Suborhube? Ma certo! Però sarebbe molto più educato se gli Anutrof se lo venissero a prendere di persona. Purtroppo non ho ancora trovato la medicina contro questo flagello che li spinge a scavare dappertutto, anche dove non si dovrebbe...";
D.q[4765] = "Non sei poi così male, alla fine.";
D.q[6075] = "";
D.q[1940] = "Sei una nuova recluta, vero?... Dubito di poterti convincere a non andare là sotto, ma vorrei tanto che questi scavi smettessero, c\'è una tale confusione! Informerò i membri della mia gilda, di\' a Pierlivet di sospendere gli affari, per prudenza.";
D.q[4173] = "Non hai ancora il permesso di atterrare, dovresti andare a vedere il pilota che controlla questo Scareoporto.";
D.q[1182] = "Da adesso fai parte della grande famiglia dei Macellai! Buona fortuna!\nAh sì, non dimenticare un piccolo macete per tagliare la carne. Non potrai fare niente senza quest\'oggetto, se vuoi te ne vendo uno.";
D.q[2299] = "Non hai ancora finito di dargli la birra. Guarda quello, ha l\'acquolina in bocca...";
D.q[4656] = "Non mi picchierai, vero? Ti seguo fino alle celle...";
D.q[6110] = "";
D.q[1172] = "Sei troppo lento, sono sicuro che ormai non siano più buone. Vai a cercarne altre!";
D.q[3064] = "Sei serio e pieno di risorse. Io sono presissimo dai lavori del castello di Allister. So di poter contare su di te. Mi piacerebbe fare una cenetta a lume di candela con la mia amata. Adora il pesce.";
D.q[3325] = "Sei giovane e vigoroso, non ti prenderà molto tempo.";
D.q[4429] = "Sei tu quello che ho incaricato di infiltrarsi nel deposito della milizia di Bonta per rubare l\'equipaggiamento? A che punto è questa storia? Sei riuscito ad introdurti lì dentro? E il rapporto di perizia di Mulic Ber allora?";
D.q[2771] = "Sei troppo giovane per passare di grado, torna da me tra qualche anno quando avrai più di 100 anni, hahaha... \nMa sarò comunque lieto di batterti ogni giorno!";
D.q[247] = "Ti ringrazio, ma quello di colpirmi è un privilegio che bisogna meritare...";
D.q[1026] = "Ne hai già trasferiti 4, sei instancabile vero? Non prenderne altri, va bene così.";
D.q[4276] = "Hai già fatto il giro delle taverne di Bonta? Non mi serve sapere chi ha la birra migliore, quello già lo so!! Hai trovato informazioni interessanti?";
D.q[2705] = "Hai fatto dono della tua persona al nostro popolo, hai imparato le nostre tradizioni e cominci a prendere confidenza anche con la nostra arte di combattimento. Meriti di sapere tutto sul Dofus di Pandala... così pensa il saggio Volpo. È lui che mi manda... sei pronto?";
D.q[6184] = "Te la sei cavata piuttosto bene fino ad ora, ma preferisco che ti alleni ancora un po\' prima della prossima missione. Torna a trovarmi quando avrai fatto dei progressi.";
D.q[2662] = "Hai fatto in fretta, grazie mille!\nDunque secondo te Amin mi suggerisce di usare il Kuartz? Ho capito dove vuole arrivare... vuole che utilizzi il potere ancestrale degli Xelor per andare indietro nel tempo e impedire a questa frattura temporale di formarsi!\n\nMa ci sono due problemi... il primo è che non ho il Kuartz e il secondo è che non posso invocare questo incantesimo su me stesso... credo proprio che il futuro del nostro mondo sia nelle tue mani, non so se capisci cosa intendo...";
D.q[6389] = "L\'hai già dimenticato? Ti basta azionare la leva che c\'è in fondo alla sala per aprire il passaggio.";
D.q[2044] = "Penso che sia arrivato il momento di darti un po\' di fiducia. Quello è un Alchimista da due soldi. Non ha trovato niente! Pffff... Santo cielo! Cosa succede nei sotterranei? Hanno fatto un incantesimo a quel povero Anutrof? O ha mangiato qualcosa di poco appetitoso?";
D.q[2464] = "Sei occupato, vero?";
D.q[1636] = "Ti sbagli di grosso, l\'aiuto reciproco è la vera chiave della sopravvivenza ad Amakna. Senza di lei le creature che scorazzano nei dintorni prenderebbero il controllo dei nostri villaggi. Non bisogna mai rifiutarsi di aiutare un debuttante.";
D.q[2812] = "Sei sulla via dell\'Illuminazione, ma il cammino è ancora lungo... Rispondi a questo kwan, e forse il tuo spirito si accenderà grazie alla luce del sapere:\nConosci la differenza tra un Pappaton e un Pandawa?";
D.q[546] = "Tu non passare! Tu carne, Kannibul avere abbastanza carne fino a prossimo pasto. Ma pasto di adesso compromesso... Me problema, me non più avere carapace tartaruga per speziare carne! Me non potere andare uccidere tartaruga su spiaggia, perché me dovere girare zuppa. Me riflettere, ma niente trovare!";
D.q[3550] = "Te avere sangue di cento mostri sulle mani. Me avere bisogno di tuo talento!";
D.q[6476] = "Ahia, difficile, difficile. È Amayiro ad averti affidato questa missione suicida?";
D.q[2020] = "Tu... tu eri nella mia visione! Ti unirai ad altri avventurieri e parteciperai agli scavi degli Anutrof nelle gallerie sotto la città! È molto importante! Tieni, prendi questo martello, ti sarà molto utile, ma l\'intelligenza e la saggezza saranno le tue migliori alleate... Questo legno è proprio strano...";
D.q[2199] = "Tu... tu eri nella mia visione! Ti unirai ad altri avventurieri e parteciperai agli scavi degli Anutrof nelle gallerie sotto la città! È molto importante!\nL\'intelligenza e la saggezza saranno le tue migliori alleate...";
D.q[5718] = "Il tuo Maestro d\'Ordine mi ha avvisato del fatto che aveva un incarico da affidarti, quindi dovresti andarlo a trovare.";
D.q[7135] = "È un lungo periplo quello che hai appena terminato.";
D.q[2186] = "Il tuo arco è già pronto! Trovo che gli archi di Enileda non siano così rapidi. Ho sostituito la corda con lana di pappatutto intrecciata tre volte. Così sono sicuro che la corda è ben stretta... Ecco, adesso è un bell\'arco... e posso finalmente insegnarti a tirare! Dai, proviamolo! Fai attenzione: è abbastanza duro da maneggiare all\'inizio...";
D.q[4764] = "I tuoi incubi sono veramente strani. E dopo?";
D.q[2599] = "Hai percorso un lungo cammino, discepolo, ma sei sulla buona strada: quella che porta alla foresta malefica... Prima di avventurarti là dentro, dovresti parlare col nostro addestratore di Dabol. Allenati con una di queste bestioline: non c\'è niente di meglio per migliorare le tecniche di combattimento! Ne avrai bisogno laggiù: dicono che quella foresta sia dimenticata dagli dei...  Se non riesci a sconfiggere un Dabol, ti consiglio di non entrare nella terra proibita, sarebbe un suicidio.";
D.q[2104] = "A giudicare dalla destrezza della tua mano, non sai giocare a Goh! Non mi fare perdere più tempo allora, altrimenti non lo troverò mai!";
D.q[2597] = "Hai percorso un lungo cammino, discepolo, ma sei sulla buona strada: quella che porta alla foresta malefica... Prima di avventurarti là dentro, dovresti parlare col nostro addestratore di Dabol. Allenati con una di queste bestioline: non c\'è niente di meglio per migliorare le tecniche di combattimento! Ne avrai bisogno laggiù: dicono che quella foresta sia dimenticata dagli dei...";
D.q[3944] = "La formula non è del tutto completa, non posso fare niente per te al momento.";
D.q[5462] = "Gnam!";
D.q[3514] = "Hum, sa di organo fresco!";
D.q[6087] = "";
D.q[3874] = "Il consigliere Yse Vewybad è convinto che i Ladrurbi abbiano lasciato degli indizi nel cimitero su come penetrare nella loro tana. Potresti fare il giro delle cripte per favore?";
D.q[860] = "Ah, questi cuervoc fritti! Veramente schifosi. Quella Sbab non sa veramente cucinare. Vai a darle una bella lezione, prendi. Sbab adora i Wabbit, devi averlo notato. Le piacciono in modo particolare le orecchie dei Tiwabbit, le trova \"adorabili\". Portagliene una decina di paia e dalle questa letterina, le farà piacere.";
D.q[5195] = "Ronan sa come convincere i goblin ad appoggiarlo. Anche se i goblin sono creature deboli, il loro numero potrebbe essere utile.";
D.q[4713] = "Qualcosa di strano? Tipo?\nNo, non ho notato niente.";
D.q[2628] = "ah... eh... sì...\n*a bassa voce* non ho proprio l\'abitudine che mi si dica sì... Ehmm, quanto dicevamo?";
D.q[4202] = "";
D.q[2327] = "zzZZZ...  hummm, chi è?";
D.q[1853] = "boubou";
D.q[765] = "seguito del tribunale";
D.q[3863] = "vhjvb.";
D.q[3890] = "testo2";
D.q[1266] = "testA";
D.q[2832] = "use later";
D.q[4048] = "";
D.q[3229] = "I Porcos sono creature molto pie. Il culto del Drago Maiale è professato da un Mago Shouh di cui nessuno conosce l\'identità. Tutti i Porcos venerano il Drago Maiale come un dio, mentre considerano i Fun Fung come dei minori. I porci adorano i funghi, e i cinghiali invece adorano i tartufi. La divinità emblematica di questo culto si chiama Ugah il Fun Fung. Certi avventurieri gli danno persino un\'offerta in cambio di chissà quale conoscenza. Molti altari per il culto di questo dio minore sono sparsi ai quattro angoli del continente. Mio nonno diceva sempre che non credeva in Ugah, ma che gli faceva paura... ebbene io, io ti dico che in Ugah ci credo, ma l\'unica cosa che mi fa paura è il Drago Maiale. Ugah è grande, fratello mio!";
D.q[4108] = "kwwizzzit!";
D.q[4535] = "Penso che questa ricerca occuperà molto tempo. Non si tratta infatti di una semplice pettegolezzo, ma di un oggetto esistente in tutto e per tutto. Dobbiamo metterci le mani sopra, fosse anche solo per impedire a Brakmar di usarlo.\nOh, ma vedo che hai già preparato il tuo stock di Noci di Kokoko. Buona idea, amo i miliziani previdenti.";
D.q[6541] = "Ma non può essere vero, è un incubo reale! Come ho potuto arruolare una creatura così, così... non ci sono parole per classificare la tua stupidità. Hai osato disobbedirmi e perdere tempo con il bersaglio che ti avevo assegnato ? Perchè tu lo sappia Pola agisce sotto i miei ordini, testando gli idioti come te. Volevo sapere fino a che punto eri malvagio, per assegnarti le missioni più importanti, ma sono stato ingannato. Tieni, qua c\'è un elenco di cose, se mi porterai tutti gli oggetti eviterò di assegnare ai miei migliori assassini il compito di ucciderti pezzetto a pezzetto.\nUn ultimo piccolo dettaglio: ti avviso di non avvicinarti mai più a lei, per nessuna ragione! Mi hai capito bene ? Osa sfiorarla, o peggio pensare a lei, e ti farò inghiottire un Myench vivo.";
D.q[6375] = "Del veleno per costringere Garutar a parlare? Idea eccellente!\nSe vuoi preparare un Blopisiero Avvelenato devi costringere un Panettiere a preparartelo, portandogli 1 Seme di Scorbuto, 1 tazza, 3 pezzi di Blop Reginetta e 2 ciliegie.\nSe ti dimentichi la ricetta torna da me.";
D.q[6540] = "Ascoltami bene, i miei ordini erano di eliminarla. Hai recuperato i kama e va bene, anche se non te l\'avevo chiesto, ma al contrario non avevi alcun motivo di lasciarla in vita. Apprezzo l\'insubordinazione,ma ci sono limiti da non oltrepassare. Ti dirò quindi che è stato un test. Pola deve valutare le reclute di un certo livello in modo che io possa giudicare fino a che punto siano malvagi. Tu hai ancora dei progressi da fare, la clemenza è un difetto che non tollero. Hai fatto grandi cose fino qua, quindi dimentica i valori morali che ti restano e potrai sperare di scalare i ranghi della nostra milizia.\nUn ultimo piccolo dettaglio: ti avviso di non avvicinarti mai più a lei, per nessuna ragione! Mi hai capito bene ? Osa sfiorarla, o peggio pensare a lei, e ti farò inghiottire un Myench vivo.";
D.q[6414] = "498, 499, 500, ci sono tutte. Tieni, eccoti la ricetta. Se la vuoi su carta di miglior qualità dovrai pagare di più, ma non si abbinerebbe alla tua tenuta da Contadino. Se non hai altro da domandarmi ti pregherei di allontanarti, altrimenti si potrebbe pensare che noi due siamo amici, ti immagini che onta?";
D.q[6402] = "Hai l\'aria di conoscere un paio di cose sul pane dei tempi antichi. Questo pane è la prova che Xavier il Panettiere non era così dotato come si può credere. Non ho mai saputo come abbia potuto preparare un pane dall\'odore e dal gusto così rivoltanti.";
D.q[6388] = "Spero che Fidji non abbia fatto storie, può essere molto noiosa quando ci si mette.\nTi aprirò l\'accesso alla mia forgia speciale, ma attenzione! Una volta che avrai fatto il tuo oggetto non potrai più entrarvi.";
D.q[4892] = "Grazie. Col tuo aiuto possiamo mettere le cose a posto rapidamente. Dovrai cambiare idea, il lavoro del miliziano non è tutto riposo ed è raro avere tempo libero per se stessi. Se non l\'hai ancora fatto, ricordati che potrai scegliere una delle specializzazioni da uno dei maestri dell\'ordine alla Torre di Bonta.";
D.q[4654] = "Ehi ma sono tutti stropicciati. Hai aiutato la spia, vero? Ti avevo detto soltanto di recuperare i documenti!\nBeh, tanto peggio. Ti darò solo una parte dei kama che volevo darti, così imparerai a rispettare i miei ordini.";
D.q[4634] = "Garutar? Il nome mi dice qualcosa. E\' una tartaruga?\nTi aiuterò molto volentieri, ma in cambio voglio un piccolo favore. Un piccolo Bwak di Fuoco è intrappolato su un pezzetto di terra ed ha paura ad attraversare quei pochi metri che lo separano dalla spiaggia. Se lo salverai ti dirò ciò che so su Garutar.\nAh, avrai sicuramente bisogno di una corda da scalata per raggiungere il pezzetto di terra sul quale il Bwak è intrappolato.";
D.q[6659] = "Esistono molte grandi città oltre Astrub. Alcune città arruolano miliziani, ciò porta ai cittadini vantaggi e anche qualche inconveniente.";
D.q[6535] = "Hai seguito i miei ordini, è un buon segno. Hai rifiutato quello che la ragazza ti aveva proposto e hai eseguito i miei ordini alla lettera. In verità è stato un test. Tu hai ucciso un Doppio, mentre la vera Pola è venuta a farmi rapporto sulle tue azioni. Continua così come ora e andrai lontano, amo che i miei subalterni siano così. Stupido e disciplinato, tutto ciò di cui ho bisogno per le mie missioni più importanti a condizione che tu sia sufficientemente adatto.";
D.q[6536] = "Hai eliminato la ragazza e in più hai recuperato le monete, non è del tutto un male. Hai leggermente disobbedito per farmi ottenere profitto, ne prendo nota. Però visto il modo in cui hai voluto addomesticarmi per avere la certezza della mia riconoscenza ti dirò la verità: è stato un test. Tu hai ucciso un Doppio, mentre la vera Pola è venuta a farmi rapporto sulle tue azioni. Continua così come ora e andrai lontano, amo che i miei subalterni siano così. Stupido e disciplinato, ma pronto a disobbedire se puoi avere un profitto personale. E\' tutto ciò di cui ho bisogno per le mie missioni più importanti a condizione che tu sia sufficientemente adatto.";
D.q[6413] = "Lasciami indovinare: hai incontrato Sim l\'Elegante, lui ti ha detto di venire a disturbarmi e tu, come un cagnolino, gli hai obbedito? Non hai proprio nulla nel cervello, ma siccome sono molto generoso ti cedo la ricetta in cambio di 500 kama. Prendere o lasciare.";
D.q[6534] = "Detesto attendere, soprattutto quando si tratta di soldi o vendetta. Qui ci sono in ballo entrambi, quindi puoi immaginare in che stato sono. Pola è già caduta in trappola?";
D.q[6398] = "Ora sappiamo dove si trova il Calderone Primordiale, ma per poterlo utilizzare bisogna riunire i diversi ingredienti. La ricetta è antica e gli ingredienti sono sconosciuti agli artigiani di oggi. Ti ho fatto una lista degli ingredienti da trovare, comincia con l\'interrogare gli specialisti di ciascun ramo dell\'artigianato. Con un po\' di fortuna, e qualche colpo dietro la testa, può darsi che torni loro la memoria. E siccome la conoscenza non è il tuo punto forte ecco la lista degli specialisti. Ascolta bene, non la ripeterò. Devi andare dai Panettieri Rucar, Harrys Corb, Kelog Korflex e Sam Croä, dalla nostra cuoca Sbab e dall\'Alchimista di Bonta, Merlisello l\'Incatenatore.";
D.q[6177] = "Buongiorno, dal tuo fiato corto capisco che hai corso fino a qui. Cosa posso fare per te ?";
D.q[4587] = "Ah, Galutal... si, venne qui molto tempo fa. Me la licoldo, abbiamo chiacchielato molto. Quando i Wabbit ci hanno cacciato con la folza mi ha detto che i Wobot le avevano lubato il suo feticcio, una bandana magica. Cledo che possiate ottenele i suoi favoli recupelando quell\'oggetto.";
D.q[4660] = "I documenti che hai recuperato addosso alla nostra spia rivelano il nascondiglio del Calderone Primordiale che, secondo la leggenda, avrebbe permesso di cucinare in meno di una giornata abbastanza cibo da soddisfare l\'appetito dei dragoni nel loro unico banchetto. Mi stupisce che il calderone sia nel mezzo della foresta, dovrebbe essere ben nascosto e di difficile accesso. Passa la zona al setaccio, i documenti sono precisi riguardo all\'ubicazione. Nei documenti che i Bontariani hanno provato a rubarci ci sono gli ingredienti necessari alla preparazione di un piatto che risulterà irresistibile per Garutar. Sarai d\'accordo sul fatto che ce ne serviremo, insieme al Grattaschiena, per domare quella maledetta tartaruga.";
D.q[1256] = "Ah! Molto bene, vediamo...\n14 diamanti ?!\nPfff, un colpo di spada e sarà tutto a posto! E sarà anche più divertente! Ho deciso, lascio perdere il veleno, è troppo chic per i miei gusti, eheh.";
D.q[4432] = "Bene, come ti dicevo, bisogna cominciare assicurandosi che Kosuke Ichazum non si impicci dell\'approvvigionamento della milizia di Bonta.\nQuanto al Forgiatore che se ne occupa, è così pessimo che ci metteremmo anni per riuscire ad indebolire la milizia ottenendo lo stesso risultato che hanno ora con il suo equipaggiamento. Bisogna quindi assolutamente che continui a fornire i nostri nemici e conto su di te per motivarlo in questa direzione, anche ungendogli un po\' le ruote o altro. Tuttavia evita di essere violento o di minacciarlo, non deve sospettare un solo istante che lavori per Brakmar.\nQuando l\'avrai trovato, non dimenticare di scambiare i suoi strumenti con i Martelli Martel.";
D.q[4075] = "Che incantesimo vuoi dimenticare ?";
D.q[4062] = "Che incantesimo vuoi dimenticare ?";
D.q[4064] = "Che incantesimo vuoi dimenticare ?";
D.q[3176] = "Ehi, comu te va a quest\'ora, fiul ?\nSei qui per raccogliere lo stercu de Tofu Real, vero ?\nSanto il cielu, mi sembri un pocu mingherlino... hai le gambe piccole comu una spiga di granu.\nGuarda bene dove metteri li piedi, potresti cadere dentru un buco!\nOu, dove vai così, scappi... furfantu!";
D.q[4425] = "Hmm. Oto vuole attaccare Bonta ? Secondo le nostre ultime informazioni non è una cattiva idea, ma bisogna assolutamente lanciare uno spionaggio intensivo. Non è che io esiti a precipitarmi in una sanguinosa ecatombe, ma tanto vale farlo bene!";
D.q[3949] = "Oh, messer Wabbit, sei già arriv... volevo diwe... awwivato al castello ? Che tu sia il benvenuto in questa dimowa, pwincipe.";
D.q[4024] = "Osano attaccawe me! Che infamia! Conosco questa wazza, non si fewmewanno qui! Tu, fedele sewvitowe, smaschewa questi scaltwi!";
D.q[270] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[3571] = "Tu mi porti la lana e io ci vedo una vittoria. La lana è la vittoria, capisci? Eppure, tu mi dai la lana e ti tieni la vittoria, perché la lana è la vittoria, ma non contiene la vittoria, sei tu che tieni la vittoria, anche se mi dai la lana, capisci? Ora vai da Arietta Fiala, lei ti aiuterà ad irrobustirti.";
D.q[3651] = "Un lavoro ? No, non ho niente di simile... Ma aspetta, credo che mia zia Pipeletta stia cercando braccia forti. Ma ti avviso, è un po\' chiacchierona, e ogni volta che la incontro ci avventuriamo in discussioni interminabili.";
D.q[468] = "Whouuuuuu Ahhhh Whooaauuu!\nSono il tewwibile Wabbit del Mezzogiowno Wadiante, fatale limite twa sewa e mattina... Sappi che non ho pauwa di niente... Ti do questa chiave solo pewché mi stai molto simpatico... Non cwedewe che abbia pauwa di questa gwossa awma che pende dalla tua cintuwa, pew niente...";
D.q[4659] = "È strano che sia capitato proprio nello stesso momento, ma una spia di Bonta è entrata nella nostra torre e ha rubato dei documenti.\nI nostri esploratori l\'hanno vista passare a Est della strada. Prendi uno Zaap e intercettala.\nUna volta che hai recuperato i documenti scrivine dei falsi e trasmettili in qualche modo ai nostri nemici affinchè finiscano su una falsa pista. Quando hai fatto quel che ti ho appena chiesto torna da me.";
D.q[6736] = "Il Grattaschiena Spentox è costituito da due parti: l\'estremità e il manico. La loro fabbricazione necessita l\'utilizzo di utensili particolari e non è sufficiente assemblare le due parti. Si devono anche aggiungere numerosi piccoli meccanismi per assicurarsi il buon funzionamento del Grattaschiena e la sua affidabilità. In più, per fabbricare tale oggetto serve la collaborazione di numerosi artigiani. Se hai bisogno di ulteriori dettagli torna da me nella mia forgia speciale e potremo discutere più tranquillamente.";
D.q[6730] = "Mmmm, si, mi dice qualcosa. Ho sentito dei clienti che ne parlavano, ma erano ubriachi fradici e non ho prestato loro molta attenzione per quello. Chiedi a Laura Soho, l\'altra cameriera, magari lei ne sa di più, ma non contarci troppo.";
D.q[4610] = "Salve, stavo per farti chiamare. Dobbiamo approfittare del nostro vantaggio su Brakmar e mettere le mani sul Corno Davola prima dei nostri nemici. Vai immediatamente sull\'isola di Moon e chiedi a Garutar di darti il Corno Davola in cambio della sua bandana. Non transigere al riguardo.";
D.q[6370] = "Non mi interrompere mai. Fai silenzio e ascolta fino alla fine, non siamo in una taverna, ma in biblioteca.\nDov\'ero rimasto ? Ah, si.\nQualche anno più tardi il Corno Davola tornò alla luce quando Moon decise di servirsene per colonizzare l\'isola che ora porta il suo nome. Dopo aver stabilito la sua autorità, la piccola scimmia non ebbe più bisogno dei poteri del Corno Davola e lo abbandonò. Da quel momento scomparve, e ai giorni nostri alcune voci, l\'una più fantasiosa dell\'altra, circolano nelle taverne e parlano del Corno e del suo possibile nascondiglio, ma io non credo a queste voci da bancone. Ora ti consiglio di andare in uno di quei luoghi, la Taverna di Amakna è rumorosa quasi quanto te.";
D.q[7546] = "Hai abbastanza kama per far si che lo spirito di Giorbak ti appaia. E\' questo il tuo desiderio? Vuoi entrare nell\'antro dello Sventurato?";
D.q[4534] = "Un Sadida di Astrub ti ha parlato di un Corno magico che è a Sufokia ? Vale la pena controllare l\'informazione. Recati là e interroga il Taverniere, i pettegolezzi circolano facilmente nelle taverne.";
D.q[3958] = "Bene, hai con te il tofu? Cosa, ma è un neonato!? Idiota, non sarà mai tanto potente da uccidere il principe! Vai da un allevatore adesso, e fatti dare qualcosa per farlo ingrassare rapidamente. Sbrigati!";
D.q[4599] = "Buongiorno, in seguito al furto di documenti perpetrato dai Brakmariani, ho domandato a Ebru Of El di inviare una delle sue spie a Brakmar. Doveva recuperare le informazioni ottenute da Brakmar sul Corno Davola e così farci guadagnare del tempo ma sono inquieto perché non è ritornato.\nVallo a trovare, ti ho dato una copia della missione che ho dato a lui. Sbrigati, credo che non sia troppo tardi. \nSe per fortuna arrivi in tempo cerca di mandare i Brakmariani su una falsa pista. Che Silvosse ti protegga.";
D.q[4571] = "Il nascondiglio del Corno Davola dove si trova io so. Dirlo a te io non voglio. Non insistere dovresti.";
D.q[4575] = "Bisogna trovare un modo per addomesticare quella tartaruga. Vai sull\'isola e interroga gli abitanti, sperando che uno di loro ci possa dare qualche suggerimento. Quando ne avrai ottenuto qualcuno prova subito ad addomesticare Garutar per ottenere il Corno Davola il prima possibile.";
D.q[6417] = "D\'accordo per 1000 kama, ma stai facendo un affare. E se non funziona non venire a piangere da me.";
D.q[5452] = "Buongiorno, la Dea Aniripsa mi ha dato il potere di aiutare le giovani Anime a riparare ai loro errori di gioventù. Quando non avrai più accesso ad Incarnam i soli mezzi che avrai a tua disposizione per dimenticare un Incantesimo o per riassegnare i Punti Caratteristica saranno combattere i Dabol ai Templi o cercare l\'aiuto dell\'Alchimista Otomai.\nAttento! Con i Dabol potrai fare il cambio di Caratteristiche una volta sola. Solo Otomai conosce il modo di fare i cambi più e più volte su un\'anima già sottoposta ad esperimenti.";
D.q[4884] = "Gli ordini sono ordini, sarò presente al momento necessario.";
D.q[6175] = "Siccome mi sembri più entusiasta degli altri pidocchi abituali, ti dispenso dal turno di equipaggiamento degli altri miliziani per l\'allenamento. Invece, per mescolare un po\' le carte, ti manderò alla Milizia di Amakna facendoti ottenere un certificato di cambio di allineamento.";
D.q[4617] = "Abbiamo il Corno, ma...\nNon so assolutamente come usarlo. Non succede niente quando si soffia dentro.\nDovresti andare a consultare Mago Ax, ad Astrub: lui saprà sicuramente farlo funzionare.";
D.q[6668] = "Il tuo non mi sembrava un viso familiare,dove ho la testa? Ringrazia Snori Nairb da parte mia e da parte di Danathor. Torna da me dopo, ho del lavoro per te.";
D.q[6416] = "Vedo, vieni da Brakmar e pensi di avere tutti i diritti nella nostra città? Lascia che ti dica che potresti infilarti pure un dito in un occhio... No, è inutile farlo davvero, è solo un modo di dire, è figurativo, non vedi? Ohlala.. hai del sangue di Yop nelle vene, davvero.\nD\'abitudine non lavoro per il nemico, ma se non ti aiuto tu andrai dalla concorrenza, e sarà di nuovo Nicola Fiammella che si prenderà gli onori, quindi dico no!\nChe cosa è che vuoi? Ah si, vuoi sapere come fabbricare un Filtro della Longevità. 5000 kama e la ricetta è tua.";
D.q[6410] = "Qualcuno ti ha parlato di questa insalata ? Io conosco questo segreto ben nascosto. Lo dividerò con te se mi porterai 10 Pelli di Kanigrù.";
D.q[2053] = "Ecco! Due colpi di soffietto, e la tua lama è forgiata. Vai dall\'Alchimista da parte mia, e chiedigli di immergerla nella sua famosa acqua di luna, diventerà molto più solida...";
D.q[4635] = "Sei più abile degli altri idioti freschi di reclutamento. Il punto debole di Garutar è la sua schiena... Vai a chiedere a Mulic Ber come fabbricare un Grattaschiena speciale. Ti conferisco temporaneamente l\'autorità di reclutare altri miliziani per questa missione, che è appena diventata una priorità. Se dovessero fare storie dai loro uno scappellotto.";
D.q[4643] = "Attenzione, vermiciattolo: la tua missione è molto precisa. Una delle nostre spie ha rubato dei documenti che riguardano il Corno Davola, a Bonta, ma è stata colpita alla gamba mentre fuggiva. Devi assolutamente recuperare i documenti, della spia non importa.\nHa cominciato a scappare sulla strada, non dev\'essere andato molto lontano.\nSbrigati, potrebbero acciuffarlo tra pochi minuti.";
D.q[4560] = "Ecco: il Corno si trova su... un\'isola, sembra. Divertente, vero? \nNon ne so di più, non sono mica una biblioteca ambulante come Harry Stote.";
D.q[4681] = "Hmm, avrei proprio voglia di restituire questa cassa a Oto e dirgli tutto quello che penso... ma ho paura che punisca la mia insubordinazione aumentandomi di grado. E non ne ho voglia.";
D.q[4683] = "L\'equipaggiamento di queste casse fa schifo, ma fa comunque meno schifo di quello che hanno attualmente.";
D.q[38] = "Sono Graham Finam, qui mi conoscono tutti, e i mostri che hanno conosciuto la lama della mia spada sono tutti morti. Se sei interessato vendo tutti gli attrezzi utili per il mestiere di Forgiatore...";
D.q[103] = "Hum, bene figliolo, io vado in pensione e vendo il mio manuale di Forgiatore di Pale. Se t\'interessa ho anche il Martello che serve per forgiare le Pale! Ormai non riesco più a sollevarlo con la mia artrosi...*sospiro*";
D.q[140] = "Fantastico, che fortuna! Hai vinto, ed era molto tempo che non accadeva in questa taverna.\n\n(Musol Ungo ti dà i kama grattandosi i baffi e facendo le fusa)";
D.q[199] = "Oh, un giocatore! Se puoi portarmi un trifoglio a 5 foglie, ti presenterò Wiss Catz, il leggendario Ecaflip che da bambino cadde nel pentolone di zuppa di trifoglio.";
D.q[242] = "Sei un po\' appiccicoso, sai? Vabbé, tanto mi sto annoiando tutto solo qui... E poi ho paura del buio. Portami 10 piume di tofu e 2 gelatine celesti, per fabbricare due ali che mi permettano di scappare da qui. In cambio ti darò la chiave della mia grotta.";
D.q[259] = "Oh, grazie! Se riesci a liberarmi da queste maledette bestiole, saprò ricompensarti a dovere. Hum... non fare questa faccia perversa, non ti pagherò in natura!";
D.q[281] = "Ha! Ha! Pensi veramente che svelerei i miei piani diabolici al primo che capita? Condividerò le mie idee solo con un vero delinquente. (Borbottando) Pfff... di questi tempi comincia ad essere complicato trovare manodopera qualificata.";
D.q[283] = "Hello! Mi chiamo Simgud, e sono un marinaio. Ho attraversato tutti i mari del mondo, ma il mio sogno è di aprire un negozio di souvenir, che si venderanno a migliaia - cosa dico - a milioni! La gente litigherà solo per poter dire di avere un souvenir di Simgud il marinaio. Penso che comincerò intagliando o decorando delle chele di granchio.";
D.q[297] = "Ciao. Mi chiamo Bellus, Sel Bellus. Sono il guardiano di questa grotta. Lascio passare solo i guerrieri esperti, capaci di resistere più di 20 secondi davanti alla terribile creature che abita questi luoghi. In più devo chiederti di portarmi quattro Peli di Cinghiale e due delle loro Zanne. Mio figlio mi ha chiesto di fargli una maschera, ma questo lavoro mi tiene bloccato qui.";
D.q[341] = "Gli Intagliatori lavorano diversi tipi di legno in base alle loro necessità, ma a volte usano anche altri elementi come pietre preziose o metalli rari.\nPiù sarai bravo nel tuo mestiere di Intagliatore, più oggetti potenti potrai intagliare.\nIo posso insegnarti il mestiere di Intagliatore, ma attenzione: l\'apprendimento di un mestiere è molto lungo e, per progredire, dovrai esercitarti seriamente.";
D.q[366] = "Ah, vedo che sei audace, se vinci tutto il montepremi sarà tuo!\nAltrimenti la metà di questa somma sarà aggiunta al primo premio...";
D.q[370] = "Ciao! Sono Otho Laringo, il Forgiatore. Sto cercando un assistente che mi aiuti nella fabbricazione delle armi. Tutti quelli che ho avuto finora sono fuggiti dopo una mezza giornata di lavoro... Tsss, che fifoni! Ho bisogno delle risorse necessarie alla fabbricazione delle mie armi. Ti pagherò naturalmente.";
D.q[383] = "Mi servirebbero diverse cose, ho persino fatto una lista.\nvediamo...\n60 Zampe di Arakne, 55 Trifogli a 5 Foglie, 40 Unghie di Cavaliere di Karne e 15 Code di Buulupo.\nNon ho voglia di stancarmi, quindi ritiro tutto in un solo lotto in cambio di una pergamena magica.";
D.q[387] = "Il mio motto è \"Non darlo ad un altro se già ce l\'ha\".\nSe vuoi che io ti fabbrichi una pergamena, portami la ricetta nonché gli ingredienti...";
D.q[390] = "Ciao, io sono Kussan Trengòn, ma non sono Duca di Kussan. O meglio, non ancora. Mi lascio trasportare dalla mia buona stella che mi dà tutto ciò di cui ho bisogno. Per esempio, scommetto che tu mi porterai presto gli ingredienti che mi mancano per preparare una pozione.";
D.q[400] = "Hello! Non complichiamoci la vita, puoi chiamarmi lo \"Stallone\". Ieri ho mangiato del prosciutto di Drago Maiale. Mi avevano parlato di certe virtù di questa carne, ma si è rivelata una cattivissima idea, gli effetti infatti non sono stati quelli che desideravo... Per farla breve, avrei bisogno di qualche ingrediente per curarmi.";
D.q[426] = "Gli Aniripsa apprezzano particolarmente le Bacchette. Queste armi necessitano spesso di molta intelligenza e di un po\' di saggezza per essere utilizzate correttamente. Le Bacchette non provocano ingenti danni, ma conferiscono spesso poteri magici importanti a chi le usa.\nGli Intagliatori di Bacchette utilizzano come attrezzo un\'Intagliatrice di Bacchette.";
D.q[427] = "Gli Archi sono le armi preferite dagli Ocra perché permettono loro di attaccare i nemici a distanza.\nGli Archi non provocano quasi mai gravi danni, ma hanno dei colpi critici sorprendenti.\nHanno bisogno di una buona agilità e di una buona forza per essere utilizzati.\nL\'attrezzo degli Intagliatori di Archi è l\'Intagliatrice di Archi.";
D.q[429] = "Ciao discepolo, io sono uno dei sei Maestri Ladrurbi, e Vil Smis è il nostro grande Maestro.\nSe vuoi evolvere e avere più responsabilità all\'interno del clan, dovrai portare a termine numerose missioni e occuparti di altri lavori per provare il tuo valore.";
D.q[432] = "I Panettieri sono persone rispettabili che cucinano il pane per gli altri.\nNoi Panettieri siamo rispettati perché permettiamo agli avventurieri indeboliti di riprendere forza grazie al nostro pane.\nPiù un Panettiere è esperto e più cuocerà del pane sempre più buono, e più il pane è buono, più gli effetti positivi sulla salute degli avventurieri saranno grandi.\nI Panettieri usano un Impastatore per fare la pasta da pane.";
D.q[438] = "Ah, conosci Hannibul Smis? È il nostro capo, è lui che organizza tutte le operazioni e che fa tutto il necessario per salvarmi quando certi pazzi mi prendono per un pazzo e mi rinchiudono. \nMa non dovrei raccontarti queste cose.";
D.q[442] = "Questo è uno dei più vecchi Alberagni della provincia di Amakna, ha già ucciso molti miei amici Taglialegna, ma ha soprattutto ucciso la mia famiglia mentre dormivamo all\'aria aperta in piena foresta.\nFu una vera carneficina selvatica, e io sono l\'unico superstite...\nVoglio vendicarmi, ma non posso farlo da me, ti chiedo quindi di farlo per me. Uccidi questo mostro e ti ricompenserò!";
D.q[450] = "I famosi Stivali di Klim...\nÈ stato Lee Ncantenato, un illustre Ciabattino un po\' stordito, che in una notte d\'insonnia ha cercato di fabbricare i famosi Potenti Stivali di Klim... Nessuno sa come ci sia riuscito, ma i primi esemplari di queste calzature erano estremamente potenti... purtroppo quando Lee se ne accorse era ormai troppo tardi.";
D.q[459] = "Tutto perso... Ho perso tutto... L\'idea era buona, avevo scritto tutti i libri necessari per la formazione a distanza degli apprendisti... Mantelli, cappelli... avrebbero potuto imparare tutto.\nE poi... quei maledetti Forgiatori oscuri, non mi hanno lasciato scampo, mi hanno rubato tutti i libri! Sono sicuro che li hanno nascosti nella loro tana...";
D.q[465] = "Ciao, ti aiutelò dandoti la licetta della pozione che ti pelmettelà di andale più in alto nell\'isola... Avlai bisogno di un buon mago pel plepalalla. \nCi vuole 1 gelatina di ogni colole, quindi blu, velde, lossa...\nBuona fortuna e che la glande coda del dio Volpo sia con te.";
D.q[478] = "Scusate mio we, non vi avevo wiconosciuto.\nSua maestà vuole accedewe alla sala del dofus?";
D.q[494] = "Ho regolarmente dei messaggi da inviargli, se gli consegni questa missiva, riceverai 1000 kama e aumenterai la stima che il nostro clan già ti porta. \nLo troverai a Sud della foresta oscura di Amakna.";
D.q[496] = "I Maestri Ladrurbi hanno ognuno un ruolo differente e una regione da gestire. Nella regione di Amakna siamo in tre.\nIl mio compito è quello di formare gli apprendisti e seguire coloro che vogliono entrare nel nostro clan.";
D.q[497] = "Ciao, vedo che powti le cose del we, in confowmità alle nostwe leggi, colui che si pwesenta con gli effetti pewsonali del we può pwendere il Dofus.\nIn cambio pewò devi lasciawmi i suoi vestiti.";
D.q[530] = "Stai tranquillo, eccoti 2000 kama di rimborso per il pane. Ero sicuro che avrei trovato qualcosa di utile da farti fare.";
D.q[552] = "Ah! È veramente un\'ottima domanda caro cliente.\nPrima di tutto, la parte Est dell\'isola è un\'immensa spiaggia che ti permetterà di goderti il sole e di abbronzarti, ringiovanendo e rinvigorendo un po\' la tua pelle. Sarai invidiato da tutti i tuoi colleghi quando tornerai al lavoro. Inoltre puoi approfittare dei momenti di relax sulla spiaggia per gustare i meravigliosi Kokos che sono a portata di mano.";
D.q[553] = "I pirati occupano una parte del Nord dell\'isola, ti accoglieranno a braccia aperte. Non perderti il loro rhum invecchiato 120 anni! Ricordati anche di salutare il loro illustre capitano, ma stai attento: non dire assolutamente niente di spiritoso sul suo calzone portafortuna. Secondo la leggenda, questo ridicolo calzone lo ha aiutato a sopravvivere a tutte le tempeste dei terribili mari di Kalmar.";
D.q[558] = "Stai attento però a non farti male con i pezzi di relitti sparsi un po\' ovunque.\nIn seguito, amante dei brividi, ti propongo una bella passeggiata nel Sud della giungla. Lo spavento è garantito con i nostri pirati fantasma autoctoni. Ma non temere, non sono molto pericolosi...";
D.q[560] = "Ti propongo di partire per un\'isola da sogno, il paradiso in terra. Immaginati: sdraiato sulla sabbia fine, il sole che ti abbronza la pelle delicata, la brezza marina che ti carezza il viso. In mano un cocktail di latte di Koko. Dopo tutta la giornata passata a non fare proprio niente, ti ritrovi alla tavolata degli abitanti locali, cuochi sopraffini, che ti trattano con i guanti bianchi. La sera, ammira lo spettacolo da favola della luna che rischiara la flora e la fauna del luogo. E se desideri divertirti di più e avere un po\' di brividi, degli agenti appositamente formati da più di 100 anni, sono al tuo servizio.";
D.q[608] = "Ahaha, ho fatto bene a venire su quest\'isola. Ci sono molte cose di valore, senza contare tutte le persone deboli da derubare... Non c\'è neanche bisogno di combattere, basta aspettare che abbiano a che fare con un Kannibul o un altro mostro dei dintorni... e voilà!";
D.q[635] = "Se vuoi delle ricette ti consiglio di fare un giro alla biblioteca. Un Alchimista ha scritto un\'enciclopedia sulle ricette rare in più di 12 volumi.";
D.q[641] = "Per continuare il tuo apprendistato, devi andare da una persona qualificata, e purtroppo io non lo sono. Vai verso l\'isola più meridionale di Amakna. Vi troverai un mastro Alchimista di cui ho dimenticato il nome. Mostragli la pergamena e questo fiore che ti do, è il simbolo che hai superato la prima lezione.";
D.q[711] = "Ciao giovane avventuriero, sono il maestro d\'armi della milizia di Bonta.\n\nSe vuoi unirti ai ranghi della milizia, aiutami a recuperare qualche spada di legnuccio per allenare i miei soldati. Dovresti andarmene a prendere una decina nel quartiere dei Forgiatori, a Est della città.";
D.q[717] = "Ciao piccolo scarafoglie, spero che tu non abbia buchi agli stivali, perché ti serviranno. Io prendo sempre la birra da un collega taverniere a Est della città. Mi piace approfittare di questi momenti di relax per scambiare qualche carta speciale con lui. Me ne deve una dal nostro ultimo incontro, potresti andare a prendermela?";
D.q[719] = "Apparentemente Torcha non era nella sua postazione l\'ultima volta che l\'hai affrontato. Fammi un piacere, fai il giro delle taverne per portarmi la lista di tutti i miliziani fannulloni come lui.\nDigli che stai facendo un censimento, e che devi prendergli il badge fino a stasera.";
D.q[740] = "Mio nipote Dike Tarak gironzola spesso nel quartiere Nord, fai finta di perdere contro di lui, gli farà piacere e se lui è contento... anch\'io sono contento. Capito?";
D.q[742] = "Mio nipote è fiero di averti battuto, mi ha fatto morir dal ridere. Però, mi ha raccontato che dei suoi amici vanno a fare cose poco Bontariane nel quartiere dei Panettieri, mi piacerebbe che tu andassi a dare un\'occhiata e che tu rimettessi le cose in ordine.";
D.q[754] = "Conosci Messer Cuervoc? Mi piacerebbe che tu gli prendessi la falce, vorrei vedere se taglia meglio della mia sciabola. Cosa vuol dire che abuso della mia autorità? Al lavoro #1!";
D.q[762] = "Ah #1, ti stavo aspettando, devo allenare i miei ragazzi domani, e con il sole che c\'è in questo momento, vorrei che tu mi procurassi un Champello bello grosso, per poter avere un po\' di ombra.";
D.q[821] = "Per chiudere il becco a quegli idioti di Bontariani, ci alleneremo tutti con il martello.\nPerò, siamo un po\' in difficoltà e se non mi porti qualche Martello di Legnuccio, 10 soldati dovranno saltare all\'allenamento... te compreso!";
D.q[854] = "Il nostro prossimo piano è di corrompere un personaggio importante di Bonta per avere un alleato... al momento necessario. Voglio che trovi qualcuno ai posti alti che potrebbe tradire Bonta. Ti consiglio di ispezionare la torre di Bonta tanto per cominciare, laggiù potrebbero esserci degli indizi.";
D.q[965] = "Le pietre delle fortificazioni di Bonta sono state tagliate dalle spoglie dei Croccaroc delle Pianure.\nQuesta notte una squadra di Bwork ha danneggiato quelle a Nord. Se vuoi darci una mano a ricostruirle, portaci almeno 4 pietre di Croccaroc delle Pianure.";
D.q[983] = "Ciao, mi chiamo Ned Atsit, io mi interesso di odontostomatologia, appassionante, no?";
D.q[1007] = "Cos\'hai fatto con questa collana, è tutta storta... Non posso restituirla in questo stato alla figlia del sindaco. Vai nel quartiere degli Orefici e procuratene una nuova.";
D.q[1010] = "Mi ha parlato di una similitudine tra i denti di pappatutto e i nostri. Quell\'animale non smetterà mai di stupirmi. Una volta recuperati i denti, portali al mio amico a Sud-Ovest della città.\nSpero che tu non sia tanto ignorante d\'aver dimenticato il numero di denti che possiede un essere umano.";
D.q[1011] = "Sei in pausa fino a domani, torna da me più tardi per avere una nuova missione.\nSono di buon umore, quindi prendi questi 1000 kama per le spese di trasferta... e per il tuo giro alla taverna... hehe! Ma non bere troppo alcool e cerca di mantenerti in forma, avrò presto ancora bisogno di te.";
D.q[1035] = "Ah, e così saresti tu la recluta di Amayiro, sembri giovane per il destino che ti aspetta. Bene, suppongo che tu sia qua per la mappa. Le tue mani sono pulite spero. Non sporcarla di sangue, o di non so cosa potresti trovare sulla tua strada, Amayiro non ne sarebbe contento.";
D.q[1020] = "Hmm, conosco qualcuno che sarà sorpreso alla prossima paga. Grazie #1, andrò a rendere loro i badge personalmente.";
D.q[1037] = "Cacciare non è tanto semplice! Bisogna avere l\'arma adeguata per colpire l\'animale. Se lo ferisce troppo o lo uccide male, il Cacciatore non potrà raccogliere i pezzi di carne più buoni da poter vendere.";
D.q[1056] = "Che dimostrazione di obbedienza. Farai molta strada, tu... se io lo vorrò.\nTieni, per ricompensarti ti propongo un piccolo divertimento.";
D.q[1090] = "Allora, è andato tutto bene?\nHo l\'impressione che tu ti sia dimenticato di portare una birra al tuo capo... vai a prendermene a prendere una alla Batosta.\nAh, dimenticavo, questa taverna si trova a Bonta, ti auguro buona fortuna...\nOppure, potresti catturare un Contadino e mandarlo a prenderla al posto tuo! Haha!";
D.q[1102] = "Benvenuto caro cliente. Qui tagliamo tutto su misura, naturalmente su corrispettivo. Camicie, pezzi d\'armatura, gole, qualsiasi cosa visto che possiamo tagliare tutto sul momento con i nostri coltelli.";
D.q[1114] = "Hummm. Ho delle scaaaaaaarpe, che si moltiplicano. E ne ho peeeeeerso il controllo!\nNO, NON VA BENE! Argh! Sono un capo io, non un cantante! Come potrò mai riuscire a mettere insieme due parole per fare colpo su di lei...\nAH, hum, scusa, stavo pensando a voce alta... Mi spiace.";
D.q[1141] = "Ehi! Di cosa mi stai parlando? Mi prendi per un mendicante, vero? Mai e poi mai, ti ho chiesto solo 5 kama.";
D.q[1142] = "Hmm, ora che ci penso, tu non hai l\'età legale per bere vino di Glutovora.\nChe peccato, non potrò dividerlo con te. Però non avevi una lettera da darmi?... Ecco, grazie. Ma che incompetente. La prossima volta ti metto in cella, hai capito?!";
D.q[1147] = "Hum, capisco, la situazione è peggiore di come la immaginavo... Ti scriverò subito la mia risposta.";
D.q[1150] = "Il mio fattorino di forniture si è sbagliato e mi ha fornito il quadruplo di polvere guaritrice per famigli in più. Per non perdere tutto a causa di questo errore, rivendo la polvere al prezzo eccezionale di 1000 kama, dimmi se sei interessato.";
D.q[1160] = "Mamma quant\'è bello, quant\'è bello, quant\'è bello il mio recinto! Voglio che duri per sempre! Ma purtroppo, si sa, i cinghiali sono come i maiali. Più diventano vecchi e più diventano stupidi!\n\nHo bisogno di gioventù! Portami un cinghialetto, te lo comprerò ad un buon prezzo. Stai tranquillo, non ci perderai, parola di Nissacram.";
D.q[1168] = "Molto bene, ma prima, mi devi fare un piccolo favore. Aga Dou ha delle esche per me, ne ho bisogno rapidamente. Questo è il patto: portamele entro 5 minuti e ti insegnerò le basi del mestiere.";
D.q[1214] = "Ormai sei pronto per unirti ai nostri ranghi.\nIn che Ordine vuoi andare?\nI Guerrieri dell\'Ordine del Cuore Sanguinante, I Guaritori dell\'Ordine dello Spirito Malsano oppure l\'Ordine dell\'Occhio Putrido?\nAttenzione, questa scelta è importante, non potrai più tornare indietro!";
D.q[1215] = "Per unirti al nostro Ordine, devi mostrare il tuo valore portandoci un Occhio di Cuervoc.";
D.q[1217] = "Per unirti al nostro Ordine, devi mostrare il tuo valore portandoci un Pelo di Barba del Bwork Mago";
D.q[1245] = "Ciaaauuu, io sono la grande Paro Cabanne, generosa creatrice, incredibile stilista e profeta geniale. Che posso fare per una personcina come te?";
D.q[1250] = "Non sei molto intraprendente! Per fare una poltiglia basta macinare 4 fiori di Blop differenti in un frantoio Munster!";
D.q[1275] = "Allora #1, non hai voglia di farti rifare i denti?\nPer te costerà solo 10000 kama.\nNo, non rifiuto mai di aiutare un amico quando ne ha bisogno.";
D.q[1280] = "Dunque sei te #1 che devi lavorare questa settimana? Prendi le patate dal mucchio laggiù e sbucciale sul tavolo in fondo. \nQuando avrai sbucciato 200 pods, portameli.";
D.q[1299] = "Ciao #1, Amayiro mi ha parlato benissimo di te. Per questo ho già un piccolo lavoretto da affidarti.";
D.q[1312] = "Perché mi proponi dei soldi che non hai? Vuoi prendermi in giro? Stai violando una delle leggi più importanti: non prendere mai in giro qualcuno più forte di te! Per questa volta te la lascio passare, fila!";
D.q[1328] = "È un bel Champello! E io che credevo mi portassi un affare tutto bucherellato. Haha!";
D.q[1388] = "Un mago è appena passato correndo, non sono riuscito a fermarlo, andava troppo veloce per me. Ma tu puoi ancora farcela, è andato verso Nord-Ovest.";
D.q[1393] = "Ho intravisto da lontano un uomo vestito con un mantello blu che correva verso Nord. Era un Bontariano in fuga? Se è così, non ha scelto bene la strada: stava andando dritto nella Gola di Sidimote dove ci sono i nostri guerrieri.";
D.q[1402] = "Ecco il veleno in questione, metti il dolce nel suo buffet, ha l\'abitudine di farselo portare, lo troverà sicuramente domani mattina.\nBuona fortuna!";
D.q[1403] = "Sei veramente sicuro di voler obbedire ad un ordine dell\'intendente di Bonta?";
D.q[1404] = "Molto bene, troverò qualcun altro per questo lavoro.\nMa non azzardarti a parlarne in giro, altrimenti farai la fine di Rimaraf!";
D.q[1415] = "I Champelli? Sono i Maestri Boleto che li portano, ne troverai nei campi a Sud di Bonta.\nNon è necessario prendere un Champello da combattimento, uno qualsiasi andrà bene.";
D.q[1446] = "Dai, dai, un\'altra lezione ad un guerriero codardo. E tu cosa vuoi da me? Vuoi una lezione anche te? Naaah, sono stanco oggi, non avrai l\'onore di batterti con me.";
D.q[1471] = "Tutto qua? Sei venuto a Bonta solo per questo? Oto ti vuole morto, vero? Gli avrei spedito tutto domani con un kwak, come d\'abitudine. Vabbé, tieni, almeno non sei venuto per niente. E adesso vattene!";
D.q[1480] = "Eh, allora spero che il messaggio sia stato chiaro, ti tengo sempre gli occhi addosso, eheh. Guarda... c\'è qualcosa in più nel tuo zaino di occhi... UN GRAPPOLO DI UOVA! Ma sei un incosciente?! Sai cosa potrebbe succedere se si dovessero schiudere qui... ARGH TROPPO TARDI, cavoli tuoi!";
D.q[1491] = "Non me ne faccio niente dei tuoi calzoni, idiota. Una delle teste dirigenti ti chiama, non farla aspettare o mi divertirò ad ucciderti. Attualmente sta ispezionando il sotterraneo della torre.";
D.q[1495] = "Capisco... Capisco... bene, bravo, hai saputo mantenere il segreto che un superiore ti ha confidato. Sono fiero di te. Senti, non ho troppe cose da darti in questo momento. C\'è un piccolo viaggio oppure... Durante una spedizione su un\'isola lontana, avevo assaggiato un vinello delizioso che si chiamava \"Vino di Glutovora\", cerca di trovarlo e portamene un po\', te lo farò assaggiare. Promesso!";
D.q[1513] = "Ah, ho capito di cosa vuoi parlare, mio zio mi ha portato degli archi nuovi nuovi, e mi ha detto che dei miliziani sarebbero venuti a prenderli.\nMi ha detto anche di venderli a 1000 kama cadauno, \"gli affari sono affari\" come dice lui...\nAttenzione, non sono resistenti... probabilmente si romperanno dopo il primo combattimento.";
D.q[1538] = "Ciao #1, questa sera ho deciso di cucinare cervello di tartaruga, ma non posso andare da solo sull\'isola di Moon, in più se il cervello non è cucinato entro 5 minuti dalla morte dell\'animale, diventa immangiabile...\nMa per fortuna, tu mi darai una mano!";
D.q[1566] = "Hmm, vedo che sei un tipo intelligente, dì pure ad Amayiro che hai aggiustato tutto.\nTi darò tutte le entrate della settimana in cambio, ovvero 10000 kama...";
D.q[1599] = "Quando acquisisci un livello, il tuo personaggio diventa un po\' più potente. Acquisisci inoltre 5 punti da distribuire tra le caratteristiche e 1 punto di bonus che ti permetterà di aumentare la potenza dei tuoi incantesimi. Se vuoi, ti posso far vedere come usare i Punti Caratteristica. Altrimenti passa direttamente nella stanza successiva. Ti farò vedere come fare evolvere gli incantesimi!";
D.q[1601] = "Ti manca ancora un oggetto... Ti ricordo che devi indossare un amuleto, una cintura e una fascia.\nTorna da me quando avrai questi 3 oggetti.";
D.q[1617] = "Ecco, questo incantesimo non è concepito per l\'attacco, ma è comunque temibile.";
D.q[1621] = "Ciao, qual buon vento ti porta nella città delle nuvole? Insieme ad un amico sto lavorando su alcune pozioni capaci di farti muovere alla velocità del vento! Non dirlo assolutamente a Girle Pylota, lei usa solo roba meccanica.";
D.q[1629] = "Grazie! Mia madre diceva sempre: \"Se mangi delle Rougely e delle Vertgely non mangiarci mai insieme 4 Blugely insieme!\"";
D.q[1631] = "Grazie! Mia madre diceva sempre: \"Se mangi delle Blugely e delle Vertgely non mangiarci mai insieme 2 Rougely!\"";
D.q[1632] = "Come stai #1? Con un freddo così, non è molto saggio passeggiare per Amakna.\nAh, ho incrociato qualcuno stamattina che mi ha detto di salutarti... Oooh, non mi ricordo più il nome!! Aiutami, è l\'Anutrof più stiloso del villaggio! Ma se? No, veramente? Pazienza...";
D.q[1640] = "#1, ti aspettavo. Oltretutto so già cosa vuoi sapere, sei così prevedibile...\n\nSo anche che stavi per dimenticare i 100 kama da pagare per farmi una domanda, preferisco ricordarteli subito...";
D.q[1678] = "È facilissimo! Dei tofu appariranno in modo aleatorio, e cominceranno a sparire subito dopo. Lo scopo è di colpire i tofu prima che scompaiono. Ma attenzione! Devi colpire solo i tofu GIALLI, se colpisci un tofu ARANCIONE hai perso!\nChe sfida, vero?\nSe riesci a colpire 60 tofu senza errore, il primo premio sarà tuo.";
D.q[1686] = "Benvenuto alla Fiera del Trool!\nL\'entrata costa 10 kama per gli adulti. Per i bambini che passano sotto il braccio dello Yop, l\'entrata è gratuita! Attenzione, il biglietto vale solo 24 ore...";
D.q[1711] = "Il tempio Sàcrido è a Nord del villaggio di Amakna, non molto lontano da qui. Parla a Rihina Tayapert per continuare il tuo apprendistato.";
D.q[1713] = "Ciao #1, vedo che i miei fratelli hanno cominciato ad istruirti, ma devi ancora imparare molto. Prima di lasciarti avventurare nel resto della regione, mi piacerebbe lanciarti una sfida!";
D.q[1721] = "I discepoli di Feca sanno utilizzare tutte le armi, ma eccellono nella padronanza dei bastoni e delle bacchette.";
D.q[1746] = "Gli Aniripsa sono personaggi molto intelligenti, per questo cercano oggetti che aumentino la loro intelligenza.";
D.q[1773] = "Ho insegnato ai Dabol le tecniche di combattimento Etram. Così saranno degli ottimi avversari qualunque sia il tuo livello.";
D.q[1785] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[1791] = "Se vuoi affrontare un Dabol, devi donare un po\' di Fili di seta al tempio...";
D.q[1794] = "Siccome molti Ecaflip vogliono allenarsi con i miei Dabol, io chiedo una donazione prima di ogni combattimento per sopperire alle necessità del tempio.\nSe vuoi affrontare un Dabol, portami un trifoglio a 5 foglie.";
D.q[1815] = "Heltan, il Forgiatore del nostro tempio è scomparso in una faglia temporale, e da allora i miei Dabol rifiutano di combattere senza un piccolo Martello di Legnuccio...\nSe vuoi affrontarne uno dovrai procurarmi uno di questi martelli, in attesa del ritrovamento di Forge Heltan...";
D.q[1817] = "Amin vuole delle Pelli di Serpentina per decorare il tempio, e ancora una volta mi ha detto di chiederle a te... Ci sono giorni così... in cui Amin sogna di costruire templi piramidali o di scrivere con pittogrammi strani, è meglio non cercare di capire...";
D.q[1826] = "Se vuoi affrontare un Dabol, devi donare un po\' di Cuoio di Cinghiale al tempio...";
D.q[1827] = "Se vuoi affrontare un Dabol, devi donare un po\' di Cuoio di Pappatutto al tempio...";
D.q[1833] = "Se vuoi affrontare un Dabol, devi donare un po di Foglie di Furbazza al tempio...";
D.q[1849] = "*all\'improvviso capisci perché: la maomao rosa davanti a lui!\nMa come spingerla ad interessarsi a lui? Bisognerebbe far in modo che questo maomao attiri la sua attenzione.*";
D.q[1863] = "Ti sta troooppo beeene! Uaoh! Ho i brividi, sì sì. Ne farai innamorare un sacco così! Ma cerca di cambiarne spesso. I Sarti possono fabbricare molte creazioni che danno un look unico!";
D.q[1880] = "Niente muscoli, una briciola di cervello e si permette di interferire nel mio giochino? Sì, le ho cambiato io di posto! L\'ho messa nel giardino per evitare che i cani del vicinato la occupassero.";
D.q[1882] = "Oh santo cielo, grazie! Sono talmente preso dal mio lavoro che un giorno o l\'altro mi dimenticherò persino dove abito, haha!\nSiccome vedo che ti piace prestare servizio, non avresti mica voglia di portarmi un fiore di Dente di Leone Diabolico, ne vedo spesso nei campi a Nord-Est del villaggio...\nMi piacerebbe paragonare la composizione dei loro semi con l\'Epyss Selvatica che ho raccolto ieri!";
D.q[1899] = "Un orso hai detto? Ad ogni modo se vuoi ritrovarlo, la notte scorsa l\'ho visto andare verso Ovest. Grazie per il tuo impegno amico, sarai ricompensato come meriti!";
D.q[1904] = "Cercare, selezionare e comprare le farine giuste dai Contadini. Fare la pasta, amalgamarla, modellarla e poi cuocerla, questo è il lavoro del Panettiere. Ma attenzione: ognuna di queste tappe richiede un\'abilità e una tecnica particolari. Ecco perché esistono così tanti tipi di pane.";
D.q[1915] = "Tutti i candidati erano piuttosto scialbi. Penso che assumerò persone motivate giorno per giorno. C\'è molta domanda per questo genere di lavoretti! Potresti effettuare la prima consegna del giorno per me? Questa volta ti pagherò il doppio, e poi potrai tornare da me per fare un\'altra consegna subito dopo - sempre che tu lo voglia, naturalmente!";
D.q[1916] = "L\'entrata del nostro deposito di grano è bloccata dalle macerie, ma io devo continuare a dare da mangiare ai miei pappatutto aspettando che gli Anutrof la liberino. Visto che manca il grano, la birra potrebbe essere utile...\nPensi che potresti aiutarmi se ti do 10 kama? Ho bisogno di 5 birre. Prendi la meno cara, i miei piccoli preferiscono la quantità alla qualità.";
D.q[1919] = "Per creare gioielli bisogna essere abili, pazienti e avere un grande senso artistico... Ahimé, non sarò mai brava come Azra Lazarus del villaggio di Amakna...";
D.q[1936] = "Arrghhh... ho un mal di zezta increzibile, zembra quazi che mi abbia calpeztato un grezze di Alberagni...";
D.q[1951] = "Ti ringrazio infinitamente! Sai, sono veramente occupatissimo. Puoi andare a chiedere al Macellaio di uccidere uno dei pappatutto che gli ho affidato? A me fanno così pena... però mi piace tanto il sanguinaccio di pappatutto! Gnam! Altro che rinunciarci! Compra 2 limoni da Seth Surset! Tieni, ecco 5 kama per i limoni.";
D.q[1964] = "Ehi, stai facendo il galletto, pochi possono vedere i capi, soprattutto quelli di alto grado... Se lo vuoi veramente te lo concederò... ma per provare la tua buona fede dovrai portarmi 2500 kama, e darmi il tuo mantello strappato. Sennò puoi sempre invocare la regola della potenza, rahaha!";
D.q[1970] = "Ma per chi ti prendi? Io ti... hmm... aspetta, dici che per il taverniere questa birra è tutta la sua vita... interessante... Molto bene se accetta di rifornirci ad un prezzo veramente basso, non gliela ruberemo più. Se non vuole, convincilo. Vai!";
D.q[1985] = "Molto bene, ecco quello che dovrai fare: vai da Touh Flowa, un amico Sadida. Ti darà un fiore di Dizbi. Ma per avere l\'estratto, ti servirà l\'aiuto di Nibé Lulla, uno dei miei vecchi allievi, ora Alchimista. Passami la mappa, ti indicherò le coordinate di Touh Flawa... La bussola guiderà i tuoi passi.\nBuon viaggio.";
D.q[1987] = "Ti manca ancora una cosina prima di poter parlare con me da Aniripsa ad Aniripsa... Ah sì, ci sono: essere un Aniripsa!";
D.q[1991] = "I nostri amici Anutrof hanno dei problemi. Durante la loro ricerca hanno scoperto delle cose... che hanno ripercussioni inquietanti. Troverai un gruppo di scavo nelle gallerie sotto la città, ma non ci andare da solo, non è prudente... Tienimi al corrente dei tuoi progressi. Buona fortuna!";
D.q[1996] = "Ehi ciao! Come butta?! Vuoi un po\' della mia nuova invenzione? Con questa non avrai più bisogno delle tue ali per wiiizzzz... Ma a parte questo, per cosa sei venuto?";
D.q[2001] = "Sto pensando a nuovi metodi di lavoro per incoraggiare i miei dipendenti a fare meglio e di più... ma non basta mai, la domanda è troppo grande! Se vuoi farti qualche soldo, ho sempre bisogno di manodopera per consegnare le Pizzaye ai numerosi clienti della città!";
D.q[2035] = "Dicono che un Anutrof del cantiere sia stato trasformato in Minatore oscuro nei sotterranei! Ma lo sfortunato conserva sempre le vecchie abitudini: assaggia regolarmente l\'acquavite del taverniere. Devi portare una goccia del suo sangue a Nibé Lulla, l\'Alchimista. Saprà ricavarne qualcosa. \nMa prima di questo devi andare da Nibé per prendere la siringa, che userai dopo aver indebolito il Minatore oscuro. Ti ho indicato la strada per andarci. Non ti resta che seguire la bussola. Tienimi al corrente...";
D.q[2039] = "Eccoti di ritorno! Molto bene, fammi vedere! Perfetto... Procediamo all\'assemblaggio finale! ... Ecco! Una spada superba, abbastanza semplice ma... la spada non fa il guerriero dopotutto! Torna dal tuo maestro di classe, ti insegnerà a maneggiarla.\nBuona fortuna, e fai attenzione alle dita! \n*pensieroso*";
D.q[2045] = "Non guardarmi così! Cerca di saperne di più! Non devi far altro che andare da Joe Pierlivet, il Maestro di Classe Anutrof e proporgli i tuoi servigi... 3 o 5 colpi di pala ben presi e sarai in piena forma... Uohoh! Infiltrare, spiare... sarà la tua vita da Etram! Torna presto da me.";
D.q[2049] = "Ma vedo che non hai armi... Tieni, in quanto Ecaflip più vecchio, ti offro questa brosa di monete, potrai procurartene una... Allo stesso tempo, mi chiedo proprio se Chronokwarz non mi abbia preso in giro. Questo metallo potrebbe scomparire presto se nessuno se ne occupa!";
D.q[2050] = "Fatto? Hai il sangue del Minatore oscuro? Bene, lo analizzerò e manderò i risultati delle mie ricerche al tuo maestro.";
D.q[2061] = "Ah rieccoti! Fammi vedere la tua spada... Perdindirindina, è proprio una bella creazione! Ti do l\'onore di apporvi il marchio degli Ecaflip: sei dei nostri oramai! Eppure ancora non so cosa stiano confabulando gli Anutrof. Qualcosa mi dice che là sotto c\'è dell\'oro, ne sono sicuro! Perché non vai ad inaugurare la tua spada nei sotterranei? Ma stai attento: non rischiare la vita senza riflettere!";
D.q[2070] = "Yeah! Sei venuto per il bastone? Certo che sei venuto per questo... ok, ti fabbricherò un bastone con il legno di Arash che mi hai portato! Ahem! Allora, credo che si faccia così... un po\' a destra, un po\' a sinistra... *dubita*... e anche un po\' in mezzo... cred..., accidenti no! Sono sicuro! Ecco, ed è... ah sì! L\'incantesimo!... ahouummm ridi\' ke kos\' serv\' ke nn so dov\'è!...\nEcco!";
D.q[2077] = "Ah! Ti scoccio, vero?! Va bene... mi dev\'essere rimasto solo un pezzo di legno di Arash, ma stacci attento, è molto raro!";
D.q[2085] = "Mamma mia! Che brontolona questa Nepra! È fatta così, ma sotto sotto è brava... Ahahah! Grazie, ho un debito!";
D.q[2090] = "Ciao giovane Feca. Mi chiamo Fallanster. Mia figlia Allisteria mi ha detto tutto quello che hai fatto. Non ha avuto il tempo di portarti un sanguinaccio di Pappatutto, era già stato divorato tutto!";
D.q[2100] = "Ha, ha, sapevo che una persona sveglia come te avrebbe colto l\'occasione!\nBene, è semplicissimo, hai esattamente 10 minuti per fare la consegna ad Erty Trapchet che si trova nel parco al centro della città, se fallisci, pagherai la pizzaya di tasca tua!";
D.q[2108] = "Saketsu mi ha parlato del tuo arrivo. Mille grazie! Saprò come far parlare questa goccia di sangue. Certo, è come se parlasse...! Dopo qualche analisi, riuscirò a capire di quale male soffre quel povero Anutrof!";
D.q[2134] = "Hai quello che serve per l\'imbottitura? Ho bisogno di 5 lane di pappaton e del mantello che ti ho fabbricato.";
D.q[2137] = "Se continui a dimenticare tutto così, Joe ti spedirà in fondo alle miniere a divertirti con i Tofu degli Osamodas! Dai! Sbrigati! Vai da Clyde Peüs, il Feca!";
D.q[2151] = "Vai da Nibé Lulla, l\'Alchimista. Fonderà questi kama per fabbricarti una lama degna del tuo braccio. Ti ho indicato la strada, ora non ti rimane che seguire la tua bussola.";
D.q[2167] = "Bene, ora che hai una spada tutta tua, impugnala e vai ad uccidere due Arakni! Voglio vedere di cosa sei capace. Se te ne mostrerai degno, ti affiderò una missione più importante.";
D.q[2217] = "Hummmm, io sfioro la morte e tu mi parli di minerali? Ebbé, minerali, metalli, per un Minatore non c\'è niente di meglio! Nelle mani di un buon Alchimista, diventerebbero pozioni. Nelle mani di un Forgiatore di spade, diventerebbero lame taglienti... e spade! E di spade ne avremo proprio bisogno, dico io!";
D.q[2222] = "Cosa aspetti ad andare a portare la medicina agli Anutrof?";
D.q[2226] = "Hmm... cosa vuoi che ci faccia con questo arco? Non sono mica arciere...";
D.q[2261] = "Creare un gruppo ti permette di comunicare semplicemente e rapidamente con gli avventurieri che hai riunito durante una sessione di gioco.\nAttento a non confondere il \"Gruppo\" con la \"Gilda\". Il Gruppo è temporaneo, la Gilda è definitiva e sottomessa a certe regole.";
D.q[2263] = "Perché la gente deve avere capelli così diversi?\nHo recensito undici tipi di capelli diversi nel mondo, eccone la lista, sono sicura che sarai abbastanza abile da portarmene un ciuffo per ogni categoria!";
D.q[2273] = "Baaah... la vita è dura quaggiù. Sì sì... e se una creatura ti prosciugherà la vita, tu ingoierai la polvere. Devi sederti per ritrovare un po\' di salute. Mangia il pane che hai comprato in panetteria, bevi le pozioni di cura preparate dagli Alchimisti, e sentirai la vita scorrere dentro di te... se te ne resta, ovvio...";
D.q[2274] = "Delle voci, eh... se ne parla in tutta Astrub... però vabbé, non fidarti troppo dell\'apparenza delle creature che incrocerai... Se sei solo e poco esperto, non azzardarti a scocciare un vecchio Pappatutto, eh! Ti strapperebbe la pelle del sedere come un ciuffo d\'erba, e lo masticherebbe con piacere guardandoti dritto negli occhi... eh sì. *Nakuneul sembra pensieroso*";
D.q[2281] = "Ogni essere che attraversa queste terre deve cercare il suo dio, e onorare il tempio a lui consacrato con la sua presenza.";
D.q[2301] = "Nibé Lulla, l\'Alchimista dovrebbe riuscire ad elaborare una buona infusione a base di fiori di Dzibi. Vedrai, sarà deliziosa...";
D.q[2318] = "Si fanno panini buonissimi con le zampe di Arakne... sempre che non si abbia il palato fine! Direi persino che per sopravvivere è indispensabile averne qualcuna sempre con sé... per questo vorrei riempire un po\' il mio stock. Potresti portarmi 10 zampe di quelle bestiole ? ... dovrebbero bastare.";
D.q[2322] = "Gli Aniripsa mi hanno detto che non c\'era nessun \"Agentis Infectofus\" nelle piume di tofu malato... Non ho ben capito cosa significa, ma qualcosa mi dice che non c\'è niente da preoccuparsi. Gli Aniripsa potrebbero essere interessati alle loro uova... e anch\'io già che ci siamo, eheheh! Allora... vediamo... 10 uova di Tofu potrebbero andare.";
D.q[2331] = "Ci sono molte regole importanti da conoscere relative alla vendita degli oggetti.\n\nPer vendere degli oggetti in un mercatino, per prima cosa devi stabilirne il prezzo e la quantità che vuoi vendere. Ma fai attenzione perché dovrai pagare una tassa ogni volta che metti in vendita un oggetto.\nNon potrai recuperare il denaro di questa tassa se vendi l\'oggetto o se decidi di riprenderlo prima che sia venduto.";
D.q[2339] = "Hmm effettivamente si tratta proprio del manoscritto Osamodas di Invocazione dell\'Orso, grazie di avercelo riportato! Puoi dire a Mang Iapoco che le sue greggi non rischiano più niente!";
D.q[2359] = "Cacciare non è tanto semplice! Bisogna avere l\'arma adeguata per colpire l\'animale. Se lo ferisce troppo o lo uccide male, il Cacciatore non potrà raccogliere i pezzi di carne più buoni da vendere in seguito.";
D.q[2365] = "Laggiù, c\'è Amakna. Ti dirò, cominciano a sentirsi un sacco di storie sugli avvenimenti che accadono da quelle parti. Vedo che il tuo sguardo è pieno di curiosità, eh?";
D.q[2373] = "Vecchie storie queste solo sono! Riempirti la capoccia come gli altri tutti lasciarti non! La metà di cosa io so loro non sanno, e soprasotto cielo e terra per delle uova trovare  mettono... Rhaahrr kof kof *tosse catarrosa*";
D.q[2374] = "Hummm... Il Mondo degli Undici sta cambiando, sì. E così vorresti i Dofus? Dovresti pensare prima a rabbonire i loro guardiani, o a combatterli... Ma stai attento, i guardiani sono potenti e gelosi, solo degli avventurieri esperti possono sfidarli!";
D.q[2384] = "Sei sicuro di voler intraprendere la carriera di Forgiatore di Pale?";
D.q[2391] = "Ciao amico! Se vieni a trovarmi qui, è perché anche tu hai la febbre del Pescatore! O vuoi parlare con me di amore e altre cose?";
D.q[2393] = "Bene, ormai sei mio apprendista. Comincia con le piccole creazioni che ho disegnato nel tuo quaderno. Per intagliare devi possedere un\'Intagliatrice appositamente concepita per l\'opera che vuoi realizzare. Stai attento a non sbagliarti nella scelta dell\'Intagliatrice. Quando l\'avrai tra le mani, usa i banchi per intagliare quello che vuoi.";
D.q[2401] = "Sei sicuro di voler passare molto tempo al buio? Diventare Minatore è veramente una vocazione, sai?";
D.q[2411] = "Ciao, io sono solo un giovane apprendista... Se vuoi saperne di più sulla nostra arte, vai da Duedita. Puoi trovarlo al mercatino, passa tutto il tempo là dentro da quando è stato aperto.";
D.q[2413] = "Noi dividiamo i mestieri in due grandi categorie: i mestieri di raccolta e i mestieri di artigianato. La seconda categoria non può esistere senza la prima.\nTra i mestieri di raccolta ci sono: il Contadino, il Taglialegna, il Pescatore, il Cacciatore e il Minatore.\nNei mestieri di artigianato ci sono invece: i diversi tipi di Forgiatore, i diversi tipi di Intagliatore, l\'Orefice, il Pescivendolo, il Macellaio, il Tuttofare, il Ciabattino e il Sarto.\nIl mestiere di Alchimista ha uno statuto particolare perché è insieme mestiere di raccolta e mestiere di artigianato.";
D.q[2414] = "Un mestiere di raccolta consiste nel raccogliere la materia prima direttamente sul posto. Ad esempio, un Minatore andrà a picconare le vene di metallo nelle miniere, l\'Alchimista andrà a raccogliere i fiori nella foresta, e così via. Quella materia prima, dopo una leggera trasformazione, (il grano in farina ad esempio) è pronta per la vendita e servirà soprattutto per i mestieri di artigianato.";
D.q[2421] = "Questo mestiere consiste evitendemente nel tagliare alberi. Il legno così ottenuto serve per numerosi mestieri di artigianato: agli Intagliatori come materia prima per bastoni, bacchette e archi, ai Forgiatori come materia secondaria per le impugnature delle armi. Le applicazioni, insomma, sono varie e la richiesta è sempre grande. Tagliare un albero però richiede molto tempo e alcuni sono abbastanza rari.";
D.q[2440] = "Il Pescivendolo prepara il pesce che il Pescatore gli porta. Lo cuoce e lo condisce. Il pesce è un alimento molto nutriente e rivitalizzante. E in più, a sentir quel che si dice... rende più intelligenti.";
D.q[2462] = "Ciao! Anche tu ami la dolcezza del bosco? Allora vai da Oli Venders, è il migliore Taglialegna di Astrub. Se sei sveglio, potrà dedicarti un po\' del suo tempo per insegnarti le basi del mestiere. Ti ho indicato il cammino, devi solo seguire la bussola.";
D.q[2467] = "Ciao amico!\nSe come me senti il sangue ribollire nelle vene, ti consiglio vivamente di andare da Saketsu, il nostro maestro di classe. Saprà mostrarti qual è il tuo destino. Posso indicarti dove si trova se vuoi. Non dovrai far altro che seguire la tua bussola. Ma attento è una vera macelleria là dentro!";
D.q[2469] = "Impari in fretta, giovane #1. Penso che tu possa fin d\'ora andare alla città di Astrub. No, aspetta! Non dimenticare che questo mondo è popolato da numerosi avventurieri come te. Non esitare a parlare con gli altri grazie alla zona di comunicazione (in basso a sinistra). Alcuni avranno bisogno di aiuto, altri aiuteranno te e altri ti proporranno persino delle missioni. Comincia a dare un\'occhiata vicino alla statua, ne troverai sicuramente qualcuno...";
D.q[2471] = "Va bene, ok. Se vuoi veramente dimostrare il tuo valore, vai da Vuoiun Amission. Ha un sacco di problemi... *sospiro*. Potresti dargli una mano... così quando sarai più forte potrai venire ad aiutare anche me...";
D.q[2478] = "Pare che a Pandala facciano fermentare delle larve blu nella bava di pappatutto, e che siano anche buone! La prima cosa che farò andando su quest\'isola è tracannare st\'alcool, per mille Anutrof! Ma tutto ciò non ci dice dov\'è finito Toyo Dzink. Se non torna con l\'ambra, non riusciremo mai a ristrutturare questo ponte!";
D.q[2484] = "Cerchi l\'Ambra da queste parti? Mi sa che devi andare verso il Sud di Amakna per trovarne... verso la foresta.";
D.q[2504] = "Perfetto! Portando questo Pandawa, mostri di aver pagato la tassa! Adesso ti consiglio di andare dallo Sciamano Surivitna. Questo strano rumore viene dal tuo stomaco, vero? È ciò che succede quando si porta un Pandawa a Pandala senza essere un Pandawa di Pandala: si prende la Pandrista...";
D.q[2511] = "Siiiiiiiiiii io sono Pyrita! I sotterranei di Astrub! Il ratto d\'Isgustoso! Eh sì! Ti siamo veramente grati! Bene... ho sentito la tua conversazione con lo Sciamano e dovresti andare dal Grandapan. È lui il capo di tutto qua. Se sei in cerca dei Dofus, e penso che sia proprio così, vai da lui, probabilmente ti darà qualche informazione interessante.";
D.q[2517] = "...il ricettacolo dei Dofus è ormai accessibile a tutti! Un sacco di gente vuole vederlo e vuole comprare i souvenir della nostra isola! (Si frega le mani). Lodato sia il Grandapan! Mmh... Posso aiutarti?";
D.q[2518] = "...Che manna questa leggenda sulle uova di drago! Presto i nostri forzieri esploderanno di soldi! Mmh... desideri un\'informazione?";
D.q[2536] = "Il Grandapan sa molte cose! Hai visto l\'autentica reliquia dei tempi antichi, il nostro ricettacolo dei Dofus? Non è la prova che legittima la leggenda? Vai pure a vederlo con i tuoi occhi, finirà di convincerti. Oh!? Hai sentito la saggezza entrare dentro di te contemplando l\'antica statua della nostra dea? Devi assolutamente vederla al più presto!";
D.q[2543] = "\"Se torni con una fiala in mano, ti voglio tanto bene\", è un proverbio di Aksadala che probabilmente conoscevi! Fammi un po\' assaggiare... Glu glu glu! Ma è acqua! Acqua in una fiala di Pandapiler! Sacrilegio! Eresia! Non hai mica la testa tu a posto, tu? Di questo passo te la taglierò!";
D.q[2548] = "Mmh... cambiamo argomento: il saggio Volpo è contento della battuta che hai fatto al maestro di Aksadala... \"Digli di andare a Erdala e scherzare anche con il capo...\" a meno che non abbia detto Terradala, con il suo accento... non sono sicuro... Vabbé, cerca di fare attenzione!";
D.q[2558] = "Non negare! So che hai portato uno di quei maledetti Dofus sulla nostra isola! Ti hanno visto uscire dalla casa dello Sciamano! Hai infranto la regola n°1 dei Pandikaze: \"Niente Dofus a Pandala\". Ti condanno all\'ingestione di Pandweiser fino alla morte! Sarai giustiziato domani. Portatelo in prigione e buona notte!";
D.q[2563] = "Eh sì! I Dofus elano fino a poco tempo fa solvegliati dai dlagoni... Ma la Stolia si è plesa la bliga di distlibuilli ai quattlo angoli del Mondo. Olmai sono nelle mani di cleatule senza fede né legge, folli e distluttlici... Un tempo questi Dofus elano poltatoli di un\'aula di almonia sul mondo. Olmai questo tempo è finito...";
D.q[2572] = "I Dofus elano fino a poco tempo fa solvegliati dai dlagoni... Ma la Storia si è plesa la bliga di distlibuilli ai quattlo angoli del Mondo. Olmai sono nelle mani di cleatule senza fede né legge, folli e distluttlici... Un tempo questi Dofus elano poltatoli di un\'aula di almonia sul mondo. Olmai questo tempo è finito...";
D.q[2576] = "Hai capito: il Dofus non ha mai lasciato Pandala... è ancola sull\'isola. Un Dofus bianco, immacolato, che nessun essele ha toccato da anni e anni... L\'ho nascosto nel dongione della penisola, a Nold-Est di Pandala. E i Pandikaze, maledetti banditi, hanno sabotato il ponte... e quando ho saputo che il Dalk Vlad possedeva un Dofus, ho cleduto che se ne fosse impadlonito!";
D.q[2588] = "Hai percorso un lungo cammino, discepolo, ma sei sulla buona strada: quella che porta alla foresta malefica... Prima di avventurarti là dentro, dovresti parlare col nostro addestratore di Dabol. Allenati con una di queste bestioline: non c\'è niente di meglio per migliorare le tecniche di combattimento! Ne avrai bisogno laggiù: dicono che quella foresta sia dimenticata dagli dei...";
D.q[2591] = "Hai percorso un lungo cammino, discepolo, ma sei sulla buona strada: quella che porta alla foresta malefica... Prima di avventurarti là dentro, dovresti parlare col nostro addestratore di Dabol. Allenati con una di queste bestioline: non c\'è niente di meglio per migliorare le tecniche di combattimento! Ne avrai bisogno laggiù: dicono che quella foresta sia dimenticata dagli dei...";
