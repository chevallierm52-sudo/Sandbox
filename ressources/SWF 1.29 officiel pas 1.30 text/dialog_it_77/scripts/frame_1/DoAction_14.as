D.q[1982] = "Non so chi tu sia, ma anche se sei riuscito ad entrare qui, dubito che tu riesca ad uscirne così facilmente...";
D.q[2468] = "Non ho il tempo di parlarti. Lasciami...";
D.q[446] = "Non ho bisogno di nient\'altro, però colleziono cinture, Cinture di Fortuna per essere precisi. Se me ne trovi un centinaio, ti darò una Piccola Pergamena di Intelligenza.";
D.q[2837] = "Più tardi!";
D.q[5169] = "Non capisco. Perché nessuno vuole la mia birra? Ci sono dei veri pezzi di ferraglia dentro!";
D.q[6758] = "Cosa? Non ho niente da dirti.";
D.q[1343] = "Lascio perdere, sei una preda troppo grossa per me, mi butto sulle arakni.\nMuhaha!";
D.q[2480] = "Strano che questi bambù si screpolino così velocemente. Non ho mai visto una cosa del genere: sembra quasi che siano stati rosicchiati da una bestiolina. Per fortuna noi Anutrof ci sappiamo fare. Un po\' d\'ambra, e sono come nuovi!";
D.q[3100] = "Non so cosa stia cercando questo squalo. Uno scaricatore marinato alla birra?";
D.q[495] = "Non ho nessuna lettera da consegnargli per adesso.";
D.q[492] = "Ho regolarmente dei messaggi da inviargli, se gli consegni questa missiva, riceverai 200 kama e aumenterai la stima che il nostro clan già ti porta. \nLo troverai sulle montagne.";
D.q[1875] = "Spero che tu conosca il colpevole.";
D.q[3178] = "Hei, Ciao avventuriero, come stai? Mi chiamo Mawy, sono nata sull\'isola dei Wabbit, e il celebre Farle Ingals è mio zio. Incredibile vero? Scommetto che ti piacerebbe visitare la mia fattoria! Ma ti servirà una chiave per entrarci, io ho perso la mia in mezzo ai campi la settimana scorsa, rotolando con il mio amante in mezzo al grano... Con un po\' di fortuna, potrai ritrovarla, a meno che una cattiva creatura dei campi non l\'abbia già presa. Se così fosse, dovrai sicuramente andarla a cacciare per recuperarla.";
D.q[6321] = "È per me? Oh, grazie. Dici che Amayiro è molto soddisfatto del mio lavoro e che mi offre questo premio d\'incoraggiamento? Ed io che pensavo di non essere all\'altezza e che volevo diventare domatore di Pìu, ora mi sento rassicurato.\nNon è tutto ma ho un lavoro da finire e devo vedere Duedita per sistemare degli affari importanti. Abbiamo appena ricevuto del nuovo minerale di una migliore qualità rispetto al precedente e nuovi strumenti e in più devo fargli firmare le ricevute. Non posso lasciare la fucina senza sorveglianza, quindi devi uscire. Se hai bisogno del mio aiuto, non ci sarò per un po\', quindi è inutile aspettarmi, torna più tardi.";
D.q[2564] = "So che una di lolo vive nella folesta malefica. Tlovala e ti dilà quale Dofus possiede... semple che tu non diventi folle! Segui il mio consiglio e vai a meditale nel tuo tempio pel plepalale questa avventula. Quando salai davanti alla cleatura, falle questa semplice domanda: \"nelle pupille di Lazeliana si lifletteva un tempo un colole... Qual è questo colole?\". Poi polta la lisposta al Saggio Volpo di Focodala! Buona Fortuna!";
D.q[3326] = "La mia nuova mappa del mondo starà benissimo appesa in bagno!";
D.q[2142] = "Sì, sì! Lo so, ne sono al corrente, sei già passato da me! Alla tua età non sarai mica già così rincretinito come il vecchio Joe?";
D.q[375] = "Mi serve soprattutto della Gelatina Celeste, siccome non ha molto gusto, si può mettere un po\' ovunque. Ma me ne serve molta, e la prendo solamente a lotti di 100 unità.";
D.q[6520] = "Perchè non prendi uno sgabello e non giochi con noi? Più sei pazzo e più riderai. Ahahaha.";
D.q[2899] = "Devo occuparmi del passaggio di grado di numerosi adepti. Se vuoi provare di nuovo, torna da me come minimo tra quattro ore!";
D.q[401] = "Ho bisogno di 45 Pelli di Larva Blu, 45 Pelli di Larva Arancione, 45 Pelli di Larva Verde e 30 Ali di Tofu Malefico.";
D.q[6527] = "Buongiorno, ti ha mandato Oto Mustam?";
D.q[6529] = "Grazie, e credimi, non dimenticherò la tua clemenza.";
D.q[1452] = "Ho detto minimo 10 cortecce!";
D.q[2280] = "Sto pregando... Siamo ad immagine e somiglianza degli dei che ci hanno creato, e dovremmo sempre ascoltarli... Per capirlo, mi è costato un pezzo d\'orecchio, ma ho guadagnato la fede!";
D.q[6702] = "Niente da segnalare!";
D.q[286] = "Io dico. Io bewe una tazza di acqua calda giovedì, con un batuffolo di latte.";
D.q[2776] = "Ah capisco, se vieni con la raccomandazione di un maestro del tempio, ti lascerò passare.\nMa solo per questa volta!";
D.q[1583] = "Spendo tutto il mio salario dai Sarti del quartiere, sì insomma... quello dei miei genitori...";
D.q[3097] = "Non avrei dovuto bere così in fretta. Un po\' d\'acqua mi rimetterà in sesto.";
D.q[2664] = "Penso proprio che installerò un meccanismo per proteggere l\'entrata dell\'orologeria, ci sono sempre più persone in questo villaggio che la scambiano per un mulino!\n\nNon ho molto tempo per te, sono il guardiano del tempo e non posso distogliere lo sguardo da questi orologi... cosa vuoi?";
D.q[1315] = "Capisco, vuoi il mio Polmone delle Pianure. Piuttosto la morte!!! In guardia!";
D.q[6530] = "Ancora grazie per la tua clemenza, questo gesto avrà più impatto di quanto tu non creda.";
D.q[2042] = "Sì, è vero, me lo stavo scordando. Tieni, ecco una siringa da pappatutto. Non  è molto fine, ma farà al caso tuo. Torna da me con il sangue... saprò come farlo parlare. Certo, è come se parlasse...! Dopo qualche analisi, riuscirò a capire di quale male soffre quel povero Anutrof!";
D.q[3231] = "Ho visto come ti batti, e onestamente sono allibito.\nNo, non scherzo. Non sai di niente, ti vesti male, hai un accento orribile... mi fai pensare a quegli ignoranti che vengono dal sud! Per fortuna, sai batterti, il che compensa un bel po\' di cose...\nBene, suppongo che tu voglia uscire di qui, vero?";
D.q[3510] = "Metterò insieme una creatura intelligente che soddisferà tutti i miei criteri.";
D.q[4489] = "Ultimamente non l\'ho visto, ma è un uomo occupatissimo... insomma, mi sembra. Mi dispiace non poterti aiutare di più.";
D.q[4074] = "Mi piacerebbe travestirmi da Koalak, e per farlo avrei semplicemente bisogno di una panoplia Koalak!\nPortami una panoplia Koalak completa e in buono stato, e forse ti perdonerò.\nSe sarò di buon umore, ti darò anche uno dei miei vecchi famigli, ma è molto difficile da nutrire, morde molto forte, puzza e non è abbastanza bello per me. Ma sono sicuro che a te piacerà.";
D.q[1283] = "Ti vuoi veramente battere con me? Se è così, entriamo nella casa che si trova dietro di me. È la sala dove mi alleno di solito.";
D.q[2735] = "Mettere piede in un posto simile, io? Mai! Ma mi sono informato presso gli autoctoni sulla strada più corta. Tengo a precisare che le mie ricerche sono state molto selettive: ho interrogato solo coloro che dicevano di essere ritornati dalla foresta E A CUI MANCAVANO DEGLI ARTI.\nSiccome mi stai quasi simpatico, ti affido quest\'opera che non ho mai avuto il tempo di finire. C\'è solo questa strada che porta alla radura del Dark Vlad, ma dubito che ci siano cose interessanti laggiù.";
D.q[2446] = "Dimmi, quale mercatino stai cercando?";
D.q[4880] = "Ti ricordi del Corno magico trovato sull\'isola di Moon ? Siccome Brakmar sa che è nelle nostre mani, ma ignora il suo potere, ho escogitato un sotterfugio per far credere ai nostri nemici che ha dei poteri sorprendenti. Però mi servono delle persone di fiducia per la messa in scena. Trovamele. Si tratta del Capitano Koda, di Turi Ordin, della gioielliera Marge Gondersun e del miliziano Niamuh Bulkier.";
D.q[722] = "Eccomi di ritorno #1, i miei superiori si complimentano con te. Questa settimana insegno a maneggiare il bastone ai miei uomini, mi servirebbero una ventina di bastoni di legnuccio, so che conosci qualche Intagliatore. Non c\'è fretta, ne ho bisogno tra qualche giorno.";
D.q[4580] = "Uno dei miei manuali, grazie. Come promesso ti aiuterò. A condizione che tu mi possa portare ciò di cui ho bisogno. Mi serve della Stoffa Magica, un Sarto potrà confezionartela con questa ricetta. Mi serve anche una Tintura Magica Arancione. Questa ricetta è poco conosciuta dagli Alchimisti perchè il mio amico Uba Tessé l\'ha dimenticata a casa mia. Te la regalo volentieri, per ringraziarti di avermi riportato uno dei miei manuali.";
D.q[6511] = "Una sala da gioco? Non so chi ti.. ah, sei tu! Perdonami, ti chiedo scusa, non volevo mentirti. E\' che... non posso parlarne a chiunque, capisci? Tieni, qui c\'è la chiave per entrare anche se io non ci fossi, la porta nascosta è in fondo alla sala. E\' sempre un piacere ricevere un Brakmariano del tuo rango nella nostra taverna. In ogni caso finisco il mio turno verso le 21.30 – 22.00, te lo dico nel caso in cui...";
D.q[6519] = "Una Etram dici? Si, mi dice qualcosa, l\'ho intravista una volta o due. L\'ultima volta che sono venuta si è intascata un grosso sacco di kama ed è scattata una rissa. Ovviamente io non ho partecipato a quella rissa, per chi mi hai presa? Io... io non avevo la mia arma con me, e allora ho preferito restare in disparte per osservare ed assicurarmi che la rissa non degenerasse.";
D.q[3068] = "Non ho proprio fortuna con le donne. A questo punto preferisco che inviti il mio amico Ghedin Lursgrò. E se riesci ricordati di portarmi anche un po\' di birra.";
D.q[3127] = "Finalmente, eccoti #1!\nSono Oshar Marif, un illustre Allevatore di Dragacchini! I Dragacchini sono la mia passione!\nSono contento che alla fine tu sia arrivato fin qui per aiutarmi, ho perso un terribile combattimento contro il Culosse, e sono talmente stanco che non riesco neanche a tornare da solo al Villaggio. Avrei bisogno di aiuto...";
D.q[4067] = "Mi spiace, ma tu non possiedi gli ingredienti necessari che servono per creare la pozione giusta.";
D.q[3128] = "La sola cosa che possa aiutarmi a ritrovare le forze, è una Tisana di Kalipto.\nSembri sorpreso #1! Eppure tutti sanno che una Tisana di Kalipto permette di ritrovare le forze!\nEcco cosa ti propongo, sbrigati a portarmi 50 Foglie di Kalipto e 50 Fiori di Kalipto in modo che possa farmi una bella Tisana e renderti partecipe del mio immenso sapere sui Dragacchini!";
D.q[4583] = "Hai l\'aria un po\' pallida per essere un membro della milizia di Brakmar. Ti è andato un Kralamore di traverso, per caso?\nAh, mi hai portato i documenti che i Bontariani hanno rubato, ma non dovreste essere in tre? Suppongo che gli altri due si siano fermati alla taverna. Raggiungili, passerò questi documenti a Fraka Kyper quando finirà la sua meditazione.";
D.q[1953] = "Sono un fattorino di birra, oggi ho deciso di passare, e passo!";
D.q[3160] = "Ciao #2. Mi chiamo Klako, e sono uno dei migliori Cacciatori di Dragacchini della regione. Il mio amico Oshar Marif, il celebre allevatore, si è avventurato nella caverna del Culosse, ma non è mai tornato. Se tu potessi andare ad aiutarlo o a raccogliere le sue spoglie, te ne sarò riconoscente. Ma solo riconoscente, non ti aspettare che ti faccia uno sconto sulle mie reti!";
D.q[6374] = "Vuoi sapere qual è l\'alimentazione di una tartaruga? Ahahah. Mangia gli idioti come te. Ohohoh.\nMi hai fatto la domanda seriamente? Vedo... Conosco un piatto di cui non ne avrà mai abbastanza, si si. Pesce su un letto di insalace, te lo scrivo sulla sabbia. Ohohoh la mia nave ohohoh..\nSei soddisfatto?";
D.q[6381] = "Sento la collewa scowwewe in te. Sei fwustwato nella tua condizione infewiowe e wowwesti che la gente ti amasse e ti temesse ? Abbwaccia la via delle tenebwe e tutto ti diventewà più facile. Le pewsone si pwostwewanno ai tuoi piedi, i tuoi nemici twemewanno solo nel sentiw pwonunciawe il tuo nome, sawai depositawio di un potewe che oltwepassa la comune compwensione.";
D.q[7065] = "Torna più tardi. Sto giocando a Carta Forbici e Sasso contro Thomas Sacro e ha solo un punto più di me.";
D.q[6667] = "Ascoltami bene, quel che ti dirò deve restare fra noi. Nessun altro dev\'essere al corrente che io rischio il posto e tu la testa, hai capito bene? Ora vai da Amayiro, alla milizia di Bonta, e digli che ti mando io.";
D.q[4596] = "Ah che catastrofe! Allora è stato raggiunto. Peccato che tu non sia riuscito a sconfiggerli... Anche Oto Mustam deve essere sulle tracce del Corno Davola, altrimenti perchè ci avrebbe rubato quei documenti? Abbiamo senza dubbio ancora un po\' di vantaggio sui nostri nemici, meglio approfittarne.";
D.q[4098] = "Ho sentito parlare di un mondo in cui il nostro popolo è cacciato per la sua pelliccia, ma è ridicolo!";
D.q[1432] = "Non ho più niente da dirti #1, e comunque sono troppo occupato.";
D.q[4491] = "I Brakmariani cercano di prendere il controllo della Baia di Cania e del Territorio dei Dabol per bloccare l\'accesso al porto e far man bassa sul traffico marittimo da questo punto. Ho già mandato lì una pattuglia e vorrei che tu gli andassi a dare man forte. Quando la battaglia sarà finita, vai a fare un primo rapporto a Mel Aghignavon, poi torna qui.";
D.q[2503] = "Non so più come dirti che la tassa si paga comprando un copricapo Pandawa.";
D.q[3860] = "Tu, visitatore di Incarnam, se trovi una pelle di Milimilupo, portamela! Sono sicura che troverò qualche cosa di molto interessante da darti.";
D.q[3602] = "Esistono numerosi mestieri, ma io conosco solo questo. Per imparare gli altri, dovrai attraversare il mondo alla ricerca di altri maestri. Ce ne sono di molto bravi ad Astrub.";
D.q[1796] = "Se vuoi affrontare un Dabol, portami una trota.";
D.q[5614] = "Salve, la famiglia Terra ha accettato di aiutarci?";
D.q[1797] = "Se vuoi affrontare un Dabol, portami una Carpa d\'Iem.";
D.q[1781] = "Se vuoi affrontare un Dabol, devi donare un po\' di Lane di Capo di Guerra Pappatutto al tempio...";
D.q[1675] = "Molto bene, mettiti davanti alla roulette Pappatutto, e gira la ruota!";
D.q[1824] = "Se vuoi affrontare un Dabol, devi donare un po\' di Cuoio di Cinghiale delle Pianure al tempio...";
D.q[1825] = "Se vuoi affrontare un Dabol, devi donare un po\' di Cuoio di Porkass al tempio...";
D.q[637] = "Se vuoi delle ricette ti consiglio di fare un giro alla biblioteca. Un Alchimista ha scritto un\'enciclopedia sulle ricette rare in più di 12 volumi.";
D.q[3752] = "Se vuoi imparare un altro mestiere, vai da Gilles nell\'atelier dell\'albergo. Lui potrà aiutarti.";
D.q[5782] = "";
D.q[1854] = "Oh davvero? Sei proprio gentile, ma fai attenzione... sono comunque feroci.\nKwikwi sarà proprio contento.";
D.q[2816] = "È per un\'offerta alla dea?";
D.q[1992] = "L\'ha fatta uscire dal coma, ma i suoi sensi sono ancora sottosopra. Cosa si può fare?\nPuoi tornare da Nepra? Cercherò di confortarla in attesa del tuo ritorno.";
D.q[1541] = "Ah, vedo che hai ricevuto il mio messaggio...\nSì, devo chiederti una cosa, ma niente di complicato... sai che le elezioni si avvicinano, e vorrei che tu interrogassi Paro Cabanne per sapere se mi verrà rinnovato il mandato o no...\nLa maggior parte delle sue predizioni si sono avverate, quindi puoi fidarti.";
D.q[4246] = "Notte affascinante, vero?";
D.q[3202] = "È un labirinto molto complesso, quindi ascolta bene quello che ho da dirti! \nDevi metterti su una delle pietre per entrare nella sala corrispondente. Il Labirinto è composto da 25 sale che formano un grande quadrato. Non puoi aprire le porte della tua sala, ma solo le porte della sala successiva. Quindi è necessario che altri avventurieri aprano la porta della tua sala. Chiaro no?";
D.q[1878] = "Marp è una piccola burlona, ha un\'anima buona ma, detto tra di noi, è un po\' insolita...";
D.q[950] = "Posso aiutarti?";
D.q[2040] = "È inutile tornare senza spada, giovane Yop!";
D.q[685] = "Ecco un\'icona che venero perennemente\nIl tuo spirito si innalza in questo presente\nAdesso devi lavorare sulla tua comunicazione\nChe sarà indispensabile per questa comunione";
D.q[2493] = "Bel posticino qui, vero?";
D.q[7073] = "Non ti sembra che questa roccia assomigli ad un bastimento che affonda? No? Strano, a volte ho delle visioni silenziose in cui mi vedo sulla prua di un vascello, il viso colpito dagli spruzzi. Insomma, cosa vuoi?";
D.q[3115] = "Non è mica poi così complicato consegnare le patate.";
D.q[960] = "Posso aiutarti?";
D.q[951] = "Posso aiutarti?";
D.q[4187] = "È stato quell\'odioso Cavaliere Nero e Rosa che mi ha soprannominato così, non è il mio vero nome, non mi chiamo Peggy la Porkass!\nVoglio vendicarmi, la mia reputazione di pilota di Scareoplano è completamente rovinata a causa di quell\'imbecille, devi fare qualcosa per me.\nPotresti andare ad affrontarlo e metterlo in ridicolo davanti a tutti?";
D.q[1958] = "Fai te... ma io non ricordo che il mio maestro si sia mai lasciato scappare una preda. Dai, fai il bravo! Così rischio di prendermi una strigliata.";
D.q[397] = "È gentile da parte tua. Allora, mi servirebbero: 60 Pelli di Larva Blu, 50 Pelli di Larva Arancione, 50 Pelli di Larva Verde, 40 Ali di Tofu Malefico e 30 Sangue di Vampiro.\nSe mi porti tutto questo, ti darò una pergamena molto potente.";
D.q[2427] = "L\'Orefice fabbrica anelli e collane, quasi sempre magiche. Dai semplici anelli di metallo alle collane che racchiudono terribili poteri elementari, questo mestiere attinge la sua essenza dal metallo, dalle pietre preziose e dai materiali magici. È quindi un mestiere dispendioso e difficile.";
D.q[1034] = "Cosa può fare Musa, il Predatore di Lupi, per te?";
D.q[676] = "Imparare cosa? Vuoi imparare a lavorare la maglia! Ma io faccio solo il ricamo! Questo è il mio segreto... Vuoi imparare il mio segreto?";
D.q[2243] = "Lasciami riposare e vai a portare il legno al mio apprendista, lui sa cosa ne deve fare.";
D.q[1046] = "Non hai vie di mezzo, eh? Dimmi, di quanta polvere hai bisogno?";
D.q[1978] = "Vediamo... non hai il cappuccio, né l\'aria subdola, mi sembri onesto... forse troppo.";
D.q[3524] = "Titi deve diventare primo magoblin.";
D.q[1981] = "Locetta è una miliziana di Bonta. È tornata da una delle sue missoni con una specie di malattia. Trovava tutti i cibi senza sapore, ma i medici non ci videro niente di anormale. L\'indomani però le sue orecchie fischiavano in continuazione e dovevamo scrivere per comunicare. Poi fu la volta della vista... poi la parola... e alla fine perse conoscenza...";
D.q[3183] = "Messer Cuervoc passeggia nelle diverse sale di questa biblioteca. Fortunatamente per te, ti accompagnerò in ogni sala per dirti dove si trova Messer Cuervoc. Mi raccomando, avvertimi quando ti sentirai confuso.";
D.q[2152] = "Marp, spiegami subito tutto questo!";
D.q[3146] = "Che Rushu bruci i tuoi ultimi brandelli di coscienza! Come hai osato attaccare delle Sadidine così giovani e indifese. \nHai persino osato rompermi il boomerang, dovrò aspettare fino al prossimo compleanno per farmene regalare un altro dal maestro Skunk!\nLontano dai miei occhi, aguzzino di bambini!";
D.q[3482] = "Solo al mondo, povero Krazybwork abbandonato.";
D.q[1726] = "I discepoli di Ecaflip sanno utilizzare tutte le armi, ma eccellono nella padronanza delle spade e delle daghe.";
D.q[2845] = "Mmh... farei volentieri un pisolino...";
D.q[2742] = "Che mille bambù ti accarezzino la schiena, nobile guerriero! Lascia che te lo dica, mi sei proprio simpatico...";
D.q[2930] = "Che il fuoco sacro ti pervada, che il suo calore ti conforti e che la sua fiamma divina ti illumini!";
D.q[466] = "Aliciao, ne hai fatta di stlada, posso accompagnalti da qualche palte?";
D.q[1727] = "I discepoli di Aniripsa sanno utilizzare tutte le armi, ma eccellono nella padronanza delle bacchette e dei bastoni.";
D.q[6503] = "Sono trasferito alla Torre di Bonta? Ai tuoi ordini!\nDevo fermare chiunque esca dalla Torre? Ai tuoi ordini!";
D.q[6082] = "";
D.q[1051] = "Naaaah! No poter pallar co\' te, sei trop cattivo cattivo! E io c\'ho la boka tuda siecca.";
D.q[6888] = "";
D.q[2906] = "Bravo, mercenario!";
D.q[2908] = "Bravo, mercenario!";
D.q[6939] = "";
D.q[1386] = "Niente da segnalare qui.";
D.q[1389] = "Niente da segnalare nei paraggi.";
D.q[6922] = "";
D.q[6083] = "";
D.q[2675] = "Che la schiuma della pinta celeste soffochi te e i tuoi discendenti per secoli e secoli! Si direbbe che hai cominciato bene... ma dopotutto non hai altra scelta!";
D.q[713] = "Forse potresti aiutarmi di nuovo. Sembrerebbe che Donna Clude, la tenutaria della taverna della Bagrutta, a Nord-Ovest della città, sia importunata da un ubriacone in questi ultimi tempi. Potresti andare da lei e informarti sull\'accaduto?";
D.q[2033] = "Forse puoi aiutarmi... C\'è qualcosa che non quadra in questa città, ma se mantieni il sangue freddo, tutto andrà bene. So che nei sotterranei accadono cose strane...";
D.q[7143] = "Forse non sai dove si trova il nostro tempio. Eppure non c\'è niente di più semplice. Basta aprire la cartina, tutti i luoghi di classe, compresi i templi, sono indicati.";
D.q[3560] = "Me capo, te no!";
D.q[3562] = "Me è capo Bwork! Tu dare regalo, me capo!";
D.q[5473] = "Me venire ogni tanto, me piacere Parco. Me piacere Parco e Mele!... e barzellette anche!";
D.q[3499] = "Me non piacere chiacchierone.";
D.q[3491] = "Me mal alla testa, *sbadiglia grattandosi la testa* me volere mammina.";
D.q[5475] = "Me piacere parco e piacere buona mela e piacere barzelletta divertente!";
D.q[5472] = "Me piacere piccolo Parco!";
D.q[3518] = "Me volere mangiare tuo cuore, non mio!";
D.q[3630] = "Me non venire con tu. Me preferire piume pìu a Gobmiket.";
D.q[3611] = "Me impazzire per lei!";
D.q[1473] = "Bene! Adesso che conosci un po\' le fogne, puoi spingerti un po\' più lontano.";
D.q[1170] = "Forza, ti aspetto.";
D.q[4100] = "Che incantesimo vuoi dimenticare ?";
D.q[3436] = "Un giorno partirò all\'avventura.";
D.q[4010] = "Io, servire un principe? Mi piacerebbe ma non ho la divisa adatta...";
D.q[5461] = "Tu conoscere barzelletta di orso polare che entra in Taverna?";
D.q[3613] = "Gobrosa rinchiusa sotto accampamento Bwork.";
D.q[3610] = "Pfff... Essere ancora più debole di me! Vai via!";
D.q[3723] = "Pìu pìu pìu ?";
D.q[1902] = "Ehi tu, giovane Feca! Smettila di sognare!... Sembri caduto dalle nuvole! Ho bisogno del tuo aiuto...";
D.q[7611] = "Buonzorno a tutti, zono la moglie di Felize. Pozzo zcambiare 3 piccoli regali di Nawal con uno normale e 3 regali normali con un grande regalo. Per zcambiare i regali bazta che mi proponi uno zcambio con la ziuzta quantità di regali. Ze non ti propongo niente in cambio, zignifica che la quantità o il tipo di ozzetto non è corretto.";
D.q[4003] = "Io, cuoco per un Wabbit? Ma se non mangiano che carote crude! È una noia mortale, a meno che non mi si stimoli un po\'...";
D.q[1851] = "Maow!\n*Questo maomao sembra felice*";
D.q[3973] = "Io, uccidere un Wabbit? No grazie, devo lavorare già abbastanza per creare la mia dolce compagna!";
D.q[1842] = "Miaaaoow!\n*questo maomao sembra proprio triste*";
D.q[4714] = "";
D.q[2919] = "Ciao, assassino. Cosa ti conduce dal tuo Maestro dell\'Ordine?";
D.q[1687] = "Comincio a risparmiare dei gettoni, pare che servano per partecipare al Gladiatrool.";
D.q[4319] = "Preferisco così. Ora mettiti a tavola e ordina da bere.";
D.q[3432] = "Sniff, i miei bambini... Hans! Gret! dove siete?...";
D.q[1588] = "E così sia...";
D.q[3414] = "Devo dirti che l\'ultima volta che ho visto una candela, era sul casco di un Minatore oscuro. Dovresti cercare da questa parte.";
D.q[3371] = "Metag ti manda da me e vuole che ti metta alla prova? Vediamo... Sì, ho da proporti una cosa degna dei più grandi guerrieri. Stai attento, perché non ripeterò niente. Quello che dovrai fare è lungo, difficile ed estremamente pericoloso. È l\'opera di tutta la mia vita. Se segui le mie orme, potresti metterci tutta la vita a fare quello che ti chiederò. Non è una missione da prendere alla leggera. Procediamo per tappe. Ecco una chiave. Trova la porta corrispondente. Entra e affronta il maestro del luogo. Torna da me quando avrai finito.";
D.q[4161] = "L\'ultima volta che l\'ho vista, stava fuggendo in direzione di questo villaggio. Ho cercato di riacciuffarla, ma era veramente troppo determinata.\nPenso che tu possa ritrovarla per me, e spiegarmi perché se ne è andata.\nMa attenzione, dovrai sicuramente affrontare le creature del villaggio per ritrovarla.";
D.q[3167] = "L\'ultima volta che ho visto Messer Cuervoc, è stato nella sala 1 della biblioteca...\n\nMesser Cuervoc si trova nella mappa 9720!";
D.q[3925] = "Allora, chi è il pretendente?";
D.q[4908] = "";
D.q[4357] = "Degli Ecaflip ultimamente? Sì, ne ho avuto uno. Ha passato la notte a bere e a giocare, l\'indomani mattina non aveva più un soldo e credo che la guardia l\'abbia messo dentro non so più per quale ragione. Ti può aiutare?";
D.q[3589] = "Cosa sai fare? Tagliare il legno? Bene, bravo. Senti, ho bisogno di un bel po\' di tavole per riparare il tetto del granaio o rinforzare i recinti. Vai nel bosco ad abbattere qualche buon albero.";
D.q[670] = "Le Metarie sono una materia allo stato grezzo. Lavorate da un Alchimista, danno origine a potenti pozioni elementari che permettono di impregnare con un elemento certi oggetti. Le mie ultime fatiche provano l\'efficacia di questi oggetti sulle armi, ma anche la difficoltà di mischiare il reale con il magico. Ecco perché ho sviluppato un metodo per riuscirci e lo insegno ad alcune persone.";
D.q[4946] = "Allora, come vanno le operazioni ad Amakna?";
D.q[2009] = "Allora vuoi veramente allenarmi? Va bene, se insisti... Un piccolo combattimento non mi farà male... Ma ti avverto, non sono così debole come pensa mio padre... Dai, preparati, te ne pentirai!";
D.q[1868] = "Allora?";
D.q[5013] = "";
D.q[5059] = "Vai sull\'isola dei Wabbit e trovami qualcuno che possa trasmettere i miei ordini.";
D.q[3433] = "Veramente? È molto gentile da parte tua! I bambini stavano giocando attorno alla fontana del villaggio. Io mi sono voltata per discutere con le mie amiche e un attimo dopo erano scomparsi. Li ho cercati dappertutto. Sono talmente preoccupata.";
D.q[5066] = "Sono fiero di appartenere alla milizia di Bonta.";
D.q[1862] = "Per l\'arco ho bisogno di una solida base, una zanna di cinghiale che avvolgerò in una stoffa, e quindi due stoffe di cinghiale. Due aculei di prespic per l\'interno dei paraorecchie e un po\' di pelliccia perché sia morbido al centro... Infine, la cosa più difficile, una stoffa di peli di Milibuulupo per le rifiniture. Dovresti riuscire a trovare tutto nella vicina foresta, vale la pena te l\'assicuro...";
D.q[2820] = "Hum, non hai pagato la tassa... non posso parlarti...";
D.q[1223] = "Alt! Non si passa!";
D.q[5174] = "";
D.q[5229] = "";
D.q[5227] = "Allora? La risposta di Divad?";
D.q[5248] = "Hai trovato qualcosa?";
D.q[5252] = "Jiva la Saggia.";
D.q[5507] = "È un errore, io sono un Etram onesto!";
D.q[1993] = "Grazie e ancora grazie! Locetta sta meglio, deve solo riposare ancora un po\' per ritrovare l\'uso dei sensi.";
D.q[5599] = "*pisolino*";
D.q[3324] = "Grazie, giovane avventuriero!";
D.q[3329] = "Grazie, giovane avventuriero.";
D.q[1843] = "Maow ?\n*Non capisci quello che vuole. Potrebbe avere sete? E se gli dessi una ciotola di lalatte?*";
D.q[1174] = "Ah ho capito, le esche di Bhan Laka. Prendile e sbrigati, non ha molta pazienza!";
D.q[1183] = "Hum, ma cos\'è questa puzza? Eppure non sono i miei pesci... Ah ecco...! Ciao, cosa vuoi?";
D.q[1224] = "Capirsi?\nA 10000 kama, potremmo forse capirci...";
D.q[1263] = "Ma non hai neanche 1000 kama! Torna da me quando sarai più ricco. Ricordati: 1000 kama o niente!";
D.q[3400] = "La tua missione è un successo. Bzzztt... La tua nuova mi... bztt krouik! Frtrtttt";
D.q[3401] = "La tua missione è un successo. Bzzztt... La tua nuova mi... bztt krouik! Frtrtttt";
D.q[3402] = "La tua missione è un successo. Bzzztt... La tua nuova mi... bztt krouik! Frtrtttt";
D.q[3405] = "La tua missione è un successo. Bzzztt... La tua nuova mi... bztt krouik! Frtrtttt";
D.q[6562] = "Mmmh, ti vedo, stai sorridendo. Sento che stai preparando un brutto tiro. Hai avvelenato il cibo? Nel dubbio preferisco gettarlo. E questa birra sa troppo d\'ammoniaca o non abbastanza, è losco... Preferisco gettare anche questa.\nHo riflettuto bene e so cosa voglio. È semplicissimo, non dovresti avere difficoltà a procurartene a Bonta. Si tratta di una Dragochiappa in Pelle Viola di Bwork. L\'ultima è stata consumata da molto ed è tempo di sostituirla, mi eviterà di avere delle vesciche a causa dello sfregamento. Cosa, perché mi guardi così? Ho detto qualcosa che ti ha scioccato?";
D.q[3592] = "Mmmm, giochi con fiale e ogni genere di miscuglio? Non ho bisogno di questo. Però se in compenso vuoi andare a raccogliere qualche fiore di lino da sgranare, mi faresti un piacere.";
D.q[3536] = "Mmmm, un fedele di Ocra. Il tuo talento si esprime a distanza. Un buon arco, una linea di tiro e i nemici sono infilzati come spiedini. Ti piacerà un sacco. Ho proprio qualcosa adatto a te.";
D.q[6121] = "";
D.q[1340] = "Ridammi il medaglione!";
D.q[1419] = "Ho sentito dire che gli abitanti di Amakna erano partiti verso Est per partecipare alla guerra che oppone Bonta e Brakmar.\nPer qualche giorno, propongo di modificare i documenti di coloro che hanno disertato e che vogliono ritornare nella nostra provincia.\nPerò, non posso aiutare le personalità di alto grado, perché i loro capi le ritroverebbero troppo facilmente.";
D.q[1422] = "Tornare ad abitare ad Amakna è possibile, ma perderai il tuo grado di miliziano e tutti i vantaggi ad esso legati.\nSe sei veramente deciso, devi cambiare i tuoi documenti e iscriverti nuovamente nel registro di Amakna, le spese per queste operazioni variano a seconda del rango che avevi ottenuto all\'interno della milizia.";
D.q[1431] = "Mi stancavo troppo a camminare cercando un posto tranquillo, allora ho deciso di portare il posto tranquillo da me. Ci ho messo un sacco di pesci e via!";
D.q[1560] = "Moo oom foond\'om morocl\'om sqoorrol\'om nord\'om ost\'om oxtorom bontom moo oom.";
D.q[852] = "Si sente sempre più parlare di te. Sono fiero che uno dei miei discepoli sia così rinomato. Continua su questa strada... Ma non montarti la testa. Sei ancora una larva che striscia sui miei stivali! D\'altronde, per essere sicuri che ti resti ben impresso nel cervello, vai ad uccidere 40 larve blu e portamene gli occhi.";
D.q[1436] = "Bé, ci ho messo tutti i pesci che sono riuscito a trovare... E dopo qualche \"incidente\" è apparsa una nuova specie. L\'ho chiamata Pescis.";
D.q[3707] = "Ci sono sempre più avventurieri che passano da Incarnam prima di dirigersi nella contrada di Amakna.";
D.q[2163] = "Ciao! Suppongo che tu voglia un\'arma... Mi dispiace ma sono pieno di richieste fin sopra la testa. Torna quando le larve avranno i denti... hihihi!";
D.q[1106] = "Continua per la tua strada, non sono venuto a combattere. Voglio solo recuperare le mie spade.";
D.q[1643] = "La multigely? È un miscuglio maledetto di caramelle gely. Ormai non la vende più nessuno, perché ha causato la scomparsa di numerosi bambini. Si dice che teletrasporti la persona che la mangia all\'interno dei suoi più terribili incubi.";
D.q[1342] = "Non passerete! Banda di Bontariani!";
D.q[4231] = "Abbiamo perso molto del nostro passato, ritrovare le condizioni di vita di quell\'epoca è l\'unico modo di svelare gli ultimi misteri della vita. Stiamo giocando agli apprendisti maghi... La... creatura che abbiamo creato... è scappata...";
D.q[2522] = "Psshh... benefici enormi... psshh... molti kama....";
D.q[2521] = "Psshh... Leggenda... psshhpsshh... ahahahah ! Psshh... inondare il mercato... psshh... Grandapan....";
D.q[1498] = "UH? Si può sapere perché sventoli il sederino così davanti a me?! Ti ho chiesto di andare a comprare degli abiti ufficiali, non di fare shopping per mostrarmi i tuoi bei vestiti! Torna da me solo quando indosserai la divisa standard.";
D.q[1590] = "Basciaci sbare, non bedi che sbiamo giobando ai dadi oba?\nSe buoi basciare questa bimensione, usa la borta bagica a sibistra...";
D.q[1591] = "Cosa buoi umano? Bome osi tu bisturbarmi dubante questa bartita?";
D.q[6290] = "Uhuhuheheheh HIARHIARHIARHAHAHA!\nTe la cavi bene con gli affari, sai quello che vuoi. Ho sentito dire che un gruppo di giovani cercava di sbarazzarsi di un gioiello a quel che sembra unico e carissimo. Posso dirti dov\'è il loro nascondiglio, ma non fidarti, gli accessi sono bloccati da diversi meccanismi e questi giovani non sono del tipo da battersi in modo leale. Senza l\'aiuto dei discepoli di diversi dei non potrai accedere al segno di riconoscimento e neutralizzare i meccanismi.\nUhuhuheheheh HIARHIARHIARHAHAHA!";
D.q[1609] = "Ciao, mi sembri in buona salute! È arrivato il momento di darci un po\' del tuo sangue... nel caso avessimo bisogno di una riserva.";
D.q[1623] = "Vuoi divertirti ad acchiappare il pescis più grosso? E va bene allora, se vuoi posso affittarti la canna da pesca speciale per pescis a 100 kama.";
D.q[4307] = "I miei colleghi mi hanno assistito per anni nelle mie ricerche, senza di loro non avrei mai appreso, né scoperto così tante cose. Mi sento in debito nei loro confronti e apprezzo molto quando gli avventurieri, in cambio delle mie pozioni, accettano di aiutarli.\nMi piacerebbe che tu aiutassi il Professor Furnesol, Paolina Pan-duro, Polka Merer, Kito, il Dottor Nauh, Spit Fayer, Flip Flap e il Dottor Le Gubré.";
D.q[1664] = "Dark Vlad non si è ancora rifatto vivo...\nPer 1000 kama in più posso cercare di indovinare tra quanto tempo tornerà.";
D.q[4150] = "I miei colleghi volevano che io gli fornissi una delle migliori farine che esistano, ovvero la famosa farina di Xavier il Panettiere!\nMa è troppo complicata da fabbricare, quindi ho avuto l\'idea di mischiare un po\' di farine insieme, di aggiungere un po\' di quella di Xavier e, con un po\' di fortuna, tutti ci cascheranno! Ho avuto l\'idea, ma mi mancano ancora le farine, ti senti in grado di aiutarmi e portarmi tutte le farine che mi servono?";
D.q[989] = "Ho quasi realizzato il mio sogno: la fiera va a meraviglia.\nMa ho ancora un sacco di progetti di nuove attrazioni in testa. Sarò soddisfatto solo quando tutto sarà finito!";
D.q[3909] = "Ah, mio caro amico, che piacere rivederti!";
D.q[3060] = "Hanno sempre fame! Un po\' di carne di larva dovrebbe rinvigorirli.";
D.q[4582] = "Ti aggiusterò la bandana, lasciami un po\' di tempo.\n...\nEcco qua, è quasi come nuova. Non sono riuscito ad eliminare completamente l\'odore di cawota, ma sparirà col tempo.";
D.q[3735] = "Come diceva il mio amico Adédé, devono nascondersi negli angoli più stretti e oscuri del Mondo dei Dodici. I draghi sono creature paranoiche. Nessuno può entrare a casa loro... neanche dalla piccola porta di dietro per rubare le loro uova. Le nascondono e le custodiscono con gelosia, peggio della prima pepita d\'oro di un Anutrof.";
D.q[1779] = "Ti insegnerò molte cose durante le tue missioni.";
D.q[1784] = "Torna da me più tardi, quando saprai usare almeno sei incantesimi diversi...";
D.q[1401] = "Caaapiti a faaagiolo! Seeembra che tu pooossa ideeentifiiicare il Bontaaaariano che haaa attaccaaato Brakmaaar?";
D.q[1792] = "Se vuoi affrontare un Dabol, devi donare un po\' di Legni di Ciliegio al tempio...";
D.q[3741] = "Consulta la tua bussola, l\'avventura è da quella parte!";
D.q[5640] = "Qual è il tuo nomignolo?\nEhi, ti sto chiedendo come ti chiami. Perché non mi rispondi?";
D.q[1846] = "*Il maomao mangia senza molta convinzione, poi ricomincia a lamentarsi*\nMaaaaoowwww";
D.q[5631] = "Prego la dea Aniripsa perché mi accordi le sue grazie. Così potrò curare i miei amici e punire i miei nemici. Posso fare anche il contrario, è questo il bello.";
D.q[3609] = "Questo non è altro che un paesino, se penso a tutti gli atelier che esistono in tutta Amakna.";
D.q[1847] = "*Forse gli farebbe bene una passeggiata intorno alla città.\nPer fare una bella passeggiata bisogna passare dal parco, respirare il buon odore del pesce al mercatino, quello dei fiori dalla fiorista, per poi tornare qui.*";
D.q[3780] = "Vuoi ritornare alla statua?";
D.q[4613] = "Bah...\nNon hai il diritto di rispondere con un\'altra domanda, è barare. Anche tu cerchi il Corno Davola? Ma ?! Tu sei una stupida Bontariana. Muori, carogna!";
D.q[3781] = "Vuoi ritornare alla statua?";
D.q[3777] = "Vuoi ritornare alla statua?";
D.q[3543] = "Ciao Pandawa! Aspetta... fammi vedere i tuoi occhi... sì, sei ancora bello ubriaco, perfetto. In questo stato sarai sicuramente molto efficace nei tuoi prossimi combattimenti. Prendi una buona ascia, qualche bottiglia e corri a combattere!";
D.q[3694] = "Stai ancora cercando lavoro nella regione?\nFrancamente, se fossi in te, andrei verso Astrub, mi sembri in grado di sbrigartela da solo.";
D.q[6514] = "Ehi ehi ehi, tu hai dei kama per me? Posso dirti tutto quel che so su Pola se hai dei kama per me. Non essere avaro, dammi tutti i tuoi kama!";
D.q[1883] = "Affascinante, le mie deduzioni erano esatte, queste due piante hanno un\'origine comune. Ah sì, mi stavo dimenticando di dirtelo! Sono uno scrittore, e sto scrivendo un\'opera sull\'apparizione delle piante aggressive ad Amakna. In antichi manoscritti ho scoperto che prima del 150 i fiori erano creature amichevoli, persino servizievoli! Mi chiedo veramente cosa li abbia resi così aggressivi!";
D.q[3814] = "Una birra? Vedo dal tuo sguardo che hai accettato l\'esperimento di Aymé. So bene che non osa venire a comprarla di persona perché ha una grosso debito con me. Vabbé, te la vendo lo stesso, in fondo tu non c\'entri niente in questa storia.";
D.q[1705] = "Il tempio Xelor è nel villaggio di Amakna. Parla ad Emilie Yuh per cominciare il tuo apprendistato.";
D.q[3539] = "Un Feca! La forza tranquilla della saggezza. Io rispetto il dono protettore della tua dea, è incredibile. E siccome tu non lo padroneggi ancora bene, ti posso proporre qualcosa che ti aiuterà ad acquisire esperienza.";
D.q[3828] = "Vi ho preceduti. Bene, se siete qui vuol dire che siete tutti motivati. Ma vi lascerò passare solo se avete la chiave di questa porta. Se non l\'avete, cercate di trovarla sulle creature che popolano Incarnam.";
D.q[3770] = "Perfetto soldato, riposati e torna a prendere gli ordini appena sei pronto.";
D.q[3008] = "Vai da Edrige Valling, nel tempio della dea Ocra, è proprio un bel tipino, credimi..";
D.q[3547] = "Che le ombre ti proteggano Etram! È così che vi salutate, vero? È vero anche che preferite agire nell\'oscurità, che usate trappole con gli avversari, e che li imbrogliate subdolamente? Allora sto cercando proprio una persona come te.";
D.q[3838] = "Allora, sei pronto a partire per la grande avventura?";
D.q[738] = "Il mio amico Rimaraf è morto questa notte in circostanze misteriose. È stato avvelenato con un Blopisiero allo scorbuto.\nVorrei che tu indagassi su questa storia e che trovassi il colpevole!";
D.q[7582] = "Vuoi tu mettere la corda al co... ehm, scusate, l\'anello al dito?";
D.q[1933] = "Ciao! Capiti a proposito! Ti spiego: il mio maestro non può muoversi - non mi fare dire quello che non ho detto, chi ha parlato di reumatismi?! *ehm* Il fatto è che è molto occupato, e tu sembri rientrare nei suoi progetti.\nSa tuuuuuuutto quello che succede da queste parti.";
D.q[4601] = "La mia bandana hai ritrovato! Per sempre perduta la credevo. Il mio vecchio amico Sfinter Cell me la ha data, molto cara al mio cuore essa è. Ringraziarti io devo.";
D.q[434] = "Mio nonno viveva in questo villaggio quando le creature lo invasero. Mi ha spiegato che un Draguovo, se catturato subito dopo la nascita, è inoffensivo. Ma alla mia età, non riesco più ad avvicinarmi ad un Draguovo per rubargli le uova. \nSe pensi di esserne capace, mi servirebbero delle Uova di Draguovo Bianco, ma il solo modo per ottenerle è di sconfiggere le Draguova!";
D.q[4661] = "Me ne infischio se è difficile trovare gli ingredienti o se non trovi nessuno che ti aiuti. Se perdi troppo tempo i Bontariani recupereranno il loro ritardo.";
D.q[1976] = "LO SAPEVO! Ne ero sicuro, tieni, ecco una piccola ricompensa per te.";
D.q[1909] = "Ah, eccoti! Mi chiamo Allisteria. Potresti darmi una mano? Devo occuparmi del mio gregge di Pappatutto, ma dopo le frane non ci riesco più.";
D.q[2883] = "Primo: ottieni l\'Incantesimo \"Cattura Anime\". Questo Incantesimo è disponibile nel Dongione di Aksadala.\nSecondo: porta con te una Pietra di Cattura.\nTerzo: attacca una creatura di cui vorresti l\'Anima. Lancia l\'Incantesimo Cattura Anime durante il combattimento, e vincilo!\nQuattro: se uccidi la creatura mentre il tuo Incantesimo è attivo, allora hai buone possibilite di impadronirti della sua Anima.\n\nOvviamente non è possibile ricatturare l\'Anima della creatura nell\'Arena...";
D.q[414] = "Il miglior modo per imparare un Mestiere è quello di chiedere ad una persona di insegnartelo. \nPurtroppo non ci sono molte persone abbastanza esperte da poterlo fare. Recati direttamente all\'Edificio legato al Mestiere che ti interessa, ad esempio, vai alla Panetteria di Kelog Korflex se vuoi diventare Panettiere o nell\'Atelier di Abely Bobel se vuoi diventare Intagliatore.";
D.q[4674] = "Un Brakmariano!! Ma come hai saputo del nascondiglio del Corno?\nBene, in ogni caso devo farti tornare da dove vieni! In guardia!";
D.q[2658] = "Il dio Xelor mi ha fatto l\'onore di nominarmi Guardiano del Tempo. A meno che tu non decida di uccidermi, è fuori discussione che tu prenda il mio posto.";
D.q[1163] = "Il mio mestiere? Perché, non si vede? Sorveglio le larve. Fanno paura ai poveri coniglietti, e devo tenerle...\nSì, insomma... tra un pisolino e l\'altro...";
D.q[4573] = "I kama inutili su questa isola sono. Se anche non lo fossero, a sufficienza non ne avresti.";
D.q[3110] = "Grazie per le patate, quando finiscono mi annoio. Vorrei tanto avere una Pala di Legnuccio per coltivarle da me.";
D.q[3120] = "Le mie padrone hanno rinchiuso il Culosse nella sua stessa caverna per poter controllare la montagna dei Koalak. Per evitare che un avventuriero cerchi di liberare il Culosse, abbiamo rinchiuso nella caverna i Koalak più aggressivi e più pazzi. Il Culosse è una creatura tranquilla, ma si dice che sia diventato un po\' pazzo, dopo che il grande Skunk gli ha rubato il suo Dofus. Un Dofus, ci credi veramente? Comunque sia, non sono qui per discutere, devo servire le mie padrone e controllare quest\'entrata!";
D.q[5758] = "";
D.q[5804] = "";
D.q[1324] = "Mi chiamo Sbab. Sono stata catturata un mese fa durante il raid dei tuoi guerrieri a Bonta. Quando sono arrivata qui mi hanno proposto di cucinare per l\'eternità o di morire immediatamente. Non avevo molta scelta, no?";
D.q[3635] = "Sei di ritorno recluta? Le guardie stanno facendo il loro lavoro, c\'è qualcosa che non va. Conosco bene quei figli di Bwork!";
D.q[6229] = "Cosa? Ti ha chiesto un favore e poi è sparito? Idiota! Per fortuna hai trovato delle tracce che indicano che i colpevoli sono i goblin, se no ti avrei fatto leccare tutti gli orifizi da un pappatutto.";
D.q[2120] = "Non hai mica visto Jim Fleps per caso?";
D.q[2132] = "Saketsu avrà i risultati in un batter d\'occhio.";
D.q[5792] = "Mi prude il naso.... Per caso hai un fiore con te? C\'è puzza di Tempofuggendula!\nOh... vuol dire che hai subito un\'alterazione del tempo... Mi dispiace davvero.\n\nSe ti va, posso darti una caramella, oppure posso darti della polvere d\'Aniripsa per i tuoi famigli. Se uno di loro è morto, posso perfino starnutire per farlo tornare in vita! Una volta in più o una in meno...  \n\nScegli per bene, non posso fare tutto allo stesso tempo!";
D.q[2221] = "I miei poveri Tofu! Solo un Osamodas può aiutarmi a trovare un rimedio per curarli.";
D.q[3718] = "Adesso che sei più forte, accetto volentieri che mi porti un po\' d\'acqua per le mie ninfette.";
D.q[6094] = "";
D.q[2139] = "Dai, svegliati! Vai a portare il messaggio alle altre gilde...";
D.q[1925] = "Ti ringrazio tantissimo. Senti, mi vergogno un po\', ma avrei bisogno di altro...";
D.q[4606] = "Non è semplice compiere una maledizione sul Ferro. Avrò bisogno dell\'aiuto di ZolTAN, lo troverai in trance davanti alla Banca di Brakmar. Inoltre ho bisogno di un Talismano del Mal Occhio, Zeorg nel Tempio Osamodas potrà darti la Ricetta. Ho anche bisogno di due membri del mio Ordine che possiedano almeno il titolo di Adepto dei Dolori. Quando avrai recuperato tutto ciò, torna qui e potremmo maledire il Ferro. Ah, dimenticavo, ho anche bisogno di Ferro.";
D.q[2165] = "Arrenditi, arrenditi, làlàlà.";
D.q[4889] = "Come? Sei arrivato troppo tardi, e tutti i soldati erano già stati abbattuti? Ahi. Siamo veramente meno efficaci di Brakmar. È preoccupante.";
D.q[2156] = "Tieni una missione.";
D.q[4811] = "Vieni qui, ho ancora del lavoro per te. Secondo il Libro della Biblioteca, è necessaria un\'Acqua particolare per raffreddare il Metallo della Lama Malefica nella Fucina. Mulic Ber mi ha segnalato che l\'Acqua delle Paludi Senza Fondo andrebbe benissimo, ma che con la corruzione dei Coccodrail, potrebbe risultare ancora più efficace.\nVai a sterminare i Capi Coccodrail che incontri finché non ti avranno dato la loro Acqua Putrida. In seguito la porterai a Mulic Ber e gli darai anche tutto ciò che gli serve per terminare la Spada. Non serve a niente tornare qui senza la Spada.";
D.q[3525] = "Mio figlio molto forte! Primo magoblin!";
D.q[3321] = "Alla prossima carica, trasformerò la fanteria di Bonta in purè.";
D.q[2632] = "Mio figlio in cambio di un semplice piatto?... VENDUTO! \n*prende il piatto e lo mangia il più velocemente possibile* Dovrai comunque convincere il capofamiglia Dento ad annullare, a sua volta, la promessa.";
D.q[1457] = "ALT! Questa è l\'entrata della sala degli interrogatori, nessuno può passare senza lasciapassare.";
D.q[2311] = "Uuuh, non hai niente di niente? Né limoni, né cosce di Pappatutto? Cosa aspetti? Su su, dai dai...";
D.q[4154] = "Mio figlio, Gian Nauh, il mio piccolo wabbit adorato, è chiuso in questo laboratorio abbandonato e io non so assolutamente come aiutarlo, non vuole più tornare e non oso andarlo a cercare, ho troppa paura delle creature che potrei incontrare.\nPotresti andarci al posto mio?";
D.q[2210] = "Non ho tempo, insetto! Ho troppo legno da vendere!";
D.q[3266] = "Il mio piccolino, il mio bambino adorato è scomparso da una settimana...\nHa seguito un vecchio e strano Anutrof su un\'isola ancora più strana verso Nord...\nEd è tornato con questo bellissimo mantello, per la sua mammina... \n\n*tira su col naso*\n\nPoi è ripartito con quell\'Hector Nawal... e non ho più avuto notizie!\nE il vecchiaccio mi evita da quel giorno.\nGira per Madrestam in questo momento, se lo trovo...\n\n*mostra una vecchia pala acciaccata*\n\nGli insegno la lezione n°2...";
D.q[4485] = "Le mie spie mi hanno appena detto - come al solito con un notevole ritardo - che Xefires si è fatto trovare ed imprigionare. E in più una delle nostre pattuglie è stata decimata al Cimitero dei Torturati. Quindi tutto fa credere che fossero al corrente per quanto riguarda Xefires e che ci abbiano preso in giro. Per fortuna abbiamo ucciso il loro Forgiatore e rubato le armi dei loro ufficiali, se no sarebbero stati equipaggiati meglio di noi, ma, di conseguenza, eccoci di nuovo in parità. Bisogna ritornare in vantaggio a tutti i costi.";
D.q[4615] = "Bah...\nNon hai il diritto di rispondere con un\'altra domanda, è barare. Anche tu cerchi il Corno Davola? Ma?! Tu sei uno stupido Bontariano. Muori, carogna!";
D.q[6664] = "Attenzione, non è una decisione da prendere alla leggera. Vuoi maggiori informazioni prima di prendere una decisione?";
D.q[4014] = "Servire un principe, eh? Deve essere ricco se è principe, no? Allora, quanto paga?";
D.q[7053] = "Benissimo, ora quale gemma desideri?";
D.q[4441] = "Le mie spie a Bonta hanno avvistato qualcuno, diciamo, di assassinabile. Il problema è che quelle teste di babbeo non avevano previsto l\'assassinio nella loro missione e quindi non hanno veleno. Bisogna portarglielo e, inoltre, il Veleno che usano si trova solo sui Bwork Maghi. Porta questo Veleno al Capo delle spie, è da qualche parte a Sud-Ovest di Bonta.";
D.q[7054] = "Benissimo, ora quale gemma desideri?";
D.q[4572] = "A ripetere io vado. Non insistere devi. Rivelare il nascondiglio io mai vorrò.";
D.q[2329] = "Il mio scoiattolo è scappato un\'altra volta! *sniff*\nScappa in continuazione... ne ho abbastanza! Questa volta, ho affisso un avviso di ricerca per ritrovarlo... leggilo. Poi se lo incroci ad Astrub e cerchi di prenderlo, sappi che si difenderà sicuramente... Ma non ti preoccupare, è adorabile... anche se i baubau del quartiere ne hanno paura...";
D.q[2309] = "Aaaaatchhhciùùùù! Snif *tira su rumorosamente*";
D.q[4622] = "Ehi ehi, calma! Pensavo che un servizio valesse un altro, ma evidentemente i Brakmariani vedono la cosa in maniera diversa...\nBeh, allora è semplice: tutto quel che so è che quel Corno magico è su un\'isola, ma ignoro quale. Non ne so di più, non sono mica una biblioteca ambulante come Harry Stote.";
D.q[6663] = "Ecco, te l\'ho indicata sulla tua mappa. Non devi fare altro che seguire la tua bussola e sarai là in un momento.";
D.q[437] = "Il mio tirocinante è morto nel forno da pane, e ora mi manca qualcuno che mi porti il legno per scaldare il forno. Se tu mi porti un\'unità di Legno di Frassino, ti darò in cambio un Lievito da Panettiere.\n\nAvrei anche bisogno di Semi di Sesamo per il pane, se me ne porti 5, in cambio ti darò un Impastatore. È un attrezzo indispensabile se vuoi esercitare il mestiere di Panettiere.";
D.q[2321] = "Non hai ancora fatto nulla? Vai da Nibé Lulla, dovrebbe trovare qualcosa per il tuo arco...";
D.q[4958] = "Molto bene, ma anche tutti i materiali del mondo non servono se nessuno li usa. Trovami della manodopera per costruire il tempio. E non accontentarti di qualche barbone di Brakmar: mi serve un sacco di gente.\nVai dal miliziano Sesi Ves, ai piedi della torre di Brakmar.\nCredo che quel vecchio scavatore abbia ancora qualche contatto in giro.";
D.q[2330] = "Ciao, e benvenuto nel mio mercatino. Spero che troverai tutto quello che cerchi.\nCome posso esserti utile?";
D.q[2343] = "Che sfiga! È impossibile avvicinarsi, hai visto?...";
D.q[1503] = "Sorvegliamo questo lato da vicino. La terra è a portata di corda o di teletrasporto. Per questo bisogna fare attenzione.";
D.q[4678] = "Ah, il mio nuovo equipaggiamento è arrivato. Ringrazia Oto da parte mia. Anzi no, non ringraziarlo, potrebbe punirmi.";
D.q[1676] = "Molto bene, mettiti davanti alla roulette Pappatutto, e gira la ruota!";
D.q[2376] = "Posso insegnarti solo una specialità tra: Intagliatore di bacchette, di bastoni o di archi. Detto ciò, se sei coraggioso e hai molto tempo, niente ti impedisce di impararne due.";
D.q[4188] = "Hai affrontato il Cavaliere Nero e Rosa per me?";
D.q[2377] = "Sei sicuro di voler intraprendere la carriera di Intagliatore di Archi?";
D.q[263] = "Questa parte del negozio è vietata alla persone non facenti parte della classe degli Ocra.";
D.q[4630] = "Hai carta bianca per fare parlare la tartaruga! Al lavoro!";
D.q[2382] = "Sei sicuro di voler intraprendere la carriera di Forgiatore di Spade?";
D.q[4682] = "Le mie spie mi hanno confermato il recupero da parte dei Bontariani del Corno Davola. Non tarderanno ad utilizzarlo contro di noi, quindi muoviti ad equipaggiare i nostri miliziani.";
D.q[6448] = "Mio zio Captain Starky verrà a liberarmi e a darti un bel calcio nel sedere, vedrai. Non mi stupisce che i Brakmariani siano tutti aggressivi: le catapecchie in cui vivono li rendono di sicuro invidiosi della nostra magnifica città di Bonta.";
D.q[3484] = "Cosa ci fai tu nella mia tana? Anche tua madre è pazza? La mia, Bworkselana, mi ha gettato qui dentro!";
D.q[6705] = "Mio zio è stato obbligato a scappare senza di me, ma niente è perduto. Arriverà con la cavalleria e raserà a zero questo sordido edificio e tutta la tua città, vedrai.";
D.q[4160] = "Mia moglie... Se n\'è andata, non so dove. E adesso cosa farò? Di tutto il resto della mia vita, di tutte queste persone che mi lasciano indifferente... Adesso che è partita!\nAnche se sono uno dei più famosi scienziati nonché discepolo di Otomai, non posso fare niente senza mia moglie!\nPosso portarti laddove l\'ho vista l\'ultima volta, potresti cercarla, e se la trovassi, potresti cercare di convincerla a tornare.";
D.q[5111] = "Le cose vanno bene, anche se ho SEMPRE queste maledette catene. Ora non mi resta che trovare qualche discepolo, poi potrei finalmente fondare il mio ordine ed eguagliare quello di Djaul. La mia ultima missione per te è questa: trovami almeno tre discepoli. Cerca nei luoghi importanti di Brakmar, per esempio.";
D.q[2396] = "Sei sicuro di voler diventare Taglialegna? Posso prenderti come apprendista, ma devi rimboccarti le maniche!";
D.q[6396] = "Ed ecco il risultato! Senza di me non avresti mai ottenuto il Grattaschiena, ammetti che sono il migliore Forgiatore di Brakmar.\nHai quel che ti serviva? E allora fuori!";
D.q[3378] = "Hai superato tutte le prove e gli ostacoli. Il tuo coraggio brilla come il sole di primavera. Viaggia verso il tuo destino, che la tua anima sia forte come l\'acciaio. Lasciami adesso, delle preoccupazioni offuscano il mio spirito.";
D.q[2406] = "Ahah un altro apprendista! Per cominciare ad esercitare questo mestiere devi procurarti assolutamente un Tagliacuoio. Se vuoi posso vendertene uno io. Una volta recuperato questo attrezzo, devi usare uno dei nostri comodi banchi da lavoro appositamente studiati per facilitare il taglio del cuoio. Comincia con dei modelli semplici, tieni, te li scrivo sul tuo taccuino di Ciabattino.";
D.q[4627] = "Non vedo l\'ora di avere questo corno tra le mani per radere al suolo Bonta e imporre la nostra visione delle cose.";
D.q[2410] = "Ciao, io sono solo un giovane apprendista... Se vuoi saperne di più sulla nostra arte, vai da Nibé Lulla. Puoi trovarlo al mercatino, passa tutto il tempo là dentro da quando è stato aperto.";
D.q[6543] = "Se vuoi una risposta alla tua domanda devi prima scommettere.\nQuanto vuoi scommettere ?";
D.q[3340] = "È proprio quello che volevo. Tieni! per ripagarti dei tuoi sforzi.";
D.q[3671] = "Sei troppo forte per questa parte del Mondo dei Dodici. Non ho più compiti da affidarti. Faresti meglio a partire alla ricerca dei Dofus.";
D.q[6521] = "Non hai scommesso molto, hai paura di perdere?";
D.q[2431] = "Grazie mille, mi hai salvato la vita!";
D.q[1126] = "Sono io il più grande, il più magico, il più dotato Forgimago di questo mondo! Le mie armi sono strapotenti e ognuna è un pezzo unico. E tu cosa vuoi?";
D.q[4593] = "...lasciarmi qui!? In queste condizioni io...\nAh!! Un Bontariano mi ha già raggiunto!";
D.q[7581] = "";
D.q[4883] = "Puoi dire ad Amayiro che può contare sul mio aiuto e su quello dei miei uomini.";
D.q[244] = "Lascia che ti metta in guardia. Questo dedalo ospita molti mostri, e moltissimi sfortunati avventurieri ci hanno rimesso la vita. Questo luogo è ormai oscuro e ostile, se vuoi entrare, è meglio che tu sia agguerrito.";
D.q[1952] = "È gentile da parte tua.";
D.q[1910] = "Il mio peluuuche, sigh, me l\'hanno rubato! Ci avevo messo tanto per vincerlo alla Fiera del Trool... Potresti aiutarmi a ritrovarlo? Sono stati i banditi... nella foresta a Nord del villaggio, mi hanno attaccato e mi hanno rubato il mio peluuuuuche...";
D.q[6399] = "Ohi. Solo sentire il suo nome mi fa passare la voglia di mangiarne. Ne hai altri così?";
D.q[725] = "Vai a contrattare un po\' con Mub Ereicifitra per la sua polvere. I nostri nuovi cannoni sono usciti dai magazzini e dobbiamo provarli durante il nostro prossimo assalto a Brakmar.\nSarà a spese tue questa volta, quindi cerca di negoziare bene, me ne servono una decina di pods.";
D.q[2451] = "Bella presa, mercenario!";
D.q[2452] = "Ah, la vecchia megera, ben fatto!";
D.q[7069] = "No, signore, non c\'è niente dietro di me. È solo una grotta vuota. Perché resto davanti ad una grotta vuota? Che domanda strana. Vai piuttosto a chiedere ad uno Yop perché va in giro con un cranio vuoto! Dai, te lo dico. Sono proprio un Etram altruista. È molto raro. Non voglio che dei camminatori si perdano e sprechino il loro tempo in questa grotta visto che non c\'è niente da fare. Per quanto riguarda tutte le fandonie che raccontano, che sia un covo di banditi e di briganti, ecco... sono delle fandonie, ti dico!";
D.q[3302] = "In una sola notte il Signore demone ci ha eretto un edificio dedicato al sapere, alla guerra, alla potenza, alla supremazia e alla strategia.";
D.q[1532] = "Si tratta di una casa privata, solo i frequentatori conoscono il codice per entrare.";
D.q[2084] = "Nepra non c\'è... Cerchi del Suborhube? Ma certo! Però sarebbe molto più educato se gli Anutrof se lo venissero a prendere di persona. Purtroppo non ho ancora trovato la medicina contro questo flagello che li spinge a scavare dappertutto, anche dove non si dovrebbe...";
D.q[2476] = "Non dobbiamo far altro che tappare tutto! Grazie!";
D.q[2475] = "L\'ambra? Mica si trova su qualsiasi albero! Devi chiederla ad un Alberagno, sono sicuro che te ne darà con piacere... (grande sorriso).";
D.q[2488] = "Ah rieccoti... Ti sei dimenticato? Mi servono 5 ambre!";
D.q[2489] = "Ciao! Hai per caso visto Toyo Dzink? È uno dei miei colleghi, sta cercando dell\'Ambra. E io cerco lui... Pare che sia sulla strada che da Astrub va verso Amakna. Non la troverà certo laggiù l\'ambra... deve andare verso sud! Gli faresti un bel favore se gliene portassi un po\'.";
D.q[2487] = "Aaaahhh l\'ambra! Grazie! Ecco la tua ricompensa!";
D.q[25] = "Ciao, sono Kelog Korflex, un celebre Panettiere di Amakna.\nHo qualche lavoretto per te, se sei interessato ovviamente.";
D.q[2492] = "Ouh! Andiamo a lavorare!";
D.q[2516] = "...il ricettacolo dei Dofus è ormai accessibile a tutti! Un sacco di gente vuole vederlo e vuole comprare i souvenir della nostra isola! (Si frega le mani). Lodato sia il Grandapan! Mmh... Posso aiutarti?";
D.q[2520] = "Psshh... Dofus... psshh... Grandapan.... Psshh... Conquista del Mondo... psshhpsshh... ahahahah !";
D.q[5910] = "";
D.q[2207] = "Pazienza! Non sai che ti perdi! Vai da Clint Pot, dovrebbe poterti aiutare...\nTi ho indicato la strada. Non ti rimane che seguire la bussola.";
D.q[3317] = "Alla prossima carica di Dragacchini, sfonderò persino le mura di Brakmar.";
D.q[2562] = "Tla i Dofus si nascondono dei falsi... Gli autentici Dofus sono deposti dai dlaghi. Bisogna ploplio essele sciocchi pel pensale che una Cawota deponga le uova! Il Dofus Cawota non è altlo che una Cawota stlegata dal We Wabbit in pelsona, il che gli confelisce comunque potenti poteli...";
D.q[2695] = "Piacere! Senza vantarmi troppo, ho valorosamente difeso la mia città, la bella città di Astrub da un\'invasione di bestiole disgustose! Ma lasciamo stare... piuttosto, ho sentito la tua discussione con lo Sciamano, e secondo me dovresti andare dal Grandapan. È lui che comanda tutto qui.";
D.q[2583] = "Altolà! Non si passa!";
D.q[3388] = "Fa bello, mi sa che vado ad abbattere un albero o due. E se sono fortunato, magari becco pure un Alberagno.";
D.q[2073] = "No? Veramente? Pazienza, non sai cosa ti perdi!";
D.q[2497] = "Niente tassa sulla Pandrista, niente Pandala!";
D.q[262] = "In quanto Ocra, hai accesso al primo piano, ma per adesso è occupato dal mio allenatore di Dabol.";
D.q[2610] = "Siamo arrivati alla fine del primo capitolo di questo manoscritto! Il prossimo sotterraneo sembra particolarmente complesso... \nUn messaggio di avvertimento senza capo ne coda dice: \"Si consiglia di indossare una collana di soda!\"";
D.q[2618] = "Tu avere trovato padre Metoasa e convinto lui?";
D.q[2619] = "Grimph";
D.q[2557] = "È inutile mentire, verme insolente! Queste uova diaboliche seminano violenza e desolazione ovunque si trovino! Ascolta bene: un uovo di drago non farebbe male ad un moskito, è tutto il gruppo di avventurieri avidi - di cui tu fai parte - che bisogna sterminare... vero?";
D.q[2131] = "Ancora nessuna notizia di Nibé Lulla. Sei sicuro di avergli portato il sangue di quel maledetto Minatore oscuro?";
D.q[2667] = "Se vuoi scambiare degli oggetti con me, indietreggia di cinque passi e mettili per terra, io farò lo stesso. Eheheh...";
D.q[6277] = "Va bene! Parlane ai ragazzi, io ci so fare con le donne. È per questo che sono io il capo.\nAllora, parliamo seriamente, mi torni a trovare domani sera, farò in modo che i ragazzi siano alla taverna e che ci lascino tranquilli. Vedrai, bel bocconcino mio, il tocco degli Etram non è solo una leggenda.";
D.q[1069] = "No prob, amiko. Tonna kuando vuoi.";
D.q[2006] = "Hai perso il tuo fiore di Dizbi? Che spreco!... tieni, eccone un altro, ma stai attento questa volta, è molto prezioso!";
D.q[712] = "I mercenari che alleno in questo momento non sono molto dotati... Ti andrebbe di farmi vedere quello che vali in combattimento?";
D.q[3217] = "Non so se conosci il labirinto del Minotoror, sembri uno che non è mai uscito di casa!\nBoh, è vero, io non sono mai uscito da questa caverna, ma non è la stessa cosa.\nSai, questo labirinto presenta le stesse caratteristiche di quello del Minotoror, è maledetto, e gli avventurieri che vi penetrano perdono la memoria e dimenticano il loro punto di registrazione, inoltre non possono usare neanche una pozione di memoria per uscire dal labirinto. Fortunatamente per te, porcellino mio, io sarò al tuo fianco per guidarti in questo labirinto! Sono stato addestrato dalla migliore guida archeologa di tutto il continente, l\'illustre, incredibile, strapotente, Lorkos! La sua frase preferita, quando portava i turisti nel labirinto, era \"conosco la strada!\". Hahaha, povero pazzo, alla fine si è perso nel suo museo! Ma lasciamo stare... mi sembra di parlare ad un muro.";
D.q[3397] = "Non ho tempo! Iiiiiiiiiiihhhh! Lasciami in pace!";
D.q[2744] = "Vedo dai tuoi piedi che hai pelcolso una lunga stlada per venile da me, cosa desideli?";
D.q[2747] = "Ti rendi conto? Per mantenerli freschi, bisogna raccogliere i Bambù con la coda. Io già non ci riesco con la mano, figuriamoci con la...! Vabbé! Preferisco raccogliere il Bambù che imbrogliare gli avventurieri. I mercanti sono un po\' birbanti... non mi stupirebbe se cercassero di rifilarti un dofus deposto da una dragacchina... non so se mi spiego...";
D.q[5703] = "No! Aspetta. Una Statuetta è nascosta nella miniera del Villaggio di Amakna. È necessaria una magia abbastanza potente per renderla visibile.";
D.q[2755] = "Se rispondi a queste domande sull\'arte Pandawushu, vuol dire che sei abbastanza esperto e che otterrai i gradi.";
D.q[2784] = "Kweeeh *kof kof*";
D.q[2798] = "Mi sembra che il richiamo della foresta, anche se maledetta, ti stia chiamando...";
D.q[5681] = "";
D.q[1158] = "No, le aquile di Tainela non hanno bisogno del codice per entrare in casa tua, non dimenticare che hanno le ali. Ma non dare mai il tuo codice ad uno sconosciuto.";
D.q[1536] = "Ecco 2000 kama per ringraziarti, gli operai saranno contenti di sapere che possono continuare i lavori.";
D.q[2801] = "...\nSmeraldo è questo colore... \nRazeriana adora contemplare la sua bellezza nel guscio del Dofus...\n...Vai adesso...";
D.q[2814] = "Mmh, parti da lontano, te... Un kwan è una domanda corta, posta dal Maestro al suo Discepolo.";
D.q[282] = "Hi! Hi! Hi! Sei sconvolto dalla mia intelligenza diabolica, vero? Vuoi entrare a fare parte del mio gruppo, bene. Portami 80 Fiori di Dente di Leone Diabolico, ti farò entrare nel mio gruppo e ti darò una ricompensa. Sono gli unici fiori che si adattano alla mia intelligenza prodigiosa.";
D.q[6499] = "No, pietà, non mi fare male, sono solo un povero vecchio un po\' pazzo. Ti dirò tutto quello che vuoi sapere e puoi perfino servirti nella mia gioielleria, è gratis.";
D.q[4237] = "No, no, ti sbagli, non si tratta del mostro della torbiera. È qua già da molto tempo. È qua da sempre. È possibile che anche lui sia legato al Plasmogrin, un\'evoluzione parallela... tutto è possibile su quest\'isola! Figurati, il mostro della torbiera è l\'ultimo dei nostri problemi.";
D.q[6405] = "No, perchè me lo chiedi?";
D.q[5224] = "No? Non avevo dubbi. Non importa, passiamo alla tappa successiva. Vai da Divad alla torre e consigliagli di calmare i membri del suo Ordine. Non tollero che si possa aggredire un partigiano di Djaul nella stessa Brakmar. Torna da me quando avrai una risposta.";
D.q[2880] = "Ciao a te. \n\nBel tempo, vero? È il tempo ideale per catturare delle anime erranti...\n\nMa ora basta con le chiacchiere, cosa posso fare per te?";
D.q[5704] = "Nooooo!!! Sei un pazzo! Feci di Pappatutto! Moccio di Bwork! Escremento di Kralamore!";
D.q[4451] = "No, no! Ti prego, non uccidermi! Non sono un Bontariano, lavoro qui solo come dipendente, è tutto!";
D.q[3000] = "Non sempre, ma abbastanza spesso! Ogni creatura ti dà degli oggetti, come un copricapo o un paio di stivali, o delle risorse, come il cuoio o l\'ambra... Tutte queste cose hanno un valore economico che non è da sottovalutare... E inoltre, con un po\' di fortuna, potrai trovare una gildalogemma! Questa pietra ti permetterà di creare la tua gilda... Se vuoi saperne di più, vai nel tempio delle Gilde...";
D.q[5028] = "Casa vietata ai non draguova. Travestimento draguovo non funzionare, avventuriero idiota avere già provato.\nAndare via.";
D.q[2877] = "Hai superato la prova, avventuriero! La foresta ti aspetta!";
D.q[29] = "Ciao, sono Bowis, il più famoso dei Ciabattini... nonché gran maestro dell\'Ordine del Cul\'a Pedate, l\'arte marziale dei Ciabattini di Amakna.";
D.q[2907] = "Bravo, mercenario!";
D.q[6493] = "Vuoi scortare il convoglio? Che proposta generosa. Tutti i volontari sono i benvenuti. Certo, sei un volontario, non vuoi essere pagato, spero. Nel caso contrario, sappi che ho dei soldati valorosi e, ehm, a buon mercato. Ci seguirai e ti accerterai che non accada niente di spiacevole. Ah, e un ultimo piccolo dettaglio, i soldati hanno come ordine di non parlare mai durante il tragitto, quindi non disturbarli, capito?\nVisto che sei qui, partirai in esplorazione, così eviterai di fare due chiacchiere con le mie guardie.";
