D.q[7431] = "";
D.q[3662] = "È questo arco di pietra che ti permette di spostarti da una parte all\'altra quasi istantaneamente.";
D.q[334] = "Sicuramente è il più bel mestiere del mondo, dopo quello di Guardiano del faro dell\'isola di Moon, Percettore, Pasticcere Mago, Domatore di Gambretti, e Imbalsamatore di Bwork Maghi. Bisogna solo saper accettare i cambiamenti climatici e non pensare alle politiche di restrizione che ci obbligano a mettere i nostri terreni a maggese.\nÈ un mestiere difficile, ma ideale per coloro che vogliono essere in armonia con la natura, e sarò lietissimo di trasmettere il mio sapere a chiunque voglia impararlo.";
D.q[4467] = "Eh? Un semplice miliziano di Bonta, ma con un equipaggiamento speciale?\nMmmh, è preoccupante. Bonta ha forse trovato un modo per equipaggiare meglio i soldati?\nVisto che non sei riuscito a sconfiggerlo, i nemici ci prenderanno ancora per dei pagliacci, questa volta mi deludi davvero. Almeno spero per te che tu non sia scappato, se no sarebbe ancora peggio. \nPer quanto riguarda il Canin Blando, almeno è efficace? A proposito, devo recuperarlo. Pizzy Karne il Macellaio mi ha proposto un ottimo prezzo.";
D.q[1561] = "È un miracolo! Il mio tabi sta meglio, ringrazio gli dei di avermi aiutato!";
D.q[7966] = "Png(1331) e Messaggio(7965)";
D.q[6641] = "";
D.q[2734] = "Una mappa? Non esageriamo! Diciamo che si tratta di un semplice promemoria... Per dirla tutta non ho ancora avuto il tempo di disegnare una mappa della foresta malefica degna di questo nome... Mi piacerebbe scrivere un libro che riporti tutte le belle passeggiate che si possono fare laggiù. È il luogo ideale per gli avventurieri, sai...";
D.q[4468] = "Eh? Un semplice miliziano di Bonta, ma con un equipaggiamento speciale?\nMmmh, è preoccupante. Bonta ha forse trovato un modo per equipaggiare meglio i soldati?\nOh, vedo che l\'hai sconfitto. Bene, così ce n\'è uno in meno, il che dovrebbe influire sul morale dei nostri nemici. Hai fatto veder loro che non bisogna prenderci per dei pagliacci, cominci a piacermi. \nPer quanto riguarda il Canin Blando, almeno è efficace? A proposito, devo recuperarlo. Pizzy Karne il Macellaio mi ha proposto un ottimo prezzo.";
D.q[7967] = "Png(1331) e Messaggio(7965)";
D.q[6820] = "";
D.q[6270] = "Mi dispiace quasi di non potermelo tenere per me. Ecco qualche kama per divertirti alla taverna. Bevi alla mia salute!";
D.q[1302] = "Una nuova tassa? Oto Mustam non ha scrupoli! Svaluta la nostra bella città! Non la pagherò mai!";
D.q[6642] = "";
D.q[135] = "È facilissimo! Per avere la possibilità di vincere il primo premio di 20000 kama, ti basta comprare un biglietto della lotteria da 10 kama.";
D.q[7968] = "Png(1331) e Messaggio(7965)";
D.q[3074] = "Uno squalo semina il panico nel porto. Vallo a cercare e dimmi dove si trova.";
D.q[2608] = "Ci sei riuscito! Tre colpi di fortuna di seguito, devo dire che non se ne vedono molti!\nIn \"Un ponte di acero\", l\'ultimo libro che sto leggendo sull\'accoppiamento degli Alberagni, i maschi che riescono a sopravvivere a tre combattimenti contro un feca sono chiamati \"kokoko koku\", affascinante no?\n\nBene! Fedele assistente, questa volta dobbiamo andare sulla penisola delle Draguova! A Ovest, sul fianco della montagna, si trova una porta simile alle precedenti, là ti aspetta la tua nuova sfida!";
D.q[3999] = "Pinta? Oh, non meriti neanche che mi occupi di te io stesso! Discepolo, vieni a dirne quattro a questo giovane sfacciato.";
D.q[7969] = "Png(1331) e Messaggio(7965)";
D.q[6643] = "";
D.q[85] = "È un ordine in cui è molto difficile entrare.\nHogmeiser era il capo dell\'Ordine del Cul\'a Pedate, ma è scomparso da anni, lasciando dietro di sé solo i suoi vecchi stivali consumati.";
D.q[7970] = "Png(1331) e Messaggio(7965)";
D.q[1581] = "Non è per me, ma ho incontrato una certa Grace Malcin un po\' a Sud di qui che ha dei problemi con il suo tabi.\nFa parte del Parlamento Bontariano, e non è bello che si deprima proprio adesso, durante le elezioni...";
D.q[5345] = "";
D.q[4437] = "Una deficiente di Sadida va a dire in giro per Brakmar che dobbiamo smettere di seguire Djaul e che bisogna rispettare la via degli anziani.\nVoglio che la elimini prima che le sue assurde parole facciano breccia tra i cittadini.";
D.q[2581] = "Perfetto! Porta 10 Bambù al Forgiatore di Scudi, sono sicuro che si mostrerà generoso con te.";
D.q[3427] = "Mi piacciono... tanto... i bambini.";
D.q[7971] = "Png(1331) e Messaggio(7965)";
D.q[7780] = "Mostramelo, presto.\nVediamo, questo va bene... Là ha reagito bene... Nessuna traccia del virus, nessuna mutazione in corso... Mmm, resta qualche residuo qui, eh, rischia di porre qualche problema.\nSenti, siamo sulla buona strada. A priori il vaccino funziona, ma credo non sarà efficace più di una settimana. Potrò vaccinarti regolarmente se mi porterai un campioncino di sangue di Pappabuk.\nNon mi resta che trovare un sistema per allungare gli effetti del vaccino e, al contrario del Conte, questo problema di Ros Olia non sarà che un pessimo ricordo.";
D.q[1018] = "Ho l\'impressione che tu abbia dimenticato la birra, pezzo d\'asino! \nSvelto, torna a prendermela!\nBisogna veramente dire tutto a questi imbranati.";
D.q[404] = "Il mestiere di Minatore è molto difficile, bisogna amare l\'oscurità, e non avere paura di affrontare un Croccaroc armati solo di un piccone.\nÈ comunque un mestiere gratificante, se lavori nelle migliori miniere puoi diventare ricco senza troppi sforzi.\nL\'attrezzo per eccellenza del Minatore è il piccone, prenditi cura del tuo e non lasciarlo arrugginire.";
D.q[2058] = "Una spada? Ti manda Nibé Lulla, vero? Quell\'ometto conosce un sacco di cose sui metalli e la vita in generale... Ecco, la tua lama è forgiata e affilata, adesso è leggera e pericolosa.";
D.q[7972] = "Credimi, il lavoro degli estrattori e delle tubature alle Lacrime di Uronigride non è di tutto riposo. Bisogna sorvegliare permanentemente gli estrattori, assicurarsi che ci sia abbastanza pressione, ma non troppa, riparare gli elementi difettosi, tenere i Croccavapore a distanza e tutta un\'altra serie di oggetti a disposizione. Non è un lavoro da funzionario, poco ma sicuro.";
D.q[4065] = "Mi dispiace, ma non ti sei ancora dimostrato abbastanza valoroso perché io possa darti un Oblio di Incantesimo. Affronta altre creature mitiche di quest\'isola e poi torna a trovarmi.";
D.q[1406] = "SÌ MI PIACE IL BLU! E ALLORA?! SONO COMUNQUE UN ABITANTE DI Brakmar!";
D.q[5217] = "";
D.q[5680] = "";
D.q[7433] = "";
D.q[2423] = "Il mestiere di Pescatore richiede più pazienza di qualsiasi altro mestiere. Il Pescatore deve prendere dei pesci che pulirà prima di venderli al Pescivendolo. Ma prendere i pesci non è così facile all\'inizio. Bisogna fare attenzione all\'ora e al luogo in cui si pesca... E anche in questo modo si rischia comunque di non prendere niente...";
D.q[7973] = "Vedo che sei d\'accordo con me. Ho perso il mio ultimo assistente quando quell\'imbecille ha confuso un bagno d\'acido con una Jacuzzi naturale... E\' morto fra atroci sofferenze, le sue urla sono durate una buona ora. Almeno avrà imparato che le apparenze ingannano.\nBeh, puoi andare da Lucetta Brifian, l\'assistente della Sindaco, e dirle che ho imperativamente bisogno di un nuovo assistente se non vuole che porto e Borgo gelino di nuovo?";
D.q[1113] = "Hei, dì un po\', dai, dì un po\', non hai un po\' di kama per me ? Posso trovarti delle armi a buon prezzo! Non hai dei kama per me ? Se vuoi, posso rubarti quello che vuoi! Non hai un po\' di kama per me ? Sono capace a sdoppiare gli oggetti, sai! Dai, non hai un po\' di kama per me ? Non ce li hai un po\' di kama per me ? Dai, dammi tutti i tuoi kama!";
D.q[5305] = "Ciao, viviamo un periodo oscuro. Numerose spie inviate alle rovine di Gisgul sono tornate con informazioni allarmanti: un potente demone avrebbe decimato parte dei loro ranghi. Ma non partirai subito, è troppo pericoloso e io ho altri problemi più urgenti da sistemare.";
D.q[7974] = "Ancora? Ne vuole uno nuovo ogni due mesi. Con questo ritmo presto non ci sarà più nessuno qualificato per aiutarlo.\nNon ho nessuno per le mani, ma magari la nostra Tuttofare Nelly Clerichetta saprà chi proporti.";
D.q[3791] = "Ciao, viaggi da solo? Ad Incarnam non avrai problemi, ma ad Amakna è molto più prudente viaggiare in gruppo. Io ho bisogno di poter contare sui miei amici. E quando voglio contattarli... op, tiro fuori l\'agenda ed è fatta. Dovresti farlo anche tu. Così potrai contattare più facilmente le persone disponibili.";
D.q[6644] = "";
D.q[7975] = "Non posso lasciar venire Francky con te, mi è troppo prezioso. Se ti serve davvero qualcuno, ti consiglio piuttosto il capo delle miniere Laurent Arancia, bighellona da più di un decennio e passa la maggior parte del suo tempo alla taverna al Borgo. Credo che lavorare non gli farebbe male.";
D.q[7976] = "Ma per chi mi hai preso? Io do gli ordini, mica li ricevo.\nSe Larry Tutthe ha bisogno di un nuovo assistente vai da Gaston. Era uno dei miei operai alla miniera, ma da quando sono infestate dai mostri si è riciclato come sorvegliante delle tubature. E\' un lavoro da funzionario.\nGli vai a dire che la sua nuova destinazione sono le Lacrime di Uronigride e che non può appellarsi alla decisione, non è mica un tribunale questo.";
D.q[3260] = "Non sembri morire dalla voglia d\'avventura, tu.\nDai smamma, che mi dai già sui nervi.";
D.q[940] = "Ciao!\nSapevi che le mura di cinta della città di Bonta sono fatte con almeno 128.369 pietre di croccaroc? Sapevi che ci sono voluti 250 operai per costruire queste mura e che un trentaduesimo di loro è morto tra atroci sofferenze durante i lavori?\nNo, non lo sapevi! Ci avrei scommesso!\n\nMa capirai sicuramente che una parte degli introiti della città, che sono di #1 kama, dovrà essere usata per pagare la pensione delle loro vedove?\n\nNo, certo? È proprio quello che pensavo. Adesso, lasciami stare, ho da fare.";
D.q[3362] = "Troverai la lista delle novità di questo aggiornamento sul forum ufficiale, nella sezione \"Diario di bordo\".";
D.q[6645] = "";
D.q[7977] = "Non disturbarmi devo sorvegliare le tubature. Se succede qualcosa mentre tu mi disturbi significa che è colpa mia e dovrò trasferirmi alla Culla di Alma. Non ho alcuna intenzione di passare i prossimi dieci anni in compagnia dei fantasmi.";
D.q[5721] = "";
D.q[3657] = "Ecco la ricetta che dovrai portare alla mia cliente Pipeletta. Ti pagherà subito.";
D.q[3406] = "La strada non è lo scopo, ma lo è il cammino che ti ci porta. Per te è stato lungo e non è ancora finito. Ma alla fine del viaggio, avrai raggiunto la destinazione? Ovvero, se la meta è raggiunta, otterrai veramente quello che brami?";
D.q[7978] = "Bagni d\'acqua calda tutto l\'anno, niente più geloni, nè Ros Olia... Cosa volere di più?";
D.q[7979] = "Mi sembra una mezza cartuccia, non vorrei fosse uno di quei funzionari che non vale nulla.\nComunque, mentre tu gironzolavi nel Borgo, sono intervenuto d\'urgenza su quell\'estrattore. Come puoi vedere la riparazione è in corso, ma ci vorrà un po\' di tempo. Prendi Gaston e fate il giro degli altri quattro estrattori per assicurarvi che tutto vada bene.\nAnche se non ci fossero problemi, torna da me per tenermi al corrente.";
D.q[6646] = "";
D.q[3883] = "Adulazione... bravo, complimenti... ora andrò a parlare con il tuo maestro, vermiciattolo. Ah già, restituiscimi l\'insegna da Ladrurbo, non la meriti ancora...";
D.q[4127] = "Ecco, tutto è pronto per la tua partenza.\nPartiamo quando vuoi. Ma attento, il viaggio è pericoloso, ti consiglio di partire con degli amici, delle persone un po\' più forti di te, poiché non sono sicuro che tu riesca ad arrivare alla fine del viaggio... persino un volgare gabbiano perverso potrebbe batterti con qualche colpo ben piazzato.";
D.q[7980] = "Che genere di danni?\nAh, vedo. Gaston sta andando a sorvegliare l\'estrattore danneggiato mentre tu vai da Nelly Clerichetta a cercare una cassa di materiale.\nNon ti preoccupare per l\'elenco, è abituata e sa cosa mi serve, è una gran brava ragazza.";
D.q[7545] = "Qui riposa Giorbak il Veniale. Non entreranno che quelli ricchi di kama per attirare la sua brama. Undici kama per ogni anno in cui ha vissuto prima di perdere la sua fortuna. Più sei kama che erano tutto quel che gli era rimasto.";
D.q[2549] = "Ha aggiunto: \"digli che non può lifiutare questo onole, soplattutto con quello che sappiamo su di lui...\"";
D.q[6647] = "";
D.q[548] = "Ciao giovane mozzo *hic* il momeento è criitico *hic*! Presto non ciii saranno piiù bevande *hic* per riempire la stiiiva *hic*. \nE non soolo *hic*, la mia muusa è scomparsa *hic*, il mio graande scheletro di leegno *hic*, il mio mooodello delle ore peerse *hic*.";
D.q[1243] = "Hum, questa ricetta deve provenire dai magazzini di Bonta, mi chiedo come abbia fatto ad arrivare nelle tue mani, ma lasciamo stare...\nServono 3 misure di polvere di Perlinpanpan e 1 olio di Gomto per ogni misura di polvere, dovresti anche prestarmi una selce per realizzare questa ricetta.";
D.q[7981] = "Francky, aiutami.\nAllora, serve questo, questo, ci serve questo strumento... Due scatole...\nOh, è pronto, con questo Larry Tutthe potrà affrontare qualsiasi situazione.";
D.q[7662] = "Fa così freddo qui...";
D.q[3724] = "Pìu pìu pìu ?";
D.q[1544] = "Hmm... vedo creature atroci... vedo luoghi esotici e strani... ti vedo mentre combatti mostri giganteschi... hai raddoppiato la tua forza, e i tuoi sensi... i tuoi numerosi combattimenti ti hanno dato molta esperienza, sarai un grande guerriero #1!";
D.q[4475] = "Ah! In una grotta del territorio Porcos. Un paranoico? Non sarà facile negoziare con lui, soprattutto se scopre chi siamo. Però bisogna provare, al massimo c\'è sempre la soluzione d\'urgenza.";
D.q[2412] = "Ciao, cerchi lavoro? Allora sei nel posto giusto. Posso informarti sui diversi mestieri e posso dirti anche dove trovare un eventuale maestro.";
D.q[1248] = "Hmm, vuole che lo sostituisca alla porta Nord? Va bene, ma dopo la mia pausa al Maokemao. \nPff, ti ringrazio.";
D.q[7982] = "Mostramelo.\nVediamo, ha pensato a questo, due scatole di quello, gli strumenti per far quell\'altro... Si, ho l\'impressione che non manchi nulla.\nGrazie, hai fatto un buon lavoro.";
D.q[6648] = "";
D.q[2216] = "Per la Bauxite, il Ferro e il Manganese, grazie! Senza di te questi ratti giganti ci avrebbero mangiato! Non abbiamo mai visto niente di così grosso! Stavamo facendo la ronda del sotterraneo quando queste bestie ci sono piombate addosso bloccandoci. Credo proprio che ci sia ancora qualche rissa, ma tutto questo eco mi impedisce di capire dove... Santo piccone, ma cosa sta succedendo ad Astrub?";
D.q[2241] = "Vecchio mio! Guarda un po\' questo minerale...\n*mostra una pietra deforme che somiglia un po\' al minerale di ferro*\nDeve valere una piccola fortuna, no?";
D.q[2400] = "Fare il Minatore è una pura vocazione. Questo mestiere richiede molto tempo ma può rivelarsi molto redditizio. All\'inizio, si trovano solo ferro e pietraia... ma è solo questione di tempo. Con l\'esperienza, infatti, si arriva anche ad estrarre oro e persino pietre preziose!";
D.q[3166] = "Ah, sento che sei ancora confuso!\nCome posso aiutarti?";
D.q[1021] = "Hmm! Finalmente, non ho tempo per occuparmi della mia sciabola.\nVai nel quartiere dei Forgiatori e chiedi a Kosuke di ripararmi la lama.";
D.q[3087] = "Una missione compiuta nel migliore dei modi. Ora posso andare a bere un po\' di latte di maiale con la mia vecchia amica Verru Kosa. Grazie a lei, ho potuto constatare che sei una persona di fiducia.";
D.q[2842] = "Vuoi tornare? Ti accompagnerò fino allo zaap del villaggio, e da lì raggiungerai lo zaap centrale.";
D.q[1233] = "Hmm capisco, un\'altra volta Mustam, ogni volta che qualcuno lo scoccia me lo manda qui. L\'ultima volta è toccata a Lothar Murofud, quant\'è impaziente quello... \nHo un piccolo servigio da chiederti, vai a dire a Tink Berval che mi sostituisca. Non ce la faccio più a sorvegliare questa porta!";
D.q[7569] = "Bene, non scherzi, a quel che vedo. Sei pronto ad esplorare il vasto continente di Amakna e altro ancora.";
D.q[2449] = "Ciao avventuriero, benvenuto nella dimora del Clan dei Mercenari. Siamo un gruppo di Mercenari devoti al popolo, pronti ad onorare qualsiasi tipo di contratto. Per qualche kama potremmo aiutarti a ritrovare l\'oggetto che cerchi tanto, accompagnarti in un\'avventura, eliminare il tuo peggior nemico o altro ancora... Non esitare ad entrare per conoscerci o a contattare un Maestro del Clan se vuoi diventare dei nostri.";
D.q[1238] = "Che bel sole, vero?";
D.q[7983] = "Già che l\'hai proposto... Mi serve aiuto per prelevare dei campioncini di sangue e trasportarli al Borgo. Ho affittato una parte del magazzino di Nest\'Leh per mettere le bottiglie e fare la mie ricerche, quindi se hai tempo bisogna fare dei prelievi qui e portarli laggiù.";
D.q[6583] = "Ah, lui? È la prima volta che lo vedo. Voleva sapere se lavoravo per Bonta, ma gli ho risposto di no. Però gli ho detto che Nara sì, ho fatto bene?";
D.q[7984] = "Strano, non somiglia a nulla che io conosco. C\'è da dire che non sono un naturalista. Credo sia meglio se mostri quel che hai ad un alchimista, è più la sua sfera di competenza che la mia. Vai a portare i campioni a Nest\'Leh.";
D.q[1445] = "Ah, voglio battermi! Voglio battermi! Ma sono il più forte ed è per questo che nessuno vuole battersi con me! Hanno tutti paura di me! Haha! Hei tu! Hai voglia di farti battere, o striscerai ai miei piedi come tutti gli altri?";
D.q[6651] = "";
D.q[2804] = "Ah, ho capito, circostanze eccezionali, ti accompagno direttamente dal Maestro, e subito dopo averci parlato, ti accompagnerò anche verso l\'uscita. Che bravo, no?";
D.q[4539] = "Ah, sei tu! Possiamo cominciare l\'attacco? La pattuglia di Brakmar arriverà da un momento all\'altro.";
D.q[7985] = "Non hai da fare altro che posarli in quell\'angolo, li aggiusterò più tardi.";
D.q[5688] = "";
D.q[4806] = "Ah, sei tu! *hic* Effettivamente ho proprio bisogno di te. Dovrei presidiare il processo sul presunto tradimento del Miliziano Bast Konliskerz ma ho rotto *hic* il mio Martello. Me ne servirebbe uno nuovo... ma non un martello qualsiasi. Ho bisogno *hic* di un Martello di Raschiatura. Conto su di te.";
D.q[5267] = "Capiti a proposito, mentre gli altri soldati si occupano delle truppe, noi attaccheremo Ronan il Barbaro. I goblin sono creature vigliacche e poco furbe, se riesco ad uccidere il loro capo, abbiamo la vittoria in tasca. Tu ti occuperai di distrarre le guardie.";
D.q[4442] = "Ah, perfetto. Dovrò riuscire a non perdere delle spie questa volta. L\'altro giorno hanno confuso il boccale del Veleno con quello del nostro Unguento di Furtività e... insomma facciamo fatica a nasconderci, quindi trovaci un nascondiglio perché qui brulica di Bontariani. Fai in modo di trovarcene uno tra qui e la biblioteca, così non saremo obbligati ad attraversare tutta Bonta.\nVisto che ci sei, scegline uno già abitato e neutralizza i suoi residenti senza ucciderli, abbiamo bisogno di cavie vive per testare il Veleno. Prendi 10 Fili di Lino per legare ogni residente.";
D.q[2224] = "Ah grazie per il dolce, tieni questo per la consegna.";
D.q[7986] = "Com\'è carino, dove l\'hai trovata? Alle Lacrime di Uronigride???\nNon sono molto esperto in creature, dovresti andare da un altro alchimista, ma dubito che ne troverai uno capace su Frigost. Credo sia meglio per ta andare a cercarne uno al di fuori, ti farà risparmiare tempo.";
D.q[6652] = "";
D.q[7663] = "Miaouuuhh !";
D.q[2505] = "Viva Pandala!";
D.q[7987] = "Sembra interessante, ma non ho tempo per occuparmene.\nVai dal mio assistente Kimiya, al laboratorio sotterraneo della spiaggia di corallo. Sarà felice di fare ricerche su questa creatura.";
D.q[6567] = "Ah, preferisco così. Non mi fido delle persone che esagerano: nascondono sempre qualcosa. Almeno ora non ti sei lasciato sopraffare, vuol dire che non vuoi davvero imbrogliarmi. Rifletterò sulla tua proposta.";
D.q[5727] = "";
D.q[4925] = "";
D.q[5316] = "Mi hai portato l\'indennità rischi? Ce ne hai messo di tempo...";
D.q[6653] = "";
D.q[7988] = "Non avevo mai visto niente di simile. La crescita di questa creatura è come paralizzata.\nDovrei poter fare qualcosa, ma mi servono gli ingredienti per le mie pozioni.\nTerrò la creatura sotto osservazione mentre vai a cercarmi 10 Bave di Kaskargo e 1 Pistillo di Tynril. Oh, mi serviranno anche degli oggetti prelevati dal luogo dove hai trovato la creatura, dovresti portarmi una decina di uova piene di vapore.";
D.q[6423] = "Come insiste questa tipa! Fammi vedere la tua spada.\n...\nHo già visto questo tipo di spada nelle mani di Ecaflip che vivono al di fuori della città. Non so bene dove precisamente, se pensi che mi ricordi di tutti i luoghi che bazzico. Tra l\'altro, a proposito di bazzicare, ti avevo chiesto di andartene e allora cosa ci fai ancora qui? Vuoi che ti faccia ancora più bella a colpi di artigli? Che poi, guarda, potrebbe farti comodo.";
D.q[1449] = "Ah perfetto! Molto bene, finalmente possiamo dedicarci a cose più serie... Hum, un idiota ha incendiato le riserve di legno che servivano per il riscaldamento della milizia. Se non vuoi ghiacciarti il sedere, porta qui 10 cortecce di Alberagni. 10, non dimenticarlo, anzi, tieni un appunto, data la tua storditaggine.";
D.q[6655] = "";
D.q[7989] = "Tutto è pronto, mi manca solo quel che mi hai portato tu.\nBasta aggiungere questo, mescolare, mettere il tutto su questa strana creatura... Ha funzionato!\nLa crescita è ripresa in maniera accelerata. Sbrigati a riportare questa creature dove l\'hai trovata se vuoi che arrivi a maturità senza effetti secondari.";
D.q[1273] = "Lasciami in pace!";
D.q[6656] = "";
D.q[7990] = "Grazie di avermi salvata. Il demone mi aveva lasciata qui allo stato di larva, ma la glaciazione ha fermato la mia crescita. Ora che sono adulta e libera di fare quel che voglio, andrò a cercare un modo per provarti la mia riconoscenza.";
D.q[398] = "Ciao, mi chiamo Eowina Fiala, e sono una grande specialista di pozioni. È il tuo giorno fortunato, ho proprio bisogno di ingredienti. Aiutami a trovarli e ti ricompenserò.";
D.q[1180] = "Ciao, ciao! Cosa desideri, pollo, vitello, maiale?\nPossiamo soddisfare qualsiasi gusto, persino i più esigenti. Chiedi quello che vuoi!";
D.q[4525] = "Ah, rieccoti qua. Danathor voleva vederti di nuovo. Cominci a farti conoscere da queste parti, vogliono tutti assumerti!";
D.q[93] = "Ciao, ho bisogno di alleviare le mie sofferenze, perché mi sono strappato i baffi battendomi con un Buulupo. Per favore, se ti avanza del pane, fammi la cortesia di darmelo. Scommetto che non conosci Wiss Catz.";
D.q[6657] = "";
D.q[7991] = "Prima di partire prendi queste monete. Le ho trovate in fondo alla vasca. Non mi sono di molta utilità, ma ho visto che tu ne hai, quindi magari a te servono per qualcosa.";
D.q[7664] = "Grace si trova alla milizia ora, se non erro. E\' una persona incantevole, ma le sue responsabilità in seno al consiglio le impongono di prendere talvolta decisioni difficili.";
D.q[3030] = "Hola compagno! La vita vale la pena di essere vissuta solo su un campo di battaglia, vero? Gli allenamenti virili, le ronde al chiaro di luna, ti piace eh? E non ti ho ancora parlato del buon cameratismo dei miliziani di Bonta! Allora, hai deciso, vuoi arruolarti?";
D.q[3775] = "Vuoi ritornare alla statua?";
D.q[7992] = "Sapevo che il tragitto verso il villaggio era pericoloso, ma non avrei mai pensato che saremmo stati attaccati sulla strada del ritorno.\nAiutaci per favore.";
D.q[4838] = "Ah, eccoti. Il piano va come previsto?";
D.q[4945] = "Ah, eccoti. Ho appena ricevuto un rapporto inquietante. Delle truppe di Brakmar, capitanate da Oto Mustam in persona, sono state avvistate in direzione di Amakna. Ho mandato delle truppe scelte e ti chiedo di unirti a loro sotto il comando dell\'ufficiale Imagiro. I soldati hanno montato l\'accampamento vicino al tempio Yop. Te l\'ho indicato sulla mappa.";
D.q[6096] = "";
D.q[315] = "Invece di piegarti in due dalle risate, vai a cercare una decina di Ali di Moskito. Devo assolutamente trovare qualcosa di geniale e le Ali di Moskito mi aiutano a riflettere. Non lo meriti per niente, ma ti ricompenserò.";
D.q[7993] = "Credo che le cawote siano cotte per noi.";
D.q[4283] = "Eccoti! Non indovinerai mai cosa mi è successo!";
D.q[1572] = "Haha, ho veramente rischiato di perdere la mia bottega, ma Danathor, che è un cliente abituale, non è dello stesso parere di Amayiro, e sta studiando una legge che autorizzi il combattimento di tofu!";
D.q[7341] = "";
D.q[7342] = "";
D.q[1330] = "HYYAAAAH! Per Jiva, poveri Wabbit! MA SEI UN MOSTRO, VATTENE!";
D.q[3363] = "Ehi? Ce l\'hai fatta? Ce l\'hai fatta veramente?\nUuh... Bene, allora... lasciami leggere il manuale... Bla bla bla... Dodici milioni di protezioni consumate di Bwork... no, non è questo... Ah, ecco: \"Ha trovato i sei Dofus\". Allora... devo darti...\n...\n...\nHmmm. Sei pronto per ricevere la ricompensa?";
D.q[7994] = "Quando penso al male che ci siamo fatti per rifornire gli abitanti del Villaggio Sepolto... C\'è da credere che gli dei si accaniscano contro di noi...";
D.q[5017] = "Fallanster è assente? Allora non c\'è tempo da perdere! Devi andare a rapire Allisteria adesso. Usa la forza se vuoi, ma portala qui il prima possibile.";
D.q[5734] = "";
D.q[7343] = "";
D.q[6475] = "Ti capisco, deve essere orribile. Finite le serate passate sotto le stelle nelle pianure di Cania, più nessuno per confortarti la notte, più nessuno per leccarti il mattino.\nLa perdita di un famiglio è sempre un momento difficile e delicato, ma ho sentito dire che è possibile riportare in vita un fantasma di famiglio. Per far ciò devi trovare un santuario nella palude e passare tutte le prove.";
D.q[2680] = "Ahahahah! Non è certo ad un Pandawa che insegnerò questo!";
D.q[2841] = "Un membro dell\'Ordine dell\'Occhio Attento ci ha portato i resti di tre rinnegati Bontariani. Abbiamo bisogno di interrogarli, ma i metodi classici di resurrezione non funzionano.\nVammi a prendere il volume intitolato \"La benedizione d\'Orazzal\" in biblioteca.";
D.q[7995] = "Pensavo che dopo aver raggiunto il villaggio la parte più dura sarebbe stata fatta. Mi sbagliavo.";
D.q[6479] = "Ah, sei tu? Avvicinati, Amayiro mi ha chiesto di farti avere un messaggio perché lui non poteva farlo, teme di essere spiato.";
D.q[5168] = "";
D.q[3917] = "Hum, non so proprio cosa stia escogitando mio zio, ma la mia nutrice mi ha fatto venire al castello e mi ha preso le misure per un vestito. È alquanto strano, porto lo stesso vestito da secoli e ora all\'improvviso mi vogliono fare un vestito nuovo!";
D.q[7996] = "Se ne usciamo vivi credo che non rimetterò mai più i piedi qui.";
D.q[5020] = "Allora? Dov\'è Allisteria?";
D.q[7344] = "";
D.q[4178] = "Sono io Coccodrail Dandy, quello che fa biancheria maliziosa in scaglie di coccodrail, quello che ipnotizza i cinghiali delle pianure con le dita, quello che ha sempre voluto trasformare quest\'isola in un parco di divertimenti!\nSono persuaso che gli avventurieri in cerca di nuove esperienze vorrebbero visitare quest\'isola nel bel mezzo di tutte le creature mostruose. Gli avventurieri di oggi adorano avere paura, ma non rischiare. Sfortunatamente, da quando le creature sono scappate dalle loro gabbie e vivono liberamente, la mia idea di fare un parco di divertimenti è andata a farsi benedire, e allora devo ripiegare su altre soluzioni.";
D.q[7997] = "Grrrr.";
D.q[1531] = "Oh, questo è un quartiere calmo, i Panettieri fanno il loro lavoro coscienziosamente, e gli abitanti mi vengono a trovare spesso.\nMmh, la sera però si anima un po\' a Nord, nei pressi della casa di Ufot...";
D.q[2624] = "Argh! Come sei riuscito a capire che non sono un vero Pandawa?!";
D.q[3521] = "Me primo magoblin!";
D.q[6822] = "";
D.q[4209] = "Hum, vista la tua costituzione avrò sicuramente bisogno di una reliquia di Corallaio Magistrale per preparare la tua pozione. Una volta ridotta in polvere, potrò ottenere tutta la potenza magica di cui ho bisogno.";
D.q[7998] = "";
D.q[4114] = "Sono il Guardiano del Ponte della Morte.\nRispondi correttamente alle mie domande per attraversare questo ponte, o morirai.";
D.q[5271] = "";
D.q[1116] = "Meeeouw.... FFFfffffffffffffff!";
D.q[7345] = "";
D.q[4356] = "Degli Ecaflip? Non corro il rischio di averli visti, li rifiuto nella mia taverna. Insomma, la maggior parte. Passano il tempo a provocare i clienti e a far scoppiare dei litigi con i loro giochi.";
D.q[7999] = "";
D.q[1850] = "Maow!";
D.q[2640] = "Lanma è libero?";
D.q[8000] = "";
D.q[5564] = "Sono appena arrivato, non ho ancora lanciato il sortilegio. Se la pozione è contaminata, preferisco affidartela. Prendila.";
D.q[4087] = "Hum, vista la tua costituzione avrò sicuramente bisogno di una reliquia di Corallaio Magistrale, una di Gurlo il Terribile, una del Rasbul Maggiore e una del Tynril per preparare la tua pozione. Una volta ridotte in polvere, potrò ottenere tutta la potenza magica di cui ho bisogno.";
D.q[8001] = "";
D.q[665] = "Sono io Hel Munster. Molte persone mi giudicano il miglior medico di Amakna, eppure non sono altro che un umile ricercatore che gravita attorno a tutto ciò che ha a che fare con la magia. E per quanto riguarda le missioni, non ho mai avuto tanto lavoro come in queste ultime settimane.";
D.q[5730] = "";
D.q[6430] = "Dei viaggiatori Ecaflip? Decine di viaggiatori passano ogni giorno da questa entrata, e parlo dei giorni tranquilli. Il traffico raggiunge facilmente molte centinaia di viaggiatori in occasione delle fiere, delle festività, dei pellegrinaggi...";
D.q[7138] = "";
D.q[6982] = "";
D.q[8002] = "";
D.q[4226] = "Sono Krula, il profeta di un terribile mostro... Quello che si nasconde dietro questa porta distruggerà le tue ultime speranze di tornare a casa. Senti il fracasso che fa quando si sveglia al mattino, è il terribile suono del re dell\'isola, il re del mondo!";
D.q[4951] = "Ah, eccoti, insetto! Ho dei grandi progetti per te. Queste maledette manette mi impediscono di agire come voglio, allora conto su di te e sulla tua efficacia nel compiere le missioni che ti darò.";
D.q[6987] = "";
D.q[4376] = "Ah, vedo che la nostra proposta t\'interessa. Lo scambio è semplice: il gioiello in cambio di 10000 kama. E la tua vita. Ti darò un gioiello falso che darai al tuo cretino di capo. Allora?";
D.q[1890] = "Prendi questa forbice - combatti solo con quest\'arma altrimenti rovinerai il fiore. Vai a cacciare delle rose demoniache a Nord-Ovest da qui, le troverai nei campi vicino alla fattoria.";
D.q[3283] = "No, non scherzo, avresti dovuto vederla con i tuoi occhi. Era impressionante!\nNe ho approfittato per usare la barca come un ponte, e far pagare i turisti che volevano raggiungere l\'isola di Moon senza dover entrare in quello stupido cannone.\nSono diventato talmente ricco grazie a questa mia brillante idea che ho potuto finanziare la costruzione del ponte di Pandala e la ricostruzione dei bastioni di Bonta.\nPoi però la mia barca è scomparsa, inghiottita nel Mar di Asse dal Kralamore Gigante dell\'Isola di Moon.";
D.q[7137] = "";
D.q[8003] = "";
D.q[8004] = "";
D.q[4291] = "Penso che tu abbia indovinato il tuo prossimo incarico. Vai alla taverna del Pandawa Ubriaco tra le 16 e mezzanotte, trova Xefires e parlagli della nostra proposta: una grande borsa di kama in cambio della sua obbedienza.";
D.q[7140] = "";
D.q[5787] = "";
D.q[6836] = "";
D.q[8005] = "";
D.q[4361] = "Ahhh... credo di ricordarmi, sì. Ludac...";
D.q[1939] = "Ahhh finalmente si combatte! Ahahaha! Di\' al tuo maestro che ce ne occuperemo noi! Ci sono un sacco di nuove reclute che non chiedono di meglio! Tuttavia avremo bisogno di aiuto, perché non chiami anche i nostri amici Aniripsa e Feca?";
D.q[3152] = "È un bellissimo mestiere, ma forse un po\' troppo stancante per una ragazzina come te.\nSto scherzando! Lavoriamo soprattutto con gli Allevatori, costruiamo per loro molte macchine che li aiutano ad occuparsi delle Cavalcature. Ma le Cavalcature sono abbastanza rozze e le macchine finiscono presto per rovinarsi. Il che, alla fine, è ottimo per i nostri affari!";
D.q[5277] = "";
D.q[6993] = "";
D.q[2231] = "AAAhh, questo è il mio dolce, non c\'è niente di meglio di un po\' di zucchero tra due spade! Tieni ragazzo mio, proprio al momento giusto.";
D.q[8006] = "";
D.q[4517] = "Aaaargh, non ti avvicinare!";
D.q[1086] = "Ecco la tua nuova lama! Come, ho fatto in fretta? Non sono mica il più famoso Forgiatore di spade di Bonta per niente...";
D.q[8007] = "";
D.q[4005] = "Non abbastanza!";
D.q[460] = "Ehi mozzo! Ti va un viaggetto? Facendo il giro del mondo in 80 giorni ho scoperto una piccola isola molto carina, abitata da strane creature. Ne abbiamo infilzata qualcuna e, sinceramente, la carne è deliziosa. Se vuoi spararti un viaggio gastronomico, ti propongo l\'andata e ritorno per 500 kama.";
D.q[7141] = "";
D.q[5709] = "";
D.q[6669] = "";
D.q[8008] = "";
D.q[6262] = "Ahia! È Oto Mustam che ha ordinato di ritardare il suo trasferimento nel caso in cui i Bontariani avessero tentato qualcosa di stupido. Non ha avuto torto.";
D.q[4371] = "Non sei riuscito a proteggere il convoglio, è seccante. I banditi si sentiranno al sicuro e la loro audacia aumenterà. In ogni modo, non siamo ancora con la schiena contro il muro.";
D.q[666] = "Ti insegnerò le basi della creazione di oggetti magici, solo a due condizioni:\n-che tu conosca la fabbricazione degli oggetti normali.\n-che tu dia prova di meritare i miei insegnamenti.";
D.q[6671] = "";
D.q[5632] = "Penso che il dio Xelor dia troppi poteri ai suoi discepoli e che i Feca siano lo scherno di tutta Amakna, anche se nessuno osa dirglielo in faccia.";
D.q[4373] = "Ho avuto una riunione con il consiglio e nonostante qualche reticenza, sono riuscito ad ottenere il suo avvallo per tendere una trappola ai banditi. Un gioiello di gran valore sarà trasportato fino ad Astrub, ma aggiungerò qualche miliziano scelto alle guardie.";
D.q[6672] = "";
D.q[1094] = "Olalà, non hai fiducia? Prendilo, ma non dimenticarti di ridarmelo.";
D.q[4066] = "Ho scoperto quest\'isola molti anni fa, un po\' per caso... Cercavo una specie di nuovo eden, un\'isola non contaminata da tutte le perversioni che si possono trovare sul continente...\nHo trovato quest\'isola per sbaglio, ne stavo cercando un\'altra ma la mia barca si è arenata qui. Sarei potuto essere più sfortunato, quest\'isola è semplicemente magnifica.";
D.q[5320] = "Ho una moglie e quattro bambini da sfamare, quindi è normale che mi diano un\'indennità rischi. Giusto?";
D.q[5529] = "Buona fortuna per la tua nuova vita ad Amakna.";
D.q[8009] = "";
D.q[4768] = "Bene, hai superato tutti i tuoi incubi. Oto sarà soddisfatto dalla potenza della Lama.";
D.q[6673] = "";
D.q[6674] = "";
D.q[430] = "Ho diverse missioni da proporti, ma per alcune di loro ho bisogno di uomini degni di fiducia che hanno dato prova di lealtà al clan dei Ladrurbi.\nTi puoi specializzare in più domini, dal furto all\'assassinio per esempio, ma ho anche bisogno di fattorini che facciano da tramite tra i vari Maestri Ladrurbi della regione.";
D.q[1772] = "Ho insegnato ai Dabol le tecniche di combattimento Ecaflip. Così saranno degli ottimi avversari qualunque sia il tuo livello.";
D.q[8010] = "";
D.q[6676] = "";
D.q[6675] = "";
D.q[2697] = "Yes, finalmente un falso Dofus... ma scolpito in un minerale prezioso, e da una Anutrofina molto abile con le mani... te lo posso confermare!";
D.q[4484] = "Ho una nuova missione per te. Secondo una recente lettera di Xefires, abbiamo proprio fatto bene a corromperlo, il bastimento Bontariano La Sedecrem avrebbe le stive piene zeppe di oggetti magici. In questo momento si dirige verso il Porto di Madrestam per essere scaricato e tu devi rubare il suo contenuto prima che sia sotto una buona scorta. Comincia interrogando il capitano Lily per sapere se il bastimento è già arrivato. Tanto vale avvisarti subito che se fallisci subirai il supplizio della Tofuna.";
D.q[8011] = "";
D.q[5301] = "";
D.q[5711] = "";
D.q[5774] = "Ciao, sono Pappawa, una delle giocatrici più famose del Pappaball di Amakna. Ho perfino allenato la squadra ufficiale del re Allister. \nSe ti va posso farti scoprire il nuovo terreno di Pappaball...";
D.q[753] = "Ho un\'indagine da affidarti: devi cercare delle informazioni su AncestralZ. È uno pseudo giustiziere mascherato che vuole fare la legge, ma la legge sono io. Chiedi a tutti gli abitanti di Bonta e scopri di chi si tratta.\n\n(Uno di loro mente, e gli altri lo coprono, il segreto è di trovare quello giusto.)";
D.q[737] = "Ho parlato di te a Danathor, l\'intendente di Bonta, e vuole incontrarti. Non so perché, suppongo che abbia un servizio da chiederti o qualcosa da offrirti...";
D.q[5278] = "Ciao. Mi spiace disturbarti di nuovo, ma la saggia Jiva ha chiesto di te per una questione molto importante.";
D.q[2542] = "Ho detto: per prima cosa porta un Pandapiler al Maestro di Aksadala!";
D.q[8012] = "";
D.q[4464] = "Ho ricevuto un rapporto inquietante. Numerosi tra i nostri guerrieri sono stati sconfitti e lasciati come morti sulla strada verso Astrub. In questo momento il colpevole dovrebbe essere ancora in strada.\nVoglio che tu faccia un\'inchiesta e che lo trovi.";
D.q[2154] = "Oh... un visitatowe nella mia fowesta, devi essewe vewamente cowaggioso per avventuwawti qui.";
D.q[169] = "Ho bisogno di Legno di Frassino per alimentare il fuoco del camino della taverna, ma non ho più il tempo di procurarmelo da solo. Se me ne porti un\'unità, ti darò dell\'acqua in cambio.";
D.q[6679] = "";
D.q[2805] = "Ti trovi nel villaggio di Terradala, ma nessuno può entrare, se non coloro che abbiano recentemente dimostrato la loro forza.";
D.q[5646] = "Ho seguito il tuo percorso, Tagliagole. Fai dei progressi, ma, secondo i miei gusti, non abbastanza velocemente. Se vuoi ottenere una posizione importante nel nostro Ordine dovrai muoverti di più.";
D.q[1619] = "Ho le vertigini, sì sì, anche se può sembrare strano per qualcuno di questo villaggio, ho paura del vuoto da quando sono piccolina. Per calmarmi mia madre mi dava delle caramelle alla gelatina, sapeva che ne andavo matta.";
D.q[8013] = "";
D.q[4936] = "";
D.q[6680] = "";
D.q[5054] = "E così gli Amaknei vogliono negoziare direttamente con Amayiro. Comunque sia Ebru of El ha seguito il consiglio di ritirare le truppe da Amakna, quindi per ora il problema è risolto...\nGrazie per avermi avvertito, mi ricorderò della tua devozione.";
D.q[2861] = "Non ho niente da insegnarti ora. Torna più tardi.";
D.q[7845] = "La perforatrice e le linee di pesca ci creano parecchi problemi, si consumano più velocemente di quanto possiamo ripararle.\nSe te la senti mi servono 5 legni di Pioppo Tremulo per riparare la perforatrice. Mi servono anche 50 Lane di Pappabuk, 30 Lane di Pappabuk leggendario e 5 Lane di Realbuk per confezionare delle corde e riparare le linee di pesca, più 5 Zanne di Ghiaccinghiale e 5 Denti di Saberbuk per gli ami.\nPer informazione, le caldaie delle nostre perforatrici funzionano con grasso di Pinguinotto, non con legno.\nGli alberi sono troppo rari per essere sprecati, ma al contrario i Pinguinotti sono così numerosi da poter essere decimati senza rimorso.\nPortami dunque 100 Grassi di Pinguinotto che io possa usare da combustibile.";
D.q[556] = "Ebbene, per la modica somma di 200 kama, posso venderti un\'andata diretta per il paradiso e questa volta l\'agenzia garantisce al 100%: soddisfatti o rimborsati!";
D.q[8014] = "";
D.q[5239] = "Ho bisogno che tu vada da certi amici per ottenere delle informazioni utili su di loro. Hai capito coso voglio dire... no? Insomma, sapere cosa desiderano, cosa gli sta a cuore...";
D.q[1309] = "Ahahah, che banda di idioti! Sei molto efficace!";
D.q[6683] = "";
D.q[3353] = "Tu vuoi andare a tosare il re dei Pappatutto, vero? Allora, o cerchi la chiave del suo antro nelle viscere di uno dei suoi sudditi, o mi porti quello che c\'è scritto su questa lista.";
D.q[493] = "Non ho nessuna lettera da consegnargli per adesso.";
D.q[5007] = "Adoro il mio tabi e non sopporto di vederlo soffrire. È come se facesse parte della famiglia.";
D.q[5716] = "";
D.q[6684] = "";
D.q[1375] = "Ma ne mancano ancora... non posso redigere un rapporto corretto se non ho tutti i campioni che coprono la totalità della zona di studio.";
D.q[6686] = "";
D.q[1235] = "Solo nove pods? La milizia usa veramente le pinzette, se vogliono sterminare Brakmar, non possono limitarsi così!\nMa vabbé, visto che sei qui in nome della milizia, ti faccio tutto al 50%, quindi sono 18000 kama...";
D.q[6742] = "Non ho visto nessun sospetto per il momento, ma tengo gli occhi aperti.";
D.q[6687] = "";
D.q[8016] = "";
D.q[6685] = "";
D.q[5919] = "";
D.q[8017] = "";
D.q[687] = "Ed ecco la seconda questione,\nCome si misura l\'attenzione\nin una coppietta di innamorati?\nIn termini di quantità, ti siamo grati.";
D.q[5717] = "Ho parlato di te ai diversi Maestri d\'Ordine e sono pronti ad accoglierti nei loro ranghi. Per farlo devi recarti alla Torre degli Ordini di Bonta e parlare con loro per scegliere la tua strada.\nTuttavia non è urgente, hai tutto il tempo che vuoi per scegliere un Ordine e non si tratta di un obbligo.";
D.q[3862] = "Ciao!";
D.q[5021] = "Un buono per un Bus Nano 638! Geniale, questo mi farà risparmiare 100000 Kama. \nRingrazia Danathor da parte mia.";
D.q[6689] = "";
D.q[8018] = "";
D.q[6690] = "";
D.q[648] = "Da un po\' di tempo ho la ricetta di un oblio incisa su un arco per non dimenticarla. Eccola:\nOblio di Freccia Magica: 4 legni elastici, 5 anelli mentali, 10 archi di cristallo puro, 1 secchio d\'acqua.\nSpero che ti possa aiutare.";
D.q[6322] = "Ho appena avuto cattive notizie e non sono di buon umore per riceverne altre. Parla se hai una buona notizia da annunciarmi, se no sloggia prima che il tuo sangue ridipinga i muri di questa stanza.";
D.q[2676] = "Non tornare da me prima di avermi portato quello che ti ho chiesto: una fiala di Pandapils!";
D.q[8019] = "";
D.q[2065] = "Te l\'ho detto! Lei mi aveva predetto il tuo arrivo qui. Ora, come ogni bravo iniziato, dovrai creare il tuo primo legame con lei. Per farlo, la natura accetta di sacrificare per te un po\' dei suoi beni, ma in cambio dovrai proteggerla. Vai dal Taglialegna, ha sicuramente quello che ci vuole: un ramo di legno di Arash. Poi torna da me.";
D.q[6342] = "E per chi altro credi che lavori io? Non siamo a Bonta? Dovresti pensarci due volte prima di fare delle domande così stupide.";
D.q[2528] = "È per una libagione alla dea?";
D.q[4352] = "Notizie di questo mercante?";
D.q[5402] = "Dai, canta con me questo ritornello: \"Bibi bibi bibi Bibiblop. Nelle Pianure Rocciose. Sei il re dei Blop. Bibi bibi bibi Bibiblop. La tua amicizia è forte come la roccia.\"\nCome... Non vuoi cantare con me? Vuoi solo entrare nel dongione? Dammi la chiave e ti lascerò entrare.";
D.q[6691] = "";
D.q[1099] = "Hmm, i loro cannoni sono buoni, sono stati fabbricati nell\'atelier qui vicino.\nL\'unico problema è che Amayiro è fissato con le armi bianche, quindi sono spesso lasciati in magazzino durante le battaglie...";
D.q[7355] = "";
D.q[4929] = "";
D.q[4096] = "Lontano dalla mia vista, spergiuro!";
D.q[488] = "Ho mandato Yrun Teller, uno dei miei discepoli, a rubare il Manuale del sarto di Amakna. Ahimé, non è ancora tornato, e ho paura che abbia deciso di tenerselo. Se mi riporti questo manuale intatto, saprò come ricompensarti.";
D.q[6818] = "";
D.q[6692] = "";
D.q[4054] = "Oh, che affronto! Sono la più grande sarta di Bonta, le personalità più celebri si rivolgono alle mie dita di fata per farsi confezionare gli abiti più belli!";
D.q[2405] = "Sei sicuro di voler diventare Ciabattino?";
D.q[1917] = "Png(471) e Messaggio(1909)";
D.q[6220] = "Xefires? Ah, sì, certo, Xefires! Gli faccio regolarmente dei magnifici vestiti in pura seta di Shin Larva e stoffa di Moon. È un uomo che ha buon gusto e che ama il lusso, diversamente da te. Desideri altro?";
D.q[2917] = "Spero che tu venga con buone notizie giovane spia #1!\nCosa posso fare per te?";
D.q[2383] = "Sei sicuro di voler intraprendere la carriera di Forgiatore di Daghe?";
D.q[6694] = "";
D.q[3147] = "Spero che tu sia fiero di te! Hai appena camminato sul mio boomerang, e ora non funziona più! Non torna più nelle mie mani ma in quelle dei miei avversari! È insopportabile, non sei che un boia di Pìu, un martirizzatore di Arakni, un ghigliottinatore di Dragacchini!";
D.q[6693] = "";
D.q[8020] = "";
D.q[1858] = "Ah, certo che no, non dico mai di no ad un aiutino. Abbiamo bisogno di una riserva di lana di pappatutto, se per caso potessi andare a tosare qualche bestia...";
D.q[6695] = "";
D.q[831] = "Questa mattina ho saputo che gli spiriti possono comunicare con i morti.\nMi piacerebbe quindi che tu ti uccidessi, e che cercassi il corpo di mio padre nel cimitero di Brakmar per chiedergli dove ha nascosto il testamento. Lo cerco da anni!\nLa tomba si trova al centro del cimitero, deve esserci ancora una mazzo di fiori davanti...";
D.q[2378] = "Sei sicuro di voler intraprendere la carriera di Intagliatore di Bastoni?";
D.q[8021] = "";
D.q[2379] = "Sei sicuro di voler intraprendere la carriera di Intagliatore di Bacchette?";
D.q[1552] = "A Bonta ti cercano per una missione molto particolare. È perfetta per te!";
D.q[2450] = "Qui sono imprigionati i peggiori mascalzoni della regione. Parla con me se vuoi imprigionare una delle tue prede.";
D.q[6697] = "";
D.q[6696] = "";
D.q[7354] = "";
D.q[8022] = "";
D.q[6698] = "";
D.q[2387] = "Sei sicuro? Questo mestiere è abbastanza difficile, richiede molto tempo e molti soldi.";
D.q[1547] = "La tua sete di avventura ti condurrà inesorabilmente verso tesori nascosti... ma anche verso una morte certa...";
D.q[8023] = "";
D.q[6154] = "Mi porti le anime che ti ho chiesto?";
D.q[3157] = "E sai perché sono il migliore ? No, ne ero sicuro, sei stupido come i tuoi piedi #1 e non sai niente, allora te lo spiego.\nSe sono il migliore è perché ho costruito la nave migliore di tutto il continente. Più bella dei campi in fiore di Rosal, resistente alle fiamme di Rushu, e più rapida di un Tofu spennato. È con questa barca che ho scoperto l\'isola del Minotoror molto tempo fa.";
D.q[2996] = "Cerchi di fregarmi? Questo l\'ho scritto io. L\'hai sicuramente trovato in una biblioteca! Torna a cercare una copia del tempo dei dragoni!";
D.q[6699] = "";
D.q[4894] = "Ciao, quindi ti manda Amayiro.\nHo un problema: il Martello di Luce è stato rubato dai Brakmariani e lo Spirito che lo abitava è stato distrutto. Io non so assolutamente creare quel genere di martello e per questo ho bisogno del tuo aiuto. Avevo già fatto ricorso ad Amayiro, ma era stato incapace di procurarmi informazioni utili.";
D.q[3931] = "Ah, lo sapevo che sarei stato ricompensato per il mio talento! Persino il re ora chiede di me!";
D.q[716] = "Restami fedele giovane recluta, non lo rimpiangerai mai... Ti metterò di nuovo alla prova. Ti propongo un piccolo allenamento con il miliziano Torcha.\nQuando ha visto i nuovi denti di suo fratello Tarke, gli ho detto che eri stato tu a toglierglieli. Ho fatto bene?";
D.q[4821] = "Sei riuscito con brio ad eliminare i Contrabbandieri e a fermare il loro traffico. Ora ho un\'altra missione che non potrai rifiutare.\nI partigiani di Djaul diventano sempre più temerari e temo che la loro sete di sangue porterà Brakmar alla sua rovina. \nFraka Kyper, il Maestro dell\'Ordine del Cuore Sanguinante, è un incosciente, come Oto Mustam. Entrambi odiano talmente Bonta che fanno prendere grossi rischi alle loro truppe, di cui tra l\'altro fai parte anche tu. Sono un cattivo esempio per la gioventù Brakmariana che non si rende conto di cosa voglia dire arruolarsi seguendo la loro strada senza rispettare più le antiche tradizioni.";
D.q[7283] = "";
D.q[3203] = "Sento che non hai capito niente... Fortunatamente, hai una mappa per ritrovarti, dovrai usarla per organizzarti con i tuoi compagni di squadra. Sì... ho dimenticato di avvertirti, se ci vai da solo non avrai scampo, dovete essere in molti per avanzare in quel terribile labirinto. Una volta nel labirinto, vedrai che ogni porta e ogni leva hanno un codice di colori.";
D.q[4073] = "Vedo che cominci a pentirti... meglio tardi che mai!\nMa non ti perdonerò così facilmente. Devi pur renderti utile una volta nella tua vita.";
D.q[4131] = "Conosco quest\'isola, è infestata da pirati e Kokoko. I Kokoko non mi fanno paura, sono stato allevato da una tribù primitiva di Kokoko quando ero bambino, e credimi, quelle bestie sono ancora più stupide di uno Yop! Invece, bisogna stare attenti ai pirati, sono astuti, vili, perversi e sporchi, il loro alito è più putrido di quello di un Rasbul imbalsamato. In poche parole, dobbiamo riparare la nave il più in fretta possibile.\nHo bisogno di legno, cerca di trovarne un po\' sull\'isola. Mi serve anche il Forziere Maledetto del Flib, si tratta di un forziere vivente che ho lasciato su quest\'isola, contiene gli attrezzi necessari per riparare la barca.";
D.q[6171] = "Non sei stupido come sembra. E se ti chiedessi di unirti ai ranghi dei difensori di Bonta? Se la cosa ti tenta ti offrirò una bella borsa piena di kama e imparerai qualche trucco da veterano che ti potrà servire in combattimento.\nAllora, che ne dici?";
D.q[6242] = "Conosco Xefires da molti anni e posso dirti che senza di lui forse non sarei la celebrità mondiale che sono diventata dalla mia vittoria alla Furbacchion Factor. Però non mi sembra che lui ti apprezzi più di tanto, ecco perché ti prego di non importunarci più.";
D.q[6579] = "Figurati che ero venuto per mettere in pratica trent\'anni di studio infaticabile. Avevo trovato dei compagni di strada che volevano far esplodere degli Chafer per recuperarne le ossa. Tutto andava bene fino al momento in cui l\'Aniripsa e il Feca ci hanno abbandonato col pretesto che la loro madre li avrebbe sgridati se non fossero tornati presto a casa. No, ma, ti sembra possibile? Abbandonarci così dentro un dongione?\nGli altri miei compagni hanno provato ad uscire, ma prima si sono fatti massacrare e poi tagliare a fettine rotonde. Quanto a me, ho scavato un buco con la mia pala e ho costruito una scala con i resti dei miei compagni. Sono stato fortunato, nessun mostro di lassù si è ancora avventurato qui. Dì un po\', non ti andrebbe d\'aiutarmi ad uscire?";
D.q[6415] = "Per i dodici Dei, com\'è possibile? Tu.. tu sei povero! Con quella tenuta da Contadino mi hai fatto venire il dubbio. Dimmi la verità, non è contagioso, vero? Tieni, prendi la ricetta e vattene, non voglio essere contagiato.";
D.q[5615] = "A sentire te, mettere le mani su quell\'Anutrof non è stato semplice. Vatti a riposare un po\', Cavaliere della Speranza, andrò a fare due chiacchiere con il nostro invitato. Riguardo ai Brakmariani incontrati sulla tomba di Terra Tibya, ne parlerò a Ebru Of El, forse le sue spie hanno scoperto qualcosa di cui non sono al corrente.";
D.q[7351] = "";
D.q[348] = "Ho bisogno di un amuleto fatto solo di legno per completare la mia collezione. Se ricordo bene, Agrid il Taglialegna ne ha uno al collo, te lo darà in cambio di un po\' di aiuto.\nSe mi porti quest\'amuleto, ti darò in cambio una pergamena che potrebbe esserti utile.\n\nSe ti piace l\'avventura, ti consiglio di andare dall\'Allevatore di Draguova, vicino al villaggio abbandonato... propone una bella ricompensa per gli Orefici.";
D.q[6397] = "Ah si, sapevo che saresti passato a portarmi quei documenti. Non preoccuparti, fino a che li avrò in mio possesso i Brakmariani non ci potranno mettere le mani sopra.\nSaluta Amayiro da parte mia, grazie.";
D.q[1852] = "Ah, cosa posso fare?! Da un po\' di tempo la mia cantina è infestata dagli scuiscuit, e oltre al baccano e alla puzza infernale che fanno, attirano tutti i maomao del quartiere! Così il mio Kwikwi ha paura! E se il mio Kwikwi ha paura io non sono contenta!";
D.q[4663] = "Allora miserabile, vuoi che ti porti a Brakmar?\nNon è una città fatta per i vigliacchi, è stata innalzata su un vecchio campo di battaglia, le mura sono ancora sporche del sangue dei nostri avversari, i fossati pieni di collera di Rushu, e io, sì io, decapito i novizi che mancano di rispetto alla nostra città e che osano criticare il mio dragacchino. Sembra che non si abbini con i miei colori. Sciocchezze!\nVuoi che la mia cavalcatura ti porti fino allo zaap di Brakmar? Prima dovrai trovare un po\' di tempo per accarezzarla.";
D.q[4022] = "Lasciami riflettere!";
D.q[2611] = "Come forse sai, l\'Orologio Divino di Xelor è regolato sui battiti dei Dofus: i Dofus pulsano all\'unisono... Se ascolti bene, forse sentirai un leggero battito... allora? Mmh, pazienza! Ti dirò quello che avresti dovuto scoprire da te: da questo battito dipende l\'armonia del nostro Mondo!\nSempre più esploratori, di questi tempi, smuovono cielo e terra per trovare le uova di drago... Tutta questa confusione non fa bene ai Dofus! Li sento agitarsi... Come se si sregolassero, e l\'Orologio Divino con loro! E se il tempo non si stabilizza prima, la porta temporale si aprirà...";
D.q[2815] = "Come ben sai se hai letto il libro di Myamowa Musashwan, i Pandawa sono abili in tutti gli elementi. Sta a te trovare il tuo!";
D.q[4546] = "Ben fatto, hai sconfitto la pattuglia. Ecco un premio. Sfortunatamente ho delle cattive notizie da darti. I Brakmariani hanno superato le trappole di Nara e visto che ha rifiutato di lavorare per loro, si sono sbarazzati di lui. Si è difeso con coraggio e ha portato numerosi Brakmariani nella tomba con lui. Resta da sapere quello che contano di fare ora i Brakmariani.";
D.q[7280] = "Devo andare al Mercatino e non posso lasciare utilizzare la Fucina a nessuno durante la mia assenza, quindi esci per favore.";
D.q[720] = "Bene #1, hai dimostrato il tuo coraggio fino ad ora. Ho una missione più pericolosa per te, devi andare ad esplorare Brakmar, ma non farti sorprendere.\nStudia il funzionamento degli ingranaggi della porta della città. Qualsiasi informazione potrebbe essere utile. Non tornare prima di aver trovato qualcosa...";
D.q[3869] = "Uk\' Not\' Allag sottometteva Amakna sotto un giogo implacabile, lasciando che le sue armate demoniache saccheggiassero e uccidessero. Avevano tutti paura, i demoni erano troppo potenti... Ma Allister aveva degli alleati, e soprattutto... un piano. Con astuzia riuscì ad intappolare Uk\' Not\' Allag in una cella. Sfortunatamente, come ho detto, il demone è riuscito ad evadere con l\'aiuto dei ladrurbi.";
D.q[6608] = "Buongiorno, ti stavo aspettando. Penso che sia passato abbastanza tempo.\nMentre combattevi i Brakmariani con coraggio, ho mandato altri miliziani ad informarsi su quel Bwork Mago. I Sadida non si sono dimostrati molto loquaci, ma Touh Flawa, il discepolo di Sadadi Sama ad Astrub, è stato l\'eccezione alla regola, ma senza parlare troppo. Riprendi l\'inchiesta a partire da lì e buona fortuna. Jiva veglia su di te.";
D.q[4511] = "Ah, bravo! Dei viveri ? Dovremo accordarci per portarglieli.";
D.q[2641] = "Poochan molto contenta, Poochan dare segreto a te per usare fonte senza effetti secondari.";
D.q[2711] = "Sto forgiando uno scudo per il Pandasiman... È un maestro nell\'arte del combattimento con lo scudo. Usa solo uno scudo benedetto da me, il suo gli è stato rubato dai Pandikaze.";
D.q[6524] = "E\' la fortuna del principiante, o quella del diavolo.. e propendo più per la seconda soluzione. Rispondo alla tua domanda fingendo che tu non mi abbia ripulito di tutti i miei kama.\nSai dov\'è il mercatino dei Minatori? Si, a Brakmar, ovviamente! Il nascondiglio di Pola si trova in prossimità del mercatino, è tutto quel che ti posso dire... non mi va di parlare di nuovo con te.\nNon dimenticare le tue vincite.";
D.q[6303] = "Insomma, capisco, in realtà non sai un granchè su questo luogo.\nIl Pozzo delle Anime Imbrattate è un luogo in cui le anime erranti bloccate nel nostro mondo possono diventare dei servitori del Male. In effetti il Pozzo è il punto d\'unione tra il nostro Mondo e un altro livello d\'esistenza in cui regna la corruzione. È per questa ragione che le anime erranti intrappolate nel pozzo non ne escono mai indenni, se ne escono vive.";
D.q[5767] = "Ronan il Burlone è più conosciuto di te anche se non ha mai fatto niente d\'interessante. Ritornare Neutro, quindi, ti costerà 4000 kama. \nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[6522] = "E\' la fortuna del principiante, o quella del diavolo.. e propendo più per la seconda soluzione. Rispondo alla tua domanda fingendo che tu non mi abbia ripulito di tutti i miei kama.\nSai dov\'è il mercatino dei Minatori? Si, a Brakmar, ovviamente! Il nascondiglio di Pola è in prossimità del mercatino, è tutto quel che ti posso dire e non mi va di parlare di nuovo con te.\nNon dimenticare le tue vincite.";
D.q[2177] = "Caro #1... Sai che noi Etram abbiamo la capacità di sdoppiarci! E ora stai parlando al mio doppio... eh sì. Ti spiegherò tutto ciò con grande piacere se ci rivedremo verso Brakmar... Nell\'attesa, ho una missione per te!";
D.q[4753] = "Come? I ladri ti hanno dato delle legnate, ma poi sei andato nel loro covo per convincerli ad incrementare le file della nostra milizia? Ecco un ottimo riflesso Brakmariano! Non dimenticare mai che più le persone sono furbe, più meritano di unirsi alla nostra causa.";
D.q[4885] = "Amayiro ha bisogno di me? Mi fa piacere aiutarlo, certo. Puoi dirgli che basterà che io venga avvisato con un giorno d\'anticipo per poter chiudere bottega e avvisare i clienti.";
D.q[4423] = "Come? Eravamo superiori in quantità e in forza, e sei riuscito a farci perdere? Che incapace!\nInsomma, l\'importante è quello che abbiamo constatato: i miliziani di Bonta sono sottoequipaggiati. È il momento di colpire! \nMa... prima vorrei conoscere l\'opinione di Fraka Kyper. Se non lo conosci ancora, passa la maggior parte del suo tempo alla Torre degli Ordini di Brakmar.";
D.q[6298] = "Essere impaziente? Mi piace. Visto che ci tieni, ecco il mio piano: Xefires può darci delle informazioni sui convogli Bontariani. Attaccheremo questi convogli, ma mandare dei Brakmariani potrebbe destare sospetti. E inoltre non mi fido dei miei ufficiali perché mi portino l\'integralità del bottino, quindi ho concepito un piano geniale che dovrebbe sviare i sospetti dei nostri nemici e allo stesso tempo assicurarmi che il bottino non cada come per magia nelle tasche dei miei uomini.";
D.q[3899] = "Allora, alla fine vieni ad aiutarci o no?";
D.q[937] = "Benvenuto alla taverna della Batosta, cosa posso fare per te ?";
D.q[4404] = "Peccato che tu non sia passato prima, avrei potuto avvisarti prima che tu tornassi a Bonta.\nI Brakmariani tramano qualcosa contro la nostra città, ma ignoro di cosa si tratti esattamente. Però so che dei ladri legati a questo affare si sono appena uniti a Oto Mustam. Il loro covo si trova a prossimità dell\'atelier dei Tuttofare e Ze Krow bazzica spesso da quelle parti. Sembrano ben organizzati quindi se vuoi far loro visita, chiedi ad altri Bontariani d\'accompagnarti.";
D.q[1440] = "Humm! Amayiro vuole ancora delle prove, prendi la sua testimonianza, sarà più credibile...\nAltrimenti, non ho proprio altre idee, chiedi a Turi Ordin come si fa un\'indagine, forse ha dei consigli da darti...";
D.q[289] = "Vendo questo terreno per un pezzo di pane! E la casa è compresa nel prezzo! Vedrai, si vive benissim... bene... benin... si vive malissimo invece. Non ne posso più di vivere qui, ma non ho abbastanza soldi per comprarmi un\'altra casa...";
D.q[4050] = "Ciao nobile messere!";
D.q[4598] = "Bella scelta. Eccoti la tua ricompensa per la tua fedeltà. Dirai ad Amayiro che la spia è stata aiutata da numerosi Brakmariani quando l\'hai raggiunta, e tu non potevi farcela contro tanti nemici.";
D.q[6241] = "Mi ricordo di te, sei già venuto a trovarmi a questo proposito. Quello che posso dire su di lui è che ama i metalli preziosi, i diamanti e i rubini, ma ha soprattutto un debole per gli oggetti esotici.";
D.q[985] = "Oh... un visitatowe nella mia fowesta, devi essewe vewamente cowaggioso per avventuwawti qui.\nHo un piccolo sewvizio da chiedewti, alla mia età non posso più andawe sull\'isola dei wabbit, ma mi piacewebbe continuawe le mie wicewche su questa wazza.";
D.q[3156] = "Ciao #2. Mi chiamo Nikos. Nikos Monote. Sono il più grande marinaio di tutti i tempi, ho navigato dove nessuno ha mai navigato, e ho scoperto cosa c\'è oltre gli oceani. Ho anche svelato il mistero del Kralamore gigante. Insomma, sono il migliore.";
D.q[1110] = "Piacere, mi chiamo Fulsura. L\'afrodite di Brakmar, la regina della bellezza. Cosa vuoi? Se vieni da me per questo, scordatelo. Prima cosa, sei orribile. Secondo, non avrai mai le tasche abbastanza piene per permettertelo.";
D.q[5679] = "";
D.q[6208] = "Sai, bella mia, la discrezione è una delle qualità più importanti nel mio mestiere. Non posso dirti niente, ma altri potranno.";
D.q[6231] = "Stavo ammirando il paesaggio che scorreva sotto i miei piedi in un trasportatore brigandino, quando, sporgendomi un po\' troppo, sono finito di sotto. Per fortuna un goblin ha attutito la mia caduta anche se di lui dopo rimaneva solo una poltiglia maleodorante. Sfortunatamente i goblin mi hanno catturato, ma visto che erano già troppo carichi, si sono liberati dell\'Etram perché mi trovavano più grassoccio. Conosci già il resto della storia. In base a quello che ho potuto capire, preparano un banchetto di cui sono il piatto principale.";
D.q[3765] = "Soldati, sono fiero di voi!";
D.q[4616] = "Lavoro meraviglioso. Fortunatamente per noi lo Yop non aveva capito che doveva scavare fino in fondo per trovare il Corno Davola. Avvicinamelo per favore. Questo Corno è magnifico, conterrà sicuramente poteri magici potentissimi. Sarà l\'asso nella manica nella nostra lotta contro Brakmar.";
D.q[6172] = "Eccellente, hai fatto un\'ottima scelta! Vai subito a trovare Oto Mustam alla milizia di Brakmar e digli che ti mando io. Esiste una scorciatoia per raggiungere la città oscura, te l\'ho segnata sulla mappa. In realtà nessuno deve sapere di questo piccolo servizio perchè i miliziani di Astrub non hanno il diritto di reclutare per le grandi città. Questo resterà fra noi, capito ?";
D.q[1252] = "Grazie alle tue indicazioni, 10 dei tuoi colleghi hanno portato a termine un raid particolarmente pericoloso a Brakmar. Domani sono invitati ad una cerimonia durante la quale riceveranno una medaglia. Ah, accidenti, ora che ci penso, siccome sono appena arrivati stravolti dalla loro missione, sicuramente non avranno il tempo di cercare dei mantelli puliti. Potresti procurarglieli tu?";
D.q[664] = "Molto è cambiato da quando la brezza quadramentale ha cominciato a soffiare sul nostro mondo. Solo ora cominciamo a dominare questa nuova potenza che ci è stata offerta. Presto la padroneggeremo completamente e allora!... Ma parliamo piuttosto di cosa ti ha condotto fin qui.";
D.q[2277] = "Hééé sììì! È impossibile fregarmi! Hahahaha! Io so riconoscere il volto dei valorosi! Ti ricordi, quando abbiamo combattuto da Sidimote a Bonta, e fino all\'isola dei Wabbit per poi tornare a Brakmar ? Avevo le gambe che esplodevano e ho perso nove dita dei piedi! ... Se avessimo usato gli zaap, piuttosto di farcela tutta a piedi, sarebbe stato più facile!";
D.q[1206] = "Lasciami con il mio dolore... E\' partito, hai sentito? Partito!";
D.q[2743] = "Stai attento ad evitare le sorgenti maledette: forse sai già che la nostra dea ha preso una sola sbronza nella sua vita, ma che dura da più di mille anni? Ebbene, questa sbronza divina le ha fatto rimettere persino le budella! E questo ha creato delle piccole sorgenti d\'acqua magica all\'incrocio tra Terradala e Aksadala. Ma attento! Quest\'acqua ha il potere di imprigionare l\'anima della prima persona che ci cade dentro... sicuramente stordita dall\'odore. Ogni persona che ci cade subisce la maledizione dell\'acqua: si trasforma e prende le sembianze dell\'ultima anima imprigionata... che cerca probabilmente di uscire da quell\'acqua stagnante.";
D.q[4523] = "Compra la mia birra, l\'unica che trasforma qualsiasi miserabile in un valoroso cavaliere!\nL\'effetto non è garantito.";
D.q[6525] = "E\' la fortuna del principiante, o quella del diavolo.. e propendo più per la seconda soluzione. Rispondo alla tua domanda fingendo che tu non mi abbia ripulito di tutti i miei kama.\nSai dov\'è il mercatino dei Minatori? Si, a Brakmar, ovviamente! Il nascondiglio di Pola si trova in prossimità del mercatino, è tutto quel che ti posso dire... non mi va di parlare di nuovo con te.\nNon dimenticare le tue vincite.";
D.q[2983] = "Non lo sai ancora, ma è ciò che desideri di più al mondo.";
D.q[733] = "Ieri, abbiamo subito una grossa sconfitta contro Brakmar, hanno usato un\'invocazione finora sconosciuta.\nMi piacerebbe che andassi da Zeorg, il maestro di classe Osamodas, e che ti informassi su questa creatura.";
D.q[4668] = "Da un recente rapporto risulta che abbiamo un lunghezza di vantaggio sui Bontariani. Vai sull\'Isola di Moon e convinci Garutar a rivelarci il nascondiglio del Corno Davola in cambio del Grattaschiena Spentox.\nHmm, offrile dell\'Insalace ripiena di Polline, potrai magari allentare la sua diffidenza. Bisogna sfruttare tutto per aver la fortuna dalla nostra parte. Io invierò gli altri miliziani a ritardare i Bontariani, quindi non contare sul loro aiuto per questa missione.";
D.q[6356] = "So che dei contrabbandieri operano in questo porto, ci scommetto la tua mano! Da quando sono state scoperte le Isole di Wabbit e di Moon e dall\'avvio dei circuiti turistici dell\'Agenzia Turista il contrabbando è fiorente. D\'altronde, tu hai un\'aria losca, non starai mica cercando di distrarmi?";
D.q[1575] = "Quindi sarò io il prossimo intendente, ma che notizia triste quella di Tedeor...\nA proposito, non hai mica voglia di rendermi ancora un servigio, giovane discepolo?";
D.q[2190] = "Non so cosa stia accadendo, ma ci sono sempre più avventurieri in questa città. Sto impazzendo di lavoro...";
D.q[1512] = "Poco tempo fa, Brakmar e Bonta sono improvvisamente riemerse, capriccio degli dei o dei guardiani, nessuno ancora lo sa. Gli Amaknei inclini ai culti oscuri andarono in piccola parte a Brakmar, mentre gli Amaknei della luce andarono a Bonta. I nuovi abitanti di Brakmar elessero 3 rappresentanti, uno per ogni culto oscuro maggiore: Djaul, Hecate, Brumario, perché governassero meglio la città. Io sono quello di Brumario.";
D.q[3163] = "Sono sicuro che ti piacerebbe sapere quello che si nasconde sulla cima di questa montagna, dietro ai gradini! Semplice, ci ho incastrato il più grosso Croccaroc che abbia mai catturato e non può più liberarsi da quanto è ingrassato. È enorme, mostruoso, terrificante! È talmente pericoloso che ho bloccato l\'accesso a questa scala. Se per caso hai una chiave, ti lascio entrare volentieri, così ti accorgerai che non ti sto mentendo, e avrai una paura boia, e griderai come una bambina e chiederai aiuto a me... a Krakot, il terribile cacciatore di Croccaroc!";
D.q[5682] = "";
D.q[4543] = "Credo che sia il momento di testare il frutto dei nostri sforzi. I miliziani sono in manovra e abbiamo appena ricevuto numerose casse dell\'equipaggiamento fabbricato da Nara. Voglio preparare un\'imboscata ad una pattuglia Brakmariana, ma per farlo devo sapere quando e dove colpire. Fai una visitina alla nostra spia a Brakmar per chiedergli dove si possono trovare dei rapporti sulle ronde delle pattuglie Brakmariane. Appena avrei messo le mani su questi documenti, portameli. Dobbiamo colpire velocemente, prima che i Brakmariani si rendano conto del furto dei documenti e cambino i loro piani.";
D.q[1630] = "Grazie! Mia madre diceva sempre: \"Se mangi delle Blugely e delle Rougely non mangiarci mai insieme 3 Vertgely!\"";
D.q[6515] = "Aww! Sei impazzito, fa male! E tutto perchè non vuoi darmi dei kama.";
D.q[6665] = "Ascoltami bene, quel che ti dirò deve restare fra noi. Nessun altro dev\'essere al corrente che io rischio il posto e tu la testa, hai capito bene? Ora vai da Oto Mustam, alla milizia di Brakmar, e digli che ti mando io.";
D.q[6666] = "Mi sembrava che la tua faccia da ratto mi fosse sconosciuta. Benvenuto alla Milizia di Brakmar, tu soffrirai, ma i tuoi nemici soffriranno di più. Vai a ringraziare Snori Nairb da parte mia e digli che sarà pagato come d\'accordo. Anzi no, non lo ringraziare, digli soltanto che ha interesse ad inviarmi altre persone, se vuole aumentare le sue ricchezze. Non dimenticare di tornare qui, molte altre missioni t\'attendono e non voglio coinvolgere gli altri miliziani.";
D.q[5600] = "";
D.q[4549] = "So già tutto, è appena arrivato un dispaccio da Astrub. Subito dopo la tua sconfitta i mercenari di Astrub sono intervenuti ed hanno arrestato i Brakmariani. Mago Ax ha recuperato il Corno Davola e ce l\'ha spedito, precisando che hai rischiato la tua vita pur di non cederlo ai Brakmariani. Quando penso a tutti i pericoli che abbiamo corso per ottenere questo Corno capisco che non ci si deve fidare dei pettegolezzi e delle leggende... Se ti può consolare ora grazie al potere di questo Corno ci sono meno reclute addette alla pelatura delle patate. In ogni caso hai servito molto bene Bonta e la tua lealtà ai miei occhi ha più valore di qualsiasi oggetto magico.";
D.q[1286] = "Sono il Capitano Assacarf, guardiano della prigione della milizia.\nAnche se sono molto attento, i Brakmariani hanno la brutta abitudine di evadere alla più piccola occasione.";
D.q[4710] = "";
D.q[5368] = "Hai l\'Oricalco?";
D.q[4620] = "Già di ritorno? Mago Ax ti ha potuto dare informazioni sul Corno Davola?";
D.q[2644] = "*Gasp* Poochan! \nCia...Ciao";
