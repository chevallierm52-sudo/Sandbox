D.q[891] = "81";
D.q[6166] = "Quindi ho delle stupende ricompense da dare agli avventurieri che mi aiuteranno a trovare ciò che cerco. Spiegare come ho trovato questi Dofus è tutta un\'altra storia. Alcuni parlano di fortuna, di casualità o di destino. Ma a me piace pensare che le mie ricerche mi abbiano sempre guidato verso ciò che il Mondo dei Dodici poteva darci di più bello o di più pericoloso.";
D.q[7950] = "Non hanno l\'aria molto robusta, ma è meglio di niente.\nTieni, ecco la tua parte.";
D.q[6633] = "";
D.q[2702] = "Ciaul! Benvenuto nella mia dimola. Hai l\'occhio scintillante come l\'astlo della notte: il tuo cuole è pulo... Cosa posso fale pel te?";
D.q[2965] = "Molte grazie! Due uova di Tofu, queste sì che sono preziose! Sono maschio e femmina almeno, vero? Non sei sicuro? Allora, bisognerà andarlo a chiedere al Mago Ax... Lui la sa lunga sul Mondo e le sue creature, e comunque dovevo già andarci... Pensa che ho trovato un Dofus e tu avrai il privilegio di portarlo al Mago Ax. Quest\'uovo di drago mi sembra troppo fragile, e ignoro il perché... Chiedilo al Mago! È uno specialista dei Dofus...";
D.q[783] = "73";
D.q[792] = "82";
D.q[801] = "91";
