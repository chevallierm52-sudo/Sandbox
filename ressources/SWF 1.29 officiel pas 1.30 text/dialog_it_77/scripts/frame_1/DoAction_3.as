D.q[859] = "49";
D.q[1838] = "... hum eppure tutto coincide, questo vecchio manoscritto è chiaro...\nOh, scusa non ti avevo visto, cosa posso fare per te? O piuttosto, cosa puoi fare tu per me?";
D.q[777] = "67";
