D.q[7948] = "Vuoi portare dei Baubau fino alla Culla di Alma? Ti costerà 5000 kama.";
D.q[766] = "56";
D.q[683] = "3 son le tappe che dovrai superare\nE son altrettanti gli argomenti di meditazione\nIl primo verte sulla tua motivazione,\nsul coraggio che non ti farà scappare.";
D.q[769] = "59";
D.q[7949] = "Sbrigati a portarmi un tiro di Baubau delle nevi, sono sicuro che i fantasmi dei pirati stanno per venire a  rubarmi il tesoro.";
D.q[6632] = "";
