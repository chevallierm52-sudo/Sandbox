D.q[6635] = "";
D.q[7951] = "Grazie alle attività vulcaniche dell\'isola, le acque delle Lacrime di Uronigride sono molto cariche di minerali. Sono convinto che il loro consumo da parte dei Frigostiani sia migliore della neve sciolta che viene bevuta attualmente.\nIl più grosso problema attualmente è l\'alto contenuto di zolfo, ma con il trattamento appropriato dovrei poterle rendere potabili.";
D.q[6636] = "";
D.q[1162] = "Hum... cosa? che c\'è ancora? Non si può veramente dormire neanche un po\' qui?\nBoh, cosa vuoi ragazzino?";
D.q[853] = "Un assassino Bontariano, ecco una cosa che non mi sarei mai aspettato. Quale migliore copertura ci potrebbe essere... un Bontariano che uccide un Bontariano. Mi devi trovare dei Bontariani, il cui cuore è ben lontano dall\'essere puro. Vai a chiedere un bastone annusatore a Fryda Artiglio-Notturno. I suoi bastoni hanno il potere di annusare il sangue che è rimasto impregnato sulle persone... potrebbe esserti utile.";
D.q[6815] = "";
D.q[4655] = "Un Brakmariano? Di già? In guardia!\nAh, ma sei TU! No, no, mi arrendo! Preferisco marcire nelle prigioni di Brakmar che morire!";
D.q[7952] = "La pista dello YeCh\'Ti non è più molto fresca. Il tempo è tiranno, se vogliamo fargliela pagare.";
D.q[4597] = "Hai deciso di darmi i documenti?";
D.q[2532] = "Non hai visto quei venditori di statuette della dea? Tutte quelle false uova di drago? I consiglieri hanno deciso di invadere tutte le botteghe del Mondo con dei prodotti a buon mercato \"made in Pandala\"! E intanto i valori ancestrali dei Pandawa vanno perdendosi!";
D.q[7352] = "";
D.q[7430] = "";
D.q[7953] = "In seguito ai numerosi massacri di Pappabuk perpetrati dallo YeCh\'Ti, abbiamo deciso di fare una spedizione punitiva per sbarazzarci di lui una volta per tutte.\nLe sue tracce ci hanno portati qui e al momento stiamo elaborando una strategia per sconfiggerlo.";
D.q[7353] = "";
D.q[1209] = "È stato Elviana a mandarti? Verrei volentieri con te ma devo ritrovare i miei due fratelli, Aigurraf e Tabach. Sono capaci di qualsiasi pazzia, visto il loro stato d\'animo.\nSembri una persona di fiducia. Ti lascio il mio badge, fallo vedere ad Elviana.";
D.q[797] = "87";
D.q[798] = "88";
D.q[799] = "89";
D.q[800] = "90";
D.q[4421] = "Un combattimento si sta svolgendo nelle pianure, sulla strada tra Bonta e Brakmar. Voglio che tu partecipi e che aiuti i nostri guerrieri a vincere!";
D.q[2054] = "Erty...ti... inv..ia? Contento... vedere...... divorare da... una piant....... il tipo...\n\n* Treffiori prende un foglio dalla tasca, sul quale c\'è scritto \"Scusa, sono afono da ieri mattina!\" *\n\nHo... notizie... interessanti... una rosa osc..ura... campi... degli Ingals..., porta un... fiore di questa... rosa ad Erty...!\n\nSem..bra... che stra...ni... motivi sono stati... diseg..nati... ne..l... grano... Li riconos...cerai da que..sto... dett..aglio...";
D.q[7954] = "Se ci avviciniamo così allo YeCh\'Ti si accorgerà di noi. Dopo aver studiato il suo comportamento ci siamo accorti che non si preoccupa dei Ghiacciopaz. Se recuperiamo delle pellicce di Ghiacciopaz in buono stato potremo vestirci con esse e sorprendere lo YeCh\'Ti.\nMi serve il tuo aiuto per recuperare un numero sufficiente di pellicce. Perchè non lo facciamo noi stessi? Perchè sennò ci sporcheremmo del sangue dei Ghiacciopaz e lo YeCh\'Ti potrebbe mangiare la foglia.";
D.q[7955] = "Abbassati o ci farai scoprire!";
D.q[1635] = "Molto bene, l\'altruismo è una virtù che sta scomparendo ai giorni nostri, ed è sempre utile avere nuovi guerrieri disposti a difendere le nostre città.\n\nUltima domanda: se un giocatore prende in giro il tuo modo di combattere o di camminare, cosa fai?";
D.q[1198] = "Molto bene, hai imparato la prima lezione: riflettere bene sulle diverse scelte prima di prendere una decisione definitiva.\nTorna quando sarai sicuro di te.";
D.q[802] = "92";
