D.q[3342] = "";
D.q[7698] = "";
D.q[6458] = "Cosa vuoi? Per quanto ne sappia io, non è proibito passeggiare, quindi lasciami in pace.";
D.q[4975] = "Cosa vuoi? Mi hai interrotto proprio nel bel mezzo delle mie ricerche!";
D.q[6585] = "Scusa, pensavo fossi un\'altra persona. Rassicurami, nessuno t\'ha seguito? Dovresti fare più attenzione, non si sa mai cosa si nasconde nell\'ombra.\nA guardarti, sembrerebbe che tu abbia avuto qualche problema per arrivare qui. Norb, almeno, si era ricordato d\'indicarti la scorciatoia? \nNon è tutto, ma devo lavorare, quindi, se non hai più niente da fare qui, non ti trattengo.";
D.q[441] = "Ciao, sono Hagal il guardiano di questa banca, solo le persone rispettabili che non sono fuorilegge hanno diritto di entrare.";
D.q[174] = "Ssssshhhh... Vattene via giovane incosssssciente... Sssssolo gli esssseri più vili possssono essssere rissscevuti dal nossstro maessstro Vil Smisssshhh...\nSssshhhhhhh....Asssshhhhhh....Uuuuuusssshhh";
D.q[1354] = "*Carta* \nHum, ho perso, sei piuttosto bravo, passiamo alla terza mano.";
D.q[3693] = "Attenzione, qui le creature sono molto aggressive.";
D.q[81] = "Ciao, qualcosa mi dice che vuoi saperne di più sulla mia storia.";
D.q[2140] = "Cosa vuoi? Non ho la pazienza per discutere della pioggia e del bel tempo, lasciami stare...";
D.q[1360] = "*Forbice*\nHum, ma come? Non è possibile? Imbroglione!";
D.q[5321] = "Ho perso tutto i soldi e i creditori non mi lasciano in pace. Con un\'indennità rischi potrei rimborsare tutti i miei debiti.";
D.q[5167] = "Ciao, cominciavo a credere che non saresti mai tornato. Hai trovato uno Xelor capace di incantare il libro in modo che ci sveli la fine della storia?";
D.q[6745] = "Buongiorno, sono un semplice mercante che vende tra Bonta e Astrub.";
D.q[6039] = "";
D.q[5695] = "Buongiorno, cerco i miei due fratelli, Aigurraf e Tabach. Sono un po\' giù in questo periodo e si comportano come dei bambini. Ho paura che finiscano per avere dei problemi.";
D.q[175] = "Ssssshhhhhhh... Il nossstro clan ci impone Ssshhhh... di parlare cossshhì... Sssembra che rinforsssssi il nossstro lato cattivooo...";
D.q[3711] = "Pìììììììììììììu";
D.q[3714] = "Attenzione, trasporto l\'acqua per le ninfette!";
D.q[347] = "Per diventare Orefice, ti devono piacere i gioielli, le pietre preziose e i metalli rari. Questo mestiere richiede molta immaginazione e un\'enorme precisione. Posso insegnartelo se vuoi, ma dovrai comunque comprare l\'attrezzo necessario per esercitarlo.\nGli Orefici utilizzano come attrezzo un Incastonatore.";
D.q[6368] = "Shhh, ho detto. Fai una domanda per volta, e non troppo ad alta voce.\nVuoi parlare del Corno magico che i pettegolezzi dicono sia a Sufokia ? Io non conosco quei pettegolezzi, non esco mai dalla biblioteca. Però conosco la storia dell\'origine di quel Corno, la vuoi sentire?";
D.q[6638] = "No, sono bianchi come il Guscio degli Scarafoglie Bianchi.";
D.q[6327] = "Buongiorno, anche a te piacciono gli animali?";
D.q[2556] = "Allora, vile cacciatore di Dofus, distruttore del mondo, turista caotico, hai qualcosa da dire?";
D.q[2460] = "Formidabile! Comincio a capire il meccanismo di mutazione delle piante!\nTemo il peggio per il futuro, ma penso che dovremmo riuscire a trovare una soluzione...";
D.q[349] = "Io odio i Moskito, questi mostriciattoli insopportabili che mi aggrediscono senza ragione quando vado a tagliare il legno. Se mi porti 10 Ali di Moskito, ti darò un\'Ascia del Taglialegna.\nSe me ne porti 100 in un sol colpo invece, ti darò un Amuleto del Taglialegna.\n\nTroverai i Moskito un po\' dappertutto, soprattutto vicino agli alberi che si possono tagliare intorno al lago.";
D.q[4778] = "";
D.q[364] = "Ciao, sono Ness Lay e la felicità mi appartiene! Sono l\'unica a conoscere i segreti della ricetta della felicità in provetta.";
D.q[405] = "Ci sono miniere disseminate un po\' ovunque sui fianchi della montagna, ma certe sono quasi vuote o infestate da mostri poco simpatici.\nCosteggia la montagna e troverai sicuramente l\'entrata che conduce alle diverse miniere della Provincia di Amakna.";
D.q[4779] = "";
D.q[1123] = "huhuhuhéhéhé HIARHIARHIARHAHAHA! \nVuoi sapere perché sto ridendo? Dammi 5 kama e te lo dico.\nhuhuhuhéhéhé HIARHIARHIARHAHAHA!";
D.q[4808] = "Ciao, sono contento di riceverti. Spero che il processo cominci in fretta in modo da fare chiarezza su questa storia di presunto tradimento.";
D.q[4980] = "Ciao, sono contento di vederti in forma. L\'intendente vuole incontrarti. È inutile che ti dica dove si trovi, devi saperlo da tempo ormai.";
D.q[6549] = "Salve, sei tu quello che ha combattuto con i Brakmariani vicino alla Baia di Cania?";
D.q[5215] = "";
D.q[3950] = "Ciao, maestro Wabbit, posso aiutarti? Vuoi controllare che sia tutto pronto per l\'arrivo del principe?";
D.q[813] = "Il padrone della taverna del Maokemao è stato sgozzato la notte scorsa, cerca di scoprire chi l\'ha ucciso e dimmi il suo nome!\nVorrei complimentarmi con lui e assoldarlo come assassino, ha fatto proprio un bel lavoro.";
D.q[6009] = "";
D.q[3740] = "Un Taglialegna può trovare dei buoni alberi da tagliare nella foresta di Amakna.";
D.q[1008] = "Ecco finalmente una Collana sfavillante, non sei stato molto rapido questa volta...";
D.q[360] = "Ciao, mi chiamo Lu, Lu Pachups e vado matto per i lecca-lecca. Ho imparato a farli ma ho quasi finito gli ingredienti.";
D.q[5503] = "Ciao, mi chiamo Suebur Dirgah e sono il guardiano delle chiavi. Chiunque voglia salire questa scala, che sia mendicante, soldato o re, deve prima mostrarmi la chiave.";
D.q[4783] = "";
D.q[448] = "Se non hai voglia di allenarti, ti rimangono sempre le pergamene. Io colleziono Anelli Agileschi, se me ne porti almeno 100 ti darò una Piccola Pergamena di Agilità.";
D.q[1702] = "Il tempio Osamodas è a Est del villaggio di Amakna. Parla a Lisa Modas per cominciare il tuo apprendistato.";
D.q[7400] = "";
D.q[7159] = "";
D.q[4784] = "";
D.q[3745] = "La raccolta è un metodo semplice e relativamente veloce per guadagnare qualche kama.";
D.q[2515] = "Ciao cittadino d\'altrove! Prima di tutto, sappi che la vendita di prodotti fermentati è severamente regolamentata su quest\'isola. Questi prodotti sono da consumare con assoluta moderazione. Ma le nostre botteghe sono aperte per te... e per i tuoi kama!";
D.q[5162] = "Ciao, la ricerca in biblioteca è stata fruttuosa?";
D.q[1395] = "Cosa vuoi? Siamo in una zona molto pericolosa. Quei maledetti Bontariani potrebbero attaccarci da un momento all\'altro! Faresti meglio a non restare nei paraggi.";
D.q[3750] = "Pulire un pesce è molto semplice. Usa il banco di lavoro per il pesce che si trova proprio là. Devi visualizzare quello che ottieni. Non dimenticare di equipaggiarti di ogni tipo di attrezzo che abbia a che fare con il tuo mestiere.";
D.q[4802] = "";
D.q[2357] = "Cosa vuoi?";
D.q[1061] = "Cosa vuoi da me!";
D.q[4853] = "Sì, a volte mi capita, ma devo dire che i Discepoli di Otomai sono portati per l\'importazione, più che per l\'esportazione. Non so se l\'hai notato, ma quest\'Isola non ha risorse, ecco perché essere il solo Capitano a fare il tragitto tra l\'Isola ed il continente è così lucrativo.\nPer tornare alla tua domanda, c\'è un Alchimista che mi chiede di consegnargli Casse di Pozioni sul continente, a destinazione di Brakmar. Si chiama Helas di Ciwillekh, lo troverai al Villaggio. Ti indicherò dov\'è, per evitare che tu ti perda di nuovo.";
D.q[1839] = "Durante le mie ricerche di cartografia, ho trovato un manoscritto che indica la posizione di alcuni sotterranei, uno dei quali ha un\'entrata nello scantinato della biblioteca, ma il meccanismo per accedervi è impossibile da trovare. Dubito che uno come te riesca ad entrarci....";
D.q[6090] = "";
D.q[5617] = "Cos\'è che vuole la piccola miliziana? Fai questo, vieni qui, aspettami, ripassa dopo. Come sta la piccolina del paparino?";
D.q[4689] = "Rieccoti finalmente. Mi spiegherai un\'altra volta cosa voleva Domen da te, in ogni modo ho l\'impressione che sia ancora più pericoloso da vivo che da morto. La Spada di cui ti ho parlato è molto difficile da forgiare. Mi porterai il primo materiale per la Lama: la Corruttite. Un nome carino, certo, ma non so dove trovarla. Vai ad interrogare quel mascalzone di Milon Coricel, è un esperto di Pietre di valore.";
D.q[7096] = "";
D.q[7160] = "";
D.q[3774] = "Vuoi ritornare alla statua?";
D.q[2106] = "Una sera, mentre ero al cimitero di Amakna per... hmm, la ragione non è tanto importante, comunque... mentre attraversavo il cimitero, ho sentito delle voci che sembravano provenire dalla tomba di mio nonno, e che dicevano \"Yke Haru... il granaio... il mio Gohbal... troverai il Colpo-Divino!\".\nAnche se avevo già cominciato a giocare a Goh, a quell\'epoca non conoscevo ancora l\'esistenza di questo colpo leggendario, quindi ho cominciato qualche ricerca e ho scoperto quello che dice la leggenda: \"Colui che troverà il Colpo-Divino al Goh sarà capace di predire il tempo e lo spazio\".\nLo so, lo so, stai sicuramente pensando che sono seduto al tavolo della taverna già da troppo tempo, ma aspetta il seguito, è ancora più eccitante...";
D.q[2926] = "Ciao, amico della cultura. Vieni ad istruirti, eh? Bé, come si dice, meglio tardi che mai... Se hai bisogno di un libro, vienimelo a chiedere.";
D.q[318] = "Ciao, siamo i banchieri. Puoi aprire un conto in banca e avere un forziere a disposizione per depositare i tuoi averi. Ma attenzione: ogni consultazione ti costerà #1 kama.";
D.q[3779] = "Vuoi ritornare alla statua?";
D.q[3778] = "Vuoi ritornare alla statua?";
D.q[6470] = "Ciao, hai un aspetto ancora più triste del mio, cosa succede?";
D.q[5326] = "Ti sei divertito alla fiera del Trool? Comunque sia, spero che tu ti sia ricordato dei palloni.";
D.q[433] = "Ciao avventuriero, sono uno dei pochi allevatori di Draguova di questa contrada, li allevo e li addestro da anni e anni. Sono la sola persona in grado di capirli e domarli.\nMa da un po\' di tempo ho qualche problemino, potresti aiutarmi?";
D.q[696] = "La gioia mi inonda di lacrime,\nE tutto unicamente grazie a te.\nIl seme della conoscenza ha preso dimora nella tua anima,\nEcco il segreto tanto atteso, si tratta del \"Bacio\"...";
D.q[5407] = "";
D.q[7097] = "";
D.q[7161] = "";
D.q[4288] = "Buongiorno. Scusami, ma sto approfittando di uno dei rari momenti di riposo, quindi non ho voglia di cominciare una conversazione.";
D.q[7098] = "";
D.q[4409] = "Ottimo, perfetto! È esattamente ciò di cui avevamo bisogno: un appuntamento alla Torre di Bonta, potremo beccarlo. Mmmh, bisognerà proprio aumentare la sorveglianza in questo perimetro...";
D.q[1524] = "Perfetto. Adesso hai una sicurezza nel combattimento più che accettabile. Ora che puoi essermi utile, ti contatterò sicuramente. Ma fino a quel momento, dobbiamo essere discreti.\nAh, mi dovevi dare anche una lettera... grazie. Fai attenzione a non dimenticare altro la prossima volta.";
D.q[7214] = "";
D.q[7464] = "";
D.q[5531] = "";
D.q[5170] = "";
D.q[2830] = "Oggi, è il mio giorno di meditazione, allora cerca di non disturbare la mia concentrazione!\n\n... zZZzzzz Zzz... zzz...";
D.q[130] = "Ogni tanto, nella taverna vengono organizzate delle feste durante le quali i menestrelli vengono a suonare per scaldare l\'ambiente e i Tofu grigliati sono a metà prezzo. Nella taverna si possono organizzare anche riunioni di gilda o di gruppi di amici.";
D.q[1027] = "Hmm, il modulo 243, devi avere grandi dubbi su qualcuno per pensare a questo test.";
D.q[576] = "Ohoh, ma stai dicendo sul serio per di più! Va bene, ti aiuterò. Per salire di grado i Kannibul tirapiedi lottano tra caste. Quello che vince prende la maschera del perdente, e chi possiede la maschera delle 4 caste le unisce per farne una nuova. Se mi porti le 4 maschere, credo di poterle unire.";
D.q[7717] = "Ascolta mozzo, io sono il capo della capitaneria, tu mi devi rispetto!\nLo so che non ci sono più partenze di battelli dalla glaciazione, salvo eccezioni, ma questo non significa che io sia disoccupato!\nNo, non ho bevuto... Mi sciacquo la bocca mentre rifletto, è diverso.\nCosa? Trovi che mi sciacquo la bocca troppo spesso? E\' normale, è per evitare che l\'interno della bocca mi si geli per il freddo. E poi parlare tanto mi fa venire sete. No, non te ne do, se hai sete vai alla taverna.";
D.q[1550] = "Hmm, Danathor è messo male, il suo rivale Tedeor è sempre più popolare nel cuore dei Bontariani... Ma vedo anche un incidente terribile, qualcosa di misterioso, un capovolgimento di situazione... vedo Danathor incoronato, sì, malgrado tutto sarà ancora intendente per molti anni, è sicuro!";
D.q[7761] = "Grazie, spero tu non ti sia sbagliato di Pappabuk.\nMentre li studio, vai a prendermi dell\'Acqua di mare isotonica, ma attento, dev\'essere il più pura possibile. Il Capitan Ciuk è il solo a sapere come procurarsela, vai a chiedere a lui.";
D.q[2766] = "Mille e un chicco di riso sono germogliati nelle risiere dell\'isola dal nostro ultimo incontro. Sento che sei pronto per passare un Danwa. Quale vorresti presentare?";
D.q[592] = "Ah eccone uno comprensivo finalmente! Per riparare questo buco mi servirebbero molte tavole di legno e vasetti di kolla. Se mi porti 2 tavole di legno e un vasetto di Kolla, ti darò in cambio una bottiglia di rhum. Ne ho un sacco!";
D.q[1443] = "Humm! Cerchi aiuto per fare bene un interrogatorio?\nTi consiglio i moduli d\'inchiesta n°33, ma li vendo a 700 kama cadauno.";
D.q[7162] = "";
D.q[7762] = "Non ne ho quasi più. Se vuoi la mia Acqua di mare isotonica devi portarmi qualcosa in cambio. No, non voglio una di quelle cose che avete voi turisti, quel che voglio è... dell\'Artemisia! E\' completamente sparita da Frigost, ma so che Erbor Ista ne ha ancora in stock. Se me ne porti, ti darò l\'acqua e me ne frego se ti serve per combattere la Ros Olia o per pulirci il tuo naso...";
D.q[5811] = "";
D.q[6107] = "";
D.q[1438] = "Hmm, stai cercando dei documenti per portare a termine un interrogatorio?\nTi consiglio i moduli d\'inchiesta n° 36, ma li vendo a 500 kama cadauno...";
D.q[7763] = "Dell\'Artemisia? Chi ti ha detto che... E\' stato il Capitan Ciuk,vero?\nQuell\'ubriacone mi ha preso in giro quando c\'è stato il concorso di invenzioni agricole e tu ora vorresti che io lo perdonassi così? Ah no, fuori questione!\nChe continui a scolpire il ghiaccio e la noia nel bere, è tutto quel che merita.";
D.q[5327] = "";
D.q[6108] = "";
D.q[2204] = "Uuuh, non voglio sembrarti scortese, ma a parte MacGivrer, non conosco proprio nessuno che possa fabbricarti un arco con così poche cose...";
D.q[1378] = "Humm... sono occupato per adesso.";
D.q[7764] = "Non sono in vendita, vai a dire a quell\'ubriacone che se vuole la mia Artemisia deve venire a portarmi le sue scuse personalmente.";
D.q[7100] = "";
D.q[7216] = "";
D.q[1070] = "Ehi, non vedi che sono occupato!";
D.q[1103] = "Hummm dimmi piccolo mio, hai mica visto i miei fratelli bazzicare nei paraggi?\nDevo assolutamente ritrovarli. Hanno il vizio di rompere tutto e, quando qualcuno cerca di fermarli, gli gettano un sacco di oggetti in testa.";
D.q[7765] = "Cosa? Vuole che gli chieda scusa perchè gli avevo chiesto se la sua invenzione prevedeva l\'uso del letame? Ma mi ha preso per scemo?";
D.q[4500] = "Affare fatto.\nAllora, ho un amico che potrebbe occuparsene. Ma è un tipo strano e tende un po\' ad essere paranoico. Insomma, un po\' tanto, in realtà.\nSi è nascosto in una grotta nella radura di Bruce Bulgur ma non posso andare a trovarlo da quando un energumeno di nome Bellus Sel ne blocca l\'accesso. Insomma, la cosa fa comodo a Nara che odia essere disturbato.";
D.q[6109] = "";
D.q[1558] = "Moo oom holp m\'om plos\'om moo oom.";
D.q[1361] = "*Carta* \nHum, ma come? Non è possibile? Imbroglione!";
D.q[7766] = "Ho capito il tuo problema, non sono mica idiota. Rifiuto di andarmi a ridicolizzare davanti a quell\'Aniripsa suscettibile, nessuno mi farà cambiare idea.";
D.q[6639] = "Garutar impiegherà solo un paio di minuti per vincere il combattimento e mandarti al Creatore.";
D.q[3058] = "Ecco le tavole, serviranno per l\'infrastruttura. Ora ho bisogno delle rocce per i muri.";
D.q[5346] = "Raaga ha bisogno di te. Ha modificato psicologicamente Ronan, ma la sconfitta alle porte di Bonta l\'ha reso molto instabile. Li troverai nella taverna del Maokemao.";
D.q[7101] = "";
D.q[7767] = "E cosa farò con tutti questi soldi, me lo dici? Ho bibite fresche a volontà, e senza spendere niente.";
D.q[1153] = "Prima di uscire da questo tempio mi piacerebbe farti un piccolo test.\nTi farò qualche domanda per essere sicuro che tu sia adatto ad avventurarti nel mondo. Se lo sarai, ti insegnerò una tecnica di meditazione molto utile.";
D.q[760] = "Da quasi 100 anni abbiamo abbandonato il cimitero di Bonta Est. Da allora numerose creature vi si sono infiltrate.\nCe n\'è una che è particolarmente forte: la Mummia Nova.\nPrendila un po\' come una prova, ma se mi porterai qualche pezzo delle sue bende, ti nominerò ufficiale della milizia di Bonta.";
D.q[6046] = "";
D.q[7102] = "";
D.q[1044] = "Eccola, splendente come il primo giorno.";
D.q[4839] = "";
D.q[662] = "Oh! Qualcuno... Vattene! No, vieni qua... Come ti chiami? Per me sono 5 anni e tu?\n\nPerché mi guardi così? Ho perso la memoria, ma non ricordo più come... comandante Chafer Paz, mio capitano! Ho un segreto, vuoi conoscerlo?";
D.q[7768] = "Hai visto la sua testa? Piuttosto bacio un Pappabuk.";
D.q[4844] = "Rieccoti. Hai messo la pozione sul tavolo di Divad?";
D.q[7769] = "Non possiedi nulla che mi interessi. Ho tutte le bibite che voglio qui e il ghiaccio non manca.";
D.q[677] = "Complimenti, hai passato con brio la prova di questo dongione.\n\nPer ricompensarti, ti offro questo animale di compagnia, potrebbe esserti utile nella tua avventura.";
D.q[3859] = "Te trovare dono per Bworknroll, te accompagnare Titi.";
D.q[3855] = "Ah, stare con le mani in mano ad ammirare Astrub. Che bel sogno! Per realizzarlo mi mancano solo uno o due Dofus da appendere sopra al camino.";
D.q[5889] = "";
D.q[1244] = "Ecco della polvere appena macinata!";
D.q[3875] = "Allora, queste cripte?";
D.q[3131] = "Prima di cercare di allevare un Dragacchino, devi riuscire a catturarlo, e per farlo, devi cercare di distrarlo, di ipnotizzarlo e, infine, catturarlo con una rete. Lo saprai già, ma l\'unica maniera di catturare un Dragacchino, è di lanciargli un incantesimo. E io sono il solo a poterti insegnare l\'incantesimo giusto. Te lo devo, anche se scommetto che non sarai mai un buon allevatore di Dragacchini.";
D.q[2696] = "Tieni, gli darai questa sublime copia di Dofus da parte degli Anutrof di Astrub. Noi purtroppo siamo in quarantena.";
D.q[5087] = "";
D.q[7770] = "E\' uno scherzo?\nMmmm quando sei libero?";
D.q[1669] = "Ecco qua, non sei stato troppo fortunato, forse ti andrà meglio con il prossimo Quaquà.";
D.q[2457] = "Ecco un\'ombra all\'ombra per molto tempo.";
D.q[7771] = "Bene, anche io. Troviamoci alla taverna in questo lasso di tempo. Ah, non vedo che interesse potresti avere a darmi buca.";
D.q[335] = "Ecco, ora hai le basi necessarie per esercitare questo mestiere, ma non dimenticare che ti serve anche l\'attrezzo adeguato. Guarda quanti attrezzi che vendo!";
D.q[484] = "Tieni, ho segnato su questa pergamena la lista delle pergamene che devo spedire. Per qualsiasi domanda, sai dove trovarmi.";
D.q[3017] = "Strani fenomeni disturbano la quiete di coloro che riposano qui. Sto cercando di capire cosa sta accadendo... Se non hai paura dei fantasmi, né di perdere la capoccia, vieni ad aiutarmi!";
D.q[7772] = "DIALOGUE TAVERNE QUÊTE. Critère : présent sur la carte de la taverne + ((PO=X et SH=X)|(PO=Y et SH=Y)|(etc))\n((PO=11205&SH>0&SH<4)|(PO=11206&SH>3&SH<7)|(PO=11207&SH>6&SH<10)|(PO=11208&SH>9&SH<13)|(PO=11209&SH>12&SH<16)|(PO=11210&SH>15&SH<19)|(PO=11211&SH>18&SH<22)|(PO=11212&(SH>21|SH<1)))\nNon pensavo saresti venuto. Prendi una sedia e siediti.\nVuoi qualcosa da bere? Non fare quella faccia, offro io.";
D.q[3603] = "Ecco, ora sei al corrente di tutto quello che ti serve per poter cominciare bene, vai dal proprietario per avere un lavoro.";
D.q[2512] = "Tieni, gli darai questa sublime copia di Dofus da parte degli Anutrof di Astrub.";
D.q[7783] = "Io e i miei amici abbiamo cercato di sbarazzarci delle zecche tosando i vitel parassitati. La maggior parte però è morta a causa della Ros Olia nelle settimane successive.\nIl rinnovamento del contatto con il continente arriva in un buon momento, possiamo finalmente chiedere aiuto ad uno specialista. Ti va di aiutarci?";
D.q[3881] = "Perché vuole i miei servigi? Non può chiedere a qualcun\'altro?";
D.q[3474] = "Heps, heps, te, venire, avvicinati, avvicinati.";
D.q[7773] = "Non devi essere timido, sai?\nAllora, cosa mi racconti di bello? Aspetta, non devi parlare con la gola secca.\nTaverniere, due altre pinte!";
D.q[4671] = "Molto gentile tu sei e succulente questa insalata è. Un Grattaschiena Spentox per me tu hai portato ? Mmm, non accettare io dovrei. Dopo molti anni che la schiena grattarmi io non riesco, uno scambio con te fare voglio. In cambio del Grattaschiena il luogo dove nascosto è il Corno Davola io ti rivelerò. \nDall\'isola a Nord-Est, vicino ad una statua di Fenice il corno si trova. \nOra a riposare io vado,l\'insalata soporifera era...";
D.q[4123] = "Hei dorifora sono io, il Capitano Kradoc in persona! Potrei portarti fino alla fine del mondo, soprattutto se servisse ad allontanarti dai miei occhi!\nPosso portarti su una magnifica isola deserta, senza Kannibul né rompiscatole se ti interessa.";
D.q[5887] = "";
D.q[1318] = "Oh che meraviglia! Sono ricco hahahahaha! Tu te ne puoi anche andare!";
D.q[7774] = "Vedi, ne hai cose da raccontare. Dai, bevi ancora un sorso per riscaldarti.";
D.q[5935] = "Ciao piccolo Palladineve, sono qui per scambiare i dolciumi che non sono più commestibili. Non mi chiedere perché dò dei dolci buoni in cambio di altri dolci non commestibili, è una storia da dormire in piedi. E tu non hai voglia di dormire in piedi.";
D.q[3646] = "Ah ciao, sono proprio contento di vedere una faccia nuova! Mi presento, mi chiamo Str\'huit. È un nome poco comune da queste parti. Anche se una volta mi ricordo di aver incrociato un Sadida che si chiamava come me. Non abbiamo parlato molto, anche se mi è sembrato subito simpatico, perché doveva andare a fare un pisolino. Tutto questo mi ricorda un aneddoto molto divertente che mi è successo molto tempo fa mentre facevo un pisolino. Vuoi ascoltare questa storia?";
D.q[7785] = "Cosa? Ah, ho dimenticato che il tempo continua a scorrere al di fuori dell\'isola. Beh, in quel caso, vai ad incontrare il suo sostituto.";
D.q[5353] = "";
D.q[3162] = "Ehi, sono sicuro che mi conosci #1! Sono Krakot, il più grande cacciatore di Croccaroc di tutti i tempi! Li acchiappo, li piego, li rompo, li smonto e li smembro, li spezzo, fanno \"croc\" e fanno \"bum\"... Sono proprio il più bravo cacciatore di Croccaroc, come avrai capito.";
D.q[7775] = "Criterio: incontro fra Capitan Ciuk e sesso maschile.\nHo un gran mal di testa... Passami la bottiglia, è il sistema migliore per lottare contro la sbornia.\nNon fare quella faccia, andrò da Erbor Ista per scusarmi, la tua prestazione mi ha convinto.\nAllora, felice?";
D.q[7786] = "Temo che questo problema sia fuori dalla mia area di competenza. Non conosco un rimedio miracoloso per sbarazzarsi delle zecche e curare i Pappabuk infetti, ma al contrario un mio vecchio amico ti potrà aiutare. Si tratta di Wogew l\'Ewemita, aspetta che ti indico dove abita.";
D.q[4145] = "Mi hai portato quello che mi serve perché possa finalmente allevare correttamente le mie creature?";
D.q[7776] = "Criterio: incontro fra Capitan Ciuk e sesso femminile.\nHo un gran mal di testa... Passami la bottiglia, è il sistema migliore per lottare contro la sbornia.\nNon fare quella faccia, andrò da Erbor Ista per scusarmi, la tua prestazione mi ha convinto.\nAllora, felice?";
D.q[4277] = "Ciao. Eheh. Attento, questo posto non è molto tranquillo...";
D.q[2002] = "Ehi tu! Pà vuole parlarti... è laggiù, verso Sud, vicino al lago. Aspetta te lo faccio vedere sulla mappa, non dovrai far altro che seguire la bussola!";
D.q[3816] = "Puoi ancora provare a batterlo! Non ti arrendere giovane avventuriero!";
D.q[7787] = "Un\'idea ce l\'ho, ma mi sewvono campioni viventi di zecche e campioncini di sangue.\nPowtami una decina di zecche e un campioncino di sangue di ciascun tipo di Pappabuk, pewchè possa studiarli.";
D.q[1151] = "Sei in un cianil. Questo luogo è il rifugio di tutti i piccoli famigli. Li curiamo mentre i loro padroni partono ad uccidere dragoni. Li coccoliamo e li trattiamo come si deve. Possiamo persino riprendere un fantasma di famiglio e darti in cambio un famiglio tutto nuovo.";
D.q[7777] = "Ignoro come tu ce l\'abbia fatta, ma il Capitan Ciuk è venuto a portarmi le sue scuse. Ero talmente sbalordito che ho dimenticato di dargli l\'Artemisia e lui se n\'è andato senza prenderla.\nTieni, portagliela, io sono un uomo di parola, non come quel maledetto Conte Allarovescia.";
D.q[5818] = "";
D.q[2069] = "Hei, mi serve una pala di legnuccio... Oh sì, una pala! Sono salvo! Scavare... e ancora scavare...\n... Sottoterra è l\'unico posto sicuro...";
D.q[3458] = "Hei! Tu, pss, no, non il Minotoror rosa, tu, pss!";
D.q[3245] = "B... B... Bene, vedi... una runa è una cosa veramente mistica e super potente, ma io non s... s... so troppe cose al riguardo. So solo c... ch... che da... da... da quando la usi sei, come dice qualcuno, pubblicato nell\'aura del mondo. Ha... ha... hai capito? Una cosa del genere insomma. E tu... tut... tutti ti riconosceranno in quanto artigiano! E così, sa... sa... sarai conosciuto, riconosciuto, e pieno di kama!!!";
D.q[7778] = "Oh, l\'avevo dimenticata.\nTi vado a cercare un secchio d\'acqua. Sbrigati a portarla al dottore prima che geli, non è nemmeno buona per fare dei cubetti di ghiaccio per rinfrescare le bibite.";
D.q[1129] = "Si può essere demoniaci e seguire la moda allo stesso tempo, non credi?";
D.q[238] = "haaaa! Ma cosa...?  Ma chi...? Ma...? Ha! Ha! Ti sei perso, vero? Dai, dai, lasciami passare! Ho del lavoro da fare io, che credi!";
D.q[7779] = "Ce ne hai messo di tempo. Si si, la cosa mi ha permesso di avanzare nelle mie ricerche. Ti chiederò un ultimo favore, ma la cosa potrebbe essere pericolosa.\nVorrei inoculare un vaccino ad una cavia che tengo nella caverna, ma non si lascia più avvicinare da me. Ho bisogno di un campioncino del suo sangue per verificare l\'azione del vaccino. Puoi incaricartene?\nAh, ha rotto il meccanismo di apertura, avrai bisogno di aiuto per andarci.";
D.q[7790] = "Gwazie di essewe townato. Sono sicuwo che lavowando con la collabowazione di uno dei più gwandi alchimisti ottewwemo wisultati sowpwendenti.\nVai ad avvisawe il tuo amico che il suo pwoblema di zecche è solo una questione di tempo.";
D.q[3660] = "Ehi, ti riconosco. Hai già lavorato per me, vero? Capiti a proposito, ho bisogno di una persona di fiducia.\nPotresti andare a portare un attrezzo a Xelorat Masket? È molto lontano e non ho tanto tempo in questo momento.";
D.q[4119] = "E adesso l\'ultima domanda, la più importante: quante noci di kokoko traumatizzate può portare un Cuervoc che ha una forza 5 volte minore della tua, ma che possiede una cintura del Rasbul e uno zaino di peli di Bituf migliorato da un Vestimago?";
D.q[7835] = "Vuoi scendere nel rifugio dei Pinguinotti?";
D.q[1698] = "Sì, sì... dai, forza, pesca un oggetto in questo grande zaino. Certi oggetti costano una fortuna... Sì sì!";
D.q[3288] = "Dov\'ero rimasto...\nAh sì ecco, ero su quest\'isola dove Otomai sbagliava sempre le trapanazioni e i trapianti di cervello che sperimentava sui suoi mostri.\nSapevi per esempio che un cervello di Yop entra nella testa di un Arakne?\nA parte questo... per aiutarlo nel suo nobile compito, nella sua corsa al sapere, ho costruito una macchina del tempo, che gli permetteva di tornare indietro e riprovare alcuni esperimenti.";
D.q[1038] = "Ciao! Musa il Predatore di Lupi ha detto che sarebbe stato semplice, ma non così tanto! Per maneggiare le armi dei Cacciatori ci vuole comunque una certa destrezza. Dimostra a Musa di avere questa destrezza e ti nominerà Cacciatore.";
D.q[4816] = "";
D.q[7781] = "Mi serve un campioncino di sangue di Pappabuk per creare nuove dosi di vaccino.";
D.q[7791] = "Dici che vogliono aiutarmi? L\'ultima volta che qualcuno ha promesso di aiutarci, un inverno perenne si è abbattuto su Frigost. I campi, una volta riempiti di cereali e di agricoltori, sono ora abbandonati, i miei poveri vitel non hanno praticamente più nulla da mangiare.\nBeh, vedremo se questi cercatori manterranno la loro promessa.";
D.q[7146] = "";
D.q[8111] = "";
D.q[3806] = "Hola! vai piano, vai piano... per questa collana dovrai portarmi molto più di una semplice pelle tarmata.";
D.q[4867] = "";
D.q[5187] = "Perché mi hai accusato? Avevi tutte le prove della mia innocenza. Che cosa ti ho fatto?";
D.q[8112] = "";
D.q[1159] = "Complimenti, hai proprio meritato di imparare la mia tecnica di meditazione.\nLe ferite inflitte dalle creature di questo mondo sono per la maggior parte superficiali.\nPer curarti con la meditazione, devi sederti e lasciare che la magia aniripsiaca che gira in questo mondo invada il tuo corpo.\n\nForza, il mondo là fuori aspetta solo te!";
D.q[8113] = "";
D.q[3947] = "Bene, ho quasi finito. Lasciami stare un momento, mescolo un po\' così, abbasso il fuoco ed ecco un... Wabbit!";
D.q[7747] = "Pur se resistente, il Frostiss è difficile da coltivare e da far riprodurre, siamo ancora lontani dall\'avere una rendita sufficiente perchè tutta la popolazione possa mangiare a sazietà. Sfortunatamente le nostre riserve di semi diminuiscono e la capacità di coltivazione delle nostre serre per gli esperimenti è limitata. Sarebbe gentile da parte tua se ci aiutassi a rinnovare le nostre scorte di semi. Che ne dici?\nSe sei d\'accordo mi servirebbero una cinquantina di Semi di Piselli, li troverai fra i peli dei Pappabuk, una decina di Semi di Farro, che trovi nei campi, e dei Semi di Frostiss.";
D.q[5360] = "Sì! Finalmente questa volta ho...\nARRRGH! MA non è possibile! Non adesso! Non puoi interrompermi proprio adesso!";
D.q[8114] = "";
D.q[1016] = "Non ne hai abbastanza, dai. Amayiro mi aveva detto che non eri tanto sveglio, e devo riconoscere che non aveva torto.";
D.q[5175] = "La storia scritta in questo libro elenca i vari proprietari di questo artefatto, a quanto pare l\'ultimo è un goblin. Vai all\'accampamento dei goblin e recupera l\'artefatto.";
D.q[8115] = "";
D.q[7215] = "";
D.q[4450] = "Ah, ma sei un Brakmariano! Cosa vuoi da me?";
D.q[1265] = "Hmm, grazie. Lo porterò a Turi Ordin per farglielo analizzare nei minimi dettagli.";
D.q[8116] = "";
D.q[3139] = "Ma cosa ci fa un essere così abietto come te nel rifugio del nostro grande maestro, il venerabile Skunk?\nNon penserai di poter varcare questa soglia?\nSolo gli avventurieri che ricevono il permesso delle quattro sorelle discepole di Skunk ne hanno il diritto.";
D.q[8117] = "";
D.q[1573] = "Hihi ciao #1, vieni a divertirti un po\'?";
D.q[5903] = "";
D.q[1194] = "Ciao compagno Brakmariano, che posso fare per il tuo servizio?";
D.q[646] = "Che disgrazia! Che tradimento! Dove sono i miei valorosi Pappatutto, ieri ancora così gentili, servizievoli, protettori... oggi invece così cattivi e stupidi!\n\nSono cambiati completamente da un giorno all\'altro. E il loro nome non gli è mai calzato così a pennello come adesso! \nAttaccano tutto ciò che si muove. Pappano tutto, solo nell\'ultima ora il mio Pappatutto Reale si è sbafato 4 Aniripsa, 2 Ecaflip e soprattutto 1 Yop. Sono sconvolto. Non mi ascoltano più! Solo le maniere forti potranno salvarci! \n\nAiutami a calmarli! Per favore... \nLa ricompensa varrà la pena!";
D.q[4285] = "Te lo giuro, è la verità. Non tradirò mai Bonta. Non sono perfetto, ma sono fedele ai principi della nostra nobile città. Sono pronto a giurarlo davanti alla dea Jiva in persona. Ti supplico, non denunciarmi. Ti prometto che non mi approvvigionerò più dai Brakmariani, ci sono altri fornitori, anche se sono un po\' più cari...";
D.q[7219] = "";
D.q[1368] = "La guarnigione ha come compito di proteggere gli abitanti del villaggio, quando i guerrieri venuti da Est li aggrediscono.";
D.q[1367] = "Ciao, mi chiamo Hertuen, il mio compito è di difendere la porta della guarnigione di Amakna. Cosa posso fare per te?";
D.q[2041] = "Ciao! Mi presento, sono Nibé Lulla, l\'Alchimista di questa vecchia e ridente cittadina. Cosa posso fare per te?";
D.q[7792] = "Comincio veramente ad inquietarmi. La mia padrona, Nelly Clerichetta, è partita per riparare il sistema di tubature che riscalda l\'Atelier dei Contadini nei Campi di Ghiaccio. Nel peggiore dei casi, se il problema è davvero importante, lei rientra prima che faccia notte e noi prepariamo insieme il necessario per i lavori, ma manca da più giorni, e nessuno l\'ha vista.\nPuoi provare a cercarla? Tutti hanno bisogno di lei, qui.";
D.q[1377] = "Strano, molto strano. Le perturbazioni della corrente magmatica sono prodotte da un potente Flusso Magico. Inoltre ho scoperto, un po\' più lontano, la Porta di una specie di Fortezza. Sembra che l\'apertura sia controllata da un meccanismo. Con un po\' di pazienza riuscirò a svelarne il mistero.";
D.q[4793] = "";
D.q[2083] = "Ciao! Ti va di giocare con me? Dai, tu fai la preda e io la cacciatrice! *Arma una freccia e punta l\'arco verso di te*";
D.q[7793] = "Allora, Hai ritrovato Nelly? Dimmi che sta bene.";
D.q[306] = "Ciao, vedo che conosci l\'inno dei Katékit, i ranger del rischio. Quando sei nel panico più totale, grida: \"Ahi Uto!\" e io arrivo. Prendo la mia forza dal Nutello, e per fare del Nutello ci voglione tante noccioline ma anche tanto amore. Io accetto tutt\'e due. Scambio 5 noccioline per un Femore di Chafer Arciere.";
D.q[389] = "Ciao. Mi piace da matti il Nutello che prepara Karim Katekit, ma mio padre dice che è troppo caro... Così, ho provato ad imitarlo. Se mischi 70 ghiande con 70 lingue di Dente di Leone Diabolico, si ottiene una pasta simile a quella di Katekit. Portami questi ingredienti e ti darò una Pergamena di Agilità.";
D.q[1334] = "Ciao, sono il capitano Koda, sono molto occupato perché sto preparando un importante assalto a Brakmar con nove dei miei uomini.";
D.q[7794] = "Nelly è occupata al momento, ripassa più tardi e approfittane per visitare il nostro Borgo.";
D.q[945] = "Ciao, sono Kosuke il Forgiatore di lame. Cosa posso fare per te?";
D.q[4358] = "Degli Ecaflip, eh... sì, ne ho ricevuto qualcuno poco tempo fa. Avevano un aspetto losco, tra l\'altro. Credo di aver sentito... per caso, ovviamente... il nome di Ludac pronunciato da uno di loro.";
D.q[5591] = "Cosa mi hai fatto? Sento un formicolio in tutto il corpo e mi fa male. Vile canaglia, sono sicura che è colpa della tua urina. Tra l\'altro dovresti smetterla di bere, si sente dal tuo alito.";
D.q[8076] = "";
D.q[6256] = "Cosa il Captain Starky? Cos\'ha? Quella mezzacartuccia non mi arriva alla caviglia. Lui e i suoi poolay, li schiaccio, li calpesto, ci salto sopra a piedi uniti fino a che non diventano della poltiglia, poi schiaccio, calpesto e salto a piedi uniti sulla poltiglia fino a farne un succo di poolay Bontariano che bevo con la mia kokosnuccia.";
D.q[7795] = "L\'Atelier dei Contadini si trova nei Campi a Est del Borgo. C\'era un problema con le tubature che l\'alimentano da Nord. Comincia le tue ricerche da là.";
D.q[7220] = "";
D.q[3546] = "Ciao! Oh scusa, non volevo ferirti... ah ah ah, era uno scherzo di cattivo gusto. Senti, so che voi Sàcrido siete di quelli che applicano la legge del taglione... mille volte più severa. Bene, ho proprio bisogno di qualcuno che sappia incassare i colpi, e darne altrettanti!";
D.q[8077] = "";
D.q[7796] = "Strano, gli occhi di questo Pupazzo di neve seguono i tuoi movimenti.\nNon noti altro nei paraggi, Francky sarà deluso.";
D.q[8078] = "";
D.q[1430] = "Sei davanti alla pichina. La mia creazione.";
D.q[5885] = "";
D.q[5618] = "Cos\'è che vuole il piccolo miliziano? Fai questo, vieni qui, aspettami, ripassa dopo. Come sta il piccolino del paparino?";
D.q[121] = "Ciao, sono Hugo Bel, giovane Maestro Feca, mi piace fare il solletico ai miei Pappatutto per farli grugnire.";
D.q[7797] = "Grazie a te Nelly è sana e salva. Non rischio di trovarmi disoccupato.";
D.q[8079] = "";
D.q[1433] = "Cavolo, sei in un bel guaio, dovresti fabbricare false prove e trovare un colpevole, perché Amayiro non lascerà correre così facilmente.\nD\'altronde, non dovresti fidarti di lui, ho l\'impressione che cominci ad essere invidioso...";
D.q[4426] = "Novità su Fraka?";
D.q[1362] = "*Pietra* \nHum, ma come? Non è possibile? Imbroglione!";
D.q[7798] = "Non capisco, è troppo furba per farsi sopraffare dai Pappabuk.\nTutto il mondo la apprezza, ha già rifatto la decorazione di numerosi interni in seguito alla glaciazione, non capisco chi potrebbe volerle male.\nNon hai notato davvero nulla di strano?";
D.q[5228] = "Eccellente. Se riesco a ottenere la fiducia dei discepoli di Hecate, le cose avanzeranno molto più velocemente. Ascoltami attentamente adesso, la tua prossima missione è molto importante.";
D.q[8080] = "";
D.q[102] = "Ciao, sono Laura Soho, la cameriera di questa taverna, cosa posso servirti?";
D.q[7123] = "";
D.q[7103] = "";
D.q[946] = "Ciao, sono Allen Tokar, ti offro una birretta amico! Dì un po\', non avresti mica 4 kama da prestarmi, te li restituirò appena mi pagheranno... Fai 8, va, è meglio.";
D.q[8081] = "";
D.q[373] = "Ciao, io sono Ariz. Mi piace fare delle caramelle a base di gomma. E per fare la gomma, ci vuole un sacco di gelatina.";
D.q[7799] = "Che rapporto c\'è con la sparizione di Nelly?\nOra che ci penso, c\'è stata quella straniera che è passata dall\'atelier l\'altra sera, poco prima della chiusura. L\'ho sentita discutere con Nelly e hanno bisticciato. Era la prima volta da un secolo che sentivo Nelly litigare con qualcuno. Nelly è poi venuta da me per avvisarmi che sarebbe andata a riparare le tubature dell\'atelier dei Contadini, all\'alba. Era molto nervosa e soprattutto la temperatura nell\'atelier era scesa improvvisamente, come se un secondo inverno vi si fosse abbattuto dentro.\nDopo di che ho persino dovuto chiedere ad Andrea Matrangos di venire a riscaldare il caseggiato perchè il freddo sembrava essersi installato permanentemente.";
D.q[8082] = "";
D.q[7725] = "Qualsiasi cosa, gela. E\' un secolo che continua, ma non capisco come mai. Se avessimo seguito la mia idea, invece di quella del Conte di Brescia, non saremmo a questi punti. Quando le coltivazioni bruciano, almeno fa caldo.\nSto seriamente pensando di andare a vivere a Nord dell\'isola, vicino alle Grotte di Lava. La sola cosa che mi darebbe fastidio;\r\n            se andassi a vivere là, sarebbe la vicinanza del castello del Conte che Sfascia.";
D.q[100] = "Ciao, sono Rish Claymore, Maestro d\'armi rispettato in tutta Amakna. Se stai cercando una Pietra per Arrotare, sei fortunato, ne vendo una.";
D.q[8083] = "";
D.q[1254] = "Che tipo di mantelli ? Dei mantelli Bontariani, ovvio. Quelli usati per tutte le cerimonie ufficiali della città. Ogni buon Sarto sa cucirne uno, basta una tintura magica blu, una piuma di cuervoc e una lana di pappaton bianco.";
D.q[7800] = "Ah quello, non è una grande cosa, ma mi chiedo come siano riusciti a far in modo che faccia più freddo dentro che fuori, malgrado il riscaldamento.\nSe ti serve una dimostrazione, sono il tuo uomo!";
D.q[295] = "Ciao, mi chiamo Alit Oskif e sono l\'apprendista di Kwaker Vans nonché fidanzato di Edrige Valling. Il problema con lei è che non sopporta il mio alito da quando lavoro come assaggiatore di Pane al curry senza curry. Ogni volta che voglio parlarle, devo ingoiare un\'enorme quantità di Gelatina Menta, ma faccio sempre più fatica a trovarne. Ti prego, aiutami.";
D.q[1240] = "Ciao, cosa desideri?";
D.q[275] = "Cosa ne sai tu delle virtù dei funghi? Non sei neanche Aniripsa?";
D.q[4336] = "Cosa faremo? Lo venderemo, ovvio. Credevi veramente che avremmo seguito il \"contratto\" alla lettera? Quando Xefires avrà portato a termine la sua missione, ci sbarazzeremo di lui, ecco tutto.\nD\'altronde, devo ricordarmi di far sparire Milon... mi ha esasperato in questa faccenda e in più è a conoscenza di troppi particolari. Ma non c\'è fretta.";
D.q[8084] = "";
D.q[3133] = "Cosa vuoi da me giovane insolente! Io sono il terribile Rigrulak!\nSono sicuro che mi hai scambiato per un altro di quei maestri Koalak, ma non fa niente, non attacco più le larve come te da molto tempo. \nAh, capisco, mi hai portato la panoplia del Culosse! No! Come! Giovane sfrontato!";
D.q[918] = "Ciao, mi chiamo Turi Ordin, specialista in spionaggio e in psicologia. So che vuoi qualcosa da me.";
D.q[7801] = "Ho due o tre cose da sistemare. Comincia ad andare, ti raggiungo ai piedi dell\'eoliana.";
D.q[3983] = "Cosa vuoi da me ? Non vedi che sono in missione ? Devo battewe una cweatuwa degna della mia stiwpe. Secondo i wacconti di un pewsonaggio vestito di newo, un tofu si nasconde in questa contwada, devo uccidewlo se voglio diventawe we un giowno.";
D.q[7124] = "";
D.q[7104] = "";
D.q[8085] = "";
D.q[4474] = "Hai trovato questo Forgiatore?";
D.q[1298] = "Ciao, nobile concittadino, sono l\'intendente di questa città. Posso esserti utile?";
D.q[7802] = "Cosa vuoi che faccia?\nNon chiedere il mio parere, o brucio tutto.";
D.q[1578] = "Héhé, spero che si ricordi della lezione!";
D.q[376] = "Ciao. Mi chiamo Téha Chiks. Faccio parte degli adoratori del Grande Guru. Quando mi stavo perdendo, quest\'uomo ha saputo mostrarmi il cammino. Da allora credo in lui, soprattutto da quando ho mangiato una frittella ai funghi... È stato Skippy a darmene la ricetta.";
D.q[6544] = "Hai il senso del gioco e il gusto per il rischio, si vede che vivi a Brakmar.";
D.q[1380] = "Cik! Sinik inik scittilik. Cimik pissik itirtik?";
D.q[4842] = "";
D.q[8086] = "";
D.q[2256] = "Credo che non abbiano sniffato solo del gas... Certi sono tornati veramenti malconci, e dubito che del Suborhube li possa rimettere in sesto. I nostri sono partiti alla ricerca degli altri Sniffatutto già da un po\'... Ho paura che si siano fatti catturare da quei maledetti ratti. Ritrovali, ti prego!";
D.q[7803] = "Spostati da là.";
D.q[4737] = "Argh! Che tu sia maledetto, Brakmariano!";
D.q[1973] = "Cosa?! È un FURTO! Humm, bé allungherò la birra con l\'acqua allora.";
D.q[4735] = "Ciao, sono Kosuke il ... ehi ma, sei un Brakmariano! Che ci fai qui?";
D.q[3242] = "Quei discepoli erano gli abitanti stessi del villaggio. Hanno voluto far riprodurre ad oltranza i Draghi del dio Osamodas che erano riusciti ad addomesticare, ma le loro intenzioni non erano delle più oneste. Tutti sanno che i Draghi sono all\'origine dei Dofus, così, per generazioni non hanno mai smesso di far riprodurre i draghi per ottenere altri Dofus. Non avrebbero dovuto dimenticare che quelle uova erano maledette e che i Draghi non sono creature addomesticabili come le altre...";
D.q[8087] = "";
D.q[6281] = "Come? Hai dato delle legnate ai ladri e poi sei andato nel loro covo per convincerli ad incrementare le file della nostra milizia? Ecco un ottimo riflesso Brakmariano! Non dimenticare mai che più le persone sono furbe, più meritano di unirsi alla nostra causa.";
D.q[4027] = "La formula non è completa? Ma se ho detto tutto quello che sapevo...";
D.q[4470] = "Eh? Strano che tu me lo chieda. Un Bontariano è passato qualche tempo fa per chiedermi di lavorare per lui...\nNo, non lavoro per Bonta, ma un mio amico ormai sì.";
D.q[7804] = "Grazie per avermi salvata da quel terribile destino.";
D.q[1836] = "Hmm, no, ti manca ancora qualcosa per costruire questa zattera.";
D.q[8088] = "";
D.q[7805] = "E\' quella straniera. E\' venuta a propormi di rifare la decorazione del castello del Conte Allarovescia, ma io ho rifiutato. Quando sono venuta qui per riparare le tubature ho notato che mi stava seguendo. Quando ho finito e me ne stavo andando ho sentito tanto freddo ghiacciarmi il sangue e mi sono trovata trasformata in Pupazzo di neve.\nChissà cosa sarebbe accaduto se tu non mi avessi trovata. Prendi qualche moneta come segno della mia riconoscenza.";
D.q[4449] = "Buongiorno. Non disturbarmi per favore, sto consultando dei libri.";
D.q[2527] = "Ciao! Ho tutti i tipi di bevanda fermentata, quale vuoi?";
D.q[1304] = "Torna da me questa sera verso le 21, con gli elementi indicati su questa lista. Poi ti spiegherò i dettagli della missione.";
D.q[8089] = "";
D.q[1739] = "Discepolo, devi imparare ancora molte cose. Cosa vuoi sapere?";
D.q[923] = "Ciao deficiente, cosa vuoi?";
D.q[7806] = "Ciao, ti do il benvenuto nel mio atelier dei Tuttofare. Questo luogo è aperto a tutti, quindi fai come se fossi a casa tua.";
D.q[4992] = "";
D.q[1715] = "Complimenti, bisogna essere rapidi per acciuffare questa bestia, sei piuttosto dotato. Se vuoi fare progressi ancora più velocemente, ho un consiglio da darti.";
D.q[7125] = "";
D.q[6133] = "Mi porti le anime che ti ho chiesto?";
D.q[4657] = "Questi documenti sono molto importanti per Brakmar. Non tollererò nessun errore da parte tua.";
D.q[8091] = "";
D.q[2831] = "Ciao. L\'entrata in questa torre è riservata agli abitanti più fedeli di Bonta, i membri degli Ordini. Se vuoi diventare uno dei nostri, vai da Amayiro, nella caserma della milizia.";
D.q[4990] = "Hum, un attacco mirato ha impedito la conquista del villaggio dei brigandini da parte di Brakmar? Ultimamente il nostro nemico si è dimostrato sempre più bellicoso. Forse impedirgli di usare i trasportatori potrebbe calmarlo.\nVai a dire all\'intendente che approvo il suo piano.";
D.q[1095] = "Hmm, vedo che fai parte della milizia Bontariana. Amayiro mi ha ordinato un rapporto che ho appena finito di scrivere.\nEccolo, e che la dea Jiva ti protegga #1.";
D.q[8092] = "";
D.q[1347] = "Hum, se vinci una partita, ti insegno a giocarci ovunque e con chiunque.";
D.q[3103] = "Cosa? Abitare con lui in quel luogo lugubre che puzza di patate marce? Ma chi si crede di essere quel vecchio galeotto! Cerca piuttosto la sua vecchia tana e torna per descrivermela.";
D.q[6545] = "Beh c\'è da dire che non ami ritirarti, gli Ecaplif adoreranno scommettere con te.";
D.q[1060] = "Hmm, interessante questo piccolo combattimento...  \nOra senti, se hai finito di divertirti, resta da fare del lavoro per il clan.";
D.q[8093] = "";
D.q[204] = "Hum. Spiacente, ma Wiss Catz mi ha detto che non scommette mai se non è sicuro di vincere. Non accetta la tua offerta... Tieni, ti restituisco il trifoglio.";
D.q[8090] = "";
D.q[5230] = "";
D.q[4043] = "Grazie! È tutto?";
D.q[280] = "Hmmm...Sììì! Lo sapevo! Haaa! Che genio! Che intelligenza! Ho messo a punto un piano a dir poco genialissimo. Ma per ora ho bisogno di trovare molte persone che sostengano la mia causa, penso che una quarantina di ladroni andrebbero bene...";
D.q[2403] = "Hmm, l\'odore del cuoio conciato mi eccita così tanto! Oh, scusa, non volevo scioccarti, sono Ygat, il miglior Ciabattino della regione. Cinture, scarpe, posso fare di tutto!";
D.q[1065] = "Hum, lasciami stare, lo vedi che sono in pausa, no?";
D.q[8094] = "";
D.q[1870] = "Ah ah! Una ragazzina... potrebbe essere una ladra, o forse una maga gelosa dei miei poteri! Tutto è più chiaro adesso! Insomma, non corriamo troppo però, prendiamola come un\'ipotesi probabile...";
D.q[7221] = "";
D.q[8095] = "";
D.q[1486] = "Humm. Non posso insegnarti le basi del mestiere. Sei già in apprendistato. Torna quando conoscerai un po\' meglio i tuoi altri mestieri.";
D.q[820] = "Sono completamente soddisfatto del tuo lavoro, cosa vuoi ancora?";
D.q[4093] = "Ecco, ho finito la pozione, sei pronto a diventare un Wabbit?";
D.q[6542] = "Mmmmff... Mmmmfff!";
D.q[1028] = "Hmm, in effetti no, non riesco più a maneggiare la mia sciabola quando li indosso. Pazienza andrò a rivenderli alla gioielleria.";
D.q[8096] = "";
D.q[6131] = "Mi porti le anime che ti ho chiesto?";
D.q[1887] = "Bene, ci divideremo i compiti, potresti andare a comprarmi delle rose? Ti faccio vedere sulla mappa dove si trova il fioraio. Nel frattempo io preparo le analisi delle tracce lasciate dal ladro.";
D.q[6269] = "Mmmh... riflettendoci bene, ci si potrebbe riuscire senza morire. La tua missione non cambia ma è inutile bagnarsi nei fossati di Brakmar e morirci, mi sei più utile da vivo.";
D.q[8097] = "";
D.q[7222] = "";
D.q[2639] = "Cosa? Cosa vuoi farmi...? Ah, una sfida!\nD\'accordo! Ti schiaccerò, ti ridurrò in poltiglia e ti darò alla piccola pandawa che hai come capo, dopo averla annegata nella sua sorgente! Vai nel dojo!";
D.q[1929] = "Ecco l\'anello. Come mostro, ti suggerisco l\'Alberagno che vive nella foresta. Le onde magiche che propaga quando muore sono le più adatte ad attivare l\'anello. Buona fortuna e fai attenzione: l\'Alberagno può essere veramente pericoloso, non esitare a chiedere aiuto. L\'anello è tuo ad ogni modo.";
D.q[8098] = "";
D.q[4777] = "";
D.q[7126] = "";
D.q[1935] = "Grazie per il rapporto... Sono veramente circondato da una banda di incapaci! E poi, cosa mi dice questo... non riesco neanche a leggere quello che scrive... squadra di scavo... un\'altra scoperta... santo cielo! Voglio sapere cos\'è!";
D.q[467] = "Uah! Sei gwande eh? Ti avvewto, io sono il Mattino che Pewla... Uno dei più potenti Wabbit al mondo... Sono il Wabbit benedetto dall\'astwo cantante... Allowa smettila di guawdawmi così... Non mi vowwai attaccawe spewo... Io ho pawtecipato alla distwuzione della gwande Towwe Yfew...\n\nE smettila di guawdawe... Non vowwai mica attaccawmi... Sono tutto solo, piccolo, guawda come bwillano i miei occhi... Non si può fawe del male ad una cweatuwa così gwaziosa, e i gwandi come te non attaccano mai i più piccoli, vewo? Hum... Se ti do una gwossa chiave mi lasci in pace, va bene?";
D.q[8099] = "";
D.q[1218] = "Grazie e benvenuto, fratello!";
D.q[8100] = "";
D.q[2682] = "Ciao! Ti piace questo dolce profumo di bambù fermentato?! Allora andremo d\'accordo... Cosa vuoi?";
D.q[5693] = "Ho sentito un\'aura malefica e ho pensato subito a te.\nCosa vuoi?";
D.q[1938] = "Come? Io? Chiudere bottega? Spero che stia scherzando! Gliel\'hai detto, vero? Fuori questione! Macché, ci mancherebbe altro... hahaha! Muoviti, vai ad avvertire i miei uomini là sotto che gli mandiamo un po\' di gente! Ah! Prendi questa pala, ti servirà tanto quanto la tua fortuna. Solo un Etram sopravviverebbe ad un buon colpo di pala. Haha!";
D.q[4058] = "Ciao, sono Otomai, uno dei più famosi incantatori del Mondo dei Dodici, l\'indiscusso specialista di tutto ciò che anima e regola l\'universo vivente. Sono anche famoso per il mio talento come Alchimista, che mi permette di creare pozioni dagli effetti vari.\nCosa vuoi sapere?";
D.q[1220] = "Grazie e benvenuto, fratello!";
D.q[5048] = "";
D.q[4164] = "Dobbiamo trovare una nuova vita, un nuovo mondo e imparare di nuovo ad amare.\nL\'euforia è stata intensa, ma breve. Oggi sono costretta a fuggire per far reagire colui che amo, anche se questo lo farà soffrire. Vorrei che tu glielo spiegassi. A volte è ingenuo come un Kanigrù e ottuso come un Bituf, ma i suoi difetti fanno parte del suo fascino. Parlagli, con un po\' di fortuna capirà e forse potremo ricominciare da capo.";
D.q[8101] = "";
D.q[1202] = "Hai tutti gli elementi per unirti all\'Ordine dello Spirito Redentore.\nSei sicuro della tua scelta?";
D.q[3172] = "Hou Hou Krabul bituf! Huhuharg. Kirbola kiki?";
D.q[1582] = "La lealtà non è ereditaria, non bisogna credere che tutti gli abitanti di Bonta siano rispettabili.";
D.q[3953] = "Matrimonio orribile? Ma, Allisteria è... Ehi! aspetta un attimo! Tu non parli come un Wabbit, tu non sei il principe! A me, mio fedele Pappatutto!";
D.q[8102] = "";
D.q[3998] = "Solo la battaglia dà onore, non la servitù!";
D.q[724] = "Abbiamo un agente spia nei ranghi della milizia di Brakmar, si chiama Bishom Pot. Infiltrati nella milizia e fatti dare le informazioni che mi servono. Per metterti in contatto con lui ti basterà dirgli: \"Brakmar è una città putrida in questa stagione\".";
D.q[2169] = "Hai paura delle Arakni che sei tornato così in fretta?";
D.q[4905] = "Salve, sei stato veloce.\nHo mandato delle Spie alla ricerca dello Spirito di Luce, ma sono tornati a mani vuote. Ho già spiegato la situazione ad Elviana Tirips e si sta informando. Vai a vedere a che punto è nelle sue ricerche e se puoi aiutarlo.";
D.q[2234] = "Come pretendi di avere un buon arco se non mi dai la lana per cambiare la corda?";
D.q[8103] = "";
D.q[1997] = "Dei fiori di Dizbi? Yeah! Hai bussato alla porta giusta! Ho quello che fa al caso tuo! E se conosco bene gli Aniripsa come te, preferite le infusioni, vero? Nibé Lulla dovrebbe poter accontentarti... e già che ci sei, se ripassando potessi portarne un po\' anche a me...";
D.q[7224] = "";
D.q[5930] = "";
D.q[8104] = "";
D.q[5085] = "Hé? Cosa? Io?\n(...)\nLo ammetto, quel giorno un tipo è venuto da me e ho accettato i soldi che mi ha proposto perché avevo molti debiti a causa dei combattimenti di tofu andati male. In cambio, io dovevo lasciarlo entrare per qualche istante nella stanza di riposo di Amayiro, ma non pensavo a tali conseguenze.\nAvevo già visto più volte questo tipo in compagnia di Danathor.";
D.q[5464] = "Ah, Te non conoscere cugino di me? Essere Ronan il Barbaro. Lui vivere vicino Brakmar.";
D.q[4439] = "Come hai potuto lasciarla filare via!? Dovrei farti giustiziare crudelmente! Tuttavia... mi piace la tua audacia. Segui la tua strada e non hai paura di mostrarlo. Dimenticherò questo piccolo incidente, ma che non accada un\'altra volta!";
D.q[7223] = "";
D.q[8105] = "";
D.q[1195] = "Mmh, capisco, Oto Mustam ti manda per prendere il rapporto. \nCapiti proprio a pennello, l\'ho appena finito. Spero che sia utile, non vedo l\'ora che le vie di questa Città diventino più oscure.";
D.q[2024] = "BAM... Sì, così! Guarda la mia forza crescere a dismisura! Non dimenticare: in combattimento lancia i tuoi incantesimi di castigo prima di ricevere un colpo, e come me potrai sentire la tua forza esplodere!";
D.q[8106] = "";
D.q[7147] = "";
D.q[6288] = "Come, il gioiello è sparito? Non è che l\'hai messo in un cofanetto nascosto in una tomba nel cimitero di Brakmar dopo aver fatto un patto con gli Chafer in modo che lo sorveglino durante la tua assenza? A meno che tu non l\'abbia consegnato a Jiaye Djaul in cambio di una compensazione pecuniaria, no? Non ti credo! Ti ho già visto bisbocciare con quel ricettatore e non mi stupirebbe scoprire che siete in affari. Riportami quel gioiello o chiederò a Sbab di cucinare dei salsicciotti con le tue trippe.";
D.q[8107] = "";
D.q[8108] = "";
D.q[7127] = "";
D.q[744] = "Abbiamo bisogno di manodopera per costruire una nuova ala dell\'edificio della milizia, mi restano due lavori da proporti, scegline uno e darò l\'altro a Torcha.\nPrima di tutto, se pensi di avere l\'anima di un Taglialegna, ci servono una ventina di tavole di frassino per fare il pavimento.\nAltrimenti, se cerchi un po\' più d\'azione, ci servirebbero una decina di radici di Alberagni per il soffitto.";
D.q[4234] = "L\'abbiamo chiamato Plasmogrin, e sappiamo che è cosciente. Terribile, vero? Questa versione semplificata dell\'organismo ci ha permesso di svelare il segreto dell\'evoluzione e quello che abbiamo trovato rimette in questione l\'equilibrio del mondo stesso!\n\nSanto cielo, se solo Otomai non si fosse spinto così lontano. Eppure non era mosso da cattive intenzioni...";
D.q[5270] = "Vorrei conoscere il tuo parere sullo svolgersi della battaglia.";
D.q[5236] = "";
D.q[5871] = "";
D.q[8109] = "";
D.q[1271] = "Che schifo, la prossima volta pulisci quello che ti chiedo di portarmi.";
D.q[6577] = "A volte degli Strateghi vengono qui perché la nostra biblioteca conta numerose opere di riferimento. C\'è soprattutto uno Stratega che ha passato gli ultimi trent\'anni a studiare la strategia, un Anutrof di nome Drena Nassema. Sfortunatamente, di recente, si è messo in testa di recarsi al Dongione degli Scheletri per mettere in pratica il suo studio. Dico sfortunatamente perché il suo ritorno era previsto più di una settimana fa e non abbiamo ancora sue notizie. Immagino che qualcosa sia andato male.";
D.q[5092] = "";
D.q[7227] = "";
D.q[7105] = "";
D.q[4440] = "Shhh! Sei venuto a portarci del Veleno?";
D.q[5874] = "";
D.q[5244] = "Abbuffarmi mentre altri eseguono il mio piano: è la mia attività preferita. Allora, dove sono i miei alimenti?";
D.q[6165] = "Nel corso di numerose ricerche archeologiche su quest\'isola abbiamo trovato molti indizi inquietanti. Quest\'antica civiltà scomparsa sembra essere strettamente legata ai Dofus. Non abbiamo ancora trovato in che modo, ci restano talmente tante cose da scoprire e da capire.";
D.q[4207] = "Ci piace mandare i gruppi di avventurieri verso una morte certa. Io e Otomai scommettiamo sempre sulla durata media dei combattimenti, prima che gli avventurieri muoiano insomma... Per questo scegliamo accuratamente coloro che possono affrontare il Kimbo, non ci piace scommettere inutilmente. Non ti lascerò passare se prima non mi dimostri di esserne veramente degno. Affronta il Tynril, e se sei capace di battere una tale creatura, allora dovresti resistere qualche minuto contro il Kimbo. In più, Mulez ti darà la chiave per accedere alla Canopea del Kimbo.";
