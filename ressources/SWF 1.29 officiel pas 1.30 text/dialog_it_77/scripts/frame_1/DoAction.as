D.q[2871] = "...";
D.q[693] = "Hogmeiser ha perso i suoi stivali durante un terribile combattimento contro un Capo di Guerra Pappatutto, il giorno della Festa delle Mutande del Capitan Chafer Paz, e mentre era sotto l\'effetto di sostanze ancora sconosciute.\nSi è poi risvegliato l\'indomani mattina, tutto nudo e senza stivali in mezzo alla palude.";
D.q[755] = "";
D.q[4854] = "Nell\'accusa di tradimento contro la città di Bonta, le aggravanti contro il Miliziano Bast Konliskerz non sono state formalmente stabilite e l\'accusato ha beneficiato di un non luogo. È dunque autorizzato a ritornare al suo posto di Miliziano sotto la sorveglianza di un altro Miliziano per un anno intero.";
D.q[1398] = "...";
D.q[810] = "100";
D.q[7029] = "";
D.q[1030] = "/azione scatenare combattimento/";
D.q[622] = "Bene, eccellente. Sei già un vero Alchimista. Ora sta a te sviluppare la tua tecnica. Buona fortuna collega!";
D.q[6931] = "";
D.q[936] = "Ciao amico, sono il miglior artificiere di Bonta. Qualsiasi materiale esplosivo tu stia cercando, io sono il tuo uomo.";
D.q[7264] = "";
D.q[614] = "La mia indagine stagnava... stavo per rifare il giro della casa quando qualcuno entrò nella stanza e mi rivolse la parola...";
D.q[2526] = "Shh,\n*a bassa voce*\nprima di parlarmi devi assolutamente aggiustare il problema della tassa, altrimenti non sarai il benvenuto qui. Non posso parlarti liberamente, è una storia di tradizione. Torna da me dopo e potremo discutere.";
D.q[1905] = "Capiti a proposito, il mio fattorino si è appena ammalato e non può fare una consegna molto speciale. Ho bisogno di braccia forti e gambe rapide per consegnare questi dolci ai quattro lati della città. Ti pagherò bene, ti interessa?";
D.q[7265] = "";
D.q[7363] = "";
D.q[4248] = "";
D.q[5177] = "";
D.q[1320] = "Ah, è il tuo turno di lavoro? Se potessi pelarmi 20 patate, saresti veramente un angelo. E avresti voglia di portarmi anche 6 zampe di cuervoc e 3 occhi, tanto per dare un po\' di gusto? Ti ringrazio in anticipo. E stai attento a non tagliarti.";
D.q[1019] = "Bene, ti sei ricordato della birra, non dimenticare che l\'allievo che ha sete di sapere deve pensare anche alla sete del suo professore... hehe! La carta finirà dritta dritta nella mia collezione.";
D.q[6992] = "";
D.q[4687] = "";
D.q[4834] = "Siccome siamo tutti qua, propongo di iniziare il Processo.\nIo, Satirev Onivin, Giudice di Bonta, dichiaro aperta la seduta per il tradimento di Bast Konliskerz.\n(...)\nEd è per questo che ti chiedo se, secondo te, la versione dei fatti di Bast Konliskerz è credibile o no.";
D.q[4032] = "Hai gli ingredienti da darmi?";
D.q[2420] = "Questo mestiere è adatto ai giovani che entrano nel duro mondo del lavoro. Abbastanza facile e poco costoso, il suo scopo principale e di fare farina per i Panettieri.";
D.q[5410] = "Dai, canta con me questo ritornello: \"Quando chiami Bibi, lui c\'è sempre. Si precipita da te. E dal verde delle Pianure Rocciose, ci fa sognare. Quando dà la caccia ai cattivi, è sempre il vincitore...\".\nBene, cosa vuoi fare adesso? Uscire dal dongione? Se hai la chiave dell\'antro del Blop Multicolore Reale, posso condurti fin là.";
D.q[2714] = "La nostra missione è di confinare i miserabili avventurieri fuori dalla nostra amata isola, ad ogni costo: sabotando i ponti, rubando tutte le scarpe sinistre, avvelenando i... traditori. Bene! Sei vuoi essere dei nostri, devi rispondere a questo enigma: tutti conoscono il suono prodotto da due pinte che brindano, ma qual è quello di una sola pinta?";
D.q[4692] = "";
D.q[4255] = "";
D.q[4588] = "A 5 anni i miei genitori mi hanno mandato a lavorare nelle Miniere di Brakmar e... non ti interessa? Allora perché me lo chiedi?\nAh, ok, vuoi informazioni sulla Corruttite. Se fossi in grado di parlare, si capirebbe meglio quello che dici! Allora, dicevo che è possibile conservare la Corruttite in un Ricettacolo speciale e che esiste un trattamento per poterla conservare fuori dal Ricettacolo, ma per questo serve un Mago. Se vuoi, posso darti la Ricetta del Ricettacolo.";
D.q[4693] = "";
D.q[4730] = "Appena sarai in  possesso del Legno di Carpine Oscuro, portalo direttamente a Mulic Ber.";
D.q[7461] = "";
D.q[6700] = "";
D.q[7583] = "Cosa c\'è? Non hai mai visto una donna con una pelosità molto sviluppata?";
D.q[5797] = "";
D.q[3569] = "Per costruire un simbolo, ci vuole soprattutto una Bandiera... ma alla fine è la stessa cosa, perché devo cucire il simbolo a forma di Bandiera...";
D.q[5796] = "";
D.q[4589] = "Spero che tu stia scherzando! È rimasta solo della polvere, ecco cosa succede quando si trasporta la Corruttite all\'aria aperta. È meglio che la prossima volta trovi un modo più sicuro per trasportarla.";
D.q[4049] = "";
D.q[6994] = "";
D.q[7832] = "Prima della glaciazione, tagliavo legna. Ora continuo, ma taglio anche gli animali, così proteggo gli altri taglialegna e il mio amico Sim Enthal è contento.";
D.q[2865] = "Avevo mandato dei Brakmariani a sgozzare i Dragacchini della Milizia di Bonta e a rubare le loro riserve di cibo, ma questi imbecilli si sono spaventati per il numero di Guardie appostate davanti ai recinti e, visto che stavano per farsi prendere, non hanno trovato niente di più intelligente da fare che bruciare i depositi di cibo per nascondere la loro fuga. Di conseguenza i Bontariani sono ancora in possesso dei Dragacchini e i depositi di cibo di Brakmar non sono stati riapprovvigionati.\n\nVai ad Astrub e trova Raymond Santho, un Mercante in contatto con Bonta. Devi fare in modo che si unisca alla nostra causa, non m\'importano i metodi che userai.";
D.q[5799] = "";
D.q[3310] = "Png(803) e Messaggio(3308)";
D.q[4700] = "";
D.q[4695] = "Sì?";
D.q[5124] = "";
D.q[7584] = "La grotta? Quale grotta?\nAh, vuoi dire QUELLA grotta... È lì che vive il mio paparino. Dopo la morte di mia madre, ha dato di matto ed è diventato molto pericoloso, per se stesso come per i visitatori. \nIl problema è che blocca l\'accesso alla migliore Miniera della Gilda Falce-Martello. È per questa ragione che non faccio entrare nessuno.";
D.q[6995] = "";
D.q[7585] = "Mi dispiace, il mio paparino si sta riposando. Qui non è un albergo, quindi torna quando sarà sveglio.";
D.q[4047] = "";
D.q[7833] = "Vedi questi tronchi? Bisogna portarli al Capo Tosto, gli servono per alimentare il riscaldamento del sistema di tubature e per tenere il porto scongelato.";
D.q[4701] = "";
D.q[4731] = "";
D.q[2146] = "Eh sì, lei ha scommesso che gli Anutrof non sarebbero stati così coraggiosi da arrischiarsi nei sotterranei \"con le creature che gironzolano nei dintorni e patatì e patatà\". \"Tutt\'altro\", ho risposto io: \"ci vanno di corsa a cercare fortuna!\".";
D.q[7586] = "Ti avviso, lì dentro è molto pericoloso. Vuoi andarci davvero?";
D.q[633] = "Oblio di Scatola di Pandora: 5 vecchi trifogli, 10 lingotti d\'oro, 1 diamante, 1 zaffiro, 1 ambra ancestrale.\nOblio di Avvistamento: 3 ossa intagliate, 20 onniscienti bastoni-sfera di veggente, 1 tintura nera.\nOblio di Compulsione: 4 selci insanguinate, 20 anelli di valore, 10 cinture di resistenza, 10 spappolatori di Yop. \nOblio di Tempesta del Tempo: 5 Immortali, 50 pozioni di vecchiaia, 5 Teschi di Drago Maiale, 10 Vecchie Ossa di Draguovo, 10 Sangue di Likrone.";
D.q[5242] = "(Resisti per qualche istante, ma Oto è troppo forte per te e ti batte senza problemi).";
D.q[2869] = "Ciao, siamo i banchieri. Puoi aprire un conto in banca e avere un forziere a disposizione per depositare i tuoi averi. Ma attenzione: ogni consultazione ti costerà #1 kama.";
D.q[4718] = "";
D.q[4151] = "Allora, sei riuscito a trovare tutte le farine di cui ho bisogno?";
D.q[5801] = "";
