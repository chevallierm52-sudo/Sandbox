D.q[681] = "Io, Don Juan, sono così triste\ndi vedere tante persone...\nFelici, ignorando l\'oblio\nDi una cosa essenziale, anzi una necessità.";
D.q[7011] = "";
D.q[682] = "Una speranza mi ha illuminato\nQuando in te ho scorto la voglia di capire,\nA te confido volentieri questo segreto,\nSì a te lo voglio proprio insegnare.";
D.q[7394] = "";
D.q[840] = "Aaah anche noi demoni abbiamo bisogno di riposare un po\' ogni tanto.\nBoh, non si può parlare veramente di riposo con mio figlio che rompe le scatole perché mi batta con lui, ma è sempre meglio che aspettare il ritorno degli agenti speciali da una missione importante.\nHmm, ora che ci penso, visto che non hai niente da fare, vai un po\' a distrarre mio figlio. Ma ricordati di perdere, altrimenti dovrò batterti io...";
D.q[7838] = "E\' Bi Ella che ti manda?\nAh, no è Gormor. Niente di grave, è la stessa cosa. Ringrazialo da parte mia, e digli che me ne serve di più.";
D.q[5508] = "Un Bontariano nella milizia? Sparisci prima che ti uccida per strapparti la tua quintessenza!";
