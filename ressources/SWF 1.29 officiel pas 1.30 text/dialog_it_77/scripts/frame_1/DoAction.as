D.q[6936] = "";
D.q[5209] = "";
D.q[1149] = "Benvenuto alla taverna Sulmenù. Se vuoi da bere, chiedimi il menù.";
D.q[6996] = "";
D.q[7809] = "Abbiamo girato in tondo per giorni interi senza incontrare nessuno, sono contenta che tu alla fine ci abbia trovati.\nVai a parlare con Richard Ritz, trova sempre una soluzione ai nostri problemi.";
