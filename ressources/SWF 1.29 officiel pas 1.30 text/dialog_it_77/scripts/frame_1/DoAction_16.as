D.q[5553] = "Allora non hai niente da fare qui!  Smettila di startene col naso in aria e trova velocemente una soluzione.";
D.q[1479] = "Cosa vuoi che me ne importi?! Vai a prendere un altro bastone e trovami un Bontariano che puzza di morte!";
D.q[6114] = "";
D.q[4267] = "Allora, così pensi che un notaio Bontariano potrebbe lavorare per noi? Capita bene, era da un po\' che ci pensavo. Però spero per te che questo Xefires sia proprio la persona che ha firmato questo documento, se no peggio per te.";
D.q[6186] = "Allora, raschiatura di cesso, vieni a trovare il tuo idolo?";
D.q[1199] = "Bene, quindi desideri restare sotto la mia tutela, nell\'Ordine del Cuore Valoroso. È una scelta di cui non ti pentirai.\nTuttavia, per confermare la tua richiesta, dovrai ritrovare il cancelliere dell\'Ordine. Da quando il suo gatto l\'ha lasciato, non fa altro che andare per taverne. Riportalo qui e accetteremo la tua richiesta.";
D.q[4159] = "Allora, vuoi tornartene su quell\'isola?";
D.q[3590] = "Un buon Contadino, dici? E va bene, vedremo. Abbiamo una grossa richiesta di grano... da un po\' di tempo ci sono molte bocche da sfamare. Mi va bene per gli affari ma devo trovare della manodopera. Vai a falciare qualche ara di grano.";
D.q[2529] = "È per una libagione alla dea?";
D.q[3052] = "Allora ci si ribella, banda di mascalzoni? Non pensavate tornassi così in fretta, vero? Ho solo una parola per qualificare un comportamento così vile, abietto, e antipatico: Aarrrgghh!";
D.q[2266] = "Allora, sei riuscito a procurarti delle forbici come si deve?";
D.q[4697] = "Allora, hai trovato qualcosa di sospetto?";
D.q[2392] = "Allora Mercenario, sei in cerca di prede e di kama? Capiti a proposito! Leggi gli avvisi di ricerca, ne saprai di più sugli individui da catturare.";
D.q[5043] = "Allora, hai visitato le miniere di Amakna?";
D.q[3831] = "Allora, sei pronto a partire per la grande avventura?";
D.q[3843] = "Allora, sei pronto a partire per la grande avventura?";
