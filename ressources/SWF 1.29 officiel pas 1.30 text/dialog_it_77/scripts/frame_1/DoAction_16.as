D.q[3839] = "Allora, sei pronto a partire per la grande avventura?";
D.q[4400] = "Allora, la pesca è stata buona?";
D.q[5203] = "Ecco dunque il famoso Ronan. Lo immaginavo più... grande. Ce ne occuperemo subito...\nAh, dovresti andare da Raaga. Ho bisogno di conoscere i suoi ultimi metodi sul lavaggio del cervello... sempre che un goblin ne abbia uno. Credo che sia andato in biblioteca.";
D.q[3962] = "Allora, questo blopisiero?";
D.q[2545] = "Ah! Il vecchio saggio ti ha parlato di quella vecchia leggenda... e tu ci hai creduto! Persino tra i Volpi, non si crede più a quella storia... Ma il saggio Volpo è convinto che molto tempo fa i Volpi proteggessero un uovo di drago... molto tempo fa... ma chi se lo ricorda?";
D.q[2577] = "Sono belli i miei cappelli, sono belli! Dei copricapi Pandawa quasi tutti nuovi! Avvicinatevi! Non basteranno per tutti!";
D.q[3051] = "Allora ci si ribella, banda di mascalzoni? Non pensavate tornassi così in fretta, vero? Aarrrgghh!";
D.q[6006] = "";
D.q[2117] = "Allora, questa consegna? Avanza o no?";
D.q[2251] = "Allora è tutto apposto? Mi hai portato le quattro cosce del mio povero Pappatutto e i due limoni che ti ho chiesto?";
D.q[3255] = "Ah sì, vuoi già andartene?";
D.q[1201] = "Bene, quindi desideri restare sotto la mia tutela, nell\'Ordine dello Spirito Redentore. È una scelta di cui non ti pentirai.\nTuttavia, per confermare la tua richiesta, dovrai ritrovare la cancelliera dell\'Ordine. Da quando i suoi due fratelli hanno strani comportamenti, sta andando di taverna in taverna per ritrovarli. Riportala qui e accetteremo la tua richiesta.";
D.q[2116] = "Ah, è così? Credi di potermi toccare adesso? Allora, dai, COLPISCIMI!";
D.q[4155] = "Allora, hai ritrovato il mio piccolo wabbit? Come sta?";
D.q[4328] = "Allora? Hai trovato un modo per far passare il messaggio?";
D.q[3512] = "Allora?";
D.q[3972] = "Cosa? Uccidere Wabbit? Non bello, non bello, non divertente per grande bwork come me.";
D.q[4185] = "Allora, hai ridotto in polvere i Pirati?";
D.q[2129] = "Secondo te l\'Uomo Orso non ha quasi più nessun potere?";
D.q[3864] = "Ah, vieni ad assicurarti che tutto sia in ordine al castello?... Non ti preoccupare, veglio io sul trono!";
D.q[4866] = "";
D.q[3089] = "Non ho affatto bisogno di questo per piacere al mio re. Per renderlo felice, mi basta il mio bel musetto. Trova qualcuno che non abbia il mio carisma felino.";
D.q[3386] = "Proprio dei bei combattimenti! Ma io non ho più niente da darti. Buona fortuna amico!";
D.q[2606] = "Molto bene, torna da me se trovi qualcosa... In una parola: addio!";
D.q[2666] = "Degli innocenti sono in pericolo al cimitero... io Nergal, servitore fedele del dio Yop, della vedova e dell\'orfano, ti prego di darmi una runa di teletrasporto per potermi recare subito in quel luogo!";
D.q[5852] = "";
D.q[327] = "Tra coloro che partiranno, certi non torneranno. E anche coloro che torneranno in realtà non torneranno. E se tornerete tutti, allora sono io che non tornerò.";
D.q[4116] = "Di che sesso è la persona che non è né tuo fratello né tua sorella, ma che è figlio dei tuoi genitori?";
D.q[5742] = "";
D.q[2894] = "Cosa ci fai qui? Dai, prendi la chiave e vattene.";
D.q[6206] = "Un certo X? Mah, forse so qualcosa, ma di solito non racconto gli affari dei miei clienti. Tengono alla propria discrezione, è per questo che vengono in questo esercizio pubblico.";
D.q[3746] = "Certi raccoglitori non vendono i frutti del loro raccolto, bensì li conservano fin quando non apprendono un secondo mestiere.";
D.q[5235] = "Qualcos\'altro per il tuo servizio?";
D.q[3105] = "Mi manca solo un caro compagno. Un famiglio morbido e che fa le fusa. Voglio un Maomao tutto bianco come me. Trovamene sei e sceglierò il più bianco.";
D.q[3515] = "Manca una cosa, è una questione un po\' complicata, ma penso che sia necessario ottenerla, anzi indispensabile!";
D.q[3673] = "Tra un po\' di tempo, anche tu affronterai le orde demoniache del malefico Rushu. Non deve assolutamente diventare il tredicesimo dio, sarebbe l\'apocalisse!";
D.q[300] = "Vittima...";
D.q[2115] = "Mi dispiace, ma non ho il tempo di chiacchierare con te. Ho un sacco di bestiole da sgozzare... Vuoi che ti faccia vedere come si fa?";
D.q[2080] = "Mi dispiace ma sono un Ocra molto occupato. Non ho il tempo di fare conoscenza.";
D.q[6313] = "Mi dispiace, amico, ma per questo non sono ancora abbastanza sbronzo. *hic* Vai a fare un giro verso il bosco di Litneg, un Trooll sarà contento di colmare la tua mancanza d\'affetto.";
D.q[2821] = "Mi spiace, ma non posso vendere della roba così forte ai turisti come te.";
D.q[3463] = "Ho bisogno di questa ricetta per mettere su la mia birreria. Cerca meglio!";
D.q[756] = "Ti ricordi del prigioniero che hai liberato?\nÈ guarito e desidera attaccare degli scheletri con te!";
D.q[1626] = "Spiacente, non parlo con gli sconosciuti...";
D.q[1874] = "Mi dispiace, ma non ho il tempo di chiacchierare con te.\nMio padre conta su di me: mi occupo del gregge famigliare di Pappatutto. Dice che è una parte importante della mia formazione. Senti, devo andare, ne sento uno che muggisce...";
D.q[301] = "Mi dispiace, ma la mia missione è di impedire ai giovani incoscienti come te di andare a farsi sventrare in un batter d\'occhio. Torna quando sarai più allenato. Tieni, ti restituisco i tuoi oggetti.";
D.q[2111] = "Ah, mi dispiace! Sono troppo occupato per occuparmi di te adesso!";
D.q[1608] = "Spiacente, non hai abbastanza soldi.";
D.q[1932] = "Spiacente, non si fa più credito.";
D.q[164] = "Mi dispiace, ma hai perso. Forse sarai più fortunato la prossima volta, non esitare a ritentare la fortuna.";
D.q[2718] = "La dea Pandawa tiene sempre d\'occhio il proprio bicchiere, ma anche te, ricordatelo!";
D.q[1750] = "Gli Etram sono personaggi molto agili e forti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro agilità e la loro forza.";
D.q[2698] = "Shh! Zitto... ascolta. La nostra dea ti sta ringraziando attraverso la mia bocca: è vero che questo Dofus è proprio somigliante! Il Grandapan adora i Dofus preziosi... Chiedi al Grandapan quello che vuoi...";
D.q[5487] = "Se ti piace la flora, discuti con Erty, è un esperto botanico.";
D.q[4473] = "Comincia guardando negli atelier di Forgiatori e Minatori. Non quelli di Bonta, ovviamente... né questi qui.";
D.q[6738] = "Ancora nessun bandito in vista? È quasi una sfortuna, questo viaggio è così noioso... Non vuoi fare qualche buffonata per divertirmi? No? Peccato.";
D.q[2022] = "Smettila di guardarmi così!... Muoviti, COLPISCIMI!... Colpiscimi forte, DAI!";
D.q[3644] = "Smettila di farmi perdere tempo con le chiacchiere. È a due passi da qui.";
D.q[4574] = "Minacce proferire tu osi? Attaccarmi tu puoi, ma la tua sicurezza assicurarti non posso perchè da molto tempo mangiato io non ho.";
D.q[3929] = "Cose strane al castello? No, ho solo visto passare Allisteria di recente.";
D.q[3930] = "Cose strane al castello? No, a parte la visita della piccola Allisteria. Insomma... mica tanto piccola, è già in età da matrimonio!";
D.q[2153] = "Niente sangue? Non hai trovato Adlu Minite il Minatore Oscuro? Pare che passi tutto il tempo a provare l\'acquavite del taverniere. Torna da me con qualche goccia del suo sangue.";
D.q[3926] = "Cose strane al castello? No, a parte la visita di Allisteria. Di solito, non lascia mai i suoi Pappatutto.";
D.q[2537] = "L\'assistente di Surivitna ti accompagnerà. È incaricato di ringraziare la dea per i suoi favori. La nostra dea è MOLTO permalosa, sai... Persino il Grandapan non dimentica mai di ringraziarla nelle sue preghiere, figurati...";
D.q[4386] = "Nessun attacco? Allora non ho più dubbi. Qualcuno di qua ai posti alti informa i banditi. C\'è qualcuno di corrotto nei nostri ranghi, è sicuro. Forse accetta delle mance per divulgare le informazioni segrete e per bloccare le nostre inchieste. Spiegherebbe anche la reticenza del consiglio a mettere fine agli intrallazzi di questi banditi.";
D.q[2779] = "Hi?";
D.q[2780] = "Quando avrai finito il tuo allenamento, vieni da me, ti aspetterò fuori dal Dojo.";
D.q[2429] = "Il Sarto sta sempre al passo con la moda. I Sarti creano cappelli e mantelli magici che, oltre a dare certi poteri a chi li porta, danno anche un aspetto unico. Questo mestiere è molto difficile, infatti i primi modelli non riescono mai bene. Senza contare che i Sarti custodiscono gelosamente i loro segreti e i loro insegnamenti sono più rari che alcune delle loro creazioni.";
D.q[2230] = "Grazie tesoro mio. Sei un po\' in ritardo, la mia merenda non è più tanto fresca. Sono obbligato a ridurre un po\' la tua paga.";
D.q[3530] = "Ecco dei kama, li metto con il gatrooll e li cuocio nel gratrooll prima di divorarli a morsi, poi col mantello mi pulirò la bocca da tutto questo buon grasso che macchia.";
D.q[6454] = "Prendi questa! *Sblam*. Sembra quasi che ti piaccia.";
D.q[1229] = "Prendi questa pinza! Strappare un dente di pappatutto è un gioco da ragazzi, metti un piede sull\'animale, scegli un dente, e dai uno strattone con la pinza!";
D.q[480] = "Tieni, ho segnato su questa pergamena la lista delle pergamene che devo spedire. Per qualsiasi domanda, sai dove trovarmi.";
D.q[2794] = "Non dire niente! Sento la morte ronzarti attorno... vuoi entrare nell\'oscurità della foresta proibita... vero?";
D.q[6408] = "Non so nulla, non ho mai cucinato prima di essere catturata da Brakmar. Faresti meglio ad interrogare Pizzy Karne, all\'atelier dei Macellai della città.";
D.q[2809] = "Molto bene! Un\'ultima domanda:\nChi è l\'autore del libro \"L\'arte Pandawushu\"?";
D.q[2813] = "Il Pappaton è bianco con una coda nera, mentre il Pandawa è nero con... dei bambù sulla schiena! La via dell\'illuminazione è lunga! Un giorno forse, un giorno... piccolo Scarafoglie...";
D.q[3733] = "Scegli.";
D.q[570] = "Si dice che quest\'isola sia stata creata dal dio Moon. Per meglio sorvegliarla, si è incarnato in un essere in carne e ossa. Ma solo i seguaci possono avvicinarsi a lui, a meno che non si voglia fargli un\'offerta. In poche parole, per avvicinarsi a Moon, bisogna avere molte noci di Kokos. Ad ogni passaggio vicino ad un totem Kokos, un numero di kokos pari alla sua grandezza ti sarà prelevato automaticamente, semplice no? Ohoh!";
D.q[2352] = "Vediamo... Aaah! Vuoi veramente diventare Alchimista? Sì, io sono un maestro. Molto bene allora, ascolta: un bravo Alchimista deve conoscere l\'intensità di magia di qualsiasi oggetto, e poterla manipolare a suo piacere. Dunque guarda con uno sguardo nuovo gli oggetti passati e futuri in tuo possesso.";
D.q[2848] = "Bravo, ti innalzo al grado di Sankwa!";
D.q[2235] = "Ha, grazie per il dolce, è per Oz. Con questo, farò di lui quello che vorrò eheh... Hai rispettato il termine di consegna, tieni.";
D.q[3684] = "Dirai a quel buono a niente di Disskray che nei campi ci sono un sacco di parassiti che distruggono i miei raccolti... anche se penso lo sappia già.";
D.q[3083] = "Grazie della tua discrezione. Se hai ancora un po\' di tempo torna da me, forse ho una consegna da affidarti.";
D.q[3102] = "Grazie dell\'aiuto. Mi piacerebbe tanto abitare in una piccola casa graziosa lontana dalla corte. Mifach O\' Bel mi ha parlato di un suo vecchio rifugio. Puoi andare da lui per chiedergli se posso andare ad abitarci?";
D.q[1185] = "Come dicevo: \"niente di più fac... ahem\". Buona fortuna per questo mestiere. Ah, non dimenticare di procurarti un coltello per il pesce, è indispensabile per esercitare il tuo mestiere. Te ne vendo uno se vuoi.";
D.q[2119] = "Grazie mille, torna a trovarmi quando ne hai voglia. Sei un bravo lavoratore!";
D.q[1322] = "Grazie mille, potrò finalmente finire il mio pasto.";
D.q[1988] = "Grazie mille.\n*Yol si gira verso Locetta e le fa bere la pozione*";
D.q[1897] = "Grazie mille. Bisogna muoversi, non mi resta più molto tempo prima dell\'appuntamento. Allora, vediamo...";
D.q[2720] = "È risaputo. I sentieri sono tortuosi e le creature che la abitano non sono amichevoli. Ma un certo Wally Oloconom è riuscito a redigerne una mappa. Sarebbe utile che lo conoscessi. Gira spesso nei dintorni di Amakna.";
D.q[2922] = "A cosa devo la visita di uno dei miei apprendisti?";
D.q[6756] = "Ti ricordo che devi partire tu in esplorazione, sei pagato per questo. \nAh, davvero, non ti pagano? Ti hanno fre... cioè, meglio così, sei una persona onesta, caritatevole e fedele alla propria città e ai suoi principi.";
D.q[3311] = "Grazie, il nostro buon re Allister potrà sfilare sulle sue fiere cavalcature adesso!";
D.q[2257] = "Grazie per l\'allenamento, mi è servito molto. Ho un ultimo favore da chiederti prima di lasciarti proseguire sulla tua strada.. Con tutto questo trambusto, alcuni pappatutto sono scappati, e sono andati verso i sotterranei...";
D.q[294] = "Scambio una porzione di pane al curry senza curry per 5 fiori di dente di leone diabolico. Mi servono per coprire l\'odore del pane raffermo.";
D.q[2938] = "Complimenti, sei riuscito a battere me e i miei scagnozzi. Sarei onorato se accettassi questo regalo.";
D.q[2949] = "Hmm";
D.q[1914] = "Ti spiego: mi serve qualcuno di abbastanza forte per trainare 1500 pods di pane, e abbastanza agile da correre velocemente... Cerca una persona che abbia queste caratteristiche, e parlagli. Se pensi che sia la persona giusta, riempi questo documento e falle appoggiare il palmo della mano in basso. Saprai così se hai fatto la scelta giusta o no.";
D.q[2945] = "Penso che tu non abbia niente da fare da queste parti.";
D.q[5573] = "Salve, hai usato la pozione sui resti dei rinnegati?";
D.q[3431] = "Grazie, grazie mille, vai a parlare con mia moglie, Dama El.";
D.q[3098] = "Grazie, adesso sono pronto ad affrontare lo squalo!";
D.q[3903] = "Raddoppierò la sicurezza... E visto che sei stato tu ad avvertirmi, ti assumo. Torna più tardi, avrò sicuramente del lavoro per te.";
D.q[2963] = "<B> test </B>\n<I>test </I>\n<U>test </U>";
D.q[3054] = "Grazie, ecco a te.";
D.q[5667] = "Grazie. Quando avrai finito con il resto, andremo nella sala del rituale.";
D.q[2966] = "Allora, sei tornato? Perché non mi hai portato le uova di Tofu? Che stai aspettando?";
D.q[3049] = "Attenzione, solo i fantasmi di famiglio possono entrare in questo santuario,  #1!\nSe hai una creatura del genere con te, puoi tentare di farla entrare, ma attenzione, non ha quasi nessuna possibilità di sopravvivere da sola, dovrebbe essere accompagnata da altri fantasmi di famiglio per sperare di uscirne viva.\nSe il tuo fantasma di famiglio riesce a battere quello di Oshima, forse riuscirà ad incontrarlo.\n\nSei sicuro di voler far entrare nel santuario uno dei tuoi fantasmi di famiglio?";
D.q[2967] = "Ciao avventuriero! Cosa posso fare per te?";
D.q[2979] = "Voglio il diluvio!";
D.q[3121] = "Mi hai battuto... Ma ho veramente apprezzato... questo combattimento... Troppo bello! E poi, il modo in cui tu sculetti... che stile... incredibile!\nSei veramente troppo... rapido... per me...\nHai veramente... uno stile... di combattimento... particolare... Come me... sei originale...\nSpero... che tu sappia prendere... il lato buono della vita...";
D.q[915] = "Grazie #1, sei sempre così disponibile. Ora posso allenare i miei ragazzi seriamente.";
D.q[1906] = "Grazie mille, ecco, ti do una lista di persone alle quali consegnare. Devono ricevere i loro dolci, diciamo... entro circa 20 minuti. I dolci sono già pagati, la consegna invece no. Sarà la tua paga.";
D.q[1119] = "Grazie mille, con questo il mio tabi dovrebbe sentirsi meglio.";
D.q[2569] = "Grazie! Le preghiere salgono più veloci al cielo quando sono accompagnate da una buona Pandaneken! Puoi sempre andare a fare due passi se vuoi, mentre io finisco la Pand... preghiera.";
D.q[6334] = "Ti ringrazio, ma preferisco che tu tenga i tuoi soldi. Per me è un piacere offrire una copia del Metodo d\'Allevamento Canino ad una gattina con un musino così carino.";
D.q[1258] = "Grazie ahahaha, ti ho fregato. Come potrebbe una ragazzina come me conoscere la ricetta di una pozione magica. Ahahah!";
D.q[1920] = "Grazie mille. Vai dal Taverniere Tek Abir, comincia già a farci il callo.";
D.q[1855] = "Grazie mille. Eccoti qualche soldo, l\'hai ben meritato. Mi chiedo comunque cosa vengano a fare questi scuiscuit qui. Io sono sicura che si tratta di tutto questo trambusto nei sotterranei, che spinge gli scuiscuit a risalire... Kwikwi è d\'accordo con me!";
D.q[4147] = "Grazie mille, adesso ho tutto quello che mi serve.";
D.q[6465] = "Grazie, ti devo molto. Ti darò della gelatina sintetizzata che ho inventato io stesso ed una ricetta in modo che tu possa usarla. Se non hai le competenze richieste, chiedi ad un Tuttofare d\'aiutarti. Ti avviso subito, non te ne darò di più, quindi assicurati che il Tuttofare che l\'utilizza sia abbastanza competente per non guastarla.";
D.q[1924] = "Grazie mille, eccoti un campione di cìo che possiamo fare, ripassa quando vuoi. Ah... ma dato che sei qui, saresti interessato a farti un po\' di soldi facili? Mi servirebbero altri elementi...";
D.q[2997] = "Allora? Non hai ancora trovato una copia del mio libro? Cerca ad Astrub, dovresti riuscire a trovarne un esemplare!";
D.q[5526] = "Grazie, per merito tuo il mio conto in banca a Brakmar scoppierà. In bocca al lupo per il seguito.";
D.q[2031] = "Sei piuttosto rapido, è una cosa positiva. Ma quello che conta veramente è la forza con la quale sferrerai gli attacchi, e il coraggio di andare fino in fondo alle tue convinzioni. Ma soprattutto, devi restare giusto... Queste sono le parole maestre della nostra casa, non dimenticarle. Adesso, dammi la tua spada affinché possa incidervi sopra il marchio del tuo destino... *Rok usa diversi attrezzi ma non sembra molto abile quando non maneggia una spada*...\nEcco fatto!";
D.q[1219] = "Grazie e benvenuto, fratello!";
D.q[4436] = "Grazie ancora.";
D.q[2846] = "C\'è il sole a PandalaLaaAdaAada... Scusa? Sono occupata, mi spiace ma non posso aiutarti.";
D.q[3012] = "Vai da Hugo Bel, nel tempio della dea Feca. Te ne procurerà.";
D.q[3205] = "È semplicissimo, per entrare devi avere la chiave! Prima ero il solo a possederne, però le cose sono cambiate... e credo di aver perso il mio mazzo di chiavi su quest\'isola, ma non so dove. Una di queste maledette creature deve avermelo sicuramente fregato mentre dormivo.";
D.q[3709] = "Grazie per i tuoi consigli, hai già l\'aria di un veterano. Vado a dormire un po\' per rendere omaggio al mio dio. Sadida dice che bisogna sempre riposarsi dopo uno sforzo intellettuale!";
D.q[2254] = "Grazie per le cosce... ma mancano ancora i 2 limoni per la mia ricetta... Dai! Sbrigati! Ho fame...";
D.q[5188] = "Grazie per avermi scagionato, te ne sarò eternalmente grato.";
D.q[3111] = "Grazie per la pala. E ringrazia Rocco Fidelio per le patate. Digli anche che dovrebbe arrestare un po\' più di gente per ravvivare un po\' questa bella prigione in riva al mare. Dovresti restare con me a pelare un po\' di patate, ci vuole arte!";
D.q[1024] = "Grazie per la polvere, i Brakmariani dovrebbero comportarsi meglio. Hehe!";
D.q[2141] = "Hai la risposta? Bene, allora trasmettila a quel vecchio spilorcio di Joe.";
D.q[584] = "Grazie carne! Tu potere andare in villaggio, tu visitare e tu tornare qui per essere cotto! Tu non allontanare te troppo!";
D.q[2126] = "Grazie ragazzo mio, sarai sempre il benvenuto qui. Se dovessi avere un problemino di soldi, ricordati che qui ci sarà sempre un lavoretto per te.";
D.q[1104] = "Ah, che aria nauseante, che oscurità, e poi queste ombre sui muri... Mammia mia quant\'è bella questa triste città di Brakmar.";
D.q[5256] = "Ho degli interessi su quella questione. Vieni da me più tardi.";
D.q[4167] = "Grazie a te mi sento rinascere, la mia voglia di sedurre Jeanne è ormai alle stelle, i nostri giochetti di seduzione non sono mai stati così saporiti!";
D.q[1064] = "Grazie ragazzo. Sei stato efficace... ma non è certo questo che farà di te il più grande squartatore di Brakmar.";
D.q[920] = "Grazie ragazzo, sei stato rapido. Hai l\'aria vivace e disciplinata...";
D.q[3039] = "Tieni, ti do questo manuale da leggere dopo che avrai compiuto la missione! Apri gli occhi, tutti e due!";
D.q[6169] = "Altolà. Sorveglio questa città quindi non imbrogliarmi o andrai direttamente in prigione senza passare dal via, capito?";
D.q[1337] = "Ti ringrazio, grazie a te potremo assistere alla cerimonia d\'onore. Bene, posso finalmente riposarmi fino a stasera.";
D.q[2068] = "Grazie a te. Ah, stavo dimenticando di dirtelo. Se si mette a correre, stalle alle calcagna. Voglio che tu le stia sempre appiccicato. Così sarò sicuro che non farà stupidaggini. Bene, credo che andrà tutto per il meglio... te la affido. A dopo.";
D.q[3070] = "Un invito a pranzo di quello stupidone di Kartier Tremen? Non sei il primo messaggero che mi manda. Il giorno che verrà lui in persona ne riparleremo!";
D.q[2097] = "Grazie, sapevo di poter contare su di te.";
D.q[6238] = "Grazie, non sapevo che i Brakmariani fossero così simpatici. Questo documento deve essere molto importante, immagino. Cosa vuoi esattamente da Xefires? È strano che i Brakmariani s\'interessino così tanto ad un Bontariano.";
D.q[3485] = "Grazie, è perché ho mangiato troppi Goblin Rossi durante la battaglia di Bworkdrift. Io facevo parte dei Goblin Bianchi.";
D.q[3081] = "La vecchia Verru Kosa mi mette i bastoni tra le ruote? Non per niente è la responsabile della dogana. La vita di contrabbandiere è ben difficile ai giorni nostri. Dalle questi 1000 kama. Dovrebbero ammansirla un po\'. Poi torna da me subito dopo, ti darò della merce vietata per questo servizio. Sbrigati, altrimenti ti ritroverò e ti darò da mangiare ai veri squali!";
D.q[2749] = "Leggo nei tuoi occhi che vuoi andare nella foresta malefica, vero?";
D.q[1427] = "Grazie, ecco 200 kama per la corsa. Torna quando vuoi, io cerco sempre degli ingredienti.";
D.q[4886] = "Se Amayiro ha un piano contro Brakmar vi parteciperò con onore.";
D.q[4814] = "Porta subito quest\'acqua a Mulic Ber.";
D.q[1282] = "Grazie, studierò tutto ciò con calma, spero che la passeggiata ti sia piaciuta e che tu ti sia riposato, le prossime missioni non saranno tanto facili...";
D.q[1622] = "Lasciami passare! Ho perso l\'indutto-ridulore del mio Bumper, e non posso più entrare a casa mia. Se solo mi rimanesse un po\' di energia Oclitica per riparare il mio modello BZ4A...";
D.q[579] = "Saresti veeramente geeentile *hic*, seenza di lui il mio geenio taaaace *hic*. Ma me ne seeerve uno inteero *hic*, e il mio teeesoro sarà tuuo *hic*";
D.q[1055] = "Lui? Questo buffone ha avuto fortuna. Vabbé... grazie per il tuo lavoro. Ti do l\'autorizzazione di fare quello che vuoi. Adesso non ho il tempo di occuparmi di te allora... sparisci!";
D.q[5623] = "È stato veloce, non trovi? Visto che te ne sei uscito fuori bene, penso che meriti il titolo d\'Adepto degli Scritti.\nChe Jiva vegli sui tuoi passi.";
D.q[3107] = "Ohlàlà, quanto sei lento, i miei pretendenti avrebbero già finito questo piccolo favore che ti chiedo.";
D.q[2788] = "Conosco più o meno il cammino fino all\'ultima guardia... La sento russare come suo solito. Osserva la stanza con calma: se ritieni che possa avanzare un po\' senza farmi vedere, dai un colpo sul pavimento.\nLe guardie qui sono abbastanza metodiche: osservandole bene dovresti riuscire a guidarmi. L\'imbranato laggiù dorme abbastanza profondamente, ascolta bene il suo russare e dimmi quando posso saltargli addosso senza rischi! Se hai capito tutto, facciamo una prova.";
D.q[4015] = "La somma mi sembra corretta, ti seguo. Hai una divisa per me?";
D.q[6359] = "È un bastimento da guerra Bontariano questo, no? Non sapevo nemmeno che stesse per attraccare. Dovresti interrogare Verru Kosa, lei dovrebbe sapere che i Bontariani stanno per arrivare nel suo porto, anche se non mi stupisce che nessuno mi abbia informato.";
D.q[2188] = "Allora, il fattorino è salvo? Non ancora? Dai, ho fiducia in te!";
D.q[4891] = "(Ad un tratto tutto diventa nero e cadi al suolo. Attaccare Garutar non è stata una buona idea.)";
D.q[2474] = "Per essere un ponte, è un bel ponte! Abbiamo dato un bell\'aiuto ai Pandawa. Ma dobbiamo tappare queste brecce, altrimenti tutto rischia di crollare. Sì... ci servirebbe proprio l\'ambra.";
D.q[6566] = "Bene, bravo, baubau. Ora pulisciti il naso con le dita dei piedi.";
D.q[6431] = "Poco tempo fa abbiamo avuto qualche problema con degli Ecaflip un po\' sbronzi. La situazione si era talmente degradata che abbiamo rischiato di venire alle mani, prima che il loro capo li facesse ragionare ricordando loro che non dovevano farsi notare e che avevano un lavoro da finire. Figurati, per quella volta era andato tutto a monte.";
D.q[634] = "Oblio d\'Erba Folle: 5 Verbene, 10 Legni di olmo, 40 Steli di Dente di Leone Diabolico, 40 pezzi di Ferro, 40 Radici di Alberagno.\nFreccia di Espiazione: 5 Legni Elastici, 5 Strapotenti Archi del Re dei Borin, 1 Pietra per Arrotare, 10 Sangue di Vampiro, 10 Mutande in Cuoio del Capitano Chafer.\nOblio di Parola di Prevenzione: 3 Campanelle, 50 Lisciatori, 50 Scorreggiatori.\nOblio d\'Attrazione: 4 Ortiche, 10 Celebrità, 10 Anelli di Soddisfazione, 2 Mantelli del Gal Lett.";
D.q[5843] = "";
D.q[3161] = "Avvicinati, avvicinati se non hai paura! Vieni qui, guardami negli occhi, voglio vedere il terrore nel tuo sguardo!";
D.q[3078] = "Ecco la soluzione, sono sfinita da tutte queste emozioni. Portami del latte di maiale da latte, cucciolo, io ti darò delle caramelle. Non mi fanno bene ai denti.";
D.q[5604] = "Mi porti una buona notizia. Grazie alla crescita accelerata dei cereali, non avremo più problemi di cibo per i dragacchini. Di sicuro potremo fare la stessa cosa con gli altri cereali per nutrire le truppe.\nQuindi eccoti Scudiera.";
D.q[2585] = "Non basta acquistarlo, mio prode, ora devi usarlo... prima di portarlo, annusalo bene come se fosse un fiore...";
D.q[2437] = "Puoi trovare tutte le attività relative ai pesci nell\'edificio a forma di kralamore.";
D.q[3988] = "Poco impowta! Andiamo subito a cewcare dei seguaci.";
D.q[307] = "No! Non è questo!";
D.q[4653] = "Ah, molto bene. Hai rispettato i miei ordini. Tanto peggio per la spia, avrebbe dovuto essere più astuto nel nascondersi! Eccoti la tua ricompensa.";
D.q[4089] = "Non è così semplice, sei pronto a ricominciare?";
D.q[6329] = "Ma, è terribile! Hai davvero un cuore di pietra ancora più solido di quello di un Croccaroc.";
D.q[5854] = "";
D.q[6767] = "Anche Sadida me lo diceva quando parlavamo... insomma, parlavo soprattutto io, a lui bastava ascoltarmi con grande attenzione e a volte scuoteva la testa con soddisfazione. Ma chiacchierare non risolve il problema della tua presenza in questi luoghi. Vuoi che ti faccia uscire da lì?";
D.q[1188] = "L\'Occhio Attento si occupa delle missioni di Bonta che necessitano delicatezza e discrezione. Certi dicono che facciamo spionaggio o sabotaggio, ma personalmente preferisco parlare di raccolta informazioni e pulizia in larga scala...";
D.q[843] = "I Bontariani sono veramente troppo calmi. Ci dev\'essere qualcosa sotto. Una delle nostre spie si è infiltrata a Bonta, si chiama Trojen Tihpor. Adesso deve essere di guardia ai bastioni della città. Vai discretamente a parlargli e fammi un rapporto sulle attività Bontariane.";
D.q[842] = "I Bontariani sono belli calmi in questo momento. Non succede quasi più nulla. Puoi approfittarne per riposarti.";
D.q[1706] = "Il tempio Ecaflip è a Nord del villaggio di Amakna, non molto lontano da qui. Parla a Feleny Muson per cominciare il tuo apprendistato.";
D.q[1709] = "Il tempio Ocra è a Sud del villaggio, non molto lontano da qui. Parla con Eluhise Valing per cominciare il tuo apprendistato.";
D.q[3357] = "Il re dei Pappatutto riceverà presto una visita.";
D.q[1641] = "Il tempio Feca è a Est della costa di Asse. Parla a Hirpina Faklamità per continuare il tuo apprendistato.";
D.q[1707] = "Il tempio Aniripsa è a Est del villaggio di Amakna, non molto lontano da qui. Parla a Limen Bryone per cominciare il tuo apprendistato.";
D.q[3744] = "Un Alchimista crea pozioni che racchiude in fiale: pozioni di cura, pozioni di ritorno al punto di registrazione, pozioni di oblio di mestiere e molte altre ancora!";
D.q[1708] = "Il tempio Yop è a Sud del villaggio di Amakna. Parla a Tajide Ragalde per cominciare il tuo apprendistato.";
D.q[3312] = "Il re sta aspettando il suo maneggio. Hai un compito reale, cerca di esserne all\'altezza!";
D.q[3323] = "La montagna dei Koalaks non è stata ben cartografata. Mi piacerebbe che dei giovani avventurieri curiosi e temerari mi portino una descrizione di questa lontana regione...";
D.q[2347] = "L\'Alchimista è un manipolatore di elementi, magici e non. Trasforma materie in altre materie. Ma soprattutto, non pensate all\'Alchimista come ad un topo di laboratorio. Un vero Alchimista passa tanto tempo nel suo atelier quanto a viaggiare per il mondo alla ricerca di ingredienti rari. E posso dirti in tutta onestà e per esperienza, che quando non ti restano più peli di Buulupo... ebbene, ti fai coraggio e vai a cercarteli!";
D.q[3522] = "L\'incantesimo Vaifuori!";
D.q[2380] = "Per essere Forgiatore devi avere molto tempo, nonché molte conoscenze. È impossibile essere Forgiatore senza conoscere un buon Minatore e un buon Taglialegna che ti forniscano le materie prime. Anche se ci sono sempre i mercatini dove poter comprare tutto, ma a me non piacciono molto.";
D.q[3919] = "Il principe d\'Ue? Sì, credo che stia cacciando a Sud di Bonta, ma non so dirti precisamente dove. Mi sembra tra l\'altro che ci sia andato da solo, un po\' strano per un principe.";
D.q[3918] = "Il principe di We? Sì, credo che stia cacciando a Sud di Bonta, ma non so dirti precisamente dove. Mi sembra tra l\'altro che ci sia andato da solo, un po\' strano per un principe.";
D.q[2751] = "Penso che lo Sciamano sia qualcuno di competente per quanto riguarda i certificati. Vai a trovarlo.";
D.q[1710] = "Il tempio Sadida è a Sud del villaggio di Amakna. Parla a Silimote Fugaris per cominciare il tuo apprendistato.";
D.q[4236] = "Logorata ogni giorno da un odio feroce nei confronti dei suoi carcerieri, dopo aver ottenuto l\'immunità per così tanto tempo, la creatura è evasa. Non ci rimane nulla di lei, solo qualche pelo della schiena. Chissà quali altri danni farà domani.";
D.q[5376] = "Non sarò prigioniero a lungo. I miei fratelli Brakmariani mi libereranno!";
D.q[1704] = "Il tempio Etram è a Sud-Est di qua, non molto lontano. Parla a Sirmina Daghera per cominciare il tuo apprendistato.";
D.q[1187] = "Il Cuore Valoroso raggruppa i più valorosi guerrieri di Bonta. Temerarietà, coraggio e determinazione sono necessari per entrare in questo ordine.\nIl nostro motto potrebbe essere: \"Colpiamo forte e veloce, il Male non si rialzerà\".";
D.q[6059] = "";
D.q[3122] = "Sono rinchiuso... nella mia stessa caverna... da anni...\nCome è... mai possibile?\nNon ne so... niente... \nÈ stato Skunk... e le sue maledette Sadidine... Mi hanno rubato... il mio prezioso... il mio Dofus... il mio... quello che amavo tanto...\nHum... non sei il primo a venire qua...\nOshar Marif... accanto a me... ha cercato di affrontarmi... ma... l\'ho battuto... e ora è troppo debole... per ripartire da solo...";
D.q[3612] = "La bella Gobrosa, schiava di Bwoksina. Puoi tu liberare lei?";
D.q[2799] = "Anche il richiamo della foresta maledetta ti eccita, discepolo.";
D.q[3938] = "Ah, c\'è movimento al castello. Dovresti chiedere a Ghedin, è lui che porta i sacchi.";
D.q[1485] = "Semplice, devi trovare l\'entrata della grotta leggendaria delle larve dorate. Secondo la leggenda si troverebbe un po\' a Ovest di Amakna. I poteri segreti della larva dorata ti permetteranno di entrare.";
D.q[4770] = "La lama è già forgiata, questo è il momento di impregnarla della potenza demoniaca. Vai da Lagren Doowile, in basso. Ti spiegherà come fare.";
D.q[1714] = "La sfida è semplice, hai notato che nel cuore di questo tempio c\'erano molti animali. Tra di loro si trova un Tofu di colore nero e vorrei che tu mi portassi una delle sue piume, per dimostrarmi il tuo valore nel combattimento.";
D.q[6728] = "Il conflitto tra le due grandi città a volte è un po\' fiacco. Ha bisogno di dinamismo. Sono qui per aiutare coloro che la pensano come me. Ho un dono per la localizzazione dei nemici. Io decido gli obiettivi e la caccia comincia.\nAllettante, no?";
D.q[2015] = "Delle fiale di cristallo di Pallido Anthir... hummm... vuoi conoscere il futuro? Mi sembri troppo poco esperto per una richiesta del genere, ma sono affari tuoi. Ti avverto, molta gente ha perso la vista cercando di guardare in questi cristalli. Tieni, ecco a te.";
D.q[5575] = "Ma, ssst, ti dico! Il tuo libro si trova qui, no, un po\' più a destra, eccolo. In silenzio! E ora che ce l\'hai, fila!";
D.q[4327] = "";
D.q[1135] = "Interessante! Il momento in cui potremo distruggere Bonta l\'usurpatrice si sta avvicinando. Le notizie che mi porti ci permetteranno di migliorare il nostro piano di battaglia.";
D.q[2428] = "Il Ciabattino fabbrica cinture e stivali bellissimi con il cuoio e un po\' di metallo. Se associate a buone risorse magiche, certe cinture danno poteri terrificanti a chi le porta.";
D.q[3408] = "Procedi bene, ma la fine della strada sembra sempre più lontana, tutto questo vale veramente la pena?";
D.q[3896] = "Ciao, leale suddito! Lunga vita al nostro amato Re! Che possa regnare per ancora lunghi anni!";
D.q[4418] = "La scoperta del traditore ha reso i nostri superiori troppo sospettosi. Preferisco non darti nessun compito per adesso.";
D.q[962] = "I quartieri di Bonta sono divisi a seconda delle attività esercitate dai diversi artigiani. Puoi riconoscere l\'attività principale di un quartiere dagli ornamenti sulle facciate delle case ma anche dai pali che sorreggono gli stemmi di ogni mestiere.";
D.q[1983] = "Il medico non conosce questa malattia, ma rifiuta di abbandonare Locetta al suo triste destino;\r\n            allora mi ha chiesto di provare diversi rimedi. Ho accettato volentieri, però mi mancano degli ingredienti... lui non può andarli a cercare e io non voglio lasciare sola Locetta. Potresti aiutarmi?";
D.q[1373] = "Hai trovato i campioni che ti ho chiesto?";
D.q[4300] = "Hai recuperato il materiale che ti ho chiesto o devo affidare questo compito a qualcuno di più abile?";
D.q[331] = "Non hai tutto quello che ti ho chiesto! Non cercare di imbrogliarmi, o chiamo il mio amico Baraballe che ti piglia a calci nelle...! Aiutooooooo!";
D.q[4057] = "Un principe Wabbit, è meglio di niente, con un poco d\'ash... pardon... d\'astuzia, dovrei riuscire a mettere d\'accordo tutti. Lasciami riflettere sui preparativi. Tu approfittane per trovare il principe e convincerlo a sposare la principessa.";
D.q[7466] = "Il primo potere permette di dimenticare totalmente le tue caratteristiche, saranno identiche a quelle che avevi quando sei arrivato nel Mondo dei Dodici. Tutto quello che avrai imparato grazie alle pergamene sarà perduto. Grazie a questo potere potrai cambiare completamente il tuo modo di combattere e di utilizzare i sortilegi, cambiando i tuoi elementi preferiti.";
D.q[2287] = "Proprio come te, tutte le creature  sono più o meno resistenti ai quattro elementi primordiali: aria, terra, fuoco, acqua. Impara a riconoscere i punti forti e deboli di ognuna di esse (e anche i tuoi!). E il mondo sarà un luogo sicuro per te... O quasi.";
D.q[3751] = "La prima cosa da fare è prendere il proprio attrezzo di lavoro. Poi scegli di macinare il grano al frantoio.\nPer ottenere una misura di farina, bastano due misure di grano. Devi visualizzare il risultato del tuo lavoro prima di mescolare gli elementi.";
D.q[7066] = "Le Pietre seguenti...";
D.q[1672] = "EHI! EHI! METTI ALLA PROVA LA TUA MEMORIA! SVELA LE TUE CAPACITÀ NASCOSTE! Tu, sì, proprio tu! So che hai del potenziale! Avresti voglia di mostrarlo a tutti? Costa solamente 20 kama e puoi vincere un sacco di gettoni!";
D.q[1470] = "(Ma cosa ci fai qui? Non è il posto per un demone come te questo! Farai saltare la mia copertura, dai dai, vattene o chiamo la guardia!)";
D.q[2719] = "La dea ti ha ben guidato fino al Dojo. Ti insegnerò l\'arte ultima e sublime chiamata Pandawushu... La quota è di 10000 kama, pagabili in anticipo...";
D.q[4211] = "Hum, vista la tua costituzione avrò sicuramente bisogno di una reliquia di Corallaio Magistrale, una di Gurlo il Terribile e una del Rasbul Maggiore per preparare la tua pozione. Una volta ridotte in polvere, potrò ottenere tutta la potenza magica di cui ho bisogno.";
D.q[136] = "(Musol Ungo scrive il tuo nome su una tabella, lancia in aria dei dadi a 37 facce, li riprende, fa degli strani calcoli, si gratta i baffi e riflette...)";
D.q[2233] = "Cool! Torna tra 5 minuti. Ti farò una bomba d\'arco...";
D.q[4729] = "L\'impugnatura della Lama deve essere di Legno, ma non un legno qualsiasi... Serve del Legno di Carpine Oscuro, ma non sapevo nemmeno che questo Legno esistesse.  \nIspeziona gli Atelier dei Taglialegna e trova qualcuno che sappia come procurarselo. Quando sarai in possesso del Legno di Carpine Oscuro, portalo a Mulic Ber, lui saprà utilizzarlo.";
D.q[3184] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella prima sala della biblioteca, o nella seconda, o nella quinta o forse nella sesta, non ricordo più.";
D.q[1884] = "Le tue informazioni sono interessanti, ma ho bisogno di saperne di più per trarne delle conclusioni affidabili. Conosco qualcuno ad Amakna, un certo Treffiori, chiedigli di farti scoprire la vegetazione della sua regione, e portami un rapporto quando ripasserai da Astrub!\nForza, vai, giovane discepolo, haha!";
D.q[825] = "Chiedi alla guardia che si trova all\'entrata se per caso ha bisogno di una mano, personalmente, non ho niente per te.";
D.q[3047] = "Finalmente possiamo andare di nuovo nel sontuoso castello di Allister.";
D.q[6729] = "Com\'è andata la caccia?";
D.q[3185] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella prima sala, o nella seconda, o nella quinta o forse nella sesta, non ricordo più.";
D.q[3190] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella terza sala, o nella quarta, o nella settima o forse nell\'ottava, non ricordo più.";
D.q[3187] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella terza sala, o nella quarta, o nella settima o forse nell\'ottava, non ricordo più.";
D.q[3196] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella nona sala, o nella decima, o nella tredicesima o forse nella quattordicesima, non ricordo più.";
D.q[3189] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella prima sala, o nella seconda, o nella quinta o forse nella sesta, non ricordo più.";
D.q[3186] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella terza sala, o nella quarta, o nella settima o forse nell\'ottava, non ricordo più.";
D.q[3197] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella nona sala, o nella decima, o nella tredicesima o forse nella quattordicesima, non ricordo più.";
D.q[3598] = "Taglialegna? Bene, è un mestiere che richiede un occhio accorto e la voglia di viaggiare. I buoni alberi sono rari e bisogna proteggere la foresta. Questo mestiere è inoltre alla base di numerosi mestieri di artigianato. Esiste qualcosa, infatti, che non sia a base di legno? Quindi siamo d\'accordo, possiamo cominciare?";
D.q[2285] = "Le creature che popolano le nostre contrade sono una più affascinante dell\'altra. Per affinare le proprie conoscenze zoologiche e botaniche, non c\'è niente di meglio che esplorare la fauna e la flora locale. Cuore semplice e intenzioni pure bastano per ammansirle la maggior parte delle volte.";
D.q[554] = "Gli abitanti dell\'isola sono abbastanza scorbutici all\'inizio. Ma non pensare che ce l\'abbiano con te! Al contrario, stravedono per i turisti! L\'unica persona più importante dei turisti è il loro capo. Dicono che sia l\'incarnazione stessa del dio dell\'isola: Moon. Non lasciarti ingannare dall\'apparenza, è veramente molto intelligente e divertente.";
D.q[571] = "Gli abitanti dell\'isola? Ahahah! C\'è qualche pirata che gira nel Sud della giungla. Sono abbastanza freddi con gli stranieri ohohoh. Erano già qui quando sono arrivato io, e probabilmente ci saranno ancora quando te ne andrai tu, sembra proprio che gli piaccia stare sull\'isola, ahaha!";
D.q[2113] = "Ciao! Torna da me quando sarai più verde.";
D.q[1652] = "Gli abitanti di questo villaggio sono molto ingegnosi, ma non sono riusciti comunque a rendere il loro villaggio sicuro\n*sfrega la sua sfera di cristallo*\nPer adesso sono le truppe di Bonta a controllare il villaggio, ma forse non per molto tempo ancora...";
D.q[2972] = "Ahah! Il classico scherzo! Ti hanno chiesto di farlo, e tu? Tu l\'hai fatto! Pensavi veramente che ti credessi? Cosa dici... un Pandawa? Non mi stupirebbe per niente! Chi sarebbe così stupido da vantarsi di avere un Dofawa?";
D.q[4004] = "Sì, ma dopo? La paga deve essere buona! Non farò il cuoco per tutta la vita...";
D.q[5146] = "Per fortuna è finita! Ho temuto di morire prima della fine del Processo a causa della puzza di Pescis marcio di questo Etram.";
D.q[5184] = "Pro-teg-ge-re. Uk\'Not\'Allag.";
D.q[368] = "Ci servirebbero 80 Gelatine Celesti e 30 Gelatine Menta.";
D.q[4312] = "Ah, mi porti della bava?";
D.q[5032] = "Scegli il simbolo che vuoi sul forziere, ti porterò fuori quando sarà finito.";
D.q[4812] = "Cosa ci fai ancora qui? Non voglio più vederti prima che Mulic Ber abbia forgiato la Spada.";
D.q[1955] = "La birra è consegnata, grazie mille. Oggi ne hai impedito il furto, ma domani? Potresti fare qualcosa?";
D.q[173] = "Il taverniere mi ha chiesto di portargli del Luppolo da dare ai suoi soci birrai, ma io non ho il tempo di andare a comprarlo dal Contadino Farle Ingals.\nSe mi porti un\'unità di Luppolo, ti offrirò una birra in cambio.";
D.q[5694] = "";
D.q[4340] = "Il mercante di vino dell\'angolo è sparito. Temo un rapimento, ma potrebbe trattarsi di qualcos\'altro. Ti puoi informare dal taverniere de la Bagrutta? Il mercante aveva l\'abitudine d\'andare da lui.";
D.q[2260] = "La mappa e la geoposizione ti saranno molto utili per spostarti nel mondo. I luoghi più importanti sono segnalati con diverse icone. Potrai anche annotare una destinazione importante grazie alla bandiera blu. La bussola indicherà quest\'ultimo luogo.";
D.q[2432] = "Il maestro non è alla segheria in questo momento, si trova al mercatino del legno.";
D.q[5720] = "Il tuo Maestro d\'Ordine mi ha detto che ha una missione per te, quindi non restartene lì immobile.";
D.q[2433] = "Il maestro è andato alla miniera. È fuori città, all\'entrata delle miniere che si trovano a Nord-Est di qua.";
D.q[4222] = "Il meccanismo che noi usiamo per aprire questa porta è abbastanza complesso e segreto, non vogliamo ingrassare inutilmente questa creatura con i curiosi in cerca di avventura.\nNon dimenticare mai che questa creatura è estremamente potente e pericolosa, il drago la cui carcassa si trova nella torbiera è probabilmente stato ucciso da lei.";
D.q[2466] = "Parla piuttosto con mio fratello Wylde. Lui ti spiega tutto bene e quando ti parla si capisce tutto ciò che dice!";
D.q[4847] = "Il Miliziano Bast Konliskerz è giudicato colpevole di tradimento, con aggravanti, contro la città di Bonta. È dunque condannato alla prigione perpetua e ad una pena equivalente di lavori forzati.";
D.q[4852] = "Il Miliziano Bast Konliskerz è giudicato innocente dall\'accusa di tradimento contro la città di Bonta. È dunque libero di tornare al suo posto di Miliziano a partire da domani.";
D.q[4228] = "Quest\'isola è qua da tanto tempo, da prima della costruzione dell\'Orologio di Xelor e della formazione dei continenti! Questo mostro è un dio vivente, nessuno può batterlo! Non so neanche se sei abbastanza degno per contemplarlo!";
D.q[4684] = "L\'equipaggiamento tarmato che abbiamo dato ai Miliziani non servirà a molto. In Biblioteca ho trovato un Libro molto interessante su una Lama Maledetta. Ma innanzitutto, quel buono a nulla di Domen mi ha detto che voleva parlarti.";
D.q[1054] = "Ku è ke deve occidere pu tu capo? Certo ki so kié...! Eccu ke te lu segno suno foglio. Tieni!";
D.q[4562] = "Questo oggetto potrebbe aiutarci a sopraffare Brakmar.";
D.q[6218] = "La sola persona che conosco il cui nome comincia con X e che mette i piedi alla torre di Bonta è Xefires, un notaio della città. Non lo conosco più di tanto, l\'ho solo incrociato qualche volta alla taverna della Bagrutta.";
D.q[3641] = "Ah, la principiante mi prende in giro! Ti faccio vedere io! Righerai dritto e sputerai sangue e piangerai proprio come la bambinetta che sei!";
D.q[1288] = "Abbiamo arredato questa prigione ispirandoci a Brakmar. Spero che ti piaccia. Hahaha!";
D.q[1898] = "I sassi che ho trovato sul tappeto provengono senza ombra di dubbio dalla grotta a Nord-Est di Amakna. Andiamoci in due, avremo più fortuna. Vai avanti, io ti raggiungo...";
D.q[1659] = "Il prisma di questa zona non è ancora stato ricostruito, il territorio Dabol è inattaccabile per adesso.";
D.q[3742] = "Il porto di Madrestam è pieno di giovani Pescatori, è un buon luogo di pesca.";
D.q[4269] = "Dobbiamo trovare un modo per contattare questo Xefires, e cercare di corromperlo.";
D.q[4292] = "Allora? Gli hai parlato?";
D.q[5837] = "";
D.q[4343] = "Scomparso!? Non può essere, era uno dei miei migliori clienti!\nDopo essere passato di qua tornava sempre a casa sua, verso Est.";
D.q[4380] = "Allora, hai il gioiello?";
D.q[4363] = "Ho sentito parlare di una banda di banditi che agisce nelle pianure di Cania, non lontano dalla fiera. È possibile che si siano spinti fino a qui...\nVorrei che tu andassi ad investigare un po\' laggiù. Torna quando avrai trovato qualcosa. Ma se non trovi niente di niente, puoi anche tornare!";
D.q[1290] = "Benvenuto nell\'oscurità di questa taverna. Prego, siediti.";
D.q[415] = "La provincia di Amakna è gradevole, ma a volte ti toccherà combattere dei mostri, difenderti dagli aggressori, punirli o sfidare altre persone.";
D.q[3699] = "Dosando saggiamente gli ingredienti, ottengo effetti ben curiosi. Mi chiedo se quello che faccio è legale.";
D.q[3445] = "La ricetta della Filtunga? E perché mai dovrei darti quel libro?";
D.q[5616] = "Le Anime dei Rinnegati alla fine sono rientrate ognuna nel proprio corpo. Potrai interrogarli. Voglio sapere che informazioni hanno svelato ai Brakmariani. La dea Jiva non può tollerare un tale tradimento.";
D.q[6721] = "La sala è situata sotto la Torre di Brakmar. Puoi entrare da un piccolo passaggio tra due scaffali, nella parte Sud-Ovest ai piedi della torre.";
D.q[5731] = "";
D.q[6167] = "Buongiorno, chiedi ad Otomai. Ti darà qualcosa da fare in base alle tue capacità. E forse ti rivelerà anche qualche segreto...";
D.q[4995] = "";
D.q[2655] = "Ti manda il Forgiatore di scudi? Molto bene, prendi il tuo scudo di allenamento, e dimmi quando sei pronto.";
D.q[6350] = "Il Forgiatore si è rifiutato d\'aiutarti e tu l\'hai eliminato? Hai fatto bene. Se non possiamo avere quel Forgiatore, nessun altro lo avrà. Fa molto Brakmariano, non ti sembra?\nAvevo previsto di darti qualcosa da fare con l\'arrivo del Forgiatore nel nostro campo, ma, visto che è morto, è andato tutto a monte. Torna a trovarmi più tardi.";
D.q[2671] = "Le condizioni degli Anutrof che sto curando qui mi preoccupano, la maggior parte vengono dalle miniere di Astrub, vai da Gasdora, è lei che mi manda tutti questi malati. Se vuoi aiutarmi, aiuta lei!";
D.q[4448] = "Lo Stratega è nella biblioteca di Bonta. Stai attento ai Canin Blandi.";
D.q[3716] = "Puoi anche sederti per guarire. Passa da me più tardi, quando sarai abbastanza forte da portare dei secchi d\'acqua.";
D.q[1655] = "Il territorio dei Dabol, hmm, è un luogo che sprizza magia. Le creature che vi risiedono prendono le sembianze di tutto quello che incontrano.\n*sfrega la sua sfera di cristallo*\nAssisto a cambiamenti di allineamento frequenti laggiù, per adesso sono le truppe di Brakmar a controllare la zona.";
D.q[4135] = "Alla fine il viaggio è stato abbastanza corto e tranquillo, sono riuscito ad evitare tutti i pericoli, non ho perso la mano con l\'età.";
D.q[2270] = "I sotterranei non sono sicuri di questi tempi. E i Tofu tornano malati, è molto strano.. Qualcuno dei nostri è andato in perlustrazione per scoprire cosa sta succedendo.";
D.q[3238] = "Il villaggio nel quale ti trovi non è altro che l\'antico villaggio di Amakna.\nI suoi abitanti hanno sempre vissuto tranquillamente fino a quando non arrivarono delle misteriose Draguova che distrussero il villaggio e bruciarono quasi tutte le persone. I sopravvissuti si rifugiarono in quello che oggi chiamiamo il castello di Amakna.";
D.q[757] = "Per mostrare la tua devozione alla milizia dovrai trovare due giovani reclute, dargli questo tagliando e dirgli di venire da me per iscriversi.";
D.q[611] = "Bene, affare fatto, ecco il tuo calzone. Sarà un piacere trattare ancora con te.";
D.q[1510] = "Prima la guerra tra Bonta e Brakmar era una guerra divina, più precisamente una guerra tra i Guardiani dei mesi. La città di Brakmar era stata costruita per onorare Rushu ed assicurare la sua sovranità su Amakna. La guerra giunse ad un punto culminante, poi le due città scomparvero di colpo. Da allora nessun guardiano ha fatto più parlare di sé.";
D.q[4038] = "Il vestito da sposa? Sì, è pronto, manca solo il velo: l\'intendente ha chiesto un velo opaco, che nasconda il futuro marito agli occhi della sposa. Ma non ho la stoffa per farlo... Scommetto che con 10 stoffe di Wabbit, questo vestito sarà la mia creazione più bella!";
D.q[6001] = "";
D.q[5435] = "";
D.q[1098] = "Ne esistono molti tipi, ma per tutti è solo una questione di dosaggio.\nSto preparando per la milizia della polvere di Nocabregor. Ha il vantaggio di costare poco e di essere stabile e non richiede che una piccola quantità di energia per provocare la combustione.\nPer i fuochi d\'artificio, uso una polvere con pochissimo nitrato per evitare i rischi inutili.\nFabbrico anche delle mine, per le quali uso una grande quantità di zolfo.\nVedi... l\'argomento è troppo vasto per parlarne oggi.";
D.q[5777] = "Ci sono tre regole ben precise per giocare: il Pappatutto non deve essere ucciso;\r\n            se una squadra uccide malauguratamente o volontariamente il giocatore che rappresenta il Pappatutto o l\'invocazione di Pappatutto, la sua squadra è eliminata.\nSono permessi quasi tutti i colpi, ma se un giocatore uccide uno dei suoi avversari è automaticamente escluso e dovrà abbandonare la partita! Alcuni posti sono riservati agli allenatori e agli eventuali sostituti;\r\n            possono esserci solo 5 giocatori della stessa squadra nel campo di gioco, ma ovviamente un giocatore può lasciare il posto ad un altro giocatore. \nLe persone fuori dal campo non possono partecipare alla partita!";
D.q[4134] = "Ecco, la nave è ancora malandata, ma possiamo ripartire. Secondo la mappa, non dovremmo essere troppo lontani. Se vuoi, puoi aspettarmi su quest\'isola qualche giorno... tornerò a prenderti.";
D.q[6429] = "Ce n\'erano molti, tra cui Shere Hacanon, se mi ricordo bene. Quando lavora sta all\'entrata Sud della città, non farai fatica a trovarlo.";
D.q[827] = "C\'è un lupo arrabbiato che bazzica attorno alla città di Brakmar, dagli una bella lezione, e speriamo che non torni...";
D.q[2817] = "Tieni, torna subito a fare la tua offerta, prima che le sfere spariscano.";
D.q[2355] = "Ecco, ho firmato questo foglietto... Ora è ufficiale: sei un Alchimista. Torna da Nibé Lulla se hai delle domande.";
D.q[1262] = "Ecco, adesso vai dal tuo maestro.";
D.q[2019] = "Ecco! La CLESSIDRA DI XELOR è pronta! È il mio supporto preferito per la divinazione... Molto bene, diamo un\'occhiata... *Chronokwartz si concentra sulla caduta dell\'Epyss, poi qualche cosa la fulmina e lascia cadere la clessidra che si spezza.* Diavolo! Cos\'è questa visione! Lasciami riprendere fiato... oh, misericordia, abbiamo un problema!";
D.q[4541] = "Questi maledetti Brakmariani vedranno come sappiamo difenderci... e attaccare! Parla al comandante per dare l\'assalto.";
D.q[1146] = "Oh! I mantelli terribili... Spero che i miei uomini non si dimentichino di metterli su una pelliccia gialla. Vai, adesso puoi andartene via preoccupato #1... uahahaha!";
D.q[2350] = "Ci sono dei mostri enormi laggiù... E in più, si tratta di specie sconosciute da mio nonno, e che metterebbero fifa persino ad uno Yop! Per non parlare di tutte quelle vecchie leggende...";
D.q[4332] = "Hanno mandato TE? Immaginavo che ci fosse qualcosa di losco. Benissimo, qual è questo scambio interessantissimo di cui si parlava nella lettera?";
D.q[5377] = "Alla fine mi hanno beccato. Ma prima sono riuscito a ottenere delle informazioni importanti. È terribile per Brakmar! Un capo centauro, Tolevaj credo, ha ottenuto un artefatto molto potente, talmente potente che potrebbe essere usato da un potrettore di Brakmar.";
D.q[3703] = "Attaccano tutto ciò che profana la Natura. Quest\'olmo è l\'ultimo di Incarnam. Nessuno può tagliare quest\'albero senza provocare l\'ira di Sadida. La sua collera potrebbe distruggere tutta Incarnam. Per questo respingo i Taglialegna con la magia.";
D.q[6088] = "";
D.q[2851] = "Ti credi valoroso? Vai a Pandala e fai quello che devi!";
D.q[3692] = "Questo ponte è solido, puoi passare.";
D.q[1539] = "Questo cervello è marcio, è da buttare nella spazzatura, non sei stato abbastanza rapido...";
D.q[2629] = "Bene, questa promessa non era niente di serio. Se mi dai 5000 kama possiamo trattare.";
D.q[1645] = "Questa fiera è veramente un successo, la gente si diverte, si incontra, i bambini ridono. È un luogo magico!";
D.q[3416] = "Si dice che questo dongione esistesse ancor prima dell\'inizio della costruzione delle mura di Amakna.\nÈ una specie di tempio nel quale si pratica un culto parecchio oscuro.\nQuesto luogo è infestato da ratti relativamente pericolosi... Ma che sono inoffensivi se confrontati con il loro maestro: Sfinter!";
D.q[3065] = "Ci divertiremo da pazzi! Ho pensato ad una cosina per chiudere la serata in bellezza. Potresti procurarmi un anello di fidanzamento?";
D.q[2499] = "Una specialità locale. Ce ne sono moltissime sull\'isola di Pandala: la Pandaneken, la Panderbrau, la Pandaburg... imparerai a scoprirle tutte... (occhiolino malizioso).";
D.q[2237] = "Ah sì, il dolce che avevo ordinato per Oz... ahimé, non mi serve più a niente, si è appena abbuffato di pane...";
D.q[3597] = "Esatto, insegno le basi a tutti gli operai. Ci sono molte cose da fare in questa fattoria. Dimmi, cosa ti interessa in particolare?";
D.q[4142] = "Perfetto, andrò subito a curare i Corallai. Cercherò di trattenermi per non bere questa deliziosa pozione prima di arrivare.";
D.q[2539] = "Non è una leggenda! La dea ha detto al Grandapan che quando i Dofus saranno riuniti, l\'eletto sarà benedetto dagli dei!";
D.q[2055] = "Che strano metallo... non ci sarà mica della magia Xelor qua dentro? Chi sa! L\'ho trasmutato, adesso è un metallo nobile e puro. Vai dal Forgiatore da parte mia. Forgerà la tua spada, che sarà leggera e farà vibrare l\'aria!";
