D.q[2435] = "Deve essere a caccia nella foresta.";
D.q[3002] = "Non hai trovato neanche una piuma? Sai che sono attaccate agli uccelli? E che gli uccelli sono animali che volano, e nei quali si può leggere l\'avvenire se si è capaci? Insomma, in poche parole, trovi un Pìu viola, e ce ne sono un sacco nei dintorni, lo attacchi e gli prendi una piuma viola. Se non ci riesci, ricominci da capo e vedrai che prima o poi ce la farai! Alla fine del tuo combattimento, visualizzi quello che hai vinto. Gli oggetti sono sistemati nel tuo inventario...";
D.q[4258] = "Allora, hai trovato quello che ti ho chiesto?";
D.q[6291] = "Hai deciso di restituirmi il gioiello o preferisci finire in salsicciotti?";
D.q[5344] = "Allora, hai tutto quello che ti serve?";
D.q[4890] = "Allora, hai ottenuto quello che ti ho chiesto ?";
D.q[2443] = "Devi sapere una cosa però: se per sbaglio dovessi urtarne una, potrebbe arrabbiarsi... Oh, per carità, niente di grave, forse avrebbe solo voglia di saziarsi delle tue viscere! O può darsi che ti sbriciolerebbe le ossa... chissà... Allora direi che ti conviene ascoltarmi...";
D.q[6432] = "Ci sto riflettendo, ma non mi ricordo nient\'altro. Ah, sì, hanno parlato di raggiungere un accampamento ad Ovest di non so più dove, a lavoro terminato.";
D.q[4278] = "Ah, sei tu quello che ha bisogno d\'informazioni su Xefires. Posso esserti utile, ma prima di tutto ho bisogno che tu mi faccia un favore. Non ti preoccupare, non è niente di che.";
D.q[2928] = "Che il vortice sacro ti circondi, che la sua velocità ti porti via e ti conceda la destrezza divina!";
D.q[6727] = "Allora sei tu a decimare i miei uomini? Daremo un taglio al tuo lavoro da cagnolino Bontariano.";
D.q[2934] = "Che la forza del fiore sacro metta radici nel tuo cuore e che la sua linfa scorra nelle tue vene!";
D.q[1564] = "Non dire assolutamente a mia moglie che sono qui!";
D.q[3513] = "Allora, adesso passiamo ai prodotti freschi: il cuore di Bworkselana, un cervello di Vampiro, un occhio di Kanigrù e del fango di Boo. Non dimenticare di usare lo scalpello.";
D.q[3664] = "Allora parlane con Xelorat Masket, perché io non ci ho mai capito niente di sta roba!";
D.q[6125] = "Mi porti le anime che ti ho chiesto?";
D.q[6124] = "Mi porti le anime che ti ho chiesto?";
