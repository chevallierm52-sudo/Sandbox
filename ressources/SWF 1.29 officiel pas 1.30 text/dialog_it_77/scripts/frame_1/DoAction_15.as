D.q[2909] = "Ah la vecchia megera, bravo!";
D.q[922] = "Niente male, vedo che hai strappato un capello a quel grosso porcello... quel Tarke!... Cosa potrò mai fare di lui. Non sa fare altro che darsi delle arie. Se si fa battere dal primo vagabondo venuto, mi domando proprio come possa lottare contro i soldati di Brakmar...";
D.q[2936] = "Il Dark Vlad tornerà dal regno dei morti tra circa #1 minuti!";
D.q[2939] = "Dai la chiave ed entra.";
D.q[6400] = "Esiste una ricetta per fare il pane Bwork? Ignoravo che i Bwork sapessero fare il pane. Suppongo che il gusto segua il nome.";
D.q[296] = "Posso proporti solo Farina Bianca. Edrige la usa come fondotinta, ma in realtà è molto buona per il pane. Una Farina Bianca in cambio di una Gelatina Menta, mi sembra onesto, no?";
D.q[2959] = "Ecco, adesso sei libero...";
D.q[2712] = "Più cose sapremo su di loro, meglio sarà!";
D.q[2975] = "(canticchia) Nel porto di Madrestam, i marinai cantano...";
D.q[2970] = "Sì, ti ascolto.";
D.q[299] = "Ti ho chiesto quattro Peli di Cinghiale e due Zanne. Cosa??? Pensi che sia un abuso di potere da parte mia? Hmm, sì in effetti lo è.";
D.q[3796] = "Oltre ad essere la creatura più bella di Incarnam, sono anche la più potente. Me lo dico tutti i giorni davanti al mio distributore di grazie.";
D.q[3582] = "Non bianco, albino! Altri Goblin chiamare pidocchio bianco o globulo. Me avere vergogna, eppure me buono. Loro gettare pietre a me.";
D.q[1088] = "Ancora niente per adesso. Questa sera parlerò di te alla riunione delle tre teste.\nTi do un giorno di riposo. Vai a farti un bel giro delle taverne, te lo sei meritato.";
D.q[1076] = "Niente da segnalare signore!";
D.q[6546] = "Per il momento, niente da segnalare. Non mi stupisce visto che abbiamo appena passato l\'avamposto.";
D.q[6741] = "Niente da segnalare per il momento.";
D.q[6494] = "Niente da segnalare, sbagliavi a preoccuparti alla fine. Cosa? Oh, no... Salviamoci!";
D.q[6609] = "Wow, non sei per niente simpatico... Se ti dico quello che vuoi sapere, poi mi lascerai dormire? Allora, apri le tue grandi orecchie, perché non lo ripeterò, è troppo faticoso.\nSadida in persona ha nascosto il Libro Magico in una priggg...*ronffff* eh, cosa? Ah, sì, è vero. Dicevo che il Libro Magico si trova in una prigione vegetale concepita da Sadida stesso, spacca di brutto il nostro dio.\nDov\'è l\'ingresso? Oh, tranquillo, non agitarti troppo, resta tranquillo. Prendi un infuso di Dizbi, calmerà il tuo stress. L\'ingresso si trova nella Foresta degli Alberagni Oscuri, eh, sì, proprio così. Sembri improvvisamente meno contento, non stai bene?";
D.q[4030] = "La formula non è completa? Ma se ho detto tutto quello che sapevo...";
D.q[3025] = "L\'anima di Menalt non trova pace! Il suo sdegno disturba il sonno dei morti... Sepolto dopo la battaglia dell\'Aurora Purpurea, è consumato dalla collera: infatti gli hanno rubato la testa e vuole recuperarla a tutti i costi! D\'altronde se noi centauri siamo diventati percettori, è soprattutto per ritrovare la testa di Menalt... e personalmente vorrei tanto trovarla prima di lui... Credimi, se riuscisse ad alzare un\'armata di morti viventi, sarebbero guai!";
D.q[2436] = "La segheria si trova ai margini del bosco.";
D.q[2172] = "Hmmmhmmmhmmmm... *fischietta*";
D.q[3056] = "Ho un po\' famuccia.";
D.q[6272] = "Ora capisco meglio perché questi imbecilli non sono ancora tornati. Vuoi vendicarti, no?";
D.q[3248] = "Oggi, tutto è finito, le Draguova si sono abituate alla luce naturale e popolano le rovine di quest\'isola. Gli altri Draghi vivono ancora nel santuario e pare che si nutrano degli avventurieri che vi si addentrano...\nSe vuoi andare ti posso aiutare, io sono più o meno... il guardiano del luogo...";
D.q[6315] = "Buuurp! Ops, mi dispiace. Credo proprio di aver bevuto troppo. Metti qui le birre, le berrò dopo. Tieni le chiavi... *plof * Ehm, beh, tieni il boccale, prendi tu le chiavi che sono dentro.";
D.q[3063] = "Potrò dire di aver partecipato alla ricostruzione del castello di Allister.";
D.q[2385] = "Sei sicuro di voler intraprendere la carriera di Forgiatore di Martelli?";
D.q[952] = "Le banche si trovano a Ovest della città.\nPuoi depositarci i tuoi soldi stando tranquillo, i dispositivi di sicurezza sono a prova di tutto!";
D.q[3069] = "Non vedo l\'ora che arrivi stasera per mangiare del pesce in buona compagnia.";
D.q[3788] = "Vedi che alla fine non era così pericoloso. Per complimentarmi del tuo coraggio e della tua curiosità, ti do questo. Sono sicuro che ti servirà. Ma adesso sei debole, corri da Grobid e comprami una buona birra. In cambio, ti renderò tutta l\'energia che hai perso.";
D.q[5240] = "Waaaa... zaaaa...";
D.q[3368] = "Lo spirito del guerriero non ti appartiene per niente.";
D.q[3075] = "Allora, hai trovato la bestia?";
D.q[308] = "Ciao! Mi presento: sono Lara Soft. Sono un\'archeologa in pensione. Mi sono accorta che il commercio di pelli e la fabbricazione di mantelli in pelle sono molto redditizi. Tutte le grandi signore di Amakna indossano abiti in pelle, e così sono diventata la fornitrice ufficiale dei mantelli di tutte le grandi serate mondane di Amakna, e la mia merce si vende alla grande!";
D.q[3080] = "Avrei proprio voglia di sorseggiare un po\' di latte di maiale mentre getto qualche pezzo di contrabbandiere agli squali...";
D.q[5206] = "Adesso che possiedi la statuetta, puoi andare a liberare Iliyzaelle dalla prigione. Ma devi scoprire dove si trova.\nVai subito al castello di Amakna per cominciare le ricerche, Iliyzaelle è stato catturata proprio là.";
D.q[3088] = "*Canticchia* ...topi morti un cesto pien e di cobra il gran velen... e per completare il tutto di un\'arancia metti il succo...";
D.q[3090] = "Questa pozione mi interessa. Potrebbe essere molto utile per i miei affari. Ecco i kama. Sento che venderò i miei stivali a decine e che saranno lustrati con bava reale!";
D.q[3095] = "Eieeh!";
D.q[4796] = "Adesso che lo dici, effettivamente mi sembra di aver intravisto un tipo che seguiva il miliziano. Si trattava di un Etram, ma la cosa più strana è che puzzava di pesce.";
D.q[3797] = "Allora, adesso che riesci a lanciare uno o due incantesimi, vieni a sfidarmi?";
D.q[1944] = "Carino quest\'albergo, peccato che la birra non sia buona come la fubuk! Vieni, avvicinati... pare che il padrone allunghi la birra con l\'acqua, ma ci pensi! Pagherei bene per averne la conferma.";
D.q[311] = "Ciao, sono Franky e sono al tuo servizio. Sono trovatrice di pozioni geniali. Invece di cercare come tutti, io trovo. Sono io la pioniera della pozione Ghetto Raid. La conosci sicuramente visti i suoi incredibili poteri.";
D.q[3113] = "Devo sorvegliare i prigionieri e la prigione. Puoi portare questi sacchi di patate a Mifach O\' Bel? Si trova alla prigione del Porto di Madrestam. Bisogna farlo mangiare prima che muoia di fame, e prima che si metta a cercare una galleria per scappare...";
D.q[849] = "Ok, visto che sei qui, trovami qualcuno che sappia fabbricare un veleno magico. Deve pure esistere una persona in questa città che abbia delle buone conoscenze in merito!";
D.q[3811] = "Queste sono le mie condizioni, non ti rimane che trovare tutto questo ad Incarnam.";
D.q[5255] = "Faremo una rappresaglia per quello che è successo a Bonta. Ora non possiamo colpire, ma possiamo cominciare a controllare i territori per rendere le cose più facili.";
D.q[314] = "La mia ultima trovata... è una pozione ancora più potente della Ghetto Raid! Un giorno la mia genialità sarà riconosciuta da tutti, ne sono sicura!";
D.q[1429] = "Non c\'è nessun potenziale sospetto nel tuo rapporto d\'inchiesta, dovresti continuare gli interrogatori...";
D.q[1860] = "Eccoti pronto per l\'inverno! Anche se... le tue orecchie... Ah, bisogna fare qualcosa! Ci vorrebbe qualcosa che mettesse in risalto i tuoi occhi e allo stesso tempo ammorbidisse i lineamenti del tuo viso. Lascia fare a me, SO quello che ci vuole!";
D.q[6343] = "Questa è già una domanda più intelligente. Quell\'incompetente di Ollatem Ossa lavora per Bonta, ma te l\'ho già detto. Forse altri Forgiatori a volte ricevono degli ordini per la città, dovresti informarti al villaggio di Amakna.";
D.q[6763] = "Ce l\'abbiamo fatta. È normale, gli Dei sono con noi.";
D.q[3358] = "Ecco, buona tosatura!";
D.q[339] = "Rischia di piovere, e ho paura che il grano si rovini. Vai a falciare 100 unità di Grano e ti darò una delle mie Falci migliori in cambio.";
D.q[1945] = "Ora che hai la birretta, puoi darne una ad ogni Pappatutto. Ma stai attento a non farli ingelosire! Torna da me quando avrai finito... Il tuo aiuto sarà sempre gradito.";
D.q[32] = "Un\'altra giornata pesante... Spero che Farle ce la faccia con la sua mietitura. Se cerchi lavoro vai subito da lui!";
D.q[2308] = "Bene, ora che hai una spada tutta tua, impugnala e vai ad uccidere due Arakni! Voglio vedere di cosa sei capace. Se te ne mostrerai degno, ti affiderò una missione più importante.";
D.q[2360] = "Ascolta bene Wilde, è mio fratello. Spiega benissimo, e quando parla si capisce tutto ciò che dice! Già da piccolo, mi spiegava tanta roba complicatissima e io la capivo... E ora mi ha detto: manco per sogno che andiamo finchè sto ratto è vicino! Allora, torna in fretta e furia!";
D.q[4286] = "Ah! I nostri sforzi hanno dato dei frutti. La taverna del Pandawa Ubriaco, eh? Ora potremo contattarlo.\nTieni, prendi queste birre per rinfrescarti la gola.";
D.q[3180] = "Eccellente domanda! Se fossi in te, farei ancora un giro in questa biblioteca, forse finirai per incontrarlo.";
D.q[1394] = "Abbiamo appena preso un Bontariano in fuga, ahaha! Deve aver pensato di avercela fatta vedendo la Gola di Sidimote. Peccato per lui che noi fossimo laggiù, ahaha!\nHuh? Lo cercavi? Beh, uno dei miei deve portarlo tra poco nella sala interrogatori della prigione.";
D.q[1960] = "Grazie mille. Vado subito a cucinarlo. Sai, la nostra famiglia è famosa per il suo sanguinaccio di pappatutto! Abbiamo una maniera speciale di metterli all\'ingrasso, che dà un gusto particolare alla carne... Mi dirai se ti piace!";
D.q[4091] = "Adesso bisognerebbe andare a prendere il vestito della sposa a Bonta. Puoi occupartene tu?";
D.q[1084] = "Ah, questo sì che è interessante! Conosco qualcuno che si beccherà un bel po\' di frustate stasera, e mica per godere questa volta! Bene!";
D.q[4037] = "Adesso bisognerebbe andare a prendere il vestito della sposa a Bonta. Puoi occupartene tu?";
D.q[1097] = "Ecco qui, torna da me quando ne avrai ancora bisogno.";
D.q[3207] = "Allora, ti sei già perso? Hahaha, lo sapevo, quando ti ho visto arrivare, sapevo che non saresti stato capace di trovare il cammino in questo dedalo.\nFortunatamente, posso aiutarti a tornare nella sala delle pietre se vuoi.";
D.q[759] = "Bene #1, un piccolo test di conoscenza sull\'arte della strategia, per vedere se meriti la mia stima.\nSe fallisci tornerai a pelare patate, haha!";
D.q[2253] = "Grazie per i limoni ma... per il sanguinaccio di pappatutto ci vogliono le cosce di... pappatutto. Mi sembra logico, no? Dai! Sbrigati! Ho fame...";
D.q[5561] = "Quello che mi racconti è gravissimo. Corri all\'atelier degli Alchimisti e spiega la situazione a Merlisello. Preghiamo Silvosse che non sia troppo tardi.";
D.q[326] = "Nessuno è entrato, la mia missione continua.\nMa chi sei tu? Non sei Hannibul... Lasciami stare, sono in missione speciale. \nAh, anche se non c\'entra niente... ho uno stock di pergamene da barattare.";
D.q[2394] = "Molto bene, ma prima, devi farmi un piccolo favore. Il Pescivendolo ha delle esche per me, ne ho bisogno rapidamente. Ecco cosa ti propongo: portamele in meno di 5 minuti e ti insegnerò le basi del mestiere.";
D.q[201] = "Va bene, ti porterò da Wiss Catz. Ma non dargli nessun trifoglio: è a dieta.";
D.q[850] = "Senti, dovresti andare sui bastioni Est. Dei Bontariani stanno per lanciare un attacco massiccio e cominciamo ad avere sempre meno Chafer. È tempo di tirare fuori le armi!";
D.q[3270] = "Quale mestiere vuoi imparare?";
D.q[371] = "Va bene. Allora portami 70 Aculei di Prespic e 70 Chele di Granchio. Mi servono per forgiare solidi scudi ornati di aculei. Resistenti, terrificanti, e molto cari. Cosa posso chiedere di più?\nAh sì, la tua ricompensa... se mi porti tutto ciò che ti ho chiesto ti darò una Pergamena di Forza.";
D.q[3275] = "Bravo, hai appena battuto l\'Alberagno Ancestrale... ma si era appena svegliato. E adesso sono sicuro che te ne vanterai subito per tutta Amakna... Apparentemente sei stato risparmiato dalla maledizione della foresta degli Alberagni. Non dovrò sopportarti a lungo!";
D.q[3228] = "Come? Vuoi continuare questa discussione? Ti ho già concesso abbastanza tempo! E ti ho detto tutto quello che sapevo sui Porcos!";
D.q[2282] = "Cerca... e troverai! I templi sono raggruppati nella provincia di Amakna, quelli della tua classe ti informeranno.";
D.q[6258] = "Certo che lo conosco. Insomma, non personalmente, ma faccio affari con lui, capisci? Caccio dragacchini e li rivendo alla milizia di Bonta quando me li ordina ed è il Captain Starky che gestisce questo commercio, quindi si può dire che lo conosca in modo indiretto.";
D.q[603] = "Sì, ho già volato, e più volte... Ero un uccello e planavo nel cielo di Amakna... Che bei sogni, mi hanno anche ispirato parecchi quadri.";
D.q[2994] = "Certo che lo sapevo... Controlla che le tue parole siano espresse a destra della stella, altrimenti nessuno ti ascolterà! E non sozzare di parole impure l\'Aria del Mondo. Insomma, resta sempre educato! Non come Herdegriz... Quel vecchio erudito dall\'insulto facile. Mi odia lo sai... penso che nella sua vita precedente fosse un Pappatutto. Sicuro, perché ogni volta che leggo l\'avvenire nelle loro budella, diventa rosso di rabbia...";
D.q[3267] = "Sì, certo... Se dovessi vedere mio figlio, digli che la mamma lo cerca!";
D.q[2164] = "Offrire i propri servigi.";
D.q[3341] = "Ciao! Benvenuto sul server di test.\n\nCosa posso fare per te?";
D.q[3339] = "Ho bisogno di qualche pezzo di Koalak. Sei pronto?";
D.q[631] = "Ah ho capito, molto bene. Non ti offenderò con un test di qualifica. Fare l\'Alchimista è soprattutto una questione di passione, e attraversando Amakna in lungo e largo per diventarlo, hai dimostrato la tua determinazione. Ecco il tuo certificato di Alchimista. Ancora un consiglio per cominciare bene: ricordati che certi fiori crescono dappertutto mentre altri hanno esigenze particolari. Prendi nota dei luoghi di raccolta migliori. Buona continuazione e buona fortuna! A presto collega!";
D.q[547] = "Oh cibo servizievole! Tu portare me 4 carapaci di diversi colori, e me preparare pasto. Per ricompensare carne, tu puoi tornare al villaggio, e aspettare per servire prossimo pasto.";
D.q[1895] = "Uff, ogni giorno è la stessa storia... se non faccio la guardia tutta la notte, mi ritrovo con la metà del gregge massacrato. Ho intravisto più volte una creatura simile ad un Milibuulupo, però molto più pelosa, ma non sono riuscito ad acciuffarla... Non so a chi chiedere per scoprirne di più... Dev\'esserci per forza qualcuno ad Astrub che sia esperto di queste creature, no?";
D.q[2510] = "Oyahoh! Mi sembra proprio di capire che vieni da Astrub, si vede dal tuo occhio tutto gonfio... Mi sono detto: questo è un occhio che ne ha viste di tutti i colori, e che ha visto salvare una pattuglia di Anutrof! Ahahah! Mi riconosci?";
D.q[3683] = "Ah no amico mio, non c\'è niente di strano qui, Incarnam è un posto sicuro. Non si può dire la stessa cosa del Mondo dei Dodici.";
D.q[4031] = "Ma sì, i denti di Wabbit! Che peccato, li ho usati tutti per la pozione precedente... Potresti andare a cercare gli ingredienti, per favore?";
D.q[310] = "Oh sì! Se tu potessi portarmi dei peli di topo... te li scambierei con il mio stock di cuoio di pappatutto. Mi resta quello della scorsa stagione e non so proprio cosa farmene.";
D.q[3871] = "Ah, vedo che hai ottenuto qualche informazione in più su quei Ladrurbi! Dimmi un po\' quello che ti ha detto l\'Etram... una zona pericolosa circondata d\'acqua...? Hum, dovresti cercare vicino al cimitero di Amakna.";
D.q[337] = "Ho bisogno di una mano per terminare la mietitura.";
D.q[3381] = "Al lavoro bello, se non finisci quello che ti ho chiesto, il maestro non sarà contento.";
D.q[3873] = "Mannaggia, dov\'è questo rifugio!? e in più sono in ritardo per il mio pisolino... Cosa! Conosci il ministro Yse Vewybad? Allora puoi aiutarmi! Ti va di cercare questo rifugio?";
D.q[2127] = "Un dolce, per me?";
D.q[1586] = "Ah! Ti manda il maestro Kwelsh. Sbrigati, mi sto giocando la vita per pagare questo debito!\nAllora come previsto, carta contro forbici?";
D.q[4944] = "";
D.q[3533] = "Torna da me quando avrai più tempo. Se hai aiutato un goblin, di sicuro aiuterai volentieri anche un bwork mago.";
D.q[5488] = "Oh! Specie di cafone!\nImpara a rivolgerti diversamente ad una signora!";
D.q[2337] = "Una rosa oscura, hai detto! Che notizia eccitante! La mutazione dei fiori sta ancora evolvendo per arrivare a specie sempre più potenti!\nIn base alle tue informazioni, mi è venuto in mente un piccolo esperimento che vorrei tu facessi per me.\nVorrei che tu utilizzassi questi semi di rosa oscura nei campi di Astrub. Secondo i miei calcoli, se li pianti sotto una di quelle rocce laggiù, avremo una bella sorpresina! Haha!";
D.q[830] = "Ho nominato 5 dei miei migliori agenti per un raid speciale su Bonta... Sai perché, vero? Comunque sia, ciascuno di loro ha bisogno di un mantello Brakmariano, per ricoprire il tabi e firmare le loro malefatte. Portameli. Loro non hanno il tempo di andare a fare shopping con la durissima preparazione psicologica alla quale li sottopongo.";
D.q[1336] = "Oh, siamo invitati da Danathor, per ricevere una medaglia d\'onore! Ma, ora che ci penso, senza un mantello Bontariano non potremo mai assistere ad una tale cerimonia...";
D.q[4105] = "La prima pozione permette di dimenticare completamente le tue caratteristiche, che torneranno ad essere esattamente quelle che avevi quando sei arrivato nel Mondo dei Dodici. Tutto quello che hai imparato grazie alle pergamene andrà perduto. Grazie a questa pozione potrai cambiare completamente il tuo stile di combattimento, cambiando i tuoi elementi preferiti.";
D.q[3981] = "Ah, dei tofu? Chiedi a Shika, ne sa più di me.";
D.q[3948] = "Oh, un Wabbit! Che tu sia il benvenuto tra le nostre mura, nobile pwincipe!";
D.q[559] = "Per finire, ti invito a visitare la parte Ovest dell\'isola. Ti aspetta una giungla da favola che ti rapirà con la sua magnifica flora e la strana fauna. Con un pizzico di fortuna potrai incontrare gli abitanti dell\'isola, scoprire il loro ricchissimo folklore e gustare i piatti tipici che ti proporranno. Se ti resta il tempo, corri nel Sud dell\'isola dove potrai avere il grandissimo privilegio di incontrare il Capo dell\'isola di Moon.";
D.q[1237] = "Ciao. Ti prego di scusarmi per i grandi movimenti pericolosi che faccio. Sai, è il mio allenamento quotidiano.";
D.q[3932] = "Ah, un esperto! Sai cosa mi hanno chiesto ultimamente? Prevedo che te lo dirò se mi porterai 10 fili di seta...";
D.q[597] = "Oh, ma come lo sai? Sì, ho già volato. Sono saltato dal tetto di casa mia e ho planato per almeno 5 metri. La cosa più difficile è stata costruire le ali di legno... Me le hanno fabbricate mio zio Taglialegna e il suo amico Sarto. Credo che abbiano utilizzato 4 tavole di Frassino e 10 Fili di Lino...";
D.q[1339] = "Ah ciao Lyeno, sei dimagrito, eh? L\'ultima volta che ti ho visto, eri grosso e rigido come un tronco...";
D.q[3505] = "Solo, sono disperatamente solo in mezzo a bruti e Cacciatori di bruti.";
D.q[377] = "Oh, niente di molto complicato. Un po\' di pasta per frittelle farcita di funghi. È deliziosa, e tutti sono più buoni dopo averne mangiato. Dimmi, non potresti portarmi un centinaio di quei deliziosi funghi? In cambio ti darò una Piccola Pergamena di Saggezza. Io non ne ho più bisogno da quando mangio queste frittelle.";
D.q[4012] = "Oh, una livrea! Grazie! Servirò il tuo principe, nobile signore.";
D.q[2259] = "Grazie, sapevo che avrei potuto contare su di te... Aspetta, stavo dimenticando. Prendi questo pane: ti guarirà dalle ferite...";
D.q[1507] = "Ah, non potrai fare grandi cose, sarebbe meglio che tu andassi a cercare un arco alla buona dal Forgiatore. A meno che tu non voglia limitarti a fare solo il tifo.";
D.q[5607] = "Oh, ma è oro puro. Grazie mille.\nQuindi volevi incontrare un membro della famiglia Terra? Non sei fortunato. Il mio vecchio amico Terra Cogita è stato catturato dai Bwork molti anni fa e nel frattempo se ne sono di sicuro serviti come aperitivo. Mi dispiace, non credo che tu possa trovare qualcosa d\'utile laggiù.";
D.q[3516] = "Hum hum, come dire, vediamo, hum, hum, direi una cocozza (senza patatine fritte). Ce n\'è sempre una che si rosola sulle spiagge del Mar di Asse.";
D.q[586] = "Ah, tu grande Kannibul importante. Bella maschera! Tu potere passare!";
D.q[3826] = "Oh, troverai sicuramente un sacco di cose di valore, ma se dovessimo incontrarci di nuovo ti darò la ricompensa per essere sopravvissuto al peggio di questa cloaca. Ma solo una volta...";
D.q[3192] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nella nona sala, o nella decima, o nella tredicesima o forse nella quattordicesima, non ricordo più.";
D.q[288] = "Oh! Una visita! Non sto sognando, vero?! Yuppi! Ciao! Mi presento: mi chiamo Ale Uan. Vivo qui da più di dieci anni, e tu sei la prima persona che vedo da allora. Ho avuto questo terreno per un pezzo di pane, e capisco solo ora quel sorrisino sarcastico del venditore. Se vuoi proprio saperla tutta, io l\'ho messo in vendita da 9 anni, 10 mesi e 17 giorni.";
D.q[1927] = "Grazie mille. Le prove potranno svolgersi senza troppi rischi adesso, ed è soprattutto grazie a te. Io stessa e tutti gli apprendisti te ne siamo riconoscenti. Prendi, per ricompensarti ti do un anello creato durante le prove precedenti. Non è ancora attivo, tocca a te fare emergere i suoi poteri magici!";
D.q[2300] = "Ohhh... sapevo che gli Aniripsa erano permalosi, ma insomma... Grazie comunque per averci provato.";
D.q[3200] = "Sei sicuro di voler entrare in questa labirintica biblioteca? Hai un invito di Messer Cuervoc o una chiave della sua biblioteca? Spero che sia disposto a riceverti, non gli piace essere disturbato durante le sue letture.";
D.q[2668] = "Sto soffrendo, il mio ultimo combattimento mi è quasi costato la vita. Non avresti una mela per tirarmi un po\' su?";
D.q[2135] = "Grazie mille, aspetta ancora un secondino per favore... Ecco, PER-FET-TO, ti piacerà un sacco, sono un geeeenio, non ci sooono altreee parooole.";
D.q[3951] = "Ah, no... è che non ti aspettavamo così presto...";
D.q[6239] = "D\'accordo, d\'accordo, ho capito, sto zitto. Voi Brakmariani siete proprio strani. In certi momenti mi ricordi mio zio Jack che è finito disossato da un Canin Blando.";
D.q[6240] = "D\'accordo, ho capito, non ti faccio più domande.\n...\nNon avresti un kama? Dai, giusto un kama, per te un kama non è niente.";
D.q[836] = "Bene #1, ti farò passare un piccolo test sull\'arte dell\'impostura, per vedere se meriti veramente di essere mio discepolo.";
D.q[2205] = "Te l\'ho detto! Lei mi aveva predetto il tuo arrivo qui. Ora, come ogni bravo iniziato, dovrai creare il tuo primo legame con lei. Per farlo, la natura accetta di sacrificare per te un po\' dei suoi beni, ma in cambio dovrai proteggerla. Vai dal Taglialegna, ha sicuramente quello che ci vuole per fare un bastone: un ramo di legno di Arash. Ti ho indicato il cammino. Non ti resta che seguire la bussola. Dopo torna da me.";
D.q[3561] = "Capo non parlare con mezza cartuccia!";
D.q[5661] = "Visto che insisti ti darò una missione. Ma, attenzione, è confidenziale, non devi parlarne a nessuno.\nDei Rinnegati Bontariani ci hanno rivelato l\'esistenza di due Statuette offerte a Sumens da Maimane. Sono il simbolo dei mali e dei beni dell\'umanità e possiedono grandi poteri, quindi avrai già capito che dobbiamo metterci le mani sopra prima di questi stupidi Bontariani. \nAndrai a trovare Setag, il maestro della classe Anutrof, e gli tirerai le parole di bocca. Pensa a portargli il necessario per ottenere la sua collaborazione.";
D.q[2159] = "Fatto, ho finito l\'analisi del sangue... Vai da Saketsu, ti spiegherà tutto...";
D.q[357] = "Ciao! Mi chiamo Lee Ebig. Sono un vecchio Contadino, e ho un problemino di vecchiaia: perdo i denti. Non posso più masticare niente e mangio solo zuppa. Mi piace particolarmente la zuppa di ghiande. Portami gli ingredienti di cui ho bisogno, e in cambio ti darò delle pergamene di agilità. Io non le uso più ormai a causa della mia artrosi.";
D.q[4461] = "Bene. Un alleato di Bonta in meno, sarà la nostra carta vincente.\nNon hai niente da fare? Meglio, allora torna a Bonta e trova il segreto dell\'addomesticamento dei Canin Blandi. Se non sai dove cercare, perché non cominciare dalla biblioteca?";
D.q[5556] = "D\'accordo, OK, voglio aiutarti.\nIn effetti esiste un incantesimo di Transgenesi, ma per prepararlo ho bisogno di tempo, di ingredienti e soprattutto di non essere disturbato ogni trenta secondi.\nAllora, mi servono 40 Semi di Panzucca, 20 Semi di Papavero, 20 Polveri di Perlinpanpan, 10 Germogli di Furbazza e 2 Liquidi vampireschi...";
D.q[3573] = "Un guerriero valoroso, ecco cosa mi serve. Bisogna liberare la regione dalle creature che la infestano. L\'avrei fatto di persona ma ho un sacco di cose da fare. Sai, delle cose insomma... e poi altre ancora, un sacco...";
D.q[4264] = "D\'accordo, calma, abbiamo capito la lezione. Se vuoi saperne di più prendi contatto con Hersa Artiglio Oscuro a Bonta, ma soprattutto evita di dirle che ti abbiamo parlato di lei.";
D.q[3588] = "Ciao, non ho proprio il tempo per discutere, se vuoi qualcosa, vai dal mio capomastro.";
D.q[4034] = "Ah, grazie, ecco gli ingredienti. Aspetta un attimo, faccio scaldare il tutto, rimescolo un po\' di qua, un po\' di là, ed ecco la tua pozione!";
D.q[4434] = "Non è Djaul che dobbiamo seguire! Ci porterebbe alla distruzione di tutto ciò che vive. Non è la vera volontà di Brakmar! Devi credermi!";
D.q[1083] = "Va bene! Va bene! Sì, lo ammetto, trovo questo sistema completamente inadeguato, non potremo mai prendere Bonta con delle leggi così, credetemi.";
D.q[4002] = "Strani? Sloggia prima che mi arrabbi!";
D.q[1371] = "Sì! Sì! Ho capito! Per essere onesto, non l\'ho mica fatto quel rapporto... Se ne vuoi uno, devi muovere il sedere al posto mio. Queste ossa sono troppo importanti e non posso abbandonarle.";
D.q[458] = "Ho catturato questi tre durante la mia escursione nelle montagne a Nord-Est del villaggio. Sono stato fortunato perché hanno molta paura, e non è facile avvicinarli.";
D.q[3599] = "La base di ogni società è un\'agricoltura solida che poggia sul lavoro dei Contadini. Seminare, raccogliere, curare e tanti altri compiti costituiscono le responsabilità del Contadino. Oltre a nutrire molta gente, il Contadino cura la terra, è un mestiere molto nobile. Comincio ad insegnarti come falciare i cereali?";
D.q[3595] = "Mi sgranocchierei volentieri un Gob!";
D.q[6498] = "OK, hai vinto tu, ridammi la tibia.\n...\nIgnoro cosa si intrallazzi precisamente, ma Milon Coricel, l\'Orefice, è implicato in un affare di corruzione. Interrogalo se vuoi saperne di più.";
D.q[1039] = "E va bene... visto che lo desideri così tanto... Devi uccidere velocemente un Pappatutto: hai due minuti. Se ci riuscirai ti nominerò Cacciatore.";
D.q[3361] = "Ok, allora portami i sei Dofus... Insomma, i sei Dofus che dovresti trovare, e vedremo cosa si può fare.";
D.q[1165] = "Bene, finalmente ce l\'hai questo maledetto pezzo di carta. Posso dormire tranquilla ora?";
D.q[2162] = "Bravo, sei riuscito a riempire la tua brocca! Ora smamma!";
D.q[1157] = "Prima di tutto... se incontri uno sconosciuto che ti dice di essere un guardiano di Tainela, proprio come me, e che ti chiede il codice per entrare a casa tua, cosa gli rispondi?";
D.q[2138] = "Bene, hai avvertito tutti... Ma tu cosa aspetti? Torna da Joe Pierlivet per fare rapporto!";
D.q[2043] = "Niente elsa, niente spada. Vai da Oli Venders il Taglialegna.";
D.q[2795] = "Così è venuto il tempo per te di andare là dove il tempo si è fermato per \"colei di cui non bisogna dire il nome\"...";
D.q[2361] = "Ehilà, ti ho detto che non è un mestiere facile e vuoi diventare Cacciatore lo stesso? Per poter maneggiare le armi del Cacciatore ci vuole una certa destrezza, provamela e ti nominerò Cacciatore.";
D.q[3633] = "Molto bene, sbriga il tuo compito e ti sarai guadagnato la paga.";
D.q[5133] = "Bene, questi tre discepoli sembrano essere promettenti. \nSoprattutto quello grosso, laggiù.\nNon mi serve altro che un nome per il mio nuovo ordine. Siccome sono abbastanza soddisfatto del tuo lavoro, nonostante gli errori, ti concederò la possibilità di propormi un nome.";
D.q[3754] = "Lasciami dare un\'occhiata in questo mucchio.";
D.q[3108] = "Durante la sua ultima visita al porto di Madrestam, il re Allister ha detto che persino le sirene invidiano la mia bellezza.";
D.q[2646] = "Penso che dovrò preparare presto un nuovo viaggio iniziatico.";
D.q[3250] = "Dopo essere entrato nel Santuario delle Draguova, potrai constatare con i tuoi occhi la follia che animava un tempo questi discepoli di Osamodas! L\'interno del Santuario è ad immagine e somiglianza degli occupanti, grandioso, terrificante, misterioso e mortale...\nPrima che tu parta alla ricerca di quei frammenti di guscio, devo avvertirti di una cosa: nel santuario esiste una porta magica che conduce direttamente alla camera creata per la riproduzione dei Draghi...";
D.q[3713] = "Un giorno mi alzerò col piede giusto, e partirò all\'avventura.";
D.q[3145] = "Il tuo momento arriverà. Skunk, il nostro mentore, ti punirà e le tue chiappe diventeranno rosse... come... come... come quelle di un Pìu rosso!";
D.q[6346] = "Allora, lontano dalla mia vista!";
D.q[382] = "Ciao, sono il grande Bolzano Vecchiamacchia, penso che tu abbia sentito parlare di me. Fabbrico un sacco di cose inutili e strane con pezzi di animali e piante. Attualmente sto lavorando ad un grande progetto, ma mi manca la materia prima per dare libero sfogo alla mia creatività.";
D.q[6245] = "Un attimo, l\'ho messa in una cassaforte e non trovo più il pezzo di carta su cui ho appuntato la combinazione per aprirla.";
D.q[2867] = "Non sperare di poter andare più lontano. I Pandikaze hanno sabotato il ponte che portava alla penisola.";
D.q[2672] = "OoOoMm Pandawa OoOoMm - (prega)";
D.q[4862] = "Uno dei peggiori mascalzoni di Astrub, Oturb Odnommi, è stato appena catturato. Adesso è detenuto alla prigione di Astrub. Voglio che lo liberi, potrebbe diventare una buona recluta.";
D.q[2910] = "OoOoMm Pandawa OoOoMm - (prega)";
D.q[2811] = "Risposta giusta, adesso ammettiamo che tu abbia per amico un Pandawa che studia il Pandawushu di Terra e che tu voglia regalargli uno scudo, quale sarebbe il più adatto per lui: lo Scudo d\'Asse, il Ftalmo, il Quadrante di Fuoco o lo Scudo Alberagno?";
D.q[3296] = "È vero, non ci credevo neanche più. Ma finalmente adesso abbiamo un edificio dedicato al sapere, alla cultura, all\'intelligenza, alla memoria, alla commemorazione della grandezza di Bonta.";
D.q[2694] = "Oyahoh! Gli amici dei miei amici sono miei amici! E siccome i Pandawa sono tutti miei amici, sei per forza mio amico.";
D.q[396] = "Ciao, mi chiamo Ozen e sono un saggio. Sono un grande specialista del rilassamento attraverso le piante. Ora sono alla ricerca di diversi ingredienti per la preparazione del calmante per eccellenza.";
D.q[2426] = "Ci sono diversi tipi di Intagliatori, uno per ogni tipo di arma intagliata: bastoni, bacchette, archi. Questo mestiere richiede molto legno e qualche altro materiale. \nCome in tutti i mestieri di artigianato ci vogliono un po\' di soldi e di conoscenze per evolvere costantemente. Ma tutti sanno che le migliori armi in legno del mondo sono intagliate dagli Intagliatori esperti.";
D.q[395] = "Siccome devo fare un gran formato che sarà poi ridotto con un processo magico, mi servono 80 Zampe di Arakne.";
D.q[399] = "Cerco di mettere a punto una nuova pozione che voglio chiamare il Gentil Nettare. Mi servono: 50 Pelli di Larva Blu, 40 Pelli di Larva Arancione, 40 Pelli di Larva Verde.";
D.q[2587] = "oOom Pandawa oOm - Shh! Le parole della dea non tarderanno ad affluire nei miei timpani sacri!";
D.q[482] = "Non ho nessuna richiesta di assassinio in questo momento. Va da qualcun\'altro.";
D.q[1105] = "Aaaaah, carne fressssssssssca! Non aver paura, non parlo di te, sei troppo magro per valere qualcosa sul mercato. Dovresti mangiare di più. Ma perché non compri un po\' di buona carne?";
D.q[4023] = "Fammi riflettere in pace!";
D.q[3888] = "Ossssììì... sssei ossstinato... bene... Ssseguimi, ssshhh.";
D.q[1723] = "I discepoli di Osamodas sanno utilizzare tutte le armi, ma eccellono nella padronanza dei martelli e dei bastoni.";
D.q[1747] = "Di solito gli Osamodas sono personaggi intelligenti o molto resistenti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro vitalità o la loro intelligenza.";
D.q[2859] = "Per uscire da qui puoi scegliere se pagare 1000 kama di cauzione o aspettare 2 minuti.\nLa prigione è troppo piccola per trattenere all\'infinito dei miserabili come te...";
D.q[2236] = "Grazie per la lana... Ma cosa vuoi che me ne faccia senz\'arco?";
D.q[2295] = "Delle ghiande avvelenate... no, sono sicuramente troppo furbi per cadere in questa trappola... Forse con un altra bambola... maledetti scoiattoli... *grmbl*";
D.q[1101] = "Guarda, siccome mi stai simpatico, ti regalo questa polvere da sparo.";
D.q[411] = "Cosa posso fare per aiutarti?";
D.q[4649] = "Allora? Spero che tu sia arrivato in tempo.";
D.q[5476] = "Ugah è una divinità minore con una testa da fungo. È un dettaglio importantissimo, credimi. Si racconta che fosse venerata dai Porcos. Ma anche molti avventurieri fanno offerte a questo dio minore,per una ragione che conoscono solo loro. Diversi altari sono sparsi un po\' in tutto il continente, per facilitare il culto di Ugah. Per quanto mi riguarda, mi accontento di incitare gli avventurieri di passaggio ad andare a farsi sculacciare un po\' da Ugah, è sempre divertente da guardare.";
D.q[420] = "Se ti piace combattere, puoi farlo con altre persone proponendogli una sfida.\nLe sfide sono concesse anche all\'interno del villaggio, le consideriamo come un divertimento, o un mezzo per allenarsi prima di andare a caccia di creature...";
D.q[2013] = "Sapevo che ti sarebbe piaciuto. Dai, diamo uno sguardo all\'avvenire, e per farlo... Come? Una truffa!?... Sappi, mio giovane amico, che gli Xelor non imbrogliano mai! Danno solo prova ogni tanto di anticipazione, un segno di intelligenza! Vabbé, ti stavo dicendo che per farlo mi serve qualche componente: due fiale di cristallo di pallido Anthir che potrai ottenere da Nibé Lulla l\'Alchimista, dei semi d\'Epyss che troverai nel magazzino delle derrate, e del legno dall\'atelier di Oli Venders, di semplice fattura, senza fioriture! Il legno determina la portata, e io non voglio guardare troppo lontano nel futuro.";
D.q[6237] = "Attento, ora attraverso. Fatto questo, scortami fino da Rigal Mano Uncinata al tempio Etram e ti darò il documento su Xefires. Sì, in effetti non te l\'avevo detto prima, ma non ho l\'informazione qui con me, eheh... Tra l\'altro se succede qualcosa nel frattempo, ci si ritrova laggiù.\nE adesso tieni bene la corda.";
D.q[2461] = "Treffiori? Sì, è uno dei nostri migliori clienti! È sovente laggiù, sulla costa di Asse...";
D.q[3977] = "Il nostlo popolo litlovelà la sua antica glolia!";
D.q[3116] = "Attento, non fare troppo il furbacchione, o ti ritroverai a pelare patate all\'ombra e a mangiare zuppa di vermi fredda.";
D.q[2028] = "In guaaarrrdia! Non siamo qua per scherzare! Qui, si marcia  e non si discute! Dai, seriamente... Visto che la gloria non cresce sugli alberi, i nostri amici Anutrof si sono fatti in quattro per portarcela su un vassoio d\'argento.";
D.q[4294] = "Se rifiuta, si può sempre ricorrere alle minacce. O peggio. Ho degli aguzzini che sono disoccupati in questo momento.";
D.q[3330] = "Attenzione, il Dio Sadida è permaloso in questo momento. Non vuole che si colgano fiori e ha incaricato dei protettori di sorvegliare questi preziosi vegetali.";
D.q[4298] = "A che punto sei con Sabina?";
D.q[1392] = "Attenzione, stai arrivando alla Gola di Sidimote, una strozzatura del terreno, passaggio quasi unico tra Bonta e Brakmar, dove gli scontri sono all\'ordine del giorno. Ad ogni modo, in questo momento regna la calma.";
D.q[3101] = "Te ne sei sicuramente reso conto, tutti vogliono vendermi qualcosa o guardarmi il sedere. E invece, quello che voglio io è solo una piccola casa dove poter vivere con un essere a me caro, lontano da tutti questi fastidi...";
D.q[4347] = "Scusa? Ho trovato qualcosa di strano qui!";
D.q[6706] = "Hai voluto dare una legnata al capo dei ladri, ma sei tu ad averne prese? Se il loro furto fosse riuscito, ti avrei punito immediatamente, ma visto che non ha funzionato, ti dò la possibilità di rifarti.";
D.q[4542] = "Le nostre frecce trafiggeranno i loro ranghi nel minor tempo possibile. Parla al comandante per dare l\'assalto.";
D.q[4388] = "So bene che approvvigionare dei miliziani non ha niente di glorioso, ma bisogna pure che qualcuno la faccia.";
D.q[3331] = "Bene, in poche parole mi servono dei pezzi di Kalipto e di Koalak.";
D.q[4095] = "La ricetta della nostra birra? Se ci tieni... ma tanto solo i Bwork sanno prepararla correttamente.";
D.q[3430] = "I nostri bambini sono scomparsi! Ero al lavoro e quando sono rientrato a casa, ho trovato Dama El, mia moglie, disperata dal dolore. Sono già due giorni e io sono preoccupatissimo. Aiutaci, ti prego.";
D.q[3882] = "Allora non m\'interessa!";
D.q[1580] = "Siccome un fiume di lava sta separando la riva dai bastioni, vai dalla nipote di Mech Riorraw e dille di chiedere a suo zio di fabbricarti un\'arma a lunga gittata.";
D.q[4367] = "I nostri convogli di mercanti verso Astrub sono presi in imboscate questi ultimi tempi. Il tuo compito è quello di scortare il convoglio successivo, proteggerlo e, se possibile, recuperare indizi su questi banditi. Forse sono gli stessi di prima.";
D.q[3053] = "Il buon re Allister ha bisogno di mangiare bistecche di Dragacchino al sangue. Potresti trovarmene qualcuna?";
D.q[3591] = "Un Pescatore? Che novità. Siamo in tanti quindi non perdere troppo tempo se vuoi prendere abbastanza pesce da sfamarci tutti.";
D.q[3308] = "Il buon re Allister mi ha incaricato di mettere su il più bel maneggio di tutta la regione. Vedo dalle tue gambe arcuate che hai già cavalcato una creatura. Potresti portarmi dei Dragacchini? Il re non è ingrato e saprà ricompensarti.";
D.q[4281] = "Hai trovato l\'Etram nella foresta degli Alberagni? Se non è così, torna subito laggiù!";
D.q[1562] = "Non dire assolutamente ai miei genitori che sono qui!";
D.q[3072] = "Lontano dalla mia vista delinquente! Zotico! Cafone!";
D.q[4665] = "Lontano da me furfante! Filibustiere delle torbiere nauseabonde! Imbalsamatore di scarafoglie! Sbollentatore di Pìu rosa!\nChe Rushu ti faccia vomitare la Filtunga dalle orecchie!";
D.q[1068] = "Unatra vota aki? Voi pallare ankora?";
D.q[2218] = "Laggiù, c\'è Amakna. Ti dirò, cominciano a sentirsi un sacco di storie sugli avvenimenti che accadono da quelle parti. Vedo che il tuo sguardo è pieno di curiosità, eh?";
D.q[473] = "Ecco, da owa potwai coltivawe cawote.";
D.q[2601] = "I Pandawa sono soprattutto abili con le asce e i bastoni. Trova un Forgiatore di Asce o un Intagliatore di Bastoni per equipaggiarti, e sarai un Pandawa realizzato!";
D.q[3923] = "Ah, il re dà in sposa sua nipote... ? Hum... Potremmo cercare di farci amico il principe... Sai se c\'è già un pretendente?";
D.q[1132] = "Non fa niente, da come sei vestito si vede che non capisci niente.";
D.q[5219] = "";
D.q[3073] = "Kartier Tremen mi propone ancora una bella bevuta?\nEccellente, affogheremo di nuovo le sue pene e i suoi pesci nella birra!";
D.q[3071] = "Kartier Tremen? Come sempre è stato rifiutato da Monabella. Ne ho abbastanza di mangiare questo pesciaccio! Assolutamente no! Con un po\' di fortuna troverò un altro pretendente più galante, più carnivoro e più ricco... eheheh.";
D.q[2482] = "Mi serve l\'Ambra, ma cosa fanno gli altri? Non deve essere poi così difficile trovarla!";
D.q[3743] = "Per prendere pesci più grossi, un Pescatore deve cambiare materiale.";
D.q[1109] = "Mi hanno sempre detto che portavo sfortuna a coloro che incrociavano il mio cammino. Credi proprio di poter scappare a questo infelice destino?";
D.q[5150] = "Sono stato obbligato a chiudere l\'albergo per la durata del Processo. Non ti rendi conto di quanti kama in meno significhi questa chiusura.";
D.q[2617] = "Lui essere riuscito a scappare a Poochan, ma io essere riuscita a strappare etichetta vestito e scoperto nome: Lanma Metoasa. Poochan conoscere padre Metoasa, che vivere vicino Dojo principale. Se Lanma fuggire, io obbligare lui a venire. Tu andare da padre, e convincere lui dare suo figlio a Poochan, lui rispettare antiche tradizioni. Tu prendere questo piatto, tu capire quando essere laggiù.";
D.q[537] = "Ciao, caro futuro cliente. Sembri stanco di tutti questi combattimenti e di tutto questo duro lavoro che offre poche gratificazioni. Ingabbiato dalla routine, il tuo appetito e il tuo umore ne risentono? Non esitare più, l\'agenzia Turista può darti una mano. Ti proponiamo felicità e relax a prezzi stracciati. Oggi un\'offerta eccezionale può essere tua: uno sconto del 50% sulle tariffe standard. Sì, hai capito bene! Approfittane!";
D.q[6316] = "Cosa, cerchi la rissa? Ti avviso, se mi aggredisci, grido e tutta la guarnigione verrà a darti dei calci nel sedere.";
D.q[2677] = "Perfetto! Allora vai da uno dei nostri favolosi venditori ambulanti! Avrà sicuramente qualcosa per accontentare la dea...";
D.q[6661] = "I principali inconvenienti quando si appartiene all\'Allineamento di una Città sono legati alle aggressioni. In effetti, se sei allineato e un Miliziano dell\'Allineamento avverso ti aggredisce, quando ti trovi in un\'area Neutra non puoi avvalerti della protezione delle Guardie. Un altro inconveniente, e non uno dei meno importanti, è che le Guardie delle Città avverse possono attaccarti se ti vedono quando passi troppo vicino a loro. Ciò costituisce un grosso ostacolo per accedere agli atelier e ai mercatini. Insomma, quando sei allineato e vieni sconfitto da un Miliziano o da una Guardia di un Allineamento nemico, rischi di trovarti in prigione. Non puoi neanche utilizzare gli Zaap per accedere alle Aree che appartengono ad un Allineamento nemico. Ti consiglio davvero di rifletterci bene prima di allinearti, non è una misura da prendere alla leggera. Nel frattempo, vai a farti le prime armi e torna a trovarmi quando avrai acquisito più esperienza, avrò forse delle dritte per te.";
D.q[3645] = "Dove troverò dei buoni operai adesso?";
D.q[3209] = "Perfetto, vedo che hai trovato le reliquie necessarie ad entrare nella sala del Minotoror! Dai, seguimi, cercherò di portarti in quella famosa sala ancora in vita, ma ti devo chiedere queste due reliquie e la chiave del Minotoror che ti ho dato, serviranno per la mia pensione.";
D.q[2893] = "Auch! Il mio zaino è così pesante! Torno da Pandala, ho fatto un mucchio di affaroni! STRAFICO!";
D.q[2891] = "Auch! Il mio zaino è così pesante! Torno da Pandala, ho fatto un mucchio di affaroni! STRAFICO!";
D.q[1514] = "Tutti vivevano tranquilli nelle proprie casette,a riscoprire la storia dei guardiani e degli dei, quando improvvisamente i guerrieri di Bonta presero d\'assalto Brakmar... fu un massacro. Dopo essere riusciti bene o male a respingere i Bontariani, abbiamo posto all\'unanimità la clausola di vendetta che tutti i culti venerano. E fu l\'inizio della guerra.";
D.q[2985] = "Perfetto, cerca di ricordartene. Queste indicazioni sono preziose.";
D.q[490] = "Non ti hanno mai detto che non bisogna rubare ad un ladro? Non hai abbastanza soldi, non posso fare niente per te.";
D.q[1956] = "Dovremmo entrare in contatto diretto con loro, o sapere almeno dove trovarli. Bisogna fermare questi furti. È difficile... hmmm!";
D.q[313] = "È inutile nasconderselo, la pozione Ghetto Raid è un fallimento continuo. Devo riuscirci... ma prima di andare in fallimento.";
D.q[3570] = "Quando mi sveglio, a volte, resto addormentato, e per un bel po! Parlo, cammino, lavoro, ma sono addormentato! Così mi riposo. È un talento, solo io so fare una cosa simile, sono troppo forte, sono Jiccì, sono Auér, anche quando sono addormentato, vedi?";
D.q[3129] = "Perfetto, hai i 50 fiori e foglie di Kalipto che mi servono per fare la tisana!";
D.q[3084] = "Come ben sai, lavoro nel contrabbando. Il re Allister ha vietato la vendita di afrodisiaci e di pozioni leccapiedi. Secondo me ha paura di esentare un commerciante dalle tasse, o di morire d\'infarto in mezzo alle belle cortigiane.";
D.q[566] = "Hum tu avvicinare, me non vedere te bene!";
D.q[1639] = "Per perfezionare le conoscenze, ti suggerisco di andare nel tempio della tua classe, il maestro d\'armi che vi si trova ti insegnerà qualche tecnica e avrà sicuramente qualche missione da affidarti.";
D.q[2679] = "Pregare, è buono. Fare delle offerte, è meglio! D\'altronde, la dea si acciglia quando parla del tuo caso. Forse non sei degno di essere uno dei suoi discepoli? Hum... lo so! Perché ti riconosca come uno dei suoi discepoli, devi offrirle una di quelle bevande che la mandano su di giri...";
D.q[679] = "Effettivamente gli Allegati dell\'Enciclopedia Alchemica sono introvabili. E non solo gli originali, ma anche le riedizioni che sarebbero dovute uscire. Certe voci dicono che questi preziosi manoscritti sono stati discretamente rubati, e tutti concordano nel dire che sicuramente sono di una certa utilità per i ladri... ma quale?";
D.q[1040] = "Eccellente, mi hai stupito con quel colpo!";
D.q[5931] = "";
D.q[587] = "Ehi, cosa fare cibo là? Tu aspettare un po\' per cuocere tu! Tu non potere passare, solo Kannibul importante potere!";
D.q[5469] = "Pfff, tu non avere senso di umorismo!";
D.q[4092] = "Perfetto, ci metto un attimo, ecco... così... un ritocchino qui... Che vestito magnifico! Te lo affido.";
D.q[2916] = "Forse sai che abbiamo catturato ed interrogato dei Rinnegati Bontariani. Questi bricconi hanno svelato ai nostri nemici l\'esistenza di due Statuette che simbolizzano i beni e i mali dell\'umanità. Sembra che Maimane abbia offerto queste Statuette a Sumens ed ora Brakmar vuole recuperarle.\nOra sappiamo che queste Statuette sono legate in un modo o in un altro alla famiglia Terra. Setag, il Maestro della classe degli Anutrof, sa di sicuro qualcosa a questo proposito, ecco perché devi andarlo a trovare.";
D.q[1528] = "Ahlàlà, non ho neanche il tempo di divertirmi con questi incapaci.";
D.q[5697] = "Seee, come se mi mettessi a piangere per del rame di una qualità mediocre quanto la tua arma.";
D.q[613] = "Che gli dei di Amakna ti benedicano figliolo! Quale miracolo ti ha condotto in questa modesta dimora celeste?";
D.q[3313] = "Dove posso trovare dei bei Dragacchini per il re Allister?";
D.q[1405] = "Cos\'hai fatto dei semi che ti avevo dato? Bene, se ne vuoi altri, questa volta ti costeranno 1000 kama!";
D.q[6160] = "Registro nel tuo libro tutto ciò che dovrai fare per riuscire a catturare un\'anima di mostro. Andrai su Pandala, spero che ti piaccia viaggiare!";
D.q[3936] = "Pff, non ho mai lavorato tanto! Ho dovuto portare dei sacchi di iuta dalla barca di Lily fino al castello! E in più sto morendo di sete...";
D.q[3461] = "Di quella che racconta che i Bwork possiedono una biblioteca con dentro alambicchi giganti che permettono di fare la birra Bwork. La ricetta è sicuramente da qualche parte.";
D.q[618] = "Mi interrogò sulle circostanze della morte. Gli risposi e gli spiegai che un dettaglio mi aveva colpito durante l\'autopsia: su ognuno dei suoi incisivi c\'era scritto un numero.";
D.q[620] = "Ciao, cosa può fare Uba Tessé, genio Alchimista, per quest\'esserino?";
D.q[2442] = "Le creature che popolano le nostre contrade sono una più affascinante dell\'altra. Per affinare le proprie conoscenze zoologiche e botaniche, non c\'è niente di meglio che esplorare la fauna e la flora locale. Cuore semplice e intenzioni pure bastano ad ammansirle la maggior parte delle volte.";
D.q[2017] = "Del legno classico, neanche intagliato, senza dettagli? È una tristezza per me lo sai! Dai, ti do discretamente un po\' di legno più pregiato, senza fioriture... anzi un pochino, dai... e sì eh, ne va del mio onore!";
D.q[2578] = "Vedo dal tuo sguardo che sei venuto ad aiutarci! (Eh sì, le notizie corrono veloci a Pandala!). Tutti i miei Pandawa sono occupati, e ho bisogno di una persona di fiducia per portare i Bambù dal Forgiatore di Scudi.";
D.q[3710] = "Pìu pìu pìu ?";
D.q[7541] = "Con quali Dobloni desideri fare lo scambio?";
