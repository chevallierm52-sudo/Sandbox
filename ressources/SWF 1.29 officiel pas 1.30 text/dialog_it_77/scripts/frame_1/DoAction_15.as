D.q[2637] = "Poochan? Poochan... Ah, la piccola pandawa! Ma è una ragazza! È vero che a Pandala tutto è possibile... Nakun potrebbe prenderla male...\nMi spiace, non posso, lascio che scelga Nakun, sbrigatela con lei.";
D.q[2615] = "Poochan sentirsi meglio così, anche tu, tu prendere questo, tu bere estratto di fonte maomao e cercare qualcuno che ha paura di te, se tu trovare, tu dire a Poochan.";
D.q[7542] = "Con quali Dobloni desideri fare lo scambio?";
D.q[1918] = "Benvenuto nel mio modesto negozio, vendo solo poche cose qui, ma formo degli apprendisti. Le mie creazioni sono uniche e spesso su ordinazione...";
D.q[6446] = "Osi mentirmi? Sai cosa ti aspetta in caso d\'insubordinazione, il Pappatutto se la godrà...";
D.q[254] = "Affrontarmi in duello è un privilegio che do solo ai membri della mia classe. Contro gli altri... lo faccio solo per uccidere!";
D.q[5534] = "Lodato sia Silvosse! E così il piccolo draguovo ha imparato a volare con le proprie ali. Ti sarò grato in eterno e sono sicuro che il dio Osamodas farà qualcosa per ringraziarti delle tue azioni.\nNon devo più insegnarti niente, è arrivato il momento che tu serva Bonta a modo tuo.";
D.q[702] = "Vedo che sai già utilizzare la meditazione curativa, non ho più niente da insegnarti dunque.\nDovresti essere capace di sbrigartela da solo ormai.";
D.q[1885] = "Tutto il mio stock di metarie e di rune è scomparso! Arrggh! Maledetto ladro! Perché a me? Perché oggi? Come farò? L\'appuntamento di questa sera sarà una catastrofe... non ho più il tempo per andare a cercarne...";
D.q[3425] = "Non hai visto i miei bambini? Sono talmente vivaci...";
D.q[1297] = "COSA! Dovrai passare sul mio corpo piuttosto!";
D.q[5498] = "Lodato sia Silvosse! E così il piccolo draguovo ha imparato a volare con le proprie ali. Ti sarò grato in eterno e sono sicuro che la dea Feca farà qualcosa per ringraziarti delle tue azioni.\nNon devo più insegnarti niente, è arrivato il momento che tu serva Bonta a modo tuo.";
D.q[3300] = "Che libro posso prendere in prestito in biblioteca? Il Tempo dei Draghi? Il Manuale dei Dragacchini?";
D.q[930] = "Sei te che hai rotto tutti i denti di mio fratello? Non provarci con me perché sennò...";
D.q[996] = "Ma come sei entrato qui?";
D.q[5537] = "Lodato sia Silvosse! E così il piccolo draguovo ha imparato a volare con le proprie ali. Ti sarò grato in eterno e sono sicuro che il dio Xelor farà qualcosa per ringraziarti delle tue azioni.\nNon devo più insegnarti niente, è arrivato il momento che tu serva Bonta a modo tuo.";
D.q[3235] = "Non approfittare della mia generosità. Sei già abbastanza ricco così. \nYiiiiihuuuu huuu...";
D.q[1148] = "Ecco, porta questo al tuo maestro, dovrebbe esserne contento.\nDigli anche di guardarsi alle spalle, alcuni dei miei discepoli non lo digeriscono proprio, muahaha!";
D.q[5077] = "Preparati un po\', potrebbe essere pericoloso. Avvertimi quando sarai pronto, ti porterò laggiù.";
D.q[4077] = "Che incantesimo vuoi dimenticare ?";
D.q[3815] = "Sapevo che avresti vinto. Se per disgrazia perdessi questa chiave o se volessi tornare nel dongione del Milimilupo, attacca pure le creature di Incarnam. Alcune hanno ingoiato degli avventurieri, e con un po\' di fortuna potresti trovare una chiave nella loro pancia.";
D.q[3914] = "Conosco la maggior parte delle dame e dei signori della corte. Secondo me nessuno è un pretendente degno di questo nome.";
D.q[4079] = "Che incantesimo vuoi dimenticare ?";
D.q[1369] = "Humm, lasciami lavorare in pace.";
D.q[1569] = "Pfff, prendi il mio atto di proprietà e non tornare più!";
D.q[5965] = "";
D.q[4081] = "Che incantesimo vuoi dimenticare ?";
D.q[1425] = "Sei già di ritorno? Pensavo che Danathor ti desse una missione, ma va bene lo stesso, se hai del tempo libero chiedi al cuoco, sta cercando degli ingredienti per la cena di stasera.";
D.q[1424] = "Il mio anello!";
D.q[1428] = "Hmm, si direbbe che tu abbia trovato il colpevole, aspetterò il rapporto degli altri investigatori e sorveglierò questo verme da vicino!";
D.q[1300] = "Grrr, vattene tu e i tuoi soldi. E di a Oto che a partire da oggi non gli faccio più credito!";
D.q[1511] = "Ne sei sicuro? Rifiutare di parlarmi vuol dire andare contro ad una delle maggiori personalità di Brakmar.";
D.q[3040] = "Uff, mi sento debole! Non ho più molta energia! Questo combattimento avrebbe potuto essermi fatale... e non ho nemmeno una pozione di cura... eheh, fortunatamente, grazie al mio senso dell\'iniziativa, me la sono cavata!";
D.q[4416] = "Davvero? Cavolo, ho paura, guarda come tremo. Mi farai veramente male se rifiuto di collaborare?";
D.q[2689] = "Io sono il miglior fabbricante al mondo di scudi pandawaiani! Ma metti comunque i miei apprendisti alla prova, solo così possiamo imparare tutti meglio e di più. Ricordatelo.";
D.q[2124] = "Sono Luk.";
D.q[2206] = "Veramente? Pazienza, non sai cosa ti perdi!";
D.q[6580] = "Davvero? Mi proponi di venire ad assistere le tue truppe durante le manovre? Con enorme piacere. Fammi uscire da qui e portami dal tuo capo. Secondo la mia valutazione, solo due gruppi ci separano dall\'uscita.\nAh, accidenti, ecco qui proprio i rib, devono averti seguito. Lascio che sia tu ad occuparti di loro, sono troppo stanco per combattere.";
D.q[1409] = "Cheee straaano, non haa nieeente a chee vedeeere con le infoooormazioooni che ci haaanno daato le seeentinelleee. Oosi mentiiire davaaanti ad un triiibuunale Brakmariaaanooo?\nNoon soo coosa farmeeene dei demoooni che non rispeettaano il protooocollo, vatteeeene viaaa!";
D.q[1896] = "Potresti andare a visitare tutti i luoghi sospetti? Dovrai analizzare i sassi, farne una breve descrizione e portarmi i risultati. Penso in particolare a 3 luoghi. Il primo si trova proprio all\'uscita della città, verso Sud. Il secondo si trova sul cammino Nord che conduce verso il margine della foresta. Il terzo porta alle grotte. Li troverai facilmente andando verso Nord e imboccando la destra all\'incrocio delle strade.";
D.q[2897] = "Devo occuparmi del passaggio di grado di numerosi adepti. Se vuoi provare di nuovo, torna da me come minimo tra due ore!";
D.q[5137] = "Carub Lard è in pieno interrogatorio.";
D.q[1820] = "Ho promesso ai miei figli di portar loro delle piccole spade di Legnuccio, ma apparentemente qualcuno a svuotato la riserva del tempio prima di me.\nSe me ne porti una, ti permetterò di affrontare un Dabol...";
D.q[6058] = "";
D.q[6223] = "Ho lavorato per Xefires per tre anni prima di riprendere la gioielleria di mia madre. All\'epoca Xefires esordiva in affari e non è stato sempre facile né per lui né per me.";
D.q[5418] = "Ruth Banke? Non vedo quel mascalzone da settimane. Se lo vedi digli di rimborsarmi in fretta, la mia pazienza sta per finire.";
D.q[6113] = "";
D.q[1748] = "I Sàcridi sono personaggi molto resistenti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro vitalità.";
D.q[2326] = "Humff? gnark rhhhhr:";
D.q[2477] = "Tutti questi bambù che si screpolano... che tristezza... Senza ambra, non si può fare niente!";
D.q[2328] = "Snifff! *trattiene un gran singhiozzo*";
D.q[5702] = "Sacrilegio! Hai il cervello di un Trooll con il quoziente intellettivo di un blop! Bisogna essere proprio pazzi per distruggere questi gioielli. E tutto solo per una misera informazione. Sei proprio il male incarnato.";
D.q[1749] = "I Sadida sono personaggi molto forti o intelligenti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro forza o la loro intelligenza.";
D.q[2079] = "Questa poi! Noi aiutiamo gli Anutrof nelle loro ricerche e, alla fine, raccogliamo solo animali malati. E che malattie! Del tipo che noi non possiamo curare... Menomale che ci sono gli Aniripsa...";
D.q[5800] = "Salve. Ti avevo chiesto dieci pelli di larva blu, spero tu me le abbia portate.";
D.q[6575] = "Salve, Amayiro ha mandato te per risolvere il nostro grosso problema di manovre?";
D.q[2454] = "Hola! Ecco la bestia! Non deve essere stato piacevole, ma la ricompensa è proporzionale al rischio...";
D.q[2989] = "Sei per caso uscito dal buco di un Bwork? Guardati un po\' intorno, questa è una taverna, il genere di posto dove si beve la birra, sai? Devi solo avvicinarti a quell\'omone grosso laggiù, il taverniere insomma, il genere di tipo che adora vendere birra, sai? (sospira)";
D.q[3548] = "Vedi che alla fine non era così difficile? Continua ad allenarti, solo i migliori conquistano il favore del loro dio.";
D.q[3373] = "So che si tratta di un compito arduo ma il luccichio dell\'artefatto di Metag dovrebbe darti un po\' di incoraggiamento.";
D.q[2363] = "Pattugliare, pattugliare... dicono! Però quelli che ci stavano lasciando le penne siamo noi!";
D.q[6317] = "Metti qui questa cassa, me ne occupo subito e preparo un rapporto per il tuo capo.";
D.q[5505] = "";
D.q[3082] = "Vuole di più? È proprio un\'Anutrof. Eccoti ancora 1000 kama. Torna in fretta per la tua ricompensa.";
D.q[3653] = "Abita appena a Nord di qua.";
D.q[3854] = "Vuoi ascoltare il seguito della mia storia?";
D.q[6599] = "Visto la sua situazione critica, sarà difficile salvarla. Spero che non sia già troppo tardi.\n...\nEcco, ho fatto del mio meglio, ma il risultato non è ottimo. Mi chiedo che ci ha fatto con questa Bambola, era in una situazione tale che si potrebbe pensare sia stata passata tra molte generazioni di Bworkette. In futuro farai meglio ad occupartene come si deve, se no rischi che il dio Sadida si offenda per il tuo atteggiamento negligente verso le sue creazioni.";
D.q[1525] = "Ho detto una decina, altrimenti non serve a niente. Vai!";
D.q[6783] = "Shh, più piano. Sei in biblioteca, non alla Taverna della Bagrutta.\nMi sembra che ci siano solo quattro soluzioni possibili. La prima è riunire i 6 Dofus Primordiali. Con una tale forza tra le mani, non farai fatica a liberare il Bwork Mago dal suo triste destino.\nLa seconda consiste nell\'invocare un demone del 666° cerchio e a fare un patto con lui, ma sfortunatamente non conosco le modalità di un tale patto, dovrai trovarle tu stesso.\nLa terza soluzione consiste nel prosciugare il Mare di Asse in meno di tre giorni, sfida quasi impossibile, ovviamente.\nQuanto all\'ultima soluzione, è un rituale che consiste nel fare il giro delle Pianure di Cania in ottanta giorni, su una mano e con gli occhi bendati. Ovviamente non puoi cambiare mano una volta cominciato il giro.\nAl massimo puoi sempre tentare di risolvere il problema costruendoti una Molletta da Bucato, ahah... ehm, scusa, mi sto perdendo.";
D.q[403] = "Scchhh!";
D.q[5567] = "Quindi sei arrivato in tempo per impedire la contaminazione dei campi, sono fiero di te.\nTi innalzo al rango di Spione. Qualcosa mi dice che avrò presto del lavoro per te.\nEcco 1000 kama per ricompensare i tuoi sforzi.\nTra l\'altro, come è andata con Fidji Merlin ?";
D.q[4413] = "Fantastico. Finalmente abbiamo catturato questo furfante e il suo corrispondente Brakmariano. Il tuo aiuto e la tua determinazione sono stati preziosi. Ho chiesto ad un Panettiere di fornirmi il suo pane migliore per festeggiare, prendine un po\'! Quanto ai due prigionieri, subiranno un interrogatorio e voglio fare in modo che le ricchezze di Xefires siano ridistribuite alla popolazione.";
D.q[3155] = "Stai zitto! Sei in una biblioteca! Pezzo d\'ignorante, non ti hanno mai insegnato che in una biblioteca bisogna fare silenzio?!";
D.q[5700] = "Bisognerebbe far rinchiudere tutti i sadici come te.";
D.q[4372] = "Perfetto! Bravo e grazie per questa protezione efficace. La prossima volta che la vedi, Gerl vorrà di sicuro ringraziarti per averle offerto una protezione così efficace... Lascia perdere, ci sono cose più urgenti per il momento. Prendi queste pozioni, cureranno le tue ferite e credo che tu le abbia ben meritate.";
D.q[2999] = "Allora... trovi un pìu viola, ce ne sono un sacco nei paraggi e davanti alla miniera. Lo attacchi piano piano, senza fargli paura... e sicuramente otterrai una piuma viola. Se per caso non la ottieni, ci riprovi. Riuscirai pure a recuperarne una! Alla fine del combattimento, vedrai ciò che hai guadagnato combattendo. Questi oggetti sono automaticamente sistemati nel tuo inventario.";
D.q[2631] = "Quanto sei disposta a spendere per mio figlio, allora?";
D.q[4149] = "Bene, è abbastanza semplice, devo fornire delle farine a base di cereali alle creature che alleviamo su quest\'isola. Diamo loro eccellenti farine per catturarle e studiarle con calma nei nostri laboratori o nei recinti. Ma a furia di essere ben trattate, diventano sempre più esigenti, e le farine che gli diamo adesso non gli piacciono più!";
D.q[4447] = "Visto che sembra che tu stia cadendo dalle nuvole, ecco il tuo bersaglio: è un mercenario arruolato da Bonta per fare delle ricerche strategiche. Si trova nella biblioteca di Bonta. Su, al lavoro.";
D.q[3576] = "Ma sì, ma sì, certo che sarai pagato, non ti preoccupare per questo. Insomma... dipende da quello che farai.";
D.q[4180] = "Non hai ancora finito di cacciare le creature che ti ho chiesto di annientare? Sbrigati se non vuoi che metta definitivamente radici qua.";
D.q[4987] = "E così Danathor vuole lanciare una controffensiva.\n*riflette un istante*\nNon penso che sia il momento opportuno per attaccare, le truppe non sono ancora ben equipaggiate. Se attacchiamo ora, rischiamo di subire gravi perdite.";
D.q[1437] = "I pescis sono una specie assai particolare, sai. Le dimensioni di questi pesci possono variare tantissimo. Questa peculiarità ha attirato moltissimi Pescatori che passavano il loro tempo parlando di decompetizione o qualcosa del genere, non l\'ho mai capito... fatto sta che ho deciso di soprannominare i Pescis, Pescis Decompetizione.";
D.q[1523] = "E così sia...\nPorta questa lettera a Oto Mustam. Poi continua la tua avventura.";
D.q[4669] = "Quindi Drena Nassema parlava di te. Non ti preoccupare, avendo visto che eri in una brutta posizione non ha voluto disturbarti e si è presentato qui da solo. Senza il tuo aiuto sarebbe ancora imprigionato in fondo al Dongione degli Scheletri. Hai fatto un buon lavoro, non mancherò di parlarne ad Amayiro.";
D.q[2007] = "Ho saputo che devo fabbricarti un arco. Allora, mi hai portato l\'arco e la lana?";
