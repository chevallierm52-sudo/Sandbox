D.q[1242] = "Vendiamo tutto e sempre, per accontentare tutti. Prego, non avere fretta.";
D.q[3996] = "Cosa vorresti da me? Che serva un Wabbit? Sono deboli, non sanno maneggiare le armi e pawlano stwanamente!";
