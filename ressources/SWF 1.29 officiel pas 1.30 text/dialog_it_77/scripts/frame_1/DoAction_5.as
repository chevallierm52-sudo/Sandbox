D.q[585] = "Non bene, me bisogno di 4 carapaci diversi. Torna quando avere ciò.";
D.q[6170] = "Non sei stupido come sembra. E se ti chiedessi di unirti ai ranghi dei difensori di Brakmar? Se la cosa ti tenta ti offrirò una bella borsa piena di kama e imparerai qualche trucco da veterano che ti potrà servire in combattimento. \nAllora, che ne dici?";
D.q[6604] = "Spero che non t\'abbia seguito nessuno. Dovrai perdere l\'abitudine di venirmi a trovare appena hai bisogno di un\'informazione, se no gli altri finiranno per avere dei sospetti.\nAllora, vuoi conoscere le ronde delle pattuglie Brakmariane? C\'è un ufficio nascosto nel dormitorio della milizia in cui Oto Mustam conserva molti documenti. Se riesci ad entrarci, troverai quello che cerchi e forse molto di più. Buona fortuna.";
D.q[4245] = "Malsera!";
D.q[6489] = "Ignoro dove siano le riserve di veleno, ma Rekojel lo sa di sicuro. É un malvivente Ecaflip che bazzica spesso nei pressi dell\'atelier dei Tuttofare. Se conti di andarlo a trovare, attento al portafoglio. Quella zona è piuttosto malfamata e a Brakmar vuol dire molto.";
D.q[6531] = "Odio questi banditi, nuociono al commercio e, ancora peggio, al MIO commercio. Questa volta hanno avuto una bella lezione. Grazie per il tuo aiuto così... disinteressato. Fai vedere questa spilla ad Amayiro per esprimergli la mia riconoscenza. Non vale niente, me la restituirà più in là.";
D.q[4909] = "Buuuh... Buuuhhh... ho detto BUH!";
D.q[6251] = "Bel lavoro. La metterò in cella temporaneamente. Nel frattempo, portami un altro Brakmariano per fare la guardia ad uno dei nostri covi vicino al quartiere dei Tuttofare. Preferisco che tu prenda uno che ha già avuto il suo primo permesso. Quando l\'avrai trovato, portamelo.";
D.q[1407] = "La giustizia Brakmariana mi ha sempre fatto ridere con i suoi verdetti crudeli, esagerati e assolutamente sadici.\nOggi, però, mi fa molto meno ridere.";
D.q[5605] = "";
D.q[7357] = "";
D.q[550] = "Ciao caro cliente, benvenuto sulla paradisiaca isola di Moon.\nSono stato inviato dall\'agenzia per accoglierti e presentarti le diverse attività che proponiamo.";
D.q[4621] = "Congratulazioni per la tua vittoria contro i Brakmariani. Quando penso a tutto quel che abbiamo passato per ottenere questo Corno.. Questo ci deve insegnare a non confidare nei pettegolezzi e nelle leggende. Se ti può consolare grazie ai poteri di questo Corno ci saranno meno reclute occupate nella pelatura delle patate. Hai servito bene Bonta e la tua lealtà ai miei occhi ha più valore di quello di un oggetto magico.";
D.q[3616] = "Te trovare Gobrosa.";
D.q[6508] = "ahahahahahhaahahah HAHAHAHAHHARHARHARHHAA!  Rido perchè tu hai appena perso 1000 kama. ahahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!";
D.q[6509] = "ahahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!\nIl vecchio padrone della Taverna del Maokemao ha una sala da gioco che, al contrario di quel che dice lui, è ancora funzionante.\nAhahahahahhaahahah\nHAHAHAHAHHARHARHARHHAA!";
D.q[6255] = "Il Captain Starky è il capo della cavalleria Bontariana. È una testa calda che molte volte ha condotto delle cariche devastanti sulle nostre truppe. Sarebbe stato un eccellente soldato Brakmariano se non avesse scelto di stare dalla parte dei perdenti. Penso che potrei proporgli comunque un posto nella nostra milizia quando Bonta non sarà niente di più di un campo di rovine fumanti.";
D.q[1648] = "Ciao, sei nello stand di baratto dei gettoni. Qui posso scambiare i gettoni che hai duramente conquistato in cambio di uno di questi oggetti.";
D.q[4676] = "I Brakmariani sono i servitori dei demoni, Jiva sia lodata per la protezione che ci concede. Ora, l\'esperienza ha provato molte volte che bisogna diffidare dei demoni, questi esseri vili e perfidi che corrompono tutto quello che toccano. Sfortunatamente, il metallo e l\'astuzia non bastano per sconfiggerli, quindi ho pensato di aumentare la potenza magica dei nostri eserciti e il numero di sortilegi a loro disposizione. Visto che sono un tipo generoso, ho pensato di condividere quest\'idea con te in modo che tu possa approfittare del buon esito di questa missione.";
D.q[1657] = "Il prisma è stato distrutto poco fa, e non è ancora stato riparato.";
D.q[1251] = "I mantelli Brakmariani ? Qualunque Sarto li sa fabbricare: 1 tintura magica oscura, 1 lana di pappaton nero e 1 osso di chafer e il gioco è fatto.";
D.q[5609] = "";
D.q[573] = "Di recente la guida turistica della tua agenzia è atterrata planando sulla spiaggia ahaha. Un pirata apprendista gironzola nel Sud dell\'isola, credo stia cercando un modo per andarsene ahahah.";
D.q[1653] = "Gli abitanti di questo villaggio sono molto ingegnosi, ma non sono riusciti comunque a rendere il loro villaggio sicuro\n*sfrega la sua sfera di cristallo*\nPer adesso sono le truppe di Brakmar a controllare il villaggio, ma forse non per molto tempo ancora..";
D.q[3719] = "Grazie per le ninfette.";
D.q[6701] = "";
D.q[6385] = "C\'è una pawte del suo cowpo che Gawutaw non può waggiungewe. Non pawlo di quello a cui hai pensato tu, ma della sua schiena. Le sue bwaccia sono twoppo cowte e il suo cawapace twoppo gwande pewchè possa gwattawsi da sola, e la telecinesi non le è di nessun aiuto. Ignowo cosa tu voglia da lei, ma con ciò che ti ho detto hai un vantaggio su di lei.";
D.q[569] = "Ahahahah! Allora sei un turista a vita di questa nuova agenzia, ohoh. Ebbene, per il tuo tempo libero, l\'isola offre numerose attrazioni... particolari, ahahah! Ma chiedi piuttosto alla tua guida che ha appena fatto un arrivo esplosivo sulla spiaggia, ahaha! In ogni caso, per visitare l\'isola nei minimi particolari dovrai pagare.";
D.q[6749] = "Gli altri sono arrivati ad Astrub senza incidenti. Nessuna traccia dei banditi, mi sa che abbiamo fatto fiasco.";
D.q[4551] = "Humm.. Molto buono questo piatto è. Della Vertgely aggiunto tu hai ? Un grande cuoco indubbiamente tu sei. Ma anche con questo piatto, ad addomesticarmi tu non riuscirai.";
D.q[6347] = "Visto che insisti ti darò una possibilità per convincermi. A forza di restare sempre in questa grotta non vedo più nessuno. Mi prende la solitudine e, come dire.. a volte ho voglia di un po\' di compagnia, capisci, quindi se tu potessi portarmi, mhh... una Dragochiappa di Pelle viola di Bwork, mi sentirei meno solo. Ah, visto che ci sei, sto provando a realizzare altre macchine e avrei bisogno di Lingue di Granchio perché la loro grana è molto piacevole al tatto e... insomma, mi porterai 10 Lingue di Granchio e pure 10 Lingue Biforcute, visto che ci sei, queste ultime mi permetteranno di testare il mio Robot Frustatore. Certo che il Robot Frustatore non è per un uso personale! Cosa vuoi insinuare esattamente?\nPer il disturbo aggiungo all\'ordine venti Tavole in Legno di Kaliptus, sembra che la loro resina emani un odore afrodisiaco. E poi in ogni modo quello che voglio farci non sono fatti tuoi!";
D.q[4577] = "Pensavo che non sarebbe stato facile, senza dubbio sono voluto andare troppo velocemente. Per fare a gara con Brakmar ho dimenticato le cose essenziali. Visto che non possiamo addomesticarla, dobbiamo prenderci del tempo per riflettere e trovare altre idee.";
D.q[5907] = "";
D.q[1062] = "Ah, è per l\'allenamento. Tieni, prendi questo e muoviti!";
D.q[6180] = "Non aiuto nessuno che abbia macchiato il suo onore. Torna da me quando avrai riscattato il tuo disonore.";
D.q[4547] = "I miliziani sono pronti a difendere la nostra città, ma mi piacerebbe sapere come i Brakmariani contano di attaccare. Prima conosceremo il loro piano d\'attacco e meglio potremo organizzare la difesa e in questo modo minimizzare le nostre perdite.";
D.q[5722] = "";
D.q[4640] = "Non faccio che il mio lavoro, nulla di più. Sono un semplice stagista, sai. Dovevo scegliere fra questo e pulire le latrine alla Fiera del Trool. Non ci ho pensato su molto a lungo.\nI documenti? Li ho ridati a Larry Poller, davanti alla torre di Bonta, il mio superiore se li passerà a prendere più tardi.";
D.q[6825] = "";
D.q[3319] = "Grazie, ecco a te.";
D.q[2538] = "Perché il Grandapan ha un piede a Pandala e un piede nel reame degli dei!";
D.q[4480] = "Il nostro nuovo amico Xefires ci ha fatto pervenire una lettera interessante. Un convoglio di armi destinate agli ufficiali di Bonta in questo preciso momento si dirige verso la città. Bisogna intercettarla ad ogni costo e rubare il carico. Visto che i miei briganti sono già occupati a depredare la casa dei Baine per rubare la legna, recruterai altre persone, Brakmariani o no, per attaccare il convoglio. Secondo la lettera di Xefires, questo convoglio è ben sorvegliato, quindi non lesinare sui mezzi. Dopo aver rubato il bottino, portalo direttamente a Calpestinor, al piano di sopra.";
D.q[5453] = "Quale rango vorresti avere nella Milizia ?";
D.q[6637] = "Ma se ti dico che sono bianchi come la Criniera d\'un abominevole Yiti delle nevi!";
D.q[4334] = "Oh...! Che meraviglia. E potrebbe essere mio se accetto le condizioni di questa lettera? \nMmmh... tradire Bonta per Brakmar... non dovrei... ma... questo gioiello è così bello...\n...\nHo bisogno di un po\' di tempo per rifletterci. Il mio soggiorno a Pandala volge al termine, ma mi resta un affare da concludere, forse potrai occupartene in segno di buona fede. Devo far consegnare questa cassa al Consigliere Boyowa, si trova dal Grandapan. Quando sarà fatto, raggiungimi nella Torre di Bonta, dove hai trovato il pezzo di lettera strappato. Lì ti dirò cosa ho deciso.";
D.q[5906] = "";
D.q[3316] = "Grazie, ecco a te.";
D.q[4499] = "Ti hanno parlato di lui? Senti, non ho proprio voglia di essere immischiato nelle tue storie né di coinvolgere un amico in queste cose. So che Bonta vuole proteggere il mondo dall\'influenza nefasta di Brakmar, ma non sono comunque sicuro di doverti aiutare.";
D.q[655] = "Scusami, avevo capito male le tue intenzioni, accetta questa ricetta in cambio delle mie scuse.\nOblio di Intimidazione: 4 selci insanguinate, 50 selci, 25 spade del potente cavaliere, 40 unità di argento.";
D.q[4579] = "Png(938) et Message(4578)";
D.q[6826] = "";
D.q[4835] = "Png(987) et Message(4834)";
D.q[4876] = "Png(992) et Message(4875)";
D.q[4956] = "Png(997) et Message(4955)";
D.q[5038] = "Png(997) et Message(4972)";
D.q[6314] = "Non ti dirò di no, visto che tra l\'altro ho appena finito la bottiglia. Arrivi proprio a fagiolo. *hic* Quello che mi farebbe davvero piacere sarebbe una birra della Bagrutta, mi ricorderà dei bei momenti. *hic* Anzi, portamene due, no, cinque. Diciamo dieci, dovrebbero bastare.";
D.q[6179] = "Sono spiacente per te, ma ho ricevuto severe istruzioni. Divieto di reclutamento per le milizie di Bonta e Brakmar.\n*sussurra* Posso aggirare le istruzioni nel caso tu volessi unirti all\'allineamento di minoranza, non dimenticarlo.";
D.q[6778] = "Metti la roba di fianco al tavolo, sarà una cosa rapida.\nNon hai attirato l\'attenzione, spero, no? Beh, al massimo troverò un pretesto, non sono le scuse fasulle che mancano a Brakmar.\nTra l\'altro, hai visto mia sorella ultimamente? Non ho sue notizie da molto tempo, ma ho sentito dire che per lei gli affari vanno molto bene. Io non mi lamento, anzi. Anche se non sono sommersa dagli ordini, ho abbastanza clienti e vivo bene.\nEcco fatto! Ho modificato le mangiatoie in modo da nutrire i dragacchini con delle melanzane senza attirare l\'attenzione. Valle a mettere nel recinto pubblico, il risultato sarà esplosivo.";
D.q[6838] = "";
D.q[3460] = "Vorrei che tu mi dicessi se i Bwork abitano sempre nel loro villaggio e se la leggenda è vera.";
D.q[1376] = "Capisco, capisco... Abbi un po\' di pazienza per favore... Ecco.\nAllora, sembra effettivamente che la massa magmatica si muova, ma in modo completamente caotico. \nCi sono poche possibilità che Brakmar rimanga sepolta dalla lava. Mi piacerebbe proprio sapere da cosa sono provocate queste perturbazioni... detto ciò, me ne sto un po\' qui. Tieni il tuo tanto agognato rapporto.";
D.q[1596] = "Cosa buoi umano? Bome osi tu bisturbarmi dubante questa bartita?";
D.q[4041] = "Attenzione, i mostwi witownano!";
D.q[6561] = "Vediamo, cosa potrei chiederti?\nPer cominciare, mi porterai dei piatti cucinati. Non ne posso più di mangiare i resti lasciati dal Buulupo. Voglio del pesce, preferibilmente non troppo cotto e non fritto, 5 Ghiozzi in pezzi di buona qualità andranno benissimo. Voglio anche della birra che assomigli all\'ammoniaca e che abbia un odore di maiale grigliato, come quella che si trova a Brakmar. Portami tutte queste cose in modo che possa riflettere su come fidarmi di te, con la pancia piena rifletto meglio.";
D.q[4632] = "Se ho ben inteso mi stai spiegando che una sola tartaruga sta tenendo testa alla volontà di Brakmar? Comincia a darmi fastidio! Non mobiliterò tutte le truppe della città per quella tartaruga!\nPicchiarla non serve a nulla e avvelenarla non ha dato risultati, bisogna dunque trovare qualcos\'altro, ma cosa?";
D.q[5524] = "Se t\'interessa servire Brakmar, posso trovare un modo per farti dei documenti che attestino la tua affiliazione alla loro milizia. Mi farà risparmiare tempo e non ti costerà nulla. \nPerché lo faccio ? Semplicemente perché Brakmar mi paga profumatamente per ogni nuova recluta arruolata grazie a me. Però ti suggerisco di andare a trovare Snori Nairb ad Astrub prima di cominciare la procedura per raggiungere lo schieramento minoritario: dà una ricompensa a chiunque desideri arruolarsi.";
D.q[4462] = "Hai comprato la sua fedeltà nei nostri confronti? Ottima idea, molto Brakmariana. Farò in modo di rimandarlo a Bonta perché possa sabotare la loro milizia! \n50000 kama? Ecco un rimborso, con un bonus per premiare questa bella trovata. \nNon hai niente da fare? Bene, allora tornerai a Bonta per trovare il segreto dell\'Addomesticamento dei Canin Blandi. Se non sai dove cercare, perché non cominciare dalla biblioteca?";
D.q[3906] = "Allora torna quando ne avrai di più, non posso fare niente senza prove.";
D.q[5819] = "";
D.q[3151] = "Sono disposto ad insegnarti il mestiere di Tuttofare, ma il re Allister mi ha ordinato dei nuovi abbeveratoi per le sue cavalcature e sono pieno di lavoro!\nSe mi porti 20 tavole di legno di Frassino e 15 tavole di legno di Acero, cercherò di trovare il tempo per insegnarti le basi del mestiere.";
D.q[7145] = "Sei riuscito a sbarazzarti di loro, bravo! Secondo il loro ordine di missione dovevano portare i documenti ad una guardia ai piedi della Torre di Brakmar, forse potresti prendere il loro posto e consegnare dei documenti falsi ? Prenderemo così due piccioni con una fava.";
D.q[6551] = "Credi che i nostri miliziani siano stati sconfitti a causa di un equipaggiamento ben inferiore a livello qualitativo rispetto a quello dei Brakmariani? È inammissibile! Non siamo la città più potente del Mondo dei Dodici?\nVado a dire due parole a questo proposito ad Amayiro, puoi andare.";
D.q[5914] = "";
D.q[5729] = "";
D.q[6828] = "";
D.q[6611] = "Onori la tua uniforme e la nostra città. Ecco per te 2000 kama, li hai davvero meritati.\nLe illustrazioni di questo Libro Magico sono di un\'oscenità molto raffinata. Scommetto che contiene dei sortilegi terribili che potremo usare per schiacciare Brakmar una volta per tutte. \nVado a prendere anche la Bambola, potrebbe rivelarsi utile e in ogni modo non ne hai più bisogno. Se avessi ancora bisogno dei tuoi servizi te lo farò sapere. Ora puoi andare.";
D.q[6211] = "Mi hai guardato bene? Mi prendi forse per un pannello segnaletico?\nMa, aspetta... Non ti sembra che ci sia puzza di Brakmariano improvvisamente?";
D.q[4603] = "Il rituale è stato un successo. Ho annotato le informazioni su una pergamena che ho datato e firmato affinchè Amayiro la possa autenticare. Buona fortuna per il seguito della missione, ne avrai bisogno.";
D.q[3428] = "Abbagliati dalla vittoria, non si vedono più i pericoli.";
D.q[5915] = "";
D.q[5916] = "";
D.q[1207] = "Io? Seguirti? Mi spiace, non posso proprio... Tutto ciò è ancora troppo recente...\nMa prendi pure il mio badge, dovrebbe bastarti!";
D.q[1444] = "Ah finalmente! Tutto torna a posto. Non me la sento di ringraziarti, sei stato troppo lento.";
D.q[4595] = "I documenti! Li hai potuti recuperare, ben fatto! Credo che Brakmar sia come noi in cerca del Corno Davola, altrimenti perchè rubarci questi documenti? A qualunque modo abbiamo sicuramente una lunghezza di vantaggio su di loro, dobbiamo approfittarne.";
D.q[605] = "Io? No, ho le vertigini, ma ho già visto altri bambini che l\'hanno fatto.";
D.q[1417] = "Bene, in questo caso devi procurarci del veleno di scorbuto perché la nostra riserva sta diminuendo. Ne troverai un sacco nelle lande di Sidimote.\nQuando ne avrai recuperati 30 pods, portameli.";
D.q[3559] = "Te sbrigarti trovare regalo!";
D.q[5728] = "";
D.q[1122] = "La mia città natale è molto più bella, ma anche questa ha il suo fascino.";
D.q[2057] = "Mannaggia agli Anutrof! Hanno di nuovo scavato a casaccio e risvegliato una bestia malefica... Haaa! Ma se sotto la città vivesse veramente una creatura del genere, l\'avremmo scoperto da tempo ormai... anche se... Cosa ci stanno nascondendo ancora? Torna nei sotterranei, dovremo pur scoprire cosa stanno tramando là sotto!";
D.q[6497] = "Sai fare affari con i Brakmariani, mi stupisce da parte tua. Ignoro cosa si intrallazzi precisamente, ma Milon Coricel, l\'Orefice, è implicato in un affare di corruzione. Interrogalo se vuoi saperne di più.";
D.q[4591] = "Una spia Brakmariana è riuscita ad infiltrarsi nella città e a rubare dei documenti! È riuscita a fuggire, ma i nostri arcieri sono sicuri di averla colpita ad una gamba. Puoi ancora acciuffarla, ha preso la strada per Brakmar.";
D.q[3023] = "In questo caso, non posso fare molto per te. Il tuo spirito non è pronto. Non sei degno, e mi sembra anche che puzzi. Torna dal dio, o da uno dei suoi discepoli. Uno Xelor potrà informarti.";
D.q[3761] = "Maledetti spaventapasseri, non smettono di muoversi. Sanno bene che gli avventurieri principianti vengono ad allenarsi qui, e siccome non possono ferire, cercano di scappare. Non ci vuole un\'alabarda per tenere a bada questi fantocci di paglia, ci vuole un forcone!";
D.q[6418] = "Malgrado la missione hai pensato al tuo capo, bene. Meriti un piccolo premio, quanto a me andrò ad usare questo filtro su Sbab.\nPerchè Sbab ? Non sono affari tuoi, occupati solo di cose che ti riguardano.";
D.q[1048] = "Solo una decina di pods? La milizia usa veramente le pinzette, se vogliono sterminare Brakmar, non possono limitarsi così!\nMa vabbé, visto che sei qui in nome della milizia, ti faccio tutto al 50%, quindi sono 20000 kama...";
D.q[6829] = "";
D.q[4624] = "Non esitare a minacciarlo. I tavernieri si fanno impressionare facilmente.";
D.q[5921] = "";
D.q[4472] = "I Forgiatori di Bonta non sono abbastanza bravi per fare questo tipo d\'equipaggiamento. Ciò significa che Bonta ha assunto un Forgiatore per farsi fabbricare le armi.\nBisogna trovare questo Forgiatore e convincerlo a lavorare per noi.";
D.q[2149] = "Png(495) e Messaggio(2148)";
D.q[1841] = "Una Eriaxis Rigida Acrimoniosa, haha, è proprio un bell\'esemplare. Guarda da te, ascolta bene quell\'orchidea, e sarai di cattivo umore per tutta la giornata!\nOh, non mi sono accorta dell\'ora, devo nutrire la mia pianta Audrey, una Brakmaris Acerba estremamente rara... Potresti aiutarmi ad annaffiarla?";
D.q[2258] = "Al contrario di noi Feca, l\'intelligenza non è il punto forte di questa bestiole! Bene... ci manca un Pappatutto: potresti andare a cercarlo? Dovresti trovarlo vicino ai sotterranei.. Vai da Gasdora, solo lei può averlo visto da queste parti...";
D.q[3726] = "Inginocchiati davanti alla potenza di Yop, il protettore di Amakna. Contempla la sua spada, simbolo della sua forza.";
D.q[7434] = "";
D.q[3945] = "Ah, hai la formula, bene! Potresti procurarmi gli ingredienti adesso?";
D.q[5936] = "";
D.q[6777] = "Una lettera per me? Vediamo cosa vuole da me il tuo maestro.\nCara Fidji Merlin... blablabla... molte dozzine di migliaia di Kama... blablabla... un incentivo per tua sorella... blablabla...\nBenissimo, anche se di solito resto al di fuori del conflitto Bonta - Brakmar, ti darò una mano.\nVammi a prendere 4 Mangiatoie al Ciliegio Selvatico e 40 Melanzane, poi ti darò il resto delle istruzioni.";
D.q[7435] = "";
D.q[1864] = "Sto diventando pazzo! Casa mia era dall\'altra parte della strada... vado a fare una passeggiata a Brakmar, torno... e puf! Addio casetta. Chi avrebbe potuto rubare una casa così? Tu? Sembri un tipo losco, d\'altronde...";
D.q[6383] = "Oh, vedo che hai già abbwacciato la via oscuwa. Hai fatto una buona scelta. Quando Bonta bwucewà, wealizzewai che i tuoi sogni sono a powtata di mano e che più nessuno potwà impediwti di wealizzawli.";
D.q[7961] = "Possiede uno dei più grandi recinti di dragacchini di tutta l\'isola. Si, è vero.\nBeh, che ne pensi del mio Pupazzomostro di neve? Non dire delle stupidate, o lo dirò a Bebert.";
D.q[4477] = "Brakmar? Vieni da... BRAKMAR?? (Impugna un\'arma)\nFuori da qui! So che vuoi ammansirmi per piantarmi meglio una Daga nella schiena subito dopo! Fuori da qui!";
D.q[3032] = "Brakmar e la sua armata di nanerottoli è fuggita ancora una volta di fronte ai valorosi di Bonta. Arruolati con i Bontariani e sarai sempre vincitore!";
D.q[7964] = "Ti indicherò dove si trova ogni Pupazzomostro. Andrai a vederlo e tornerai per dirci quale è il più orribile. E\' così facile che anche uno Yop può riuscirci.";
D.q[3715] = "Sì, cospargendoti di acqua delle fontane, puoi guarire da tutte le ferite. E siccome c\'è molta gente che si cura qui, sono costretta a riempire le vasche senza sosta.";
D.q[7436] = "";
D.q[5504] = "Dei Brakmariani sono arrivati fino a qui! Se credi di potermi fermare, seguace del Male, sarai ben deluso.\nLa tua sconfitta sarà il primo passo verso la mia vendetta.";
D.q[2171] = "Png(475) e Messaggio(1965)";
D.q[6387] = "Dove ho la testa ? Ho dimenticato di rendergliele l\'ultima volta che abbiamo passato la notte insieme... vabbè, questo non ti riguarda. Tieni, ecco le chiavi. Digli che la prossima volta penserò a rendergliele prima che abbia bisogno di mandarmi qualcuno a ricordarmelo, è scontroso qualche volta.";
D.q[3608] = "Allora, hai finito? Immagino di sì se vieni a parlarmi. Bel lavoro, se hai ancora tempo di lavorare per me, non esitare a tornare. Ma ricordati che non fornisco i materiali.";
D.q[551] = "Ma caro cliente, il contratto specificava bene che si trattava di un biglietto di sola andata, il ritorno non fa parte della promozione. Avresti dovuto pagare un supplemento o scegliere un\'altra destinazione.";
D.q[3964] = "Me li porti questi kama, si o no?";
D.q[3246] = "Se... se... sei un po\' duro di comprendonio tu, no? Va bene, cerco di spiegartelo chiaramente: usa una runa di riferimento, impugna il tuo attrezzo da artigiano, e hop! Sei nella li... li... lista. Rimetti a posto il tuo attrezzo, e hop! Non sei più sulla... la... lista. Quando sei sulla li... li... lista tutti possono vederti. Ok, hai capito sta volta?";
D.q[5486] = "*arrossisce*\nVile adulatore.";
D.q[4197] = "Ciao, sono Mulez, la guardiana di questo laboratorio. Prima ci lavoravo come Alchimista, ma poi Otomai ha deciso di abbandonarlo a causa di un esperimento andato male. Ci alleviamo una delle creature più sorprendenti che ci siano, il Tynril.\nQuesta creatura è capace di sdoppiarsi, a seconda del suo umore e della sua voglia. Non è pericolosa, ma è selvaggia e lunatica, per questo ci è molto difficile predire il suo comportamento.";
D.q[3375] = "Mi stupisci, ma non è finita. Ecco la chiave che ti condurrà al prossimo combattimento.";
D.q[3575] = "Sì, mi piace il coraggio, e mi piacciono i guerrieri potenti. Anch\'io, sono molto coraggiosa, non ho paura di queste creature viscide, striscianti, rampicanti, luccicanti e sporche che frequentano i dintorni. Ricompenserò personalmente il tuo... ardore. Mostrami il tuo ardore!";
D.q[4235] = "È in questa gabbia di titanio e di catene rinforzate che viveva la più bella creazione di Otomai, il gioiello dell\'isola, il cui nome ne rifletteva allo stesso tempo la voracità e la forza. Chi avrebbe mai creduto che quel cosino potesse diventare così grosso?";
D.q[7446] = "";
D.q[303] = "Vendicatore...";
D.q[6395] = "Per fare un Grattaschiena, ti serve un Grattaschiena incompleto. Una volta che lo hai ottenuto posizionati davanti alla forgia e lo termineremo insieme.";
D.q[5932] = "";
D.q[5657] = "Ma, cosa mi succede? Non controllo più il mio corpo. \nPerché gesticolo in tutti i sensi come una scema in modo così ridicolo? Cosa succede al mio chignon, perché mi si rizzano i capelli in testa a forma di cresta? Le braccia non mi obbediscono più, passano vicino alla testa senza che lo voglia. No, è orribile, sto ballando la pektonik!\nÈ un incubo, sembro più cretina di una Yop scervellata incrociata ad un Tofu. Non voglio essere lo zimbello di Amakna ed essere trattata come una pek. \n...\nCough cough... quello che cerchi... cough cough... si trova... cough cough... nelle miniere... cough cough... dei Croccaroc...";
D.q[4524] = "Non è così semplice come può sembrare, abbiamo fatto tutto con l\'aiuto di Otomai perché nessuno possa avvicinarsi...\nPer prima cosa bisogna riuscire ad aprire questa porta, grazie alle pietre, grazie alle quattro sale...\nSolo una squadra ben affiatata, ben organizzata e che conosca tutti gli anfratti dell\'isola, può sperare di aprire questa porta. Coloro che se ne mostrano capaci, sono giudicati degni di incontrare... la bestia!";
D.q[5666] = "Ti occupi tu di questo?\nQuello che ti serve per catturare un\'Anima ricalcitrante è una Pietra d\'Anima Ammansita. Posso aiutarti a fabbricarne una, ma per farlo ho bisogno di varie cose. In un primo tempo mi servono gli Ingredienti, cioè una Grande Pietra d\'Anima Felice, 4 Fantasmi di Maomao, 4 Sangue di Pappatutto, 4 Melanzane ed un Cocktail Moritov che è possibile trovare sull\'Isola di Otomai. Quando avrai tutto, raggiungimi nella sala del rituale che si trova sotto la Torre di Brakmar. Puoi entrare da un piccolo passaggio situato tra due scaffali, nella parte a Sud-Ovest ai piedi della Torre. Per incantare la Pietra, ho bisogno dell\'assistenza di un Osamodas che conosca l\'Incantesimo di Resistenza Naturale e di un Alchimista in grado di fabbricare Sangue di Fenice.";
D.q[6394] = "Per assemblare il manico e l\'estremità del Grattaschiena bisogna che un Tuttofare si posizioni davanti alla forgia. Deve essere equipaggiato con un Martello del Tuttofare ed avere con se 2 Ebonite, più il manico e l\'estremità, ovviamente.";
D.q[4666] = "Che ci fai ancora qui? Gli altri miliziani sono già impegnati a ritardare i Bontariani, ma non potranno farlo in eterno. Muoviti a portarmi il Corno Davola.";
D.q[4184] = "Conosci i Pirati dell\'Arca di Otomai? Quelle abiette creature mi lanciano delle palle di cannone ogni volta che sorvolo l\'arca. Ho già perso numerosi Scareoplani a causa loro. Ti farò utilizzare i miei Scareoplani se accetti di andare ad uccidere qualche pirata, così si calmeranno un po\'.";
D.q[1311] = "Ma cosa fai? Cerchi di essere gentile? Ma che cavolata... Hmmm, aspetta un attimo... Stai cercando di ammansirmi... di corrompermi insomma! Male! Molto male! Bravo!!!";
D.q[6393] = "Per scolpire il manico del Grattaschiena bisogna che un Intagliatore di Bastoni si posizioni davanti alla forgia. Deve essere equipaggiato con un Intagliatore di Manici ed avere con se 2 Legno di Acero e 5 Resina di Alberagno.";
D.q[6658] = "Che lo spirito della luce intrappolato in questo martello possa essere liberato.\nChe le tenebre inghiottano quel che apparteneva ai demoni.\nChe la magia nera del martello sia infine ripristinata.";
D.q[4179] = "Ormai propongo solo partite di caccia. Gli avventurieri dei tempi moderni non sanno più fissarsi una meta. Allora cerco di dare un senso alla loro vita con la caccia. In via accessoria, questo mi permette di regolare un po\' la popolazione di creature sull\'isola. Otomai è contro questo genere di ragionamenti, preferisce lasciare che la natura prenda il sopravvento, ma ci siamo messi d\'accordo, e ha accettato il mio intervento sull\'ecosistema a condizione che lo tenga al corrente sui risultati.\nVuoi tentare la fortuna con una piccola caccia?";
D.q[4128] = "I Pirati ci attaccano!\nNon ho neanche avuto il tempo di sparargli una palla di cannone! Maledizione, renditi utile una volta nella vita, buttati nella mischia e uccidi quei furfanti, quegli scorbuti acquatici mangiatori di Raul Mops!";
D.q[3722] = "Pìu pìu pìììììììììììììììu!!!";
D.q[3725] = "Pìu!";
D.q[4060] = "Che incantesimo vuoi dimenticare ?";
D.q[4076] = "Che incantesimo vuoi dimenticare ?";
D.q[2773] = "Ciau! Benvenuto nella mia dimola. Hai l\'occhio scintillante come l\'astlo della notte.";
D.q[4126] = "Finalmente, cominciavo a perdere la pazienza! Vado a caricare le munizioni nella barca e a fare colazione, potrai tornare da me quando sarai pronto a viaggiare verso quell\'isola.";
D.q[4141] = "Grazie a te, i Corallai potranno continuare ad usare quel poco di cervello che gli resta per cose utili, come ad esempio rompere le conchiglie o giocare a rimbalzino sulla spiaggia. Se Otomai vedesse quello che hai fatto per loro, ne sarebbe entusiasta.";
D.q[5954] = "";
D.q[4636] = "Salve. Hai trovato qualcuno per fabbricare il Grattaschiena ? Se sono riluttanti ad aiutarti, digli di venire da me.";
D.q[1476] = "Un bastone annusatore? Di sangue suppongo. Non ne faccio più di questi tempi. Se ne vuoi uno devi portarmi del sangue di vampiro, io mi occuperò degli altri ingredienti. Un boccale circa per ogni bastone più 100 kama per la manodopera.";
D.q[7595] = "Ho formato i migliori Cacciatori dei nostri tempi, il cappello che indosso mi è stato regalato da uno dei miei vecchi allievi, Mikoule.\nParlando di caccia, che ne dici di affrontare uno dei miei trofei?\nOh, non te l\'ho detto? Possiedo la più grande collezione di anime di creature, anche quella del celebre Alchimista Otomai fa una misera figura vicino alla mia.";
D.q[6412] = "Se questo è il caso allora è inutile che mi porti le pelli. Ti darò la ricetta in modo che anche tu possa vedere che è un\'insalata vera, salutare, mica come quelle cose dietetiche piene di chissà cosa che i mercanti ambulanti rifilano alla gente.";
D.q[6036] = "";
D.q[7438] = "";
D.q[4208] = "Ho perso la mia scommessa, avevo scommesso contro di te in questo combattimento. Battere il Kimbo sul suo terreno è un\'impresa degna dei più grandi eroi della nostra epoca. Con un po\' di fortuna potresti affrontare un Kralamore Gigante o un Drago. Otomai aveva ragione, le creature sono come noi, hanno tutte un punto debole e finiscono per essere sostituite, è un\'evoluzione naturale e senza rimedio.\nTu stesso, un giorno finirai nello stomaco di una creatura più forte di te. La digestione sarà difficile, e potrebbe addirittura strozzarsi cercando di ingoiare le tue caviglie! Prendi questa ricompensa, un giorno Otomai mi ha detto che aveva un gran valore.";
D.q[2754] = "Sei coraggioso, ma sei abbastanza forte? Ti sfido a battere uno dei miei allievi. Ha messo la sua divisa da combattimento apposta per te!";
D.q[261] = "Mi dispiace, ma ci sono ancora degli intrusi non desiderati in soffitta. Li sento camminare. Torna quando avrai ciò che ti ho chiesto.";
D.q[3419] = "Ma furono perseguiti dall\'infame cugino di Orukawa, assetato di vendetta. Li dissanguò come fossero Pappatutto, e vendette le loro spoglie come carne da salsiccia sui mercati di Brakmar. Che triste fine!\nFu così che il ratto di Yoshawa si ritrovò solo, e si rifugiò nelle fogne del castello di Amakna per molti anni.\nSi dice che in seguito incontrò Otomai in persona, mentre quest\'ultimo provava nuove pozioni dagli effetti sconosciuti su tartarughe provenienti dall\'isola di Moon.";
D.q[3420] = "Otomai affidò le tartarughe al ratto, ma nessuno avrebbe mai pensato che gli effetti della pozione somministrata alle tartarughe si potessero trasmettere ai ratti...\nFu così che il ratto divenne enorme e ancora più pericoloso.\nCerti saggi del nostro mondo sono convinti che le dimensioni smisurate di certi ratti che vivono nelle grotte e nelle fogne, siano dovute agli effetti secondari di questa pozione che si trasmettono rapidamente tra i ratti, con un morso o tramite l\'accoppiamento. E già sai come sono fatti i ratti, un po\' come i Wabbit!";
D.q[212] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[1819] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[5547] = "Cosa? Vuoi la mia foto?\nQui è pieno di correnti d\'aria e non riesco a mantenere una forma stabile. E in più ti fa ridere?\nE poi l\'illuminazione è schifosa. Chi si è occupato della decorazione? Perfino la torbiera di Otomai è più bella.";
D.q[5959] = "";
D.q[3500] = "Bworkidé istigare Bwork non paxifiki. Tu avere molto male, baaastonee!!!";
D.q[3552] = "Te non contento? Me chiamare femmine bwork, te discutere arredamento con loro ascia!";
D.q[6670] = "Png(367) et Message(4810)";
D.q[1828] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[8015] = "";
D.q[7437] = "";
D.q[549] = "Per la Graande Baaarba! Lo farai *hic*? Diventeraai il mio erooe *hic* e come ricompensa potrai prendeere una bootte *hic*.\nPortaami quello che vuoi *hic*, ma non dell\'acquuua... mi fa maaale *hic*. Una boottiglia di rum andrà beeene *hic* per meritaarti la ricoompeeensa *hic*.";
D.q[4112] = "Per fabbricarti questa chiave ho bisogno di: 1 Pietra di Aerosmith il Rocker, 1 Pietra di Aquaplanning il Guidatore, 1 Pietra di Ignercocopops l\'Affamato e 1 Pietra di  Terrabruciata il Tattico.";
D.q[4113] = "Per fabbricarti questa chiave ho bisogno di: 5 Scarpe di Porkass, 1 Seconda parte della chiave del labirinto del Drago Maiale, 1 Prima parte della chiave del Labirinto del Drago Maiale, 5 Tridenti Rotti, e 5 Orecchie di Porkass.";
D.q[544] = "Credo proprio che perlustrerò l\'isola, ci deve sicuramente essere un tesoro da qualche parte. E ne approfitterò per raccogliere un sacco di oggetti diversi coi quali poter costruire una zattera e andarmene via di qua!";
D.q[1259] = "Pfff, non hai neanche abbastanza soldi.";
D.q[129] = "Gli archi magici sono rari e delicati da fabbricare, servono legni pregiati e metalli o pietre preziose per fare di un arco un\'arma magica ed efficace.";
D.q[3182] = "Ti trovi in un\'incredibile biblioteca labirintica, da cui forse non riuscirai ad uscirne vivo.\nQuesta biblioteca è composta da sedici piccole sale. Le sedici sale formano un grande edificio quadrato. L\'unico modo di uscirne è affrontare il gruppo giusto di creature. Ogni gruppo ti porterà in una nuova sala. Esistono due tipi di gruppi di creature differenti. Quando riuscirai a battere uno dei due gruppi di creature, sarai ricompensato con l\'accesso alla sala successiva. Ma attenzione: queste creature hanno le loro piccole abitudini e cercheranno di portarti sempre nella stessa direzione. Dovrai, quindi, affrontare gruppi differenti per cambiare direzione ed evitare di girare in tondo per l\'eternità.";
D.q[3978] = "Celto! Ma come avvicinalsi?";
D.q[1800] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[3470] = "Fossa Trooll di là. Trooll forzuto!";
D.q[5420] = "";
D.q[2756] = "Sei forte, certo, ma sei abbastanza intelligente? Ti sfido a battere un altro dei miei allievi. Si è messo la divisa da combattimento apposta per te!";
D.q[4887] = "Molto bene, ecco qui il mio piano: farò credere ai Brakmariani che il Corno Davola ha il potere di distruggere le mura e di paralizzare coloro che si trovano davanti al Corno nel momento in cui viene suonato. La parte più grossa è praticamente fatta, ma mi restano ancora delle cose da sistemare, ed ho ancora bisogno del tuo aiuto. Mi servono ancora delle Terhmiti per rendere la roccia friabile e del grasso di Gelatina Reale per completare la pozione paralizzante che i volontari berranno al momento opportuno.";
D.q[1204] = "Hai tutti gli elementi per unirti all\'Ordine del Cuore Valoroso.\nSei sicuro della tua scelta?";
D.q[6386] = "Hai bisogno di un Grattaschiena speciale? No, no, non voglio sapere a cosa ti serve. Comincia col riportarmi le mie chiavi, Fidji Merlin si è di nuovo dimenticata di rendermele.";
D.q[970] = "Capitan Arlok, al tuo servizio! Cosa posso fare per te?";
D.q[2552] = "Se rifiuti, mi offendo. Se mi offendi, offendi tutti i Pandawa, per non parlare della nostra dea... A quel punto non pensare di poter ottenere una qualsiasi informazione sul Dofus di Pandala... Sei qui per questo, no?";
D.q[568] = "Sei sull\'isola di Moon. Sarà la tua casa per i prossimi 50 anni ahahah. Fortunatamente per te, c\'è un po\' più di vita sull\'isola negli ultimi tempi. Non ti annoierai sicuramente... la prima settimana almeno! Ahahah!";
D.q[3992] = "Cewto, sei abbastanza fowte e ti pwendo al mio seguito. Ma da solo non basti...  cewca di powtawmi altwi avventuwiewi, se ne sei capace...";
D.q[2279] = "*sotto voce*\nChe il dio Yop ti dia Vitalità, che la tua spada sia affilata, che il tuo braccio sia lungo con Compulsione!";
D.q[543] = "Ciao ciao straniero, mi chiamo Kib Roche, e sono un futuro grande pirata. Mi sono arenato su quest\'isola seguendo le indicazione del mio ultimissimo acquisto: una mappa del tesoro parlante. Però arrivando ho fatto troppo rumore, e quel maledetto pappagallo se n\'è scappato via!";
D.q[6392] = "Sei riuscito a fabbricare il tuo oggetto. Non è male,ma devi migliorarlo se conti di battermi, un giorno.";
D.q[847] = "Sbrigati a rimediare alle tue stupidaggini!";
D.q[305] = "Kat... Kat... Kat...ékit";
D.q[7439] = "";
D.q[2604] = "Non hai incontlato il mio messaggelo? Devi andale a Telladala, e plesentalti al capo che sta spesso fuoli dal villaggio. Sbligati!";
D.q[2582] = "...contaminare le cuffie Pandawa con i germi della Pandrista è stata un\'idea geniale! In più il vento ha portato altre malattie sull\'isola: questi maledetti avventurieri rischiano di vedersela brutta...";
D.q[1257] = "Ahah! Perché dovrei darti la ricetta? Mi servirebbero almeno 1000 kama per bagnarmi un po\' la gola...";
D.q[2885] = "Nessuno ha il permesso di avvicinarsi al ricettacolo, anche se il Grandapan lo considera come un\'attrazione turistica. Questo oggetto attira i feroci mostri che lo proteggono. Solo i più forti possono entrare nel villaggio... e i pandawa, per il rituale di iniziazione.";
D.q[3622] = "Peso mio in piscio Bwork!";
D.q[4529] = "Farai una visitina a Larry Poller, alla Torre degli Ordini di Bonta e vedrai con lui come migliorare il nostro arsenale magico. Me ne frego completamente dei mezzi utilizzati per riuscirci, l\'importante è ottenere risultati concreti.";
D.q[1294] = "Hai avuto fortuna, ho perso perché avevo il sole negli occhi. Torna domani e prenderò la mia rivincita...";
D.q[5061] = "";
D.q[1690] = "Scegli l\'ammontare dei gettoni";
D.q[1694] = "Scegli il tuo regalo.";
D.q[2320] = "Allora è tutto apposto, hai portato l\'arco a Nibé Lulla?";
D.q[7548] = "Buongiorno #1, vedo che sei nuovo. Ti invito a seguire questo corso rapido sui principi di base di questo Mondo.";
D.q[5062] = "";
D.q[1249] = "*hic* succo di glutovora! *hic*\nSe me ne porti almeno 4 ti farò v... *hic*";
D.q[1264] = "Hai un modo molto strano di incoraggiare i sognatori.\nNon riesci veramente a capire quanta gioia porta la mia fiera? Oppure sei semplicemente geloso... Comunque sia, ecco il tuo modulo riempito.";
D.q[3062] = "Dovresti riuscire a trovare tutto nei dintorni.";
D.q[2887] = "Se sei pronto a ripartire, ti riporto all\'entrata del Villaggio.";
D.q[1291] = "Scrocchiolio Scricccchiolio Scriscricchiolio Scrocchiolio Scrocchiolio Scrocc Scrocchiolio Oiolio!";
D.q[5873] = "";
D.q[1543] = "Ah, le elezioni, sono bravissimo in questo genere di pronostici, però per essere veramente affidabile, ho bisogno di un po\' di polvere di Oni.\nSe vuoi sapere chi sarà il nostro prossimo intendente, ti costerà 200 kama e un sacchetto di quella famosa polvere.";
D.q[1589] = "Dai, sparisci adesso!";
D.q[5876] = "";
D.q[3001] = "Bel lavoro, anche se è vero che un pìu non è così feroce, eh?! (Scarabocchia freneticamente borbottando). Aah! Il furbo! Non rispetta veramente niente! Argh! Tieni, ti do questo libro, ora non ci sono più errori... e prendi anche questo manuale, te lo metto nell\'inventario, consultalo in continuazione! È un\'opera utile per i giovani avventurieri.";
D.q[3471] = "Torna da me quando avrai più tempo. Se hai aiutato un goblin, di sicuro aiuterai volentieri anche un bwork mago.";
D.q[2544] = "Ahahah! Non ti preoccupare: si tratta di un segno di riconoscimento tra me e il saggio Volpo. Benvenuto tra noi! Posso sapere che cosa ti conduce fin qui?";
D.q[3856] = "Gli avventurieri vengono spesso a riposarsi alla taverna per recuperare l\'energia persa, chiacchierare e bere un po\' di lalatte fresco.";
D.q[5063] = "";
D.q[5880] = "";
D.q[1959] = "Passa dal magazzino di legno qui vicino, e trova l\'entrata del suo nascondiglio, è una botola nascosta. Naturalmente devi essere molto discreto, se ti catturano o ti uccidono... ma questo lo sai già da te...\nTi ho indicato il cammino. Non ti resta che seguire la bussola.";
D.q[2187] = "Ci sono dei Dente di Leone nei campi a Nord-Est della città, se ricordo bene...";
D.q[5974] = "";
D.q[2160] = "Una brocca piena per metà, è mezza vuota?";
D.q[731] = "Questa mattina una veggente mi ha svelato che il capitano Tsog aveva informazioni di grande importanza da rivelarmi prima di morire.\nTrova un modo di entrare in comunicazione con lui al cimitero Est di Bonta e riferiscimi le sue ultime parole.\nChiedi al Capitan Alrok se vuoi informazioni più precise sull\'ubicazione della sua tomba.";
D.q[6744] = "Sorvegliamo tutte le uscite, nessuno può entrare o uscire senza la nostra autorizzazione.";
D.q[6420] = "Sentimi bene, giovanotto, se sei venuto per vantarti, stai parlando alla persona sbagliata. I pretenziosi come te, li prendo e faccio della chirurgia sperimentale con la loro faccia che neanche la madre potrà più riconoscerli, capito cosa voglio dire? Allora, resta discreto e vattene.";
D.q[4638] = "Bene, ora hai capito che è meglio non contrariarmi. Per il futuro sono sicuro che riuscirai a completare le missioni che ti assegnerò.";
D.q[6421] = "Sentimi bene, ragazzina, ti consiglio d\'andare a dimenare il tuo sederino altrove. Le seduttrici come te, le prendo e faccio della chirurgia sperimentale con la loro faccia che neanche la madre potrà più riconoscerle, capito cosa voglio dire? Allora, resta discreta e vattene.";
D.q[6042] = "";
D.q[5981] = "";
D.q[5979] = "";
D.q[6380] = "Hai scelto la pawte dei pewdenti, ma non è twoppo tawdi pew cambiawe. Ti wiempiono di illusioni pew contwollawti meglio, la luce ti acceca e non sai dove andawe. Winuncia owa, abbwaccia le tenebwe e i tuoi potewi sawanno senza limiti. Non wicevewai più owdini da nessuno, sawai il padwone di te stesso.";
D.q[6739] = "Alla fine siamo fortunati, ogni chilometro percorso ci avvicina piano piano alla nostra destinazione e diminuisce i rischi di subire un attacco.";
D.q[7440] = "";
D.q[4646] = "Eh!? Vuoi lasciarmi qui!? In questo stato mi prenderanno! Non farai questo ad un alleato Brakmariano, vero?";
D.q[5982] = "";
D.q[2386] = "Sei sicuro di voler intraprendere la carriera di Forgiatore di Asce?";
D.q[3273] = "Dai, avvicinati, e cerca di non cadere maldestramente in un buco, guarda dove metti i piedi! Su ogni pietra c\'è un numero che indica il numero di pietre contenenti una trappola sulle 8 pietre adiacenti. Per deduzione dovresti riuscire facilmente ad individuare le pietre con la trappola e a camminare solo su quelle che ti condurranno dall\'altra parte.";
D.q[1597] = "Non sei ancora arrivato al livello 2.\nTorna ad allenarti contro quell\'Arakne.";
D.q[2553] = "Hai provato il tuo valore! Meriti di sapere tutto sui Dofus di Pandala... o almeno è ciò che mi ha detto il saggio Volpo. È lui che mi manda... ti senti pronto?";
D.q[7441] = "";
D.q[5984] = "";
D.q[2824] = "In pochissimo tempo sei diventato un Pandawa degno di Pandawa. La nostra dea ti fa i complimenti. Adesso il Maestro Volpo ha pienamente fiducia in te, e ti affida un compito importante. Se porterai a termine questa missione, la tua richiesta verrà accettata.";
D.q[4122] = "Mi hai battuto al mio stesso gioco, non riesco ancora a capacitarmene...\nPer tutta la notte ho cercato di trovare una risposta alla tua domanda, e non l\'ho trovata...\nNell\'attesa, vai vai, attraversa il ponte.";
D.q[3290] = "Anche tu hai appena sconfitto il terribile Mob la Spugna! Con un po\' di fortuna, penserai a me quando sarai digerito dal Kralamore Gigante.\nOps, mi sembri teso, rilassati, il combattimento è finito, fa bello, c\'è il sole e sei nella zona di Astrub! Cosa vuoi di più?\nMa non sto scherzando, sei rigido come un paletto di kalipto secco.\nLasciami fare, ti insegnerò a rilassarti!";
D.q[393] = "Sei fortunato, mi sembra di avercela qui. Mi mancano 90 Zampe di Arakne e 65 Trifogli a 5 foglie.";
D.q[6427] = "Degli Ecaflip? Mai visto degli Ecaflip, mai. Cos\'è precisamente un Ecaflip?";
D.q[7442] = "";
D.q[6523] = "Si direbbe che non sia il tuo giorno fortunato, ma ti risponderò lo stesso, così eviterò di averti intorno tutta la sera. Sai dov\'è il mercatino dei Minatori? Si, a Brakmar, ovviamente! Il nascondiglio di Pola si trova in prossimità del mercatino, è tutto quel che ti posso dire... non mi va di parlare di nuovo con te.";
D.q[5988] = "";
D.q[3483] = "Dai, riproviamo, colpisci più forte questa volta!";
D.q[829] = "Va bene, dai, dì al tuo maestro cos\'è successo.";
D.q[5401] = "";
D.q[5735] = "";
D.q[5990] = "";
D.q[2445] = "Li riconoscerai facilmente. Si tratta di grandi archi disseminati un po\' dappertutto nel mondo. Quando ne vedrai uno, avvicinati. Conserverà la traccia del tuo passaggio. In seguito potrai teletrasportarti con l\'aiuto di un altro Zaap, al costo di qualche kama.";
D.q[5892] = "";
D.q[5991] = "";
D.q[2123] = "Vieni qua, devo convalidare le tue missioni.";
D.q[1534] = "Oh, dai, dai, non serve a niente arrabbiarsi, il codice per entrare è \"11115555\".";
D.q[2873] = "...";
D.q[7144] = "Torni dal tempio? Spero che tu ne abbia approfittato per visitarlo da cima a fondo, ci sono tante cose da fare laggiù.";
D.q[5992] = "";
D.q[2673] = "Ti consiglio di andarti a riposare all\'albergo del villaggio centrale, aver percorso tutta l\'isola per portarmi questa fiala ti ha distrutto.";
D.q[6886] = "";
D.q[2605] = "Ahah! La mia consegna di bambù, potrò fabbricare moltissimi scudi grazie a te, eccone uno piccolo per te...";
D.q[2690] = "Sono il miglior fabbricante di scudi pandawaiani al mondo! E sfido costantemente i miei discepoli a superarmi, è così che si diventa più bravi, tanto loro quanto me, ricordatelo bene.";
D.q[5897] = "";
D.q[4090] = "Attenzione, sei sicuro di voler dimenticare tutti i livelli di questo incantesimo?";
D.q[5993] = "";
D.q[344] = "Per diventare Taglialegna ci vuole molta passione, tagliare alberi tutta la giornata richiede una grande forza di volontà. Certi alberi sono più semplici da tagliare che altri, e ti servirà molta esperienza nel mestiere per poter tagliare gli alberi più grossi. Per esercitare questo mestiere è indispensabile avere un\'ascia, te ne posso vendere una se vuoi.\nPosso anche insegnarti le basi del mestiere di Taglialegna.";
D.q[6434] = "Tu hai il senso degli affari. Se vuoi saperne di più, contatta Hersa Artiglio Oscuro a Bonta, ma soprattutto evita di dirle che ti abbiamo parlato di lei.";
D.q[5900] = "";
D.q[5997] = "";
D.q[5899] = "";
D.q[5995] = "";
D.q[2314] = "Arrgh! Mi hai fatto paura! Pensavo fosse ancora uno di quei ratti d\'Isgustosi... A proposito di ratti... forse mi resta qualcosa per riempirti le tasche...";
D.q[5901] = "";
D.q[3343] = "Complimenti!\n\nHai vinto un magnifico viaggio turistico nella giungla di Wabbit, sponsorizzato dalla compagnia aerea In Kamas! Atmosfera safari garantita!\n\nSenza rancore... E buon viaggio!";
D.q[5999] = "";
D.q[6484] = "Oh, è solo un maomao. Appena mi distraggo, se qualcuno o qualcosa si avvicina, rischio di farmi rubare il documento e di farmi dare delle bacchettate sulle dita.";
D.q[6880] = "";
D.q[6640] = "Hai UNA possibilità di andartene vivo, prendila e scappa!";
D.q[5070] = "";
D.q[7448] = "";
D.q[1587] = "Vuoi restituirmi l\'anello?";
D.q[6887] = "";
D.q[4001] = "Io sono molto più forte di te, ma se batti il mio discepolo migliore, allora servirò il tuo principe.";
D.q[4219] = "Non dovresti avventurarti laggiù, è un luogo estremamente pericoloso.\nUna terribile creatura ci vive da molti anni, pensiamo addirittura che fosse già lì prima che l\'Isola emergesse.\nNumerosi sono gli avventurieri che ha divorato, il suo appetito per la carne fresca sembra essere insaziabile.";
D.q[6450] = "Devi mettere le mani su una chiave del covo, suppongo che certi banditi ai posti alti ne abbiano una copia. Quando avrai questa chiave, fatti accompagnare da dei miliziani o dei mercenari e vai al covo. Ispeziona il luogo e recupera ogni documento che potrebbe aiutare la nostra inchiesta. Conto su di te e sulla tua discrezione. Conoscendo i contatti di Hersa, può sicuramente esserti utile.";
D.q[6308] = "Sei talmente brutta che perfino i poteri di mille dei sarebbero insufficienti per esaudire la tua richiesta.";
D.q[2935] = "Complimenti ti sei battuto bene! Confermo il tuo passaggio di grado...";
D.q[5302] = "";
D.q[4789] = "";
D.q[6305] = "Troverai l\'entrata del sotterraneo che conduce al Pozzo delle Anime Imbrattate ad Est del Territorio dei Banditi. Potrai avere accesso al pozzo solo in compagnia di almeno altri quattro Brakmariani la cui viltà non debba più essere provata e che, se non hanno ancora scelto una specialità, siano in grado di farlo.";
D.q[5397] = "";
D.q[3583] = "Sì. Me vuole diventare angelo e volare sopra Bonta.";
D.q[4567] = "Buongiorno, vuoi partire per un viaggio? Cadi a fagiolo, ho giusto una missione che ti farà andare lontano. Devi andare sull\'isola di Moon e devi trovare il guardiano del Corno Davola. Se nella stessa occasione riesci anche a recuperare il Corno portalo pure.";
D.q[5303] = "Sbrigati, non mi piace per niente tutto ciò. Non voglio ritrovarmi in un bagno di sangue, non adesso.";
D.q[2741] = "Mostri impeto negli allenamenti, e questo mi piace. Ma se pensi di calpestare il suolo del mio Dojo vestito così, ti sbagli. E di grosso anche. Niente mi dice che tu sia in buona salute: d\'altronde, ti hanno già detto che hai il fondo dell\'occhio rossastro? No? E va bene, adesso lo sai! Mettiti alla ricerca di un certificato sciamanico, e di una divisa da allenamento.";
D.q[6007] = "";
D.q[5395] = "";
D.q[6263] = "Cos\'è che ti avevo detto l\'altra volta? Che non volevo essere coinvolto in questi intrallazzi...";
D.q[6889] = "";
D.q[6008] = "";
D.q[5772] = "La tua reputazione ti precede, ma tanto vale dirti subito che, per quello che mi riguarda, gioca a tuo sfavore. Troppi documenti da trattare, quindi più oggetti da riciclare: ecco perché il costo importante di 128000 kama per ritornare Neutro. \nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[3625] = "Te volere schiacciare pìu con tue scarpe? Te dare me uova di pìu!";
D.q[7450] = "";
D.q[2625] = "Vuoi mio figlio! Ma avete fatto un passaparola o cosa!\n*a voce bassa* Cos\'è che lo rende così popolare... saranno mica i capelli? Mi spiace, ma mio figlio è già promesso alla figlia del proprietario del Dojo. Non potrei mai cederlo per una somma inferiore ai 100000 kama.";
D.q[2783] = "Penso di restare un po\' qui, giusto il tempo che ci vuole ai miei amici per ristabilirsi. E poi... ho incontrato una giovane mercante la cui peluria è morbida come i peli della mia barba! I suoi occhi sono due rubini e... per tutta la barba di Anutrof... trinca più di me! Non partirò senza aver provato a picconare un po\' il suo cuore! Sono persino disposto ad aprire il mio zaino di gioielli, figurati! La giovinezza sta riaffluendo nelle mie vene!";
D.q[4566] = "Il tuo Mondo mi ha divertito molto, ecco perchè rispetterò la mia promessa di non distruggerlo... per ora.\nSe mi porti un vecchio Mazzo di Chiavi posso scambiartelo con uno nuovo che ti servirà per misurarti con mostri più forti.";
D.q[6010] = "";
D.q[6213] = "Non mi sembra che tu abbia afferrato. Non posso dire niente, capito?";
D.q[5068] = "Mago Ax ha trovato qualcosa?";
D.q[5306] = "";
D.q[6014] = "";
D.q[2178] = "Se potessi fare meno rumore, sai, Locetta dorme profondamente. Aveva mal di testa quando è rientrata dalla missione. Spero non sia niente di grave.";
D.q[2770] = "Ti senti pronto per cercare di raggiungere il grado di Sandanwa? Perfetto! Sfida in combattimento un guerriero di questo grado. Battilo per provare il tuo valore.";
D.q[6026] = "";
D.q[6015] = "";
D.q[6234] = "Grazie tante. Tieni, prendi questo pane. Non è molto, ma ti riempirà lo stomaco durante il viaggio..\nOra mostrami la cartina, ti indicherò il luogo in cui ho visto l\'Etram.";
D.q[4790] = "";
D.q[2768] = "Ti senti pronto per cercare di raggiungere il grado di Shodanwa? Perfetto! Sfida in combattimento un guerriero di questo grado. Battilo per provare il tuo valore.";
D.q[6029] = "";
D.q[4125] = "Sembri determinato... o pazzo. Mi piacciono i divoratori di Bituf come te, quelli che ingoiano la vita e i nemici. Stiamo per partire per una lunga avventura, dobbiamo proteggerci. Recentemente ho acquistato un cannone stupendo per la mia nave, ma mi mancano le munizioni. Le ho usate tutte per allenarmi sui Raul Mops della Baia di Cania, dovresti andare a farci un giro. Mi serviranno anche delle punte di freccia per proteggerci da eventuali Kannibul.\nE mi piacerebbe anche che tu mi portassi il mio pasto preferito, un orecchio di Kanigrù fritto in olio di sesamo! Quando mi avrai portato tutto ciò, potremo partire!";
D.q[6019] = "";
D.q[6011] = "";
D.q[2769] = "Ti senti pronto per cercare di raggiungere il grado di Nidanwa? Perfetto! Sfida in combattimento un guerriero di questo grado. Battilo per provare il tuo valore.";
D.q[6020] = "";
D.q[2888] = "Bulbavo! Bilbulubu bu ba bi bobo bu bulbi bi bo....\nBi bu bi bebe ibu ob eb bort be bune.";
D.q[2904] = "Bene, e se possiedi un cappello Goyave e un cappello Kannipìu, quale dei due è meglio portare per acquisire più vitalità in combattimento?";
D.q[6021] = "";
D.q[6890] = "";
D.q[6024] = "";
D.q[3234] = "Yiiihhhaaaaa, kama, kama.\nNe vuoi?";
D.q[2759] = "Per arrivare al grado Rokwa, devi battere un discepolo che abbia il tuo stesso grado, in uno scontro testa a testa e davanti ai miei occhi!\nNon dimenticarti di venire con la tua divisa!";
D.q[3580] = "Te promesso aiutare me.";
D.q[6226] = "Calmati, ti dirò quel poco che so. Quando lavoravo da lui, spesso ci sono state visite di persone losche, un po\' come te, ma più distinte. Poi ha guadagnato molti soldi e si è conquistato una buona posizione nella società Bontariana. In seguito io ho ripreso l\'attività di mia madre e nello stesso periodo lui ha deciso di trasferirsi in appartamenti più lussuosi. Da quel momento non l\'ho quasi più visto, tranne di tanto in tanto, quando viene a passarmi degli ordini, il che è molto raro. Non so nient\'altro, te lo giuro.";
D.q[6023] = "";
D.q[1946] = "Io... io... Ah, sono finito *sospiro*.";
D.q[5307] = "Ancora tu? Ho ancora un occhio tutto nero, dopo la bastonata di prima.";
D.q[6891] = "";
D.q[1548] = "Le circostanze sono favorevoli per dimostrare il tuo valore. Non sprecare un\'occasione così!";
D.q[6460] = "Che carogna! Sapevo che avremmo dovuto eliminarla quando con i miei amici ne abbiamo avuto l\'occasione. Dimmi cosa vuoi e vedrò se posso trovare una soluzione.";
D.q[2761] = "Devo occuparmi del passaggio di grado di numerosi adepti. Se vuoi provare di nuovo, torna da me tra un\'ora!";
D.q[6038] = "";
D.q[5308] = "Hmm? Vediamo...\nAh, ok. Huhuhu...";
D.q[5388] = "Ciao giovane draguovo. Hai finito il giro dei bar?";
D.q[3244] = "Ha-ha-ha-hai voglia di farti un sac-co-co di soldi? Allora di-di-diventa artigiano! E per farti conoscere, ades-so-so hai le ru-ru-rune!";
D.q[4369] = "Non sei servito a niente, mi chiedo proprio perché Amayiro ci abbia fatto scortare per una tale nullità. Eppure io e lui ci siamo lasciati in ottimi termini e dava l\'impressione d\'aver apprezzato il nostro incontro... Non capisco perché l\'abbia fatto. Quanto a questi banditi, sentiranno parlare del paese, puoi credermi. Non resterò con le mani in mano, parola di Etram.";
D.q[5317] = "Se hai i kama per la mia indennità rischi, li prendo subito!";
D.q[3757] = "Sì, hai delle cose interessanti, possiamo barattare qualcosa.";
D.q[3494] = "Te vincere, te paxifiko.";
D.q[3262] = "Uf, mi hai fatto paura.\nNon so cos\'hanno tutti, ma ho già fatto andare via una ventina di Yop piagnucoloni che promettevano di non essere mai più cattivi in vita loro.\nPer lo meno tu hai del fegato!\nDai, ci vediamo più tardi!";
D.q[2700] = "L\'occhio della dea è fisso su di te... Mi dice che ti aspetta un destino glorioso. Recati al Ricettacolo dei Dofus. Poi, vai dal Saggio Volpo che abita lì vicino.";
D.q[2760] = "A parte il Pandawushu originale, quanti stili ha la nostra arte marziale?";
D.q[1649] = "Vieni a riflettere un po\' qui, degustando uno dei nostri gelati. Abbiamo un enorme scelta di gusti. Su, dai un\'occhiata al menù!";
D.q[6893] = "";
D.q[1667] = "VIENI A MISURARE LA TUA DESTREZZA! CI SONO UN SACCO DI PREMI DA VINCERE! Oh ciao, sento che sei dotato per il tiro a distanza! Non so nemmeno se farti giocare, ho proprio paura che vincerai tutti i premi... Dai, va bene, gioca pure, mi fa piacere! E poi sono solo 20 kama a partita.";
D.q[2642] = "Sono la persona più popolare di quest\'isola, la più bella, la più forte e non temo niente e nessuno uahahahaha! Hmmm, sì, scusa, cosa volevi?";
D.q[5318] = "Perché gli altri dovrebbero avere un\'indennità rischi, e io no?";
D.q[6044] = "";
D.q[2940] = "Hum, vedo che hai la chiave di questo rifugio... Ti lascerò entrare, ma fai attenzione, penso che i miei colleghi non ti faciliteranno il compito. Il Maestro Pandora, che si è insediato in questo rifugio, ha reclutato i migliori Pandikaze per farsi proteggere. Sei sicuro di voler entrare ?";
D.q[7445] = "";
D.q[1660] = "Vieni ad ammirrrarrre ogni generre di mostrri per la modica somma di 10 kama! Tutti gli errrrori di Sir Silvosse, il maestrro della naturrrra, che prrrobabilmente si è fatto distrrrarre da uno spirrrito maligno!\nNon metterre la mano trrra le sbarrre delle gabbie, non ti avvicinarrre trrroppo e forrrse non ti succederrrrà niente! eheheheh!";
D.q[6451] = "Lo fai apposta? Quando mi parli, mi devi chiamare \'Padrona\', \'Per favore, Padrona\', \'Sì, Padrona\'";
D.q[1663] = "Dark Vlad si è rifatto vivo, e si è di nuovo impadronito della foresta malefica!";
D.q[6048] = "";
D.q[4405] = "Ohoh, un Bontariano qui a Brakmar? Suppongo che l\'informazione circoli perfino nei ranghi nemici. In teoria dovrei chiamare la guardia per scorticarti, ma forse potresti arricchirmi ancora di più?";
D.q[6053] = "";
D.q[1565] = "Cavolo, non pensavo che la milizia venisse a ficcare il naso nei miei affari. Non credi che dovresti occuparti di Brakmar, piuttosto che disturbare la gente che lavora onestamente?";
D.q[6056] = "";
D.q[53] = "Non è possibile! Eppure c\'era un passaggio per entrare in una miniera qui... Maledizione, non riesco più a trovarlo... comincio quasi ad avere la barba bianca...";
D.q[359] = "Fai bollire in un pentolone 75 Ghiande, 75 Lingue di Dente di Leone Diabolico e 70 Petali di Rosa, e otterrai una deliziosa zuppa di ghiande!\nGnam, che buona!";
D.q[4868] = "";
D.q[2840] = "Vediamo un po\'... Sì, sembra che tu abbia cominciato a seguire i corsi del valoroso Amayiro.\nForse è arrivato il momento che tu scelga un ordine e una specializzazione per poter servire al meglio gli interessi di Bonta!\n\nIo sono il maestro dell\'Ordine dello Spirito Redentore, ma se vuoi informazioni su un altro ordine, ti consiglio di visitare gli altri piani della torre...";
D.q[1439] = "Mostra ad Amayiro questo veleno dicendogli che l\'hai trovato vicino alla casa di Rimaraf.\nCi ho scritto il nome \"Oni Tnec\" sulla prova d\'acquisto.\nSe non funziona così, chiedi ad Anik Mek di fabbricarti un nuovo badge con questo nome per una missione cosiddetta confidenziale...";
D.q[4324] = "Nell\'attesa che Milon finisca il gioiello, bisogna dare un appuntamento al nostro amico Xefires. La torre di Bonta sarà perfetta: nel luogo in cui hai trovato il pezzo di carta. Tieni, ecco una lettera: fai in modo che Xefires la riceva. Ti ricordo che passa molto tempo alla taverna del Pandawa Ubriaco... visto che di sicuro te ne sei già dimenticato.";
D.q[1228] = "Non vedi che sono di pattuglia? Vattene!";
D.q[642] = "Ecco una piccola firma... Vai dall\'Alchimista Esaminatore. Purtroppo non so dove sia. Pare che in questo momento stia facendo delle ricerche sul calcio della cartilagine intranasale post-mortem.";
D.q[4287] = "Lo scopo è di farsi passare per mercanti, non per mendicanti. Avresti potuto chiedere ad Amayiro di trovarti una tenuta decente. Insomma, in ogni modo ora è troppo tardi, dobbiamo andare. Altre guardie sono nascoste nei veicoli, ci assisteranno in caso d\'attacco. Andiamo!";
D.q[6894] = "";
D.q[5319] = "Ne ho abbastanza di essere pagato sempre di meno. Abbastanza di rischiare la vita per questi imbecilli. Sì, sono nervoso perché il mio lavoro è troppo duro, troppo rischioso, con orari schifosi e sottopagato.";
D.q[5455] = "";
D.q[3889] = "Il mio testo.";
D.q[5456] = "";
D.q[6895] = "";
D.q[4168] = "Ti avverto, non sopporto chi prende in giro il mio nome.\nImmagino che se sei qui è per usare il mio Scareoplano.\nMa prima dovrai aiutarmi.";
D.q[6149] = "Mi porti le anime che ti ho chiesto?";
D.q[6064] = "";
D.q[6148] = "Mi porti le anime che ti ho chiesto?";
D.q[5324] = "";
D.q[4337] = "Xefires ti aspetterà nella torre di Bonta, nel luogo in cui hai trovato il pezzo di lettera la prima volta. Stai attento a non farti beccare con il gioiello.";
D.q[6144] = "Mi porti le anime che ti ho chiesto?";
D.q[6528] = "Ascoltami,prima di fare un\'idiozia, ho vinto molti soldi ultimamente e posso rimborsare Oto Mustam con gli interessi. Lo so che dovevo rimborsarlo più di due settimane fa, ma avevo problemi finanziari. Non mi ucciderai, ora che sai che ho quel che il tuo capo vuole, no? Al limite posso esaudire i tuoi desideri, se mi lasci vivere, che ne pensi?";
D.q[7401] = "";
D.q[5325] = "";
D.q[987] = "Allowa, hai twovato quello che ti ho chiesto?";
D.q[6897] = "";
D.q[2239] = "Ha...hai ritrovato il mio... peluche...?";
D.q[6069] = "";
D.q[2340] = "Hai scoperto da dove viene la bestia che devasta il mio gregge? Torna da me solo quando l\'avrai uccisa!";
