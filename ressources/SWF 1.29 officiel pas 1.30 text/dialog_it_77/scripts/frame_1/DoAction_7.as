D.q[3295] = "E sì, giovane Bontariano, dopo tutti questi anni a lavorare come volontario nei servizi della nostra bella città di Bonta, finalmente ci siamo!";
D.q[2915] = "Ciao, spero che tu le abbia date di santa ragione ad un bel po\' di Brakmariani!\nCosa posso fare per te?";
D.q[5950] = "";
D.q[6037] = "";
D.q[751] = "Una nuova razza di ratti è apparsa nelle fogne della nostra città, sono riconoscibili per il loro colore verde e la terribile puzza che emanano...\nPer lottare contro la loro proliferazione, abbiamo deciso di chiedere ad ogni soldato di ucciderne 4, ora sai cosa devi fare #1...";
D.q[1519] = "Hai una risposta da darmi?";
D.q[6118] = "";
D.q[5953] = "";
D.q[5958] = "";
D.q[6352] = "Ahah. Senza le loro armi i Bontariani faranno una misera figura di fronte alla mia cavalleria. Li calpeeeesterò tutti.\nContinua a servire Brakmar in questo modo e forse potrai venire con me a schiacciaaaare dei Bontariani.";
D.q[4389] = "Sembra che qualcuno voglia farti incolpare. Metterò questo rapporto al sicuro. Se le cose dovessero andare male per te, Turi Ordin potrebbe servirsene dimostrando che è stato falsificato. Per quanto ti riguarda, riposati un po\', nel frattempo potrò riflettere a come risolvere questa situazione.";
D.q[7421] = "";
D.q[5707] = "";
D.q[4647] = "Aaaargh... maledetto sia tu che mi lasci morire qui, Oto!\nTieni, prendi i tuoi schifosi documenti e scappa, io proverò a nascondermi...";
D.q[6858] = "";
D.q[5706] = "";
D.q[1628] = "HEI STOP COCCO BELLO! Dove credi di andare così?! Non provare ad avvicinarti ai miei bambini! Non voglio che uno debuluccio come te gli si avvicini. Devono avere solo buoni esempi, per poter essere i migliori!";
