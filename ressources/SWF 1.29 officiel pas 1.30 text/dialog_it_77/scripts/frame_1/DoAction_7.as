D.q[4132] = "Fai attenzione, l\'ultima volta che l\'ho portato su quest\'isola, più di 35 anni fa, gli ho detto di aspettarmi, e che sarei tornato a prenderlo qualche giorno dopo. Chiaramente non sono più tornato, ed ero proprio contento di essermene sbarazzato. Deve veramente essere arrabbiato con me, passare 35 anni ad aspettare su un\'isola deserta con qualche kokoko e qualche pirata, dev\'esser peggio che passare la vita con te!\nE mentre ci siamo... avrei un po\' sete, senza bere non riuscirò a riparare le vele e lo scafo della nave, cerca di trovarmi una Noce di Kokoko e qualche cosa per berne il succo. Questa volta cerca di non portarmi roba avariata...\nCosa ci fai ancora qui, muoviti, ho sete!";
D.q[7704] = "Non ti avvicinare, sei malato. Vai di corsa da Albert Pes, il nostro dottore.";
D.q[4722] = "";
D.q[4466] = "Ahahah, spero che tu stia scherzando. No? Senti, non so cos\'hai in testa, ma io non voglio avere a che fare coi tuoi intrallazzi.";
D.q[5743] = "";
D.q[4771] = "";
D.q[5802] = "";
D.q[7093] = "";
D.q[5763] = "";
D.q[6330] = "Ahahah, almeno tu hai il senso dello humour. Di questi tempi è una qualità rara che molti ignorano o non capiscono.";
D.q[7703] = "Ciao, vedo che hai fatto di testa tua e ti sei ammalato. Se tu avessi ascoltato i miei consigli, tutto questo non sarebbe accaduto.\nVai di corsa dal nostro dottore, Albert Pes, sta lavorando ad un antidoto.";
D.q[5708] = "";
D.q[4165] = "Allora, l\'hai trovata, cosa ti ha detto?";
D.q[6295] = "Ahahahah. Solo perché hai trovato il nostro nascondiglio credi che ti obbedirò? \nAhahahah, sei ridicolo come il cappello che indossi.";
D.q[4742] = "";
D.q[6628] = "";
D.q[1025] = "Nulla ti ferma. Bene, la mia stima per te #1 è sempre più grande.";
D.q[7094] = "";
D.q[7705] = "Comprate i miei Pescetti!\nSono freschi i miei Pescetti!";
D.q[4741] = "Hai il Martello dei Chus, vero? Posso ridurre i suoi poteri demoniaci se vuoi. La potenza della Lama resterà invariata, ma l\'effetto dello Spirito del suo proprietario diminuirà.";
D.q[6483] = "Stop! Chi va là?";
D.q[5173] = "";
D.q[7095] = "";
D.q[7085] = "";
D.q[1121] = "Levati di mezzo, insetto. Non ho tempo per giocare, devo andare a calmare mio fratello.";
D.q[1477] = "Aspetta un attimo... Ecco, un bastone annusatore! Lo punti verso un giocatore e lo usi. Funziona a distanza di 20 metri circa. Torna pure se ne vuoi altri.";
D.q[443] = "Per vendicarmi di questa mostruosa creatura, dovrei conservarne un souvenir immortale... \nDopo che l\'avrai uccisa, prendile l\'Ambra Ancestrale e cerca di forgiare delle Daghe Ancestrali con quest\'ambra...\n\nPortami queste daghe e in cambio ti darò il Legno Ancestrale che ti permetterà di fabbricare un Amuleto dagli stupefacenti poteri e forse anche di riforgiare la leggendaria Fenditrice di Alberagno Ancestrale, un\'ascia che trasformerà il suo padrone in uno dei più potenti guerrieri di Amakna.\nMa stai attento: dovrai trovare un Forgiatore di Daghe molto esperto per riuscire a forgiare le daghe che sto cercando. Per fabbricare, inoltre, questo amuleto e la famosa ascia di cui ti ho parlato, dovrai rivolgerti ad artigiani d\'eccezione.\nUn\'ultima cosa, non sottovalutare la potenza dell\'Alberagno Ancestrale...";
D.q[7090] = "";
D.q[7091] = "";
D.q[1998] = "È l\'ora del pisolino... *sbadiglia*";
D.q[7673] = "Gli stock di Apewicubi devono essere sorvegliati giorno e notte perchè i Pinguinotti tentano regolarmente di rubarli. E\' un compito ingrato ma necessario, poichè tagliare e ricostruire tutti quei blocchi di ghiaccio ha già chiesto innumerevoli sforzi.";
D.q[3335] = "Quando sarai più forte potrai portarmi delle risorse dalla regione di Koalak.";
D.q[7688] = "I tuoi occhi sono iniettati di sangue, lo stesso sangue che ora copre le tue mani.\nSe vuoi sterminare altre creature, ho sempre del lavoro per te.";
D.q[7076] = "";
D.q[7329] = "";
D.q[7742] = "Buongiorno e benvenuto.\nI servizi attualmente disponibili sono i seguenti:\n- consultazione degli artigiani disponibili, tutti i mestieri.\n- agenzia immobiliare con l\'elenco di tutte le case e i recinti in vendita.\nLe sedute di massaggi privati sono riservate al direttore dell\'agenzia e al capo della milizia.";
D.q[3579] = "Canticchia \nGobriel, mentre bruciano il tuo spirito\ne l\'odio ti soffoca la vita\nBonta, si fa speranza\nperché nelle loro mani muori ogni sera!";
D.q[7674] = "Parli degli apewicubi? Contengono quello che si trovava nel lago nel momento in cui è gelato. Il che significa un po\' di tutto... C\'è del pesce surgelato, lo so che è normale, del pane surgelato e poi caramelle, chiavi e un sacco di altre cose. Una volta ci abbiamo persino tirato fuori un oggetto di allevamento!";
D.q[7689] = "Ho abbastanza gente per cacciare le creature che gironzolano vicino alle abitazioni. Al contrario non trovo nessuno che vada a cacciare le creature nelle zone più isolate dell\'isola.\nHo subito visto che noi due condividiamo un odio viscerale per le creature dell\'isola.\nEcco la lista degli animali da sterminare, soprattutto non dimenticarti di portarmi una prova del tuo lavoro.";
D.q[3586] = "Me riflettere bene situazione e me accettare.";
D.q[1145] = "Argh, ma non ti avevo chiesto di portarmi un dente? Mica vuoi farmi arrabbiare, vero?";
D.q[7263] = "";
D.q[5213] = "Bene, bene. Lo plageremo un bel po\', e ci sarà utilissimo in combattimento.";
D.q[1379] = "Delle perturbazioni... gnagnagna... Flusso magico... gnagnagna... Ah! Nessun grave rischio per Brakmar. Ecco quello che mi interessava. Tutto il resto serve solo agli scienziati, che ce ne frega a noi! \nPerché vedi, mentre tu perdevi tempo nelle caverne una divisione di spie Bontariane è entrata a Brakmar! Fortunatamente li abbiamo presi tutti... tranne uno. Proprio quello che è riuscito a fuggire con dei documenti importanti! Raggiungilo e recupera i documenti, svelto! Chiedi alle guardie e alle sentinelle che incontrerai se l\'hanno visto passare, vai!";
D.q[7675] = "Oh, una Piuma Vibrante di Pinguinotto! Che ci fa nel tuo fondoschiena? Non rispondere, non voglio saperlo.\nIgnori senza dubbio a cosa serva, vero? Meglio... Se mi dai quella piuma, te la scambio con degli Apewicubi freschi freschi appena tagliati. Che ne dici?";
D.q[7744] = "Allora, hai preso confidenza con i luoghi?\nNon esitare a parlare con gli abitanti del Borgo e dei suoi dintorni, hanno una gran quantità di problemi da risolvere.\nQuando ti sentirai pronto potrai andare ad affrontare il Conte Allarovescia e portarti via una parte delle sue ricchezze.";
D.q[5355] = "Spero che tu abbia i due oggetti che ti ho chiesto.";
D.q[5341] = "Non va ancora bene. Tenterò una nuova pozione su di lui: mi servono 1 Sangue di Pappatutto, 10 Polveri di Perlinpanpan, 10 unità di Canapa, e 2 Fiori di Kalipto. Avrei bisogno anche di qualche informazione in più sull\'isola di Otomai che dovresti poter ottenere da uno dei miei colleghi nel villaggio degli allevatori. Purtroppo non ricordo il suo nome.";
D.q[5293] = "(Sembra proprio che stiano per picchiarsi...)";
D.q[5554] = "Mi porti una buona notizia. Grazie alla crescita accelerata dei cereali, non avremo più problemi di cibo per i dragacchini. Di sicuro potremo fare la stessa cosa con gli altri cereali per nutrire le truppe.\nQuindi eccoti Scudiero.";
D.q[7676] = "Grazie a te. Tieni, prendi quanti Apewicubi vuoi.\nSe trovi altre Piume Vibranti di Pinguinotto non esitare a portarmele, ti darò in cambio altri Apewicubi, tanto ne ho uno stock intero da quando ci hai aiutati a ristabilire la nostre linee di pesca...";
D.q[2717] = "Non negare! So che hai portato uno di quei maledetti Dofus sulla nostra isola! Ti hanno visto uscire dalla casa dello Sciamano! Hai infranto la regola n°1 dei Pandikaze: \"Niente Dofus a Pandala\". Ti condanno all\'ingestione di Pandaneken fino alla morte! Sarai giustiziato domani. Portatelo in prigione e buona notte!";
D.q[7691] = "Il municipio si trova non lontano dallo zaap ed è stato recentemente riparato grazie ai continentali.\nEccoti una mappa della zona, ci ho indicato i punti importanti della regione.";
D.q[7272] = "";
D.q[5348] = "";
D.q[1239] = "Humm... mi servono delle scarpe...";
D.q[1972] = "Chiedere un altro accordo?!";
D.q[5074] = "";
D.q[7677] = "Prendi il tuo tempo e avvisami quando avrai deciso.";
D.q[7687] = "Ho visto la fiamma che brucia nel tuo sguardo. Anche tu odi gli animali, vero?\nEcco la lista degli animali da sterminare, soprattutto non dimenticarti di portarmi una prova del tuo lavoro.";
D.q[7692] = "Buongiorno e benvenuto a Frigost.\nCome avrai potuto constatare venendo qui, il Borgo non è al massimo della sua forma, ma grazie agli sforzi dei nostri valorosi cittadini il contatto col continente ha potuto essere ristabilito.";
D.q[2183] = "Locetta si è svegliata? Bene, temevo che un\'altra notte senza sensi le sarebbe stata fatale. Non immagini neanche quanto siano importanti nell\'essenza della vita. Bene, continuiamo dunque con i rimedi ancestrali. Vai a cercare una pietra in fondo alla grotta Ovest, e portala in men che non si dica all\'Orefice Shani. Lei ti spiegherà il perché di tutta questa fretta.";
D.q[7336] = "";
D.q[7254] = "";
D.q[5249] = "Ha! Un orecchino, eh? Interessante. Ho una piccola idea sul colpevole, ma è da confermare... Hmm, come posso fare? Ah, ecco! Vai da Divad alla torre e chiedigli di usare il suo potere divinatorio per trovare il proprietario di quest\'oggetto.";
D.q[1287] = "Bevi per Brakmar! La migliore città del mondo! Lotterò per sempre per la mia città!";
D.q[2535] = "La nostra dea ti ringrazia attraverso la mia bocca: questo Dofus è molto somigliante! Il Grandapan ammira gli avventurieri come te, pronti a rischiare la vita per le preziose uova di drago. Chiedigli quello che vuoi...";
D.q[4864] = "Allora, dov\'è Eturb?";
D.q[7338] = "";
D.q[7218] = "";
D.q[4832] = "";
D.q[5559] = "Hai scoperto cos\'hanno in testa i Brakmariani?";
D.q[7335] = "";
D.q[5106] = "Hai trovato una soluzione? Spero proprio di sì!";
D.q[4623] = "I nostri recenti fallimenti mi fanno andare in bestia, ma forse ho trovato un modo per annientare Bonta una volta per tutte. Mi trovavo in visita \"diplomatica\" alla taverna di Sufokia, quando mi hanno parlato di un Corno magico potentissimo. Torna laggiù e cerca più informazioni.";
D.q[4515] = "Hai già calmato Linglés?";
D.q[5701] = "Ma sei malato? Stai impazzendo? Un Anello così bello...";
D.q[3227] = "Nonostante le apparenze, i Porcos sono delle creature molto pie e il culto del Drago Maiale è molto diffuso tra di loro! C\'è anche Ugah, una divinità minore, con la testa a forma di Fung. Mio nonno diceva sempre di non credere in Ugah, ma che talvolta gli faceva paura... Ebbene io... io credo in Ugah e l\'unica cosa di cui ho paura è il Drago Maiale! Ugah è grande, fratello!";
D.q[7686] = "Siccome hai vendicato l\'affronto fatto dal Realbuk alla mia sposa, parlerò col mio amico della compagnia Asfog e Figlie perchè ti lasci usare il trasportatore.";
D.q[4290] = "Oh? Un gioiello sontuoso? Ma certo, ne ho una decina tra le mani. Prendi pure quello che ti piace. E non c\'è mica bisogno di pagare, offre la casa.";
D.q[1107] = "Aaaarggh! Il mio corno! Dov\'è il mio corno!";
D.q[7709] = "Se vuoi conoscere meglio la regione, la cosa migliore da fare è incontrare gli abitanti del Borgo.\nE\' abbastanza inutile parlare con tutti, ecco perchè ti ho fatto una lista delle personalità più interessanti.\nQuando avrai familiarizzato con tutti i luoghi torna da me, avrò dei favori da chiederti.";
D.q[5300] = "Cosa vuoi?";
D.q[7322] = "";
D.q[7266] = "";
D.q[4056] = "Ero sicuro che tu fossi qualcuno di rispettabile malgrado il tuo aspetto sospetto e il tuo sorriso sornione!\nBene, è semplice, sto cercando ogni tipo di cavalcatura, rossa, verde, rasata, pelosa, puzzolente, immatura, sterile, tutto mi interessa, tranne quelle che sono già morte.\nHahahaha!\nPortami dei certificati di cavalcature e in cambo io ti darò delle pergamene che ho trovato nella biblioteca. Puoi anche portarmi dei certificati non validi, me la sbrigherò per falsificarli.";
D.q[7269] = "";
D.q[7217] = "";
D.q[5372] = "Finirò per dare ragione a quel goblin... Ma non troppo, altrimenti ne approfitterà per ribellarsi.";
D.q[4230] = "Si tratta di una tecnica particolare, perché non conosciamo assolutamente questo batterio! Pensiamo che sia apparso all\'inizio della formazione del mondo, quando gli uomini conoscevano le sottigliezze di tutti gli elementi.";
D.q[7748] = "Mentre conducevamo un esperimento sui cereali ho pensato che potremmo modificarli in modo che possano essere utilizzabili nella fabbricazione di diversi alimenti per aumentarne la rendita, per esempio creando dei biscotti. Per fare questo mi servono 60 Semi di Granola, che abbondano sulle creature della Foresta dei Pini Perduti, e 10 Semi di Pigna per studiarne la loro eccezionale resistenza al freddo. Puoi incaricarti di portarmeli?";
D.q[3448] = "Tu avere ricetta? Bene! Tu andare a cercare ingredienti, io cucinare.";
D.q[2533] = "Hai notato? Ripeti sempre la fine delle mie frasi... Che strana questa mania... Ma lasciamo stare! Gli antenati dei Pandawa prima erano solidi e vigorosi.\nAllattati dalla più tenera infanzia con il latte di Bambù fermentato, i nostri avi apprendevano molto presto la legge delle tre B...";
D.q[5071] = "";
D.q[5194] = "Rieccoti. Ho una nuova missione per te. Abbiamo saputo che un capo goblin abbastanza importante, chiamato Ronan il Barbaro, è stato appena catturato da un convoglio Bontariano. Voglio che lo intercetti e che porti Ronan qui: potrebbe esserci utile in seguito.\nUna spia mi ha detto d\'aver visto il convoglio alle Montagne dei Croccaroc, mentre si dirigeva verso Astrub, sarà meglio se ti sbrighi prima che raggiunga la città dei mercenari.";
D.q[7690] = "Buongiorno e benvenuto al Borgo di Frigost. Hai fatto un buon viaggio?\nNon vedo camicie a fiori e bermuda da molto tempo, ma credo ti convenga coprirti, a meno che tu non voglia ammalarti.\nSe non l\'hai già fatto, ti invito a cercare la nostra Sindaco, sarà un piacere per lei accoglierti e mostrarti i luoghi.";
D.q[4359] = "Non ho visto nessun Ecaflip, ma ieri ho sentito delle guardie parlare di una banda d\'Ecaflip che ultimamente creano dei problemi. Se può aiutarti...";
D.q[7749] = "Albert Pes mi ha detto che i Pinguinotti sono così resistenti perchè mangiano semi ricchi in ferro. Magari per noi è un modo per accrescere la resistenza dei nostri cereali.\nPortami 65 Semi di Lenticchia e ti ricompenserò.";
D.q[660] = "Sulla tua strada incontrerai moltissime porte chiuse, alcune nascondono creature che è meglio non risvegliare, ma altre potrebbero farti diventare ricco e valoroso.\n\nLa porta che si trova dietro di me appartiene ad un dongione di allenamento. L\'ho riempito di Pappatutto, ma per entrare dovrai trovare una chiave che ho nascosto dentro uno dei loro simili.";
D.q[764] = "Fare parte di una giuria > fare delle mappe per un tribunale...";
D.q[1554] = "Magnifico, sapevo che ce l\'avresti fatta! Per ricompensarti, prendi questo uovo di Bwak. Di solito io me ne servo per concepire delle pozioni, ma forse tu gli troverai un\'altra utilità.";
D.q[7594] = "Quel che vedi laggiù è il tesoro di tutta una vita dedicata a caccia ed avventura, e non è mica poco.\nQuando anche tu avrai vissuto tante avventure quante ne ho vissute io vorrai senza dubbio ritirarti, ed è allora che la noia ti assalirà.\nIo sono stato membro dei Banditi, ho sconfitto il Mega Croccaroc nella lotta e battuto Dragnute L\'Irascibile nella corsa. Ho assistito alla cattura del demone Uk\'Not\'Allag che terrorizzava Amakna, ho scoperto l\'isola di Otomai con il mio amico, il Capitano Kradoc, ho viaggiato sull\'isola di Nawal ed ho incontrato il Conte Allarovescia in persona.";
D.q[7253] = "";
D.q[5221] = "Hai sicuramente notato il clima di tensione che regna in città, è intollerabile. Domerei volentieri tutti i dissidenti con la forza, ma ignoro l\'identità di una buona parte di loro.\nVorrei che tu andassi da Kalfen, un anziano membro del Triumvirato che si è... fortuitamente... ritrovato in cella. Fagli questa proposta: la libertà in cambio della sua propaganda a favore di Djaul presso il suo ordine - l\'Ordine dello Spirito Malsano.";
D.q[5314] = "Sei qui per l\'indennità rischi? Meglio tardi che mai.";
D.q[1186] = "Questa torre? Si tratta del punto d\'incontro dei tre Ordini di Bonta più potenti: l\'Ordine dell\'Occhio Attento, quello dello Spirito Redentore e quello del Cuore Valoroso.";
D.q[4011] = "Bene, ora che mi hai dimostrato la tua forza... accetto, servirò il tuo principe.";
D.q[1177] = "Ciao fedele discepolo di Menalt, vedo che ti sei fatto più massiccio dal nostro ultimo incontro!\nCosa posso fare per te #1?";
D.q[7750] = "Png(1239) e Messaggio(7746)";
D.q[5012] = "";
D.q[4459] = "Oto Mustam mi ha rimandato qui. Devo fare in modo che la milizia di Bonta sia il meno efficiente possibile.";
D.q[2059] = "Cosa vuoi?";
D.q[2144] = "Ooooh, ma perché... Dai, perfa... fai uno sforzo... Portami l\'estratto del fiore di Dizbi così potrò annusarne un po\' mentre contemplo la natura seduto all\'ombra del mio castagno preferito.";
D.q[7710] = "Grazie, non è una cosa enorme, ma ci aiuterà molto. Ah sicuro non è come prima. Mi ricordo ancora delle lunghe file di carri pieni di cereali che facevano la spola fra i campi e il porto...\nMa questo appartiene al passato, inutile pensarci.";
D.q[3955] = "Ah, quel caro Uba... Tieni, prendi questo taccuino e scrivici tutto quello che imparerai, ti sarà utile.";
D.q[2643] = "AAAAAAAAAAAAAH! Vattene! Vattene! Vattene! Vattene!";
D.q[4592] = "Non può andare tanto veloce nelle sue condizioni, ma non perdere tempo, un altro Brakmariano potrebbe trovarlo e impadronirsi dei documenti.";
D.q[7694] = "Ah, bene. Abitualmente è Annetta Dimposta che si incarica di portarmi i cereali, ma ha la tendenza a fantasticare e spesso dimentica il suo lavoro. Ho provato molte volte a farla ragionare, ma vedi, è nella natura di un Sadida e non si può lottare contro la natura delle cose. Noi Frigostiani lo sappiamo bene...\nBene, mi arrangerò con te, rimpiazzala e portami una decina di Frostiss.";
D.q[1526] = "Ma cosa dici! Non ci sei ancora neanche andato! Mi prendi per un imbecille?";
D.q[3915] = "Se ho visto un nobile? Sì certo, anzi ne ho visti molti, ma con tutto quello che bevono qui, l\'unica donna che possono sposare è la principessa pinta!";
D.q[3042] = "Aaarghh, come mi sento debole! Non ho più molta energia!";
D.q[7753] = "Grazie, con il tuo aiuto possiamo continuare i nostri esperimenti sui cereali, chissà, magari un giorno riusciremo a rilanciare di nuovo l\'agricoltura abbastanza da sfidare di nuovo Amakna.";
D.q[7226] = "";
D.q[5274] = "I feriti soffrono, hai portato qualcosa che dia loro sollievo?";
D.q[5853] = "";
D.q[5100] = "Bava di pappatutto, sangue di Trooll, e.... AAARGH! Mi hai interrotto proprio nel momento SBAGLIATO! Cosa vuoi?";
D.q[5110] = "Bene, bene. Mi occuperò di piegare queste miserabili creature alla mia volontà e di trasformarle in guardie.";
D.q[7711] = "";
D.q[3615] = "Gobmiket resta solo, che destino difficile. Nessuna energia per vivere. Mio cuore non batte più. Addio.";
D.q[3620] = "Te volere piume? Me scambiare con piscio bwork.";
D.q[278] = "Hu! Hi! Hi! Ciao! Mi chiamo Mori Arty, sono il più grande brigante di tutti i tempi. Quando mi hanno arrestato ho dovuto pelare patate per più di dieci anni. Ma adesso sono di nuovo libero, e ricomincerò a fare quello che facevo ogni notte: tentare di conquistare il mondo!";
D.q[5272] = "Congratulazioni, ti sei battuto valorosamente. Sei un esempio per molte delle nostre giovani recrute. Ecco un regalino per rendere onore al tuo coraggio, così potrai raccontare le tue imprese negli alberghi o pagarti delle meritate vacanze quando avremo risolto tutti questi problemi.";
D.q[1913] = "Se ne va? Lo licenzio prima io! Bene, adesso devi trovarmi un nuovo fattorino! Mi spiace, ma ci sei solo te a portata di mano...";
D.q[7712] = "No, non voglio il tuo liquame qui. Comincio ad averne abbastanza di questo scherzo idiota.\nAh, non distribuisci letame? A vederti così... credevo... ehm, no niente...\nMa aspetta, non sei di qua, è evidente! Dimentica quindi quella storia di letami e benvenuto nel mio atelier.\nVuoi una tisana?";
D.q[2623] = "Grimph\n*Fa finta di sgranocchiare un bambù*";
D.q[4978] = "";
D.q[5076] = "A furia di scavare, i Wabbit hanno scoperto un sotterraneo. Sento che si nasconde una presenza demoniaca all\'interno, ma potrebbe essere una trappola. Quindi ci andrai per primo per tastare il terreno, e quando sarai andato fino in fondo, torna a farmi il resoconto.\nNel frattempo ordinerò ai Wabbit di occuparsi della pozione.";
D.q[7755] = "Ah, ogni tanto penso che l\'invenzione del Conte avrebbe dovuto farci approfittare di cicli di coltura più lunghi che permettessero ai raccolti di sopravvivere all\'inverno corto ma rigoroso... e invece ci siamo trovati con l\'inverno tutto l\'anno e i nostri raccolti abbondanti non sono che un lontano ricordo....\nMi hai portato i Semi di Lenticchia? Grazie, incrociandoli con gli altri cereali dovremmo ottenere nuove specie più resistenti.";
D.q[7713] = "";
D.q[486] = "Hahaha, queste missioni segrete sono riservate ai maestri del clan.";
D.q[4193] = "Otomai ha voluto portare su quest\'isola una coppia di ogni creatura incontrata. L\'ha fatto perché la sua idea era quella di farle riprodurre, di incrociarle e di studiare l\'evoluzione degli ibridi che creava. Ma per realizzare certi esperimenti, aveva bisogno di quantità notevoli di materiale alchemico e di cibo per le creature.\nPer questo io facevo regolarmente la strada da e verso quest\'isola.\nLa cartografia dei mari era, però, molto approssimativa e ci succedeva di fare delle tappe non programmate sull\'isola di Moon o sull\'isola dei Naufraghi.";
D.q[5389] = "";
D.q[5896] = "";
D.q[2645] = "Gempa? Hmm, a quest\'ora deve allenarsi nel Dojo, o cercare enormi quantità di cibo.";
D.q[2366] = "Ci sono dei mostri enormi laggiù... E in più, si tratta di specie sconosciute da mio nonno, e che metterebbero fifa persino ad uno Yop! Per non parlare di tutte quelle vecchie leggende...";
D.q[7756] = "Png(1239) e Messaggio(7746)";
D.q[4238] = "Il segreto di Otomai è al sicuro. Questa eccellente creazione, sviluppata con i migliori batteri dell\'isola, è una macchina mangiatutto. Le caratteristiche dimensionali del Plasmogrin permettono a questa creatura di conservare il suo stomaco in un\'altra dimensione. È quasi immortale!";
D.q[7757] = "Png(1239) e Messaggio(7746)";
D.q[4895] = "";
D.q[5517] = "Cosa posso fare per te, abitante di Brakmar?";
D.q[7715] = "";
D.q[7758] = "Png(1239) e Messaggio(7746)";
D.q[3990] = "Pew gli dei, che tipo di mostwo ewa ? Il mio valowe ha vinto sulla sua cwudeltà. Ma questo non mi distwawwà dalla mia missione, devo sposawe una pwincipessa! Diventa un po\' più fowte e potwai fawe pawte del mio seguito!";
D.q[5105] = "Dei BONTARIANI? Che fastidio. Se hanno già frugato il tempio, forse avranno trovato il mio antro, e nelle mie condizioni... ebbene... potrei... stancarmi a massacrarli tutti.\nHum. Il problema è che nessuno vuole controllare un posto così deserto. Vai a Brakmar e trova il modo di farmi mandare almeno qualche guardia.";
D.q[5809] = "";
D.q[1701] = "Ciao #1, cosa posso fare per te?";
D.q[7759] = "Una volta, l\'agricoltura era fiorente perchè il suolo dell\'isola, composto di polvere vulcanica, era molto ricco in minerali.\nIl solo ostacolo era l\'inverno, molto breve, ma incredibilmente intenso. Talmente intenso che ghiacciava il ciclo di tutte le colture , obbligandoci a seminare, far crescere e raccogliere solo durante il periodo temperato. Tutte le colture seminate prima dell\'inverno venivano distrutte dal gelo.";
D.q[5597] = "Dei Semi di Papavero? Interessante... E mi dici che gliene servono 20? Credo d\'avere un\'idea: sostituiremo i Semi di Papavero con dei Semi di Scorbuto. Se questo Merlisello è un incapace come dice Finch Aticus, non ci capirà un\'acca. Ho qui 20 Semi di Scorbuto appena raccolti, li immergerò in un Veleno sferzante e modificherò il loro aspetto con una Tintura Magica Verdastra. Vammi a prendere questi oggetti e torna subito, non bisogna perdere troppo tempo.";
D.q[1352] = "*Forbice*\nHum, ho perso, sei piuttosto bravo, passiamo alla terza mano.";
D.q[7716] = "";
D.q[523] = "Ahahahah! Non sono più solo! Il mio desiderio è stato esaudito! Benvenuto sull\'isola di Moon, coinquilino. Sono Gropinson Crulué. Ah, ma forse mi sono già presentato. Non ricordo più, arriva così tanta gente nuova da un po\' di tempo, ahahah!";
D.q[6754] = "Attento, Oshima lascia entrare solo certe anime nel suo santuario. Se ti senti pronto a portare l\'involucro etereo di un fantasma per un po\' di tempo allora potrai entrare. Combatti le creature del santuario e Oshima ti concederà un favore. Con quale forma desideri entrare?";
D.q[1353] = "*Pietra* \nHum, ho perso, sei piuttosto bravo, passiamo alla terza mano.";
D.q[7714] = "Non ho tempo!\nBevi un litro d\'alcool, immergi la ferita nell\'acqua bollente e copri la piaga con del bendaggio sterilizzato con bava di Pappabuk.\nEh? Cosa? Non sei ferito?\nOh, scusa, cosa posso fare per te? Fai veloce, non ho molto tempo da dedicarti perchè al ritmo con cui la Ros Olia si estende, avremo presto un\'epidemia. \nDevo trovare presto un vaccino efficace prima che sia troppo tardi.";
D.q[6034] = "";
D.q[2496] = "Perfetto! Vai da uno dei nostri fantastici mercanti ambulanti! Sono abilitati a riscuotere la tassa da parte del Grandapan, e ti alleggeriranno volentieri di qualche kama. Viva Pandala! Viva il Grandapan!";
D.q[4901] = "";
D.q[7760] = "Non me l\'aspettavo! E\' raro vedere persone di buona volontà ai giorni nostri.\nMi servono campioncini di sangue di Pappabuk. Vai nei campi e prelevane una mezza dozzina.\nAttenzione però: mi servono unicamente campioncini prelevati da Pappabuk adulti malati, non troppo giovani e non troppo vecchi.";
D.q[4206] = "Arrivare a questa altezza senza essersi fatto mangiare è veramente un\'impresa. Immagino che tu ti senta pronto ad affrontare il Maestro del luogo, l\'incredibile Kimbo. È il Guardiano di quest\'albero, ed è rispettato da tutte le creature dell\'Isola. Era già qui molto prima che arrivasse Otomai con i suoi esperimenti, e fino ad ora, tutti coloro che hanno osato sfidarlo si sono fatti umiliare.\nQuesta creatura adora giocare con gli avventurieri, ha una scaltrezza senza eguali, e per questo è una creatura che Otomai adora senza mezzi termini.";
D.q[5745] = "";
D.q[7718] = "";
D.q[7719] = "Ciao, sono sicura che cerchi pesce fresco. Sei finito nel posto giusto, il mio è il pesce più fresco, qualunque sia il periodo dell\'anno. Non si può dire altrettanto della povera Lucetta, ma così è la vita.\nLibero di non credermi se non vuoi, ma ho visto Mac Ghiacciver flirtare con la piccola Trice. Cosa direbbe la madre se lo sapesse...";
D.q[6905] = "";
D.q[982] = "Sei #1, ti ha mandato Amayiro per portarmi i denti di pappatutto, giusto?";
D.q[5525] = "Grazie, per merito tuo posso ingrandire la mia proprietà a Bonta. In bocca al lupo per il seguito.";
D.q[5282] = "Ciao, hai trovato la caverna o un indizio qualsiasi sull\'autore di questa aggressione?";
D.q[5749] = "";
D.q[7720] = "Nella mia famiglia siamo tutti allevatori di animali da 5 generazioni.\nLa glaciazione mi ha permesso di perfezionarmi, e al momento sono la miglior addestratrice di Baubau della storia di Frigost. Vedi quei Baubau là? Sono io che li ho addestrati.\nLa chiave per la riuscita di un buon addestramento è la fermezza e non saranno i proprietari di Baubau delle nevi a dire il contrario.\nNon ti sbagli, i miei talenti di addestratrice si applicano a quasi tutta la totalità della fauna di Frigost, ma i Baubau sono la mia specialità.";
D.q[2969] = "Ma cosa vuoi che ne sappia, io? Non sono mica allevatore di Tofu!";
D.q[3137] = "Perfetto! È incredibile, il mio sogno si sta realizzando, finalmente sarò prestante come il Culosse!\nHai proprio meritato la chiave che ti ho appena dato, ma ricordati, Skunk è un maestro Aniripsa, è molto pericoloso, che io sappia nessuno è ancora riuscito a batterlo!\nPer arrivare fin da lui, dovrai attraversare una valle popolata di pericolosi Koalak, e presentare questa chiave al guardiano della tana di Skunk...";
D.q[5390] = "Vuoi la formula della pozione di allegria?\nNessun problema.";
D.q[5095] = "";
D.q[2198] = "Perfetto. Eccoci, ahahah! Hem! Scusami! Molto bene, diamo un\'occhiata... *Chronokwartz si concentra sulla caduta dell\'Epyss, poi qualche cosa la fulmina e lascia cadere la clessidra che si spezza*. Diavolo! Cos\'è questa visione! Lasciami riprendere fiato... oh, misericordia, abbiamo un problema!";
D.q[5365] = "Ah, eccoti! Ti stavo aspettando! Ho bisogno di certi ingredienti per un rituale di cui ti parlerò più tardi. Mi servono cinque unità di sangue di Vampiro, cinque pietre di Croccaroc speciali che troverai addosso al Kirbul l\'Eroso nel dongione Croccaroc, e un Maiale di Farle vivo che troverai senza dubbio nel dongione del Drago Maiale. Mi servono anche quattro asce Agrida per equipaggiare le mie guardie.";
D.q[7361] = "";
D.q[7721] = "";
D.q[5766] = "Cominci a cavartela e si è già parlato di te in alcune taverne. Ecco perché ritornare Neutro ti costerà 2000 kama. \nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[5398] = "Sono proprio io l\'incantatore Helas di Ciwillekh, perché?";
D.q[7470] = "";
D.q[7471] = "";
D.q[6443] = "Buongiorno e benvenuto alla Taverna della Bagrutta. Qui troverai tutto ciò di cui hai bisogno per rinfrescarti. Mi chiamo Ecarezza, posso essere la tua cameriera esclusiva durante il tuo soggiorno nel nostro stabilimento, se lo desideri, ovviamente. Maoooo.";
D.q[1911] = "Bé, cosa credi, ho un appuntamento e una seccatura quindi... ah... kof kof, uff e sono anche malato. Non posso uscire di casa prima di stasera, ordine del medico. Nessuna consegna eccezionale oggi.";
D.q[5770] = "Cominci a far parlare di te al di fuori delle mura della tua città. Un\'ottima cosa per te, ma ritornare Neutro ti sarà più difficile. Quindi dovrai sborsare 32000 kama. \nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[3254] = "Pfiouuuuuuu... Fa veramente troppo caldo qui...\nNon ti stanchi mai di tutto questo sole e di quest\'afa?\n\n*suda a goccioloni*\n\nHum, io ho proprio voglia di tornare sulla mia isoletta...";
D.q[3614] = "Gobrosa non venire. Che rabbia! Uccidi suoi pìu preferiti, lei verrà!";
D.q[7723] = "";
D.q[5768] = "Ah, quindi, ti avvicini alla corte dei grandi? In questo caso ritornare Neutro ti costerà 8000 kama. \nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[5967] = "";
D.q[5764] = "Visto che sei giovane e che le tue competenze lasciano a desiderare, ritornare Neutro ti costerà solo 500 kama.\nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[34] = "Ciao compagno!\nHo bisogno di qualche ingrediente per dare un po\' di gusto al mio pane. Se mi porti una cawota, ti darò un sacchetto di sale come ricompensa.";
D.q[5481] = "Non ho più niente da chiederti. Il mio potere cresce giorno dopo giorno e ben presto avrò il controllo totale della città. E allora, Djaul potrà rivendicare ciò che gli appartiene...";
D.q[5281] = "";
D.q[6422] = "Non sarai mica un gran rompipalle? Fammi vedere la tua spada.\n...\nHo già visto questo tipo di spada nelle mani di Ecaflip che vivono al di fuori della città. Non so bene dove precisamente, se pensi che mi ricordi di tutti i luoghi che bazzico. Tra l\'altro, a proposito di bazzicare, ti avevo chiesto di andartene e allora cosa ci fai ancora qui? Sei innamorato?";
D.q[5516] = "Buongiorno, sei di sicuro al corrente che le battaglie tra le città rivali sono sempre più frequenti. Per questa ragione, numerosi soldati ne hanno abbastanza di questi combattimenti incessanti e disertano alla prima occasione, diventando dei fuggitivi. Il nostro buon re Allister ha pietà di queste persone e dà loro una seconda possibilità qui, sul territorio di Amakna. Quindi posso redigere dei documenti ufficiali che attestano la neutralità delle persone che vengono da me e che la chiedono.";
D.q[7724] = "";
D.q[4350] = "Non capisci quello che dico o hai un cencio ficcato nelle orecchie? Ho bisogno di un miliziano che abbia già provato il suo valore e ricevuto il suo primo permesso. Quello lì è un grosso incompetente, non posso affidargli una missione importante.";
D.q[1333] = "Hmm, tutto porta a credere che il colpevole sia lui, ma manca ancora qualcosa...";
D.q[6773] = "";
D.q[5752] = "";
D.q[4965] = "Ho ridotto in schiavitù i Wabbit che sono arrivati. La costruzione del tempio può finalmente iniziare.\nI Wabbit non sono proprio dei grandi lavoratori, ma aspettando di trovare di meglio, mi accontenterò...";
D.q[4952] = "Cerca delle informazioni sulle catene che mi imprigionano. È stato Allister, che sia maledetto, ad avermele messe: perquisisci a menadito il castello di Amakna e trova un modo di liberarmi.";
D.q[2633] = "Ciao nobile avventuriero, Sli Dento si inchina davanti a te, posso aiutarti in qualche modo?";
D.q[6287] = "Il Consigliere Boyowa non ti ha cacciato in prigione? Voglio dire, è andata bene con il Consigliere Boyowa, gli hai consegnato la cassa di merce?";
D.q[2782] = "Psh...blabla...Pshh...falso....pashh...dofus...blah..shh...\nHmm ma sto parlando da solo, no?";
D.q[6600] = "Buongiorno, nobile servitore di Bonta. Come procede la missione che ti ho affidato per la più grande gloria di Bonta?";
D.q[5754] = "";
D.q[7362] = "";
D.q[6105] = "";
D.q[6106] = "";
D.q[5557] = "Ora devo trovare dove ho messo la formula...\nAllora, è molto semplice: metti una goccia di questa pozione su ogni seme, li pianti e quando avrai finito, leggi ad alta voce il testo scritto su questa pergamena. Sai leggere, no?\nQuesto incantesimo funziona solo sull\'avena, quindi bisogna trovare un campo in cui usarlo. È importante fare bene le cose, ecco perché l\'aiuto di molti Contadini e Alchimisti è necessario. Ho mandato qualcuno a preparare un campo per te. T\'indicherò dove sulla mappa, in modo che tu non perda tempo a cercarlo.";
D.q[7727] = "Maledette bestie! Se il Conte non ci avesse traditi le mie miniere non sarebbero infestate a questo modo. Spero che uno di questi giorni qualcuno di abbastanza forte lo punisca. Quel che ci serve è gente di Amakna, che lo prenda a calci nel sedere, perchè i buffoni che sono qui non sono riusciti a far nulla.\nNel frattempo le mie miniere sono infestate e non c\'è modo di estrarre l\' Ossidiana.";
D.q[3268] = "Ciao pioniere dell\'estremo!\nSono sicuro che ti piacerebbe provare i vecchi e i nuovi mestieri!";
D.q[7349] = "";
D.q[5845] = "";
D.q[5755] = "";
D.q[2179] = "Ah, è il fiore che ho chiesto per il rimedio di Locetta? Molto bene, vado a preparare la pozione. Ti avverto che questo caso va oltre le mie conoscenze, spero che funzioni... Ecco, portala subito a Yol.";
D.q[352] = "Questa linfa è quasi magica, se correttamente utilizzata permette di ridare vita ad un Bastone in Radice di Alberagno, e renderlo estremamente più potente. Informati da un esperto Intagliatore di Bastoni, potrà sicuramente fabbricarti un bastone così se gli porti questa linfa...\nMa fai attenzione: questa linfa rilavorata è da usare con precauzione. È stato un Alchimista molto famoso di nome Adam Ehehv a rilavorarla. Si è persino trasformato in Alberagno per qualche ora ingoiando un po\' di questa linfa.";
D.q[7348] = "";
D.q[5002] = "";
D.q[7372] = "";
D.q[7728] = "";
D.q[5454] = "Arrosto di pappatutto al succo di kokoko! Pizza quattro blop! Spiedino di tofu grigliato! Eh, hum... vuoi qualcosa?";
D.q[1677] = "VIENI A RILASSARTI DIVERTENDOTI GRAZIE ALLE NOSTRE BESTIOLINE GIALLE PREFERITE!\nCiao, leggo nel tuo sguardo che hai bisogno di sfogarti un po\', di espellere la tensione della routine: zaapo, crafto, dormo. Bene, non andare oltre, ti propongo di farlo qua, e in più con la possibilità di vincere un sacco di soldi! E tutto questo per soli 20 kama!";
D.q[5856] = "";
D.q[5771] = "Perfino Ronan il Barbaro deve tremare di paura al tuo nome. Tanto vale dirti che ciò non conviene per i miei affari perché avrò più documenti da compilare. E sai cosa vuol dire? Lavorare di più, quindi guadagnare di più. Invece tu dovrai pagare di più, ecco perché la modica somma di 64000 kama per ritornare Neutro. \nInvece, se vuoi raggiungere un schieramento minoritario, non dimenticare che posso farti cambiare fedeltà gratis.";
D.q[7729] = "";
D.q[5940] = "";
D.q[5005] = "";
D.q[6469] = "Ma buongiorno, sei tu quello di corvé per l\'approvvigionamento? Devi aver fatto una bella stupidaggine per ritrovarti qui, a meno che tu non abbia appena integrato la milizia e che Amayiro abbia voluto farti fare un po\' di gavetta. In ogni modo, grazie per il prosciutto.";
D.q[5756] = "";
D.q[7730] = "";
D.q[5370] = "Ho ricevuto degli ordini per te: devi andare alla torre di Gisgul e incontrare... tu sai chi.";
D.q[4974] = "Sì? Vuoi scusarti per aver tramato contro di me servendo stupidamente Oto Mustam e Domen?";
D.q[5258] = "Parecchi, ma ho ancora dei colloqui prima di scegliere te. Passa più tardi.";
D.q[5279] = "Ciao. Quello che ti dirò non deve uscire da queste mura.\nMaiman lo Stabilizzatore, Protettore del mese di Octobel, è stato aggredito ma si rifiuta di dirne di più.";
D.q[7731] = "";
D.q[5592] = "Vai a fare un giro a Bonta e chiedi a Finch Aticus se ci sono delle novità.";
D.q[6249] = "Buongiorno, cosa fai qui da me? Se vuoi fare una rapina in casa mia, ti avviso: mio zio Starky è capitano della milizia di Bonta e te la farà pagare cara.";
D.q[4948] = "Qualcuno d\'importante vuole vederti. Si trova a Nord-Est, nella torre di Gisgul.\nAscoltami bene, non potrai vederlo se non fai quel che ti dico.\nDevi mettere un Liquido Vampiresco davanti a ciascuna statua di demone, te ne serviranno 2 in tutto. Dovrai avere anche 10 Stomaco di Pappatutto. \nUna volta che avrai gli oggetti, trova quattro Brakmariani che hanno già portato Trof Hapyus, e portali con te, si dovranno mettere sulle ossa.\nDovrai anche trovare un Feca che abbia l\'incantesimo Scienza del Bastone, e che non sia un seguace della nostra causa, per sacrificarlo, e anche lui dovrà avere su di se un Liquido Vampiresco.\nQuando tutto sarà a posto sacrifica il Feca, poi dona come offerta gli stomaci di pappatutto. Avrai allora accesso al passaggio segreto a Sud-Est della sala, nascosto tra i due pilastri, che ti condurrà da colui che ha chiesto di te.";
D.q[2150] = "Sbrigati ad andare dal Forgiatore. Fonderà questi kama per fabbricarti una lama degna del tuo braccio. Ti ho indicato la strada, ora non ti rimane che seguire la bussola. Dopo torna da me.";
D.q[5283] = "";
D.q[3541] = "Ciao giovane Ecaflip. So che voi Ecaflip non vedete l\'ora di partire per l\'avventura e sfidare la vostra fortuna. \nSe ti piace mettere la vita in gioco, ho qualche cosa per te. Sei pronto a rischiare?";
D.q[7732] = "Buongiorno, sai che è grazie a me ed ai miei uomini se siamo riusciti a stabilire un collegamento con Amakna? Beh, non è proprio Amakna, ma è come se lo fosse.\nAbbiamo lavorato per molti decenni per immagazzinare il calore e convogliarlo fino al porto, per mettere a punto un sistema di riscaldamento a vapore. Ora dobbiamo riuscire a scongelare la restante parte del porto e questa è una cosa lunga da fare.";
D.q[3314] = "Voglio caaaaaaaaaaricare!!! Portami in fretta quei Dragacchini.";
D.q[5759] = "";
D.q[4605] = "Sbrigati! Tutto è indicato sulla lista che ti ho dato.";
D.q[6098] = "";
D.q[7465] = "Buongiorno, vedo che possiedi un Orbe Magico. Dispone di due poteri, puoi utilizzarne solo uno. Ne vuoi sapere di più?";
D.q[7733] = "Te ne capisci di alchimia? Ah, ecco spiegato lo stato dei tuoi vestiti...\nMeglio, fa piacere incontrare qualcuno con un quoziente intellettivo superiore a quello di un Pappabuk.\nHo un piccolo favore da chiederti, se lo chiedo a te è perchè non posso contare sui miei concittadini. Vedi, ci sono troppi cittadini, se capisci quel che intendo...\nCi sono talmente tante persone malfidate che non posso lasciare il mio atelier senza sorveglianza, ma le mie riserve di Bucaneve si stanno esaurendo. Puoi portarmene una decina?";
D.q[4973] = "Cosa? COME? Osi criticare il mio piano? Fai attenzione a quello che dici, cretino! Farai come dico io e basta!\nSe hai bisogno di aiuto vallo a chiedere agli altri idioti della torre di Brakmar, invece di venire a disturbare me!";
D.q[6785] = "Olledrob Oterges? Non viene più da quando ha avuto una reazione allergica a contatto con i peli di Maomao e d\'Arakne. Peccato, era un buon cliente.";
D.q[6103] = "";
D.q[6100] = "";
D.q[986] = "Usa la siwinga e pweleva il sangue al wabbit GM dopo avewlo stowdito.\nTi pwometto una wicompensa intewessante se mi powti l\'analisi del suo sangue.";
D.q[5780] = "";
D.q[5839] = "";
D.q[4997] = "Sei sordo, o cosa?\nIl mio tempo è prezioso, e non ho voglia di perderne con te.\nPerché non vai nella sala del trono del castello di Allister e consulti l\'agenda di Fallanster?\nSarà più facile e smetterai di annoiarmi.";
D.q[5243] = "L\'esito era prevedibile. Questa spada mi dà ENORMI poteri. Bene, prendi queste pozioni per recuperare le forze e vai a cercare un Hamburger di Trool, delle Patatine di Girasole Selvatico, e una decina di palloni rossi alla Fiera del Trool.";
D.q[3668] = "Di più!";
D.q[5241] = "Hai fatto la tua parte del lavoro, ora finiremo senza di te. In realtà, dei guerrieri Brakmariani - compreso Ronan - stanno attuando una diversione su Bonta... mentre altri si occupano del piano principale.\nPerché non approfittiamo di questo momento di respiro per farci un duello!";
D.q[5820] = "";
D.q[4950] = "Non hai più niente da fare qui. Vai via, ho dei colloqui molto importanti in questo momento.";
D.q[7734] = "Oh, sono così belle... Prima della glaciazione centinaia di specie di piante differenti riempivano Frigost. Ma i Frigostiani hanno preferito seguire il Conte e mi prendevano in giro... Ora impareranno, quegli idioti!\nParlando di fiori, dovresti visitare le nostre serre, fuori dal Borgo. I miei amici Truffo e Bisalius lavorano su nuove specie. Non puoi non vederle, ce ne sono moltissime nei campi intorno al Borgo.";
D.q[7074] = "";
D.q[630] = "Certe ossa del luogo sono semplicemente prodigiose! Dopo la morte si animano di vita propria. Un soggetto appassionante... Potrei studiarlo fino alla morte! hahaha!";
D.q[1139] = "Rapido, efficace, silenzioso, tutti aggettivi che non ti corrispondono per niente.\n#1, hai visto il tempo che ci hai messo per portarmi questa poltiglia?\nE in più ho appena scoperto che quel maledetto tabi è immune ai veleni comuni. Solo uno magico potrebbe funzionare.";
D.q[35] = "Ciao straniero.\nIo sono una famosissima Orefice ad Amakna, tutti vogliono le mie nuove creazioni.\nPer questo ultimamente sono molto occupata. Se cerchi lavoro, posso dartene io.";
D.q[7735] = "Eh, non parlarmene. Con l\'arrivo di tutti questi continentali le mie riserve di assottigliano a vista d\'occhio. Ho talmente paura di non averne per i prossimi mesi, che ho smesso di darne al mio Maomao. Ora, povero piccolo Indus, ha fame.\nCosa ne dici di guadagnare qualche kama? Se mi porti 10 Pescetti saprò dimostrarmi generosa.";
D.q[5740] = "";
D.q[5744] = "";
D.q[5366] = "Hai gli ingredienti che mi servono?";
D.q[4454] = "50000 kama? Per questa somma, sono pronto a diventare dei vostri! Ma non hai l\'aria di avere così tanti kama...";
D.q[134] = "Ciao, mi chiamo Musol Ungo e sono un appassionato del gioco d\'azzardo, posso proporti di partecipare alla Grande Lotteria di Amakna se vuoi.\nPuoi anche giocare con me al gioco \"Le Pinte del Caso\" o al gioco di carte \"Tragic The Gardening\".";
D.q[7736] = "Grazie, se tutti facessero come te le mie riserve di Pescetti durerebbero di più.\nHo sentito dire che Albert Pes, il nostro dottore, ha contratto una brutta malattia quando era giovane e folle. Sembra anche che la sua ricerca del vaccino contro la Ros Olia non sia altro che un pretesto per trovare un rimedio per la sua malattia...\nSe non me l\'avesse detto una persona di cui mi fido, non te ne avrei mai parlato.";
D.q[5823] = "";
D.q[5122] = "Uk\'Not\'Allag mi ha nominato luogotenente-colonello proprio quando sono arrivato! Vabbé, non ho nessuna responsabilità, ma chiamarsi \"Luogotenente-colonnello Kapi Tagno\" è una figata, no?";
D.q[5860] = "";
D.q[3755] = "A volte ho l\'impressione di essere manipolato da un\'entità superiore che detta i miei atti e le mie parole... no, non uno dei dodici dei, ma qualcos\'altro...";
D.q[4163] = "A volte si dimentica delle piccole attenzioni che fanno respirare una coppia, e di quel piccolo gioco di seduzione che la tiene in vita.\nPrima abitavamo a Bonta ed eravamo molto innamorati.\nMa con il tempo, il nostro amore si è adagiato, ha perso la fiamma che l\'animava i primi tempi.\nCosì, lui ha avuto l\'idea di portarmi su quest\'isola insolita, per ricominciare da capo, una nuova vita, lontani da tutto quel conformismo urbano che snatura le nostre relazioni.";
D.q[7737] = "Perchè te lo dico? Tutto il mio personale è sparito nel momento in cui sono apparse le prime creature nelle miniere. Il Conte mi ha tradito, i Frigostiani mi hanno tradito... Si, potrebbe essere peggio...\nHo bisogno di ossidiana per fondere delle leghe per aggiustare il sistema di tubature che alimenta il porto. Puoi portarmene una dozzina?";
D.q[5918] = "";
D.q[5824] = "";
D.q[5645] = "";
D.q[4262] = "";
D.q[4261] = "";
D.q[4251] = "";
D.q[7738] = "Sei più bravo di quel che sembra. Abbiamo bisogno di gente come te per andare dal Conte e fargliela pagare.";
D.q[4252] = "";
D.q[246] = "Mi dispiace, ma non ti lascerò entrare fino a quando non sarai capace di strappare un\'unghia ad un cavaliere di Karne. Sennò ho paura che sarai te a fartene strappare più di una dentro questo labirinto...";
D.q[4254] = "";
D.q[5753] = "";
D.q[3674] = "Puoi dire a Disskray che va tutto bene.";
D.q[6202] = "";
D.q[6199] = "";
D.q[6195] = "";
D.q[7726] = "";
D.q[292] = "È un\'idea rivoluzionaria, ma richiede molti esperimenti: uso il Femore del Capitano Chafer ridotto in polvere per simulare il gusto del curry. Ma è difficile trovare la dose giusta e adesso sono in carenza di femori.";
D.q[7739] = "La braccia non mancano, ma gli uomini sono stanchi e le bestie feroci vagano nella foresta. \nInoltre dobbiamo costantemente lottare contro il gelo del porto e cominciamo ad essere senza combustibile per le nostre caldaie. Sarebbe utile se tu mi potessi portare 10 Legni di Pioppo Tremulo.";
D.q[5080] = "Hai fatto un buon lavoro. Non mi fidavo di quel giovane miliziano, per questo l\'ho fatto seguire mentre tu indagavi, ma i miei uomini hanno perduto le sue tracce nel quartiere dei panettieri. Vai a fare un giro laggiù e cerca di ritrovarlo.";
D.q[7697] = "";
D.q[3686] = "Niente da segnalare, zona protetta.";
D.q[7740] = "il tuo vigore potrebbe spiegarsi con delle origini frigostiane. Vado a chiamare i ragazzi perchè facciano seccare il legno.\nSe torni con dell\'altro, lo prendo.";
D.q[3447] = "La Filtunga è una ricetta un po\' ricca ma così deliziosa.";
D.q[6437] = "Salve. Mi chiamo Gerl e sono a capo di un importante gruppo di mercanti. Quando non sono occupata nel mondo degli affari, mi occupo personalmente degli uomini d\'affari e, credimi, ne so tantissimo sia d\'affari che di uomini. Tra l\'altro alcuni dicono che io sia molto dura in affari, in tutti i sensi del termine. E tu che ne pensi?";
D.q[7701] = "";
D.q[7699] = "";
D.q[7702] = "";
D.q[7700] = "";
D.q[3690] = "Niente da segnalare, zona protetta.";
D.q[7741] = "Grazie alla glaciazione ho potuto ottenere un allevamento 100% bio. I miei vitel sono cibati con semi e il loro pelo trattato con prodotti di origine vegetale completamente biodegradabili. Oh, uffa, va bene, hanno fame e mangiano quel che possono, ma sopravvivono anche se, al contrario di prima, non hanno molto da mettere sotto ai denti.\nIl solo grosso problema sono le zecche. E che non mi vengano a parlare di etica dei Frigostiani: nessuno ne ha più di me.";
D.q[1167] = "Ciao, se vieni a trovarmi in questa modesta dimora circondata da pietre e sassolini, è perché sicuramente anche te hai la passione per la pesca! Oppure vuoi parlare con me di amore e altre cose...";
