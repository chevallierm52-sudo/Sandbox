D.q[422] = "Le Spade sono le armi preferite dagli Yop e dagli Ecaflip, di solito necessitano di molta forza per essere utilizzate, e fanno danni molto importanti.\nI Forgiatori di Spade utilizzano come attrezzo il Martello del Forgiatore di Spade.";
D.q[6363] = "Cosa? Non esco molto spesso, sai, preferisco questo posto oscuro e calmo all\'esterno agitato del porto.";
D.q[3106] = "Grazie per tutti i tuoi servigi. Sembro un po\' capricciosa, lo so, ma se dicessi di sì a tutti sarei costretta a correre ovunque come fai tu, e il mio metabolismo non lo sopporterebbe.";
D.q[4156] = "Grazie a te ora so perché mio figlio voleva allontanarsi da me, ho imparato la lezione e non lo chiamerò mai più mio piccolo wabbit, da ora in poi lo chiamerò mio piccolo pappaton, sono sicuro che lo apprezzerà!";
D.q[1835] = "Grazie mille! Grazie agli oggetti che mi hai portato sono riuscito a fabbricare una bella zattera. Potrò lasciare l\'isola molto presto.";
D.q[2941] = "Attenzione avventuriero, terribili creature abitano questo dongione. Solo un gruppo di almeno tre avventurieri può sperare di uscirne vivo. Sei sicuro di voler entrare ?";
D.q[3905] = "Tutto ok, il piano sta andando come previsto.";
D.q[658] = "No! La morte, soprattutto se provocata o simulata, NON CONSENTE di rompere il vincolo indistruttibile del matrimonio! Ah, non era questa la domanda? Ah no! Noi non ci occupiamo per niente dei funerali. Quindi quando morirai vai al cimitero, trova una tomba. Seppellisciti e il cielo ti seppellirà!";
D.q[1374] = "Grazie, cominciamo... Ma... Sangue di Djaul! La lava non ha le caratteristiche attese! Tutto fa pensare che la corrente magmatica sia in movimento. Bisogna assolutamente capire cosa sta succedendo là sotto. C\'è l\'entrata di una grotta a Sud-Est di qua. Sul fondo di questa grotta cola un fiume di lava. Penso che sia il miglior punto per studiare il fenomeno. Purtroppo la grotta è infestata dai mostri, quindi tu mi accompagnerai e mi farai da scudo.";
D.q[5465] = "Orso entrare in Taverna. Orso dire: \"Me volere Birra di Astrub...";
D.q[5193] = "";
D.q[7296] = "";
D.q[1246] = "Va bene, era l\'ultima volta. Voglio essere buono e chiudere gli occhi per quanto riguarda la provenienza di questa ricetta, ma non bisogna approfittare della mia bontà...";
D.q[1764] = "Ho insegnato ai Dabol le tecniche di combattimento Anutrof. Così saranno degli ottimi avversari qualunque sia il tuo livello.";
D.q[6976] = "";
D.q[4303] = "Sei sicuro di voler tornare laddove ti avevo portato? Ti ricordi della pericolosità di quel posto?\nTi riaccompagnerò, se mi procurerai un Calice di Fecorza.";
D.q[1435] = "Questa mattina, dando da mangiare ai pescis, ho fatto cadere l\'anello sul fondo. Mi succede sempre.";
D.q[741] = "Non sono di buon umore in questo momento.\nChiedi al Capitano Assacarf se ha bisogno di aiuto...";
D.q[3171] = "Diamantina? Sei tu? Non ti riconosco! Avvicinati, per favore!";
D.q[4017] = "Bene, ecco la tua divisa.";
D.q[6786] = "Se ti diverte...";
D.q[7851] = "I pescatori dicono che i Pinguinotti, scontenti dello sterminio di cui sono vittime dall\'arrivo dei continentali e dell\'affronto fatto al loro re, stanno preparando una spedizione punitiva.\nAll\'inizio non gli ho creduto, fino a quando le bestie non si sono fatte vedere.\nPreparati a combattere e vienimi ad aiutare a respingerli.";
D.q[7024] = "";
D.q[451] = "Si é rivolto all\'Ordine del Cul\'a Pedate per far cambiare, senza l\'accordo dei clienti, questi famosi stivali troppo potenti con gli Strapotenti Stivali di Klim... altrettanto potenti, ma più difficili da portare.\n\nL\'Ordine del Cul\'a Pedate ha dovuto portare a termine una gigantesca operazione, e non è stato facile. Infatti molti clienti si sono accorti del cambiamento di stivali e hanno cominciato a braccare e a minacciare il povero Ciabattino, che ha dovuto abbandonare Amakna per sempre...\nOggi, il servizio clienti è gestito dall\'Ordine del Cul\'a Pedate che, per le persone in difficoltà, sostituisce gli Strapotenti Stivali di Klim con l\'ultimo modello dei Potenti Stivali di Klim (molto di moda tra l\'altro). Se vuoi fare questo scambio, vieni, sono a tua disposizione.";
D.q[845] = "Sembra che ci siano parecchi smottamenti nelle fogne. Anche se la terra dei dintorni non è molto stabile, certe voci dicono che non si tratti di smottamenti naturali. Vai a controllare.";
D.q[7380] = "Comincio ad averne abbastanza di incompetenti. Mi occuperò di questo fastidio al tuo posto, anche se non credo che la lezione darà i suoi frutti.";
D.q[1834] = "Tutti i miei Dabol sono stanchi adesso, torna domani se vuoi allenarti ancora...";
D.q[6977] = "";
D.q[6978] = "";
D.q[1795] = "Se vuoi affrontare un Dabol ti consiglio di prepararti. Allora? Sei pronto?";
D.q[7297] = "";
D.q[7852] = "Non ho tempo per parlare, una nuova ondata di Pinguinotti sta arrivando. Curati e preparati al combattimento.";
D.q[6979] = "";
D.q[5179] = "";
D.q[7853] = "I Pinguinotti sono stati respinti e i danni sono minimi. Qualche pescatore è caduto dalla falesia durante i combattimenti, ma le perdite umane sono sotto al 7%, cosa tollerabile. I Pinguinotti dovrebbero lasciarci tranquilli al momento, penso che Damar ne approfitterà per riaprire le linee di approvvigionamento fino a Frigost, quindi vai da lui.";
D.q[394] = "Ciao, sono Alì Akel, pittore illustratore. Siccome le mie illustrazioni sono in bianco e nero, uso delle Zampe di Arakne ridotte in polvere per produrre queste tinte. In questo momento ne ho proprio bisogno, ho un ordine urgente.";
D.q[3469] = "Bwork vogliono nutrire *snif snif* Trooll con Raxitiko. Me non *snif snif* volere, me avere 19 minigob da nutrire *snif*...";
D.q[5205] = "";
D.q[7026] = "";
D.q[249] = "Adesso ho altri problemi, ma tu puoi divertirti con i nostri Dabol se vuoi. Vai da Brigitebardò Pol, è lei che li alleva.";
D.q[7298] = "";
D.q[3154] = "Ciao #2. Mi chiamo Fidji Merlin, sono la sorella di Leroy Merlin, e una delle più celebri Tuttofare del continente. La nostra famiglia è Tuttofare da moltissime generazioni, e io e mia sorella abbiamo deciso di installarci nelle città nemiche fra loro per elargire a tutti il nostro sapere e la nostra esperienza. Cosa vuoi sapere ?";
D.q[7027] = "";
D.q[1281] = "Che spreco... scommetto che hai usato la sciabola per tagliare queste patate!";
D.q[1518] = "E così sia...\nPorta questa lettera a Oto Mustam.";
D.q[4912] = "";
D.q[6980] = "";
D.q[7299] = "";
D.q[5996] = "";
D.q[1462] = "Molto bene #1, sapevo di poter contare su di te, ma attento, se accetti non potrai più tornare indietro.";
D.q[1766] = "Ho insegnato ai Dabol le tecniche di combattimento Osamodas. Così saranno degli ottimi avversari qualunque sia il tuo livello.";
D.q[241] = "Ti ripeto che non parlerò! Non ti dirò mai che è nascosto in una grotta, la cui entrata si trova sotto un cerspuglio luminoso. Ops... bah, tanto l\'entrata è sigillata... e non so neanche più dove si trovi questo cespuglio.";
D.q[7300] = "";
D.q[1522] = "Che sia così...\nVai a portare questa lettere a Oto. E prosegui sulla tua strada.";
D.q[7301] = "";
D.q[7028] = "";
D.q[3772] = "Prova, non puoi perdere!";
D.q[2173] = "Grazie mille. Questa riunione era di vitale importanza. Eccoti qualche kama come ricompensa. Torna da me quando vuoi. Ti concederò un po\' del mio tempo prezioso...";
D.q[4433] = "Ciao!";
D.q[6464] = "Vuoi creare una chiave in più esemplari? Posso aiutarti, ma in cambio devi portarmi 5 Tavole di Ciliegio Selvatico, ne ho bisogno per riparare le macchine del recinto pubblico. I recinti privati sono troppo poco numerosi e molti allevatori sono obbligati a ricorrere ai recinti pubblici, cosa che rovina fatalmente le macchine e, visto che sono responsabile del loro buon funzionamento, non posso permettermi di lasciare usare del materiale difettoso alla gente. Metti che un lop utilizzi una dragochiappa il cui cuoio è completamente logoro e rugoso. Ti lascio immaginare i guai che può provocare.";
D.q[691] = "Ecco l\'ultima interrogazione,\nPoi valuteremo la situazione.\nOra pensiamo alla coccolina,\ndi sera, pomeriggio o di mattina?";
D.q[7302] = "";
D.q[5208] = "";
D.q[408] = "Il Ciabattino lavora soprattutto il cuoio, e ne fa cinture e stivali.\nA volte i Ciabattini usano anche legno o metalli preziosi per decorare o rinforzare le loro creazioni. Come attrezzo di lavoro, il Ciabattino usa una daga chiamata \"Tagliacuoio\".\nSe cerchi questo attrezzo, posso dartelo io in cambio del tuo aiuto.";
D.q[5104] = "Allora? Cos\'era?";
D.q[7478] = "";
D.q[1120] = "Grazie, la dea protettrice Jiva ti ringrazierà.";
D.q[4904] = "Png(679) et Message(4903)";
D.q[4153] = "Grazie alla mia idea geniale, ho potuto risparmiare moltissimo tempo e molta farina di qualità. Spero che tu comprenda ormai perché sono una delle migliori Panettiere del Mondo dei Dodici...";
D.q[7025] = "";
D.q[7303] = "";
D.q[5180] = "";
D.q[7479] = "";
D.q[7367] = "";
D.q[721] = "Basandomi sulle tue ultime informazioni, penso di aver trovato un modo per sabotare la porta di Brakmar. Ne parlerò ai miei superiori. Ti ringrazio.";
D.q[3496] = "Bworkidé essere paxifiko.";
D.q[7309] = "";
D.q[7368] = "";
D.q[2353] = "Bé, tutto quello che so è che il consiglio ci ha chiesto di pattugliare in quei maledetti sotterranei... Devono sapere qualcosa su quello che sta succedendo là sotto! Sono sicuro, e non saranno certo le vecchie leggende che placheranno la questione...";
D.q[3691] = "Non ho notato niente, è tutto a posto.";
D.q[7480] = "";
D.q[7304] = "";
D.q[7481] = "";
D.q[1576] = "Pietà! Voglio uscire da questa sordida prigione!";
D.q[5610] = "Forse comincio od overe delle ollucinozioni. Ecco, il vecchio Terra Cogita perde lo testo.";
D.q[4910] = "";
D.q[6983] = "";
D.q[4311] = "";
D.q[4349] = "";
D.q[7305] = "";
D.q[4824] = "Con tutti questi elementi, non c\'è dubbio che Bast Konliskerz sarà dichiarato innocente.";
D.q[7854] = "Fortunatamente possiamo contare su Trice per la sicurezza del sito. Quando era piccina si divertiva a combattere le rocce aiutandosi con una pala.\nVisto che la minaccia pinguinotta è calmata, al momento, possiamo andare ad approvvigionare i nostri concittadini senza rischi.\nVai da Ordinalfabetiz e digli che la distribuzione di Pescetti può riprendere.";
D.q[5223] = "";
D.q[2008] = "Ahi, smettila... miri tutto storto! Ci faremo sgridare se appartiene a qualcuno. Povero Pappatutto, è morto sul colpo. Credo che non ti abbia visto nessuno. Dai, muoviti a portare l\'Arco all\'Alchimista Nibé Lulla, ne migliorerà la corda... anche se non dev\'essere proprio un problema dell\'Arco...";
D.q[6984] = "";
D.q[6811] = "";
D.q[6482] = "È carino da parte tua, ma gli ordini sono ordini e non posso mostrarti il rapporto che ti riguarda. Però per ringraziarti posso dirti che il rapporto originale si trova nella Torre di Bonta. Non ho avuto il permesso di gettarci un occhio per verificare la sua autenticità, il che modifica la procedura abituale perché dopotutto sono io l\'esperto. Certo, se qualcuno riuscisse a rubarlo, potrei autentificarlo. Il problema è la sorveglianza. Una persona abile come te deve saperlo rubare da sotto il naso delle guardie, se si distraggono un attimo. Comunque resta un\'idea ipotetica, no?";
D.q[6217] = "Non so di cosa tu stia parlando. Non metto mai i piedi nella torre di Bonta. È il taverniere Bagrutta ad averti parlato di me? Gli insegnerò a farsi gli affari suoi.";
D.q[3581] = "Me non malato.";
D.q[7306] = "";
D.q[4920] = "";
D.q[5689] = "";
D.q[477] = "Wobot matwicola 53, 2a classe dell\'11o weggimento di wobot della guawdia del We.\nAltolà!";
D.q[7828] = "Garantire la sicurezza dei pescatori era più facile una volta. Da quando il cratere si è riempito di acqua calda è diventato pescosissimo. L\'attività di pesca è quindi molto importante qui. Ma da quando si è gelato, è diventato tutto più difficile.\nPrima bastava solo temere le creature della Foresta, ora c\'è anche da respingere gli assalti dei Pinguinotti che rubano il pesce scongelato.";
D.q[6985] = "";
D.q[1857] = "La creazione di nuovi vestiti è abbastanza stancante. Se si utilizzano dei modelli è un po\' più facile, ma non di tanto... Un buon Sarto deve avere una buona rete di fornitori, altrimenti non combinerà molto... Senza contare che ci vuole molta esperienza per fare vestiti degni di questo nome.";
D.q[5460] = "Me morire di fame! Me volere mela!";
D.q[7830] = "Non hai trovato altro?\nPovero Gerard, possiamo dire che è morto come ha vissuto, da imbecille.\nSai, questa storia mi ha fatto venire fame, a te no?";
D.q[7307] = "";
D.q[3434] = "I bambini di El? No, non li ho visti.";
D.q[953] = "La porta di questa torre si trova a Nord-Ovest di Bonta, qui ci sono tutti gli uffici amministrativi della città. Se cerchi il tesoriere, o il sindaco di Bonta, li troverai sicuramente là dentro.";
D.q[7310] = "";
D.q[3912] = "Un nobile? Ce ne sono molti qua, ma nessuno che mi sembri degno della principessa.";
D.q[92] = "Hyooohooo, devo farmi delle bretelle in cuoio per evitare che i pantaloni mi cadano ancora! Portami del cuoio di Pappatutto, e ti darò in cambio la mia Intagliatrice di Bastoni: ti permetterà di intagliare dei bastoni, nel caso esercitassi questo mestiere.";
D.q[1703] = "Il tempio Anutrof è a Nord del villaggio di Amakna, non molto lontano da qui. Parla ad Elisa Granito per cominciare il tuo apprendistato.";
D.q[7311] = "";
D.q[5790] = "";
D.q[1047] = "Ah! Un amante dei cannoni a quanto vedo? Se hai domande sull\'argomento, io sono il migliore.";
D.q[4117] = "Sai incrociare le braccia?";
D.q[5793] = "No, niente. Finta allerta. Ahhh!";
D.q[7678] = "Ah, cosa posso fare?! Da un po\' di tempo la mia cantina è infestata dai ratti storditi slavati, e oltre al baccano e alla puzza infernale che fanno, attirano tutti i baubau del quartiere! Così il mio Kiki ha paura! E se il mio Kiki ha paura io non sono contento!";
D.q[1478] = "Ahah! Bravo, la trasmetterò subito alla nostra squadra di reclutamento. Saranno contentissimi.";
D.q[6921] = "";
D.q[4749] = "";
D.q[7312] = "";
D.q[5791] = "";
D.q[7684] = "Ancora un turista... Hai visto una luce e quindi sei entrato, vero? Non capisco perchè Seth Leurse, il mio predecessore, non abbia fatto mettere un chiavistello alla porta.\nVabbè, già che sei qui potrai renderti utile. Degli animali turbano la quiete di Frigost, ma io non hoil tempo per decimarli tutti. Che ne dici di darmi una mano?";
D.q[7313] = "";
D.q[5226] = "";
D.q[749] = "William Linglés comincia ad infastidire veramente troppo gli abitanti della Città. Fammi un piacere... vai a dare una bella lezione a lui e al suo gruppo.\nSi trova ad Ovest di Bonta.";
D.q[7685] = "Ciao, ti trovi nel luogo più caldo dell\'isola, senza contare il vulcano, ovviamente.\nCi serviamo di queste serre per coltivare nuove piante che non sopravvivrebbero alle temperature glaciali dell\'isola e soprattutto per poterle ripiantare quando l\'era glaciale sarà terminata. Sfortunatamente dei Pappabuk affamati sono entrati ed hanno eletto il loro domicilio nelle serre, sono in cerca di cibo, ma sono diventati aggressivi per colpa del caldo. Si sono messi ad attaccare il personale e a divorare le piante, sono arrivati perfino a brucare il prato della mia sposa, che era la direttrice della serra, ti rendi conto?\nIn cambio della chiave della serra ti lascerò entrare per prendere a calci il fondoschiena del Realbuk, ma fai attenzione: è un tipo pantofolaio e sembra avere reazioni spropositate quando viene fatto muovere.";
D.q[7706] = "Ciao, se pensi che ti lascerò usare il mio trasportatore devi aver preso una bella botta in testa. Provami che sei degno di fiducia e forse, ho detto forse, ti lascerò salire a bordo.";
D.q[4016] = "Una divisa da valletto per un principe Wabbit? È un\'ordine poco comune, mi manca la stoffa adeguata. Mi serve un tessuto porpora, come quello dei bwork maghi, per poi cucire il tutto con 10 fili di seta. Se mi trovi questi oggetti, ti farò una divisa degna di un valletto principesco.";
D.q[4913] = "";
D.q[3199] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nell\'undicesima sala, o nella dodicesima, o nella quindicesima o forse nella sedicesima, non ricordo più.";
D.q[7856] = "E\' Ordinalfabetiz che ti manda? Credevo che quel grosso goffo uomo ci odiasse. Sembra essere meno ottuso di come credevo che fosse.\nRingrazialo da parte mia.";
D.q[7857] = "Bleah, ma è ripugnante. Questi Pescetti sono predigeriti, è fuori questione che li mangeremo.";
D.q[5182] = "";
D.q[3987] = "Pew dio, una pwincipessa da sposawe! Questa è una notizia intewessante. Io sono il tuo pwincipe! Andiamo via di qua!";
D.q[2485] = "Ah grazie! Grazie a te possiamo rimetterci a lavorare... (sbadiglia).";
D.q[3198] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nell\'undicesima sala, o nella dodicesima, o nella quindicesima o forse nella sedicesima, non ricordo più.";
D.q[3195] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nell\'undicesima sala, o nella dodicesima, o nella quindicesima o forse nella sedicesima, non ricordo più.";
D.q[5518] = "Cosa posso fare per te, abitante di Brakmar?";
D.q[7314] = "";
D.q[1859] = "Grazie mille... Tieni: ecco il tipo di mantello che si può ottenere.\nAh, come sei carino con questo mantello! Ma ti ci vuole un\'imbottitura per le serate d\'inverno! Mi servirebbe della lana di pappatutto standard, è meno pregiata ma è molto più calda... Portami il tuo mantello e 5 lane e me ne occuperò io... no no, non accetto un no come risposta!";
D.q[4754] = "";
D.q[7858] = "Ti ricordo che la digestione del Pinguinobesotto comincia fra 30 minuti, quindi devi finire di consegnare i Pescetti in tempo utile.";
D.q[4375] = "";
D.q[3194] = "L\'ultima volta che ho visto Messer Cuervoc, era nascosto nell\'undicesima sala, o nella dodicesima, o nella quindicesima o forse nella sedicesima, non ricordo più.";
D.q[3865] = "Ciao. Ho visto che sei un guerriero valoroso...\nVorresti dare una mano per proteggere Amakna e il trono di Allister?";
D.q[7315] = "";
D.q[3355] = "Hei, hei! Non hai la chiave!";
D.q[4755] = "";
D.q[5237] = "Hai finito?";
D.q[5234] = "";
D.q[7859] = "";
D.q[5298] = "";
D.q[4411] = "Ehhh, buongiorno. Come? Cosa ci faccio qui? Beh, faccio un giro nella torre... Ne ho il diritto, no?";
D.q[7860] = "Era da molto che non mangiavamo Pescetti, è un buon cambiamento con le crocchette di Kanigloo.\nGrazie sia a te che ai Pescatori.";
D.q[1189] = "L\'Ordine dello Spirito Redentore è quello che conosce meglio gli arcani della magia e della guarigione.\nSiamo votati al bene degli altri, e alla protezione della città contro gli attacchi demoniaci degli adepti di Hecate di Brakmar.";
D.q[7861] = "Sei sicuro che questi Pescetti siano freschi? Ho piuttosto l\'impressione che siano stati immersi nei succhi gastrici...";
D.q[6449] = "Il consiglio m\'impedisce di mandare le truppe per attaccare il covo dei banditi. Sono sicuro che il covo dei banditi contiene delle informazioni che potrebbero rivelare l\'identità del loro protettore, ma il consiglio m\'impedisce di mandare le truppe per attaccarlo. La missione che sto per chiederti è rischiosa, ma non ho scelta.";
D.q[5191] = "";
D.q[7862] = "Pescetti freschi e succosi, i clienti li adoreranno. Questo dovrebbe far salire il morale della sposa di Truffo.\nAveva un piccolo giardino segreto con molto prato, in una delle serre, ma il Realbuk le ha brucato tutto. Ora lei è depressa e Truffo vuole la pelle di quella bestia.";
D.q[868] = "58";
D.q[6365] = "La Sedecrem è in mare da dei lustri e, per quanto ne so io, il bastimento ha previsto d\'attraccare solo fra due settimane al minimo sull\'isola di Otomai. In ogni modo non era previsto che andasse al porto di Madrestam. \nInvece, a proposito di Bontariani, c\'è un importante carico di equipaggiamento uscito dalle nostre fucine e partito in direzione di Bonta più di una settimana fa. In questo momento il convoglio dovrebbe essere arrivato a destinazione e i miliziani staranno di sicuro testando la loro nuova attrezzatura.";
D.q[7863] = "Ehm, sono veramente Pescetti? Sembra piuttosto la sbobba servita da Walter Ehgo. Hai sbagliato di sicuro la consegna.";
D.q[5265] = "";
D.q[4757] = "";
D.q[7864] = "Bel lavoro, me ne ricorderò per le prossime consegne.\nGrazie al tuo aiuto, sperando che il dio Anutrof sia con noi, arriveremo a pescare pesce a sufficienza per sostenere i nostri bisogni.";
D.q[1731] = "I discepoli di Sàcrido possono utilizzare tutte le armi, ma non eccellono in nessuna... Loro sono più bravi con gli incantesimi.";
D.q[781] = "71";
D.q[782] = "72";
D.q[882] = "72";
D.q[5114] = "";
D.q[428] = "I Bastoni sono armi poco efficaci nel combattimento corpo a corpo, ma conferiscono importanti poteri a chi li usa.\nI Sadida e i Feca maneggiano molto bene i Bastoni, i quali necessitano di un po\' di forza e di molta intelligenza per poter essere utilizzati.\nGli Intagliatori di Bastoni utilizzano come attrezzo un\'Intagliatrice di Bastoni.";
D.q[1681] = "LE LARVE PIÙ RAPIDE DI TUTTA AMAKNA! VENITE A SCOMMETTERE SULLE VOSTRE LARVE PREFERITE! FACILE, POCO CARO E CON GRANDI PREMI!\nCiao, vuoi assistere ad una corsa di larve per 40 kama?";
D.q[7745] = "E\' per colpa di questo sinistro Xelor che l\'inverno perpetuo si è installato sulla nostra bella isola. Da quel momento si è indebolito ed è scivolato nella follia sempre di più ogni giorno. Bisogna punirlo il prima possibile.";
D.q[4937] = "";
D.q[7782] = "Da poco meno di un decennio le zecche sono uscite dal loro letargo. Hanno eletto domicilio sui miei vitel, al caldo, protette dalla spessa lana del loro padrone di casa. Suppongo che siano portatrici di un agente patogeno che rende i miei vitel stupidi e aggressivi.";
D.q[2105] = "Il \"Colpo-Divino\"! Quello grazie al quale diventerò ricco e famoso! Se vuoi saperne di più, siediti, prendi una birra e ascoltami, amico mio, è una storia fantastica!";
D.q[7784] = "Vai da Oshima e spiegagli il nostro problema. Quello specialista di animali troverà di sicuro una soluzione... Che c\'è? Perchè mi guardi così?";
D.q[4068] = "Ciao!";
D.q[4140] = "Allora, sei riuscito a procurarti una pozione Bulbica?";
D.q[6923] = "";
D.q[790] = "80";
D.q[791] = "81";
D.q[890] = "80";
D.q[7316] = "";
D.q[2650] = "Il Pandasiman, o \"arte della schivata con lo scudo\", è una delle più efficaci scuole del Pandawushu.\nContrariamente all\'arte dello scudo Feca che ha sviluppato una tecnica di protezione pura, questa scuola insegna ad usare lo scudo come un mezzo di parata. La caratteristica di quest\'arte è quella di usare lo scudo non solo passivamente, ma attivamente.";
D.q[794] = "84";
D.q[7369] = "";
D.q[7629] = "Un\'opera su Gultard, precisamente sulla sua infanzia? Si, ne abbiamo un esemplare. Sfortunatamente dovrai andare da Lethalin Sigisbul per consultarla.";
D.q[479] = "L\'accesso a questa pawte dell\'isola è wisewato al we. Fuowi di qui!";
D.q[893] = "83";
D.q[7061] = "Le Pietre seguenti...";
D.q[7317] = "";
D.q[3961] = "L\'attentato con il tofu è fallito... credo sia meglio fare le cose alla maniera dei ladrurbi e avvelenare semplicemente questo \"cawo pwincipe\" con un blopisiero avvelenato.";
D.q[7866] = "Ci manca soprattutto il legno. Il Pioppo Tremulo si è ben adattato al clima di Frigost. Tuttavia ho sentito parlare di un legno esotico che diffonde un odore buono e piacevole, si chiama Kalipto. Penso che combinando i due tipi di legno potremmo ottenere case dallo stile unico.\nMe ne potresti procurare? Dubito che tu possa trasportare tutto quello che ci servirebbe, quindi ti chiedo solo 5 Legni di Pioppo Tremulo e una tavola di Kalipto.";
D.q[5247] = "";
D.q[7462] = "";
D.q[7060] = "Le Pietre seguenti...";
D.q[7062] = "Le Pietre seguenti...";
D.q[695] = "Quanto basta mediterai.\nE all\'ora nulla tornerai.\nQuest\'ora segreta ti bacerà,\nSe la pazienza ti aiuterà.";
D.q[5751] = "";
D.q[2800] = "Il tuo sangue ribolle all\'idea di spargersi in un luogo maledetto... Per caso stai cercando di entrare nel labirinto?";
D.q[7318] = "";
D.q[805] = "95";
D.q[7370] = "";
D.q[905] = "95";
D.q[7812] = "Come si sono potuti perdere?\nConto su di te per portarmi gli altri sani e salvi.";
D.q[7815] = "Non credo tu abbia interesse a toccare mia sorella, o farà presto molto caldo per te.";
D.q[7319] = "";
D.q[7808] = "Finalmente qualcuno, siamo salvi!\nNon indovinerai mai cosa ci è accaduto. Mentre ci preparavamo a rientrare al Borgo con una buona riserva di legno, siamo stati vittime del fato.\nAbbiamo perduto l\'orientamento, e ci siamo trovati a vagare in tondo incapaci di ritrovare la nostra strada. Ovunque andassimo, finivamo sempre qui, contro la nostra volontà. Ma visto che ci sei tu ora potrai riaccompagnarci uno ad uno.\nAh, non te l\'ho detto? Il maleficio è più potente se siamo in gruppo, ma siccome non sembri toccato da questo maleficio potrai guidarci fuori.\nComincia con Storm Siù, preferisco saperla al sicuro.";
D.q[1043] = "Hmm! Questa collana è veramente conciata male, ti costerà 1000 kama ripararla.";
D.q[5361] = "";
D.q[2155] = "Tieni, ti do tutto.";
D.q[4943] = "";
D.q[5825] = "";
D.q[5362] = "";
D.q[5259] = "";
D.q[3277] = "Questa chiave sontuosa può condurti direttamente laddove si nasconde la Quercia Molle, o quasi, ti toccherà forse vedertela con qualche indesiderato contrattempo. Sei sicuro di volerci andare?";
D.q[4417] = "Muoviti. Non bisogna assolutamente mancare all\'appuntamento.";
D.q[7308] = "";
D.q[5941] = "";
D.q[2158] = "Guarda, riprendo tutto.";
D.q[7631] = "Un\'opera su Gultard, precisamente sulla sua infanzia? Si, ne abbiamo un esemplare. Sfortunatamente dovrai andare da Grace Malcin per consultarla.";
D.q[7867] = "Oh, non pensavo l\'avresti fatto, sei veramente servizievole, grazie. Servirebbero più persone come te. Per il disturbo che hai preso, ti farò uno sconto quando verrai in vacanza nel nostro futuro hotel.";
D.q[4626] = "Allora, cosa aspetti? Vai sull\'isola di Moon e trova degli indizi! Vai!";
D.q[7320] = "";
D.q[6930] = "";
D.q[5602] = "Quel cretino di Merlisello non si accorgerà di niente. Quanto a te, eccoti Spia Oscura.\nAllora, contento?";
D.q[7819] = "Va bene, non hai troppo male?\nRientriamo in città!";
D.q[1574] = "Ma ne hai già uno!";
D.q[3452] = "Filtunga finita, tu mangi!";
D.q[6457] = "Questo combinaguai? Me ne ricordo come se fosse ieri. Dava dei problemi in una taverna, quindi l\'abbiamo arrestato e messo in cella. Purtroppo abbiamo ricevuto l\'ordine di farlo uscire il giorno dopo con il pretesto che aveva le pulci e le zecche e non volevano un\'emergenza sanitaria in prigione. È la prima volta che sento parlare di emergenza sanitaria nella nostra prigione, ma gli ordini sono ordini.\nHo chiesto ai miei uomini di dargli un\'occhiata e mi hanno riferito che era spesso dalle parti della Torre degli Ordini, ma finché riga dritto, non posso farlo arrestare.";
D.q[5352] = "Sei riuscito a fargli ammettere qualcosa?";
D.q[6988] = "";
D.q[7321] = "";
D.q[7824] = "Freddo io? Mai!\nIo sono Damar, capo dei Pescatori, sangue di Pinguinotto scorre nelle mie vene... a furia di berne troppo...\nSe vuoi renderti utile, smetti di fare domande stupide.";
D.q[7825] = "Gerard? No, è da un po\' che non lo vedo. Se fosse stato nei dintorni l\'avrei di sicuro notato, lui e quei suoi ubriaconi di amici fanno un tale baccano che li si sentirebbe dal Castello del Conte. Vai a rompere le scatole agli illuminati qui a fianco, invece di interrompere il nostro lavoro.";
D.q[7371] = "";
D.q[640] = "Questa è una fontana della giovinezza! Serve per recuperare punti vita.\n\nQuando combatti un mostro, perderai sicuramente dei punti vita.\nSe non hai ancora raggiunto il livello 6, puoi curarti con questa fontana.";
D.q[4788] = "";
D.q[7827] = "Quell\'ubriacone non ci ha insultati per un po\', deduco che non sia venuto qui dopo il sonnellino.\nInvece di perdere tempo a cercarlo, ti consiglio di trovare qualcosa di più utile da fare. Tuttavia, se proprio ci tieni a trovarlo, chiedi a Trice. Lei si è incaricata della sicurezza della zona dei pescatori e se c\'è qualcosa di inusuale lei è la prima a saperlo.";
D.q[5747] = "";
D.q[6989] = "";
D.q[1358] = "*Muove la mano*";
D.q[1014] = "Grazie, conosco qualcuno che grazie a te potrà finalmente tornare a mangiare delle bistecche di pappatutto.\nSaluta Amayiro da parte mia!";
D.q[316] = "Ti ringrazio, sei molto gentile, ma devo cavarmela da sola. Se tu potessi trovarmi solo una decina di Ali di Moskito... mi aiutano a riflettere, sai. Non ti preoccupare, saprò come ricompensarti in cambio.";
D.q[4791] = "";
D.q[4967] = "";
D.q[7831] = "Ciao, non parlarmi di agricoltura, non voglio più sentire una sola parola al riguardo.\nHo investito una buona parte delle mie ricchezze per comprare questa serra ed avere l\'esclusiva.\nTi sbagli, non sono egoista, uso questa serra per sviluppare tutta una serie di piante per usi diversi. Sto provando a creare delle piante commestibili, resistenti al clima di Frigost, per lottare contro la fame e rimpiazzare l\'agricoltura. Così solo gli alchimisti possono coltivarle, e ciò che è successo a causa dell\'agricoltura e del Conte Allarovescia non accadrà più.";
D.q[7323] = "";
D.q[7373] = "";
D.q[3520] = "Me diventare magoblin, me troppo forte!";
D.q[1557] = "Grazie, ma per guarire il mio tabi ci vorrebbe un miracolo. Ho chiesto ai più grandi specialisti, medici, incantatori o maghi e non hanno saputo farci niente.\nUn miracolo... non chiedo altro...";
D.q[5291] = "";
D.q[7324] = "";
D.q[3303] = "Ignorante, porta un po\' il tuo sedere incolto nella nuova biblioteca di Brakmar! In questo luogo, imparerai tutto sulle tecniche di combattimento, di magia e di allevamento. Ci sono addirittura scaffali pieni di consigli su come sopravvivere in condizioni estreme.";
D.q[7634] = "Fuori dalla mia vista, scarafaggio. Ti schiaccerò come l\'insetto ripugnante che sei.";
D.q[7868] = "E\' massacrante passare le proprie giornate al freddo a rompere il ghiaccio o ad aspettare che un pesce abbocchi. Niente a che vedere con il bel tempo in cui l\'acqua era tiepida e i pesci ti saltavano in mano...";
D.q[7374] = "";
D.q[3462] = "Questa ricetta è troppo difficile da realizzare. E io che pensavo di diventare ricco fabbricando birra di Bwork! Credo che mi accontenterò di allevare dei Pworks...";
D.q[2519] = "...questo falso uovo di drago capita a fagiolo! E se ne facessimo delle copie autentiche \"Made in Pandala\"? Dovremmo solo tingere delle uova di Dragacchino. Gli avventurieri impazziranno... le compreranno come il pane di Amakna, credimi! Aaah, sono un genio... Hmm, ma devo smetterla di pensare a voce alta...";
D.q[5289] = "";
D.q[7325] = "";
D.q[4198] = "È questa creatura che fa nascere la maggior parte delle piante viventi di questa foresta. Ogni petalo, ogni stame, ogni fiocco di polline che perde, fa nascere una nuova creatura, che prende posto nella catena alimentare dell\'isola. Oggi, questa creatura è diventata incontrollabile. Ma tempo fa riuscivamo persino ad introdurci nel laboratorio e a scoprire a quale creatura, il Tynril, desse la vita.";
D.q[7326] = "";
D.q[7636] = "Allora, mi hai portato tutto quel che ti ho chiesto?";
D.q[2310] = "Ecco i fatti: gli Anutrof hanno chiesto il nostro aiuto. Da un po\' di tempo, si manifestano strani fenomeni durante i loro scavi. È una situazione pericolosa, e quando si parla di pericolo si parla di Yop! Sei già pronto per andare ad aiutarli. Vai da Gasdora nelle gallerie! E stai in guardia!";
D.q[2003] = "Dell\'estratto di Dzibi! Bene! Se un giorno hai bisogno di qualche cosa, non farti problemi. D\'altronde, forse ti interessa un\'assicurazione? No? Dai, va bene, più tardi allora. Per adesso, buon sonnellino! Heuuu... buona fortuna volevo dire! ";
D.q[470] = "Caspita... che wandellate che mi hai dato! Non potwò sedewmi pew un bel po\'... ti pwopongo qualcosa pew wingwaziawti di questo bel combattimento che mi ha wicowdato la mia gioventù... Scegli twa il mio bastone, il mio mantello o la mia cowona, ti offwo uno dei twe oggetti...\nMa sopwattutto towna a twovawmi, ci siamo pwopwio diwewtiti!";
D.q[7327] = "";
D.q[33] = "Argh, mi sono ancora fatto pungere da questi maledetti moskito... Mamma dice che è colpa della mia pelle di pesca troppo zuccherata... \nCredo che tu possa aiutarmi.";
D.q[6134] = "Mi porti le anime che ti ho chiesto?";
D.q[7637] = "Da quel che ne so dovrebbe essere alla milizia che sistema i suoi affari. Vai laggiù se devi parlarle.";
D.q[688] = "Ed ecco la seconda questione,\nCome si misura l\'attenzione\nin una coppietta di innamorati?\nIn termini di quantità, ti siamo grati.";
D.q[2211] = "Treffiori risiede nella regione che si trova a Sud. Chiedi alla taverna di Amakna, sono sicuro che qualcuno saprà dirti dove si trova, haha! Ha sempre avuto un debole per la birra...";
D.q[346] = "Ho diversi lavori da proporti: sterminare moskito, raccogliere legno di Alberagno, creare un Bastone in Radice di Alberagno e sterminare l\'Alberagno Ancestrale.";
D.q[7328] = "";
D.q[3808] = "Mi sembra un affare onesto, ecco la tua collana.";
D.q[4035] = "Ciao! Sono contento di rivederti, amico mio! Potresti aiutarmi ancora una volta?";
D.q[1741] = "Discepolo, devi imparare ancora molte cose. Cosa vuoi sapere?";
D.q[6564] = "Mettiti a quattro zampe.";
D.q[1736] = "Discepolo, devi imparare ancora molte cose. Cosa vuoi sapere?";
D.q[1732] = "Discepolo Anutrof, devi imparare ancora molte cose. Cosa vuoi sapere?";
D.q[5128] = "";
D.q[7869] = "Un giorno, quando sarò grande, sarò una principessa... Ecco cosa mi ripeteva mio papà prima della glaciazione. Ora lui è morto e io non sono cresciuta. In più, il mio compagno Knil mi ha abbandonata per andare da Anope, che trova più carina, e ho pure perduto il mio peluche Feca. Lo odio ancora più del Conte!";
D.q[7463] = "";
D.q[5354] = "";
D.q[2438] = "I banchi per lavorare la carne del Cacciatore sono nel retrobottega della macelleria.";
D.q[3370] = "Il mondo è popolato da deboli. C\'è un vero guerriero da qualche parte?";
D.q[7870] = "L\'hai ritrovata??\nGrazie grazie grazie!!! Siccome sei stato così gentile prendi questo kama di ghiaccio, io non ne ho bisogno.";
D.q[90] = "Ciao, sono Edrige Valling, famosa donna arciere. Sarò contentissima di rispondere a tutte le tue domande sugli Archi e sul modo di fabbricarli.";
D.q[2228] = "Ah, alla fine il cliente che me l\'ha ordinato è già andato via. Lo mangerò io allora. Non ci penso proprio a pagare la consegna!";
D.q[7871] = "Grazie per aver ritrovato il mio peluche. Apone è gelosa e rinfaccia a Knil di non avergliene dato uno...";
D.q[6926] = "";
D.q[1755] = "Gli Xelor sono personaggi molto intelligenti, per questo cercano di equipaggiarsi con oggetti che aumentino la loro intelligenza.";
D.q[7872] = "Buongiorno, assisto Aurora Boreale nella sua creazione di un villaggio nel ghiaccio. Sono in qualche modo il direttore tecnico del progetto.\nVedi, ora sto cercando di adattare una perforatrice ai nostri bisogni, ma ho anche altri strumenti di cui dovermi occupare nel frattempo. Eh, non dispongo di certo della stessa manodopera di cui disponeva il conte e per giunta il tempo era clemente, ma dovrò adattarmi.\nDimmi, hai mica della gomma da masticare, per caso?";
D.q[2838] = "Quindi vuoi diventare spia? Capiti bene, ho una missione per te.\nDi sicuro sai già che i Brakmariani hanno incendiato i depositi di cibo dei dragacchini della milizia. Quindi ti chiedi perché l\'hanno fatto, no? Eccoti l\'occasione per saperlo.\nVai subito alla Torre di Brakmar e troverai degli indizi su quello che tramano i Brakmariani. Approfitterai d\'essere nella città nemica per fare visita a Fidji Merlin e a darle questo, lei capirà. Quando avrà letto il contenuto della lettera, segui le sue istruzioni alla lettera, conto su di te.";
D.q[4420] = "Posso aiutarti?";
D.q[4223] = "Le opinioni divergono su questo argomento, ma si racconta che un terribile drago abbia tentato di attaccare questa creatura. Quest\'ultima avrebbe preso il drago con i suoi tentacoli per soffocarlo sotto la torba, prendendolo di sorpresa.\nI draghi incarnano la potenza, e molte persone non credono a questa storia. Ma i fatti sono evidenti, c\'è una carcassa di drago sepolta sotto la torbiera.";
D.q[6085] = "";
D.q[7330] = "";
D.q[1200] = "Bene, quindi desideri restare sotto la mia tutela, nell\'Ordine dell\'Occhio Attento. È una scelta di cui non ti pentirai.\nTuttavia, per confermare la tua richiesta, dovrai ritrovare il cancelliere dell\'Ordine. Da quando il suo topo di compagnia l\'ha lasciato, non fa altro che andare per taverne. Riportalo qui e accetteremo la tua richiesta.";
D.q[128] = "Per fabbricare gli archi sono utilizzati tutti i tipi di legno. Certi sono più adatti di altri, per cui non bisogna stupirsi se un arco in Legno di Frassino è meno efficace di un arco in Legno di Tasso. Di solito gli archi migliori sono composti da legni diversi, il che rende più complicata la loro fabbricazione. Bisogna inoltre essere in buoni rapporti con i Taglialegna.";
D.q[7873] = "Geniale, questo risolverà molti problemi. Sai che, se unita ad altri oggetti, questa gomma da masticare servirà per costruire un propulsore da neve, una scatola di direzione per la perforatrice o ancora riparare il termostato del sistema di tubature?\nPrendi questi Kama di ghiaccio, e se trovi altre gomme da masticare portamele immediatamente, d\'accordo?";
D.q[1745] = "I Feca sono personaggi molto intelligenti, per questo e cercano di equipaggiarsi con oggetti che aumentino la loro intelligenza.";
D.q[5357] = "Ma cosa...? Zzzzzz...";
D.q[3975] = "Cosa? Uccidere Wabbit? Non avere tempo, io dovere dare regali a femmine.";
D.q[7874] = "Ho bisogno di una grande varietà di piante per fare degli incroci multipli ed ottenere delle nuove specie più resistenti e multifunzionali.\nMolti Pappabuk hanno saccheggiato la mia serra e hanno dei Yucca Lele nei loro peli. Idealmente, bisognerebbe che 55 di queste piante sopravvivano.\nMi servono anche una decina di Tulip Osuzioni, che crescono nei campi, e due Bucaneve.";
D.q[4046] = "Ciao";
D.q[5198] = "";
D.q[7332] = "";
D.q[7639] = "Sbrigati, i miei preparativi avanzano rapidamente.";
D.q[4488] = "Desolato, ma non do certe informazioni così.";
D.q[7875] = "Sono contento di aver trovato qualcuno di cui fidarmi. Spero tu non abbia l\'intenzione di cambiare bandiera. In ogni caso, grazie.\nNon andare troppo lontano, ti chiederò di nuovo aiuto prossimamente.";
D.q[7331] = "";
D.q[7375] = "";
D.q[5356] = "Hai cinque secondi per spiegarmi quello che vuoi questa volta.";
D.q[6595] = "Png(1121) e Messaggio(6594)";
D.q[7376] = "";
D.q[4794] = "Allora, hai trovato la persona che, secondo Biph\'Olco, seguiva Bast Konliskerz quel giorno?\nSpero che quel bambino non abbia inventato questa storia solo per salvare il suo amico.";
D.q[7640] = "Ora che tutto è al suo posto devi andare a mettere questa collana d\'oro sulla tomba di Istriona, la madre di Gultard.";
D.q[7876] = "La ricchezza del suolo ha permesso un\'agricoltura molto intensiva ma oggi non ne restano che le spoglie. L\'inverno ha gelato la terra e ucciso i giovani germogli, la neve ricopre poco a poco i vegetali che tentano di sopravvivere.\nNella Foresta dei Pini Perduti nascono talvolta dei Mima Osamodas, ma questi fiori, una volta abbondanti, sono praticamente spariti, ai giorni nostri. Ho comunque bisogni di trovarne una decina per alcuni incroci di piante. Te ne puoi occupare tu e contemporaneamente portarmi una sessantina di Rose Nelson? Le troverai nei luoghi in cui vivono le creature della foresta.";
D.q[302] = "Non deprimerti più...";
D.q[621] = "L\'Alchimista è un manipolatore di elementi, magici e non. Trasforma materie in altre materie. Ma soprattutto, non pensate all\'Alchimista come ad un topo di laboratorio. Un vero Alchimista passa tanto tempo nel suo atelier quanto a viaggiare per il mondo alla ricerca di ingredienti rari. E posso dirti in tutta onestà e per esperienza, che quando non ti restano più peli di Buulupo... ebbene, ti fai coraggio e vai a cercarteli!";
D.q[7377] = "";
D.q[7641] = "Ecco cosa mi piace, la trappola è tesa ma restano ancora delle cose da fare. Siccome mi ci vuole tempo, mi aiuterai. Ho tante cose da fare e tu sei degno di confidenza. La mia padrona, la demone Minuit, mi ha segnalato un Bwork dotato per il combattimento. Potrebbe servire la mia padrona, portamelo mentre io perfeziono la mia opera.";
D.q[7877] = "Sapevo che dei Mima Osamodas erano sopravvissuti. Grazie per l\'aiuto.\nSe arrivo a portare i miei esperimenti alla fine potremo fare a meno dei cereali e la fame non sarà che un ricordo.";
D.q[7333] = "";
D.q[5470] = "Cosa? A tu piacere noce pecan? Gnam! Me preferire Meeela!";
D.q[7642] = "Cosa vuole tu? Grabumph?";
D.q[7878] = "Ho appena capito una cosa: se voglio soppiantare l\'agricoltura devo rendere più appetitose le piante rispetto ai cereali.\nI biscotti sono a base di cereali, ma quanti ne esistono a base di piante? Sto seriamente pensando di aggiungere del Rabarbapapà filato per stregare i palati dei consumatori. Si tratta di una pianta che cresce solo nelle grotte di ghiaccio, che per noi sono inaccessibili. Però i Pinguinotti le trasportano spesso, quindi ecco l\'occasione per recuperarne un po...\nAndresti al Lago Ghiacciato e convinceresti i Pinguinotti a darmi 65 Rabarbapapà filato?";
D.q[5732] = "";
D.q[7334] = "";
D.q[7378] = "";
D.q[7643] = "Me battuto, me prigioniero. Tu lasci villaggio e io seguire te.";
D.q[7879] = "Sei dotato per la negoziazione, senza dubbio. Anche il Conte Allarovescia lo era, è per quello che ha vinto il concorso agricolo proponendo una macchina rivoluzionaria: un estrattore geotermico gigante calibrato sulle stagioni, che permetteva di riscaldare le coltivazioni, grazie al vapore, durante la stagione fredda. E\' un derivato di quel sistema che riscalda le nostre serre attualmente.";
D.q[6737] = "Una breve pausa per fare merenda non fa male. Non hai preso niente per riempirti la pancia? Peccato. Io ho tutta una riserva di brioche dorate, diverse marmellate e perfino dei dolci. Ne vuoi? Avresti dovuto pensare a comprarne prima di partire!";
D.q[5436] = "";
D.q[7880] = "Molta gente abbandona i propri famigli o i proprio animali da compagnia. A Frigost, dopo la glaciazione, non è molto frequente, poichè gli animali non sopravvivono che qualche giorno.\nQuando il villaggio di ghiaccio sarà finito costruirò un cianil, così potrò accogliere tutte quelle povere bestie.";
D.q[5847] = "";
D.q[4190] = "Ho l\'impressione che tu stia cercando il modo di entrare in questa grotta puzzolente...\nSpero che tu sappia quello che stai facendo!\nE spero anche che tu sappia che non ti farò entrare se non mi darai la chiave. Io l\'ho persa sulla spiaggia di corallo, e penso che le creature che ci vivono me l\'abbiano rubata.";
D.q[3696] = "I raccoglitori di alto livello recuperano molte più risorse dei principianti.";
D.q[86] = "Non vendo stivali a chiunque, insomma!";
D.q[7881] = "Raccolgo i Tipinguinotti diventati orfani dopo il massacro delle loro madri da parte dei Pescatori e dei continentali.\nNe ho qualcuno di troppo e non ho più il tempo per occuparmi di tutti, senza contare che rischiano di scappare. Te ne darò uno in cambio di un Pescetto.";
D.q[7379] = "";
D.q[101] = "Ciao, se ti interessa vendo il Piccone di mio marito. Buone condizioni e usato molto poco.";
D.q[5528] = " È necessaria un\'altra firma sul registro. Senza di essa, sarò costretta ad annullare la procedura e le spese non saranno rimborsate.";
D.q[5947] = "";
D.q[1484] = "Una larva? Quale larva... AH! Una larva dorata! È una larva leggendaria! Secondo la leggenda non è altro che un neonato che... AH!, non abbiamo molto tempo. Devi riportare questa larva dai suoi genitori, prima che vengano a cercarla.";
D.q[7884] = "I miei gioielli di famiglia, li hai ritrovati! E\' mia moglie che sarà felice, in realtà.\nPrendi questa borsa di kama e non farne parola con nessuno.";
D.q[6927] = "";
D.q[4191] = "Il povero Corallaio Magistrale non è durato molto, ma non mi sono impressionata per questo!\nPrendi questi due regali in cambio della tua chiave, ti saranno molto utili.";
D.q[402] = "Zitto. Silenzio. Questa è una biblioteca. Sei hai bisogno di un libro chiedi a me. Ma in silenzio! Scchhh! Neanche una parola! Vai a sederti adesso, in silenzio!\nNon voglio più sentirti.\nNeanche una parola!";
D.q[6605] = "";
D.q[7885] = "Posso toccare?\nOooh, sono impressionato. Non ne avevo mai visti di così grossi e fermi. Allo stesso tempo morbido e solido, deve fondersi in bocca, sono tutto eccitato...\nMi hai aiutato, chiederò al mio amico della compagnia Asfog e Figlie di lasciarti usare il trasportatore, se vuoi andare alla Culla di Alma.";
D.q[6606] = "";
D.q[2707] = "Tempo fa noi Volpi elavamo i plotettoli di un Dofus.\nInvidiati dai Pandawa di Focodala, fummo vittime di un complotto tla gli stessi Pandawa e gli infami Wabbit! E fu così che ci caccialono dalla nostla isola... Per quanto liguarda il Dofus, nessuno sa cosa sia successo... Una cosa è celta: non l\'hanno preso né i Pandawa di Fuoco né i Pandikaze... altlimenti lo avlebbelo ullato ai quattlo venti! Per quanto ligualda i Pandawa di Aksadala, lolo sono miei amici. Limangono i Pandawa di Eldala... Mi falesti un bel favole se ci andassi a dale un\'occhiata... Ancola qui? Che aspetti?";
D.q[4819] = "";
D.q[7337] = "";
D.q[729] = "C\'è un tipo che gestisce una fiera nelle pianure, vorrei che tu andassi a verificare se si tratta dell\'ennesimo stratagemma nemico per nascondere un accampamento nelle vicinanze di Bonta.\n\nVai a parlare con Turi Ordin, fabbrica dei test infallibili per individuare i Brakmariani.";
D.q[6928] = "";
D.q[6607] = "";
D.q[1769] = "Qualche anno fa, i Feca usavano i Pappatutto per allenarsi a combattere, ma da poco abbiamo scoperto una razza chiamata Dabol che vive solo per combattere. Sono dei buonissimi avversari per allenarsi, qualunque sia il tuo livello.";
D.q[7886] = "Quel che manca a Frigost è un nuovo grande progetto. Prima l\'attività girava intorno all\'esportazione di risorse agrarie. Ora non è più così da molto tempo e noi passiamo le nostre giornate a provare a scongelare il porto... Tutto per colpa del Conte. Ho veramente voglia di mettermi a fare delle altre cose...";
D.q[5001] = "";
D.q[848] = "Certe teste dirigenti cominciano ad apprezzare... un po\' troppo il tuo lavoro. Bene, siccome ora sei così forte posso cominciare a darti delle missioni più difficili, vero? Sai, ho appeno pensato al tuo test di passaggio per la classe superiore. Devi andare a saccheggiare 5 miliziani di Bonta e portarmi il loro zain... no anzi, i loro calzoni. Haha.";
D.q[293] = "Ti darò un\'intera unità di farina, ma avrai anche il privilegio di assaggiare uno dei miei prototipi di pane al curry. Gli effetti non sono garantiti, ma potrebbero essere sorprendenti. Di solito per l\'assaggio uso il mio garzone ma di questi tempi è un po\' restio.";
D.q[6033] = "";
D.q[4831] = "Sono veramente obbligato a restare qui in compagnia di un Etram che puzza di pesce andato a male?";
D.q[5857] = "";
D.q[3672] = "Ora che sei diventato una persona competente, ricordati che il giorno in cui avrai un Dofus, non dovrai romperlo! Fare le crêpe con un uovo di Dofus non è molto ragionevole!";
D.q[643] = "La dolce brezza che ti carezza i capelli, l\'arma in pugno, il sorriso sulle labbra, l\'esaltazione del combattimento, l\'adrenalina che sale quando colpisci... Oh! mi dispiace, non ti avevo visto...\n\nCiao giovane avventuriero! Sono il guardiano di Tainela.\nI miei fratelli hanno già cominciato il tuo apprendistato. \nEccoti pronto per andare ad Amakna... \nScegli in fretta il tuo mestiere, scopri nuovi territori, impara ad usare quanti più possibili oggetti e incantesimi...\nNon dimenticare di tenere sempre gli occhi aperti in questo mondo e di diffidare delle intenzioni degli altri avventurieri.";
D.q[7888] = "All\'inizio ce l\'avevo con lui, per aver distrutto tutta quella vegetazione. Poi ho scoperto il fascino della terra innevata e ora spero di tutto cuore che l\'inverno duri per sempre.";
D.q[4194] = "Un giorno mentre facevamo scalo sull\'isola di Moon, dei vili pirati si sono nascosti nella stiva della nostra arca. Ci hanno attaccato quando siamo arrivati su quest\'isola, sono usciti dalla stiva in piena notte e hanno decimato quasi tutto il mio equipaggio. Hanno preso il controllo della mia nave, ma il loro capo confondeva la sinistra con la destra... e sono andati a finire nella torbiera... così hanno deciso di rimanerci per l\'eternità.";
D.q[5457] = "";
D.q[7887] = "Non credevo che un continentale ci sarebbe venuto ad aiutare.\nAbbiamo molto lavoro, ma poca manodopera e poco personale qualificato. Bisogna convincere la Sindaco Stoletta a farci reclutare gente nel Borgo, potresti occupartene tu? Io ho troppe cose da fare ed Aurora non è vista di buon occhio dalla Sindaco, per le sue idee troppo pro-invernali.";
D.q[5412] = "";
D.q[7427] = "";
D.q[5858] = "";
D.q[1397] = "...";
D.q[1798] = "Se vuoi affrontare un Dabol, portami un Pezzo del Puzzle dell\'Artiglio.";
D.q[3407] = "Il Mastro di Chiavi mi ha raccontato del tuo successo. Ho dubitato di te e me ne scuso. Non preoccuparti, manterrò la mia promessa. Ecco, metto nelle tue mani avide la reliquia della nostra famiglia. Sappi che tutti i guerrieri l\'hanno utilizzata, certi anche più volte! Ti avverto però... una potente maledizione colpirà colui che la restituisce! Fanne buon uso.";
D.q[5364] = "";
D.q[7889] = "Aurora Boreale ha delle idee strambe. Il nostro obiettivo è quello di sopprimere la maledizione dell\'inverno perenne. Quando ci riusciremo, il suo progetto del villaggio di ghiaccio cadrà in acqua... Non vedo dunque nessun interesse ad investire tempo e gente in un progetto destinato al fallimento.\nSo che dopo un secolo di glaciazione alcune persone non condividono più il mio punto di vista, ma se a loro va di sprecare il loro tempo, beh, buon pro gli faccia.";
D.q[268] = "Ci vuole troppo tempo per convincere un novizio con i discorsi... vai piuttosto in cantina da Juhdo Pol e chiedigli di allenarti.";
D.q[168] = "I Birrai sono in sciopero da quando un Croccaroc assetato ha distrutto la birreria del paese, ma il gestore della taverna ha deciso di prestargli la cantina perché possano installarvi una birreria e continuare a produrre la loro deliziosa Birra.\nSpero che la Birreria sia presto in funzione, perché le nostre riserve di birra diminuiscono a vista d\'occhio!";
D.q[362] = "Ciao. Mi chiamo Ronsha Nesto. Sono vedova. Anzi, sono quadri-vedova. Tutti i miei mariti sono morti con un Aculeo di Prespic piantato nel cuore. Le autorità non sono mai riuscite a trovare il Prespic all\'origine di questi terribili fatti.";
D.q[7890] = "Sembra divertente, in ogni caso più del disgelo del porto, ma ho paura di venir attaccato lungo la strada. Puoi accompagnarmi, per favore?";
D.q[4509] = "Buongiorno, hai parlato con Mel Aghignavon nella Torre degli Ordini? La pazienza non è il suo forte e faresti meglio a non essere in ritardo.";
D.q[4690] = "";
D.q[4781] = "";
D.q[1832] = "Se vuoi affrontare un Dabol, devi donare un po\' di Foglie di Girasole al tempio...";
D.q[2448] = "Ogni volta che perdi un combattimento, perdi anche punti Energia. Insomma, se non fai attenzione, te ne andrai presto all\'altro mondo. Pare che certe persone sappiano manipolare l\'Energia grazie a pozioni e pani incantati.";
D.q[7647] = "Pensi che io non abbia altro da fare se non ascoltare le tue suppliche? Fuori dalla mia vista.";
D.q[7891] = "L\'altra pazza vuole i miei marinai e i miei scaricatori per lavorare al suo progetto scemo del villaggio di ghiaccio? E\' fuori questione, rifiuto che chiunque sotto la mia responsabilità vada a lavorare laggiù. Mi serve un gran numero di persone qui, non le obbedirò come un cucciolo di Baubau solo perchè la signorina è una aristocratica...\nLa cosa è abbastanza chiara per te?";
D.q[5864] = "";
D.q[2011] = "E gli Yop lo sanno? Che roba! Ci mancano solo più i Sàcridi... bisogna veramente fare di tutto qui! Cassaforte e adesso anche guardie del corpo...";
D.q[4903] = "Allora, hai ritrovato il Martello di Luce?";
D.q[7892] = "Per chi mi hai preso? Non sono un ufficio di collocamento...\nSenti, mi va bene parlare della necessità di manodopera per la realizzazione di un villaggio scolpito nel ghiaccio, ma in cambio, mi devi promettere che mi farai un favore. Che ne dici?";
D.q[4985] = "";
D.q[7893] = "Grazie, non te ne posso parlare per ora, è troppo rischioso.\nQuando tutto sarà pronto ti farò sapere di quale tipo di servizio si tratta, ma mentre aspetti ricordati di non parlarne con nessuno, capito?";
D.q[2752] = "La divisa per praticare il Pandawushu è fatta di un mantello tradizionale e di una Benda Pandawushu, qualsiasi Sarto è capace di farne una. È indispensabile indossare questa divisa ad ogni passaggio di grado, quindi prenditene cura!";
D.q[5866] = "";
D.q[5865] = "";
D.q[2220] = "Allora? L\'affascinante Nepra Lido ti ha dato il Suborhube?";
