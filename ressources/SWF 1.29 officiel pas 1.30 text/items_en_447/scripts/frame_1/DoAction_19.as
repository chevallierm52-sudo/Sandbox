I.u[8688] = {n:"Ross Ghost Transformation",t:27,d:"You\'ve been transformed into a ghost to be able to get in the Pet Sanctuary.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Victory Mark",t:24,d:"You easily defeated the disciple. He agreed and gave you this scroll.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Transformation Potion Formula",t:24,d:"This book contains theories from various alchemists about the possibility of Wabbit Twansfowmation. All it does is show how little they\'ve done on the subject.",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Feanor",t:18,d:"Thanks to this pet, all your classmates will be giving you puppy eyes. Here\'s a tip: don\'t count your chickens before they hatch! You\'ll soon realize that your lover has been hypnotized by Fëanor. It won\'t even be an advantage: the one you once had eyes for will begin to munch on raw Snapper and rub up against your legs... Not the best. This pet only eats fish.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Candied Chilli",t:42,d:"This candied chilli is as explosive as the strainings from the devil\'s jockstrap. This mind bending mixture of sugar and fire led one Dragoturkey to a string of controversial victories in a the world Dragokart championships before being banned by all major sporting associations. You can use it as a suppository if you need to make a quick exit or as a pill if getting in is your problem.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"Sword Hikk",t:6,d:"Like Brice said: \"It\'s not the size that counts, it\'s the sharpness.\"",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
I.u[8696] = {n:"",t:23,d:"",ep:0,g:14,l:1,wd:false,fm:true,w:1,p:1};
I.u[8697] = {n:"Olol² Dofus",t:23,d:"description",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[8698] = {n:"Cloudy Dofus",t:23,d:"description",ep:0,g:16,l:1,wd:false,fm:true,w:1,p:1};
I.u[8699] = {n:"Tynril Hat",t:16,d:"You\'ll always have an out-of-bed look if you wear this hat, even if you\'ve spent hours brushing your hair. The hairs on a Tynril\'s bark curl when the weather is humid, which makes it the surest weather forecaster in the world. This hat fears fire, however, so be extremely careful and keep it away from flames if you don\'t want to become a human torch.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Emerald Shell",t:16,d:"This headgear has been crafted from a broken Emerald Dofus. The egg is not quite empty, so treat yourself to a nice, energising hair mask while you\'re at it.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Nicked Sword",t:6,d:"This sumptuous sword used to belong to a famous thief who was renowned for getting nicked every time he committed a crime.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8702] = {n:"",t:4,d:"",ep:0,g:74,l:1,wd:false,fm:true,w:1,an:12,tw:true,e:[0,0,1,1,0,0,false,false],p:1};
I.u[8703] = {n:"",t:5,d:"",ep:0,g:63,l:1,wd:false,fm:true,w:1,an:13,e:[1,0,1,1,1,1,false,false],p:1};
I.u[8704] = {n:"Jester Hat",t:16,d:"If you shake your two little bells, you might be able to play music.",ep:22,g:190,l:160,wd:true,fm:true,w:10,p:47625};
I.u[8706] = {n:"Fëanor Ghost",t:90,d:"This Ghost hasn\'t left the living world yet. Will you find a way to resurrect it or cowardly abandon it once and for all?",ep:3,g:48,l:1,wd:true,fm:true,w:1,p:1};
I.u[8707] = {n:"Bow Kennel Certificate: Fëanor",t:77,d:"This certificate describes the characteristics of the Finer you\'ve put in the Bow Kennels.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8708] = {n:"Bow Kennel Certificate: Atooin",t:77,d:"This certificate describes the characteristics of the Atooin you\'ve put in the Bow Kennels.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Fëanor Ghost Transformation",t:27,d:"You\'ve been transformed into a ghost to be able to get in the Pet Sanctuary.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Fëanor Gift",t:89,d:"If you shake this object vigorously and hold your ear to it, you\'ll hear a strange noise... like a tiny animal weeping... yeah, actually maybe you don\'t want to shake it... Ahhh, just open the damn thing. You\'ll find a wonderful pet inside it, as well as some food and healing Eniripsa powders.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Piece of Goldemort",t:110,d:"Congratulations! You managed to steal a piece of Goldemort\'s corpse. You\'d make a vulture proud!",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Getas Bernacles",t:11,d:"In some countries, it seems that the Getas Bernacle are thrown at the feet of enemies  to propose a duel... kind of like hitting your opponent with a pair of gloves. The advantage of the Getas Bernacles is that they add the stench factor to the actual blow. Pandawas never were famous for their foot hygiene...",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Honoh Ring",t:9,d:"Wearing this ring is an honour. It shows that you\'re a faithful worshipper of the goddess Cra, the only one to reveal how to harden your muscle more quickly to be able fire more effectively.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Blaber Ring",t:9,d:"Ecaflips have the gift of the gab. They can talk you into almost any bet you can think of. This ring celebrates their business smarts. It can also be used as a spare dice or to scratch yourself...",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Lion Ring",t:9,d:"Osamodettes love this ring which gives an extra feline touch to their walk. Because they\'re always so close to monsters, they\'re starting to behave like real animals themselves. But in reality, they\'re as devoted and caring as lioness mothers.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Ring Bellious",t:9,d:"Spiteful gossips claim that this ring is the least useful fashion accessory in the world. The wings attached to it are very awkward when you need to get a tissue out of your pocket. Now, as Iops have neither tissues nor pockets, they don\'t care. Instead, they prefer shredding their enemies\' flesh with the wings during close combat. Thinking about it, you wonder why this isn\'t the Sacriers\' ring instead.",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Memo Ring",t:9,d:"Fecas use the mini shields on this ring as memo boards to write love notes and to-do lists. This jewel has been nicknamed the anti-forgetfulness shield. However, it does not protect you from stammering or slips of the tongue.",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Rememb Ring",t:9,d:"Thanks to this item, Enutrofs can remember their happy times whenever they want. They just need to extract the shovel driven into it. To make the remembrance even more genuine, you\'d need to add a specific smell to it... Good luck!",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Chee Ring",t:9,d:"The goddess Eniripsa gave this item to her worshippers as a sign of their spiritual union during the class spell initiation session. Incidentally, Eniripsas can also use it as a sponge bracelet to clean off the blood of their allies.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Ear Ring",t:9,d:"This jewel tends to turn Pandawas into insulting devils after two or three beers... just remember the old proverb  \"Sticks and stones may break my bones, but a drunken bear-like creature will never hurt me.\"",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Elkebi Ring",t:9,d:"This jewel with a skull on it was traditionally offered to all Sram kids to reward them for their treachery and blows below the belt. The other classes seem to discredit this practice which tends to overexcite the kids and turn them into little devils.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Subma Ring",t:9,d:"This ring is the only jewel that can tell the time and which is perfectly waterproof. Some believe that if you enlarge it a few hundred times, it\'ll make a submarine too. A submarine that can tell the time.",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Hai Ring",t:9,d:"Contrary to the rumour, Sadidas do not let their hair down... This hair has just been adjusted round a wonderful ring to reinforce its benefits. Never ever cut it! Thanks to the Hai Ring, you\'ll always be perfect!",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"Ring Neinwonwon",t:9,d:"If you see a character who\'s not a Sacrier wear the Ring Neinwonwon, take him directly to intensive care. Indeed, this jewel is extremely harmful. In general, people lose their cool when they face the pool of blood caused by this ring.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Crusuede Shoes",t:11,d:"These shoes enable their wearer to dance all night long, despite blisters and corns! They dance to the rhythm of the night and make a little \"beep beep\" sound when they\'re next to religious artefacts. You\'ll be bright as a button the next day too, ready for a bit of slaughter.",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Relief Boots",t:11,d:"When Fecas are embarrassed and wish to change the subject, they always mention their Relief Boots. They talk about the way you can pace up and down all sorts of landscapes with them on. When their allies are in trouble on the battlefield, these comfy boots help them recover and ward off the threat.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Veggie Boots",t:11,d:"The numerous straps around these shoes can be used as spare bow strings. Young Craettes also use them to cook vegetables. The smell of feet doesn\'t seem to bother them.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Worn Coral",t:51,d:"Coral only loosens itself from the Coralator when the weather is dry. Coral is a beautiful substance and is often used to make jewellery. Other brutes actually eat it... but only because they mistake it for crab sticks.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Coralator Coccyx",t:47,d:"This strategically-located bone enables the Coralator to sit down with dignity. Now that he\'s dead, you can use it to establish your own authority upon his fellow creatures.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Great Coral",t:51,d:"The only difference between the Worn Coral and the Great Coral is their size and what you can do with them. However, a whole lot of worn Corals will never replace a Great Coral.",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Kurasso Coral",t:51,d:"This coral\'s remarkable blue colour is a result of the Kurasso Craboral\'s unhealthy diet. It doesn\'t even manage to eat a single piece of fruit or veg a day, let alone 5!",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Mahlibuh Coral",t:51,d:"This coral\'s remarkable green colour is a result of the Mahlibuh Craboral\'s unhealthy diet. It doesn\'t even manage to eat a single piece of fruit or veg a day, let alone 5!",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Passaoh Coral",t:51,d:"This coral\'s remarkable red colour is a result of the Passaoh Craboral\'s unhealthy diet. It doesn\'t even manage to eat a single piece of fruit or veg a day, let alone 5!",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Mojeeto Coral",t:51,d:"This coral\'s remarkable yellow colour is a result of the Mojeeto Craboral\'s unhealthy diet. It doesn\'t even manage to eat a single piece of fruit or veg a day, let alone 5!",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Polished Stone Heart",t:51,d:"The only thing that can differentiate a Crackler\'s heart from that of a polished Crackler is the delicacy with which the item can break between your toes when you least expect it.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Polished Ball",t:51,d:"From what part of the Crackrock\'s anatomy does this ball come? And why do they always come in pairs?",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Great Sacrum",t:47,d:"The Coralator offers you a bone from its backside. It doesn\'t have much use for it anyway.",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Sparo\'s Humerus",t:47,d:"Even though this bone\'s called a humerus, it\'s hard to tell if it actually comes from Sparo\'s arm. When he died, his skeleton was put in a barrel and smashed up. It sounds painful, even for a bone.",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Flib\'s Stump",t:47,d:"If I were you I wouldn\'t pick this thing up - the mouth it came from is about as clean as the devil\'s crotch. But well, you\'re the adventurer, you know your business!",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Kido Beak",t:47,d:"This beak is so fragile that Otomai\'s disciples used it to make training arrows with blunt ends.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Craboral Pincer",t:47,d:"Just avoid shaking a Craboral on the pincer! You might lose your hand to politeness.",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Kurasso Petal",t:35,d:"The colour of this petal reveals its doubtful origin. Alcohol abuse can even be noticed in Otomai\'s disciples\' creations.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Mahlibuh Petal",t:35,d:"The colour of this petal reveals its doubtful origin. Alcohol abuse can even be noticed in Otomai\'s disciples\' creations.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8747] = {n:"Passaoh Petal",t:35,d:"The colour of this petal reveals its doubtful origin. Alcohol abuse can even be noticed in Otomai\'s disciples\' creations.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Mojeeto Petal",t:35,d:"The colour of this petal suggests its doubtful origin. Alcohol abuse can even be noticed in the creations of Otomai\'s disciples.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Kurasso Bulb",t:36,d:"The Palmflower doesn\'t grow from a seed but a bulb soaked in alcohol. Why? Just because!",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Mahlibuh Bulb",t:36,d:"The Palmflower doesn\'t grow from a seed but a bulb soaked in alcohol. Why? Just because!",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Passaoh Bulb",t:36,d:"The Palmflower doesn\'t grow from a seed but a bulb soaked in alcohol. Why? Just because!",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Mojeeto Bulb",t:36,d:"The Palmflower doesn\'t grow from a seed but a bulb soaked in alcohol. Why? Just because!",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Mane in Bloom",t:36,d:"This mane is an improbable hybrid of hairs and flower petals, which means it\'s doubly allergenic. So keep away if you\'re sensitive... a single sneeze could send your brain flying out your nose.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Barbrossa\'s Ridiculous Beard",t:54,d:"This tiny hair tuft will remind you of your holidays thanks to its smell of sand, sunscreen and alcohol. What a pity it stinks so much of gunpowder too!",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Flib\'s Red Tuft",t:54,d:"No one knows whether the colour of this tuft is natural or due to some untimely bush fire.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Kilibriss Down",t:54,d:"Kilibriss down is light and much sought after for the making of mattresses.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Barbrossa\'s Shirt",t:15,d:"Do you need an insect repellent? Just put Barbrossa\'s Shirt on! One side effect is that people will vomit automatically if they come within five feet of you.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Gourlo\'s Wrecked Shorts",t:15,d:"No one ever found an intact pair of Gourlo\'s shorts - he was a pyromaniac, and frequently burnt his clothes right off his body.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Flib\'s Cursed Little Box",t:15,d:"This box is shaped like Flib... unless it\'s the opposite! In any case, it\'s still a cursed little chest.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Sparo\'s Scarf",t:15,d:"This scarf is an essential accessory for both the summer and winter seasons. It will give you an original look, though a bit kitsch. Its flashy colour will certainly excite male Gobballs, but is that really what you want?",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Gourlo\'s Explosive Powder",t:48,d:"To compensate for the cannon he couldn\'t transplant as an arm, Gourlo never goes out without his weapon. He can\'t shoot very quickly since he must wait for the powder to dry each time.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Polished Brain Fragment",t:50,d:"Thanks to this fragment, you\'ll learn the Cracklers\' good manners: hand crushing to say hi.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Mufafah Moustache",t:15,d:"Marylork the painter prefers his brushes to be made from thick, luxuriant Mufafah Moustache, rather than the slightly wispy Kittenfish Moustache, which is liable to blow away in the slightest of breezes.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Greater Bherb Eyebrow",t:15,d:"To prove that he\'s the Boss, the eyebrows of the Greater Bherb are always frowning, even beyond death.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Kilibriss Staff",t:15,d:"Thanks to its length, this staff will enable you to reach the most difficult places to access and to scratch yourself all over.",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Kido Rear Feather",t:53,d:"One of Otomai\'s greatest riddles was inspired by this resource: what\'s the heaviest? One hundred pods of Kido feathers or one hundred pods of Pyrute?",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Plain Pikoko Wing",t:104,d:"The Pikoko never was famous for its grace in flight. Once you\'ve seen its wings, well, you\'ll understand why.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Torn Pumbaa Ear",t:106,d:"If you stick this ear to yours, you\'ll be able to hear the plain boar gallop instead of the  roar of the sea.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Plain Pikoko Nut",t:111,d:"There\'s no milk in this Pikoko Nut but you\'ll find some brain juice with a few floating neurones.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Tynril Bark",t:96,d:"This bark is curiously curved. It looks like it went through a rasp.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Floramor Bark",t:96,d:"This bark is curiously curved. It looks like it went through a rasp.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Rotaflor Bark",t:96,d:"This bark is curiously curved. It looks like it went through a rasp.",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Gwass Bark",t:96,d:"This bark is curiously curved. It looks like it went through a rasp.",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Barkritter Bark",t:96,d:"This bark is curiously curved. It looks like it went through a rasp.",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Warguerite Bark",t:96,d:"This bark is curiously curved. It looks like it went through a rasp.",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Dark Pikoko Nut",t:111,d:"There\'s no milk inside this Pikoko Nut, just brain juice. If you\'re lucky, you might find a few neurons floating on the surface.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Tynril Pistil",t:36,d:"Should a Sacrier be lucky enough to remove several of these sexual organs from the four Tynrils after a long, arduous fight, the rest of his teammates would be well within their rights to refer to them as \"The Sac\'s Pistils\". Whether they should or not is another matter altogether.",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Floramor Stamen",t:36,d:"The stamen is the male organ of a plant. Yep! Despite appearances, it seems that Floramor is a male...",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Rotaflor Carpel",t:36,d:"A little biology lesson: the flowers are the plants\' sexual organs and the pistil is part of the flower while the carpel is part of the pistil... I\'ll let you decide what does what.",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Gwass Sepal",t:36,d:"This part of the Gwass\' body is always green, no matter what. Is it due to some excess of chlorophyll or to something else?",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Barkritter Calyx",t:36,d:"Don\'t bother trying to use the Barkritter Calyx to drink anything. It might resemble a cup, but it\'s about as solid as a sieve.",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Warguerite Bract",t:36,d:"The Warguerite bract refers to an area that decency prevents me from uttering.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Dark Pikoko Tonsils",t:15,d:"The Dark Pikoko is not as nuts once he\'s got his tonsils removed. Well, this is no surprise since the surgery usually kills him.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Dark Treeckler\'s Achilles\' Heel",t:15,d:"You won\'t defeat the Dark Treeckler by shooting an arrow in his Achilles\' heel. But you can always try...",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Dark Treeckler Seed",t:58,d:"With a lot of patience, time, water and fertilizer, you might manage to grow a Treeckler in your garden so that you can practice fighting against him. It would be easier to just catch a boat to Otomai Island..",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Cheeken Plait",t:15,d:"This thick and harsh hair can be used as a mop if not to hide your baldness. But you\'ll have to wash it many, many times before.",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Cheeken Cloaca",t:15,d:"No, it\'s not disgusting! It\'s nature!",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Air Pikoko Rump",t:15,d:"This rump will enable you to create items that will cover up your own backside.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Kimbo Sock",t:15,d:"Despite appearances, Kimbo does wear socks, but he just doesn\'t wear them on his feet. He prefers rolling them and then placing them in strategic places.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Moopet Stuffing",t:15,d:"Nature having been only modestly generous to the Moopet, the creature has to resort to artifice to pass for a living thing. At times, he uses it to make his bed pass for a bed too.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Moopet Fabric",t:55,d:"This fabric has a strange texture but will quickly dress any modest monster.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Air Pikoko Nut",t:111,d:"There\'s no milk in this Pikoko Nut but you\'ll find some brain juice with a few floating neurones.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Snailmet Shell",t:111,d:"Round and shiny, this shell has been polished with slobber for several centuries.",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Kimbo Wig",t:54,d:"To hide his premature baldness, Kimbo puts on this stupid wig. Fortunately for him, the coconut covers most of it.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Light Treeckler Knot",t:38,d:"Captain Chafer heard the name of this object, and for ever more, the Treeckler was known as \"Knob Head\".",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Light Treeckler Stump",t:38,d:"A stump unlike any other stump, and yet, it spins.",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Greater Bherb Feathered Tail",t:65,d:"One by one, year after year, the number of feathers on the Bherb\'s tail increases. You can tell its age by the bushiness of its brush.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Pumbaa Armpit Hair",t:54,d:"Even if he often shaves it off, his hair always grows back thick and smelly. So the smell is not due to sweat.",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Zoth Fabric",t:55,d:"Made of a soft and resistant material, this fabric is perfectly adapted to the Zoths\' figure and hides what needs to be hidden.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Ouassingue Fabric",t:55,d:"This fabric has more holes than Swiss cheese, but it is still capable of absorbing a maximum amount of waste to regurgitate at the least opportune moment.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Zoth Warrior Shinbone",t:47,d:"Just like all the other bones of the Zoth Warrior, this shinbone has been broken many times. It healed perfectly and became even stronger. If it could talk it would say: \"What doesn\'t kill you, makes you stronger.\"",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Zoth Disciple\'s Kneecap",t:47,d:"Since the Zoth Disciple always attacks with his knees, the kneecaps became extremely large and tough. I know tortoises who\'d trade their shells for one of these things.",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Zoth Master\'s Fly",t:15,d:"The Zoth Master\'s fly is outstanding. It\'s been specially designed not to cut you.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Zoth Girl\'s Handkerchief",t:15,d:"The Zoth girl does not use this handkerchief to wipe away her tears but to clean off her enemies\' blood.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Zoth Sergeant\'s Tab",t:15,d:"This embroidered tab is more of a childhood memory than a military insignia.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Ouassingue Juice",t:15,d:"Unless you\'re flaming drunk, there\'s no way you\'ll confuse Ouassingue juice with any drinkable liquid you can name. The nauseating stench will dissuade the blind from knocking back a mouthful.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
I.u[8808] = {n:"Mopy King Fabric",t:55,d:"This fabric has more holes than Swiss cheese, but it is still capable of absorbing a maximum amount of waste to regurgitate at the least opportune moment. BANG! And the dirt is back.",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"Mopy King Inside Out Shorts",t:15,d:"Taking after their ancestor, Mopy King Dagobert, all Mopy Kings wear their shorts inside out. What\'s confusing is that it doesn\'t turn their stomachs inside out as well.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Dried Mopeat Peat",t:15,d:"Made from rotting vegetables, this peat has incredible powers of absorption. Mama Bworks save them for Auntie Floe\'s monthly visits.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Miremop Double Chin",t:15,d:"The Miremop spends a lot of his time taking mud baths in the hopes of slimming down. He has never lost an ounce, but at least his double chin evens out his figure.",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Gigantic Kralove Ink",t:15,d:"Slimy and dense, the Kralove ink can be used either to write romantic letters or to paint your room a depressing black depending on how your love-life\'s going.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Gigantic Kralove Sucker",t:15,d:"Given the size of this sucker, there\'s no doubt about its grip. And when you remove it, the slurping noise is deafening.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Purse of 5,000 Kamas",t:100,d:"This purse is heavy - it must be worth a fair bit. A tradesman will be happy to exchange it for its value in Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Purse of 1,000 Kamas",t:100,d:"This purse is quite heavy - it must be worth something. A tradesman will be happy to exchange it for its value in Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Gift: Wicked Sword",t:89,d:"If you shake this gift box vigorously, you\'ll find it\'s not empty. For once, the gods might not have been pulling your leg.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Gift: Satanass\' Hat",t:89,d:"If you shake this gift box vigorously, you\'ll find it\'s not empty. For once, the gods might not have been pulling your leg.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"Mopy King Sovereign Cape",t:17,d:"Made from Mopy King Fabric, this cape is riddled with micro-holes that allow sweat to escape more easily during periods of intense exercise, during aggressive melees in steamy swamps, for example. Even though this cape lets the humidity out, it keeps the heat in. This way you\'re always dry, no matter the situation. What a pity the stench of mould is so hard to shift, though.",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Ouassingue Cape",t:17,d:"Even though this cape is not as powerful as the fancier Mopy King version, it still has the same sweat evacuation system. You\'ll be able to face any situation wearing it, as long as you\'re able to fight while holding your breath, that is. The stench is truly unbearable!",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Zoth Sergeant Mask",t:16,d:"Thanks to this mask, you\'ll face all sorts of dangers without fear! But it\'s normal since it blocks the view.",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Zoth Disciple Hat",t:16,d:"From a distance, this hat looks like a lampshade with two holes for the eyes. It looks the same up close actually.",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Light Treeckler Mask",t:16,d:"This mask won\'t help you avoid or heal hangovers, but at least it gives you some chance of hiding the effects.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Dark Treeckler Mask",t:16,d:"This mask won\'t help you avoid or heal hangovers, but at least it gives you some chance of hiding the effects. The dark touch simply indicates that you\'re in a bad mood... and that you should not be annoyed and you\'re ready to throw a flurry of blows to anyone who does not respect that!",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Snailmet",t:16,d:"You\'ll look like a Snailmet if you wear this hat. Of course it will protect your head from blows, but does that make up for the slobber all over your head?",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Great Coralator Mace",t:7,d:"Bigger, heavier and more powerful, this mace makes a louder noise when smashing the enemies. But curiously, it\'s lighter and has a better grip to it. The Coralator we used to make it wasn\'t great for no reason!",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Zoth Girl Hammer",t:7,d:"Despite her small size, the Zoth Girl carries a huge hammer. It\'s a way to reinforce her muscle structure. No need to add weights round her wrists and ankles to increase her strength. Dragging the hammer is quite enough!",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Zoth Warrior Axe",t:19,d:"The Zoth Warrior is used to carrying two axes because he can\'t reach his enemy\'s left side with his right hand. It\'s hard to tell whether it is due to a lack of self-confidence or if he was just born clumsy!",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Cheeken Wig",t:16,d:"The Cheeken is an awkward winged creature which has as much energy as if it had the avian flu and is as intelligent as  a Tofu. No need to say that it was not especially proned to survive. However, some people seem to just love its weird hair looking like a plaited mop. Human nature is an infinite mystery!",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Barbrossa\'s Hat",t:16,d:"This hat is large enough to hide Barbrossa\'s ridiculously hairless head and beard. But it won\'t cover big-headed skulls.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8832] = {n:"Snailmet Slobber",t:15,d:"This Snailmet slobber won\'t break a Pikoko\'s bones, but it\'ll certainly keep one glued to the ground.",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Coralator Mace",t:7,d:"This hammer took its nice colour from the pieces of Coralator used to make it. Unlike what people think, it was not originally used to crush Iops and other enemies, it a door knocker for the hard of hearing.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Dark Treeckler Branch",t:3,d:"This branch was apparently used to scrape some otherwise inaccessible body part. But don\'t worry, the dark colour is authentic, it\'s got nothing to do with the various sorts of deposits contained in the inaccessible cavities of the Treeckler.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Light Treeckler Branch",t:3,d:"This branch was apparently used to scrape some otherwise inaccessible body part. This might explain the stick\'s stickiness.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Rotaflor Stem",t:4,d:"Rotaflors use their stem to clean their ears. However, staff carvers prefer to use them as a weapon. Proof, if needed, that there\'s no accounting for tastes.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Zoth Master Staff",t:4,d:"This staff completely binds the Zoth Master, making him fearless and therefore formidable. When it comes to eating though, it makes an awful mess.",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Tynril Rhizome",t:4,d:"Just like weeds, Tynrils can breed infinitely thanks to this simple piece of rhizome. After making this discovery some greedy staffmakers make a staff from Tynril and tried to breed it. It was a miserable failure.",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Thierry Voodoo Mask",t:16,d:"This is reputed to be the only mask that allows you to eat while you wear it.",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Jav Voodoo Mask",t:16,d:"When Jav Kanniballs feel a little blue, they dye their hair this colour. Is it due to frustrated love or something else? Hard to know for sure, but It would be great if they could just wear the mask and stop telling everyone how sad they were.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Sarbak Voodoo Mask",t:16,d:"Many moons ago, the Kannibal\'s were travelling actors respected for their comedies and tragedies, as represented by two masks - one laughing, the other cruel. When their chief lost the happy mask, the Kannibals descended into savagery.",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Archer Voodoo Mask",t:16,d:"Kanniball archers can\'t concentrate and aim right unless they are very angry. They painted their masks red so they\'d be fuming all the time.",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Crocodyl Dandy\'s Hat",t:16,d:"When he puts on this hat, Crocodyl Dandy thinks he\'s at the forefront of fashion. Fashion must be pretty dull if that\'s the case. However, it\'d be best if you didn\'t let him know how ridiculous he looks, after all, he is particularly touchy...",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"Mopy King Sovereign Hood",t:16,d:"This hood, a royal headdress, shares the same virtues as the Mopy King Sovereign Cape. Its micro-vents allow sweat to drain away more easily, so you\'ll always have a cool head. Unfortunately, it also has the same defects as the cape: its foul stench is so strong, you could almost cut it with a knife.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Ouassingue Hood",t:16,d:"Though it is less efficient than the royal hood, this one allows for a good draining of the sweat. Maybe too good, actually. As a result, whether you wear it or not, it doesn\'t make any difference.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Zoth Girl Hat",t:16,d:"The Zoth girl\'s hat makes her see double. Strange. This is the reason she lisps.",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Zoth Warrior Helmet",t:16,d:"This helmet has the same advantages as other Zoth hats - it\'ll protect you from the sun no matter how hot it is, from blows dealt on the head, and it prevents the wearer from being aware of the danger by restricting his visual field. Anyway, this is the perfect warrior headgear.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Zoth Master Hat",t:16,d:"The Zoth Master hat has the great advantage of almost completely restricting your field of vision... This way, you have to hit out wildly, so you\'ve some chance of hitting something.",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Barkritter Root",t:4,d:"This stick is a firm favourite with the trunk-women. But it\'ll seduce any old kind of girl. Probably.",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Floramor Root",t:4,d:"If you\'re superstitious and always need to knock on wood, use the Floramor Root! On the other hand, you should try to be careful not to saw the branch you\'re sitting on and especially not to get your fingers in the way!",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"Worn Treasure Map",t:24,d:"Even though your eyes are wet with joy, you are still able to read that the treasure is hidden somewhere along the road of enslaved waters.",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"Crack Sparrow\'s Own Withered Hat",t:16,d:"You say that a kraken, with the foulest breath you\'ve ever seen, follows you wherever you go? Well, deal with it: it\'s only a tiny inconvenience that comes with the hat!",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"Sharkal Shield",t:82,d:"This shield is protecting you for now, but don\'t be fooled, it won\'t last.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Bherbal Bherb Belt",t:10,d:"When the Bherb has got butterflies, he wears his Bherbal belt and healthily eliminates them.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Boots Kwish",t:11,d:"These boots create a disgusting suction noise with each step, which will remind you of a rutting Trool\'s love chant if you\'ve ever heard it. A painful memory that you could easily live without.",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"Mopy King Sovereign Seal",t:9,d:"This seal indicates that its owner is the undisputed sovereign of the Bottomless Peat Bog of Otomai Island. It\'s hard to imagine a more pastoral kingdom...",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Coral Ring",t:9,d:"This ring was pulled off the still-warm finger of a freshly slaughtered Coralator. His mother was expecting him for dinner, until she saw him being transformed into a tombstone. Coralators are not as stone-hearted as people might imagine.",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Round Kimbo Sandals",t:11,d:"Only Kimbos, with their weird feet, feel comfortable in these sandals. However, they\'re not the only ones who can benefit from their powers. But be careful not to wear them the wrong way!",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Parkinn Pan Pikokowal Belt",t:10,d:"Parkinn Pan truly believed that he could fly thanks to this belt trimmed with Pikoko wings, but didn\'t know that very few Pikokos can fly. That\'s why every time he jumped off the Tree Keeholo he systematically crashed on the ground. His nickname \"Cake\" comes from \"falling as flat as a pancake\".",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothulet",t:1,d:"This amulet is just a piece of wood with a strip of torn fabric. But Zoths are absolutely convinced that it has powers. Old fools!",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Snailmet Bow",t:2,d:"This bow string is made of Snailmet slobber, not too dry with a unique elasticity. However, its slimy and gooey texture reminds you of ... well, nothing really, but it\'s quite unpleasant.",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Snailmet Ring",t:9,d:"Carved in a Snailmet carapace, this ring can resist anything or anyone.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Powerful Dazzling Cloak",t:17,d:"Weaved from Zoth fabrics, this cape has extraordinary power of unknown origin.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Moopet Cape",t:17,d:"With this cape on, you\'ll be craving for some vinaigrette.",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Cheeken Axe",t:19,d:"The Cheeken Beak on this weapon is absolutely useless, and can be more of a handicap than anything else. \nFortunately, it is quite powerful.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Wooden Treeckler Boots",t:11,d:"These boots are so heavy that they should actually be categorised as weapons. Indeed, they make the slightest kick lethal.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Dark Treeckler Belt",t:10,d:"Carved in a Dark Treeckler, this belt isn\'t pliable enough to let you move around easily, but at least, it\'ll protects you.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Light Treeckler Belt",t:10,d:"Carved from a Light Treeckler, this belt won\'t afford you great protection, but at least it is soft enough to let you move around freely.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Ring Dikuloos",t:9,d:"This jewel is not precious but is the perfect size to balance the moorgale in a nice belgroot flavoured with a hint of Glaviooze.",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Krabelt",t:10,d:"Finally a good excuse to smell of the sea!",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Ouassulet",t:1,d:"This jewel sometimes tries to steal some of your food when you\'re eating, so don\'t let it hang down too low.",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Inky Veil",t:17,d:"This strange cape seems to be made of black ink, but oddly enough, it behaves just like fabric - it doesn\'t run. As for stains, well, that\'s another matter. Your backside will never be clean again.",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Kringlove",t:9,d:"Once round your finger, you won\'t be able to take it off, ever. Its suckers are way too powerful.",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kidommer",t:7,d:"This hammer is not handy, not particularly good looking, not very ergonomic, not powerful, too light, too fragile, unbalanced, too shiny and smelly. But at least it\'s got pretty colours.",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
I.u[8879] = {n:"Polished Ring",t:9,d:"Unfortunately, this ring is only polished on the outside. You put your finger through a hole full of sharp rock fragments. It is recommended for Sacriers.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Amufafah",t:1,d:"It\'s the Mufafah moustaches that cause the wearer of this necklace to bellow so loudly. Why? They hang down and tickle the nipples constantly.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Solo\'s Ring",t:9,d:"Solo was a nice good-for-nothing, and he admitted as much himself. That didn\'t stop him from being hanged on the village square for stealing a thong belonging to the chief\'s wife. Solo wasn\'t a bright guy, no, but he was a nice guy all the same..",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Guild House Potion",t:12,d:"This potion enables you to get back to your guild house.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Tabby Bow Meow Ghost",t:90,d:"This Tabby Bow Meow hasn\'t left the living world yet. Will you find a way to resurrect it or cowardly abandon it once and for all?",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Tabby Bow Meow Ghost Transformation",t:27,d:"You\'ve been transformed into a ghost to be able to get in the Pet Sanctuary.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8887] = {n:"Bow Kennel Certificate: Tabby Bow Meow",t:77,d:"This certificate describes the characteristics of the Tabby Bow Meow you\'ve put in the Bow Kennels.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8888] = {n:"Bow Kennel Certificate: Mischievous Squirrel",t:77,d:"This certificate describes the characteristics of the Mischievous Squirrel you\'ve put into the Bow Kennels.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
