I.u[11367] = {n:"Syringe of Lurgi vaccine",t:24,d:"This syringe contains a single dose of vaccine against the Lurgi, tested and certified by Rose Line.",ep:0,g:31,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11368] = {n:"Mama Pingwin",t:32,d:"This Mama Pingwin follows you because she has no choice, but she will flee at the first opportunity.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11369] = {n:"Panoramist\'s Seed",t:24,d:"This seed has been entrusted to you by Panoramist to repopulate the Lonesome Pine Trails.",ep:0,g:831,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11370] = {n:"Friswein",t:79,d:"This drink is very sweet and has the distinction of being made from frozen grapes. This explains its rarity and its unique, refined taste.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,p:2};
I.u[11371] = {n:"Frigrowka",t:79,d:"Also known as the \"Mastogob grass drink\", Frigrowka is said to facilitate human contact and address difficult issues. As for Frigostians, they drink it mostly because they like to drink.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,p:2};
I.u[11372] = {n:"Paper Cape",t:17,d:"This cape is long enough for you to be able to afford to leave blank lines between each cribbed note you\'ve made before you take that all-important, life-changing exam.",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:166,p:9175};
I.u[11373] = {n:"Paper Hat",t:16,d:"The tailor who made this hat had to use 12 powerful characteristic scrolls to craft it. Or possibly 12 sheets of toilet paper.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:166,p:9400};
I.u[11374] = {n:"Paper Amulet",t:1,d:"There\'s enough room for one of your friends to write your name on this paper amulet, which is just what breeders do so they know which Gobballs belong to them.",ep:0,g:0,l:62,wd:false,fm:true,w:10,an:0,s:166,p:10100};
I.u[11375] = {n:"Paper Pants",t:1,d:"This strong and rigid undergarment is not very comfortable, but then it was made with paper mache, after all. Having the saliva of a stranger on your buttocks does not seem to bother you in the slightest, I notice.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:166,p:9900};
I.u[11376] = {n:"Feather Cape",t:17,d:"This huge feather cape accentuates your figure.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:167,p:8428};
I.u[11377] = {n:"Feather Hat",t:16,d:"In some tribes, the wisdom of the Chief is measured by the number of feathers on his hat. Yours has only one, and what\'s more, it is very small, and quite grubby.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:167,p:9380};
I.u[11378] = {n:"Feather Sandals",t:11,d:"Lighter than conventional sandals, they have only one real drawback, they don\'t suit ticklish people at all.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:167,p:8230};
I.u[11379] = {n:"Feather Amulet",t:1,d:"This amulet will tickle your neck and make you cough up that frog in your throat.",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:167,p:9250};
I.u[11380] = {n:"Wounded Hunter",t:32,d:"This wounded hunter needs Herr Peece\' medical expertise. At the slightest hint of a fight, he\'ll take refuge where you found him.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11381] = {n:"Request for a Harness",t:24,d:"This request was prepared by Djauns for a harness for Snow Bow Wows. Before signing it, he reminded you to hurry because time is running out.",ep:0,g:55,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11382] = {n:"Poppinz Cape",t:17,d:"The last person who tried to use this cape to fly down from a cloud crashed into a bank.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:168,p:8300};
I.u[11383] = {n:"Poppinz Hat",t:16,d:"This hat isn\'t waterproof, and as a result, you\'ll have to use a ridiculous umbrella wherever you go.",ep:0,g:0,l:53,wd:false,fm:true,w:10,an:0,s:168,p:7503};
I.u[11384] = {n:"Poppinz Ring",t:9,d:"Hook this ring around the neck of any children in your charge, and then connect the ring to a rope that you\'ve hung from a tree. Now you can enjoy yourself and the children can\'t escape.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:168,p:8895};
I.u[11385] = {n:"Intact Snowfoux Fur",t:24,d:"Collecting this fur without damaging it was no mean feat when you take into account how badly you fought its former owner.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11386] = {n:"Poppinz Boots",t:11,d:"These boots are perfect for dishing out punishment with your feet so that you don\'t have to get your hands dirty. The children will adore you!",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:168,p:9275};
I.u[11387] = {n:"Gaston",t:32,d:"You must escort him to Larry Tutthe so he can become his new assistant.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11388] = {n:"Crate of Equipment",t:24,d:"This crate contains everything that Larry Tutthe needs.",ep:0,g:44,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11389] = {n:"Water Sample",t:24,d:"You collected this water from the Tears of Ouronigride for Ogivol Victor.",ep:0,g:764,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11390] = {n:"",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11391] = {n:"Modified Water Creature",t:24,d:"This creature is developing right before your eyes! You\'d better hurry up or it\'ll get so big you won\'t be able to carry it any more.",ep:0,g:760,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11392] = {n:"Snowfoux Remains",t:24,d:"You proudly fought the Snowfoux. Their remains are proof of your victory.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11393] = {n:"Prisoner Cape",t:17,d:"The striped cape belonged to a prisoner famous for his dilemma.",ep:0,g:0,l:51,wd:false,fm:true,w:10,an:0,s:169,p:7003};
I.u[11394] = {n:"Prisoner Hat",t:16,d:"This striped hat is big enough to hide a ball and chain. But not necessarily the one you have hanging around your foot.",ep:0,g:0,l:55,wd:false,fm:true,w:10,an:0,s:169,p:7900};
I.u[11395] = {n:"Prisoner Amulet",t:1,d:"This small chain could pass for an amulet if wasn\'t the tip of a padlock.",ep:0,g:0,l:54,wd:false,fm:true,w:10,an:0,s:169,p:7825};
I.u[11396] = {n:"Prisoner Belt",t:1,d:"The man who gave this belt such a stupid name is actively sought by the police, the years he\'ll spend in prison when the catch him still won\'t make up for such a lack of creativity.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:169,p:8750};
I.u[11397] = {n:"Borbacape",t:17,d:"This cloak with a ridiculous name is intriguing nonetheless, and belonged to a righteous man who claimed he wanted to clean up the streets of Brakmar. Nobody knows if he was a vigilante or a dustman.",ep:0,g:0,l:54,wd:false,fm:true,w:10,an:0,s:170,p:7703};
I.u[11398] = {n:"Borbahat",t:16,d:"This hat will give you the allure of a Borbat. You\'re single at the moment, right? Yeah, you\'re going to stay single for quite a while.",ep:0,g:0,l:57,wd:false,fm:true,w:10,an:0,s:170,p:8575};
I.u[11399] = {n:"Borbamulet",t:9,d:"This book\'s spine reads: \"A book for upholders of the law who doesn\'t afraid of anything\". And you thought you could use it...",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:170,p:9187};
I.u[11400] = {n:"Borboots",t:11,d:"The shoemaker who designed these boots fitted them with Borbat wings so that their wearer could fly. Well, it was difficult to hear anything above the obnoxious din, but that\'s what you thought you the merchant was saying when you bought them from him at the Astrub Zaap.",ep:0,g:0,l:57,wd:false,fm:true,w:10,an:0,s:170,p:8500};
I.u[11401] = {n:"Pinokio Cape",t:17,d:"This wooden cape grows larger when you lie. There\'s a good chance you\'ll trip over it regularly as a result.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:171,p:9428};
I.u[11402] = {n:"Pinokio Hat",t:16,d:"You can also use this hat as traffic cone should you have an accident while riding your Dragoturkey.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:171,p:9875};
I.u[11403] = {n:"Sea sickness",t:24,d:"Transforming into a ghost pirate didn\'t really suit you, you\'re definitely not a sailor. You\'ll feel better in 24 hours, I\'m sure.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11404] = {n:"Ghost Pirate Transformation",t:27,d:"You\'ve been turned into a ghost so that you can enter the Rebellious Spirit\'s wreck.",ep:0,g:3,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11406] = {n:"Pingwin Serum",t:24,d:"Only educated people know the usefulness of this serum, which is why you haven\'t got a clue what it does.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11407] = {n:"Crystallised Gullipop Guano",t:24,d:"If you serve your drinks \"on the rocks\" using this special ice cube, they\'re sure to have an unrivalled flavour and freshness.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11408] = {n:"Truth Serum",t:24,d:"Do you swear to tell the truth, the whole truth and nothing but the truth?",ep:0,g:2,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11409] = {n:"Purse of Kamas",t:24,d:"This purse contains enough Kamas to help you buy a decent outfit. Given the difficulty of the job, it represents a fortune. You can\'t use it for anything else, sadly.",ep:0,g:243,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11410] = {n:"Adam costume",t:24,d:"Worn to Captain Chafer\'s Panty Party, this outfit will cause envy amongst men, and especially amongst women eager to taste the forbidden fruit.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11411] = {n:"Eve costume",t:24,d:"Worn to Captain Chafer\'s Panty Party, this dress will turn your suitors\' heads and cause many a stiff neck. Your local physiotherapist will thank you.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11412] = {n:"A copy of the Santho family dossier",t:24,d:"These documents are a copy of the inheritance, property deeds and other paperwork belonging to the Santho family. They show, among other things, the purchase and the legacy of hundreds of acres of farmland south of Bonta. The purchases are spread between the years 551 and 555, just after the glaciation of Frigost. They were made possible by the immense wealth of Edmond Santho, who made his fortune by selling huge quantities of cereals of Frigostian origin.\nCurrently, only one field does not belong to Raymond Santho: that of Robin Marmoni.",ep:0,g:33,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11413] = {n:"Key to Heike Holo\'s cell",t:24,d:"The key to Heike Holo\'s cell.",ep:0,g:790,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11414] = {n:"Heike Holo",t:32,d:"Heike Holo wants to escape, you must escort her to the boat bound for Wabbit Island.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11415] = {n:"Documents about the theft.",t:24,d:"These documents concern the theft of cereals coming from Frigost. The Montay family\'s boats are mentioned.",ep:0,g:26,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11416] = {n:"Pinokio Boots",t:11,d:"This pair of boots was carved out of a tree trunk. Unless it\'s the opposite.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:171,p:8800};
I.u[11417] = {n:"Pinokio Ring",t:9,d:"This ring was made from sawdust and something very sticky, and it\'s better that you leave it at that.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:171,p:9825};
I.u[11418] = {n:"Jon Lemon\'s Cape",t:17,d:"Jon Lemon loved this cape to death, which explains why he wears it to each of his funerals.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:172,p:9858};
I.u[11419] = {n:"Jon Lemon\'s Boots",t:11,d:"Jon Lemon always put on these boots when he had a deposit to make... in the hut at the bottom of his garden.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:172,p:8950};
I.u[11420] = {n:"Jon Lemon\'s Hat",t:16,d:"This old hat is bordering on the ridiculous, and it\'s how Jon Lemon earned the nickname \"The Moustachioed Grandmother\". That name tends to put him in a bad mood...",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:172,p:8980};
I.u[11421] = {n:"Jon Lemon\'s Blowpipe",t:4,d:"Jon Lemon should never have used this blowpipe just after eating. Since that day he\'s had to use it as a simple staff and as he so often repeats, \"It was better before\".",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:12,e:[7,3,1,1,35,55,false,false],c:"CI>70&CV>50&CA>25",s:172,p:8050};
