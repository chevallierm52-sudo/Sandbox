I.u[11277] = {n:"Rascally Pingwinkle",t:32,d:"This Pingwinkle doesn\'t like being adopted and will and flee at the first opportunity. In the meantime, you can show it to your friends for them to abuse.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11278] = {n:"Skrat",t:30,d:"You have defeated a Skrat but unfortunately it has decided to follow you everywhere. Now you have the opportunity to find out if its bad luck is a legend or not.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11279] = {n:"Ice Saw",t:15,d:"This saw is used to cut blocks of ice. It will also cut frozen limbs particularly well.",ep:0,g:0,l:100,wd:false,fm:false,w:5,an:0,p:1};
I.u[11280] = {n:"Steel Plate",t:40,d:"Steel plates are very popular among Frigostians, who use them to manufacture machinery and steel pipes.",ep:0,g:0,l:100,wd:false,fm:true,w:50,an:0,p:1};
I.u[11281] = {n:"Protective Mask",t:15,d:"This mask is used by workers to protect their faces in hazardous working conditions. It also protects very well from slaps and thrown dishes if you have forgotten your wife\'s birthday.",ep:0,g:0,l:100,wd:false,fm:true,w:5,an:0,p:1};
I.u[11282] = {n:"Protective Gloves",t:15,d:"These gloves protect objects from your grubby little mitts. Certain Srams use them to protect their identity by hiding their fingerprints.",ep:0,g:0,l:100,wd:false,fm:true,w:2,an:0,p:1};
I.u[11283] = {n:"Ice Saw Recipe",t:24,d:"A Sword Smith can create this saw from:\n- 2 x Glacial Boar Leather.\n- 1 x Mama Pingwin Oil.\n- 2 x Gullipop Feather.\n- 1 x Pingwinkle Beak.\n- 1 x Kriptonite.\n- 1 x Aspen Wood.\n- 5 x Mastogob Wool.\n- 10 x  Whetstone",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11284] = {n:"Steel Plate Recipe",t:24,d:"A Miner can melt this plate from:\n- 5 x Coal.\n- 25 x Iron.\n- 10 x Tin.\n- 10 x Manganese.\n- 5 x Cobalt.\n- 1 x Aluminite.\n- 1 x Sulphur Pouch.\n- 1 x Mother of Pearl.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11285] = {n:"Protective Mask Recipe",t:24,d:"A Tailor can make this hat from:\n- 5 x Mama Pingwin Down\n- 5 x Venerable Mastogob Wool\n- 2 x Kanigloo Ear.\n- 2 x Glacial Boar Leather.\n- 2 x Pingwinkle Beak.\n- 1 x Coal.\n- 5 x Iron.\n- 5 x Tin.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11286] = {n:"Protective Gloves Recipe",t:24,d:"A Jeweller can make this ring from:\n- 4 x Pingwinkle Feather.\n- 2 x Pingwobble Wing.\n- 10 x Shaman Pingwin Beard Hair\n- 10 x Sabredon Hair.\n- 2 x Skrat Tail.\n- 4 x Mastogobbly Leather.\n- 2 x Crabeye Pincer.\n- 10 x Woolly Bow Meow Hair.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11287] = {n:"Zobie the Ship\'s Apprentice",t:32,d:"You must escort him to Mac Gayver.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11288] = {n:"Blueprint for a Frigostian Hornbeam Drinking Trough",t:24,d:"This plan shows how to cobble together a prototype Drinking Trough from:\n- 1 x Charm Drinking Trough.\n- 2 x Kung Fu Pingwin Ear.\n- 10 x Mama Pingwin Down.\n- 2 x Kanigloo Fabric.\n- 10 x Glacial Boar Leather.\n- 2 x Crabeye Eye.\n- 10 x Stunted Rat Fabric.\n- 2 x Frighog Baleful Eye.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11289] = {n:"Blueprint for a Prototype Frigostian Hornbeam Manger",t:24,d:"This plan shows how to cobble together a prototype Manger from:\n- 1 x Charm Manger.\n- 2 x Mama Pingwin Oil.\n- 10 x Shaman Pingwin Bear Hair.\n- 2 x Skrat Acorn.\n- 10 x Frighog Pierced Ear.\n- 2 x Gullipop Beak.\n- 10 x Crabeye Claw.\n- 10 x Sabredon Hair.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11290] = {n:"Blueprint for a Frigostian Hornbeam Lightning Thrower",t:24,d:"This plan shows how to cobble together a prototype Lightning Thrower from:\n- 1 x Charm Lightning Thrower.\n- 2 x Shaman Pingwin Giant Fishbone.\n- 10 x Pingwinkle Feather.\n- 2 x Glacial Boar Tusk.\n- 10 x Kanigloo Ear.\n- 2 x Woolly Bow Meow Sternum.\n- 10 x Gullipop Feather.\n- 2 x Pingwinkle Beak.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11291] = {n:"Blueprint for a Frigostian Hornbeam Slapper",t:24,d:"This plan shows how to cobble together a prototype Slapper from:\n- 1 x Charm Slapper.\n- 2 x Pingwobble Wing.\n- 10 x Kung Fu Pingwin Tail.\n- 2 x Sabredon Tooth.\n- 10 x Skrat Tail.\n- 2 x Stunted Rat Paw.\n- 10 x Woolly Bow Meow Hair.\n- 10 x Pingwobble Skin.",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11292] = {n:"Prototype Frigostian Hornbeam Drinking Trough",t:93,d:"This prototype breeding item still requires a few tweaks before being fully functional.",ep:0,g:0,l:100,wd:false,fm:true,w:10,an:0,p:1};
I.u[11293] = {n:"Prototype Frigostian Hornbeam Manger",t:93,d:"This prototype breeding item still requires a few tweaks before being fully functional.",ep:0,g:0,l:100,wd:false,fm:true,w:10,an:0,p:1};
