I.u[11296] = {n:"Dose of Lurgi Vaccine",t:24,d:"Here\'s a dose of vaccine against the Lurgi.",ep:0,g:31,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11297] = {n:"Kack Handed\'s Letter",t:24,d:"Germain, if you\'re reading this letter, it means I am dead. You\'re probably looking for my booty, so I want you to know that I will never tell you where it is hidden. \nCheers!",ep:0,g:55,l:1,wd:false,fm:true,w:0,an:0,p:1};
