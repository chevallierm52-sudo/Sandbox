I.u[11182] = {n:"Royal Mastogob Wig",t:24,d:"One thing\'s for sure, without his wig, the Royal Mastogob certainly loses some of his authority...",ep:0,g:826,l:1,wd:false,fm:true,w:0,p:1};
I.u[11183] = {n:"Royal Icefish",t:24,d:"The Royal Pingwin himself used this Icefish against you. Wherever it came from, however, it will just end up on the barbeque like any other Icefish.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
