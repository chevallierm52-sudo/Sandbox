I.u[11041] = {n:"Viopal Sword",t:6,d:"Heavy, clumsy, dull and ugly, just how was Goultard able to become such a formidable fighter using this mediocre sword? Wielding it yourself will not improve your skills, it will just make you look ridiculous.",ep:0,g:99,l:40,wd:false,fm:true,w:10,an:14,e:[6,4,1,1,40,40,false,false],s:159,p:4000};
I.u[11042] = {n:"Doggona Rope",t:10,d:"This belt was given to Goultard by his father for his 5th birthday. It is more solid than its appearance suggests, and will keep your trousers snugly around your hips. It can also be used as a washing line, or even a skipping rope.",ep:0,g:175,l:40,wd:false,fm:true,w:10,s:159,p:4300};
I.u[11043] = {n:"Capocalypse",t:16,d:"This hat is so tight-fitting that it compresses the skull and causes strong hallucinations. Fortunately, Goultard wore it when he was young, and what\'s more, he has quite a small skull, which betrays his roots.",ep:0,g:265,l:41,wd:false,fm:true,w:10,s:159,p:4500};
I.u[11044] = {n:"Remains of Goultard\'s family",t:24,d:"A few mouldering bones and some funereal jewellery is all that is left of Goultard\'s family.",ep:0,g:818,l:1,wd:false,fm:true,w:0,p:0};
I.u[11045] = {n:"Youllbea Mantle",t:17,d:"Goultard wore this mantle until he discovered the three sisters, when it was forgotten about in the back of an old cupboard.",ep:0,g:179,l:43,wd:false,fm:true,w:10,s:159,p:5050};
I.u[11046] = {n:"Cabotine\'s Cursed Necklace",t:24,d:"This cursed necklace\'s aura is so powerful you\'re having difficulty getting rid of the damned thing.",ep:0,g:819,l:1,wd:false,fm:true,w:0,p:0};
I.u[11047] = {n:"Da Rorc",t:32,d:"Da Rorc has given himself up, escort him to Lethaline.",ep:0,g:29,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11048] = {n:"Hints for Dark Vlad",t:24,d:"A simple map and an intelligence potion. Even Dark Vlad should be able to escape from his maze with that.",ep:0,g:820,l:1,wd:false,fm:true,w:0,p:0};
I.u[11049] = {n:"Clementine Hat",t:16,d:"Slap this hat on your head, peel it for a few hours, and eventually, if you\'re lucky, you might find a tiny pip.",ep:0,g:262,l:32,wd:false,fm:true,w:10,s:161,p:2900};
I.u[11050] = {n:"Clementine Cape",t:17,d:"The cape, which releases a pleasant citrus aroma as you walk, will transform you into a powerful Moskito trap.",ep:0,g:177,l:32,wd:false,fm:true,w:10,s:161,p:2850};
I.u[11051] = {n:"Clementine Amulet",t:1,d:"If you dip this amulet into your glass, your tasteless water will be transformed into a delicious, citrus-flavoured beverage.",ep:0,g:161,l:32,wd:false,fm:true,w:10,s:161,p:2925};
I.u[11052] = {n:"Clementine Boots",t:11,d:"The soles of these boots are made from the tough skin of fruit harvested on an island whose very existence remains unknown to mere mortals.",ep:0,g:161,l:34,wd:false,fm:true,w:10,an:0,s:161,p:3205};
I.u[11053] = {n:"",t:31,d:"",ep:0,g:0,l:1,wd:false,fm:false,w:0,p:0};
I.u[11054] = {n:"",t:49,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,c:"Sc=994",ut:true,p:0};
I.u[11055] = {n:"Pynekone Hat",t:16,d:"Padded with Bow Meow hair and covered with bark, this hat is extremely flammable. You should not sit on it if your pants are on fire.",ep:0,g:263,l:41,wd:false,fm:true,w:10,an:0,s:162,p:4553};
I.u[11056] = {n:"Pynekone Cape",t:17,d:"In hot weather, this cape\'s scales spread open to help your sweat evaporate. When it rains, this cape\'s scales spread open to let the rain in and rinse your posterior.",ep:0,g:178,l:42,wd:false,fm:true,w:10,an:0,s:162,p:4875};
I.u[11057] = {n:"Pynekone Belt",t:10,d:"This belt is composed of scales arranged spirally in accordance with the Vibronacci suite.",ep:0,g:174,l:40,wd:false,fm:true,w:10,an:0,s:162,p:4305};
I.u[11058] = {n:"Pynekone Ring",t:9,d:"Who were you hoping to seduce with a ring like this?",ep:0,g:189,l:43,wd:false,fm:true,w:10,an:0,s:162,p:5100};
