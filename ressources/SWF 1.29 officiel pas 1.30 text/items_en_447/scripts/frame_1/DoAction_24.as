I.u[11077] = {n:"Lonne\'s Hammer",t:7,d:"When it comes to sounding out his opponents, Lonne Jenone has more than one string to his fiddle - he uses it as a hammer. One thing is certain: sparks will fly!",ep:0,g:75,l:54,wd:false,fm:true,w:20,an:0,e:[6,5,1,1,42,50,false,false],c:"CA>20&CV>40",s:163,p:9700};
I.u[11078] = {n:"Lonne\'s Cape",t:17,d:"This leather cape, though light, will accompany you on all your incredible rides on the back of a Dragoturkey...",ep:0,g:176,l:55,wd:false,fm:true,w:10,an:0,s:163,p:7900};
I.u[11079] = {n:"Lonne\'s Hat",t:16,d:"Before being worn by Lonne Jenone, this hat belonged to Sergeant Payper, who was a rather quiet chap rarely prone to sticking his oar in.",ep:0,g:261,l:55,wd:false,fm:true,w:10,an:0,s:163,p:8050};
I.u[11080] = {n:"Lonne\'s Boots",t:11,d:"This versatile pair of boots will guarantee full freedom of movement, which is the reason that Lonne Jenone wears them when he dances with Boowolves.",ep:0,g:160,l:55,wd:false,fm:false,w:10,an:0,s:163,p:7925};
I.u[11082] = {n:"Gobbowl Boots",t:11,d:"These boots were specially designed to destroy your opponents\' shin pads, and then their shins, and then your own toes.",ep:0,g:157,l:28,wd:false,fm:true,w:10,an:0,c:"Sc=11",p:2300};
I.u[11083] = {n:"Gobbowl Ring",t:9,d:"You can use this ring to puncture the Gobbowl Ball when you want to quietly enjoy a break in play.",ep:0,g:187,l:31,wd:false,fm:true,w:10,an:0,c:"Sc=12",p:2666};
I.u[11084] = {n:"Gadjet\'s Hat",t:16,d:"Gadget was one of the most creative handymen the World of Twelve has ever seen. Unfortunately, he was also one of the most stupid. They say he mistook his wife\'s head for his anvil on more than one occasion, although she didn\'t complain, apparently.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6400};
I.u[11085] = {n:"Gadjet\'s Belt",t:10,d:"If you wear this belt upside down and press on it hard enough, you may be able to activate its integrated retromagic module. It has never worked, but you can activate it anyway. Then you can then sell it on to someone even more naive than you.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6358};
I.u[11086] = {n:"Gadjet\'s Cape",t:17,d:"Gadget made this cape in the hope that it might enable him to fly and thus more easily escape the beatings administered daily by his wife.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6350};
I.u[11087] = {n:"Gadjet\'s Ring",t:9,d:"Worn by several generations of handymen, this ring will protect your knuckle from hammer blows. Unfortunately, it is never sold in packs of five.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6453};
I.u[11088] = {n:"Grillian\'s Hat",t:16,d:"Grillian was a great magician. He is most famous for having reinvented Scamper powder, having forgotten how to manufacture it.",ep:0,g:0,l:49,wd:false,fm:true,w:10,s:164,p:6325};
I.u[11089] = {n:"Grillian\'s Cape",t:17,d:"This cape is supposed to protect your posterior from carnivorous plant bites.",ep:0,g:0,l:48,wd:false,fm:true,w:10,s:164,p:6250};
I.u[11090] = {n:"Wanted notice",t:24,d:"This is a wanted notice for Lethaline Sigibul.",ep:0,g:821,l:1,wd:false,fm:true,w:0,p:0};
I.u[11091] = {n:"Grillian\'s Boots",t:11,d:"Grillian the magician traded a magic ring for this pair of boots. It seems that he lost out on the deal, as they aren\'t even padded.",ep:0,g:0,l:46,wd:false,fm:true,w:10,an:0,s:164,p:5600};
I.u[11092] = {n:"Grillian\'s Amulet",t:1,d:"Grillian wore this amulet around his neck when... When... Oh, what does it matter? He died and now this amulet is yours.",ep:0,g:0,l:45,wd:false,fm:true,w:10,s:164,p:5450};
