I.u[11100] = {n:"Gift: Extract from the Origins of Goultard",t:89,d:"If you shake this gift box vigorously, you\'ll find it\'s not empty. For once, the gods might not have been pulling your leg. \nPlease note, this gift can only be opened on a DOFUS 2.0 server.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11102] = {n:"Snowdrop",t:35,d:"Hardened to Frigost\'s harsh climate, this flower is much more resistant than its delicate aspect would suggest. That said, to preserve the alchemic properties of such a rare plant, it must be handled carefully when harvested.",ep:0,g:635,l:100,wd:false,fm:true,w:1,p:0};
I.u[11103] = {n:"Bag of Snowdrops",t:100,d:"This enormous bag contains an impressive quantity of Snowdrops.",ep:0,g:57,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11104] = {n:"Improved Quaquack",t:18,d:"Beyond the realms of the Tofu, the Gobball and even the Iop, there is a creature dwelling in a dimension of idiocy unimaginable even to your cretinous mind: the Quaquack!",ep:0,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[11105] = {n:"Improved Quaquack Ghost",t:90,d:"This Quaquack hasn\'t left the living world yet. Will you find a way to resurrect it or cowardly abandon it once and for all?",ep:0,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[11106] = {n:"Icefish",t:41,d:"Spines as sharp as Bworker\'s blades, scales as thick as the bark of a Soft Oak, and eyes as black as the feathers of a Crow. This fish may be formidable, but served up on a plate it is quite simply delicious.",ep:0,g:403,l:100,wd:false,fm:true,w:1,p:100};
I.u[11107] = {n:"Aspen",t:38,d:"This tree appears to tremble when you touch it. After all the axe blows you\'ve dealt it, it\'s not surprising it\'s scared of you.",ep:0,g:677,l:100,wd:false,fm:true,w:5,p:100};
I.u[11109] = {n:"Frosteez",t:34,d:"Not only is this surprising cereal resistant to Frigost\'s extreme climate, it lends a delicate taste of chocolate to any milk into which it is dipped.",ep:0,g:552,l:100,wd:false,fm:true,w:1,p:100};
I.u[11110] = {n:"Obsidian",t:39,d:"Hard enough to scratch glass and dark enough to sap your morale, this rock has lost all of the heat of the lava from which it came. It would be perfect as a tombstone, as long as it isn\'t yours.",ep:0,g:90,l:100,wd:false,fm:true,w:5,p:0};
I.u[11111] = {n:"Bag of Icefish",t:100,d:"This enormous bag contains an impressive quantity of Icefish.",ep:0,g:59,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11112] = {n:"Bag of Aspen",t:100,d:"This enormous bag contains an impressive quantity of Aspen.",ep:0,g:58,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11113] = {n:"Bag of Frosteez",t:100,d:"This enormous bag contains an impressive quantity of Frosteez.",ep:0,g:60,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11114] = {n:"Bag of Obsidian",t:100,d:"This enormous bag contains an impressive quantity of Obsidian.",ep:0,g:34,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11115] = {n:"Aperirel Snapper",t:30,d:"Spring is here, you can smell it. Well, it\'s either Spring or the rotten Uridnac that\'s attached to you.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[11116] = {n:"Uridnac",t:94,d:"This little fish is very fond of people and attaches itself to them easily. \nHowever, its biological rhythm is peculiar: it is only active in the month of Aperirel when Silouate warms the fresh water where the fish thrives.",ep:0,g:19,l:1,wd:false,fm:false,w:1,c:"SG=3&POX11115",u:true,ut:true,p:0};
I.u[11117] = {n:"Mastogob Wool",t:57,d:"Mastogobs need to be shorn once a year, just like the armpits of Pikokos.",ep:0,g:211,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11118] = {n:"Mastogob Clavicle",t:47,d:"There isn\'t the tiniest piece of edible meat left on this bone, so there\'s no point you gnawing on it.",ep:0,g:660,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11119] = {n:"Mastogobbly Ear",t:106,d:"Frigostians normally eat these ears with vinaigrette, as they taste awful, and Frigostians love vinaigrette.",ep:0,g:624,l:96,wd:false,fm:true,w:10,p:1};
I.u[11120] = {n:"Mastogobbly Leather",t:56,d:"They say that if you boil this leather 8 times in water, it becomes edible. That\'s a Frigostian\'s idea of a funny joke, by the way.",ep:0,g:534,l:96,wd:false,fm:true,w:10,p:1};
I.u[11121] = {n:"Mastogob Warrior Eye",t:109,d:"This eye must have seen the rumps of a fair few female Mastogobs in its time. Now all the poor thing can see is the fluff in your pocket.",ep:0,g:590,l:112,wd:false,fm:true,w:10,p:1};
I.u[11122] = {n:"Mastogob Warrior Horn",t:47,d:"The most reckless Frigostians play a game with Mastogob Warriors while they are sleeping by attempting to throw three metallic rings around each of their horns without waking them up. Unsurprisingly, no one has ever made it to the end of the game alive.",ep:0,g:661,l:112,wd:false,fm:true,w:10,p:1};
I.u[11123] = {n:"Mastogob Wisdom Tooth",t:24,d:"You pulled this tooth from the jaw of a still-living Mastogob. What\'s wrong with you? Are you crazy, or something?",ep:0,g:822,l:1,wd:false,fm:true,w:0,p:1};
I.u[11124] = {n:"Frozen Entrails",t:24,d:"These entrails froze as soon as you pulled them from their body cavity.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11125] = {n:"Pingwin Foot",t:24,d:"As if it wasn\'t already bad enough that he has no arms, what\'s going to happen to the Pingwin whose foot you tore off?",ep:0,g:823,l:1,wd:false,fm:true,w:0,p:1};
I.u[11126] = {n:"Ethereal Skull",t:24,d:"How can a skull be ethereal? Having thought about it a lot, you find yourself laughing at the answer to that question.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11127] = {n:"Volun Tear",t:24,d:"This tear symbolises resilience in the face of oppression.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11128] = {n:"Magmatic Teardrop",t:24,d:"Instead of wetting, this tear burns any combustible material with which it comes into contact, so there\'s no risk of your makeup running when your boyfriend leaves you for his Dragoturkey.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11129] = {n:"Givranchy",t:24,d:"Extract of Snowfoux musk is enormously popular with the female Snowfoux population, and makes a great gift for your suitors or rivals.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11130] = {n:"Petrified Lichen",t:24,d:"This lump of lichen was frozen solid by the cold. Once defrosted, you can use it in a Frigostian variant of Black Pudding Pizza.",ep:0,g:827,l:1,wd:false,fm:true,w:0,p:1};
I.u[11131] = {n:"Strange Object",t:24,d:"You\'d have to be a real dork not to understand how useful an object like this is.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11132] = {n:"Spoon",t:24,d:"Because you stole his spoon, that poor bear has to use his fingers to eat. You\'re a monster.",ep:0,g:824,l:1,wd:false,fm:true,w:0,p:1};
I.u[11133] = {n:"Vibrating Pingwin Feather",t:94,d:"Following the example set by the Royal Tofu, certain Pingwins grow a vibrating feather that is chock-full of magic. As for its usefulness...",ep:0,g:20,l:50,wd:false,fm:false,w:1,c:"Qc=555&Qa!555",u:true,p:500};
I.u[11134] = {n:"Apewicube",t:94,d:"There\'s something trapped in this cube of ice cut from Frigost\'s Frozen Lake. You\'ve got two options if you want to find out what it is: wait until the ice melts, or, like any self-respecting brat, hit it until it shatters.",ep:0,g:21,l:50,wd:false,fm:true,w:1,u:true,p:500};
I.u[11135] = {n:"Venerable Mastogob Tail",t:65,d:"This hairy little tail was well hidden under the Venerable Mastogob\'s thick wool. That didn\'t stop you from finding it and pulling it off, though, did it?",ep:0,g:752,l:118,wd:false,fm:true,w:10,p:1};
I.u[11136] = {n:"Venerable Mastogob Wool",t:57,d:"It\'s dirty, but venerable. Kinda reminds you of someone.",ep:0,g:212,l:118,wd:false,fm:true,w:10,p:1};
I.u[11137] = {n:"A lump of Faded Stunted Rat",t:24,d:"This is all that\'s left of the Stunted Rats from Grandfather\'s cellar. You certainly didn\'t pull any punches, did you?",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11138] = {n:"Pea Seed",t:24,d:"Nope, that\'s not a Mastogob Brain you\'re holding in your hand, it\'s a Pea Seed. The difference is obvious: the Pea Seed is cold to the touch.",ep:0,g:828,l:1,wd:false,fm:true,w:0,p:1};
I.u[11139] = {n:"Emmer Seed",t:24,d:"Emmer is an ancient version of the wheat that is currently cultivated in Amakna. Anyone would think time stands still on Frigost.",ep:0,g:829,l:1,wd:false,fm:true,w:0,p:1};
I.u[11140] = {n:"Granola Seed",t:24,d:"Once used as flour for biscuits, the cultivation of this seed was banned following a stupid bet. The former mayor of Frigost bet an Ecaflip that he would only eat one cookie made from Granola Flour. He lost the bet, and his fortune.",ep:0,g:830,l:1,wd:false,fm:true,w:0,p:1};
I.u[11141] = {n:"Pynekone Seed",t:24,d:"This tiny seed comes from a mature Pynekone.",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11142] = {n:"Lentil Seed",t:24,d:"Placing a Lentil Seed on each of your eyelids won\'t make you see better, but you\'ll certainly look more stupid than usual if anyone sees you doing it.",ep:0,g:832,l:1,wd:false,fm:true,w:0,p:1};
I.u[11143] = {n:"Grain of Salt",t:24,d:"Sparo wasn\'t worth his salt, and that\'s why he ended up in a barrel. Don\'t say you weren\'t warned.",ep:0,g:833,l:1,wd:false,fm:true,w:0,p:1};
I.u[11144] = {n:"Grenhayde Seed",t:24,d:"Pull the stalk out, count to two and throw this seed as far as you can. If it lands next to an Atomystique he\'ll explode with rage. Young militiamen finish their Grenhayde Seed training pretty quickly.",ep:0,g:834,l:1,wd:false,fm:true,w:0,p:1};
I.u[11145] = {n:"Hay Seed",t:24,d:"Slum-dwelling children attack civilised people with these seeds. You may be wondering how that works, but it\'s better not to know, really.",ep:0,g:835,l:1,wd:false,fm:true,w:0,p:1};
I.u[11146] = {n:"Basalt Seed",t:24,d:"This seed has undergone a massive increase in temperature followed by extreme cooling, which has made it brittle and fragile.",ep:0,g:836,l:1,wd:false,fm:true,w:0,p:1};
I.u[11147] = {n:"Cole Seed",t:24,d:"This seed has a high carbon content and when there\'s a full moon, it makes a strange noise. You\'d have to be really stupid or a Iop to believe such nonsense.",ep:0,g:837,l:1,wd:false,fm:true,w:0,p:1};
I.u[11148] = {n:"Evil Seed",t:24,d:"An old legend tells that the flour made from this seed was used for making the bread of Demon Steak sandwiches, favourite dish of the demon lord Rushu. Even today, Frigostians are wary of it.",ep:0,g:838,l:1,wd:false,fm:true,w:0,p:1};
I.u[11149] = {n:"Star Seed",t:24,d:"If you like piling on the slap, and singing in the shower, this seed is for you. Eating it will have you wiggling your hips in front of a roaring crowd. Be careful, however, as its effect is very temporary.",ep:0,g:839,l:1,wd:false,fm:true,w:0,p:1};
I.u[11150] = {n:"",t:24,d:"",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
