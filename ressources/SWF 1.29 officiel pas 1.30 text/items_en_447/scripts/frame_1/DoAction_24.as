I.u[11174] = {n:"Mastogob Dungeon Key",t:84,d:"Use this key to enter the greenhouse where the Royal Mastogob hides.",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[11175] = {n:"The Pingwin Key",t:84,d:"The key contains high levels of asbestos and as a result floats very well on water and on salad dressing. You can also use it to enter the Pingwin Dungeon.",ep:0,g:255,l:1,wd:false,fm:true,w:1,p:1};
