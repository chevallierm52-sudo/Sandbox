I.u[11190] = {n:"Gift: YeCh\'Ti Amulet",t:89,d:"If you shake this gift box vigorously, you\'ll find it\'s not empty. For once, the gods might not have been pulling your leg.\nPlease note, this gift can only be opened on a DOFUS 2.0 server.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11191] = {n:"Legend of the Dungeons Boots",t:11,d:"Their soles may be worn but these boots are very comfortable. They have trampled the soil of the most dangerous dungeons as well as the heads of the most vicious monsters.",ep:0,g:162,l:73,wd:true,fm:true,w:10,an:0,p:13700};
I.u[11192] = {n:"Gift: Legend of the Dungeons Boots",t:89,d:"If you shake this gift box vigorously, you\'ll find it\'s not empty. For once, the gods might not have been pulling your leg. \nPlease note, this gift can only be opened on a DOFUS 2.0 server.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11193] = {n:"Aspen Plank",t:95,d:"A Handyman could use this plank to make something delightful - a coffin, for example. Just bear that in mind.",ep:0,g:23,l:100,wd:false,fm:true,w:10,p:10};
I.u[11194] = {n:"Frosteez Flour",t:52,d:"This flour dissolves in mimilk, giving it a delightful chocolate flavour. The inhabitants of a lost island, preferring frozen desserts, like to dissolve it in water.",ep:0,g:260,l:100,wd:false,fm:true,w:1,p:1};
I.u[11195] = {n:"The Lurgi",t:30,d:"You need find some treatment before you get any worse.",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11196] = {n:"Ice Kama",t:24,d:"Unable to strike new currency because of a lack of metal, Frigostians carve Kamas from the ice and trade them for various local objects. This coin has no value outside of the island.",ep:0,g:825,l:1,wd:false,fm:true,w:0,p:1};
I.u[11197] = {n:"The Sarapox",t:30,d:"The vaccination campaign against this disease has already cost the town of Frigost the modest sum of 2 billion Kamas and has had no significant result. The Frigostians may as well just throw their Kamas out of the window.",ep:0,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11198] = {n:"Lurgi Vaccine",t:24,d:"This vaccine provides effective protection from the Lurgi, but its effects wear off quickly. It needs to be renewed every week.",ep:0,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[11199] = {n:"Frosteez Seed",t:58,d:"This seed, cold to the touch, releases a powerful chocolate aroma.",ep:0,g:0,l:100,wd:false,fm:true,w:1,p:1};
I.u[11200] = {n:"Gift: Hispanian Shield",t:89,d:"If you shake this gift box vigorously, you\'ll find it\'s not empty. For once, the gods might not have been pulling your leg.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[11201] = {n:"Mastogob Blood Sample",t:24,d:"You took this sample from a Mastogob suffering from a heavy cold.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11202] = {n:"Isotonic Seawater",t:24,d:"Herr Peece needs this water for his research into a cure for the common cold.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[11203] = {n:"Mugwort",t:24,d:"This weed is well sought by alchemists, Eniripsas and Eniripsa alchemists. A plant similar to this one can be used to make a powerful liqueur popular with sailors, Enutrofs and Enutrof sailors.",ep:0,g:103,l:1,wd:false,fm:true,w:0,p:1};
I.u[11204] = {n:"The Beast Blood Sample",t:24,d:"You went to great lengths to get this blood sample. Let\'s hope it was worth it.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11205] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 1am but before 4am.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11206] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 4am but before 7am.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11207] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 7am but before 10am.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11208] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 10am but before 1pm.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11209] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 1pm but before 4pm.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11210] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 4pm but before 7pm.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11211] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 7pm but before 10pm.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11212] = {n:"Meeting time",t:24,d:"You have a meeting with Cap\'n Tankerous at the inn, any time from 10pm but before 1am.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11213] = {n:"Mastogob Ticks",t:24,d:"More resistant than a pair of Captain Chafer\'s Kriptonite Underpants, and more aggressive than a band of Astrubian Hunters, these ticks are a veritable nightmare for their host.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[11214] = {n:"Contaminated Mastogob Blood",t:24,d:"This blood sample was taken from a Mastogob infected with ticks.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11215] = {n:"Contaminated Mastogob Warrior Blood",t:24,d:"This blood sample was taken from a Mastogob Warrior infected with ticks.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11216] = {n:"Contaminated Venerable Mastogob Blood",t:24,d:"This blood sample was taken from a Venerable Mastogob infected with ticks.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11217] = {n:"Contaminated Mastogobbly Blood",t:24,d:"This blood sample was taken from a Mastogobbly infected with ticks.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11218] = {n:"An Envelope for Otomai",t:24,d:"Wogew the Hewmit has asked you to deliver this envelope to Otomai. It contains several useful documents on the ticks that live on Mastogobs, but also on Wabbits.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[11219] = {n:"Royal Mastogob Tail",t:65,d:"The Royal Mastogob uses his tail to shoo away Moskitoes during the summer months. It\'s neither use nor ornament the rest of the year, and sometimes he even forgets it\'s there.",ep:0,g:755,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11221] = {n:"Royal Mastogob Wool",t:57,d:"No one knows for sure exactly when the Mastogobs arrived on Frigost. What is for sure is that they\'ve been there a long time, because certain Frigostian households still pass down Mastogob Wool underwear from generation to generation, and there are several examples dating back centuries.",ep:0,g:213,l:125,wd:false,fm:true,w:10,an:0,p:10};
