I.u[11156] = {n:"Lele Yucca",t:24,d:"This flower was popularised by the town crier Jorg Farmboy, all the other town criers hate him for it.",ep:0,g:841,l:1,wd:false,fm:true,w:0,p:1};
I.u[11157] = {n:"Osuction Tulip",t:24,d:"Powdered and boiled, ingesting this tulip is recommended if you want to lose weight quickly. The disadvantage is that the weight of your wallet diminishes just as quickly.",ep:0,g:842,l:1,wd:false,fm:true,w:0,p:1};
I.u[11158] = {n:"Nelson Rose",t:24,d:"Discovered by the famous botanist Yosef, this rose gives off the heady scent of sweaty Frighog dung, and reminds you of your most intimate moments.",ep:0,g:843,l:1,wd:false,fm:true,w:0,p:1};
I.u[11159] = {n:"Modas Mimosa",t:24,d:"This flower casts a shadow in the shape of an Osamodas.",ep:0,g:844,l:1,wd:false,fm:true,w:0,p:1};
I.u[11160] = {n:"Ershop Rhubarb",t:24,d:"The stems of this flavoursome rhubarb are hollow, and once appropriately arranged, produce a sound when blown into that\'s not unlike unaccompanied vocal music characterized by consonant four-part chords for every melody note in a predominantly homophonic texture. Or so the story goes, anyway.",ep:0,g:845,l:1,wd:false,fm:true,w:0,p:1};
I.u[11161] = {n:"Rosenberg Willow",t:24,d:"The person who discovered this exquisite flower quickly went around proclaiming it to be the most beautiful ever discovered, and I, for one, wholeheartedly agree.",ep:0,g:846,l:1,wd:false,fm:true,w:0,p:1};
I.u[11162] = {n:"Tyler Rose",t:24,d:"A Xelor Lord of Time discovered this beautiful flower, but was tearfully forced to part with it.",ep:0,g:847,l:1,wd:false,fm:true,w:0,p:1};
I.u[11163] = {n:"De Lima Rose",t:24,d:"They say that this rose is blessed by the gods, something that they don\'t say about you.",ep:0,g:848,l:1,wd:false,fm:true,w:0,p:1};
I.u[11164] = {n:"Elboy Hellebore",t:24,d:"The petals of this hellebore smell like dry-roasted peanuts.",ep:0,g:849,l:1,wd:false,fm:true,w:0,p:1};
I.u[11165] = {n:"Jenrel Woundwort",t:24,d:"There was a time when chewing this flower was fashionable amongst Iop high society. They thought it made them look smart, which might have been true, if Iops were capable of thinking.",ep:0,g:850,l:1,wd:false,fm:true,w:0,p:1};
I.u[11166] = {n:"Sander Lily",t:24,d:"The name of this flower is a tribute to Sander, the famous admiral of the Frigost fleet, who died hitting his head against the walls of the house of his rival, Al Hiartus.",ep:0,g:851,l:1,wd:false,fm:true,w:0,p:1};
I.u[11167] = {n:"Allen Lily",t:24,d:"The pollen of this lily has the peculiar property of bringing some people out in a terrible rash, or invoking a euphoric sense of happiness in others.",ep:0,g:852,l:1,wd:false,fm:true,w:0,p:1};
