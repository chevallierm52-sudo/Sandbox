I.u[11008] = {n:"Bow Kennel Certificate: Snow Bow Meow",t:77,d:"This certificate describes the characteristics of the Snow Bow Meow you\'ve put in the Bow Kennels.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[11009] = {n:"Snow Bow Meow Hormone",t:48,d:"This dehydrated growth hormone can be used to make a powerful potion to improve a pet\'s characteristics.",ep:0,g:262,l:1,wd:true,fm:true,w:1,p:10};
I.u[11010] = {n:"Enhancement Potion: Snow Bow Meow",t:116,d:"Using this powerful potion will increase the capacity of your pet permanently. Be careful though, only one dose will work. Trying more than once will cause disappointing results.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PO=10985",u:true,p:10};
I.u[11011] = {n:"Brindled Minifoux",t:18,d:"Crazier than a regular Minifoux, but much less ginger, this pet can swim underwater without needing to block up its nose. It feeds on creatures that live in the Tree Keeholo.",ep:0,g:63,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11012] = {n:"Brindled Bow Wow",t:18,d:"This pet may have stripes, but that won\'t stop it from sniffing your bottom or trying to relieve itself on your carpet. What did you expect? This pet loves to hunt the creatures that live in the Sidimote Moors.",ep:0,g:64,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11013] = {n:"Black Quaquack",t:18,d:"This ugly Black Quaquack was rejected by his own family because he was different: he loved listening to the songs of Jon Lemon, the famous minstrel. Maybe he was just misunderstood. After a difficult childhood, he decided to arbitrarily take revenge on all creatures of the Crow family. He devours them without pity.",ep:0,g:65,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11014] = {n:"Stone-washed Borbat",t:18,d:"This pet stayed out too long in acid rain. It doesn\'t glow in the dark and it isn\'t magic, but you can make a very potent salad dressing from its saliva. It will only eat creatures from the Jelly family.",ep:0,g:66,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11015] = {n:"Gupin",t:18,d:"This strange creature crossed the oceans on a block of ice to escape from a lost port. It looks like it\'s taken you for a block of ice. This soul-eating pet only likes the taste of beach creatures.",ep:0,g:67,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[11016] = {n:"Brindled Minifoux Ghost",t:90,d:"This ghost hasn\'t left the living world yet. Will you find a way to resurrect it or cowardly abandon it once and for all?",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
