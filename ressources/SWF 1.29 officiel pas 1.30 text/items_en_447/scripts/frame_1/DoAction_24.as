I.u[11070] = {n:"Hata Marie",t:32,d:"Hata was a prisoner of the Bworks, and now she wants you to escort her out of the village.",ep:0,g:30,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[11071] = {n:"Extract from the Origins of Goultard",t:25,d:"Stained, spotted and wrinkled, these few pages are almost illegible. However, through the thick layer of grime you can still make out some words. These pages are an extract from a forgotten book detailing Goultard\'s origins.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
