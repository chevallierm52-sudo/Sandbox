I.u[6995] = {n:"Graytess Cape",t:17,d:"You just can\'t stay inside this cape, it\'ll throw you out whether you want to go or not.",ep:18,g:81,l:105,wd:true,fm:true,w:10,p:28300};
I.u[6996] = {n:"Ring o\'Stradamus",t:9,d:"Stradamus was an old drunken Enutrof who could read the future in pints of beer. Legend has it he was buried standing up in a wall of the Brakmar inn upon his own request, \"so that no drunkard can ever spill his beer over my grave\". This has been told at least once a week by every drunk in every inn in Brakmar. That\'s a lot. God I hate that story.",ep:18,g:78,l:48,wd:true,fm:true,w:5,p:6075};
I.u[6997] = {n:"Conno Ring",t:9,d:"The woman who created this ring was convinced the end of the world was near due to plummeting food supplies. She used to spend entire days engraving messages on wooden tables with her motto \'No steak but what we bake\'. Time proved her wrong.",ep:18,g:79,l:70,wd:true,fm:true,w:5,p:12730};
I.u[6998] = {n:"Elya Wood\'s Wedding Ring",t:9,d:"This small wedding ring will fit an Eniripsa\'s little fingers perfectly. For Iops, however, it\'s almost unusable. Their fingers are too fat and they can\'t get it into their heads that it\'s not a bracelet.",ep:18,g:84,l:120,wd:true,fm:true,w:15,s:39,p:36000};
I.u[6999] = {n:"Lahilama Medal",t:1,d:"Lahilama was a great spiritual guide who kept his temple right in the heart of the mountains. He was so bored that he spent his days sewing little yellow hats for his disciples. They just had nothing to talk about. They all slowly went mad years of awkward conversation.",ep:18,g:83,l:31,wd:true,fm:true,w:3,p:2800};
I.u[7000] = {n:"Bambamulet",t:1,d:"This ridiculous little piece of bamboo has the strangest magical powers. It used to be worn by young Pandawas, once their puberty came to an end. You might want to wait another couple of years yourself before you slip it around your neck...",ep:18,g:78,l:40,wd:true,fm:true,w:5,p:4400};
I.u[7001] = {n:"Bow\'hee Talisman",t:1,d:"\"I, I am the kheeng, you, you are the quheen, whee can be heeroes just for one daaaayyyy...\" \nDavyd, famous minstrel, was singing his head off on his way back from Moon Island...",ep:18,g:84,l:55,wd:true,fm:true,w:10,p:8000};
I.u[7002] = {n:"Lil\' Resin",t:1,d:"This amulet of Bamboo resin will spread a nice smell all around you. It comes in handy when you\'re practising your Wind of Panic.",ep:18,g:85,l:94,wd:true,fm:true,w:5,p:22800};
I.u[7003] = {n:"Elya Wood\'s Talisman",t:1,d:"This Talisman was created with stardust and precious stones, encased in Ancestral Treechnid Amber. The mixture can be quite explosive, so it is not recommended you try to make it yourself. Leave it to a Jeweller you don\'t like.",ep:18,g:86,l:135,wd:true,fm:true,w:10,s:39,p:45600};
I.u[7004] = {n:"Risky Soul Stone for Average Souls",t:83,d:"You\'ll have a limited chance of capturing level 100 souls using this soul stone.",ep:5,g:8,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7005] = {n:"Risky Soul Stone for Big Souls",t:83,d:"You\'ll have a limited chance of capturing level 150 souls using this soul stone.",ep:5,g:9,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7006] = {n:"Risky Soul Stone for Huge Souls",t:83,d:"You\'ll have a limited chance of capturing level 200 souls using this soul stone.",ep:16,g:10,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7007] = {n:"Regular Soul Stone for Small Souls",t:83,d:"You\'ll have an even chance of capturing level 50 souls using this soul stone.",ep:5,g:2,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7008] = {n:"Regular Soul Stone for Average Souls",t:83,d:"You\'ll have an even chance of capturing level 100 souls using this soul stone.",ep:5,g:12,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7009] = {n:"Regular Soul Stone for Big Souls",t:83,d:"You\'ll have an even chance of capturing level 150 souls using this soul stone.",ep:16,g:13,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7010] = {n:"Full Soul Stone",t:85,d:"This soul stone contains the souls of a group of monsters whose only wish is to come back to life to tear your body to pieces. It can only be used in special arenas, located in big cities.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7011] = {n:"Desire o\'Ball Cloak",t:17,d:"This cloak is made of red beard hair... it is quite unique. Animated by extraordinarily powerful magic that renders it all but living, it adores playing practical jokes on the unfortunate bugger who puts it on. It\'s favourite trick? It unfindably conceals itself when it senses you need it most. If you do ever manage to discipline it, it can be very powerful in fights. As the Wabbits like to say it\'s a \"weal good instwument of wawfawe\".",ep:13,g:83,l:67,wd:false,fm:true,w:10,s:38,p:11875};
I.u[7012] = {n:"Smoothitch o\'Bal",t:1,d:"This Amulet is, in fact, a candy. It might have been edible if it hadn\'t been carefully rolled under female Bworker armpits for 36 generations as part of some bizarre ritual.",ep:7,g:87,l:77,wd:true,fm:true,w:10,s:38,p:15425};
I.u[7013] = {n:"Bamboo Wood",t:38,d:"Unlike reed, bamboo can break when bent. Most of the time, it\'s the teeth of a careless adventurer that will break first. These bloody dentists even have nature on their side... I tell you.",ep:18,g:673,l:50,wd:true,fm:true,w:5,p:0};
I.u[7014] = {n:"Holy Bamboo Wood",t:38,d:"You wouldn\'t think to look at it, but this wood is sacred. Normally, only the finest Pandawas can get their hands on a piece but sometimes, sometimes, lumberjack tourists take a little souvenir of their trip to Pandala island. Bloody tourists.",ep:18,g:671,l:100,wd:true,fm:true,w:5,p:0};
I.u[7015] = {n:"Bamboo Shoots",t:38,d:"Being completely tasteless, these bamboo shoots are not a popular foodstuff. You should cut them down with a well-rusted scythe and marinate them for a couple years in Greedovore juice before you serve them up to your friends. Another tip from unscrupulous restaurateurs willing to feed you anything at all.",ep:1,g:676,l:50,wd:true,fm:true,w:2,p:5};
I.u[7016] = {n:"Dark Bamboo Wood",t:38,d:"Walloh, a young Pandawa once asked his father: \"what\'s the difference between Bamboo and Dark Bamboo daddy?\" His dad slapped him in the face for asking such a stupid question. Everyone knows that the difference between Bamboo and Dark Bamboo is the size of their seeds.",ep:18,g:672,l:60,wd:true,fm:true,w:5,p:0};
I.u[7017] = {n:"Golden Bamboo Wood",t:38,d:"Walloh, a young Pandawa once asked his father: \'what\'s the difference between Bamboo and Golden Bamboo daddy?\'. His dad smacked him for asking such a stupid question. Everyone knows that the difference between Bamboo and Golden Bamboo is the size of their roots.",ep:18,g:669,l:45,wd:true,fm:true,w:5,p:20};
I.u[7018] = {n:"Rice",t:34,d:"Either sticky or slimy, rice is a long-time favourite with young, starving Pandawas.",ep:18,g:10,l:20,wd:true,fm:true,w:2,p:0};
I.u[7020] = {n:"Lotus Flower",t:38,d:"Some say it\'s the oldest known flower. It symbolizes fertility as well as detachment since it can submerge itself in water without getting wet. Some Pandawa Chiefs use this symbol to make their followers understand they have to live their life in the world without falling under its influence...",ep:1,g:141,l:30,wd:true,fm:true,w:1,p:2};
I.u[7022] = {n:"Sangroku\'s Staff",t:4,d:"This Staff belonged to Sangroku\'s grandfather, Sangrokrane, famous for his big head. Legend says this magic staff has the ability to stretch to any length desired... use it to flatten your enemies or stick it down your pants, you\'re always a winner with this thing...",ep:18,g:47,l:120,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,50,60,false,false],c:"CA>250&CV>300",p:36620};
I.u[7023] = {n:"Aquamarine Stone",t:51,d:"This stone is usually found around Pandala Island. Pandawas are convinced it has special powers. Just like the rumours about Iops and their hidden intelligence, no one has proven this myth.",ep:1,g:75,l:60,wd:true,fm:true,w:5,p:600};
I.u[7024] = {n:"Topaz Stone",t:51,d:"Batches of this weird-looking stone were once used feed the young Crackrocks of Pandala breeders. Believe it or not, the stones are now endangered, so this practice has been discontinued.",ep:5,g:76,l:70,wd:true,fm:true,w:5,p:700};
I.u[7025] = {n:"Agathe Stone",t:51,d:"This stone has been named after a Pandala river in which great quantities of it used to be found. But times have changed and the intensive exploitation of the past now means it is difficult to find.",ep:5,g:128,l:80,wd:true,fm:true,w:5,p:1};
I.u[7026] = {n:"Aquamarine",t:50,d:"This precious, slightly blue, transparent stone is so bright that it can hide the most ravine-like wrinkles when worn as a necklace. Pandawas even tell tourists: \"With this stone, keep your man happy and watch with pity the ravages of time misshape your loved ones.\" A nice way to kill two birds with one stone!",ep:1,g:101,l:60,wd:true,fm:true,w:5,p:600};
I.u[7027] = {n:"Topaz",t:50,d:"For some dubious reasons, Topaz is still the most popular jewel among jewellers. It attracts quite a lot of Crows in the Cania Plains.",ep:5,g:102,l:70,wd:true,fm:true,w:5,p:700};
I.u[7028] = {n:"Agathe",t:50,d:"This stone has been named after a very famous female Pandawa: Agathe Pahtes. She could be found in places of debauchery such as the Sufokia Pirates\' Pub, where she spent her last years dancing, chained up to a big mast in the middle of the pub.",ep:5,g:103,l:80,wd:true,fm:true,w:5,p:800};
I.u[7029] = {n:"Sangroku\'s Belt",t:10,d:"Sangroku ate way too many magic beans one time. Forever more, it was a constant struggle to restrain the winds of panic that erupted from his britches without the slightest warning... Those very same winds made him famous the length and breadth of Amakna.",ep:13,g:80,l:86,wd:false,fm:true,w:10,c:"CS>100",p:18400};
I.u[7030] = {n:"Kaniger Skin",t:59,d:"Once shaved, Kaniger skin is very soft, a bit like a female Sadida\'s.",ep:13,g:47,l:70,wd:true,fm:true,w:5,p:1};
I.u[7031] = {n:"Flooey\'s Clock",t:1,d:"Poor Flooey lost his mind after a terrible fight against Many. Fortunately, his amulet didn\'t suffer. It kept both its mesmerizing properties and its laxative powers. To be taken only when absolutely necessary.",ep:18,g:90,l:46,wd:false,fm:true,w:2,p:5600};
I.u[7032] = {n:"Silicate",t:39,d:"This ore probably comes from the depths of the Pandala island mines where Gardan Framine fell head over heels in love with a female Pandawa ghost. Love really doesn\'t know any boundaries!",ep:16,g:111,l:70,wd:true,fm:true,w:5,p:0};
I.u[7033] = {n:"Dolomite",t:39,d:"Irko, the Dark Miner, had great respect for Dolomite. \'The hard and unbreakable rock\' he used to call it.",ep:16,g:110,l:80,wd:true,fm:true,w:5,p:0};
I.u[7034] = {n:"Master Nabur Helmet",t:16,d:"Passed down from generation to generation, this misshapen helmet was even worn by Crail himself. Many adventurers think it has mysterious powers. As with many divinities and modern heroes, the magical powers of this helmet have all the potency of a shoe...",ep:16,g:93,l:97,wd:false,fm:true,w:10,p:23000};
I.u[7035] = {n:"Pyrute",t:40,d:"This alloy was used to forge blades which wouldn\'t rust when in contact with the blood and drool of its victims",ep:16,g:708,l:100,wd:true,fm:true,w:100,p:0};
I.u[7036] = {n:"Brassic",t:40,d:"A shiny alloy, Brassic is tolerated by bankrupt jewellers who can\'t afford precious stones. They usually make very competitively priced alloys. Comes in handy when you want to marry for money.",ep:16,g:707,l:100,wd:true,fm:true,w:100,p:0};
I.u[7037] = {n:"Granny Candy\'s Stick",t:4,d:"This stick used to belong to Granny Candy, one of the three famous Love Priestesses. Sharpened at one end and shiny at the other, this stick is renowned for its versatility and its annoying tendency to turn up just about anywhere. None can resist its power.",ep:18,g:48,l:98,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,50,50,false,false],c:"CS>100&CV>300",p:24500};
I.u[7038] = {n:"King Jellix\'s Crown",t:16,d:"This crown belonged to the famous King Jellix, renowned for his unbounded romanticism and his seductive power which left its mark on many female Jellies... Some even say he is the father of all the Jellies of the region of Amakna, proof (if needed) of his stamina and legendary fecundity.",ep:7,g:94,l:79,wd:true,fm:true,w:15,p:15000};
I.u[7039] = {n:"Frank Lee Bruce\'s Black Belt",t:10,d:"A famous Sunday fighter, Frank crossed over into martial arts after he failed miserably at his stone-cutter apprenticeship.",ep:13,g:81,l:47,wd:true,fm:true,w:5,p:5900};
I.u[7040] = {n:"Kuri Bow",t:2,d:"This bow belonged to Kuri, the famous Love Priestess and left-hand woman of Granny Candy. Never turn your back on a Love Priestess. One arrow from this bow is enough to tear your heart to shreds, or your arse if you have actually turned around.",ep:18,g:43,l:56,wd:true,fm:true,w:10,an:10,tw:true,e:[15,5,2,6,20,40,false,true],p:8300};
I.u[7041] = {n:"MacSheth",t:30,d:"Also called the Duncan Flonuts, The Soil and Bubble or the Pandawa Trots, the MacSheth is a Pandala speciality! Symptoms: an urgent need to get to the throne, violent yanking on the chain of command and a ruthless desire to evacuate all that blocks your passage...",ep:18,g:8,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7042] = {n:"Pandawa Headgear",t:14,d:"Unlike the Pandawa of Amakna, the Pandawa from Pandala won\'t make you big-headed, but will arouse an inexplicable urge to throw fertilizer around the place!",ep:18,g:31,l:1,wd:false,fm:true,w:1,c:"PG!12",u:true,p:1000};
I.u[7043] = {n:"Ice Dofus",t:23,d:"Legend says that this magnificent Dofus came out of the frozen hole of the Water dragon Aguabrial. Legend does not say if he had a cold that day, though it\'s highly likely.",ep:1,g:5,l:1,wd:false,fm:true,w:1,p:1};
I.u[7044] = {n:"Fake Dofus",t:24,d:"This Dofus looks like no other... Wait a minu...",ep:18,g:256,l:1,wd:false,fm:true,w:0,p:1};
I.u[7045] = {n:"Pandaburg Flask",t:79,d:"Pandaburg is a tasty drink which could very slowly make you blind, mute and deaf. How convenient! Pandawas aren\'t the speedy kind.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[7046] = {n:"Pandapiler Flask",t:79,d:"According to the erudite Hel Munster, this genuine nectar delights the goddess Pandawa herself, making her completely euphoric. Any true Pandawa should give his Pandapilers away to the venerated goddess.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[7047] = {n:"Pandapils Flask",t:79,d:"One of the more sensible Pandawan traditions goes like this: Clink glasses with your neighbour, throw sugar on your hair and burp the following line - \"Pandapils, Pandapils, tralalalaHIHOO!\".",ep:18,g:4,l:1,wd:true,fm:true,w:1,p:1};
I.u[7055] = {n:"Pandneken Flask",t:79,d:"\"It\'s true that Bwaks have short legs, but there\'d be no point making them longer\". This is the type of conversation you end up having after consuming Pandneken. That\'s why Pandawas now prefer to keep it for their libations to Pandawa.",ep:18,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[7056] = {n:"Kracker Cap",t:16,d:"This unique hat used to belong to a Xelor grandmaster, known the world over for his explosive theories and his incessant meddling with time. His death was as explosive and untimely as his life... Jealous of his neighbour\'s hat, whose magic powers were said to be even greater than his, he rashly unleashed a Wind of Panic to remove it forever, forgetting about his own. He was blown into a million little pieces when his hat exploded like a giant firecracker.",ep:19,g:95,l:149,wd:true,fm:true,w:10,p:45850};
I.u[7057] = {n:"Shaman\'s Assistant",t:32,d:"Bring the assistant to the goddess, he will be grateful...",ep:18,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7058] = {n:"Octovius",t:16,d:"This headgear is made of dead dried Kralove leftovers. Be careful, it can come back to life if you use it as a bathing cap.",ep:18,g:96,l:77,wd:true,fm:true,w:10,p:15475};
I.u[7059] = {n:"Pandkin Seed",t:58,d:"This humongous seed is filled with a heavy but magical oil. Its shell is said to be unbreakable and many craftsmen use it to enchant their weapons. Others stick wiggly eyes on it and put it on the dashboard of their cart...",ep:18,g:67,l:100,wd:true,fm:true,w:10,p:10};
I.u[7060] = {n:"Pandapiler Special",t:24,d:"Lenald the Wise gave you this Pandapiler to bring to the Pandawushu Master of the water path.",ep:18,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[7061] = {n:"Bow Meow Curse",t:31,d:"The water from the source juice-sane-ki-oak of the Bow Meow temporarily turned you into a Bow Meow. The slightest shock will make you go back to normal.",ep:18,g:21,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7062] = {n:"Poochan",t:32,d:"You must take Poochan to her future husband.",ep:18,g:21,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7063] = {n:"Imp Flower",t:35,d:"This pretty flower only grows in the Imp village, a bit like an Impette, only not as mean.",ep:1,g:634,l:40,wd:true,fm:true,w:2,p:10};
I.u[7064] = {n:"Itchy Orchid",t:35,d:"This magnificent orchid is very well-known for the enraging itch that grips anyone who dares to prune it.",ep:1,g:633,l:40,wd:true,fm:true,w:2,p:10};
I.u[7068] = {n:"Rice Flour",t:52,d:"This flour is perfect for making cement or even bedding for your dog.",ep:18,g:7,l:50,wd:true,fm:true,w:2,p:0};
I.u[7069] = {n:"Smashed Sidimote Shield",t:82,d:"This shield has seen a few battles too many, in this state it is good for nothing. Perhaps Bouwada, in Pandala village, could replace it for you.",ep:18,g:8,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:15650};
