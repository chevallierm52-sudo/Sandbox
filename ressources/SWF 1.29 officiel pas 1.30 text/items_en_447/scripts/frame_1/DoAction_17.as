I.u[7652] = {n:"Memory Potion",t:12,d:"This potion allows you to steal part of a being\'s essence and retain an everlasting memory of your victim\'s soul. Quite handy for marking your territory or your goods, this potion is often used to create signature runes.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
