I.u[1137] = {n:"Houvette\'s Discreet Wand",t:3,d:"Houvette invented these wands to claim back her Enutrof husband from the liquid grip of the bar where he spent his evenings. She also used them to spice up their relationship, but nobody knows exactly how...",ep:7,g:19,l:40,wd:true,fm:true,w:12,an:11,e:[5,3,2,2,50,50,false,true],c:"CW>10&CI>45",p:4000};
