I.u[1438] = {n:"Unlucky Pick",t:21,d:"This pick is considered a lucky charm, although anyone depending on a pick to make their living has usually seen that boat sail a long time ago.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,4,1,1,50,50,false,true],c:"CC>30",p:2500};
I.u[1439] = {n:"Lucky Pick",t:21,d:"This pick seems to bring the evil eye upon you. With a few alterations here and there, perhaps you could have a great pick on your hands.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,6,1,1,50,10,false,true],p:250};
