I.u[997] = {n:"Kokonut",t:46,d:"Round as a cannonball, the Kokonut also has 3 holes, which makes it very easy to throw away.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Captain Pirate\'s Cute Shorts",t:15,d:"Captain Pirate\'s shorts are the proof that ridicule has actually killed someone. But apparently, they are also very lucky.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Not Tempting Canvas",t:55,d:"This large piece of canvas is slimy and smelly but yet of quite good quality. Too bad it has so many holes!",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Empty Barrel",t:15,d:"This big barrel was emptied a long time ago, nevertheless we can still guess what it used to contain: rum, Kamas, drunken pirates... anything you can find in a barrel besides water.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Kokoko Wood Plank",t:95,d:"What will you do with this plank? Build a boat? Lay a floor in your house? Do you really care? Whatever, it\'s just a simple plank for the moment.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"Kokonut Palm Trunk",t:38,d:"Kokonut palm trunks are similar to other trunks: straight and strong, yet they are slightly thinner than the average.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Kokoko Wood Beam",t:38,d:"Solid wood beam. Don\'t put it into someone\'s eye.",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Essential Rope",t:15,d:"No self-respecting adventurer would go without such a Rope in his inventory. You should be advised to do the same, although it\'s a piece of advice seldom taken!",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Raft Receipt",t:24,d:"A receipt signed by Kib Rock telling you your raft will be ready soon.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Pirate Hat",t:24,d:"Large brim, the insignia of death embroidered on, fur to make it nice...This pirate hat is a classic of its kind among captains.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Hook",t:24,d:"Essential accessory for unlucky pirates, this hook can be used as a hand. Its colour gives it a classy style...",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Falling Jaw",t:24,d:"People say that this Jaw necklace was created when a captain caught one of his sailors smiling at him.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Pirate Skull",t:24,d:"This skull wearing a headband proves that a even a dead pirate can hide his baldness.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Green Shell",t:24,d:"The shell of a mad turtle that thinks it\'s a ninja.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1011] = {n:"Yellow Shell",t:24,d:"The Shell of a mad turtle who had probably ingested too many dangerous substances.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Red Shell",t:24,d:"The shell of a mad turtle that liked tomatoes and cheese on a warm slice of bread.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Blue Shell",t:24,d:"The shell of a mad turtle who wanted to imitate Zowwo, the Masked Fox.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Green Mask",t:24,d:"This Mask of Cheerful Kanniball has been made in the image of Greenery, element which is linked to meat seasoning.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Yellow Mask",t:24,d:"This Whining Kanniball mask has been made in the image of Lightning. What does that mean? Hey, I just work here, buddy.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Red Mask",t:24,d:"This Mask of Irascible Kanniball has been made in the image of Fire, element of roasting meat.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Blue Mask",t:24,d:"Mask of a Surprised Kanniball that has been made in the image of Water, element which slakes thirst between two mouthfuls of meat.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Glu",t:15,d:"This pot of pink jelly might smell good... But you must never taste it or you won\'t ever speak again. It\'s an excellent fixative.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Helmet",t:16,d:"Wearing this hat creates a very special look... halfway between ridiculous and comical.",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Broken Helmet",t:15,d:"This helmet took a bullet for you pal... He died for you, man...",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Wooden Wings",t:17,d:"For those who have always dreamt of flying like a Kwak, go back to bed because these wings will turn you into a public menace and an idiot.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Broken Wings",t:104,d:"Looking at these broken wings makes you realise just how badly you wanted to stay in bed this morning.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Bottle of Rum",t:15,d:"The label says \'10 year old rum\' but it is quite impossible to check if it tells the truth. Don\'t drink it excessively on the road for fear of seasickness.",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
I.u[1026] = {n:"Small Stek Knife",t:5,d:"One day, the infamously crazy T. Bun Stek found two strange yet impressive knives... No one could figure out what they were for. He used the very same knives to sacrifice half his livestock to the Gods and soon after they bellowed the answer from the heave\'s. He was slaughtering a particularly noisy cow at that very moment... The poor guy didn\'t hear a word.",ep:1,g:13,l:32,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>32&CS>10",p:3000};
