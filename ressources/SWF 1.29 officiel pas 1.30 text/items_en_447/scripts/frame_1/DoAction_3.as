I.u[1133] = {n:"Small Inacleft Stick",t:3,d:"This stick was the key to the emancipation of the Eniripsa housewives: a fearsome weapon against both monsters and hard-to-reach dust.",ep:1,g:20,l:30,wd:true,fm:true,w:10,an:11,e:[7,4,2,2,50,50,false,true],c:"CI>50",p:5000};
