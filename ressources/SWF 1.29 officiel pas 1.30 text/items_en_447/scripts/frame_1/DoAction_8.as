I.u[3648] = {n:"Captain Chafer\'s Small Daggers",t:5,d:"Captain Chafer has disappeared but you have his dagger in your hands. Just imagine what the blade must have seen all that time it was in his murderous grasp.",ep:14,g:32,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>50",p:18000};
I.u[3649] = {n:"Daguiero\'s Daggers",t:5,d:"We owe this magnificent blade to a craftsman named Daguiero. Before a descent into gambling and other dubious activities, this was his last creation worthy of interest. Not a bad way of ending a career...",ep:9,g:33,l:95,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:23000};
I.u[3650] = {n:"Regah Daggers",t:5,d:"These powerful daggers are the result of a collaboration between a group of wise craftsmen in order to secure their professional future. The group consisted of two. They both died arguing over the name of the daggers.",ep:3,g:34,l:120,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>100",p:37000};
