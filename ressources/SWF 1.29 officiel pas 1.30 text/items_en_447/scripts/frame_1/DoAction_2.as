I.u[901] = {n:"Piglet Leather",t:56,d:"Just like mimolette, this leather becomes a dirty shade of orange with the passage of time... and the horrible smell... Uggh!",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Klime\'s Small Boots",t:11,d:"These boots gave such agility to Klime the Shoemaker that he was able to ride Gobballs. He died when he mistook a Jelly for a Gobball... It was the day of his brother\'s wedding, he was understandably a little under the weather.",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Klime\'s Boots",t:11,d:"These boots gave such agility to Klime the Shoemaker that he was able to ride Gobballs. He died when he mistook a Jelly for a Gobball... It was the day of his brother\'s wedding, he was understandably a little under the weather.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Klime\'s Great Boots",t:11,d:"These boots gave such agility to Klime the Shoemaker that he was able to ride Gobballs. He died when he mistook a Jelly for a Gobball... It was the day of his brother\'s wedding, he was understandably a little under the weather.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Klime\'s Ultra-Powerful Boots",t:11,d:"According to the legend, these boots were secretly replaced by another pair, which though defective, were ultra-powerful;\r\n            they were made by a clumsy, overworked shoemaker.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Small Chase Boots",t:11,d:"With these boots, Hogmeiser used to chase off the only human beings he couldn\'t stand the sight of: children. Fortunately for them, the weight of the footwear prevented him from ever catching a single one.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Chase Boots",t:11,d:"With these boots, Hogmeiser used to chase off the only human beings he couldn\'t stand the sight of: children. Fortunately for them, the weight of the footwear prevented him from ever catching a single one.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Great Chase Boots",t:11,d:"With these boots, Hogmeiser used to chase off the only human beings he couldn\'t stand the sight of: children. Fortunately for them, the weight of the footwear prevented him from ever catching a single one.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Powerful Chase Boots",t:11,d:"With these boots, Hogmeiser used to chase off the only human beings he couldn\'t stand the sight of: children. Fortunately for them, the weight of the footwear prevented him from ever catching a single one.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Hogmeiser\'s Boots",t:11,d:"These boots belonged to Hogmeiser for many years, before he actually lost them on a stupid bet with Grizmine. The moral of this story is... never gamble with an Ecaflip.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Hogmeiser\'s Worn Boots",t:11,d:"These boots seem to have belonged to Hogmeiser for many years. They are now worn and uncomfortable. If you\'re lucky enough, a good shoemaker will repair them for you.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Hogmeiser\'s Golden Boots",t:11,d:"These magnificent Hogmeiser boots are finely peppered with precious stones, protecting you against magic attacks. Brouce Boulgoure himself used them to crush the Treechnid King\'s head many years ago, just to liven up the opening of the Trool Fair.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[916] = {n:"Silicate Amulet",t:1,d:"Silicate made this amulet on a wintry morning for a famous adventurer named Rimb Vardi, who was hunting down an old Magus Bwork. The bungling magic that followed was the root of many a natural disaster.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"Autumn Leaf",t:1,d:"This Brooch was made one fall morning in the depths of a Beech and Elm forest, near the Olag-Lacustre Island. It is considered to be a true relic by a great many Lumberjacks.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Ancestral Amber",t:50,d:"This amber comes from an Ancestral Treechnid and is priceless. It can confer magic properties on some items, provided they are made by skilled hands.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Ancestral Daggers",t:5,d:"These powerful daggers, forged from Ancestral Amber according to ancient techniques, were used during the colonization of Moon Island. It soon became wild again.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Ancestral Wood",t:38,d:"This elm wood comes from the Olag-lacustre Island, which was struck by lightning one Fall morning. Rumours have it that a Bwork Magus is responsible for it because he didn\'t control his elementary spells properly.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Axe Smith\'s Hammer",t:7,d:"An essential tool for making axes.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Treechnid Splitter",t:19,d:"This battle axe was forged by Kademlia Boulgoure to fight against the most terrifying Treechnids. Legend has it that this legendary weapon killed more Treechnids in a night than there are trees in Amakna.",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Klime\'s Powerful Boots",t:11,d:"These boots gave such agility to Klime the Shoemaker that he was able to ride Gobballs. He died when he mistook a Jelly for a Gobball... It was the day of his brother\'s wedding, he was understandably a little under the weather.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Bewitched Wood",t:38,d:"This wood was bewitched by a Treechnid Magus to give birth to a tiny Treechnid once put into water. This wood is obviously extremely magical.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Ancestral Treechnid Splitter",t:19,d:"This battle axe was forged by Kademlia Boulgoure to fight against the Ancestral Treechnid. Only the best warriors can handle it.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Ogralimde\'s Sword",t:6,d:"Ogralimde was a great warrior who derived his strength from his master Adyol, an exceptionally intelligent and powerful Bwork Magus. This apprentice never surpassed his master.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristalite",t:50,d:"This magic stone with a particular name is not suitable for general public as it can give great powers to weapons and jewels.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Dark Miners\' Treasure Map",t:24,d:"This map reveals the location of the Dark Miners\' Treasure Chest:  \n\"The chest may be found on an island. You\'ll have to pass behind a foundry to lay your hands on it.\"",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Dark Bakers\' Treasure Map",t:24,d:"This map reveals the location of the Dark Bakers chest: \n\"The chest may be found on an island south of Amakna;\r\n            you have to walk behind rocks, between two small ponds.\"",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Small Redness Cloak",t:17,d:"This cloak increases life.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
I.u[933] = {n:"Redness Cloak",t:17,d:"This cloak increases life.",ep:1,g:13,l:13,wd:true,fm:true,w:5,p:650};
I.u[934] = {n:"Great Redness Cloak",t:17,d:"This cloak increases life.",ep:1,g:13,l:16,wd:true,fm:true,w:5,p:900};
I.u[935] = {n:"Small Bluish Cloak",t:17,d:"This cloak increases chance.",ep:1,g:18,l:1,wd:true,fm:true,w:5,p:560};
I.u[936] = {n:"Bluish Cloak",t:17,d:"This cloak increases chance.",ep:1,g:18,l:3,wd:true,fm:true,w:5,p:1020};
I.u[937] = {n:"Great Bluish Cloak",t:17,d:"This cloak increases chance",ep:1,g:18,l:6,wd:true,fm:true,w:5,p:1560};
I.u[938] = {n:"Dark Smiths\' Treasure Map",t:24,d:"This map reveals the location of the Dark Smiths\' treasure chest.",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Bworks\' Treasure Map",t:24,d:"This map indicates the location of the Bworks\' treasure chest: \"The chest may be found in a dead end, in the South-East of the Dark Forest. It will certainly be kept by a group of Bworks.\"",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Farter",t:16,d:"The Farter protects you from physical damage.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Komintot Headband",t:16,d:"The Komintot increases the wisdom of the wearer.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Smoother",t:16,d:"The Smoother resists magic damage.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Small Vitality Headband",t:16,d:"This headband increases vitality.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Vitality Headband",t:16,d:"This headband increases vitality.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
I.u[945] = {n:"Small Dark Cloak",t:17,d:"This cloak increases wisdom.",ep:1,g:15,l:8,wd:true,fm:true,w:5,p:375};
I.u[946] = {n:"Dark Cloak",t:17,d:"This cloak increases wisdom.",ep:1,g:15,l:12,wd:true,fm:true,w:5,p:600};
I.u[947] = {n:"Great Dark Cloak",t:17,d:"This cloak increases wisdom.",ep:1,g:15,l:19,wd:true,fm:true,w:5,p:1200};
I.u[948] = {n:"Treecloak",t:17,d:"This magnificent cloak is a clever mix of Treechnid essence and nice familial Gobball.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Great Vitality Headband",t:16,d:"This headband increases vitality.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Needles and Thread",t:20,d:"This needle and thread will help you on your way to becoming a great tailor.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Mad Boowolf Cloak",t:17,d:"This cloak was made of hairs and other organic elements taken from Boowolves... I can smell its power from here...",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Mad Tofu Cloak",t:17,d:"With this handmade cloak of Tofu feathers, you will be able to run faster and escape from tackle zones with the grace of a shotgun-blasted pigeon...",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"Poak Cloak",t:17,d:"The legendary Poak Cloak was specially embroidered for warriors who live for close combat situations.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Cape Hillary",t:17,d:"Hairdressers use the Cape Hillary to tie up their hair. Will you?",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Cape Rice",t:17,d:"This cloak increases your range, allowing distant targets to be attacked... or naïve adventurers to be dumbfounded into unsuspecting admiration. Haha!",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"The Gobb",t:17,d:"The Gobb increases damage and vitality, but it gives off a nasty odour, too. Don\'t be surprised if the Gobballs think you\'re one of the gang.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofusteuse",t:17,d:"This cloak is certainly one of the most powerful of its kind in the world. It increases all the characteristics of its wearer.",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Treasure Map 5",t:24,d:"-- to do --",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Wabbit Potion",t:24,d:"This potion is a cure for myxomawosis. A sip of it and you will be able to visit Wabbit Island safely.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Wabbit Key",t:24,d:"One of the three keys which will enable you to enter the Wabbit Castle.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Wabbit Key",t:24,d:"One of the three keys which will enable you to enter the Wabbit Castle.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
I.u[963] = {n:"Wabbit Key",t:24,d:"One of the three keys which will enable you to enter the Wabbit Castle.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Dopple Stone",t:50,d:"This stone comes from the Dopple World. It\'s highly-prized by some inhabitants of Amakna.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Tailor Manual",t:25,d:"(Double click to learn how to become a Tailor) \nThis tailor manual will teach you the tricks of the trade. For those who lack imagination, the first pages have a few simple cut out patterns.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Dazzling Cloak",t:17,d:"This magnificent cloak increases AP, as well as vitality and wisdom.",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
I.u[968] = {n:"Dazzling Belt",t:10,d:"This magnificent belt increases action points, vitality and wisdom.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Wa Wabbit\'s Crown",t:16,d:"This magnificent Crown once belonged to the notorious Wa Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Wa Wabbit\'s Staff",t:4,d:"This staff once belonged to the notorious Wa Wabbit.",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Wa Wabbit\'s Cloak",t:17,d:"This cloak once belonged to the notorious Wa Wabbit. It is still impregnated with his perspiration which will bring back a few memories of the amazing fight every time you put it on.",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Cawwot Dofus",t:23,d:"The Cawwot Dofus increases its bearer\'s wisdom.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Arachnid Leg",t:24,d:"A very thin but very hairy Leg. The best Alchemists manage to create powerful poisons with the juice extracted from these legs.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Distressed Farmer\'s Head",t:24,d:"He had it coming: the distressed farmer lost his head...",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Captive Vampire Fang",t:24,d:"This very pointy fang belonged to a vampire. If you wear it round your neck, or even if you simply carry it in your inventory... you\'ll be able to show it to your buddies. Sorry, were you expecting more?",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Pumpkwin",t:16,d:"A distinctive feature of the Pumpkwin is that it prevents the dispersion of magic particles, making it a good magic insulator. That\'s why some warriors use this vegetable as headgear.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Lemon Shigekax",t:42,d:"Rediscover the flavour of bygone days with this bitter lemon drop. \nThis candy gives 100 energy points.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Strawberry Shigekax",t:42,d:"Rediscover the flavour of bygone days with this strawberry drop.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Mint Shigekax",t:42,d:"Rediscover the flavour of bygone days with this minty drop. \nThis candy gives 200 energy points.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Cherry Shigekax",t:42,d:"Rediscover the flavour of bygone days with this cherry drop. \nThis candy gives 50 energy points.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Greenjely",t:42,d:"Though made of mint jelly, this candy has repulsed more than a few vegetarians, but it\'s still a speciality of Amakna.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Redjely",t:42,d:"Made out of strawberry jelly, even if it repelled quite a few vegetarian, it\'s still a specialty of Amakna.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Blujely",t:42,d:"Blue-jelly based, it\'s one of the specialties of Amakna even though it repelled many vegetarians.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multijely",t:42,d:"Multijely was banned after children started disappearing soon after eating it. Not long after, they realised the kids were just going to the shop to get more.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
