I.u[897] = {n:"Small Dagguise",t:5,d:"These modest-looking daggers are extremely dangerous. They are easily hidden down the pants which makes them a weapon of choice for murderous eunuchs throughout the land. The words chicken and egg come to mind...",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
