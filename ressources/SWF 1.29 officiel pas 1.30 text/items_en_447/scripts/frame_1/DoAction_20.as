I.u[9255] = {n:"Livitinem Amulet",t:113,d:"This living polymorphous object can either be a predator or a symbiote of inanimate amulets. (This amulet is a living thing. You must feed it other amulets to keep it healthy and strong. Give it a meal, say, every 12 hours.)",ep:1,g:139,l:1,wd:true,fm:false,w:1,p:1};
I.u[9256] = {n:"Livitinem Ring",t:113,d:"This living polymorphous object can either be a predator or a symbiote of inanimate rings. (This ring is a living thing. You must feed it other rings to keep it healthy and strong. Give it a meal, say, every 12 hours.)",ep:1,g:161,l:1,wd:true,fm:false,w:1,p:1};
