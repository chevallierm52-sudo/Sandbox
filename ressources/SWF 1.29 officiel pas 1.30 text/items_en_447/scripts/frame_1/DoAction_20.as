I.u[9153] = {n:"Royal Cherry Amublop",t:1,d:"This Amublop costs a lot more to make than an ordinary Amublop, but look on the bright side... it will sell for a lot more too, especially if you offload it on an Astrubian.",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
