I.u[9043] = {n:"Mega Attack Potion",t:14,d:"This potion will make you so angry that you\'ll automatically attack enemies that get too close.",ep:0,g:35,l:1,wd:false,fm:true,w:1,c:"Pg>21,4",u:true,p:10};
I.u[9044] = {n:"Iop Disguise Potion",t:14,d:"This potion will allow you to take on the appearance of your choosing. Watch out, your mum might call the police if she finds you in your bed tomorrow morning.",ep:0,g:43,l:1,wd:false,fm:true,w:1,c:"Pg>10,3",u:true,p:10};
