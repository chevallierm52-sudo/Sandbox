I.u[10606] = {n:"White Rat Spiritual Gem",t:85,d:"This gem is awarded after a certain number of victories in duels, and it contains the soul of a monster. Keep in a cool, dry, dark place, away from strong odours. Shake well before use.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
