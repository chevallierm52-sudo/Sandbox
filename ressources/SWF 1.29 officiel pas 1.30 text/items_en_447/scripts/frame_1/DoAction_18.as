I.u[8348] = {n:"Black Dragoss Shell",t:111,d:"You can use this shell to protect what\'s most precious to you.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Sapphire Dragoss Shell",t:111,d:"You can use this shell to protect what\'s most precious to you.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
I.u[8350] = {n:"White Dragoss Shell",t:111,d:"You can use this shell to protect what\'s most precious to you.",ep:11,g:740,l:50,wd:true,fm:true,w:1,p:10};
I.u[8351] = {n:"Golden Dragoss Shell",t:111,d:"You can use this shell to protect what\'s most precious to you.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Black Dragoss Scale",t:59,d:"You could use this scale to make a very nice pair of boots or fighting underwear.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Sapphire Dragoss Scale",t:59,d:"You could use this scale to make a very nice pair of boots or fighting underwear.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"White Dragoss Scale",t:59,d:"You could use this scale to make a very nice pair of boots or fighting underwear.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Golden Dragoss Scale",t:59,d:"You could use this scale to make a very nice pair of boots or fighting underwear.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Dragostess Skin",t:59,d:"Smooth and perfumed with young adventurers\' blood, this skin makes Dragostesses irresistible. Used to make boots or belts, this skin can be washed in a washing machine at any temperature.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Dragostess Horn",t:47,d:"The Dragostess has two small horns at the back of her head with which she detects the love waves that float through the air during mating season... which never really ends for the Dreggons.",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Dragostess Protection",t:111,d:"This pair of Dreggon shells protects the Dragostess from love at first sight. Males can also use it, but they\'ll have to wear it below the belt.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Flying Dreggon Wing",t:104,d:"Even when this wing is damaged, torn and burnt, the Flying Dreggon can still freely fly above void like a young carefree Moskito.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Flying Dreggon Skin",t:59,d:"This dark skin is covered with a multitude of small scales that are supposed to improve the aerodynamics of the Flying Dreggon. In fact, they\'re useless and only make people talk.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Flying Dreggon Horn",t:47,d:"The Flying Dreggon uses this horn as an aiming device to help him hit his targets when he drinks and flies.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Dreggon Warrior Skin",t:59,d:"Tough enough to resist its own blade, Dreggon Warrior skin is also renowned for being edible... you\'ll have to boil it for several years first though.",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Dreggon Warrior Horn",t:47,d:"The Dreggon Warrior has three different horns: two on the back of his head and a third one on his snout. After a fight, a horn usually ends up in the behind of his victim and the two others stuck up in the nostrils of the foolhardy challenger. But from time to time, the Dreggon Warrior mistakes the behind for the nostrils. This only makes it worse for his victims.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Dreggon Warrior Leather Strap ",t:15,d:"This leather strap enables the Dreggon Warrior to attach his shoulder pad or to replace his shoulder strap.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Crocabulia\'s Broken Horn",t:47,d:"Crocabulia broke her horn in a terrible fight while protecting the egg from which Crocoburio hatched some 15 years later.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Little Red Waddling Cape",t:17,d:"This cape used to belong to a famous Capon, a long-feathered bird that loved to dance in front of the Bonta Zaap where all the gullible poultry and immature chicken hang out.",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Crocabulia Skin",t:59,d:"You could use this red skin to make a Little Red Waddling Cape, but your tailor would be very confused. \"This recipe has produced nothing!\" they would cry, somewhat awkwardly.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Crocabulia Tooth",t:47,d:"This huge tooth was pulled out at the very last minute, right before Crocabulia closed her mouth for the very last time.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Terrakubiack the Warrior Shell Fragment",t:111,d:"This shell fragment belonging to Terrakubiack the Warrior should help you make a key to access the Dreggon Sanctuary.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Ignilicrobur the Warrior Shell Fragment",t:111,d:"This shell fragment belonging to Ignilicrobur the Warrior should help you make a key to access the Dreggon Sanctuary.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Aeroktor the Warrior Shell Fragment",t:111,d:"This shell fragment belonging to Aeroktor the Warrior should help you make a key to access the Dreggon Sanctuary.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Aquabralak the Warrior Shell Fragment",t:111,d:"This shell fragment belonging to Aquabralak the Warrior should help you make a key to access the Dreggon Sanctuary.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Stone of Ignirkocropos the Famished",t:51,d:"This stone can release a powerful magic wave that will activate and open a magic door, if and only if it is combined with the three other missing stones.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Stone of Aqualikros the Merciless",t:51,d:"This stone can release a powerful magic wave that will activate and open a magic door, if and only if it is combined with the three other missing stones.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Stone of Terraburkahl the Perfidious",t:51,d:"This stone can release a powerful magic wave that will activate and open a magic door, if and only if it is combined with the three other missing stones.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Stone of Aerogoburius the Malicious",t:51,d:"This stone can release a powerful magic wave that will activate and open a magic door, if and only if it is combined with the three other missing stones.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Handyman Rune",t:88,d:"Handymen use this stone to give their position to clients.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Magic Fragment",t:88,d:"This fragment contains some magic transferred by an ancient object. You should be able to get a few magic runes out of it at least.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Vie Rune",t:78,d:"This small rune will make you more hardy.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Peki Fabric",t:55,d:"This fabric used to cover up the Peki\'s hairy behind until you rubbed it up the wrong way.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Magic Peki Tail",t:65,d:"This tail is so magic that it still wiggles even after it\'s been cut, dried and stuffed! It you\'re smart enough, you\'ll find it another use for it than hanging it above your fireplace.",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Moon Skin",t:59,d:"Deprived of his soft skin, poor Moon was taken by surprise and could only run away in the jungle screaming with pain. This is a nice bedtime story you\'ll enjoy telling your kids to make them go to sleep.",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Magic Moon Fabric",t:55,d:"This fabric seems to be magic and you find it hard to believe. But one day, you\'ll have to face the truth... You\'re just too stupid to tell if something\'s magic or not. Do not follow your Astrubian killer instinct... trust all these descriptions.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Shin Larva Skin",t:59,d:"This Shin Larva skin is even more sticky and slimy than you\'d have ever imagined. It reminds you of the last princess you rescued.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Shin Larva Tooth",t:47,d:"No one would have ever believed that a Shin Larva would actually have a mouth full of teeth. It\'s probably because Shin Larvae only have one tooth.",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Vibrating Royal Tofu Feather",t:53,d:"More royal than the Royal Tofu feather, more vibrating than the Vibrating Kirball of the Kruup mines, this feather will tickle whoever you want, wherever you want. The instructions say that it should be easy to look after.",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Bworkette Skin",t:59,d:"The Bworkette let you take some of her skin in exchange for your clemency. But she forgot to tell you that she told her big brother Bworker... he might want some of yours in exchange!",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Bworkette Hair",t:54,d:"The Bworkette has very soft skin everywhere but under her arms. Well, the little cookies she makes have to be flavoured somehow, don\'t they?",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Farle\'s Pig Skin",t:59,d:"If you believe the breeders, Farle was the greatest breeder of all. But then again, they were all jealous of Shika. Anyway, what\'s certain is Farle is the one who created Farle\'s Pigs. Another certainty is that he wasn\'t the most handsome creature - the pigs were created in his own image.",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"Dorgan Ation Skin",t:59,d:"Dorgan Ation has once more been extremely generous with you in spite of his bad temper. He gave you his skin before leaving and moaning like a Lousy Pig. What a nerve!",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"Blodz Uker Skin",t:59,d:"You used a cheese grater to scrape this skin off a poor Blodz Uker. No doubt he will remember that terrible event for life. Don\'t count on him to tell you the way next time you get lost in his maze.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Dragon Pig Hair",t:54,d:"Though you\'ve searched thoroughly, you couldn\'t find out where this Dragon Pig hair came from. Search some more. The Dragon Pig\'s anatomy is full of surprises...",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Mega Legendary Crackler Rock",t:51,d:"This humongous rock looks like a rock from the Legendary Crackler, but it is not. It\'s a lot more special than that!",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Boowolf Mojo",t:15,d:"This small flask contains all the virile power of the Boowolf. Be careful! Its contents are not edible.",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Wa Wabbit Hair",t:54,d:"The Wa Wabbit is usually quite miserly and balks at sharing its hairs. Exceptionally, to reward your courage (or buy your clemency), he has decided to give you one of his body parts. How touching!",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Wa Wabbit Fabric",t:55,d:"No one really knows where the Wa Wabbit got this fabric and no one seems to be willing to know either. Disturbing and disquieting, the origin of the fabric remains one of the greatest mysteries of all Amakna.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Pandora Master Hair",t:54,d:"Once again, the Pandora Master tried to show off. Another lesson he won\'t forget. He\'d have been better off in his box.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Pandora Master Fabric",t:55,d:"Whether protecting the nape of his neck or his ample behind, this fabric saved the Pandora Master\'s life more than once! \nBut not this time, however...",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Pandora Master Skin",t:59,d:"Worn out by magic attacks, dried out by the wind from Pandala Island, this skin is now of a very poor quality. But you seem to be attached to it as if you were trying to keep a precious memory from this courageous Pandora Master, who tried to kill you many times. It\'s at times like these that we see the difference between a real monster and a sissy.",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Koolich Stone",t:51,d:"Though the Koolich is quite a generous thing, he wasn\'t exactly happy about giving you his big stone. And it\'s understandable, given what you\'re going to do with it.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
I.u[8403] = {n:"Koolich Braid",t:15,d:"This huge braid was made by the Koolich himself, some years ago. With the passing years, it became as stiff as a rock. However, it still holds a foul, slimy liquid that attracts Moskitoes from time to time. The most surprising thing is that this braid used to perfectly suit the Koolich. Like a big Slob, you had the ridiculous idea to steal it.",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Skeunk Skin",t:59,d:"This piece of skin probably comes from Skeunk\'s heels which can explain its nice yellowish colour. Though this old skin won\'t enable you to make fashionable clothes, you\'ll still be able to create \"retro\" ones that younger generations will love.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Skeunk Hair",t:54,d:"Skeunk thinks nothing of a full body-shave. Here\'s the proof.",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Minotot Wool",t:57,d:"This wool is particularly thin making it possible for the Minotot not to have frizzy hair all over his body. No one knows why he has it. Maybe you should try to make hair grafts out of this wool so that you\'ll be able to display an abundant growth of brown hair on your chest. See, even your childhood dreams can come true!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Minotot Leather",t:56,d:"Almost as rare as Gobball leather, this leather is perfect for creations that require supple seams... leather masks, for example.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Minotot Hoof",t:47,d:"An enormous number of adventurers have been trampled by this hoof, but then so have many huge turds scattered around the Labyrinth of the Minotoror. You must understand that it\'s not easy for a charging Minotot to distinguish between the two at first glance.",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
