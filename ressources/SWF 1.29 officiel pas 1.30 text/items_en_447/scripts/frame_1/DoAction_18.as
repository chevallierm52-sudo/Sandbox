I.u[8175] = {n:"Bow Kennel Certificate: Treechster",t:77,d:"This Certificate describes the characteristics of Treechster that you\'ve put in the Bow Kennel.",ep:3,g:36,l:1,wd:false,fm:true,w:1,p:100};
