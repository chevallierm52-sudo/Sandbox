I.u[8211] = {n:"Pingoku",t:18,d:"This creature must have escaped from a zoo or some remote island somewhere. He is known to improve the damage of his master in combat. He also shares his most distinguishing feature with his master - his rotting-fish breath which comes from his strict fish diet. We suggest that you tape his mouth closed whenever you want to go to sleep.",ep:3,g:38,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8213] = {n:"Red Piwi Amulet",t:1,d:"This amulet seems to have been made with a small, dried red Piwi head. Vanity knows no bounds.",ep:1,g:100,l:1,wd:true,fm:true,w:1,s:60,p:1};
