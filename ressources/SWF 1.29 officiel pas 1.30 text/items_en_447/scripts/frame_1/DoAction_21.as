I.u[9523] = {n:"Mercenary Mission Large Reward",t:14,d:"This scroll certifies that you deserve a large reward for your commitment in completing the Mercenary missions.",ep:0,g:6,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
