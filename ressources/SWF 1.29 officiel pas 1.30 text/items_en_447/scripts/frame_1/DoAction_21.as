I.u[9652] = {n:"Alowa Headband",t:16,d:"This headband is perfect to absorb perspiration or to display your \"Alowa Attitude\".",ep:0,g:236,l:48,wd:true,fm:true,w:10,s:129,p:6175};
I.u[9653] = {n:"Kwakap",t:16,d:"The wings on this cap protect you from your insults.",ep:0,g:237,l:42,wd:true,fm:true,w:10,s:140,p:4825};
I.u[9654] = {n:"Alowa Cape",t:17,d:"This cape will flatter the curves of your backside, or the hump on your back.",ep:0,g:165,l:48,wd:true,fm:true,w:10,s:129,p:6105};
I.u[9655] = {n:"Alowa Sandals",t:11,d:"The soles of these sandals are thicker than regular sandals to make sure they\'ll resist the weight of the heavier Alowas.",ep:0,g:132,l:49,wd:true,fm:true,w:10,s:129,p:6475};
I.u[9656] = {n:"Slump Rollers",t:11,d:"These roller skates make it easier to go down stairs but considerably increase the risk of you breaking a few bones. It\'s up to you to take that risk.",ep:0,g:133,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9657] = {n:"Poopapink Staff",t:4,d:"Who gave that staff such a stupid appearance? Well, no one knows... But you\'ll still have to brandish it in front of your enemies... no matter how stupid YOU look doing so!",ep:0,g:82,l:42,wd:true,fm:true,w:10,an:12,e:[1,3,1,1,10,40,false,false],c:"CV>60&CW>30",s:140,p:4200};
I.u[9658] = {n:"Alowa Amulet",t:1,d:"This amulet is a mere flower necklace. It\'s supposed to give off a magic smell and transform an Alowa into an Alowaian...",ep:0,g:144,l:47,wd:true,fm:true,w:10,s:129,p:6000};
I.u[9659] = {n:"Slump Necklace",t:1,d:"Erala wore this amulet for her entire childhood. No one knows what\'s inside it, not even her.",ep:0,g:143,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9660] = {n:"Slait Cape",t:17,d:"Two tails on one body... A dream which finally comes true!",ep:0,g:166,l:47,wd:true,fm:true,w:10,s:128,p:5825};
