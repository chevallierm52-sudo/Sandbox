I.u[2168] = {n:"Start of Report",t:24,d:"This report starts to outline the worrying changes in the Brakmarian magmatic mass.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2169] = {n:"Raaga",t:32,d:"Bring Raaga to a magmatic cave.",ep:14,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2170] = {n:"Mercenary\'s Sword",t:6,d:"This long sword is heavy and difficult to handle, but it cuts like any sword you can name...",ep:1,g:25,l:1,wd:true,fm:true,w:1,an:14,tw:true,e:[30,5,1,1,25,50,false,false],p:1};
I.u[2171] = {n:"Raaga\'s Report",t:24,d:"This report outlines the chaotic changes in volcanic activities around Brakmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2172] = {n:"List of Samples to find",t:24,d:"Raaga roughly wrote down the information you need to find good lava samples:\n\'Search within a 5 miles radius. Look for small peaks.\'",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2173] = {n:"Secrets of the Squirrel Language",t:25,d:"This dictionary will teach you how to talk with squirrels, or at least how to try to...",ep:2,g:6,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[2174] = {n:"Interrogation Room Pass",t:24,d:"With this piece of paper, you can freely enter the prison\'s small Interrogation Rooms",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2175] = {n:"Danathor\'s Threat",t:24,d:"This is a threat that Danathor wrote not to forget he needed something to fall back on in any circumstances.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2176] = {n:"Rimaraf\'s Address",t:24,d:"Rimaraf lives in a red brick house at 13 Carving Alley, in the Butcher\'s quarter.",ep:2,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[2177] = {n:"Danathor\'s Brooch",t:24,d:"Danathor gave you this small brooch.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2178] = {n:"Investigation Form 36",t:80,d:"This form is a good way to identify potential suspects of criminal actions. \n(Click on it, then on someone else to use it)",ep:16,g:6,l:1,wd:true,fm:true,w:1,c:"PO!2181&PO!2177&Ps=1&Pa=27",ut:true,p:100};
I.u[2179] = {n:"Dragoturkey Tooth",t:47,d:"This tooth seems to be very sharp. It could become a fearsome weapon in the wrong hands. Fortunately, the Dragoturkey only uses it to chew salad.",ep:2,g:419,l:20,wd:true,fm:true,w:2,p:1};
I.u[2180] = {n:"Statement",t:24,d:"This person\'s alibi seems to hold up perfectly.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
