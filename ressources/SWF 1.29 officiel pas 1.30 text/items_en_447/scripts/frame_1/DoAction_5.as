I.u[2154] = {n:"De Sendar\'s Ring",t:9,d:"A ring worn by Silaisie.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2155] = {n:"Jiva Necklace",t:1,d:"An amulet worn by Silaisie.",ep:1,g:19,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2156] = {n:"Sword of Justice",t:6,d:"This sword allows you to preach to the people.",ep:1,g:16,l:1,wd:false,fm:true,w:1,an:14,e:[30,5,1,1,30,50,false,false],c:"PN~Silaisie",p:1};
I.u[2157] = {n:"Clint",t:16,d:"The Clint is a simple but classy hat. The latest version of this hat strangely suits both delicate female adventurers and the more virile male sort. A sure sign of quality, that.",ep:1,g:38,l:50,wd:true,fm:true,w:10,c:"Ps=3",p:1};
I.u[2158] = {n:"Letter from Oto Mustam to Sbab",t:24,d:"The aim of this fully ironic letter is to denigrate Sbab.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2159] = {n:"Scroll of Bravery",t:14,d:"This parchment increases your Strength. It can be useful when a furious Kaniger charges you.",ep:1,g:2,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2160] = {n:"Disheartening Scroll",t:14,d:"Use this scroll to reduce the Strength of a single target. This can be useful when a furious Kaniger is charging your enemy.",ep:1,g:4,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2161] = {n:"Scroll of Suppleness",t:14,d:"This parchment increases your Agility. It can be useful for dodging Moowolves.",ep:1,g:6,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2162] = {n:"Scroll of Stiffness",t:14,d:"This parchment reduces the Agility of a single target. Use it to prevent your enemy from escaping a Moowolf attack.",ep:16,g:5,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2163] = {n:"Truce",t:31,d:"You can\'t be attacked until your next fight.",ep:1,g:3,l:1,wd:true,fm:true,w:0,m:true,c:"Ps=0",p:1};
