I.u[2146] = {n:"Oni Tnec\'s Confession",t:24,d:"Oni Tnec describes the dreadful way he killed Rimaraf in his confession.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2147] = {n:"Scurvion Poison",t:24,d:"Some Scurvion poison. The bill for the delivery is addressed to Oni Tnec.",ep:2,g:39,l:1,wd:true,fm:true,w:0,p:1};
