I.u[1916] = {n:"Insect Flesh **",t:63,d:"Similar to Moskito flesh except there is ten times more of it. Fortunately, some people like it.",ep:3,g:370,l:50,wd:true,fm:true,w:4,p:1};
I.u[1917] = {n:"Pork Loin",t:63,d:"This choice morsel of boar is quite bloody for the moment but it will make a great meal.",ep:1,g:331,l:30,wd:true,fm:true,w:3,p:1};
I.u[1918] = {n:"Pork Loin **",t:63,d:"A bit bigger for a bit more happiness, this skilfully carved lump of Plain Boar will delight all kinds of carnivores.",ep:13,g:331,l:50,wd:true,fm:true,w:3,p:1};
I.u[1919] = {n:"Pork Loin ****",t:63,d:"That piece of Dragon Pig is so tender and soft that you could make a perfect cushion with it. But it\'s still nicer to eat it.",ep:2,g:331,l:80,wd:true,fm:true,w:4,p:1};
I.u[1920] = {n:"Bontarian Badge",t:24,d:"This badge is used to identify militiamen who have fallen on battlefields. Apparently some people collect them in Brakmar.",ep:2,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[1921] = {n:"Pork Loin ***",t:63,d:"A deliciously tough loin of pork from an athletic pig.",ep:1,g:331,l:60,wd:true,fm:true,w:3,p:1};
I.u[1922] = {n:"Dragomeat",t:63,d:"Rare high-quality meat, it remains hot hours after roasting. It\'s very convenient for picnics.",ep:2,g:371,l:40,wd:true,fm:true,w:2,p:1};
I.u[1923] = {n:"Dragomeat **",t:63,d:"This dragomeat, on top of remaining hot, has a  naturally smoky taste.",ep:2,g:371,l:60,wd:true,fm:true,w:2,p:1};
I.u[1924] = {n:"Dragomeat ***",t:63,d:"Dreggon Dragomeat is a bit hard to chew but is far more nourishing than standard Dragomeat. Some say it has magic properties.",ep:11,g:371,l:70,wd:true,fm:true,w:2,p:1};
I.u[1925] = {n:"A Day Leave",t:24,d:"This pass gives you a day leave.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[1926] = {n:"Dragomeat ****",t:63,d:"The meat of the Dragon Pig\'s dragon parts (nobody knows their exact location, nor does anybody want to try) is a godsend. Which makes sense given that Dragon Pigs can fly.",ep:2,g:371,l:80,wd:true,fm:true,w:2,p:1};
I.u[1927] = {n:"Muzzle",t:63,d:"Miliboowolf muzzle, with its small, firm chops, accompanies all salads perfectly.",ep:1,g:372,l:30,wd:true,fm:true,w:1,p:1};
I.u[1928] = {n:"Aggressive Boar Tusk",t:24,d:"The extraction of this Plain Boar tusk certainly required a great deal of know how.",ep:2,g:51,l:1,wd:true,fm:true,w:0,p:1};
I.u[1929] = {n:"Muzzle **",t:63,d:"This dainty muzzle is synonymous with a lack of will. Consume without moderation.",ep:1,g:373,l:50,wd:true,fm:true,w:2,p:1};
I.u[1930] = {n:"Muzzle ***",t:63,d:"This tasty meat must be eaten in moderation. There\'s a reason the Moowolf has such terribly bad breath!",ep:2,g:374,l:70,wd:true,fm:true,w:2,p:1};
I.u[1931] = {n:"Nicked Katana",t:24,d:"It\'s Amayiro\'s weapon. You can easily handle it but it seems to be slightly nicked.",ep:2,g:52,l:1,wd:true,fm:true,w:0,p:1};
I.u[1932] = {n:"Repaired Katana",t:24,d:"This weapon, which used to be nicked, is now ready to cut whatever you want. Amayiro won\'t be disappointed.",ep:2,g:53,l:1,wd:true,fm:true,w:0,p:1};
I.u[1933] = {n:"Bird Meat ****",t:63,d:"This small piece of crow is impregnated with powerful magic. Lord Crow himself is responsible for its power.",ep:13,g:350,l:30,wd:true,fm:true,w:2,p:1};
I.u[1934] = {n:"Hunting Knife",t:20,d:"This knife is the typical hallmark of the hunter. The brighter, sharper and bigger the blades are, the better-looking the hunters are... according to themselves at least...",ep:1,g:14,l:1,wd:true,fm:true,w:2,an:13,e:[10,3,1,1,25,30,false,false],c:"PJ>41,0",p:1};
I.u[1935] = {n:"Cheque for 100,000 Kamas",t:24,d:"Whoever pays his debts grows rich ok, but this is quite a sum! It would be better to avoid such debt, your children will be grateful...",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[1936] = {n:"Hunting Axe",t:20,d:"This axe is especially designed to quickly cut off any part of an animal, living or dead.",ep:1,g:15,l:1,wd:true,fm:true,w:5,an:17,e:[10,4,1,1,30,40,false,false],c:"PJ>41,9",p:1000};
