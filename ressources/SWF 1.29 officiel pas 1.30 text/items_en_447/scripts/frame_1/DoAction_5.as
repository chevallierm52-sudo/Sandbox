I.u[2141] = {n:"Plain Lungs",t:24,d:"A big green diamond adorns this necklace. It\'s so flashy that people usually focus more on the diamond than the person who\'s wearing it, which can be useful in some situations.",ep:1,g:66,l:1,wd:true,fm:true,w:0,p:1};
I.u[2143] = {n:"Mercenary Key",t:15,d:"Use this key to enter the Mercenaries\' house.",ep:1,g:404,l:1,wd:true,fm:true,w:0,p:1};
