I.u[2149] = {n:"Oni Tnec\'s Badge",t:24,d:"Oni Tnec\'s Badge, found in Rimaraf\'s home.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2150] = {n:"Scurvion Seed",t:58,d:"These seeds have been prepared with Scurvion venom. The effects of this lethal poison are exponential, according to the dose you take...",ep:14,g:405,l:36,wd:true,fm:true,w:1,p:1};
I.u[2151] = {n:"Rasputin Cake",t:33,d:"This cake is really good, just great... For exactly this reason, it is the single greatest source of malicious poisoning by Scurvion seed.",ep:3,g:406,l:30,wd:true,fm:true,w:5,p:1};
I.u[2152] = {n:"Colonel Lyeno",t:32,d:"Bring Colonel Lyeno to Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
