H.h[503] = {n:"Mittelgroßes Haus des Schmiedes",d:"Dieses Haus besteht aus 2 ausgebauten Etagen, und auf dem Speicher befinden sich alle Gerätschaften, die nötig sind, um in Ruhe seinem Beruf nachgehen zu können."};
