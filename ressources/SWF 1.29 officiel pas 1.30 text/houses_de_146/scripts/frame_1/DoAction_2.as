H.h[890] = {n:"Großes Strohhaus",d:"Ein hübsches Haus mit allen Schikanen! Zudem liegt es mitten auf einer Paradiesinsel! Da kann es gut sein, dass ihr nach einem Besuch eure Schwiegermutter gar nicht mehr loswerdet... Zum Glück gibt es mit drei Schatztruhen notfalls genug Platz, einen Kadaver verschwinden zu lassen."};
H.h[891] = {n:"Kleines Strohhaus",d:"Dieses niedliche kleine Haus ist genau das Richtige für den kleinen Geldbeutel. Dennoch werden auch die feinen Damen problemlos ihre gesamte Garderobe nebst Schminkköfferchen in der Schatztruhe des Hauses unterbringen können."};
H.h[892] = {n:"Mittelgroßes Strohhaus",d:"Diese reizende Bleibe ist genau das Richtige für junge Ehepaare, die das Meer und Meeresfrüchte lieben. Mit einer Schatztruhe für den Hausherrn und einer für die Hausherrin kann auch bei Ehepaaren mit einem Hang zur Unabhängigkeit nicht mehr schief gehen."};
