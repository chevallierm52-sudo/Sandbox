H.h[66] = {n:"Kleines Rieddachhaus",d:"Dieses kleine Haus mit seinem Rieddach befindet sich ganz in der Nähe eines kleinen Flusses, was Angler sehr erfreuen wird. Es gibt über dem Erdgeschoss noch eine ausgebaute Etage, allerdings ist die Treppe bei einem Haus dieser Preislage nicht im Preis nicht miteinbegriffen, weshalb man die großzügig zur Verfügung gestellte Leiter benutzen muss."};
H.h[67] = {n:"Kleines Rieddachhaus",d:"Dieses kleine Haus mit seinem Rieddach befindet sich ganz in der Nähe eines kleinen Flusses, was Angler sehr erfreuen wird. Es gibt über dem Erdgeschoss noch eine ausgebaute Etage, allerdings ist eine Treppe im Preis nicht mit inbegriffen, weshalb man die großzügig zur Verfügung gestellte Leiter benutzen muss."};
H.h[68] = {n:"Kleines Haus",d:"Dieses kleine Haus verfügt nur über eine einzige bewohnbare Etage. Der Speicher ist nämlich nicht mehr zugänglich, seitdem eine aggressive Rattenfamilie sich dort breitgemacht hat."};
H.h[69] = {n:"Zweistöckiges Haus",d:"Diese Haus besteht aus zwei Stockwerken, was all denen gefallen dürfte, die gern große Parties veranstalten, wohl aber nicht denen, die nur ungern Treppen steigen."};
H.h[70] = {n:"Einstöckiges Haus",d:"Dieses Haus liegt in der Nähe des Flusses und des Dorfes, was beides die Tatsache wieder wett macht, dass es nur ein einziges Stockwerk besitzt. Doch Vorsicht: Bei Hochwasser steht das Erdgeschoss meist unter Wasser."};
H.h[74] = {n:"Haus beim Geschäft",d:"Dieses kleine Haus ist ebenerdig. Doch der größte Vorteil ist seine direkte Nähe zu den Geschäften im Zentrum des Dorfes. Mit seinen zwei getrennten Betten ist es eher das Richtige für Paare, die auf ihre individuelle Privatsphäre wert legen."};
H.h[75] = {n:"Kate am Brunnen",d:"Diese Kate hat nur eine Etage, befindet sich allerdings direkt am Brunnenplatz. Darum ist sie ideal für all diejenigen, die gern ihren Besitz zur Schau stellen."};
H.h[76] = {n:"Gebäude am Brunnen",d:"Dieses ältere Gebäude umfasst immerhin 2 Stockwerke. Es gehörte einem überaus reichen Notar, der unter mysteriösen Umständen von einem Tag auf den anderen verschwand."};
H.h[77] = {n:"Gebäude an der Taverne",d:"Dieses ältere Gebäude umfasst nur 1 Stockwerk. Es wird besonders von gewohnheitsmäßigen Biertrinkern sehr geschätzt, die nach einer durchzechten Nacht in der Taverne gelegentlich Schwierigkeiten haben, ihren Heimweg zu finden. In der Tat befindet sich das Gebäude nur wenige Schritte von der Taverne entfernt."};
H.h[78] = {n:"Großes Haus des Meisters",d:"Dieses Herrenhaus mit seinen 3 großen Räumen ist definitiv den reichsten Einwohnern Amaknas vorbehalten. Es ist allerdings groß genug, um gleich mehrere Familien aufzunehmen, vorausgesetzt, diese sind daran gewöhnt, in enger Gemeinschaft zu leben."};
H.h[79] = {n:"Gebäude des Bäckers",d:"Dieses Gebäude umfasst 1 Stockwerk, in welchem einst eine bekannte Bäckerin ihre Brötchen meistbietend zu verkaufen pflegte. Heutzutage entspricht das Gebäude wieder sämtlichen Normen und steht anderen Häusern konfortmäßig in nichts nach."};
H.h[80] = {n:"Kate der Bäckerin",d:"Diese Kate mit einer Etage gehörte einst einer berühmten Bäckerin, deren Name allerdings im Laufe der Jahre in Vergessenheit geriet. Der ideale Ort also für angehende Bäcker/innen, die sich einen Namen machen wollen."};
H.h[81] = {n:"Haus beim Xélor-Tempel",d:"Dieses kleine Haus besteht zwar nur aus einem einzigen Raum, doch hat es den Vorteil, ganz nah beim Xélor-Tempel  und der Bäckerei zu liegen."};
H.h[82] = {n:"Kate beim Xélor-Tempel",d:"Diese ebenerdige Kate grenzt direkt an den Xélor-Tempel an. Darum ist sie die ideale Wahl für alle Xélors."};
H.h[83] = {n:"Kate des Schneiders",d:"Diese Kate mit nur einer Etage gehörte einst dem bekanntesten Schneider von Amkana, Elvis Trosse, Spezialist in der Anfertigung von blauen Hosen."};
H.h[84] = {n:"Haus des Bowisses",d:"Dieses niedliche kleine Häuslein wurde vom Bowissen, dem berühmten Schuhmacher, höchstpersönlich gebaut, was es zu einem der populärsten Gebäude Amaknas macht. Gleich nach der Bäckerei von Xaver, dem Bäcker."};
H.h[85] = {n:"Kate der Fresssäcke",d:"Diese niedliche kleine Kate hat nur 1 Stockwerk. Doch die Nähe zum Kanojedo-Tempel steigert gewaltig ihren Wert bei jungen Möchtegern-Abenteurern, obwohl sie gelegentlich von ausgehungerten Fresssackherden heimgesucht wird."};
H.h[87] = {n:"Kate beim Crâ-Geschäft",d:"Diese Kate mit nur einer Etage gehörte einst Edridge Valling, bevor sie den Speicher ihres Geschäfts ausbaute, um dort zu wohnen. Die Wände tragen noch die Spuren der Pfeileinschläge, was dieser Kate einen gewissen rustikalen Charme verleiht."};
H.h[88] = {n:"Haus beim Crâ-Geschäft",d:"Dieses kleine Haus besteht aus nur einem einzigen Raum. Dennoch ist es sehr teuer, da es direkt neben dem berühmten Crâ-Geschäft von Edridge Valling liegt. Zahlreich sind diejenigen, die dieses Haus einzig aus diesem Grund gekauft haben, weil sie so ihrer Angehimmelten öfter begegnen konnten."};
H.h[89] = {n:"Chalet an der Gießerei",d:"Dieses hölzerne Chalet besteht aus einem ausgebauten Stockwerk und befindet sich direkt bei der Gießerei. Liebhaber von geschmolzenem Metall werden hier voll auf ihre Kosten kommen. Leider nur wird die Umgebung auch desöfteren von Fresssäcken heimgesucht."};
H.h[90] = {n:"Seemannshütte",d:"Diese Hütte besteht nur aus einem kleinen Raum, welcher frühmorgens wunderbar das Sonnenlicht einfängt. Es gibt doch wirklich nichts Besseres, als sich morgens beim Aufwachen schon die Sonne auf den Bauch scheinen zu lassen!"};
H.h[91] = {n:"Fischerhütte",d:"Dieses kleine Hütte besteht nur aus einem einzigen Raum. Dennoch steht sie unter Denkmalschutz, denn sie gehörte einst dem berühmten fahrenden Sänger und Axtschmied Oh\'Nein, der dort seine Lieder zu komponieren pflegte."};
H.h[92] = {n:"Fischerheim",d:"Dieses kleine Heim mit einem Raum unterscheidet sich in nichts von anderen vergleichbaren Räumen, außer dass der berühmte Bowisse eine Zeit lang darin gewohnt hatte."};
H.h[93] = {n:"Fischer-Hütte",d:"Diese kleine Fischerhütte besteht nur aus einem einzigen kleinen Raum. Das Dach und die Fassade müssten auch mal wieder renoviert werden, doch genau all dies macht seinen Charme aus."};
H.h[94] = {n:"Kate des Fischers",d:"Diese gemütliche Kate ist ebenerdig gebaut. Sie diente einst als Zwischenlager für die frisch gefangenen Krebse."};
H.h[95] = {n:"Schiffshüllen-Gebäude",d:"Dieses ältere Gebäude umfasst nur 1 Stockwerk. Es gehörte einst dem berüchtigten Kapitän E-Glou, bevor dieser in ein viel praktischeres und völlig sicheres Einzelzimmer im Inneren des städtischen Gefängnisses umzog."};
H.h[96] = {n:"Kleine Hütte beim Hafen",d:"Dieses Haus besteht zwar nur aus einem einzigen Raum, doch liegt es direkt an der Küste. Man kann vom Haus aus tagtäglich der rollenden Brandung des Meeres zuhören. Gibt es irgendetwas Schöneres?"};
H.h[97] = {n:"Großes Schiffshüllendach-Haus am Hafen",d:"Dieses große Haus mit Schiffshüllendach besteht aus 3 riesigen Räumen. Ein echtes Herrenhaus eben. Da es so nah am Wasser steht, spart man sich die hohen Abfallgebüren, weil man seinen Müll direkt aus dem Fenster ins Wasser werfen kann. Wie bequem und praktisch!"};
H.h[109] = {n:"Eisenbahnhaus",d:"Dieses kleine Haus besteht nur aus einem einzigen Raum. Es gehörte vorher einem Bahnhofsvorsteher, Hassan Séhef, der es verließ, als die Zuggleise abgerissen wurden."};
H.h[110] = {n:"Kleines Haus bei den Schienen",d:"Dieses kleine Haus besteht nur aus einem einzigen Raum. Es gehörte vorher einem alten Bergmann, der täglich in seiner Lohre zur Arbeit einfuhr."};
H.h[111] = {n:"Fresssack-Gebäude",d:"Dieses ältere Gebäude umfasst nur 1 Stockwerk. Es gehörte einst dem berüchtigten Kapitän E-Glou, bevor dieser in ein viel praktischeres und völlig sicheres Einzelzimmer im Inneren des städtischen Gefängnisses umzog."};
H.h[112] = {n:"Haus der Fresssäcke",d:"Dieses Haus besteht nur aus einem einzigen Raum. Dennoch ist es sehr begehrt. Die wilden Fresssackherden, die gern in der Nähe des Hauses grasen, machen es attraktiv für alle, die sich für frische Fresssackschenkel begeistern."};
H.h[113] = {n:"Pilzhaus",d:"Dieses kleine Haus besteht nur aus einem einzigen Raum. Es gehörte früher einem alten Alchemisten, der aus diversen Pilzsorten Tränke mit oftmals stark unterschätzter Wirkung braute. Doch Vorsicht: die Pilze, die um das Haus herum wachsen, sind nicht nur selten, sondern auch gefährlich und sogar aggressiv."};
H.h[114] = {n:"Kleines Haus am Marktplatz",d:"Dieses kleine Fischerhaus befindet sich an einem touristischen Brennpunkt. Für Fischer, die normalerweise eher die Einsamkeit und Ruhe suchen, könnte dies etwas problematisch sein, doch für gesellige Abenteurer, die gern viele Gelegenheitsbekanntschaften schließen, ist es ideal."};
H.h[115] = {n:"Kleines Haus am Marktplatz",d:"Dieses kleine Seemannshaus besteht nur aus einem bescheidenen Raum. Somit wird es eher das Richtige sein für all diejenigen, die nicht nach materiellen Werten streben und in der Lage sind, auch ohne Luxus glücklich zu sein."};
H.h[116] = {n:"Kleines Haus am Marktplatz",d:"Dieses Seemannshaus besteht nur aus einem einzigen  Raum. Doch aus bisher ungeklärten Gründen besitzt es den Ruf, die Fruchtbarkeit der dort wohnenden Paare drastisch zu steigern. Vielleicht liegt das ja an der Enge und dem schmalen Bett, wer weiß?"};
H.h[117] = {n:"Kleines Haus am Marktplatz",d:"Dieses kleine Fischerhaus ist gut gelegen, direkt am Hafen neben einem Brunnen. Leider besteht es nur aus einem einzigen Raum, was auch den relativ bezahlbaren Preis erklärt."};
H.h[118] = {n:"Schiffshüllendach-Haus am Marktplatz",d:"Dieses Haus mit einer Schiffshülle als Dach liegt direkt gegenüber vom Brunnen des zentralen Marktplatzes am Hafen. Daher ist es auch besonders für Händler geeignet, die ihre Waren dann direkt vom Fenster aus anpreisen können."};
H.h[119] = {n:"Schiffshüllendach-Haus am Hafen",d:"Dieses Haus mit einer Schiffshülle als Dach bietet eine sehr gute Sicht auf den Leuchtturm. Ideal für große Romantiker, die ihre Liebste gerne mit selbstgemachten kleinen chinesischen Schattenspielchen verzaubern."};
H.h[120] = {n:"Kleines Haus am Hafen",d:"Dieses kleine Haus besteht nur aus einem einzigen Raum. Dennoch ist es dermaßen niedlich, dass nur wenige Touristen der Versuchung widerstehen, es zu kaufen. Die Tatsache, dass die sanitären Einrichtungen in Richtung des Meeres gebaut sind, spielt wohl eine nicht unerhebliche Rolle dabei."};
H.h[122] = {n:"Haus des Kanojedo-Wächters",d:"Dieses Haus besteht aus nur einem einzigen bewohnbaren Raum (der Speicher ist seid dem letzten Termiteneinfall, der sämtliche Dachziegeln gekostet hat, nicht mehr bewohnbar). Da es direkt neben dem Kanojedo-Tempel liegt, ist dieses Haus den Tempelwächtern vorbehalten."};
H.h[123] = {n:"Kleines Haus an der Brücke",d:"Dieses Haus besteht aus nur einem einzigen Raum, der aber ziemlich groß ist. Es befindet sich auf einer abgelegenen Insel fernab jeder Zivilisation, direkt an einer Brücke in der Nähe einer Gießerei. Die Nebenkosten sind im Preis noch nicht enthalten."};
H.h[124] = {n:"Haus des Gärtners",d:"Dieses kleine Haus besteht nur aus einem einzigen Raum. Es besitzt einen kleinen Gemüsegarten und befindet sich nahe an der Küste, weshalb es ideal ist für alle Bauern, die ein wenig Urlaub am Meer benötigen."};
H.h[125] = {n:"Kate am See",d:"Die kleine Kate am See besteht aus einer klassischen Etage, voll eingerichtet, sowie aus einem Nebengebäude, welches allerdings getrennt erworben werden muss. Dort lassen sich eventuell benötigte Bedienstete oder Leibwächter unterbringen."};
H.h[126] = {n:"Haus am See",d:"Dieses Haus besteht nur aus einem einzigen Raum. Doch liegt es dafür direkt am See und gleichzeitig in der Nähe der Küste, was sowohl Süß-, als auch Salzwasserangler beglücken wird."};
H.h[127] = {n:"Kleines Haus am See",d:"Dieses kleine, bescheiden aussehende Haus besteht zwar nur aus einem einzigen Raum, doch ist dieser dafür sehr geräumig und gut eingerichtet. Hobby-Süßwasserangler,      -Taucher und -Schwimmer werden hier voll auf ihre Kosten kommen, da es am Rande eines großen Sees liegt."};
H.h[128] = {n:"Kate mit Allee",d:"Diese Kate besteht aus nur einer Etage, hat allerdings zwei große Zimmer, die sich perfekt dafür eignen, große Runden von \"Tragic the Gardening\" darin stattfinden zu lassen. Die Pflege der Bäume in der Allee am Eingang hat allerdings ausschließlich durch den Eigentümer zu erfolgen."};
H.h[129] = {n:"Haus von MAX-LoL",d:"Dieses kleine Haus besteht zwar nur aus einer einzigen Etage, hat allerdings den Vorteil, auf einer kleinen Insel gelegen zu sein. Dadurch läßt es sich leicht gegen gegnerische Angriffe verteidigen, beispielsweise gegen den Halsabschneider-Clan."};
H.h[130] = {n:"Schiffshüllen-Haus",d:"Dieses eingeschossige Haus trägt eine alte Schiffshülle auf dem Dach, was sehr nützlich sein kann, zum Beispiel bei Hochwasser oder Springfluten."};
H.h[131] = {n:"Kleines Seemannshaus",d:"Dieses kleine Haus hat nur ein einziges Stockwerk. Da es sich sowohl in der Nähe des Hafens, als auch an einer Bucht des Schlammmeeres befindet, ist es schlichtweg ideal für Krebszüchter."};
H.h[132] = {n:"Fischer-Haus",d:"Dieses Fischer-Häuslein besteht nur aus einem einzigen Raum. Zudem hat sich inzwischen das Meer weiter zurückgezogen, was den Verkaufspreis stark gesenkt hat. Doch etwas weniger betuchte Abenteurer könnte genau das interessieren."};
H.h[133] = {n:"Haus mit Schiffshüllendach",d:"Dieses originelle Haus hat ein umgedrehtes Schiff auf dem Dach, was dem Eigentümer erspart, nach jedem Sturm wieder neue Dachziegeln einsetzen zu müssen. Unter dem Schiff befinden sich 2 gemütlich eingerichtete Etagen."};
H.h[134] = {n:"Kleines Haus beim Fluss",d:"Dieses kleine Haus besteht nur aus einem einzigen, bescheidenen Raum. Somit es am Besten für Einsiedler oder Bewohner mit sehr kleiner Körpergröße geeignet."};
H.h[135] = {n:"Kleines Fischerhaus",d:"Dieses kleine Fischerhaus besteht nur aus einem einzigen Raum. Es wird besonders von Hobby-Anglern sehr geschätzt, da sie hier ihrer Lieblingsbeschäftigung nachgehen können, ohne das Haus verlassen zu müssen."};
H.h[136] = {n:"Haus des Fresssacks",d:"Dieses Haus besitzt eine riesige Fläche, die auch noch pompös genug eingerichtet ist, um einen Botschafter zu empfangen. Außerdem wird beim Kauf eine kleine Schubkarre mit Heu dazugeschenkt. Doch Vorsicht: der Vorbesitzer war ein Fresssackzüchter und hat seine Tiere nach dem Verkauf schlicht und einfach freigelassen."};
H.h[137] = {n:"Kate bei der Vogelkirsche",d:"Dieses Haus besteht aus nur einer eingerichteten Etage. Allerdings besitzt es eine wunderschöne Treppe aus Eichenholz. Das Rieddach und der große Vogelkirschbaum im Garten geben ihm einen rustikalen Charme, der besonders von jenen geschätzt wird, die sich gern von ihren Mitmenschen abheben."};
H.h[138] = {n:"Kleines Haus beim Vogelkirschbaum",d:"Dieses Haus besteht aus nur einem einzigen Raum, welcher jedoch sehr groß und gut eingerichtet ist. Außerdem spendet der große Vogelkirschbaum im Garten im Sommer viel Schatten."};
H.h[139] = {n:"Haus beim Sägewerk",d:"Dieses kleine Haus verfügt über ein gut ausgebautes Stockwerk. Dank seiner Nähe zum Sägewerk ist es die ideale Unterkunft für dessen Eigentümer."};
H.h[140] = {n:"Kate am Sägewerk",d:"Dieses kleine Haus ist ebenerdig und direkt neben dem Sägewerk gelegen. Perfekt also für Holzfäller, die es meist hassen, für die Ausübung ihres Handwerkes außer Haus gehen zu müssen."};
H.h[141] = {n:"Haus von Aria Knofob",d:"NPC-Haus"};
H.h[142] = {n:"Berghaus",d:"Dieses Haus besteht nur aus einem einzigen Raum. Doch ist dieser sehr groß und gut eingerichtet."};
H.h[143] = {n:"Großes Schiffshüllendach-Haus am Hafen",d:"Dieses Große Haus mit einem Schiffshüllendach besteht aus 2 Stockwerken. Seine Nähe zum Hafen macht es interessant für alle Abenteurer mit Reiselust. Jedoch ist der Speicher heruntergekommen und voller Spinnennetze."};
H.h[144] = {n:"Haus in Sufokia",d:"Ein edles Haus mit Blick aufs Meer und konfortabel eingerichtetem Inneren. Dieses Haus ist schlicht und einfach bezaubernd."};
