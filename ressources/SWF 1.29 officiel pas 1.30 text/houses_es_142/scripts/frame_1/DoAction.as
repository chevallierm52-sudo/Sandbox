H.h[66] = {n:"Casa pequeña de Paja",d:"Esta pequeña casa con tejado de paja y a orillas del río gustará a los aficionados a la pesca. Tiene un piso pero hará falta utilizar una escalera de mano ya que la escalera fija no está comprendida en el precio de este tipo de casas."};
H.h[67] = {n:"Casa pequeña de Paja",d:"Esta pequeña casa con tejado de paja y a orillas del río gustará a los aficionados a la pesca. Tiene un piso pero hará falta utilizar una escalera de mano ya que la escalera fija no está comprendida en el precio de este tipo de casas."};
H.h[68] = {n:"Casa pequeña",d:"Esta pequeña casa sólo tiene un piso habitable, ya no se puede acceder al desván desde que una familia de ratas vive en él."};
H.h[69] = {n:"Casa de dos pisos",d:"Esta casa tiene dos pisos y es ideal para organizar grandes fiestas pero no convendrá a los que no les gusta subir escaleras."};
H.h[70] = {n:"Casa de un piso",d:"Esta casa está cerca del río y del pueblo lo cual compensa el hecho de tener sólo un piso. Pero ten cuidado, cuando está con crecida el río, la planta baja se inunda a menudo."};
H.h[74] = {n:"Casa cerca de la tienda",d:"Esta pequeña casa tiene un piso, pero su ventaja principal consiste en su ubicación al lado de la tienda de Celín y Carlota a unos pasos del centro del pueblo. Encantará a las parejas que quieren conservar un poco de intimidad con sus dos camas separadas en el piso de arriba."};
H.h[75] = {n:"Choza de la fuente",d:"Esta choza solamente tiene un piso pero está situada en la plaza de la fuente lo cual hace de ella una casa estupenda para los que deseen enseñar sus posesiones al pueblo."};
H.h[76] = {n:"Construcción de la Fuente",d:"Esta construcción de dos plantas pertenecía a un riquísimo notario que desapareció en circunstancias extrañas dejando la casa abandonada."};
H.h[77] = {n:"Construcción cerca de la taberna",d:"Esta construcción de un solo piso, que se encuentra a tan sólo unos pasos de la taberna, es muy apreciada por los bebedores de cerveza a los que les resulta difícil encontrar el camino tras haberse pasado de copas."};
H.h[78] = {n:"Casa grande de maestro",d:"Esta casa de maestro, de un piso y con tres habitaciones, está obviamente reservada para las personas más ricas de Ankama. Sin embargo, es lo suficientemente grande como para poder acoger a varias familias diferentes a condición de que ellas acepten vivir en comunidad, un poco como las hormigas."};
H.h[79] = {n:"Construcción de la Panadería",d:"Esta construcción de una planta era antiguamente la tienda de una famosa panadera en la cual vendía sus panes. Hoy esta construcción ha sido rehabilitada, todo está a las normas y en materia de confort no tiene nada que envidiarle a las demás casas."};
H.h[80] = {n:"Choza de la Panadería",d:"Esta choza con un piso pertenecía a una famosa panadera cuyo nombre sigue siendo desconocido. Esta choza es de lejos la casa ideal para cualquier Panadero o Panadera que se respeta."};
H.h[81] = {n:"Casa cerca del templo Xelor",d:"Esta pequeña casa sólo tiene una habitación pero tiene la ventaja de estar cerca del templo de Xelor y de la panadería."};
H.h[82] = {n:"Choza cerca del templo Xelor",d:"Esta choza con un piso está situada justo en frente del templo Xelor, lo cual hace de ella una vivienda perfecta para los Xelors."};
H.h[83] = {n:"Choza cerca de la Sastrería",d:"Esta choza que tiene un solo piso pertenecía al sastre más popular de Amakna, Elvis Tros que estaba especializado en la confección de pantalones azules."};
H.h[84] = {n:"Casita del Bowis",d:"Esta magnífica casita ha sido edificada por Bowis el zapatero en persona, eso hace de ella uno de los edificios más populares de toda Amakna. Es, sin lugar a duda, uno de los lugares turísticos más visitados después de la panadería de Javier el Panadero."};
H.h[85] = {n:"Choza de los Jalatós",d:"Esta choza encantadora tiene un piso. Aunque esté a menudo rodeada por hambrientos Jalatós, el hecho de estar cerca de un templo Kanojedo le da mucho valor para los aventureros novatos."};
H.h[87] = {n:"Choza cerca de la tienda ocra",d:"Esta choza que tiene un solo piso servía de casa a Edridge Valling antes de que hiciera obras en el desván de su tienda para poder vivir en él. Las paredes todavía están cubiertas por impactos de flechas pero eso le da un encanto especial a esta vivienda."};
H.h[88] = {n:"Casa cerca de la tienda ocra",d:"Esta pequeña casa tiene una sola habitación pero es muy cara porque está muy cerca del almacén de Edridge Valling. Muchos de sus pretendientes compraron esta casa para verla más a menudo."};
H.h[89] = {n:"Chalet de la Fundición",d:"Este chalet de madera tiene un piso y está situado cerca de la fundición. Los aficionados a metales en fusión serán felices viviendo en esta casa. Pero cuidado, la zona está a veces plagada de Jalatós."};
H.h[90] = {n:"Chabola del Marinero",d:"Esta chabola sólo tiene una habitación pero está muy bien orientada, al abrigo de los vientos dominantes puede sin embargo gozar de los rayos de sol matinales. Y poder sentir los rayos del sol acariciarte la piel al despertarte, no tiene precio, eso todo el mundo lo sabe."};
H.h[91] = {n:"Cabaña del pescador",d:"Esta cabaña de una sola habitación es un edificio clasificado como monumento histórico. Aquí fue donde el famoso trovador Juan Güís Lerra escribió sus 440 canciones."};
H.h[92] = {n:"Morada del Pescador",d:"Esta morada con una sola habitación no tiene nada de especial aparte que fue en este sitio donde el famoso Bowis ha pasado la mayor parte de su infancia."};
H.h[93] = {n:"Casita del Pescador",d:"Esta casita de pescador sólo tiene una habitación y la fachada necesita algunos trabajos de mantenimiento pero eso forma también parte de su encanto."};
H.h[94] = {n:"Choza del Pescador",d:"Esta choza de pescado tiene un piso. Hace tiempo, servía para almacenar cangrejos."};
H.h[95] = {n:"Construcción Casco",d:"Esta antigua construcción tiene un piso. Pertenecía al Captain Iglut, antes de conseguir un alojamiento de función dentro del recinto de la prisión."};
H.h[96] = {n:"Pequeña Chabola cerca del puerto",d:"Esta pequeña chabola sólo tiene una habitación pero está orientada hacia el mar, por eso es posible oír la resaca del mar durante todo el día para entretenerse."};
H.h[97] = {n:"Casa grande Casco del puerto",d:"Esta gran casa con tejado de casco de barco dispone de tres habitaciones lo cual hace de ella una casa de Maestro. Como está a orillas del agua, permite echar la basura directamente en el mar sin tener que preocuparse por los días de recogida de las basuras. Vamos, que es una manera de concebir el confort..."};
H.h[109] = {n:"Casa de los Ferrocarriles",d:"Esta pequeña casa sólo tiene una habitación. Antes pertenecía a un antiguo jefe de estación llamado Rinfe que abandonó su casa cuando la vía férrea dejó de funcionar."};
H.h[110] = {n:"Casa pequeña cerca de las vías",d:"Esta pequeña casa sólo tiene una habitación. Pertenecía a un antiguo minero que se iba al trabajo en su vagoncito para minerales."};
H.h[111] = {n:"Construcción de los jalatós",d:"Esta casa de un piso y con el tejado de paja está bastante bien amueblada, todo hay que decirlo. Su antiguo propietario tenía por costumbre de alimentar a los jalatós que pasaban por delante de su casa. Los cebaba durante varios meses para después degollarlos con viejas dagas oxidadas. Una especie de ritual bastante particular."};
H.h[112] = {n:"Casita de los Jalatós",d:"Esta casita sólo tiene una habitación y sin embargo es muy rebuscada ya que la presencia de rebaños de Jalatós Salvajes la vuelve muy interesante para los aficionados al Jalató asado."};
H.h[113] = {n:"Casa de las Setas",d:"Esta pequeña casa sólo tiene una habitación. Antes pertenecía a un viejo Alquimista que utilizaba muchísimos champiñones para sus pócimas con efectos a menudo subestimados. Ten cuidado, los champiñones que crecen alrededor pueden ser peligrosos e incluso agresivos."};
H.h[114] = {n:"Casa pequeña cerca de la plaza",d:"Esta pequeña casa de marinero está situada en un lugar muy frecuentado por los turistas.Esto puede ser un problema para los que buscan tranquilidad pero también una buena elección para los que no tengan wauwau que les ladre y quieran hacerse amigos."};
H.h[115] = {n:"Casa pequeña cerca de la plaza",d:"Esta pequeña casa de marinero sólo tiene una humilde habitación. Ideal para las personas poco materialistas que saben contentarse con poco y cuya prioridad no es el confort cuando compran una casa."};
H.h[116] = {n:"Casa pequeña cerca de la plaza",d:"Esta casa de marinero sólo tiene una única habitación pero tiene fama de facilitar la fecundidad de las parejas que viven en ella, por razones desconocidas. La única cama y lo diminuta que es desempeñan sin duda un papel importante en esta historia."};
H.h[117] = {n:"Casa pequeña cerca de la plaza",d:"Esta pequeña casa de pescador bien situada está justo al lado de la fuente del puerto. Una pena que sólo tenga una habitación. Su precio, relativamente asequible para este tipo de casas, compensa este punto negativo."};
H.h[118] = {n:"Casa Casco cerca de la plaza",d:"Esta casa con un tejado en forma de casco de barco tiene un piso. Está situada a los alrededores de la plaza del puerto, justo enfrente de la fuente lo cual no dejará de interesar a los comerciantes que no tendrán que caminar mucho para vender a gritos por el puerto."};
H.h[119] = {n:"Casa Casco del Puerto",d:"Esta casa con tejado en forma de casco de barco tiene un piso que ofrece una vista hacia el faro. Es ideal para aquellos románticos de Amakna a los que les gusta seducir aprovechando la luz del faro para hacer sombras chinas explícitas... Y se sabe que de estos hay muchísimos por el mundo adelante..."};
H.h[120] = {n:"Casa Pequeña del puerto",d:"Esta pequeña casa sólo tiene una habitación pero es tan hermosa que pocos turistas pueden resistir a las ganas de comprarla. Puede que sea porque los aseos dan directamente al mar."};
H.h[122] = {n:"Casa del guardián de Kanojedo",d:"Esta casa sólo tiene una habitación (el desván está prohibido al paso desde que unas polillas comedoras de tejas lo han invadido). Está situada justo al lado de un templo Kanojedo, está en general reservada para los guardianes del templo."};
H.h[123] = {n:"Casa pequeña cerca del puente",d:"Esta casa sólo tiene una amplia habitación. Esta situada sobre una isla de talla respetable, alejada de toda civilización estando sin embargo cerca de un puente y no está más que a unos pasos de la fundición. Los gastos de mantenimiento no vienen comprendidos en el precio."};
H.h[124] = {n:"Casa del Jardinero",d:"Esta pequeña casa sólo tiene una habitación. Pero en cambio dispone de un pequeño huerto y está cerca de la costa. Ideal para los campesinos no muy ricos a los que les gusta tomarse vacaciones en un lugar tranquilo."};
H.h[125] = {n:"Choza cerca del lago",d:"Esta choza tiene un piso vulgar y corriente así como una pequeña dependencia a su lado que se compra separadamente. Lo cual te permitirá alojar más fácilmente a un guardián o a uno de tus sirvientes."};
H.h[126] = {n:"Casita cerca del lago",d:"Esta casita sólo tiene una habitación pero está al mismo tiempo cerca del lago y cerca de la costa. Ideal para los pescadores de agua dulce y agua salada."};
H.h[127] = {n:"Casa pequeña cerca del lago",d:"Esta pequeña casa en apariencia humilde sólo tiene una habitación pero es espaciosa y está muy bien amueblada. Los aficionados a la pesca en agua dulce y a los chapuzones apreciarán el hecho que esté cerca del lago."};
H.h[128] = {n:"Choza con paseo",d:"Esta choza tiene un piso pero las dos habitaciones son muy amplias, lo suficiente para organizar grandes partidas de Tragic The Gardening. El propietario ha de hacerse cargo del mantenimiento de los árboles del paseo."};
H.h[129] = {n:"Casa de MAX-LoL",d:"Esta pequeña casa tiene un único piso pero tiene la ventaja de estar situada encima de una pequeña isla. Muy práctico para defenderla contra los Tymadores por ejemplo."};
H.h[130] = {n:"Casa casco de barco",d:"Esta casa de un piso tiene por tejado un viejo casco de barco encallado. Eso puede revelarse útil en caso de que suba mucho el nivel del mar o si se producen marejadas espectaculares."};
H.h[131] = {n:"Casa pequeña de marinero",d:"Esta pequeña casa de un piso está a la vez a proximidad del puerto y de un brazo de mar muy poco profundo ideal para los criadores de cangrejos que toleran la presencia de vecinos."};
H.h[132] = {n:"Casita de Pescador",d:"Esta casita de pescador sólo tiene una habitación y con el paso del tiempo, el mar se ha alejado lo cual ha quitado una parte de interés a esta casa. Sin embargo, las personas menos afortunadas sabrán contentarse con ella, por lo menos durante el tiempo que ahorren para comprarse una mejor."};
H.h[133] = {n:"Casa con tejado de casco",d:"El tejado de esta casa muy original está hecha con el casco de un barco lo cual evitará que su propietario tenga que cambiar las tejas del tejado después de grandes tempestades. Esta casa tiene dos pisos correctamente habilitados."};
H.h[134] = {n:"Casa pequeña del río",d:"Esta pequeña casa sólo tiene una humilde habitación, lo que la predispone a acoger aventureros solitarios o a inquilinos muy pequeñitos."};
H.h[135] = {n:"Casa pequeña del pescador",d:"Esta diminuta casa de pescador de una sola habitación es el sueño de todos los aficionados al pescado ya que pueden pescar sin tener que salir de su casa."};
H.h[136] = {n:"Casa de los jalatós",d:"Esta casa de un piso es bastante amplia, y lo suficientemente grande como para que el embajador reciba a sus invitados. Te regalan la carretilla de paja si compras esta casa. Pero ojo, su anterior propietario criaba jalatós y los ha dejado sueltos alrededor de la casa."};
H.h[137] = {n:"Choza cerca del Cerezo Silvestre",d:"Esta casa tiene un piso y una magnífica escalera de madera de roble. Su tejado de paja y el cerezo silvestre que crece frente a la puerta hacen de ella una casa muy rústica pero apreciada por personas a las que les gusta desmarcarse de los demás."};
H.h[138] = {n:"Casa pequeña cerca del Cerezo Silvestre",d:"Esta casa sólo tiene una amplia habitación. Un magnífico cerezo salvaje procura sombra en verano a los propietarios de esta encantadora morada."};
H.h[139] = {n:"Casa del aserradero",d:"Esta pequeña casa tiene sin embargo un piso. Su proximidad con el aserradero la convierte en casa ideal para el propietario del aserradero."};
H.h[140] = {n:"Choza del aserradero",d:"Esta pequeña casa tiene un piso vulgar y corriente pero está situada cerca del aserradero. Eso le gustará a los leñadores que odian perder tiempo para ir hasta su lugar de trabajo."};
H.h[141] = {n:"Casa de Aria Knofob",d:"Casa de PNJ."};
H.h[142] = {n:"Casa Montañesa",d:"Esta casa sólo tiene una habitación pero es amplia y está bien amueblada."};
H.h[143] = {n:"Casa grande Casco del puerto",d:"Esta gran casa con tejado de casco de barco dispone de dos pisos lo cual hace de ella una casa de Maestro. Su proximidad con el puerto hace de ella una morada ideal para los que quieren viajar. En cambio, el desván es lúgubre y rebosa de telas de araña."};
H.h[144] = {n:"Casa de Sufokia",d:"Noble hábitat, con vistas hacia el mar y gran confort interior. Esta casa te seducirá por la gran riqueza de su mobiliario."};
H.h[145] = {n:"Casa grande de Sufokia",d:"Una casa aislada cuya arquitectura sorprende por su luminosidad y su confort. Su primera planta posee un magnífico jardín interior muy apreciable para relajarse al son del océano."};
