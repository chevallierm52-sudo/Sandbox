VERSION = 54;
SR = new Object();
SR[1] = {n:"Jiva",d:"Jiva is de beschermster van de maand Javian. Zij vervangt Solar op deze post toen hij gedood werd door Djaul. Zij staat aan het begin van de opbouw van Bonta. Ze besloot het te bouwen met Pouchecot en Menalt om de groeiende macht van Brakmar te verhinderen.",l:"fr",p:"4",t:0,c:"0",date:"1093298400000",rlng:[]};
SR[2] = {n:"Rushu",d:"Rushu is een demon, die ervan droomt om hetzelfde te worden als de goden. Hij is erin geslaagd om indruk te maken op Djaul, zijn leenplichtige, zoals de beschermer van de maand Descendre. Hij is jaloers op de Sacrier-godin en beschuldigt haar ervan dat ze de plaats inneemt die hem eigenlijk toekomt.",l:"en",p:"2",t:0,c:"2",date:"1125525600000",rlng:[]};
SR[3] = {n:"Djaul",d:"Djaul is een demon, die trouw is aan Rushu. Hij is ook en vooral de beschermer van de maand Descendre. Hij heeft zo\'n aanhoudende haat tegen de andere beschermers, dat hij een van hen gedood heeft en niet de minste: de betreurde Solar, vroegere beschermer van Javian.",l:"fr",p:"4",t:0,c:"0",date:"1132527600000",rlng:[]};
SR[4] = {n:"Raval",d:"Raval, de verschrikkelijke, is de beschermer van de maand Septanger. Niemand weet of hij dat echt wil. Raval hielp de Brakmariërs om de duistere stad van Brakmar te bouwen. Echter, tijdens de slag om het Rode Ochtendgloren, gaf hij hen de genadeslag. De Gladjanussen dragen een mysterieuze cultus aan hem op.",l:"fr",p:"4",t:0,c:"0",date:"1140562800000",rlng:[]};
SR[5] = {n:"Hecate",d:"Hecate is de beschermster van de maand Jullier. Zij is een demon, die alleen naar zichzelf luistert. Zij redde Ulgrude, de beschermer van Martalo, nadat hij met Djaul in gevecht was geraakt. Zij is stiekem stapelverliefd op Ulgrude.",l:"fr",p:"4",t:0,c:"0",date:"1145916000000",rlng:[]};
SR[6] = {n:"Sumens",d:"Sumens is een vurige aanhanger van de god Enutrof. Hij is ook de beschermer van de maand Junissidor. Als hij verteert, gebeuren er vaak vreemde dingen. Want alles wat hij eet, komt de een of andere dag weer naar buiten in de vorm van waardevolle stenen.",l:"fr",p:"4",t:0,c:"0",date:"1149717600000",rlng:[]};
SR[7] = {n:"Menalt",d:"Menalt was een machtige centaurkrijger en de commandeur van de orde van het Moedige Hart. Hij was ook de beschermer van de maand Martalo. Ondanks zijn heldhaftigheid, is hij bezweken onder de aanvallen van de Brakmariërs tijdens de veldslag van het Rode Ochtendgloren.",l:"fr",p:"4",t:0,c:"0",date:"1156802400000",rlng:[]};
SR[8] = {n:"Rosal",d:"Rosal is de meester van de bloemen en de beschermer van de maand Meisial. Vertrouw niet zijn zachte uiterlijk. Als telepaat weet hij de geest van de doden te doorgronden: intieme geheimen en leugens onthullen is kinderspel voor hem. En hij heeft geen enkel mededogen voor degene die niet een zuivere ziel heeft.",l:"en",p:"1",t:0,c:"2",date:"1159221600000",rlng:[]};
SR[9] = {n:"Maimane",d:"Maimane, de stabilisator, is de beschermer van de maand Oktolliard. Afgeschrikt door de voortdurende veldslagen die de Wereld beheersten, besloot hij om de emoties te verzegelen door ze wonderbaarlijk onder de grond te stoppen. Zowel de liefde als de haat zijn begraven, de vraag is echter voor hoe lang?.",l:"fr",p:"4",t:0,c:"0",date:"1159826400000",rlng:[]};
SR[10] = {n:"Silvosse",d:"Silvosse, meester van de stek, is de beschermer van de maand Flovor. Toen het ging om het beschermen van de vegetatie liet hij zich leiden door een vreselijke woede. Hij overmeesterde lang geleden de zielen van onbezonnen houthakkers. Door ze gevangen te zetten in de bomen, schiep hij het ras van de Boomchnids.",l:"fr",p:"4",t:0,c:"0",date:"1165273200000",rlng:[]};
SR[11] = {n:"Brumaire",d:"Brumaire, de vreselijke slachter, is de beschermer van Novamaire. Hij stond aan de kant van Djaul tijdens de nederlaag van het Rode Ochtendgloren. Hij zint op wraak en wantrouwt Djaul, die hij een incompetente lomperik vindt.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[12] = {n:"Pouchecot",d:"Pouchecot, de grote fruitige, is de beschermer van Frauguctor. Hij nam deel aan de oprichting van de stad van Bonta. Hij, verlicht van geest en groot amateur van kunst en muziek, is ook beroemd onder de goden en de stervelingen om zijn grappen, waar een Slappe Eik dubbel om ligt van het lachen.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[13] = {n:"Silouate",d:"Silouate is een Minotoror en door zijn wijsheid is hij de beschermer van Aperirel geworden. Hij houdt zich bezig met het verjagen van de voorbije winterse kou. Hij is een vriend van Sumens en men zegt ook dat Silouate een van de wijzen is die de beslissing namen om de Dofus te beschermen tegen de hebzucht van de avonturiers.",l:"fr",p:"4",t:0,c:"0",date:"1171321200000",rlng:[]};
SR[14] = {n:"Domen",d:"Domen is een van de drie hoge pieten van Brakmar. Trouw aan Brumaire en totaal slecht, is hij zoals de beschermer vervuld met bitterheid over de nederlaag sinds het Rode Ochtendgloren. Hij heeft over het algemeen een dolend uiterlijk aangenomen.",l:"fr",p:"4",t:0,c:"0",date:"1175724000000",rlng:[]};
SR[15] = {n:"Amayiro",d:"Amayiro maakt deel uit van de grote raad van Bonta. Als krijgswapenmeester heeft hij het initiatief genomen om de militie op te richten voor de verdediging en veiligheid van de stad. Ondanks zijn gevorderde leeftijd is hij nu nog steeds hoofd van de militie.",l:"fr",p:"4",t:0,c:"0",date:"1179784800000",rlng:[]};
SR[16] = {n:"Rykke-Errel",d:"Rykke Errel was een jonge Iop discipel. De enige die de moed had om verschrikkelijk draak Bolgrot uit te dagen. Toen hij eenmaal overwon, besloot hij om het wezen te sparen en sloot vriendschap met hem. Rykke moest echter de draak later doden, waarna deze laatste, gek van woede en jaloezie, het leven genomen heeft van zijn meest geliefde.",l:"fr",p:"4",t:0,c:"0",date:"1182808800000",rlng:[]};
SR[17] = {n:"Hyrkul",d:"Hyrkul is een toegewijde dienaar van Djaul. Hij is ook een machtig krijger, net zo slecht en wreed als de demon die hij dient. Hij is onsterfelijk verklaard door Rushu als dank voor de verleende diensten aan de demonheer.",l:"fr",p:"4",t:0,c:"0",date:"1183413600000",rlng:[]};
SR[18] = {n:"Helsephine",d:"Helsephine was een tovenaar wiens schoonheid alleen gelijk stond aan haar vriendelijkheid. Ze stal de harten van de beroemde held Rykke Errel en zijn draakvriend Bolgrot. In plaats van de jonge vrouw haar hart te ontvlammen, werd Bolgrot gek van jaloezie en zette haar in brand... Rykke Errel doodde de draak om zijn geliefde te wreken.",l:"fr",p:"4",t:0,c:"0",date:"1192485600000",rlng:[]};
SR[19] = {n:"Allister",d:"Koning Allister is de erg geliefde heerser van Amakna. Deze Feca kwam van een bescheiden achtergrond als een herder maar stapte toen in het voetlicht toen hij de demon As\' Ruoy\' Dnim gevangen nam. Het was toen dat hij de eerste guild startte in de geschiedenis van de Wereld van Twaalf. Nadat hij zich zolang had opgesloten in zijn kateel, probeerdt zich Allister beetje bij beetje in de zaken van het koninkrijk te verdiepen.",l:"fr",p:"4",t:0,c:"0",date:"1196722800000",rlng:[]};
SR[20] = {n:"Otomai",d:"Otomai is een machtige alchemist die verantwoordelijk is voor het befaamde anti-myxomawosis drankje. Deze tovenaar specialiseert in de studie van levende schepsels en hij was degene die achter de ontdekking van het eiland zit, welke tot vandaag de dag zijn naam draagt. Het was op deze plaats dat hij alle schepsels probeerde te verenigen in de Wereld van Twaalf voor zijn mysterieuze experimenten...",l:"fr",p:"4",t:0,c:"0",date:"1201215600000",rlng:[]};
SR[21] = {n:"Lily",d:"Lily een bekende reiziger, ging de wereld rond in 80 dagen. Toen leerde en begon ze te houden van Wabbits ... voornamelijk wanneer zij op kebabs zijn! Ze gaat vaak naar hun eiland om te genieten van een kleine “gastronomische reis” en soms neemt ze zelf haar avonturiers met zich mee voor enkele Kamas... Niet alleen heeft Lily een goed richtingsgevoel, maar ze is ook goed in zaken doen!",l:"fr",p:"2",t:0,c:"0",date:"1203030000000",rlng:[]};
SR[22] = {n:"Oto Mustam",d:"Oto Mustam is de baas van de Brakmariaanse militie. Impulsief, gewelddadig en gemeen, hij is loyaal aan Djaul en veracht het menselijk ras. Zijn loyaliteit aan de demonen is bekend geraakt bij Rushu, hun leider, die hem een missie heeft gegeven: voor een agressievere en chaotische Wereld van Twaalf te zorgen. Oto zal dan helden moeten selecteren die zich bij het Grootste Duistere Leger zullen voegen, die de wereld zullen binnenvallen en de goden verslaan, als de tijd rijp is.",l:"en",p:"0",t:1,c:"2",date:"1222120800000",rlng:[]};
SR[23] = {n:"Hel Munster",d:"Door zijn gelijken gezien als de beste tovenaar in heel Amakna, Hel Munster leert Smidsmagie aan avonturiers, met de voorwaarde dat zij het leren van de kunst verdienen. Hij is ook de auteur van het populaire handboek \"Magische Voorwerpen Creëren voor Dombo\'s\" waar hij zijn theorie  ontketend over het ontstaan van the Quadramental Breeze, samen met andere hete lucht.",l:"fr",p:"2",t:0,c:"0",date:"1205794800000",rlng:[]};
SR[24] = {n:"Danathor",d:"Jiva zelf koos Denathor om beheerder in Bonta\'s militia te zijn. Hij is loyaal aan de beschermer van Javian en zal voor niets stoppen om de stad van Brakmar te verpulveren en een plaats te maken voor zichzelf in de hiërarchie van de Wereld van Twaalf. Danthor is de gezworen vijand van Amayiro.",l:"fr",p:"2",t:0,c:"0",date:"1208469600000",rlng:[]};
SR[25] = {n:"Kuri",d:"Kuri is een van de drie alom bekende hoog-priesters van de liefde. Zij waren verantwoordelijk voor de emotionele epidemie die de Jellies van Amakna raakte, vele jaren geleden. Ze is Granny Candy\'s rechterhand en je zult haar herkennen door de legendarische boog en het belachelijke hoofddeksel die zij draagt.",l:"fr",p:"1",t:0,c:"0",date:"1211839200000",rlng:[]};
SR[26] = {n:"Mily",d:"Voor ze een Liefdes Priester werd was Mily een gewone Exaflipette. Ze stond op het punt geselecteerd te worden voor het DOFUS Idol programma. Tot dat Granny Candy Mily zag en haar bewaker van de Toren van de Moeilijke Liefde maakte.",l:"fr",p:"1",t:0,c:"0",date:"1223330400000",rlng:[]};
SR[27] = {n:"Goultard",d:"Goultard mag er dan wel als een Iop uitzien, maar nee... hij is ver van menselijk. Het hart van de krijger was ooit zo groot als zijn spieren maar op een duistere nacht viel zijn leven uiteen en sindsdien doet hij niets anders dan chaos en vernietiging zaaien. Goultard is zonder twijfel de meest krachtige strijder in de Wereld van Twaalf.",l:"fr",p:"0",t:0,c:"0",date:"1227135600000",rlng:[]};
SR[28] = {n:"Ruliet",d:"Ruliet\'s schoonheid is alom bekend in het land. She heerst over haar liefdes met een zachte hand en een ijzeren klauw en laat iedereen achter met pijn in hun nek. Dodge de Ecaflip is een van haar welbekende veroveringen, maar hun liefde verdween toen Dodge, in een vlaag van woede, Ruliet in veel stukken hakte omdat ze zijn hart gebroken zou hebben. In een ander onafhankelijke gebeurtenis, gebeurde er met hem hetzelfde door Vlad.",l:"fr",p:"0",t:0,c:"0",date:"1230505200000",rlng:[]};
SR[29] = {n:"Vil Smisse",d:"Vil Smisse\'s leven is lang geweest, en hij heeft het niet weggegooid! Sinds zijn jeugd als een jong rovertje, is de Baas van de Gladjanus Clan gegroeid tot een mysterieus symbool van het kwaad.",l:"fr",p:"1",t:0,c:"0",date:"1234479600000",rlng:[]};
SR[30] = {n:"Many",d:"Many is Djaul\'s meest nuttige Xelor, en het is niet moeilijk om in te zien waarom - hij kan zelfs de meest onwillende en geharde spionnen hem hun diepste geheimen laten vertellen. Talloze onschuldige personen hebben de meest afschuwelijke misdaden toegegeven onder invloed van de hand van Many en alhoewel hij hard werkt, geniet deze tijdvolgeling van elk moment.",l:"fr",p:"0",t:0,c:"0",date:"1236898800000",rlng:[]};
SR[31] = {n:"Solar",d:"Solar was een legendarische Iop strijder en de eerste beschermer van de maand van Javian. Zijn ongelofelijke krachten stegen en vielen met de zon. Van \'s ochtends tot midden op de dag, steeg het gestaag om zijn volledige kracht aan te nemen. Na de middag, gebeurde het omgekeerde totdat de Iop slap was rond middernacht. Solot was verslagen door Djaul op 31 december, 11 en vervangen door Jiva op 12 Flovor, 12.",l:"en",p:"0",t:0,c:"2",date:"1214258400000",rlng:[]};
SR[32] = {n:"Crocoburio",d:"Zoon van Crocabulia en Grougalorasalar, Crocoburio werd de krijgsheer van het Crocodyl ras. Als een uitstekende vechter, onderscheidde hij zich in vele veldslagen, totdat hij uiteindelijk zijn leven verloor in een gevecht tegen Bonta toen hij werd gedood door de stad bewakers. Alles wat er nog van hem is is Crocobur, zijn legendarische zwaard.",l:"fr",p:"0",t:0,c:"0",date:"1259017200000",rlng:[]};
SR[33] = {n:"Li Crounch",d:"Een leerling van sadida en schilder van beroep, heeft Li Crounch zijn leven in harmonie te brengen met de voorschriften van zijn God met de meest onverbiddelijke strengheid: meditatie en liefde voor de natuur. De jonge kunstenaar wijdt zich aan slapen voor ten minste 20 uur per dag en verft bloemen de rest van de tijd, hoewel weinig mensen dat geloven. Hij blijft nog steeds een rolmodel voor vele Sadidas.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[35] = {n:"Farle",d:"Farle Ingalsse, de bekende landbouwer, is vooral bekend voor zijn geduld en zijn liefde voor het land. Hij heeft zijn zorgvuldig gecultiveerde velden in het hart van het platteland van Amakna sinds onheuglijke tijden, ook al hebben hordes avonturiers getrapt op zijn percelen graan. Farle is ook bewonderd voor de kunst van het verleiden en het lessen van de dorst van een andere mooie bloem voor avontuur: de beroemde avonturier Shika Ingalsse.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[36] = {n:"Agride",d:"Waar andere Amakneanse houthakkers zoals Brouce Boulgoure bladzijden in de geschiedenis boeken zijn geworden door hun daden, bleven anderen meer bescheiden en anoniem, zoals in het geval van Agride. Gelukkig zijn noch waarde noch verdienste gerelateerd aan roem. Geen gebrek aan beide, streeft Agride ernaar om de fijne kneepjes van de kunst van houthakken over te brengen aan wie hem vraagt om hulp.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[37] = {n:"Bowisse",d:"Bowisse is een getalenteerde en gerespecteerde schoenmaker, en het is hem die we moeten bedanken voor de mooiste en meest originele gordels en paar laarzen in de wereld van 12. Hij is vooral beroemd om zijn unieke vermogen om kleding die perfect is afgestemd op de persoon die zijn ontwerp bestelde. Veel avonturiers zijn tegen hun achterste geschopt door hem, maar geen van hen heeft ooit geklaagd!",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[38] = {n:"Ogivol",d:"",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[39] = {n:"Lethaline",d:"",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[40] = {n:"Aermyne",d:"Aermyne had lang genoten van een gloeiende reputatie onder de moeders van Amakna. Verwisselen van luiers, het wassen van kleren, en het geven van baby\'s flesjes was wat ze het beste deed, en ze deed het beter dan wie dan ook. Alleen, op een dag, een stem sprak opeens in haar hoofd, en alles was veranderd. De was en de baby flessen waren verleden tijd, en Aermyne joeg de kleine mormels uit haar huis met clouts rond de oren. Niemand begreep waarom ze dit deed en zo werd Aermyne verbannen naar Pandala.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[41] = {n:"Zatoïshwan",d:"Zatoïshwan was een verstokte gokker, wat ongebruikelijk was voor een Pandawa, en wat meer is, hij was blind. Zijn reputatie was zo groot dat zelfs de grootste ecaflip gokkers hem vreesden. Getroffen door de bliksem op een dag, kwam hij als verlicht door de godin Pandawa terug en had binnen enkele weken de oude kunst onder de knie van Pandawushu. Hij deelde streng recht uit aan de deugnieten van zijn tijd, voordat hij toegaf aan zijn donkere kant en de veel gevraagde bandiet werd waar iedereen over heeft gehoord, maar die maar weinigen hebben gezien.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
