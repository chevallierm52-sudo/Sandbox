SR[905] = {n:"Beta Dofus 2.0 JA",d:"",l:"ja",p:"0",t:0,c:"10",date:"1255039200000",rlng:[]};
SR[1001] = {n:"Shika",d:"Shika, de mooie vrouw van de beroemde Farle Ingalsse, en nog altijd vriendin van de koning Allister, is beroemd om haar verovering van Po\'Deog\'Sap, een vreselijke en valse demon. Men zegt het haar ongelofelijk hard, maar ze heeft niet meer nodig dan haar kleine knuistjes om de wezens uit de weg te ruimen die haar rust zouden durven te verstoren.",l:"en",p:"0",t:0,c:"1",date:"1175724000000",rlng:["en"]};
SR[3001] = {n:"Nehra",d:"Nehra is een machtige tovenares, die heel lang geleden het eerste dorp van de inwoners van Amakna gered heeft van de ondergang. Maar het gebeurt hedentendage nog, dat ze plotseling verschijnt om avonturiers in nood te redden. Zoals ze nooit praat en altijd meteen erna verschijnt, weten zelfs de wijzen niet veel over haar. Maar dat doet niet af aan het feit dat talloze avonturiers haar verafgoden als hun beschermheilige.",l:"de",p:"0",t:0,c:"3",date:"1184104800000",rlng:["de"]};
SR[3002] = {n:"Katar",d:"Katar was een uitzonderlijke Sacrier krijger. Sterk als een Boowolf, behendig als Moon, zijn reputatie als een uitzonderlijke krijger ging hem vooraf, en bereikte uiteindelijk de oren van een demon ... een verzamelaar van uitzonderlijke krijgers. De demon kreeg grip op van de Sacrier\'s dapperheid . Katar was bezeten, zijn lichaam en ziel. Sinds die dag heeft Katar het land afgelopen op zoek naar een krijger die hem kon verslaan en hem kon bevrijden van zijn vloek.",l:"de",p:"0",t:0,c:"3",date:"1259103600000",rlng:[]};
SR[4001] = {n:"Alma",d:"Alma is de beschermster van doorgewinterde ontdekkingsreizigers. Volgens een legende zou zij een Nieuwe Wereld hebben gevonden en zou ze later een nautische kaart hebben gezonden om er heen te gaan. Er gaat ook een gerucht dat degenen die het avontuur wagen naar de zee en niet meer van hun reis terugkomen, van toen af aan in een Betere Wereld leven... Anderen beweren haar gezien te hebben toen ze verdwaald waren in minder gastvrije plaatsen en dat dankzij haar zij erin geslaagd zijn hun weg terug te vinden...",l:"es",p:"4",t:0,c:"4",date:"1184104800000",rlng:["es"]};
SR[4002] = {n:"Aguabrial",d:"Agubrial de draak heeft de opdracht één van de vier elementen te beschermen. Hij bescherm Water. Hij was degene die de eerste Turkooise Dofus creëerde toen de wereld nog jong was. Lang geleden is Aguabrial bedrogen door Djual en sinds die dag, is hij op zoek naar wraak op de demon. Normaal gesproken is hij rustig en zachtaardig, Aguabrial kan ook terreur op zijn vijanden brengen. Tenslotte, vertelt het oude spreekwoord niet dat stil water het meest gevaarlijkst is?",l:"es",p:"2",t:0,c:"4",date:"1195772400000",rlng:["es"]};
SR[4003] = {n:"Buhorado",d:"Buhorado is de beroemde Meester die verdween bij het handelshuis waar alle uilen van de Wereld van Twaalf bijeenkomen: professoren, boekhouders ... degenen die de de geschiedenis en de bankrekeningen van Amakna in de gaten houden!!! Aldo Rada was de wijste van hen allemaal totdat hij de weg kwijt raakte bij het spelen van \"Godfather Fortunes\". De legende beweerd dat zijn geest vele eeuwen later weer verscheen... Maar Allister\'s volgelingen ontkennen zulke legendes en zien Buhorado als één van de laatste Peetvaders van de \"Mafian tijden\" en daarom een potentiële afwijzing van de Konings autoriteit.",l:"es",p:"2",t:0,c:"4",date:"1212357600000",rlng:["es"]};
SR[4004] = {n:"Darkness",d:"Darkness is berucht om de massamoorden die hij veroorzaakt heeft en om het legendarische wapen dat hem hierbij geholpen heeft. Dit wapen heeft de naam \"Tormentor\". Het wapen is gemaakt door zijn adoptie vader, Hissering de Klusjesman. Wanneer Darkness en Tormentor samenkomen worden ze de Dark Knight en hebben ze onvoorstelbaar veel kracht.",l:"es",p:"1",t:0,c:"4",date:"1224108000000",rlng:["es"]};
SR[4005] = {n:"Bolgrot",d:"Bolgrot is een mysterieuze draak van wie zijn lot de Wereld van Twaalf veranderde. Verwekt door Aguabrial, verstopte Bolgrot zich in de eerste jaren van zijn bestaan, tot de dag dat hij Rykke Errel ontmoette, bij de poort van Amakna. Rykke kwam om Bolgrot uit te dagen, maar in plaats van te vechten, werden ze beste vrienden. Hun vriendschap eindigde echter toen Bolgrot, gevuld met woede, Helsephine, Rykke\'s geliefde, vermoordde. Een spectaculair duel begon, tot ze beiden stierven. De wijze mannen van Amakna vonden tussen de overblijfselen van Bolgrot, 6 eieren in vreemde kleuren. Dat is hoe de legende van de Dofus is geboren.",l:"es",p:"0",t:0,c:"4",date:"1238709600000",rlng:[]};
SR[4006] = {n:"Nomekop",d:"Nomekop Wodly heeft slechts twee vrienden, Eratz de protesteerder en Edasse de Killjoy. Hij heeft meer vijanden dan er Blops zijn op de Cania Plains. Waar Nomekop wandelt, vallen zijn vijanden neer, en groeit het gras niet terug.",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4007] = {n:"Edasse",d:"Ondanks de bijnaam \"The Killjoy\", is Edasse nog steeds graag van de partij - je hoort hem vaak zeggen: \"Kom hier, ik heb een cadeautje voor je!\". Wat maakt hem zo gelukkig? Geruchten suggereren hij in het bezit is van een Dofus, of indien hij niet, dan is het een van zijn vrienden, Nomekop of Eratz. Ik denk dat met hem zult moeten gaan praten als je de waarheid wilt weten van ...",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4008] = {n:"Eratz",d:"Eratz is een van de drie legendarische Cania bandieten, en je weet dat als je hem ziet, de anderen niet ver weg zijn. De laatste persoon die hem gezien heeft is niet meer hier om het verhaal te vertellen, echter. De zware inname van adem die je maakt bij het zien van Eratz de Demonstrant zal waarschijnlijk je laatste zijn ...",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[6001] = {n:"Spiritia",d:"De glinsterende regenboog draak symboliseert de goddelijke geest zijn afdaling naar vaste vorm en vertoond alle schepsels van de wereld. Het vertegenwoordigt ook de Quadramental Breeze, als Hel Munster – een alchemiemeester vermeldde in zijn boeken.",l:"pt",p:"0",t:0,c:"6",date:"1206572400000",rlng:["en","pt"]};
SR[6002] = {n:"Helioboros",d:"Helioboros is een van drie draken die aanbeden wordt door Osamodas\' volgelingen. Volgens hun legendes, bracht deze Grote Witte Draaak het licht in de wereld toen hij voor het eerste gemaakt werd. Srams, denken echter dat het Ouronigride de Grote Zwarte Draak was, die in Helioboros\' staart beet en dat de twee draken de wereld per ongelukt gemaakt hebben toen ze in gevecht waren... Welke versie de waarheid is? Welke je maar wilt geloven! Voor een paar Kamas, zal Magier Ax je allerlei soorten lange verhalen zoals dat vertellen...",l:"pt",p:"0",t:0,c:"6",date:"1253484000000",rlng:["en","pt"]};
SR[7001] = {n:"Dark Vlad",d:"Dark Vlad is de meest beruchte Iop in heel Amakna, Bonta en Brakmar... Hij is nog steeds de enige Iop die ooit bovenop een Vliegende Karne is geklommen en maar weinig wapens in de Wereld van Twaalf hebben zoveel stervelingen verslagen als zijn vlammende zwaard. Het is ook geen verrassing dat hij een plaats als het Duivelse Bos zijn thuis noemt.\nDaar wacht hij tot er weer een onnozele avonturier in zijn duistere schuilplaats komt.",l:"nl",p:"0",t:0,c:"7",date:"1219788000000",rlng:["nl"]};
SR[9001] = {n:"Ereziah\r\n",d:"Ereziah is een oude alchemist en getalenteerde exorcist die ook wel bekend staat voor zijn vriendschap met Aguabrial, de waterdraak. Hij is over de hele wereld bekend voor zijn magische vaardigheden en zijn scherpzinnigheid. Hij redde zijn draak vriend Aguabrial van Djaul de demon. Maar weinig alchemisten kunnen trots zijn op zichzelf om Dujaul\'s plannen verhinderd te hebben.\n\nDe legende zegt dat een sterveling de machtige draak heeft bevrijd van de spreuk van de demon, Djaul de Spetterende Jongen. De gebeurtenis leidde tot het uitkomen van de Dofus en de geboorte van Bolgrot de draak.",l:"it",p:"0",t:0,c:"9",date:"1212357600000",rlng:["it"]};
