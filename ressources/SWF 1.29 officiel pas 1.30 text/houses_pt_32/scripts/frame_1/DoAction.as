H.h[66] = {n:"Cabana coberta de palha",d:"Esta cabana coberta de palha é localizada próxima do rio. É perfeita para pescadores amadores. Possui um piso superior, mas você terá de usar uma escada de mão, já que as escadas não estão incluídas no projeto original deste tipo de casa."};
H.h[67] = {n:"Cabana coberta de palha",d:"Esta cabana coberta de palha é localizada próxima do rio. É perfeita para pescadores amadores. Possui um piso superior, porém as escadas não estão incluídas na compra. Você terá de usar uma escada de mão gentilmente oferecida."};
H.h[68] = {n:"Casebre",d:"Esta pequena casa possui um piso superior, mas tem apenas um andar habitável, já que o sótão foi tomado por uma família de ratos."};
H.h[69] = {n:"Casa de três andares",d:"Quem gosta de organizar festas grandes vai amar esta casa de três andares. Quem não aprecia subir escadas não gostará tanto assim."};
H.h[70] = {n:"Casa com um andar",d:"Esta casa é próxima ao rio e ao vilarejo, o que compensa o fato de ela ser a única casa na região, e ter apenas o piso superior. Atenção! Durante as cheias, o rio alaga todo o térreo e você se sentirá em um barco.."};
H.h[74] = {n:"Casa perto da Loja",d:"Esta pequena casa com um piso superior está localizada próxima de Seline e à loja de Charlotte, poucos passos do centro da vila. Casais que querem manter sua intimidade vão adorar esta casa."};
H.h[75] = {n:"Cabana coberta de palha da Fonte",d:"Localizada na praça da fonte, esta casa é ideal para quem gosta de exibir suas riquezas para as pessoas."};
H.h[76] = {n:"Prédio da Fonte",d:"Esta mansão com três andares costumava pertencer a um ricaço notório que desapareceu em circunstâncias estranhas. Adquira por seu próprio risco!"};
H.h[77] = {n:"Prédio perto da Taverna",d:"Este prédio é muito apreciado por bebedores de energético que frequentemente não encontram o caminho de volta para casa após ficarem por muito tempo na Taverna. Afinal, o prédio é muito próximo da Taverna."};
H.h[78] = {n:"Casarão",d:"Esta casa com um piso superior e três cômodos é obviamente criada para as pessoas mais ricas de Amakna. É grande o bastante para acomodar várias famílias diferentes, desde que aceitem viver em comunidade. Como as formigas."};
H.h[79] = {n:"Prédio da Padaria",d:"Este prédio tem um piso superior e costumava ser uma padaria onde um famoso padeiro vendia seus pães. Hoje, este prédio foi restaurado e é confortável, como qualquer outra casa."};
H.h[80] = {n:"Cabana coberta de palha da Padaria",d:"Esta pequena casa costumava pertencer a um famoso padeiro cujo nome não foi revelado. De qualquer forma, é perfeita para qualquer padeiro."};
H.h[81] = {n:"Casa perto do Templo Xelor",d:"Esta pequena casa de um cômodo tem a vantagem de estar localizada próxima do Templo Xelor e da padaria."};
H.h[82] = {n:"Cabana coberta de palha perto do Templo Xelor",d:"Esta pequena casa localizada exatamente em frente do Templo Xelor obviamente é perfeita para Xelors."};
H.h[83] = {n:"Cabana coberta de palha de Alfaiate",d:"Esta pequena casa possui um piso superior e costumava pertencer ao mais popular alfaiate de Amakna, Elvis Trosse. Ele era especializado em fazer calças azuis."};
H.h[84] = {n:"Casinha de Bowisse",d:"Bowisse, o sapateiro, construiu esta maravilhosa pequena casa com suas próprias mãos, fazendo dela um dos prédios mais populares de Amakna. É provavelmente um dos locais mais visitados após a padaria de Xavier."};
H.h[85] = {n:"Choupana coberta de palha de Gobballs",d:"Esta charmosa choupana freqüentemente é rodeada pelos incômodos Gobballs. Porém, ela possui dois andares e  é localizada próxima ao Templo Kanojedo. Esses dois fatores a tornam de grande interesse para aventureiros iniciantes."};
H.h[87] = {n:"Cabana coberta de palha perto da loja Cra",d:"Esta pequena casa costumava ser de Edridge Valling antes dela decidir abandoná-la e ir morar no sótão de sua loja. As paredes ainda estão cobertas com o impacto das flechas, mas elas dão um charme todo especial à casa."};
H.h[88] = {n:"Casa perto da Loja Cra",d:"Esta pequena casa de um cômodo é muito cara devido à sua proximidade com a loja de Edridge Valling. Assim, muitos dos pretendentes de Edridge compram o lugar para ficar mais perto dela."};
H.h[89] = {n:"Chalé da Fundição",d:"Este chalé de madeira, por estar próximo à fundição, é perfeito para amadores que trabalham com metal derretido. Mas tenha cuidado para não incendiar sua casa por engano!"};
H.h[90] = {n:"Cabana de Marinheiro",d:"Esta cabana de um cômodo é muito bem localizada. É protegida de ventos fortes e recebe os raios de sol ao amanhecer. Sentir os raios de sol em sua pele de manhã não tem preço!"};
H.h[91] = {n:"Cabine de Pescador",d:"Esta cabine de um cômodo é descrita como um prédio histórico. Foi onde o menestrel e Ferreiro de Machados, Jony Lenon, escreveu muitas de suas músicas."};
H.h[92] = {n:"Residência de Pescador",d:"Esta residência de um cômodo não tem nada de especial, exceto que foi o lugar onde o famoso Bowisse passou sua infância."};
H.h[93] = {n:"Casa Pequena de Pescador",d:"Esta pequena casa de pescador de um cômodo precisa de uma pintura nova na fachada, embora isso dê um charme especial."};
H.h[94] = {n:"Cabana de Pescador",d:"Esta pequena casa de pescador com um piso superior costumava ser um armazém de caranguejos."};
H.h[95] = {n:"Prédio de Casco de Barco",d:"Este velho prédio tem um piso superior. O Capitão Iglout costumava viver lá antes de arrumar uma acomodação na prisão."};
H.h[96] = {n:"Cabana Pequena próxima do Porto",d:"Esta pequena cabana de um cômodo fica próxima do mar. Você pode ouvir a ressaca das águas durante o dia todo. Divirta-se!"};
H.h[97] = {n:"Casarão do Porto",d:"Esta casa grande com três cômodos tem um casco de barco no telhado. Sua localização próximo à água permite você jogue seu lixo no mar sem ter de se preocupar com o dia de coleta. Não que você vá fazer isso. Ou vai?"};
H.h[109] = {n:"Casa da Estrada de Ferro",d:"Esta pequena casa de um cômodo costumava pertencer a um velho chefe da estação, Hamm Trakk, que se mudou quando a estrada de ferro foi abandonada."};
H.h[110] = {n:"Casebre perto da Estrada de Ferro",d:"Esta pequena casa de um cômodo costumava pertencer a um velho minerador que ia trabalhar em seu mini-vagão de minério."};
H.h[111] = {n:"Prédio de Gobballs",d:"Esta casa com um piso superior é bem prática. Seu proprietário anterior costumava alimentar os Gobballs que passavam pela casa. Após alguns meses, os Gobballs estavam gordos o suficiente para virarem comida. Que sorte, não?"};
H.h[112] = {n:"Casa Pequena de Gobballs",d:"Esta pequena casa de um cômodo é muito desejada. A presença de muitos Gobballs selvagens nas redondezas faz dela muito interessante para os que amam Gobballs."};
H.h[113] = {n:"Casa de Cogumelos",d:"Esta casa pequena de um cômodo costumava pertencer a um velho alquimista que usava vários cogumelos para fazer suas poções, cujos efeitos frequentemente são desconhecidos. Tenha cuidado! Os cogumelos que crescem ao redor podem ser perigosos e bem agressivos."};
H.h[114] = {n:"Casebre perto da praça principal",d:"Esta pequena casa de marinheiro está localizada em uma área turística, o que pode ser um problema para quem busca tranqüilidade. Porém, para quem não tem muitos amigos, pode ser perfeita."};
H.h[115] = {n:"Casebre perto da praça principal",d:"Esta pequena casa de marinheiro de um cômodo provará ser perfeita para pessoas não materialistas, que não procuram conforto quando compram uma casa e que se satisfazem facilmente."};
H.h[116] = {n:"Casebre perto da Praça",d:"Esta casa de marinheiro de um cômodo diz aumentar a fertilidade de casais que vivem nela. As pessoas acreditam que a cama de solteiro e a escassez do espaço contribuem como parte importante desta história."};
H.h[117] = {n:"Casebre perto da praça principal",d:"Esta pequena casa de pescador é bem localizada, próxima à fonte do porto. É uma pena possuir apenas um cômodo. Porém, também faz dela bem acessível para uma casa deste tipo."};
H.h[118] = {n:"Carasão perto do Porto",d:"Esta casa com um casco de barco no telhado está localizada nos arredores do porto, bem de frente à fonte, fazendo dela um local interessante para comerciantes. Afinal, eles não terão de ir longe para vender seus itens no leilão do porto."};
H.h[119] = {n:"Casarão do Porto",d:"Esta casa com um piso superior tem um casco de barco no telhado oferecendo uma visão maravilhosa no farol. Certamente agradarão aos românticos de Amakna que fazem desenhos nas sombras com a luz do farol... E Deus sabe que eles são muitos!"};
H.h[120] = {n:"Casebre do Porto",d:"Esta é uma pequena casa de um cômodo e, como fica em um local adorável, muitos turistas querem comprá-la. A vista do mar que se tem nos banheiros é a melhor explicação para a fascinação por esta casa."};
H.h[122] = {n:"Casa do Guarda de Kanojedo",d:"Esta casa tem apenas um único cômodo habitável desde que o sótão foi invadido por cupins. Localizada perto do Templo Kanojedo, é normalmente alugada para o guarda do templo."};
H.h[123] = {n:"Casebre perto da Ponte",d:"Esta é uma casa de um cômodo é localizada na ilha, longe de qualquer tipo de civilização, próxima de uma ponte e uma fundição. Nenhum dos custos são incluídos no aluguel."};
H.h[124] = {n:"Casa de Jardineiro",d:"Esta pequena casa de um cômodo tem um belo jardim de vegetais e é perto do mar. É uma casa ideal para qualquer fazendeiro com pouco dinheiro que goste de locais quietos para seus feriados."};
H.h[125] = {n:"Cabana perto do Lago",d:"Esta cabana coberta de palha possui um piso superior e um pequeno anexo externo (vendido separadamente), permitindo que você acomode guardas ou serviçais."};
H.h[126] = {n:"Casebre perto do Lago",d:"Esta casa de um cômodo é próxima do lago e da praia. É um deleite para pescadores amadores que gostem de pescar tanto em água doce quanto em água salgada."};
H.h[127] = {n:"Casa Pequena perto do Lago",d:"Esta casa de um cômodo de aparência modesta é bem espaçosa e organizada. Pescadores amadores de pesca em água doce adorarão esta casa, pois fica próxima do lago."};
H.h[128] = {n:"Cabana coberta de palha com propriedade",d:"Esta pequena casa tem dois cômodos enormes, grandes o bastante para organizar jogos de Tragic The Gardening. O dono é responsável por cuidar das árvores na propriedade."};
H.h[129] = {n:"Casa do MAX-LoL",d:"Esta pequena casa possui um piso superior e está situada em uma pequena ilha. Assim fica fácil protegê-la de ataques dos ladinos, por exemplo."};
H.h[130] = {n:"Casa de Casco de Barco",d:"Esta casa, com um piso superior, tem um casco de barco no telhado que sempre acaba sendo útil quando os rios transbordam."};
H.h[131] = {n:"Casebre de Marinheiro",d:"Esta pequena casa possui um piso superior e está próxima do porto, além de também estar próxima do trecho enlameado do mar. É sedutora para criadores de caranguejo que não se importam de ter vizinhos."};
H.h[132] = {n:"Casebre de Pescador",d:"Esta pequena casa de pescador tem apenas um cômodo, e conforme o tempo passou, o mar se afastou dela. Isso a tornou menos interessante. De qualquer forma, pessoas mais pobres saberão apreciá-la."};
H.h[133] = {n:"Casa de Casco de Barco",d:"Esta casa é extremamente original. Tem um velho casco de barco como telhado. Desta forma, o proprietário não terá de subir e trocar as telhas após cada tempestade. Ela possui dois andares bem organizados."};
H.h[134] = {n:"Casa Pequena do Rio",d:"Esta pequena casa de um cômodo é geralmente alugada para solteirões ou casais não muito grandes."};
H.h[135] = {n:"Casebre de Pescador",d:"Esta casa de pescador de um cômodo é bem cobiçada por pescadores amadores que podem pescar sem sair de casa."};
H.h[136] = {n:"Casa de Gobballs",d:"Esta casa tem um grande térreo onde você pode dar uma festa animada. A carroça de feno vem de brinde com a casa. Aviso! O dono anterior costumava alimentar os Gobballs e, por isso, eles ainda voltam de tempos em tempos."};
H.h[137] = {n:"Casa coberta de palha perto da cerejeira",d:"Esta casa possui um piso superior e escadas maravilhosas feitas de carvalho. O telhado de palha, junto com a cerejeira que cresce de frente à porta, dá a esta casa um estilo muito rústico. Pessoas que gostam de se diferenciar das outras irão adorá-la."};
H.h[138] = {n:"Casebre perto da Cerejeira",d:"Esta é uma casa com um cômodo grande e uma maravilhosa cerejeira que garante sombra sobre os felizes proprietários durante o verão."};
H.h[139] = {n:"Casa da Serraria",d:"Esta pequena casa tem um piso superior. Localizada próxima da Serralheria. É perfeita para o seu proprietário."};
H.h[140] = {n:"Cabana coberta de palha da Serraria",d:"Esta pequena casa com um piso superior está localizada próxima da serraria, ótima para lenhadores que odeiam perder tempo para se deslocar até o trabalho."};
H.h[141] = {n:"Casa de Aria Knofob",d:"Casa de NPC."};
H.h[142] = {n:"Casa da Montanha",d:"Esta casa tem um cômodo bem grande e organizado."};
H.h[143] = {n:"Casarão do Porto",d:"Esta casa grande com um piso superior tem um casco de barco no telhado. Sua localização próxima do porto faz dela uma casa ideal para viajantes. Entretanto, o porão é escuro e cheio de teias de aranha."};
H.h[144] = {n:"Casa de Sufokia",d:"Uma casa nobre, confortável e com vista para o mar. Tudo isso com um interior luxuoso. Você será atraído pelo esplendor da mobília."};
H.h[145] = {n:"Casarão de Sufokia",d:"Esta casa isolada tem uma arquitetura surpreendente, tornando-a extremamente luminosa e confortável. Há um esplêndido jardim no piso superior onde você pode relaxar com o som do oceano."};
