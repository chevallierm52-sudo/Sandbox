I.u[2803] = {n:"Cinto de Caranguejo",t:10,d:"Este estranho cinto é totalmente feito de fragmentos de garras e carapaça de caranguejo. Mesmo com uma poderosa magia, ele cheirará ruim para sempre. É melhor você se acostumar com isso.",ep:1,g:49,l:8,wd:true,fm:true,w:2,p:400};
I.u[2804] = {n:"Cinto de Boodesejo",t:10,d:"O Boolobo doou seus preciosos órgãos para a fabricação deste incrível cinto. Não confie na estranha aparência dele (que podia satisfazer o Chafer mais depravado), pois ele é muito poderoso.",ep:2,g:50,l:81,wd:true,fm:true,w:10,p:16800};
I.u[2805] = {n:"Glândulas Mágicos de Boolobo",t:15,d:"Ninguém sabe exatamente quando ou como aconteceu, mas um dia estas glândulas receberam poderes mágicos... A extensão de seus verdadeiros poderes permanece envolta em mistério.",ep:1,g:12,l:80,wd:true,fm:true,w:20,p:1000};
I.u[2806] = {n:"Glândulas Mágicos de Moolobo",t:15,d:"Tão estranho quanto possa parecer, estas glândulas têm poderes mágicos. Até que ponto eles foram realmente úteis para o Boolobo? É melhor não saber.",ep:2,g:12,l:198,wd:true,fm:true,w:10,p:2000};
I.u[2807] = {n:"Cinto Moowish",t:10,d:"Foi Bowisse, o Sapateiro, quem fez este cinto. Ele o deu para Brouce Boulgoure, quando o lenhador arrancou pela raiz o Carvalho Mole, isto tudo há muito tempo.",ep:2,g:51,l:129,wd:true,fm:true,w:20,p:50000};
I.u[2808] = {n:"Cinto Drasmuty",t:10,d:"Difícil resistir a você com este cinto. Bowisse recomenda para não se aproximar de um Dragão-Porco com este cinto, se não quiser despertar os impulsos atormentados daquela criatura.",ep:2,g:52,l:77,wd:true,fm:true,w:20,s:58,p:16000};
I.u[2809] = {n:"Cinto Chafeuse",t:10,d:"Bowisse, o Sapateiro, deu a esta grande criação um nome bastante ridículo. Ele teve a idéia de juntar os restos de seus inimigos para fazer o cinto, enquanto entrava no Calabouço dos Esqueletos.",ep:3,g:53,l:49,wd:true,fm:true,w:10,p:6500};
I.u[2810] = {n:"Cinto Picante",t:10,d:"Este magnífico cinto vermelho é uma ótima maneira de ajudá-lo a se concentrar melhor e aprender mais rápido, graças aos seus poderes mágicos. O sonho de todos os tolos de Amakna.",ep:1,g:54,l:26,wd:true,fm:true,w:6,p:2000};
I.u[2811] = {n:"Cinto de Ouginiakal",t:10,d:"Um cinto que vai agradar aos perseguidores de emoções fortes. Ele foi projetado para aproximar-se sem risco dos Ouginaks. No entanto, sua efetividade ainda não foi comprovada.",ep:14,g:55,l:65,wd:true,fm:true,w:10,p:11000};
