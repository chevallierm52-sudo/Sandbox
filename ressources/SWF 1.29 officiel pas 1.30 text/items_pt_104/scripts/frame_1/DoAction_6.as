I.u[2340] = {n:"Calção de Homem da Milícia",t:24,d:"Calção de homem da milícia. Você deve ser um verdadeiro fetichista para ter um destes... ou alguém quer caçoar de você...",ep:2,g:84,l:1,wd:true,fm:true,w:0,p:1};
I.u[2341] = {n:"Arco de Mech Riorraw",t:2,d:"Mech Riorraw desenvolveu especialmente este arco que pode cruzar rios de lava e alcançar o topo dos muros de Brakmar. Nem mais nem menos.",ep:16,g:8,l:10,wd:true,fm:true,w:100,an:10,tw:true,e:[0,6,20,21,0,30,false,true],c:"Ps=1",p:0};
I.u[2342] = {n:"Anel de Allegiance",t:24,d:"Domen lhe deu este anel. Devolvê-lo significaria que você concorda com uma destruição global. Você, então, ficará do lado dos adoradores do Djaul.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[2343] = {n:"Bracelete de Djaul",t:24,d:"Djaul lhe deu esta pulseira. Ela mostra a todos que você concorda com as palavras dele.",ep:2,g:85,l:1,wd:true,fm:true,w:0,p:1};
I.u[2344] = {n:"Carta para Oto",t:24,d:"Domen lhe deu esta carta endereçada a Oto.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2345] = {n:"Olho de Tartaruga",t:24,d:"Esta tartaruga não se exibirá mais.",ep:2,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2346] = {n:"Traje de Ladino",t:14,d:"Desculpe, isto NÃO é o traje do Dragovamp – o famoso morcego voador. Este é o traje de um morador do cemitério, um tipo de ladino...",ep:1,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[2347] = {n:"Relatório da Missão",t:24,d:"Este relatório explica como aconteceu o assalto de Brakmar pela muralha Leste.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2348] = {n:"Atitude de Ladino",t:31,d:"Você tem a Atitude de Ladino até a sua próxima luta.",ep:1,g:17,l:1,wd:true,fm:false,w:0,m:true,u:true,p:1};
I.u[2349] = {n:"Carta para Oto",t:24,d:"Domen lhe deu esta carta endereçada a Oto, mas você esqueceu de entregar a ele.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2350] = {n:"Tufo de Cabelo",t:24,d:"Este tufo de cabelo deve pertencer a um de seus inimigos.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2351] = {n:"Pão Pinchaut",t:33,d:"Você pode beber e comer ao mesmo tempo com esse pão, o brilhante é que você pode até mesmo extrair energético dele.",ep:16,g:13,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[2352] = {n:"Carta de Danathor",t:24,d:"“Preciso falar com você, venha me ver quando tiver um tempo livre. Vejo você em breve, meu jovem amigo”.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2353] = {n:"Carta de Larry Poller",t:24,d:"“Oi, sou Larry Poller, nós nos encontramos quando o Coronel Lyeno foi libertado. Preciso da sua ajuda. Venha me ver quando tiver um tempo livre. Vejo você em breve”.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2354] = {n:"Cérebro de Tartaruga",t:24,d:"Cozido com grande cuidado e amor, esse Cérebro de Tartaruga pode se tornar uma comida deliciosa.",ep:2,g:89,l:1,wd:true,fm:true,w:0,p:1};
I.u[2355] = {n:"Pó de Oni",t:24,d:"Este pó azulado é um catalisador mágico muito poderoso.",ep:2,g:88,l:1,wd:true,fm:true,w:0,p:1};
I.u[2356] = {n:"Milagre",t:31,d:"Você tem um poder milagroso até sua próxima luta.",ep:13,g:19,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2357] = {n:"Madeira de Oliviolet",t:38,d:"Esta madeira parece ser resistente ao calor. Não tente usá-la para fazer fogo, já que você morreria de frio antes de a madeira realmente pegar fogo.",ep:14,g:481,l:50,wd:true,fm:true,w:5,p:0};
I.u[2358] = {n:"Madeira de Bombu",t:38,d:"Esta madeira é a mais macia que você pode encontrar. É facilmente maleável e agradável para esculpir.",ep:13,g:482,l:50,wd:true,fm:true,w:5,p:0};
I.u[2359] = {n:"Broche de Heticili Ufot",t:24,d:"Broche que Heticili Ufot deu a você.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2360] = {n:"Título de Propriedade",t:24,d:"É o título de propriedade da casa do Heticili Ufot.",ep:2,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[2361] = {n:"Arco de Mulic Bere",t:2,d:"Este arco é uma criação do brilhante Mulic Bere. Seu alcance máximo é simplesmente incrível. O problema é que o alcance mínimo também é simplesmente incrível.",ep:16,g:10,l:10,wd:true,fm:false,w:100,an:10,tw:true,e:[0,6,17,23,0,30,false,true],p:0};
I.u[2362] = {n:"Profecia de Paro Cabanne",t:24,d:"A profecia de Paro Cabanne para as próximas eleições.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2364] = {n:"Pedra do Conhecimento",t:50,d:"Esta pedra conhece tudo e compartilha seu conhecimento de vez em quando.",ep:0,g:485,l:1,wd:true,fm:true,w:1,p:1};
I.u[2365] = {n:"Folha de Arbusto de Hestia",t:36,d:"Esta folha de arbusto de aparência simples é uma planta essencial para algumas estranhas receitas.",ep:16,g:415,l:1,wd:true,fm:true,w:1,p:1};
I.u[2366] = {n:"Vara de Pesca para Kralamor",t:20,d:"Esta Vara de Pesca feita de metal e diamantes é a única capaz de suportar o peso do kralamor. Também está impregnada com o cheiro de uma kralamor a fim de se ter uma pequena chance de atrair este monstro.",ep:1,g:8,l:1,wd:false,fm:true,w:10,an:18,e:[2,6,1,9,30,30,false,false],p:1};
I.u[2367] = {n:"O Amigo Lehunui",t:10,d:"Lehunui sabia como fazer amigos;\r\n            ele freqüentemente convidava-os para bailes de máscara. Ele gostava de fornecer comida de primeira e dar magníficas jóias para seus convidados.",ep:8,g:21,l:37,wd:true,fm:true,w:20,c:"CW>49&Ps=1",p:3700};
I.u[2368] = {n:"Ramoune, O Eterno",t:10,d:"Ramoune era um amigo de infância da radiante Nova. Quando Ramoune decidiu colocar sua mente imaculada para descansar em uma soneca eterna, também colocou um fim à sua amizade.",ep:2,g:22,l:37,wd:true,fm:true,w:50,c:"CW>49&Ps=2",p:1000};
I.u[2369] = {n:"Poderoso Cinto Ofuscante",t:10,d:"Este cinto magnífico é o resultado de um cinto maluco que deveria melhorar um dos mais belos cintos criados em Amakna: o Cinto Ofuscante. Pakape Promethe ganhou o cinto.",ep:2,g:26,l:80,wd:true,fm:true,w:150,p:300000};
I.u[2370] = {n:"O Vegete Hative",t:10,d:"Equipamento incrivelmente leve que traz alguma delicadeza ao cruel mundo dos Bworks em decomposição.",ep:2,g:23,l:41,wd:true,fm:true,w:5,c:"CA>50",p:4575};
I.u[2371] = {n:"Cinto Comfleecy",t:10,d:"Jiva recomenda este cinto para as noites frias e rigorosas. É tão confortável que, quando usá-lo, você vai pensar duas vezes antes de se mover. Se manchar, lave-o com Rimennelle.",ep:13,g:24,l:27,wd:true,fm:true,w:30,p:2775};
I.u[2372] = {n:"Botas de Lymph a Tik",t:11,d:"Ao usar estas botas você terá a impressão de caminhar sobre grama fresca. Elas são perfeitas para pessoas com chulé.",ep:5,g:18,l:39,wd:true,fm:true,w:5,c:"CC>50",p:4100};
I.u[2373] = {n:"Botas da Lua",t:11,d:"O pêlo da Lua, usado para fazer este par de botas, é absolutamente perfeito para manter seus pés aquecidos. Estas botas também são uma reconfortante memória da Lua.",ep:14,g:19,l:62,wd:true,fm:true,w:30,p:10000};
I.u[2374] = {n:"Botas de Tarsy",t:11,d:"Tarsy era um ermitão que, inevitavelmente, não suportava visitas. Conseqüentemente, recebia seus convidados mostrando-lhes o tamanho de suas botas...",ep:4,g:20,l:38,wd:true,fm:true,w:40,p:4000};
I.u[2375] = {n:"Botas Orino",t:11,d:"Graças a estas botas, você poderá ouvir o barulho do vento nas velas de um barco ou o grito dado por um Chafer Lançador perdido nas profundezas do labirinto.",ep:13,g:21,l:77,wd:true,fm:true,w:40,p:15500};
I.u[2376] = {n:"Machado de Hemal",t:19,d:"Este machado é o único capaz de resistir aos poderes da árvore ‘Kaerlier\' e, portanto, o único capaz de cortá-la.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,6,1,1,45,45,false,false],c:"PJ>2,79",p:1};
I.u[2377] = {n:"Picareta de Trhon",t:21,d:"Esta picareta de Enutrof é apenas uma picareta capaz de chegar ao \'Sangue da Rocha\' desde que resista às temperaturas extremas.",ep:0,g:1,l:1,wd:false,fm:true,w:10,e:[6,6,1,1,50,50,false,false],c:"PJ>24,79",p:1};
I.u[2378] = {n:"Rocha Sanguinária",t:51,d:"Esta pedra de cor carmesim é usada para fazer poções muito poderosas.",ep:16,g:459,l:1,wd:true,fm:true,w:0,p:1};
I.u[2379] = {n:"Madeira de Kaerlier",t:38,d:"Esta madeira vem das árvores lendárias Kaerlier. Suas propriedades são... surpreendentes.",ep:14,g:140,l:40,wd:true,fm:true,w:5,p:20};
I.u[2380] = {n:"Manto de Mushd",t:17,d:"É um estranho manto feito com pedaços de Mushd que são todos de um único pedaço. E você pode dar à pessoa que está rindo, um pedaço da mente dele.",ep:13,g:35,l:41,wd:true,fm:true,w:10,p:4500};
I.u[2381] = {n:"Manto Flutuante",t:17,d:"Este manto foi feito de uma bandeira, que costumava ser colocada na torre mais alta do Castelo de Amakna. Provavelmente, é por isto que ele cheira a linho fresco secado ao sol.",ep:5,g:36,l:61,wd:true,fm:true,w:10,c:"CI>90",p:9500};
I.u[2382] = {n:"Manto de Maimpa",t:17,d:"Maimpa foi um Ecaflip que não tinha medo de altura, pensando que ele sempre aterrissaria sobre seus pés. Mas um dia ele aterrissou em um trool faminto. Ele foi enterrado no mesmo dia no local onde foi encontrado... Hum, em todo lugar de certo modo...",ep:14,g:37,l:36,wd:true,fm:true,w:10,p:6500};
I.u[2383] = {n:"Capa de Sangue",t:17,d:"Feita de tecido de sangue, a Capa de Sangue tem o aspecto de um papelão, como se a tintura avermelhada tivesse coagulado.",ep:7,g:38,l:50,wd:true,fm:true,w:10,c:"CS>90",p:6000};
I.u[2384] = {n:"Botas Animais",t:11,d:"Há algo de... como eu posso dizer... hum ... bestial sobre estas botas. Então, não fique surpreso se um Boolobo se apaixonar pelas suas botas. Pode ser a pior coisa que lhe poderia acontecer.",ep:14,g:22,l:94,wd:true,fm:true,w:40,p:23000};
I.u[2385] = {n:"Grazor",t:17,d:"É uma ferramenta de jardinagem ideal que também pode ser usada como um capacho. Originalmente desenvolvida para os Sadidas, ela respeita os cabelos, mesmo os mais delicados. Alguns alegam que pode até mesmo reduzir a queda dos cabelos.",ep:12,g:39,l:88,wd:true,fm:true,w:10,p:20000};
I.u[2386] = {n:"Farrapo",t:17,d:"Esta capa estranha atrai a força de quem a olha. Os imundos levarão mais vantagem ao usá-la.",ep:13,g:40,l:53,wd:true,fm:true,w:10,p:7000};
I.u[2387] = {n:"Manto Peludo",t:17,d:"Devemos admitir que este manto tem um cheiro horrível. Verdade seja dita, ele é feito da mistura de vários pêlos de monstros.",ep:14,g:41,l:63,wd:true,fm:true,w:10,c:"CW>30&CV>50",p:10500};
I.u[2388] = {n:"Amuleto do Quebra-cabeça de Garra",t:1,d:"Muito tempo atrás, um seguidor de Ecaflip chamado Dodge estilhaçou uma pedra na qual estava gravado um cartão de tesouro. Acreditando que podia consertar o seu erro, ele manteve o maior pedaço e fez dele um amuleto. Ninguém sabe onde está esse amuleto agora.",ep:14,g:36,l:44,wd:true,fm:true,w:5,p:4000};
I.u[2389] = {n:"Amuleto Louco",t:1,d:"Dodge deu um significado à vida dele quebrando tudo que tinha valor aos seus olhos. Ele disse que isto era uma prova de que ele existiu. Gosto não se discute!",ep:14,g:37,l:32,wd:true,fm:true,w:5,p:3200};
I.u[2390] = {n:"Amuleto de Sorte",t:1,d:"Este Amuleto é quase perfeito. Ele aumenta consideravelmente a sabedoria do seu portador. Muito útil para fazer você parecer mais sábio para os amigos ou para fazer você se passar por um verdadeiro estudante.",ep:5,g:38,l:49,wd:true,fm:true,w:1,p:6400};
I.u[2391] = {n:"Amuleto de Sorte Dupla",t:1,d:"Há um velho provérbio que diz: \"Sorte em um dia, o dobro de sorte no dia seguinte\". Você pode notar que, quanto mais antigo for o provérbio, mais ridículo ele é.",ep:5,g:39,l:98,wd:true,fm:true,w:1,p:24400};
I.u[2392] = {n:"Dragolyre Modificado",t:1,d:"Graças aos artesãos de Amakna que são multitalentosos, o Dragolyre Modificado é quase perfeito. Certo Dragão Porco das montanhas até botou seus olhos nele... querendo usá-lo como uma arma contra visitas indesejáveis.",ep:11,g:25,l:42,wd:true,fm:true,w:1,p:5000};
I.u[2393] = {n:"Omelete Amuleto",t:1,d:"O Osamodas Onehaieuf Bek queria ser altamente respeitado pelos membros de sua guilda. Então, ele decidiu criar um Amuleto revolucionário. Ele encontrou inspiração enquanto fazia o café da manhã para seus amigos... que seja!",ep:1,g:40,l:17,wd:true,fm:true,w:10,p:1000};
I.u[2394] = {n:"Botão",t:1,d:"Aquecido pelo sol, é reconfortante e dá um sentimento de invulnerabilidade para o portador. É tão leve que nós, freqüentemente, esquecemos de tirá-lo para dormir.",ep:9,g:41,l:32,wd:true,fm:true,w:1,p:3000};
I.u[2395] = {n:"O Tecido do Toucinho Louco",t:1,d:"O Toucinho Louco era um pequeno demônio vil que não conseguia ficar de pé na frente das pessoas sem se mover. Ele era resistente à magia, o que impôs respeito na ocasião. O Toucinho Louco está longe agora, esperando em algum lugar de Amakna.",ep:8,g:42,l:42,wd:true,fm:true,w:15,p:5000};
I.u[2396] = {n:"Lou Ptiote",t:1,d:"Sylveline não era exatamente brilhante. Sua mãe deu uma lanterna como presente, dizendo que sua filha deveria ‘brilhar na noite\' pelo menos. Não é preciso dizer que Lou não era tão brilhante, todavia ela teve a brilhante idéia de dar a lanterna à sua filha, que iluminou a vida de Sylveline desde então.",ep:7,g:43,l:15,wd:true,fm:true,w:5,p:1500};
I.u[2397] = {n:"O Bibelaw",t:1,d:"O Law-bibe era um velho homem que pegava tudo que caía em suas mãos para criar itens estranhos. Um dia, ele fez um medalhão com formas estranhas. Quando ele pôs isto ao redor de seu pescoço, ele sentiu uma sensação estranha. Uma sensação muito estranha.",ep:13,g:44,l:30,wd:true,fm:true,w:10,p:3000};
I.u[2398] = {n:"Olho do Kaniger",t:1,d:"O famoso Kanigrou Rook Y Balboua deu isto para Melyonen para agradecê-la por apresentar-lhe à sua futura esposa;\r\n            Ar d ‘rieeeeeeeeeneuh, como ele gosta de chamá-la.",ep:13,g:45,l:52,wd:true,fm:true,w:1,p:7000};
I.u[2399] = {n:"O Colar dos Bezerros",t:1,d:"Jozebo Vez era um pastor. Seus Bezerros eram primos distantes dos Gobballs. Alguns destes animais tinham um tipo suave de pêlo que podia ser vendido por um preço alto. Para reconhecer seus bezerros, ele tinha o hábito de pôr um colar ao redor dos pescoços deles.",ep:13,g:46,l:15,wd:true,fm:true,w:1,p:1};
I.u[2400] = {n:"Botas de Animal das Sombras",t:11,d:"Há algo de... hum... como eu poderia dizer... sombrio sobre estas botas. Então, não fique surpreso se um Vampiro se apaixonar por você e pelas suas botas. Pode ser a pior coisa que poderia lhe acontecer.",ep:14,g:23,l:122,wd:true,fm:true,w:35,p:38000};
I.u[2401] = {n:"Carta de Kwelsh",t:15,d:"Esta carta está ligada ao mestre Kwelsh. É tudo que você sabe e precisa saber.",ep:16,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[2402] = {n:"Espada de Seriano-Kerm",t:6,d:"Esta espada é um presente de honra apenas para mercenários completos. E ela corta bem também.",ep:1,g:25,l:30,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[2403] = {n:"SeeU",t:10,d:"Em dias passados, ele era usado para parolar, o SeeU aparentemente tinha um poder de reserva em relação aos outros cintos. Mas ninguém descobriu qual era, conseqüentemente você deveria ficar de olho neste cinto.",ep:13,g:25,l:49,wd:true,fm:true,w:10,p:6100};
I.u[2404] = {n:"Cinto do Rato",t:10,d:"Este cinto pertenceu a um Rato de Esgoto. Serve perfeitamente, pois firma seus quadris, permitindo esconder as gordurinhas.",ep:2,g:27,l:55,wd:true,fm:true,w:10,p:8100};
I.u[2409] = {n:"Touca de Kwak do Fogo",t:16,d:"A Touca de Kwak do Fogo lhe deixará um verdadeiro charme, o que é muito conveniente para bater em seus inimigos quando eles caírem no chão, de tanto rir, depois que eles virem você usando esta touca.",ep:13,g:39,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2410] = {n:"Treecapacete",t:16,d:"O Treecapacete lhe protege de enxaquecas.",ep:1,g:40,l:45,wd:true,fm:true,w:50,s:3,p:5500};
I.u[2411] = {n:"Elmo Gobball",t:16,d:"Este magnífico elmo aumenta a força e a inteligência do portador se ele conseguir agüentar o cheiro.",ep:1,g:41,l:10,wd:true,fm:true,w:15,s:1,p:2050};
I.u[2412] = {n:"Kwakanto do Fogo",t:17,d:"Este manto não lhe permitirá voar ou deslizar, mas certamente lhe dará coceira. Ainda que você costure um grande ‘M\' nele, não funcionará... embora algumas pessoas estivessem absolutamente seguras disso. Que pena.",ep:8,g:42,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2413] = {n:"Treecapa",t:17,d:"Este cajado manteve toda a agressividade do Treechnid, mas não manteve o cheiro bolorento que freqüentemente caracteriza velhos Treechnids.",ep:1,g:43,l:45,wd:true,fm:true,w:17,s:3,p:5500};
I.u[2414] = {n:"Capa Gobbling",t:17,d:"Esta capa tem tudo isso: é resistente, confortável, colorida e rara... Mas seu cheiro é terrível para as cavidades nasais. Você, obviamente, não pode ter tudo!",ep:1,g:44,l:10,wd:true,fm:true,w:30,s:1,p:2780};
I.u[2415] = {n:"Kwaklâmina do Fogo",t:6,d:"A Kwaklâmina do Fogo é uma arma magnífica. Ainda que você não assuste seu inimigo, pelo menos, você o impressionará. Aproveite-se disto para golpeá-lo com um ataque enganoso.",ep:5,g:52,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CI>50&CV>50",s:2,p:4600};
I.u[2416] = {n:"Martelo do Gobball",t:7,d:"O manual do usuário explica que este surpreendente martelo pode lançar uma incrível energia quando corretamente usado. Outro manual para Osamoda traduzido para Sadida...",ep:1,g:23,l:10,wd:true,fm:true,w:25,an:15,e:[5,5,1,1,40,40,false,true],s:1,p:845};
I.u[2417] = {n:"Treecajado",t:4,d:"Este cajado manteve toda a agressividade do Treechnid, mas não manteve o cheiro bolorento que freqüentemente caracteriza velhos Treechnids.",ep:1,g:23,l:45,wd:true,fm:true,w:10,an:12,tw:true,e:[3,4,1,1,30,50,false,false],s:3,p:5500};
I.u[2418] = {n:"Kwakanel do Fogo",t:9,d:"Graças a este anel, seu mestre será capaz de encontrá-lo se você se perder quando for entregar uma carta.",ep:5,g:43,l:42,wd:true,fm:true,w:2,s:2,p:4900};
I.u[2419] = {n:"Anel de Bouze Lite Yeah",t:9,d:"Este anel pertenceu ao renomado Bouze Lite Yeah, o salvador dos tempos modernos. Sua oração favorita era sobre a Taverna \"Finito e Além\".",ep:1,g:44,l:10,wd:true,fm:true,w:10,s:1,p:775};
I.u[2420] = {n:"Aneltree",t:9,d:"O galho de Treechnid não é fácil de esculpir. Mas com alguma perseverança você pode obter um anel simples e elegante. Claro que um Sadida em uma taverna não é tão simples e tão elegante.",ep:1,g:45,l:40,wd:true,fm:true,w:10,s:3,p:4500};
I.u[2421] = {n:"Kwakobotas do Fogo",t:11,d:"Com estes esporões de Kwak do Fogo, seja cuidadoso e tenha cuidado com Srams mal-intencionados que podem roubá-los de você.",ep:5,g:25,l:40,wd:true,fm:true,w:5,s:2,p:4400};
I.u[2422] = {n:"Gobbotas",t:11,d:"Estas são as botas mais confortáveis que já existiram. O interior parece ser acolchoado com Lã de Gobball e você consegue sentir um líquido circulando entre os dedos do seu pé. Pelo que você sabe, poderia ser Saliva de Gobball ou Sangue. Mas que seja.",ep:1,g:26,l:10,wd:true,fm:true,w:15,s:1,p:1700};
I.u[2423] = {n:"Treebotas",t:11,d:"Esta s Botas são tão pesadas que é melhor não entrar num lago com elas.... Ouça o meu conselho.",ep:1,g:27,l:45,wd:true,fm:true,w:20,s:3,p:4500};
I.u[2424] = {n:"Amukwak do Fogo",t:1,d:"Com todas estas penas ao redor do pescoço, você parecerá Aldo Rado, o grande Sacrier aventureiro que está procurando uma cidade dourada.",ep:5,g:47,l:42,wd:true,fm:true,w:3,s:2,p:4900};
I.u[2425] = {n:"Amuleto do Gobball",t:1,d:"Um bom chifre de Gobball é um chifre que traz sabedoria e paz. Então, um bom pingente de Gobball lhe trará paz e sabedoria. Ou o contrário. Ou outra coisa. Ou nada.",ep:1,g:48,l:3,wd:true,fm:true,w:10,s:1,p:550};
I.u[2426] = {n:"Arachnamu",t:1,d:"Esta pequena Aracne é a prova de que você não precisa empalhar um animal para transformá-lo em amuleto. Ela fará cócegas no seu pescoço e poderá até tecer uma teia na frente da sua boca, se você bocejar demais ou estiver com mau hálito.",ep:1,g:49,l:20,wd:true,fm:true,w:10,s:3,p:1300};
I.u[2427] = {n:"Kwacinto do Fogo",t:10,d:"Este Cinto é perfeito para se desfilar como um Kwak do Fogo durante a estação do amor. Desde que, claro, isto seja a única coisa que você estará vestindo.",ep:12,g:28,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2428] = {n:"Cinto do Gobball",t:10,d:"Fácil de equipar, este cinto é bastante leve em relação ao seu tamanho. A lã parece ser nova. Isto é normal porque, de acordo com a lenda, foi necessário picar cerca de cem Gobballs para obter esse aspecto liso e sedoso.",ep:1,g:29,l:20,wd:true,fm:true,w:10,s:1,p:1253};
I.u[2429] = {n:"Treecinto",t:10,d:"Este cinto lhe fará ganhar autoconfiança e um grande abdômen de madeira. No entanto, é recomendado um tratamento anti-Aracne uma vez ao ano. É mais ou menos o mesmo com o cabelo de um Sadida, mas felizmente com menos antiparasitas.",ep:1,g:30,l:45,wd:true,fm:true,w:25,s:3,p:4500};
I.u[2430] = {n:"Poça de Geléia Azul",t:24,d:"Pobre Geléia Azul! Mesmo assim, você a cozinhou um pouco demais! Tenha cuidado porque um dia você poderá pagar caro por isto...",ep:7,g:91,l:1,wd:true,fm:true,w:0,p:1};
I.u[2431] = {n:"Poça de Geléia Limão",t:24,d:"Você ameaçou esta pobre e pequenina Geléia de Limão. Tenha cuidado, um dia você poderá ser esmagado assim como ela está agora...",ep:7,g:90,l:1,wd:true,fm:true,w:0,p:1};
I.u[2432] = {n:"Poça de Geléia de Morango",t:24,d:"Você ameaçou esta pobre Geléia de Morango. Tenha cuidado, um dia você pode ficar deformado tanto quanto ela é agora...",ep:7,g:92,l:1,wd:true,fm:true,w:0,p:1};
I.u[2433] = {n:"Poça de Geléia de Menta",t:24,d:"Você maltratou esta pequena geléia de menta. Tenha cuidado, porque um dia, você pode ficar tão esmagado quanto ela está agora...",ep:7,g:93,l:1,wd:true,fm:true,w:0,p:1};
I.u[2435] = {n:"Eni Kere",t:11,d:"Graças a estas caseiras botas, Kere foi o único seguidor de Eniripsa que conseguiu ganhar a Grande Maratona de Amakna. Todos os discípulos de Ecaflip ficaram estupefatos ao vê-lo correndo sobre o Mar de Asse... Muito elegante!",ep:5,g:29,l:45,wd:true,fm:true,w:5,p:4800};
I.u[2436] = {n:"Geléia Limão",t:110,d:"Este pote de Geléia de Limão possui uma aparência estranha. De acordo com Elrik Ola, esta geléia veio da sua casa. Do outro lado da galáxia, para ser mais preciso. Não é preciso mencionar não ser exatamente na casa ao lado!",ep:7,g:490,l:45,wd:true,fm:true,w:1,p:1};
I.u[2437] = {n:"Geléia Limão Real",t:110,d:"Alguns dizem que a Geléia de Limão Real é muito mais gostosa que todas as demais. Talvez devido ao fato de o limão esconder o gosto da geléia.",ep:7,g:491,l:200,wd:true,fm:true,w:1,p:100};
I.u[2438] = {n:"Elmo Gobball Real",t:16,d:"O Elmo Gobball Real nunca sairá da moda. Além de ficar elegante, quem usá-lo ganha força e inteligência.",ep:1,g:42,l:50,wd:true,fm:true,w:45,s:4,p:100};
I.u[2440] = {n:"Espada Gobball Real",t:6,d:"Esta espada está sempre hesitando ... Ela inflige dano de todos os elementos.",ep:1,g:30,l:70,wd:true,fm:true,w:65,an:14,e:[4,4,1,1,30,50,false,false],s:4,p:30000};
I.u[2441] = {n:"Anel Gobball Real",t:9,d:"Este anel aumenta a vida de quem possuí-lo;\r\n            o cheiro de Gobball Real fêmea aumenta o seu charme...",ep:1,g:46,l:30,wd:true,fm:true,w:5,s:4,p:100};
I.u[2442] = {n:"Gobotas Reais",t:11,d:"Brilha e irradia poder: perfeito para um rei.",ep:1,g:30,l:50,wd:true,fm:true,w:50,s:4,p:6600};
I.u[2443] = {n:"Amuleto Gobball Real",t:1,d:"Este amuleto aumenta a inteligência e a força de quem possuí-lo.",ep:1,g:50,l:50,wd:true,fm:true,w:10,s:4,p:5000};
I.u[2444] = {n:"Cinto do Gobball Real",t:10,d:"Com este magnífico cinto, você poderá aumentar a sua vitalidade e carregar seus itens mais facilmente. É tão macio que você vai poder usá-lo até para amarrar as mãos e os pés da sua amada, quando ela se recusar a ficar em casa.",ep:1,g:31,l:52,wd:true,fm:true,w:10,s:4,p:7000};
I.u[2445] = {n:"Capa de Gobbling Real",t:17,d:"No topo da moda, esta capa, usada pelo grande Gobball Real, dá incrível força.",ep:1,g:46,l:50,wd:true,fm:true,w:60,s:4,p:50000};
I.u[2446] = {n:"Gelcapa",t:17,d:"Sem nenhum cabelo ou fio, esta capa continua um mistério para as cabeças pensantes de Amkana que não passam de dez pessoas.",ep:7,g:47,l:60,wd:true,fm:true,w:10,s:6,p:1000};
I.u[2447] = {n:"Geltouca",t:16,d:"Com esta touca, você pode ter certeza de que seus amigos sonharam em ter uma. É uma das coisas que o Capitão Chafer sempre sonhou numa época.",ep:5,g:43,l:60,wd:true,fm:true,w:23,s:6,p:9500};
I.u[2448] = {n:"Cérebro de Gobball",t:15,d:"Não existe dúvida de que este Cérebro vem de um Gobball. Bem cozido, é o prato favorito de jovens Iops que querem ficar grandes e fortes. Isto também os ajuda a ficar inteligentes, mas eles não sabem disso, senão, parariam de comer.",ep:1,g:492,l:9,wd:true,fm:true,w:1,p:1};
I.u[2449] = {n:"Exército de Carrapatos",t:15,d:"De acordo com os caçadores, um Exército de Carrapatos Famintos pode devorar toda a lã de um Gobball em uma noite. Alguns bebedores de energético até asseguram que eles conseguem penetrar na magnífica juba de um Sadida.",ep:1,g:493,l:9,wd:true,fm:true,w:1,p:1};
I.u[2451] = {n:"Casco de Gobball",t:47,d:"Antes usados para descanso (muito se precisou de acessórios para evitar marcas de taças nas mesas quando você queria dar uma grande festa), os cascos de Gobballs são reciclados por alguns - galanteadores - alquimistas da classe dos Eniripsas, que agora fazem tigelas com eles. Essas tigelas são ideais se você acha que seus cereais precisam de um gosto bom e forte.",ep:1,g:495,l:9,wd:true,fm:true,w:1,p:1};
I.u[2453] = {n:"Olho de Gobball",t:109,d:"Os olhos de Gobball já foram usados como o principal ingrediente de sopas deliciosas, tão deliciosa que a receita foi apagada dos livros porque muitos caçadores matavam Gobballs só por causa dos olhos deles, deixando para trás, as fumegantes carcaças.",ep:1,g:497,l:9,wd:true,fm:true,w:1,p:1};
I.u[2454] = {n:"Estômago de Gobball",t:15,d:"Tal estômago possui eficientes propriedades elásticas. Mas não se preocupe se ainda existir um pouco de mingau de Trevos dentro dele. Pelo contrário, fiquem felizes senhoritas, este mingau é muito bom para pele.",ep:1,g:498,l:9,wd:true,fm:true,w:1,p:1};
I.u[2455] = {n:"Sangue de Gobball",t:15,d:"Você não pode ir caçar sem sangue de Gobball como isca. Seu cheiro atrai alguns dos maiores Gobballs, assim como Moskitoes, embora ninguém saiba o motivo.",ep:1,g:499,l:9,wd:true,fm:true,w:1,p:1};
I.u[2460] = {n:"Olho de Gobbly",t:109,d:"Correndo o risco de ser considerado paranóico, você confia em seu forte pressentimento que lhe diz que o Gobbly está sempre de olho em você...",ep:1,g:500,l:2,wd:true,fm:true,w:1,p:1};
I.u[2462] = {n:"Cérebro de Chefe de Guerra Gobball",t:15,d:"Inevitavelmente, o Chefe de Guerra Gobball do qual você extraiu este Cérebro terá alguma dificuldade para pensar.",ep:1,g:501,l:19,wd:true,fm:true,w:1,p:1};
I.u[2463] = {n:"Dente de Chefe de Guerra Gobball",t:47,d:"Muito poucas pessoas são suficientemente qualificadas para extrair um Dente de um Chefe de Guerra Gobball. Note que este Dente aumenta de valor quando está danificado. Não me pergunte o motivo, aparentemente tem algo a ver com equilíbrio econômico ou algo do tipo.",ep:1,g:502,l:19,wd:true,fm:true,w:1,p:1};
I.u[2464] = {n:"Rabo de Chefe de Guerra Gobball",t:65,d:"Escondido na floresta, assista pacientemente, sem fazer barulho, e você pode ser capaz de ver um Chefe de Guerra Gobball balançando seu rabo com alegria. Mas este pequeno gesto trivial só acontece durante o período de acasalamento.",ep:1,g:503,l:19,wd:true,fm:true,w:1,p:1};
I.u[2465] = {n:"Chifre de Chefe de Guerra Gobball",t:47,d:"Menos gentil que seus companheiros, o Chefe de Guerra Gobball espeta mais facilmente Srams e outras espécies imprudentes. Alguém pode encontrar, freqüentemente, pedaços de tecido em seus chifres, como um pequeno troféu que ele se orgulha de mostrar.",ep:1,g:504,l:19,wd:true,fm:true,w:1,p:1};
I.u[2466] = {n:"Língua de Chefe de Guerra Gobball",t:15,d:"A expressão ‘seu hálito fede\' está absolutamente correta para o Chefe de Guerra Gobball. É verdade que freqüentemente se tem a sensação de que ele come um Trool doente em cada refeição.",ep:1,g:505,l:19,wd:true,fm:true,w:1,p:1};
I.u[2467] = {n:"Casco de Chefe de Guerra Gobball",t:47,d:"De acordo com os sapateiros, este casco é um dos mais resistentes e maleáveis da Província. Até que você saiba o significado exato que eles dão à palavra “maleável”. Eles, aparentemente, querem fazer uma cópia das botas de borracha Wallington com este casco.",ep:1,g:538,l:18,wd:true,fm:true,w:1,p:1};
I.u[2468] = {n:"Estômago de Chefe de Guerra Gobball",t:15,d:"Você achará uma surpresa dentro deste estômago. O mindinho de um Enutrof, um nariz de Osamoda...Você quase poderia montar seu próprio herói com todas estas partes do corpo.",ep:1,g:506,l:19,wd:true,fm:true,w:1,p:1};
I.u[2469] = {n:"Gelano",t:9,d:"Com este anel, não é preciso roer suas unhas, apenas lamba seus dedos!",ep:7,g:47,l:60,wd:true,fm:true,w:5,s:6,p:10000};
I.u[2470] = {n:"Gelbotas",t:11,d:"Estas botas são muito confortáveis no verão devido a exalarem odores de morangos selvagens, mascarando o cheio de transpiração dos dedos peludos de um velho Sadida.",ep:5,g:31,l:60,wd:true,fm:true,w:50,s:6,p:1000};
I.u[2471] = {n:"Gelcinto",t:10,d:"A coisa mais difícil é que neste caso de muita fome, somos tentados a dar uma mordida.",ep:7,g:32,l:60,wd:true,fm:true,w:15,s:6,p:1000};
I.u[2472] = {n:"Gelamu",t:1,d:"Este amuleto trai sua notável preferência por geléias. Não é a melhor maneira de ser um socialite bem-sucedido, mas você tem que se orgulhar de sua fraqueza por geléias.",ep:5,g:51,l:60,wd:true,fm:true,w:4,s:6,p:1000};
I.u[2473] = {n:"Manto de Aventureiro",t:17,d:"Elegante, mas não muito eficiente, esta capa irá satisfazer o bom gosto dos jovens aventureiros.",ep:1,g:48,l:1,wd:true,fm:true,w:7,s:5,p:100};
I.u[2474] = {n:"Chapéu de Aventureiro",t:16,d:"Este chapéu não é realmente útil para nada, exceto para assustar as moças legais...",ep:1,g:44,l:1,wd:true,fm:true,w:12,s:5,p:100};
I.u[2475] = {n:"Anel de Aventureiro",t:9,d:"Um pequeno e agradável anel para novatos que também pode divertir crianças e os seguidores de Ecaflip.",ep:1,g:48,l:1,wd:true,fm:true,w:5,s:5,p:10};
I.u[2476] = {n:"Botas de Aventureiro",t:11,d:"Estas botas clássicas são atraentes para jovens com um espírito aventureiro.",ep:1,g:32,l:1,wd:true,fm:true,w:15,s:5,p:10};
I.u[2477] = {n:"Cinto de Aventureiro",t:10,d:"Um pequeno cinto para aventureiros aspirantes.",ep:1,g:33,l:1,wd:true,fm:true,w:6,s:5,p:10};
I.u[2478] = {n:"Amuleto de Aventureiro",t:1,d:"Este estranho amuleto permite ao seu portador tirar um cochilo no meio de uma luta. Assim como um seguidor de Feca faria contra um grupo de Cracklers.",ep:1,g:52,l:1,wd:true,fm:true,w:2,s:5,p:10};
I.u[2479] = {n:"Corte de Cabelo de Porco Imundo",t:15,d:"Este corte de cabelo é sinal de maturidade para o Porco Imundo. Este é o motivo de os jovens pubescentes Eniripsa poderem algumas vezes se perguntar sobre a cidade com o mesmo corte de cabelo. Mas eles não vão para as Planícies Rochosas assim.",ep:13,g:507,l:18,wd:true,fm:true,w:1,p:1};
I.u[2480] = {n:"Cueca de Porco Imundo",t:56,d:"‘Um porco imundo sem cueca é um porco imundo morto\' era a expressão favorita da Dama Harre, um discípulo de Feca e uma entusiasta perturbadora, além de espreitadora. Seu passatempo favorito era forçar seus ‘amigos\' a escorregar pelas sujeiras dos porcos.",ep:13,g:508,l:18,wd:true,fm:true,w:1,p:1};
I.u[2481] = {n:"Focinho de Porco Imundo",t:15,d:"Este focinho, tão rosa quanto as nádegas de um bebê Osamodas, pode certamente ser usado em uma receita. Ou você pode talvez fazer um colar de focinho, mas terá de ser corajoso o bastante para usá-lo aos olhos de seus vizinhos.",ep:13,g:509,l:18,wd:true,fm:true,w:1,p:1};
I.u[2482] = {n:"Sapato de Porca Imunda",t:15,d:"Era uma vez, um sapato encontrado nos degraus do palácio real. Alguns rumores diziam que este sapato foi perdido depois da partida apressada de uma porca imunda que estava com medo de voltar para casa depois do soar da meia-noite.",ep:13,g:510,l:18,wd:true,fm:true,w:2,p:1};
I.u[2483] = {n:"Dentadura de Porco Imundo",t:47,d:"Alguns Porcos Imundos não têm dentes. Outros acordam um dia sem dentes, sem lembrar o que aconteceu.",ep:13,g:511,l:30,wd:true,fm:true,w:1,p:1};
I.u[2484] = {n:"Tridente Quebrado",t:15,d:"Mantenha isto como uma lembrança do Porco Imundo que você acabou de derrotar. O problema é que ele poderia usá-lo contra você... Seria melhor não colidir com ele novamente porque Porcos Imundos são Piolhentos e são teimosos.",ep:13,g:512,l:18,wd:true,fm:true,w:2,p:1};
I.u[2485] = {n:"Vegagorro",t:16,d:"O Item da moda, mas somente no nordeste de Amakna.",ep:1,g:45,l:40,wd:true,fm:true,w:25,s:10,p:4500};
I.u[2486] = {n:"Orelha de Porco Imundo",t:106,d:"Esta Orelha obterá respeito das pessoas ao seu redor. É um troféu, assim como uma prova que você pode domar os Porcos Imundos. Mas tenha cuidado, não exiba diante de outros Porcos Imundos ou você terá sérios problemas.",ep:13,g:513,l:18,wd:true,fm:true,w:1,p:1};
I.u[2487] = {n:"Carapaça de Escorpião",t:107,d:"Ideal para fazer armaduras pesadas, o Escorpião costuma ser caçado pela milícia de Brakmar, devido à sua incrível capacidade de reprodução. Até mesmo as geléias foram ultrapassadas.",ep:14,g:514,l:36,wd:true,fm:true,w:1,p:1};
I.u[2488] = {n:"Entranhas de Escorpião",t:15,d:"À primeira vista, estas entranhas não parecem muito apetitosas. Bastante justo. Entranhas de Escorpião são revoltantes, mesmo quando cozidas com muito cuidado.",ep:14,g:445,l:36,wd:true,fm:true,w:1,p:1};
I.u[2489] = {n:"Vegacape",t:17,d:"Esta capa elegante o fará irresistível a qualquer espécie de amador.",ep:1,g:49,l:58,wd:true,fm:true,w:15,s:10,p:1000};
I.u[2490] = {n:"Pata de Escorpião",t:103,d:"É um tanto raro conseguir uma pata de Escorpião em boas condições. Use-a com sabedoria, para abrir as fechaduras em portas, por exemplo... Brincadeira... bem, talvez não...",ep:14,g:515,l:36,wd:true,fm:true,w:1,p:1};
I.u[2491] = {n:"Olho de Ouginak",t:109,d:"Dê uma olhada neste perturbador porém excitante Olho;\r\n            ele não mostra o que você espera ver. Por exemplo, em vez do seu reflexo você verá sua contraparte, um Dopple. É completamente confuso.",ep:14,g:516,l:51,wd:true,fm:true,w:1,p:1};
I.u[2492] = {n:"Corrente",t:15,d:"Esta maldita Corrente obviamente vem de um Ouginak. Antes de ser quebrada, ela provavelmente costumava prender o Ouginak de forma que ele não conseguia escapar.",ep:14,g:517,l:51,wd:true,fm:true,w:2,p:1};
I.u[2493] = {n:"Coração de Ouginak",t:15,d:"Este coração será fiel a você. Enquanto você não o vender ou trocar, ele permanecerá com você. Que pensamento adorável!",ep:14,g:518,l:51,wd:true,fm:true,w:1,p:1};
I.u[2494] = {n:"Pomo de Espada",t:15,d:"Um sopro ultrapoderoso deve ter sido necessário para terminar esta Espada Mítica. A pessoa em posse da Espada de um Ouginak não pode ajudar gritando de alegria! Woohoo!",ep:14,g:519,l:51,wd:true,fm:true,w:2,p:1};
I.u[2495] = {n:"Olho de Kolerato",t:109,d:"Este olho brilha na sombra mesmo arrancado do rosto de seu proprietário. É tão brilhante que pode até mesmo iluminar sua noite!",ep:2,g:520,l:9,wd:true,fm:true,w:1,p:1};
I.u[2496] = {n:"Unha de Kolerato",t:65,d:"Cuidadosamente cortada, a Unha de Kolerato tem gosto de salsicha. O estranho é que quando você come um pedaço grande, o gosto de salsicha desaparece. Outro enigma da culinária deste mundo.",ep:2,g:521,l:9,wd:true,fm:true,w:1,p:1};
I.u[2497] = {n:"Orelhas de Kolerato",t:106,d:"Coloque perto de sua orelha e você poderá ouvir o mar.",ep:2,g:522,l:9,wd:true,fm:true,w:1,p:1};
I.u[2498] = {n:"Vegamu",t:1,d:"O Vegamu atrai facilmente os Moskitos que acham que é um de seus amigos. Eles normalmente ficam decepcionados quando vêem alguém com o amuleto.",ep:1,g:53,l:40,wd:true,fm:true,w:20,s:10,p:1000};
I.u[2499] = {n:"Nariz de Kolerato",t:15,d:"O Kolerato tem um nariz muito bom, não tão bom quanto o Ouginak, mas pode farejar predadores dentro de um raio de 300 metros. Muito conveniente para evitar predadores.",ep:2,g:523,l:9,wd:true,fm:true,w:1,p:1};
I.u[2500] = {n:"Kolerat Morto",t:15,d:"Você fez bem em coletar isto, pois está intacto. Morto, mas intacto.",ep:2,g:524,l:9,wd:true,fm:true,w:10,p:1};
I.u[2501] = {n:"Rabo de Lupis Albino",t:65,d:"A Deusa Osamodas não gosta que as pessoas coloquem um dedo sequer em animais selvagens. ‘São tão fofos\'! como ele sempre grita. É um grito! Ele obviamente nunca foi rasgado a pedaços pelo ‘cutie\'.",ep:1,g:525,l:19,wd:true,fm:true,w:1,p:1};
I.u[2502] = {n:"Pata de Lupis Albino",t:103,d:"As Patas do Lupis Albino são muito apreciadas pelos gastrônomos. Compartilham suas propriedades mágicas com quem usá-las, como sorte por exemplo. Melhor que nada.",ep:1,g:526,l:19,wd:true,fm:true,w:1,p:1};
I.u[2503] = {n:"Pano de Lupis Albino",t:55,d:"Um Lupis Albino é tão maligno quanto este pano. Se um de seus sonhos era usar um pano na cabeça e mover como felinos, ele se fez. Mas, cá entre nós, você tem sonhos estranhos.",ep:1,g:200,l:19,wd:true,fm:true,w:1,p:1};
I.u[2504] = {n:"Língua de Lupis Albino",t:15,d:"Esta língua certamente passou por muitos lugares diferentes antes de você recebê-la.",ep:1,g:527,l:19,wd:true,fm:true,w:1,p:1};
I.u[2505] = {n:"Croquete",t:15,d:"Para atrair um Lupis Claro para ser domesticado, lance para ele um Croquete, ele é louco por isto. Ele nunca lhe confessará, mas você terá feito um amigo para toda a vida.",ep:1,g:528,l:19,wd:true,fm:true,w:1,p:1};
I.u[2506] = {n:"Sino",t:15,d:"Você pode ouvir a Plissken a quilômetros de distância graças ao sino dela. E felizmente, já que ela não é facilmente visível na exuberante vegetação das Planícies Cania.",ep:13,g:529,l:10,wd:true,fm:true,w:1,p:1};
I.u[2507] = {n:"Língua Bifurcada",t:15,d:"Você pode chicotear seus amigos com esta Língua. Os seguidores de Osamoda e os de Sacrier ficarão muito contentes.",ep:13,g:530,l:10,wd:true,fm:true,w:1,p:1};
I.u[2508] = {n:"Veneno de Plissken",t:15,d:"Este terrível veneno pode derrubar a melhor das tropas de furiosos gobballs. Ele é usado para controlar rebanhos;\r\n            apenas coloque um pouco dele na ponta de um cajado e pronto!",ep:13,g:531,l:10,wd:true,fm:true,w:1,p:1};
I.u[2509] = {n:"Dente de Plissken",t:47,d:"Este dente uma vez pertenceu a uma Plissken. Não pode ser de outro animal. Pode-se perceber isso por causa da ponta extremamente afiada do dente.",ep:13,g:432,l:10,wd:true,fm:true,w:1,p:1};
I.u[2510] = {n:"Estômago de Javali das Planícies",t:15,d:"Este estômago é grande o suficiente para colocar diversas coisas nele. Uma oportunidade que caiu do céu para os seguidores de Iop organizarem suas Espadas.",ep:13,g:532,l:44,wd:true,fm:true,w:1,p:1};
I.u[2511] = {n:"Couro de Javali das Planícies",t:56,d:"Por causa das propriedades desse couro, os sapateiros hesitaram há muito tempo antes de usá-lo para fazer cintos e botas. De fato, esse couro não tinha cheiro e, portanto, vários clientes acharam que era falso.",ep:2,g:410,l:44,wd:true,fm:true,w:10,p:1};
I.u[2512] = {n:"Rabo de Javali das Planícies",t:65,d:"Muitos caçadores brakmarianos coletam esse troféu peludo. A razão disso ainda é desconhecida.",ep:13,g:536,l:44,wd:true,fm:true,w:1,p:1};
I.u[2513] = {n:"Tecido de Javali das Planícies",t:55,d:"Ao contrário do seu couro, o Tecido do Javali das Planícies tem um cheiro que é radical contra problemas de olfato. Ele pode até mesmo acordar um seguidor de Sadida em hibernação.",ep:13,g:537,l:44,wd:true,fm:true,w:1,p:1};
I.u[2514] = {n:"Pata de Javali das Planícies",t:47,d:"As patas de Javali geralmente estão cobertas de lama ou porcaria, mas às vezes também de coloridos Biblops, o que não é incomum. O Javali das Planícies odeia os Biblops tanto quanto você.",ep:13,g:539,l:44,wd:true,fm:true,w:1,p:1};
I.u[2515] = {n:"Focinho de Javali das Planícies",t:15,d:"De primeira vista, esse focinho não parece muito delicado. Mas não se engane, ele é o focinho mais macio e limpo de todos.",ep:13,g:540,l:44,wd:true,fm:true,w:1,p:1};
I.u[2516] = {n:"Dente de Javali das Planícies",t:47,d:"Este dente de Javali das Planícies irá lembrar você de como esse tipo de javali é desagradável. De fato, esse dente está tão usado quanto os dentes de Wabbit usados para comer cenouwawa.",ep:13,g:541,l:44,wd:true,fm:true,w:1,p:1};
I.u[2517] = {n:"Megacapa",t:17,d:"Esta capa pertenceu a um herói que era famoso por confrontar o terrível Dr. Wily, que tentou dominar o Mundo dos Doze com seu exército de robôs insanos.",ep:1,g:50,l:45,wd:true,fm:true,w:2,s:76,p:5500};
I.u[2518] = {n:"Capa Viewtiful",t:17,d:"Apesar de ter sido costurada com cortinas velhas, esta capa se parece mais com um esfregão usado, velho e fervido em caldo de Porco Imundo.",ep:1,g:51,l:45,wd:true,fm:true,w:2,s:75,p:5500};
I.u[2519] = {n:"Megacapacete",t:16,d:"Desenvolvido pelo Doutor Albert, este é o capacete ideal para você que é fã de robôs e gosta de passar por situações extremas.",ep:1,g:46,l:44,wd:true,fm:true,w:2,s:76,p:5200};
I.u[2520] = {n:"Capacete Viewtiful",t:16,d:"Este capacete pertenceu ao velho Jojo, um famoso herói que viveu no Mundo dos Doze.",ep:1,g:47,l:44,wd:true,fm:true,w:2,s:75,p:5200};
I.u[2521] = {n:"Megabotas",t:11,d:"Desenvolvidas pelo Doutor Albert, estas botas pertenceram ao irmão de uma garota chamada Roll.",ep:1,g:33,l:43,wd:true,fm:true,w:2,s:76,p:5000};
I.u[2522] = {n:"Botas Viewtiful",t:11,d:"Estas botas permitiram que Jojo aperfeiçoasse seu lendário chute girátorio, que ficou conhecido como \"Chute Vermelho Picante\". Mas se ela são brancas, de onde foi que esse nome surgiu...?",ep:1,g:34,l:43,wd:true,fm:true,w:2,s:75,p:5000};
I.u[2523] = {n:"Megacinto",t:10,d:"Este cinto foi especialmente criado para proteger os quadris de nossos valiosos heróis. Totalmente inútil para você.",ep:1,g:34,l:45,wd:true,fm:true,w:2,s:76,p:5600};
I.u[2524] = {n:"Cinto Viewtiful",t:10,d:"Os rumores dizem  que este cinto foi criado pelo Capitão Blooe em pessoa. Não é incrívi.. Incrível! Você não acredita em mim, não é?",ep:1,g:35,l:46,wd:true,fm:true,w:2,s:75,p:5600};
I.u[2525] = {n:"Coração do Lorde Corvo",t:15,d:"Sem o Coração, a música não é apenas um sopro sem sentido. Mas não diga nada ao Lorde Corvo, ele é muito sensível.",ep:13,g:328,l:160,wd:true,fm:true,w:1,p:1};
I.u[2526] = {n:"Gadanha do Lorde Corvo",t:15,d:"Esta gadanha foi originalmente desenvolvida para retalhar os discípulos de Iop, mas Lorde Corvo compreendeu que era tão afiada a ponto de cortar qualquer coisa.",ep:1,g:557,l:160,wd:true,fm:true,w:10,p:1};
I.u[2527] = {n:"Clakoss",t:15,d:"O Lorde Corvo é uma criatura cheia de surpresas! Por exemplo, ele tinha um Clakoss - o famoso queijo real, em seu bolso. Isto só prova que Lorde Corvo o adora. Entretanto, não é recomendado que mantenha o queijo com você, por causa do cheiro.",ep:13,g:558,l:160,wd:true,fm:true,w:1,p:1};
I.u[2528] = {n:"Unha de Kanigrou",t:47,d:"Você precisa ser poderoso e rápido para pegar a unha de um Kanigrou – poderoso para retirá-la e rápido para evitar uma pancada na cabeça.",ep:13,g:559,l:70,wd:true,fm:true,w:1,p:1};
I.u[2529] = {n:"Poção de Metal Líquido",t:26,d:"Esta poção devolve um pouco de realidade para as espadas celestes.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2530] = {n:"Carabotas",t:11,d:"Um pouco pesadas, mas muito bonitas. Você será a rainha da noite com estas Carabotas.",ep:12,g:35,l:60,wd:true,fm:true,w:50,s:9,p:1000};
I.u[2531] = {n:"Carachapeú",t:16,d:"Assim como você, tartarugas têm cabeças muito pequenas. Que conveniente! Este chapéu é do tamanho certo para vocês dois.",ep:12,g:48,l:60,wd:true,fm:true,w:24,s:9,p:10000};
I.u[2532] = {n:"Caracapa",t:17,d:"Um manto conveniente e resistente. Não fará de você uma celebridade, mas você nunca foi uma celebridade, então sem problemas!",ep:12,g:52,l:60,wd:true,fm:true,w:15,s:9,p:10000};
I.u[2534] = {n:"Kwakcapa de Gelo",t:17,d:"Ideal para mantê-lo fresco durante o verão da Ilha da Lua, ótima também para desacelerar o avanço de seus amigos mais ansiosos, esta capa satisfará os aventureiros dos tempos modernos.",ep:8,g:53,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2535] = {n:"Touca de Kwak de Gelo",t:16,d:"Esta touca de Kwak de Gelo ajudará você a manter a cabeça fresca com idéias brilhantes. Entretanto, não é poderosa o bastante para um Iop.",ep:13,g:49,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2537] = {n:"Kwakcinto de Gelo",t:10,d:"Ideal para proteger seu quadril, este cinto permitirá sustentar o que você tiver abaixo da cintura.",ep:12,g:36,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2538] = {n:"Poção de Metal Líquido Grosso",t:26,d:"Esta poção devolve um pouco de realidade para as espadas celestes.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2539] = {n:"Poção de Serragem",t:26,d:"Esta poção devolve a vida a alguma escultura celeste",ep:1,g:16,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2540] = {n:"Poção de Fragmentos de Força",t:26,d:"Esta poção devolve realidade a uma escultura etérea.",ep:1,g:17,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2541] = {n:"Poção de Metal Líquido Precioso",t:26,d:"Esta poção devolve muita realidade para as espadas celestes.",ep:2,g:15,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2542] = {n:"Poção de Casa",t:12,d:"Esta poção o faz voltar para casa quando quiser.",ep:1,g:142,l:1,wd:true,fm:true,w:2,u:true,p:100};
I.u[2543] = {n:"Poção de Fragmentos Raros",t:26,d:"Esta poção devolve realidade à escultura celeste.",ep:9,g:18,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2544] = {n:"Crolâmina",t:6,d:"Terrivelmente afiada e incrivelmente refinada, esta lâmina deixará os Corvos de seus amigos com ciúmes.",ep:1,g:32,l:45,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,20,50,false,false],s:8,p:4500};
I.u[2545] = {n:"Crobotas",t:11,d:"Com estas botas, você se sentirá incrivelmente leve e particularmente ridículo.",ep:1,g:37,l:45,wd:true,fm:true,w:1,s:8,p:1000};
I.u[2546] = {n:"Capacete de Corvo",t:16,d:"Graças a este magnífico capacete, você terá tanta classe quanto o notório Lorde Corvo.",ep:1,g:50,l:45,wd:true,fm:true,w:23,s:8,p:1000};
I.u[2547] = {n:"Manto Mastralis",t:17,d:"Os melhores alfaiates de Amakna se juntaram para usar os restos do Lorde Corvo e fazer um manto magnífico. Com este manto sobre seus ombros, VOCÊ é o mestre.",ep:13,g:56,l:127,wd:true,fm:true,w:30,p:41000};
I.u[2549] = {n:"Lata de Kanigrou",t:15,d:"Esta lata contém um Kaniger cortado em pedaços. Muito conveniente para carregar, um Kaniger em pedaços é realmente o melhor amigo de um homem.",ep:13,g:560,l:70,wd:true,fm:true,w:1,p:1};
I.u[2550] = {n:"Tecido de Kanigrou",t:55,d:"Este tecido é um substituto capilar perfeito e maravilhoso. Se você usá-lo, todos vão notar sua presença!",ep:13,g:561,l:70,wd:true,fm:true,w:1,p:1};
I.u[2551] = {n:"Orelha de Kanigrou",t:106,d:"É o prato favorito de Ouginak: orelhas de Kanigrou com molho tradicional. É cozido com muita menta selvagem e algumas unhas para dar sabor.",ep:13,g:562,l:70,wd:true,fm:true,w:1,p:1};
I.u[2552] = {n:"Olho de Kanigrou",t:109,d:"O olho de Kanigrou é um fenômeno da moda;\r\n            basta olhar para todos estes aventureiros usando-o em seus pescoços...",ep:13,g:563,l:70,wd:true,fm:true,w:1,p:1};
I.u[2553] = {n:"Grande Bola de Canhão",t:15,d:"É uma verdadeira Bola de Canhão. Muito pesada, pode, a qualquer momento, perfurar seu crânio. Muito chato...",ep:1,g:564,l:40,wd:true,fm:true,w:500,p:1};
I.u[2554] = {n:"Mandíbula de Porco Imundo",t:47,d:"As mandíbulas de Porcos Imundos têm um sabor especial. Algumas pessoas cozinham com suco picante, outras comem cru. Para o Porco Imundo, é preferível você. Para ensinar sua própria... receita.",ep:13,g:159,l:40,wd:true,fm:true,w:1,p:1};
I.u[2555] = {n:"Couro de Sela",t:56,d:"O Porco Imundo é muito sensível, mas ele tem dificuldade em encarar os fatos. A prova disso é que ele secretamente enche a sela para ficar mais confortável. Depois de modificada, sua sela pode fazer chinelos perfeitos.",ep:13,g:565,l:40,wd:true,fm:true,w:5,p:1};
I.u[2556] = {n:"Pólen de Blop",t:15,d:"O pólen de Blop causa todas as alergias benignas deste mundo. O mais preocupante é que todas as alergias letais começam com alergias benignas. Resumindo, não mantenha este pólen em seus bolsos se você não precisar dele.",ep:5,g:566,l:34,wd:true,fm:true,w:1,p:1};
I.u[2557] = {n:"Pétala de Blop",t:35,d:"Por mais estranho que pareça, as Pétalas de Blop não são comestíveis, nem cozidas nem cruas.",ep:5,g:567,l:34,wd:true,fm:true,w:1,p:1};
I.u[2558] = {n:"Blop Morto",t:15,d:"Você fez bem em coletar isto, está intacto. Morto, mas intacto.",ep:5,g:568,l:34,wd:true,fm:true,w:10,p:1};
I.u[2559] = {n:"Juba de Trool",t:15,d:"Uma juba como esta aqui é difícil de encontrar. Apenas Enutrofs ricos podem usá-la como uma reposição de cabelos.",ep:4,g:569,l:115,wd:true,fm:true,w:1,p:1};
I.u[2560] = {n:"Epaulette de Trooll",t:15,d:"É melhor para você olhar esta Dragona assim, do que quando ela ainda está no ombro do Trooll. Eles fingiriam ser modelos no mínimo!",ep:4,g:570,l:115,wd:true,fm:true,w:5,p:1};
I.u[2561] = {n:"Bracelete de Força de Trool",t:15,d:"Como se um Trooll precisasse de uma Pulseira de Força! Esta incrível \"máquina de moer ossos\" usa uma pulseira em cada pulso.",ep:4,g:571,l:115,wd:true,fm:true,w:5,p:1};
I.u[2562] = {n:"Cueca de Trool",t:56,d:"Pelo estado de suas cuecas, o Trool aparentemente senta em todos os lugares. Graças a suas cuecas, podemos facilmente determinar o quão velho o Trool é... você só tem de confiar no seu olfato...",ep:4,g:572,l:115,wd:true,fm:true,w:1,p:1};
I.u[2563] = {n:"Tronco",t:38,d:"Para o Tronknyde, isto serve para calçar os pés, para isso que existe o tronco, infelizmente, o Tronknyde é sempre confundido e pára entre os dedos.",ep:9,g:573,l:35,wd:true,fm:true,w:2,p:1};
I.u[2564] = {n:"Trunknid",t:38,d:"Você sempre quis saber como o Trunknid assusta visitas descuidadas? Você tem a resposta na sua frente: sobrancelhas grossas.",ep:9,g:574,l:35,wd:true,fm:true,w:2,p:1};
I.u[2565] = {n:"Pedaço de Trunknid",t:15,d:"Este pedaço de Trunknid foi nada menos nada mais que um pedaço de vida...",ep:9,g:575,l:35,wd:true,fm:true,w:2,p:1};
I.u[2566] = {n:"Pedaço Mágico de Trunknid",t:15,d:"Este pedaço parece diferente dos outros de Trunknid. Quando foi cortado, uma luz brilhante vinda de outros Trunknid surgiu e depois desapareceu, deixando apenas este pedaço no chão.",ep:9,g:576,l:35,wd:true,fm:true,w:2,p:1};
I.u[2567] = {n:"Reflexos Super-humanos",t:29,d:"Esta bênção lhe deixará muito mais vívido em suas próximas lutas.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2568] = {n:"Reflexos Subumanos",t:30,d:"Esta bênção faz você entrar em um estado de semiconsciência;\r\n            seus reflexos ficam enfraquecidos para a próxima luta.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2569] = {n:"Pergaminho de Reflexos Super-humanos",t:14,d:"Este pergaminho o deixará mais aguçado para sua próxima luta.",ep:1,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2570] = {n:"Pergaminho de Reflexos Subumanos",t:14,d:"Este pergaminho deixará você um pouco inerte em um ponto durante a próxima luta.",ep:1,g:29,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2571] = {n:"Pata de Prespic",t:103,d:"Como um Prespic pode ser tão ágil com apenas duas patas? Isso continua sendo um mistério.",ep:1,g:577,l:18,wd:true,fm:true,w:1,p:1};
I.u[2572] = {n:"Estômago de Prespic",t:15,d:"‘Se você ficar comendo sempre a mesma coisa, cedo ou tarde você irá parecer o que você come\' foram as palavras do sábio Bontarian Hyu Hey. Agora nós entendemos o do estômago dos Prespic ser tão verde quanto à grama.",ep:1,g:578,l:18,wd:true,fm:true,w:1,p:1};
I.u[2573] = {n:"Rabo de Prespic",t:65,d:"O Prespic raramente usa seu rabo. De fato, o poder do seu rabo é surpreendente. Alguns Lenhadores até viram Prespics carregando pedaços de madeira com o rabo pela noite.",ep:1,g:579,l:18,wd:true,fm:true,w:1,p:1};
I.u[2574] = {n:"Juba de Prespic",t:15,d:"Para as festas de ‘O Olhar\', essa Juba é perfeita. Se você estiver perto de um seguidor de Osamoda, você certamente será confundido pela invocação dele.",ep:1,g:580,l:18,wd:true,fm:true,w:1,p:1};
I.u[2575] = {n:"Escalpo de Boolobo",t:15,d:"Quando o viu, o Boolobo certamente planejou fazer a mesma coisa que você, isto é, cortar com mais ou menos delicadeza seu couro cabeludo. Você foi mais rápido.",ep:1,g:581,l:70,wd:true,fm:true,w:1,p:1};
I.u[2576] = {n:"Escalpo de Miliboolobo",t:15,d:"Quando ele o viu, o Boolobo certamente pretendia fazer a mesma coisa que você... quer dizer, cortar mais ou menos delicadamente seu escalpo. Ele não queria aparecer para ninguém sem o topo de seu crânio.",ep:1,g:582,l:22,wd:true,fm:true,w:1,p:1};
I.u[2577] = {n:"Escalpo de Moolobo",t:15,d:"Quando o viu, o Boolobo certamente planejou fazer a mesma coisa que você, isto é, cortar com mais ou menos delicadeza seu couro cabeludo. Agora, ele deveria tomar cuidado para não pegar uma congestão nasal.",ep:2,g:583,l:198,wd:true,fm:true,w:1,p:1};
I.u[2578] = {n:"Olho de Boolobo",t:109,d:"Mesmo extraído, este Olho continua olhando ameaçadoramente para você. É quase como se ele o estivesse seguindo ...É muito impressionante.",ep:1,g:584,l:70,wd:true,fm:true,w:1,p:1};
I.u[2579] = {n:"Olho de Miliboolobo",t:109,d:"Mesmo arrancado, este olho parece ameaçador. Você quase poderia esperar uma piscada... é bem impressionante.",ep:1,g:585,l:22,wd:true,fm:true,w:1,p:1};
I.u[2580] = {n:"Olho de Moolobo",t:109,d:"Mesmo extraído, este Olho olha ameaçadoramente para você. Você quase pôde vê-lo franzir as sobrancelhas... É muito impressionante.",ep:2,g:586,l:198,wd:true,fm:true,w:1,p:1};
I.u[2581] = {n:"Dentes de Moolobo",t:47,d:"Na família Boolobo, se você quisesse aquele com os maiores dentes, seria este. ‘O melhor para babar em vocês, meus filhos.\'",ep:2,g:587,l:198,wd:true,fm:true,w:1,p:1};
I.u[2582] = {n:"Glândulas de Moolobo",t:15,d:"Considerando que o preço destas glândulas de Boolobo é extravagante e escandaloso, você logo entenderá que tem em mãos um enorme par de... lingotes.",ep:2,g:12,l:198,wd:true,fm:true,w:20,p:1};
I.u[2583] = {n:"Olho de Caranguejo",t:109,d:"Os que não gostam do mar são fãs deste Olho de Caranguejo só porque eles podem pegá-lo em terra firme.",ep:1,g:589,l:4,wd:true,fm:true,w:1,p:1};
I.u[2584] = {n:"Mão de Mushd",t:15,d:"Esta Mão de Mushd está coberta de lama, pelo menos é o que as pessoas pensam. Mas imagine que não há nada debaixo daquela lama, nem mesmo a mão do Mushd.",ep:2,g:590,l:19,wd:true,fm:true,w:1,p:1};
I.u[2585] = {n:"Coração de Lama de Mushd",t:15,d:"Por causa de seu Coração de Lama, o Mushd é difícil de classificar na cadeia alimentar. Mas se você pensar sobre isto, o Mushd certamente viria no fim da cadeia.",ep:2,g:591,l:19,wd:true,fm:true,w:1,p:1};
I.u[2586] = {n:"Asa de Dragossauro Gengibre Selvagem",t:104,d:"Esta Asa cheira a enxofre. Qualquer criador de Dragossauro vai dizer que é a parte mais macia para um churrasco. Só não esqueça de temperá-la porque a Asa é a parte mais sem sabor.",ep:2,g:592,l:29,wd:true,fm:true,w:1,p:1};
I.u[2587] = {n:"Machadinha de Lenhador",t:19,d:"Esta machadinha é a ferramenta ideal para qualquer lenhador. Não é muito útil (você não pode derrubar uma árvore com ela), mas sua presença presa ao cinto garante tranqüilidade e segurança.",ep:1,g:6,l:3,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,30,30,false,false],c:"CV>2",p:20};
I.u[2588] = {n:"Asa de Dragossauro",t:104,d:"O Dragossauro doméstico é bem mais gostoso do que seu primo selvagem. Ele não tem gosto de enxofre e a carne é deliciosamente saborosa. É por isso que ele é a comida favorita de todas as crianças.",ep:2,g:593,l:29,wd:true,fm:true,w:1,p:1};
I.u[2589] = {n:"Machadinha Hevlalav",t:19,d:"Este pequeno machado não serve para derrubar árvores, mas pode protegê-lo contra pequenos monstros. No entanto, você ainda terá de correr se encontrar um Minotoro.",ep:1,g:7,l:6,wd:true,fm:true,w:10,an:17,e:[10,4,1,1,40,40,false,false],p:60};
I.u[2590] = {n:"Machado Vôr\'Om",t:19,d:"Um dia, um aprendiz de Ferreiro de Bwork fez uma série de machados. Um deles bem equilibrado e bastante poderoso. Este Bwork simplesmente criou A arma para o jovem aventureiro. ",ep:1,g:13,l:12,wd:true,fm:true,w:15,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>10",p:120};
I.u[2591] = {n:"Cauda de Dragossauro Gengibre Selvagem",t:65,d:"A importância dessa cauda é bastante simples: ponha numa pedra redonda e gire a Cauda. Quando parar, siga a direção indicada por sua ponta. Era assim que os Sadidas a usaram durante séculos, indo de um ponto ao outro.",ep:2,g:594,l:27,wd:true,fm:true,w:1,p:1};
I.u[2592] = {n:"Cortador de Bombu",t:19,d:"Muito leve e fácil de manejar, este machado alivia os amplos gestos exigidos para cortar Bombu com segurança.",ep:13,g:15,l:39,wd:true,fm:true,w:1,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>20&CW>20",p:390};
I.u[2593] = {n:"Podador de Oliviolet",t:19,d:"Este machado, feito de Oliveira é o único capaz de resistir às ondas de choque violeta do Oliveira. O tipo de luta fogo contra fogo.",ep:14,g:14,l:42,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>60",p:420};
I.u[2594] = {n:"Cauda de Drago Dino",t:65,d:"Por incrível que pareça, o Rabo de Dragossauro não tem poder mágico. Como o Crocodyl, seu rabo cresce de novo rapidamente. Uma lenda também diz que um Dragossauro cresce na extremidade do seu rabo. Agora, você foi advertido.",ep:2,g:595,l:17,wd:true,fm:true,w:1,p:1};
I.u[2595] = {n:"Machado de Pedra",t:19,d:"Este machado é, apesar de tudo, eficiente... não para derrubar árvores, de qualquer forma...",ep:5,g:2,l:51,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>50&CV>60",p:510};
I.u[2596] = {n:"Leite de Dragossauro",t:15,d:"Os criadores apreciam o fato de ordenhar seus Dragossauros. O único problema é que eles não podem vender o Leite porque é revoltantemente nojento, então, eles o usam para alimentar jovens Dragossauros... é uma espécie de ciclo vicioso.",ep:2,g:424,l:29,wd:true,fm:true,w:1,p:1};
I.u[2597] = {n:"Machado de Fenda",t:19,d:"Este longo machado penetra nas fendas das árvores para dividi-las em duas. Seu uso é semelhante em lutas, já que inimigos sempre têm uma ou duas fendas que você poderá usar.",ep:14,g:16,l:54,wd:true,fm:true,w:20,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>70",p:540};
I.u[2598] = {n:"Pico de Dragossauro Gengibre Selvagem",t:47,d:"Este Pico é na verdade uma protuberância óssea. Como Dragossauros nunca o usam, as pessoas se perguntavam se ele podia ser tirado. Mas quando os cientistas os viam esfregá-lo contra os Trools, tudo fez sentido.",ep:2,g:596,l:29,wd:true,fm:true,w:1,p:1};
I.u[2599] = {n:"Cume de Dragossauro",t:47,d:"Localizado no dorso do Dragossauro, este Cume pode ser usado para arranhar sua virilha, desde que você possa montar um Dragossauro.",ep:2,g:597,l:29,wd:true,fm:true,w:1,p:1};
I.u[2600] = {n:"Cortador Estrondoso",t:19,d:"Este machado grande faz um barulho horrendo quando bate em algo, e deixa quem está por perto em silêncio. Seja quem for.",ep:14,g:17,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>30&CV>30&CA>30",p:660};
I.u[2601] = {n:"Machado de Darsson",t:19,d:"Darsson era um valente Enutrof, mas não era muito hábil com as mãos. Como ele freqüentemente dropava sua pá em lutas, ele decidiu amarrar um machado sobressalente em seu cinto. Isto salvou sua vida muitas vezes, até que ele dropou seu machado...",ep:14,g:18,l:57,wd:true,fm:true,w:15,an:17,e:[12,4,1,1,30,30,false,false],c:"CC>20&CA>20&CV>20",p:570};
I.u[2602] = {n:"Pétala de Glukoko",t:35,d:"Menor que um olho de caranguejo, a pétala de Glukoko é composta por numerosas bolhas pegajosas e esponjosas. Depois de uma tempestade, pode ser usada para tampar um buraco no telhado por onde a chuva passa.",ep:12,g:598,l:12,wd:true,fm:true,w:1,p:1};
I.u[2603] = {n:"Cortador de Partes",t:19,d:"Este machado é muito útil para separar partes difíceis de uma árvore, como as pequenas partes dilatadas dos troncos, especialmente quando você quer cortar uma árvore circular e lisa.",ep:13,g:2,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CS>30",p:660};
I.u[2604] = {n:"Bardiche de Homem da Milícia",t:19,d:"Esta bardiche é amplamente usada pelos homens da milícia de Amakna. Seu tamanho e eficiência, provavelmente, compensam as outras coisas.",ep:13,g:3,l:78,wd:true,fm:true,w:30,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>30&CS>30&CW>30&CC>5",p:780};
I.u[2605] = {n:"Pele de Glukoko",t:59,d:"Não fique surpreso se você for informado que a Pele de Glukoko cola. Você pode colar o que quiser no teto graças a ela. Nós devemos isto a um camponês que registrou uma patente para esta invenção, o nome dele era Rollio de Scautche.",ep:12,g:599,l:12,wd:true,fm:true,w:1,p:1};
I.u[2606] = {n:"Machadinha Inteligente",t:19,d:"Muitas inscrições podem ser lidas nesta grande machadinha. Elas evocam algumas noções básicas de Amakniano. Seu criador, Claus Ansipedi, pensou que seria bom trazer um pouco de cultura para aquelas rudes pessoas estúpidas. Que desperdício de tempo! Alguém rachou o crânio do pobre homem velho.",ep:4,g:4,l:81,wd:true,fm:true,w:30,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CA>50&CI>50",p:810};
I.u[2607] = {n:"Glukoko Morto",t:15,d:"Você fez a coisa certa ao coletar isto. Está intacto. Morto, mas intacto.",ep:12,g:600,l:14,wd:true,fm:true,w:10,p:1};
I.u[2608] = {n:"Francique Basquaise",t:19,d:"Este Machado dava, freqüentemente, uma volta pelo mundo, começando da parte inferior. Realmente, este tipo de machado é feito por uma pequena guilda de caçadores de tesouro conhecida por sua eficiência, no Sul de Amakna.",ep:18,g:1,l:84,wd:true,fm:true,w:18,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>100&CS>50",p:840};
I.u[2609] = {n:"Concha Verde Vazia",t:107,d:"Mas onde está o dono? Ele deve ter saído para comprar pão com tomate.",ep:7,g:601,l:24,wd:true,fm:true,w:2,p:1};
I.u[2610] = {n:"Concha Vermelha Vazia",t:107,d:"Mas onde está o dono? Ele deve ter se mudado recentemente.",ep:7,g:602,l:24,wd:true,fm:true,w:2,p:1};
I.u[2611] = {n:"Concha Amarela Vazia",t:107,d:"Mas onde está o dono? Talvez esteja tirando um cochilo dentro dela.",ep:7,g:603,l:24,wd:true,fm:true,w:2,p:1};
I.u[2612] = {n:"Machado de Pesca",t:19,d:"Este longo machado é usado por marinheiros peritos em lutar contra peixes gigantescos. Conseqüentemente, ele é realmente prejudicial aos pequenos monstros.",ep:14,g:4,l:87,wd:true,fm:true,w:32,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>50&CA>50",p:870};
I.u[2613] = {n:"Concha Azul Vazia",t:107,d:"Mas onde está o dono? Ele deve estar debaixo do chuveiro.",ep:7,g:604,l:24,wd:true,fm:true,w:2,p:1};
I.u[2614] = {n:"Machado de Dame Oise",t:19,d:"A Dama Oise era uma bela princesa que radiava ingenuidade e frescor. Durante uma invasão Bwork em sua cidade, ela surpreendeu todo mundo quando tirou este machado e destruiu metade dos inimigos sozinha.",ep:18,g:5,l:90,wd:true,fm:true,w:28,an:17,tw:true,e:[10,4,1,1,40,40,false,false],c:"CV>150&CW>50&CS>250",p:900};
I.u[2615] = {n:"Machado de Lookabeer",t:19,d:"Este machado é conhecido por liquidar rápido e definitivo, uma fila de Enutrofs eufóricos.",ep:18,g:8,l:96,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>120",p:960};
I.u[2616] = {n:"Inferno de Bardos",t:19,d:"Este machado deve seu nome ao teste feito para provar sua mortal eficiência: um machado gigantesco, um mitofóbico e um salão repleto de bardos.",ep:14,g:7,l:99,wd:true,fm:true,w:40,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>100&CS>100",p:990};
I.u[2617] = {n:"Pedaço de Kokonoz",t:15,d:"Haaaaahh... Finalmente algo que o lembre dos feriados. Esta agência de viagens mandou bem!",ep:12,g:605,l:14,wd:true,fm:true,w:1,p:1};
I.u[2618] = {n:"Kokocanudo",t:15,d:"Para tomar um gole fresco, você precisa de um canudo colorido. Agora, basta encontrar um buraco no Kokonoz...",ep:12,g:433,l:14,wd:true,fm:true,w:1,p:1};
I.u[2619] = {n:"Kokoleite",t:15,d:"Que boa idéia! Kokoleite em uma garrafa! Você pode bebê-lo onde e quando quiser.",ep:12,g:423,l:14,wd:true,fm:true,w:1,p:1};
I.u[2620] = {n:"Refresco de Qualidade",t:15,d:"Este refresco deve ter vindo de uma adega extremamente cara. A menos que tenha vindo de um frasco esquecido por muitas gerações na carteira de alguém.",ep:12,g:177,l:94,wd:true,fm:true,w:1,p:1};
I.u[2621] = {n:"Barba de Chouque",t:15,d:"Você arrancou a barba de Chouque do seu queixo. Muito estranho... Os dentes vieram com a barba, talvez por ele ter morrido muito tempo atrás.",ep:12,g:606,l:94,wd:true,fm:true,w:1,p:1};
I.u[2622] = {n:"Espiral de Chouque",t:15,d:"Do topo desta espiral, sete gerações de piratas o contemplaram.",ep:12,g:607,l:94,wd:true,fm:true,w:2,p:1};
I.u[2623] = {n:"Bwak Esquelético",t:15,d:"Criadores sempre acreditam que Bwaks voam no final de suas vidas... este Bwak deve ser uma exceção.",ep:12,g:608,l:94,wd:true,fm:true,w:1,p:1};
I.u[2624] = {n:"Folha de Kokoko",t:36,d:"Alguns caçadores ousados querem pegar a Folha de Kokoko como uma lembrança antes de deixarem a ilha. Não importa o preço a pagar... então, por quê não?",ep:12,g:609,l:42,wd:true,fm:true,w:1,p:1};
I.u[2625] = {n:"Boneca Vodu Thierry",t:15,d:"Uma força emana desta boneca e você tem a estranha sensação de que ela está chamando alguém.",ep:12,g:610,l:51,wd:true,fm:true,w:2,p:1};
I.u[2626] = {n:"Boneca Vodu Jav",t:15,d:"Uma força emana desta boneca e você tem uma sensação estranha de que se parece com alguém.",ep:12,g:611,l:51,wd:true,fm:true,w:2,p:1};
I.u[2627] = {n:"Boneca Vodu Sarbak",t:15,d:"Uma força emana deste boneco e você tem uma estranha impressão de que está ouvindo alguém.",ep:12,g:612,l:51,wd:true,fm:true,w:2,p:1};
I.u[2628] = {n:"Boneca Vodu Arqueira",t:15,d:"Uma força emana desta boneca e você tem o estranho pressentimento de que ela está esperando alguém.",ep:12,g:613,l:51,wd:true,fm:true,w:2,p:1};
I.u[2629] = {n:"Caracapa Minotoris",t:17,d:"Esta capa, que parece real, oferece uma proteção incrível. Ela fez a reputação de um renomado alfaiate que morreu vítima do seu sucesso, esmagado pela multidão.",ep:13,g:55,l:121,wd:true,fm:true,w:10,p:38500};
I.u[2630] = {n:"Pote de Greedovore",t:15,d:"O Greedovore em si não é muito generoso. Você terá muita sorte se este pote estiver cheio até a boca. Você precisa descobrir o que fazer com ele.",ep:12,g:614,l:44,wd:true,fm:true,w:1,p:1};
I.u[2631] = {n:"Estômago de Greedovore",t:15,d:"Este é o estômago mais resistente que você já viu. Tão elástico, você pode até mesmo esconder algo nele.",ep:12,g:615,l:44,wd:true,fm:true,w:1,p:1};
I.u[2632] = {n:"Refresco de Greedo",t:15,d:"Esta garrafa foi acidentalmente deixada dentro de um Greedovore e estranhamente o refresco melhorou. Não compartilhe sua descoberta com os camponeses ou os armazéns serão abastecidos de Greedovores.",ep:12,g:177,l:44,wd:true,fm:true,w:1,p:1};
I.u[2633] = {n:"Refresco Enganador",t:15,d:"Um truque enganador do Ambusher é para encher uma garrafa de refresco com... bem, refresco. Mas seu cheiro pode ser facilmente descoberto de longe: o cheiro de secou Glukoko.",ep:12,g:177,l:24,wd:true,fm:true,w:1,p:1};
I.u[2634] = {n:"Lança Quebrada",t:15,d:"O Emboscador se sentirá constrangido sem esta Lança. Ela permanece para ver se você será capaz de usá-la...",ep:12,g:616,l:24,wd:true,fm:true,w:2,p:1};
I.u[2635] = {n:"Pão de Qui Leure",t:33,d:"Danioul Garnioul, o padeiro, foi o rival de Xavier, o padeiro. Como as pessoas sempre se divertem com o nome ridículo, ele se vingou misturando a massa de farinha com seus pés. Esta receita agora está em suas mãos.",ep:1,g:13,l:80,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2636] = {n:"Pão Tahde",t:33,d:"Este Pão contém deliciosos pedacinhos de carne que têm gosto e aparência de galinha. E, além disso, se você aproximar este pão de seu nariz, sentirá o cheiro de Tofu.",ep:1,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2637] = {n:"A Garra",t:6,d:"Esta lâmina, feita de osso, chifre e cartilagem, e de forma curvada, é tão afiada quanto uma garra de Ecaflip.",ep:13,g:33,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[2638] = {n:"Garra Afiada",t:6,d:"100% natural, esta espada é a sexta garra da mão de um seguidor de Ecaflip. Cuidado para não arranhar seu nariz com ela!",ep:14,g:34,l:68,wd:true,fm:true,w:12,an:14,e:[12,4,1,1,30,50,false,false],c:"CV>30&CA>30&CS>30",p:6800};
I.u[2639] = {n:"Garra Falsa de Ceangal",t:6,d:"Uma ferreira Ecaflip criou esta espada depois de seu fracasso em dominar a técnica ancestral ‘Garra de Ceangal\'. Ela chamou sua espada ‘Falsa Garra de Ceangal\', feliz como ela foi para perceber que, ao menos, podia dominar algo.",ep:14,g:35,l:95,wd:true,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[2640] = {n:"Cajado de Carnívoro",t:4,d:"Estranhamente esculpido, este cajado não vem das redondezas. Ele cheira a lugares úmidos e escuros de Brakmar.",ep:1,g:24,l:30,wd:true,fm:true,w:56,an:12,e:[3,5,1,1,20,50,false,false],s:7,p:1000};
I.u[2641] = {n:"Toady",t:16,d:"Este chapéu vem em vermelho ou em branco e é incrivelmente elegante. Este chapéu irá assegurar que você seja considerado um encantador socialite e seja convidado para as elegantes festas do Embaixador. Quando você apertar as mãos do Embaixador, não se esqueça de agradecer e lhe dizer: ‘Embaixador, que você realmente está nos roubando... \'",ep:1,g:51,l:30,wd:true,fm:true,w:10,s:7,p:2700};
I.u[2642] = {n:"Maxilar de Rib",t:47,d:"O Rib ainda é pequenino e magrelo;\r\n            se no topo disso tudo, ele perde o maxilar, será tão ofensivo quanto um exército de cucos em hibernação.",ep:3,g:617,l:33,wd:true,fm:true,w:1,p:1};
I.u[2643] = {n:"Chifre de Dragão-Porco",t:47,d:"Este chifre pertence a um dos predadores mais famosos das montanhas de Amakna: o Dragão-Porco. Muitos caçadores estariam prontos para vender a família inteira só para comprar o que está em suas mãos. Esta é a oportunidade dos sonhos para você ter uma familía a um preço baixo!",ep:2,g:618,l:70,wd:true,fm:true,w:1,p:1};
I.u[2644] = {n:"Cauda de Dragão-Porco",t:65,d:"Este grande pedaço de Rabo de Dragão-Porco é um verdadeiro encanto. Frite-o com algumas Sementes de Gergelim, cubra tudo com Molho de guissa e seus convidados nunca sairão da sua casa, não é demais? Não? Oh, bem...",ep:2,g:619,l:70,wd:true,fm:true,w:1,p:1};
I.u[2645] = {n:"Focinho de Dragão Porco",t:15,d:"Por suposição, o Dragão Porco foi surpreendido pelo golpe. Pobre Dragão Porco!",ep:2,g:620,l:70,wd:true,fm:true,w:1,p:1};
I.u[2646] = {n:"Roupa de Porco de Leite",t:56,d:"Estas largas peças de roupa se adaptam aos Porcos de Leite, a costura está bem elástica e reforçada para o seu conforto durante os combates de perto. Como a tradição exige, esta peça de roupa não deve ser lavada porque se pode perder suas qualidades interiores – ainda desconhecidas, mas temidas apesar de tudo.",ep:1,g:621,l:20,wd:true,fm:true,w:1,p:1};
I.u[2647] = {n:"Orelhas de Porco de Leite",t:106,d:"Porcos de leite não são caçados pelas suas orelhas, mas pelos seus dentes. Mas quando não há dentes...",ep:1,g:623,l:20,wd:true,fm:true,w:1,p:1};
I.u[2648] = {n:"Garras de Kwak",t:15,d:"O Kwak não é um devorador de cadáveres, mas tem muita sujeira embaixo das unhas. Nós o pouparemos dos detalhes.",ep:1,g:624,l:30,wd:true,fm:true,w:1,p:1};
I.u[2649] = {n:"Verme da Terra",t:15,d:"Este verme da terra é o prato favorito de Kwaks selvagens. O mais estranho é que ele permanece vivo mesmo após ser extraído do estômago do Kwak.",ep:5,g:625,l:30,wd:true,fm:true,w:1,p:1};
I.u[2650] = {n:"Verme d\'Água",t:15,d:"Este verme d\'água é o prato favorito dos Kwaks selvagens. É a única coisa que permanece viva ao extrair do estômago do Kwak.",ep:1,g:626,l:30,wd:true,fm:true,w:1,p:1};
I.u[2651] = {n:"Verme do Fogo",t:15,d:"Este verme do fogo é o prato favorito de Kwaks selvagens. O mais estranho é que ele permanece vivo mesmo após ser extraído do estômago do Kwak.",ep:5,g:627,l:30,wd:true,fm:true,w:1,p:1};
I.u[2652] = {n:"Verme de Ar",t:15,d:"Este verme do ar é o prato preferido de Kwaks selvagens. O mais estranho é que ele ainda permanece vivo mesmo sendo extraído do estômago do Kwak.",ep:5,g:628,l:30,wd:true,fm:true,w:1,p:1};
I.u[2653] = {n:"Aracne Maior Morta",t:15,d:"Você fez bem em coletar isto, está intacta. Morta, mas intacta.",ep:1,g:629,l:43,wd:true,fm:true,w:10,p:1};
I.u[2654] = {n:"Ovos de Aracne Adulta",t:105,d:"Os problemas com Aracnes é que elas se reproduzem rapidamente quando o sol está brilhando. Deve ser uma loucura caminhar longe na Floresta de Treechnids durante dias quentes.",ep:1,g:630,l:43,wd:true,fm:true,w:1,p:1};
I.u[2655] = {n:"Cinto de Crowish",t:10,d:"Este cinto é um trabalho com retalhos feito com os restos do Lorde Corvo. Uma vez equipado com isto, você terá uma impressão maravilhosa de poder. O Chouque até aceitou emprestar a sua fivela para a ocasião.",ep:13,g:56,l:120,wd:true,fm:true,w:10,p:36938};
I.u[2656] = {n:"Fio Resistente",t:15,d:"Se os sapateiros e alfaiates soubessem da existência do Fio Resistente, certamente teriam inventado a Semana do Fio Resistente, a Feira do Fio Resistente e o Feriado do Fio Resistente.",ep:1,g:631,l:43,wd:true,fm:true,w:1,p:1};
I.u[2659] = {n:"Pétala de Girassol Selvagem",t:35,d:"Esta pétala se move. Move de acordo com o sol. Ponha-a no seu bolso direito de manhã;\r\n            na esquerda à noite.",ep:1,g:632,l:12,wd:true,fm:true,w:1,p:1};
I.u[2661] = {n:"Folha de Girassol Selvagem",t:36,d:"Esta parte do Girassol não é a única Folha da planta, é também o arco do seu pé. Não se surpreenda se tiver pés malcheirosos.",ep:1,g:633,l:12,wd:true,fm:true,w:1,p:1};
I.u[2662] = {n:"Saliva de Rosa Demoníaca",t:15,d:"Uma rosa furiosa tem o mau hábito de babar em quem ousa se aproximar dela. Mas parece ser um sinal de afeto. Uma furiosa, porém afetuosa Rosa Demoníaca, você já viu algo parecido com isto?",ep:1,g:634,l:8,wd:true,fm:true,w:1,p:1};
I.u[2663] = {n:"Fertilizante",t:15,d:"Qualquer bela planta necessita de fertilizante. É por isso que as Enutrofs em fase de envelhecimento não precisam disto.",ep:1,g:635,l:8,wd:true,fm:true,w:1,p:1};
I.u[2664] = {n:"Osso de Crocodyl",t:47,d:"Este estranho e esverdeado osso vem da pata do Crocodyl. O pobre animal certamente derramou lágrimas de crocodilo quando percebeu que uma de suas patas estava faltando.",ep:4,g:636,l:36,wd:true,fm:true,w:2,p:100};
I.u[2665] = {n:"Grama Selvagem",t:36,d:"É um tipo de Grama que você pega no chão do cercado do Gobball. Certamente é uma espécie Selvagem porque freqüentemente foge da cerca por conta própria. Bastante estranho para uma moita de Grama.",ep:1,g:637,l:9,wd:true,fm:true,w:1,p:1};
I.u[2666] = {n:"Casco de Minotoro",t:47,d:"O Minotoro, certamente, esmagou muitos aventureiros com este casco. Agora que só tem uma pata, ele deve parecer um tolo quando tenta lutar graciosamente. Ou ele parece estúpido ou perigoso.",ep:2,g:800,l:125,wd:true,fm:true,w:1,p:1};
I.u[2667] = {n:"Rabo de Minotoro",t:65,d:"É um milagre ver um rabo de Minotoro sem ver o próprio Minotoro. O pobre deve estar procurando por isto em todos os lugares. A menos que ele não esteja realmente ciente da situação, o que é possível.",ep:2,g:640,l:125,wd:true,fm:true,w:1,p:1};
I.u[2669] = {n:"Morcego",t:15,d:"Às vezes, os vampiros se transformam em morcegos quando eles querem fugir. O pior é que eles se sentem obrigados a dar uma pequena risada maléfica que é mais ou menos assim: ‘gnak gnook gnak gnak\'. Sua risada pode derrotar um exército... de carrapatos.",ep:3,g:641,l:21,wd:true,fm:true,w:1,p:1};
I.u[2673] = {n:"Ovo Podre",t:105,d:"Que vergonha! Como alguém pôde deixa um ovo de Tofu já em decomposição? Apenas pessoas malignas podem ter este tipo de idéia...",ep:1,g:642,l:3,wd:true,fm:true,w:1,p:1};
I.u[2674] = {n:"Abóbora Pequena",t:46,d:"Esta pequena abóbora é saborosa nesta estação. Grande o bastante para ser provada, pequena demais para evitar a transformação em Olantewn. Suculenta e reembolsada por Hellz Keir.",ep:4,g:643,l:15,wd:true,fm:true,w:1,p:1};
I.u[2675] = {n:"Pena de Tofu Maléfico",t:53,d:"O Tofu Maléfico não tem muitas Penas. Portanto, ele está arriscado a pegar um terrível resfriado. Não fique surpreso se você ouvi-lo espirrar à noite.",ep:1,g:644,l:3,wd:true,fm:true,w:1,p:1};
I.u[2676] = {n:"Olho Morot",t:15,d:"Você fez bem em coletar isto, está intacto. Morto, mas intacto.",ep:4,g:645,l:274,wd:true,fm:true,w:10,p:1};
I.u[2677] = {n:"Cinto Chouquish",t:10,d:"Este cinto foi feito com os pertences mais poderosos do Chouque, como a sua famosa cueca. É suficiente para mergulhar em confusão todas as piratas dos Piratas Trancam.",ep:12,g:41,l:98,wd:true,fm:true,w:10,p:25000};
I.u[2678] = {n:"Cinto de Kokokette",t:10,d:"Este cinto lembra uma tanga. Muito conveniente para camuflar-se entre os Kokokos da Ilha da Lua, ou mesmo para cortejar um deles.",ep:12,g:40,l:42,wd:true,fm:true,w:10,p:4800};
I.u[2681] = {n:"Cinto de Tartaruga Amarelo",t:10,d:"Este pequeno cinto é ideal para proteger contra golpes críticos as partes mais sensíveis. Antes de vesti-lo, não se esqueça de verificar se o dono da carapaça realmente foi removido pelo sapateiro. ",ep:7,g:43,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2683] = {n:"Cinto de Tartaruga Azul",t:10,d:"Este pequeno cinto é ideal para proteger contra golpes críticos as partes mais sensíveis. Antes de vesti-lo, não se esqueça de verificar se o dono da carapaça realmente foi removido pelo sapateiro.",ep:7,g:44,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2685] = {n:"Cinto de Tartaruga Verde",t:10,d:"Este pequeno cinto é ideal para proteger as partes mais sensíveis contra ataques críticos. Antes de vesti-lo, não se esqueça de verificar se o dono da carapaça realmente foi removido pelo sapateiro.",ep:7,g:42,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2687] = {n:"Cinto de Tartaruga Vermelho",t:10,d:"Este pequeno cinto é ideal para proteger as partes mais sensíveis contra ataques críticos.\nAntes de vesti-lo, não se esqueça de verificar se o dono da carapaça realmente foi removido pelo sapateiro.",ep:7,g:45,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2688] = {n:"Cinto Fedorento",t:10,d:"Após equipar-se com este cinto, é difícil perdê-lo, pelo menos é o que dizem! Os distraídos e as vítimas de roubo ficarão gratos....",ep:12,g:46,l:50,wd:true,fm:true,w:10,p:6600};
I.u[2689] = {n:"Cinto Banisação",t:10,d:"O sapateiro que criou este cinto usando os restos de um Dragossauro, certamente não tinha imaginação para dar-lhe um nome tão estúpido.",ep:2,g:47,l:29,wd:true,fm:true,w:10,p:2400};
I.u[2710] = {n:"Cinto Banisation Selvagem",t:10,d:"Modelo modificado do Cinto normal de Banisation, tem reforços de metal projetados especialmente para caçar Dragossauros Selvagens em Amakna.",ep:2,g:48,l:32,wd:true,fm:true,w:10,p:3000};
