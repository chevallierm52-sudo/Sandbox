I.u[6642] = {n:"Poderosa Espada Urandal",t:6,d:"Esta espada é uma recompensa dada apenas aos mais talentosos mercenários. Ela corta muito bem também.",ep:1,g:25,l:50,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[6643] = {n:"Sorvete de Mushden",t:42,d:"Este delicioso sorvete é feito usando-se métodos tradicionais da pequena fazenda Mushden. A fazenda tenta impor o mushd como um elemento básico na fabricação de sobremesas geladas.",ep:13,g:143,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:150};
I.u[6644] = {n:"Casquinha Wayal",t:42,d:"A parte superior do sorvete foi inspirada pelo famoso chapéu de Wa.",ep:13,g:144,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:120};
I.u[6646] = {n:"Sorvete de Bonta",t:42,d:"Este sorvete, uma mistura sutil dos sabores de frutas, é o resultado da ‘técnica dos anjos\'...Bem, é o que está escrito na caixa.",ep:13,g:145,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:90};
I.u[6647] = {n:"Magma de Brakmar",t:42,d:"Este sorvete, combinando ingredientes doces e crocante, mostra \"mais uma vez, a superioridade de Brakmar\"...Bem, de qualquer maneira, é o que está escrito na caixa.",ep:13,g:146,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:90};
I.u[6648] = {n:"Balão Vermelho",t:15,d:"Este balão é uma lembrança da Feira de Trool.",ep:13,g:690,l:1,wd:true,fm:true,w:1,p:15};
