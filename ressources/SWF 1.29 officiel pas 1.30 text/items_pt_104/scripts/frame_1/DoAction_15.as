I.u[6601] = {n:"Pó de Fada de Artifício",t:48,d:"Quando seus convidados começarem a ficar entediados, a melhor solução é usar as famosas Fadas de artifício. Você pode construir isto sozinho, graças a este pó e muitos outros ingredientes. Esta Fada dará uma atmosfera explosiva para sua festa.",ep:16,g:670,l:1,wd:true,fm:true,w:1,p:100};
I.u[6602] = {n:"Sangue de Rato Hyoativo",t:24,d:"As normas de segurança bontarianas exigem que você mantenha 100 passos de distância de uma substância Hyoativa. Se você não o fizer, o jogo ficará três vezes mais longo.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[6603] = {n:"Gobball Empalhado",t:61,d:"Este Gobball empalhado é a cara de um Gobball;\r\n            seus criadores deram até o mesmo cheiro a ele. Assim, não fique surpreso se você sentir um cheiro ruim logo de manhã.",ep:13,g:671,l:1,wd:true,fm:true,w:10,p:1};
I.u[6604] = {n:"Quaquack",t:18,d:"O Tofu, o Gobball ou mesmo Iops encontraram mais um equivalente em estupidez: o Quaquack!",ep:1,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[6605] = {n:"Gobball Real Empalhado",t:61,d:"Este Gobball empalhado é incrível, desde a costura até o enchimento, tudo foi bem pensado. É um presente excelente para crianças mimadas ou moleques ricos.",ep:13,g:672,l:1,wd:true,fm:true,w:10,p:1};
I.u[6606] = {n:"Sadida Dopple Empalhado",t:61,d:"Este Sadida Dopple empalhado tem um grande relógio despertador, muito útil para os discípulos de Sadida que têm dificuldade de acordar no horário. Não é aconselhável prendê-lo a um carpino, pois você perderá momentos preciosos.",ep:13,g:673,l:1,wd:true,fm:true,w:10,p:1};
I.u[6607] = {n:"Ecaflip Dopple Empalhado",t:61,d:"Este Ecaflip Dopple diverte Ecaflips de todas as idades.",ep:13,g:674,l:1,wd:true,fm:true,w:10,p:1};
I.u[6608] = {n:"Iop Dopple Empalhado",t:61,d:"Este Ecaflip Dopple parece um Iop de verdade. Tão estúpido com as palavras e sem nada na cabeça.",ep:13,g:675,l:1,wd:true,fm:true,w:10,p:1};
I.u[6610] = {n:"Sram Dopple Empalhado",t:61,d:"Este Sram Dopple empalhado foi roubado de um jovem Sram que o roubou de seus amigos...",ep:13,g:677,l:1,wd:true,fm:true,w:10,p:1};
I.u[6611] = {n:"Eniripsa Dopple Empalhado",t:61,d:"Este Eniripsa Dopple empalhado poderia quase voar, porém suas asas estão usadas. Não é novo, mas ainda assim é um belo presente.",ep:13,g:678,l:1,wd:true,fm:true,w:10,p:1};
I.u[6612] = {n:"Enutrof Dopple Empalhado",t:61,d:"Tenha cuidado, pois ele é muito pesado. É na verdade empalhado com pedras de bauxita e pepitas de ouro.",ep:13,g:679,l:1,wd:true,fm:true,w:10,p:1};
I.u[6613] = {n:"Feca Dopple Empalhado",t:61,d:"Este Feca Dopple é quase inquebrável, assim é perfeito para discípulos de Feca jovens e descuidados.",ep:13,g:680,l:1,wd:true,fm:true,w:10,p:1};
I.u[6614] = {n:"Osamodas Dopple Empalhado",t:61,d:"Dizem que um Osamodas Dopple empalhado pode invocar outros brinquedos se for corretamente guardado. É na verdade uma velha lenda para evitar que jovens discípulos de Osamodas o comam.",ep:13,g:681,l:1,wd:true,fm:true,w:10,p:1};
I.u[6615] = {n:"Cra Dopple Empalhado",t:61,d:"Este Cra Dopple empalhado é feito para jogar para seus companheiros, como um tipo de bumerangue que não volta.",ep:13,g:682,l:1,wd:true,fm:true,w:10,p:1};
I.u[6616] = {n:"Xelor Dopple Empalhado",t:61,d:"Este Xelor Dopple empalhado faz um barulho estranho. Tem um relógio em sua cabeça, um tipo de canção de ninar para que jovens discípulos de Xelor durmam mais rapidamente.",ep:13,g:683,l:1,wd:true,fm:true,w:10,p:1};
I.u[6617] = {n:"Javali Empalhado",t:61,d:"Este Javali empalhado curiosamente parece um Javali empalhado. Impressionante! Note que seus pêlos foram tirados de um javali de verdade. Certamente, um sinal de qualidade.",ep:13,g:684,l:1,wd:true,fm:true,w:10,p:1};
I.u[6618] = {n:"Tofu Empalhado",t:61,d:"Quem nunca sonhou em abraçar um Tofu contra o peito? Com este Tofu empalhado, finalmente será possível...",ep:13,g:685,l:1,wd:true,fm:true,w:10,p:1};
I.u[6619] = {n:"Cogu Empalhado",t:61,d:"Este Cogu não tem espinhos dolorosos nem veneno paralisante. Mas é terrível o bastante para amedrontar os Iops mais estúpidos.",ep:13,g:686,l:1,wd:false,fm:true,w:10,p:1};
I.u[6620] = {n:"Prespic Empalhado",t:61,d:"Este Prespic empalhado não tem espinhos e não pode ficar invisível. Porém, é um bom brinquedo e deixará seus amigos com inveja.",ep:13,g:687,l:1,wd:true,fm:true,w:10,p:1};
I.u[6621] = {n:"Wabbit Empalhado",t:61,d:"O Wabbit empalhado é indispensável, pois nunca sairá da moda. Diferentemente de você.",ep:13,g:688,l:1,wd:true,fm:true,w:10,p:1};
I.u[6622] = {n:"Chocalho de Dark Vlad",t:15,d:"Este chocalho pertenceu a Dark Vlad, o bastante para torná-lo inestimável mesmo para um modelo clássico.",ep:13,g:696,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6624] = {n:"Dragão Porco Empalhado",t:61,d:"Este Dragão Porco é único. Mas tenha cuidado, é destinado apenas para um público advertido.",ep:13,g:689,l:1,wd:true,fm:true,w:10,p:1};
I.u[6625] = {n:"Bilboquete do Lorde Corvo",t:15,d:"Este magnífico brinquedo pertenceu ao Lorde Corvo. Muito estúpido para entender como isso funcionava, ele o usou para esmagar seus queridos corvinhos. Todo mundo tem direito ao seu próprio passatempo.",ep:13,g:710,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6626] = {n:"Corda do Capitão Chafer",t:15,d:"Capitão Chafer usou esta corda para manter as juntas de seus dedos em forma. Desde que ele desapareceu de Amakna, ela tem passado de mão em mão.",ep:13,g:695,l:1,wd:true,fm:true,w:1,p:50};
I.u[6627] = {n:"Pequenas Fadas de Artifício Multicoloridas",t:74,d:"Estas fadas de artifício surpreenderão e deslumbrarão o mais apático de seus amigos. É mais recomendado usá-las na festa para celebrar a despedida de sua guilda.",ep:1,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:350};
