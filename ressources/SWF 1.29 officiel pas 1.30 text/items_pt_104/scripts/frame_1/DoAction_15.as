I.u[6652] = {n:"Bola da Feira do Trool",t:15,d:"Esta bela bola achará o seu lugar em uma abóbada sobre a lareira.",ep:13,g:694,l:1,wd:true,fm:true,w:1,p:15};
I.u[6653] = {n:"Ingresso para Feira do Trool",t:24,d:"Com este ingresso você pode entrar na feira...",ep:13,g:94,l:1,wd:true,fm:true,w:0,p:1};
I.u[6654] = {n:"Botas do Guardião do Esgoto",t:11,d:"O grande absurdo é que o Guardião do Esgoto foi devorado pela Guardiã do Esgoto. Ele foi digerido mais de 100 anos antes de, finalmente, morrer. Suas botas eram, felizmente, mais resistentes do que ele e ainda estão em boas condições.",ep:16,g:28,l:83,wd:true,fm:true,w:10,p:17800};
I.u[6655] = {n:"Sacola Surpresa da Sorte",t:89,d:"As pessoas que puseram esta sacola em sua conta são muito generosas. Isto também é a maneira de eles dizerem que gostam de você. (CLIQUE DUPLO PARA ABRIR A BOLSA)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6656] = {n:"Surprising Lucky Bag",t:89,d:"As pessoas que puseram esta sacola em sua conta são muito generosas. Isto também é a maneira de eles dizerem que gostam de você. (CLIQUE DUPLO PARA ABRIR A BOLSA)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6657] = {n:"Sacola da Troca",t:89,d:"ne pas traduire ce texte.",ep:1,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[6658] = {n:"Boolofo Empalhado",t:61,d:"Este Boolofo empalhado manterá você quente e espalhará um agradável cheio de suor de Boolobo morto pelo seu quarto.",ep:13,g:699,l:1,wd:true,fm:true,w:10,p:1};
I.u[6659] = {n:"Quaquack Falso",t:15,d:"Não confie nisto, é um falso Quaquack. Dê isto para Skroo Nossa, que está próximo à Tenda dos Patos. Você deve ser recompensado.",ep:1,g:700,l:1,wd:true,fm:true,w:1,p:1};
I.u[6660] = {n:"Chapéu de Noivo",t:16,d:"Você ficará irresistível com este chapéu. Abalará corações e conhecerá a glória!",ep:2,g:53,l:1,wd:true,fm:true,w:5,c:"PS=0",p:1000};
I.u[6661] = {n:"Vara de Pesca para Quaquack",t:20,d:"Com esta vara, você pode pescar um Quaquack na Feira de Trool.",ep:13,g:8,l:1,wd:true,fm:true,w:10,an:18,e:[0,10,1,1,50,2,false,false],p:1};
I.u[6662] = {n:"Chapéu de Noiva",t:16,d:"Este maravilhoso chapéu 100% seda de larva do Sul, lavável em água fresca, fará a sua amada derreter como uma geléia de menta no sol.",ep:2,g:54,l:1,wd:true,fm:true,w:5,c:"PS=1",p:1000};
I.u[6663] = {n:"Buquê de Rosas Demoníacas",t:6,d:"Com este maravilhoso buquê de Rosas Demoníacas, você mostrará à sua amada que está pronto para encarar 1.001 perigos pelo belo rostinho dela. Por uma modesta soma e sem um arranhão.",ep:2,g:47,l:1,wd:false,fm:true,w:3,an:14,e:[1,4,1,1,50,50,false,true],p:70};
I.u[6664] = {n:"Feitiço Especial \'Felintion\'",t:75,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe ensina o feitiço \"Felintion\"... para Ecaflips apenas.",ep:2,g:5,l:1,wd:true,fm:true,w:1,c:"PG=6",u:true,p:10000};
I.u[6666] = {n:"Pirulito de Tofu",t:42,d:"Este pirulito com aroma de Tofu é um encanto para suas papilas e um pesadelo catastrófico para o seu hálito.",ep:13,g:147,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:30};
I.u[6667] = {n:"Pirulito Trool",t:42,d:"Um pirulito realmente delicioso e infinito. Para ser consumido com seus amigos, de preferência.",ep:13,g:148,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6668] = {n:"Cachorro-quente de Tofu",t:42,d:"Com esta salsicha gorducha, você recuperará força suficiente para digerir todas as outras salsichas que comeu.",ep:13,g:150,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6669] = {n:"Trool Burguer",t:42,d:"Este impressionante hambúrguer poderia alimentar um exército de Chafers famintos. Consumir com moderação. O uso exagerado de Trool é perigoso.",ep:13,g:149,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:600};
I.u[6670] = {n:"Fritas de Girassol Selvagem",t:42,d:"Estas fritas são feitas com os talos do Girassol Selvagem. Então, são fritos em óleo de Girassol Selvagem, para que eles se sintam em casa enquanto fritam.",ep:13,g:151,l:1,wd:false,fm:true,w:1,u:true,p:300};
I.u[6671] = {n:"Feijão",t:58,d:"...",ep:1,g:471,l:1,wd:true,fm:true,w:1,p:1};
I.u[6672] = {n:"Farinha Xavier de Padeiro",t:52,d:"Esta farinha é excepcionalmente fina e leve. É tão macia que normalmente é usada para manter as traseiras de bebês de Iop secas. Depois de usada, dá muito mais gosto ao pão.",ep:1,g:250,l:100,wd:true,fm:true,w:1,p:0};
I.u[6673] = {n:"Pena de Tofu Preto",t:24,d:"Uma pena preta de Tofu Preto...",ep:1,g:96,l:1,wd:false,fm:true,w:0,p:1};
I.u[6676] = {n:"Espada Urandal",t:6,d:"Esta espada é uma recompensa dada aos melhores mercenários. Corta muito bem também.",ep:1,g:25,l:25,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[6677] = {n:"Poderosa Espada de Seriano-Kerm",t:6,d:"Esta é uma Espada de Recompensa dada somente aos hábeis aventureiros. Mas ela também corta muito bem.",ep:1,g:25,l:70,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:10};
I.u[6679] = {n:"Tufo de Cabelo de Feca",t:24,d:"Este tufo de cabelos pertencia a um Feca.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=1",p:1};
I.u[6680] = {n:"Tufo de Osamodas",t:24,d:"Um tufo de cabelo de Osamodas...",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=2",p:1};
I.u[6681] = {n:"Tufo de Pêlos de Enutrof",t:24,d:"Este tufo pertencia a um Enutrof.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=3",p:1};
I.u[6682] = {n:"Tufo de Pêlo de Sram",t:24,d:"Este tufo de pêlo pertenceu a um Sram.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=4",p:1};
I.u[6683] = {n:"Tufo de Cabelo de Xelor",t:24,d:"Este tufo de cabelo pertenceu ao Xelor.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=5",p:1};
I.u[6684] = {n:"Tufo de Ecaflip",t:24,d:"Este tufo de cabelos pertenceu a um Ecaflip.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=6",p:1};
I.u[6685] = {n:"Tufo de Eniripsa",t:24,d:"Este tudo de cabelos pertencia a uma Eniripsa.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=7",p:1};
I.u[6686] = {n:"Tufo de Pêlo de Iop",t:24,d:"Este tufo de pêlo pertenceu a um Iop.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=8",p:1};
I.u[6687] = {n:"Tufo de Cra",t:24,d:"Este tufo de cabelos pertenceu a um Cra.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=9",p:1};
I.u[6688] = {n:"Tufo de Pêlo de Sadida",t:24,d:"Um tufo de pêlo de Sadida.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=10",p:1};
I.u[6689] = {n:"Tufo de Pêlo de Sacrier",t:24,d:"Um tufo de pêlo de Sacrier.",ep:1,g:30,l:1,wd:false,fm:true,w:0,c:"PG=11",p:1};
I.u[6690] = {n:"Par de tesouras danificadas",t:80,d:"Um par básico de tesouras danificadas, nada mais ...",ep:1,g:33,l:1,wd:true,fm:true,w:2,ut:true,p:1};
I.u[6706] = {n:"Bandagem de Muúmia Nova",t:15,d:"Estas bandagens são tão velhas quanto o seu dono, que é tão velho quanto as suas bandagens. Com o passar do tempo, elas ficaram ensopadas com os poderes mágicos da Múmia Nova, mas também com seu cheiro de carne em decomposição.",ep:1,g:712,l:150,wd:true,fm:true,w:1,p:1000};
I.u[6707] = {n:"Manto de Múmia Nova",t:17,d:"Este manto malcheiroso é feito com algumas bandagens malcheirosas de Múmia Nova. Suficiente para excitar todos os habitantes dos cemitérios das redondezas.",ep:14,g:63,l:75,wd:false,fm:true,w:10,p:14600};
I.u[6708] = {n:"Dopple",t:24,d:"Este certificado indica sua última vitória sobre um Dopple.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6712] = {n:"Capa de Chifre",t:17,d:"Esta capa magnífica cheira a flores da floresta. Não é o bastante para fazer Craette se apaixonar por você, mas é o suficiente para ocultar o cheiro de um Sadida imundo.",ep:1,g:82,l:71,wd:true,fm:true,w:10,p:13100};
I.u[6713] = {n:"Adagas de Lordsoth",t:5,d:"Ensopadas com o sangue do terrível Lordsoth, estas adagas ajudaram a derrubar o Rei Chafer durante a famosa prova de arremesso de adagas no Parque Troolmusement. O Rei Chafer jamais ousou se exibir novamente, já que se exilou com o ilustre Capitão Chafer nos arredores do cemitério de Pandala.",ep:1,g:34,l:100,wd:false,fm:true,w:10,an:13,e:[10,3,1,1,30,30,false,false],c:"PN~Lordsoth",p:1};
I.u[6716] = {n:"Nomoon",t:18,d:"Este macaquinho gatuno parece gostar de você agora. Ele é muito dócil, mas também é muito exigente com a comida que lhe é dada. Ele só comerá coisas que crescem em sua ilha.",ep:3,g:11,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6717] = {n:"Auau Preto",t:18,d:"Você saboreará a alegria de levar o cachorro para fazer xixi, graças a este cãozinho. Eu não posso aconselhá-lo com veemência a alimentá-lo pelo medo de perder uma mão, pois esta criatura tem raízes selvagens.\n(ESTE LEGENDÁRIO ANIMAL DE ESTIMAÇÃO NÃO PRECISA COMER)",ep:1,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6718] = {n:"Miau Branco",t:18,d:"Esta pequena bola de pêlo maldosa e fofa faz as mulheres de todas as classes ficarem loucas. Portanto, um animal temível.\n(ESTE ANIMAL LENDÁRIO NÃO PRECISA COMER)",ep:1,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6719] = {n:"Elmo de Urso",t:16,d:"Este elmo pertenceu ao notório Homem-Urso. Costurado a partir dos restos da cabeça de um urso em decomposição, o elmo lhe permitirá chamar atenção;\r\n            mas, acima de tudo, graças ao seu cheiro incomum, que deixará um rastro de sua passagem.",ep:1,g:64,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6720] = {n:"Manto do Homem-Urso",t:17,d:"Este belo manto foi usado durante anos pelo famoso Homem-Urso. Ele não fará de você um urso, mas lhe permitirá competir com os maiores lutadores.",ep:8,g:58,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6721] = {n:"Botas do Homem-Urso",t:11,d:"Estas botas são acolchoadas com pele de urso: ideais para manter aquecidos até os pés dos companheiros de sangue-frio.",ep:2,g:51,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6722] = {n:"Aliança do Homem-Urso",t:9,d:"O Homem-Urso nunca tirou esta aliança, apesar de sua esposa ter sido devorada na sua frente por um dos ursos que ele acabara de invocar, justamente para impressionar a sua amada. Ela realmente ficou muito impressionada.",ep:1,g:66,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6723] = {n:"Colar do Homem-Urso",t:1,d:"O Homem-Urso estava usando este amuleto em volta do pescoço, quando enfrentou os sustenidos da toca de Bimdhul. Diz a lenda que ele foi salvo pelo amuleto... Olhando de perto, é fácil perceber que a lenda não é totalmente verdadeira.",ep:1,g:74,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6724] = {n:"Cinto do Homem-Urso",t:10,d:"Este pequeno cinto, coberto de pêlos de urso, esconde perfeitamente seus punhados de amor. Você devia usá-lo sempre, para evitar desapontar a sua amada.",ep:1,g:66,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6725] = {n:"Cajado do Homem-Urso",t:4,d:"O Homem-Urso usava este cajado para domesticar suas invocações de urso. E, de vez em quando, para bater nos dedos dos filhos, quando eles não faziam os deveres de casa. Aqui está um homem que entendia tudo de educação.",ep:14,g:46,l:20,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CA>50&CV>50",s:12,p:1300};
I.u[6731] = {n:"Kwakamuleto de Gelo",t:1,d:"Com este amuleto em volta de seu pescoço, você ficará tentado a fazer as pessoas acreditarem que você tem um hálito fresco. Esqueça, é uma perda de tempo.",ep:1,g:71,l:42,wd:true,fm:true,w:3,s:13,p:4900};
I.u[6732] = {n:"Kwakanel de Gelo",t:9,d:"Este pequeno anel foi há muito tempo desejado pelos Enutrofettes como artigo de decoração. Um jeito perfeito de esconder suas verrugas.",ep:1,g:63,l:42,wd:true,fm:true,w:2,s:13,p:4900};
I.u[6735] = {n:"Raiz de Emboscada",t:98,d:"Esta minúscula raiz personifica perfeitamente a traição. Ninguém sabe por que, mas todos sabem disso.",ep:12,g:96,l:22,wd:true,fm:true,w:5,p:200};
I.u[6736] = {n:"Botão de Emboscada",t:108,d:"Este pequeno broto de Emboscada contém uma seiva pegajosa e melosa. Se tiver o infortúnio de caminhar sobre uma velha Ambusher oculta na grama alta, você pode permanecer preso até que ela devore completamente suas botas. Por outro lado, se conseguir pegar um broto intacto de Ambusher, você poderá silenciar um Feca resmungão dando isso para ele como goma de mascar.",ep:12,g:97,l:22,wd:true,fm:true,w:5,p:1};
I.u[6737] = {n:"Casca de Emboscada",t:96,d:"A Emboscada não tem nenhum galho verdadeiro, como qualquer árvore que se preze. Entretanto, ela tem uma fina casca que é bastante robusta e coberta por um vasto número de saliências. Muito prática para criar cabos de ferramentas que não deslizem entre os dedos, ou para bater nas costas das crianças mais insolentes. Em ambas as situações, você ficará completamente satisfeito, se for você quem estiver segurando o cabo.",ep:12,g:98,l:22,wd:true,fm:true,w:5,p:200};
I.u[6738] = {n:"Crânio do Chefe Crocodyl",t:47,d:"Este enorme crânio é um testemunho da deplorável higiene dental do Chefe Crocodyl. O engraçado é que isto ainda parece conter algum poder mágico, já que é ainda habitado pela alma do Chefe Crocodyl. Às vezes, ele até deixa cair algumas lágrimas de Crocodyl se você for muito mau com ele.",ep:4,g:637,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6739] = {n:"Pele de Crocodyl",t:59,d:"Realmente, conseguir um pedaço completo de pele de Crocodyl é quase um milagre. A maior parte do tempo, os caçadores ilegais só coletam algumas poucas escamas. Ideal fazer sacolas, esta pele velha também será apreciada por alfaiates que fazem roupas íntimas de luta.",ep:4,g:601,l:36,wd:true,fm:true,w:10,p:1000};
I.u[6740] = {n:"Pele do Chefe Crocodyl",t:59,d:"Esta pele, constituída de muitas escamas, é superior a qualquer outra pele clássica de Crocodyl. Realmente, o lado externo da pele do Chefe Crocodyl é mais resistente e coberto com escamas perigosamente afiadas, enquanto o lado interno é particularmente macio. Conta-se que alguns alfaiates velhos confundem um lado com o outro na hora da confecção de roupa íntima. A história não diz se eles conseguiram mais ou menos clientes como resultado...",ep:4,g:600,l:69,wd:true,fm:true,w:10,p:1000};
I.u[6741] = {n:"A Bandana Invisível",t:16,d:"Esta bandana é inútil.",ep:0,g:75,l:200,wd:false,fm:true,w:0,p:1};
I.u[6742] = {n:"Amuleto Enganador",t:1,d:"Este amuleto é feito de uma mistura de folhas de Emboscador e lixo da Ilha da Lua. Parece mais com uma guirlanda do que com um verdadeiro amuleto, mas ele lhe permitirá seduzir facilmente a fauna local da Ilha da Lua, composta quase exclusivamente de criaturas abomináveis. Assim, nenhum Emboscador resistirá a você, todos eles saltarão em seus braços para lhe dar um chupão. Os mais azarados no amor serão capazes de ficar satisfeitos com o amuleto.",ep:12,g:69,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6743] = {n:"Aliança Enganadora",t:9,d:"Pegue algumas folhas de Emboscador, empilhe-as, deixe-as macerar em energético estragado, perfure-as, beba o energético que sobrou, prenda as folhas em volta de um pedaço de casca, fixe alguns pedaços de folha de Kokoko com um material pegajoso, e aqui está a magnífica Aliança Enganosa. Ela tem um odor ruim e será muito útil para justificar o cheiro de todos os seus dedos, se você tiver a tendência de colocá-los em todos os lugares. Especialmente onde você não devia.",ep:12,g:60,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6744] = {n:"Botas de Emboscada",t:11,d:"Quando experimentar estas botas, você não será mais capaz de se desfazer delas. Não porque elas são excepcionais, mas porque são excepcionalmente pegajosas. Uma característica que elas compartilham freqüentemente com as Ambushers fêmeas...",ep:12,g:47,l:34,wd:true,fm:true,w:5,s:16,p:3200};
I.u[6745] = {n:"Cinto Enganador",t:10,d:"Excelente trabalho manual feito com restos de Emboscadores e lixo coletado ao longo das praias da Lua. No meio da espuma imunda, este cinto, quando vestido só, lhe dará um aspecto realmente assombroso. Suficiente para desconcertar seus inimigos ou surpreender a sua amada, você poderá se aproveitar desse momento especial quando, pelo menos uma vez, tiver a vantagem.",ep:12,g:62,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6746] = {n:"Kwakamuleto da Terra",t:1,d:"Oto Mustam, o líder dos guerreiros de Brakmar, usou este amuleto pequeno há muito tempo e ele só o usou para se vestir bem para orgias organizadas em Brakmar.",ep:5,g:72,l:42,wd:true,fm:true,w:3,s:14,p:4900};
I.u[6747] = {n:"Kwakmuleto do vento",t:1,d:"Quando batem rajadas de vento nas suas penas, o Kwak do Vento sente-se livre como um pássaro, e desliza como uma velha folha morta carregada pelo vento. Apesar das aparências, é bastante impressionante.",ep:5,g:70,l:42,wd:true,fm:true,w:3,s:15,p:4900};
I.u[6748] = {n:"Kwakanel da Terra",t:9,d:"Criteriosamente usado, este anel permitirá que você deixe seus dedos gordos mais atrativos. Infelizmente, só funciona nos dedos.",ep:5,g:64,l:42,wd:true,fm:true,w:2,s:14,p:4900};
I.u[6749] = {n:"Kwakanel do Vento",t:9,d:"Este anel é tão leve que ao soprar do vento ele pode voar por aí. Mas não conte com isso, mas se acontecer, você não irá junto a ele. Na pior das hipóteses você vai arrancar grandes gargalhadas.",ep:5,g:62,l:42,wd:true,fm:true,w:2,s:15,p:4900};
I.u[6750] = {n:"Kwaklâmina de Gelo",t:6,d:"Fria e afiada, esta lâmina reviverá os instintos primários de quem possuí-la.",ep:1,g:51,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CC>50&CV>50",s:13,p:4600};
I.u[6751] = {n:"Kwakamina da Terra",t:6,d:"‘Esta lâmina afiada será perfeita para aventureiros experientes que procuram por novas emoções.\' Esta descrição pode ser lida no manual desta espada. Manuais não são mais como antes.",ep:5,g:53,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>50&CV>50",s:14,p:4600};
I.u[6752] = {n:"Kwakamina do Vento",t:6,d:"Ideal para cortar nuvens, esta lâmina também tem capacidade de criar uma brisa se você não tiver ventilador. É uma técnica excelente para dizimar os Moskitos ou bagunçar o rosto dos amigos.",ep:5,g:50,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CA>50&CV>50",s:15,p:4600};
I.u[6753] = {n:"Kwakabotas de Gelo",t:11,d:"Tão perfeito quanto esquis de gelo para deslizar por lagos congelados, estas botas são muito úteis para manter seu pé quente ou armazenar seu lanche durante os dias quentes. Entretanto, não é recomendável secá-las através do fogo ou você poderá não as ver de novo.",ep:2,g:36,l:40,wd:true,fm:true,w:5,s:13,p:4400};
I.u[6754] = {n:"Kwakbotas da Terra",t:11,d:"‘Nada é melhor que Kwakbotas da Terra para caminhar pelo solo\', disse Rola Ingalsse, famosa lavradora, um pouco antes de ela ficar cega quando um monte de terra foi jogador em seus olhos.",ep:5,g:49,l:40,wd:true,fm:true,w:5,s:14,p:4400};
I.u[6755] = {n:"Kwakbotas do Vento",t:11,d:"Simples mas eficientes estas botas do vento, antes de serem reformadas, eram birutas que indicavam a direção do vento. É aconselhado ficar no lado certo da biruta para não morrer sufocado.",ep:5,g:48,l:40,wd:true,fm:true,w:5,s:15,p:4400};
I.u[6756] = {n:"Kwape da Terra",t:17,d:"Ideal para se camuflar em um monte de terra, este manto permitirá que você atraia lavradores pela surpresa e roube seus tesouros. ",ep:8,g:64,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6757] = {n:"Kwapa do Vento",t:17,d:"Leve e refinada, com a criação deste acessório pode ser usada como uma cortina pelas pessoas mais desamparadas. Há muito tempo ela era muito cogitada pela Múmia Nova, que quis sair bem vestida à noite. Ótima para seguir as pessoas.",ep:8,g:62,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6758] = {n:"Kwacar da Terra",t:10,d:"O Kwacar da Terra não é muito sociável e é especialmente caçado por suas penas, todo o mundo sabe isso. Se você usar este cinto, estará exposto à deslealdade dos caçadores, que pensarão, de longe, que você é um Kwacar doente e decadente.",ep:12,g:65,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6759] = {n:"Kwaktura do Vento",t:10,d:"‘Pra pegar um Kwak de Vento desanimado é só disfarçar como um Kwak de Vento fêmea e mandar um oizinho! Agora você sabe o que deve ser feito.",ep:12,g:63,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6760] = {n:"Touca de Kwak da Terra",t:16,d:"Esta touca de Kwak da Terra é tão pesada que você sempre manterá seus pés no chão. Mas ela também fará que você caia às vezes. Você não pode ter tudo.",ep:13,g:71,l:41,wd:true,fm:true,w:25,s:14,p:4600};
I.u[6761] = {n:"Kwakocar do Vento",t:16,d:"Para manter o seu cabelo com o vento só mesmo com um cocar, não há nada como este lindo Kwakocar do Vento que certamente capacitará você a dar asas a seu cabelo. O suficiente para surpreender o mais indiferente dos Chafers.",ep:13,g:69,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6762] = {n:"Ápice de Emboscada",t:4,d:"‘Para uma luta, nada melhor que o ápice de Emboscada.\' Isto é o que podia ser lido em um folheto de publicidade da Equipe-A Agência de Viagens, que propõe a seus clientes reconstruírem, eles mesmos, seus cajados com vários recursos espalhados pela Ilha da Lua. Uma espécie de caça ao tesouro, só que sem mapas.",ep:12,g:44,l:32,wd:true,fm:true,w:5,e:[15,4,1,1,20,70,false,false],s:16,p:2900};
I.u[6763] = {n:"Emboscada Podre",t:17,d:"Diz a história que as Emboscadas mortas ficam muito confortáveis uma vez que passam o tempo apodrecendo debaixo do sol. Realmente, elas ficam muito mais flexíveis e suaves com o tempo. Muitos aventureiros diriam o mesmo de suas amadas.",ep:12,g:61,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6764] = {n:"Elmo Emboscada",t:16,d:"Este elmo não o faz parecer esperto. Mas você ainda parece menos estúpido com ele. Então, mantenha-o na cabeça!",ep:12,g:68,l:31,wd:true,fm:true,w:5,s:16,p:2800};
I.u[6765] = {n:"Leileite",t:79,d:"Atenção! Como especificado claramente na embalagem, você não deve dar Leileite para um Miau Jovem ou ele borrará seu lar doce lar.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:4};
I.u[6766] = {n:"Orelhas de Farle",t:1,d:"Este amuleto aparentemente básico foi feito com três espigas mágicas de Milho, cobertas com pó de pedra preciosa, e colhidas nas planícies de Snossios durante a décima terceira colheita de Istrabraq. Ele dá uma incrível coragem ao seu portador, que é agora capaz de colher em planícies e vales sem falhar.",ep:1,g:68,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6767] = {n:"Pulseira Mágica de Farle",t:9,d:"Esta pulseira feita de pedras preciosas foi coberta com um pano de Sarraceno por Shika, a fim de evitar chamar a atenção dos Corvos, quando Farle estava semeando seu Amaranto.",ep:13,g:61,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6768] = {n:"Soki",t:32,d:"Leve este miserável Miau com você para entretê-lo.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[6769] = {n:"Cajado de Farle",t:4,d:"Este magnífico cajado tem belos dentes em sua extremidade, o que faz disso uma excelente forquilha. Farle o usou para formar enormes montes de feno - mais altos que o maior Olmo crescente, eras atrás, na floresta de Eltneg. Dizem que o próprio Brouce Boulgoure cortou a madeira necessária para a fabricação deste cajado, em troca de enormes porções diárias de flocos de aveia, oferecidas por Shika Ingalsse. Ele costumava engoli-los antes de desmatar florestas inteiras.",ep:14,g:43,l:80,wd:true,fm:true,w:10,an:12,tw:true,e:[10,5,1,1,45,45,false,true],c:"CS>100&CV>100",s:17,p:16500};
I.u[6770] = {n:"Cacamundongo",t:15,d:"Este Cacamundongo foi expulso da casa da Vovó por uma vassoura.",ep:1,g:282,l:1,wd:true,fm:true,w:10,p:1};
I.u[6771] = {n:"Anel de Chá",t:9,d:"Este anel ainda não demonstrou a sua capacidade. É uma criação sem igual feita por um aprendiz de joalheiro para um importante teste. Ele é feito de um anel comum de ferro mergulhado em uma solução de Chá mágico.",ep:1,g:1,l:4,wd:false,fm:true,w:1,p:50};
I.u[6773] = {n:"Amuleto Tude",t:1,d:"Este amuleto foi feito ao modo Tude, de onde vem seu nome. É um dos mais antigos métodos de criação, porque ele é o mais simples e, por isso, é ensinado aos aprendizes de joalheiro. É verdade que o produto não é muito poderoso, mas você não pode pedir demais, não é?",ep:1,g:19,l:1,wd:false,fm:true,w:1,p:25};
I.u[6774] = {n:"Cascos de Farle",t:11,d:"Estes cascos foram esculpidos em madeira rara, reforçados com pedaços de couro de um valor inestimável, e acolchoados com cereais mágicos. Leve, elegante e confortável, estes cascos resistirão aos tormentos do tempo. Muitos aventureiros misóginos reclamam que gostariam de poder dizer o mesmo sobre sua amada.",ep:9,g:46,l:80,wd:true,fm:true,w:10,s:17,p:16600};
I.u[6775] = {n:"Capa de Farle",t:17,d:"Esta capa feita de tecido e couro permitiu que Farle Ingalsse semeasse campos inteiros durante toda uma estação sem ter de parar. Realmente, uma vez dobrada e usada como sacola, sua capacidade parece ser quase ilimitada. Ninguém realmente sabe quem é o alfaiate por trás dessa maravilha. A história só conta que ele se aposentou quando os clientes começaram a misturar seus mantos com panos de chão. Que coisa triste antes da aposentadoria!",ep:13,g:70,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6776] = {n:"Farlecinto",t:10,d:"Farle Ingalsse também usou este cinto como um avental de açougueiro quando ele tinha que degolar seus rebanhos de Gobball. Uma cruel e insatisfatória tarefa da qual ele próprio se livrou com evidente prazer.",ep:4,g:61,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6778] = {n:"Chapéu de Palha de Farle",t:16,d:"Este chapéu de palha foi feito com várias espigas mágicas trançadas e é acolchoado por dentro com vários tipos de pêlos e tecidos costurados à mão pela esposa de Farle, Shika Ingalsse. Superior ao Ninnish e mais elegante do que o Doddgy, este chapéu o protegerá do calor assim como protegeu Farle durante as centenas de colheitas que ele fez. Além disso, lhe dará um olhar jovial e realmente bacana. Suficiente para agir como um rei ou uma rainha dos campos.",ep:13,g:67,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6779] = {n:"Relatório do Espião Sram",t:24,d:"Relatório do espião Ztiv Oztin, foi tirado com muita dificuldade das mãos de Joe Pierlivet.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6780] = {n:"Espada de Iniciado",t:6,d:"Esta arma de aparência rudimentar fará você se sentir como alguém que sabe como lutar.",ep:1,g:96,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6781] = {n:"Varinha Mágica de Iniciado",t:3,d:"Esta arma de aparência rudimentar fará você se sentir como alguém que sabe como lutar.",ep:1,g:8,l:1,wd:true,fm:true,w:10,an:11,e:[5,4,2,3,50,50,false,true],p:1};
I.u[6782] = {n:"Cajado de Iniciativa",t:4,d:"Com esta arma de aparência rudimentar, você sentirá como se soubesse lutar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6783] = {n:"Arco de Iniciado",t:2,d:"Esta arma de aparência rudimentar fará você se sentir como alguém que sabe lutar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,6,50,50,false,true],p:1};
I.u[6784] = {n:"Adaga de Iniciativa",t:5,d:"Com esta arma de aparência rudimentar, você sentirá como se soubesse lutar.",ep:1,g:10,l:1,wd:true,fm:true,w:10,an:13,e:[5,3,1,1,30,50,false,false],p:1};
I.u[6785] = {n:"Martelo de Iniciado",t:7,d:"Esta arma de aparência rudimentar fará você se sentir como alguém que sabe como lutar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:15,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6786] = {n:"Pá de Iniciado",t:8,d:"Esta arma de aparência rudimentar fará você se sentir como alguém que sabe como lutar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6787] = {n:"Cartão Preenchido e Válido",t:80,d:"Este cartãozinho contém o nome de um candidato potencial a tornar-se o entregador do padeiro.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW>1499&CA>49",p:0};
I.u[6788] = {n:"Bolos",t:24,d:"Estes bolos acabaram de sair do forno. Você tem de entregá-los enquanto ainda estão quentes. Você realmente acha que tem tempo para examiná-los bem?",ep:1,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[6789] = {n:"Amuleto dos Campos",t:1,d:"Este pequeno amuleto floresce na primavera, mas seca totalmente no verão, enfraquece no outono e apodrece no inverno. Uma oportunidade ideal para mudar o seu estilo com o passar das estações.",ep:1,g:73,l:10,wd:false,fm:true,w:5,s:18,p:500};
I.u[6790] = {n:"Formulário para preencher",t:80,d:"Este formulário parece uma simples folha de papel. Entretanto, quando alguém o toca, o contato com a pele faz ele descobrir imediatamente se a pessoa se encaixa nos critérios mencionados no cabeçalho.",ep:1,g:6,l:1,wd:false,fm:true,w:0,ut:true,p:0};
I.u[6791] = {n:"Anel do Condado",t:9,d:"Com este pequeno anel no dedo, você pode tentar passar quase despercebido no meio dos campos.",ep:1,g:65,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6792] = {n:"O Plantador dos Campos",t:4,d:"Este cajado em forma de flor foi feito dos restos de flores selvagens que morreram durante batalhas horríveis e cruéis. A raiva e ódio sentidos por estas pobres flores estão contidos neste cajado ridiculamente pequeno. Esta arma é usada pelos mais traiçoeiros Srams, que tentam convencer as ingênuas mulheres de que eles pretendem lhes oferecer um buquê de flores. Uma vez ao alcance das mãos delas, ele pode acabar danificado, bata repetidamente na cabeça.",ep:1,g:45,l:10,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,45,50,false,false],c:"CV>20",s:18,p:500};
I.u[6793] = {n:"Anel de Chá",t:9,d:"Este anel demonstrou a sua capacidade, como comprova a marquinha feita no seu interior. É uma criação sem igual feita por um aprendiz de joalheiro para um importante teste. Ele é feito de um anel comum de ferro mergulhado em uma solução de Chá mágico.",ep:1,g:1,l:4,wd:true,fm:true,w:1,p:50};
I.u[6794] = {n:"Botas Campestres.",t:11,d:"Não há nada melhor do que estas botas - foram feitas com restos de flores selvagens - esmagarem as miseráveis flores que crescem nos campos. Além do mais, estas botas permitirão que seus pés exalem um aroma florido cheiroso. É uma pena, tinha de estar disponível como calção...",ep:1,g:50,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6795] = {n:"Manto Violeta",t:17,d:"Se você quer ser a rainha da noite e sair para dançar, é deste manto que você precisa.",ep:1,g:65,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6796] = {n:"Cinto Florido",t:10,d:"Com este cinto, decorado com pequenas pétalas, ao redor sua cintura, você facilmente conseguirá se passar por uma bailaria principal no meio de uma luta perdida com antecedência. Suficiente para desconcertar um exército de Chafer e inverter a situação para a sua vantagem.",ep:1,g:64,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6797] = {n:"Florelmo",t:16,d:"Se você sempre sonhou ser um floricultor e ter um hálito com aroma de rosa, é o momento para você colocar este estranho elmo.",ep:1,g:70,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6798] = {n:"Flor de Dizbi",t:24,d:"Possui uma leve, sutil e intoxicante essência... Mas os Sadidas são os únicos que sabem o segredo destas flores.",ep:1,g:117,l:1,wd:false,fm:true,w:0,p:1};
I.u[6799] = {n:"Lâmina do Chefe Bwork",t:6,d:"Afiada como uma lâmina de Bwork, a lâmina do Chefe Bwork tem a vantagem de ser muito mais pesada. Ela é certamente menos fácil de manejar, mas você só tem que deixá-la cair sobre seu adversário para cortá-lo em dois, como uma fatia comum de Trunknyd. Se seu inimigo não morre de dor, ele certamente morrerá de vergonha e você, de rir.",ep:1,g:48,l:100,wd:true,fm:true,w:100,an:14,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>200&CA>200&CV>200",s:19,p:25000};
I.u[6800] = {n:"Manto Básico",t:17,d:"Esta capa é feita de lã de Gobball. Você não precisará dela a menos que você queira parecer chique...",ep:1,g:15,l:1,wd:true,fm:true,w:1,p:1};
I.u[6801] = {n:"Capa de Inverno",t:17,d:"Aconchegante, quentinho e cheira a forro que caiu muito bem numa capa costumeira. Em você ou na chaminé, esta capa, finalmente, será útil.",ep:1,g:18,l:1,wd:true,fm:true,w:2,p:1};
I.u[6802] = {n:"Protetor de Ouvido",t:16,d:"Este protetor de ouvido muito macio manterá suas orelhas de abano aquecidas.",ep:1,g:73,l:1,wd:true,fm:true,w:10,p:1};
I.u[6803] = {n:"Essência de flor de Dizbi",t:24,d:"Apenas não beba isto!",ep:1,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[6804] = {n:"Amuleto do Chefe Bwork",t:1,d:"Apesar da aparência rudimentar, este amuleto em forma de sílex é dotado de uma magia muito poderosa, que pode transformar um Bwork em princesa, ou o oposto, ninguém sabe.",ep:1,g:66,l:100,wd:true,fm:true,w:1,s:19,p:25600};
I.u[6805] = {n:"Bracelete do Chefe Bwork",t:9,d:"Com este pequeno anel em seu bolso, você poderá fazer com que as pessoas ao seu redor acreditem que se casou com um grande Chefe Bwork e que ele lhe deu esta pulseira como presente de casamento. É suficiente para atrair a atenção sobre você nas festas na Pousada, se você não tem um bom papo.",ep:1,g:58,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6806] = {n:"Fragmento de Madeira",t:24,d:"Este fragmento de madeira vem de uma construção recente, provavelmente vermelha.",ep:1,g:246,l:1,wd:false,fm:true,w:0,p:1};
I.u[6807] = {n:"Botas do Chefe Bwork",t:11,d:"Estas botas parecem ordinárias botas de Bwork. E ainda assim elas são botas do Chefe Bwork. Resistentes, poderosas e fedorentas, elas ainda farão a diferença até mesmo em uma luta que você sabe que vai perder.",ep:1,g:44,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6808] = {n:"Pedaço Rasgado de Tecido",t:24,d:"Este pedaço de tecido branco é muito macio e muito manchado.",ep:1,g:247,l:1,wd:false,fm:true,w:0,p:1};
I.u[6809] = {n:"Descrição vaga",t:24,d:"Esta descrição fala sobre uma menininha com cabelo claro vestida com uma cor escura.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6810] = {n:"Relatório da Atividade na Vizinhança",t:24,d:"Este relatório estipula que nenhum incidente foi registrado na vizinhança no dia do roubo. Exceto um vagabundo foi descoberto na noite do incidente.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6811] = {n:"Manto do Chefe Bwork",t:17,d:"Este manto rasgado e furado fará você parecer um grande guerreiro Bwork. É perfeito se você quiser aterrorizar o idoso da vila. Por outro lado, se você quiser seduzir sua alma gêmea com isto, pode ser mais difícil... a menos que você vista apenas isto, e continue a assustar o idoso da vila também!",ep:1,g:60,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6812] = {n:"Cuecas do Chefe Bwork",t:10,d:"Estas cuecas de couro roxo são auto-suficientes;\r\n            você pode vestir apenas elas e ainda parecer distinto, desde que elas caibam e você não acabe com elas caídas nos joelhos durante uma difícil competição de pular corda.",ep:1,g:59,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6813] = {n:"Capacete do Chefe Bwork",t:16,d:"Se você realmente quiser parecer com uma pessoa seriamente retardada, este capacete foi feito para você. Se tiver sorte, ninguém notará a diferença quando você tirá-lo.",ep:1,g:65,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6814] = {n:"Conjunto de Pedaços de Madeira",t:24,d:"Este conjunto de pedaços de madeira cria uma cama pequena aconchegante, ideal para a coberta de um Piwi.",ep:1,g:248,l:1,wd:false,fm:true,w:0,p:1};
I.u[6815] = {n:"Seringa de Libélula",t:24,d:"Libélula lhe deu esta seringa para você pegar uma amostra do sangue do Radlu Minite, o Mineiro das Sombras.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6816] = {n:"Amostra de Sangue",t:24,d:"Você, finalmente, conseguiu pegar uma amostra de sangue do Radlu Minite. Dá água na boca.",ep:1,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[6817] = {n:"Amuelto do Chefe Crocodyl",t:1,d:"Este incrível amuleto foi realmente feito de uma Proteção Réptil, da qual todas as pedras preciosas foram removidas. Portanto, isto é um pedaço de jóia particularmente pesado para usar, mas é bastante resistente. Seu pescoço estará perfeitamente protegido de vampiros, como também dos chupões das ousadas aldeãs.",ep:4,g:67,l:70,wd:true,fm:true,w:100,s:20,p:12700};
I.u[6818] = {n:"Rosa Demoníaca Cortada",t:35,d:"Esta flor costumava ser demoníaca. Mas agora ela é um lindo presente. E se tudo o que você ganhar de agradecimento é um olhar neutro, você sempre pode fazer geléia dela.",ep:1,g:118,l:1,wd:false,fm:true,w:1,p:1};
I.u[6819] = {n:"Bracelete do Chefe Crocodyl",t:9,d:"Esta pulseira, estranhamente, se parece com uma luva, e ainda assim não é uma luva, mas uma pulseira. As aparências, às vezes, enganam.",ep:4,g:59,l:70,wd:true,fm:true,w:20,s:20,p:12800};
I.u[6820] = {n:"Erva Curativa",t:24,d:"Esta erva é o ingrediente principal de qualquer remédio antigo de alquimista. Não é usado nos dias atuais. Trevo agora é favorecido, pois não causa inchaço fácil, que a verdade seja dita, uma bela vantagem.",ep:1,g:103,l:1,wd:true,fm:true,w:0,p:1};
I.u[6821] = {n:"Lâmina do Chefe Crocodyl",t:6,d:"Feita dos restos de um Chefe Crocodyl, esta arma provará ser muito útil se você for bonito, esperto, inteligente e forte suficiente para manejá-la. Se tiver sorte, você acabará encontrando alguém que concordará em trocá-la por uma espada ou em negociar isto por uma espada de Twiggywood.",ep:4,g:49,l:70,wd:true,fm:true,w:100,an:14,e:[12,6,1,1,40,40,false,false],c:"CA>150&CC>150&CV>100",s:20,p:12800};
I.u[6822] = {n:"Injeção Despertadora",t:24,d:"Esta seringa contém um remédio tão poderoso que pode levantar um morto. Na verdade, alguns dizem que o famoso morto Hyrkul vive com injeções regulares. Esta é a melhor evidência de sua efetividade.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6823] = {n:"Poção a base de Planta",t:24,d:"Esta poção pútrida poderia acordar um sadida durante seu sono... Ou quase... Se o sadida for jovem e estiver quase acordando.",ep:1,g:500,l:1,wd:true,fm:true,w:0,p:1};
I.u[6824] = {n:"Pedra Curativa com Poder Esvaecente",t:24,d:"Esta pedra curativa perde seu poder bem rápido. Para confinar o poder da pedra e manter sua eficiência ao máximo, você precisa envolvê-la com um metal que absorve radiações. Você preferirá os amuletos comuns: são quase tão eficientes e mais baratos.",ep:1,g:104,l:1,wd:false,fm:true,w:0,p:1};
I.u[6825] = {n:"Chinelos Afiados do Chefe Crocodyl",t:11,d:"Estes belos chinelos, feitos de pele e escamas do Chefe Crocodyl, vêm com dentes afiados em suas pontas. Tenha cuidado quando for acariciar a sua amada debaixo da mesa, pois você poderia rasgar a adorada meia-calça dela, feita de lã de Tabi.",ep:4,g:45,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6826] = {n:"Pedra Elegante Curativa",t:24,d:"Este amuleto é uma pedra curativa com poder de desaparecimento que está bem fixada em um pedaço de metal raro. Segurar isto o faz se sentir bem, a fadiga desaparece e seu cérebro fica livre. E, além disso, quando você o estiver usando, você ficará visível à noite.",ep:1,g:105,l:1,wd:false,fm:true,w:0,p:1};
I.u[6827] = {n:"Carta de Joe Stonefiddler",t:24,d:"Joe confiou-lhe a missão de levar esta carta para o seu bom amigo Howard, o Yeahbutno, um lop... hum... bem... você sabe, um Iop!",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6828] = {n:"Punho de Espada",t:24,d:"Este punho não o transformará em um mestre no manejo da espada mas pode  ajudá-lo a se tornar um.",ep:1,g:97,l:1,wd:false,fm:true,w:0,p:1};
I.u[6829] = {n:"Espada de Justforged",t:24,d:"Esta espada foi forjada.",ep:1,g:98,l:1,wd:false,fm:true,w:0,p:1};
I.u[6830] = {n:"Mochila Escola do Chefe Crocodyl",t:81,d:"A volta às aulas é uma experiência dolorosa para os jovens, e não é diferente em Amakna. É até pior para os jovens Iops, para os quais voltar para a escola é um verdadeiro martírio, cheio de testes insuperáveis. Encoraje-os com esta bela mochila feita de pele e escamas de Chefe Crocodyl, com bastantes pêlos.",ep:14,g:58,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6831] = {n:"Cinto do Chefe Crocodyl",t:10,d:"Muito rígido para ser usado como chicote, este cinto coberto de minúsculas pedras preciosas pode, apesar de tudo, ser usado de uma maneira mais convencional, ou seja, evitar que suas polainas caiam de seus joelhos, por exemplo.",ep:4,g:60,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6832] = {n:"Entregador de Energético",t:32,d:"O entregador de energético é tão importante quanto um transportador de fundos do banco. No entanto, ele é muito mais agressivo.",ep:1,g:15,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6833] = {n:"Bolsa de Kamas Duvidosa",t:24,d:"Estes Kamas parecem vir de outros tempos. Eles deveriam ser rapidamente derretidos antes que decidam voltar para onde eles realmente vieram.",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6834] = {n:"Elmo do Chefe Crocodyl",t:16,d:"Se você sempre sonhou se parecer com um Crocodyl – sem se tornar um –, então este elmo é feito para você. Nem pense em usar este elmo para enganar seus amigos e dizer a eles que você realmente matou um Crocodyl. Eles não acreditarão em você.",ep:4,g:66,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6835] = {n:"Metal Transformado",t:24,d:"A questionável sacola de Kamas foi primorosamente transmudada por Libérula. Uma espada agora pode ser forjada com este metal...",ep:1,g:241,l:1,wd:true,fm:true,w:0,p:1};
I.u[6836] = {n:"Espada Rudimentar",t:24,d:"Aqui está uma espada forjada pelas mãos de Dois-Dedos, mas ainda parece tão frágil para você. Libérula, o alquimista, deve ser capaz de fazer algo a respeito.",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6837] = {n:"Espada Vigorosa",t:24,d:"Leve e perigosa, esta espada é designada para você. Mas o toque de final está faltando – algo Ecaflip...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6838] = {n:"Espada Rudimentar de Fogo",t:24,d:"A água da lua parece ser eficiente. Esta espada sólida pode resistir a qualquer coisa, mas algo no Ecalip está errado...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6839] = {n:"Espada Yingnitiate",t:6,d:"Esta arma, que leva a marca do Miau-Miau, podia se transformar num legendário Ecaflip, talvez...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=0",p:1};
I.u[6840] = {n:"Espada Yanguru",t:6,d:"Esta arma, que tem a marca de Miau-Miau, pode se transformar em um Ecaflip lendário, talvez...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=1",p:1};
I.u[6841] = {n:"Tecido de Urso",t:55,d:"Este estranho tecido cheira como um urso. Cuidado, isto atrai fêmeas...",ep:1,g:121,l:22,wd:true,fm:true,w:1,p:500};
I.u[6842] = {n:"Dente de Urso",t:47,d:"Este estranho dente pertenceu a um velho Urso. Ou, para ser mais preciso, a um Urso invocado, o que é – alguém tem que dizer – completamente diferente, já que o que você realmente tem nas mãos é um dente invocado. Muito interessante.",ep:1,g:432,l:22,wd:true,fm:true,w:1,p:500};
I.u[6843] = {n:"Osso de Urso",t:47,d:"Este osso afiado quebrou durante uma terrível luta contra um dos Homens-Urso Invocadores de Urso. É muito tarde para pôr um gesso na pata deste pobre Urso agonizante que estava morrendo e gemendo de dor por causa de seus ataques contínuos. Você preferiu deixá-lo morrer lentamente sufocando-o com baba de Gobball, desmembrando-o e arrancando este osso enquanto ele ainda estava consciente. Nenhuma piedade para com as invocações.",ep:1,g:48,l:22,wd:true,fm:true,w:1,p:500};
I.u[6844] = {n:"Pêlo de Urso",t:54,d:"Às vezes, o Homem-Urso decide fazer uma sessão de depilação em uma de suas invocações de Urso a fim de se divertir ou como passatempo. Então, ele coleta os pêlos para fazer roupas íntimas de qualidade, que são apreciadas pelos solitários caçadores atraídos por sensações e cheiros fortes.",ep:1,g:195,l:22,wd:true,fm:true,w:1,p:500};
I.u[6845] = {n:"Pele de Urso",t:59,d:"Esta áspera e calva pele é o resultado de uma longa e intensiva sessão de depilação usando óleo fervendo e ferro quente. Não fique surpreso se ela tiver cheiro de queimado.",ep:1,g:35,l:22,wd:true,fm:true,w:1,p:500};
I.u[6846] = {n:"Frasco de Cristal de Pale Anthir",t:24,d:"Um ordinário frasco à primeira vista. Mas ele possui um tremendo poder que só os Xelors sabem como usar.",ep:1,g:99,l:1,wd:false,fm:true,w:0,p:1};
I.u[6847] = {n:"Saco de grãos de Epyss",t:24,d:"Um tipo raro de grama, é inútil dizer a verdade. Que diz ‘como os Xelors\'?",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6848] = {n:"Madeira Embelezada",t:24,d:"Madeira de qualidade média.",ep:1,g:100,l:1,wd:false,fm:true,w:0,p:1};
I.u[6849] = {n:"Caixa de Subosycold",t:24,d:"Enutrofs são os únicos que sabem como usar esta caixa. Talvez, devido às pessoas preferirem não saber muito sobre seus segredos... e que segredos!!!",ep:1,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[6850] = {n:"Pizznosh",t:24,d:"Você pode comer um pizznosh – uma das especialidades de Astrub, onde e quando quiser exceto quando estiver perto de carniceiros, já que o seu fedor é insuportável...",ep:1,g:107,l:1,wd:false,fm:true,w:0,p:1};
I.u[6852] = {n:"Brinquedo da Feira do Trool",t:24,d:"O brinquedo de pelúcia que o Bebê Kry ganhou na feira de Trool...",ep:1,g:151,l:1,wd:true,fm:true,w:0,p:1};
I.u[6853] = {n:"Hurrywood",t:24,d:"Esta madeira tem uma característica distinta de se passar por um bastão. Prática para armazenar...",ep:1,g:100,l:1,wd:true,fm:true,w:0,p:1};
I.u[6854] = {n:"Pele de Larva Azul",t:24,d:"Pegajoso pedaço de carne arrancado de uma pobre larva impotente.",ep:1,g:101,l:1,wd:false,fm:true,w:0,p:1};
I.u[6855] = {n:"Pequeno Arco de Enileda",t:24,d:"Fruto do trabalho de Enileda, famosa fabricante de arco, este pequeno arco não é considerado um modelo.",ep:1,g:244,l:1,wd:true,fm:true,w:0,p:1};
I.u[6856] = {n:"Tesoura de Rosa Demoníaca",t:20,d:"O formato desta tesoura foi especialmente projetado para cortar o talo das rosas demoníacas sem danificar as pétalas, mesmo quando ela morde sua panturrilha.",ep:1,g:22,l:1,wd:true,fm:true,w:2,an:13,e:[5,3,1,1,20,20,false,false],p:1};
I.u[6857] = {n:"Energético de Astrub",t:37,d:"Este é um clássico energético que contribui para o desenvolvimento de seu abdômen, mais conhecido como tanquinho.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:4};
I.u[6858] = {n:"Cartão Preenchido, mas Inválido",t:80,d:"Infelizmente, este cartãozinho contém o nome de um candidato mal- sucedido para a posição de entregador do padeiro. A marquinha vermelha na parte inferior indica que ele não teve força nem agilidade suficientes para o trabalho.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW<1500|CA<50",p:0};
I.u[6859] = {n:"Tesoura",t:24,d:"Este par de tesouras não é muito atrativo... De acordo com alguns cabeleireiros, é mais útil para aparar do que para cortar... é o que dizem...",ep:1,g:150,l:1,wd:true,fm:true,w:0,p:1};
I.u[6862] = {n:"Pergaminho de Urso",t:24,d:"Este estranho pergaminho explica como o Homem-Urso aprendeu a invocar Ursos. Incrível!",ep:1,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[6863] = {n:"Capacete dos Mercenários de Astrub",t:16,d:"Capacete dos Mercenários de Astrub.",ep:1,g:72,l:1,wd:false,fm:true,w:10,p:1};
I.u[6864] = {n:"Pétalas de Rosa Obscura",t:24,d:"As pétalas desta rosa são tão escuras que sua sombra, em comparação, parece cintilar.",ep:2,g:106,l:23,wd:true,fm:true,w:0,p:1};
I.u[6865] = {n:"Nota",t:24,d:"‘Encontre-me na beira da floresta para a entrega\'",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6866] = {n:"Pedaço de Manto",t:24,d:"Este pedaço de manto azul pertencia aos seus agressores. Você não acharia isso, mas você os arrebentou.",ep:1,g:249,l:1,wd:false,fm:true,w:0,p:1};
I.u[6867] = {n:"Nota da Colheita",t:24,d:"Para lembrar-se da hora que você tem de fazer a colheita de Wynd, você escreveu neste papel.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6868] = {n:"Tábua de Castanheiro",t:95,d:"Esta tábua é essencial para marceneiros que fazem coisas de madeira, como caixões feitos de tábuas por exemplo.",ep:1,g:1,l:10,wd:true,fm:true,w:10,p:20};
I.u[6869] = {n:"Kry Bebê",t:32,d:"Kry Bebê não se lembra onde está sua casa, assim você deve conduzi-lo de volta...",ep:1,g:14,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6870] = {n:"Nomarow Transplent",t:32,d:"Nomarow Transplent está sob seu controle agora. Leve-o em segurança para a prisão.",ep:13,g:8,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6871] = {n:"Frakacia Leukocytine",t:32,d:"Frakacia está sob seu controle agora. Leve-a em segurança para a prisão.",ep:1,g:11,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6872] = {n:"Nervoes Brakdoun",t:32,d:"Nervoes Brakdoun está sob seu controle agora. Leve-o em segurança para a prisão.",ep:1,g:10,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6873] = {n:"Qil Bil",t:32,d:"Akornadikt está sob seu controle agora. Leve-o em segurança para a prisão.",ep:14,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6874] = {n:"Brumen Tinctorias",t:32,d:"Brumen Tinctorias está sob seu controle agora. Leve-o em segurança para a prisão.",ep:14,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6875] = {n:"Akornadikt",t:32,d:"Akornadikt está sob seu controle agora. Leve-o em segurança para a prisão.",ep:1,g:12,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6876] = {n:"Ogivol Scarlarcin",t:32,d:"Ogivol está sob seu controle agora. Leve-o em segurança para a prisão.",ep:16,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6884] = {n:"Chave do Calabouço do Bworker",t:84,d:"Com esta chave, você poderá entrar no Calabouço do Bworker. Tenha cuidado, pois ela se autodestruirá depois de usada.",ep:4,g:713,l:30,wd:true,fm:true,w:1,p:100};
I.u[6885] = {n:"Ficha de Bworker",t:15,d:"Ideal para jogar cara ou coroa ou matar seu inimigo depois de lançar uma moeda, esta ficha em ouro puro fará de você um feliz jogador, mas talvez azarado também...",ep:13,g:90,l:100,wd:true,fm:true,w:1,p:100};
I.u[6886] = {n:"Manto dos Mercenários de Astrub",t:17,d:"A capa dos mercenários de Astrub, o que mais poderia fazer você esperar?",ep:1,g:59,l:1,wd:false,fm:true,w:10,p:1};
I.u[6887] = {n:"Pacote Surpresa de Bwork",t:89,d:"Abrir este pacote exige uma enorme quantidade de serenidade de seu proprietário, porque isto influencia na qualidade de seu conteúdo.",ep:1,g:42,l:1,wd:false,fm:true,w:4,u:true,p:100};
