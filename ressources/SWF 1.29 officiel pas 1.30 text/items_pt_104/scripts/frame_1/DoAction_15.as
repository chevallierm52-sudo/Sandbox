I.u[6894] = {n:"Super Miau de Combate",t:18,d:"Este superpoderoso Miau lutador é a encarnação do superpoder. Muito impressionante. Atenção, ele só pode ser confiado aos cuidados dos Mestres das Brincadeiras porque eles o merecem.",ep:1,g:1,l:1,wd:false,fm:false,w:10,c:"PX=3|PX=5",p:1};
I.u[6895] = {n:"Pequeno Miau de Combate",t:18,d:"Menos superpoderoso que o superpoderoso Miau, este pequeno Miau de luta ainda é muito potente. Este ser mimado continua uma aposta segura para mestres em Jogos, mas ele suja muito mais fácil. Então, não se esqueça de lavá-lo energeticamente com água fervente de vez em quando para que ele mantenha seu esplendor.",ep:1,g:9,l:1,wd:false,fm:true,w:10,p:1};
I.u[6896] = {n:"Inteligência de Miau Buzzard",t:18,d:"...",ep:1,g:1,l:1,wd:false,fm:true,w:10,p:1};
I.u[6897] = {n:"Pena de Piwi Azul",t:53,d:"Esta pena de Piwi foi tirada do traseiro de um infeliz pássaro.",ep:1,g:114,l:1,wd:true,fm:true,w:1,p:10};
I.u[6898] = {n:"Pena de Piwi Violeta",t:53,d:"Esta pena de Piwi foi tirada do traseiro de um pássaro miserável.",ep:1,g:115,l:1,wd:true,fm:true,w:1,p:10};
I.u[6899] = {n:"Pena do Piwi Verde",t:53,d:"Esta pena de Piwi foi tirada do traseiro de um pássaro miserável.",ep:1,g:116,l:1,wd:true,fm:true,w:1,p:10};
I.u[6900] = {n:"Pena de Piwi Vermelho",t:53,d:"Esta pena de Piwi foi tirada do traseiro de um pássaro miserável.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:10};
I.u[6902] = {n:"Pena de Piwi Amarelo",t:53,d:"Esta pena de Piwi foi tirada do coco do coitado.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[6903] = {n:"Pena de Piwi Rosa",t:53,d:"Esta pena de Piwi foi arrancada do traseiro de um passarinho azarado.",ep:1,g:119,l:1,wd:true,fm:true,w:1,p:10};
I.u[6904] = {n:"Saco de Provisões Bwork",t:15,d:"Amar às vezes pode ser mais destrutivo do que uma guerra. Bworker sabe muito bem disso.",ep:1,g:268,l:200,wd:true,fm:true,w:1,p:1000};
I.u[6905] = {n:"Pacote Surpresa de Bwork",t:89,d:"Abrir este pacote exige uma enorme quantidade de serenidade de seu proprietário, porque isto influencia na qualidade de seu conteúdo.",ep:1,g:42,l:1,wd:true,fm:true,w:4,u:true,p:100};
I.u[6906] = {n:"`SRVT:MERCENARY_INTRONIZER` Neófito",t:14,d:"Este pergaminho oficializa a entrada do `SRVT:MERCENARY_SHORT_NAME`. Ao receber, terá o seu nome adicional no registro do clã, como um neófito.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6907] = {n:"Neutralizador",t:14,d:"Com o Neutralizador, você pode destruir todos os registros relativos a uma pessoa que estejam tanto nas facções de Bonta, Brakmar ou Seriano.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6908] = {n:"Strapcinto",t:10,d:"Peludo, mas elegante, este cinto deve lembrá-lo da sua amada.",ep:1,g:75,l:18,wd:true,fm:true,w:2,s:21,p:1050};
I.u[6909] = {n:"Pés de Javali",t:11,d:"Estas são as botas perfeitas para andar na lama ou arranhar pisos de madeira. É proibido usá-las em pistas de dança.",ep:1,g:51,l:22,wd:true,fm:true,w:2,s:21,p:1525};
I.u[6910] = {n:"Anel de Javali",t:9,d:"Este anel costumava ser colocado nas patas de javalis no cio, de forma que criadores podiam facilmente reconhecê-los. Hoje, você está usando esse anel. Você pode interpretar isso como quiser...",ep:1,g:73,l:19,wd:true,fm:true,w:2,s:21,p:1200};
I.u[6911] = {n:"Arachnoton",t:9,d:"Este anel ridiculamente pequeno lhe permitirá superar com sucesso a sua Aracneofobia.",ep:1,g:76,l:5,wd:true,fm:true,w:1,s:22,p:275};
I.u[6912] = {n:"Arachnoture",t:10,d:"Confeccionado a partir de velhos restos de Aracnes em decomposição, você vai adorar este cinto. De vez em quando, ele pode voltar à vida e gulosamente morder seus quadris. Que coisa sanguinária!",ep:1,g:73,l:6,wd:true,fm:true,w:1,s:22,p:305};
I.u[6913] = {n:"Aracapacete",t:16,d:"Com este Aracapacete, você parecerá uma Aracne selvagem. Na melhor das hipóteses, você assustará Moskitos ingênuos.",ep:1,g:83,l:6,wd:true,fm:true,w:2,s:22,p:305};
I.u[6914] = {n:"Cortador de Aracne",t:19,d:"Estranhamente, a Aracne só tem quatro patas cabeludas, o que significa que com apenas quatro golpes de seu machado, você pode transformá-la em um Tronco de Aracne.",ep:1,g:31,l:8,wd:true,fm:true,w:5,an:17,e:[5,4,1,1,50,50,false,false],s:22,p:600};
I.u[6915] = {n:"Mos Kitano",t:9,d:"Este é um anel tão leve que se você usá-lo, seus dedos poderão fazer qualquer acrobacia. O que também é bastante útil se você quiser humilhar alguém menor, esmagando a cabeça dele ou dela com seu polegar.",ep:1,g:71,l:21,wd:true,fm:true,w:2,s:23,p:1400};
I.u[6916] = {n:"Pequena Mochila de Moskito",t:81,d:"Esta mochila feita de pele e asas de Moskito costumava ser uma grande moda em escolas. Hoje, ela é moda ultrapassada e foi substituída pela Pequena Mochila do Chefe Crocodyl. É tolice visto que uma Pequena Mochila do Chefe Crocodyl é muito mais cara e feia. A moda é cruel.",ep:1,g:59,l:16,wd:true,fm:true,w:2,s:23,p:900};
I.u[6917] = {n:"Moskabuto",t:16,d:"Este elmo recebeu seu nome exótico do excêntrico Enutrof, que o descobriu primeiro, enquanto esvaziava um velho Moskito doente. Extremamente útil para aventureiros novatos, este elmo lhe permitirá seduzir Aracnes famintas.",ep:1,g:80,l:15,wd:true,fm:true,w:2,s:23,p:900};
I.u[6918] = {n:"Amuleto de Moskito",t:1,d:"Este pequeno amuleto não é tão eficiente ou tão procurado como o famoso Arachnamu. Porém, ele pode parecer muito charmoso, quando você usar apenas isto em uma pele cabeluda (para maior efeito).",ep:1,g:75,l:15,wd:true,fm:true,w:2,s:23,p:800};
I.u[6919] = {n:"Anel de Cogu Cogu",t:9,d:"O Cogu Cogu não tem a reputação de ser uma criatura agradável. Ele importuna você em toda oportunidade que tem, morde forte e é muito mal-humorado. Surpreendentemente, essa criatura te lembra a sua companheira. Estranho, não é?",ep:1,g:74,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6920] = {n:"Aliança de Cogu Cogu",t:9,d:"Quando o Cogu Cogu se casa, ele dá esta aliança para sua noiva. Como a noiva não tem braços, a aliança é posta delicadamente em um de seus espinhos. Se conseguir pegar esta aliança, você vai desfazer o casamento entre as duas criaturas e, no melhor dos casos, o Cogu Cogu o escolherá como noiva dele.",ep:1,g:75,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6921] = {n:"Mushelmo",t:16,d:"Mushelmo costumava ser usado para fazer chá de ervas. Este elmo realmente tem tudo isso.",ep:1,g:84,l:9,wd:true,fm:true,w:3,s:24,p:425};
I.u[6922] = {n:"Manto de Cogu-Cogu",t:17,d:"A única coisa mais impressionante que um Cogu-Cogu lívido é um Cogu-Cogu lívido usando um manto. Realmente, este manto peculiar é a materialização de certo tipo de roupa ultrapoderosa, porém muito feia.",ep:1,g:76,l:9,wd:true,fm:true,w:2,s:24,p:450};
I.u[6923] = {n:"Amuleto do Gatuno",t:1,d:"Este amuleto pertenceu ao grande gatuno \"Thisme\", que era famoso por sua crueldade sem limites e morte idiota. Sua vida podia ter sido um conto de Eniripsa. Ele morreu afogado e foi esmagado por uma prensa de oliva quando saiu da cadeia, após uma sentença de 30 anos por ter roubado uma noz.",ep:1,g:76,l:16,wd:true,fm:true,w:2,s:25,p:900};
I.u[6924] = {n:"Adagas do Gatuno",t:5,d:"Estas adagas afiadas são muito populares entre gatunos e não difundidas entre jovens aventureiros, pelos mesmos motivos. As adagas podem conjurar feitiços que permitem roubar Kamas de um adversário. Você não vê esse tipo de coisa em qualquer lugar.",ep:1,g:9,l:12,wd:true,fm:true,w:1,an:13,e:[5,3,1,1,30,50,false,false],s:25,p:600};
I.u[6925] = {n:"Cinto do Gatuno",t:10,d:"Este conveniente cinto parecerá mais belo se você já tiver se juntado aos gatunos da rua principal. Do contrário, ficará ridículo em você.",ep:1,g:72,l:15,wd:true,fm:true,w:2,s:25,p:850};
I.u[6926] = {n:"Peruca de Prespic",t:16,d:"Com esta peruca de Prespic, você irá parecer a Devie Crockett, a mais famosa caçadora dos tempos modernos, que teria feito qualquer coisa para esconder a sua calvície incipiente. Infelizmente, tudo que você pode fazer é vestir esta peruca avermelhada que exala um cheiro nojento quando chove.",ep:1,g:81,l:36,wd:true,fm:true,w:2,s:31,p:3600};
I.u[6927] = {n:"Capa de Prespic",t:17,d:"Esta pequena capa avermelhada também pode ser usada como tapete ou capacho, assim você poderá redecorar a sua casa economizando um bom dinheiro.",ep:1,g:75,l:37,wd:true,fm:true,w:3,s:31,p:3800};
I.u[6928] = {n:"Anel de Prespic",t:9,d:"Este anel, simples e original, vai seduzir os aventureiros que têm sede de coisas luxuosas, mas não as compram porque não querem que esses pequenos animais selvagens e ridículos estraguem as suas jóias. A ambição não tem limite.",ep:1,g:72,l:38,wd:true,fm:true,w:1,s:31,p:4000};
I.u[6929] = {n:"Cinto de Prespic",t:10,d:"Esse cinto de Prespic é ideal para manter o seu quadril esquentado. Sua única desvantagem é ser desagradável a peles suaves;\r\n            então, apenas caras durões de pele grossa podem usá-lo.",ep:1,g:71,l:33,wd:true,fm:true,w:2,s:31,p:3000};
I.u[6930] = {n:"Capacete de Crackler",t:16,d:"Este capacete diretamente esculpido na pedra vale o seu peso em ouro. Ele tanto o protegerá dos ataques de um Crackrock quanto lhe permitirá dar cabeçadas dignas de um Desirock. É perfeito para fazer seus oponentes saírem da sua cadeira de balanço. =+",ep:5,g:85,l:44,wd:true,fm:true,w:200,s:26,p:5300};
I.u[6931] = {n:"Cracklymanto",t:17,d:"Este manto de pedra é um pouco rígido demais, mas ainda é uma proteção muito boa contra lançamento de pedras, ou contra os mais perigosos cuspes de Cracklers.",ep:5,g:77,l:46,wd:true,fm:true,w:1,s:26,p:5800};
I.u[6933] = {n:"Botas de Crackler",t:11,d:"Incrivelmente pesadas, mas realmente eficientes, estas botas rochosas lhe darão uma boa desculpa para arrastar os pés quando tiver de defender um Coletor em uma briga que você sabe que não pode ganhar.",ep:5,g:52,l:47,wd:true,fm:true,w:10,s:26,p:4700};
I.u[6934] = {n:"O Amuleto de Crackler",t:1,d:"Este amuleto é tão pesado quanto um Blop bulímico. Portanto, ele não foi projetado para aventureiros fracos. Entretanto, quando você se acostumar a usá-lo ao redor de seu pescoço e agüentar seu peso pesado, você certamente causará uma boa impressão!",ep:5,g:77,l:46,wd:true,fm:true,w:10,s:26,p:4600};
I.u[6935] = {n:"O cinto de Crackler",t:10,d:"Use isto em sua cintura e você ganhará o respeito de seus colegas. Use em sua cabeça e você será o alvo de risos de Astrub.",ep:5,g:74,l:45,wd:true,fm:true,w:10,s:26,p:5400};
I.u[6936] = {n:"Escarapacete Verde",t:16,d:"Com este capacete, você poderá ser um caçador de Escarafolha.",ep:3,g:78,l:44,wd:true,fm:true,w:2,s:27,p:5200};
I.u[6937] = {n:"Escaracapacete Vermelho",t:16,d:"Com este capacete, você poderá ser um caçador de Escarafolha.",ep:3,g:77,l:44,wd:true,fm:true,w:2,s:28,p:5200};
I.u[6938] = {n:"Escaracapacete Branco",t:16,d:"Com este capacete você poderá fingir ser um caçador de Scarafolha.",ep:3,g:79,l:44,wd:true,fm:true,w:2,s:29,p:5200};
I.u[6939] = {n:"Escaracapacete Azul",t:16,d:"Com este capacete, você poderá fingir ser um caçador de Escarafolha.",ep:3,g:76,l:44,wd:true,fm:true,w:2,s:30,p:5200};
I.u[6940] = {n:"Escaracapa Verde",t:17,d:"Você já sonhou em usar uma capa feita de conchas de Escarafolha? Bem, aqui está sua chance! Após equipada, você deve sentir-se como um verdadeiro Escarafolha e pode deslizar por aí. Deve ser o bastante para surpreender toda uma horda de Trools.",ep:3,g:74,l:45,wd:true,fm:true,w:2,s:27,p:5500};
I.u[6941] = {n:"Escaramanto Azul",t:17,d:"Quem nunca sonhou em vestir um manto feito de carapaça de Escarafolhas? Uma vez equipado, você provavelmente acreditará ser um verdadeiro Escarafolhas, e talvez você consiga se deslocar deslizando e escorregando. Isto é suficiente para deixar uma multidão de Trools surpresos.",ep:3,g:73,l:45,wd:true,fm:true,w:2,s:30,p:5500};
I.u[6942] = {n:"Escaramanto Vermelho",t:17,d:"Quem nunca sonhou em usar um manto feito de conchas de Escarafolhas? Após equipado, você acreditará ser mesmo um Escarafolha e talvez possa se mover escorregando por aí. É o bastante para atrair de volta as multidões de Trools.",ep:3,g:72,l:45,wd:true,fm:true,w:2,s:28,p:5500};
I.u[6943] = {n:"Escaracapa Branca",t:17,d:"Quem nunca sonhou usar uma capa feita de casco de Escarafolha? Uma vez equipado, você provavelmente acreditará ser um verdadeiro Escarafolha, e assim você conseguirá passar por caminhos escorregadios e difíceis. Isso é o suficiente para deixar uma multidão de Trools pra trás.",ep:3,g:71,l:45,wd:true,fm:true,w:2,s:29,p:5500};
I.u[6944] = {n:"Escaranel Verde",t:9,d:"Quando você usar este anel, poupará todos os Escarafolhas que você exterminou. Você então talvez se pergunte se este é o preço deste massacre... É, claro que é!",ep:3,g:69,l:43,wd:true,fm:true,w:2,s:27,p:5000};
I.u[6945] = {n:"Escaranel Vermelho",t:9,d:"Quando você usar este anel, poupará todos os Escarafolhas que você exterminou. Você então talvez se pergunte se este é o preço deste massacre... É, claro que é!",ep:3,g:68,l:43,wd:true,fm:true,w:2,s:28,p:5000};
I.u[6946] = {n:"Escaranel Branco",t:9,d:"Quando você usar este anel, você pensará em cada Escarafolha que você matou. Então talvez não valha a pena ... Sim, com certeza vale a pena!",ep:3,g:67,l:43,wd:true,fm:true,w:2,s:29,p:5000};
I.u[6947] = {n:"Escaraanel Azul",t:9,d:"Quando você usar este anel, terá um pensamento de misericórdia por todos os Escarafolhas que você eliminou. Então, talvez você se pergunte se valeu a pena esta matança... Sim, claro que valeu a pena!",ep:3,g:70,l:43,wd:true,fm:true,w:2,s:30,p:5000};
I.u[6948] = {n:"Escaracinto Verde",t:10,d:"No passado, o Escaracinto foi usado para avaliar as perícias de luta. Iniciantes vestiam o Escaracinto Verde. O vermelho era usado por lutadores que bebiam o sangue de seus oponentes após matá-los. O cinto branco indicava que você era um verdadeiro exterminador, finalmente o azul que indicada que você era pobre demais para comprar o Escaracinto verde, vermelho ou branco.",ep:3,g:67,l:46,wd:true,fm:true,w:2,s:27,p:5600};
I.u[6949] = {n:"Escaracinto Branco",t:10,d:"No passado, o Escaracinto foi usado para avaliar habilidades de lutadores. Os novatos usavam o Escaracinto Verde. O vermelho foi usado por lutadores que beberam o sangue de seus oponentes depois que os matou. O cinto branco indicava que era um exterminador real e finalmente o azul foi indicado como o pior porque não se comparava com o verde, vermelho, ou Escaracinto branco.",ep:3,g:69,l:46,wd:true,fm:true,w:2,s:29,p:5600};
I.u[6950] = {n:"Escaracinto Vermelho",t:10,d:"O Escaracinto costumava ser algo que pessoas olhavam para avaliar sua perícia em lutar de mãos vazias. Se você tiver um Escaracinto Verde, seu inimigo saberá que você é um novato. Se tiver um vermelho, significa que você é um guerreiro sanguinário que lambe o sangue de seus inimigos exterminados... E o branco indica que você é um verdadeiro exterminador! Mas se tiver um azul, todo mundo saberá que você não teve kamas suficientes para comprar um dos outros três Escaracintos.",ep:3,g:68,l:46,wd:true,fm:true,w:2,s:28,p:5600};
I.u[6951] = {n:"Escaracinto Azul",t:10,d:"O Escaracinto costumava ser algo que pessoas olhavam para avaliar sua perícia em lutar de mãos vazias. Se você tiver um Escaracinto Verde, seu inimigo saberá que você é um novato. Se tiver um vermelho, significa que você é um guerreiro sanguinário que lambe o sangue de seus inimigos exterminados... E o branco indica que você é um verdadeiro exterminador! Mas se tiver um azul, todo mundo saberá que você não teve kamas suficientes para comprar um do outros três Escaracintos.",ep:3,g:70,l:46,wd:true,fm:true,w:2,s:30,p:5600};
I.u[6952] = {n:"Cabeça de Boolobo",t:16,d:"Com esta cabeça de Boolobo na cabeça, você terá uma boa desculpa para o seu mau hálito!",ep:1,g:131,l:61,wd:true,fm:true,w:4,s:32,p:10000};
I.u[6953] = {n:"Botas de Boolobo",t:11,d:"Estas botas são cobertas por pêlos de Boolobo. Elas são extremamente úteis para limpar chãos de madeira empoeirados ou espanar as cabeças dos seus inimigos agonizando nos campos de batalha.",ep:1,g:76,l:61,wd:true,fm:true,w:2,s:32,p:9700};
I.u[6954] = {n:"Manto de Boolobo",t:17,d:"Esta pele de Boolobo é uma excelente proteção contra o frio e contra aventureiros que têm o olfato altamente desenvolvido.",ep:1,g:99,l:64,wd:true,fm:true,w:5,s:32,p:11000};
I.u[6955] = {n:"Tira de Boolobo",t:10,d:"Usado como um chicote, esta tira de couro pode ser muito mais eficiente do que aparenta, para motivar seus companheiros de estrada quando eles perderem a alegria e a excitação.",ep:1,g:92,l:49,wd:true,fm:true,w:2,s:32,p:6500};
I.u[6956] = {n:"Anel de Boolobo",t:9,d:"Cuidado! Este anel fará o seu dedo feder. Este odor nojento pode encobrir outro cheiro... Isto pode ser a melhor coisa que poderia acontecer ao seu dedo e aos seus parentes...",ep:1,g:103,l:51,wd:true,fm:true,w:2,s:32,p:7000};
I.u[6957] = {n:"Lâmina de Crackler",t:6,d:"Esta espada costumava ser usada para cortar blocos de granito para construir muralhas ao redor das prestigiosas cidades, como Bonta ou Brakmar. Hoje em dia, esta arma é muito procurada por sua capacidade de esmagar todos os tipos de criaturas vivas, conscientes disto ou não.",ep:5,g:54,l:37,wd:true,fm:true,w:10,an:14,tw:true,e:[5,6,1,1,50,50,false,true],s:26,p:3800};
I.u[6958] = {n:"Disfarce do Mestre Tartaruga",t:16,d:"Com um visual incomparável, este é o item ideal para aquelas festas de verão que ocorrem durante a noite.",ep:5,g:82,l:22,wd:true,fm:true,w:12,p:1525};
I.u[6961] = {n:"Anel do Gângster",t:9,d:"Este anel é popular tanto na comunidade dos dentistas quanto nas congregações dos gângsteres. Ambos o utilizam para quebrar os dentes das pessoas imprudentes. Porém, a boa notícia é que ele previne contra cáries...",ep:1,g:77,l:17,wd:true,fm:true,w:2,s:25,p:1000};
I.u[6962] = {n:"Presente de Aniversário",t:89,d:"FELIZ ANIVERSÁRIO! Nós não revelaremos a surpresa e diremos a você o que está neste presente! Tudo o que importa é que você chegará à festa e irá se divertir muito! Isto é o mínimo que podíamos fazer em um dia tão especial!",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6963] = {n:"Bolas de Minotoball",t:12,d:"Estas bolas incrivelmente grandes são deliciosas. Você achará que não há nenhuma utilidade para elas, mas quem se importa?",ep:1,g:143,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6964] = {n:"Poção da Cidade: Brakmar",t:12,d:"Esta poção à base de arroz permite a todo Brakmariano voltar para a cidade instantaneamente.",ep:1,g:145,l:1,wd:true,fm:true,w:1,c:"Ps=2|Ps=0|Ps=3",u:true,p:1};
I.u[6965] = {n:"Poção de Cidade: Bonta",t:12,d:"Esta poção à base de arroz permite que qualquer bontariano vá para Bonta num piscar de olho.",ep:1,g:144,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=0|Ps=3",u:true,p:1};
I.u[6966] = {n:"Feitiço Especial: \"Aziago\"",t:75,d:"Este pergaminho lhe ensina o feitiço \"Aziago\", somente para Srams.\n(Clique duas vezes para aprender o feitiço)",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"PG=4",u:true,p:10000};
I.u[6967] = {n:"`SRVT:MERCENARY_INTRONIZER` Aprendiz",t:14,d:"Este pergaminho permite o `SRVT:MERCENARY_SHORT_NAME` ser promovido a Aprendiz.",ep:1,g:5,l:1,wd:false,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6968] = {n:"`SRVT:MERCENARY_SHORT_NAME` `SRVT:MERCENARY_INTRONIZER`",t:14,d:"Com esse pergaminho, o `SRVT:MERCENARY_SHORT_NAME` será promovido a `SRVT:MERCENARY_SHORT_NAME` por inteiro.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6969] = {n:"Grande `SRVT:MERCENARY_SHORT_NAME` `SRVT:MERCENARY_INTRONIZER`",t:14,d:"Com este pergaminho, um `SRVT:MERCENARY_SHORT_NAME pode ser promovido a Grande `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6970] = {n:"Mestre`SRVT:MERCENARY_INTRONIZER`",t:14,d:"Com este pergaminho, um `SRVT:MERCENARY_SHORT_NAME` pode ser promovido a Mestre `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6971] = {n:"Clint do discípulo `SRVT:MERCENARY_SHORT_NAME`",t:16,d:"Este chapéu é uma réplica muito boa do famoso Clint. Se adaptará perfeitamente aos `SRVT:MERCENARY_SHORT_NAME` discípulos dispostos a fingirem ser o mestre.",ep:1,g:38,l:1,wd:false,fm:true,w:20,c:"Ps=3",p:1};
I.u[6975] = {n:"Clint do Novato",t:16,d:"Este chapéu ultrapoderoso é o emblema Seriano. Tem o poder de protegê-lo da chuva e do sol... não é um bom começo?",ep:1,g:38,l:1,wd:false,fm:true,w:20,p:1};
I.u[6978] = {n:"Peki",t:18,d:"Esta criatura pode parecer um Au-au a distância. Um simples olhar para a sua cabeça e você poderá ver que ela passou por coisas terríveis que a tornaram vegetariana. Ela come apenas vegetais e plantas que crescem na Ilha Pandala.",ep:3,g:12,l:60,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6979] = {n:"Manto de Swoard Vaipay",t:17,d:"Este manto o protege de aventureiros que possam lhe atacar.",ep:1,g:59,l:50,wd:false,fm:true,w:10,p:5000};
I.u[6980] = {n:"Dofus Vulbis",t:23,d:"Este Dofus foi colocado por um dragão que decidiu permanecer anônimo. Mesmo os aventureiros mais sábios ainda se perguntam por que.",ep:11,g:4,l:6,wd:false,fm:true,w:1,p:500000};
I.u[6981] = {n:"Adagas de Gelo",t:5,d:"A lâmina destas adagas é feita de gelo. É muito útil para refrescar o bafo de seus inimigos. Abra a boca deles, crave sua Adaga de Gelo e pronto!",ep:19,g:44,l:150,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>150",p:15};
I.u[6982] = {n:"Adagas Oni",t:5,d:"Estas adagas estão encharcadas de sangue de várias criaturas demoníacas, como crianças. Isto as torna muito especiais.",ep:18,g:50,l:46,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5775};
I.u[6983] = {n:"Adagas Crivas",t:5,d:"Afiadas uma vez por década, estas adagas ainda são letais. Regidas por uma magia negra, elas, às vezes, vagam sozinhas à noite para ir - na melhor das hipóteses – até os traseiros dos imprudentes... Outra história que contamos aos jovens Iops para assustá-los.",ep:19,g:47,l:143,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>250&CA>100",p:15};
I.u[6984] = {n:"Adagas do Aprendiz de Assassino de Gobbly",t:5,d:"Estas adagas pertenceram a um Sadida cuja deslumbrante riqueza será lembrada na história de Amakna. Realmente, este Sadida dedicou sua vida à caça de Gobbly, o que fez todos os aldeãos rirem. Alguns até vinham de áreas distantes para assisti-lo caçar aquelas criaturas ridículas e zombar dele. Sua vingança foi terrível. Uma vez que ficou rico, ele permitiu-se colocar um preço para cada cabeça que riu dele.",ep:18,g:46,l:113,wd:true,fm:true,w:15,an:13,tw:true,e:[5,3,1,1,25,50,false,false],c:"CS>300&CA>100",p:32750};
I.u[6986] = {n:"Escudo do Monte Fedoranto Quebrado",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:1,l:1,wd:false,fm:true,w:20,c:"BI=non équipable",p:5400};
I.u[6987] = {n:"Pequena Pedra da Alma Perigosa",t:83,d:"Esta pedra lhe oferece uma pequena chance de capturar pequenas almas.",ep:5,g:1,l:1,wd:false,fm:true,w:1,tw:true,p:1250};
I.u[6988] = {n:"Sulik",t:16,d:"Um Xelor selvagem cuja irmã foi raptada por feitores de escravos inescrupulosos que costumavam vesti-la. Este suntuoso chapéu fará você se parecer com um selvagem original.",ep:19,g:92,l:172,wd:true,fm:true,w:10,p:56100};
I.u[6989] = {n:"Krokop",t:16,d:"Este chapéu foi feito Há muito tempo, por aprendizes alfaiates que queriam se proteger dos punhos furiosos de Mirko, o alfaiate. Mirko normalmente dizimava seus aprendizes chutando-os na cabeça quando não trabalham o bastante;\r\n            uma forma diferente de motivá-los a voltar ao trabalho.",ep:19,g:86,l:120,wd:true,fm:true,w:20,p:37025};
I.u[6990] = {n:"Motchapéu",t:16,d:"Este chapéu é um tributo aos primos distantes dos Moskitos: as Traças. Muito maiores e mais legais que os Moskitos, as Traças estavam tentando se reproduzir com muita dificuldade (freqüentemente se reproduzindo com qualquer coisa) e isto as guiou para uma progressiva extinção de sua espécie. Esta terrível história afetou a maioria das pessoas. Hoje em dia, é comum insultar um aventureiro chamando-o de Traça para lhe dizer que ele não escolheu bem seus companheiros...",ep:19,g:87,l:113,wd:true,fm:true,w:10,p:32925};
I.u[6991] = {n:"Guavchapéu",t:16,d:"Este chapéu estranho parece uma grande fruta podre e desidratada... Parece com você após uma noite na taverna.",ep:18,g:88,l:46,wd:true,fm:true,w:10,p:5800};
I.u[6992] = {n:"Kannipiwi",t:16,d:"Versão embelezada da famosa máscara Kanniball, a Kannipiwi fará você se parecer com um verdadeiro caçado Piwi.",ep:12,g:89,l:55,wd:true,fm:true,w:5,p:8000};
I.u[6993] = {n:"Manto Hallelujah",t:17,d:"Lonard Kohen, famoso menestrel, pôde cantar até ficar mudo. Ele foi queimado vivo diante de um banco de Bonta, após fazer uma cena com sua nova música ‘Porque você não frita\'.",ep:18,g:79,l:46,wd:true,fm:true,w:10,p:5600};
I.u[6994] = {n:"Manto Encapado",t:17,d:"Esta criação híbrida de capa e manto é incrível. Se fosse de couro, o Capitão Chafer iria adorar.",ep:1,g:80,l:58,wd:true,fm:true,w:10,p:8875};
I.u[6995] = {n:"Capa Houte",t:17,d:"Uma capa ultrapoderosa que roubou todos os tolos que tentaram vesti-la, uma característica compartilhada com a Múmia Nova.",ep:18,g:81,l:105,wd:true,fm:true,w:10,p:28300};
I.u[6996] = {n:"Anel de O\'stradamus",t:9,d:"Stradamus foi um velho Enutrof eufórico que podia ler o futuro em gotas de energético. A lenda diz que ele foi enterrado verticalmente em um muro da taverna de Brakmar como um pedido pessoal: \"Assim nenhum apreciador de energético poderá espirrar esta bebida em minha sepultura\". Esta lenda é contada nas festas organizadas pelos Mestres Serianos.",ep:18,g:78,l:48,wd:true,fm:true,w:5,p:6075};
I.u[6997] = {n:"Anel de Fioutioure",t:9,d:"A pessoa que criou este anel pensou que o fim do mundo estava próximo. Ela costumava passar dias inteiros gravando, em mesas de madeira, o seu provérbio, dizendo que não havia mais nenhum futuro para os habitantes de Amakna. O tempo provou que ela estava errada.",ep:18,g:79,l:70,wd:true,fm:true,w:5,p:12730};
I.u[6998] = {n:"Aliança de Elya Wood",t:9,d:"Esta pequena aliança se encaixa perfeitamente nos dedinhos dos Eniripsas. Por outro lado, não pode ser usada por Iops por causa de seus grandes dedos gordinhos e de sua incapacidade intelectual para entender em qual dedo se põe uma aliança.",ep:18,g:84,l:120,wd:true,fm:true,w:15,s:39,p:36000};
I.u[6999] = {n:"Medalha Lahilama",t:1,d:"Lahilama foi um grande guia espiritual que celebra uma cerimônia no coração das montanhas. Ele estava tão entediado que passava seus dias costurando pequenos chapéus amarelos para seus discípulos. Loucura sem limites.",ep:18,g:83,l:31,wd:true,fm:true,w:3,p:2800};
I.u[7000] = {n:"Bambamuleto",t:1,d:"Este pequeno pedaço ridículo de bambu possui os mais misteriosos poderes mágicos. Costumava ser usado por jovens Pandawas, até que sua puberdade terminava. Talvez você queira esperar alguns anos antes de pôr isto ao redor do seu pescoço...",ep:18,g:78,l:40,wd:true,fm:true,w:5,p:4400};
I.u[7001] = {n:"Talismã de Bow\'hee",t:1,d:"‘Eu, eu sou o rreeeiii, você, você é a raenhaaa, nóiisss podemos ser heeeróis só por um diiiaaaa...\' Davyd, famoso trovador, estava cantando enquanto voltava da Ilha da Lua... Até que ele foi caçado com este arco.",ep:18,g:84,l:55,wd:true,fm:true,w:10,p:8000};
I.u[7002] = {n:"Pequena Resina",t:1,d:"Este amuleto feito de resina de Bambu espalhará um bom cheiro em você. Será útil quando você estiver em um de seus Ventos de Pânico.",ep:18,g:85,l:94,wd:true,fm:true,w:5,p:22800};
I.u[7003] = {n:"Talismã de Elya Wood",t:1,d:"Esse Talismã foi criado com pó de estrela e de pedras preciosas envoltos no Âmbar de Treechnid Ancestral. A mistura pode ser bastante explosiva. Por isso, não é recomendado que você tente fazê-la. Deixe isso para um Joalheiro pouco amigo seu.",ep:18,g:86,l:135,wd:true,fm:true,w:10,s:39,p:45600};
I.u[7004] = {n:"Pedra de Alma Mediana Perigosa",t:83,d:"Com esta pedra você tem uma pequena chance de capturar almas relativamente importantes...",ep:5,g:8,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
