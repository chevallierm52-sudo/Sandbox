I.u[9324] = {n:"Escudo Inacabado de Dardondakal",t:24,d:"Este escudo foi feito na escala do tamanho de Dardondakal, o Dragão Branco. Embora ainda não esteja terminado, ainda há nele uma poderosa aura de poder. Um de seus antigos donos teve a terrível idéia de pintá-lo num azul horrível. Ele nunca poderá ser equipado.",ep:3,g:807,l:1,wd:false,fm:true,w:0,p:1};
