I.u[8985] = {n:"Pílula Hippi-Ho D&M",t:116,d:"Com esta pílula poderosa, você pode aumenta a força de seu Dragoone ou Minotoro para sempre. Mas tenha cuidado! Não dê mais que uma dose... Você terá um Treechster ou  Minotoro morto em suas mãos... Falando nisso, ambas as carnes são muito, muito comestíveis. É melhor deixar os marinados para... certo, vou parar de falar...",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"PO=7519|PO=8155",u:true,p:1};
I.u[8986] = {n:"Pílula Hippi-Ho G&F",t:116,d:"Com esta pílula poderosa, você pode aumenta a força de seu Gobtubby ou Fantosminha para sempre. Mas tenha cuidado! não dê mais que uma dose... Você terá um Treechster ou  Minotoro morto em suas mãos... Falando nisso, ambas as carnes são muito, muito comestíveis. É melhor deixar os marinados para... certo, vou parar de falar...",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"PO=8151|PO=7518",u:true,p:1};
I.u[8987] = {n:"Pílula Hippi-Ho E&C",t:116,d:"Com esta pílula poderosa, você pode aumenta a força de seu El Scarador ou Croo para sempre. Mas tenha cuidado! não dê mais que uma dose... Você terá um Treechster ou Minotoro morto em suas mãos... Falando nisso, ambas as carnes são muito, muito comestíveis. É melhor deixar os marinados para... certo, vou parar de falar...",ep:1,g:10,l:1,wd:true,fm:true,w:1,c:"PO=8154|PO=7520",u:true,p:1};
I.u[8988] = {n:"Pílula Hippi-Ho T&M",t:116,d:"Com esta pílula poderosa, você pode aumenta a força de seu Treechster ou Minotoro para sempre. Mas tenha cuidado! não dê mais que uma dose... Você terá um Treechster ou Minotoro morto em suas mãos... Falando nisso, ambas as carnes são muito, muito comestíveis. É melhor deixar os marinados para... certo, vou parar de falar...",ep:1,g:11,l:1,wd:true,fm:true,w:1,c:"PO=8153|PO=7522",u:true,p:1};
I.u[8989] = {n:"Capacete de Pikoko do Ar",t:16,d:"Com este capacete, você pode ter a esperança de voar se girar na velocidade do som. Já para aterrissar, você terá dificuldades.",ep:22,g:209,l:154,wd:true,fm:true,w:10,p:44350};
I.u[8990] = {n:"Prisma de Conquista",t:112,d:"Esta pedra mágica pode preencher o canto mais escudo com uma luz brilhante - não precisa desperdiçar sua urina preciosa quando marcar seu terri\'torio. Não deve ser usada com moderação, se você tiver um espírito conquistador. Cuidado! Você pode colocar um prisma somente se claramente exibir seu rank (com o modo jogar versus jogador ativado), se você estiver em uma área sem outros prismas. A área onde você deve colocar um prisma de conquista deve ser adjacente ao mnos 5 minutos da antiga área aliada.",ep:4,g:1,l:1,wd:true,fm:true,w:10,c:"PL>9&PP>2",u:true,p:1};
I.u[8991] = {n:"Faixa Principal",t:9,d:"Esse anel frio e viscoso nunca se separará de seu dedo. Se você passar por uma ventania, entretanto, poderá controlar grandes poderes.",ep:22,g:145,l:189,wd:true,fm:true,w:10,s:97,p:55000};
I.u[8992] = {n:"Gadanha Amaldiçoada do Guerreiro Blord",t:22,d:"Esta lâmina corta trigo tão bem quanto inimigos, mas também faz seus aliados extremamente invejosos. Este é o destino de pessoas poderosas.",ep:22,g:3,l:200,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,100,50,false,false],p:58000};
I.u[8993] = {n:"Espada Amaldiçoada do Guerreiro Blord",t:6,d:"Esta espada mantém um poder imenso de muitas vítimas que preencheram os capítulos dos livros de história. Por outro lado, esta arma influencia gerando perigos mortais. Há alguém que possa domar esta força viciosa?",ep:20,g:83,l:200,wd:true,fm:true,w:10,an:14,tw:true,e:[10,5,1,1,100,2,false,false],p:58000};
I.u[8994] = {n:"Tecido de Coralator",t:55,d:"Este pano úmido estava escondido debaixo d\'água onde partículas de coral cobriram sua superfície. É uma pena que é tão duro quanto uma pedra - seria um ótimo lenço.",ep:22,g:728,l:150,wd:true,fm:true,w:1,p:100};
I.u[8995] = {n:"Tecido de Gourlo o Terrível",t:55,d:"Usada no passado como uma bandagem por Gourlo o Terrível, este tecido ainda está impregnado com um cheiro vertiginoso. O engraçado é, uma cheirada e você ficará com muita fome.",ep:22,g:729,l:150,wd:true,fm:true,w:1,p:100};
I.u[8996] = {n:"Pele de Grande Bherb",t:59,d:"Esta pele é mais lisa que o traseiro de um Kilibris.",ep:22,g:48,l:250,wd:true,fm:true,w:1,p:100};
I.u[8997] = {n:"Pele de Tunril Lacerada",t:59,d:"Esta pele provavelmente cobriu uma área sensível do Tynril. Pobre rapaz.",ep:22,g:629,l:400,wd:true,fm:true,w:1,p:100};
I.u[8998] = {n:"Pedra Preciosa de Kimbo",t:50,d:"Deixe-me te contar uma histórinha... há muitos anos atrás, o Kimbo engoliu esta pedra preciosa para amaciá-la. Então ele empurrou-a pelas narinas. Hmm, algumas vezes a mão natureza amamenta seus seres desprezíveis.",ep:22,g:109,l:900,wd:true,fm:true,w:1,p:100};
I.u[9000] = {n:"",t:82,d:"",ep:0,g:10,l:1,wd:false,fm:true,w:10,c:"PP>5",p:1};
I.u[9001] = {n:"Escudo de Sidimote",t:82,d:"Este escudo lembrará seus oponentes que você cresceu nas terras de Sidimote. E que sozinho pode ser o bastante para afastá-los.",ep:18,g:8,l:1,wd:true,fm:true,w:10,c:"PP>4",p:15650};
I.u[9002] = {n:"Phtalmo",t:82,d:"Este escudo é coberto com pimenta para permitir a você devastar os olhos dos demônios. Incontrolável.",ep:18,g:5,l:1,wd:true,fm:true,w:10,c:"PP>4",p:33000};
I.u[9003] = {n:"Escudo Taverna",t:82,d:"O taverneiro da fábrica de energéticos de Feubuk em Bonta estava provavelmente bastante entediado quando teve a idéia de equipar seus vigias com escudos publicitários.",ep:18,g:6,l:1,wd:true,fm:true,w:10,c:"PP>3",p:16200};
I.u[9004] = {n:"Escudo Akwadala",t:82,d:"Para afastar o mal ou golpes fortes, este escudo de  Akwadala deve servir.",ep:14,g:31,l:1,wd:true,fm:true,w:2,c:"PP>2",s:34,p:5350};
I.u[9005] = {n:"Escudo Ventilador",t:82,d:"Quando seus aliados perderem o fôlego, ou quando você quiser limpar o ar após um vento de pânico inesperado, este escudo pode salvar sua vida. A única coisa que você precisa fazer é movimentar energicamente em todas as direções, como você faz com um bebê faminto.",ep:18,g:11,l:1,wd:true,fm:true,w:10,c:"PP>8",p:54450};
I.u[9006] = {n:"Escudo Sadida",t:82,d:"Originalmente este escudo foi usado como um banco pelos Sadidas para eles descansarem. Após arregaçar seus pés, ele te protegerá de muitos dos ataques, mas não da explosão de gargalhadas de seus oponentes.",ep:18,g:12,l:1,wd:true,fm:true,w:10,c:"PP>6",p:18700};
I.u[9007] = {n:"Escudo em Cueca",t:82,d:"Esta criação surpreendente cobre seu escudo nas Cuecas de Couro do Lançador Chafer, que foi fervida, limpada e esticada, então abraçou tão perfeitamente que o prencheu, com as curvas generosas de seu dono.. Eu acho que já é o bastante.",ep:18,g:13,l:1,wd:true,fm:true,w:10,c:"PP>5",p:26700};
I.u[9008] = {n:"Escudo Asse",t:82,d:"Este magnífico escudo contém alguns achados do Mar de Asse. Não apenas traz boa sorte, mas também pode ser usado como um frasco.",ep:18,g:16,l:1,wd:true,fm:true,w:10,c:"PP>7",p:32450};
I.u[9009] = {n:"Escudo de Treechnid",t:82,d:"Escondido atrás deste escudo, alguns aventureiros ingênuos poderiam te enganar com um Treechnid e fugir gritando. Os ataques serão mais intensos, pensando que podem conseguir âmbar de você.",ep:18,g:19,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5950};
I.u[9010] = {n:"Escudo Pandawa",t:82,d:"Perfeito se você quiser combinar com um Pandala, ou sobressair! A maior vantagem deste escudo consiste nele ser inteiramente coberto com pêlo Pandawa hipoalérgico, então você não precisa enrolar sua cueca e sua armadura em malas separadas quando for viajar nas férias.",ep:18,g:22,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5600};
I.u[9011] = {n:"Disco de Fogo",t:82,d:"Este escudo especial te protegerá do elemento Fogo e incidentalmente dará tempo a seus oponentes. Muito útil para conseguir tempo para derrotar!",ep:18,g:24,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9012] = {n:"Disco de Ar",t:82,d:"Este escudo especial te protegerá do elemento Ar e incidentalmente dará muito tempo a seus oponentes. Tempo para fazer os últimos desejos!",ep:18,g:26,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9013] = {n:"Disco de Terra",t:82,d:"Este escudo especial te protegerá do elemento Terra e incidentalmente dará muito tempo a seus oponentes. Tempo para fazer os últimos desejos!",ep:18,g:27,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9014] = {n:"Disco de Água",t:82,d:"Este escudo especial te protegerá do elemento Água e incidentalmente dará muito tempo a seus oponentes. Tempo para fazer os últimos desejos!",ep:18,g:25,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9015] = {n:"Escudo Lenhador",t:82,d:"Este escudo costumava proteger lenhadores de árvores em queda. Ele rapidamente mudou. Você pode usá-lo para se proteger de inimigos em queda quem aterrissam sem avisar!",ep:18,g:4,l:1,wd:true,fm:true,w:10,c:"PP>1",p:1200};
I.u[9016] = {n:"Escudo Monte Fedorento",t:82,d:"Esverdeado e fedorento, este escudo permanece a primeira escolha de proteção quando se luta com as criaturas do Monte Fedoranto.",ep:18,g:1,l:1,wd:true,fm:true,w:20,c:"PP>2",p:5400};
I.u[9017] = {n:"Escudo Diabinho",t:82,d:"Se o seu maior sonho é se tornar um diabinho, este é o escudo que você precisa. Passado de geração em geração, permitirá que você roube jovens aventureiros de Astrub sem se ferir.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"PP>6",p:30700};
I.u[9018] = {n:"Coração em Quatro",t:82,d:"Um famoso aventureiro passou toda a sua vida procurando as quatro partes deste escudo. Alguns dizem que quando a estiver completo, terá exatamente o efeito oposto de quebrar um espelho.",ep:18,g:7,l:1,wd:true,fm:true,w:10,c:"PP>3",p:13000};
I.u[9019] = {n:"Escudo Bawbawian",t:82,d:"Nem todos os Wabbits são criaturinhas bonitas. De fato, todos os Wabbits são criaturas vis. Alguns esmagam cawwots com seus grandes escudos e tomam banho no suco.",ep:18,g:2,l:1,wd:true,fm:true,w:15,c:"PP>3",p:10500};
I.u[9020] = {n:"Derma Tho",t:82,d:"Este escudo de pele será perfeito como uma luva. Não se esqueça de tratar suas verrugas e furúnculos de vez em quando para evitar desgastá-la.",ep:18,g:3,l:1,wd:true,fm:true,w:10,c:"PP>2",p:2200};
I.u[9021] = {n:"Escudo Capitão Amakna",t:82,d:"Um jovem aventureiro uma vez sonhou em seu juntar à milícia de Bonta para proteger os oprimidos. Considerado moralmente inapropriado para o serviço, ele estava em contato co um alquimista de Amakna que levou vantagem de sua boa natureza, usando-o como um porquinho da índia com suas poções. Você ficará feliz em saber que é uma história que termina... bem, no meio é um pouco feliz. Ele se tornou tão forte que era mais conhecido como Capitão Amakna e este escudo com reputação de indestrutível foi forjado por ele. No fim.. bem, você não vai querer saber o fim.",ep:18,g:14,l:1,wd:true,fm:true,w:30,c:"PP>9",p:63200};
I.u[9022] = {n:"Kloome",t:82,d:"Este enorme escudo salvou o famoso aventureiro Kloome de uma morte terrível: esmagado pelo peso de um Crackler que estava apaixonado por ele. A lenda não diz se ele sobreviveu aos efeitos colaterais desta história de amor com o Crackler.",ep:18,g:15,l:1,wd:true,fm:true,w:10,c:"PP>4",p:22100};
I.u[9023] = {n:"Escudo Voador",t:82,d:"Tão estranho quanto isto pode soar, alguns dizem que este escudo feito de madeira e pêlos, permite aos mais leves aventureiros voar por um breve momento... a última tentativa de surpreender os inimigos deles antes de desfalecerem estupidamente no chão.",ep:18,g:17,l:1,wd:true,fm:true,w:1,c:"PP>0",p:1200};
I.u[9024] = {n:"Escudo Chouque",t:82,d:"O Chouque usou este escudo para proteger-se de bolas de canhão aliadas que seus amigos jogaram nele. Algumas histórias loucas dizem que estas bolas estavam vivas.",ep:18,g:18,l:1,wd:true,fm:true,w:10,c:"PP>6",p:36850};
I.u[9025] = {n:"Escudo Gobball",t:82,d:"Embora inútil, este cheiro espalhará sua fama por toda a parte. Este escuro acompanhou muitos jovens aventureiros em suas primeiras missões - talvez é o motivo de poucos terem chegado aos trinta...",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PP>0",p:400};
I.u[9026] = {n:"Escudo de Bowisse",t:82,d:"Este escudo é um tributo ao Manto de Bowisse já que ele em si era um tributo à famosa relíquia composta de três formas triangulares. Oh deus, esta história está me deixando com sono.",ep:18,g:21,l:1,wd:true,fm:true,w:10,c:"PP>3",p:10150};
I.u[9027] = {n:"Escudo Crackler",t:82,d:"Esta pedra é na verdade feita da cabeça de um Crackler, esmagada pelo pé de um Minotoro. Uma combinação perfeita de cabeça grande e pés fedorentos!",ep:5,g:23,l:1,wd:true,fm:true,w:10,c:"PP>2",p:6300};
I.u[9028] = {n:"Escudo de Terrdala",t:82,d:"O escudo de Terrdala deve ajudá-lo a mantê-lo salvo dos golpes fortes.",ep:18,g:32,l:1,wd:true,fm:true,w:10,c:"PP>3",s:36,p:14100};
I.u[9029] = {n:"Escudo Feudala",t:82,d:"Para afastar o mal ou golpes fortes, este escudo de  Akwadala deve servir.",ep:18,g:33,l:1,wd:true,fm:true,w:15,c:"PP>5",s:37,p:27100};
I.u[9030] = {n:"Escudo Aerdala",t:82,d:"Para afastar o mal ou golpes fortes, este escudo de  Akwadala deve servir.",ep:18,g:30,l:1,wd:true,fm:true,w:10,c:"PP>4",s:35,p:11600};
I.u[9031] = {n:"Anel de Mestre Gore (GM somente)",t:9,d:"Neste tempo, o Mestre Gore era muito jovem e tinha tudo que precisava: dinheiro, mulheres e mais. Ele não era bem merecedor de tudo já que conseguiu sua força a partir deste belo anel. Até que um dia, ele atravessou a rua sem cuidado. E BAM! Acabou o Mestre Gore. Desde então, pessoas inescrupulosas passam-no para outras pessoas de mesmo nível.",ep:0,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[9035] = {n:"Poção Padoque da Guilda",t:12,d:"Esta poção permite a você voltar para o padoque de sua guilda.",ep:5,g:25,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[9036] = {n:"Poção da Vila: Zoth",t:12,d:"Esta poção permite a você teletransportar-se para a Vila Zoth, se você possuí-la.",ep:0,g:24,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9037] = {n:"Poção da Descoberta",t:14,d:"Esta poção permite a você revelar todos os personagens invisíveis ao seu redor.",ep:0,g:59,l:1,wd:true,fm:true,w:1,p:10};
I.u[9038] = {n:"Poção Ataque Pequeno",t:14,d:"Esta poção deixará você tão nervoso que atacará automaticamente inimigo que estiverem bem próximos.",ep:0,g:32,l:1,wd:true,fm:true,w:1,c:"Pg=21",u:true,p:10};
I.u[9039] = {n:"Poção Chamado de Prisma",t:12,d:"Esta poção permite a você teletransportar-s para o prisma aliado mais próximo.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9040] = {n:"Poção de Ataque Médio",t:14,d:"Esta poção deixará você tão nervoso que atacará automaticamente inimigo que estiverem bem próximos.",ep:0,g:33,l:1,wd:true,fm:true,w:1,c:"Pg>21,1",u:true,p:10};
