I.u[8913] = {n:"Poção Bulbish",t:12,d:"Esta poção foi feita de extrator de bulbos que ensoparam a massa de Kloug. Os alquimistas mais audaciosos usam farinha de arroz ao invés de massa de Kloug, que não pode ser mais encontrado. Embora parece impossível se adaptar ao sabor.",ep:22,g:23,l:110,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[8914] = {n:"Cartão de Informação de Marceneiro",t:24,d:"Este cartão contém toda a informação necessária para encontrar o marceneiro descrito.",ep:0,g:176,l:1,wd:false,fm:true,w:0,c:"PJ>65,50",p:1};
I.u[8915] = {n:"Cartão Vazio de Informação de Marceneiro",t:80,d:"Este cartão vazio deve ser preenchido com todas as informações necessárias para identificar um marceneiro.",ep:0,g:6,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[8916] = {n:"Âmber de Tynril",t:50,d:"Este escudo foi visto em batalhas demais, neste estado é inútil. Este âmbar é diferente dos outros. Se você olhar bem, chacoalhá-lo e dançar um tango maníaco do Capitão Chafer, você sentirá que ele vibra e brilha como seu espírito misterioso o habitasse. Para ser honesto, você parecerá um idiota, mas um idiota brilhante e vibrante!",ep:22,g:1,l:100,wd:true,fm:true,w:10,p:1};
I.u[8917] = {n:"Chave da Gruta Hesque",t:84,d:"Esta chave estranha fará você entrar na Gruta Hesque são e salvo.",ep:22,g:244,l:1,wd:true,fm:true,w:1,p:1};
I.u[8918] = {n:"Capacete Melhorado",t:16,d:"Na teoria, este capacete melhorado permite cavalgar mais rápido os Escarafolhas sem você perder sua peruca. Simplesmente inestimável!",ep:22,g:25,l:1,wd:true,fm:true,w:10,p:1};
I.u[8919] = {n:"Asas de Madeiras Improvisadas",t:17,d:"Estas asas de madeira melhoradas foram acolchoadas e deixadas mais leves, além de um tecido de alta qualidade. Mas a estrutura ainda é de madeira e é difícil não quebrar!",ep:22,g:22,l:30,wd:true,fm:true,w:10,p:2633};
I.u[8922] = {n:"Bolsa de Kamas",t:24,d:"Esta bolsa contém uma quantia considerável de kama. Escolha com cuidado que você suborna.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8923] = {n:"Sacola de Batatas",t:24,d:"Uma sacola de batatas.. O que você vai fazer com uma sacola de batatas. Idiota.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8924] = {n:"Arco Rahm",t:2,d:"Era uma vez, um homem chamado Rahm se perdeu na floresta. Já ouviu sobre Viet Rham?",ep:22,g:59,l:151,wd:true,fm:true,w:10,an:10,e:[10,3,2,7,30,50,false,true],c:"CA>200",p:46105};
I.u[8925] = {n:"Pequeno Arco do Sono",t:2,d:"Este estranho arco foi esculpido por uma Sadidette durante um passeio sonâmbulo bastante produtivo. Só de olha, já faz você ficar com sono - serve tanto para o arqueiro quanto para o alvo.",ep:22,g:60,l:185,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,3,8,30,50,false,true],c:"CA>300&CI>300",p:51125};
I.u[8926] = {n:"Dagg\'Adou",t:5,d:"Estas adagas são perfeitas para puxar bananas e moer café. Alguns até as usam para esmagar maças e peras.",ep:22,g:65,l:175,wd:true,fm:true,w:10,an:13,tw:true,e:[7,3,1,1,30,30,false,false],c:"CA>250&CC>250&CS>150",p:49775};
I.u[8927] = {n:"Adagas Gaga",t:5,d:"Há muito tempo lá viveu um louco Sram chamado Gaga... Este sujeito roubou de um pobre para dar a um rico.",ep:22,g:66,l:171,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>350&CA>200",p:49280};
I.u[8928] = {n:"Adagas Porkeez",t:5,d:"Porkeez é melhor bebedor do que lutador, e deixe-me dizer a você que ele não conseguiu melhorar com o passar do tempo. Tudo igual, vai procurar uma rolha quando perde as adagas.",ep:22,g:67,l:158,wd:true,fm:true,w:10,an:13,e:[15,2,1,1,30,50,false,false],c:"CA>300",p:47275};
I.u[8929] = {n:"Kriss Tobal",t:5,d:"Isto não deve ser engano para o famoso cajado de nome similar. As lâminas neste implemento derramam sangue longe.",ep:22,g:68,l:149,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CI>250&CC>250",p:45875};
I.u[8930] = {n:"Fuchsia",t:6,d:"Muitos aventureiros orgulhosos recusaram esta arma por causa da cor. Muitos morreram por esta lâmina.",ep:22,g:78,l:163,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,30,50,false,false],c:"CA>300&CI>300",p:48245};
I.u[8931] = {n:"Az\'tech",t:6,d:"Esta espada costumava pertencer a um velho e poderoso Enutrof faminto. Como seu ego, ela é feita de ouro sólido.",ep:22,g:79,l:186,wd:true,fm:true,w:10,an:14,tw:true,e:[7,5,1,1,45,50,false,false],c:"CA>200&CC>200&CS>200",p:51275};
I.u[8932] = {n:"Kukri Kura",t:6,d:"Sorria! Diga xis! Perfeito! Foto tirada!",ep:22,g:80,l:179,wd:true,fm:true,w:10,an:14,e:[7,4,1,1,40,50,false,false],c:"CS>300&CA>150",p:50330};
I.u[8933] = {n:"Machado Enfermo",t:19,d:"Ourag\'han foi um velho Pandawa com pele tão suave que era conhecido como Slippiderm. Seu odor por outro lado fez com ele ficasse conhecido por outro nome. Ele batizou seu fiel machado da mesma forma.",ep:22,g:49,l:162,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,50,50,false,false],c:"CW>250&CS>300",p:47900};
I.u[8934] = {n:"Machado Michael Dougle",t:19,d:"Surge uma fúria quando um esquilo travesso rouba um grão de arroz durante um feriado de verão na ilha de Pandawa, Brouce Boulgour usava este machado para achatar e em cada bambu o esquilo saltava dentro. Os Pandawas na vila tem de alimentar metade do estoque de vinho de bambu para evitar de destruir toda a floresta. Acredite no velho Broucey.",ep:22,g:50,l:158,wd:true,fm:true,w:10,an:17,e:[7,5,1,1,50,50,false,false],c:"CC>150&CA>150&CI>150",p:47542};
I.u[8935] = {n:"Pá Hickory",t:8,d:"Mesmo como uma jovem Iopette, Mel sonhava em caçar dragões. Com uma pá como espada e uma rocha como dragão, ela afia a pele das costas. A mera menção da pá agora deixa a pobre rocha com convulsões.",ep:22,g:48,l:176,wd:true,fm:true,w:10,an:16,e:[7,4,1,1,35,50,false,false],c:"CC>250&CI>250",p:49985};
I.u[8936] = {n:"Pá Shattkitou",t:8,d:"Esta é uma pá selvagem que tentou morder seu dono a cada vez que ele a pegava. Faz sons incomuns quando está feliz e só pode ser pacificada com sons suaves de harmonia.",ep:22,g:49,l:137,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>150&CA>200",p:43945};
I.u[8937] = {n:"Pá de Egant",t:8,d:"Um Enutrof esperto tornou-se um pirata após notar que há mais tesouros para serem encontrados em corpos frescos do que em túmulos podres. Sua pá vermelha de sangue era o símbolo dos marinheiros destas águas com terror.",ep:22,g:50,l:156,wd:true,fm:true,w:10,an:16,e:[7,5,1,1,20,50,false,false],c:"CS>250&CI>250",p:49455};
