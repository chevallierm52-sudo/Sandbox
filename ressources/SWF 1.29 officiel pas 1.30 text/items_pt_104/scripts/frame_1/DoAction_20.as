I.u[8955] = {n:"Bala de Melão",t:42,d:"Com esta bala de melão preparada tradicionalmente, você poderá redescobrir o sabor açucarado dos velhos tempos. De longe, essa é a bala mais potente de todas.\nEste doce aumenta seus Pontos de Ação em 1 por 5 lutas.",ep:1,g:19,l:1,wd:true,fm:true,w:1,c:"PO!8947",u:true,p:1};
