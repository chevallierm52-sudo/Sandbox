I.u[8890] = {n:"Presente: Miau Tabby",t:89,d:"Se você chacoalhar este objeto com força e colocá-lo próximo a sua orelha, perceberá que é possível escutar um barulho estranho que lembra o choro de um animal. \nEi, espere! Tem um mascote aí dentro! Talvez seja melhor abri-la. Dentro dela, você encontrará comida e pó curativo de Eniripsa.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8891] = {n:"Presente: Esquilo Travesso",t:89,d:"Se você chacoalhar este objeto com força  e colocar próximo ao ouvido, escutará um barulho estranho... como um pequeno animal chorando... sim, atualmente talvez você não queira chacoalhá-lo... Ahhh, só abra esta coisa maldita. Você encontrará um mascote maravilhoso dentro dela, assim como um pouco de comida e pós curativos de Eniripsa.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8892] = {n:"Presente: Leopardo",t:89,d:"Se você chacoalhar este objeto com força  e colocar próximo ao ouvido, escutará um barulho estranho... como um pequeno animal chorando... sim, atualmente talvez você não queira chacoalhá-lo... Ahhh, só abra esta coisa maldita. Você encontrará um animal de estimação maravilhoso dentro dela, assim como um pouco de comida e pós curativos de Eniripsa.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
