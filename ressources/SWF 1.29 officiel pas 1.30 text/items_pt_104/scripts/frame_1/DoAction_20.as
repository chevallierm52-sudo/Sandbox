I.u[8964] = {n:"Garra de Ecaflip",t:6,d:"\"A sorte favore os destemidos\", sussurrou os díscipulos de Ecaflip. Agora você está pronto, será capaz de mostrar como joga. Esta espada prestigiosa e pura é extremamente rara.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
