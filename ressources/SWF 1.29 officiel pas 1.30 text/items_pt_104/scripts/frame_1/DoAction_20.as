I.u[9263] = {n:"Casca de Mushnid",t:96,d:"Um parasita nunca se sente tão em casa como quando está alojado na casca de um Mushnid. De vez em quando, a criatura se coça, arranca parte da pele doente que pode transformá-lo em um cogumelo se cair no lugar certo. Este cogumelo então encontrará o Mushnid para parasitar... como um ciclo vicioso, é algo bem nojento.",ep:23,g:109,l:113,wd:true,fm:true,w:1,p:10};
I.u[9264] = {n:"",t:32,d:"",ep:1,g:28,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9265] = {n:"Grande Tigela de Vidro de Miteters",t:24,d:"O vidro desta tigela é cheia de miteteres, você pode encontrar estas coisas estranhas nos Cracklers sujos.",ep:5,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9266] = {n:"Gordura de Geléia Real",t:24,d:"Essa gordura veio de uma Geléia Real. É um ingrediente essencial de poções paralisantes.",ep:7,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9267] = {n:"Tronco do Trumperelle",t:15,d:"Este tronco de Trumperelle tem o sopro tóxico de seu dono. Agora, é normalmente usado como um instrumento musical falso para acabar com a audiência nos \'infiltradores de concerto.\'",ep:23,g:764,l:125,wd:true,fm:true,w:1,p:10};
I.u[9268] = {n:"Martelo da Luz Sem Espírito",t:24,d:"Este Martelo da Luz parece ter perdido o espírito que lhe dava forças. De repente, ele não parece grande coisa.",ep:3,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9269] = {n:"Língua Mushmunch",t:15,d:"O Mushmunch tem uma língua de comprimento incrível e suavidade para lamber os esporos de suas companhias. Se não estou enganado, é o único tato invejável que eles têm.",ep:23,g:765,l:134,wd:true,fm:true,w:1,p:1};
