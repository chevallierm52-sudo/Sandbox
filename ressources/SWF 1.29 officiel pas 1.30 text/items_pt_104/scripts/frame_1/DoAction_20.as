I.u[9209] = {n:"Madeira de Carpino das Trevas",t:24,d:"Esta Madeira de Madeira de Carpino das Sombras foi enlameada pelo toque sujo do Treechnid Das Sombras. Agora ela poderá ser usada para fazer lâminas e outras armas demonícas",ep:9,g:176,l:1,wd:false,fm:true,w:0,p:1};
