I.u[9216] = {n:"Martelo Bateocrático",t:24,d:"Este é o Martelo da Luz, sem o espírito da luz! Domen pegou para si os poderes mais sinistros dessa arma, e por isso,  você pode forjar armas com segurança.",ep:16,g:751,l:1,wd:false,fm:true,w:0,p:1};
