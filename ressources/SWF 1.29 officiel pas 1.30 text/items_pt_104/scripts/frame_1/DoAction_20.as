I.u[8966] = {n:"Garra Ecaflip Magnífica",t:6,d:"Esta espada representa a encarnação do deus da sorte Ecaflip. Ter uma dessas prova que você tem muita sorte.",ep:1,g:81,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
