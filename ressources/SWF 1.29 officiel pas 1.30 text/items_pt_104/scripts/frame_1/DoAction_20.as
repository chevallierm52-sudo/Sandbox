I.u[9321] = {n:"A captura de Jiva",t:24,d:"Este livro relata a captura de Jiva de Djaul. O orgulhoso protetor não ficará muito feliz em descobrir que sua vergonhosa derrota foi registrada em um livro, pena que escrita em uma língua desconhecida.",ep:9,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9322] = {n:"Livro Encantado sobre a Captura de Jiva",t:24,d:"Este livro relata a captura de Jiva de Djaul. O orgulhoso protetor não ficará muito feliz em descobrir que sua vergonhosa derrota foi registrada em um livro, pena que escrita em uma língua desconhecida. Um mestre Xelor lançou um feitiço para decifrar a esta estranha escrita, mas continua indecifrável.",ep:9,g:95,l:1,wd:false,fm:true,w:0,p:1};
