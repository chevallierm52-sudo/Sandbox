I.u[9129] = {n:"Anel Blop Índigo Real",t:9,d:"Kroula tinha um plano.  Ele iria colocar este anel no dedão do pé, conseguir Blops para lamber seu pé e coletar litros de suco de Blop Real. Bem, o anel não entrou.",ep:5,g:156,l:80,wd:true,fm:true,w:10,s:105,p:15000};
I.u[9130] = {n:"Ougaamuleto",t:1,d:"Este rascunho do Grande Ougaa é usado em volta do pescoço... Um olhar faminto e um cuidado atento são essenciais.",ep:23,g:127,l:181,wd:true,fm:true,w:15,s:118,p:58000};
I.u[9131] = {n:"Anel Colette",t:9,d:"Uma jovem Craette chamada Colette uma vez perdeu a cabeça na Floresta Eltneg. A pobre garota cruzou o caminho da machadinha de Brouce Boulgoure e ele pensou que a garota era uma gigante. Sorte que ela não viveu, deveria ter morrido se descobrisse que foi confundida com uma gigante.",ep:23,g:146,l:188,wd:true,fm:true,w:10,s:119,p:57950};
I.u[9132] = {n:"Anel Tash",t:9,d:"Seus dedos são jovens demais para entrar em boas casas noturnas? Ficam nervosos perto de garotas? Bem, coloque este anel, ele adicionará alguns anos à sua idade e fará você ter auto-confiança.",ep:23,g:147,l:180,wd:true,fm:true,w:10,s:121,p:57822};
I.u[9133] = {n:"Anel Fungoso",t:9,d:"Balance seus dedos diante de quaisquer inimigos que são alérgicos a cogumelos. Deixa a luta mais rápida.",ep:23,g:148,l:186,wd:true,fm:true,w:10,s:107,p:56000};
I.u[9134] = {n:"Arco Camal",t:2,d:"Este arco foi feito de costelas afiadas, finas e flexíveis que normalmente são usadas para fazer camas do que armas mortais. Agora eles costumam propor algo mais permanente para dormir. Quanta coincidência.",ep:23,g:61,l:187,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>300&CI>300",p:58421};
I.u[9135] = {n:"Varinherelle",t:3,d:"Este fungo em formato de trombeta foi usado para chamar o menestrel vagabundo Jon Lemons para a cena de batalha. Quando ele começou a cantar, todos que não taparam os ouvidos morreram na hora. Quando o som e a música insuportáveis começaram a ficar populares, os deuses bloquearam a trompa e transformaram-na em uma varinha mágica relativamente inofensiva.",ep:23,g:66,l:184,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,45,50,false,true],c:"CI>300&CA>300",p:54284};
I.u[9136] = {n:"Cajado Cogu Mishish",t:4,d:"Os três pontos deste cajado podem atrair particulas de Plasmogrine presentes na briza quadramental. Para fazer isso, alinhe-os com os ponteiros de um relógio Xelor invertido, conte até sessenta (experimente até seis se você for um Iop) e aperte suas bochechas. Você terá cinqüenta por cento de chance de fazer um raio.. e transformar seus inimigos em Kirballs torrados.",ep:23,g:80,l:191,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>200&CC>200&CI>100",p:55000};
I.u[9137] = {n:"Cogu Cuteers",t:5,d:"Estas facas foram usadas para lixar os pés de reis e rainhas, aliviando-os de vermes e fungos que pegam no pé de qualquer um.",ep:23,g:69,l:187,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,30,50,false,false],c:"CA>450",s:119,p:57000};
I.u[9138] = {n:"Lâmina Canni",t:19,d:"As lâminas triplas deste machado têm sido usadas por muitos anos para cortar presunto e queijo três vezes mais rápido que o normal. Se você vir um guerreiro carregando uma, fuja o mais rápido possível... você provavelmente viu um canibal.",ep:23,g:51,l:176,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,50,50,false,false],c:"CC>450",s:120,p:54854};
I.u[9139] = {n:"Botas Ta",t:11,d:"Estas botas sem artelho são perfeitas para dar uma boa lição a quem ousar falar palavras proibidas.",ep:23,g:115,l:175,wd:true,fm:true,w:10,s:120,p:54852};
I.u[9140] = {n:"Botas Espora",t:11,d:"Contrário à errada concepção popular, os buracos nestes sapatos não estão lá para seus pés respirarem, mas para permitir que a desova do fungos dos seus pés escape e infecte os pés de outros aventureiros livres e felizes.",ep:23,g:116,l:181,wd:true,fm:true,w:15,s:121,p:57000};
I.u[9141] = {n:"Ragoat",t:17,d:"Se não estivesse tão embolorado, faria uma ótima toalha de mesa. Não se preocupe, você sempre pode secar a louça quando seus convidados não estiver olhando.",ep:23,g:154,l:181,wd:true,fm:true,w:10,s:119,p:58000};
I.u[9142] = {n:"Capa da Noite Mortífera",t:17,d:"Mais um vidro na estrada? Ah, bem, estradas são longas, e as noites são curtas. Essa capa é normalmente usada para manter os ratos em alerta enquanto concluem seus turnos noturnos infindáveis. Acabarei com todos no final, você sabe.",ep:23,g:150,l:190,wd:true,fm:true,w:10,s:107,p:60000};
I.u[9143] = {n:"Stringseticida",t:10,d:"Como o nome sugere, esta corrente mata qualquer mosca que estiver perto o bastante de seus doces. Apenas um pequeno conselho: nunca, jamais tente arrancar com seus dentes.",ep:23,g:132,l:192,wd:true,fm:true,w:20,s:107,p:48000};
I.u[9144] = {n:"Cinto Fungas",t:10,d:"Como você pode evitar fungos entre na virilha? Bem, certifique de ir para um lugar menos particular... seus quadris! Com este cinto, você não resolverá nada, apenas moverá o problema de lugar.",ep:23,g:133,l:177,wd:true,fm:true,w:10,s:121,p:58444};
I.u[9145] = {n:"Pedaço de Arbusto",t:10,d:"Pegue um Olmeiro, tire a casaca, deixe-o por alguns meses em uma poça de lama, cubra-o com fungos infecciosos, deixe sobre sua cama por uma semana enquanto dorme no chão, bata nele regularmente com um Blop gordo. É tudo que você precisa saber para fazer um cinto de Olmeiro que fede. Está feliz agora?",ep:23,g:134,l:179,wd:true,fm:true,w:10,s:120,p:68420};
I.u[9146] = {n:"Ougaacinto",t:10,d:"A etiqueta no cinto diz... \'Sinto muito, mas se você está procurando um meio de conseguir os poderes de Ougaa, este cinto não serve para você.\' Bem, é ótimo, não é.",ep:23,g:135,l:185,wd:true,fm:true,w:10,s:118,p:56000};
I.u[9147] = {n:"Cogu Ombrero",t:16,d:"Leve um Dora, cubra-o com cuspe de Gobball e suor de Iop, deixe-o cozinhar por algumas semanas e você terá uma idéia dos efeitos tóxicos do Cogu Ombrero. Tente de afastar das máquinas pesas enquanto o usa. De fato, fique longe de qualquer coisa pesada.",ep:23,g:221,l:185,wd:true,fm:true,w:10,s:119,p:48521};
I.u[9148] = {n:"Anel Blop Arco-Íris Real",t:9,d:"Ao invés de parar de tomar suco de Blop impuro, Shika Ingalsse tomou até ficar eufórica. Um dia, como ela estava cambaleando e caindo nos campos dourados, Shika aterrissou com estas asas. Quem disse que suco de Blop impuro deve ser tomado com moderação?",ep:5,g:157,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9149] = {n:"Amublop Cereja",t:1,d:"Quando Lorkos sair para sua viagem no Labirinto de Minotoro, a primeira coisa que ele colocou foi seu Amublop. Ninguém jamais descobriu o motivo.",ep:5,g:128,l:50,wd:true,fm:true,w:10,s:98,p:1000};
