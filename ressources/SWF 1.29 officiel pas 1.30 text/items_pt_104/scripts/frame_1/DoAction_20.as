I.u[9126] = {n:"Anel Blop Cereja Real",t:9,d:"Kroula tinha um plano.  Ele iria colocar este anel no dedão do pé, conseguir Blops para lamber seu pé e coletar litros de suco de Blop Real. Bem, o anel não entrou.",ep:5,g:153,l:80,wd:true,fm:true,w:10,s:102,p:15000};
I.u[9127] = {n:"Anel Blop Maçã Real",t:9,d:"Kroula tinha um plano.  Ele iria colocar este anel no dedão do pé, conseguir Blops para lamber seu pé e coletar litros de suco de Blop Real. Bem, o anel não entrou.",ep:5,g:154,l:80,wd:true,fm:true,w:10,s:103,p:15000};
