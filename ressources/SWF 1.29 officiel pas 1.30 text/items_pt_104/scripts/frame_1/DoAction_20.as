I.u[9059] = {n:"",t:24,d:"",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[9060] = {n:"Pedaço de papel rasgado",t:24,d:"Parte de uma carta que alguém rasgou. Nela, pode-se ler: \"...como pensávamos, estou certo de que esta investigação não leverá a lugar nenhum. Venha ao lugar de sempre me pagar o valor que combinamos... Onde as mulheres são bonitas...\" A carta está assinada com um X.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9061] = {n:"Exoram",t:32,d:"Exoram precisa ser escoltado para fora do campo goblin e levado ao templo Sram.",ep:1,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9062] = {n:"Documento sobre Xephires",t:24,d:"Este documento contém muitas informações sobre um rapaz chamado Xephires. O mais incrível é o tempo que ele gasta na Taverna de Astrub.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9063] = {n:"Lista de Milone",t:24,d:"Esta lista incrível foi entregue a você por Milone o Joalheiro. Ela lhe diz o que é necessário para a criação de uma jóia magnífica.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9064] = {n:"Gobball Real Babão",t:24,d:"Existe realmente alguma diferença para um babão? Com certeza não parece.",ep:1,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9065] = {n:"Carta para Milone",t:24,d:"Esta carta escrita as pressas explica para Milone que a jóia está em perigo... Então, por que você ainda está lendo isto? Ao trabalho!!!",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9066] = {n:"Carta do Chefe dos Ladinos",t:24,d:"Isto foi encontrado em um combate contra o arrombador na casa de Milone. Este joalheiro acabou de criar uma valiosa jóia. Roubá-la parece ser algo inevitável. Felizmente, Milone deu a ele a cópia, mas não foi graças a você. No verso da mensagem, porém, havia um guia para o esconderijo. Uma visita amigável? Porque sim! Apesar de que não acho boa idéia você ir sozinho.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9067] = {n:"Carta de Xephires",t:24,d:"Esta carta de Oto Mustam explica à Xephires o plano em detalhes.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9068] = {n:"Jóia de Milone",t:24,d:"Você obrigou Milone, o Joalheiro, a criar esta jóia. Será vendido por uma fortuna... Se você achar alguém que a queira, claro!",ep:16,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9069] = {n:"Nova carta para Xephires",t:24,d:"Oto descreve como corromper Xephires.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9070] = {n:"Espada Estranha",t:24,d:"Esta espada é realmente incomum. Você nunca viu nada parecido em Bonta.",ep:1,g:718,l:1,wd:false,fm:true,w:0,p:1};
I.u[9071] = {n:"Observações do Hospedeiro Feubuk",t:24,d:"O Hospedeiro Feubuk recebeu os Ecaflips que mencionaram o nome de Loudac.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9072] = {n:"Observações do Hospedeiro Pinchaut",t:24,d:"O Hospedeiro Pinchaut ouviu os guardas conversando sobre problemas que tiveram com uma gangue de Ecaflips.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9073] = {n:"Emblema do Ladino Ecaflip",t:24,d:"Você encontrou este emblema na Planície dos Ladinos Ecaflips, nos arredores de Cania.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9074] = {n:"Jóia de Amayiro",t:24,d:"Esta jóia será perfeita como isca para atrair o chefe ladino para a a sua armadilha",ep:1,g:111,l:1,wd:false,fm:true,w:0,p:1};
I.u[9075] = {n:"Carta Xelor",t:24,d:"Esta carta foi transmitida para você através de Marge o Joalheiro. Entregue a jóia para Ekysoy Kubnan na Taverna de Woodenglass. Será mais rápido para nós e mais lucrativo para você.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9076] = {n:"Jóia de Amayiro (falsa)",t:24,d:"Esta jóia parece com a que Amariyo enviou para você.",ep:1,g:110,l:1,wd:false,fm:true,w:0,p:1};
I.u[9077] = {n:"Crânio Feca",t:47,d:"Este crânio de Feca é um perfeito apoio de livro.",ep:1,g:34,l:1,wd:true,fm:false,w:1,p:1};
I.u[9078] = {n:"Crânio de Osamodas",t:47,d:"Um Tofu aqui, um Bwork Mago ali... Este discípulo de Osamodas perdeu a cabeça!",ep:1,g:33,l:1,wd:true,fm:false,w:2,p:1};
I.u[9079] = {n:"Crânio Enutrof",t:47,d:"Este troféu já estava velho antes mesmo de se tornar um troféu.",ep:1,g:32,l:1,wd:true,fm:false,w:2,p:1};
I.u[9080] = {n:"Crânio de Sram",t:47,d:"Este troféu já era mórbido antes e mesmo assim se tornou um troféu.",ep:1,g:31,l:1,wd:true,fm:false,w:2,p:1};
I.u[9081] = {n:"Crânio Xelor",t:47,d:"Este crânio é normalmente confundido com o da famosa múmia Tuthan Kamha. Mas não se engane, estas bandagens não são feitas com kamas derretidos e sim com papel machê.",ep:1,g:30,l:1,wd:true,fm:false,w:2,p:1};
I.u[9082] = {n:"Crânio Ecaflip",t:47,d:"Não há mais cabeças ou rabos para apostas, mas poderemos brincar com os ossos dos dedos!",ep:1,g:29,l:1,wd:true,fm:false,w:2,p:1};
I.u[9083] = {n:"Crânio Eniripsa",t:47,d:"Não seja cruel... Não é a caveira de um pardal!",ep:1,g:28,l:1,wd:true,fm:false,w:2,p:1};
I.u[9084] = {n:"Crânio Iop",t:47,d:"Este troféu está mais vazio agora do que quando estava supostamente vivo...",ep:1,g:27,l:1,wd:true,fm:false,w:1,p:1};
I.u[9085] = {n:"Crânio Cra",t:47,d:"Este belo crânio de Cra parece estar saindo de um escavação arqueológica recente.",ep:1,g:26,l:1,wd:true,fm:false,w:2,p:1};
I.u[9086] = {n:"Crânio Sadida",t:47,d:"O que? Há mesmo um crânio embaixo deste punhado de pêlos?!",ep:1,g:25,l:1,wd:true,fm:false,w:2,p:1};
I.u[9087] = {n:"Crânio Sacrier",t:47,d:"Este Sacrier não pode se exibir mais com estes milhares de pontos de vida.",ep:1,g:24,l:1,wd:true,fm:false,w:2,p:1};
I.u[9088] = {n:"Crânio Pandawa",t:47,d:"Alguém pensou que depois de tomar energético, o Pandawa teria uma bela enxaqeuca!",ep:1,g:23,l:1,wd:true,fm:false,w:2,p:1};
I.u[9089] = {n:"Bandeira da Patrulha Bontariana",t:24,d:"Você encontrou essa bandeira durante o combate com as forças Bontarianas.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9090] = {n:"Emblema da Patrulha Brakmariana",t:24,d:"Você encontrou esse crachá durante a batalha contra Brakmar.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9092] = {n:"",t:24,d:"",ep:16,g:86,l:1,wd:false,fm:true,w:0,p:1};
I.u[9094] = {n:"Veneno de Bwork",t:24,d:"Este material parece mais com uma simples geléia do que com veneno. Bworks não sabem fazer geléia, portanto só pode mesmo ser veneno.",ep:4,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9096] = {n:"Estrategista Bontariano",t:32,d:"O estrategista concordou em acompanhar você até o seu líder.",ep:16,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9097] = {n:"Crachá do Poderoso Homem da Milícia",t:24,d:"Você encontrou esse crachá em um soldado amedrontador, que acabou com vários guerreiros de Brakmar. Seu equipamento não combina nada com você",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9098] = {n:"Martelo de Nara",t:24,d:"Este martelo irá provar a Oto que você conseguiu banir o Armeiro Mercenário de Bonta.",ep:16,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9099] = {n:"Pedido de ajuda de Amayiro",t:24,d:"Assinado por Amayiro, essa carta foi um pedido oficial por ajuda.",ep:3,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9100] = {n:"Cueca de Lenglad",t:24,d:"Lengland não quer que as pessoas fofoquem sobre ele por muito tempo.",ep:1,g:84,l:1,wd:false,fm:true,w:0,p:1};
I.u[9101] = {n:"Caixa de Ferramentas de Nara",t:24,d:"Nessa caixa de ferramentas, estão todas as ferramentas de Nara, o ferreiro.",ep:3,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9103] = {n:"Plano de Ataque",t:24,d:"Essa carta, de uma semana atrás, explica os detalhes do plano de ataque a Bonta. Você precisará ser cauteloso, uma nota no fim diz que o plano ainda não foi confirmado e poderá ser alterado nos próximos dias pelo oficial Kapp Tenn. Por isso, você deverá investigar o que está acontecendo com o plano nesse exato momento.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9104] = {n:"Emblema da Patrulha do Cemitério",t:24,d:"Você encontrou esse emblema na patrulha Brakmariana que foi atacada por você no Cemitério dos Atormentados.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9105] = {n:"Carta de Danathor",t:24,d:"Alguem colocou esta carta na sua mochila enquanto Amayiro lhe entregava sua missão: Recupere os documentos, mas traga-os para mim ao invés de Amayiro. Você será recompensado. Danathor.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9106] = {n:"Documento Bontariano Secreto",t:24,d:"Estes documentos possuem muitas informações sobre o sistema de defesa Bontariano. Mas para quem você irá entregá-lo?",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9107] = {n:"Direções de espião Bontariano",t:24,d:"Invadir a Torre de Brakmar a meia-noite e coletar todos os documentos que encontrar no segundo andar. Volte para Bonta pela estrada leste. Não, isso não é o que VOCÊ precisa fazer, são instruções para o espião que você precisa salvar.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9108] = {n:"Documentos Secretos Brakmarianos",t:24,d:"Estes documentos possuem muitas informações sobre as defesas de Brakmar.",ep:14,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9109] = {n:"Bandana Esfarrapada",t:24,d:"Esta bandana esfarrapada está em seu estado normal. Coberta de muco, parece que foi usada como lenço por gerações de Wabbits. Ela pertence a Elturt, o que é bem óbvio, apesar do cheio de cawwots, você ainda pode sentir o cheiro podre. Deve conter alguma magia muito poderoso já que cheira tão mal assim após tantos anos.",ep:8,g:748,l:1,wd:false,fm:true,w:0,p:1};
I.u[9110] = {n:"Chifre de Fogornleg",t:24,d:"Você tentou assoprar ela, mas nada aconteceu.",ep:16,g:720,l:1,wd:false,fm:true,w:0,p:1};
I.u[9112] = {n:"Ordens do Espião de Brakmar",t:24,d:"Invadir a Torre de Bonta a meia-noite, derrotar todos que tentarem impedi-lo, e coletar todos os documentos no primeiro andar. Depois voltar para Brakmar pela estrada.\nNÃO, isso não é o que você precisa fazer, essas eram as instruções para o espião que você precisava encontrar.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9113] = {n:"Documentos Secretos Roubados",t:24,d:"Estes são os documentos que o espião ferido recuperou da Torre de Bonta.",ep:13,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9114] = {n:"Papéis Secretos Amassados",t:24,d:"Este documento foi encontrado por um espião ferido na Torre de Bonta. Eles foram levemente danificados por causa de uma luta entre os combatentes bontarianos.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9115] = {n:"Salada com pólen",t:24,d:"Esta salada foi preparada no caldeirão primordial, o que deu a ela propriedades especiais. Para descobrir o que são, você terá que provar. Infelizmente, ela está destinada ao consumo de Elturt. As vezes a vida consegue ser bem cruel.",ep:12,g:719,l:1,wd:false,fm:true,w:0,p:1};
I.u[9116] = {n:"Caixa de equipamentos",t:24,d:"Uma arma, um elmo, um escudo: essa caixa contém armas rudimentares mas efetivas para guerreiros.",ep:16,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9117] = {n:"Ougaammer",t:7,d:"Era apenas uma questão de tempo antes de eles começarem a fazer martelos com a cabeça deste idiota.",ep:23,g:67,l:180,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,50,50,false,false],c:"CV>1200",s:118,p:50000};
