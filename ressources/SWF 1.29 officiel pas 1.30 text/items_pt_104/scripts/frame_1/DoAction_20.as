I.u[9171] = {n:"Cinto Blop Cereja Real",t:10,d:"O menor cantor de blues do mundo está tocando blues para este cinto na menor guitarra no mundo. Ele perdeu sua fivela. Se os cintos pudessem chorar, este choraria para sempre.",ep:5,g:140,l:80,wd:true,fm:true,w:10,s:102,p:16000};
I.u[9172] = {n:"Cinto Blop Maçã Real",t:10,d:"O menor cantor de blues do mundo está tocando blues para este cinto na menor guitarra no mundo. Ele perdeu sua fivela. Se os cintos pudessem chorar, este choraria para sempre.",ep:5,g:141,l:80,wd:true,fm:true,w:10,s:103,p:16000};
