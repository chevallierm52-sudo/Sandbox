I.u[9042] = {n:"Poção Ataque Poderoso",t:14,d:"Esta poção deixará você tão nervoso que atacará automaticamente inimigo que estiverem bem próximos.",ep:0,g:36,l:1,wd:false,fm:true,w:1,c:"Pg>21,3",u:true,p:10};
I.u[9043] = {n:"Poção Mega Ataque",t:14,d:"Esta poção deixará você tão nervoso que atacará automaticamente inimigo que estiverem bem próximos.",ep:0,g:35,l:1,wd:false,fm:true,w:1,c:"Pg>21,4",u:true,p:10};
