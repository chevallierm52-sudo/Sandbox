I.u[9271] = {n:"A Promessa Maskara",t:24,d:"Este anel simboliza a promessa feita por Maskara... Ela disse que brincaria de bonecas quando você quisesse, e que ela seria a boneca.",ep:1,g:730,l:1,wd:false,fm:true,w:0,p:1};
I.u[9272] = {n:"Nota de Maskara",t:24,d:"Esta notinha pede que você espere trinta minutos antes de que ela o torne um brinquedinho recheado!",ep:1,g:44,l:1,wd:false,fm:true,w:0,p:1};
