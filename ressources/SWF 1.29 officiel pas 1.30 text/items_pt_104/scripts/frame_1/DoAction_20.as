I.u[8961] = {n:"Garra de Ecaflip",t:6,d:"O povo supersticioso acredita que uma simples perna de coelho em volta do pescoço pode trazer sorte e fortuna. Graças a esta lendária espada, você será capaz de testar a teoria. Esta lâmina é extremamente afiada e não lembra em nada sua antiga espada.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
