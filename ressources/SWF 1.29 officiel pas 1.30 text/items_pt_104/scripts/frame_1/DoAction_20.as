I.u[9153] = {n:"Amublop Cereja Real",t:1,d:"Este Amublop custa muito mais que um simples Amublop, mas veja pelo lado bom... você venderá por um bom preço também, especialmente se for para um astrubiano.",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
