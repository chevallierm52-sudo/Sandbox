I.u[8879] = {n:"Anel Polido",t:9,d:"Infelizmente, este anel só está polido do lado de foda. Você coloca em seu dedo através de um buraco cheio de fragmentos de rochas afiadas. É recomendado para  Sacriers.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Amufafah",t:1,d:"Este colar faz o usuário desejar gritar já que o bigode de Mufafah faz cócegas em seus mamilos.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Anel de Solo",t:9,d:"Solo era é um inútil, como ele mesmo se descreve. Mas não tenha misericórdia, ele foi enforcado em público na praça principal da vila após roubar as calcinhas da mulher do chefe. Solo não era um sujeito inteligente, mas certamente um...",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Poção da Casa da Guilda",t:12,d:"Esta poção permite a você voltar para a casa de sua guilda.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Miau Tabby Fantasma",t:90,d:"Este Miau Tabby não deixou o mundo dos vivos ainda. Você vai encontrar um meio de ressuscitá-lo ou vai abandoná-lo covardemente de uma vez por todas?",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Transformação de Miau Tabby Fantasma",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
