I.u[9157] = {n:"Amublop Arco-Íris Real",t:1,d:"Se você não colocasse montes de aditivos e cores artificiais nesta geléia, não teria nenhuma cor ou sabor. Agora quanta diversão deve ter?",ep:5,g:136,l:90,wd:true,fm:true,w:10,s:106,p:21000};
I.u[9158] = {n:"Blooptas Cereja",t:11,d:"Sua boca fica engraçada quando você diz o nome deste objeto? Bem, deixe dizer a você, se eu encontrar cara a cara o ladrão que suas your \'Boot.. Bloops... Bloo...\', você terá tempo o bastante para correr enquanto eu descubro como pronunciar a palavra. Então pare de reclamar.",ep:5,g:117,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9159] = {n:"Bloopts Maçã",t:11,d:"Sua boca fica engraçada quando você diz o nome deste objeto? Bem, deixe dizer a você, se eu encontrar cara a cara o ladrão que suas \'Boot.. Bloops... Bloo...\', você terá tempo o bastante para correr enquanto eu descubro como pronunciar a palavra. Então pare de reclamar.",ep:5,g:118,l:50,wd:true,fm:true,w:10,s:99,p:1000};
