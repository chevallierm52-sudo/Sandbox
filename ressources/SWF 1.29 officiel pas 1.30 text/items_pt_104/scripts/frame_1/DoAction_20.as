I.u[9277] = {n:"Olho do Cogu Mish",t:109,d:"O Cogu Mish tem horrível hábito de coçar seus olhos sarnentos.  O hábito se torna ainda pior quando ele coça seus olhos com a sua arma.",ep:23,g:587,l:152,wd:true,fm:true,w:1,p:1};
I.u[9278] = {n:"Lâmina de Cogu Tup",t:15,d:"O Cogu Tup tem dois braços, duas pernas e duas cabeças. Isso tudo significa que ele é duas vezes mais idiota que você esperava.",ep:23,g:766,l:144,wd:true,fm:true,w:1,p:1};
I.u[9279] = {n:"Saliva de Cogu Rhume",t:15,d:"Este cuspe é delicioso, um pouco viscoso. É normalmente usado para lubrificar armas. Ou para guerreiros que gostam de lutar sem roupas.",ep:23,g:45,l:149,wd:true,fm:true,w:1,p:1};
I.u[9280] = {n:"Ougaad",t:15,d:"Esta fera só tem quatro espinhos na cabeça, mas que espinhos... tão afiados quanto talhadeiras!",ep:23,g:40,l:900,wd:true,fm:true,w:1,p:1};
