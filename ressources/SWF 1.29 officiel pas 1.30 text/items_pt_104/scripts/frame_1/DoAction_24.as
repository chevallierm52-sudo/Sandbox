I.u[11155] = {n:"",t:24,d:"",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11156] = {n:"Lele Yucca",t:24,d:"Essa flor foi popularizada pela letra de Jorg Farmboy, e todos os outros cantores o odeiam por causa disso.",ep:0,g:841,l:1,wd:false,fm:true,w:0,p:1};
I.u[11157] = {n:"Tulipa Osuction",t:24,d:"Triturada e fervida, ingerir essa tulipa é recomendado se você quiser perder peso rapidamente. A desvantagem é que isso irá fazer sua carteira perder peso também.",ep:0,g:842,l:1,wd:false,fm:true,w:0,p:1};
I.u[11158] = {n:"Rosa Nelson",t:24,d:"Descoberta pelo famoso botânico Yosef, essa rosa entrega o aroma de um Frighog suado, e lembra a você de seus momentos íntimos.",ep:0,g:843,l:1,wd:false,fm:true,w:0,p:1};
I.u[11159] = {n:"Mimosa Modas",t:24,d:"Esta flor conjura uma sombra com o formato de um Osamodas.",ep:0,g:844,l:1,wd:false,fm:true,w:0,p:1};
I.u[11160] = {n:"Ruibarbo Ershop",t:24,d:"Os caules desse ruibarbo saboroso são ocos, e quando propriamente montados, produzem um som quando é soprado. Normalmente é acompanhado por música vocal.",ep:0,g:845,l:1,wd:false,fm:true,w:0,p:1};
I.u[11161] = {n:"Rosenberg Willow",t:24,d:"A pessoa que descobriu essa requintada flor rapidamente proclamou que ela era uma das mais belas já descobertas, e eu concordo totalmente.",ep:0,g:846,l:1,wd:false,fm:true,w:0,p:1};
I.u[11162] = {n:"Rosa Tyler",t:24,d:"Um Lorde do Tempo Xelor descobriu essa linda flor, mas foi forçado a se separar dela.",ep:0,g:847,l:1,wd:false,fm:true,w:0,p:1};
I.u[11163] = {n:"Rosa de Lima",t:24,d:"Dizem que essa rosa é abençoada pelos deuses, algo que eles não dizem sobre você.",ep:0,g:848,l:1,wd:false,fm:true,w:0,p:1};
I.u[11164] = {n:"Heléboro Elboy",t:24,d:"As pétalas deste heléboro cheiram como amendoins torrados.",ep:0,g:849,l:1,wd:false,fm:true,w:0,p:1};
I.u[11165] = {n:"Stachys Jenrel",t:24,d:"Houve um tempo onde mastigar essa flor era símbolo de status entre a alta sociedade. Eles achavam que isso fazia eles pareceram espertos, o que seria verdade, caso Iops fossem capazes de pensar.",ep:0,g:850,l:1,wd:false,fm:true,w:0,p:1};
I.u[11166] = {n:"Lírio Sander",t:24,d:"O nome dessa flor é um tributo a Sander, o famoso almirante da frota de Frigost, que morreu batendo sua cabeça contra a parede da casa de seu rival, Al Hiartus.",ep:0,g:851,l:1,wd:false,fm:true,w:0,p:1};
I.u[11167] = {n:"Lírio Allen",t:24,d:"O pólen desse lírio tem a propriedade única de trazer coceira a algumas pessoas, ou invocar uma sensação eufórica de felicidade em outros.",ep:0,g:852,l:1,wd:false,fm:true,w:0,p:1};
