I.u[11070] = {n:"Hata Marie",t:32,d:"Hata era um prisioneiro dos Bworks, e agora ela quer que você a escolte para fora da vila.",ep:0,g:30,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[11071] = {n:"Extração de Origens de Goultard",t:25,d:"Manchada, amassada e suja, essas poucas páginas estão quase ilegíveis. Contudo, através da fina capa de sujeira você consegue ler algumas palavras. Essas páginas são uma extração de um esquecido livro que detalha as origens de Goultard.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
