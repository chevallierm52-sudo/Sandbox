I.u[11076] = {n:"Presente: Conjunto Congelado",t:89,d:"Se você chacoalhar esta caixa com vigor, irá descobrir que não está vazia. Parece que finalmente os deuses não estão enganando você. Por favor note que este presente só pode ser aberto em um servidor 2.0 de DOFUS.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11077] = {n:"Martelo de Lonne",t:7,d:"Quando ele quer ressoar seus oponente, Lonne tem mais do que cordas - ele utiliza um martelo. Uma coisa é certa: faíscas irão voar!",ep:0,g:75,l:54,wd:false,fm:true,w:20,an:0,e:[6,5,1,1,42,50,false,false],c:"CA>20&CV>40",s:163,p:9700};
I.u[11078] = {n:"Capa de Lonne",t:17,d:"Esta capa de couro, apesar de leve, irá acompanhar você em todas as suas incríveis corridas nas costas de um Dragossauro...",ep:0,g:176,l:55,wd:false,fm:true,w:10,an:0,s:163,p:7900};
I.u[11079] = {n:"Chapéu de Lonne",t:16,d:"Antes de ser usado por Lonne Jenone, este chapéu pertenceu ao sargento Payper, que era um cara bem na dele, e que quase nunca metia a colher na vida dos outros",ep:0,g:261,l:55,wd:false,fm:true,w:10,an:0,s:163,p:8050};
I.u[11080] = {n:"Botas de Lonne",t:11,d:"Este versátil par de botas irá garantir total liberdade de movimento, sendo essa a razão pela qual Lonne Jenone as usa quando ele dança com Boolobos.",ep:0,g:160,l:55,wd:false,fm:false,w:10,an:0,s:163,p:7925};
I.u[11082] = {n:"Botas de Gobbowl",t:11,d:"Essas botas foram especialmente desenhadas para destruir as caneleiras de seus oponentes, e depois as canelas delas, e depois seus próprios pés.",ep:0,g:157,l:28,wd:false,fm:true,w:10,an:0,c:"Sc=11",p:2300};
I.u[11083] = {n:"Anel Gobbowl",t:9,d:"Você pode utilizar este anel para furar a bola de Gobbowl quando quiser aproveitar tranquilamente um intervalo de jogo.",ep:0,g:187,l:31,wd:false,fm:true,w:10,an:0,c:"Sc=12",p:2666};
I.u[11084] = {n:"",t:16,d:"",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6400};
I.u[11085] = {n:"Cinto de Gadjet",t:10,d:"Se você vestir esse cinto de cabeça para baixo e apertá-lo com força suficiente, você pode ser capaz de ativar seu sistema de módulo eletromagnético. Isso nunca funcionou, mas você pode ativá-lo mesmo assim. Ai você pode vendê-lo para alguém ainda mais ingênuo que você.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6358};
I.u[11086] = {n:"Capa de Gadjet",t:17,d:"Gadjet fez esta capa na esperança de que ela permitiria que ele voasse e assim escapar mais facilmente das surras administradas diariamente por sua esposa.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6350};
I.u[11087] = {n:"Anel de Gadjet",t:9,d:"Usado há varias gerações de artesãos, este anel irá proteger sua mão de pancadas de martelo. Infelizmente, ele nunca é vendido em pacotes de cinco.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6453};
I.u[11088] = {n:"Chapéu de Grillian",t:16,d:"Grillian era um excelente mago. Ele é muito famoso por ter reinventado o pó alegre, após ter esquecido como fabricava.",ep:0,g:270,l:49,wd:false,fm:true,w:10,s:164,p:6325};
I.u[11089] = {n:"Capa de Grillian",t:17,d:"Essa capa supostamente deve proteger seu superior de mordidas de plantas-carnívoras.",ep:0,g:181,l:48,wd:false,fm:true,w:10,s:164,p:6250};
I.u[11090] = {n:"Aviso de Procurado",t:24,d:"Este é um aviso de procurado para Lethaline Sigibul.",ep:0,g:821,l:1,wd:false,fm:true,w:0,p:0};
I.u[11091] = {n:"Botas de Grillian",t:11,d:"Grillian, o mago, trocou um anel mágico por este par de botas. Parece que ele saiu perdendo nessa troca, já que elas não eram nem acolchoadas.",ep:0,g:164,l:46,wd:false,fm:true,w:10,an:0,s:164,p:5600};
I.u[11092] = {n:"Amuleto de Grillian",t:1,d:"Grillian usava este amuleto em seu pescoço quando... Quando... Bah, isso importa? Ele morreu e agora o amuleto é seu.",ep:0,g:164,l:45,wd:false,fm:true,w:10,s:164,p:5450};
