I.u[11174] = {n:"Chave do Calabouço Mastogob",t:84,d:"Use esta chave para entrar na estufa onde o Mastogob Real se esconde.",ep:0,g:257,l:1,wd:false,fm:true,w:1,p:1};
I.u[11175] = {n:"A Chave Pingwin",t:84,d:"A chave contém alto nível de amianto e como resultado flutua muito bem em água ou em molho para salada. Você também pode usá-la para entrar no Calabouço Pingwin.",ep:0,g:255,l:1,wd:false,fm:true,w:1,p:1};
