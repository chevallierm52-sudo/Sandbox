I.u[10899] = {n:"Cajado do Manitou de Zoth",t:4,d:"Manitou de Zoth é um ex-estivador - ele movia problemas ao invés de resolvê-los. Tendo isso em vista, a comunidade Zoth tinha medo dele porquê ele conseguia gritar mais alto do que todos os outros, o que era o bastante para transformá-lo em chefe de Zoth. Seu cajado ainda é animado pelo seu espírito. Você pode encarná-lo com sucesso se equipar esta arma.",ep:0,g:91,l:50,wd:false,fm:false,w:10,an:12,e:[5,3,1,1,40,50,false,false],p:6000};
I.u[10900] = {n:"Casca de Ovo",t:24,d:"Isso que você está segurando em suas mãos é tudo o que resta dos enormes ovos que apareceram na Península dos Dragonetes. Não serve nem pra fazer um cinzeiro decente.",ep:0,g:767,l:1,wd:false,fm:true,w:0,p:0};
I.u[10901] = {n:"Presa Gigantesca",t:24,d:"Grasmera e Grozilla em uma batalha épica. Tudo o que resta é esta presa gigantesca. Quem vai acreditar que você estava lá?",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:0};
I.u[10902] = {n:"",t:24,d:"",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10903] = {n:"Chave da Toca de Manitou Zoth",t:24,d:"Usar esta chave irá permitir que você lute contra Manitou Zoth",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[10904] = {n:"Grozillamuleto",t:1,d:"Você ganhou este amuleto graças a sua incomparável capacidade em quebrar ovos sem fazer um omelete.",ep:0,g:157,l:51,wd:false,fm:true,w:10,p:7050};
I.u[10906] = {n:"Escudo de Escama",t:82,d:"Criado a partir de uma das escamas do Grozilla, este é um escudo pesado com uma estatura excepcional. Apenas raros e temíveis lutadores podem usá-lo com orgulho.",ep:0,g:51,l:1,wd:false,fm:false,w:10,p:0};
I.u[10907] = {n:"Grofus",t:23,d:"Bem, ai está. Você conseguiu: Fez parte do maior exercício de controle de nascimento de dragões de todos os tempos. Como resultado, deverá comer omeletes durante todas as próximas semanas.",ep:0,g:17,l:1,wd:false,fm:true,w:10,p:0};
I.u[10908] = {n:"",t:89,d:"",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10909] = {n:"",t:48,d:"",ep:0,g:241,l:1,wd:false,fm:true,w:1,p:1};
I.u[10910] = {n:"",t:89,d:"",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10911] = {n:"",t:12,d:"",ep:0,g:26,l:1,wd:false,fm:false,w:0,c:"Sc=666",u:true,p:0};
I.u[10912] = {n:"Presente de Nawtal Ridículo",t:89,d:"Nem todos os presentes de Nawtal são do mesmo tamanho. Aventureiros tímidos recebem apenas presentes ridículos, além de serem ridicularizados e terem só o direito de chorarem feito criancinhas.",ep:0,g:2,l:6,wd:false,fm:true,w:10,u:true,p:1};
I.u[10913] = {n:"Presente de Nawtal Satisfatório",t:89,d:"Quem quer que seja que embrulhou este presente já imaginava, eles sabiam que você seria estúpido o bastante para pensar que seu conteúdo poderia de algum modo ser melhor do que são na verdade.",ep:0,g:2,l:7,wd:false,fm:true,w:20,u:true,p:1};
I.u[10914] = {n:"Presente de Nawtal Potencialmente Overpower",t:89,d:"Se você acreditar no que está escrito na etiqueta, este presente tem potencial. Contudo, como qualquer aventureiro experiente lhe dirá - nunca acredite no que está escrito na etiqueta.",ep:0,g:2,l:8,wd:false,fm:true,w:30,u:true,p:1};
I.u[10915] = {n:"Ordens de Harry Kwismas",t:24,d:"Harry Kwismas revelou a identidade de um dos monstros responsáveis pela invasão a oficina do Papai Nowel. Se você não for capaz de derrotar o monstro em duas horas, você pode voltar até Harry e pegar uma nova ordem.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10916] = {n:"Parabéns de Harry Kwismas",t:24,d:"Harry Kwismas está muito satisfeito com sua vitória. Volte em 24 horas, ele irá precisar de sua ajuda de novo se todas as caixas de presentes ainda não estiverem sido encontradas.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10917] = {n:"Pequena caixa de presentes",t:24,d:"Esta pequena caixa vem da oficina do Papai Nowel. Você será um verdadeiro herói se retorná-la pra ele.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10918] = {n:"Caixa de presentes",t:24,d:"Esta caixa vem da oficina do Papai Nowel. Você será um verdadeiro herói se retorná-la pra ele.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10919] = {n:"Grande caixa de presentes",t:24,d:"Esta grande caixa vem da oficina do Papai Nowel. Você será um verdadeiro herói se retorná-la pra ele.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10920] = {n:"Biscoitos de Nawtal",t:24,d:"Esses deliciosos biscoitos feitos a mão foram assados com amor. É uma pena você não poder experimentá-los.",ep:0,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[10921] = {n:"Presente selado de Minotobola",t:24,d:"Ninguém sabe o que este presente contém, o Minotobola levou o segredo até o túmulo. Você realmente precisa ser lembrado de que isso foi sua culpa? Você deve estar enjoado de ouvir isso.",ep:0,g:715,l:1,wd:false,fm:true,w:0,p:1};
I.u[10922] = {n:"Escudo do Mestre Lenhador",t:82,d:"Este escudo mostra a todos os outros aventureiros que você foi um pioneiro em sua profissão.",ep:0,g:57,l:1,wd:false,fm:true,w:10,c:"PJ=2,100",p:1};
