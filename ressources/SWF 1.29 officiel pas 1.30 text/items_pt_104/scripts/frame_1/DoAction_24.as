I.u[11102] = {n:"Gota de Neve",t:35,d:"Endurecida pelo crima de Frigost, esta flor é muito mais resistente do que seu aspecto delicado sugere. Dito isso, para preservar as propriedades alquímicas de uma planta tão rara, ela deve ser manuseada com cuidado.",ep:0,g:635,l:100,wd:false,fm:true,w:1,p:0};
I.u[11103] = {n:"Sacola de Gotas de Neve",t:100,d:"Esta enorme sacola contém uma impressionante quantidade de Gotas de Neve.",ep:0,g:57,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11104] = {n:"Quaquack Improvisado",t:18,d:"Além dos reinos de Tofu, Gobball e até o Iop, existe uma criatura habitando a dimensão da idiotice inimaginável até mesmo para sua mente cretina: o Quaquack!",ep:0,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[11105] = {n:"Fantasma de Quaquack Improvisado",t:90,d:"Este Quaquack ainda não abandonou o mundo dos vivos. Você irá encontrar uma maneira de ressuscitá-lo ou irá abandoná-lo covardemente de uma vez por todas?",ep:0,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[11106] = {n:"Peixe de Gelo",t:41,d:"Espinhas tão afiadas quanto lâminas de Bworker, escamas tão duras quanto a casca de Carvalho Mole, e olhos tão negros quanto as penas de um Corvo. Este peixe pode ser formidável, mas servido em um prato é simplesmente delicioso.",ep:0,g:403,l:100,wd:false,fm:true,w:1,p:100};
I.u[11107] = {n:"Alpino",t:38,d:"Essa árvore parece tremer quando você a toca. Após todos os golpes de machado que você deu nela, não é surpresa que ela esteja com medo de você.",ep:0,g:677,l:100,wd:false,fm:true,w:5,p:100};
I.u[11109] = {n:"Frosteez",t:34,d:"Não apenas esse surpreendente cereal é resistente ao clima extremo de Frigost, ele dá um delicado sabor de chocolate a qualquer leite em que for molhado.",ep:0,g:552,l:100,wd:false,fm:true,w:1,p:100};
I.u[11110] = {n:"Obsidiano",t:39,d:"Duro o suficiente para arranhar vidro e negro o suficiente para sugar sua moral, esta pedra perdeu todo o seu calor da lava de onde veio. Seria perfeita para um túmulo, desde que não seja o seu.",ep:0,g:90,l:100,wd:false,fm:true,w:5,p:0};
I.u[11111] = {n:"Sacola de Peixe de Gelo",t:100,d:"Esta enorme sacola contém uma impressionante quantidade de Peixe de Gelo.",ep:0,g:59,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11112] = {n:"Sacola de Alpino",t:100,d:"Essa enorme sacola contém uma impressionante quantidade de Alpino.",ep:0,g:58,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11113] = {n:"Sacola de Frosteez",t:100,d:"Esta enorme sacola contém uma impressionante quantidade de Frosteez.",ep:0,g:60,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11114] = {n:"Sacola de Obsidiano",t:100,d:"Esta enorme sacola contém uma impressionante quantidade de Obsidiano.",ep:0,g:34,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11115] = {n:"Peixe Aperirel",t:30,d:"A primeira chegou, você pode sentir seu cheiro. Bem, ou é a primavera ou o Uridnac podre que está grudado em você.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[11116] = {n:"Uridnac",t:94,d:"Este pequeno peixe é muito carinhoso com pessoas e se liga a elas com facilidade.\nContudo, seu ritmo biológico é peculiar: Ele é apenas ativo no mês de Aperirel quando Silouate esquenta a água pura onde o peixe prospera.",ep:0,g:19,l:1,wd:false,fm:false,w:1,c:"SG=3&POX11115",u:true,ut:true,p:0};
I.u[11117] = {n:"Lã de Mastogob",t:57,d:"Mastogobs precisam ser tosados uma vez ao ano, assim como axilas de Pikokos.",ep:0,g:211,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11118] = {n:"Clavícula de Mastogob",t:47,d:"Não sobrou um só pedaço de carne comestível neste osso, então não tem porque roê-lo.",ep:0,g:660,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11119] = {n:"Orelha de Mastogobbly",t:106,d:"Frigostianos normalmente comem essas orelhas com vinagrete, como elas são horríveis, e Frigostianos adoram vinagrete.",ep:0,g:624,l:96,wd:false,fm:true,w:10,p:1};
I.u[11120] = {n:"Couro de Mastogoblly",t:56,d:"Dizem que se você ferver este couro 8 vezes em água, ele se torna utilizável. Isso é uma idéia Frigostiana de piada engraçada, aliás.",ep:0,g:659,l:96,wd:false,fm:true,w:10,p:1};
I.u[11121] = {n:"Olho de Guerreiro de Mastogob",t:109,d:"Este olho deve ter visto várias nádegas de novas Mastogobs fêmeas na época dele. Agora esse pobrezinho só pode ver o tecido do seu bolso.",ep:0,g:590,l:112,wd:false,fm:true,w:10,p:1};
I.u[11122] = {n:"Chifre de Guerreiro de Mastogob",t:47,d:"Os Frigostianos mais descuidados jogam um jogo com Guerreiros Mastogobs enquanto eles estão dormindo, tentando jogar seus três anéis metálicos em volta de seus chifres sem acordá-los. Não surpreendentemente, ninguém nunca saiu desse jogo vivo.",ep:0,g:661,l:112,wd:false,fm:true,w:10,p:1};
I.u[11123] = {n:"Dente da Sabedoria de Mastogob",t:24,d:"Você puxou esse dente da mandíbula de um Mastogob ainda vivo. O que há de errado com você? Você é louco ou coisa assim?",ep:0,g:822,l:1,wd:false,fm:true,w:0,p:1};
I.u[11124] = {n:"Entranhas Congeladas",t:24,d:"Essas entranhas congelaram assim que você as puxou da cavidade do corpo.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11125] = {n:"Pata de Pingwin",t:24,d:"Como se não fosse ruim o bastante não possuir braços, o que irá acontecer ao Pingwin que você retirou as patas?",ep:0,g:823,l:1,wd:false,fm:true,w:0,p:1};
I.u[11126] = {n:"Crânio Etéreo",t:24,d:"Como pode um crânio ser etéreo? Após pensar nisso durante muito tempo, você se pegou rindo a resposta dessa pergunta.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11127] = {n:"Lágrima Volun",t:24,d:"Esta lágrima simbolisa a resiliência na face da opressão.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11128] = {n:"Lágrima Magmática",t:24,d:"Ao invés de molhar, essa lágrima queima qualquer material combustível que entrar em contato, então não há riscos de sua maquiagem sair quando seu namorado lhe trocar pelo Dragossauro dele.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11129] = {n:"Givranchy",t:24,d:"Extrato de Snowfoux é muito popular entre as fêmeas Snowfoux, e faz disso um ótimo presente para seus pretendentes ou rivais.",ep:0,g:870,l:1,wd:false,fm:true,w:0,p:1};
I.u[11130] = {n:"Lichen Petrificado",t:24,d:"Este caroço de Lichen foi congelado pelo frio. Assim que for descongelado, você pode utilizar como uma variante Frigostiana de Pudim de Pizza.",ep:0,g:827,l:1,wd:false,fm:true,w:0,p:1};
I.u[11131] = {n:"Objeto Estranho",t:24,d:"Você deve ser um completo idiota para não entender como um objeto como esse é útil.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11132] = {n:"Colher",t:24,d:"Graças a você que roubou a colher dele, aquele pobre urso deve usar seus dedos para comer. Seu monstro.",ep:0,g:824,l:1,wd:false,fm:true,w:0,p:1};
I.u[11133] = {n:"Pena Vibrante de Pingwin",t:94,d:"Seguindo o exemplo do Tofu Real, alguns Pingwins criam uma pena vibrante que é cheia de mágica. Mas quanto a sua utilidade...",ep:0,g:20,l:50,wd:false,fm:false,w:1,c:"Qc=555&Qa!555",u:true,p:500};
I.u[11134] = {n:"Apewicubo",t:94,d:"Tem alguma coisa presa neste cubo de gelo cortado do Lago Congelado de Frigost. Você tem duas opções se quiser descobrir o que é: esperar que o gelo derreta, ou, como qualquer pessoa de respeito, bata nele até que se quebre.",ep:0,g:21,l:50,wd:false,fm:true,w:1,u:true,p:500};
I.u[11135] = {n:"Cauda de Mastogob Lendário",t:65,d:"Esta pequena cauda lendária estava muito bem escondida dentro do grosso pêlo do Mastogob Lendário. Isso não parou você de encontrá-lo e puxá-lo fora, não é?",ep:0,g:752,l:118,wd:false,fm:true,w:10,p:1};
I.u[11136] = {n:"Lã de Mastogob Lendário",t:57,d:"É sujo, mas é lendário. Lembra um pouco de alguém.",ep:0,g:212,l:118,wd:false,fm:true,w:10,p:1};
I.u[11137] = {n:"Caroço de Rato Atrofiado",t:24,d:"Isso é tudo o que restou de Ratos Atrofiados no celeiro do Vovô. Você realmente não perdoou, não é?",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11138] = {n:"Semente de Pêra",t:24,d:"Não, não é um Cérebro de Mastogob que você está segurando em sua mão, é uma Semente de Pêra. A diferença é óbvia: a semente de pêra é fria ao contato.",ep:0,g:828,l:1,wd:false,fm:true,w:0,p:1};
I.u[11139] = {n:"Semente de Emmer",t:24,d:"Emmer é uma versão antiga da farinha que é atualmente cultivada em Amakna. Qualquer um iria pensar que o tempo não passa em Frigost.",ep:0,g:829,l:1,wd:false,fm:true,w:0,p:1};
I.u[11140] = {n:"Semente de Granola",t:24,d:"Antes usada como farinha para biscoitos, o cultivo dessa semente foi banido graças a uma aposta estúpida. O antigo prefeito de Frigost apostou com um Ecaflip que ele iria comer apenas um biscoito feito de Farinha de Granola. Ele perdeu a aposta, e sua fortuna.",ep:0,g:830,l:1,wd:false,fm:true,w:0,p:1};
I.u[11141] = {n:"Semente de Pynekone",t:24,d:"Essa pequena semente vem de um Pynekone maduro.",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11142] = {n:"Semente de Lentilha",t:24,d:"Colocar uma Semente de Lentilha em cada um dos seus olhos não irá fazer você ver melhor, mas certamente irá deixar você mais estúpido do que o normal.",ep:0,g:832,l:1,wd:false,fm:true,w:0,p:1};
I.u[11143] = {n:"Grão de Sal",t:24,d:"Sparo não valeu a pena pelo seu sal, e isso explica o porquê dele terminar em um barril. Não diga que não avisamos.",ep:0,g:833,l:1,wd:false,fm:true,w:0,p:1};
I.u[11144] = {n:"Semente de Granada",t:24,d:"Puxe o caule fora, conte até dois e jogue essa semente o mais longe que puder. Se ela cair próxima a um Crackler ele explodirá em ódio. Jovens milicianos terminam seu treinamento de semente de Granada muito rapidamente.",ep:0,g:834,l:1,wd:false,fm:true,w:0,p:1};
I.u[11145] = {n:"Semente de Feno",t:24,d:"Crianças moradoras de bairros pobres atacam as pessoas civilizadas com essas sementes. Você deve estar se perguntando como isso funciona, mas é melhor não saber, de verdade.",ep:0,g:835,l:1,wd:false,fm:true,w:0,p:1};
I.u[11146] = {n:"Semente de Basalto",t:24,d:"Essa semente passou por um aumento massivo na temperatura seguido de um congelamento extremo, o que a tornou muito frágil.",ep:0,g:836,l:1,wd:false,fm:true,w:0,p:1};
I.u[11147] = {n:"Semente de Couve",t:24,d:"Essa semente possui uma alta quantidade de carbono, e quando estamos na lua cheia, emite um estranho ruído. Você deve ser muito estúpido ou um Iop para acreditar em tamanha besteira.",ep:0,g:837,l:1,wd:false,fm:true,w:0,p:1};
I.u[11148] = {n:"Semente do Mal",t:24,d:"Uma antiga lenda diz que a farinha feita dessa semente foi usada para fazer o pão de sanduíches de Steak Demoníaco, prato preferido do lorde demônio Rushu. Ainda hoje, os Frigostianos sabem disso.",ep:0,g:838,l:1,wd:false,fm:true,w:0,p:1};
I.u[11149] = {n:"Semente de Estrela",t:24,d:"Se você gosta de falar ou de cantar no chuveiro, esta semente é para você. Comê-la irá deixar você sem vergonha nenhuma de falar em público. Mas tome cuidado, já que seus efeitos são muito temporários.",ep:0,g:839,l:1,wd:false,fm:true,w:0,p:1};
I.u[11150] = {n:"",t:24,d:"",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11151] = {n:"",t:24,d:"",ep:0,g:832,l:1,wd:false,fm:true,w:0,p:1};
I.u[11152] = {n:"",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
