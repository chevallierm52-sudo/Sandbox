I.u[11055] = {n:"Chapéu Pynekone",t:16,d:"Acolchoada com cabelo de Miau e coberta com pele, este chapéu é extremamente inflamável. Você não deve sentar sobre ele se suas calças estiverem em chamas.",ep:0,g:263,l:41,wd:false,fm:true,w:10,an:0,s:162,p:4553};
I.u[11056] = {n:"Capa Pynekone",t:17,d:"No calor, as escamas dessa capa abrem para ajudar seu suor a evaporar. Quando chove, as escamas dessa capa abrem para deixar a chuva entrar e lavar seu traseiro.",ep:0,g:178,l:42,wd:false,fm:true,w:10,an:0,s:162,p:4875};
I.u[11057] = {n:"Cinto Pynekone",t:10,d:"Este cinto é composto de escamas arranjadas em espiral de acordo com Vibronacci.",ep:0,g:174,l:40,wd:false,fm:true,w:10,an:0,s:162,p:4305};
I.u[11058] = {n:"Anel Pynekone",t:9,d:"Quem você estava esperando seduzir com um anel desses?",ep:0,g:189,l:43,wd:false,fm:true,w:10,an:0,s:162,p:5100};
