I.u[10860] = {n:"Poção de Troca de nome",t:12,d:"Você pode usar essa poção para trocar o seu nome. Ninguém irá lembrar que você costumava se chamar Xx-naruto-matador-feca-xX-Br-Huehue. Uma nova vida, livre de piadinhas e tiração de sarro o espera. Finalmente, você será alguém.",ep:0,g:718,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10861] = {n:"",t:12,d:"",ep:0,g:717,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10862] = {n:"Poção de Troca de Sexo",t:12,d:"Esta poção, para ser bebida diretamente da garrafa, irá permitir que você se torne ele, se era ela, ou que se torne ela, se era ele. Para ser consumida sem moderação.",ep:0,g:719,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10863] = {n:"Tarzantula",t:18,d:"Tarzantula é incrivelmente mal comportada, ela pula por todos os lados, grita o tempo todo e morde qualquer um que encontra - mas você a ama do mesmo jeito, mesmo sem saber o porquê. Mãe Natureza a abençoou com um apetite voraz, e assim essa devoradora de almas adora comer Mosquitos e Larvas.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10864] = {n:"Coguzim",t:18,d:"Esse Cogu Cogu único foi criado por uma alcatéia de Boolobos, o que ainda não explica o motivo dele ter axilas tão peludas. Esse devorador de almas adora frutos do mar, e irá comer apenas criaturas da praia.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10865] = {n:"Tofulia",t:18,d:"Tofulia foi atingida por raios 11 vezes enquanto crescia. Você irá tomar um choque sempre que encostar nela, e ela irá lhe dar um choque se não encostar nela. Cabe a você escolher. Esse devorador de almas detesta ratos, e irá avançar neles sempre que tiver a chance de comer.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10866] = {n:"Sting",t:18,d:"Sting, o Prespic, adora alcachofras com sangue de Bherb, ama cabelo de Pikoko e as músicas de Jon Lemon. Ele parece gostar de sua companhia tambem. Esse devorador de almas devora apenas as criaturas da Selva Escura.",ep:0,g:61,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
