I.u[10955] = {n:"Anel do Corvo Negro",t:9,d:"Não há nada incomum em um pássaro no anel.",ep:0,g:188,l:33,wd:false,fm:true,w:10,s:155,p:3150};
I.u[10956] = {n:"Botas do Corvo Negro",t:11,d:"Como o restante do conjunto do Corvo Negro, este par de botas foi passado de geração pra geração, pé a pé. Isso explica o forte cheiro de Clakoss...",ep:0,g:158,l:32,wd:false,fm:true,w:10,s:155,p:2850};
I.u[10957] = {n:"Capa do Corvo Negro",t:17,d:"Alguns fios, uma agulha, algumas penas retiradas de restos de corvos e voilá! Você possui uma das capas mais chiques!",ep:0,g:174,l:35,wd:false,fm:true,w:10,s:155,p:3400};
I.u[10958] = {n:"Elmo do Corvo Negro",t:16,d:"Você não pode se esconder, você foi desmascarado! Então, o Corvo Negro é você afinal! Você teria escapado, se não fossem aquelas crianças metidas e aquele cachorro!",ep:0,g:259,l:32,wd:false,fm:true,w:10,s:155,p:2900};
I.u[10959] = {n:"Lança Penetrante do Corvo Negro",t:6,d:"Pode ter demorado um pouco, mas aqui está, finalmente em suas mãos: a Lança do Corvo Negro!",ep:0,g:98,l:39,wd:false,fm:true,w:10,an:14,e:[13,5,1,1,40,50,false,false],c:"CA>60&CV>60",s:155,p:4400};
I.u[10960] = {n:"Presente: Anel do Corvo Negro",t:89,d:"Se você chacoalhar esta caixa vigorosamente, irá descobrir que ela não está vazia. Pelo menos uma vez, talvez os deuses não tenham lhe pregado uma peça.\nAtenção, este presente só pode ser aberto em servidores de DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10961] = {n:"Presente: Lança Penetrante do Corvo Negro",t:89,d:"Se você chacoalhar esta caixa vigorosamente, irá descobrir que ela não está vazia. Pelo menos uma vez, talvez os deuses não tenham lhe pregado uma peça.\nAtenção, este presente só pode ser aberto em servidores de DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10962] = {n:"Cajado de Plunder",t:4,d:"Não há nada melhor do que este cajado para desentupir canos, ou as narinas de seus oponentes. Esta arma ainda está impregnada com a magia de Plunder. Talvez você consiga encarná-lo se equipá-la.",ep:0,g:92,l:30,wd:false,fm:false,w:10,an:12,e:[6,3,1,1,50,50,false,false],c:"CV>30",s:156,p:2650};
I.u[10963] = {n:"Botas de Plunder",t:11,d:"A sola dessas botas são esponjosas, então ela pode absorver a sujeira de esgoto e ir soltando a cada passo, permitindo que você refaça seus passos com facilidade.",ep:0,g:156,l:32,wd:false,fm:true,w:10,s:156,p:2900};
I.u[10964] = {n:"Cinto de Plunder",t:10,d:"Plunder pendurava seu tesouro neste cinto. Você ver uma pequena válvula no seu interior. Essa válvula permite que o cinto encha de ar, se transformando em uma bóia. Um item essencial para se aventurar em esgotos.",ep:0,g:172,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10965] = {n:"Amuleto de Plunder",t:1,d:"Este amuleto foi especialmente criado para não ficar preso nos cabelos do pescoço de Plunder, então você pode utilizá-lo sem medo no seu suvaco ou até em sua mão.",ep:0,g:160,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10966] = {n:"Transformação de Larva",t:31,d:"Fofocas insinuam que sua natureza verdadeira foi revelada. Talvez eles estejam certos?",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=21",p:0};
I.u[10967] = {n:"Cérebro de Larva",t:69,d:"Você precisa estar realmente desesperado para comer isso. Não, não faça isso!",ep:0,g:113,l:1,wd:false,fm:true,w:0,c:"Sc=21",u:true,ut:true,p:1};
I.u[10968] = {n:"Twansfowmação de Wabbit",t:31,d:"Um tanto surpreendente, você não está tão parcial com Cenouwawas no momento.",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=22",p:0};
I.u[10969] = {n:"Poção Wefwescante",t:12,d:"A doçura de uma cenouwawa, o frescor de um Dragossauro corredor de maratonas. Não há nada melhor para manter sua energia. Boa saúde, viva o império!",ep:0,g:141,l:20,wd:false,fm:true,w:1,c:"Sc=22",u:true,ut:true,p:1};
I.u[10970] = {n:"Suor de Dragossauro",t:15,d:"Santo Bwork! Como você conseguiu pegar isso? E, mais especificamente, porquê? Você é realmente estranho.",ep:0,g:773,l:1,wd:false,fm:true,w:1,p:1};
I.u[10971] = {n:"Sacola Atrevida",t:81,d:"Com essa sacola pendurada em um ângulo bem disposto em cima de seu ombro, você poderá reclamar enquanto mantém aquele sorriso charmoso em seu rosto!",ep:0,g:25,l:20,wd:false,fm:true,w:10,c:"Sc=23",p:1};
I.u[10972] = {n:"Seguidor Corvo",t:31,d:"Apesar de muito afetivo, você suspeita que este volátil aviano irá voar embora ao primeiro sinal de perigo.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,c:"Sc=24",p:0};
I.u[10973] = {n:"Poção: Destino Desconhecido",t:12,d:"Seus instintos dizem para você não engolir o conteúdo deste jarro. Não apenas seus instintos, seu nariz também. A mistura cheira a suvaco de um Bwork centenário.",ep:0,g:189,l:20,wd:false,fm:true,w:1,c:"Sc=25",u:true,p:10};
I.u[10974] = {n:"Fada-de-artifício Festiva",t:74,d:"FES-TA! FES-TA! FES-TA!",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"Sc=26",ut:true,p:1};
I.u[10975] = {n:"Espada de Phong Huss",t:6,d:"Ela pode cheirar a champagne mofado, mas não há nada de mofado na lâmina dessa espada. Esta arma ainda está imbuida com a mágica de Phong Huss. Talvez você consiga encarná-lo se equipá-la.",ep:0,g:97,l:33,wd:false,fm:false,w:10,an:14,e:[12,6,1,1,40,60,false,false],c:"CS>50",s:157,p:3100};
I.u[10976] = {n:"Anel de Phong Huss",t:9,d:"Fungi geralmente possuem colares, mas Phong Huss preferia anéis, possivelmente porque com eles ele podia se vangloriar sobre ter dedos.",ep:0,g:185,l:33,wd:false,fm:true,w:10,s:157,p:3150};
I.u[10977] = {n:"Cinto de Phong Huss",t:10,d:"Phong Huss vestia este cinto de um jeito meio desleixado. Ele tentou utilizar como ombreira para assim pendurar sua espada. O cinto beliscou seus mamilos em várias ocasiões, mas além disso, não tinha outro uso.",ep:0,g:170,l:30,wd:false,fm:true,w:10,s:157,p:2650};
I.u[10978] = {n:"Botas de Phong Huss",t:11,d:"Os pés de um fungi raramente são limpos - costumam estar cobertos de micélio. Os pés de Phong Huss não eram exceções a essa regra e ele fazia questão de escondê-los em suas botas. Elas não cheiram muito bem, mas são muito boas para criar cogumelos. Quem irá vencer, seu estômago ou seu nariz?",ep:0,g:153,l:32,wd:false,fm:true,w:10,s:157,p:2900};
I.u[10979] = {n:"Martelo de Ektope",t:7,d:"Ektope tinha grande prazer em arrastar sua arma atrás dele. Ele era muito conhecido por ser preguiçoso como um Gobball, mas seu principal motivo era alertar seus oponentes de sua sensacional chegada. Esta arma ainda está imbuida com a magia de Ektope. Talvez você consiga encarná-lo se equipá-la.",ep:0,g:74,l:30,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,50,50,false,false],c:"CA>50",s:158,p:2800};
I.u[10980] = {n:"Amuleto de Ektope",t:1,d:"Esse amuleto fantasma deve ser extremamente poderoso, se alguém acreditar nas lendas sobre fantasmas, é claro.",ep:0,g:159,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10981] = {n:"Anel de Ektope",t:9,d:"É um fato conhecido que fantasmas de verdade não tem dedos. Como eles eram capaz de utilizar esse anel?",ep:0,g:186,l:32,wd:false,fm:true,w:10,s:158,p:2970};
I.u[10982] = {n:"Cinto de Ektope",t:10,d:"Um bêbado Capitão Kradoc certa vez trombou com Ektope quando saia de uma festa na pousada Ripate. “Ectoplasma de Patins” ele se surpreendeu. Pobre Capitão Kradoc, o álcool estava pregando peças nele, Ektope nunca usou patins na vida.",ep:0,g:171,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10984] = {n:"Amuleto YeCh\'Ti",t:1,d:"Quando seus inimigos vêem este amuleto ao redor do seu pescoço fino eles irão pensar que você é realmente tão peludo quanto o YeCh\'Ti, o que irá deixá-los apavorados.",ep:0,g:162,l:66,wd:false,fm:false,w:10,an:0,p:11500};
I.u[10985] = {n:"Miau de Neve",t:18,d:"Este Miau de Neve conheceu o inverno do extremo norte, mesmo sem nunca ter realmente visto o extremo norte. Ninguém sabe como ele chegou em Amakna, apesar que os anciãos dizem que ele foi importado da ilha de Frigost para contra-atacar a sempre em expansão população Wabbit. Assim, este devorador de almas só irá comer Wabbits.",ep:0,g:62,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10986] = {n:"Fantasma de Miau de Neve",t:90,d:"Este Miau de Neve ainda não deixou o mundo dos vivos. Você irá encontrar um modo de ressuscitá-lo ou irá abandoná-lo covardemente de uma vez por todas?",ep:0,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[10987] = {n:"Cinto Gelado",t:10,d:"Este cinto esfria quadris, órgãos e o ardor daqueles que se atrevem a usá-lo. Para ser dado para aqueles pretendentes mais teimosos.",ep:0,g:173,l:35,wd:false,fm:true,w:10,s:141,p:3500};
I.u[10988] = {n:"Chapéu Gelado",t:16,d:"Este chapéu é ideal para manter sua cabeça fria e suas idéias frescas. Dito isso, se você não quiser ficar parecendo um feio cubo de gelo, terá de encontrar outra alternativa.",ep:0,g:260,l:35,wd:false,fm:true,w:10,s:141,p:3450};
I.u[10989] = {n:"Capa Gelada",t:17,d:"Jon Lemon vestia uma capa parecida durante seu famoso concerto na Clareira Brouce Boulgoure. Aqueles que não ficaram surdos ainda se lembram do clímax do concerto, quando ele parou de cantar após ficar preso no gelo por causa de sua própria capa.",ep:0,g:175,l:33,wd:false,fm:true,w:10,s:141,p:3150};
I.u[10990] = {n:"Botas Geladas",t:11,d:"Pesada e dura, essas botas não parecem ser particularmente especiais, mas suas solas de gelo irão permitir que você patine sem a necessidade de gelo. É claro, você irá precisar encontrar uma superfície coberta com lâminas de patins de gelo, mas nesses tempos malucos não deve ser muito difícil de conseguir.",ep:0,g:159,l:33,wd:false,fm:true,w:10,s:141,p:3000};
I.u[10991] = {n:"Presente: Miau de Neve",t:89,d:"Se você chacoalhar esta caixa vigorosamente, irá descobrir que ela não está vazia. Pelo menos uma vez, talvez os deuses não tenham lhe pregado uma peça.\nAtenção, este presente só pode ser aberto em servidores de DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
