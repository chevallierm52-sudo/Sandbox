I.u[11041] = {n:"Espada Viopal",t:6,d:"Pesada, desajeitada e feia, como Goultard conseguiu se tornar um guerreiro formidável com essa espada medíocre? Manejá-la não irá transformá-lo em nada, apenas ridículo.",ep:0,g:99,l:40,wd:false,fm:true,w:10,an:14,e:[6,4,1,1,40,40,false,false],s:159,p:4000};
I.u[11042] = {n:"Corda de Doggona",t:10,d:"Este cinto foi dado a Goultard por seu pai pelo seu quinto aniversário. É mais sólido do que a aparência sugere, e irá manter suas calças bem firmes na sua cintura. Também pode ser usado como varal ou corda de pular.",ep:0,g:175,l:40,wd:false,fm:true,w:10,s:159,p:4300};
I.u[11043] = {n:"Chapocalipse",t:16,d:"Este chapéu é tão apertado que aperta seu crânio e causa fortes alucinações. Felizmente, Goultard o usava quando era jovem, e além disso, ele possui um crânio pequeno, o que trai suas raízes.",ep:0,g:265,l:41,wd:false,fm:true,w:10,s:159,p:4500};
I.u[11044] = {n:"Restos da família de Goultard",t:24,d:"Alguns ossos abandonados e algumas jóias fúnebres é tudo o que resta da família de Goultard.",ep:0,g:818,l:1,wd:false,fm:true,w:0,p:0};
I.u[11045] = {n:"Manto Youllbea",t:17,d:"Goultard usava este manto até descobrir as três irmãs, quando ele foi esquecido atrás de um velho armário.",ep:0,g:179,l:43,wd:false,fm:true,w:10,s:159,p:5050};
I.u[11046] = {n:"Colar Amaldiçoado de Cabotine",t:24,d:"A aura amaldiçoada deste colar é tão poderosa que você está com dificuldades para se livrar dessa porcaria.",ep:0,g:819,l:1,wd:false,fm:true,w:0,p:0};
I.u[11047] = {n:"Da Rorc",t:32,d:"Da Rorc se entregou, escolte-o até Lethaline.",ep:0,g:29,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11048] = {n:"Dicas para Dark Vlad",t:24,d:"Um pequeno mapa e uma poção de inteligência. Até mesmo Dark Vlad conseguirá escapa de seu labirinto com isso.",ep:0,g:820,l:1,wd:false,fm:true,w:0,p:0};
I.u[11049] = {n:"Chapéu Clementine",t:16,d:"Coloque este chapéu na cabeça, descasque-o por algumas horas e com sorte você poderá encontrar uma minúscula semente.",ep:0,g:262,l:32,wd:false,fm:true,w:10,s:161,p:2900};
I.u[11050] = {n:"Capa Clementine",t:17,d:"A capa, que solta um agradável aroma cítrico conforme você anda, irá transformar você em uma poderosa armadilha para Moskitos.",ep:0,g:177,l:32,wd:false,fm:true,w:10,s:161,p:2850};
I.u[11051] = {n:"Amuleto Clementine",t:1,d:"Se você molhar este amuleto em seu copo, sua água sem sabor irá se transformar em uma bebida deliciosa com sabor cítrico.",ep:0,g:161,l:32,wd:false,fm:true,w:10,s:161,p:2925};
I.u[11052] = {n:"Botas Clementine",t:11,d:"A sola dessas botas são feitas de uma dura pele de uma fruta cultivada em uma ilha cuja existência continua desconhecida a meros mortais.",ep:0,g:161,l:34,wd:false,fm:true,w:10,an:0,s:161,p:3205};
