I.u[11008] = {n:"Certificado de Canil: Miau de Neve",t:77,d:"Este certificado descreve as características do Miau de Neve que você deixou no canil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[11009] = {n:"Hormônio de Miau de Neve",t:48,d:"Este hormônio de crescimento desidratado pode ser utilizado para criar uma poderosa poção para melhorar características de uma mascote.",ep:0,g:262,l:1,wd:true,fm:true,w:1,p:10};
I.u[11010] = {n:"Poção de Encantamento: Miau de Neve",t:116,d:"Usar esta poderosa poção irá aumentar a capacidade de sua mascote permanentemente. Mas tome cuidado, apenas uma dose irá funcionar. Tentar mais de uma vez irá produzir resultados desapontantes.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PO=10985",u:true,p:10};
I.u[11011] = {n:"Raposa Malhada",t:18,d:"Mais maluca do que uma Raposa comum, mas muito menos ruiva, essa mascote pode nadar embaixo d\'água sem a necessidade de tapar seu nariz. Ela se alimenta de criaturas que vivem na Árvore Keeholo.",ep:0,g:63,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11012] = {n:"Au-Au Malhado",t:18,d:"Esta mascote pode ter listras, mas isso não irá impedi-la de cheirar seu traseiro ou tentar se aliviar em seu carpete. O que você esperava? Esta mascote adora caçar as criaturas que vivem no Pântano de Sidimote.",ep:0,g:64,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11013] = {n:"Quaquack Negro",t:18,d:"Este feio Quaquack negro foi rejeitado por sua própria família porque era diferente: ele amava escutar as músicas de Jon Lemon, o famoso menestrel. Talvez ele fosse apenas incompreendido. Após uma infância difícil, ele decidiu se vingar arbitrariamente de todas as criaturas da família Corvo. Ele os devora sem piedade.",ep:0,g:65,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11014] = {n:"Borcego Desbotado",t:18,d:"Esta mascote passou tempo demais em chuva ácida. Ela não brilha no escuro e não é mágica, mas você pode fazer uma salada muito potente com sua saliva. Ela irá apenas comer criaturas da família das Geléias.",ep:0,g:66,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11015] = {n:"Gupin",t:18,d:"Esta estranha criatura atravessou os oceanos em um bloco de gelo para escapar de um porto perdido. Esse devorador de almas irá apenas se alimentar de criaturas da praia.",ep:0,g:67,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
