I.u[10784] = {n:"Amuleto de Aprendiz",t:1,d:"Ninguem faz a menor idéia de que poderes este amuleto atrás, mas todos sabem o que ele leva: sua credibilidade.",ep:0,g:163,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10785] = {n:"Anel de Aprendiz",t:9,d:"Você já ouviu falar de Pedra Papel Tesoura, certo? Bem, este anel te protege do Papel.",ep:0,g:190,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10786] = {n:"Pele de Koalak Imaturo",t:24,d:"Este pequeno Koalak imaturo do qual você arrancou a pede, não concordou em dá-la a você. Mas quem se importa, você é mais forte e mais cruel.",ep:20,g:811,l:1,wd:true,fm:true,w:1,p:10};
I.u[10787] = {n:"Asa de Dragossauro Gengibre Selvagem",t:24,d:"Esta Asa cheira a enxofre. Qualquer criador de Dragossauro vai dizer que é a parte mais macia para um churrasco. Só não esqueça de temperá-la porque a Asa é a parte mais sem sabor.",ep:2,g:812,l:29,wd:true,fm:true,w:1,p:1};
I.u[10788] = {n:"Asa de Dragossauro",t:24,d:"O Dragossauro doméstico é bem mais gostoso do que seu primo selvagem. Ele não tem gosto de enxofre e a carne é deliciosamente saborosa. É por isso que ele é a comida favorita de todas as crianças.",ep:2,g:813,l:29,wd:true,fm:true,w:1,p:1};
I.u[10789] = {n:"Pêlos de Koalak Florestal",t:24,d:"Estes pêlos cobertos por seiva de Kaliptus são muito brilhantes. Infelizmente, eles não podem ser usados para alta-costura, pois cheiram como um Dragossauro morto.",ep:20,g:814,l:1,wd:true,fm:true,w:1,p:100};
I.u[10790] = {n:"Osso de Mama Koalak",t:24,d:"Mama Koalak tem ossos sólidos que não quebram apesar de seu peso. O mesmo não é verdade para Jony Lenon, famoso menestrel que perdeu a capacidade de seus dois braços quando foi esmagado pela imensa coxa de Mama Koalak.",ep:20,g:815,l:1,wd:true,fm:true,w:1,p:10};
I.u[10791] = {n:"Pêlos de Barba do Warko Marrom",t:24,d:"Estes pêlos são urticantes o suficiente para transformar os simples beijos do Warko Marrom em armas de destruição em massa.",ep:20,g:816,l:1,wd:true,fm:true,w:1,p:10};
I.u[10792] = {n:"Poção de Cura de Aprendiz",t:12,d:"Este frasco continha um líquido de procedência duvidosa... Agora contém uma poção que irá recuperar um pouco do seu PV. Ele foi lavado antes? Te desafio a descobrir!",ep:0,g:2,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10793] = {n:"Pão de Aprendiz",t:33,d:"É seco, você quebrará seus dentes com ele, ele fede a cueca de Bwork não lavada, mas irá recuperar um pouco de seus PV\'s, então pare de fazer essa cara e engula logo.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10794] = {n:"Botas de Aprendiz",t:11,d:"Quente por dentro e fria por fora, essas botas irão permitir que você chute traseiros de bonecos de neve sem derreter suas nádegas.",ep:0,g:2,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10795] = {n:"Peixe de Aprendiz",t:49,d:"Se você bater neste peixe, irá escutar um eco. Bata em si mesmo enquanto come este peixe e irá se transformar em um instrumento musical.",ep:0,g:92,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10796] = {n:"Pastoso de Aprendiz",t:69,d:"Pegue uma pequena quantidade de qualquer coisa indigerível de Amakna, bata com um pouco de pimenta vermelha, envolva-a com um pouco de gordura podre e você vai terminar com essa... Coisa. Empurrada até a boca de um jovem Feca, ela faz dele um ótimo boneco, apesar.",ep:0,g:113,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10797] = {n:"Espada de Aprendiz",t:6,d:"Retirada de sua bainha, essa espada pode cortar presunto, Enutrofs, homens com uma perna só, dançarinas e Enutrofs dançarinos de uma perna só enrolados em um pedaço de presunto. Infelizmente, é inútil para derrotar monstros.",ep:0,g:96,l:1,wd:false,fm:true,w:1,an:14,e:[5,4,1,1,40,50,false,false],s:150,p:1};
I.u[10798] = {n:"Escudo de Aprendiz",t:82,d:"Este escudo não o protegerá de sua própria estupidez.",ep:0,g:55,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10799] = {n:"Cinto de Aprendiz",t:10,d:"Tendo problemas em esconder sua adaga em sua cueca? Tudo bem, você pode guardá-la entre suas partes e este cinto!",ep:0,g:10,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10800] = {n:"Capa de Aprendiz",t:17,d:"Você poderá voar com essa capa em volta de seus ombros. Apenas feche seus olhos, feche seus punhos, abra sua boca, estique seus braços e pule de um penhasco gritando \"EU POSSO VOAR!\". Momentos depois, você acordará com duas pernas quebradas.",ep:0,g:3,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10801] = {n:"Chapéu de Aprendiz",t:16,d:"Este chapéu malfeito esconde sua calvície admiravelmente.\nInfelizmente, não é grande o bastante para esconder sua falsa modéstia.",ep:0,g:264,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10802] = {n:"Dragoone Dourado",t:18,d:"Mais dourado do que um Dragoone Preto, menos rosa do que um Dragoone Rosa, e mais raro do que um Dragoone Esqueleto, esta mascote irá atrair toda as atenções a você, mesmo se você for tão feio quanto um Piwi. Essa mascote devoradora de almas irá apenas comer os Dopples que podem ser encontrados nos templos de raça.",ep:0,g:57,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:151,p:1};
I.u[10803] = {n:"",t:32,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10804] = {n:"Presente: Dragoone Dourado",t:89,d:"Se você chacoalhar este objeto vigorosamente e colocá-lo próximo a sua orelha, você vai ouvir um barulho estranho... Como um pequeno animal chorando... É, talvez seja melhor você não chacoalhar... Ahh, apenas abra logo essa coisa. Você irá encontrar uma ótima mascote dentro, além de um pouco de comida e pó de Eniripsa.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
