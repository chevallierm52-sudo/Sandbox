I.u[1393] = {n:"O Metronome",t:7,d:"Este Martelo foi feito de um relógio, o famoso relógio tragado pelo Crocodyl que devorou a mão de Capitão Hawkfish. Entretanto, botamos a mão no relógio, a mão ainda está faltando...",ep:5,g:21,l:54,wd:true,fm:true,w:20,an:15,e:[8,6,1,1,40,40,false,true],c:"CI>62&CW>22",p:9700};
