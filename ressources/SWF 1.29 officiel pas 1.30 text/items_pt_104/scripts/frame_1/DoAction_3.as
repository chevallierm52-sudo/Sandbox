I.u[1321] = {n:"Poção do Esquecimento: ‘Flecha de Desaceleração\'",t:43,d:"Esta poção permite ao seu consumidor desaprender um nível do feitiço de Cra: \'Flecha Desaleração\'.",ep:2,g:34,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1322] = {n:"Poção do Esquecimento: \'Flecha Explosiva\'",t:43,d:"Esta poção permite ao seu consumidor desaprender um nível do feitiço de Cra: \'Flecha Explosiva\'.",ep:2,g:34,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1323] = {n:"Poção do Esquecimento: \'Perícia com Arco\'",t:43,d:"Esta poção permite ao seu consumidor desaprender um nível do feitiço de Cra: \'Perícia com Arco\'.",ep:2,g:34,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1324] = {n:"Erva dos Gatos",t:36,d:"Esta planta faz os seguidores de Ecaflip ficarem com água na boca.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1325] = {n:"Casca de Noz",t:46,d:"Normalmente resistente a todo tipo de golpes, esta casca simboliza a ideologia do Feca.",ep:2,g:52,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1326] = {n:"Pedra Sanguinária",t:51,d:"Esta pedra resistente e afiada foi aparentemente usada contra algo ou alguém. Tjhis é um item cru e perigoso que ilustra perfeitamente as características de um seguidor de Iop.",ep:2,g:47,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1327] = {n:"Osso Talhado",t:47,d:"É um item perigoso e sombrio. Uma vez trabalhado, é tão perigoso quanto um Sram.",ep:2,g:48,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1328] = {n:"Kama enigmática",t:15,d:"Uma cabeça de Tofu com um estranho chapéu decora esta kama.",ep:1,g:182,l:1,wd:true,fm:true,w:10,p:1};
I.u[1329] = {n:"Madeira Flexível",t:38,d:"Este grande galho de madeira, com sua forma flexível e curvilínea, faz você pensar imediatamente nos Cras.",ep:2,g:49,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1330] = {n:"Amuleto de Itbe",t:1,d:"Criação original do ourives John Les Nonnes, agora é umas das jóias mais clássicas.",ep:1,g:31,l:10,wd:true,fm:true,w:5,p:500};
I.u[1331] = {n:"Medalha Oly",t:1,d:"Oly era uma seguidora de Iop com um único talento;\r\n            ela era boa na cozinha. Dizem que o próprio Iop deu a ela esta medalha a fim de compensá-la por suas fraquezas em luta. Apenas pessoas de coração puro podem usar esta medalha.",ep:7,g:23,l:51,wd:true,fm:true,w:10,c:"Ps=1&Pa>10",p:7000};
I.u[1332] = {n:"Velho Trevo de Quatro Folhas",t:36,d:"Os trevos de quatro folhas são mais raros que os de cinco folhas. Então, quando você encontrar um, você deverá secá-lo entre pergaminhos de feitiços.",ep:2,g:50,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1333] = {n:"Poção de Fagulha",t:26,d:"Graças à fraca mágica de fogo que contém, esta poção de aquecimento é usada para encantar vários tipos de itens.",ep:3,g:1,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1334] = {n:"Sacola de Enxofre",t:48,d:"Esta pequena sacola exala um odor insuportável... O mesmo cheiro dos discípulos de Osamodas...",ep:2,g:51,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1335] = {n:"Poção de Chuvisco",t:26,d:"Graças à fraca magia de água que contém, esta poção borbulhante é normalmente usada para enfeitiçar todos os tipos de itens.",ep:3,g:2,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1336] = {n:"Urtigas",t:36,d:"Esfregar rapidamente esta planta em sua pele o fará sofrer, mas a excitação produz efeitos benéficos... de qualquer maneira, é o que os Sacriers dizem.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1337] = {n:"Poção de Corrente de AR",t:26,d:"Graças à magia de ar fraca que ela contém, esta poção suspirante é normalmente usada para enfeitiçar todos os tipos de itens.",ep:3,g:3,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1338] = {n:"Poção do Tremor",t:26,d:"Graças à fraca magia da Terra que contém, esta poção vibrante é usada para enfeitiçar todos os tipos de itens.",ep:3,g:4,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1339] = {n:"Sinos",t:35,d:"Estes lírios do vale são muito pequenos, delicados e atraentes. Ainda por cima, alguns dizem que eles têm o poder de acalmar espíritos e curar algumas enfermidades. Eles provavelmente foram criados por uma divindade que queria uma planta à imagem dos Eniripsas.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1340] = {n:"Poção de Deslizamento",t:26,d:"Graças à sua mágica da terra, esta tremenda poção é usada para enfeitiçar todos os tipos de itens.",ep:9,g:4,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1341] = {n:"Poção Propagadora",t:26,d:"Graças à água mágica que ela contém, esta poção agitada é usada para enfeitiçar corretamente vários tipos de itens.",ep:9,g:2,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1342] = {n:"Poção de Vento",t:26,d:"Graças à mágica de ar que ela contém, esta poção é usada para encantar todos os tipos de itens.",ep:9,g:3,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1343] = {n:"Poção Chama de Fogo",t:26,d:"Graças à magia de fogo que contém, esta poção crepitante é geralmente usada para enfeitiçar corretamente todos os tipos de itens.",ep:9,g:1,l:25,wd:true,fm:true,w:1,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1344] = {n:"Verbena",t:36,d:"Esta planta especial ajuda as pessoas a facilmente cair no sono. Provavelmente deve ser o emblema do Sadida.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1345] = {n:"Poção do Fogo",t:26,d:"Graças à poderosa magia de fogo que contém, esta poção fulminante é usada para enfeitiçar poderosamente todos os tipos de itens.",ep:4,g:1,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1346] = {n:"Poção de Tsunami",t:26,d:"Graças à poderosa magia de água que contém, esta poção transbordante é usada para enfeitiçar poderosamente todos os tipos de itens.",ep:4,g:2,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1347] = {n:"Poção da Tempestade",t:26,d:"Graças à poderosa magia de ar que contém, esta poção é usada para enfeitiçar poderosamente todos os tipos de itens.",ep:4,g:3,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1348] = {n:"Poção de Terremoto",t:26,d:"Graças à poderosa magia de terra que contém, esta poção fixadora é usada para enfeitiçar poderosamente todos os tipos de itens.",ep:4,g:4,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1350] = {n:"Arco Forte",t:2,d:"Este arco foi criado por um mago que gostava de beber. Para resolver esse problema, ele inventou este arco do tipo água.",ep:3,g:4,l:15,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,3,6,30,50,false,true],p:250};
I.u[1351] = {n:"Arco Ykulf",t:2,d:"É Como diz o ditado: “Com um arco, ou se faz ou quebra”. Homens sábios evitam este arco. Dizem que dá mau-olhado.",ep:1,g:51,l:30,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,10,10,false,true],c:"CC>30",p:1600};
I.u[1352] = {n:"Arco de Mushd",t:2,d:"Este arco carrega as forças da terra e da água. A desgraça sucede àquele que não consegue controlar pelo menos uma das duas forças...",ep:2,g:6,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],p:5000};
I.u[1353] = {n:"Arco de Polia",t:2,d:"Todas as partes deste arco foram serradas. Costumava ser um símbolo do conflito entre o Bem e o Mal.\nToque-o e você será capaz de sentir o fervor dos antigos disseminadores de justiça.",ep:12,g:10,l:41,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"Ps=1&Pa>10&CI>30&CW>30",p:200};
I.u[1354] = {n:"Arco de Hick",t:2,d:"Hick era um Cra amaldiçoado: ele não conseguia parar de soluçar... Um dia, ele jogou seu arco no fogo e decidiu usar uma espada. A maldição, estranhamente, desapareceu naquele exato momento...",ep:13,g:11,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,6,40,40,false,true],p:1000};
I.u[1355] = {n:"Arco de Hidsad",t:2,d:"O homem que criou este arco, um certo Marc Hidsad, nunca soube realmente como usá-lo. Ele poderia machucar seriamente o seu oponente tanto quanto ele mesmo.",ep:14,g:12,l:40,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,7,30,50,false,true],p:4000};
I.u[1356] = {n:"Metade de um Bastão",t:3,d:"Rika Zarouil, a padeira, é famosa por ter sido o menor discípulo de Eniripsa em todo o mundo de Amakna. Ela fez seu pão em pequenas fornalhas de papelão e pode lutar com metade de um bastão.",ep:1,g:13,l:11,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,30,50,false,true],p:1000};
I.u[1357] = {n:"Pequenas Adagas",t:3,d:"Um perverso escultor tentou fazer as pessoas pensarem que suas varinhas eram adagas. O estratagema dele não foi eficiente, mas as varinhas eram.",ep:7,g:17,l:35,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,40,40,false,true],c:"CI>25",p:3500};
I.u[1359] = {n:"Astuto",t:3,d:"A origem deste resto de varinha é obscura. No entanto, ultimamente, ajudou seus proprietários a acharem estradas menos congestionadas de Amakna, o que pode ser tão útil quanto uma armadilha do Rei Gobball.",ep:9,g:12,l:59,wd:true,fm:true,w:10,an:11,e:[7,3,2,3,30,50,false,true],c:"CI>70&CS>30",p:5000};
I.u[1360] = {n:"O Hyldegarde",t:3,d:"Esta varinha mágica foi criada muitos anos atrás nas chamas da forja de Dyin Ard. É aconselhado ter água sempre à mão só para mantê-la sob controle.",ep:13,g:8,l:48,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],p:4800};
I.u[1361] = {n:"Varinha Mágica Sylvian",t:3,d:"A Varinha Mágica de Sylvian dá uma visão afiada ao seu portador;\r\n            fará você ágil o suficiente para escapar do perigo.",ep:1,g:15,l:43,wd:true,fm:true,w:10,an:11,e:[4,5,2,2,40,40,false,true],c:"CA>80",p:4000};
I.u[1362] = {n:"Estaca Vampírica",t:3,d:"A Estaca Vampírica nada mais é que uma varinha de um vampiro que desistiu de sua vida social e se suicidou. Este estranho pedaço de madeira herdou algumas qualidades de seu proprietário anterior.",ep:7,g:14,l:65,wd:true,fm:true,w:10,an:11,e:[5,6,2,3,50,20,false,true],c:"CA>30&CW<60",p:4000};
I.u[1363] = {n:"Cajado de Tont\'Ata",t:4,d:"Além do seu nome insuportável, este cajado tem muitas outras maneiras de afetar os nervos do seu portador.",ep:1,g:5,l:40,wd:true,fm:true,w:10,an:12,e:[5,5,1,1,5,5,false,true],c:"CI<100",p:5000};
I.u[1364] = {n:"Cajado do Esquecimento",t:4,d:"Todas as suas preocupações e pensamentos ruins desapareceram, graças a este cajado... assim como, às vezes, também desaparece uma parte da sua memória. Em breve, você pode ser incapaz de se concentrar. Apenas para homens sábios.",ep:13,g:11,l:30,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,true],c:"CW>50",p:3000};
I.u[1365] = {n:"Cajado de Hed",t:4,d:"Hed foi um terrível guerreiro, graças a este cajado, desde que descobriu que o mesmo era mágico e podia conjurar fogo.",ep:1,g:68,l:20,wd:true,fm:true,w:15,an:12,e:[8,5,1,1,50,40,false,true],p:2000};
I.u[1366] = {n:"Cajado de Gobberd",t:4,d:"Geralmente, este cajado é usado por Gobberds durante o transhumance. Bworks gostam de Gobballs em finas fatias como aperitivo e, como prato principal, o próprio Gobberd.",ep:9,g:9,l:12,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,true],p:1200};
I.u[1367] = {n:"Cajado de Dina \'Mite\'",t:4,d:"Este cajado pertenceu à bela Dina “Mito”, conhecida por sua graça... Em resumo, um verdadeiro bebê.",ep:13,g:6,l:40,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,30,50,false,true],c:"CI>50&CA>40",p:4000};
I.u[1368] = {n:"Lança de um dos ‘110‘",t:4,d:"‘Os 110‘ foi o nome dado aos 110 valentes bombeiros de Amakna. Eles combateram o fogo de Draconiano no ano de 450. Esta lança pertenceu a um deles e exige força e bravura a quem deseja manuseá-la.",ep:1,g:18,l:29,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,true],c:"CC>10",p:2500};
I.u[1369] = {n:"Facas de Mesa",t:5,d:"Estas facas foram especialmente concebidas para serem usadas em um restaurante de luxo. Mas, por causa da aparência bastante estranha delas, o dono decidiu revendê-las para um lançador de facas viajante.",ep:1,g:13,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>55&CC>5",p:3000};
I.u[1370] = {n:"Ergot Mina",t:5,d:"O punho desta arma é gorduroso e escorregadio, mas realmente parece sensacional.",ep:1,g:14,l:20,wd:true,fm:true,w:10,an:13,e:[8,3,1,1,50,50,false,true],p:2000};
I.u[1371] = {n:"Adaga de Eulasse",t:5,d:"Eulasse era um Gobberd de Amakna. Mas, um dia, ele achou no monte de esterco de seus Gobballs um par de adagas ligeiramente sujas. Tenha cuidado se for usar estas adagas, pois o punho é um pouco escorregadio...",ep:1,g:10,l:40,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>40",p:4000};
I.u[1372] = {n:"Adagas Otof\'Mai\'We",t:5,d:"Otof\'Mai\'We foi um eremita, um legendário discípulo de Sram, que passou a vida evitando todo contato com outros. Quando ele morreu, suas adagas favoritas foram encontradas próximas do seu corpo. Apenas o mais sagaz dos homens poderia controlá-las.",ep:9,g:19,l:44,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5300};
I.u[1373] = {n:"A Navalha Infernal",t:5,d:"Todo discípulo de Enutrof merecedor do nome tem barba, e o velho Krys Nosheive não era uma exceção. Um dia, sua esposa, Sra. Nosheive, comprou-lhe uma navalha, mas ele decidiu usá-la como arma.",ep:1,g:17,l:30,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1374] = {n:"Adagas de Tylo",t:5,d:"Tylo foi um antigo escriba de Amakna que viveu séculos atrás. Ele tinha a particularidade de esculpir pedras usando adagas em vez de buris. Esta magnífica e resistente adaga pertenceu a ele.",ep:1,g:12,l:30,wd:true,fm:true,w:13,an:13,e:[10,3,1,1,30,50,false,false],c:"CS>50",p:3000};
I.u[1375] = {n:"Machado de Terophyle",t:19,d:"Terophyle era um discípulo de Iop capaz de mover pedras impressionantes... Não é realmente uma prova de inteligência, mas nós não devemos esquecer o fato de que ele era um discípulo de Iop.",ep:1,g:14,l:15,wd:true,fm:true,w:25,an:17,e:[10,5,1,1,50,50,false,true],c:"CS>70&CI<10",p:800};
I.u[1376] = {n:"Machado Heuvante",t:19,d:"Este machado, certas vezes pesado para manusear, é ideal para derrubar Troold. As runas mágicas que ele contém também podem incendiar inimigos.",ep:7,g:15,l:35,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,50,false,true],c:"CS>50",p:3000};
I.u[1377] = {n:"Machado de Hure",t:19,d:"Hure foi um jovem padre que adorava usar armas para espalhar a palavra. Sua arma favorita era um machado em que ele gravou inúmeras linhas... seu significado está perdido para sempre.",ep:1,g:16,l:22,wd:true,fm:true,w:22,an:17,e:[10,5,1,1,50,50,false,true],c:"CW>30",p:2200};
I.u[1378] = {n:"Francisque à Brêles",t:19,d:"Este machado de batalha é designado para jovens guerreiros que têm, como o seu nome indica, a particularidade de fazer um barulho estridente e desagradável cada vez que bate em outra arma.",ep:1,g:17,l:28,wd:true,fm:true,w:22,an:17,e:[8,5,1,1,40,40,false,true],c:"CA>30",p:2300};
I.u[1379] = {n:"O Scrounnchhh",t:7,d:"A lenda diz que o nome deste martelo é, na verdade, a transcrição do barulho que ele faz quando esmaga crânios. Infelizmente, será impossível para os inimigos confirmarem isto.",ep:7,g:9,l:35,wd:true,fm:true,w:35,an:15,e:[8,5,1,1,30,40,false,true],c:"CS>50&CA>20",p:35000};
