I.u[968] = {n:"Cinto Deslumbrante",t:10,d:"Este magnífico cinto aumenta os pontos de ação do seu portador, assim como a vitalidade e a sabedoria.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Coroa de Wa Wabbit",t:16,d:"Esta Coroa magnífica uma vez pertenceu a um famoso Wa Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Cajado de Wa Wabbit",t:4,d:"Este cajado uma vez pertenceu a um famoso Wa Wabbit.",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Capa de Wa Wabbit",t:17,d:"Esta capa uma vez pertenceu a um famoso Wa Wabbit. Ainda está impregnado com a sua transpiração, que o fará se lembrar da surpreendente luta cada vez você usá-la.",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Dofus Cenouwawa",t:23,d:"O Dofus Cenouwawa aumenta sabedoria de seu portador.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Pata de Aracne",t:24,d:"Uma Perna muito magra e cabeluda. Os melhores Alquimistas conseguem criar um poderoso veneno com o suco extraído dessas pernas.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Cabeça de Fazendeiro Angustiado",t:24,d:"Ele pediu isto: o fazendeiro angustiado acabou perdendo a cabeça...",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Captive Vampire Fang",t:24,d:"Este canino muito pontudo pertenceu a um vampiro. Se tiver isto no seu inventário ou se usá-lo em volta do seu pescoço, você poderá, seguramente, fazer seus amigos acreditarem que você é um caçador de vampiro...",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Olantewn",t:16,d:"Uma característica distintiva do Olantewn é que previne a dispersão de partículas mágicas, o que faz dele, portanto, um bom isolador mágico. É por isso que alguns guerreiros usam este legume como um elmo.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Bala de Limão",t:42,d:"Redescubra o sabor dos tempos antigos com esta bala de limão.\nEste doce concede 100 pontos de energia.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Bala de Morango",t:42,d:"Redescubra o sabor dos tempos antigos com esta bala de morango.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Bala de Menta",t:42,d:"Redescubra o sabor dos tempos antigos com esta bala de menta.\nEste doce concede 200 pontos de energia.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Bala de Cereja",t:42,d:"Redescubra o sabor dos tempos antigos com esta bala de cereja.\nEsse doce concede 50 pontos de energia.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Vergeléia",t:42,d:"Feito de geléia de morango, é mais enjoativo que um vegetariano, mas ainda é uma especialidade de Amakna.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Geléia Vermelha",t:42,d:"Feita de geléia de morango, mesmo se rejeitada por alguns vegetarianos, ainda é uma especialidade de Amakna.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Geléiazul",t:42,d:"Preparada à base de geléia azul, é uma das especialidades de Amakna, embora isto tenha repelido muitos vegetarianos.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multigeléia",t:42,d:"A venda de Multigeléia foi proibida porque as pessoas pensavam que ela era a razão do desaparecimento de muitas crianças. Dizem que a Multigeléia faz seus piores pesadelos se tornarem realidade se você comê-la.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[997] = {n:"Kokonoz",t:46,d:"Redondo como uma bola de canhão, a Kokonoz também tem 3 buracos, muito conveniente para levantar e jogá-la por aí.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Cuecas do Capitão Pirata",t:15,d:"As cuecas do Capitão Pirata são a prova de que o ridículo realmente matou alguém. Mas, aparentemente, elas também dão sorte.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Lona nada tentadora",t:55,d:"Este pedação de lona está enlameado e fedorento, mas ainda é de boa qualidade. Que pena que tem tantos buracos!",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Barril Vazio",t:15,d:"Este grande barril foi esvaziado muito tempo atrás, todavia, ainda podemos adivinhar o que ele costumava conter: rum, Kamas, piratas eufóricos... tudo o que você pode achar em um barril além de água.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Tábua de Madeira de Kokoko",t:95,d:"Futuro fragmento de barco? Futuro piso da casa? Seja como for, no momento é apenas uma simples tábua.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"Tronco de Kokonoz",t:38,d:"Os troncos de Kokonoz são muito similares com outros: sólidos e mais finos que a média.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Madeira Luminosa de Kokoko",t:38,d:"Madeira sólida luminosa. Nunca coloque no olho de alguém.",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Corda Estencial",t:15,d:"Nenhum aventureiro que se preze ficaria sem tal Corda em seu inventário. Você deveria ser aconselhado a fazer o mesmo, embora ela seja um pedaço de conselho dificilmente seguido!",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Recibo para a Janga",t:24,d:"Um recibo assinado por Kib Roche dizendo que sua jangada estará pronta em breve.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Chapéu de Pirata",t:24,d:"Um chapéu com grandes bordas, a insígnia da morte bordada nele e com pêlo para deixá-lo bonito. Este chapéu de pirata é um clássico entre os capitães.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Gancho",t:24,d:"Acessório essencial para piratas sem sorte, este ganho pode ser usado como uma mão. Sua cor dá um estilo clássico...",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Mandíbula Caída",t:24,d:"As pessoas dizem que este colar de Mandíbula foi criado quando um capitão ficou bravo com um marinheiro sorridente que viu suas cuecas.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Crânio de Pirata",t:24,d:"Este crânio vestindo uma bandana prova que até mesmo piratas mortos podem esconder a sua calvície.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Concha Verde",t:24,d:"A caparaça de uma tartaruga maluca que pensa ser um ninja.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1011] = {n:"Carapaça amarela",t:24,d:"A carcaça de uma tartaruga doida que provavelmente tomou substâncias estranhas demais.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Concha Vermelha",t:24,d:"Concha de tartaruga doida que gostava de tomate e queijo em uma fatia quente de pão.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Concha Azul",t:24,d:"A concha de uma tartaruga louca que quis imitar Zowwo, a Raposa Mascarada.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Máscara Verde",t:24,d:"Esta Máscara de Kanniball foi feita a partir da de Verdura, elemento que é vinculado ao tempero de carne.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Máscara Amarela",t:24,d:"Esta Máscara de Kanniball Tristonha foi feita com um Relâmpago, elemento que normalmente assusta os mais jovens.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Máscara Vermelha",t:24,d:"A Máscara de Kanniball Irascível foi feita à imagem de Fogo, elemento de carne assada.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Máscara Azul",t:24,d:"A máscara de um Kanniball Surpreso que foi feita à imagem da Água, elemento que sacia a sede entre dois bocados de carne.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Cola",t:15,d:"Este Pote de Geléia Rosa cheira muito bem, mas você não deve saboreá-lo ou jamais falará novamente. Realmente, é um excelente fixador.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Capacete",t:16,d:"Com este capacete, você terá uma aparência muito especial, estará na metade do caminho entre ser ridículo e cômico.",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Capacete Quebrado",t:15,d:"Este capacete morreu para salvar a sua vida.",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Asas de Madeira",t:17,d:"Para as pessoas que sempre sonharam em voar como um Kwak, voltem para a cama porque estas asas os transformarão numa ameaça pública e em idiotas.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Asas Quebradas",t:104,d:"Estas asas quebradas constantemente o lembram que você realmente devia ter voltado para a cama.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Garrafa de rum",t:15,d:"O rótulo diz ‘rum de 10 anos de idade\', mas é quase impossível verificar sua veracidade. Não o beba excessivamente na estrada para evitar o enjôo do mar.",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
I.u[1026] = {n:"Pequena Faca Stek",t:5,d:"Um dia, o vergonhoso e louco T Bun Stek encontrou duas facas impressionantes... Sua utilidade era um mistério para todos até que ele um dia ele as usou para oferecer comida ao seu Deus. Ele sorria a todo momento fazendo um barulho particularmente estranho... Este pobre rapaz nunca disse uma só palavra.",ep:1,g:13,l:32,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>32&CS>10",p:3000};
I.u[1027] = {n:"Faca de Bife",t:5,d:"Estas facas estranhas e terríveis pertenceram ao famoso e louco Stek Dardar. Seu uso era um mistério para todos até que ele ofereceu comida ao seu deus.",ep:1,g:13,l:35,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>35&CS>12",p:3400};
I.u[1028] = {n:"Grande Faca de Stek",t:5,d:"Estas estranhas e perigosas facas pertenceram ao renomado e louco Stek Dardar. Sua utilidade estava oculta em mistério até que ele ofereceu comida ao seu Deus como um sacrifício.",ep:1,g:13,l:38,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>38&CS>14",p:3800};
I.u[1029] = {n:"Faca Grande de Stek",t:5,d:"Estas facas estranhas e terríveis aparentemente pertenceram ao famoso louco Stek Dardar. Seu uso foi descoberto quando ele sacrificou carne para seu deus.",ep:1,g:13,l:41,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>41&CS>16",p:4000};
I.u[1030] = {n:"Garras de Gato",t:5,d:"Este par de adagas na verdade é um jogo mágico. Criado para entreter jovens discípulos de Ecaflip, ele foi banido quando uma criança seguidora de Sram participou do jogo.",ep:14,g:20,l:25,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>40&CS>20&CV>20",p:1800};
I.u[1031] = {n:"Adagas Cruéis de Elorie Entuwan",t:5,d:"Estas magníficas adagas pertenceram à Sramette mais cruel que Amakna já viu... Na verdade, ela era apenas um pouco mais cruel que os outros, se não, pelo menos tão cruel quanto os outros, o que já é muito bom!",ep:1,g:7,l:40,wd:true,fm:true,w:1,an:13,e:[12,3,1,1,30,50,false,false],c:"CA>40",p:4000};
I.u[1032] = {n:"Pequena Lâmina de Rowler",t:5,d:"Esta adaga foi originalmente usada pela irmandade secreta de Rowler. Esta guilda queria mergulhar Amakna em um estado de caos. No final das contas, eles foram os primeiros a desaparecer, quando a ilha onde eles se escondiam foi submergida pelo mar.",ep:1,g:14,l:44,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>44&CC>5",p:5000};
I.u[1033] = {n:"Lâmina de Fon",t:5,d:"Esta adaga foi originalmente usada pela irmandade secreta de Fon. Esta guilda queria mergulhar Amakna em um estado de caos. A Irmandade de Fon finalmente desapareceu quando a ilha em que eles se escondiam submergiu pelas ondas.",ep:1,g:14,l:48,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>48&CC>8",p:5500};
I.u[1034] = {n:"Lâmina Grande de Rowler",t:5,d:"Esta adaga foi usada originalmente pela irmandade secreta de Rowler. Esta guilda quer mergulhar Amakna em um caos. A guilda finalmente desapareceu quando a ilha onde ela estava submergiu pelas ondas.",ep:1,g:14,l:52,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>52&CC>10",p:6000};
I.u[1035] = {n:"Poderosa Espada de Rowler",t:5,d:"Esta adaga foi originalmente usada pela irmandade secreta de Rowler. Esta guilda queria tornar Amakna um lugar de caos. Ela desapareceu quando a ilha que os escondia foi submergida pelas ondas.",ep:1,g:14,l:56,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>56&CC>12",p:6500};
I.u[1036] = {n:"Pequenas Adagas Enganadoras",t:5,d:"Esta adaga de Sram é enganosamente figurada. Tanto que alguém pode ficar pensando se ela realmente é uma adaga. Quando a resposta é revelada, é geralmente tarde demais...",ep:7,g:11,l:53,wd:true,fm:true,w:1,e:[14,3,1,1,30,50,false,false],c:"CA>53&CS>18",p:7000};
I.u[1037] = {n:"Adaga Enganadora",t:5,d:"Esta adaga de Sram tem uma forma enganosa. Tão enganosa que alguém pode se perguntar se ela é realmente uma adaga. Quando a resposta é revelada, geralmente já é tarde demais...",ep:7,g:11,l:58,wd:true,fm:true,w:10,e:[15,3,1,1,30,50,false,false],c:"CA>58&CS>20",p:7500};
I.u[1038] = {n:"Bela Adaga Enganadora",t:5,d:"Esta adaga de Sram tem uma forma enganosa. Tão enganosa que alguém pode se perguntar se ela é realmente uma adaga. Quando a resposta é revelada, geralmente já é tarde demais...",ep:7,g:11,l:63,wd:true,fm:true,w:10,an:13,e:[16,3,1,1,30,50,false,false],c:"CA>63&CS>22",p:8000};
I.u[1039] = {n:"Adaga Enganadora Hipnótica",t:5,d:"Esta adaga Sram tem uma forma enganadora, as pessoas se perguntarão se é realmente uma adaga. Quando encontrarem a resposta, será tarde demais...",ep:7,g:11,l:67,wd:true,fm:true,w:10,an:13,e:[17,3,1,1,30,50,false,false],c:"CA>67&CS>25",p:8500};
I.u[1040] = {n:"Lâminas Sangrentas de Ortimus Contrari",t:5,d:"Ortimus Contrari é um infiltrado lendário. O modo que ele executava seus contratos era completamente oposto aos métodos tradicionais. Nem tente saber mais sobre isto, você se arrependeria no mesmo instante...",ep:9,g:19,l:80,wd:true,fm:true,w:15,an:13,e:[15,3,1,1,20,50,false,false],c:"CA>79&CS>40",p:10000};
I.u[1041] = {n:"Espada Quebrada de um Cavaleiro Sem Sorte",t:5,d:"Um jovem seguidor de lop, Souze Schel, recebeu essa espada para seu treino. Infelizmente, durante sua primeira missão, ele tropeçou em uma pedra que, na verdade, era um crackler...",ep:1,g:43,l:35,wd:true,fm:true,w:20,an:13,e:[5,5,1,1,30,50,false,false],c:"CS>20",p:3000};
I.u[1042] = {n:"Pequena Pá Dormente",t:8,d:"Esta pá é feita de um tipo muito raro de madeira. De acordo com a lenda, toda moça que toca nesta arma, cai em um sono eterno. Note que em caso de contato contínuo, heróis valentes também podem ser afetados.",ep:1,g:20,l:34,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>26",p:3200};
I.u[1043] = {n:"Pá Dormente",t:8,d:"Esta pá é feita de um tipo de madeira muito raro. De acordo com a lenda, jovens meninas caíram em profundo sono no toque desta pá. Note que no caso de repetidos contatos, corajosos heróis podem também ser afetados.",ep:1,g:20,l:37,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>27",p:3400};
I.u[1044] = {n:"Grande Pá Soporífica",t:8,d:"Esta pá é feita de um tipo muito raro de madeira. De acordo com a lenda, jovens garotas caíam em sono eterno quando eram tocadas por esta arma. Note que, em caso de contato repetido, heróis valentes também podem ser afetados.",ep:1,g:20,l:40,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>28",p:3600};
I.u[1045] = {n:"Pá Magnífica Dormente",t:8,d:"Esta pá é feita de um tipo muito raro de madeira. De acordo com a lenda, jovens garotas caem em sono eterno quando tocam esta arma. Note que em caso de contato repetido, qualquer um pode ser afetado também.",ep:1,g:20,l:43,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>30",p:3800};
I.u[1046] = {n:"Pequena Mishmapá",t:8,d:"O que pode ser melhor que uma pá ecológica para aparar ervas daninhas? Esta pá é A solução para arrancar margaridas e fazer seus inimigos comerem goela abaixo começando pela raiz!",ep:1,g:18,l:38,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CS>10&CC>28",p:4000};
I.u[1047] = {n:"Mismapá",t:8,d:"O que pode ser melhor que uma pá ecológica para se livrar de ervas daninhas? Esta pá é A solução para arrancar margaridas e fazer seus inimigos comê-las.",ep:1,g:18,l:42,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CS>11&CC>31",p:4200};
I.u[1048] = {n:"Grande Mismaspá",t:8,d:"O que pode ser melhor que uma pá ecológica para cortar ervas daninhas? Esta pá é a solução para colher margaridas e fazer seus inimigos comê-las pela raiz!",ep:1,g:18,l:46,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CS>12&CC>33",p:4400};
I.u[1049] = {n:"Poderosa Pá Enrolada",t:8,d:"O que pode ser melhor do que uma pá que não é prejudicial ao meio ambiente? Esta pá é A solução para extrair margaridas e fazer os seus inimigos comerem elas começando pela raiz!",ep:1,g:18,l:50,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CC>35&CS>15",p:4600};
I.u[1050] = {n:"Pequena Pá de Woukuis",t:8,d:"A família Woukuis criou esta pá durante a guerra envolvendo dois grupos, os Elle-Pomas e os Touge-Woukuis. O seu único problema é que ela engordura as suas mãos durante o uso. É muito popular entre os solteirões. Não sei por quê!",ep:3,g:21,l:49,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>40&CS>40",p:5000};
I.u[1051] = {n:"Pá Woukuis",t:8,d:"A família de Woukuis forjou e usou esta pá durante a guerra mortal entre dois grupos, o Elle-Poma e o Touge-Woukuis, competidores diretos de exportação de tofus assados. É uma arma aterrorizante, seu único defeito é deixar as mãos gordurosas.",ep:3,g:21,l:54,wd:true,fm:true,w:35,an:16,e:[7,4,1,1,50,50,false,false],c:"CC>42&CS>42",p:5300};
I.u[1052] = {n:"Grande Pá dos Woukuis",t:8,d:"A família Woukuis forjou e usou esta pá durante a vergonhosa guerra mortal entre dois grupos – Elle-Poma e Touge-Woukuis –, em competição direta na exploração de tofus grelhados. É uma arma apavorante e só tem um defeito – enche a mão de graxa.",ep:3,g:21,l:59,wd:true,fm:true,w:35,an:16,e:[7,4,1,1,50,50,false,false],c:"CC>45&CS>45",p:5600};
I.u[1053] = {n:"Imponente Pá Woukuis",t:8,d:"A família Woukuis forjou e usou esta pá durante a guerra infame entre dois grupos – Elle-Poma e Touge-Woukuis –, que competiam pela exportação de tofus grelhados. É uma arma temível e só tem uma desvantagem – ela cobre as mãos de graxa.",ep:3,g:21,l:64,wd:true,fm:true,w:35,an:16,e:[7,4,1,1,50,50,false,false],c:"CC>50&CS>50",p:6000};
I.u[1054] = {n:"Espátula-Pá Cruel",t:8,d:"Uma mistura de uma espátula e uma pá, a pá-espátula perdeu suas características úteis para se tornar uma arma indispensável. Fácil de manejar e guardar graças ao seu tamanho, é o acessório ideal para qualquer seguidor de Enutrof que é fã de energético.",ep:13,g:15,l:53,wd:true,fm:true,w:20,an:16,e:[5,3,1,1,40,40,false,false],c:"CC>47",p:5000};
I.u[1055] = {n:"Pá Pequena de Koutoulou",t:8,d:"Estas pás medonhas são feitas à mão pelos moradores da ilha que desprezam o trabalho manual. Inútil para cavar buracos, seu propósito principal é assustar espíritos e crianças desobedientes.",ep:8,g:19,l:25,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>22&CI>3",p:1500};
I.u[1056] = {n:"Pá de Koutoulou",t:8,d:"Estas pás medonhas são feitas à mão pelos moradores da ilha que desprezam o trabalho manual. Inútil para cavar buracos, seu propósito principal é assustar espíritos e crianças desobedientes.",ep:8,g:19,l:28,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>24&CI>4",p:1800};
I.u[1057] = {n:"Pá Grande de Koutoulou",t:8,d:"Estas pás medonhas são feitas à mão pelos moradores da ilha que desprezam o trabalho manual. Inútil para cavar buracos, seu propósito principal é assustar espíritos e crianças desobedientes.",ep:8,g:19,l:31,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>27&CI>5",p:2100};
I.u[1058] = {n:"Pá Assustadora de Koutoulou",t:8,d:"Estas pás medonhas são feitas à mão pelos moradores da ilha que desprezam o trabalho manual. Inútil para cavar buracos, seu propósito principal é assustar espíritos e crianças desobedientes.",ep:8,g:19,l:34,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>29&CI>5",p:2400};
I.u[1059] = {n:"Pá dos Campos",t:8,d:"É a pá favorita dos fazendeiros, e especialmente de fazendeiros cultivadores de batata. Mas você pode usá-la para outros tipos de cultivo também.",ep:1,g:17,l:15,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>15",p:750};
I.u[1060] = {n:"Pequena Maça de Dha",t:7,d:"Uma arma criada por Ha. Esta maça com formato aerodinâmico perfura o ar para rachar crânios... Pelo menos uma boa razão para possuir esta arma.",ep:1,g:16,l:18,wd:true,fm:true,w:40,an:15,e:[10,5,1,1,60,40,false,false],c:"CS>18&CI>2",p:3000};
I.u[1061] = {n:"Maça de Dha",t:7,d:"Uma arma criada por Ha. Esta Maça, com uma forma aerodinâmica especial, é ideal para rachar os crânios de seus inimigos... Uma razão muito boa para possuir esta arma.",ep:1,g:16,l:20,wd:true,fm:true,w:40,an:15,e:[10,5,1,1,60,40,false,false],c:"CS>20&CI>3",p:4000};
I.u[1062] = {n:"Maça Sólida de Dha",t:7,d:"Uma arma criada por Ha. Esta Maça, com uma forma aerodinâmica especial, é ideal para rachar os crânios de seus inimigos em um piscar de olhos...Uma razão muito boa para possuir esta arma.",ep:1,g:16,l:22,wd:true,fm:true,w:40,an:15,e:[10,5,1,1,60,40,false,false],c:"CS>22&CI>4",p:5000};
I.u[1063] = {n:"Maça Inquebrável de Dha",t:7,d:"Uma arma criada por Ha. Esta maça com formato aerodinâmico é ideal para rachar os crânios de seus inimigos. Uma razão muito boa para possuir esta arma.",ep:1,g:16,l:24,wd:true,fm:true,w:40,an:15,e:[10,5,1,1,60,40,false,false],c:"CS>24&CI>4",p:6000};
I.u[1064] = {n:"Pequeno Martelo R‘Unique",t:7,d:"Antigos ferreiros Xelor fizeram este martelo;\r\n            as pessoas consideram-no uma peça exclusiva. Alguns dizem que é a primeira letra de um nome de ferreiro. Tente acertar um inimigo na cabeça e dê sua opinião.",ep:1,g:18,l:21,wd:true,fm:true,w:45,an:15,e:[5,4,1,1,40,40,false,false],c:"CI>28&CS>3",p:7000};
I.u[1065] = {n:"Martelo R\'Unique",t:7,d:"Como os antigos ferreiros Xelor fizeram manualmente este martelo, as pessoas consideram uma peça única. Algumas pessoas consideram ser uma letra formando o sinal de uma ferraria. Tente bater na cabeça de alguém e veja você mesmo...",ep:1,g:18,l:24,wd:true,fm:true,w:45,an:15,e:[5,4,1,1,40,40,false,false],c:"CI>30&CS>4",p:5000};
I.u[1066] = {n:"Grande Martelo R\'Único",t:7,d:"Rumores dizem que este martelo é o uma peça única, fabricada a mão pelos antigos Ferreiros Xelor. Entretanto, algumas pessoas dizem que é apenas uma runa de um nome de ferreiro. Veja você mesmo. Bata na cabeça de alguém!",ep:1,g:18,l:27,wd:true,fm:true,w:45,an:15,e:[5,4,1,1,40,40,false,false],c:"CI>32&CS>5",p:5500};
I.u[1067] = {n:"Imponente Martelo R\'Unique",t:7,d:"É dito que este martelo é uma peça única já que foi feita a mão por antigos ferreiros Xelor. Entretanto, algumas pessoas dizem que é apenas uma runa de um nome do ferreiro. Veja você mesmo e bata na cabeça de alguém!",ep:1,g:18,l:30,wd:true,fm:true,w:45,an:15,e:[5,4,1,1,40,40,false,false],c:"CI>34&CS>6",p:6000};
I.u[1068] = {n:"Pequena Maça Tmosfer",t:7,d:"Esta maça possibilita ao seu usuário prever o tempo. Pelo menos era o que o inventor pensou antes de ser atingido por um raio e falecer. Muito depois esta maça provou ser boa tanto em receber quando em dar assopros.",ep:2,g:14,l:34,wd:true,fm:true,w:40,an:15,e:[7,4,1,1,50,50,false,false],c:"CI>10&CS>10",p:14000};
I.u[1069] = {n:"Maça Tmosfer",t:7,d:"Esta maça permite que você determine qual o clima na área. Isso era pelo menos o que o seu inventor pensou antes de ser atingido por um raio. Muitos anos depois, as pessoas entenderam que esta maça era uma arma poderosa, capaz de receber e também de distribuir.",ep:2,g:14,l:37,wd:true,fm:true,w:40,an:15,e:[7,4,1,1,50,50,false,false],c:"CI>11&CS>11",p:16000};
I.u[1070] = {n:"Longa Maça Tmosfer",t:7,d:"Com esta Maça, você pode prever o tempo. Pelo menos é o que o seu inventor pensava antes de morrer por um raio. Depois, entendemos que esta maça era uma arma poderosa tão boa para receber quanto para distribuir.",ep:2,g:14,l:40,wd:true,fm:true,w:40,an:15,e:[7,4,1,1,50,50,false,false],c:"CI>13&CS>13",p:20000};
I.u[1071] = {n:"Perigosa Maça Tmosfer",t:7,d:"Antes de ser atingido por um raio, o criador desta maça realmente pensou que ela lhe permitiria prever o tempo. Muito mais tarde, foi descoberto que esta maça era muito boa tanto dando quanto recebendo golpes.",ep:2,g:14,l:43,wd:true,fm:true,w:40,an:15,e:[7,4,1,1,50,50,false,false],c:"CI>15&CS>15",p:25000};
I.u[1072] = {n:"Pequeno Martelo de Tronom",t:7,d:"De acordo com a lenda, Tronom Grande Bwork encomendou estes perigosos martelos de uma aldeia de discípulos de Xelor, fazendo a promessa de que a aldeia deles seria poupada se os martelos fossem eficientes. Quando ele recebeu os martelos, ele destruiu a aldeia. Afinal, ele precisou testar suas novas armas.",ep:1,g:6,l:36,wd:true,fm:true,w:50,an:15,e:[15,5,1,1,60,40,false,false],c:"CS>35&CI>8",p:3600};
I.u[1073] = {n:"Martelo Outar",t:7,d:"De acordo com a lenda, o Grande Bwork de Outar enviou esses apavorantes martelos para uma vila de seguidores de Xelor, fazendo a promessa de que a vila deles iria sobreviver se os martelos fossem eficientes. Quando ele recebeu os martelos, ele destruiu a vila. Ele tinha que testar as suas novas armas apesar de tudo.",ep:1,g:6,l:40,wd:true,fm:true,w:50,an:15,e:[15,5,1,1,60,40,false,false],c:"CS>36&CI>9",p:14000};
I.u[1074] = {n:"Grande Martelo de Outar",t:7,d:"De acordo com a lenda, Outar Grande Bwork solicitou estes terríveis martelos da vila dos discípulos Xelor com a promessa de poupá-los se os martelos fossem eficientes. Quando ele recebeu os martelos, destruiu a vila. Ele precisava testar suas novas armas.",ep:1,g:6,l:44,wd:true,fm:true,w:50,an:15,e:[15,5,1,1,60,40,false,false],c:"CS>38&CI>10",p:17000};
I.u[1075] = {n:"Imponente Martelo Outar",t:7,d:"O grande Bwork Outar solicitou estes terríveis martelos à vila Xelor em troca de um tratado de paz. Se os martelos fossem eficientes, ele pouparia a vila. Quando os recebeu, a vila foi aniquilada. Bem, ele tinha de experimentar, não é?",ep:1,g:6,l:48,wd:true,fm:true,w:50,an:15,e:[15,5,1,1,60,40,false,false],c:"CS>42&CI>10",p:22000};
I.u[1076] = {n:"Pequena Maça Aj Taye",t:7,d:"Esta maça é um legado da tribo pacífica Aj Taye. Sua principal função é fazer desaparecer a dor se você rolar ela em músculos doídos. Muitas pessoas brutais lhe dirão que ela pode também fazer a dor aparecer.",ep:7,g:17,l:39,wd:true,fm:true,w:35,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>40&CS>8",p:4000};
I.u[1077] = {n:"Maça de Aj Taye",t:7,d:"Esta maça é a herança deixada pela pacífica tribo Aj Taye. Role-a em músculos doloridos e a dor desaparecerá. Os brigões lhe dirão que ela também é muito efetiva para fazê-la aparecer.",ep:7,g:17,l:43,wd:true,fm:true,w:35,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>42&CS>8",p:5000};
I.u[1078] = {n:"Grande Maça Aj Taye",t:7,d:"Esta maça é um tipo de antigo legado de uma tribo pacífica Aj Taye. Eles deram uma função principal: rolar pelos músculos doloridos para fazer a dor desaparecer. Grandes tiranos ensinarão a você que ela também pode fazer a dor surgir.",ep:7,g:17,l:47,wd:true,fm:true,w:35,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>42&CS>8",p:6000};
I.u[1079] = {n:"Poderosa Maça de Aj Taye",t:7,d:"Esta maça é a herança deixada pela pacífica tribo Aj Taye. Passe ela em músculos dolorosos e a dor irá desaparecer. Grandes tiranos lhe dirão que ela também é eficiente para fazer a dor aparecer.",ep:7,g:17,l:51,wd:true,fm:true,w:35,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>45&CS>8",p:7000};
I.u[1080] = {n:"Pequeno Martelo Pospodrol",t:7,d:"Este martelo parece tão ridículo que seu oponente perderá a cabeça de tanto rir... dando-lhe tempo para esmagá-lo até a morte.",ep:1,g:5,l:55,wd:true,fm:true,w:50,an:15,e:[10,6,1,1,50,50,false,false],c:"CI>25&CS>25",p:7000};
I.u[1081] = {n:"Martelo Pospodrol",t:7,d:"Este martelo é tão ridículo que seus inimigos irão rir da cabeça dele. Isso lhe dará tempo o suficiente para arrancar a cabeça dele.",ep:1,g:5,l:60,wd:true,fm:true,w:50,an:15,e:[10,6,1,1,50,50,false,false],c:"CI>26&CS>26",p:9000};
I.u[1082] = {n:"Poderoso Martelo Pospodrol",t:7,d:"Este martelo parece tão ridículo que seu oponente disfarçará sorrisos da sua cara, quando ele o ver, lhe dando tempo suficiente para esmagá-lo.",ep:1,g:5,l:65,wd:true,fm:true,w:50,an:15,e:[10,6,1,1,40,50,false,false],c:"CI>28&CS>28",p:10000};
I.u[1083] = {n:"Poderoso Martelo Pospodrol",t:7,d:"Este martelo é tão ridículo que o seu oponente irá rir dele, dando-lhe tempo para matar ele!",ep:1,g:5,l:70,wd:true,fm:true,w:50,an:15,e:[10,6,1,1,40,50,false,false],c:"CI>30&CS>30",p:12000};
I.u[1084] = {n:"Martelo Errante",t:7,d:"Com este temível Martelo você poderá provar às pessoas que pensam que o músculo supera o cérebro que estão erradas. Isso não vale para pessoas fracas, de resto não esqueça que eles estão SEMPRE corretos.",ep:9,g:20,l:81,wd:true,fm:true,w:60,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100",p:15000};
I.u[1085] = {n:"Martelo dos Falistos",t:7,d:"Falistos são demônios de Xelors. Eles traíram seus antigos princípios e desenvolveram sua força forjando martelos cada vez mais poderosos. Depois que eles trouxeram o caos, foram derrotados e banidos para o subterrâneo. Mas algumas das armas que eles forjaram permanecem intactas...",ep:9,g:19,l:79,wd:true,fm:true,w:70,an:15,tw:true,e:[15,7,1,1,50,25,false,false],c:"CS>79",p:10000};
I.u[1086] = {n:"Tinta Preta",t:15,d:"Você pode repintar qualquer coisa com esta lata de pintura: sua casa, seu Tofu de estimação, seus amigos ou até você mesmo...",ep:12,g:175,l:1,wd:true,fm:true,w:2,p:1};
I.u[1087] = {n:"Anel Mental",t:9,d:"Graças a este anel, o nível de inteligência do portador é sensivelmente aumentado.",ep:1,g:36,l:14,wd:true,fm:true,w:2,p:775};
I.u[1088] = {n:"Máscara de Kanniball",t:16,d:"Esta máscara é uma réplica fiel, só um pouco maior que a máscara que orgulhosamente pertenceu a Kanniballs importantes.",ep:12,g:26,l:40,wd:true,fm:true,w:10,p:5000};
I.u[1089] = {n:"Ingresso para Ilha da Lua",t:15,d:"Destino: Ilha Paradisíaca\nPreço: 1.000 Kamas\nValidade: Bilhete de ida",ep:2,g:172,l:1,wd:true,fm:true,w:1,p:1};
I.u[1090] = {n:"Astroperuca",t:16,d:"Você terá um excelente corte de cabelo, graças à Astroperuca.",ep:1,g:27,l:20,wd:true,fm:true,w:4,p:1300};
I.u[1091] = {n:"Poção do Esquecimento: \'Cara ou Coroa\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço de Ecaflip: \'Cara ou Coroa\'.",ep:2,g:27,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1092] = {n:"Pequeno Arco Pequeno",t:2,d:"Este arco é usado para caçar pássaros. Leve e fácil de usar, você conseguirá atacar quase qualquer um.",ep:1,g:17,l:15,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>15&CS>20",p:800};
I.u[1093] = {n:"Arco de Buzzard",t:2,d:"Este arco é especialmente projetado para caçar pássaros. Leve e fácil de manejar, será possível para você atacar quase qualquer um.",ep:1,g:17,l:18,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>17&CS>28",p:1100};
I.u[1094] = {n:"Grande Arco Buzzard",t:2,d:"Este arco é normalmente usado para caçar pássaros. Além disso, é mais fácil de usar e, por ser leve, será possível voar.",ep:1,g:17,l:21,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>20&CS>31",p:1400};
I.u[1095] = {n:"Poderoso Arco de Búteo",t:2,d:"Este arco é usado para caçar pássaros. Leve e fácil de usar, você poderá atacar qualquer coisa.",ep:1,g:17,l:24,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>23&CS>33",p:1700};
I.u[1096] = {n:"Arco Pequeno Feito de Chifre Gobball",t:2,d:"“Com um Gobball, não há desperdício!” era o slogan de um lojista especializado na reciclagem de Gobball. Este arco é um dos melhores produtos dele não por razões estéticas, mas porque é uma arma perigosa.",ep:1,g:22,l:29,wd:true,fm:true,w:30,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CS>45&CA>5",p:10000};
I.u[1097] = {n:"Arco em Chifre de Gobball",t:2,d:"“Com um Gobball não há desperdício!” era o slogan de um lojista especializado na reciclagem de Gobball. Este arco é um dos melhores produtos dele não por razões estéticas, mas porque é uma arma perigosa.",ep:1,g:22,l:32,wd:true,fm:true,w:30,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CS>44&CA>8",p:12000};
I.u[1098] = {n:"Arco Pesado de Chifre de Gobball",t:2,d:"“Com um gobball, não há desperdício!” era o slogan de um lojista especializado na reciclagem de Gobball. Este arco é um dos melhores produtos dele não por razões estéticas, mas porque é uma arma perigosa.",ep:1,g:22,l:35,wd:true,fm:true,w:30,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CS>47&CA>10",p:14000};
I.u[1099] = {n:"Amuleto Elementar",t:1,d:"Apenas para teste.",ep:1,g:33,l:100,wd:false,fm:true,w:1,p:1};
I.u[1101] = {n:"Pequena Varinha Mágica Horária",t:3,d:"A Eniripsa chamada Mie Dopan fez esta série de varinhas pontudas para conter gatunos. Na teoria, ela é capaz de voltar no tempo para prevenir agressões, mas ela geralmente acaba dentro do olho de um demônio.",ep:4,g:17,l:15,wd:true,fm:true,w:10,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>25&CS>1",p:1500};
I.u[1102] = {n:"Varinha Mágica Horária",t:3,d:"O Eniripsa Mie Dopan fez uma série de varinhas pontiagudas para roubar na luta. Na teoria, este tipo de varinha deve voltar a tempo de evitar qualquer agressão, mas geralmente termina no olho de um demônio.",ep:4,g:17,l:20,wd:true,fm:true,w:10,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>27&CS>2",p:2000};
I.u[1103] = {n:"Grande Varinha Mágica da Hora",t:3,d:"O discípulo dos Eniripsas, Mie Dopan, fez esta série de varinhas mágicas com pontos para roubar na luta. Teoricamente, ele pode voltar no tempo para evitar qualquer agressão. Sim, normalmente acaba em um olho de demônio.",ep:4,g:17,l:25,wd:true,fm:true,w:10,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>29&CS>3",p:2500};
I.u[1104] = {n:"Varinha Mágica Assustadora",t:3,d:"O discípulo de Eniripsa, Mie Dopan, fez esta série de varinhas mágicas pontiagudas para resistir a roubos. Teoricamente falando, esta varinha mágica pode voltar no tempo para prevenir qualquer agressão, e geralmente acaba em olho do demônio.",ep:4,g:17,l:30,wd:true,fm:true,w:10,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>31&CS>4",p:3000};
I.u[1105] = {n:"Pequena Varinha Mágica Clériga",t:3,d:"Esta pesada Varinha rompeu muito mais que o crânio de um pecador. Os padres Iops a usam para perdoar de uma vez por todas as pessoas arrependidas.",ep:2,g:16,l:36,wd:true,fm:true,w:1,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>36&CS>25",p:5000};
I.u[1107] = {n:"Varinha Mágica de Clergy",t:3,d:"Esta pesada varinha mágica quebrou mais que crânio do pescador. Os padres de Iop a usam para converter as pessoas definitivamente.",ep:2,g:16,l:41,wd:true,fm:true,w:1,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>40&CS>25",p:5700};
I.u[1108] = {n:"Varinha Mágica Pesada de Sacerdócio",t:3,d:"Esta pesada varinha mágica está mais quebrada do que crânio de pescador. Os padres Iops a usam para convertê-los de uma vez por todas... Barbaridade? Não exatamente... Escrita divina funciona.",ep:2,g:16,l:46,wd:true,fm:true,w:30,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>45&CS>25",p:6300};
