I.u[1403] = {n:"Martelo de Tau",t:7,d:"Este martelo pertenceu a Tau, um jovem discípulo de Osamodas que passava todo o seu tempo contando piadas estúpidas. Conseqüentemente, este martelo realmente não faz pessoas ficarem inteligentes, mas pode atenuar a atmosfera às vezes.",ep:1,g:3,l:23,wd:true,fm:true,w:20,an:15,e:[4,4,1,1,30,30,false,true],c:"CA>20",p:1700};
I.u[1404] = {n:"Martelo de Toh\'Lo",t:7,d:"Você gosta de animais? Toh\'Lo também. Ele até dedicou sua vida a esta causa. Este martelo de certo modo representa sua vida: uma grande comunhão com animais, uma comunhão tão instável quanto um gobball manco com apenas 2 dedos do pé.",ep:5,g:15,l:35,wd:true,fm:true,w:35,an:15,e:[6,4,1,1,30,30,false,true],c:"CI>80&CW>30",p:3400};
I.u[1405] = {n:"Água de Fada",t:12,d:"A água de fada tem as mesmas propriedades curativas que o sangue de um Eniripsa. Não é mais preciso fazê-los sangrar até secarem...",ep:3,g:41,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1406] = {n:"Sangue de Unikron",t:12,d:"Esta poção reproduz fielmente as propriedades do sangue de Unikron, exceto a imortalidade. Beba-o e você será curado!",ep:3,g:40,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
