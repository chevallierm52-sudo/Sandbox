I.u[10657] = {n:"Caçador de Ogrines",t:18,d:"Este estranho animal é o resultado da mistura de diversos monstros de Amakna. A sua enorme tromba lhe permite localizar Ogrines, mesmo escondidos em regiões aquáticas e levou anos para que Otomai criasse essa monstruosidade. Rez a lenda que Otomai o criou pois havia perdido algo importante e precisava de alguém para encontrar.\nO processo de localizar pessoas ou itens é muito desgastante, e por isso, o animal precisa se alimentar da alma de outros montros.\nO Caçador só se alimenta de criaturas da Ilha Otomai, pois lá é sua terra natal.",ep:0,g:56,l:1,wd:true,fm:true,w:10,p:1};
I.u[10658] = {n:"Fantasma do Caçador de Ogrines",t:90,d:"O Caçador de Ogrines ainda não deixou o nosso mundo.\nVocê será bravo o suficiente para encontrar um meio de traz o seu companheiro de volta ou vai se portar como um covarde?",ep:0,g:56,l:1,wd:true,fm:true,w:1,p:1};
I.u[10659] = {n:"Ovo de Caçador de Ogrines",t:72,d:"Esse estranho ovo contém uma pequena criatura mágica. Mantenha-o aquecido e, com certeza, ele chocará.",ep:0,g:206,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10660] = {n:"Presente: Ovo de Caçador de Ogrines",t:89,d:"Se você balançar esse presente e colocar o ouvido próximo a ele, ouvirá alguns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela, você vai encontrar um maravilhoso animal de estimação e também alguns recursos que servirão para cuidar do seu novo bichinho! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10661] = {n:"Certificado de Canil: Caçador de Ogrines",t:77,d:"Este certificado descreve as características do Caçador de Ogrines que você deixou no Canil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10662] = {n:"Runa da Prospecção",t:78,d:"Esta runa aumenta sua chance de encontrar itens raros.",ep:0,g:36,l:20,wd:true,fm:true,w:1,p:10};
I.u[10663] = {n:"Brioche de carne de Gobball",t:33,d:"Você vai precisar de um estômago forte para engolir este brioche. A carne de gobball usada nele, nem sempre o corte mais fresco devo salientar, da um sabor que lembra ostras em chocolate. Bworks ficam loucos por ele.",ep:0,g:71,l:20,wd:true,fm:true,w:1,c:"Sc=1",u:true,ut:true,p:1};
I.u[10664] = {n:"Árvorenoz",t:94,d:"Se você esfregar esta noz gentilmente, irá aumentar, e após algum tempo se esfregar um pouco mais, o treechnid preso dentro dela irá explodir pra fora.",ep:0,g:15,l:1,wd:true,fm:true,w:0,c:"Sc=2&(PB=4|PB=22|PB=33|PB=169|PB=170|PB=486|PB=168)",u:true,p:0};
I.u[10665] = {n:"Arca de Nanok",t:94,d:"Nanok perdeu toda sua fortuna, será que ela está dentro desta estranha arca? Abra-a e descubra.",ep:0,g:16,l:1,wd:true,fm:true,w:1,u:true,p:0};
I.u[10667] = {n:"Pegadas de Nanok",t:24,d:"Você conseguiu anotar quando o espírito de Nanok ficará visível. Não há necessidade de apressar as coisas.",ep:0,g:251,l:1,wd:true,fm:true,w:0,p:0};
I.u[10668] = {n:"Boa Sorte de Nanok",t:28,d:"Por um curto tempo, você vai se beneficiar da sorte de Nanok.",ep:0,g:16,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10669] = {n:"Poção da Chimera Empinada",t:12,d:"Isso vai ensiná-lo a pensar antes de beber!",ep:0,g:18,l:1,wd:true,fm:true,w:1,c:"Sc=4",u:true,p:0};
I.u[10670] = {n:"Pergaminho de Percimol",t:94,d:"Tão simples quanto seguir uma weceita de Wabbit, as instruções desse pergaminho revelam um segredo encantador.",ep:0,g:17,l:1,wd:true,fm:true,w:1,c:"Sc=5",u:true,p:0};
I.u[10673] = {n:"Poção HmmMmmMmmm",t:12,d:"HmmMmmMmmm.",ep:0,g:191,l:1,wd:true,fm:false,w:1,c:"Sc=7",u:true,ut:true,p:1};
I.u[10674] = {n:"Mmmmm",t:28,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:0,g:18,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10675] = {n:"Presente de Aniversário",t:89,d:"FELIZ ANIVERSÁRIO! Nós não revelaremos a surpresa e diremos a você o que está neste presente! Tudo o que importa é que você chegará à festa e irá se divertir muito! Isto é o mínimo que podíamos fazer em um dia tão especial!",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10676] = {n:"Efeito Duplo Khalls",t:28,d:"Sua prospecção e Sabedoria são aumentadas durante alguns combates.",ep:0,g:19,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10677] = {n:"Bala Khalls",t:42,d:"Com esta bala preparada tradicionalmente, você poderá redescobrir o sabor açucarado dos velhos tempos. Ela aumenta a sua prospecção e Sabedoria em 100 pontos durante 20 combates.",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"PO!10676",u:true,p:1};
I.u[10678] = {n:"",t:25,d:"",ep:0,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10679] = {n:"",t:12,d:"",ep:0,g:716,l:1,wd:false,fm:true,w:0,c:"Qf=485",u:true,p:1};
I.u[10680] = {n:"Lembrança Horrenda de Goultarminador",t:24,d:"Você removeu essa horrível parte de uma Essência Maléfica de Goultarminador. Agora, você pode colocar na sua mesa e usar como enfeite.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
