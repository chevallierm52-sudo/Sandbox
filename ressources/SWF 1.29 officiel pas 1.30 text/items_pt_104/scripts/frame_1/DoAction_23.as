I.u[10606] = {n:"Gema Espiritual do Rato Branco",t:85,d:"Esta gema é recebida após um certo número de vitórias em duelos e contém o espírito de um monstro. Mantenha fora do alcance de crianças. Agite bem antes de usar.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
