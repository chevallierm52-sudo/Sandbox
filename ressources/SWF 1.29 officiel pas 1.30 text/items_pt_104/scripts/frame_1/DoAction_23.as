I.u[10544] = {n:"Jellufo",t:18,d:"Essa criatura de terras distantes foi domada pelo mestre aposentado e só come monstros blop. Talvez isso explique sua estranha aparência e seu hálito de Blop.",ep:0,g:55,l:1,wd:true,fm:true,w:10,p:1};
I.u[10552] = {n:"Ughat",t:16,d:"Este chapéu irá manter seus ouvidos protegidos contra o frio e piadas ruins.",ep:0,g:245,l:41,wd:true,fm:true,w:10,s:134,p:4525};
I.u[10553] = {n:"Elmo Brasiwawa",t:16,d:"Somente um jogador de futebol teria a idéia de se disfarçar de Tofu para intimidar seus oponentes. Esse elmo aerodinâmico permite seu usuário correr como um míssil. Afinal de contas, talvez não seja uma ideia tão ruim assim. Você certamente vai chamar a atenção.",ep:0,g:252,l:41,wd:false,fm:true,w:10,s:142,p:4550};
I.u[10554] = {n:"Elmo Beneji",t:16,d:"São os óculos vermelhos que fazem esse elmo se tornar a melhor escolha para qualquer Esportista que se preze.",ep:0,g:253,l:41,wd:false,fm:true,w:10,s:143,p:4550};
I.u[10555] = {n:"Escudo da Seleção Brasiwawa",t:82,d:"Esse imponente escudo carrega a marca de várias vitórias de futebol. Embora tenha uma aparência intimidadora e robusta, ele não apresenta muita utilidade em uma batalha, mas é ótimo para defender gols.",ep:0,g:54,l:1,wd:false,fm:true,w:10,c:"PP>0",s:142,p:1};
I.u[10556] = {n:"Escudo da Seleção Lusiwawa",t:82,d:"Esse imponente escudo se ajusta perfeitamente à juventude: estilo acima do conteúdo. Não ajudará em nada quando lutar, a menos que o inimigo enfrente você usando um balão.",ep:0,g:53,l:1,wd:false,fm:true,w:10,c:"PP>0",s:143,p:1};
I.u[10557] = {n:"Luvas da Seleção Brasiwawa",t:9,d:"Essa luva velha e gasta ajudará você a pegar bolas de futebol, ou qualquer outro item redondo envolto em couro. O que você fará com isso é problema seu...",ep:0,g:176,l:43,wd:true,fm:true,w:10,s:142,p:4500};
I.u[10558] = {n:"Luvas da Seleção Lusiwawa",t:9,d:"Com essas luvas em suas mãos, você poderá fingir que é um jogador famoso de Gobboliche quando estiver jogando com seus Miaus.",ep:0,g:177,l:43,wd:true,fm:true,w:10,s:143,p:4500};
I.u[10559] = {n:"Cinto Brasiwawa",t:10,d:"Partidas de futebol são brutais, e esse cinto foi feito para proteger o jogador de dores musculares. Entretanto, você também pode usá-lo como bóia enquanto nada. Mas quem faria isso?",ep:0,g:159,l:41,wd:false,fm:true,w:10,s:142,p:4600};
I.u[10560] = {n:"Cinto Mounu",t:10,d:"Algumas pessoas dizem que Gobboliche é um jogo para homens de verdade, assim como esse cinto. Ele tem protetores que amortecem golpes.",ep:0,g:160,l:41,wd:false,fm:true,w:10,s:143,p:4600};
I.u[10561] = {n:"Botas da Seleção Brasiwawa",t:11,d:"Essas botas já foram usadas por um bom tempo, você pode facilmente sentir o mau cheiro. Vista-as e você se parecerá como um verdadeiro jogador de futebol.",ep:0,g:144,l:42,wd:false,fm:true,w:10,s:142,p:4825};
I.u[10562] = {n:"Botas da Seleção Lusiwawa",t:11,d:"Botas elegantes alimentam o fascínio dos fãs. Quando essas botas são polidas, elas ajudam nos seus dribles e, certamente, nenhum oponente o alcançará!... Isso tudo, enquanto a torcida grita! Sim, você aprendeu o básico do Gobboliche.",ep:0,g:145,l:42,wd:false,fm:true,w:10,s:143,p:4825};
I.u[10563] = {n:"Orbe Mágica",t:50,d:"Esta orbe permite que você compartilhe seus pontos de atributos. Mestres de Templo sabem como usá-la.",ep:0,g:460,l:1,wd:true,fm:true,w:100,p:1000};
I.u[10564] = {n:"Caixa da Orbe Mágica",t:89,d:"Esta caixa contém uma orbe embrulhada cuidadosamente.",ep:0,g:42,l:1,wd:true,fm:true,w:0,u:true,p:1};
