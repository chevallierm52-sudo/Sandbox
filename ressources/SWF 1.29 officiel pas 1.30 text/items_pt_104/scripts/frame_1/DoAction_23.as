I.u[10685] = {n:"Máscara Hax Or",t:16,d:"Equipado com este capacete de ouro, sua cabeça logo estará fazendo dinheiro e valendo seu peso em ouro.",ep:0,g:254,l:52,wd:false,fm:true,w:10,s:151,p:7325};
I.u[10686] = {n:"Capa Hax Or",t:17,d:"Esta capa de tecido, revestida com uma fina camada de ouro, é mágica. Ela atrai atenção e reflete luz diretamente nas pupilas de tipinhos desonestos que tentam te apunhalar por trás. Indispensável se você tiver amigos Srams.",ep:0,g:171,l:54,wd:false,fm:true,w:10,s:151,p:7750};
I.u[10687] = {n:"Anel Hax Or",t:9,d:"Este anel é tão pesado que aumenta em muitas vezes a inércia de seu punho quando você distribue pancadas em seus oponentes. Quando você começar a punir os camponeses, será praticamente impossível parar.",ep:0,g:182,l:51,wd:false,fm:true,w:10,s:151,p:6862};
I.u[10688] = {n:"Cinto Hax Or",t:10,d:"Este cinto é ideal para pendurar suas barras de ouro em torno de sua cintura, elas passam despercebidas.",ep:0,g:166,l:53,wd:false,fm:true,w:10,s:151,p:7525};
