I.u[9603] = {n:"Relato de um Encontro",t:24,d:"Este é um relato de uma discussão entre Silvosse e Maimane. Seu conteúdo é sobre como causar danos em Djaul.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:0};
I.u[9604] = {n:"Documento falso de Maimane",t:24,d:"Este documento é tão amassado quanto se estivesse mergulhado em um estômago de Trool pelas últimas semanas. O bom é que todos pensarão que os Bontarianos tentaram se livrar deste papel falso.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:0};
I.u[9605] = {n:"Testemunho de um Amakniano",t:24,d:"Este testemunho foi dado por um membro corrupto da milícia de nome Retep Sellers e explica que Maimane foi visto várias vezes na vila de Amakna espalhando slogans anti anti-demônios.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:0};
I.u[9606] = {n:"Relatório sobre Maimane",t:24,d:"Este relatório sobre Maimane, feito por Austinamou Flowa o famoso espião, explica como Maimane coletou Adagas Raivosas para equipar seu exército se preparando para batalhar contra Djaul e seus aliados.",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:0};
