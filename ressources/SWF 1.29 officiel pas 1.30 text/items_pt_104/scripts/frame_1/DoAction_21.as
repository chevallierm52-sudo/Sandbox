I.u[9379] = {n:"Caixa de Chocolate",t:42,d:"Ofereça esta caixa de chocolates para aquela pessoa especial. Se você for do tipo que tem poucos amigos, poderá comê-la sozinho.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9380] = {n:"Fadas de Artifício de Coração",t:74,d:"Este artefato espalha amor no Mundo dos Doze!",ep:1,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[9381] = {n:"Flor Glutoblop",t:35,d:"O Glutoblop está tão faminto que poderia comer suas próprias flores. Felizmente ele sempre tropeça em algum aventureiro nesta hora.",ep:5,g:7,l:50,wd:true,fm:true,w:1,p:1};
I.u[9382] = {n:"Flor de Blopshroom",t:35,d:"Esta flor nunca foi tirada da cabeça de um Blopshroom. Não se preocupe, o Blopshroom nunca gostou de qualquer forma.",ep:5,g:8,l:40,wd:true,fm:true,w:1,p:1};
I.u[9383] = {n:"Raiz de Trunkiblop",t:98,d:"O Trunkiblop tem grandes raízes que puxam aventureiros para o chão.",ep:5,g:1,l:40,wd:true,fm:true,w:1,p:1};
I.u[9384] = {n:"Folha Blop Cereja Real",t:35,d:"Se esta flor não for real, eu aposto que você vai jogá-la fora agora.",ep:5,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[9385] = {n:"Folha Blop Coco Real",t:35,d:"Se esta flor não for real, eu aposto que você vai jogá-la fora agora.",ep:5,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[9386] = {n:"Folha Blop Índigo Real",t:35,d:"Se esta flor não for real, eu aposto que você vai jogá-la fora agora.",ep:5,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[9387] = {n:"Folha Blop Maçã Real",t:35,d:"Se esta flor não for real, eu aposto que você vai jogá-la fora agora.",ep:5,g:10,l:100,wd:true,fm:true,w:1,p:1};
I.u[9388] = {n:"Folha Blop Real",t:36,d:"Quando seca, enrolada e defumada, esta folha pode evocar alucinações nos aventureiros mais fracos, assim como um desejo implacável de... Alívio. Uma overdose pode levar a uma morte mais rápida.",ep:5,g:13,l:100,wd:true,fm:true,w:1,p:1};
I.u[9389] = {n:"Folha Blop Arco-Íris Real",t:36,d:"Esta folha alimenta a matéria cinzenta do Blop Arco-Íris Real. É uma boa coisa, não é tão voraz!",ep:5,g:14,l:150,wd:true,fm:true,w:1,p:1};
I.u[9390] = {n:"",t:113,d:"",ep:0,g:211,l:1,wd:false,fm:true,w:0,p:1};
I.u[9391] = {n:"Flor de Blop Arco-Íris Real",t:35,d:"Esta flor estava escondida na caixa craniana do Blop Arco-Íris Real. Tapou todos os buracos na memória da criatura.",ep:5,g:13,l:150,wd:true,fm:true,w:1,p:1};
I.u[9394] = {n:"Mitch Shroom",t:16,d:"Este capacete dará um estilo classe Mitcho para qualquer um que usá-lo. Tem um cheio forte de arbusto que seus amigos não poderiam ficar sem.",ep:22,g:222,l:152,wd:true,fm:true,w:15,p:45782};
I.u[9395] = {n:"Bloprown Real",t:16,d:"Este capacete foi usado pelo Kuri em pessoa por alguns anos. Antes que ela decidiu parar de usar, é isso.",ep:22,g:223,l:161,wd:true,fm:true,w:10,p:47750};
I.u[9396] = {n:"Selo de Zawooin",t:9,d:"Chamado \'Zawooin Ling\' na linguagem antiga dos Lenalds, os rumores dizem que este item foi forjado em um vulcão embaixo do Fogo de Pandara por Zeewon, um misterioso Wabbit.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PX=3|PX=5",p:1};
I.u[9398] = {n:"",t:24,d:"",ep:2,g:27,l:1,wd:false,fm:true,w:0,p:1};
I.u[9399] = {n:"",t:24,d:"",ep:16,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9400] = {n:"Mapa da Vila Gisgoul",t:24,d:"Este mapa está bem velho e amassado... É difícil ler as marcações, incluindo o local do ritual. Mas após estudar bastante o mapa você finalmente descobre o local da celebração : no norte da Vila Gisgoul, perto das montanhas.",ep:16,g:6,l:1,wd:false,fm:true,w:0,p:1};
I.u[9401] = {n:"Pele de Bworker",t:59,d:"Esta pele passou por guerras e ainda está ilesa. Deve ser tão útil agora que foi removida de seu dono.",ep:14,g:9,l:400,wd:true,fm:true,w:10,p:1};
I.u[9402] = {n:"Pantufa Abelhuda",t:11,d:"As pequenas asas acopladas a estas pantufas darão a sensação de leveza aos seus pés. Mas tenha cuidado: não os use para jogar Goboliche... os Gobballs não gostariam de tomar uma espetada no traseiro.",ep:1,g:128,l:34,wd:true,fm:true,w:5,s:112,p:3200};
I.u[9403] = {n:"Martelo Ferrão",t:7,d:"As pequenas asinhas acopladas a este martelo fazem dele muito mais simples de manusear. De tão leve, ele pode até mesmo voar e acertar sua cabeça quando estiver dormindo... Tome cuidado!",ep:1,g:68,l:27,wd:true,fm:true,w:12,an:15,e:[10,4,1,1,45,50,false,false],c:"CI>17&CC>5",s:112,p:2100};
I.u[9404] = {n:"Capa de Abelha",t:17,d:"O ferrão ao final desta capa irá preveni-lo de ter seu traseiro chutado por seus inimigos. Mas você também não poderá sentar sem se machucar...",ep:1,g:155,l:33,wd:true,fm:true,w:5,s:112,p:3000};
I.u[9405] = {n:"Chapéu de Abelha",t:16,d:"Ao usar este chapéu, você deve estar ciente de que está aceitando o risco de ser acertado por um Moskito...",ep:1,g:224,l:37,wd:true,fm:true,w:9,s:112,p:3825};
I.u[9406] = {n:"Orelhas de Porquinho",t:16,d:"Estas nojentas orelhas de porco ainda estão quentes e são essenciais para seduzir qualquer porco nojento que estiver ao redor. Não ria, você nem imagina como poderá se sentir sozinho nos campos de Amakna",ep:1,g:225,l:36,wd:true,fm:true,w:2,s:113,p:3600};
I.u[9407] = {n:"Manto de rolha",t:17,d:"Atualmente muita gente chama esta capa de “Manto Saca-Rolha” e odeiam quem chama de qualquer outra coisa. Não importa como chamam esta capa, uma coisa é certa, é inútil para abrir garrafas!",ep:1,g:156,l:37,wd:true,fm:true,w:3,s:113,p:3800};
I.u[9408] = {n:"Anel Imundo",t:9,d:"Este anel o tornará um Porco Nojento que agradará seus amigos mais próximos",ep:1,g:162,l:40,wd:true,fm:true,w:3,s:113,p:500};
I.u[9409] = {n:"Cinto Lardine",t:10,d:"Este pequeno rabo em formato de sacarrolha trará a tona o melhor das pessoas que te cercam",ep:1,g:149,l:39,wd:true,fm:true,w:1,s:113,p:4225};
I.u[9410] = {n:"Chapéu do Xerife Astrubiano",t:16,d:"Pode não ter um design tradicional, mas é bem elegante! Este chapéu mostrará aos outros o quão moderno você é",ep:1,g:226,l:40,wd:true,fm:true,w:25,s:114,p:1000};
I.u[9411] = {n:"Capa do Xerife Astrubiano",t:17,d:"Esta capa protegerá sua retaguarda das queimaduras de sol. Seja cuidadoso, pois ela não pode ser usada nas costas de um vaqueiro qualquer.",ep:1,g:157,l:36,wd:true,fm:true,w:10,s:114,p:6500};
I.u[9412] = {n:"Cinto do Xerife Astrubiano",t:10,d:"A fivela deste cinto é extremamente resistente. Tanto que você não será capaz de soltá-la nunca mais. Isso é prova de que você é um verdadeiro xerife!",ep:1,g:150,l:32,wd:true,fm:true,w:10,s:114,p:3000};
I.u[9413] = {n:"Botas do Xerife Astrubiano",t:11,d:"As esporas destas botas permitirão que você fatie seu Dragossauro quando achar que é hora de comê-lo.",ep:1,g:129,l:30,wd:true,fm:true,w:10,s:114,p:2700};
I.u[9414] = {n:"Chapéu Limão",t:16,d:"Sua cabeça combinará facilmente com este enorme limão vazio e a semente no seu interior o fará se sentir em casa!",ep:1,g:227,l:30,wd:true,fm:true,w:9,s:115,p:2600};
I.u[9415] = {n:"Capa Limão",t:17,d:"Esta capa foi feita a partir de cascas de diferentes frutar cítricas. É muito refrescante, mas infelizmente ela não brilha no escuro.",ep:1,g:158,l:30,wd:true,fm:true,w:8,s:115,p:2525};
I.u[9416] = {n:"Anel do Sabor",t:9,d:"Se sua água se tornar sem sabor, apenas coloque o seu anel no dedo, seu dedo no copo de água e mexa vigorosamente antes que sua mão seja arrancada. Pronto! Uma deliciosa mistura de laranja-limão e sangue! O seu dedo? Ah...não se pode ter tudo na vida....",ep:1,g:163,l:20,wd:true,fm:true,w:4,s:115,p:1300};
I.u[9417] = {n:"Strawaff",t:4,d:"Se você sempre sonhou em passar por cima de seus inimigos em batalha, este cajado foi feito para você",ep:1,g:81,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",s:115,p:2900};
I.u[9418] = {n:"Chapéu Cristal",t:16,d:"O próximo barbeiro que tentar cortar o seu cabelo terá sorte de não quebrar a crista.",ep:1,g:228,l:22,wd:false,fm:true,w:12,s:125,p:1525};
I.u[9451] = {n:"Capa Cristal",t:17,d:"Este enorme pedaço de cristal pode ser usado com uma capa rígida, mas não pense que o fará mais forte... Bem, o próximo monstro que tentar comê-lo ficará engasgado.",ep:1,g:159,l:21,wd:false,fm:true,w:10,s:125,p:1400};
I.u[9452] = {n:"Anel Cristal",t:9,d:"Este anel fará o seu dedo radiante",ep:1,g:164,l:30,wd:false,fm:true,w:4,s:125,p:2600};
I.u[9453] = {n:"Cinto Cristal",t:10,d:"Com este cinto em volta de seu quadril, ninguém o beliscará sem temer que seus dedos sejam arrancados",ep:1,g:151,l:48,wd:false,fm:true,w:30,s:125,p:6075};
I.u[9454] = {n:"Bobblamuleto",t:1,d:"Este amuleto pode ser usado como um babador tanto para crianças como para os velhinhos.",ep:1,g:140,l:27,wd:false,fm:true,w:5,s:124,p:2200};
I.u[9455] = {n:"Bobbleanel",t:9,d:"Você pode usar este anel em qualquer dedo do pé se você precisar disfaeçar o mal cheiro dele.",ep:1,g:165,l:30,wd:false,fm:true,w:4,s:124,p:2600};
I.u[9456] = {n:"Bobblecapa",t:17,d:"Se você que as suas costas nunca receberam a devida atenção, apenas coloque esta longa capa que chamará a tenção de todos que o cercam.",ep:1,g:160,l:33,wd:false,fm:true,w:5,s:124,p:3075};
I.u[9457] = {n:"Chapéu de Bobbl",t:16,d:"Este chapéu tem cheiro de Rosas Demoníacas que te livra dos piolhos e também de qualquer outro parasita que se instale em sua cabeça.",ep:1,g:229,l:33,wd:false,fm:true,w:5,s:124,p:3000};
I.u[9458] = {n:"",t:24,d:"",ep:16,g:3,l:1,wd:false,fm:true,w:0,p:1};
I.u[9459] = {n:"Lista de Desejos para Santa Jaws",t:24,d:"Santa Jaws conseguiu uma dor de dente quando leu a lista de desejos de uma criança que ele devorou.\nVocê não escreveu sua lista ainda, então aqui há um exemplo.",ep:1,g:41,l:1,wd:false,fm:true,w:0,p:0};
I.u[9460] = {n:"Maçã Pik",t:24,d:"Este é um Pokipik que nunca verá a luz do dia. Você não está envergonhado de si mesmo?",ep:1,g:123,l:1,wd:false,fm:true,w:0,p:0};
I.u[9461] = {n:"O Kim",t:16,d:"Dizem que o Kimbo usa esta peruca para pagar tributo a um formoso, perfeitamente tosado jovem que ele encontrou na ilha. Que belo sorriso ele tinha! De qualquer forma, ele escondeu a peruca ridícula embaixo de seu coco.",ep:22,g:230,l:196,wd:true,fm:true,w:10,p:60000};
I.u[9462] = {n:"Escudo Danificado de Dardondakal",t:24,d:"Este escudo foi feito na escala do tamanho de Dardondakal, o Dragão Branco, mas o dano ainda não acabou! Ele é quase tão inútil quanto você!",ep:5,g:807,l:1,wd:false,fm:true,w:0,p:1};
I.u[9463] = {n:"Amunita",t:1,d:"Esta jóia é tão poderosa que matou um Moskito dentro de 30 passos, se só o cheiro não evitar de se aproximar!",ep:23,g:141,l:189,wd:true,fm:true,w:10,s:107,p:58000};
I.u[9464] = {n:"Kralomansão",t:1,d:"Esse amuleto amedrontador foi escondido em uma mansão distante. Quando estava vivo, costumava sonhar com o mundo e todos os locais que pudesse ver. No final, o único lugar a que ele chegou foi seu pescoço. Pobre coisinha!",ep:22,g:142,l:194,wd:true,fm:true,w:30,s:97,p:58411};
I.u[9465] = {n:"",t:76,d:"",ep:0,g:20,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9466] = {n:"Dofus Demoníaco Inacabado",t:24,d:"Você chegou na hora exata de assistir a criação do Dofus. É um lindo objeto, mas sem serventia. Você pensará em colocá-lo em sua coleção.",ep:14,g:737,l:1,wd:false,fm:true,w:0,p:1};
I.u[9467] = {n:"Crachá de Agente Brakmariano",t:24,d:"Este crachá foi encontrado na caverna onde o protetor Maimane foi atacado",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9468] = {n:"Pá Emlaka",t:8,d:"Esta perigosa pá roubará sua vitalidade, sua juventude, a água em seu corpo e seu precioso Troofles.",ep:22,g:51,l:191,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,35,50,false,false],c:"CC>450",p:58401};
I.u[9469] = {n:"Espada Indinz",t:6,d:"Feita com fungo, esta espada é perfeita para infectar o intestino de seus inimigos.",ep:23,g:85,l:184,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,50,50,false,false],c:"CC>300&CA>300",p:58456};
I.u[9471] = {n:"Chapéu do Dia de São Valentim",t:16,d:"Para todos os ???? que estão à procura de sua alma-gêmea, este elegante chapéu se torna um sinal inconfundível. Este chapéu mágico só pode ser usado pelos aventureiros que ainda não se casaram. É assim que você descobre se existem corações disponíveis.",ep:1,g:231,l:1,wd:false,fm:true,w:1,c:"PR=0",p:1};
I.u[9472] = {n:"Bala do Amor",t:42,d:"Bala feita especialmente para os apaixonados. Presente ideal para a sua cara-metade.\nEste doce concede entre 11 e 20 Pontos de Vida e ainda um surpresa especial!",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
