I.u[9525] = {n:"Presente do Dia dos Namorados",t:89,d:"Este presente é um kit de primeiros socorros – especialmente para os que estão sofrendo de amor!",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9526] = {n:"Nota sobre ameaças",t:24,d:"Você escreveu esta notinha neste pedaço de papel como um lembrete de que nunca deve ameaçar um Astrubiano quando há guardas por perto.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9527] = {n:"Pó de Unha Encarnado",t:24,d:"Esse é um antigo pó de unha, que um dia pertenceu ao dedão do pé de um Enutrof. Muitos anos se passaram desde que ele foi moído, mas ainda cheira a pé.",ep:1,g:37,l:1,wd:false,fm:true,w:0,p:1};
I.u[9528] = {n:"Amuleto de Lear",t:24,d:"Este poderoso amuleto pertenceu à Lear, o líder de uma seita extinta que cultuava os que já se foram. Aparentemente ele se comunica com seres de outra dimensão e parece ser capaz de clonar almas. Ele também parece ser capaz de se ressuscitar...algo útil quando não se tem sacerdotes por perto.",ep:9,g:48,l:1,wd:false,fm:true,w:0,p:1};
I.u[9529] = {n:"Poção da Ressurreição Forçada",t:24,d:"Algumas vezes as almas não podem ou não querem reencarnar. Esta poção é útil quando utilizada para forçá-las a recuperar sua antiga forma.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9530] = {n:"Vara de Pesca Encantada Para Caranhas",t:24,d:"Com um pouco de sorte, você pegará Linguas de Gabby em vez de Caranhas com esta vara de pesca",ep:0,g:739,l:1,wd:false,fm:true,w:0,p:1};
I.u[9531] = {n:"Língua de Gabby",t:24,d:"Esse estranho órgão ocasionalmente é usado para o método Língua de Gabby.\nEsse método secreto exige que uma vítima engula uma Língua de Gabby, fazendo-a tagarelar como um louco. Isso causa uma canseira repentina, e o segundo efeito começa a funcionar: a vítima ficará amiga de qualquer pessoa que cruzar seu caminho. Tirar informações de alguém nesse estado é muito fácil.",ep:1,g:740,l:1,wd:false,fm:true,w:0,p:1};
I.u[9532] = {n:"Estátua de Sumens",t:24,d:"Esta é uma das duas estátuas entregues a Summens por Maimane. Elas respresentam a bondade e perversidade de toda a humanidade.",ep:14,g:738,l:1,wd:false,fm:true,w:0,p:1};
I.u[9533] = {n:"Pedra Coaxial",t:24,d:"Esta pedra da alma foi encantada pelo mestre da Ordem do Olho Pútrido. Ela faz que almas coaxiais se deixem capturar por vontade própria.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9534] = {n:"Pedra da Alma Terra Tibya",t:24,d:"Esta pedra da alma contém a alma do Enutrof Terra Tibya. Você precisa ter cuidado se não quiser que a sua própria alma acabe presa dentro dela.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9535] = {n:"Poção de Transgênese",t:24,d:"Se manipulá-la corretamente, esta poção poderá acelerar o crescimento de plantas através da modificação de seus genes. Ninguém sabe se tem algum efeito colateral caso as plantas sejam comidas, mas shhhhh. Se os clientes não ficarem sabendo, também não passarão mal. Você precisará de 2 camponeses e 2 alquimistas para concluir esta operação.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9536] = {n:"Pergaminho Transgênese",t:24,d:"Este pergaminho ativa os efeitos da Poção de Transgênese quando derramado sobre os cereais.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9537] = {n:"Bênção de Erzal",t:24,d:"Este livro não possui apenas histórias estranhas sobre coisas do além, mas também descreve o ritual sobre como trazer uma alma de volta a um corpo.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9538] = {n:"",t:24,d:"",ep:0,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[9539] = {n:"Crachá do Chefe Renegado",t:24,d:"Você pegou esse crachá de um Bontariano renegado que, com certeza, não o merecia.",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9540] = {n:"A Capa do Padrinho",t:17,d:"Esta capa protegerá seu pescoço do tempo frio e sua retaguarda de ventos baixos.",ep:0,g:163,l:48,wd:true,fm:true,w:10,s:126,p:6200};
I.u[9541] = {n:"Chapéu do Padrinho",t:16,d:"Este chapéu especial o fará parecer com o Padrinho. Você deveria se orgulhar!",ep:0,g:234,l:43,wd:true,fm:true,w:10,s:126,p:5100};
I.u[9542] = {n:"Sapatos Polidos do Padrinho",t:11,d:"Estes sapatos ficam muito mais brilhantes quando estão gastos. Eles são perfeitos para impressionar seus oponentes quando estiverem cara a cara.",ep:0,g:130,l:40,wd:true,fm:true,w:10,s:126,p:4450};
I.u[9543] = {n:"Anel do Padrinho",t:9,d:"Este pesado anel dará mais poder para as suas palmadas e mais paixão para o seu afago.",ep:0,g:166,l:40,wd:true,fm:true,w:10,s:126,p:0};
