I.u[9582] = {n:"Dragossauro Blindado",t:97,d:"Esse certificado permite a você pegar sua montaria no estábulo. Aviso! Esse certificado é válido apenas por 20 dias. Quando o tempo acabar, sua montaria será solta para a natureza e seu certificado não terá mais validade. Você não poderá recuperar sua montaria. Sempre deixe sua montaria no estábulo se você for ficar longe durante muito tempo.",ep:0,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
