I.u[9576] = {n:"Botas Pretas Wab",t:11,d:"Feitas a partir do couro de um Wabbit Preto, essas botas possuem um cheiro nada agradável, mas eles são tão confortáveis que você nem mesmo irá perceber o cheiro... Elas são ótimas para andar na mata.",ep:0,g:131,l:47,wd:true,fm:true,w:10,s:127,p:5850};
