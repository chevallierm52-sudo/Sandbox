I.u[9479] = {n:"Pochapéu",t:16,d:"No mínimo, o pino pregado neste chapéu vai encolher uma cabeça grande.",ep:1,g:232,l:45,wd:true,fm:true,w:23,s:123,p:1000};
I.u[9480] = {n:"Caposh",t:17,d:"Quando um belo alvo aparece nas costas da sua capa, seus inimigos não vão ter desculpas para errar o ataque.",ep:1,g:161,l:33,wd:true,fm:true,w:10,s:123,p:3000};
I.u[9481] = {n:"Poescudo",t:82,d:"O pino pregado neste escudo pode ser usado como uma arma extra para combater e matar seus inimigos.",ep:1,g:36,l:1,wd:true,fm:true,w:1,s:123,p:1};
I.u[9482] = {n:"Escudo Kada",t:82,d:"Se não quiser assustar seus amigos com a sua cara feia, é melhor se esconder por trás desse belo e convidativo escudo.",ep:1,g:37,l:1,wd:true,fm:true,w:1,s:122,p:1};
I.u[9483] = {n:"Escudo Boh-Bihn",t:82,d:"Quando os Iops ganham estrelas de seus professores por terem trabalhado bem, grudam-nas neste escudo. De tempos em tempos, eles grudam em si mesmos para se mostrar para seus colegas de escola.",ep:1,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[9484] = {n:"Escudo Listrado",t:82,d:"Este escudo não é uma garantia total de proteção para o seu dono, mas é ótimo para perseguir fantasmas.",ep:1,g:39,l:1,wd:true,fm:true,w:1,p:1};
I.u[9485] = {n:"Cicapeda",t:17,d:"Estas três pequenas bolas na parte inferior da capa permitirão dar boas cabeçadas, isto se você aprender a dar piruetas!",ep:1,g:162,l:30,wd:true,fm:true,w:10,s:122,p:2500};
I.u[9486] = {n:"Cicad\'Chapéu",t:16,d:"Com ou sem esse chapéu, você vai parecer um palhaço... Mas, com ele, pelo menos você terá uma desculpa!",ep:1,g:233,l:33,wd:true,fm:true,w:10,s:122,p:3075};
I.u[9487] = {n:"Certificado de Conversão de Alinhamento",t:24,d:"Este certificado foi dado para você por Morry Gane. Ele possue alguns detalhes que deverá te interessar e atestará a sua conversa.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9488] = {n:"O Registro de Bonta",t:24,d:"Este registro pertence a Morgan Faym´n e possue muitos documentos, alguns deles explicam como se tornar um Bontariano. Dentro dele há uma página que você deve preencher.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9489] = {n:"O Registro de Brakmar",t:24,d:"Este registro pertence a Morgan Faym´n e possue muitos documentos, alguns deles explicam como se tonar um Bontariano. Dentro dele há página que você pode preencher.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9490] = {n:"Certificado de Ordem No. 5",t:24,d:"Este certificado declara que você pertence a uma ordem. Se você que entrar em outra ordem, você deverá esperar por sete dias após ter recebido seu certificado. Eventualmente alguns guerreiros mudam de idéia de tempos em tempos, mas não faça disso um hábito!",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9491] = {n:"Maldição de Chocrosis",t:30,d:"Agora você enxerga a vida com óculos rosa e está feliz como um porco no chiqueiro.",ep:1,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
