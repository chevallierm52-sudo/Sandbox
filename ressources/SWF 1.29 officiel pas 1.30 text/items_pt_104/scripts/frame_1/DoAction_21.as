I.u[9474] = {n:"Pedra da Alma Arriscadamente Sublime",t:83,d:"Esta pedra oferece a você uma pequena chance de capturar almas incrivelmente poderosas.",ep:0,g:17,l:1,wd:false,fm:true,w:1,tw:true,p:23000};
I.u[9475] = {n:"Pedra de Alma Sublime",t:83,d:"Esta pedra oferece a você uma pequena chance de capturar almas incrivelmente poderosas.",ep:0,g:16,l:1,wd:false,fm:true,w:1,tw:true,p:50000};
