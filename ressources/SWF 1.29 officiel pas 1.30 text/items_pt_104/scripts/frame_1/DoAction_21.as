I.u[9572] = {n:"Presente para a Madame Guardiã",t:24,d:"Este presente é para a Madame Guardiã. Como você sabe, ele contem um tesouro considerável - suficiente para pagar por bons equipamentos por alguns anos. Infelizmente, mesmo que você pense em roubar o que está dentro dele, você não viverá o bastante para gastar nem um centavo.",ep:0,g:742,l:1,wd:false,fm:true,w:0,p:1};
