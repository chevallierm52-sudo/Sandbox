I.u[9365] = {n:"Pergaminho do Sono",t:24,d:"Este pergaminho é poderoso o suficiente para fazer com que todos à sua volta durmam. Rip van Winkle jura que é verdade.",ep:16,g:768,l:1,wd:false,fm:true,w:0,p:1};
I.u[9366] = {n:"Tutu Rosa",t:10,d:"Este tofu rosa será ideal para colocar nas costas nas festividades de Ano Novo. Feito de algodão ancestral e musse esticado de Sponge Mob, ele é leve e confortável como uma garotinha, este pedaço pode ser o primeiro em uma linha de tutus para uma futura estrela da dança.",ep:22,g:148,l:49,wd:true,fm:true,w:5,p:300};
I.u[9367] = {n:"Anel de Divad",t:24,d:"Este é o anel que você roubou de Divad Dleifrepok. Ele diz que ajudou em sua carreira de ilusionista... será inútil para você.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9368] = {n:"Pingente de Shush",t:24,d:"Este é o pingente que foi roubado de Shush Tercesasti. Você desconhece sua utilidade.",ep:16,g:41,l:1,wd:false,fm:true,w:0,p:1};
