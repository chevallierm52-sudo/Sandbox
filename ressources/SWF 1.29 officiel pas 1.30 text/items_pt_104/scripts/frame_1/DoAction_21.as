I.u[9614] = {n:"Chave para o Santuário Hotomani",t:24,d:"Este horrivel colar éde fato a chave para o Santuário Hotomani. E você fica admirado porque ninguém quer uma cópia dela.",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:0};
