I.u[9808] = {n:"Presente: Shushu Rushu",t:89,d:"Se você sacudir este objeto com bastante força e depois colocar perto do ouvido, você ouvirá um barulho estranho... como o de um pequeno animal chorando... ahm, tavlez você não queira sacudir isto... Ahhh, abra logo esta caixa. Você irá encontrar um mascote maravilhoso junto com um pouco de Pó de Eniripsa.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
