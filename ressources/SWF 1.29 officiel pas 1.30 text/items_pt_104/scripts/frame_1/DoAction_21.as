I.u[9566] = {n:"Escudo Pára-Raios",t:82,d:"Dizem que o primeiro Escudo dessa linhagem foi forjado em uma taverna em Pandala e que a própria deusa Pandawa deu sua contribuição. Alguns acham que o escudo protege de raios, enquanto outros falam que o escudo é feito de raios. Fato ou Ficção? Golpe de marketing dos forjadores? Quem sabe... apenas o tempo dirá.",ep:0,g:34,l:1,wd:false,fm:true,w:1,p:5000};
I.u[9567] = {n:"Chapéu Preto Wab",t:16,d:"Com esse chapéu você irá parecer um vingador mascarado, ou talvez vai parecer que você está usando um berço como chapéu. Você sabe como os Wabs são...",ep:0,g:235,l:49,wd:true,fm:true,w:10,s:127,p:6325};
I.u[9569] = {n:"Capa Preta Wab",t:17,d:"O pequeno pompom no final dessa capa é o maior roupão da história.  É tão pequeno que ele pode até ser colocado embaixo da sua mobília. Não se esqueça de tirá-la quando estiver trabalhando nos campos.",ep:0,g:164,l:46,wd:true,fm:true,w:10,s:127,p:5600};
