I.u[9549] = {n:"Suspensório para Ceroulas do Padrinho",t:10,d:"O lema do alfaiate que fez este milagre era: \"Mesmo no centro da ação, suas calças devem permanecer justas, graças a alta qualidade do suspensório de linho.\" É, realmente não é um bom lema...",ep:0,g:152,l:48,wd:true,fm:true,w:10,s:126,p:6175};
I.u[9550] = {n:"Localizado no campo",t:24,d:"Merlanmagus contou a você onde a milícia está indo para usar o feitiço de Transgênese. Você precisará se apressar antes que seja tarde demais.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
