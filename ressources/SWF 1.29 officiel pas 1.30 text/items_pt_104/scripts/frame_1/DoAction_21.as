I.u[9594] = {n:"O Gobtubby do Padrinho",t:18,d:"Este Gobtubby parece perfeitamente normal... Entretanto, sua lã parece se tornar escura em alguns lugares... Dê um tempo e você ficará surpreso!",ep:0,g:46,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9595] = {n:"O Gobtubby Fantasma do Padrinho",t:90,d:"Esse fantasma ainda não deixou esse mundo. Você irá encontrar um jeito de ressuscitá-lo ou abandoná-lo covardemente de uma vez por todas?",ep:0,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[9596] = {n:"Presente: O Gobtubby do Padrinho",t:89,d:"Se você sacudir este objeto vigorosamente e colocá-lo perto de seu ouvido, você ouvirá barulhos estranhos... Como um pequeno animal chorando... Pode ser que você não queira sacudí-la agora... Ahhh, apenas abra logo! Você encontrará um belo animal de estimação juntamente com um pouco de Pó Eniripsa dentro.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9597] = {n:"Transformação do Gobtubby Fantasma do Padrinho",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9598] = {n:"Certificado de Canil: O Gobtubby do Padrinho",t:77,d:"Este certificado descreve as características do animal de estimação que você deixou no Canil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
