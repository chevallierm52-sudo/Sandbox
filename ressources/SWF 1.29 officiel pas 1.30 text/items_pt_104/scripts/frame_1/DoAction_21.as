I.u[9785] = {n:"Shushu Rushu",t:18,d:"Este pequeno capetinha irá acompanhá-lo na sua jornada, seja ela no Zaap de Asturb até mesmo nos lugares mais perigosos. Esse filhote possui uma boca suja e pode falar algumas besteiras, mas nada que um balde com água e sabão não resolva. Se você entrar em combates, certamente ele irá lhe ajudar!",ep:0,g:52,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9786] = {n:"Shushu Rushu Fantasma",t:90,d:"Este Fantasma ainda não deixou o mundo dos vivos. Irá você encontrar uma maneira de ressuscitá-lo ou irá deixá-lo abandonado para todo o sempre?",ep:0,g:49,l:1,wd:true,fm:true,w:1,p:1};
I.u[9787] = {n:"Pequeno Fragmento de Inteligência",t:115,d:"Este fragmento vem de um Shushu. Você pode usá-lo para deixar as armas Shushumi mais poderosas. Se uma arma Shushumi exceder seu poder máximo, os fragmentos serão removidos e enviados para o invetário.\n(Clique duas vezes para colocar este Fragmento de Alma em uma arma Shushumi que estiver equipada.)",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
