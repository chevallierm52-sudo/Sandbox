I.u[9523] = {n:"Recompensa da Supermissão `SRVT:MERCENARY_SHORT_NAME`",t:14,d:"Este superpergaminho certifica que você merece uma super-recompensa por completar as missões `SRVT:MERCENARY_SHORT_NAME`.",ep:0,g:6,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
