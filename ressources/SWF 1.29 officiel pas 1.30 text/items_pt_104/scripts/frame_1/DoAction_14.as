I.u[6436] = {n:"Machado de Ucibatev",t:19,d:"#1",ep:2,g:23,l:150,wd:false,fm:true,w:39,et:true,an:17,e:[6,6,1,1,40,30,false,true],c:"CS>120",p:151000};
I.u[6437] = {n:"Machado de Ikalugi",t:19,d:"#1",ep:2,g:21,l:150,wd:false,fm:true,w:21,et:true,an:17,e:[2,6,1,1,40,30,false,true],c:"CI>100&CW>7",p:151000};
I.u[6438] = {n:"Varinha Mágica Mole",t:3,d:"Esta varinha mágica é constituída de elementos moles tornando seu uso difícil. Entretanto, durante a luta, ela revela seu verdadeiro poder.",ep:5,g:33,l:85,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,70,false,true],c:"CI>85",p:8500};
I.u[6439] = {n:"Varinha Irreal",t:3,d:"Esta varinha irreal é resultado de uma mistura mágica de elementos sobrenaturais. Assustadoramente estranha, esta varinha é exemplo típico de instabilidade.",ep:4,g:32,l:90,wd:true,fm:true,w:12,an:11,e:[10,4,2,3,20,20,false,false],c:"CI>90&CW>30",p:9000};
I.u[6440] = {n:"Varinha Mágica Peluda",t:3,d:"Esta varinha não é apenas um simples monte de pêlos. Seu centro absorve a essência mágica dos tufos e depois libera de uma só vez. Muito estranho, mas eficiente!",ep:14,g:31,l:95,wd:true,fm:true,w:12,an:11,e:[5,3,2,5,40,40,false,true],c:"CW>40&CI>40",p:9500};
I.u[6441] = {n:"Pêlos da Lua",t:54,d:"Estes pêlos parecem incrivelmente macios e mornos ao toque;\r\n            você tem a impressão de que eles ainda estão vivos.",ep:12,g:656,l:200,wd:true,fm:true,w:2,p:10000};
I.u[6442] = {n:"Cajado de Aga Dou",t:4,d:"Sempre ávido por surpreender seus inimigos, o Sadida Aga Dou teve o cuidado de pendurar uma pequena boneca na extremidade de seu cajado. Os jovens Iopettes inevitavelmente corriam para pegar a boneca e morriam empalados.",ep:14,g:31,l:81,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>80&CV>50",p:17000};
I.u[6443] = {n:"Amuleto Renovado",t:1,d:"O famoso e divertido Yamato, um artesão desprezado injustamente, devido ao seu arco ridículo, foi o primeiro que ousou enfeitiçar um amuleto com vários efeitos mágicos... o que até então acreditavam ser impossível.",ep:9,g:57,l:126,wd:true,fm:true,w:20,p:40000};
I.u[6444] = {n:"Amuleto Turquesa",t:1,d:"Este amuleto não tem nenhuma conexão, exceto a sua cor, com o famoso Dofus Turquesa. Entretanto, ele é bastante poderoso. Você, s vezes, pode contar com as aparências...",ep:9,g:58,l:63,wd:true,fm:true,w:10,p:10300};
I.u[6445] = {n:"Arco Curvado",t:2,d:"A forma deste arco foi cuidadosamente desenhada, tendo uma curvatura perfeita. Dizem que seu criador usou um ovo Dofus como modelo.",ep:14,g:13,l:80,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>70&CC>50",p:16500};
I.u[6446] = {n:"Arco de Chiduc",t:2,d:"Chiduc era um escultor de arcos famoso por seus erros de pronúncia. Ele era incapaz de pronunciar o som “ar” sem adicionar “co” logo em seguida. Os grandes artistas são todos iguais.",ep:12,g:14,l:87,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,30,false,true],c:"CW>50&CA>80",p:19000};
I.u[6447] = {n:"Poção de Chaferfu",t:43,d:"Com esta poção você pode esquecer um nível da Magia de Invocação de Chaferfu.",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6448] = {n:"Poção do Esquecimento: \'Invocação de Aracne\'",t:43,d:"Com esta poção, você pode desaprender um nível do feitiço de \'Invocação da Aracne\'.",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6449] = {n:"Corvocapa",t:17,d:"Você conhece maneira melhor de impressionar meninas na frente da Padaria, antes do cair da noite, do que se transformar em uma sombra ou até mesmo em Lorde Corvo? Esta capa lhe permitirá fazer isto.",ep:1,g:54,l:45,wd:true,fm:true,w:26,s:8,p:1000};
I.u[6450] = {n:"Cinto do Amante da Hora",t:10,d:"Uma renomada sapateira tinha um amante que freqüentemente a decepcionava. Como o amor é cego, ela ainda lhe deu este magnífico cinto como símbolo de seu amor secreto.",ep:14,g:57,l:121,wd:true,fm:true,w:20,p:37255};
I.u[6451] = {n:"Arco de Anjo",t:2,d:"Vendo este arco, você pode se perguntar por que ele tem um nome tão estúpido. Isto é que o também nos perguntamos ao ver você.",ep:14,g:31,l:82,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>80&CS>50",p:17000};
I.u[6452] = {n:"Arco de Arquiteto",t:2,d:"Este arco com uma complexa forma é uma obra de arte. O escultor de arcos que o criou também é famoso por ter exposto seus modelos mais controversos na caverna de Loopine, um lugar proibido para o público ignorante.",ep:9,g:30,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>200&CS>100&CI>30",p:37000};
I.u[6453] = {n:"Arco de Pesca",t:2,d:"Oriundo da afirmação “o arco pode ser muito útil para pescar peixe-voador”, este arco contém uma vara integrada, que é usada para pescar outros peixes além do peixe-voador.",ep:14,g:32,l:70,wd:true,fm:true,w:1,an:10,tw:true,e:[10,4,2,8,30,50,false,true],c:"CS>70&CA>70",p:13000};
I.u[6454] = {n:"Treescajado das Sombras",t:4,d:"Este galho de Treechnid das Sombras é, na realidade, um dos braços dele. Ideal para treinar para o braço de ferro, é, acima de tudo, uma excelente arma para aterrorizar os filhos de seus inimigos ou machucar os Trunknids.",ep:13,g:23,l:87,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,50,false,false],c:"CV>150&CW>50",p:20000};
I.u[6455] = {n:"A Gadanha das Colheiras Celestiais",t:22,d:"...",ep:0,g:1,l:100,wd:false,fm:true,w:1,e:[-1,-1,1,-1,-1,-1,false,false],p:1};
I.u[6457] = {n:"Kriptonita",t:40,d:"A origem desta liga extraordinária é bem remota. De qualquer forma, você pode usá-la para decorar a lareira ou, se desejar, para acertar Iops na cabeça e garantir que ficarão sem cérebro!",ep:1,g:706,l:80,wd:true,fm:true,w:80,p:0};
I.u[6458] = {n:"Kobalite",t:40,d:"Kobalite é a liga mais surpreendente já descoberta. Os antigos mineiros pensavam que era a liga perfeita até notar que diminui a poeira quando entra em contato com Saliva de Gobball.",ep:1,g:704,l:100,wd:true,fm:true,w:100,p:0};
I.u[6459] = {n:"Amuleto do Mineiro das Sombras",t:1,d:"A única chance de sobreviver em uma mina infestada de mineiros das sombras é ter luz. Como você não pode roubar as velas deles, use este amuleto, ele traz boa sorte.",ep:14,g:61,l:39,wd:true,fm:true,w:1,c:"CC>30",p:4200};
I.u[6460] = {n:"Folha de Inverno",t:1,d:"Este magnífico broche faz homenagem à resistência dos mineiros da Mina de Prata de Grimoth. Gastaram um inverno lutando com um Crackler da pior espécie e todos morreram, por um Tofu perdido.",ep:1,g:65,l:98,wd:true,fm:true,w:10,p:25000};
I.u[6461] = {n:"Folha da Primavera",t:1,d:"Este amuleto foi especialmente criado para os velhos discípulos de Enutrof que, há muito tempo, permitiram a Setag livrar-se de todos os outros mineiros da mina de Grimoth. Um método exagerado, ainda que bem eficiente.",ep:7,g:62,l:123,wd:true,fm:true,w:10,p:40000};
I.u[6462] = {n:"Folha de Verão",t:1,d:"Este pequeno broche é muito charmoso. Foi feito para ajudar pessoas sem sorte a se darem bem na feira, mas também é útil quando você for para festas épicas de caça.",ep:13,g:63,l:45,wd:true,fm:true,w:4,p:5400};
I.u[6463] = {n:"Anel Itinerante",t:9,d:"Este anel foi criado por um famoso viajante, mas, infelizmente, ninguém conseguiu lembrar o seu nome. Ele morreu durante um confronto numa competição com arco, colocando uma semente de Girassol Selvagem em sua cabeça em vez da tradicional abóbora.",ep:1,g:50,l:44,wd:true,fm:true,w:5,p:5300};
I.u[6464] = {n:"Anel de Invocador Satisfeito",t:9,d:"Este anel é um modelo melhorado do bastante conhecido Anel de Satisfação. É ideal para permitir que suas pequenas feras lutem em seu lugar ou apenas para exibir-se invocando um exército de Tofus.",ep:1,g:51,l:40,wd:true,fm:true,w:5,p:4000};
I.u[6465] = {n:"Anel de Loopine",t:9,d:"Loopine uma vez perguntou ao monstro que assombrava a sua caverna o segredo para fazer um anel em troca de alguns favores. Mas o que Lopine não sabia era que ele podia mudar sua vida para sempre. Pessoas mais informadas deveriam ter dito isso a ele...",ep:5,g:52,l:80,wd:true,fm:true,w:10,p:16000};
I.u[6466] = {n:"Amuleto de Shika",t:1,d:"Este amuleto permitiu que Shika Ingalsse sobrevivesse em várias ocasiões, quando enfrentava Gobballs furiosos, nas quais foram agredidos, tornando a vida dela uma miséria.",ep:14,g:60,l:29,wd:true,fm:true,w:10,p:2300};
I.u[6467] = {n:"Anel de Ano Nimos",t:9,d:"Ninguém conhece o proprietário deste anel. Ele quis permanecer anônimo depois de uma humilhante derrota para uma Aracne invocada. Podemos dizer em defesa dele que esta Aracne tinha acabado de ser examinada por um seguidor de Iop...",ep:1,g:53,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6468] = {n:"Anel do Jovem Vald",t:9,d:"Cada seguidor de Iop dependendo de sua idade recebe presentes tal como um Tabi ou um Goultarde de madeira para sua comunhão, Vald recebeu este anel. Este é apenas um jogo para se divertir com seus amigos, mas é muito útil durante as lutas.",ep:1,g:54,l:59,wd:true,fm:true,w:10,p:9275};
I.u[6469] = {n:"Aliança de Farle",t:9,d:"Esta aliança foi arranhada por espigas de Amaranto do Inverno durante centenas de colheitas. Também testemunhou a união de Farle e Shika quando eles se casaram no meio de um campo de frutas de primavera.",ep:9,g:55,l:87,wd:true,fm:true,w:5,p:20000};
I.u[6470] = {n:"Botas de Criador de Gobballs",t:11,d:"Estas magníficas botas são perfeitas para chutar o traseiro de Gobballs, quando você tiver de mudá-los de pasto ou fazê-los passar por uma aldeia. Elas também são muito úteis para forçar as crianças Iops a fazerem seus deveres de casa e irem para a escola.",ep:13,g:40,l:68,wd:true,fm:true,w:10,p:12000};
I.u[6471] = {n:"Sapatos Exclusivos de Porco Imundo",t:11,d:"Estes pequenos sapatos são reforçados, reparados e com desodorantes. Eles normalmente são usados para pegar Cogu-Cogu já que o substrato deixado pelo Porco Imundo parece apetitoso para eles...",ep:13,g:41,l:30,wd:true,fm:true,w:10,p:2700};
I.u[6472] = {n:"Dregelmo Dourado",t:16,d:"Esta porção de conchas de Dragonete Dourado fornece uma boa proteção contra relâmpagos de Bwork Mago.",ep:11,g:55,l:57,wd:true,fm:true,w:10,p:8500};
I.u[6473] = {n:"Dregelmo Safira",t:16,d:"Esta concha de Dragonete de Safira será perfeita para você. Como um equipamento para cabeça não pode servir em todos... se uma prova for necessária, apenas olhe os trajes dos Iops!",ep:11,g:57,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6474] = {n:"Elmo de Dragonete Preto",t:16,d:"Esta concha de Dragonete Preto é ideal para permanecer discreto à noite, ou ser protegido contra pedras em queda, ou até mesmo quando você desafiar um Crackler em arremesso de pedras.",ep:11,g:56,l:93,wd:true,fm:true,w:20,p:22300};
I.u[6475] = {n:"Capacete Quebrado de Chafer",t:15,d:"Você não pode usar este capacete em tal estado. Machucaria a sua cabeça. Um bom alfaiate, certamente, poderá pôr um enchimento nele e conseguir bastante Kamas de você.",ep:3,g:709,l:40,wd:true,fm:true,w:20,p:1000};
I.u[6476] = {n:"Vela Mágica do Mineiro das Sombras",t:15,d:"Esta vela brilha até quando não existe chama e não emite calor. Aproxime sua orelha e você ouvirá um leve crepitar, como o barulho de cereais do café da manhã em uma tigela de leite.",ep:1,g:701,l:40,wd:true,fm:true,w:10,p:10000};
I.u[6477] = {n:"Chapéu do Mineiro das Sombras",t:16,d:"Este magnífico chapéu lhe ajudará a ver tudo tão brilhante quanto a luz do dia, mesmo se estiver de dia. Também poderá ser útil para deslumbrar as bestas que assombram as minas ou para fazer Iops acreditarem que você é uma das brilhantes personalidades de sua geração.",ep:16,g:90,l:103,wd:true,fm:true,w:20,p:27000};
I.u[6478] = {n:"Makroute Mutilado",t:15,d:"Este Makroute mágico está em um estado muito ruim. Ele não resistiu à violência de seus ataques e seu pêlo agora está preto. Uma nova vida poderia se abrir para ele se você apenas pudesse curá-lo...",ep:14,g:702,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6479] = {n:"Urso Mutilado",t:15,d:"Esta pequena Cabeça de Urso está em um estado muito ruim. Algumas linhas, tecido e inspiração transformarão esta coisa horrível em um magnífico elmo.",ep:1,g:703,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6480] = {n:"Vime das Sombras",t:15,d:"Este Pedaço de Vime é tão escuro quanto o mais escuro dos fantasmas, tão mágico quanto o mais mágico dos fantasmas, tão resistente quanto o mais resistente dos fantasmas. Lembre-se apenas que fantasmas não existem.",ep:14,g:123,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6481] = {n:"Dora Bora",t:16,d:"Este esplêndido chapéu foi criado na Ilha de Dora Bora, ao sul da Ilha da Lua. Perfeitamente adaptado para lutar, também é muito apreciado como uma cesta de fruta, para armazenar as nozes dos Kokokos Traumatizados, por exemplo.",ep:12,g:61,l:120,wd:true,fm:true,w:20,p:40000};
I.u[6482] = {n:"Korko Kousto",t:16,d:"Nova versão de Jouik Kramp, este chapéu foi feito dos melhores recursos encontrados na Ilha da Lua, dando-lhe um aspecto rural. Mesmo se você não se parece com um Kanniball, conseguirá dar boas cabeçadas.",ep:12,g:59,l:73,wd:true,fm:true,w:10,c:"PG=10",p:14000};
I.u[6483] = {n:"Capacete de Bwork de Bronze",t:16,d:"De acordo com a lenda, este surpreendente capacete transforma o seu dono em um Bwork de Bronze. Tente com pessoas pesadas, então as derreta e ganhe muito dinheiro.",ep:20,g:91,l:144,wd:true,fm:true,w:10,p:46625};
I.u[6484] = {n:"Arco do Sram Arqueiro",t:2,d:"Quando adagas não são mais suficientes, quando os deuses estiverem caçoando de você, você tem de encontrar o seu próprio modo de lutar. Alguns seguidores de Sram aparentemente entenderam, outros ainda estão contando com a ajuda dos deuses...",ep:9,g:40,l:90,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>90&CA>90&CW>50",p:16000};
I.u[6485] = {n:"Arco de Chafer Arqueiro",t:2,d:"Por causa de seus ossos trêmulos e uma óbvia falta de destreza e inteligência, o Chafer Arqueiro nunca foi capaz de manejar tal arco. Tirando o problema dos ossos trêmulos, você pode acabar que nem o pobre Chafer, em uma situação ridícula.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CC>100&CS>100",p:36600};
I.u[6486] = {n:"Casca de Carvalho Mole",t:96,d:"Esta casca de árvore é mais resistente do que outras, pois uma força emana dela. Mas nada prova que não seja uma casca de árvore Treechnid pintada. Agora pode ser uma boa hora para enganar um amigo...",ep:9,g:666,l:200,wd:true,fm:true,w:10,p:10};
I.u[6487] = {n:"Broto de Carvalho Mole",t:108,d:"Este enorme broto quente e delicioso de seiva deve lembrá-lo das mamadeiras de bebê se ousar tomar o seu conteúdo. Mas tenha cuidado, pois você pode se transformar em uma folha morta com o efeito colateral.",ep:9,g:665,l:200,wd:true,fm:true,w:10,p:10};
I.u[6488] = {n:"Raiz de Carvalho Mole",t:98,d:"Algumas pessoas fazem energético com este tipo de raiz, na qual é altamente desaconselhável porque o Carvalho Mole pode facilmente ficar eufórico. Suas raízes se tornam instáveis em contato com o líquido de energético. A mesma coisa acontece com um seguidor de Sadida.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[6489] = {n:"Madeira de Carvalho Mole",t:38,d:"Esta madeira passou perto de um machado de Brouce Boulgoure. Também enfrentou outros perigos e mistérios, até mesmo o livro do Mago Bwork não revela. Nós estamos certos de esperar o pior.",ep:1,g:668,l:200,wd:true,fm:true,w:10,p:10};
I.u[6490] = {n:"Âmbar de Carvalho Mole",t:50,d:"Este âmbar contém um inseto patético aprisionado na resina. Esta jóia pertencente ao Carvalho Macio é um item de colecionador como as meias amarelas com pontinhos vermelhos de Chouque.",ep:9,g:669,l:200,wd:true,fm:true,w:10,p:10};
I.u[6491] = {n:"Trunknydum",t:2,d:"Este arco surgiu do cruzamento de um Trunknid com um Treechnid. Obviamente é um fracasso para um Lenhador, mas um verdadeiro sucesso para um Escultor de Arco. Seus pais desejavam poder dizer o mesmo de você.",ep:9,g:41,l:57,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],p:8500};
I.u[6492] = {n:"Cajado Wobot",t:4,d:"A distância entre os lados deste cajado é idêntica ao espaço entre os olhos dos Lenalds... Qual será o limite para os howiveis Wabbits?",ep:2,g:37,l:60,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>60&CV>60",s:11,p:9400};
I.u[6493] = {n:"Chinelo Wabbits",t:11,d:"Estes chinelos Wabbit lhe dão a \"atitude de cenouwawa\". É recomendado a qualquer perito em danças rituais, dançar sapateado ou um tango rápido de Captain Chafer.",ep:8,g:39,l:60,wd:true,fm:true,w:10,s:11,p:9300};
I.u[6494] = {n:"Varinha Mágica de Elya Wood",t:3,d:"Usada pelos mais famosos seguidores de Eniripsa, esta varinha mágica é uma arma perfeita para conjurar um feitiço em seus inimigos ou fazer alguns de seus amigos ficarem mais inteligentes. Sendo assim, você pode transformar um discípulo de Iop em uma abóbora, por exemplo.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,50,50,false,true],c:"CI>300&CW>100",s:39,p:36800};
I.u[6495] = {n:"Varinha do Carvalho Mole",t:3,d:"Fetio de restos de Carvalho Mole, esta varinha mágica é ultra-poderosa. Apenas chacoalhe da direita para a esquerda de acordo com os padrões rítmicos específicos e talvez você se parecerá com um perfeito idiota.",ep:22,g:42,l:172,wd:true,fm:true,w:10,an:11,tw:true,e:[7,3,3,4,45,70,false,true],c:"CI>400&CC>250&CW>150",p:45000};
I.u[6496] = {n:"Varinha de Raiz de Treechnid Escura",t:3,d:"Esta varinha às vezes pode virar contra seu dono. Neste caso, a melhor coisa a se fazer é dá-la a um de seus inimigos, ou a um seguidor de Iop;\r\n            ele certamente pensará que é um presente.",ep:9,g:40,l:67,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>70&CW>70",p:12000};
I.u[6497] = {n:"Balgourde dos Esclarecidos",t:3,d:"A esposa do Brouce Boulgoure, uma Eniripsa, costumava roubar seu famoso machado. Para impedí-la de roubar novamente, ele cortou uma de suas asas e um braço. Para que ela o perdoasse, ele lhe deu então este bastão. Este homem soube como tratar mulheres.",ep:9,g:43,l:63,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,50,false,true],c:"CI>63&CW>30",p:10325};
I.u[6498] = {n:"Cueca do Wabbit GM",t:10,d:"Esta cueca de tamanho respeitável ainda ostenta as marcas de seu antigo dono (mais alguns pêlos realmente estranhos). Nas nádegas ou na cabeça, este calção fará de você uma pessoa respeitada em Amakna.",ep:8,g:58,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6499] = {n:"Amuleto \"Dentes de Wabbits\"",t:1,d:"Os dentes deste amuleto roeram mais Cenouwawas do que Brouce Boulgoure arrancou árvores. Então, não fique surpreso se você cheirar a Cenouwawa e se os Tiwabbits tentarem lhe dar beijos no pescoço.",ep:8,g:59,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6500] = {n:"Orelhas de Wabbits",t:16,d:"Estas Orelhas não melhorarão a sua audição, mas por outro lado seus amigos o notarão facilmente numa multidão... e seus inimigos darão boas risadas. Continue sorrindo, este par de orelhas provará que é indispensável com o tempo.",ep:8,g:52,l:60,wd:true,fm:true,w:10,s:11,p:9500};
I.u[6501] = {n:"Sacola-Cenouwawa",t:81,d:"Se você levar esta sacola em suas costas, você pode fazer uma viagem sem se preocupar com comida. Ainda que a Cenouwawa esteja tão vazia quanto um crânio de Iop, as folhas no topo dela podem crescer novamente. Ideal para fazer chá de ervas.",ep:8,g:57,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6503] = {n:"Martelo Polpulete",t:7,d:"O Polpulete é o resultado do cruzamento entre um Kwak de Fogo agressivo e um fraco Tofu. Desde o surgimento do mundo, a caçada Polpulete é um ritual imutável. Caçar essa horrível criatura é um prazer.",ep:13,g:35,l:57,wd:true,fm:true,w:20,an:15,e:[6,5,1,1,40,50,false,false],c:"CI>60&CS>20",p:8000};
I.u[6504] = {n:"Martelo Fantal",t:7,d:"As únicas coisas que sabemos sobre o criador deste martelo são seu apelido – certo Fantal – e seu péssimo gosto. Ele adorava cobrir-se com Geléia Real e penas de Tofu Real... Uma idéia bastante volúvel de luxo.",ep:9,g:36,l:81,wd:true,fm:true,w:20,an:15,e:[10,5,1,1,50,50,false,false],c:"CS>80&CV>70",p:17000};
I.u[6505] = {n:"Martelo Rehadaure",t:7,d:"Este martelo é ideal para lutar contra bestas com chifre e não é recomendável arranhar suas cores diante da multidão.",ep:9,g:37,l:100,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CC>100&CW>40&CS>50",p:26000};
I.u[6506] = {n:"Anel do Mineiro Gogorificado",t:9,d:"Uma lenda Enutrof diz que um mineiro é \"gogorificado\" quando não passa mais tempo à luz do dia do que o tempo gasto na mina. Nunca traga uma vela perto demais de um mineiro ou ele te transformará em bronze.",ep:1,g:40,l:84,wd:true,fm:true,w:10,c:"PG=3",p:18500};
I.u[6507] = {n:"Martelo de Terps",t:7,d:"A Terps era uma criatura muito sórdida, perigosa e odiada como o velho Liche, seu grande rival. Determinada a superar este rival, a Terps criou este martelo para esmagar os dedos do pé dele, mas a dor atacou principalmente no pescoço. Era o início de uma grande história de amor.",ep:9,g:38,l:90,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,35,80,false,false],c:"CS>60&CI>60",p:19000};
