I.u[7005] = {n:"Grande Pedra de Alma Perigosa",t:83,d:"Com esta runa, você tem uma pequena chance de capturar almas particularmente selvagens...",ep:5,g:9,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7006] = {n:"Enorme Pedra da Alma Perigosa",t:83,d:"Esta runa oferece uma pequena chance de capturar almas extremamente difíceis...",ep:16,g:10,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7007] = {n:"Pequena Pedra da Alma",t:83,d:"Esta pedra lhe oferece uma grande chance de capturar pequenas almas.",ep:5,g:2,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7008] = {n:"Pedra da Alma Mediana",t:83,d:"Com esta pedra você tem uma chance mediana de capturar almas relativamente importantes...",ep:5,g:12,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7009] = {n:"Grande Pedra de Alma",t:83,d:"Com esta runa, você tem chances médias de capturar almas particularmente selvagens...",ep:16,g:13,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7010] = {n:"Pedra de Alma Plena",t:85,d:"Esta pedra da alma contém as almas de um grupo de monstros que estão só pensando em voltar à vida para se vingar de você. Mas a pedra só pode ser usada em determinadas arenas, localizadas em grandes cidades.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7011] = {n:"Manto de Bola dos Desejos",t:17,d:"Este manto quase vivo, feito de pêlos de barba ruiva, é único. Alimentado por uma extraordinária magia, tende a fazer muitos truques com quem o veste. Seu favorito é se esconder antes de a pessoa sair em uma aventura, quando mais se precisa dele. Além de seus pequenos truques, pode ser muito poderoso em lutas e alguns Wabbits até dizem que ele é um ‘veldadeiro instlumento de guella\'.",ep:13,g:83,l:67,wd:false,fm:true,w:10,s:38,p:11875};
I.u[7012] = {n:"Amuletofedor O\'Bal",t:1,d:"Este amuleto é, na verdade, um doce. Podia ser comido se não estivesse enrolado no sovaco por 36 gerações de uma horda de Bworks fêmeas.",ep:7,g:87,l:77,wd:true,fm:true,w:10,s:38,p:15425};
I.u[7013] = {n:"Madeira de Bambu",t:38,d:"Ao contrário das canas, os bambus podem se curvar e quebrar. Na maioria das vezes, são os descuidados dentes dos aventureiros que quebram primeiro. Algumas vezes até mesmo a natureza se submete aos inescrupulosos dentistas.",ep:18,g:673,l:50,wd:true,fm:true,w:5,p:0};
I.u[7014] = {n:"Madeira de Bambu Sagrado",t:38,d:"Apesar da aparência, esta madeira é sagrada. Só os melhores Pandawas conseguem cortar esta madeira. Mas, algumas vezes, lenhadores turistas levam um pedaço como recordação da viagem à Ilha de Pandala. Malditos turistas.",ep:18,g:671,l:100,wd:true,fm:true,w:5,p:0};
I.u[7015] = {n:"Brotos de Bambu",t:38,d:"Estes brotos de bambu são impróprios para consumo. Eles não têm nenhum gosto. Portanto, você pode cortá-los com uma foice enferrujada ou deixá-los marinando por alguns anos no suco de Greedovore, antes de servi-los aos amigos. Outra dica dos inescrupulosos donos de restaurante dispostos a fazer você comer qualquer coisa.",ep:1,g:676,l:50,wd:true,fm:true,w:2,p:5};
I.u[7016] = {n:"Madeira de Bambu da Sombra",t:38,d:"Walloh, um jovem Pandawa, uma vez perguntou a seu pai: ‘Papai, qual a diferença entre Bambu e o Bambu das Sombras?\' Seu pai lhe deu um tapa na cara por ter ousado fazer uma pergunta tão estúpida. Todo mundo sabe que a diferença entre o Bambu e o Bambu das Sombras é o tamanho de suas sementes.",ep:18,g:672,l:60,wd:true,fm:true,w:5,p:0};
I.u[7017] = {n:"Madeira de Bambu Dourado",t:38,d:"Walloh, um jovem Pandawa uma vez perguntou ao seu pai: ‘Qual a diferença entre Bambu e Bambu Dourado, papai?‘ Seu pai beijou-o e perguntou como ousa perguntar algo tão estúpido. Todos sabem que a diferença entre o Bambu e o Bambu Dourado é o tamanho de suas raízes.",ep:18,g:669,l:45,wd:true,fm:true,w:5,p:20};
I.u[7018] = {n:"Arroz",t:34,d:"Seco ou viscoso, o arroz é sempre um sucesso ente os jovens Pandawas famintos.",ep:18,g:10,l:20,wd:true,fm:true,w:2,p:0};
I.u[7020] = {n:"Flor de Lótus",t:38,d:"Alguns dizem é a flor mais velha conhecida. Simboliza a fertilidade assim como a separação, já que emerge da água sem se molhar. Alguns Chefes Pandawas usam este símbolo para fazer com que seus discípulos compreendam que precisam viver a vida no mundo sem ser influenciados.",ep:1,g:141,l:30,wd:true,fm:true,w:1,p:2};
I.u[7022] = {n:"Cajado de Sangroku",t:4,d:"Este cajado pertenceu ao avô de Sangroku, Sandrokrane, famoso por sua cabeça grande. A lenda diz que este cajado mágico pode esticar para alcançar todos os inimigos ou, simplesmente, compensar o complexo de inferioridade dos seus usuários.",ep:18,g:47,l:120,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,50,60,false,false],c:"CA>250&CV>300",p:36620};
I.u[7023] = {n:"Pedra de Água-Marinha",t:51,d:"Esta pedra é normalmente encontrada nas redondezas da Ilha de Pandala. Os Pandawas dizem que esta pedra tem poderes peculiares. Todos falam disso, mas ninguém ainda os descobriu. Como os inteligentes Iops, por exemplo!",ep:1,g:75,l:60,wd:true,fm:true,w:5,p:600};
I.u[7024] = {n:"Pedra de Topázio",t:51,d:"Esta pedra de aparência esquisita costumava ser a comida dos jovens Crackrocks dos criadores de Pandala. Agora, é proibido alimentar Crackrocks com estas pedras já que elas se tornaram muito raras.",ep:5,g:76,l:70,wd:true,fm:true,w:5,p:700};
I.u[7025] = {n:"Pedra de Agathe",t:51,d:"Esta pedra foi nomeada depois de um rio de Pandala no qual ela costumava ser encontrada em grande quantidade. Mas os tempos mudaram e a exploração intensa de suas jazidas acabou tornando-a rara de ser encontrada hoje em dia.",ep:5,g:128,l:80,wd:true,fm:true,w:5,p:1};
I.u[7026] = {n:"Água-Marinha",t:50,d:"Esta preciosa pedra transparente, ligeiramente azul, pode ser tão brilhante que pode esconder – quando usada como um colar, as rugas mais profundas. Os Pandawas sempre dizem aos turistas: ‘Com esta pedra, faça sua amada feliz e aceite mais facilmente as marcas do tempo\'. Uma boa maneira de matar dois coelhos com uma pedra!",ep:1,g:101,l:60,wd:true,fm:true,w:5,p:600};
I.u[7027] = {n:"Topázio",t:50,d:"Por algumas razões duvidosas, esta pedra preciosa permanece a favorita dos joalheiros. Ela atrai bastantes Corvos no meio das Planícies de Cania.",ep:5,g:102,l:70,wd:true,fm:true,w:5,p:700};
I.u[7028] = {n:"Agathe",t:50,d:"Esta pedra foi batizada depois de uma Pandawa muito famosa: Agathe Pahtes. Ela podia ser encontrada em lugares de libertinagem, como o Bar dos Piratas Sufokia, onde ela passou seus últimos anos dançando acorrentada a um grande mastro bem no meio do bar.",ep:5,g:103,l:80,wd:true,fm:true,w:5,p:800};
I.u[7029] = {n:"Cinto de Sangroku",t:10,d:"Quando Sangroku comia muitos feijões mágicos, ele agarrava firme este cinto para conter o máximo de Ventos de Pânico... Eram os mesmos ventos que o tornaram famoso ao cruzar toda a província de Amakna.",ep:13,g:80,l:86,wd:false,fm:true,w:10,c:"CS>100",p:18400};
I.u[7030] = {n:"Pele de Kaniger",t:59,d:"Uma vez depilada, a pele de Kaniger é muito macia, como uma mulher Sadida.",ep:13,g:47,l:70,wd:true,fm:true,w:5,p:1};
I.u[7031] = {n:"Pêndulo do Flooey",t:1,d:"Pobre Flooey, perdeu a cabeça depois de uma terrível luta contra Many. Felizmente, seu amuleto não sofreu dano durante o confronto. Manteve tanto seus poderes hipnóticos quanto os laxativos. Usar com moderação.",ep:18,g:90,l:46,wd:false,fm:true,w:2,p:5600};
I.u[7032] = {n:"Silicato",t:39,d:"Este minério provavelmente vem das profundezas das minas da ilha Pandala onde Gardan Framine se apaixonou completamente por uma fantasma Pandawa. O amor realmente não tem limites! ",ep:16,g:111,l:70,wd:true,fm:true,w:5,p:0};
I.u[7033] = {n:"Dolomita",t:39,d:"Irko, o Mineiro das Sombras, costumava dizer ‘Sempre rígida e inquebrável\' quando falava sobre a Dolomita.",ep:16,g:110,l:80,wd:true,fm:true,w:5,p:0};
I.u[7034] = {n:"Capacete do Mestre Nabur",t:16,d:"Passado de geração em geração, este capacete deformado era usado pelo Crail em pessoa. Muitos aventureiros pensam que ele tem poderes, mas não tem. Característica compartilhada por muitas divindades e heróis modernos.",ep:16,g:93,l:97,wd:false,fm:true,w:10,p:23000};
I.u[7035] = {n:"Pyrute",t:40,d:"Esta liga foi usada para forjar lâminas que não enferrujam quando em contato com sangue ou saliva dos inimigos.",ep:16,g:708,l:100,wd:true,fm:true,w:100,p:0};
I.u[7036] = {n:"Rutile",t:40,d:"Liga brilhante bem apreciada por joalheiros corruptos que não podem usar pedras preciosas. Fazem ligas muito interessantes. É útil quando você quer casar por interesse.",ep:16,g:707,l:100,wd:true,fm:true,w:100,p:0};
I.u[7037] = {n:"Espeto de Granny Candy=+",t:4,d:"Este bastão costumava pertencer a Mamãe Bombom, uma das três sacerdotisas do amor. Afiado em uma ponta e brilhante na outra, este bastão era famoso por sua versatilidade e capacidade de ultrapassar qualquer coisa. Ninguém poderia estar complemente impenetrável a ele.",ep:18,g:48,l:98,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,50,50,false,false],c:"CS>100&CV>300",p:24500};
I.u[7038] = {n:"Coroa do Rei Geléias",t:16,d:"Este corvo pertenceu ao famoso Rei Geléias, conhecido pelo seu romantismo ilimitado e seu poder de sedução que deixaram marcas em muitas Geléias fêmeas... Alguns dizem que ele é o pai de todas as Geléias da região de Amakna, prova de sua resistência e fertilidade lendária.",ep:7,g:94,l:79,wd:true,fm:true,w:15,p:15000};
I.u[7039] = {n:"Cinto Preto de Frank Lee Bruce",t:10,d:"Famoso lutador de domingo, Franck mudou-se para as artes marciais depois que perdeu, miseravelmente, o seu diploma de escultor de pedra.",ep:13,g:81,l:47,wd:true,fm:true,w:5,p:5900};
I.u[7040] = {n:"Arco de Kuri",t:2,d:"Este arco pertenceu à própria Kuri, famosa sacerdotisa do amor e braço esquero de Mamãe Bombom. Jamais devolveu à sacerdotisa do amor. Uma flecha deste arco é o bastante para despedaçar seu coração ou mesmo seu traseiro se você não estiver de frente para o oponente.",ep:18,g:43,l:56,wd:true,fm:true,w:10,an:10,tw:true,e:[15,5,2,6,20,40,false,true],p:8300};
I.u[7041] = {n:"Pandrista",t:30,d:"Também conhecido como a Diarréia dos Pandawa, o Pandrista é a especialidade de Pandala, os viajantes sabem disso! Sintomas: necessidade urgente de ir ao banheiro, imediatamente seguida da incapacidade de produzir o esperado cocô!",ep:18,g:8,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7042] = {n:"Chapéu Pandawa",t:14,d:"Diferentemente do Pandawa de Amakna, o Pandawa de Pandala não o deixará com a cabeça grande, mas vai tornar você um grande fertilizante! Divulgue-o no vegetal ou Miau mais próximo! É igualmente eficiente (para você) e muito mais divertido!",ep:18,g:31,l:1,wd:false,fm:true,w:1,c:"PG!12",u:true,p:1000};
I.u[7043] = {n:"Dofus de Gelo",t:23,d:"A lenda diz que este esplêndido Dofus saiu de um buraco congelado de Aguabrial, o dragão de Água. A lenda não diz se ele tinha frio nesse dia, mas é fácil de adivinhar.",ep:1,g:5,l:1,wd:false,fm:true,w:1,p:1};
I.u[7044] = {n:"Dofus Falso",t:24,d:"Este Dofus não se parece com os outros e ainda...",ep:18,g:256,l:1,wd:false,fm:true,w:0,p:1};
I.u[7045] = {n:"Frasco de Pandaburg",t:79,d:"Pandaburg é uma deliciosa bebida que poderia lentamente deixar você cego, mudo e surdo. Que conveniente! Os Pandawas não são muito rápidos.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[7046] = {n:"Frasco de Pandapiler",t:79,d:"De acordo com o sábio Hel Munster, esse néctar genuíno deleita a própria deusa Pandawa, deixando-a completamente eufórica. Todos os Pandawas devem dar os seus Pandapilers para a nossa venerada deusa.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[7047] = {n:"Frasco de Pandapils",t:79,d:"Há uma estranha tradição Pandawaiian que faz você tinir os copos com uma pena de Tofu na cabeça e cantando: ‘Pandapils, Pandapils, tralalalaHIHOO!\' Longe de ser a pior....",ep:18,g:4,l:1,wd:true,fm:true,w:1,p:1};
I.u[7048] = {n:"Frasco Pandalartois",t:79,d:"O Pandalartois é uma bebida muito tóxica e seu consumo (mesmo em moderação) pode levar a sérias disfunções no sistema nervoso. Mas como o gosto é bom, Pandawas continuam bebendo todo dia.",ep:0,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[7049] = {n:"Frasco Panduff",t:79,d:"Ideal para libações à deusa desde que você respeite o seguinte ritual: deite no chão, olhe para a estátua, beba um bocado de Panduff, então engula e finalmente o mais importante: leve um gole de Panduff. Olhe a estátua da deusa nos olhos. Após alguns dias nesta dieta, ela aparecerá para você. Se não, vá ver um Xamã.",ep:0,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[7050] = {n:"Frasco Panduvel",t:79,d:"Dê um peixe a um Pandawa e ele o comerá o dia todo. \nEnsine um Pandawa como pescar e ele passar seus dias em um barco a remo bebendo Panduvel (velho ditado Pandawaiian).",ep:0,g:7,l:1,wd:true,fm:true,w:1,p:1};
I.u[7051] = {n:"Frasco Pandarium Tremens",t:79,d:"\"Pandarium Tremens prova o amor de Pandawa e ele nos fará feliz.\" Esta reza endereçada à deusa é uma evidência de paz entre todos os Pandawas.",ep:0,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[7052] = {n:"Frasco Pandakwa",t:79,d:"A diferença entre um Pandakwa e a deusa Pandawa é que esse Pandakwa pode ser livre de energéticos!",ep:0,g:10,l:1,wd:true,fm:true,w:1,p:1};
I.u[7053] = {n:"Frasco Vodkawa",t:79,d:"\"Você saberá que bebeu uma garrafa muitas vezes após bebê-la\". Este velho ditado Pandawaiian é a origem de numerosos excessos festivos. Foi mesmo inspirado no famoso menestrel Jon Lemon por algumas de suas músicas.",ep:0,g:8,l:1,wd:true,fm:true,w:1,p:1};
I.u[7054] = {n:"Frasco Whysdawa",t:79,d:"Whysdawa é como peitos. Um não é o bastante e três é demais (velho ditado Pandawaiian).",ep:0,g:11,l:1,wd:true,fm:true,w:1,p:1};
I.u[7055] = {n:"Frasco de Pandneken",t:79,d:"‘É verdade que as pernas de Bwak são pequenas, mas não tem sentido deixá-las mais longas\'. Este é o tipo de conversa que você terá após consumir um Pandneken. Esse é o motivo pelo qual os Pandawas agora preferem guardá-los para os rituais religiosos para Pandawa.",ep:18,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[7056] = {n:"Kracklin Kepi",t:16,d:"Este chapéu único pertenceu a um Xelor. Ele era famoso por suas idéias explosivas e domínio do tempo. Ele morreu de um jeito bem incomum. Lançando um Vento de Pânico que levou seu chapéu para longe, então ele esqueceu que seu chapéu não estava mais com ele e jogou algumas fagulhas por toda a parte. Alguns dizem que sua morte foi muito dolorosa, mas tão brilhante que iluminou toda a cidade de Brakmar por vários segundos.",ep:19,g:95,l:149,wd:true,fm:true,w:10,p:45850};
I.u[7057] = {n:"Assistente de Xamã",t:32,d:"Traga o assistente para a deusa, ela ficará agradecida...",ep:18,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7058] = {n:"Octovius",t:16,d:"Este elmo é feito de restos de Kralove seco. Tenha cuidado, ele pode voltar à vida se você usá-lo como uma touca de banho.",ep:18,g:96,l:77,wd:true,fm:true,w:10,p:15475};
I.u[7059] = {n:"Sementes de Pandkin",t:58,d:"Estas enormes sementes estão cheias de um óleo pesado porém mágico. Dizem que sua casca é inquebrável e alguns artesões as usam para aprimorar suas armas. Outros as usam em bolas para jogar críquete.",ep:18,g:67,l:100,wd:true,fm:true,w:10,p:10};
I.u[7060] = {n:"Pandapiler Especial",t:24,d:"O Sábio Lenald lhe concedeu esse Pandapiler para que você o levasse ao Mestre Pandawushu do caminho das águas.",ep:18,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[7061] = {n:"Miau Amaldiçoado",t:31,d:"A água da fonte de suco-sã-ki-carvalho do Miau o transformou temporariamente em um Miau. O choque mais leve fará você voltar ao normal.",ep:18,g:21,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7062] = {n:"Poochan",t:32,d:"Você deve levar Poochan ao seu futuro marido.",ep:18,g:21,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7063] = {n:"Flor dos Diabinhos",t:35,d:"Esta bonita flor só cresce na Vila dos Diabinhos.",ep:1,g:634,l:40,wd:true,fm:true,w:2,p:10};
I.u[7064] = {n:"Orquídea Sarnenta",t:35,d:"Esta bela orquídea é muito conhecida por provocar coceira a todos que ousam cortá-la.",ep:1,g:633,l:40,wd:true,fm:true,w:2,p:10};
I.u[7068] = {n:"Farinha de Arroz",t:52,d:"Esta farinha é perfeita para cimento ou até mesmo como liteira de Ouginak.",ep:18,g:7,l:50,wd:true,fm:true,w:2,p:0};
I.u[7069] = {n:"Escudo de Sidimote Retorcido",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:8,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:15650};
I.u[7070] = {n:"Escudo dos Diabinhos Arranhado",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"BI=non équipable",p:30700};
