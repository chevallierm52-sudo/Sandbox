I.u[7379] = {n:"Tecido de Fantasma Pandikaze",t:55,d:"Este conjunto de pêlos está quase intacto apesar do tratamento que você deve ter dado a este pobre Fantasma Pandikaze para obtê-lo.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7380] = {n:"Tecido de Raposa Maho Maho",t:55,d:"Este tecido mágico de cor vermelha está impregnado de mágica superpoderosa. Não é bem um item que você compartilha!",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7381] = {n:"Tecido de Raposa Soryo Fantasma",t:55,d:"Este tecido de tamanho modesto é perfeito para tapar os buracos em baixo das portas velhas quando o Inverno chega.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7382] = {n:"Tecido de Fantasma Leopardo",t:55,d:"Este tecido não é tão macio quanto a música de Leopardo, mas deve ser bem útil. Para que? Esta é a questão...",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7383] = {n:"Pano de Raposa Yokai",t:55,d:"Este pano vem das partes mais sensíveis da Raposa Fantasma de Yokai e as mais fedorentas também. Muitos aventureiros se enganam pensando que estão falando de seu bigode.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7384] = {n:"Tecido de Fantasma Pandulum",t:55,d:"Ao contrário do que dizem, esse tecido não é comestível. Os últimos que tentaram cozinhar ele se transformaram em Tanukouï San. Mas que sorte!",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7385] = {n:"Tecido de Fantasma Tanukouï San",t:55,d:"Este tecido vem das axilas do Fantasma Tanukouï San, famoso por sua suavidade e pelo seu cheiro parecido com aquele de carne de Corvo em decomposição... no melhor dos casos!",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7386] = {n:"Glândulas de Tanukouï San",t:15,d:"Estas imensas glândulas são cobertas por uma penugem muito suave que protege tanto contra ataques mágicos quanto contra golpes de perna de pau que o Tanukouï San pode dar em si mesmo quando ele não presta atenção no que está fazendo ou quando entra em transe durante a invocação de um Tanuki Chan. Em todo caso, o que você tem nas mãos é algo especial!",ep:1,g:2,l:120,wd:true,fm:true,w:200,p:10};
I.u[7387] = {n:"O clã de `SRVT:MERCENARY_CLAN`",t:25,d:"Você entenderá os mínimos detalhes sobre o `SRVT:MERCENARY_SHORT_NAME`! Por `SRVT:MERCENARY_LEADER`, Grande Mestre `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:19,l:1,wd:true,fm:true,w:1,u:true,p:1};
