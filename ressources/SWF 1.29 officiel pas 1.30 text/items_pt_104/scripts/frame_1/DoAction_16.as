I.u[7356] = {n:"Transformação Bwak",t:31,d:"A água da maldita fonte de suco-sã-ki-carvalho do Bwak lhe transformou temporariamente em um Bwak. O mais leve choque fará você voltar ao normal.",ep:18,g:22,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7357] = {n:"Transformação Javalizinho",t:31,d:"A água da fonte amaldiçoada de sangue de Javalizinho transformou-o temporariamente em Javalizinho, o menor choque fará retornar ao estado normal.",ep:18,g:20,l:1,wd:false,fm:false,w:0,m:true,p:1};
