I.u[7389] = {n:"Poção do Esquecimento: \'Fúria\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço de Sacrier: \'Fúria\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
