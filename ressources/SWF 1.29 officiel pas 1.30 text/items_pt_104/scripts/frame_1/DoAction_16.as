I.u[7392] = {n:"Poção do Esquecimento: \'Loucura Sanguinária\'",t:43,d:"Esta poção permite ao seu consumidor desaprender um nível do feitiço de Sacrier: \'Loucura Sanguinária\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7393] = {n:"Tecido de Fantasma Pandora",t:55,d:"Este tecido ainda está impregnado com o suor de Pandora. Ele o dá um valor adicional considerável.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7394] = {n:"Poção do Esquecimento: \'Golpe Felino\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço especial: \'Golpe Felino\'.",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7395] = {n:"Poção do Esquecimento: \'Captura de Alma\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço especial: \'Captura Almas\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7396] = {n:"Prosperidade",t:29,d:"Esta bênção irá fazer você ganhar resistência à Água para as suas próximas lutas.",ep:18,g:10,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7397] = {n:"Perspicácia",t:29,d:"Esta bênção fará você ganhar resistência ao Fogo para suas próximas lutas.",ep:18,g:9,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7398] = {n:"Elasticidade",t:29,d:"Esta bênção o fará ganhar resistência a Ar em suas próximas lutas.",ep:18,g:8,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7399] = {n:"Rigidez",t:29,d:"Esta bênção lhe fará ganhar resistência à Terra em suas próximas lutas.",ep:18,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7400] = {n:"Pergaminho Amarrado",t:87,d:"Este Pergaminho lhe permite localizar seu alvo de maneira que você possa caçá-lo.",ep:1,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:1};
I.u[7401] = {n:"Pergaminho virgem",t:87,d:"Este pergaminho é capaz de ‘marcar\' um alvo para a procura dele.",ep:16,g:1,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,ut:true,p:100};
I.u[7402] = {n:"Pacote de Dez Pergaminhos Virgens",t:87,d:"Com este pacote você poderá ‘marcar\' <b>um único alvo</b> que você poderá caçar várias vezes.",ep:16,g:3,l:10,wd:false,fm:true,w:10,c:"Ps!0&PP>0",u:true,ut:true,p:500};
I.u[7403] = {n:"Osso de Fantasma Leopardo",t:47,d:"Os Diabinhos usaram este pequeno osso pontudo como decoração nasal. Um jeito elegante de realçar um nariz curvo, por exemplo.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7404] = {n:"Osso de Raposa Maho Fantasma",t:47,d:"Este osso ainda está impregnado com uma magia de fabricação caseira. Não fique surpreso se este osso voltar à vida e tentar encontrar os restos de seu dono.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7405] = {n:"Osso de Fantasma Pandikaze",t:47,d:"Este osso é a única coisa que restou do fantasma que você acabou de exterminar. Que má sorte a sua, ele não parece ter qualquer indício mágico.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7406] = {n:"Osso de Fantasma Pandora",t:47,d:"Este osso não sai da Caixa de Pandora... mesmo assim, ainda temos todos os motivos para acreditar que sai.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7407] = {n:"Osso de Fantasma Pandulum",t:47,d:"Finamente esculpido, este osso pode ser usado como um ponteiro para um relógio gigante. Simplesmente essencial.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7408] = {n:"Osso da Raposa Fantasma de Soryo",t:47,d:"A primeira vez que a Raposa Soryo quebrou um osso, ele tentou se vingar no primeiro homem que apareceu. Naquele mesmo momento, Jony Lenon, trovador de seu estado, estava caminhando e cantando quando ele topou com a Raposa Soryo. Ninguém sabe o que aconteceu a seguir. A única coisa que pôde ser notada depois foi que sua voz ficou ainda mais aguda.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7410] = {n:"Osso de Fantasma Tanukouï San",t:47,d:"A primeira vez que a Raposa Soryo quebrou um osso, ele tentou se vingar no primeiro homem que apareceu. Naquele mesmo momento, Jony Lenon, trovador de seu estado, estava caminhando e cantando quando ele topou com a Raposa Soryo. Ninguém sabe o que aconteceu a seguir. A única coisa que pôde ser notada depois foi que sua voz ficou ainda mais aguda.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7411] = {n:"Osso da Raposa Fantasma Yokai",t:47,d:"Este osso podia ter sido usado para rachar crânios abertos dos aventureiros audaciosos, ou enterrar Enutrofs como meros aspargos. Mas desde que está em suas mãos, seu destino parece ser diferente...",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7412] = {n:"Pacote de Cem Pergaminhos Virgens",t:87,d:"Com este pacote você poderá ‘marcar\' <b>um único alvo</b> que você poderá caçar várias vezes.",ep:16,g:3,l:10,wd:false,fm:true,w:100,c:"Ps!0&PP>0",u:true,ut:true,p:3500};
I.u[7413] = {n:"Pergaminho \"Aponte seu dedo\"",t:25,d:"(Clique duas vezes para aprender este emote)\nCom este pergaminho poderá \"Apontar seu dedo\" para mostrar uma direção ou denunciar abertamente trapaceiros.",ep:18,g:9,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7414] = {n:"Pequeno Miau Branco",t:18,d:"Esta bola de pêlos, mordidas, arranhões e tudo mais incluindo a mão que o alimenta! É terrível, mas ainda assim é uma criatura fascinante e irresistível. Qualquer semelhança com uma mulher não será acidental. Tenha cuidado, esta criatura não é apenas de temperamento quente, mas também bastante difícil de agradar com comida. Assim,  dê apenas carne fresca de criaturas caçadas.",ep:3,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7415] = {n:"Pequeno Au-au Preto",t:18,d:"Esta estranha criatura só come peixe fresco. Mas não se preocupe, ela é uma boa companhia apesar do bafo de peixe desidratado.",ep:3,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7417] = {n:"Certificado do Canil: Peki Peki",t:77,d:"Este certificado descreve as características do Peki Peki que você pôs no Canil.",ep:3,g:26,l:1,wd:false,fm:true,w:1,p:100};
I.u[7418] = {n:"Certificado do Canil: Pequeno Miau Branco",t:77,d:"Este certificado descreve as características do Miau que você pôs no Canil.",ep:3,g:27,l:1,wd:false,fm:true,w:1,p:100};
I.u[7419] = {n:"Certificado do Canil: Pequeno Miau Preto",t:77,d:"Este certificado descreve as características do Au-au que você pôs no Canil.",ep:3,g:28,l:1,wd:false,fm:true,w:1,p:100};
I.u[7420] = {n:"Certificado do Canil: Nomoon",t:77,d:"Este certificado descreve as características do Nomoon que você pôs no Canil.",ep:3,g:35,l:1,wd:false,fm:true,w:1,p:100};
I.u[7421] = {n:"Poção de Esquecimento de Profissão: Ferreiro de Escudo",t:44,d:"Com esta poção você esquecerá a profissão de Ferreiro de Escudo.",ep:18,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7422] = {n:"Abacamáscara",t:16,d:"Diferentemente da mochila de Cenouwawa, a Abacachila não é tão espaçosa, portanto você não pode colocar qualquer coisa nela. Além disso, ela é bem pesada.",ep:1,g:117,l:1,wd:true,fm:true,w:1,s:74,p:10};
I.u[7423] = {n:"Ovo de Larva Dourada",t:12,d:"Tão estranho quanto parece, estes Ovos de Larva Dourada não foram botados por uma Larva Dourada e sim pelo tipo comum verde, laranja ou mesmo azul. A natureza pode mesmo surpreender.",ep:1,g:715,l:10,wd:true,fm:true,w:1,u:true,p:1};
I.u[7425] = {n:"Pequena Larva Dourada",t:32,d:"Esta larva acabou de sair da incubação. Como você foi a primeira coisa que ela viu, parabéns, ela considera você como mãe.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
