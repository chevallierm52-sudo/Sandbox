I.u[7228] = {n:"Chapéu de Feudala",t:16,d:"De longe, usando este chapéu, você parece um Pandawushuka da vila de Feudala. De perto, você não se parece com nada.",ep:18,g:145,l:98,wd:true,fm:true,w:20,s:37,p:24800};
