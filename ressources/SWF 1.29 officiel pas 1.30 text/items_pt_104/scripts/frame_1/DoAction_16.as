I.u[7331] = {n:"Enorme Pedra da Alma",t:83,d:"Esta runa oferece uma chance de capturar almas extremamente difíceis...",ep:16,g:14,l:1,wd:false,fm:true,w:1,tw:true,p:10000};
I.u[7332] = {n:"Pequena Pedra da Alma Feliz",t:83,d:"Esta pedra lhe oferece uma boa chance de capturar pequenas almas.",ep:5,g:3,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7333] = {n:"Pedra da Alma Feliz Mediana",t:83,d:"Esta pedra lhe oferece uma boa chance de capturar almas bastante nobres...",ep:5,g:4,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7334] = {n:"Grande Pedra de Alma Feliz",t:83,d:"Esta runa lhe oferece uma boa chance de capturar almas particularmente selvagens...",ep:16,g:5,l:1,wd:false,fm:true,w:1,tw:true,p:10500};
I.u[7335] = {n:"Enorme Pedra da Alma Feliz",t:83,d:"Esta runa oferece uma boa chance de capturar almas extremamente difíceis...",ep:16,g:6,l:1,wd:false,fm:true,w:1,tw:true,p:15000};
I.u[7336] = {n:"Giga Pedra de Alma Perigosa",t:83,d:"Esta Runa lhe oferece uma pequena chance de capturar almas gigantes...",ep:16,g:11,l:1,wd:false,fm:true,w:1,tw:true,p:12500};
I.u[7337] = {n:"Giga Pedra de Alma",t:83,d:"Esta Runa lhe oferece uma chance média de capturar almas gigantes...",ep:16,g:15,l:1,wd:false,fm:true,w:1,tw:true,p:25000};
I.u[7338] = {n:"Giga Pedra de Alma Feliz",t:83,d:"Esta runa oferece uma boa chance de pegar almas fortes.",ep:16,g:7,l:1,wd:false,fm:true,w:1,tw:true,p:37500};
I.u[7339] = {n:"Chapeú de Kitsou",t:16,d:"Esta chapéu Kitsou só pode ser usado por aventureiros que perderam o olfato. Não nos pergunte o motivo...",ep:18,g:97,l:61,wd:true,fm:true,w:10,s:41,p:9875};
I.u[7340] = {n:"Capa de Kitsou",t:17,d:"Esta capa é lavável no rio, entretanto, ela pode descolorir após a terceira lavagem.",ep:18,g:84,l:62,wd:true,fm:true,w:10,s:41,p:10225};
I.u[7341] = {n:"Anel de Kitsou",t:9,d:"Este pequeno anel de Kitsou deve protegê-lo de suas preocupações diárias.",ep:1,g:93,l:55,wd:true,fm:true,w:10,s:41,p:8125};
I.u[7342] = {n:"Amuleto de Kitsou",t:1,d:"Este amuleto de Kitson atrairá a atenção para o seu queixo duplo.",ep:18,g:91,l:26,wd:true,fm:true,w:10,s:41,p:2000};
I.u[7343] = {n:"Pêlos de Leopardo",t:54,d:"Não importa o que todos pensam, estes pêlos são diferentes dos outros.",ep:18,g:205,l:50,wd:true,fm:true,w:5,p:1};
