I.u[7368] = {n:"Varinha Mágica Estelar",t:3,d:"O criador desta varinha queria que ela fosse capaz de destruir estrelas cadentes que o impediam de dormir à noite. A lenda diz que ele tentou usar esta varinha, após uma noite de bebedeira no bar e pensou que a lua fosse uma estrela cadente. A varinha sendo muito poderosa, partiu a lua ao meio e um dos pedaços caiu no Mar de Asse originando a Ilha da Lua como a conhecemos hoje. Aqui está outra história estúpida para dizer aos seus amigos nas noites de festa.",ep:19,g:55,l:126,wd:true,fm:true,w:15,an:11,e:[5,4,2,4,50,50,false,true],c:"CS>100&CV>150&CI>300",p:39355};
I.u[7369] = {n:"Âmbar de Bambuto",t:50,d:"Este âmbar normalmente está agarrado no topo do Bambuto. Seu uso principal é como jóia, mas ele também pode ser útil para machucá-lo, ainda mais quando o Bambuto decidir atacar você. Que criatura inteligente!",ep:18,g:2,l:40,wd:true,fm:true,w:2,p:100};
I.u[7370] = {n:"Âmbar de Bambuto Sagrado",t:50,d:"Este âmbar é a única riqueza do Bambu Sagrado. Bem provável, pois é tão amargo e destina-se a turistas que visitam a Ilha de Pandala.",ep:18,g:1,l:120,wd:true,fm:true,w:2,p:100};
I.u[7371] = {n:"A Era Dofus - Fragmentos Encontrados IV",t:25,d:"Volume IV dos fragmentos da História do Mundo, encontrado por Acidrik Gutspliter e reescrito pelo próprio.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7372] = {n:"Relógio Divino de Xelor – Parte VI",t:25,d:"A Parte VI dos fragmentos da História do Mundo foi encontrada pelo sábio Gutspliter de Acidrik e reescrito por ele mesmo.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
