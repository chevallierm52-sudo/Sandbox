I.u[7075] = {n:"Escudo de Bawbawian Explodido",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:2,l:1,wd:false,fm:true,w:15,c:"BI=non équipable",p:10500};
I.u[7076] = {n:"Derma Tho Decaído",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:3,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:2200};
I.u[7077] = {n:"Esponjaescudo",t:82,d:"Este escudo amarelo, poroso, porém absorvente, foi feito com os restos de uma criatura que costumava viver em uma Máscara de Abacaxi no fundo do mar.",ep:1,g:10,l:1,wd:true,fm:true,w:10,s:63,p:1};
