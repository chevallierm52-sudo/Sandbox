I.u[7437] = {n:"Runa Do Ren",t:78,d:"Esta runa reflete o dano liberado mais facilmente.",ep:1,g:17,l:20,wd:true,fm:true,w:1,p:10};
I.u[7438] = {n:"Runa Po",t:78,d:"Esta runa aumentará o alcance de seus ataques.",ep:1,g:18,l:20,wd:true,fm:true,w:1,p:10};
I.u[7439] = {n:"Recompensa da missão `SRVT:MERCENARY_SHORT_NAME`",t:14,d:"Este pergaminho certifica que você merece uma recompensa de honra para cada envolvimento em suas missões para `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"Ps=3&Pa>79",u:true,ut:true,p:1};
