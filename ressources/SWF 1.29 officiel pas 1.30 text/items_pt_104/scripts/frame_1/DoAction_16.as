I.u[7433] = {n:"Runa Cri",t:78,d:"Esta runa deixará seus ataques mais surpreendentes.",ep:1,g:14,l:20,wd:true,fm:true,w:1,p:10};
I.u[7434] = {n:"Runa So",t:78,d:"Esta runa aumentará sua habilidade de curar os outros.",ep:1,g:13,l:20,wd:true,fm:true,w:1,p:10};
I.u[7435] = {n:"Runa Do",t:78,d:"Esta runa aumentará o dano causado em seus inimigos.",ep:1,g:15,l:20,wd:true,fm:true,w:1,p:10};
