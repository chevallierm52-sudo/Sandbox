I.u[7097] = {n:"Escudo de Treinamento",t:82,d:"Este Escudo é dado aos discípulos que ainda não sabem como usar corretamente um Escudo.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[7098] = {n:"Martelo do Ferreiro de Escudo",t:7,d:"Nenhum escudo pode ser feito sem este martelo.",ep:18,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:500};
I.u[7101] = {n:"Manual de Ferreiro de Escudo",t:25,d:"Teste para aprender a profissão de Ferreiro de Escudo.",ep:0,g:8,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7102] = {n:"Espada do Cavaleiro de Gelo",t:6,d:"O Cavaleiro de Gelo era famoso por ter sido um dos maiores ferreiros de espada de toda Amakna. Abandonou o atemorizante e impiedoso Liche, que nunca reconheceu seu talento. Ofendido por esta criatura que nunca admirou suas criações, ele apresentou uma advertência. Parou de trabalhar antes que ela reconhecesse publicamente seu talento. Mas Liche não o fez. Porém, um longo tempo se passou e ele esqueceu como fazer boas espadas. Esta espada ridícula foi sua última criação útil.",ep:1,g:51,l:12,wd:true,fm:true,w:10,an:14,e:[5,6,1,1,40,60,false,false],p:575};
I.u[7103] = {n:"O Xyothine",t:3,d:"Esta Varinha Mágica foi usada para decapitar todos os caipiras de Amakna. Inútil dizer que ela tem sido muito usada. É muito interessante notar o quanto ela parece com um cajado ou até mesmo uma bengala... Poderia até ter sido usada para satisfazer as perversas fantasias de seu dono que finalmente deu a ela seu nome. Ninguém nunca saberá o final desta sórdida história.",ep:19,g:53,l:145,wd:true,fm:true,w:15,an:11,tw:true,e:[7,4,3,5,30,50,false,true],c:"CI>450&CV>200",p:10000};
I.u[7104] = {n:"Chinelos",t:11,d:"Estas sandálias de dedo foram usadas para praticar várias artes marciais. Não muito revolucionárias, mas, artisticamente falando, um fracasso, elas foram rapidamente esquecidas, um pouco como você, mas não tão rápido...",ep:18,g:58,l:67,wd:true,fm:true,w:5,p:11700};
I.u[7105] = {n:"Amuleto de Pandala",t:24,d:"Na primeira impressão, ele parece apenas um simples amuleto, mas, na verdade, ele guarda um segredo que apenas um Pandawa moribundo pode entender...",ep:18,g:48,l:0,wd:true,fm:true,w:0,p:1};
I.u[7106] = {n:"Larvamuleto",t:1,d:"Com esta cabeça de Larva em torno de seu pescoço, você vai parecer com Stive Irween, famoso domador de larva dos tempos modernos.",ep:5,g:88,l:26,wd:true,fm:true,w:5,s:33,p:1950};
I.u[7107] = {n:"Larvabotas",t:11,d:"Você provavelmente nunca sonhou em colocar seus pés nas tripas de uma Larva... Mas esta é a sua chance... Vai lá.",ep:1,g:53,l:33,wd:true,fm:true,w:10,s:33,p:3150};
I.u[7108] = {n:"Larvasacola",t:81,d:"Esta sacola costumava estar bem na moda, mas há muito tempo. É um ótimo exemplo do péssimo gosto dos ancestrais.",ep:5,g:60,l:27,wd:true,fm:true,w:10,s:33,p:2150};
I.u[7109] = {n:"Larvachapéu",t:16,d:"Você finalmente tem a chance de se parecer com uma verdadeira larva. Você será capaz de mostrar abertamente ao mundo seu estilo de vida larviano.",ep:5,g:103,l:34,wd:true,fm:true,w:10,s:33,p:3225};
I.u[7110] = {n:"Varinha Mágica Larvaresque",t:3,d:"Esta incrível varinha mágica é feita de tripas de larva que, após mortas, foram encantadas e reidratadas. É amorfa. Um pouco parecida com você, exceto pelo fato de você não ter sido encantado.",ep:5,g:19,l:40,wd:true,fm:true,w:5,an:11,e:[5,3,2,4,40,50,false,true],s:33,p:4000};
I.u[7112] = {n:"Dofus Pintado de Preto",t:23,d:"Você só pode conseguir tal ovo pelo acasalando de um dragão preto com um branco. Ou então, você foi enganado.",ep:1,g:8,l:6,wd:true,fm:true,w:1,p:50000};
I.u[7113] = {n:"Dofawa",t:23,d:"Este Dofus se parece estranhamente com um ovo de Dragossauro selvagem... pelo menos por uma vez, as aparências não são tão enganosas.",ep:1,g:9,l:6,wd:false,fm:true,w:1,p:10};
I.u[7114] = {n:"Dofus Ébano",t:23,d:"Tão escuro quanto pode ser a escuridão, tão sólido quanto uma rocha, o Dragão que pôs tal ovo provavelmente lembrou-se dele por muito tempo.",ep:1,g:7,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7115] = {n:"Dofus Marfim",t:23,d:"Dizem que esta pérola branca é sem igual. O mesmo não pode ser dito sobre o dente de Dragão Porco.",ep:1,g:11,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7116] = {n:"Anel de Merta",t:9,d:"O encantamento deste anel é muito estranho. Assim, após ser colocado no dedo, a única pessoa com quem você será capaz de falar será o joalheiro que o fez.",ep:18,g:91,l:59,wd:true,fm:true,w:5,p:9155};
I.u[7117] = {n:"Anel Ostarr",t:9,d:"Um bando de menestréis cosmopolitanos, decididos a usar este anel para reconhecer cada um dentro da multidão que veio ver a atração. No final, este anel não tem sido um sucesso por muito tempo. Algumas más línguas - ainda que com ouvidos musicais - dizem que eles tiveram o que mereceram.",ep:18,g:92,l:53,wd:true,fm:true,w:5,p:7150};
I.u[7118] = {n:"Anel Ugle",t:9,d:"Este anel grande no formato de uma mariposa não aumentará suas mãos;\r\n            não é uma coisa boa?",ep:18,g:94,l:90,wd:true,fm:true,w:5,p:20775};
I.u[7119] = {n:"Anél Nonsenz",t:9,d:"O joalheiro que criou esta obra-prima não tinha nenhuma relação com o famoso Ferreiro de Espada, apesar das aparências. Ninguém jamais entendeu o que o criador tentou explicar sobre o uso do seu anel.",ep:18,g:85,l:58,wd:true,fm:true,w:5,p:8750};
I.u[7120] = {n:"Anel de Noha",t:9,d:"Dizem que este anel pertenceu a um velho que salvou todas as criaturas da Ilha da Lua de uma terrível enchente, levando-as em sua balsa. Outra versão desse rumor é que ele comercializou a jangada por pequenos macacos em vez de salvar todas as criaturas da ilha.",ep:18,g:86,l:44,wd:true,fm:true,w:2,p:5350};
I.u[7121] = {n:"Anel Nozokomial",t:9,d:"Este anel animado tem uma terrível maldição capaz de fazer o mais resistente dos aventureiros ficar doente. Alguns dizem que ele foi originalmente projetado para curar a pessoa que o usaria em seu dedo indicador. Mas ele se tornou cada vez mais perigoso e agressivo à medida que se encontrou em lugares infames contra a sua vontade.",ep:18,g:87,l:50,wd:true,fm:true,w:5,p:6655};
I.u[7122] = {n:"Anel de Novato",t:9,d:"Este Anel é feito para novatos. Ele também é o que melhor simboliza algumas tradições impublicáveis. Parece feito para você sob medida. Perfeito.",ep:16,g:88,l:18,wd:true,fm:true,w:2,p:1100};
I.u[7123] = {n:"Anel Obscuro",t:9,d:"Apenas para aventureiros informados. Realmente, este anel poderia chocar a sua família e os amigos, se forem jovens e inocentes criaturas.",ep:18,g:95,l:70,wd:true,fm:true,w:2,p:12900};
I.u[7124] = {n:"Dofus ao Leite",t:42,d:"Este ovo de Dofus tem um poder excepcional. Ele pode fazer você babar como se fosse um brinquedo.",ep:1,g:27,l:1,wd:false,fm:true,w:1,p:1};
I.u[7125] = {n:"Dofus ao chocolate branco",t:42,d:"Este ovo de Dofus tem um poder excepcional. Para babar de alegria.",ep:1,g:28,l:1,wd:false,fm:true,w:1,p:1};
I.u[7126] = {n:"Mini Ovos de Dofus",t:42,d:"Vermelho, verde ou mesmo azul, estes pequenos ovos não tem gosto de nada. Apenas prove-os para não morrer ignorante.",ep:0,g:29,l:1,wd:false,fm:true,w:1,p:1};
I.u[7127] = {n:"Concha de Dofus",t:42,d:"...",ep:1,g:30,l:1,wd:false,fm:true,w:1,p:1};
I.u[7128] = {n:"OkaRinga",t:9,d:"Diferentemente do que alguns pensam, este anel não tem nada a ver com a bela Karina que muitas vezes fez exóticos shows sensuais no Bar dos Piratas de Sufokia. Na realidade, foi um músico que cria Tofus que deu este nome ao anel, já que se usado em seu polegar, ele pode emitir um som parecido com o de um Tofu agonizante.",ep:18,g:89,l:54,wd:true,fm:true,w:5,p:7700};
I.u[7129] = {n:"Chocolate Panda",t:42,d:"Não se engane... Não só deixa o chocolate com um gosto bom, mas a forma doce traz mais sabor também. Compare-o com um chocolate Ouassingue e você entenderá melhor.",ep:0,g:31,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[7130] = {n:"Receita de Dofus em Chocolate",t:24,d:"A receita do Dofus em chocolate é uma obrigação se quer impressionar seus amigos.",ep:1,g:250,l:1,wd:false,fm:true,w:0,p:100};
I.u[7131] = {n:"Anel Opiom",t:9,d:"Muitos outros aventureiros sonhavam em conseguir esta jóia bem antes de você o fazer. Realmente, dizem que ela tem muitas virtudes, como transformar guerreiros em sonhadores. As instruções mencionam claramente que é aconselhado queimá-la. Mas não especifica o porquê...",ep:16,g:90,l:57,wd:true,fm:true,w:5,p:8475};
I.u[7132] = {n:"O\' Anel Ami",t:9,d:"Este anel deve seu nome às últimas palavras pronunciadas por seu criador: ‘O\' Anel Ami! Você é tão meu amigo!\' Ele disse em um chocalho tão doloroso, mas incrível. É interessante notar que este anel feito de Bambu, foi, na verdade, feito antes de o Bambu aparecer. Outro mistério que não será resolvido por outra década, pelo menos!",ep:16,g:96,l:49,wd:true,fm:true,w:5,p:6300};
I.u[7133] = {n:"Mixomawose",t:30,d:"Qualquer Wabbit lhe dirá que, se você não quiser ver tudo vermelho, evite a Mixomawose como você evitaria a praga.",ep:1,g:9,l:1,wd:false,fm:true,w:0,p:1};
I.u[7134] = {n:"Rabies",t:30,d:"Alguns dizem que os Rabies mudam completamente a existência afetada. Guerreiros se tornam dóceis, pessoas calmas se tornam agressivas. Entretanto, pessoas que babam continuarão iguais.",ep:1,g:10,l:1,wd:false,fm:true,w:0,p:1};
I.u[7135] = {n:"Maloria",t:30,d:"Uma doença transmitida por Moskitos de regiões tropicais. Alguns indígenas a chamam de Maloria, pois a doença pode ser transmitida pela saliva de Moskitos também.",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[7136] = {n:"Medalha AyKido",t:1,d:"Esta medalha costumava pertencer a um famoso Pandawa, mestre de uma antiga escola de arte marcial, que ensinou a seus discípulos os princípios de defesa usando a força de seus oponentes. Sua escola finalmente fechou porque seus oponentes não eram mais fortes o suficiente.",ep:19,g:89,l:125,wd:true,fm:true,w:10,p:40425};
I.u[7137] = {n:"Capa Huccino",t:17,d:"Esta Capa foi costurada à mão por uma única razão: criar uma capa capaz de manter o seu portador acordado por muitos dias em uma fila. O resultado está aqui. A Capa é tão rígida que o manterá em pé, não importa as circunstâncias. Mas, tenha cuidado, pois você não poderá mais amarrar seus sapatos.",ep:16,g:15,l:44,wd:true,fm:true,w:15,p:5300};
I.u[7138] = {n:"Urtigaz",t:17,d:"Usado pelas pessoas mais importantes deste mundo, este manto é famoso por sua maciez lendária, graças à qual você não precisa vestir quaisquer roupas íntimas durante as estações quentes. Uma maneira elegante de se expor...",ep:19,g:91,l:125,wd:true,fm:true,w:15,p:40175};
I.u[7139] = {n:"Cinto de Sula",t:10,d:"A sapateira adorava passear nos campos, procurando um amor improvável. Em vez de achar a sua alma gêmea, ela morreu caindo em um enorme fosso cheio de lixo, perto da Zona dos Porcos. Seu corpo foi encontrado 70 anos mais tarde, quando eles, finalmente, esvaziaram o fosso. Seu irmão aparentemente disse: “Eu sabia que ela tinha ido a algum lugar”, um pouco antes de ele também cair no mesmo fosso.",ep:19,g:82,l:125,wd:true,fm:true,w:15,p:39975};
I.u[7140] = {n:"Xenature",t:10,d:"Ao contrário do que parecia, Xenature não era um guerreiro, mas sim um sapateiro. Sua figura generosa e sua imensa paixão pelo trabalho doméstico eram tamanhas que se previa brilhante carreira nas fábricas de energético de Amakna. Mas o destino já estava tomado.",ep:19,g:83,l:125,wd:true,fm:true,w:15,p:40125};
I.u[7141] = {n:"Holoone",t:16,d:"Este estranho chapéu o protegerá da radiação solar, mesmo à noite. Tenha cuidado, a cada trinta anos ele volta à vida e tenta sufocar seu possuidor durante o sono.",ep:19,g:111,l:122,wd:true,fm:true,w:10,p:37925};
I.u[7142] = {n:"Peruka",t:16,d:"Este chapéu foi usado por algum Xelors que escondeu sua calvície. Algum Enutrofs usou para se esconder da sua esposa. Uma maneira prática para esconder dois problemas do cotidiano.",ep:19,g:112,l:145,wd:true,fm:true,w:15,p:46980};
I.u[7143] = {n:"Solomonk",t:16,d:"O Solomonk era o chapéu que o velho Chefe da tribo Pandawa, perito em poções laxantes, costumava usar. Pandawas em questão eram muitas vezes forçados a testarem em si mesmos os efeitos de suas poções. Eles usavam este tipo de chapéu que eram pelo menos bons substitutos para penicos.",ep:19,g:123,l:120,wd:true,fm:true,w:50,p:36880};
I.u[7144] = {n:"Palishat",t:16,d:"Este chapéu de noiva está bem fora de moda provavelmente porque seu estilo é de outra época. Reciclado em Ceroulas e usado em uma cabeça cabeluda, ele ainda pode fazer o mais blasé dos Chafers entrar em transe.",ep:19,g:116,l:108,wd:true,fm:true,w:15,p:29775};
I.u[7145] = {n:"Chapéu do Gaddie",t:16,d:"Gaddie, uma estranha criatura de um mundo imaginário, sempre se sobressaiu por sua incrível astúcia, por sua total aversão ao reino vegetal e por sua habilidade de jejuar por vários dias em tempos de guerra. Uma criatura tão complexa de entender era, obviamente, impossível de ser controlada. Ela foi largada sozinha nas profundidades das Minas de Kruup, onde ela conheceu um velho Liche, um devorador de Gobbly.",ep:19,g:115,l:106,wd:true,fm:true,w:15,p:26375};
I.u[7146] = {n:"Lullabye",t:16,d:"Este chapéu superpoderoso se parece com uma peruca, mas ainda é superpoderoso. Assim, o usuário adora colocá-lo e pretende levar vantagem de outras pessoas ingênuas. Seus jogos sujos foram revelados, assim como seu crânio uma vez que o chapéu é tirado. Seu grande talento como artista salvou sua vida já que ele sugeriu que poderia esculpir uma estátua gigante das partes íntimas de MooLobo, alguns dias antes de ser executado. Ele foi queimado vivo uma vez que a estátua fora terminada.",ep:18,g:114,l:81,wd:true,fm:true,w:10,p:16925};
I.u[7147] = {n:"Um Quadrinho de Choclate de Leite",t:42,d:"...",ep:0,g:32,l:1,wd:true,fm:true,w:1,p:1};
I.u[7148] = {n:"Um Quadrado de Chocolate Branco",t:42,d:"...",ep:1,g:33,l:1,wd:false,fm:true,w:1,p:1};
I.u[7149] = {n:"Pedaço de Chocolate Preto",t:42,d:"Extraído diretamente dos grãos de cacau, este pedaço de chocolate preto é muito saboroso. Tenha cuidado para não comer muito ou terá problemas digestivos.",ep:1,g:34,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:200};
I.u[7150] = {n:"Krutch",t:16,d:"Este chapéu, de nome estranho, pertenceu a um pobre Ecaflip que ficou mudo após um evento traumático. O artista foi compelido a seguir o treinamento de fermentador. Quando completou 14 anos, foi afogado em um barril de energético e lágrimas. Felizmente, o energético não foi desperdiçado, pois o padre que estava encarregado do funeral entrou em coma energético por muitos anos antes que ele pudesse parar.",ep:19,g:109,l:111,wd:true,fm:true,w:20,p:31725};
I.u[7151] = {n:"Gigante",t:16,d:"O anúncio deste capacete dizia: ‘Este grosseiro capacete de barro lhe transformará em um gigante com uma cabeça de barro‘. Mas um estudo aprofundado do objeto fará você perceber que o capacete não é de barro, mas de chumbo. Isto com certeza lhe dará um pouco de noção.",ep:19,g:108,l:120,wd:true,fm:true,w:15,p:36925};
I.u[7152] = {n:"Kanistere",t:16,d:"Este chapéu simples foi usado pelo bombeiro de Amakna nos campos de cereais em chamas. Atualmente, ele é muito usado por fermentadores e garçonetes que servem bebidas aos fregueses.",ep:19,g:110,l:120,wd:true,fm:true,w:20,p:36675};
I.u[7153] = {n:"Martelo de Hubohu",t:7,d:"Este enorme martelo faz um barulho muito alto quando bate em um crânio de Iop, porque ele tende a ampliar as ressonâncias. Tão surpreendente quanto eficiente.",ep:19,g:51,l:126,wd:true,fm:true,w:15,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>200",p:40200};
I.u[7154] = {n:"Martelo de Brinquedo",t:7,d:"Este leve martelo é projetado para seres pequenos. Xelors usaram a haste, e as Aracnes receberam a maceta na cabeça. Seu uso mudou rapidamente e se tornou um pequeno brinquedo para jovens Iops faz-tudo.",ep:18,g:46,l:107,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>350&CV>200&CW>100",p:29475};
I.u[7155] = {n:"Martelo Ingthaiphoons",t:7,d:"O famoso Capitão Adock usou por 10 mil anos este terrível martelo para matar qualquer um que cruzasse seu caminho – inclusive mulheres e crianças. Além de seu lendário temperamento ruim e o excesso de energético, ele é muito respeitado pelos diferentes corpos do exército, inimigos e aliados.",ep:18,g:48,l:113,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,40,60,false,false],c:"CI>150&CW>100&PG=5",p:32650};
I.u[7156] = {n:"Martelo Ican",t:7,d:"Este martelo enferrujado é perfeito para esmagar árvores de bordo ou mesmo Moskitos.",ep:18,g:50,l:107,wd:true,fm:true,w:20,an:15,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>150&CV>150&(PG=2|PG=5)",p:334251};
I.u[7157] = {n:"Martelo de Toksin",t:7,d:"Este martelo foi usado para soar o sino da Igreja de Amakna. Hoje em dia, ele ainda é usado para fazer música, mas agora, está moendo os ossos dos imprudentes, por exemplo.",ep:19,g:49,l:124,wd:true,fm:true,w:15,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CI>250",p:29400};
I.u[7158] = {n:"Martelo de Luhene",t:7,d:"Este martelo foi feito por um famoso alquimista durante sua estada na prisão de Brakmar. Foi inicialmente feito para destruir o equipamento de alquimia de seus competidores.",ep:19,g:47,l:143,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CA>250&PG=5",p:46550};
I.u[7159] = {n:"Martelo da Colina",t:7,d:"Este martelo de mineiro pode ser usado como uma pá ou uma picareta de acordo com a necessidade. Seu uso para a jardinagem é proibido, pois tende a destruir todo o gramado.",ep:19,g:52,l:135,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>300",p:41200};
I.u[7160] = {n:"Arco Doozi",t:2,d:"Este Arco foi encantado há muito tempo por uma das magias mais negras. Algo para preocupar tanto seu proprietário quanto seus inimigos.",ep:19,g:44,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CI>400&PG=9",p:36900};
I.u[7161] = {n:"Arco Selvagem",t:2,d:"Este arco foi principalmente usado para caçar Javalis. De fato, ele é tão poderoso que pode matar muitos javalizinhos com uma única flecha, ficando todos alinhados.",ep:18,g:45,l:107,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CI>250&CA>150",p:29325};
I.u[7162] = {n:"Arco Musical",t:2,d:"Este arco pertenceu a um grupo independente de Menestréis, especialmente conhecidos por seu grito de guerra destruindo os ouvidos dos inimigos. O grupo foi banido de Pandala por vários anos, já que suas músicas podiam fazer um Corvo de Brakmar ficar surdo. Após deixarem gerações de Pandawa malucas, eles foram levados ao Grande Sorlok para serem lentamente digeridos por mais de 752 anos.",ep:19,g:46,l:130,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,3,6,30,50,false,true],c:"CA>200&CC>70&PG=9",p:30000};
I.u[7163] = {n:"Arco Fugitivo",t:2,d:"Este arco foi usado como uma arma dissuasiva. Assim, o usuário do Arco Fugitivo explicou que estava usando flechas envenenadas e amedrontava a população local. O arco é feito de todos os covardes que ele encontrou em fuga.",ep:19,g:47,l:124,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"PG=9&CA>250",p:39050};
I.u[7164] = {n:"Arco Angelical",t:2,d:"Leve e frágil, este arco seduziu numerosos aventureiros que davam mais importância à aparência do que à eficiência.",ep:19,g:48,l:143,wd:true,fm:true,w:15,an:10,e:[5,5,2,6,30,50,false,true],c:"CA>120&CI>120&CC>120&CV>300",p:46025};
I.u[7165] = {n:"Varinha Mágica Jaro Kilih",t:3,d:"Esta varinha explosiva esteve mergulhada na lava de um vulcão em erupção antes de ser esculpida, e então, encantada. É inútil mencionar que esta é uma varinha muito poderosa, apesar de sua aparência ridícula.",ep:18,g:54,l:105,wd:true,fm:true,w:15,an:11,e:[5,4,3,6,50,50,false,true],c:"CI>300",p:28625};
I.u[7167] = {n:"Varinha Anelar",t:3,d:"O artesão que criou esta varinha teve muitos aprendizes. Ele os fez trabalhar o dia todo. Supostamente ensinou-lhes os truques do negócio, mas ele não era um bom professor. Ele começa alguma explicação, mas nunca termina.",ep:18,g:50,l:43,wd:true,fm:true,w:5,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>60",p:5000};
I.u[7168] = {n:"Varinha Mágica Pintada",t:3,d:"Quando feita, esta varinha foi mergulhada em energético por diversos anos. Ela começou a apodrecer, mas ainda tem atributos mágicos o suficiente para distrair ou exterminar os seus aliados.",ep:18,g:51,l:63,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150",p:4800};
I.u[7169] = {n:"Varinha Mágica Fagulhante",t:3,d:"Ideal para acender um fogo, ou para alegrar casamentos tediosos. Com esta varinha, você terá a chance de brilhar pelo menos uma vez em sua vida. Uma oportunidade para não ser perdida.",ep:18,g:52,l:81,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>200",p:17000};
I.u[7170] = {n:"Varinha Mágica de Creizy-Stufh",t:3,d:"Creizy, o doceiro era tão louco, que casou-se com a lenhadora Stufh e no dia seguinte, a sufocou até a morte com suas massas gordurosas. Desde então, freqüentemente usamos o termo \"Creizy Stufh\" para falar sobre as coisas mais surpreendentes.",ep:18,g:46,l:112,wd:true,fm:true,w:15,an:11,tw:true,e:[5,2,3,4,30,50,false,true],c:"CI>350&CV>200",p:32330};
I.u[7171] = {n:"Varinha Heroff",t:3,d:"O desenhista desta varinha esqueceu-se de pegar os seus filhos na escola. A esposa, que era mãe de muitos outros filhos, ficou encantada. Sabendo que era distraído, esculpiu esta varinha para lembrar-se de pegar seus filhos na escola. Depois, tentou criar varinhas semelhantes para lembrar a sua esposa fazer o trabalho doméstico, mas a varinha não surtiu efeito suficiente para conseguir tal façanha.",ep:19,g:47,l:127,wd:true,fm:true,w:15,an:11,tw:true,e:[10,4,4,6,40,60,false,true],c:"CI>300&CV>300",p:43125};
I.u[7172] = {n:"Varinha Mágica de Boogey",t:3,d:"Esta varinha mágica ainda é usada hoje em dia para esvaziar fossas sépticas, limpar fossos e até o nariz de alguém. A maioria dos desenhistas informados lhe explicará que elas puxam toda a magia dos lixos que elas vêem, mas principalmente o de seu nariz.",ep:18,g:49,l:105,wd:true,fm:true,w:20,an:11,tw:true,e:[10,4,2,4,30,60,false,true],c:"CI>200&CW>50",p:28375};
I.u[7173] = {n:"Varinha Mágica Estranha",t:3,d:"Esta incrível varinha pode se enrolar no pescoço de seus oponentes e estrangulá-los lentamente. Uma forma original de matar inimigos que você não respeita.",ep:18,g:48,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,4,50,50,false,true],c:"CI>50",p:2100};
I.u[7174] = {n:"Capa de Pandawushu",t:17,d:"Esta capa é essencial, se você quiser praticar Pandawushu...",ep:1,g:89,l:10,wd:true,fm:true,w:5,p:10};
I.u[7175] = {n:"Certificado de Xamã",t:24,d:"Certificado médico essencial, se você quer praticar Pandawushuka.",ep:18,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[7176] = {n:"Raiz do Bem",t:4,d:"Maxx Evanz, escultor de cajado, é que criou esta pequena maravilha capaz de escurecer o céu e derramar o sangue dos inimigos mesmo que eles não tenham. A lenda diz que ele levou milhares de horas para esculpi-lo. Mesmo seus inimigos não ficarão indiferentes diante deste cajado.",ep:19,g:53,l:143,wd:true,fm:true,w:15,an:12,e:[10,4,1,1,45,70,false,false],c:"CS>150&CV>400&CI>50&CA>50",p:46600};
I.u[7177] = {n:"Bandana Pandawushu",t:16,d:"Com essa bandana Pandawushu em volta do seu crânio, você poderá assustar jovens Lenalds fingindo ser um Mestre das artes marciais. Não esqueça de usar algum grito de guerra para ser mais convincente.",ep:1,g:102,l:1,wd:false,fm:true,w:5,p:10};
I.u[7178] = {n:"Raiz Mágica",t:4,d:"Depois de gerações, os Sadidas têm usado raízes mágicas como cajados. Entretanto, parece que alguns deles ainda se negam a usá-las, preferem os que estiverem mais próximos da fruta do que de uma raiz. Fruta ou raiz, não importa, machuca e isso que é relevante.",ep:18,g:58,l:86,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,50,50,false,false],c:"CI>150",p:19100};
I.u[7179] = {n:"Rota: Floresta Amaldiçoada",t:25,d:"Este livro contém o melhor itinerário turístico do labirinto da Floresta Amaldiçoada! Pelo menos é isso o que diz na capa.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7180] = {n:"Mutação Temporária de Geléia",t:27,d:"...",ep:1,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7181] = {n:"Raiz Vermelha Chileepaperz",t:4,d:"Red foi uma jovem Sadidette. Ela amava cantar, embora fosse péssima nisso. Queria viajar o mundo incluindo Chili. Ela sempre tentava, mas nunca conseguia ir para lugar algum.",ep:18,g:54,l:106,wd:true,fm:true,w:15,an:12,tw:true,e:[10,4,1,1,50,50,false,false],c:"CV>250&CW>60",p:28575};
I.u[7182] = {n:"Raiz Escura de Mel",t:4,d:"Mel era bastante azarada. Seu marido era um grosseirão preguiçoso, incapaz de assumir sua posição de líder da família. Ela era forçada a fazer chantagem emocional, desta forma, ele faria algo. Por exemplo ‘Você terá sua geléia de morango se você colher os cereais\' ou ‘Você poderá descansar quando você tosquiar os Gobballs\', e assim por diante. Obviamente, esta história não tem nada a ver com esta raiz muito poderosa, a menos que ela comece a chantagear você também...",ep:18,g:60,l:103,wd:true,fm:true,w:15,an:12,tw:true,e:[15,4,1,1,25,50,false,false],c:"CV>200",p:27280};
I.u[7183] = {n:"Raiz Dama",t:4,d:"Esta raiz tem formas puras que alguns artesãos qualificaram como perfeitas. ",ep:18,g:55,l:88,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>70",p:20000};
I.u[7184] = {n:"Raiz de Desastre",t:4,d:"Esta terrível raiz é conhecida principalmente por sua capacidade de provocar desastres climáticos no lugar exato onde ela é usada. Evite usá-la para chutar os traseiros de seus inimigos... nunca sabemos o que pode acontecer.",ep:18,g:56,l:86,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>100",p:18945};
I.u[7185] = {n:"Raiz Hécure",t:4,d:"Usar esta raiz durante uma luta facilita bastante. Todavia, pode acontecer de a raiz reviver e fazer o que quiser... Geralmente, quando o dono grita ‘Esta não é uma Raiz Hécure comum, não é?\' De fato, é comum sim.",ep:18,g:57,l:103,wd:true,fm:true,w:20,an:12,e:[5,5,1,1,50,50,false,false],c:"CV>200&CW>150",p:27425};
I.u[7186] = {n:"Passagem de Nível",t:24,d:"Neste pedaço de papel, você pode ler a última vez que cruzou a passagem de nível Pandawashuka.",ep:18,g:58,l:0,wd:true,fm:true,w:0,p:1};
I.u[7187] = {n:"George Bowsh",t:2,d:"Este arco é conhecido por roubar, discretamente, o dinheiro de pessoas que estão longe. A coisa mais surpreendente é que ele permaneceu popular mesmo com o passar do tempo. Felizmente, para as pessoas, ele está começando a ficar desgastado.",ep:19,g:50,l:124,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,4,6,30,2,false,true],c:"CA>100&CC>100&PG=9",p:40000};
I.u[7188] = {n:"Adagas de Citrus",t:5,d:"Estas adagas são perfeitas para cortar frutas cítricas em pedaços, ou cortar a grama debaixo dos pés de seus inimigos. Um modo original de surpreendê-los.",ep:18,g:48,l:113,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,35,50,false,false],c:"CA>100&CI>100",p:32575};
I.u[7189] = {n:"Rod Gerse",t:4,d:"Este cajado estranho é uma versão melhorada da Vara Deus. Assim, ele foi desenvolvido de acordo com vários testes na Vara Deus pela Sacerdotisa do Amor. Este modelo foi até mesmo usado pelo próprio Kuri, fazendo dele uma peça única.",ep:19,g:59,l:176,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,100,false,false],c:"CI>450",p:57000};
I.u[7190] = {n:"Adagas Maydhyn China",t:5,d:"Estas adagas magníficas foram feitas por encomenda para uma Sramette que precisa de fortes emoções. Assim, como ficou desapontada por não encontrar adagas que a satisfizessem, ela desafiou todos os ferreiros de adaga de Amakna: o primeiro que forjasse suas adagas capazes de matar qualquer Tofu com um único golpe, poderia passar três noites com ela. Infelizmente, nenhum ferreiro se interessou. Ela teve de esperar uma centena de anos para um Enutrof aposentado se interessar pela recompensa, embora tenha mudado de idéia com o passar do tempo...",ep:18,g:45,l:100,wd:true,fm:true,w:10,an:13,tw:true,e:[15,3,1,1,35,50,false,false],c:"CS>150&CA>150",p:21800};
I.u[7191] = {n:"Montador de Ramougre",t:5,d:"Ramougre era um velho Sram que se tornou um mestre na confecção de bijuterias. Ele costumava usar este montador para suas criações assim como para infiltrar seus próprios clientes quando estava entediado. Ele era conhecido pelo seu temperamento ruim que às vezes o levava a destruir seu montado e suas belas criações. Hoje, os usuários destas adagas sabem como retribuir usando-as para matar a família de joalheiros.",ep:19,g:49,l:127,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,30,false,false],c:"CA>200&CS>200",p:40825};
I.u[7192] = {n:"Garra de Grizmine",t:6,d:"Grizmine nunca conseguiu usar direito esta Garra. Pois ele jogava cartas e apostava nos jogos enquanto bebia energético, assim seus músculos rapidamente se contraíram. Aparentemente, este tipo de atividade pode mesmo encolher outros órgãos.",ep:18,g:59,l:111,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>300&CA>120",p:31625};
I.u[7193] = {n:"Espada de Dark Vlad",t:6,d:"Ninguém, exceto o próprio Vlad das Sombras, pode fazer uso completo da magia desta espada. Se você carregá-la por aí, você orgulhosamente mostrará que não acabou como um daqueles aventureiros ridículos que morreram sob esta lâmina.",ep:19,g:61,l:126,wd:true,fm:true,w:20,an:14,e:[12,5,1,1,50,100,false,false],c:"CV>250&CI>300&PG=8",p:40625};
I.u[7194] = {n:"Arco de Arkanum",t:2,d:"Este arco prova que a associação entre tecnologia e mágica pode dar excelentes resultados. Entretanto, este arco foi rapidamente esquecido por razões obscuras. Arkanum, o artesão que criou este arco, teve de fechar a sua loja, o que entristeceu a maior parte de seus fiéis clientes.",ep:18,g:49,l:96,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"CI>200&CA>60&PG=9",p:23500};
I.u[7195] = {n:"Karnak",t:6,d:"Esta lendária espada foi forjada de manhã por um soldado Enutrof eufórico, nas profundezas das minas de Grimoth. Ela tem uma aura muito poderosa, assim como um cheiro de energético.",ep:19,g:60,l:158,wd:true,fm:true,w:15,an:14,tw:true,e:[10,5,1,1,50,80,false,false],c:"CV>300&CA>300&PG=8",p:51100};
I.u[7196] = {n:"Escudo Pandawushuka",t:82,d:"O próprio Mestre Pandawushuka ofereceu a você este escudo para cores da escola de artes marciais. É o símbolo da conclusão de treinamento com honra.",ep:0,g:34,l:1,wd:true,fm:true,w:1,p:1};
I.u[7197] = {n:"Martelo Sheys",t:7,d:"Este martelo foi usado para quebrar barras de chocolate e deixá-las em pó. Com o passar dos anos, ele ganhou um cheiro e gosto deliciosos. Um outro motivo para fazer seus inimigos provarem-no!",ep:19,g:53,l:150,wd:true,fm:true,w:100,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CI>150&CV>200&(PG=5|PG=2)",p:473751};
I.u[7198] = {n:"Navalha Noturna",t:6,d:"Qualquer velho Enutrof lhe dirá que uma bela barba é uma bem cuidada. Sua lâmina é tão finamente formada que até se adaptaria a mulheres muito cabeludas.",ep:18,g:62,l:106,wd:true,fm:true,w:15,an:14,e:[10,4,1,1,50,50,false,false],c:"CS>200&CA>100",p:28925};
I.u[7199] = {n:"Espada de Metzger",t:6,d:"Esta espada pertenceu a um açougueiro chamado Metzger que a usou para estripar seus inimigos e fazer salsicha com a carne deles. Depois, ele ia aos mercados de Bonta para vendê-la a um preço bem baixo.",ep:19,g:63,l:135,wd:true,fm:true,w:15,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>200&CA>120&CV>300",p:44225};
I.u[7200] = {n:"Sabre Shodanwa",t:6,d:"Este sabre magnífico é usado por discípulos Pandawushuka quando eles alcançam o nível Shodanwa vivos (isto é, sem morrer entre os níveis).",ep:18,g:55,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>60",p:4300};
I.u[7201] = {n:"Sabre Nidanwa",t:6,d:"Este magnífico Sabre é usado pelos discípulos de Pandawushuka quando eles alcançam o grau Nidanwa vivos (isto é, sem morrer entre os graus).",ep:18,g:56,l:66,wd:true,fm:true,w:15,an:14,e:[10,5,1,1,50,50,false,false],c:"CA>80",p:11300};
I.u[7202] = {n:"Sabre Sandanwa",t:6,d:"Este magnífico sabre é usado pelos discípulos Pandawushuka quando eles alcançam o nível Sandanwa vivos (isto é, sem morrer entre os níveis).",ep:18,g:57,l:83,wd:true,fm:true,w:10,an:14,e:[10,5,1,1,50,50,false,false],c:"CS>120",p:17800};
I.u[7203] = {n:"Sabre Yondanwa",t:6,d:"Este magnífico sabre é usado por discípulos de Pandawushuka quando alcançam o nível de Yondanwa vivo (isso sem se machucar nos outros níveis).",ep:18,g:58,l:93,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,50,50,false,false],c:"CA>100",p:22175};
I.u[7204] = {n:"Cajado de Shodanwa",t:4,d:"Este cajado é usado pelos discípulos Pandawushuka quando alcançam o nível Shodanwa, sem perder o uso dos braços entre os níveis.",ep:18,g:49,l:46,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,false],c:"CV>30&CW>10",p:5775};
I.u[7205] = {n:"Cajado de Nidanwa",t:4,d:"Normalmente, este Cajado é usado por discípulos de Pandawushuka, quando alcançam o grau Nidanwa sem perder a utilidade dos braços entre os graus.",ep:18,g:50,l:62,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>100",p:10125};
I.u[7206] = {n:"Cajado de Sandanwa",t:4,d:"Normalmente, este cajado é usado pelos discípulos Pandawushuka, quando alcançam o nível Sandanwa vivos (isto é, sem morrer entre os níveis).",ep:18,g:51,l:80,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,30,50,false,false],c:"CA>100&CV>70",p:16700};
I.u[7207] = {n:"Cajado Yondanwa",t:4,d:"Este cajado normalmente é usado por discípulos de Pandawushuka, quando alcançam o nível de Yondanwa, sem perder um dos braços entre os níveis.",ep:18,g:52,l:93,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>250",p:22500};
I.u[7208] = {n:"Machado de Shodanwa",t:19,d:"Este machado é usado pelos discípulos Pandawushuka quando eles alcançam o nível Shodanwa. É muito conveniente para devastar Florestas de Bambu bem como qualquer coisa que possa se esconder lá.",ep:18,g:37,l:36,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:3550};
I.u[7209] = {n:"Machado de Nidanwa",t:19,d:"Este Machado é usado pelos discípulos de Pandawushuka quando eles alcançam o grau Nidanwa. É muito conveniente para devastar Florestas de Bambu assim como qualquer coisa que possa estar escondida lá.",ep:18,g:36,l:59,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],c:"CS>100&CV>50",p:9000};
I.u[7210] = {n:"Machado de Sandanwa",t:19,d:"Este Machado é usado pelos discípulos de Pandawushuka quando eles alcançam o grau Nidanwa. É muito conveniente para devastar Florestas de Bambu assim como qualquer coisa que possa estar escondida lá.",ep:18,g:35,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:17800};
I.u[7211] = {n:"Machado Yondanwa",t:19,d:"Este machado é usado pelos discípulos de Pandawushuka quando alcançam o nível de Yondanwa. É muito bom para devastar as Florestas de Bambu e também para esconder.",ep:18,g:34,l:98,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,50,50,false,false],c:"CI>150&CS>75&CV>85",p:24500};
I.u[7212] = {n:"Assassino de Bambu",t:19,d:"Equipado com este leve e elegante Machado, você poderá progredir facilmente pelas Florestas de Bambu de Pandala. Você poderá se proteger eficientemente dos mais traiçoeiros Pandis, sempre prontos para atacar lenhadores solitários por obscuras histórias de sacolas...",ep:18,g:33,l:26,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:2000};
I.u[7213] = {n:"Pá Penetrante",t:8,d:"Esta Pá deve rachar através do ar em uma incrível velocidade. Aqueles que sabem como manuseá-la geralmente partem os crânios de seus inimigos.",ep:19,g:7,l:142,wd:true,fm:true,w:15,an:16,tw:true,e:[10,5,1,1,40,70,false,false],c:"CC>400&CV>250",p:46050};
I.u[7214] = {n:"Sandálias Macian",t:11,d:"Estas sandálias pertenceram aos Macians, uma tribo de Ouginak, que entrou em extinção. Ela era bastante próxima dos Pandawas. Gerações se passaram, e esta amizade próxima mudou a cor da pele – branca com pintas pretas. Todos eles foram mortos por uma mulher horrível que queria fazer um casaco com as peles.",ep:18,g:59,l:30,wd:true,fm:true,w:10,p:2650};
I.u[7215] = {n:"Sandálias Provocantes",t:11,d:"Estas sandálias eram usadas por algumas Pandits para seduzir aventureiros perdidos e, assim, atraí-los para armadilhas.",ep:19,g:60,l:121,wd:true,fm:true,w:20,p:37400};
I.u[7216] = {n:"Sandálias Koholiks",t:11,d:"Estas sandálias foram dadas a Pandawas doentes que precisavam correr bem depressa quando eram contaminados por vírus Pandrista ou quando bebiam demais nas noitadas da taverna.",ep:18,g:61,l:58,wd:true,fm:true,w:10,p:8975};
I.u[7217] = {n:"Sandálias Firmes",t:11,d:"Pandawas sempre foram atraídos por bebidas energéticas. Com o passar do tempo, eles aprenderam como conservar melhor e aprimorar o sabor. Em relação a estas sandálias, elas foram especialmente feitas para Pandawas eufóricos. Há cascalho nas solas para manter seus pés no chão por mais tempo.",ep:19,g:62,l:159,wd:true,fm:true,w:50,p:50800};
I.u[7218] = {n:"Sandálias Adin",t:11,d:"Adin era um jovem Pandawa que amava colecionar lâmpadas, mas ele estava longe de ser um gênio.",ep:18,g:63,l:76,wd:true,fm:true,w:15,p:14900};
I.u[7219] = {n:"Sandálias Ailuya",t:11,d:"Estas sandálias eram confiadas a Pandits no fim dos rituais religiosos. Atualmente, elas são principalmente usadas para campeonatos de sapateado.",ep:18,g:64,l:56,wd:true,fm:true,w:15,p:8200};
I.u[7220] = {n:"Bilhete de Loteria",t:15,d:"Você tem nas mãos um excelente Bilhete de Loteria. Guarde-o com carinho, pois você pode ser o sortudo ganhador.",ep:1,g:717,l:2,wd:true,fm:true,w:1,p:1};
I.u[7221] = {n:"Colar do Tanukouï San",t:1,d:"Todo Tanukouï San usa este colar desde a infância, o que aumenta o seu valor quando você sabe do que ele é capaz, até como uma criança.",ep:19,g:92,l:152,wd:true,fm:true,w:10,p:49030};
I.u[7222] = {n:"Artefato Pandawushu Água",t:50,d:"Este artefato mágico é usado pelos discípulos de Pandawushu para encantar seus equipamentos.",ep:1,g:104,l:1,wd:true,fm:true,w:1,p:1};
I.u[7223] = {n:"Artefato Pandawushu de Ar",t:50,d:"Este artefato mágico é usado pelos discípulos de Pandawushu para enfeitiçar seus equipamentos.",ep:18,g:105,l:1,wd:true,fm:true,w:1,p:1};
I.u[7224] = {n:"Artefato Pandawushu da Terra",t:50,d:"Este artefato mágico é usado pelos discípulos de Pandawushu para enfeitiçar seus equipamentos.",ep:18,g:106,l:1,wd:true,fm:true,w:1,p:1};
I.u[7225] = {n:"Artefato de Pandawushu do Fogo",t:50,d:"Este artefato mágico é usado pelos discípulos de Pandawushu para enfeitiçar os equipamentos deles.",ep:18,g:107,l:1,wd:true,fm:true,w:1,p:1};
I.u[7226] = {n:"Chapéu de Akwadala",t:16,d:"De longe, usando este chapéu, você parece um Pandawushuka da vila de Akwadala. De perto, você não se parece com nada.",ep:18,g:146,l:43,wd:true,fm:true,w:2,s:34,p:5100};
