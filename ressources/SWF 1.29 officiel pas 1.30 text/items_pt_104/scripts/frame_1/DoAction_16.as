I.u[7230] = {n:"Manto de Akwadala",t:17,d:"Esta capa é proveniente de Akwadala. Pode ser usada como capacho ou até mesmo como pano de chão se você acabou de sair da água.",ep:18,g:113,l:41,wd:true,fm:true,w:10,s:34,p:4550};
I.u[7231] = {n:"Manto de Terrdala",t:17,d:"Este manto é proveniente de Terrdala. Pode ser usado como capacho ou até mesmo como pano de chão se você acabou de sair da água.",ep:18,g:112,l:63,wd:true,fm:true,w:15,s:36,p:10305};
I.u[7232] = {n:"Manto de Feudala",t:17,d:"Este manto é proveniente de Feudala. Pode ser usado como capacho ou até mesmo como pano de chão se você acabou de sair da água.",ep:18,g:111,l:92,wd:true,fm:true,w:10,s:37,p:21750};
I.u[7233] = {n:"Manto de Aerdala",t:17,d:"Este manto é proveniente de Aerdala. Pode ser usado como capacho ou até mesmo como pano de chão se você acabou de sair da água.",ep:18,g:114,l:65,wd:true,fm:true,w:10,s:35,p:11200};
I.u[7234] = {n:"Escudo de Akwadala",t:82,d:"Para impedir golpes fracos ou fortes, este escudo de Aerdala deve servir.",ep:18,g:31,l:1,wd:false,fm:true,w:2,c:"BI=non équipable",p:5350};
I.u[7235] = {n:"Escudo Terrdala",t:82,d:"Para impedir golpes fracos ou fortes, este escudo de Terrdala deve servir.",ep:18,g:32,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:14100};
I.u[7236] = {n:"Escudo de Feudala Queimado",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:33,l:1,wd:false,fm:true,w:15,c:"BI=non équipable",p:27100};
I.u[7237] = {n:"Escudo de Aerdala desaparecido",t:82,d:"Este escudo já presenciou batalhas demais, neste estado, não serve para nada. Talvez Bouwada, na vila de Pandala, possa substituí-lo para você.",ep:18,g:30,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:11600};
I.u[7238] = {n:"Cinto de Akwadala",t:10,d:"Pandawas de Akwadala sempre cuidam de suas silhuetas. Se apertar ao máximo este cinto, você obterá um bom resultado com a sua barriga flácida.",ep:18,g:76,l:41,wd:true,fm:true,w:2,s:34,p:4600};
I.u[7239] = {n:"Cinto Terrdala",t:10,d:"Pandawas de Terrdala sempre cuidam de suas silhuetas. Se apertar ao máximo este cinto, você vai obter um bom resultado com a sua barriga flácida.",ep:18,g:78,l:49,wd:true,fm:true,w:10,s:36,p:6353};
I.u[7240] = {n:"Cinto de Feudala",t:10,d:"Pandawas de Feudala sempre cuidam de suas silhuetas. Se apertar ao máximo este cinto, você obterá um bom resultado com a sua barriga flácida.",ep:18,g:77,l:81,wd:true,fm:true,w:10,s:37,p:16925};
I.u[7241] = {n:"Cinto de Aerda",t:10,d:"Pandawas de Aerdala sempre cuidam de suas silhuetas. Se apertar ao máximo este cinto, você obterá um bom resultado com a sua barriga flácida.",ep:18,g:79,l:70,wd:true,fm:true,w:10,s:35,p:13000};
I.u[7242] = {n:"Geta de Akwadala",t:11,d:"Estes calçados de madeira foram feitos pelos melhores sapateiros da vila de Akwadala. Muito arejados, eles permitirão que suas verrugas tomem ar fresco e apreciem a paisagem.",ep:18,g:54,l:35,wd:true,fm:true,w:10,s:34,p:3350};
I.u[7243] = {n:"Geta Terrdala",t:11,d:"Estes calçados de madeira foram feitos pelos melhores sapateiros da vila de Terrdala. Muito arejados, eles permitirão que suas verrugas tomem ar fresco e apreciem a paisagem.",ep:18,g:55,l:76,wd:true,fm:true,w:15,s:36,p:15000};
I.u[7244] = {n:"Calçado de Feudala",t:11,d:"Estes calçados de madeira foram feitos pelos melhores sapateiros da vila de Feudala. Muito arejados, eles permitirão que suas verrugas tomem ar fresco e apreciem a paisagem.",ep:16,g:56,l:68,wd:true,fm:true,w:25,s:37,p:12050};
I.u[7245] = {n:"Geta de Aerdala",t:11,d:"Estes calçados de madeira foram feitos pelos melhores sapateiros da vila de Aerdala. Muito arejados, eles permitirão que suas verrugas tomem ar fresco e apreciem a paisagem.",ep:18,g:57,l:57,wd:true,fm:true,w:10,s:35,p:8700};
I.u[7246] = {n:"Aliança de Akwadala",t:9,d:"Esta aliança é proveniente da vila de Akwadala. Mais para um talismã do que para uma relíquia mágica, você ainda fará seus amigos acreditarem que encontrou a sua alma gêmea.",ep:1,g:80,l:37,wd:true,fm:true,w:2,s:34,p:3800};
I.u[7247] = {n:"Aliança Terrdala",t:9,d:"Esta Aliança é proveniente da vila de Terrdala. Mais para um talismã do que para uma relíquia mágica, você ainda fará seus amigos acreditarem que encontrou a sua alma gêmea.",ep:18,g:81,l:77,wd:true,fm:true,w:10,s:36,p:15425};
I.u[7248] = {n:"Aliança de Feudala",t:9,d:"Esta aliança é proveniente da vila de Feudala. Mais para um talismã do que para uma relíquia mágica, você ainda fará seus amigos acreditarem que encontrou a sua alma gêmea.",ep:18,g:82,l:81,wd:true,fm:true,w:10,s:37,p:17000};
I.u[7249] = {n:"Aliança de Aerdala",t:9,d:"Esta aliança é proveniente da vila de Aerdala. Mais para um talismã do que para uma relíquia mágica, você ainda fará seus amigos acreditarem que encontrou a sua alma gêmea.",ep:18,g:83,l:57,wd:true,fm:true,w:5,s:35,p:8600};
I.u[7250] = {n:"Amuleto de Akwadala",t:1,d:"Os habitantes de Akwadala são os únicos que têm permissão para usar este amuleto. Este amuleto é supostamente parte do traje formal e tradicional dos habitantes, entretanto, todos ainda se perguntam por quê.",ep:18,g:79,l:41,wd:true,fm:true,w:2,s:34,p:5050};
I.u[7251] = {n:"Amuleto de Terrdala",t:1,d:"As únicas pessoas que têm permissão para usar este amuleto são os habitantes da vila de Terrdala. Este amuleto é parte do traje formal e tradicional dos habitantes, entretanto, todos ainda se perguntam por quê.",ep:18,g:80,l:80,wd:true,fm:true,w:10,s:36,p:16550};
I.u[7252] = {n:"Amuleto de Feudala",t:1,d:"As únicas pessoas que têm permissão para usar este amuleto são os habitantes da vila de Feudala. Este amuleto é parte do traje formal e tradicional dos habitantes, entretanto, todos ainda se perguntam por quê.",ep:18,g:81,l:91,wd:true,fm:true,w:10,s:37,p:21225};
I.u[7253] = {n:"Amuleto de Aerdala",t:1,d:"As únicas pessoas que têm permissão para usar este amuleto são os habitantes da vila de Aerdala. Este amuleto é parte do traje formal e tradicional dos habitantes, entretanto, todos ainda se perguntam por quê.",ep:18,g:82,l:62,wd:true,fm:true,w:10,s:35,p:10000};
I.u[7254] = {n:"Cajado de Akwadala",t:4,d:"Este cajado era usado para corrigir os jovens Pandawas um pouco turbulentos. Três golpes nos dedos, quinze nas costas, seis na cabeça, dois nos olhos, e isso é tudo!",ep:18,g:61,l:43,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,false],c:"CC>50",s:34,p:5040};
I.u[7255] = {n:"Machado Terrdala",t:19,d:"Este machado, desde o início, foi projetado para cortar seres vivos. Tenha cuidado! Um simples deslize e você pode ser cortado ao meio!",ep:18,g:32,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],s:36,p:17635};
I.u[7256] = {n:"Adagas de Aerdala",t:5,d:"Tão afiadas quanto as garras do Moowolf, estas adagas o transformarão em um excelente aprendiz de infiltrador.",ep:18,g:51,l:62,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>50",s:35,p:10105};
I.u[7257] = {n:"Sabre Feudala",t:6,d:"Este sabre foi forjado pelo próprio Hotari Honza. Dizem ser uma das últimas criações antes de ele se converter em chefe. Um item de coleção!",ep:18,g:64,l:76,wd:true,fm:true,w:1,an:14,e:[5,6,1,1,50,50,false,false],c:"CI>200&CA>60",s:37,p:14900};
I.u[7258] = {n:"Pêlos de Pandikaze",t:54,d:"Esses pêlos extremamente finos parecem ter sido arrancados das nádegas de uma Sadida fêmea, mas não se engane, eles não foram!",ep:16,g:556,l:40,wd:true,fm:true,w:1,p:10};
I.u[7259] = {n:"Tecido de Pandikaze",t:55,d:"Este conjunto de pêlos está quase intacto apesar do tratamento que você deve ter dado a este pobre Pandikaze para arrancar ele.",ep:18,g:124,l:40,wd:true,fm:true,w:1,p:10};
I.u[7260] = {n:"Pele de Pandikaze",t:59,d:"Esta pele ainda está levemente coberta por uma penugem, tão macia quanto às axilas de uma Eniripsa, mas... sem o cheiro de transpiração.",ep:18,g:40,l:40,wd:true,fm:true,w:2,p:10};
I.u[7261] = {n:"Madeira de Bambu Mágico",t:38,d:"Este incrível pedaço de Bambu pode mover. Uma lenda tribal diz que toda a noite ele vaga pela vila batendo nas portas das pessoas que se perderam para os prazeres noturnos. Os Pandawas normalmente proíbem o Bambu Mágico antes de dormir para evitar todo o tipo de decepção.",ep:18,g:670,l:220,wd:true,fm:true,w:5,p:20};
I.u[7262] = {n:"Raiz de Bulbiflor",t:98,d:"Esta Raiz de Bulbiflor não é como as outras raízes. Ela pode ser mastigada por séculos sem que você perca seus dentes. Tenha cuidado, ao contrário dos verdadeiros doces, ela tem um gosto muito ruim!",ep:18,g:142,l:26,wd:true,fm:true,w:2,p:20};
I.u[7263] = {n:"Raiz de Bulbush",t:98,d:"Esta Raiz de Bulbush não é como as outras raízes. Ela pode ser mastigada por séculos sem que você perca seus dentes. Tenha cuidado, ao contrário dos verdadeiros doces, ela tem um gosto muito ruim!",ep:18,g:143,l:42,wd:true,fm:true,w:2,p:20};
I.u[7264] = {n:"Raiz de Bulbambu",t:98,d:"Esta Raiz de Bulbambu não é como as outras raízes. Ela pode ser mastigada por séculos sem que você perca seus dentes. Tenha cuidado, ao contrário dos verdadeiros doces, ela tem um gosto muito ruim!",ep:18,g:145,l:67,wd:true,fm:true,w:2,p:20};
I.u[7265] = {n:"Raiz de Bulbig",t:98,d:"Esta Raiz de Bulbig não é como as outras raízes. Ela pode ser mastigada por séculos sem que você perca seus dentes. Tenha cuidado, ao contrário dos verdadeiros doces, ela tem um gosto muito ruim!",ep:18,g:144,l:150,wd:true,fm:true,w:2,p:20};
I.u[7266] = {n:"Flor de Bulbiflor",t:35,d:"Esta flor só cresce na cabeça do Bulbiflor, então não tente colocá-la em sua própria cabeça, o substrato não é rico o suficiente.",ep:18,g:119,l:26,wd:true,fm:true,w:1,p:10};
I.u[7267] = {n:"Folha de Bulbush",t:36,d:"Estas folhas só crescem na cabeça do Bulbush. Não tente fazer uma crescer em sua própria cabeça. Ela murcharia muito rápido.",ep:18,g:55,l:42,wd:true,fm:true,w:2,p:10};
I.u[7268] = {n:"Broto de Bulbambu",t:36,d:"Este broto pode crescer na cabeça do Bulbambu. Não tente pôr isto na sua cabeça, pois ele não encontraria nada interessante para comer nela.",ep:18,g:56,l:67,wd:true,fm:true,w:2,p:10};
I.u[7269] = {n:"Casca Mágica de Bulbig",t:96,d:"Esta casca mágica é tão resistente quanto o escudo do Capitão Amakna, mas é não tão bonita...",ep:18,g:105,l:150,wd:true,fm:true,w:2,p:10};
I.u[7270] = {n:"Casca Mágica de Bulbiflor",t:96,d:"Essa casca é tão fina e frágil que poderia ser usada para fazer renda e até roupas íntimas.",ep:18,g:106,l:26,wd:true,fm:true,w:2,p:10};
I.u[7271] = {n:"Casca Mágica de Bulbush",t:96,d:"Esta casca áspera é perfeita para fazer solas antiderrapantes.",ep:18,g:107,l:42,wd:true,fm:true,w:2,p:10};
I.u[7272] = {n:"Casca Mágica de Bulbambu",t:96,d:"Essa casca de árvore lisa é perfeita para fazer piso de madeira ou de dança.",ep:18,g:108,l:67,wd:true,fm:true,w:2,p:10};
I.u[7273] = {n:"Pele de Serpente",t:59,d:"Esta pele desliza pelos seus dedos mais do que qualquer outra. Não faça sapatos com ela ou você não conseguirá retirá-los!",ep:18,g:41,l:67,wd:true,fm:true,w:2,p:10};
I.u[7274] = {n:"Dente de Cobra-Rato Mágico",t:47,d:"Este dente não é como os outros. Seu cheiro é até pior que o terrível bafo de Rato Cobra.",ep:18,g:16,l:67,wd:true,fm:true,w:2,p:100};
I.u[7275] = {n:"Cabelos de Kitsou Nae",t:54,d:"Pêlos de Kitsou Nae são muito macios e gostosos de acariciar. Eles dariam um ótimo carpete para a sua casa.",ep:16,g:560,l:29,wd:true,fm:true,w:1,p:10};
I.u[7276] = {n:"Pêlos de Kitsou Nufeu",t:54,d:"Pêlos muito macios e gostosos de acariciar. Eles dariam um ótimo carpete para a sua casa.",ep:18,g:557,l:111,wd:true,fm:true,w:1,p:10};
I.u[7277] = {n:"Cabelos de Kitsou Nere",t:54,d:"Pêlos de Kitsou Nere são muito macios e gostosos de acariciar. Eles dariam um ótimo carpete para a sua casa.",ep:16,g:558,l:80,wd:true,fm:true,w:1,p:10};
I.u[7278] = {n:"Cabelos de Kitsou Nakwa",t:54,d:"Pêlos de Kitsou Nakwa são muito macios e gostosos de acariciar. Eles dariam um ótimo carpete para a sua casa.",ep:1,g:559,l:60,wd:true,fm:true,w:1,p:10};
I.u[7279] = {n:"Pele de Kitsou Nae",t:59,d:"Esta pele de alta qualidade pode ser cortada em tiras finas para fazer um chicote muito eficiente. O presente ideal para pais de crianças insolentes.",ep:18,g:46,l:19,wd:true,fm:true,w:2,p:10};
I.u[7280] = {n:"Pele de Kitsou Nufeu",t:59,d:"Esta pele de alta qualidade pode ser cortada em tiras finas para fazer um chicote muito eficiente. O presente ideal para pais de crianças insolentes.",ep:18,g:44,l:111,wd:true,fm:true,w:2,p:10};
I.u[7281] = {n:"Pele de Kistsou Nere",t:59,d:"Esta pele de Kitsou Nere é de qualidade excepcional, cortada em tiras finas, poderia fazer um chicote perfeito. É o presente ideal para pais de crianças travessas.",ep:18,g:45,l:80,wd:true,fm:true,w:2,p:10};
I.u[7282] = {n:"Pele de Kitsou Nakwa",t:59,d:"Esta pele de Kitsou Nakwa é de qualidade excepcional, cortada em tiras finas, poderia fazer um chicote perfeito. É o presente ideal para pais de crianças travessas.",ep:1,g:43,l:60,wd:true,fm:true,w:2,p:10};
I.u[7283] = {n:"Pele de Tanukouï San",t:59,d:"Esta pele enorme e distensa de Tanukouï San poderia se tornar uma excelente sacola para pôr suas kamas.",ep:1,g:2,l:85,wd:true,fm:true,w:2,p:100};
I.u[7284] = {n:"Pêlos de Tanukouï San",t:54,d:"Estes pêlos do Tanukouï San fedem, mas quem se importa?! Eles ainda são pêlos de um Tanukouï San.",ep:1,g:3,l:85,wd:true,fm:true,w:2,p:100};
I.u[7285] = {n:"Pata de Araknawa",t:103,d:"Esta pequena pata continuará se retorcendo durante muito tempo após você tê-la arrancado do corpo da Araknawa. Coloque-a nas calças de seus inimigos para instabilizá-los durante uma luta;\r\n            deste modo, você ganhará facilmente a luta.",ep:18,g:716,l:43,wd:true,fm:true,w:2,p:100};
I.u[7286] = {n:"Madeira de Bambu",t:38,d:"A madeira de bambu é quase tão cara quanto a madeira de Cubulto, ainda que seja muito mais comum. Não faz sentido, faz?",ep:18,g:675,l:47,wd:true,fm:true,w:2,p:100};
I.u[7287] = {n:"Folha de Bambu",t:36,d:"As folhas de bambu são grandes e grossas, um pouco parecidas com a Bwork fêmea, só que menos agressivas.",ep:18,g:69,l:47,wd:true,fm:true,w:2,p:1};
I.u[7288] = {n:"Folha de Bambu Sagrado",t:36,d:"Esta folha grande é tão dura e pesada que poderia lhe achatar se acontecer de você cair no sono embaixo de um Bambu Sagrado em queda.",ep:18,g:68,l:120,wd:true,fm:true,w:2,p:100};
I.u[7289] = {n:"Madeira de Bambu Sagrado",t:38,d:"Você deve ser cuidadoso com esta madeira. Nem todos devem tê-la nas mãos. Mas ninguém sabe o motivo.",ep:18,g:674,l:120,wd:true,fm:true,w:10,p:100};
I.u[7290] = {n:"Raiz de Bambuto Mágico",t:98,d:"Esta raiz permite que o Bambuto atraia sua mágica do solo antes de a luta.",ep:18,g:100,l:20,wd:true,fm:true,w:2,p:10};
I.u[7291] = {n:"Raiz Mágica de Bambuto Sagrado",t:98,d:"Esta raiz permite que o Bambuto Sagrado atraia sua mágica do solo antes de a luta.",ep:18,g:99,l:87,wd:true,fm:true,w:2,p:100};
I.u[7292] = {n:"Pêlos de Raposa Maho",t:54,d:"Estes pêlos de Raposa Maho, uma terrível criatura com aparência frágil, mas que no final possui terríveis poderes mágicos.",ep:18,g:202,l:150,wd:true,fm:true,w:2,p:1};
I.u[7293] = {n:"Pêlos de Raposa Soryo",t:54,d:"Este pêlo é proveniente de uma criatura pequena marrom-avermelhada bem perversa, como tantas outras.",ep:18,g:203,l:130,wd:true,fm:true,w:10,p:1};
I.u[7294] = {n:"Pêlo da Raposa Yokai",t:54,d:"Estes cabelos grossos de malodorous foram arrancados com força das costas de uma criatura horrível ruiva.",ep:18,g:204,l:110,wd:true,fm:true,w:10,p:10};
I.u[7295] = {n:"Pêlos de Pandora",t:54,d:"Esses pêlos misteriosos geralmente permitem a costura de chapéus mágicos e capas com efeitos mágicos surpreendentes.",ep:18,g:2,l:200,wd:true,fm:true,w:10,p:200};
I.u[7297] = {n:"Pêlos de Pandulum",t:54,d:"Esses pequenos pêlos mágicos são fortes o suficiente para trazer um relógio quebrado de volta à vida.",ep:18,g:206,l:150,wd:true,fm:true,w:1,p:1};
I.u[7298] = {n:"Pele de Raposa Maho",t:59,d:"Esta pele fina e lisa oferece uma excelente proteção contra vários ataques mágicos que a Raposa Maho encara quando seus feitiços retornam para eles.",ep:18,g:42,l:150,wd:true,fm:true,w:1,p:100};
I.u[7299] = {n:"Pele de Raposa Soryo",t:59,d:"Esta pele era antigamente usada para pregar roupas íntimas para crianças com pele sensível. Roupas íntimas de Raposa Soyo Feitas-de-Pele são aprovadas pelos descendentes do Capitão Chafer.",ep:18,g:38,l:130,wd:true,fm:true,w:1,p:100};
I.u[7300] = {n:"Pele de Raposa Yokai",t:59,d:"Esta pele grossa é uma boa proteção contra golpes de bambu.",ep:18,g:37,l:110,wd:true,fm:true,w:1,p:100};
I.u[7301] = {n:"Pele de Leopardo",t:59,d:"Esta pele foi usada por um Pandawa para roupas de baixo leves e minimalistas.",ep:18,g:36,l:40,wd:true,fm:true,w:1,p:10};
I.u[7302] = {n:"Pele de Pandora",t:59,d:"Se você é um sapateiro, a pele de Pandora tem mais do que uma surpresa guardada para você.",ep:18,g:1,l:200,wd:true,fm:true,w:10,p:100};
I.u[7303] = {n:"Pele de Pandulum",t:59,d:"A cor dessa grossa pele regularmente muda, mas ninguém sabe o motivo.",ep:18,g:39,l:100,wd:true,fm:true,w:1,p:10};
I.u[7304] = {n:"Tecido de Raposa Maho",t:55,d:"Este tecido vermelho tem um poder mágico. Eu ficaria contente em dizer o mesmo de você mas...",ep:18,g:11,l:150,wd:true,fm:true,w:1,p:100};
I.u[7305] = {n:"Tecido de Raposa Soryo",t:55,d:"Este tecido de tamanho médio pode ser usado para tapar buracos em baixo de portas velhas quando o inverno chegar.",ep:18,g:10,l:130,wd:true,fm:true,w:1,p:10};
I.u[7306] = {n:"Pano de Yokai Raposa",t:55,d:"Este pano vem das partes mais sensíveis da Raposa Yokai e as mais fedorentas também. Muitos aventureiros se enganam pensando que estão falando de seu bigode.",ep:18,g:9,l:110,wd:true,fm:true,w:1,p:10};
I.u[7307] = {n:"Tecido de Pandora",t:55,d:"Este tecido deve ser tão raro quanto uma boa surpresa na caixa de Pandora.",ep:18,g:125,l:200,wd:true,fm:true,w:10,p:10};
I.u[7308] = {n:"Tecido de Pandulum",t:55,d:"Este tecido não é comestível como as pessoas dizem. Os últimos que tentaram cozinhar ele acabaram como um Tanukouï San. Mas que sorte!",ep:18,g:12,l:100,wd:true,fm:true,w:1,p:10};
I.u[7309] = {n:"Chave Pandikaze",t:84,d:"Esta chave lhe dá permissão para acessar o Calabouço Pandikaze. Tenha cuidado, ela se autodestruirá após o uso.",ep:13,g:229,l:1,wd:true,fm:true,w:1,p:100};
I.u[7310] = {n:"Chave da Caverna dos Bulbes",t:84,d:"Com esta chave, você poderá entrar no Calabouço dos Bulbes. Tenha cuidado, pois ela se autodestruirá depois de usada.",ep:1,g:230,l:1,wd:true,fm:true,w:1,p:100};
I.u[7311] = {n:"Chave do Calabouço de Kitsou",t:84,d:"Com esta chave, você poderá entrar no Calabouço dos Ferreiros. Tenha cuidado, pois ela se autodestruirá depois de usada.",ep:1,g:231,l:1,wd:true,fm:true,w:1,p:100};
I.u[7312] = {n:"Chave do Calabouço das Raposas",t:84,d:"Com esta chave, você poderá entrar no Calabouço das Raposas. Tenha cuidado, pois ela se autodestruirá depois de usada.",ep:2,g:232,l:1,wd:true,fm:true,w:1,p:100};
I.u[7313] = {n:"A Arte Pandawushu",t:25,d:"Todo devoto Pandawushu devia saber este livro de cor...",ep:18,g:19,l:1,wd:true,fm:true,w:2,u:true,p:1};
