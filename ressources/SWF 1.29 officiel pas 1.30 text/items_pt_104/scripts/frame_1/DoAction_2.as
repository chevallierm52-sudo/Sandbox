I.u[811] = {n:"Pergaminho de Sorte",t:76,d:"(Clique duas vezes para ganhar Sorte)\nCom este pergaminho você pode seguramente aumentar sua sorte em definitivo. Mas tenha cuidado, você só pode usá-lo se sua sorte estiver abaixo de 50.",ep:1,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<50",u:true,p:2500};
I.u[812] = {n:"Grande Pergaminho da Sorte",t:76,d:"(Clique duas vezes para ganhar sorte)\nCom este pergaminho você pode aumentar sua sorte. Mas tenha cuidado, você só pode usá-lo se sua sorte estiver abaixo de 80.",ep:2,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<80",u:true,p:5000};
I.u[814] = {n:"Poderoso Pergaminho de Sorte",t:76,d:"(Clique duas vezes para ganhar Sorte)\nCom esse pergaminho você pode seguramente aumentar a sua sorte para sempre. Mas tenha cuidado, você só pode usá-lo se sua sorte for menor que 100.",ep:1,g:22,l:1,wd:true,fm:true,w:1,c:"Cc<100",u:true,p:8000};
I.u[815] = {n:"Pergaminho de Inteligência",t:76,d:"(Clique duas vezes para ganhar Inteligência)\nCom este pergaminho você pode seguramente aumentar sua inteligência em definitivo. Mas tenha cuidado, você só pode usá-lo se sua inteligência estiver abaixo de 50.",ep:1,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<50",u:true,p:2500};
I.u[816] = {n:"Grande Pergaminho da Inteligência",t:76,d:"(Clique duas vezes para ganhar inteligência)\nCom este pergaminho você pode aumentar sua inteligência. Mas tenha cuidado, você só pode usá-lo se sua inteligência estiver abaixo de 80.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<80",u:true,p:5000};
I.u[817] = {n:"Poderoso Pergaminho de Inteligência",t:76,d:"(Clique duas vezes para ganhar Inteligência)\nCom esse pergaminho você pode seguramente aumentar a sua inteligência para sempre. Mas tenha cuidado, você só pode usá-lo se sua inteligência for menor que 100.",ep:1,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<100",u:true,p:8000};
I.u[818] = {n:"Chave de Pedra de Ded Aleicar",t:12,d:"Esta pequena chave de pedra abrirá a porta da caverna de Ded Aleicar. Isto é, se você encontrá-la...",ep:4,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[819] = {n:"Espada Sagrada",t:6,d:"Uma espada sagrada dada a guerreiros jovens durante o treinamento.",ep:1,g:1,l:15,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>30&CV>3",p:800};
I.u[820] = {n:"Grande Espada Sagrada",t:6,d:"Uma espada sagrada distribuída para guerreiros jovens durante o treinamento.",ep:1,g:1,l:16,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>32&CV>4",p:900};
I.u[821] = {n:"Poderosa Espada Sagrada",t:6,d:"Uma espada sagrada destinada a jovens guerreiros durante seu treinamento.",ep:1,g:1,l:17,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>34&CV>5",p:1000};
I.u[822] = {n:"Espada de Cavaleiro",t:6,d:"A espada do Cavaleiro é uma arma sólida e eficiente. Se for bem usada, causa sérios danos aos seus inimigos.",ep:7,g:9,l:23,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>46",p:1600};
I.u[823] = {n:"Espada do Grande Cavaleiro",t:6,d:"A Grande Espada de Cavaleiro é uma arma robusta e eficiente. Ao ser usada devidamente, causa sérios danos aos seus inimigos.",ep:7,g:9,l:24,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>48",p:1800};
I.u[824] = {n:"Poderosa Espada de Cavalheiro",t:6,d:"A Poderosa Espada de Cavalheiro é uma espada eficiente e vigorosa. Quando usada corretamente, ela causa sérios danos aos seus inimigos.",ep:7,g:9,l:26,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>52",p:2000};
I.u[825] = {n:"Lâmina de Bwork",t:6,d:"Esta espada de aparência rudimentar satisfaz os Bworks mais idiotas, ou seja, os que são incapazes de usar um arco ou um cajado... Alguns deles até confundem a lâmina com o punho. Os inimigos não conseguem deixar de dar boas risadas.",ep:1,g:13,l:23,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>46&CA>8",p:1600};
I.u[826] = {n:"Lâmina do Grande Bwork",t:6,d:"Esta modesta espada é bem apreciada pelos Bworks imbecis que são incapazes de usar um arco ou um cajado... Alguns deles até mesmo confundem a lâmina com o cabo. Os inimigos caem na gargalhada!",ep:1,g:13,l:24,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>48&CA>14",p:1800};
I.u[827] = {n:"Poderosa Espada de Bwork",t:6,d:"Esta espada de aparência básica satisfaz os Bworks mais imbecis que não podem usar um arco ou um cajado... Alguns deles até confundem a lâmina com o punho. Os inimigos não agüentam de rir!",ep:1,g:13,l:26,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>52&CA>16",p:2000};
I.u[828] = {n:"Arco Estrondoso",t:2,d:"Este arco atira suas flechas tão rapidamente que o barulho do assobio se alastra por uma grande distância. Em relação ao som, se quiser ser o mais discreto possível, equipe-o com um silenciador.",ep:1,g:15,l:11,wd:true,fm:true,w:10,an:10,tw:true,e:[5,3,2,6,30,40,false,true],c:"CA>11&CS>5",p:550};
I.u[829] = {n:"Arco de Ade",t:2,d:"Este arco não é muito eficiente, devido ao seu alcance limitado, mas você ainda pode debilitar o inimigo antes de matá-lo com outra arma ou feitiço.",ep:1,g:1,l:8,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,30,50,false,true],c:"CA>8",p:400};
I.u[830] = {n:"Varinha de Inteligência",t:3,d:"Esta varinha aumenta a inteligência de seu portador.",ep:7,g:1,l:24,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>24",p:1700};
I.u[831] = {n:"Grande Varinha Mágica da Inteligência",t:3,d:"Com esta varinha mágica, você aumenta sua inteligência.",ep:7,g:1,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>27",p:2100};
I.u[832] = {n:"Poderosa Varinha Mágica da Inteligência",t:3,d:"Esta varinha aumenta a inteligência do seu portador.",ep:7,g:1,l:29,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>29",p:2500};
I.u[833] = {n:"Varinha da Sabedoria",t:3,d:"Esta varinha aumenta a sabedoria de seu portador.",ep:1,g:4,l:23,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>23&CW>7",p:1600};
I.u[834] = {n:"Grande Varinha Mágica da Sabedoria",t:3,d:"Com esta varinha mágica, você aumenta sua sabedoria.",ep:1,g:4,l:25,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>25&CW>9",p:1900};
I.u[835] = {n:"Poderosa Varinha Mágica da Sabedoria",t:3,d:"Esta varinha aumenta a sabedoria do seu portador.",ep:1,g:4,l:27,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>27&CW>11",p:2200};
I.u[836] = {n:"Treechanel",t:9,d:"Este anel, feito de casca de Treechnid, tem grandes poderes e implica grandes responsabilidades. Entretanto, apesar de seu valor, dizem que ele é amaldiçoado.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:100};
I.u[837] = {n:"Botas de Kluh",t:11,d:"Estas botas aumentam a sua força, mas também o transformam em um perfeito idiota. Elas poderiam até mesmo transformá-lo em um Iop, no caso de uso regular e prolongado.",ep:1,g:3,l:8,wd:true,fm:true,w:1,p:400};
I.u[838] = {n:"Sangue Oni",t:15,d:"Este frasco muito procurado de Sangue de Oni é usado por experientes alquimistas para dar assustadoras propriedades a algumas armas.",ep:4,g:662,l:75,wd:true,fm:true,w:1,p:100};
I.u[840] = {n:"Pêlos de Minotoro",t:54,d:"Estes pêlos têm um cheiro muito ruim, mas são muito resistentes. Vestir um material feito de pêlos de Minotoro fará de você um temível adversário... e ainda por cima, muito apreciado pelas moscas.",ep:2,g:201,l:125,wd:true,fm:true,w:1,p:100};
I.u[841] = {n:"Anel de Satisfação",t:9,d:"Este anel aumenta os PA de quem possuí-lo em troca dos pontos de força e inteligência.",ep:1,g:12,l:8,wd:true,fm:true,w:1,p:10};
I.u[842] = {n:"Carapaça de Dragonete de Bronze",t:111,d:"Esta carapaça é quase irrompível, mas, se for polida durante gerações, os melhores joalheiros podem usar suas propriedades mágicas para fazer amuletos com poderes excepcionais.",ep:11,g:202,l:64,wd:true,fm:true,w:5,p:1};
I.u[843] = {n:"Concha de Dragonete Preto",t:111,d:"Esta concha é quase irrompível, mas, se for polida durante gerações, os melhores joalheiros poderão usar suas propriedades mágicas para fazer amuletos com poderes excepcionais.",ep:11,g:203,l:64,wd:true,fm:true,w:5,p:150};
I.u[844] = {n:"Ovo de Dragão Safira",t:105,d:"Este pequeno Dragonete sairá deste ovo estranho após ser chocado com uma fêmea Dragonete de Safira. Enquanto isso, não tente mantê-lo quente com seu corpo, nunca sabemos...",ep:11,g:204,l:74,wd:true,fm:true,w:20,p:100};
I.u[845] = {n:"Ovo de Dragonete Dourado",t:105,d:"Um belo e pequeno Dragonete sairá deste ovo estranho de uma Dragonete Dourada fêmea. Enquanto isso, não tente chocá-lo com seu corpo, nós nunca saberemos...",ep:11,g:205,l:74,wd:true,fm:true,w:20,p:100};
I.u[846] = {n:"Ovo de Dragonete Preto",t:105,d:"Um pequeno Dragonete fofo sairá deste estranho ovo, se chocado por uma Dragonete Preta. Enquanto isso, não tente mantê-lo aquecido perto de você, nunca sabemos...",ep:11,g:206,l:74,wd:true,fm:true,w:20,p:100};
I.u[847] = {n:"Ovo de Dragonete Branco",t:105,d:"Um pequeno e gracioso Dragonete sairá deste ovo estranho que foi colocado por um Dragonete Branco fêmea. Mesmo assim, não tente mantê-lo aquecido perto de você, nunca se sabe o que poderá acontecer...",ep:10,g:38,l:74,wd:true,fm:true,w:1,p:100};
I.u[848] = {n:"Velho Osso de Dragonete",t:47,d:"Este velho osso é mágico. Corretamente usado, deveria fazer itens muito poderosos.",ep:11,g:15,l:70,wd:true,fm:true,w:20,p:100};
I.u[849] = {n:"Anel de Força",t:9,d:"Este pequeno anel dá força a quem possuí-lo.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[850] = {n:"Anel Ágil",t:9,d:"Os coletores Amaknianos estão desesperados para conseguir pegar este anel, ainda que ele não valha nem um centavo.",ep:1,g:1,l:1,wd:true,fm:true,w:1,p:50};
I.u[851] = {n:"Anel Vitalício",t:9,d:"Esse pequeno anel aumenta a vida de quem o usar.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[852] = {n:"Pequeno Anel Mágico",t:9,d:"Este pequeno anel aumenta a inteligência de seu usuário.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[853] = {n:"Pequeno Anel da Sorte",t:9,d:"Este pequeno anel aumenta a chance de seu portador.",ep:1,g:42,l:1,wd:true,fm:true,w:1,p:50};
I.u[854] = {n:"Amuleto de Pequeno Urso",t:1,d:"Este pequeno amuleto aumentará a força de quem usá-lo.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[855] = {n:"Amuleto Novato",t:1,d:"Este pequeno amuleto aumenta a vida de seu possuidor.",ep:0,g:6,l:1,wd:true,fm:true,w:1,p:50};
I.u[856] = {n:"Sapinho",t:1,d:"Com este pequeno amuleto, você aumenta sua agilidade.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[859] = {n:"Cinto de Agilidade",t:10,d:"Este modesto cinto aumenta a agilidade de seu portador.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:50};
I.u[860] = {n:"Cinto da Sorte",t:10,d:"Este simples cinto aumenta a sorte de quem possuí-lo.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[861] = {n:"Pequenas Botas de Força",t:11,d:"Estas botas aumentam a força do usuário em detrimento de sua agilidade, o tornando totalmente diferente de um Tofu... Exceto pela sua inteligência",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[862] = {n:"Sandálias de Inteligência",t:11,d:"Estas sandálias aumentam a inteligência de quem possuí-las. Elas também permitem que ele/ela fique na moda;\r\n            as solas de nozes garantem uma incrível aderência.",ep:1,g:4,l:8,wd:true,fm:true,w:1,p:400};
I.u[863] = {n:"Botas Ágeis",t:11,d:"Estas botas aumentam a agilidade do portador de forma que possa agir facilmente como um Tofu todas as vezes que ele se sentir como um.",ep:1,g:5,l:8,wd:true,fm:true,w:1,p:400};
I.u[864] = {n:"Botas da Sorte",t:11,d:"Estas botas aumentam a sorte de quem possuí-las, para encontrar itens poderosos como saliva de Gobball.",ep:1,g:1,l:8,wd:true,fm:true,w:1,p:100};
I.u[867] = {n:"Dragolyre",t:1,d:"Este esplêndido amuleto feito de restos de Dragovo é impressionante o suficiente para fazer a maioria dos valentes inimigos bater em retirada.",ep:11,g:9,l:32,wd:true,fm:true,w:2,p:4700};
I.u[878] = {n:"Pergaminho do Padeiro",t:13,d:"(Clique duas vezes para usá-lo)\nCom este pergaminho, você ganha pontos de experiência como padeiro.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[879] = {n:"Pergaminho de Sapateiro",t:13,d:"(Clique duas vezes para usá-lo)\nCom este pergaminho você ganha Experiência como Sapateiro.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[880] = {n:"Lã do Rei Gobball",t:57,d:"Esta lã é realmente magnífica;\r\n            é macia e leve, mas também é de segunda mão e frágil, considerando o quão velho o Rei Gobball é. Também pode causar coceira em peles sensíveis.",ep:1,g:207,l:35,wd:true,fm:true,w:1,p:4000};
I.u[881] = {n:"Lã de Gobbly Branco",t:57,d:"Essa lã tirada de um Gobbly abatido é extremamente macia. Mas tenha cuidado, ainda está impregnada com o cheiro do Gobbly, e a múmia do Gobbly pode tentar lamber você...",ep:1,g:208,l:2,wd:true,fm:true,w:1,p:1};
I.u[882] = {n:"Lã do Chefe de Guerra Gobball",t:57,d:"Esta lã cheira muito mal, mas uma vez pertenceu a um Chefe de Guerra de Gobball... por isso é de grande valor sentimental aos guerreiros.",ep:1,g:209,l:19,wd:true,fm:true,w:1,p:1};
I.u[883] = {n:"Couro de Gobbly Branco",t:56,d:"Estes couros macios muito lisos são muito usados na fabricação de roupas de baixo de couro. O Chafer é um exemplo com sua cueca de couro... ",ep:1,g:534,l:2,wd:true,fm:true,w:1,p:1};
I.u[884] = {n:"Couro de Gobbly Preto",t:56,d:"Este couro brilhante é freqüentemente usado por sapateiros e alfaiates para fazer botas e chapéus pequenos.",ep:1,g:16,l:2,wd:true,fm:true,w:1,p:1};
I.u[885] = {n:"Lã de Gobbly Preto",t:57,d:"Ainda que os alfaiates não a usem tanto, esta áspera lã é muito popular entre os Enutrofs, que a usam para esconder sua calvície prematura.",ep:1,g:210,l:2,wd:true,fm:true,w:1,p:1};
I.u[886] = {n:"Couro de Gobball Real",t:56,d:"A incrível flexibilidade deste couro é ideal para um rei, e as rachaduras provam a longevidade do Gobball Real. É o melhor couro em Amakna.",ep:1,g:535,l:35,wd:true,fm:true,w:1,p:4000};
I.u[887] = {n:"Couro do Chefe de Guerra Gobball",t:56,d:"‘Há algo que você pode enviar para mim, botas Amaknish de couro de Amaknish‘ – estas foram as palavras do famoso Trovador Francisque Kabroule, antes de ele morrer sufocado pelo cheiro de um Chefe de Guerra Gobball.",ep:1,g:534,l:19,wd:true,fm:true,w:1,p:1};
I.u[888] = {n:"Grandes Botas de Concentração",t:11,d:"Estas botas são tão confortáveis que aumentam a concentração de quem calçá-las.",ep:1,g:6,l:26,wd:true,fm:true,w:15,p:1950};
I.u[889] = {n:"Poderosas Botas de Concentração",t:11,d:"Esta s botas são tão confortáveis que elas aumentam a concentração do portador.",ep:1,g:6,l:27,wd:true,fm:true,w:15,p:2200};
I.u[890] = {n:"Botas do Gobball",t:11,d:"Com estas botas feitas de couro de Gobball, criadores podem facilmente se aproximar e matar outros Gobballs, graças ao odor que elas exalam.",ep:1,g:3,l:1,wd:true,fm:true,w:3,p:150};
I.u[891] = {n:"Botas de Grande Gobball",t:11,d:"Estas botas são feitas de couro de Gobball. Graças ao cheiro que exalam, criadores podem facilmente se aproximar e matar outros Gobballs.",ep:1,g:3,l:2,wd:true,fm:true,w:4,p:200};
I.u[892] = {n:"Poderosas Botas de Gobball",t:11,d:"Com essas botas feitas de Couro de Gobball, domadores podem facilmente se aproximar e matar outros Gobballs graças ao cheiro que elas liberam.",ep:1,g:3,l:4,wd:true,fm:true,w:5,p:250};
I.u[893] = {n:"Pequenas Adagas Silvestres",t:5,d:"Estas adagas foram adaptadas particularmente bem para cortar raízes e brotos mas elas começaram a ser usadas como armas quase mortais.",ep:1,g:6,l:20,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>20&CI>5",p:1300};
I.u[894] = {n:"Adagas Silvestres",t:5,d:"Estas adagas foram particularmente bem adaptadas para cortar raízes e brotos, mas elas começaram a ser usadas como armas quase mortais.",ep:1,g:6,l:23,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>23&CI>5",p:1600};
I.u[895] = {n:"Grandes Adagas Silvestres",t:5,d:"Estas adagas eram particularmente aptas para cortar raízes e galhos jovens, mas acabam sendo usadas para um propósito bem diferente: causar morte.",ep:1,g:6,l:25,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>25&CI>5",p:1900};
I.u[896] = {n:"Poderosas Adagas Silvestres",t:5,d:"Esta s adagas foram feitas para cortar raízes e galhos pequenos, mas logo foram dadas a elas um novo uso como armas quase fatais.",ep:1,g:6,l:27,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>27&CI>5",p:2200};
I.u[897] = {n:"Pequena Adaguisas",t:5,d:"Estas simples adagas são, no entanto, muito perigosas. Elas podem ser facilmente escondidas e são, conseqüentemente, a escolha de arma para infiltradores.",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
I.u[898] = {n:"Adagas Afiadas",t:5,d:"Estas simples adagas são, no entanto, muito perigosas. Elas podem ser facilmente escondidas e são, conseqüentemente, a escolha de arma para infiltradores.",ep:7,g:10,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>33&CW>5",p:3100};
I.u[899] = {n:"Grandes Adaguises",t:5,d:"Estas adagas têm aparência modesta, porém são muito perigosas. Elas podem ser facilmente escondidas, tornando-as armas perfeitas para infiltradores.",ep:7,g:10,l:36,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>36&CW>5",p:3600};
I.u[900] = {n:"Poderosas Adagas",t:5,d:"Esta s simples adagas são muito perigosas. Elas podem ser facilmente escondidas e são sem dúvida a arma preferida dos infiltradores.",ep:7,g:10,l:39,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>39&CW>5",p:4100};
I.u[901] = {n:"Couro de Porco de Leite",t:56,d:"Assim como o queijo mimolette, esse couro se torna quase laranja com o passar do tempo... sem mencionar o horrível cheiro que piora.",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Botas Pequenas de Klime",t:11,d:"Estas botas davam tamanha Agilidade para Klime, o Sapateiro, que ele era capaz de montar em Gobballs. Ele acabou se dando mal após confundir uma Geléia com um Gobball, quando estava eufórico como um peixe contra a correnteza.",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Botas de Klime",t:11,d:"A agilidade oferecida por estas botas a Klime, o sapateiro, permitiu que ele montasse facilmente qualquer Gobball. Ele morreu após confundir uma Geléia com um Gobball, quando estava eufórico como um peixe contra a correnteza.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Botas Grandes de Klime",t:11,d:"A agilidade oferecida por estas botas a Klime, o sapateiro, permitiu que ele montasse facilmente qualquer Gobball. Ele morreu após confundir uma Geléia com um Gobball, quando estava eufórico como um peixe contra a correnteza.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Botas Possantes de Klime\'",t:11,d:"De acordo com a lenda, estas botas foram secretamente substituídas por outro par, que, embora defeituoso, era extremamente poderoso;\r\n            tinham sido feitos por um sapateiro desajeitado e cansado.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Pequenas Botas de Perseguição",t:11,d:"Estas botas permitiram que Hogmeiser perseguisse os únicos seres humanos que ele não agüentava enxergar – crianças. Felizmente, o peso de suas botas não permitia que ele chutasse os traseiros delas.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Botas de Perseguição",t:11,d:"Com estas botas, Hogmeiser perseguiu os únicos seres humanos que ele não suportava: crianças. Felizmente para elas, o peso destas botas o prevenia de chutar seus traseiros.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Grandes Botas de Caça",t:11,d:"Com estas botas, Hogmeiser perseguia os únicos humanos que não poderiam ficar em sua vista: crianças. Felizmente, o peso de suas botas impedia que ele chutasse o traseiro das crianças.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Poderosas Botas de Caça",t:11,d:"Com essas botas, Hogmeiser costumava perseguir os únicos seres humanos que ele não agüentava: crianças. Felizmente, o peso das botas prevenia que ele chutasse as suas bundas.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Botas de Hogmeiser",t:11,d:"Estas botas pertenceram a Hogmeiser muitos anos atrás, antes de ele perder uma estúpida aposta com Grizmine. A moral desta história é: nunca jogue com um Ecaflip.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Botas Usadas de Hogmeiser",t:11,d:"Estas botas parecem ter pertencido a Hogmeiser durante muitos anos. Elas estão gastas e desconfortáveis. Se tiver sorte o bastante, um bom sapateiropoderá repará-las para você.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Botas Douradas de Hogmeiser",t:11,d:"Estas magníficas botas de Hogmeiser são finalmente cobertas com pedras preciosas e assim protegidas contra alguns ataques mágicos. Brouce Boulgoure, o próprio, usou-as para esmagar a cabeça do Rei Treechnids muito tempo atrás, e agora revive apenas na abertura da Feira de Trool.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[913] = {n:"Chapéu do Aprendiz de Padeiro",t:16,d:"Com este chapéu, você mostrará a todos que é um aprendiz de padeiro.",ep:0,g:258,l:1,wd:false,fm:true,w:1,p:10000};
I.u[914] = {n:"Chapéu de Padeiro",t:16,d:"Com este chapéu, você mostrará a todos que é um padeiro.",ep:0,g:257,l:1,wd:false,fm:true,w:1,p:10000};
I.u[915] = {n:"Chapéu do Mestre Padeiro",t:16,d:"Com este chapéu, você dirá a todos que é um Mestre Padeiro! Mas, sabemos com certeza, você cozinha e mistura mais rápido do que qualquer outro padeiro.",ep:0,g:74,l:1,wd:false,fm:true,w:1,c:"PJ>25,100",p:10000};
I.u[916] = {n:"Amuleto de Silicato",t:1,d:"Silicate fez este amuleto numa manhã de inverno para um famoso aventureiro chamado Rimb Vardi, que estava caçando um antigo Bwork Mago. Este último foi responsável por muitos desastres naturais causados por sua mágica duvidosa.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"Folha de Outono",t:1,d:"Este Broche foi confeccionado em uma manhã de outono no meio de uma floresta de Faias e Olmos, próxima à Ilha de Olag-lacustre. É considerada uma verdadeira relíquia por um grande número de lenhadores.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Âmbar Ancestral",t:50,d:"Este âmbar é proveniente de um Treechnid Ancestral e é inestimável. Pode conferir propriedades mágicas a alguns itens, desde que seja feito por mãos hábeis.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Adagas Ancestrais",t:5,d:"Estas poderosas adagas, tradicionalmente forjadas a partir do Âmbar Ancestral, foram usadas durante a colonização da Ilha da Lua, antes de ela tornar-se novamente selvagem.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Madeira Ancestral",t:38,d:"Este elmo de madeira é proveniente da Ilha de Olag-lacustre, uma ilha que foi atingida, em uma manhã, por um raio. Rumores dizem que um Bwork Mago é responsável por isso, porque ele não domina perfeitamente seus feitiços elementares.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Martelo de Ferreiro de Machado",t:7,d:"Ferramenta essencial para criar machados.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Separador de Treechnid",t:19,d:"Este machado de batalha foi forjado por Kademlia Boulgoure para lutar contra o mais terrível Treechnid. A lenda diz que esta lendária arma matou mais Treechnids em uma noite do que as árvores existentes em Amakna.",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Botas Poderosas de Klime",t:11,d:"A agilidade oferecida por estas botas a Klime, o sapateiro, permitiu que ele montasse facilmente qualquer Gobball. Ele morreu após confundir uma Geléia com um Gobball, quando estava eufórico como um peixe contra a correnteza.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Madeira Encantada",t:38,d:"Esta madeira foi encantada por um Treechnid Mago para dar à luz a um minúsculo Treechnid que foi posto na água. Esta madeira é, obviamente, extremamente mágica.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Rachador de Treechnid Ancestral",t:19,d:"Este machado de guerra foi forjado por Kademlia Boulgoure para lutar contra o Treechnid Ancestral. Só os melhores guerreiros podem usá-lo.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Espada de Ogralimde",t:6,d:"Ogralimde era um grande guerreiro que devia sua força a seu mestre Adyol, um Bwork Mago excepcionalmente inteligente e poderoso. Mais um fato, ao contrário da lenda, o aprendiz nunca superou o mestre.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristalite",t:50,d:"Esta pedra mágica com um nome particular não é ideal para o público em geral, pois pode dar grandes poderes às armas e jóias.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Mapa do Tesouro dos Mineiros das Sombras",t:24,d:"Este mapa indica a localização do Baú de Tesouros dos Mineiros das Sombras:‘O baú pode ser encontrado em uma ilha. Você terá de passar atrás de uma fundição para pôr suas mãos nele\'.",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Mapa do Tesouro dos Padeiros das Sombras",t:24,d:"Este mapa indica a localização do baú dos Padeiros das Sombras:\n‘O baú pode ser encontrado em uma ilha, ao Sul de Amakna;\r\n            você tem de caminhar por trás de pedras, entre duas lagoas pequenas\'.",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Pequeno Manto de Vermelhidão",t:17,d:"Este manto aumenta a vida de seu usuário.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
I.u[933] = {n:"Manto de Vermelhidão",t:17,d:"Este manto aumenta a vida de quem possuí-lo.",ep:1,g:13,l:13,wd:true,fm:true,w:5,p:650};
I.u[934] = {n:"Grande Manto Avermelhado",t:17,d:"Este manto aumenta a vida de quem possuí-lo.",ep:1,g:13,l:16,wd:true,fm:true,w:5,p:900};
I.u[935] = {n:"Pequeno Manto Azulado",t:17,d:"Este manto aumenta a sorte de quem possuí-lo.",ep:1,g:18,l:1,wd:true,fm:true,w:5,p:560};
I.u[936] = {n:"Manto de Bluish",t:17,d:"Este manto aumenta a sorte de seu portador.",ep:1,g:18,l:3,wd:true,fm:true,w:5,p:1020};
I.u[937] = {n:"Grande Manto Azulado",t:17,d:"Este manto aumenta a sorte de quem usá-lo.",ep:1,g:18,l:6,wd:true,fm:true,w:5,p:1560};
I.u[938] = {n:"Mapa do Tesouro dos Ferreiros das Sombras",t:24,d:"Este mapa indica a localização do baú dos Ferreiros das Sombras.",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Mapa do Tesouro dos Bworks",t:24,d:"Este mapa indica a localização do baú de tesouros dos Bworks: ‘O baú pode ser encontrado em um beco sem saída, no sudeste da Floresta Negra. Ele certamente estará protegido por um grupo de Bworks\'.",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Farter",t:16,d:"O Farter protege contra danos físicos.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Bandana de Komintot",t:16,d:"O Komintot aumenta a sabedoria de quem possuí-lo.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Aplainador",t:16,d:"O Aplainador interrompe danos mágicos.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Pequena Bandada de Vitalidade",t:16,d:"Esta fita de cabelo aumenta a vitalidade do seu portador.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Bandana de Vitalidade",t:16,d:"Esta bandana aumenta a vitalidade de quem usá-la.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
I.u[945] = {n:"Pequeno Manto da Sombra",t:17,d:"Este manto aumenta a sabedoria do seu portador.",ep:1,g:15,l:8,wd:true,fm:true,w:5,p:375};
I.u[946] = {n:"Manto Sombra",t:17,d:"Este manto aumenta a sabedoria de seu portador.",ep:1,g:15,l:12,wd:true,fm:true,w:5,p:600};
I.u[947] = {n:"Grande Manto das Sombras",t:17,d:"Este manto aumenta a sabedoria de quem usá-lo.",ep:1,g:15,l:19,wd:true,fm:true,w:5,p:1200};
I.u[948] = {n:"Treemanto",t:17,d:"Este magnífico manto é uma engenhosa mistura de essência de Treechnid com um bom Gobball doméstico.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Grande Bandana de Vitalidade",t:16,d:"Esta bandana aumenta a vitalidade de quem usá-la.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Agulhas e Linha",t:20,d:"Estas agulhas e esta linha lhe permitirão ser um alfaiate.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Manto de Moolobo Louco",t:17,d:"Este manto foi feito de pêlos e outros elementos orgânicos de Boolobos... Você pode sentir o cheiro de poder...",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Manto de Tofu Louco",t:17,d:"Com este manto de penas de Tofu feito à mão, você será capaz de correr mais rápido e escapar de zonas de ataque.",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"La Samoulaille",t:17,d:"A Samoulaille é um manto lendário, costurado por alfaiates para facilitar o combate corpo-a-corpo.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Capa Hillary",t:17,d:"A Capa Hillary é um tipo de capa muito apreciada por cabeleireiros. Eles adoram se enrolar nela. Ela torna o cabelo do seu portador mais resistente a choques.",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Capa Rice",t:17,d:"Este manto aumenta o alcance de ação do portador, permitindo-lhe alcançar alvos bem distantes... ou impressionar aventureiros ingênuos.",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"O Gobb",t:17,d:"O Gobb aumenta os danos e a vitalidade de seu portador. Emite um cheiro forte. Pode acontecer de um Gobball achar que você é um deles.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofusteuse",t:17,d:"Este manto é certamente uma das armas mais poderosas do mundo. Ele aumenta todas as características de seu portador.",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Cartão de Tesouro 5",t:24,d:"\"-- a fazer --\"",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Poção Wabbit",t:24,d:"Esta poção é uma cura para myxomawosis. Um gole dela e você poderá visitar com segurança a Ilha Wabbits.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Chave Wabbit",t:24,d:"Uma das três chaves que o capacitarão a entrar no Castelo Wabbit.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Chave Wabbit",t:24,d:"Uma das três chaves que o capacitarão a entrar o Castelo Wabbit.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
I.u[963] = {n:"Chave Wabbit",t:24,d:"Uma das três chaves que o capacitarão a entrar no Castelo Wabbit.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Pedra de Dopple",t:50,d:"Esta pedra vem do Mundo dos Dopples. É altamente apreciada por alguns habitantes de Amakna.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Manual do Alfaiate",t:25,d:"(Clique duplo para aprender como se tornar um Alfaiate) \nEste manual do alfaiate lhe ensinará os truques da profissão. Para aqueles desprovidos de imaginação, as primeiras páginas propõem modelos simples de se fazer.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Manto Deslumbrante",t:17,d:"Este magnífico manto aumenta os pontos de ação do portador, assim como sua vitalidade e sabedoria.",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
