I.u[397] = {n:"Óleo Gorduroso",t:60,d:"Este tipo raro de óleo é um verdadeiro elixir. Ele é tão lubrificante, que previne equipamentos e dentes de engrenagem de enferrujarem. Este é o resultado de uma inteligente mistura de óleos diferentes.",ep:4,g:69,l:32,wd:true,fm:true,w:1,p:100};
I.u[398] = {n:"Frutos de Palma",t:46,d:"Estes estranhos frutos produzem um óleo refinado quando espremidos. Pena que você não pode espremê-los por causa da sua casca que é tão dura quanto às solas das Botas Bowisse.",ep:3,g:81,l:32,wd:true,fm:true,w:1,p:10};
I.u[399] = {n:"Óleo de Gergelim",t:60,d:"Óleo de Gergelim é obtido de sementes de gergelim e pode ser distinguido dos outros por seu rico e gostoso sabor de avelãs torradas. O único problema é que ele cheira a Gobball grelhado.",ep:1,g:71,l:1,wd:true,fm:true,w:1,p:100};
I.u[400] = {n:"Amaranto",t:34,d:"O Amaranto é um tipo de cereal usado para fazer energético. Também é usado para alimentar o gado, especialmente o gado bebedor de energético.",ep:1,g:82,l:10,wd:true,fm:true,w:2,p:0};
I.u[401] = {n:"Teff",t:34,d:"A flor da planta fêmea de Teff contém todos os ingredientes ativos usados por fermentadores como resina e óleos essenciais. ‘Isso me lembra minhas aulas de biologia, embora eu nunca assistisse às aulas\', disse Gabrielle Naye, quando ela viu pela primeira vez esta descrição um pouco romântica.",ep:1,g:80,l:30,wd:true,fm:true,w:2,p:0};
I.u[402] = {n:"Fermento de Pólvora",t:48,d:"As células deste fermento não afundam, mas flutuam no energético enquanto precipita. Este fermento é particularmente raro e consequentemente caro.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[403] = {n:"Fermento Floculante",t:48,d:"É um fermento padrão, vendido por muitas lojas.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[404] = {n:"Fermento de Energético",t:48,d:"É o fermento padrão, essencial para fermentar o energético e consequentemente para todos os seres vivos que se alimentam de energético.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[405] = {n:"Malte",t:34,d:"É o nome do Amaranto germinado, o ingrediente mais importante em energéticos de qualidade. Tenha cuidado com o Malte, pois tem uma tendência estranha para absorver energético durante a fase de germinação, assim como Tot após um difícil dia de caça a Tofus.",ep:1,g:83,l:60,wd:true,fm:true,w:2,p:0};
I.u[406] = {n:"Estômago de Wo Wabbit",t:15,d:"A característica principal deste estômago é que facilmente pode se esticar. Isso ajuda muito nos problemas digestivos do Wo Wabbit causados por beber excessivamente fermentados de Cenouwawas.",ep:8,g:146,l:39,wd:true,fm:true,w:1,p:10};
I.u[407] = {n:"Unha de Prespic",t:47,d:"Nada é melhor do que uma unha de Prespic para pegar o seu dente ou fazer uma nova ponta de flecha.",ep:1,g:134,l:18,wd:true,fm:true,w:1,p:50};
I.u[408] = {n:"Dentadura de Markschafer",t:47,d:"O Markschafer tem dentes estragados pelo energético obrigando-o a usar uma dentadura. Ela custa uma fortuna, pois, primeiro, foi feita de dentes de ouro e, segundo, o bafo fétido de Chafer dá aos dentes poderes imprevisíveis.",ep:9,g:129,l:43,wd:true,fm:true,w:1,p:50};
I.u[409] = {n:"Pêlos da Barba de Bwork Mago",t:54,d:"Por razões obscuras, esses pêlos vermelhos não cheiram bem quando chove. Os Bworks Magos levam vantagem de seus poderes mágicos que poderiam ser de interesse de alguns alquimistas.",ep:4,g:131,l:23,wd:true,fm:true,w:1,p:20};
I.u[410] = {n:"Livro de Bwork Mago",t:25,d:"Este livro é um verdadeiro item de coleção. É a fonte de inspiração e tenacidade para um Bwork Mago. Cada página deste livro contém numerosos segredos sobre a anatomia de algumas criaturas em Amakna.",ep:4,g:130,l:1,wd:true,fm:true,w:1,p:100};
I.u[411] = {n:"Bico de Kwak de Gelo",t:47,d:"Graças ao seu bico extraordinariamente forte, o Kwak de Gelo pode cavar buracos no gelo por um simples prazer. Os Kwaks de Gelo são muito estranhos, não há dúvida disso.",ep:1,g:133,l:24,wd:true,fm:true,w:1,p:20};
I.u[412] = {n:"Bico do Kwak do Fogo",t:47,d:"Graças ao seu bico extraordinariamente forte, o Kwak do Fogo pode apagar brasas só pelo prazer de apagar brasas. Os Kwaks do Fogo são muito estranhos, não há dúvida disso.",ep:5,g:132,l:24,wd:true,fm:true,w:1,p:20};
I.u[413] = {n:"Bico de Kwak do Vento",t:47,d:"Graças ao bico reforçado, o Kwak do Fogo pode soltar fogo para fora, só pelo prazer de pôr para fora as brasas. Os Kwaks do Fogo são realmente estranhos, não há nenhuma dúvida sobre isso.",ep:5,g:110,l:24,wd:true,fm:true,w:1,p:20};
I.u[414] = {n:"Pena de Kwak de Gelo",t:53,d:"Um atributo distinto desta pena é a resistência ao frio. Um bom motivo para isso, você não pode encontrar Kwak de Gelo coberto no gelo.",ep:1,g:112,l:24,wd:true,fm:true,w:1,p:20};
I.u[415] = {n:"Pena do Kwak do Fogo",t:53,d:"Uma característica distintiva desta pena é que ela resiste a chamas. É por isso que você não achará um Kwak do Fogo em chamas.",ep:5,g:111,l:24,wd:true,fm:true,w:1,p:20};
I.u[416] = {n:"Pena de Kwak do Vento",t:53,d:"Uma característica distinta desta pena é que resiste a rajadas de vento. O Kwak de Vento pode agüentar nas tempestades os ventos mais terríveis...",ep:5,g:113,l:24,wd:true,fm:true,w:1,p:20};
I.u[417] = {n:"Lama de Mushd",t:15,d:"O Mushd agressivo é composto por muitos pedaços de lama juntos. A única maneira de vencê-lo é secá-lo totalmente. O que é difícil, considerando o estado de umidade dele.",ep:2,g:116,l:17,wd:true,fm:true,w:1,p:1};
I.u[418] = {n:"Cabelo da Barba do Avô do Wabbit",t:54,d:"O Avô do Wabbit tem uma barba falsa, assim como o Papai Noel, só que pior. Como ele sempre baba na frente da Avó Wabbit, os pêlos da sua barba ficam impregnados com os poderes irreconhecíveis da sua baba.",ep:8,g:114,l:39,wd:true,fm:true,w:1,p:100};
I.u[419] = {n:"Orelha do Avô do Wabbit",t:106,d:"Estas orelhas são pontudas e rígidas, e cobertas com uma bela pele desnudada grossa. É sem dúvida uma pele rara, principalmente porque não tem mau cheiro.",ep:8,g:115,l:39,wd:true,fm:true,w:1,p:1};
I.u[420] = {n:"Corda de Linho",t:15,d:"Com esta corda de linho muito resistente, você pode escolher fazer costuras bonitas e robustas ou amarrar as mãos de seus amigos e chutá-los para mostrar a eles quem é o verdadeiro mestre da guilda.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[421] = {n:"Flor de Linho",t:35,d:"A Flor de Linho pode ser azul ou branca, de acordo com o período do ano que a semente foi plantada. Em decocção ou infusão, lhe dá um sentimento incomum de bem-estar.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:0};
I.u[422] = {n:"Semente de Linho",t:58,d:"Esta minúscula semente contém muitas coisas boas. Os caçadores de Kwak usam estas brilhantes sementes para atrair kwaks para armadilhas.",ep:1,g:119,l:1,wd:true,fm:true,w:2,p:1};
I.u[423] = {n:"Linho",t:34,d:"Não existe nada especial no Caule de Linho, a não ser que ele é capaz de se endireitar 7 vezes depois de ser curvado por tempestades. Esta certamente é a razão de sua fibra ser tão flexível.",ep:1,g:122,l:40,wd:true,fm:true,w:2,p:0};
I.u[424] = {n:"Fibra de Linho",t:55,d:"É o tipo perfeito de Fibra para fazer magníficos materiais... Esta fibra é bastante rara e cara, e os tecedores amam sua alta qualidade.",ep:13,g:120,l:46,wd:true,fm:true,w:1,p:1};
I.u[425] = {n:"Sarraceno",t:34,d:"O Caule de Sarraceno pode ser usado em pesquisas, mas também é usado por tecedores que utilizam as fibras para os mais diferentes fins.",ep:1,g:121,l:70,wd:true,fm:true,w:2,p:0};
I.u[426] = {n:"Fibra de Sarraceno",t:55,d:"Esta fibra não é tão bonita, mas é bem resistente. Pode ser usada em seus momentos de sossego e reflexão.",ep:13,g:123,l:46,wd:true,fm:true,w:1,p:1};
I.u[427] = {n:"Semente de Sarraceno",t:58,d:"A semente de Sarraceno é usada para acalmar multidões de Tabis durante o cio. Tudo que você precisa fazer é administrar algumas destas sementes e eles repentinamente ficarão menos selvagens.",ep:1,g:157,l:10,wd:true,fm:true,w:1,p:10};
I.u[428] = {n:"Flor de Sarraceno",t:35,d:"Esta flor é usada para fazer poções de efeitos aleatórios. Tais efeitos podem variar de paralisia geral a invulnerabilidade para asas de Wabbits.",ep:1,g:156,l:10,wd:true,fm:true,w:1,p:0};
I.u[429] = {n:"Ponta de Flecha de Bwork Arqueiro",t:15,d:"Esta ponta de flecha enferrujada é feita de um metal raro que pode ser encontrado só nestas pontas de flechas.",ep:4,g:125,l:24,wd:true,fm:true,w:1,p:1};
I.u[430] = {n:"Osso de Chafer Invisível",t:47,d:"Este osso é invisível graças às suas propriedades especiais. Ele deve ser usado para fazer poções mágicas.",ep:1,g:126,l:23,wd:true,fm:true,w:1,p:20};
I.u[431] = {n:"Pedra de Crackler",t:51,d:"Esta pedra está quase viva, ela suga a vida das pedras preciosas que contém. Ninguém pode quebrá-la, exceto um Crackler. É perfeita para fazer um grande martelo de pedra.",ep:2,g:127,l:31,wd:true,fm:true,w:5,p:1};
I.u[432] = {n:"Mandíbula de Rib",t:47,d:"As mandíbulas de Ribs são muito boas grelhadas, mas não há muito a comer...",ep:3,g:158,l:33,wd:true,fm:true,w:1,p:100};
I.u[433] = {n:"Fêmur do Chafer Arqueiro",t:47,d:"É um osso muito estranho, particularmente friável, que exala um cheiro de caril mofado quando queimado... Isto certamente irá agradar alguns cozinheiros inescrupulosos.",ep:1,g:101,l:34,wd:true,fm:true,w:1,p:100};
I.u[434] = {n:"Casca de Treechnid",t:96,d:"Este pedaço de casca é áspero, rachado, cheio de pequenas protuberâncias e cheira estranhamente bem, assim como a pele dos pés de um Enutrof.",ep:1,g:103,l:32,wd:true,fm:true,w:1,p:1};
I.u[435] = {n:"Raiz Treechnid",t:98,d:"Este pedaço de raiz ganhou muita experiência acompanhando o Treechnid passear sobre a vegetação rasteira. Isto não explica o porquê deste pedaço de raiz ser mágico.",ep:1,g:102,l:32,wd:true,fm:true,w:1,p:1};
I.u[436] = {n:"Cajado de Raiz de Treechnid",t:4,d:"Este cajado feito de uma raiz grande é útil durante combates corpo-a-corpo. O único problema para o usuário é que ele pode regenerar suas raízes quando em contato com água...",ep:1,g:1,l:30,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,20,50,false,false],c:"CI>30&CC>5",p:2650};
I.u[437] = {n:"Broto de Treechnid",t:108,d:"Durante a puberdade, Treechnids são cobertos com brotos feios, mas cheios de seiva suculenta, rica em vitaminas. Mais tarde, esses brotos darão à luz novos brotos que darão à luz outros brotos.",ep:1,g:104,l:32,wd:true,fm:true,w:1,p:1};
I.u[438] = {n:"Cauda de Boolobo",t:65,d:"O Rabo do Boolobo e um grande tronco cabeludo são tão semelhantes que você não consegue diferenciá-los. Tenha cuidado!",ep:1,g:105,l:70,wd:true,fm:true,w:1,p:50};
I.u[439] = {n:"Dente de Boolobo",t:47,d:"Este dente afiado é, acima de tudo, apreciado como amuleto. De qualquer maneira, ele tem um odor realmente ruim.",ep:1,g:106,l:70,wd:true,fm:true,w:1,p:1};
I.u[440] = {n:"Garra de Boolobo",t:15,d:"Esta garra muito suja é usada para fazer armas perigosas.",ep:1,g:107,l:70,wd:true,fm:true,w:1,p:1};
I.u[441] = {n:"Pedra de Cobre",t:39,d:"O cobre é um metal útil para fazer armas baratas... é quase um substituto para o ouro se desprezarmos as numerosas qualidades do ouro.",ep:1,g:108,l:10,wd:true,fm:true,w:5,p:0};
I.u[442] = {n:"Bronze",t:39,d:"Este metal é freqüentemente usado na fabricação de itens decorativos. É ideal para embelezar suas armas a um baixo custo.",ep:1,g:109,l:20,wd:true,fm:true,w:5,p:0};
I.u[443] = {n:"Pedra de Kobalt",t:39,d:"O nome ‘Kobalt\' significa ‘Cobre do Diabo\' em Sadida antigo. É um metal bem apto para forjar armas leves e elegantes – ainda que letais.",ep:1,g:77,l:30,wd:true,fm:true,w:5,p:0};
I.u[444] = {n:"Estanho",t:39,d:"Estanho é um metal macio e pesado, um pouco como os Wo Wabbits, mas pior.",ep:1,g:78,l:50,wd:true,fm:true,w:5,p:0};
I.u[445] = {n:"Manganês",t:39,d:"Diferente do que as pessoas normalmente pensam, este metal não é usado para fazer goteiras, mas armas incríveis como a terrível ‘Lâmina Manganesa\' que infiltrou muitos Tofus nas Festas de Bulgur.",ep:1,g:397,l:40,wd:true,fm:true,w:5,p:0};
I.u[446] = {n:"Pedra de Bauxita",t:39,d:"Quando corretamente afiado, este metal é muito apreciado por sua cor prata e por seu corte.",ep:1,g:76,l:70,wd:true,fm:true,w:5,p:0};
I.u[447] = {n:"Carvão",t:39,d:"O carvão não tem nenhuma propriedade mágica específica, diferentemente do que podem pensar. Entretanto, ele atrai raios, conserva-o e, infelizmente, o lança em tempo ruim.",ep:5,g:75,l:1,wd:true,fm:true,w:5,p:0};
I.u[448] = {n:"Sílex",t:51,d:"Esta pedra particularmente afiada cortou as gargantas de mais de um espião descuidado.",ep:1,g:74,l:22,wd:true,fm:true,w:5,p:1};
I.u[449] = {n:"Madeira de Ébano",t:38,d:"Esta madeira deve seu nome a um engano... A única família de lenhadores que vivia nesta floresta teve uma filha chamada Bonnie. Bonnie era a única que sabia onde encontrar um tipo de árvore muito especial. Conseqüentemente, esta madeira recebeu este nome em sua homenagem: a ‘madeira de Bonnie\'. O tempo passou e com a ajuda da grafia errada, ela passou a se chamar ‘madeira de Ébano\'.",ep:7,g:73,l:70,wd:true,fm:true,w:5,p:0};
I.u[450] = {n:"Pedra de Granito",t:51,d:"Você não pode usar este mineral muito pesado, ele restringe o uso na forja. Se você tiver paciência, pode extrair pedras preciosas dele.",ep:1,g:1,l:30,wd:true,fm:true,w:20,p:1};
I.u[454] = {n:"Machado de Lenhador",t:19,d:"Este machado é essencial para lenhadores que querem trabalhar devidamente no meio profissional. Também pode protegê-los de monstros quando necessário.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:150};
I.u[455] = {n:"Martelo da Alvorada",t:7,d:"Este martelo ridiculamente pequeno foi usado por Zokrim, o camponês. Ele usou para construir uma cerca na alvorada. Ninguém sabe o motivo de Zokim construí-la na alvorada. Mas a lenda diz que ele tinha bons motivos.",ep:1,g:2,l:26,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CS>10&CI>16",p:2000};
I.u[456] = {n:"Assassino de Carvalho",t:19,d:"Este machado lhe permite cortar facilmente árvores, até as maiores. Ele é, acima de tudo, apreciado pelo seu grande peso, que permite cortar um Bwork em três. O único requisito é você ser forte o suficiente para erguer este machado!",ep:7,g:2,l:33,wd:true,fm:true,w:50,an:17,e:[5,4,1,1,40,40,false,false],c:"CS>66&CA>10",p:3150};
I.u[458] = {n:"Amuleto do Capitão Chafer",t:1,d:"O Capitão Chafer é muito sensível e distinto e sempre usa um amuleto feito dos crânios de seus primos mortos em combate. O mais estranho é que ele não tem primos...",ep:1,g:3,l:19,wd:true,fm:true,w:4,p:1200};
I.u[459] = {n:"Tábua de Freixo",t:95,d:"Esta tábua de Freixo permite aos faz-tudo construir qualquer coisa que eles queiram. Como um caixão de freixo, por exemplo.",ep:1,g:93,l:1,wd:true,fm:true,w:10,p:10};
I.u[460] = {n:"Madeira de Carvalho",t:38,d:"Esta madeira de alta qualidade é particularmente resistente. É ideal para fazer coisas como porretes, casas ou até barcos. Mas a melhor maneira de usá-la é para fazer barris de energético. (Ic!).",ep:1,g:92,l:30,wd:true,fm:true,w:5,p:0};
I.u[461] = {n:"Madeira Yew",t:38,d:"A madeira da árvore Teixo é muito forte e flexível;\r\n            por isso, é madeira de qualidade para a fabricação de arcos. É bastante difícil de achar porque os camponeses de Amakna a destroem arrancando-as. É bastante compreensível, quando os gobballs ficam de cama, comem Madeira de Teixo.",ep:1,g:94,l:50,wd:true,fm:true,w:5,p:0};
I.u[462] = {n:"Arco em Raiz de Treechnid",t:2,d:"A madeira de Treechnid ainda continua viva mesmo depois de ter sido cortada e isto a faz ser de uso muito difícil. Matar um Treechnid com um arco feito da raiz de um de seus irmãos é, sem dúvida, a melhor maneira de ridicularizar tal criatura, se você realmente quiser isso...",ep:1,g:1,l:28,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,30,50,false,true],c:"CS>10&CA>28",p:2250};
I.u[463] = {n:"Âmbar",t:50,d:"Esta magnífica pedra preciosa é feita de resina de árvore fossilizada. Às vezes, você pode achar um pequeno Moskito que ficou preso dentro dela por séculos, o que atribui mais valor a esta pedra.",ep:1,g:96,l:32,wd:true,fm:true,w:4,p:20};
I.u[464] = {n:"Âmbar de Treechnid",t:50,d:"Esta magnífica pedra preciosa é feita de resina de treechnid petrificada. No interior, você às vezes pode achar uma pequena Aracne, capturada há eras pela seiva de seu Mestre. Esta é uma morte bem merecida para este tipo de Monstro.",ep:1,g:97,l:32,wd:true,fm:true,w:5,p:40};
I.u[465] = {n:"Cristal",t:50,d:"O cristal é uma pedra translúcida e frágil. A vida é assim, nada é perfeito até no meio das pedras preciosas.",ep:1,g:98,l:50,wd:true,fm:true,w:20,p:5000};
I.u[466] = {n:"Safira",t:50,d:"Esta pedra preciosa azul é perfeita para fazer armas com efeitos mágicos. O motivo de ser azul? Talvez devido aos criadores do jogo carentes de inspiração sempre usarem esta cor para representar mana.",ep:1,g:99,l:50,wd:true,fm:true,w:20,p:5000};
I.u[467] = {n:"Rubi",t:50,d:"Esta pedra preciosa com pouco calor evoca as penas de Kwak de Fogo. Mas é tão fria quanto as penas de Kwak de Gelo.",ep:1,g:100,l:50,wd:true,fm:true,w:20,p:5000};
I.u[468] = {n:"Pão de Amakna",t:33,d:"Ainda quente do forno, este pequeno pão com um miolo macio e a casca dourada permite recuperar pontos de vida. É o tipo mais popular de pão e geralmente, o mais barato.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[469] = {n:"Varinha de Raiz de Treechnid",t:3,d:"Esta varinha usa as propriedades mágicas da Raiz de Treechnid. Cuidado com os efeitos negativos desta varinha viva, às vezes pode virar contra seu dono.",ep:1,g:3,l:33,wd:true,fm:true,w:20,an:11,e:[5,4,2,2,50,40,false,true],c:"CI>33&CW>10",p:3100};
I.u[470] = {n:"Madeira de Olmo",t:38,d:"Antigamente, um tipo comum de madeira, a madeira de Olmo agora é muito procurada. Há muito tempo, um feitiço terrível chamado Grafioze foi conjurado por um poderoso Bwork Mago do pior tipo, dizimando todos os Olmos.",ep:3,g:140,l:90,wd:true,fm:true,w:5,p:0};
I.u[471] = {n:"Madeira de Bordo",t:38,d:"As folhas de bordo inspiram pessoas não muito criativas para elaboração de uma bandeira. O xarope adiciona sabor às panquecas. Quanto à madeira de bordo, ainda estamos pesquisando seu uso.",ep:1,g:153,l:40,wd:true,fm:true,w:5,p:0};
I.u[472] = {n:"Madeira de Carpino",t:38,d:"É chamada de Madeira de Carpino devido aos Sadidas sempre ouvirem uma trombeta sobre a árvore. Aparentemente, ajuda encontrar-se... Você pode encontrar mais informações sobre o assunto no Livro do Bwork Mago...",ep:1,g:138,l:80,wd:true,fm:true,w:5,p:0};
I.u[473] = {n:"Madeira de Castanheiro",t:38,d:"O cheiro da madeira de Castanheiro é um repelente de moscas, não funciona maravilhas em moscas que adoram castanheiros e/ou perderam o olfato... Quando você realmente pensa sobre isto, você vê que madeira de castanheiro não repele mosca nenhuma...",ep:1,g:86,l:10,wd:true,fm:true,w:5,p:0};
I.u[474] = {n:"Madeira de Cerejeira",t:38,d:"Este tipo de madeira é apreciado pelos marceneiros por causa de sua textura densa e a cor marrom-avermelhada que ela adquire com o tempo.",ep:1,g:139,l:60,wd:true,fm:true,w:5,p:0};
I.u[476] = {n:"Madeira de Noz",t:38,d:"A madeira de noz é muito usada em desenvolvimento de móveis.",ep:1,g:95,l:20,wd:true,fm:true,w:5,p:0};
I.u[477] = {n:"Sangue de Dragão Porco",t:15,d:"Este frasco está cheio de um sangue que costumava conferir poderes diabólicos ao Dragão Porco. Para ser consumido com moderação ou para ser usado como ingrediente do chouriço de Dragão Porco, se você gostar disto, claro.",ep:2,g:544,l:70,wd:true,fm:true,w:10,p:100};
I.u[478] = {n:"Podador de Charme",t:19,d:"Este machado deve seu nome à Woodee, a Lenhadora... Ela sabia perfeitamente como usar seu charme para desviar a atenção dos lenhadores e, assim, manter secreta a localização dos raros feitiços que ela queria preservar.",ep:7,g:3,l:47,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,40,40,false,false],c:"CW>20&CI>20&CC>20",p:5900};
I.u[479] = {n:"Marfim",t:47,d:"Marfim é bastante procurado pelos coletores, devido à sua lendária brancura. Ferreiros também se entusiasmam pelo marfim, pois ele é essencial na criação de armas letais. É claro que o marfim é muito popular na região de Amakma.",ep:1,g:88,l:40,wd:true,fm:true,w:10,p:100};
I.u[480] = {n:"Minério Estranho",t:39,d:"Este minério foi extraído de uma pedreira misteriosa e desconhecida. Diferente dos itens mais estranhos que você pode encontrar em Amakna, este não é mágico de nenhuma maneira.",ep:1,g:90,l:24,wd:true,fm:true,w:5,p:100};
I.u[481] = {n:"Crânio de Dragão Porco",t:47,d:"Apesar de sua pequena capacidade, este crânio é um verdadeiro artigo de coleção. Sua semelhança com o crânio de um seguidor de Iop permitiu a muitos estudantes de medicina explicar a origem das debilidades intelectuais entre a classe dos Iops.",ep:2,g:91,l:70,wd:true,fm:true,w:50,p:100};
I.u[482] = {n:"Pá de Teuze",t:8,d:"Um Enutrof que bebeu muitas na taverna, percebeu um dia que esta pá, originalmente projetada para o trabalho de construção, também era uma excelente arma para lutas de bebedores de energético.",ep:1,g:8,l:27,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>7&CC>20",p:2200};
I.u[483] = {n:"Grande Pá de Teuze",t:8,d:"Um Enutrof faz o dia com esta pá;\r\n            originalmente criada para o trabalho de construção, mostrou-se uma excelente arma para bater em bebedores de energético.",ep:1,g:8,l:29,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>9&CC>20",p:2500};
I.u[484] = {n:"Poderosa Pá Teuze",t:8,d:"Um Enutrof que já estava cheio na Pousada um dia percebeu que esta pá, originalmente desenvolvida para trabalho de construção, era uma excelente arma.",ep:1,g:8,l:31,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>11&CC>20",p:2800};
I.u[485] = {n:"Cueca de Couro do Chafer Lançador",t:56,d:"Quando o inverno chega, o Chafer Lançador nunca sai sem sua cueca de couro, o que permite que ele mantenha suas juntas aquecidas e distraia seus inimigos se for necessário.",ep:1,g:152,l:44,wd:true,fm:true,w:10,p:100};
I.u[486] = {n:"Couro de Javali",t:56,d:"Este couro particularmente resistente cheira como um javali macho no cio. Os nativos usam esta característica para prender as fêmeas que são muito estúpidas para estragar estes planos enganosos.",ep:1,g:16,l:14,wd:true,fm:true,w:10,p:1};
I.u[487] = {n:"Couro de Dragão Porco",t:56,d:"Para continuar fingindo que é um dragão, o Dragão Porco queimou os pêlos de seu couro, o que explica, de alguma maneira, o cheiro de porco assado que exala deste couro.",ep:2,g:142,l:70,wd:true,fm:true,w:10,p:6000};
I.u[489] = {n:"Lupa",t:20,d:"Com esta lupa, você poderá analisar os elementos do local. Tesouros serão seus!",ep:1,g:3,l:1,wd:true,fm:true,w:10,an:3,e:[1,6,1,1,100,10,false,false],p:10};
I.u[490] = {n:"Frasco",t:20,d:"Este Frasco, um item essencial para qualquer alquimista que se preze, manterá seguras suas melhores poções.",ep:1,g:2,l:1,wd:true,fm:true,w:3,an:4,e:[1,6,1,1,200,2,false,false],p:10};
I.u[491] = {n:"Montador",t:5,d:"Item essencial para Joalheiro fazer jóias.",ep:1,g:16,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[492] = {n:"O Amassador",t:20,d:"Ferramenta essencial se você planejar ser um padeiro-confeiteiro.",ep:1,g:1,l:1,wd:true,fm:true,w:8,an:4,tw:true,e:[50,6,1,1,500,10,false,false],p:10};
I.u[493] = {n:"Martelo do Ferreiro de Martelo",t:7,d:"Ferramenta essencial para fazer martelos.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[494] = {n:"Martelo do Ferreiro de Espada",t:7,d:"Ferramenta essencial para fazer espadas.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[495] = {n:"Martelo de Ferreiro de Adaga",t:7,d:"Uma ferramenta essencial para fazer adagas.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[496] = {n:"Martelo do Ferreiro de Pá",t:7,d:"Ferramenta essencial para fazer pás.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[497] = {n:"Picareta de Mineiro",t:21,d:"Ferramenta indispensável para a coleta de minerais.",ep:1,g:1,l:1,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[498] = {n:"Talhador de Cajado",t:5,d:"Uma ferramenta essencial para fazer cajados.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[499] = {n:"Varinha Slasher",t:5,d:"Uma ferramenta essencial para fazer varinhas.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[500] = {n:"Talhador de Arco",t:5,d:"Uma ferramenta essencial para a fabricação de arco.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[501] = {n:"Seiva Trabalhada de Treechnid",t:15,d:"Esta seiva melada foi modificada por um famoso Alquimista que queria dar vida às Raízes de Treechnids. Obviamente, este tipo de seiva deve ser manejado com cuidado.",ep:2,g:162,l:30,wd:true,fm:true,w:2,p:50};
I.u[502] = {n:"Faca de Corte Yew",t:19,d:"Este era o único machado que pode cortar árvores encantadas. O que quer dizer que se pode cortar tudo que é encantado, vivo ou não.",ep:1,g:4,l:17,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,50,false,false],c:"CS>10&CI>35",p:950};
I.u[515] = {n:"Boulgourde da Clareira",t:19,d:"Este machado pertenceu ao famoso Lenhador Brouce Boulgoure. Ele era casado com Kassiopee Baine, filha de outro grande Lenhador. Esta arma freqüentemente o protegia à noite, quando ele cortava florestas inteiras.",ep:7,g:5,l:62,wd:true,fm:true,w:60,an:17,tw:true,e:[15,6,1,1,50,40,false,false],c:"CI>124&CC>30&CV>10",p:10100};
I.u[519] = {n:"Cura Mágica",t:48,d:"Este pó é feito de Linho e Pão. Entretanto, não explica o motivo de ser mágico.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[520] = {n:"Pão de Sementes de Papoula",t:33,d:"É sempre difícil fazer esse tipo de pão por causa da natureza do seu ingrediente principal. Acredite ou não mas as pessoas dizem que os padeiros que sentem este cheiro têm tendência a estranhos sintomas como ficar dançando na padaria.",ep:1,g:10,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[521] = {n:"Pão de Semente de Gergelim",t:33,d:"Os mais ousados Kwaks geralmente se vestem de padeiros para roubar sementes de gergelim mas, felizmente, eles somente enganam os padeiros Iop.",ep:1,g:11,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[522] = {n:"Pão de Sementes de Linho",t:33,d:"Este pão é rico em proteínas, mas é insípido. As coisas são assim, a vida é uma questão de escolhas.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[524] = {n:"Pão com Avelã",t:33,d:"Este pão com sabor delicado não contém corante, nem conservante;\r\n            diferente da Geléia Real.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[526] = {n:"Pão de Ceral",t:33,d:"Este pão multicereais contém proteínas suficientes para fazer um Chafer voltar à vida.",ep:1,g:6,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[527] = {n:"Pão de Noz",t:33,d:"Primeiro as nozes são torradas e amaciadas. Então, o pão é cozido na madeira de noz.",ep:4,g:8,l:40,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[528] = {n:"Pão Integral",t:33,d:"Este pão Integral é um produto de qualidade para discernir paladares.",ep:1,g:7,l:20,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[529] = {n:"Farinha de Amaranto",t:52,d:"Esta farinha é feita no moinho, moendo-se grãos de Amaranto. Ela dá certa leveza sem igual ao miolo do pão, a menos que você use alguma mágica oculta enquanto faz seus pães.",ep:1,g:256,l:1,wd:true,fm:true,w:2,p:0};
I.u[530] = {n:"Farinha de Centeio",t:52,d:"Esta farinha herda todas as características do centeio. De acordo com a lenda, o centeio que germina ao amanhecer nunca amadurece. Além disso, alguns camponeses procriam ao amanhecer, esperando que as futuras crianças nunca envelheçam.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[531] = {n:"Farinha de aveia",t:52,d:"Esta farinha não cresce quando assada, o que deixa o pão muito denso, ideal para quando você tiver que arremessar pão aos monstros.",ep:1,g:250,l:1,wd:true,fm:true,w:2,p:0};
I.u[532] = {n:"Centeio",t:34,d:"Este cereal escuro cresce em condições difíceis. É um dos poucos cereais capazes de sobreviver a períodos de extrema seca.",ep:1,g:82,l:50,wd:true,fm:true,w:2,p:0};
I.u[533] = {n:"Aveia",t:34,d:"Este tipo de cereal é usado para alimentar jovens Tabis, muito jovens para ruminar. Os camponeses, no entanto, dão isto avarosamente, porque a aveia, às vezes, causa aerofobia em animais com estômago sensível.",ep:1,g:154,l:20,wd:true,fm:true,w:2,p:0};
I.u[534] = {n:"Farinha de Malte",t:52,d:"Esta farinha branca é feita de grãos moídos de cevada, o que dá um gosto ácido ao pão, ou o melhor, gosto de energético estragado. Pode ser útil para desviciar progressivamente do energético. E pedaços de pão que foram feito com esta farinha antes de colocar na forma, dizem que facilita o efeito de uma noite agitada. Especialmente se você mesmo se embebedar.",ep:1,g:255,l:1,wd:true,fm:true,w:2,p:0};
I.u[535] = {n:"Farinha de Teff",t:52,d:"Esta farinha dá um gosto delicado de energético ao pão, sem ter de desperdiçar energético no processo. A natureza é uma coisa maravilhosa, não acha?",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[536] = {n:"Pão com flocos de aveia",t:33,d:"Este pão com um leve miolo é ideal para as pessoas que foram dotadas pela Mãe Natureza de um estômago minúsculo...",ep:1,g:5,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[537] = {n:"Batata",t:68,d:"Falando de maneira geral, quando você encontra uma batata, significa que você está no meio de um campo ou de um calabouço.",ep:1,g:135,l:1,wd:true,fm:true,w:20,p:10};
I.u[538] = {n:"Batatas Peladas",t:68,d:"Essas batatas peladas são comestíveis.",ep:1,g:136,l:1,wd:true,fm:true,w:20,p:10};
I.u[539] = {n:"Pão de Centeio",t:33,d:"Este pão é preparado com farinha de centeio de uma coloração marrom com partes moles e um sabor açucarado.",ep:1,g:9,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[543] = {n:"Pedra de Diamante",t:51,d:"Quando corretamente polida, esta pedra torna-se um magnífico diamante.",ep:1,g:144,l:30,wd:true,fm:true,w:20,p:15};
I.u[544] = {n:"Pedra de Esmeralda",t:51,d:"Quando corretamente polida, esta pedra se torna uma magnífica Esmeralda.",ep:1,g:145,l:30,wd:true,fm:true,w:20,p:15};
I.u[545] = {n:"Pedra de Cristal",t:51,d:"Quando corretamente polida, esta pedra torna-se um magnífico Cristal.",ep:1,g:141,l:30,wd:true,fm:true,w:20,p:15};
I.u[546] = {n:"Pedra de Safira",t:51,d:"Quando devidamente polida, esta pedra é uma Safira magnífica.",ep:1,g:151,l:30,wd:true,fm:true,w:20,p:15};
I.u[547] = {n:"Pedra de Rubi",t:51,d:"Quando devidamente polida, esta pedra é um Rubi magnífico.",ep:1,g:150,l:30,wd:true,fm:true,w:20,p:15};
I.u[548] = {n:"Poção da Lembrança",t:12,d:"Use a Poção de Lembrança para voltar ao seu último Ponto de Salvamento.",ep:1,g:17,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[577] = {n:"Gadanha de Camponês",t:22,d:"Esta gadanha não pode ser uma arma apavorante, pois é um pouco rústica e não muito bem afiada... Por outro lado, é a ferramenta perfeita para cortar.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[578] = {n:"Pedra de Amolar",t:51,d:"Eu nunca lançarei a primeira pedra...",ep:2,g:127,l:1,wd:true,fm:true,w:20,p:1};
I.u[579] = {n:"Cortador de Couro",t:5,d:"Ferramenta essencial para fazer sapatos e cintos.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[580] = {n:"Poção Invasão de Gueto",t:12,d:"Com esta poção, você recuperará alguns Pontos de Vida.",ep:1,g:18,l:10,wd:true,fm:true,w:1,u:true,p:20};
I.u[582] = {n:"Farinha Branca",t:52,d:"Foi preciso vários cereais para fazer esta farinha, que é muito apreciada pela sua qualidade de panificação. À primeira vista, você não veria a diferença de qualidade.",ep:1,g:7,l:1,wd:true,fm:true,w:2,p:0};
I.u[583] = {n:"Farinha do Beijo Marrom Cinzento",t:52,d:"Esta farinha quase branca leva o nome de seu inventor, uma camponesa que adorava dar grandes beijocas, cobrindo o rosto com farinha. Muito travessa!",ep:1,g:7,l:20,wd:true,fm:true,w:2,p:0};
I.u[586] = {n:"Farinha de Camponês",t:52,d:"Shika Ingalsse teve a idéia de criar esta farinha popular enquanto batia na esposa do Brouce Boulgoure com sacos de farinha. Algumas vezes, brigas de gato são mais do que simples entretenimento.",ep:1,g:258,l:30,wd:true,fm:true,w:2,p:0};
I.u[587] = {n:"Farinha Enriquecida",t:52,d:"Esta farinha é uma mistura de vários tipos de cereais e portanto é uma farinha enriquecida, muito útil para pão integral.",ep:1,g:259,l:40,wd:true,fm:true,w:2,p:0};
I.u[592] = {n:"Corda de Ivan Nowé",t:2,d:"Este arco uma vez pertenceu a Ivan Nowé, um ousado discípulo de Cra que já tinha roubado mais do que um Tofu vagabundo. Este arco pode infligir danos surpreendentes que confundem os inimigos e depois os mata.",ep:7,g:1,l:36,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,15,50,false,true],c:"CS>30&CA>36",p:3600};
I.u[593] = {n:"Orquídea Freyesque",t:35,d:"Esta flor é tão rara quanto bonita. Isto não será surpreendente quando você souber que Sapos as usam para alimentar a prole deles.",ep:1,g:192,l:40,wd:true,fm:true,w:1,p:0};
I.u[594] = {n:"Edelvais",t:35,d:"Esta flor é tão rara quanto bonita. Não é incrível quando você sabe que a magia dela é tão poderosa que pode ressuscitar pessoas mortas.",ep:1,g:191,l:50,wd:true,fm:true,w:1,p:0};
I.u[595] = {n:"Aplainador de Joiner",t:20,d:"Esta ferramenta permite que marceneiros derrubem troncos de árvores para fazer tábuas e vigas... É uma profissão bastante interessante para quem adora construir casas de madeira.",ep:1,g:19,l:1,wd:false,fm:true,w:1,e:[1,4,1,1,100,100,false,false],p:10};
I.u[596] = {n:"Vara de Pescar Curta",t:20,d:"Esta pequena vara de pesca é perfeita para capturar pequenos peixes em lagos.",ep:1,g:8,l:1,wd:true,fm:true,w:1,an:18,e:[1,4,1,1,100,100,false,false],p:200};
I.u[597] = {n:"Rede Simples de Captura",t:99,d:"Extremamente resistente, esta rede possibilita a você capturar as mais selvagens montarias, desde que primeiro você distraia e hipnotize-a.",ep:20,g:1,l:1,wd:true,fm:true,w:1,an:0,p:10};
I.u[598] = {n:"Grawn",t:41,d:"Os Grawns são apreciados por seu gosto refinado e coloração rosa. Mesmo assim, são odiados pelo seu lendário tempero ruim e antenas em forma de gomina.",ep:1,g:292,l:1,wd:true,fm:true,w:1,p:10};
I.u[600] = {n:"Kralamor",t:41,d:"O Kralove parece bobo, mas não tem nada disso;\r\n            por detrás de seus olhos doentios, há um predador terrível, muito agressivo com estranhos.",ep:2,g:309,l:20,wd:true,fm:true,w:1,p:10};
I.u[602] = {n:"Tubarão Martelo-Foice",t:41,d:"Este tubarão vermelho é um tubarão ativista com instinto de grupo;\r\n            não há consciência do indivíduo no grupo mesmo se o chefe deles, o tubarão Stakanoviou, é idolatrado.",ep:2,g:322,l:80,wd:true,fm:true,w:2,p:1};
I.u[603] = {n:"Peixe-Gato",t:41,d:"O peixe-gato tem duas características;\r\n            tem bigode e faz barulho debaixo d\'água para assustar os peixes voadores.",ep:1,g:277,l:1,wd:true,fm:true,w:1,p:50};
I.u[607] = {n:"Truta Lamacenta",t:41,d:"A Truta Lamacenta está, de alguma maneira, relacionada ao salmão agressivo da Ilha da Lua. Esta truta é deliciosa tanto crua quanto cozida...",ep:1,g:395,l:1,wd:true,fm:true,w:1,p:50};
I.u[610] = {n:"Amuleto de Caranguejo",t:1,d:"Este delicado, porém original, amuleto esbranquiçado é feito de Caranguejo.",ep:1,g:30,l:24,wd:true,fm:true,w:2,p:1800};
I.u[616] = {n:"Amuleto do Pescador",t:1,d:"Este amuleto, enfeitado com escamas de peixe, traz sorte ao seu portador quando ele sai para o mar em dias tempestuosos.",ep:1,g:29,l:22,wd:true,fm:true,w:2,p:2000};
I.u[617] = {n:"Amuleto de Pirata",t:1,d:"Vários navegadores ficaram impressionados com este amuleto aterrorizante. Tudo que você tem de fazer é colocá-lo para se tornar um temido combatente.",ep:1,g:20,l:41,wd:true,fm:true,w:2,p:4500};
I.u[619] = {n:"Cajado do Mestre dos Gobballs",t:4,d:"Este cajado permitiu que Farle Ingalsse, criador de Gobballs, invocasse facilmente Tofus para manter os flocos em segurança. Com o passar dos dias, o cajado provou ser uma arma de combate ideal.",ep:7,g:6,l:85,wd:true,fm:true,w:20,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>60&CW>20&CA>40",p:10000};
I.u[620] = {n:"Espada de Corte de Kralamor",t:6,d:"Graças a esta espada, o famoso marinheiro Mobby Diqueriveurse fatiou os tentáculos do não menos famoso Kralamor Gigante da Ilha da Lua, conhecido por sufocar marinheiros eufóricos.",ep:1,g:8,l:61,wd:true,fm:true,w:50,an:14,e:[10,7,1,1,50,50,false,false],c:"CV>60&CW>60",p:9900};
I.u[629] = {n:"Chapéu Pontudo",t:16,d:"Seu herói será a Rainha do Equilíbrio com esse magnífico chapéu.",ep:5,g:1,l:21,wd:true,fm:true,w:5,p:1400};
I.u[638] = {n:"Amuleto de Pescador de Salmão",t:1,d:"Pescar um Somoon é quase um milagre, mas não se preocupe, com este amuleto em volta do pescoço, não há palavras como \"não posso\".",ep:12,g:24,l:35,wd:true,fm:true,w:5,p:2500};
I.u[639] = {n:"Amuleto das Profundezas",t:1,d:"O Amuleto das Profundezas foi encontrado nos destroços submersos do navio do renomado pescador Kralamorus, Moby Diqueriveurse, também famoso por suas piadas ruins no bar dos piratas.",ep:14,g:22,l:47,wd:true,fm:true,w:5,p:6000};
I.u[640] = {n:"Arco de Praia",t:2,d:"Este arco permitiu aos pescadores limpar as praias, matando os animais daninhos das redondezas... dos Piratas Trancam Janelas, sem ter de levantar de suas cadeiras...",ep:14,g:38,l:46,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,10,30,45,false,true],c:"CA>46",p:5600};
I.u[641] = {n:"Algodão",t:15,d:"Este algodão é tão macio quanto a pele de uma jovem Ecaflip, tão branco quanto uma nuvem de primavera, mas tão delicado quanto uma pena de Tofu.",ep:1,g:657,l:6,wd:true,fm:true,w:1,p:500};
I.u[642] = {n:"Casulo do Bicho-da-Seda",t:15,d:"Este casulo esbranquiçado pode ser desatado para obter 100% de puro filamento de seda. Foi dito também que o aventureiro Harry Hane o utilizou para escapar do labirinto Dark Vlad.",ep:1,g:489,l:6,wd:true,fm:true,w:1,p:100};
I.u[643] = {n:"Fio de Seda",t:15,d:"Considerando a delicadeza e flexibilidade deste Fio, você não o achará em nenhum outro lugar. Seda é, além disso, o tipo favorito de tecido usado pelo Chafer para sua roupa íntima de luta.",ep:1,g:486,l:5,wd:true,fm:true,w:1,p:100};
I.u[646] = {n:"Pêlo de Tiwabbit Preto",t:54,d:"Este pêlo preto não mostra a sujeira. Esta é uma vantagem que interessará alguns heróis não tão aficionados por higiene e flerte. O único problema é que estes pêlos se desprendem com suor abundante e corrosivo.",ep:8,g:195,l:11,wd:true,fm:true,w:1,p:50};
I.u[648] = {n:"Pêlo de Wabbit",t:54,d:"Este tipo de cabelo não é muito apreciado por experientes Alfaiates, mas tem a virtude de repelir moskitos por causa de seu aroma de Citronela.",ep:8,g:196,l:18,wd:true,fm:true,w:1,p:1};
I.u[649] = {n:"Pêlo de Wo Wabbit",t:54,d:"Este tipo de pêlo é tão gorduroso que pode ser usado pra fazer panos à prova de água.",ep:8,g:197,l:39,wd:true,fm:true,w:1,p:40};
I.u[650] = {n:"Pelo do Avô do Wabbit",t:54,d:"Este cabelo de malodourous raramente é usado por um costureiro porque tem uma tendência a cachear em contato com suco de cenouwawa.",ep:8,g:198,l:39,wd:true,fm:true,w:1,p:50};
I.u[651] = {n:"Tecido de Boolobo",t:55,d:"Este tecido feito de pêlos de Boolobo é muito raro. É forte o suficiente para resistir a qualquer tipo de agressão física e até mágica.",ep:1,g:199,l:70,wd:true,fm:true,w:1,p:100};
I.u[652] = {n:"Tecido de Javali",t:55,d:"Este tecido feito de pêlos de Javali é áspero e malcheiroso... mas protege eficazmente contra danos físicos.",ep:1,g:220,l:13,wd:true,fm:true,w:1,p:50};
I.u[653] = {n:"Tecido de Prespic",t:55,d:"Sob as suas unhas o Prespic tem um pêlo vermelho macio que libera um cheiro desagradável em dias de chuva. Felizmente, nunca chove em Amakna. Não use esse tecido para fazer sunga.",ep:1,g:661,l:17,wd:true,fm:true,w:1,p:100};
I.u[654] = {n:"Tecido de Wabbit",t:55,d:"Este tecido saiu dos cabelos do Wabbit Avô e é muito espesso e também irritante, parecido uma lagarta grande e peluda.",ep:8,g:15,l:18,wd:true,fm:true,w:1,p:100};
I.u[657] = {n:"Cajado do Mestre dos Tofus",t:4,d:"Este cajado permitiu a Shika Ingalsse, uma criadora de Tofus, invocar facilmente Tofus que mantinham os rebanhos seguros. Com o passar dos dias, este cajado provou ser uma excelente arma de luta.",ep:7,g:6,l:56,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>40&CW>10&CS>30",p:5600};
I.u[658] = {n:"Cajado de Mestre Tabi",t:4,d:"Este cajado permitiu a Gramine Ingalsse, uma criadora de Tabis, invocar facilmente Tofus que mantinham os rebanhos seguros. Com o passar dos dias, o cajado provou ser uma excelente arma de luta.",ep:7,g:6,l:34,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>20&CW>5",p:3400};
I.u[666] = {n:"Purê Falho",t:15,d:"Originalmente sinônimo com falha culinária, este prato é dado quando é aparente que um erro foi feito, não importa sua origem.",ep:0,g:116,l:1,wd:false,fm:true,w:0,p:0};
I.u[670] = {n:"Agrame",t:22,d:"Esta gadanha uma vez pertenceu a Gramine Ingalsse, uma das melhores mulheres ceifadoras de trigo de Amakna. Seu lendário jeito de andar permitiu a ela separar as pernas de muitos homens descuidados.",ep:0,g:1,l:36,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,35,45,false,false],c:"CS>10",p:3600};
I.u[671] = {n:"Fergussonne",t:22,d:"A Fergussonne é uma gadanha lendária, forjada por Massee Fergussonne, tia-avó de Farle Ingalsse, que só confia em gadanhas de madeira de tronco, muito agradável de usar.",ep:0,g:1,l:40,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,45,45,false,false],c:"CS>20&CV>20",p:4400};
I.u[672] = {n:"Gadanha do Ceifador de Sorgo",t:22,d:"Esta gadanha foi originalmente criada para cortar sorgo, mas os fazendeiros logo perceberam que era afiada o bastante para cortar qualquer coisa que ele quisessem...",ep:0,g:1,l:18,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,45,45,false,false],c:"CS>5",p:1100};
I.u[673] = {n:"Devorador de Castanheira",t:19,d:"Este machado não tem nenhuma particularidade, exceto sua leveza natural, devido à madeira de Castanheiro. Assim sendo, ele tem um punho tão leve quanto uma pena de um jovem Tofu Maléfico.",ep:1,g:6,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>8&CA>3",p:400};
I.u[674] = {n:"Divisor de Cereja",t:19,d:"‘Este machado só tem vantagens\'. Este era o lema famoso de Brouce Boulgoure – Madeireiro famoso. Seu cabo feito de cerejeira, emite vibrações quando você está cortando árvores ou rachando crânios.",ep:1,g:7,l:32,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>40",p:2900};
I.u[675] = {n:"Cortador de Nozes",t:19,d:"Este machado tem uma aparência simples, mas não o faz menos eficiente. Brouce Boulgoure foi o Madeireiro que ganhou a competição de Cortes de Anões Bworks com esta ferramenta. O qual nos conta muito bem sobre a eficiência desse machado.",ep:1,g:8,l:21,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>30",p:1350};
I.u[676] = {n:"Devorador de Árvore de Bordo",t:19,d:"Este machado nunca enferruja, poupa você de surpresas desagradáveis quando lenhadores ambiciosos começam a cuspir na lâmina após trabalhar duro em um longo dia cortando árvores.",ep:1,g:10,l:25,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CA>30",p:1850};
I.u[677] = {n:"Manto de Pirata",t:17,d:"Este manto uma vez pertenceu a Zokrim, um velho pirata. Ele ter ser sem sorte...",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:1};
I.u[678] = {n:"Pergaminho de Marfim",t:13,d:"(Clique duas vezes para ganhar experiência)\nCom este pergaminho, você ganhará Experiência sem correr riscos.",ep:1,g:3,l:25,wd:true,fm:true,w:1,u:true,p:1};
I.u[679] = {n:"Pergaminho Branco",t:13,d:"(Duplo clique para ganhar experiência) \nCom este pergaminho, você ganhará experiência.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[680] = {n:"Pergaminho Dourado",t:13,d:"(Clique duas vezes para ganhar experiência)\nCom este pergaminho, você ganha experiência sem correr nenhum risco.",ep:1,g:3,l:50,wd:true,fm:true,w:1,u:true,p:1};
I.u[682] = {n:"Gadanha do Ceifador de Arroz",t:22,d:"Esta gadanha foi originalmente criada para cortar arroz, mas os fazendeiros logo perceberam que era afiada o bastante para cortar qualquer coisa que ele quisessem...",ep:0,g:1,l:1,wd:true,fm:true,w:1,an:17,e:[1,1,1,1,1,1,false,false],p:1};
I.u[683] = {n:"Pequeno Pergaminho de Força",t:76,d:"(Clique duas vezes para ganhar força)\nEste pergaminho lhe permite aumentar a força de maneira definitiva e segura, mas tenha cuidado, você não pode usá-lo se sua força for maior que 25.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<25",u:true,p:1000};
I.u[684] = {n:"Pergaminho de Feitiços",t:76,d:"(Clique duas vezes para ganhar Pontos de Feitiço)\nCom este pergaminho você pode seguramente aumentar seus Pontos de Feitiço em definitivo.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:15000};
I.u[686] = {n:"Pequeno Pergaminho de Inteligência",t:76,d:"(Clique duas vezes para ganhar inteligência)\nEste pergaminho lhe permite aumentar a inteligência de maneira definitiva e segura, mas tenha cuidado, você não pode usá-lo se sua inteligência for maior que 25.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<25",u:true,p:1000};
I.u[690] = {n:"Farinha de Linho",t:52,d:"Esta farinha é muito estranha;\r\n            não é feita de cereais, o que explica o motivo de ela não parecer com qualquer outro tipo de farinha.",ep:1,g:254,l:1,wd:true,fm:true,w:2,p:0};
I.u[691] = {n:"Fermento Mágico",t:48,d:"Primeiro, este fermento deixa tudo subir, mesmo que não possa subir. Então, ele transforma comida não mágica em comida mágica.",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:50};
I.u[692] = {n:"Pão Consistente",t:33,d:"Este Pão é engordurado com uma parte macia marrom porque ele é feito com Farinha de Linho. Muito rica em óleos essenciais, ela no entanto tem um gosto ruim.",ep:1,g:12,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[694] = {n:"Dofus Carmesim",t:23,d:"Ignemikhal, o Dragão do Fogo, que criou o Dofus Púrpuro. O mínimo que podemos dizer deste ovo é que ele cheira a enxofre – mas também cheira a muitas outras coisas...",ep:1,g:1,l:6,wd:true,fm:true,w:5,p:500000};
I.u[695] = {n:"Pergaminho de Lenhador",t:13,d:"(Clique duas vezes para ganhar Pontos de Experiência)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[696] = {n:"Touca Suja",t:16,d:"Apesar da aparência brega, a Touca-Suja é muito eficiente durante as lutas, pelo menos para um mero chapéu.",ep:1,g:2,l:20,wd:true,fm:true,w:4,p:1300};
I.u[697] = {n:"Makroute",t:16,d:"Makroute é um cachorro muito carinhoso... Ele nunca sai das costas de seus novos amigos e sempre volta para casa...",ep:2,g:3,l:6,wd:true,fm:true,w:6,p:30000};
I.u[698] = {n:"Sortingat Hogwat",t:16,d:"O Sortingat Hogwat vem de uma famosa Escola de Magia. Esta criatura vivente conheceu os grandes mágicos de nosso tempo, como a Sra. Magoa AlaGale, Sr. Doublegore e o renomado Remy Krokeur.",ep:1,g:4,l:33,wd:true,fm:true,w:6,p:3000};
I.u[699] = {n:"O Troma",t:16,d:"O Troma é tão desagradável quanto um Eraserhead feito de pêlos de Bituft, e isto realmente diz algo. (Se você não souber com o que um Eraserhead feito de pêlos de Bituft se parece, consulte os grandes livros de Hen Pens).",ep:1,g:5,l:22,wd:true,fm:true,w:10,p:1525};
I.u[700] = {n:"Pandawa",t:16,d:"Hum, o Pandawa, mas que cabeça grande que ele tem! Assim como esse Makroute, ele passa o tempo todo na cabeça do dono. Ele não precisa se mover como quando ele está em forma, ele pode até mesmo roubar comida do seu carregador.",ep:2,g:6,l:6,wd:true,fm:true,w:10,c:"PG!10",p:12000};
I.u[701] = {n:"O Oiram",t:16,d:"O Oiram tem muitos entusiastas em todo o mundo graças à sua aparência refinada... Este chapéu pertenceu a um encanador que passou seu tempo correndo e pulando...",ep:1,g:7,l:22,wd:true,fm:true,w:12,c:"PG!10",p:1525};
I.u[702] = {n:"Kritter",t:16,d:"Este crânio de demônio, reconstruído de vários ossos, tornando-o gracioso e elegante... Suas amigas sentirão inveja...",ep:1,g:8,l:30,wd:true,fm:true,w:9,c:"PG!10",p:2600};
I.u[703] = {n:"Dora",t:16,d:"Este chapéu, que parece com uma cesta de frutas feita de vime de cabeça para baixo, é, na realidade, uma cesta mágica de frutas de cabeça para baixo. Certamente impressionará pessoas ao seu redor, especialmente se elas forem aprendizes de Bworks Magos.",ep:2,g:9,l:36,wd:true,fm:true,w:20,p:3550};
I.u[704] = {n:"Dantgoule",t:16,d:"Com este chapéu feito das cuecas de couro de Chafer, a bwork maga não resistirá a você. Claro que você conhece estas damas: elas usam barbas vermelhas e são famosas por sua feminilidade transbordante.",ep:2,g:10,l:36,wd:true,fm:true,w:10,p:3550};
I.u[705] = {n:"Máscara Tromatizante",t:16,d:"Você precisa deste magnífico côco com buracos para ficar traumatizado. Nós lembramos ao usuário que uma palha, assim como bebidas frescas estão à sua disposição no interior.",ep:12,g:11,l:47,wd:true,fm:true,w:10,p:6000};
I.u[706] = {n:"Bola de Cristal",t:16,d:"Hugne ‘Memória Curta‘ possuiu uma magnífica bola de cristal, que seu vovô havia lhe dado. Bem decidido mantê-la pelo resto de sua vida, ele a pôs no chapéu que nunca tirava... Ela foi tão bem guardada, que ele morreu de fadiga tentando encontrá-la.",ep:4,g:12,l:24,wd:true,fm:true,w:12,s:38,p:1775};
I.u[707] = {n:"MinotoHorno",t:16,d:"Este chapéu, feito de chifres de Minotoro, é muito eficiente se você for impressionar seus adversários se passando por um Minotoro. Este truque só funciona com criaturas estúpidas como os discípulos de Iop e Tofus.",ep:2,g:13,l:33,wd:true,fm:true,w:10,s:54,p:3000};
I.u[708] = {n:"Houde",t:16,d:"Este chapéu feito de pele de larva verde mágica dá ao portador uma aparência alegre, porém estúpida. Nem sempre podemos conseguir o que queremos e o portador deste chapéu é um ótimo exemplo.",ep:1,g:14,l:30,wd:true,fm:true,w:8,p:2525};
I.u[709] = {n:"Lroko Kasko",t:16,d:"Este chapéu feito de casca de árvore encantada pertence a Lroko, um lenhador. Ele desafiou o famoso Brouce Boulgoure para lutar com ele em um duelo de levantamento de raiz de Olmo na clareira de Liroye Merline.",ep:9,g:15,l:37,wd:true,fm:true,w:9,c:"PG!10",p:3825};
I.u[710] = {n:"Korko Klako",t:16,d:"O Korko Klako é um chapéu maravilhoso que foi usado por muitos Sadidas.",ep:1,g:16,l:17,wd:true,fm:true,w:9,c:"PG=10",p:1000};
I.u[711] = {n:"Jouik Krampe",t:16,d:"Esta magnífica máscara de couro pertenceu a Jouik Krampe, primo de Zeurg. Eles gostavam de roupas de couro bem apertadas. Assim como o Capitão Chafer, mas não tão pervertido.",ep:8,g:17,l:26,wd:true,fm:true,w:15,c:"PG=10",p:2025};
I.u[712] = {n:"Gulliver",t:16,d:"Este chapéu é tão original que você pensará ser único. Dizem que antigamente Rakmar Bilgout o usava para seduzir a rainha dos Gobballs. Depois disso, ele não tinha qualquer dificuldade em cortar a garganta dela.",ep:13,g:18,l:33,wd:true,fm:true,w:10,p:3075};
I.u[713] = {n:"Pergaminho do Ferreiro de Espada",t:13,d:"(Clique duas vezes para ganhar Pontos de Experiência)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[714] = {n:"Pergaminho do Ferreiro de Adaga",t:13,d:"(Clique duas vezes para ganhar Pontos de Experiência)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[715] = {n:"Pergaminho do Escultor de Arco",t:13,d:"(Clique duas vezes para ganhar Pontos de Experiência)",ep:4,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[716] = {n:"Pergaminho do Escultor de Cajados",t:13,d:"(Clique duas vezes para ganhar Pontos de Experiência)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[717] = {n:"Pergaminho do Escultor de Varinha Mágica",t:13,d:"(Clique duas vezes para ganhar Pontos de Experiência)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[718] = {n:"Feitiço \'Torta de Alho-Poró\'",t:75,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe ensina o feitiço elementar \"Torta de Alho-Poró\".",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[719] = {n:"Feitiço \'Liberação\'",t:75,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe ensina o feitiço elementar \"Liberação\".",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[720] = {n:"Feitiço \'Golpeamento\'",t:75,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe ensina o feitiço elementar \"Golpeamento\".",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[721] = {n:"Feitiço \'invocação de Aracne\'",t:75,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe ensina o feitiço de invocação de Aracne.",ep:16,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[724] = {n:"Feitiço \'perícia em cajado\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando utilizar um cajado.",ep:1,g:2,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[725] = {n:"Feitiço \'perícia em espada\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando usar uma espada.",ep:3,g:1,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[726] = {n:"Feitiço \'perícia em arco\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando usar um arco.",ep:4,g:3,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[727] = {n:"Feitiço \'perícia em martelo\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando usar um martelo.",ep:1,g:4,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[728] = {n:"Feitiço \'perícia em varinha mágica\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando usar uma varinha.",ep:1,g:5,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[729] = {n:"Feitiço \'perícia em adaga\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando usar uma adaga.",ep:2,g:6,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[730] = {n:"Feitiço \'perícia em pá\'",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho possibilita que você cause mais dano quando usar uma pá.",ep:7,g:7,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[731] = {n:"Feitiço Especial \'Brokle\'",t:75,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe ensina o feitiço \"Brockle\"... para Iops apenas.",ep:2,g:4,l:1,wd:true,fm:true,w:1,c:"PG=8",u:true,p:10000};
I.u[732] = {n:"Aliança de Silimelle",t:9,d:"Este maravilhoso anel de casamento foi roubado de Silimelle, a Fermentadora de Energético, durante uma refeição com muito energético na Pousada. Pode acontecer com qualquer um que compre bebidas estranhas...",ep:1,g:30,l:26,wd:true,fm:true,w:1,p:2000};
I.u[733] = {n:"Botas de Ragalde",t:11,d:"Sem sombra de dúvida, Ragalde foi o mais apressado dos guerreiros Iop. Com estas botas mágicas, ele matava um grande número de inimigos.",ep:1,g:7,l:49,wd:true,fm:true,w:1,p:5000};
I.u[734] = {n:"Cinto de Segurança",t:10,d:"Com este cinto, os guardas do Castelo Amakna podem conter tumultos e impedir que as coisas saiam do controle durante celebrações populares.",ep:1,g:7,l:17,wd:true,fm:true,w:10,p:1000};
I.u[737] = {n:"Dofus Esmeralda",t:23,d:"Mais verde que um Tofu doente, o Dofus Esmeralda foi criado por Aerafal, o Dragão do Ar. Para criar algo tão verde, ele provavelmente estava sofrendo de enjôos durante os vôos. Isto seria a última gota, não é?",ep:1,g:2,l:6,wd:true,fm:true,w:5,p:500000};
I.u[739] = {n:"Dofus Turquesa",t:23,d:"O Dofus Turquesa foi criado por Aguabrial, o Dragão da Água. É incrível o que um Dragão pode fazer com a água...",ep:1,g:3,l:6,wd:true,fm:true,w:5,p:500000};
I.u[742] = {n:"Cajado de Chifre",t:4,d:"\"A lalaôôôô..... Estava atravessanto o deserto do Saara, veio um Tofu e sentou na minha cara\"... Esse foi o último sucesso do famoso músico Jon Lemon antes do seu acidente com o Tofu.",ep:1,g:1,l:29,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,200,false,false],c:"CC>20&CI>30",p:2350};
I.u[743] = {n:"Brioche Tostado",t:33,d:"A receita deste brioche foi elaborada pelo próprio Xavier, o padeiro. Ele quis fazer um brioche leve e gostoso. Certamente, um grande sucesso e até mais do que esperava ...",ep:1,g:8,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[744] = {n:"Manto de Bowisse",t:17,d:"Como seu portador, este manto é único e é freqüentemente subestimado. Ele é feito de peles de larvas verdes, o que lhe dá o mais agradável aspecto áspero.",ep:1,g:1,l:20,wd:true,fm:true,w:10,p:1275};
I.u[745] = {n:"Lingote de Ouro",t:40,d:"Você obtém este lingote fundindo ouro bruto.",ep:1,g:241,l:10,wd:true,fm:true,w:1,p:0};
I.u[746] = {n:"Ebonite",t:40,d:"Esta liga rara é usada na fabricação de itens raros e freqüentemente letais. É fato que a Ebonite, uma vez enferrujada, se torna um perigoso veneno.",ep:1,g:658,l:20,wd:true,fm:true,w:20,p:0};
I.u[747] = {n:"Aluminita",t:40,d:"Esta liga é incrivelmente leve e é, conseqüentemente, um metal escolhido para pequenas adagas ou espadas curtas.",ep:1,g:660,l:10,wd:true,fm:true,w:10,p:0};
I.u[748] = {n:"Magnesita",t:40,d:"Esta liga excêntrica é quase mágica;\r\n            ela brilha e vibra à noite, boa o bastante para assustar um Bwork ingênuo.",ep:1,g:659,l:30,wd:true,fm:true,w:30,p:0};
I.u[749] = {n:"Baquelite",t:40,d:"O baquelite não é uma liga sólida, mas, se corretamente afiada, torna-se tão afiada quanto a Lâmina de um Chafer.",ep:1,g:487,l:40,wd:true,fm:true,w:40,p:0};
I.u[750] = {n:"Kouartz",t:40,d:"Esta liga estranha contém uma energia impressionante que fica bem instável em certas circunstâncias. Os melhores ferreiros são loucos por Kouartz e usam-na para criar armas com poderes praticamente lendários.",ep:1,g:664,l:60,wd:true,fm:true,w:60,p:0};
I.u[752] = {n:"Sangue de Vampiro",t:15,d:"Este sangue é mágico e é o ingrediente essencial para o Pudim Preto Mágico. Os efeitos colaterais são desconhecidos até agora.",ep:2,g:89,l:15,wd:true,fm:true,w:1,p:100};
I.u[754] = {n:"Capa de Vampiro",t:17,d:"Esta capa é tão vermelha quanto o sangue que foi chupado durante anos. Esse tipo de capa é muito apreciado durante as celebrações de Dalouhine.",ep:7,g:17,l:29,wd:true,fm:true,w:13,p:2500};
I.u[756] = {n:"Cueca de Couro de Vampiro",t:56,d:"Para evitar batidas em certos lugares, o Vampiro às vezes leva consigo a sua Cueca de Couro quando vai caçar. As cuecas também lhe fornecem uma boa proteção contra queimaduras",ep:3,g:622,l:15,wd:true,fm:true,w:1,p:100};
I.u[757] = {n:"Geléia Azulada",t:110,d:"Esta geléia gruda bem forte nas penas dos Tofus. Mas por que alguém deveria querer fazer isto?",ep:5,g:42,l:3,wd:true,fm:true,w:1,p:1};
I.u[758] = {n:"Manto de Justiceiro",t:17,d:"Este manto só pode ser usado pelos grandes justiceiros... Você também poderia dizer que quase ninguém o veste.",ep:1,g:2,l:30,wd:true,fm:true,w:10,c:"Ps=1&Pa>20",p:2550};
I.u[759] = {n:"Manto de Frengo Chogreloting",t:17,d:"Este magnífico manto foi feito com as penas do último Frengo de Amakna. É uma verdadeira raridade que coletores sonham em adicionar a sua coleção.",ep:8,g:3,l:33,wd:true,fm:true,w:4,p:5000};
I.u[760] = {n:"Pão sem Caril",t:33,d:"Um protótipo de Kwaker Vans. Seu sabor e qualidade são sempre surpreendentes... mas infelizmente ao cheiro, você se acostumará.",ep:2,g:12,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[761] = {n:"Pêlos de Rato",t:54,d:"Estes pêlos de camundongo são muito finos e macios e, conseqüentemente, são um elemento muito procurado para a fabricação de casacos. Os casacos feitos com a pele e os pêlos de camundongo são altamente estimados na sociedade de Amakna. Elegante, não é?",ep:1,g:549,l:1,wd:true,fm:true,w:1,p:1};
I.u[764] = {n:"Amuleto de Pequena Coruja",t:1,d:"Este pequeno amuleto alegrará os iniciantes.",ep:1,g:1,l:1,wd:true,fm:true,w:2,p:50};
I.u[765] = {n:"Foice de Farle Ingalsse",t:22,d:"Esta foice pertenceu ao Farle Ingalsse em pessoa, é afiada o suficiente para ceifar qualquer tipo de cereal e qualquer tipo de monstro escondido nos campos de cereais.",ep:3,g:1,l:13,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,50,false,false],c:"CC>10",p:650};
I.u[766] = {n:"Koliet Aclou",t:1,d:"Este amuleto permite que você cause mais danos se for um aventureiro iniciante.",ep:1,g:34,l:1,wd:true,fm:true,w:1,p:20};
I.u[767] = {n:"Gantie Real",t:9,d:"Não acredite em seu nome pomposo, este anel só torna seu herói um pouco mais forte, e tolo.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[768] = {n:"Camate",t:9,d:"Este anel influencia o seu destino;\r\n            você fica mais resistente, mas menos sortudo. Em outras palavras, você aumenta as suas chances de viver muito tempo e diminui as chances de viver feliz.",ep:1,g:33,l:1,wd:true,fm:true,w:1,p:100};
I.u[769] = {n:"Einekeineux",t:11,d:"Botas que trazem sorte. Infelizmente, elas diminuem sua resistência em lutas.",ep:1,g:5,l:2,wd:true,fm:true,w:1,p:200};
I.u[770] = {n:"Fecaflip",t:11,d:"Este magnífico par de botas converte um pouco de sua força em inteligência.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[771] = {n:"Devorador de Freixo",t:19,d:"Este machado não tem nada de excepcional, todavia, é apreciado por aprendizes de Lenhador por sua simplicidade de uso.",ep:1,g:9,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>10&CC>10",p:400};
I.u[772] = {n:"Fanfamanto",t:17,d:"De acordo com o que as pessoas dizem, este lendário manto faz você se tornar quase invisível se você combiná-lo à lendária espada dos esgrimistas, a Dard Tagnan, e ao lendário chapéu dos Seis Rameaux de Bergers Rahks.",ep:7,g:4,l:22,wd:true,fm:true,w:10,p:1500};
I.u[773] = {n:"Manto de Ellinie",t:17,d:"Este leve manto vem do País de Patitalianos, um lugar onde as pessoas conversam com suas mãos. Isto explica a total liberdade de movimento dada pelo manto. Além disso, é surpreendentemente leve.",ep:1,g:5,l:14,wd:true,fm:true,w:1,p:775};
I.u[774] = {n:"Capa Ulais",t:17,d:"Vinda do Monte Taigüe, esta capa acabou envenenando sua ex-proprietária... Mas ela aumenta, estranhamente, a resistência do seu portador.",ep:1,g:7,l:14,wd:true,fm:true,w:3,p:775};
I.u[775] = {n:"Manto de Habilidade",t:17,d:"Este é um manto feito com atenção e cuidado infinitos, que permite ao seu portador encontrar os pontos fracos de seus inimigos.",ep:5,g:9,l:17,wd:true,fm:true,w:10,p:1000};
I.u[776] = {n:"Capa Sulcorp",t:17,d:"Uma certa Mulba a usou para transportar itens incômodos, durante a sua missão para achar as Sete Galinhas de Cristal que caíram das estrelas. Este manto aumenta consideravelmente a força.",ep:5,g:8,l:14,wd:true,fm:true,w:3,p:775};
I.u[777] = {n:"Capa do Galo Velho",t:17,d:"Antes desta capa ser feita, o galo lutou vários dias e noites até que morreu de exaustão. Então, o dono o depenou, coletando as preciosas penas em um choro exaustivo, mas satisfeito.",ep:5,g:10,l:44,wd:true,fm:true,w:10,p:5275};
I.u[778] = {n:"Manto de Mori Arty",t:17,d:"Este autêntico manto maligno é uma prova que você pertence à diabólica quadrilha do Mori Arty. Dizem que a má sorte dele se igualou à sua espantosa inteligência. Apenas verdadeiros sujeitos maus podem usá-lo.",ep:2,g:11,l:6,wd:true,fm:true,w:1,c:"Ps=2&Pa>30",p:20000};
I.u[779] = {n:"Manto de Maj\'Hic",t:17,d:"Este manto de aparência qualquer, não é ordinário. Ele pode tornar o usuário invisível aos olhos de quem não estiver olhando para ele. Realmente impressionante!",ep:8,g:12,l:34,wd:true,fm:true,w:15,p:3300};
I.u[781] = {n:"Capa Itou Lascione",t:17,d:"Este belo manto uma vez pertenceu ao Grande Stratequerre. Este famoso e experiente estrategista de guerra, faminto por conquistas universais, desistiu de seus planos após vestir seu manto. Muito estranho!",ep:8,g:7,l:21,wd:true,fm:true,w:10,p:1400};
I.u[782] = {n:"Agride",t:19,d:"Este machado é muito especial e era originalmente designado para o treinamento da profissão de lenhador. Quando bem usado, pode dividir um jovem Treechnid descuidado em dois, desde que tal Treechnid exista...",ep:1,g:11,l:27,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CW>15",p:2200};
I.u[783] = {n:"Amuleto do Lenhador",t:1,d:"Este amuleto, feito somente de madeira preciosa, é apreciado por lenhadores que, normalmente, exageram em suas habilidades para falar sobre os poderes que eles de fato não têm.",ep:1,g:9,l:22,wd:true,fm:true,w:2,p:1500};
I.u[784] = {n:"Botas de Gato Teimoso",t:11,d:"“Gato Teimoso” era o nome de um famoso discípulo de Ecaflip. Ele era o mais teimoso da sua classe e, durante as lutas, apenas a sorte dele podia salvá-lo de sua inexistente inteligência.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[785] = {n:"Anel Fortificante",t:9,d:"É um anel que é passado de Avô para Pai na sociedade Enutrof e que dá ao portador uma incrível força. Este aqui é uma imitação pálida, mas mesmo assim pode satisfazer colecionadores, sejam eles Enutrofs ou não.",ep:1,g:29,l:11,wd:true,fm:true,w:1,p:525};
I.u[786] = {n:"Pendente de Coruja Fraca",t:1,d:"O joalheiro cometeu um engano quando criou este amuleto que transmite mais inteligência ao possuidor, porém, em troca, dá a ele/ela uma grave enxaqueca enfraquecendo sua condição física.",ep:1,g:1,l:2,wd:true,fm:true,w:1,p:200};
I.u[787] = {n:"Anel de Ano Rexik",t:9,d:"Este pequeno anel estranho pode aumentar a agilidade do seu portador em troca de pontos de sorte.",ep:1,g:31,l:1,wd:true,fm:true,w:1,p:100};
I.u[789] = {n:"Cinto de Koober",t:10,d:"Este cinto é a última moda entre os jovens de Amakna. Um costureiro - discípulo de Sadida - está por trás dessa moda. Quando ele vendeu o seu primeiro cinto, disse: “A vida é curta, jogue duro!”.",ep:2,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[790] = {n:"Capa da Boa Esperança",t:17,d:"Os efeitos mágicos desta capa são freqüentemente superestimados, o que, inevitavelmente, causou a perda de numerosos aventureiros, entre eles, o notório trovador Jony Lenon.",ep:8,g:5,l:30,wd:true,fm:true,w:8,p:2525};
I.u[791] = {n:"Treechnidis Vivitus",t:4,d:"Este é um cajado feito de raízes de Treechnid, que ainda estão vivas. Mas tenha cuidado já que este cajado tem uma tendência a se rebelar contra seu mestre. Ele pode ser muito eficiente quando decide atacar o mesmo alvo que seu mestre.",ep:2,g:1,l:34,wd:true,fm:true,w:10,an:12,e:[5,2,1,1,50,30,false,false],c:"CC>30&CI>34&CW>15",p:3400};
I.u[792] = {n:"Seiva de Treechnid",t:15,d:"Esta seiva melada é inútil a menos que você esteja pronto para esperar um longo, longo tempo para ela se transformar em Âmbar. As pessoas dizem que uma menina esperta e particularmente atraente da Guilda dos Enutrofs encontrou uma maneira de acelerar este processo.",ep:1,g:162,l:45,wd:true,fm:true,w:2,p:50};
I.u[793] = {n:"Poção da Velhice",t:12,d:"Esta poção acelera alguns processos químicos, como a formação de precipitados. É como um fermento muito poderoso, sem o gosto ruim.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[795] = {n:"Pergaminho de Força",t:76,d:"(Clique duas vezes para ganhar Força)\nCom este pergaminho você pode seguramente aumentar sua força em definitivo. Mas tenha cuidado, você só pode usá-lo se sua força estiver abaixo de 50.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<50",u:true,p:2500};
I.u[796] = {n:"Grande Pergaminho da Força",t:76,d:"(Clique duas vezes para ganhar força)\nCom este pergaminho você pode aumentar sua força. Mas tenha cuidado, você só pode usá-lo se sua força estiver abaixo de 80.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<80",u:true,p:5000};
I.u[797] = {n:"Poderoso Pergaminho de Força",t:76,d:"(Clique duas vezes para ganhar Força)\nCom esse pergaminho você pode seguramente aumentar a sua força para sempre. Mas tenha cuidado, você só pode usá-lo se sua força for menor que 100.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<100",u:true,p:8000};
I.u[798] = {n:"Pequeno Pergaminho de Agilidade",t:76,d:"(Clique duas vezes para ganhar agilidade)\nEste pergaminho lhe permite aumentar a agilidade de maneira definitiva e segura, mas tenha cuidado, você não pode usá-lo se sua agilidade for maior que 25.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<25",u:true,p:1000};
