I.u[8225] = {n:"Sandálias de Piwi Vermelho",t:11,d:"Perfeitas para proteger seus pezinhos e esmagar pequenas criaturas rastejando entre as folhas de grama como Xelors ou Eniripsas por exemplo.",ep:1,g:78,l:1,wd:true,fm:true,w:1,s:60,p:1};
I.u[8226] = {n:"Sandálias de Piwi Azul",t:11,d:"Elas são perfeitas para proteger seus pequenos pés e para esmagar pequenas criaturas que rastejam pela grama como Xelors ou Eniripsas, por exemplo.",ep:1,g:79,l:1,wd:true,fm:true,w:1,s:61,p:1};
I.u[8227] = {n:"Sandálias de Piwi Violeta",t:11,d:"Perfeitas para proteger seus pezinhos e esmagar pequenas criaturas rastejando entre as folhas de grama como Xelors ou Eniripsas por exemplo.",ep:1,g:80,l:1,wd:true,fm:true,w:1,s:62,p:1};
I.u[8228] = {n:"Sandálias do Piwi Verde",t:11,d:"São perfeitas para proteger seus pezinhos e esmagar criaturas pequenas rastejando entre a grama como Xelors e Eniripsas, por exemplo.",ep:1,g:81,l:1,wd:true,fm:true,w:1,s:71,p:1};
I.u[8229] = {n:"Sandálias de Piwi Amarelo",t:11,d:"São perfeitas para proteger para seus pés e das abobrinhas das criaturas pequenas rastejantes entre a grama como Xelors ou Eniripsas, por exemplo.",ep:1,g:82,l:1,wd:true,fm:true,w:1,s:72,p:1};
