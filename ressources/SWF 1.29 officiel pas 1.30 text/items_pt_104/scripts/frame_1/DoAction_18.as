I.u[8050] = {n:"Pele de Koalak Imaturo",t:59,d:"Este pequeno Koalak imaturo do qual você arrancou a pede, não concordou em dá-la a você. Mas quem se importa, você é mais forte e mais cruel.",ep:20,g:3,l:1,wd:true,fm:true,w:1,p:10};
I.u[8051] = {n:"Pele de Koalak Sative",t:59,d:"Se você não tem um urionol ou uma árvore a seu alcance, fique longe desta pele.",ep:0,g:4,l:1,wd:true,fm:true,w:1,p:10};
I.u[8052] = {n:"Pele do Mestre Koalak",t:59,d:"Esta pele velha e usada costumava proteger as costas do Mestre Koalak. Ainda mantém traços avermelhados, prova de uma vida louca e sem descanso.",ep:20,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[8053] = {n:"Pele de Montaria Koalak",t:59,d:"Esta pele rasgada foi usada na Montaria de Koalak. Obviamente, é uma prova de boa qualidade.",ep:20,g:6,l:1,wd:true,fm:true,w:1,p:10};
I.u[8054] = {n:"Pele de Drakoalak",t:59,d:"O cheiro desta pele deve lembrar-lhe um daqueles celeiros do Castelo de Amakna. Muito útil para assustar almas sensíveis e matá-las antes de elas decidirem ir contigo em um calabouço.",ep:20,g:7,l:1,wd:true,fm:true,w:1,p:10};
I.u[8055] = {n:"Osso de Mama Koalak",t:47,d:"Mama Koalak tem ossos sólidos que não quebram apesar de seu peso. O mesmo não é verdade para Jony Lenon, famoso menestrel que perdeu a capacidade de seus dois braços quando foi esmagado pela imensa coxa de Mama Koalak.",ep:20,g:638,l:1,wd:true,fm:true,w:1,p:10};
I.u[8056] = {n:"Fêmur de Koalak Selvagem",t:47,d:"Uma vez esculpido em formato de punhal, este osso pode ser usado como tal ou como um piercing.",ep:20,g:639,l:1,wd:true,fm:true,w:1,p:10};
I.u[8057] = {n:"Tíbia de Koalak Coveiro",t:47,d:"Este osso pode ser usado como uma pá para desenterrar corpos e despi-los, se você gosta de aproveitar os feriados próximos de cemitérios. É também a tíbia de um Koalak Coveiro.",ep:20,g:640,l:1,wd:true,fm:true,w:1,p:10};
I.u[8058] = {n:"Ulna de Múmia Koalak",t:47,d:"Este osso mantém todo o seu esplendor graças às numerosas tiras da Múmia Koalak, oferecendo boa proteção contra os mais poderosos ataques mágicos.",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8059] = {n:"Pêlos de Cereja Morello Koalak",t:54,d:"Estes pêlos estão cobertos com pólen de Blop, o que lhes dá um gosto delicioso, mas um cheiro nojento.",ep:20,g:660,l:1,wd:true,fm:true,w:1,p:10};
I.u[8060] = {n:"Pêlos de Koko Koalak",t:54,d:"Estes pêlos estão cobertos de pólen Blop que dá um gosto delicioso, porém um cheiro desagradável.",ep:20,g:662,l:1,wd:true,fm:true,w:1,p:10};
I.u[8061] = {n:"Pêlos de Koalak Maçã",t:54,d:"Esses pêlos estão cobertos de pólen de Blop, o que os deixa com um gosto delicioso, mas com um cheiro nojento.",ep:20,g:661,l:1,wd:true,fm:true,w:1,p:10};
I.u[8062] = {n:"Pêlos de Koalak Índigo",t:54,d:"Estes pêlos estão cobertos com pólen de Blop que dá um gosto delicioso, mas um cheiro horrível.",ep:20,g:659,l:1,wd:true,fm:true,w:1,p:10};
I.u[8063] = {n:"Cauda de Koalak Sanguinário",t:65,d:"Esta ridícula cauda minúscula podia ter pertencido a você, já que você é tão insignificante. Mas isto não vem ao caso e considere-se sortudo por estar aqui!",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8064] = {n:"Bumerangue do Koalak Sanguinário",t:15,d:"Este pedaço de madeira de forma estranha viajou durante muito tempo no ar entre linhas inimigas, antes de quebrar. Diz o rumor que, uma vez lançado, ele sempre voltará para o seu dono, mas raramente em suas mãos...",ep:20,g:721,l:1,wd:true,fm:true,w:1,p:10};
I.u[8065] = {n:"Pêlos de Barba do Warko Marrom",t:54,d:"Estes pêlos são urticantes o suficiente para transformar os simples beijos do Warko Marrom em armas de destruição em massa.",ep:20,g:657,l:1,wd:true,fm:true,w:1,p:10};
I.u[8066] = {n:"Pêlos de Barba de Warko Violeta",t:54,d:"Estes pêlos são urticantes tornando esta barba uma arma mais destrutiva que um bafo de Bwork, se formos comparar.",ep:20,g:658,l:1,wd:true,fm:true,w:1,p:10};
I.u[8067] = {n:"Botas de Campeão",t:11,d:"Alguns aventureiros dizem que estas botas permitem caminhar sobre armadilhas sem ativá-las. Mas tenha cuidado, pois isso pode ser uma armadilha...",ep:1,g:72,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8068] = {n:"Capa de Campeão",t:17,d:"Esta esplêndida capa foi criada com ombreiras para fazer você, finalmente, parecer um verdadeiro campeão.",ep:1,g:96,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8069] = {n:"Capacete de Campeão",t:16,d:"Com este imponente capacete, você, obviamente, ficará com um cabeção, se já não tiver um!",ep:1,g:127,l:1,wd:false,fm:true,w:100,s:45,p:10};
I.u[8070] = {n:"Cinto de Campeão",t:10,d:"Com este cinto em volta dos quadris, você esconderá facilmente o que não mostra as suas vantagens.",ep:1,g:88,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8071] = {n:"Míni Cogumelo",t:18,d:"Esta pequena criatura só aceita seguir campeões... Então ele o seguirá por alguns dias antes de descobrir que você é um impostor. A partir deste momento, você é quem seguirá como um pequeno animalzinho de estimação.",ep:1,g:32,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:45,p:1};
I.u[8072] = {n:"Dofus Kaliptus",t:23,d:"Ninguém sabe sobre o dragão que criou este Dofus. Dizem que ele ingeriu uma incrível quantidade de Kaliptus, botou o ovo e morreu de uma terrível prisão de ventre.",ep:1,g:10,l:6,wd:false,fm:true,w:1,p:500000};
I.u[8073] = {n:"Chave do Esconderijo de Skeunk",t:84,d:"Rigroulak lhe deu esta chave em troca do conjunto Koolich. Esta chave lhe permitirá entrar no esconderijo de Skeunk.",ep:13,g:11,l:1,wd:true,fm:true,w:1,p:100};
I.u[8075] = {n:"Bumerangue de Dok Alako",t:15,d:"Este pedaço de madeira de forma estranha viajou durante muito tempo no ar entre linhas inimigas, antes de quebrar. Diz o rumor que, uma vez lançado, ele sempre voltará para o seu dono, mas raramente em suas mãos...",ep:20,g:722,l:1,wd:true,fm:true,w:1,p:10};
I.u[8076] = {n:"Bumerangue do Mestre Koalak",t:15,d:"Este pedaço de madeira de forma estranha viajou durante muito tempo no ar entre linhas inimigas, antes de quebrar. Diz o rumor que, uma vez lançado, ele sempre voltará para o seu dono, mas raramente em suas mãos...",ep:20,g:723,l:1,wd:true,fm:true,w:1,p:10};
I.u[8077] = {n:"Bumerangue de Warko Marrom",t:15,d:"Este pedaço de madeira de forma estranha viajou durante muito tempo no ar entre linhas inimigas, antes de quebrar. Diz o rumor que, uma vez lançado, ele sempre voltará para o seu dono, mas raramente em suas mãos...",ep:20,g:724,l:1,wd:true,fm:true,w:1,p:10};
I.u[8078] = {n:"Tábua de Kaliptus",t:95,d:"Esta tábua permite que marceneiros construam itens de madeira, como um caixão, por exemplo.",ep:20,g:22,l:70,wd:true,fm:true,w:10,p:10};
I.u[8079] = {n:"Transformação Fantasma de Pequeno Miau Branco",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8080] = {n:"Transformação Fantasma de Pequeno Au-au Preto",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8081] = {n:"Sacola de Carpino",t:100,d:"Esta sacola enorme contém uma quantidade impressionante de Carpino.",ep:1,g:55,l:1,wd:true,fm:true,w:250,u:true,p:100};
I.u[8082] = {n:"Tecido de Reapalak",t:55,d:"Este tecido cheira como a morte, apesar de que você cheira como se estivesse morto. A diferença é notável.",ep:20,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8083] = {n:"Osso de Peixeralak",t:47,d:"Este osso é bastante esponjoso e permite ao Peixeralak flutuar se ele cair na água tentando capturar uma grande presa.",ep:20,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[8084] = {n:"Pele de Piralak",t:59,d:"Esta pele coberta de cicatrizes se tornou mais resistente que uma pedra, mas permaneceu extremamente flexível. É a pele perfeita para fazer chicotes e sandálias.",ep:20,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[8085] = {n:"Pêlos de Koalak Florestal",t:54,d:"Estes pêlos cobertos por seiva de Kaliptus são muito brilhantes. Infelizmente, eles não podem ser usados para alta-costura, pois cheiram como um Dragossauro morto.",ep:20,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[8086] = {n:"Elmo Cortador de Drakoalak",t:15,d:"Esta estranha touca era normalmente usada para esconder a calvície prematura de Drakoalak. Com um pouco de prática, ela poderá em breve esconder a sua.",ep:20,g:725,l:1,wd:true,fm:true,w:1,p:100};
I.u[8087] = {n:"Feitiço de Perícia com Machado",t:73,d:"(Clique duas vezes para aprender o feitiço)\nEste pergaminho lhe permitirá causar mais dano quando estiver usando um machado.",ep:20,g:8,l:20,wd:false,fm:true,w:1,u:true,p:10000};
I.u[8088] = {n:"Varinha Mágica Gyver",t:3,d:"Esta varinha mágica feita de nada, possui uma mágica incrível. A lenda diz que pode mover seu possuidor, escolhe seu alvo e o protege até mesmo quando estiver morrendo.",ep:20,g:56,l:128,wd:true,fm:true,w:10,an:11,e:[5,5,2,5,40,50,false,true],c:"CI>250",p:41257};
I.u[8089] = {n:"Varinha Mágica Iots",t:3,d:"Iots era um papagaio que repetia tudo que você dizia. Dizem que esta varinha mágica foi forjada em seu bico.",ep:20,g:57,l:138,wd:true,fm:true,w:20,an:11,tw:true,e:[5,4,3,4,40,50,false,true],c:"CI>150&CA>100&CC>100&CS>100",p:44125};
I.u[8090] = {n:"Cajado de Karibbhean",t:4,d:"Este cajado já mordeu pessoas ou, talvez, as pessoas o tenham mordido. Não podemos lhes dizer com certeza.",ep:20,g:64,l:114,wd:true,fm:true,w:10,an:12,tw:true,e:[5,5,1,1,35,50,false,true],c:"CI>200&CA>150",p:33520};
I.u[8091] = {n:"Taquara",t:4,d:"Este pedaço de taquara vem da parte sul do país. Infelizmente, ele não se transformou em ouro quando estava lá.",ep:20,g:65,l:134,wd:true,fm:true,w:20,an:12,tw:true,e:[20,4,1,1,150,150,false,true],c:"CS>150&CA>150&CI>150",p:43550};
I.u[8092] = {n:"Adaga de Ostwogoth",t:5,d:"O Ostwogoth não é afiado nem esperto, mas, quando tem adagas em suas hábeis mãos, ninguém se arrisca a enfrentá-lo.",ep:20,g:56,l:135,wd:true,fm:true,w:20,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CS>250&CA>100",p:43510};
I.u[8093] = {n:"Adaga Mick",t:5,d:"Carregar estas adagas não fará de você um herói... Elas podem deixá-lo parecido com uma heroína se carregar nas suas calcinhas.",ep:0,g:64,l:58,wd:true,fm:true,w:1,e:[-1,-1,1,1,-1,-1,false,false],p:4253};
I.u[8094] = {n:"Espada de Killarious",t:6,d:"Esta espada ilustra perfeitamente o velho provérbio Iop ‘Por trás de um inimigo morto, está uma espada hilariante\'.",ep:20,g:66,l:169,wd:true,fm:true,w:30,an:14,e:[10,5,1,1,50,50,false,true],c:"CS>450&CV>450",p:49010};
I.u[8095] = {n:"Sabre Ayassalama",t:6,d:"Esta espada foi forjada de acordo com esteticismo específico para você decorar sua lareira luxuosa. Mas por ser bem eficiente em luta, também é muito usada. As pessoas não respeitam mais a arte.",ep:20,g:67,l:143,wd:true,fm:true,w:20,an:14,e:[15,4,1,1,80,50,false,true],c:"CI>300&CS>130&(PG=6|PG=8|PG=11)",p:44587};
I.u[8096] = {n:"Martelo de Dunb",t:7,d:"Seu antigo dono costumava dançar com Moolobos. Ele foi comido rapidamente.",ep:20,g:56,l:140,wd:true,fm:true,w:20,an:15,e:[5,5,1,1,30,45,false,true],c:"CI>250&CC>250",p:44541};
I.u[8097] = {n:"Martelo Oin",t:7,d:"Este martelo fará você ver a vida com um tom mais rosa antes de esmagar sua cabeça em vários pedaços.",ep:20,g:57,l:129,wd:true,fm:true,w:30,an:15,e:[5,4,1,1,40,15,false,true],c:"CS>250&CI>150",p:42658};
I.u[8098] = {n:"Lâmina de Thoven",t:19,d:"Este machado é muito especial. Sua lâmina vibratória toca belas músicas enquanto você dilacera a vida de seus inimigos.",ep:0,g:38,l:1,wd:false,fm:true,w:1,an:17,e:[10,4,1,1,50,50,false,true],p:1};
I.u[8099] = {n:"Machado de Mentiras",t:19,d:"Esta arma foi mergulhada em uma fonte de raios puros e, então, foi borrifado pó de estrela. Mas diz o rumor que nada disto é verdade.",ep:20,g:39,l:116,wd:true,fm:true,w:10,an:17,tw:true,e:[7,5,1,1,35,50,false,false],c:"CA>120&CV>150",p:34562};
I.u[8100] = {n:"Machado Isca",t:19,d:"Este machado foi perfurado em diversos lugares, fazendo-o assobiar alegremente ao bater em seus inimigos. Mas ele silencia os gritos de dor de seus inimigos. Que pena!",ep:20,g:40,l:112,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,40,50,false,false],c:"CS>150&CW>150",p:30300};
I.u[8101] = {n:"Machado Tichok",t:19,d:"Este machado foi forjado por Brouce Boulgoure quando ele tentou se tornar um padeiro para agradar seu amigo Xavier, o padeiro. Ele quis fazer uma pá de torta.++",ep:20,g:41,l:128,wd:true,fm:true,w:1,an:17,e:[5,4,1,1,20,30,false,false],c:"CI>230&CA>60&CV>250",p:444};
I.u[8102] = {n:"Rocha de Crackler Lendário",t:51,d:"Dizem que esta rocha é o coração do lendário Crackler. O que nós sabemos é que o lendário Crackler nunca teve um coração pesado. Assim, esta rocha é incrivelmente leve, tornando possível criar itens adequados para personagens que favorecem a mobilidade, agilidade e proteção. Perfeito!",ep:5,g:457,l:120,wd:true,fm:true,w:50,p:100};
I.u[8103] = {n:"Arco de Bew",t:2,d:"Este arco é, de fato, o cabelo fossilizado de um Sadida que dormiu por muito tempo e no qual Aracnes teceram suas teias.",ep:20,g:53,l:121,wd:true,fm:true,w:20,an:10,tw:true,e:[5,5,2,6,30,50,false,true],c:"CS>100&CA>100&CI>100&CC>100&CV>200",p:34857};
I.u[8104] = {n:"Arco de Chetlion",t:2,d:"Este arco tem uma cor estranha, mas é perfeito para ser exibido no Zaap de Bonta... Você não se passará por um galo, mas, seguramente, atrairá todos os pintinhos!!! Às vezes incrível, às vezes asqueroso, ele pode até derrotar seus inimigos sem que você tenha de atirar ao menos uma flecha.",ep:20,g:54,l:129,wd:true,fm:true,w:20,an:10,tw:true,e:[7,4,2,6,35,40,false,true],c:"CI>300&CV>300&CA>100",p:42510};
I.u[8105] = {n:"Bomba de Fumaça",t:74,d:"Esta bomba cria uma cortina de fumaça, na qual esconde seus movimentos e suas ações, como se você fosse um ninja ou um pobre mágico.",ep:1,g:30,l:1,wd:false,fm:true,w:1,c:"(PX=3)|(PX=4)",ut:true,p:1};
I.u[8106] = {n:"Poção de Esquecimento de Profissão: Faz-tudo",t:44,d:"Com esta poção você esquecerá a profissão de Faz-tudo.",ep:7,g:2,l:1,wd:false,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[8107] = {n:"ne pas traduire",t:25,d:"ne pas traduire",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8108] = {n:"Amuleto de Tofu",t:1,d:"Tão leve quanto uma pena de Tofu, este amuleto pode ser usado ao redor do pescoço ou ao redor da testa, se você quiser ser original.",ep:3,g:95,l:22,wd:true,fm:true,w:5,s:50,p:1525};
I.u[8109] = {n:"Anel de Tofu",t:9,d:"Este anel ridiculamente pequeno pode acabar sendo essencial. Realmente, seus inimigos podem ter tanta piedade de você, que acabarão contigo em vez de o deixarem agonizar. Vamos pensar positivo!",ep:3,g:100,l:21,wd:true,fm:true,w:5,s:50,p:1350};
I.u[8110] = {n:"Varinha Mágica de Tofu",t:3,d:"Ao contrário do que alguns aventureiros podem pensar, esta varinha mágica não é usada pelos Tofus (modo muito estúpido de se saber usar tal arma), mas contra os Tofus. Realmente, esta varinha mágica é feita de penas de Tofu que permitem aos caçadores simular a dança de acasalamento deles para pegá-los. O que mais estes terríveis caçadores inventarão para satisfazer seus instintos?",ep:3,g:58,l:25,wd:true,fm:true,w:10,an:11,e:[5,6,2,2,50,50,false,false],s:50,p:100};
I.u[8111] = {n:"Chinelos de Tofu",t:11,d:"Leves e macios, esses chinelos são mornos no inverno e frios no verão. Infelizmente, eles não podem ser lavados em lavadoras de roupas.",ep:3,g:73,l:23,wd:true,fm:true,w:10,s:50,p:1575};
I.u[8112] = {n:"Manto de Tofu",t:17,d:"Este misterioso manto foi cortado pela metade. Mas por que alguém cortaria isto pela metade? Ninguém sabe... apesar de todo mundo ter sua própria opinião sobre isto.",ep:3,g:97,l:26,wd:true,fm:true,w:10,s:50,p:2000};
I.u[8113] = {n:"Cinto de Tofu",t:10,d:"Este cinto é a ferramenta ideal para estrangular Tofus, mas caçadores também o usam para chicotear forasteiros que se aventuram em suas terras na época da caça. Portanto, aconselhamos a não brincar com os nossos amigos caçadores. Tofus não são os únicos numa situação ruim!",ep:3,g:89,l:22,wd:true,fm:true,w:5,s:50,p:1553};
I.u[8114] = {n:"Capacetofu",t:16,d:"Este capacete, seguramente, se torna um item da moda que toda aventureira deveria ter. Qual o problema com este mundo?",ep:3,g:128,l:23,wd:true,fm:true,w:5,s:50,p:1575};
I.u[8116] = {n:"Escarapacete Dourado",t:16,d:"Este capacete é perfeito para esconder suas acnes de adolescente ou sua cara feia ou angelical.",ep:6,g:129,l:58,wd:true,fm:true,w:10,s:51,p:8900};
I.u[8117] = {n:"Escaracapa Dourada",t:17,d:"Mais dourada que Escaracapa clássica e menos preta que a Escaracapa preta, esta capa é perfeita para esconder seu crescimento. O Escarafeio costumava usá-la para esconder sua horrível corcunda. Hoje em dia, esta capa é muito usada para esconder a terrível aparência das costas. Nem é preciso dizer que esta capa é muito popular.",ep:6,g:98,l:58,wd:true,fm:true,w:10,s:51,p:8980};
I.u[8118] = {n:"Varinha Mágica do Escarafeio Dourado",t:3,d:"Esta varinha mágica é perfeita para limpar mobília antiga ou pessoas velhas.",ep:6,g:59,l:59,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,60,false,false],s:51,p:9300};
I.u[8119] = {n:"Escaracinto Dourado",t:10,d:"Se você adora correr nu pelas praias da paradisíaca Ilha de Lua, certamente gostará deste cinto.",ep:6,g:90,l:51,wd:true,fm:true,w:10,s:51,p:6825};
I.u[8120] = {n:"Amuleto de Escarafeio Dourado",t:1,d:"Usado em um torso peludo, este amuleto parece fantástico! Tufos de pêlo são a combinação perfeita para este amuleto.",ep:6,g:96,l:45,wd:true,fm:true,w:5,s:51,p:5375};
I.u[8121] = {n:"Anel do Escarafeio Dourado",t:9,d:"Um Escarafeio é uma criatura estranha. Nasce concurda e feio, é motivo de piada entre os Escarafolhas. Pode ser esse o motivo que faz você se sentir tão perto dessa criatura.",ep:6,g:101,l:43,wd:true,fm:true,w:5,s:51,p:5000};
I.u[8122] = {n:"Escarabotas Douradas",t:11,d:"Estas botas de escalada tornam fácil subir por penhascos ou lavrar seus campos sem usar um arado.",ep:6,g:74,l:54,wd:true,fm:true,w:10,s:51,p:7725};
I.u[8123] = {n:"Amuleto de Fazendeiro",t:1,d:"Este amuleto cheira a óleo de Girassol Selvagem e ervas. Você pode usá-lo como isca para pegar perigosos ruminantes que gostaria de aprisionar, como Gobballs ou sogras, por exemplo.",ep:1,g:97,l:20,wd:true,fm:true,w:5,s:47,p:1255};
I.u[8124] = {n:"Cintormudas do Fazendeiro",t:10,d:"Este cinto é simplesmente excepcional, assim como a bermuda de linho presa a ele. Este cinto é projetado para aqueles que gostam de se livrar das roupas e agir depressa. Entretanto, tenha cuidado. Por motivos higiênicos, este cinto é proibido em piscinas públicas.",ep:1,g:91,l:20,wd:true,fm:true,w:10,s:47,p:1300};
I.u[8125] = {n:"Sombreiro do Fazendeiro",t:16,d:"Se você precisa estar protegido do sol enquanto trabalha nos campos, então você precisa de um elmo Slob. Se você precisa estar protegido do sol enquanto trabalha nos campos e se você é pobre, tudo o que você precisa é do famoso Sombreiro do Fazendeiro.",ep:1,g:130,l:19,wd:true,fm:true,w:10,s:47,p:1200};
I.u[8126] = {n:"Luvas Roídas por Traças do Fazendeiro",t:9,d:"Estas luvas roídas por traças são um verdadeiro tesouro. Elas parecem ser cobertas com pó de diamante, o que lhes dá uma extraordinária resistência. Elas têm um lado abrasivo perfeito para esfregar o traseiro de seus Gobballs ou daquela sua esposa.",ep:1,g:102,l:12,wd:true,fm:true,w:5,s:47,p:600};
I.u[8127] = {n:"Gadanha Danificada de Fazendeiro",t:22,d:"Esta robusta, porém danificada foice não corta muito bem já que tem sido muito usada. Entretanto, é extremamente eficiente extrair tenras carnes superficiais e para arrancar as varizes de seus oponentes.",ep:1,g:2,l:17,wd:true,fm:true,w:1,an:17,e:[5,3,1,1,50,50,false,false],s:47,p:950};
I.u[8128] = {n:"Botas de Fazendeiro",t:11,d:"Estas botas são acolchoadas com palha de trigo, o que lhes permite absorver a transpiração e cultivar cogumelos tóxicos a um pequeno custo. Graças às suas suaves solas, elas foram recomendadas pelos melhores jogadores de Gobbol.",ep:1,g:75,l:18,wd:true,fm:true,w:5,s:47,p:1100};
I.u[8129] = {n:"Booloboamul",t:1,d:"Atrás deste estúpido nome você encontrará um amuleto extremamente poderoso, feito com caninos e ossos de Boolobo, o que explica o terrível odor dele. Pode ser que ele não se adapte ao seu pescoço, mas se adaptará perfeitamente ao seu hálito.",ep:1,g:98,l:57,wd:true,fm:true,w:10,s:32,p:8550};
I.u[8130] = {n:"Machado de Boolobo",t:19,d:"Este terrível machado decapitou muitos aventureiros precipitados ainda que ele não corte muito bem. Realmente, uma dúzia de tentativas pode ser necessária para terminar de cortar um pescoço resistente.",ep:1,g:42,l:55,wd:true,fm:true,w:10,an:17,tw:true,e:[5,6,1,1,50,50,false,false],s:32,p:8125};
I.u[8131] = {n:"Sacola do Fazendeiro",t:81,d:"Esta sacola é muito badalada entre os jovens alunos e é ideal para armazenar farinhas animais e vegetais. Uma vez aberta, desdobrada e descosturada, você poderá usá-la como uma saia se você não se importar em mostrar suas pernas cabeludas.",ep:1,g:3,l:19,wd:true,fm:true,w:1,s:47,p:1153};
I.u[8132] = {n:"Escaracinto Preto",t:10,d:"Este cinto é tudo, menos original. Entretanto, parece estar combinando com seu corte de cabelo.",ep:6,g:93,l:43,wd:true,fm:true,w:10,s:49,p:4955};
I.u[8133] = {n:"Escaracapacete Preto",t:16,d:"Este capacete é perfeito para aqueles que querem ver o lado negro das coisas.",ep:6,g:132,l:53,wd:true,fm:true,w:10,s:49,p:7350};
I.u[8134] = {n:"Escaracapa Preta",t:17,d:"Se você não tem condições de comprar uma Caracapa Mastralis, mas você gosta de assustar Aracnes vestindo roupas pretas, esta é a capa que você precisa!",ep:6,g:100,l:53,wd:true,fm:true,w:10,s:49,p:7575};
I.u[8135] = {n:"Chave do Calabouço dos Bworks",t:84,d:"Esta surpreendente chave lhe permitirá entrar no Calabouço dos Bworks, mas não deixará você sair vivo de lá.",ep:1,g:234,l:1,wd:true,fm:true,w:1,p:100};
I.u[8136] = {n:"Escaraanel Preto",t:9,d:"Este belo anel pode ser usado no seu dedão do pé. É perfeito para esconder suas verrugas e suas unhas encravadas.",ep:6,g:104,l:48,wd:true,fm:true,w:10,s:49,p:6200};
I.u[8137] = {n:"Entranhas do Escarafeio Dourado",t:15,d:"Estas estranhas são responsáveis por dificultar a digestão do Escarafeio Dourado. Você está encarregado de fritá-lo sem remorso algum.",ep:6,g:726,l:70,wd:true,fm:true,w:5,p:100};
I.u[8138] = {n:"Carapaça de Escarafolha Preta",t:107,d:"De cabeça para baixo, esta carapaça pode ser usada como cinzeiro.",ep:6,g:727,l:40,wd:true,fm:true,w:5,p:100};
I.u[8139] = {n:"Chave do Calabouço dos Escarafolhas",t:84,d:"Esta maravilhosa chave de ouro permitira que você entre no calabouço dos Escarafolhas. E você pensou que já tinha visto de tudo?",ep:1,g:233,l:1,wd:true,fm:true,w:1,p:100};
I.u[8140] = {n:"Antenas de Escarafolha Preta",t:15,d:"O próprio Escarafolha Preto nunca soube por que lhe foram dadas estas antenas. Às vezes, a natureza pode ser uma coisa terrível.",ep:6,g:728,l:40,wd:true,fm:true,w:1,p:100};
I.u[8141] = {n:"Asas de Escarafolha Preta",t:104,d:"Diferentemente do que alguns aventureiros possam pensar, as asas do Escarafolha Preto não são pretas, mas brancas. Outro mistério que a Mãe Natureza nos deu para ser discutido na taverna.",ep:6,g:729,l:40,wd:true,fm:true,w:1,p:100};
I.u[8142] = {n:"Chave Sereta para a Tofucasa Real",t:84,d:"Com esta chave, você poderá entrar na Tofucasa Real. Você ganhará uma surra memorável lá.",ep:3,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[8143] = {n:"Chave dos Campos",t:84,d:"Esta chave não o deixará fugir do Calabouço do Campo. Ao contrário, ela o trancará lá, para você ser empurrado para cima de margaridas.",ep:1,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8144] = {n:"Mojo de Moolobo",t:15,d:"Este pequeno frasco contém todos os poderes viris do Boolobo. Atenção! Isto não é comestível.",ep:2,g:730,l:1,wd:true,fm:true,w:1,p:1};
I.u[8145] = {n:"Energético de Bwork",t:37,d:"O energético de Bwork pode deixar eufórico um Feca a 12 pés de distância e um Sadida de 15 pés de altura. Nós não podemos dizer se tem sido feito por Bworks, de Bworks ou ambos.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8146] = {n:"Botas de Crackler Lendário",t:11,d:"Se você gosta de dançar e pisar nos pés dos seus parceiros, estas botas foram feitas para você!",ep:5,g:77,l:86,wd:true,fm:true,w:10,s:52,p:19150};
I.u[8147] = {n:"Capacete de Crackler Lendário",t:16,d:"Esta é uma versão melhorada do capacete de Crackler. Esta rocha fornece proteção eficiente contra rochas que deslizam, mas não contra a perda de cabelo.",ep:5,g:133,l:80,wd:true,fm:true,w:10,s:52,p:16530};
I.u[8148] = {n:"Martelo de Crackler Lendário",t:7,d:"Este martelo enorme é na verdade uma espada de Crackler, adornada com uma rocha de um lendário Crackler. Esta criação surpreendente surpreenderá seus oponentes, logo antes de esmagá-los.",ep:5,g:58,l:81,wd:true,fm:true,w:10,an:15,e:[7,5,1,1,40,50,false,false],c:"CA>100&CI>50",s:52,p:16850};
I.u[8149] = {n:"Crackleranel Lendário",t:9,d:"Esta rocha adornada com pedras preciosas é perfeita para marcar os tempos ou a testa de seus inimigos para sempre.",ep:18,g:105,l:80,wd:true,fm:true,w:10,s:52,p:16775};
I.u[8150] = {n:"Amuleto de Crackler Lendário",t:1,d:"De aparência modesta, este amuleto contém muitos segredos, incluindo um que conta os segredos que ele contém.",ep:5,g:99,l:84,wd:true,fm:true,w:10,s:52,p:18350};
I.u[8151] = {n:"Gobtubby",t:18,d:"Este monstrinho o seguirá em todos os lugares e comerá os restos dos companheiros dele. Tanto apavorante quanto divertido, ele iluminará sua vida, talvez antes de tirá-la de você para sempre.",ep:3,g:35,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8152] = {n:"Cinto de Crackler Lendário",t:10,d:"O lendário Crackler usa este cinto em torno dos dedos dos pés e você em torno da cintura ou do tornozelo, talvez...",ep:5,g:94,l:80,wd:true,fm:true,w:10,s:52,p:16506};
I.u[8153] = {n:"Treechster",t:18,d:"Este jovem Treechnid não podia mais permanecer em sua família, e como você, ele decidiu se rebelar. Hoje, ele o acompanha e contará todos os membros da família dele que você conseguirá exterminar.",ep:3,g:34,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8154] = {n:"El Scarador",t:18,d:"Esta encantadora coisa pequena é, na verdade, um perigoso besouro. Humilhado por seus amigos quando era mais jovem, ele decidiu começar sua vingança e a ajudá-lo a chutar o traseiro de todo o Escarafolha que você encontrar.",ep:3,g:36,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8155] = {n:"Míni Raposa",t:18,d:"Esta criatura esplêndida é um parente distante do famoso Lenald da Ilha de Wabbits. Muito afobada, mas também muito mais indisciplinada, ela o ajudará durante suas lutas e sua inacreditável traição também ajudará você a derrotar os membros da própria família.",ep:3,g:37,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8156] = {n:"Chave do Calabouço dos Canidaes",t:84,d:"Com esta chave, você poderá entrar neste terrível Calabouço Canidaes. Uma vez lá dentro, você será estripado em uma atmosfera feliz.",ep:1,g:235,l:1,wd:true,fm:true,w:1,p:1};
I.u[8157] = {n:"Pétala Mágica de Girassol Faminto",t:35,d:"Assim como qualquer item mágico, esta pétala impressiona e emite uma aura tão poderosa quanto à crença dos aventureiros que a vêem.",ep:1,g:2,l:20,wd:true,fm:true,w:1,p:100};
I.u[8158] = {n:"Pena Engordurada de Tofu",t:53,d:"O Tofurby se suja regularmente de graxa para suas penas nunca caírem de sua plumagem. Uma técnica tão velha quanto às colinas, que permite aos Enutrofs manterem um pouco de seus cabelos até mesmo após a puberdade.",ep:3,g:1,l:50,wd:true,fm:true,w:1,p:10};
I.u[8159] = {n:"Carapaça do Escarafeio Dourado",t:107,d:"Coloque sua cabeça nesta carapaça para se proteger do mau tempo e dos guanos que caem.",ep:6,g:731,l:70,wd:true,fm:true,w:5,p:100};
I.u[8160] = {n:"Antenas do Escarafeio Dourado",t:15,d:"Se você quer se parecer com Korgamone, o Capão Carpático, é muito simples: finque estas antenas em suas narinas e cante bem alto no condado, girando da esquerda para a direita.",ep:6,g:732,l:70,wd:true,fm:true,w:1,p:100};
I.u[8161] = {n:"Asas do Escarafeio Dourado",t:104,d:"Se você sempre sonhou em voar como um Piwi gordo, prenda estas asas em seu cinto e salte da torre em Brakmar. Se você tiver sorte o bastante, parecerá com um Corvo achatado, oferecendo um pouco de diversão para os brakmarianos e uma bela refeição para outros Corvos.",ep:6,g:733,l:70,wd:true,fm:true,w:1,p:100};
I.u[8162] = {n:"Cabeça de Abópota",t:16,d:"Com esta abópota mágica na cabeça, você parece mais idiota do que o normal. Mas lembre-se da maldição de Al Howin... que os transforma em criaturas desfiguradas...\nparece que esse item para a cabeça é a única coisa que pode protegê-los dessa terrível maldição.",ep:1,g:134,l:1,wd:true,fm:true,w:1,p:1};
I.u[8163] = {n:"Kabuto",t:16,d:"Antes pertencente às autoridades das maiores cidades, este capacete agora é usado para assustar quem se rebela e quer saber mais sobre o universo que o rodeia.",ep:20,g:135,l:101,wd:true,fm:true,w:10,p:26000};
I.u[8164] = {n:"Presente: Gobtubby",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8165] = {n:"Presente: Treechster",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8166] = {n:"Presente: El Scarador",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8167] = {n:"Presente: Mini Raposa",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso mascote, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8168] = {n:"Presente de Al Howin",t:89,d:"Al Howin foi um dos maiores fazendeiros de abópota de todo o continente. Infelizmente, ele também foi um aprendiz de Bwork Mago fascinado demais pelos segredos arcanos. Para conseguir as maiores abópotas cultivadas com estrume de Porcos Selvagens, Al Howin trapaceou pedindo ajuda a Bwork Mago que tentou um novo encantamento nas abópotas. Quem comeu das abópotas mágicas se transformou em estranhas criaturas deformadas por vários dias... e isto acontece todo ano no mesmo período. Esta maldição pode até mesmo ser transmitida a aventureiros que se aproximarem demais das criaturas. Para evitar este infortúnio, os habitantes de Amakna e redondezas colocam uma abópota em suas cabeças por vários dias para que as criaturas sejam poupadas. O mais surpreendente é que parece estar dando certo!",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[8169] = {n:"Transformação em Gobball Halouine",t:27,d:"Você foi transformado em um Gobball Halouine. Para escapar desta terrível maldição, você terá de derrotar outro aventureiro.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
