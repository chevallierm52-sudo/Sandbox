I.u[8231] = {n:"Capa de Piwi Vermelho",t:17,d:"Se você for mesmo pequeno, esta capa feita com algumas penas de Piwi cobrirá o seu traseiro. Uma modesta proteção que chamará a atenção das pessoas para qualquer outra coisa que não seja o seu cabelo oleoso e suas grandes verrugas .",ep:1,g:103,l:1,wd:true,fm:true,w:10,s:60,p:100};
I.u[8232] = {n:"Capa de Piwi Azul",t:17,d:"Se você for mesmo pequeno, esta capa feita com algumas penas de Piwi cobrirá o seu traseiro. Uma modesta proteção que chamará a atenção das pessoas para qualquer outra coisa que não seja o seu cabelo oleoso e suas grandes verrugas .",ep:1,g:104,l:1,wd:true,fm:true,w:10,s:61,p:100};
I.u[8233] = {n:"Capa do Piwi Verde",t:17,d:"Se você é pequeno o bastante, esta capa feita com algumas penas de Piwi pode cobrir suas costas. Uma proteção modesta que atrairá a atenção das pessoas para outra coisa além do seu cabelo oleoso e grandes verrugas.",ep:1,g:105,l:1,wd:true,fm:true,w:10,s:71,p:100};
I.u[8234] = {n:"Capa de Piwi Violeta",t:17,d:"Se você for mesmo pequeno, esta capa feita com algumas penas de Piwi cobrirá o seu traseiro. Uma modesta proteção que chamará a atenção das pessoas para qualquer outra coisa que não seja o seu cabelo oleoso e suas grandes verrugas .",ep:1,g:106,l:1,wd:true,fm:true,w:10,s:62,p:100};
I.u[8235] = {n:"Capa de Piwi Rosa",t:17,d:"Se você for mesmo pequeno, esta capa feita com algumas penas de Piwi cobrirá o seu traseiro. Uma modesta proteção que chamará a atenção das pessoas para qualquer outra coisa que não seja o seu cabelo oleoso e suas grandes verrugas .",ep:1,g:108,l:1,wd:true,fm:true,w:10,s:70,p:100};
I.u[8236] = {n:"Capa de Piwi Amarelo",t:17,d:"Se você for mesmo pequeno,  esta capa feita com algumas penas de Piwi cobrirá o seu traseiro Uma proteção modesta que tirará atenção das pessoas a algo mais do que o seu cabelo gorduroso e as suas grandes verrugas.",ep:1,g:107,l:1,wd:true,fm:true,w:10,s:72,p:100};
I.u[8237] = {n:"Cinto de Piwi Vermelho",t:10,d:"Este pequeno cinto deixará seus quadris mais livres durante uma luta. Então, ele será usado para firmar seu abdome quando um javali agressivo planejar rasgá-lo mata a dentro.",ep:1,g:96,l:1,wd:true,fm:true,w:1,s:60,p:1};
I.u[8238] = {n:"Cinto de Piwi Azul",t:10,d:"Este cinto pequeno liberará seus quadris em uma luta. Então, ele servirá para conter suas tripas quando um agressivo javali das planícies o destripar nas profundezas da floresta.",ep:1,g:97,l:1,wd:true,fm:true,w:1,s:61,p:1};
I.u[8239] = {n:"Cinto de Piwi Violeta",t:10,d:"Este pequeno cinto deixará seus quadris mais livres durante uma luta. Então, ele será usado para firmar seu abdome quando um javali agressivo planejar rasgá-lo mata a dentro.",ep:1,g:98,l:1,wd:true,fm:true,w:1,s:62,p:1};
I.u[8240] = {n:"Cinto do Piwi Verde",t:10,d:"Este pequeno cinto deixará seus quadris mais livres durante uma luta. Então, ele será usado para firmar seu abdome quando um javali agressivo planejar rasgá-lo mata a dentro.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:71,p:1};
I.u[8241] = {n:"Cinto de Piwi Amarelo",t:10,d:"Este pequeno cinto tirará seus quadris para uma luta. Então, ele poderá ser usado para segurar suas banhas quando um simples javali agressivo tentar rasgá-las.",ep:1,g:100,l:1,wd:true,fm:true,w:1,s:72,p:1};
I.u[8242] = {n:"Cinto de Piwi Rosa",t:10,d:"Este pequeno cinto vai enfatizar o seu quadril durante uma luta. Logo, ele será usado para segurar as suas tripas quando um agressivo javali das planícies tiver rasgado você ao meio nas profundezas da floresta.",ep:1,g:101,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8243] = {n:"Chapéu de Piwi Vermelho",t:16,d:"Com este chapéu, você ficará ridículo, mas também extremamente charmoso. A vida é uma questão de escolhas.",ep:1,g:137,l:1,wd:true,fm:true,w:1,s:60,p:1};
I.u[8244] = {n:"Chapéu de Piwi Azul",t:16,d:"Com este chapéu, você ficará ridículo, mas também extremamente charmoso. A vida é uma questão de escolhas.",ep:1,g:138,l:1,wd:true,fm:true,w:1,s:61,p:1};
I.u[8245] = {n:"Chapéu de Piwi Violeta",t:16,d:"Com este chapéu, você ficará ridículo, mas também extremamente charmoso. A vida é uma questão de escolhas.",ep:1,g:139,l:1,wd:true,fm:true,w:1,s:62,p:1};
I.u[8246] = {n:"Chapéu do Piwi Verde",t:16,d:"Com este chapéu, você ficará ridículo, mas também extremamente charmoso. A vida é uma questão de escolhas.",ep:1,g:140,l:1,wd:true,fm:true,w:1,s:71,p:1};
I.u[8247] = {n:"Chapéu de Piwi Amarelo",t:16,d:"Com este chapéu, você parecerá ridículo, mas também vai mostrar todo o seu charme. A vida é cheia de escolhas.",ep:1,g:141,l:1,wd:false,fm:true,w:1,s:72,p:1};
I.u[8248] = {n:"Chapéu de Piwi Rosa",t:16,d:"Com este chapéu, você ficará ridículo, mas ao mesmo tempo extremamente fascinante. A vida é uma questão de escolhas.",ep:1,g:142,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8249] = {n:"Pena de Eufórico",t:53,d:"Esta pena usada e ensopada de energético, é extremamente inflamável. É muito útil para cozinhar um bebedor de energético assado.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[8250] = {n:"Pêlo de Crowfox",t:54,d:"O Crowfox adora se vestir como um Corvo. Ninguém realmente sabe o porquê de até as mais perversas mentes terem sua própria opinião sobre isto...",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[8251] = {n:"Pêlos de Peki",t:54,d:"Quem iria acreditar que um Peki aceitaria dar para você um conjunto de pêlos apenas para lhe agradar? Ninguém, exceto Garlik Jorisk, famoso incompetente de Amakna, conhecido pela sua desonestidade, desleixo, e sua doentia paixão por Pekis empalhados.",ep:18,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[8252] = {n:"Pena de Corvo Domesticado",t:53,d:"Esta gordurosa pena pertence a um Corvo Domesticado que passou a maior parte de sua vida trancado e forçado a comer até ser gordo o suficiente para ocupar completamente o espaço de sua gaiola.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[8253] = {n:"Amuleto Esponja",t:1,d:"Este amuleto é normalmente confundido com uma sacola de brinquedos de sorte, quando, na verdade, é algo para você acertar como um alvo para tiro.",ep:1,g:106,l:11,wd:true,fm:true,w:2,s:63,p:525};
I.u[8254] = {n:"Anel Esponja",t:9,d:"Oferecer uma aliança significa duas coisas: \"Eu te amo\" e \"Vá lavar a louça\". Perfeito para quem odeia repetir sempre a mesma coisa.",ep:1,g:112,l:10,wd:true,fm:true,w:2,s:63,p:500};
I.u[8255] = {n:"Pá Esponja",t:8,d:"Muitos aventureiros iniciantes deverão se lembrar desta terrível e poderosa arma contra os montes de terra. Depois de encharcada, ela se torna leve e pode ser rolada e geralmente exige duas pessoas para isso.",ep:1,g:44,l:10,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,true],s:63,p:500};
I.u[8256] = {n:"Botas Esponja",t:11,d:"Com estas botas, um Eniripsa pode caminhar sobre a água, algo bem inútil, já que eles podem voar, e isto sempre atrai a multidão. Outros podem sempre usar estas botas para arranhar os pés, enquanto caminham ou simplesmente os lavam.",ep:1,g:84,l:11,wd:true,fm:true,w:5,s:63,p:525};
I.u[8257] = {n:"Cinto Esponja",t:10,d:"Este cinto possibilitou que Vald tomasse o seu banho sem arriscar a vida. De fato, nenhum Iop aprendeu com sucesso a nadar.",ep:1,g:102,l:10,wd:true,fm:true,w:5,s:63,p:500};
I.u[8258] = {n:"Capa Esponja",t:17,d:"Esta capa é perfeita para camuflagem em um ambiente natural, porém, só se ninguém o ver.",ep:1,g:109,l:10,wd:true,fm:true,w:1,s:63,p:505};
I.u[8259] = {n:"Capacete Esponja",t:16,d:"Nestas instruções, pode ser lido: “Ofereço este capacete ao seu marido. Junto à cabeça dele e arrastado pelos pés em sua cozinha. Você sabia que tem um chão claro e limpo”. É um resumo da concepção nova e moderna de como um casal deve ser e de como deve compartilhar as tarefas domésticas.",ep:1,g:143,l:11,wd:true,fm:true,w:10,s:63,p:525};
I.u[8260] = {n:"Bandana Kaliptus",t:16,d:"Esta bandana fará Iops parecerem mais belos do que nunca!",ep:20,g:124,l:133,wd:true,fm:true,w:10,p:43500};
I.u[8262] = {n:"Um Moolet",t:1,d:"O Moolet contém uma estranha substância achada nas vísceras de um Moolobo. Alguns dizem que é a essência do monstro, mas outros dizem que é apenas alguns Kirball que ele comeu.",ep:20,g:107,l:143,wd:true,fm:true,w:1,s:55,p:44850};
I.u[8263] = {n:"Anel de Moolobo",t:9,d:"Tenha cuidado! Este anel fará o seu dedo feder. Um cheiro que pode encobrir outro e isso pode ser uma ótima coisa para você e seu círculo...",ep:20,g:113,l:126,wd:true,fm:true,w:10,s:55,p:40190};
I.u[8264] = {n:"Botas de Moolobo",t:11,d:"Estas botas ainda são movidas pelo apetite voraz do Moolobo. Se seus pés cheirarem a queijo, elas, provavelmente, os morderão.",ep:18,g:85,l:131,wd:true,fm:true,w:20,s:55,p:42840};
I.u[8265] = {n:"Capa de Moolobo",t:17,d:"O Moolobo tem um belo rabo longo e fofo, que se arrasta pelo chão. Cheios de inveja, alguns aventureiros o arrancaram e, agora, eles o usam na esperança de ficar mais viris.",ep:20,g:110,l:139,wd:true,fm:true,w:10,s:55,p:44500};
I.u[8266] = {n:"Cinto de Moolobo",t:10,d:"Este cinto colorido tem um maravilhoso tufo de pêlos púrpura na frente e, se usá-lo ao contrário, você poderá passar por um Wabbit.",ep:20,g:103,l:125,wd:true,fm:true,w:1,s:55,p:1};
I.u[8267] = {n:"Capacete Moolobo",t:16,d:"Enquanto desmembrava o Moolobo, caçadores descobriram que ele só tem um grande chifre cruzando seu crânio. Mas isto não parece aborrecer os Iops que orgulhosamente o usam.",ep:4,g:144,l:141,wd:true,fm:true,w:10,s:55,p:44600};
I.u[8268] = {n:"Colar de Minotoro",t:1,d:"Este colar protegeu o Minotoro de pegar pulgas, carrapatos e até mesmo piolhos. Pelo que parece, você realmente precisou disso.",ep:18,g:112,l:111,wd:true,fm:true,w:1,s:54,p:31260};
I.u[8269] = {n:"Anel de Minotoro",t:9,d:"Ao contrário do que alguns aventureiros possam pensar, este anel nunca foi usado pelo Minotoro, que era incapaz de pôr tal anel em seus cascos.",ep:21,g:117,l:105,wd:true,fm:true,w:1,s:54,p:28010};
I.u[8270] = {n:"Bracelete de Minotot",t:9,d:"Esta pulseira protege completamente o braço de um Eniripsa, mas triplica o seu peso.",ep:21,g:116,l:151,wd:true,fm:true,w:10,s:57,p:45425};
I.u[8271] = {n:"Anel de Dragão-Porco",t:9,d:"Este anel feito de couro e marfim torna fácil para você estimular seus companheiros.",ep:18,g:115,l:108,wd:true,fm:true,w:1,s:58,p:29600};
I.u[8272] = {n:"Colar de Minotot",t:1,d:"Este colar protege as vértebras cervicais do Minotot dos socos letais do Wabbit.",ep:21,g:111,l:158,wd:true,fm:true,w:20,s:57,p:47800};
I.u[8273] = {n:"Colar de Dragão-Porco",t:1,d:"Este colar tem uma pequena fivela, na qual o dono do Dragão-Porco podia prender uma corrente, a fim de levá-lo para um passeio noturno.",ep:21,g:110,l:100,wd:true,fm:true,w:1,s:58,p:25470};
I.u[8274] = {n:"Machado de Minotoro",t:19,d:"Este machado realmente decapitou um dos Minotoros mais perigosos da província de Amakna. O mais inacreditável nesta história é que você parece completamente indiferente a ela.",ep:21,g:44,l:109,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,40,50,false,true],s:54,p:30110};
I.u[8275] = {n:"Cetro de Minotot",t:4,d:"Este cetro, com uma cabeça de serpente feita de pedras preciosas em sua extremidade, lhe permite amedrontar jovens aventureiros e chutar seus traseiros rosados.",ep:21,g:67,l:151,wd:true,fm:true,w:50,an:12,tw:true,e:[5,4,1,1,40,50,false,false],s:57,p:46200};
I.u[8276] = {n:"Botas de Minotoro",t:11,d:"Estas terríveis botas feitas de couro e pêlo de Minotoro são, obviamente, muito pesadas para fazer você ganhar a lendária corrida da Baía de Amakna. Entretanto, elas permitirão que você esmague os pés dos outros competidores na linha de partida.",ep:21,g:89,l:113,wd:true,fm:true,w:40,s:54,p:32290};
I.u[8277] = {n:"Sandálias de Minotot",t:11,d:"Estas incríveis sandálias lhe permitirão tomar banho nas águas mais perigosas sem o risco de machucar seus pés. Entretanto, tenha cuidado, dizem que elas arranham o fundo de banheiras.",ep:21,g:88,l:163,wd:true,fm:true,w:20,s:57,p:48400};
I.u[8278] = {n:"Chinelos de Dragão-Porco",t:11,d:"Um bom par de chinelos e você se sentirá bem mais forte, mais poderoso e até mesmo mais eficiente de alguma maneira. Ainda que eles sejam apenas chinelos!",ep:20,g:87,l:93,wd:true,fm:true,w:5,s:58,p:22800};
I.u[8279] = {n:"Manto de Minotoro",t:17,d:"Pegue um Minotoro. Amarre-o com firmeza. Pegue um avião gigante e em uma só passagem, descasque sua parte de trás. Pronto! Você conseguiu seu Manto de Minotoro!",ep:21,g:117,l:109,wd:true,fm:true,w:10,s:54,p:30500};
I.u[8280] = {n:"Manto de Minotot",t:17,d:"Esta é a capa perfeita para sair ou para praticar seu poder de sedução no baile de máscaras do Capitão Chafer.",ep:21,g:116,l:156,wd:true,fm:true,w:40,s:57,p:48850};
I.u[8281] = {n:"Manto de Dragão Porco",t:17,d:"Este manto não o tornará um Leitão, mas lhe permitirá vestir-se bem por uma noite, então, você poderá seduzir uma bela porca.",ep:20,g:118,l:103,wd:true,fm:true,w:10,s:58,p:27500};
I.u[8282] = {n:"Cinto de Minotoro",t:10,d:"Este cinto flexível pode ser usado para chicotear o traseiro de crianças teimosas. Sua fivela poderia até marcar a pele delas, mas isso apenas as ensinaria uma lição de uma vez por todas.",ep:21,g:106,l:111,wd:true,fm:true,w:1,s:54,p:1};
I.u[8283] = {n:"Cinto de Minotot",t:10,d:"O Minotot usou este forte cinto para conter a sua enorme pança, prevenindo-o de tombar toda vez que havia uma corrente de ar.",ep:21,g:105,l:149,wd:true,fm:true,w:30,s:57,p:49950};
I.u[8284] = {n:"Capacete Minotot",t:16,d:"Este capacete passou de geração em geração na família Minotot. Isto explica parcialmente o motivo de cheirar a caspas em decomposição.",ep:21,g:151,l:157,wd:true,fm:true,w:20,s:57,p:47652};
I.u[8285] = {n:"Capacete de Dragão-Porco",t:16,d:"Com este enorme crânio, você parecerá um Grizbola de pêlo áspero eriçado, mas sem pêlos. Seus admiradores ficarão mudos.",ep:20,g:150,l:98,wd:true,fm:true,w:10,s:58,p:24500};
I.u[8286] = {n:"Capa de Dragonete",t:17,d:"De acordo com a lenda, esta capa coberta por escamas o protegerá de raios, feijões e, acima de tudo, das mulheres fatais....",ep:11,g:115,l:127,wd:true,fm:true,w:10,s:56,p:41000};
I.u[8287] = {n:"Capacete de Dragonete",t:16,d:"Um anjinho como você poderia facilmente passar por um guerreiro impiedoso com tal capacete horripilante e desproporcional. Uma vez pregado a uma parede, será um cabideiro.",ep:11,g:149,l:128,wd:true,fm:true,w:10,s:56,p:41500};
I.u[8288] = {n:"Cinto de Dragonete",t:10,d:"As mais pervertidas mentes de Amakna dizem que este cinto poderia ser usado como prótese. Ninguém entendeu o porquê e, felizmente, isto foi apenas um rumor falso. É apenas um simples Cinto de Dragonete.",ep:20,g:104,l:124,wd:true,fm:true,w:1,s:56,p:1};
I.u[8289] = {n:"Anel de Dragonete",t:9,d:"Este anel, esculpido diretamente em uma escama gigante de Dragonete, protegerá uma pequena parte da sua falange. Provavelmente, o mais importante.",ep:20,g:114,l:128,wd:true,fm:true,w:10,s:56,p:41468};
I.u[8290] = {n:"Amuleto de Dragonete",t:1,d:"Feito de escamas de Dragonete, este amuleto protegerá eficazmente o seu pomo-de-adão ou suas amídalas. Ele fará toda a diferença em um campo de batalha.",ep:11,g:108,l:124,wd:true,fm:true,w:1,s:56,p:38930};
I.u[8291] = {n:"Botas de Dragonete",t:11,d:"Estas botas são perfeitas para matar Gobballs durante uma partida de Gobbol ou fazer seus inimigos sofrerem um pouco mais durante as sessões de espancamento.",ep:20,g:86,l:129,wd:true,fm:true,w:20,s:56,p:41500};
I.u[8292] = {n:"Espada de Dragonete",t:6,d:"Tão afiada quanto uma navalha, esta lâmina lhe permitirá se barbear de manhã, mas somente as axilas.",ep:11,g:68,l:127,wd:true,fm:true,w:30,an:14,e:[8,5,1,1,40,50,false,true],c:"CS>200&CA>200",p:41025};
I.u[8293] = {n:"Machado de Dragonete",t:19,d:"Este machado racha crânios tão facilmente quanto faria com uma manteiga.",ep:20,g:43,l:126,wd:true,fm:true,w:20,an:17,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>180&CW>80",p:40854};
I.u[8294] = {n:"Martelo de Dragonete",t:7,d:"Mais pesado que um crânio vazio de Munchor, porém menos sólido que um fêmur de Kirball das Cavernas, este martelo, ainda assim, é uma arma bastante perigosa.",ep:20,g:59,l:123,wd:true,fm:true,w:30,an:15,e:[10,5,1,1,45,50,false,true],c:"CI>200&CC>100",p:38542};
I.u[8295] = {n:"Arco de Dragonete",t:2,d:"Este arco é tão poderoso que pode mandar ovos podres de Dragonete acima da grande muralha de Brakmar. Que desperdício maravilhoso!",ep:20,g:55,l:122,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,8,40,50,false,true],c:"CS>300&CV>250",p:38015};
I.u[8296] = {n:"Varinha Mágica de Dragonete",t:3,d:"Esta varinha mágica parece ser muito mais eficiente quando usada como um cacetete ou como um Mata-Moskitos!",ep:21,g:60,l:124,wd:true,fm:true,w:10,an:11,e:[5,3,2,5,30,30,false,true],c:"CI>100&CA>200",p:37884};
I.u[8297] = {n:"Cajado de Dragonete",t:4,d:"Em uma de suas extremidades, este cajado possui uma grande ponta e ninguém sabe de onde ela veio. Entretanto, alguns aventureiros bem informados sabem para onde ela deveria ir...",ep:20,g:66,l:124,wd:true,fm:true,w:30,an:12,tw:true,e:[5,5,1,1,30,50,false,true],c:"CS>300&CA>150&CV>300",p:39800};
I.u[8298] = {n:"Orelhas de Shika",t:1,d:"Shika costumava ajudar Farle a colher pegando as orelhas mágicas que caiam sob a foice dele. Ela costumava fazer um colar das orelhas. Apesar de estarem desprovidas de suas raízes e do resto de seu caule, estas orelhas mágicas continuavam a florescer a cada ano no mesmo período.",ep:18,g:113,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8299] = {n:"Bracelete Mágico de Shika",t:9,d:"Este bracelete cobria os braços de Shika. Desta maneira, ele protegia Shika de queimaduras do sol e de bicadas de Corvos, que eram atraídos pela sua beleza estonteante. Os braceletes ainda estão impregnados com o doce suor dela.",ep:21,g:118,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8300] = {n:"Cajado de Shika",t:4,d:"Feito para medir, este cajado permitia que Shika fizesse os mais altos montes de palha de toda Amakna. A lenda diz que eles eram tão grandes que os marinheiros os usavam como marcas para saber se estavam se aproximando ou não da costa de Amaknean.",ep:20,g:69,l:80,wd:true,fm:true,w:10,an:12,e:[10,5,1,1,45,45,false,false],s:53,p:16500};
I.u[8301] = {n:"Tamancos de Shika",t:11,d:"Estes tamancos foram criados para Shika para que ela não pisasse no solo arado quando semeava as planícies de Snossios. Ela acrescentou saltos altos nos tamancos para facilitar a corrida no restolho sem machucar seus tornozelos ou que o orvalho molhasse seus tamancos.",ep:21,g:91,l:80,wd:true,fm:true,w:10,s:53,p:16600};
I.u[8302] = {n:"Capa de Shika",t:17,d:"Flores dos tempos de colheita foram costuradas nesta capa feita de cereais mágicos. Guiada por tal mágica poderosa, Shika usou a capa como proteção contra raios durante noites tempestuosas.",ep:20,g:120,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8303] = {n:"Cinto de Shika",t:10,d:"Este cinto feito de couro costumava proteger as coisas de Shika, quando ela passava pelos campos de trigo para trazer de volta ao rebanho Gobballs perdidos. Coberto de pólen de cereais mágicos, a lenda diz que o cinto brilhava nas noites de luar e não deixava que Farle cortasse as pernas de sua esposa enquanto faziam a colheita nos campos de cereais.",ep:21,g:107,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8304] = {n:"Chapéu de Shika",t:16,d:"Coberto com uma grande quantidade de flores, este chapéu fez Shika parecer feliz e resplandecente quando ela saáa ao nascer do sol para lavrar as Colinas da Igreja.",ep:20,g:156,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8305] = {n:"Relíquia de Mumminotor",t:24,d:"Esta estranha relíquia é essencial para você encontrar o Minotoro.",ep:21,g:119,l:1,wd:false,fm:true,w:0,p:1};
I.u[8306] = {n:"Relíquia de Deminobola",t:24,d:"Esta estranha relíquia é essencial para você encontrar o Minotoro.",ep:21,g:120,l:1,wd:false,fm:true,w:0,p:1};
I.u[8307] = {n:"Chave da Sala do Minotot",t:84,d:"Feita de diversos recursos, esta chave lhe permitirá conhecer o incrível Minotot. Um encontro que marcará a sua vida, já que o coice do Minotot no traseiro é bastante memorável.",ep:13,g:15,l:1,wd:true,fm:true,w:1,p:10};
I.u[8308] = {n:"Concha de Escaratos",t:107,d:"Esta pequena concha brilhante é muito útil para criar belas jóias a um custo baixo, assim você poderá vender uma fortuna após convencer um Astrubiano de que é uma relíquia poderosa que permitirá voar e ficar invisível.",ep:21,g:735,l:1,wd:true,fm:true,w:1,p:10};
I.u[8309] = {n:"Pena de Quetsnakiatl",t:53,d:"Esta pena é coberta com pó de pedra mágica que explica o motivo de uma unidade de pena de Quetsnakiatl ser mais pesada que três unidades de penas de Tofu. Tudo faz sentido.",ep:21,g:4,l:1,wd:true,fm:true,w:10,p:1};
I.u[8310] = {n:"Geléia de Geldice",t:110,d:"Este pote de geléia contém um cheiro repulsivo e um gosto espantoso, e, ainda, você está sonhando secretamente em ser coberto por ela. Mais um comportamento estranho que pode esconder dos outros...",ep:21,g:736,l:1,wd:true,fm:true,w:1,p:1};
I.u[8311] = {n:"Cabelo de Minokid",t:54,d:"Este cabelo parece coberto com um tipo de gel à base de almíscar de Tuftie de pêlo curto e de graxa de Kirball das cavernas. Eles quase parecem apetitosos.",ep:21,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[8312] = {n:"Pele de Minoskito",t:59,d:"Desgastada pela areia e pelo sal do mar, esta pele é tão fina quanto uma meia velha desgastada pela areia e pelo sal do mar. Bem, talvez você quisesse dizer que o Minoskito parece uma meia velha, mas você não dirá.",ep:21,g:604,l:1,wd:true,fm:true,w:1,p:1};
I.u[8313] = {n:"Fêmur de Minotoro",t:47,d:"Este osso é forte o bastante para ser usado como uma viga mestra ou para quebrar tijolos em dez partes. Ele pode ser muito útil para destruir a casa de seus vizinhos, mas é inútil para pessoas lúcidas.",ep:2,g:644,l:1,wd:true,fm:true,w:1,p:1};
I.u[8314] = {n:"Pele de Khamelerost",t:59,d:"Esta pele queimada protege peles sensíveis dos raios solares. É uma pele particularmente justa.",ep:21,g:603,l:1,wd:true,fm:true,w:1,p:1};
I.u[8315] = {n:"Pele de Manderisha",t:59,d:"Dizem que esta pele manchada é coberta com um veneno capaz de secar qualquer Karaball.",ep:21,g:602,l:1,wd:true,fm:true,w:1,p:1};
I.u[8316] = {n:"Míni Raposa: Como criar seu animal favorito",t:25,d:"Este livro, escrito por Oshimo Bigglip, explica como criar uma Minifoux.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8317] = {n:"El Scarador: Como criar seu animal favorito",t:25,d:"Este livro, escrito por Oshimo Bigglip, explica como criar El Scarador.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8318] = {n:"Treechster: Como criar seu animal favorito",t:25,d:"Este livro, escrito por Oshimo Bigglip, lhe explica como criar um Treechster.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8319] = {n:"Gobtubby: Como criar seu animal de estimação favorito",t:25,d:"Este livro, escrito por Oshimo Bigglip, lhe explica como criar um Gobtubby.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8320] = {n:"Chave da Caverna do Dragão-Porco",t:84,d:"Depois de entrar no labirinto do Dragão-Porco e se perder, você percebeu que esqueceu de trazer a sua chave da Caverna do Dragão-Porco. Felizmente, seus amigos Porcos tinham uma chave reserva com eles.",ep:15,g:16,l:1,wd:true,fm:true,w:1,p:100};
I.u[8321] = {n:"Pêlo de Deminobola",t:54,d:"É inútil insistir! Estes pêlos não são comestíveis.",ep:21,g:664,l:100,wd:true,fm:true,w:1,p:10};
I.u[8322] = {n:"Pêlo de Mumminotor",t:54,d:"Debaixo de sua bandagem, o Mumminotor esconde uma penugem muito macia, que deixaria com inveja a mais emplumada das princesas.",ep:21,g:663,l:100,wd:true,fm:true,w:1,p:10};
I.u[8323] = {n:"Couro de Deminobola",t:56,d:"Este couro rachado e áspero lhe lembrará as bochechas de sua amada.",ep:21,g:657,l:100,wd:true,fm:true,w:1,p:10};
I.u[8324] = {n:"Couro de Muminotor",t:56,d:"O Muminotor sempre teve uma pele sensível, é por isso que ele deve ser coberto com muitas bandagens. Os maldosos fofoqueiros dizem que é para esconder outras coisas surpreendentes....",ep:21,g:656,l:100,wd:true,fm:true,w:1,p:10};
I.u[8325] = {n:"Capacete de Mumminotor",t:16,d:"Se você quer proteger seu rostinho lindo do intemperismo, sugerimos este capacete. Ele faz um grande adulto forte também...",ep:0,g:157,l:110,wd:false,fm:true,w:10,s:59,p:100};
I.u[8326] = {n:"Bandagem de Mumminotor",t:15,d:"Enrolada nos chifres, mas especialmente nas partes íntimas do Muminotor, esta bandagem ficou impregnada com a magia do Muminotor, com o passar dos anos. Fedorenta e apavorante, esta bandagem é um elemento essencial para arqueólogos famosos colecionarem.",ep:21,g:734,l:100,wd:true,fm:true,w:1,p:10};
I.u[8327] = {n:"Chifre de Deminobola",t:47,d:"À primeira vista, este impressionante chifre não parece ser muito útil. E, mesmo se você olhar mais de perto, continua não parecendo muito útil: como um exército de carrapatos.",ep:21,g:643,l:100,wd:true,fm:true,w:1,p:10};
I.u[8328] = {n:"Chifre de Mumminotor",t:47,d:"Enrolado em uma bandagem mágica, este chifre deve ser extremamente caro, muito precioso, muito fedorento e amaldiçoado. Um pouco como uma múmia seria.",ep:21,g:642,l:100,wd:true,fm:true,w:1,p:10};
I.u[8329] = {n:"Chave da Mina de Sakai",t:84,d:"Quem iria querer a chave para uma mina abandonada em uma ilha congelada, perdida e guardada por estranhos goblins que buscam desesperadamente uma pepita perdida?",ep:1,g:256,l:200,wd:true,fm:true,w:10,p:10};
I.u[8330] = {n:"Elmo de Dragonete Voador",t:16,d:"Este pequeno elmo permite ao Dragonete Voador atacar seus inimigos sem arriscar ser machucado ao contundir as cabeças deles. Ele foi usado por muito tempo nas maiores construções de Amakna. Este elmo tornou-se bastante popular depois que os Moolobos vindos da Montanha de Kruup invadiram Astrub. Não existe lógica nesta história... mas o que importa?",ep:13,g:152,l:72,wd:true,fm:true,w:10,p:16000};
I.u[8331] = {n:"Chapéu de Dragoss",t:16,d:"Com este chapéu, você ficará charmoso e atraente. Dizem até que você conseguirá conquistar um Astrubiano!",ep:18,g:153,l:95,wd:true,fm:true,w:10,p:23000};
I.u[8333] = {n:"Capa de Papai Nowel",t:17,d:"Esta misteriosa capa apareceu durante as temporadas frias e permite que impostores finjam ser velhos extremamente generosos.",ep:1,g:119,l:19,wd:true,fm:true,w:10,p:1205};
I.u[8334] = {n:"Chapéu de Papai Nowel",t:16,d:"Este chapéu permitirá que você esconda as cicatrizes em sua cabeça. Dessa forma, as crianças gostarão mais de você.",ep:1,g:155,l:22,wd:true,fm:true,w:10,p:1478};
I.u[8335] = {n:"Pequeno Presente de Nowel",t:89,d:"A Equipe Ankama lhe manda suas mais sinceras saudações da temporada. Este presente lhe fará mais feliz que nunca.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8336] = {n:"Pequeno Presente de Nowel",t:89,d:"O Time Ankama envia a você suas mais calorosas saudações da temporada. Este presente o tornará mais feliz que nunca.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8337] = {n:"Presente de Nowel",t:89,d:"A Equipe Ankama lhe manda suas mais sinceras saudações da temporada. Este presente lhe fará mais feliz que nunca.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8338] = {n:"Espada de Nowel",t:6,d:"Esta espada estranha não o tornará invencível, mas pode ser usada para fatiar bolas de neve.",ep:1,g:69,l:1,wd:false,fm:true,w:1,an:14,e:[1,1,1,1,2,2,false,true],p:1};
I.u[8339] = {n:"Grande Presente de Nowel",t:89,d:"A Equipe Ankama lhe manda suas mais sinceras saudações da temporada. Este presente lhe fará mais feliz que nunca.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8340] = {n:"Presente Incrível de Nowel",t:89,d:"A equipe de Ankama envia a você cumprimentos da estação mais quente. Este presente o fará mais feliz que nunca.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8341] = {n:"Abacabotas",t:11,d:"Estas botas tem cheiro de suco de abacaxi misturado com meias molhadas. A grande sacada é que quando você visitar seus amigos, eles nunca vão lhe pedir para tirar os sapatos.",ep:1,g:90,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8342] = {n:"Chave do Santuário dos Dragonetes",t:84,d:"Esta chave feita de carapaça de Dragonete lhe dará acesso ao terrível Santuário dos Dragonetes, onde os habitantes são conhecidos por não ser muito tagarelas.",ep:10,g:18,l:1,wd:true,fm:true,w:1,p:100};
I.u[8343] = {n:"Chave do Calabouço do Dragonete",t:84,d:"Você pensou que já havia passado por tudo quando entrou no Santuário dos Dragonete, mas entendeu tudo errado! Esta chave o levará para uma morte certa.",ep:10,g:17,l:1,wd:true,fm:true,w:1,p:100};
I.u[8344] = {n:"Chifre de Dragoss Preto",t:47,d:"Não é tão pontiagudo quanto o ponteiro do relógio de um Xelor, porém, é muito mais forte. Este chifre permite aos Dragoss transformar uma sessão de surra em outra de espancamento.",ep:11,g:648,l:50,wd:true,fm:true,w:1,p:10};
I.u[8345] = {n:"Chifre de Dragoss Safira",t:47,d:"Não é tão pontiagudo quanto o ponteiro do relógio de um Xelor, porém, é muito mais forte. Este chifre permite ao Dragoss transformar uma sessão de surra em outra de espancamento.",ep:11,g:647,l:50,wd:true,fm:true,w:1,p:10};
I.u[8346] = {n:"Chifre de Dragoss Branco",t:47,d:"Não é tão pontudo como uma agulha de Xelor, mas é bem mais sólido. Este chifre permite aos Dragoss se transformar em batedores até quebrar um.",ep:11,g:646,l:50,wd:true,fm:true,w:1,p:10};
I.u[8347] = {n:"Chifre de Dragoss Dourado",t:47,d:"Não é pontiagudo como um ponteiro Xelor, porém, é mais sólido. Este chifre permite aos Dragoss transformar Spanking em Cracking.",ep:11,g:645,l:50,wd:true,fm:true,w:1,p:10};
I.u[8348] = {n:"Concha de Dragoss Preto",t:111,d:"Esta concha pode ser usada para proteger o que é mais precioso para você.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Concha de Dragoss Safia",t:111,d:"Você pode usar esta concha para proteger seus bens mais preciosos.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
I.u[8350] = {n:"Casco de Dragoss Branco",t:111,d:"Pode se usar este casco para proteger o que é mais precioso para você.",ep:11,g:740,l:50,wd:true,fm:true,w:1,p:10};
I.u[8351] = {n:"Concha de Dragoss Dourado",t:111,d:"Você pode usar esta concha para proteger o que tiver de mais precioso.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Escama de Dragoss Preto",t:59,d:"Você podia usar esta escama para fazer um par muito bom de botas ou roupa íntima de luta.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Escama de Dragoss Safira",t:59,d:"Você pode usar estas escamas para fazer um par de botas ou uma rouba de baixo para lutar.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"Escama de Dragoss Branco",t:59,d:"Pode-se usar esta escama para fazer um lindo par de botas ou roupas de baixo para lutadores.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Escama de Dragoss Dourado",t:59,d:"Você pode usar esta escama para fazer um belo par de botas ou uma roupa debaixo para luta.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Pele de Dragostess",t:59,d:"Macia e perfumada com o sangue de jovens aventureiros, esta pele faz das Dragostesses, irresistíveis. Usada para fazer botas ou cintos, esta pele pode ser lavada em máquina de lavar, a qualquer temperatura.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Chifre de Dragostess",t:47,d:"A Dragostess tem dois chifres pequenos atrás da cabeça. Estes lhe permitem capturar facilmente as ondas de amor enviadas pelos Dragonetes durante a época de acasalamento, que, na verdade, nunca acaba para eles.",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Proteção de Dragostess",t:111,d:"Este par de cascas de Dragonete protege a Dragostess do amor à primeira vista. Os machos também podem usá-las mas eles terão que vesti-las por baixo do cinto.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Asa de Dragonete Voador",t:104,d:"Até quando esta asa for danificada, rasgada e queimada, o Dragonete Voador pode ainda voar livremente acima de tudo como um Moskito jovem despreocupado.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Pele de Dragonete Voador",t:59,d:"Esta pele escura é coberta com uma multidão de pequenas escamas que deveriam melhorar a aerodinâmica do Dragonete Voador. De fato, elas são inúteis e só servem para impressionar as pessoas.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Chifre de Dragonete Voador",t:47,d:"Os dragonetes voadores usam o chifre como uma ferramenta na hora de beber ou para não perder o alvo.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Pele de Dragonete Guerreiro",t:59,d:"Forte o suficiente para resistir à sua própria lâmina, a pele de Dragonete Guerreiro é também conhecida por ser comestível depois de ser fervida por vários anos.",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Chifre de Dragonete Guerreiro",t:47,d:"O Dragonete Guerreiro tem três chifres diferentes: dois atrás da cabeça e um terceiro no focinho. Depois de uma luta, um chifre normalmente acaba nas costas de uma das vítimas dele, e os outros dois grudados nas narinas de um imprudente. Mas, de vez em quando, o Dragonete Guerreiro confunde as costas com as narinas e isto só piora as coisas para suas vítimas.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Tira de Couro de Dragonete Guerreiro",t:15,d:"Esta correia de couro permite ao Dragonete Guerreiro prender sua dragona ou substituir seus suspensórios.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Chifre Quebrado de Crocabulia",t:47,d:"Crocabulia quebrou o seu próprio chifre em uma terrível luta, enquanto protegia um ovo que deu à luz Crocoburio 15 anos mais tarde.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Capa Bamboleante Vermelhinha",t:17,d:"Esta capa costumava pertencer a um famoso Capão, um pássaro de penas longas que adorava regozijar em frente ao Zaap de Bonta onde todas as galinhas ingênuas e imatura moravam.",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Pele de Crocabulia",t:59,d:"Esta pele vermelha lhe permitirá fazer uma capa para o Bamboleante Capãozinho Vermelho, se você não temer a gozação de seus aliados.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Dente de Crocabulia",t:47,d:"Este enorme dente foi arrancado no último minuto, um pouco antes de a Crocabulia fechar seu focinho para sempre.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Pedaço de Escama de Terrakubiack, O Guerreiro",t:111,d:"Este pedaço de escama pertencente ao Terrakubiack, o Guerreiro, deve ajudar você a fazer uma chave para acessar o Santuário do Dragonete.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Pedaço de Escama de Ignilicrobur, O Guerreiro",t:111,d:"Este pedaço de escama pertencente ao Ignilicrobur, o Guerreiro, deve ajudar você a fazer uma chave para acessar o Santuário do Dragonete.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Pedaço de Escama de Aeroktor, O Guerreiro",t:111,d:"Este pedaço de escama pertencente ao Aeroktor, o Guerreiro, deve ajudar você a fazer uma chave para acessar o Santuário do Dragonete.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Pedaço de Escama de Aquabralak, O Guerreiro",t:111,d:"Este pedaço de escama pertencente ao Aquabralak, o Guerreiro, deve ajudar você a fazer uma chave para acessar o Santuário do Dragonete.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Pedra de Ignirkocropos, O Faminto",t:51,d:"Esta pedra pode libertar uma mágica poderosa que ativará a abertura de uma porta mágica, se e somente se combinada com as três outras pedras perdidas.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Pedra de Aqualikros, O Cruel",t:51,d:"Esta pedra pode libertar uma mágica poderosa que ativará a abertura de uma porta mágica, se e somente se combinada com as três outras pedras perdidas.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Pedra de Terraburkahl, O Pérfido",t:51,d:"Esta pedra pode libertar uma mágica poderosa que ativará a abertura de uma porta mágica, se e somente se combinada com as três outras pedras perdidas.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Pedra de Aerogoburius, O Malicioso",t:51,d:"Esta pedra pode libertar uma mágica poderosa que ativará a abertura de uma porta mágica, se e somente se combinada com as três outras pedras perdidas.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Runa de Marceneiro",t:88,d:"Esta pedra mágica permite aos Alquimistas informarem sua posição aos clientes.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Fragmento Mágico",t:88,d:"Este fragmento contém um pouco de magia transferida por um objeto antigo.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Runa Vie",t:78,d:"Esta pequena runa deixará você mais resistente.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Tecido de Peki",t:55,d:"Este tecido costumava cobrir a parte do Peki antes que você decidisse usá-la de forma errada.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Cauda Mágica de Peki",t:65,d:"Esta cauda é tão mágica que ainda sacode mesmo após ter sido cortada, seca e empalhada! Se você for muito esperto, vai encontrar outro uso, além de apenas pendurá-la sobre a lareira.",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Pele da Lua",t:59,d:"Destituído de sua macia pele, a pobre Lua foi pega de surpresa e só conseguiu fugir para a selva gritando de dor. Esta é uma boa história para dormir que você gostará de contar para seus filhos para fazê-los pegar no sono.",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Tecido Mágico da Lua",t:55,d:"Este tecido parece ser mágico;\r\n            é difícil de acreditar que você o encontrou. Mas um dia você terá de encarar a verdade... Você é tão estúpido para dizer se alguma coisa é mágica ou não. Não siga seu instinto astrubiano e confie nas descrições.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Pele de Larva Shin",t:59,d:"Esta pele de Larva Shin é a mais pegajosa e nojenta que você jamais imaginou. Ela lembra você da última princesa que você resgatou.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Dente de Larva Shin",t:47,d:"Ninguém jamais acreditaria que uma Larva Shin teria uma boca cheia de dentes. Provavelmente, é porque Larva Shin tem somente um dente.",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Pena Vibrante de Tofu Real",t:53,d:"Mais real que a pena de Tofu Real, mais vibrante que o vibrante Kirball das minas de Kruup, esta pena faz cócegas em quem você quiser, onde quer que seja. As instruções dizem que é simples de se cuidar.",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Pele de Bworkette",t:59,d:"A Bworkette deixa pegar um pouco da pele dela em troca de sua clemência. Mas ela se esqueceu de lhe dizer que seu grande irmão Bworker ficará mais do que feliz de rasgar a sua!!!",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Pêlo de Bworkette",t:54,d:"A Bworkette tem uma pele muito macia, com exceção das axilas dela. Bem, os biscoitinhos que ela rola debaixo de suas axilas têm que ser saborosos, não têm?",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Pele de Porco de Farle",t:59,d:"Se você escutar o que criadores dizem, Farle era o maior criador de porco (porcos e porcas). Mas todos eles tinham ciúmes de Shika. De qualquer maneira, o que é certo é que ele foi quem criou os Porcos de Farle, aos quais ele deu seu nome, já que eles haviam sido feitos à sua imagem.",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"Pele de Dorgan Ation",t:59,d:"O Dorgan Ation foi, mais uma vez, extremamente generoso com você, apesar do temperamento ruim dele. Ele lhe dá sua pele antes de partir e gemer como um Porco Imundo. Que ousadia!",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"Pele de Blodz Uker",t:59,d:"O Blodz Uker que você descascou com um ralador de queijo para conseguir uma fina pele;\r\n            vai se lembrar disto por toda a vida. Nós podemos até imaginar que ele guardará rancor de você por muito tempo. Não conte com ele para lhe indicar o caminho na próxima vez que você se perder no labirinto dele.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Pêlo de Dragão Porco",t:54,d:"Você pode procurar a fundo, mas não conseguirá encontrar a parte do corpo do Dragão Porco da qual este pêlo vem. Procure um pouco mais. A anatomia do Dragão Porco é cheia de surpresas...",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Mega Rocha de Crackler Lendário",t:51,d:"Esta rocha gigante parece um Crackler Lendário, mas não é, é mais que isso!",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Mojo de Moolobo",t:15,d:"Este pequeno frasco contém todo o poder viril do Boolobo. Tenha cuidado! Seu conteúdo não é comestível.",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Pêlo de Wa Wabbit",t:54,d:"O Wa Wabbit normalmente é bastante avarento e reluta em compartilhar seus cabelos. Excepcionalmente, para recompensar sua coragem (ou a compra de sua clemência), decide dar-lhe uma das suas partes de corpo. Emocionante!",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Tecido de Wa Wabbit",t:55,d:"Ninguém sabe de fato onde o Wa Wabbit conseguiu esse tecido, e ninguém parece disposto a saber. Perturbadora e inquietante, a origem do tecido continua sendo um dos maiores mistérios de toda Amakna.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Pêlos de Mestre Pandora",t:54,d:"Mais uma vez, o Mestre Pandora quis se exibir e aprendeu uma lição que não irá esquecer. Ele já teve dias melhores em sua caixa.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Tecido de Mestre Pandora",t:55,d:"Protegendo as suas costas ou até mesmo a parte de trás da sua cabeça, esse tecido salvou a vida do Mestre Pandora mais de uma vez! Mas não desta vez.",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Pele de Mestre Pandora",t:59,d:"Desgastada pelos ataques mágicos, secada pelos ventos da Ilha Pandala, esta pele agora é de muito baixa qualidade. Mas você parece unido a ela como se estivesse tentando proteger uma preciosa lembrança deste corajoso Mestre Pandora, que tentou matar você algumas vezes. São nessas situações que nós podemos diferenciar um monstro real de um fresco.",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Pedra de Koolich",t:51,d:"Embora o Koolich seja bem generoso, ele não fica muito feliz em lhe dar sua pedra grande. É algo compreensível desde que alguém saiba o que ele fará com a pedra.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
