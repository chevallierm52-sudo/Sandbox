I.u[7997] = {n:"Espada de luz",t:6,d:"Esta espada mágica foi forjada por rituais do Minotot.",ep:0,g:65,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],p:1};
I.u[7999] = {n:"Abacapa",t:17,d:"Alguns aventureiros dizem que essa capa é tão áspera quanto a pele de um crocodilo. Outros dizem ser ainda mais áspera que as costas de uma Bwork fêmea. Certifique-se de vesti-la da maneira correta, se não quiser ser descascado como uma laranja.",ep:1,g:94,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8000] = {n:"Bworky",t:18,d:"Esta pequena criatura é um Bwork. Ele vem sendo mantido vivo preso dentro de um jarro há várias décadas. Então, ele tomou a forma do jarro e agora será um anão a vida inteira. Seu bom humor e o humor lendário fazem dele o companheiro perfeito para calabouços que você sabe que não pode vencer, ou para tumultuadas festas da sociedade.",ep:3,g:31,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8001] = {n:"Bandana de Guerreiro Koalak",t:15,d:"Esta bandagem é normalmente enrolada em torno dos braços do Guerreiro Koalak. Dessa forma, ele pode assoar o nariz sem usar lenço. Quando esta bandagem fica velha e gasta, você pode reciclá-la pendurando no teto da sua casa para pegar os Moskitos que passam.",ep:20,g:719,l:70,wd:true,fm:true,w:5,p:100};
I.u[8002] = {n:"Tecido de Dok Alako",t:55,d:"Este tecido parece estar impregnado com uma magia ancestral que é muito imprevisível e incontrolável: outra coisa em comum com sua amada.",ep:20,g:720,l:40,wd:true,fm:true,w:5,p:1};
I.u[8003] = {n:"Amuleto de Koalak",t:1,d:"Este amuleto não se parece com nenhum outro, simplesmente por não existir nenhum amuleto como este.",ep:20,g:94,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8004] = {n:"Anel de Koalak",t:9,d:"Este magnífico anel é usado por muitos Koalaks que ousam roubá-lo de aventureiros que saem do banco em Astrub.",ep:20,g:99,l:53,wd:true,fm:true,w:10,s:46,p:7375};
I.u[8005] = {n:"Arco de Koalak",t:2,d:"Este arco surpreendente permite que você roube a vida de seus oponentes algumas vezes. Não é nada demais, porém, continua sendo impressionante.",ep:20,g:52,l:61,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,4,50,50,false,true],s:46,p:9775};
I.u[8006] = {n:"Botas de Koalak",t:11,d:"Estas botas são de pés de Koalok de verdade, que foram brutalmente arrancados. Então foi esvaziado o seu conteúdo e recoberto com pêlos de Koalok. Espantosas e atraentes, estas botas vão torná-lo o terror de Astrub.",ep:20,g:71,l:60,wd:true,fm:true,w:10,s:46,p:9600};
I.u[8007] = {n:"Manto de Koalak",t:17,d:"Este manto o protegerá de muitos ataques, mas não de parecer ridículo.",ep:20,g:95,l:61,wd:true,fm:true,w:10,s:46,p:9675};
I.u[8008] = {n:"Cinto de Koalak",t:10,d:"Este cinto, feito de Kaliptus, espalha um bom cheiro pelo camponês, que pode escondê-lo de outros. Além disso, este cinto é perfeito para esconder suas gordurinhas.",ep:20,g:87,l:60,wd:true,fm:true,w:10,s:46,p:9508};
I.u[8009] = {n:"Capacete Koalak",t:16,d:"Este capacete é adornado com grandes orelhas de Koalak que amplificam os sons emitidos por criaturas ao redor. Tenha cuidado, ele pode destruir seus tímpanos se seus amigos são adeptos de ventos de pânico.",ep:20,g:125,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8010] = {n:"Desmontador",t:93,d:"Permite recuperar um equipamento instalado em um paddock.",ep:1,g:96,l:1,wd:false,fm:true,w:10,ut:true,p:1};
I.u[8011] = {n:"Profetas, Cultos e Fé",t:25,d:"Ótimas histórias de culto que irão agradar qualquer místico básico.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8012] = {n:"Pó de Ressurreição",t:48,d:"Este pó traz de volta a vida de um animal de estimação fantasma, desde que você saiba como alimentar o fantasma.",ep:20,g:51,l:1,wd:true,fm:true,w:1,p:100};
I.u[8013] = {n:"Transformação Fantasma de Miau",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8014] = {n:"Koalak Coveiro",t:18,d:"Esta pequena criatura passa seus dias e noites escavando corpos em cemitérios para fazer novos amigos. O mais surpreendente é que parece dar certo.",ep:1,g:0,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[8015] = {n:"Koalak Imaturo",t:18,d:"Como o nome indica, este jovem Koalak está na metade do seu crescimento. Talvez nunca pare de crescer e se torne tão alto quanto você. Então, você será o animal de estimação dele.",ep:1,g:0,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[8016] = {n:"Fantasma do Koalak Sanguinário",t:90,d:"Este fantasma ainda não deixou o mundo dos vivos. Você pode encontrar um jeito de ressuscitá-lo ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:43,l:1,wd:true,fm:true,w:1,p:1};
