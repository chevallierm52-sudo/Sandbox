I.u[7496] = {n:"Poção de Ressurreição em Massa",t:14,d:"Esta poção permite a você ressuscitar todos os aliados nas proximidades.",ep:0,g:60,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7497] = {n:"Poçao de Liberação em Massa",t:14,d:"Esta poção permite a você libertar as almas de seus inimigos para enviá-los diretamente para o cemitério, sem dar a eles uma chance de ressuscitação.",ep:0,g:59,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7498] = {n:"Poção de Cura em Massa",t:14,d:"Esta poção permite a você curar todos os aliados presentes no mapa.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"Pg>23,2",u:true,p:10};
I.u[7499] = {n:"Poção da Vila: dos Kwaks do Gelo",t:12,d:"Esta poção permite a você teletransportar-se para a Vila Kwak do Gelo... Claro, se a poção for sua.",ep:0,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7500] = {n:"Poção da Vila: dos Kwarks do Fogo",t:12,d:"Esta poção permite a você teletransportar-se para a Vila Kwak de Fogo, se você possuí-la.",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7501] = {n:"Poção da Vila: dos Kwarks do Vento",t:12,d:"Esta poção permite a você teletransportar-se para a Vila Kwak de Vento, se você possuí-la.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7502] = {n:"Poção de Reunião",t:12,d:"Esta poção permite a você criar um ponto de reunião. Então permite alinhar aventureiros para se juntarem a você e atacar ou proteger uma vila. Esta poção mágica também permite salvar a posição dos personagens que se juntaram a você para que eles voltem rapidamente ao ponto de partida.",ep:0,g:21,l:1,wd:false,fm:true,w:1,p:1};
I.u[7503] = {n:"Runa de Salvamento",t:88,d:"Com esta runa, você pode salvar sua posição não importa onde esteja.",ep:1,g:45,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7504] = {n:"Runa da Lembrança",t:88,d:"Esta runa permite que você volte rapidamente para seu último ponto de salvamento.",ep:1,g:46,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7505] = {n:"Poção de Esquecimento de Profissão: Alfaiate Mago",t:44,d:"Com esta poção você esquecerá a profissão de Alfaiate Mágico.",ep:9,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7506] = {n:"Poção de Esquecimento de Profissão: Settmagus",t:44,d:"Com esta poção você esquecerá a profissão de Settmagus.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7507] = {n:"Poção de Esquecimento de Profissão: Sapateiro Mágico",t:44,d:"Com esta poção você esquecerá a profissão de Ferreiro Mágico de Escudo.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7508] = {n:"Runa de Assinatura",t:50,d:"Esta runa possibilita ao melhor artesão colocar sua assinatura em suas criações (para ser usado junto com os ingredientes quando estiver criando itens).",ep:18,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[7509] = {n:"Primeira parte da Chave do Labirinto do Dragão Porco",t:84,d:"Se este focinho não está atraído por você, não tente fazer algo a respeito disto. Você correrá o risco de receber um tapa fatal, ainda mais se você estiver desligado.",ep:13,g:1,l:1,wd:true,fm:true,w:1,p:100};
I.u[7510] = {n:"Chave para a Segunda Parte do Labirinho do Dragão-Porco",t:84,d:"Esta peça pode ser uma parte da chave que abre o baú de tesouros com o qual você sempre sonhou. A menos que seja a chave para a sua tumba.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[7511] = {n:"Chave do Labirinto do Dragão-Porco",t:84,d:"Se você acha que esta chave o fará encontrar muitos Porcos Imundos, você realmente não entendeu nada... A única coisa que ela abrirá é o esconderijo do Dragão-Porco. \nTenha cuidado, pois ela se autodestruirá depois de usada.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:100};
I.u[7512] = {n:"Espírito de Porco",t:24,d:"Este troféu prova o seu amor por porcos. Mas não se esqueça de tomar banho antes de voltar para casa e encontrar sua esposa se não quiser dormir com os Gobballs.",ep:1,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[7513] = {n:"Sandálias Titude",t:11,d:"Titude era um modesto sapateiro Enutrof, menor até que um Xelor. A lenda diz que ele criou estas sandálias para poder beijar sua amada, uma Eniripsa sem pernas. Mas não foi o bastante e ele teve que desistir de beijá-la em pé.",ep:20,g:67,l:122,wd:true,fm:true,w:10,p:37800};
I.u[7514] = {n:"Botas de Harry",t:11,d:"Harry foi um velho sábio que usou seus dias para pescar nas docas de Sufokia. Seu grande bigode tornava-o parecido com Danous Kwaide, famoso ator de uma companhia de teatro que costumava atuar na taverna de Amakna. Tudo isso foi apenas um prelúdio aos incríveis energéticos e festas com almôndegas.",ep:20,g:70,l:123,wd:true,fm:true,w:10,p:37850};
I.u[7515] = {n:"Capa Tenfuture",t:17,d:"Esta capa não vem da sua Galáxia, mas parece combinar com a cor das suas meias para pesca feitas de lã de Gobbly.",ep:20,g:92,l:148,wd:true,fm:true,w:10,p:47925};
I.u[7516] = {n:"Chapéu de Bimd\'Oule",t:16,d:"Foi um velho e amargo Enutrof azarado quem primeiro descobriu este horrível chapéu, escondido no fundo de uma alcova nas grutas de Bimd\'Oule. Mais tarde, o Enutrof se exilou longe das terras de Amakna para escapar do tédio e descobrir novos horizontes. A lenda diz que ele voltou à sua terra natal depois de um século para ridicularizar seus velhos amigos e, principalmente, porque ele se sentia nostálgico.",ep:20,g:121,l:110,wd:true,fm:true,w:10,p:31675};
I.u[7517] = {n:"Energético de Ripate",t:37,d:"Este energético é tão ácido que dificilmente pode ser servido. Assim, a acidez dá uma expectativa de vida semelhante à de um Moskito...",ep:7,g:4,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7518] = {n:"Fantosminha",t:18,d:"Esta surpreende criatura veio do além e não está disposta a voltar para lá, a menos que você queira acompanhá-la...",ep:3,g:13,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7519] = {n:"Dragoone Rosa",t:18,d:"A pele desse pequeno dragão é tão rosa quanto as costas de uma Bwork! Este é um jeito seguro e barato de fazer você imaginar ou apenas se lembrar de boas lembranças. Felizmente, esse dragão não é apenas o objeto da sua fantasia, mas também é uma criatura muito sábia e poderosa. No entanto, tenha cuidado, a sua voracidade pode ser comparada com a perversidade de um Chafer em noites de lua cheia... ele apenas se alimenta de outros animais de estimação.",ep:3,g:14,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7520] = {n:"Croo",t:18,d:"Soldado de brinquedo aposentado, esta criatura de metal ganhou vida. Ele o seguirá por todos os lugares e se arriscará para protegê-lo se você apenas se dar ao trabalho de lhe dar algo para comer regularmente. Mas não pense que ele levará golpes em seu lugar... ele não substituirá os novatos aventureiros de Astrub.",ep:3,g:15,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7521] = {n:"Presente Fanstominha",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bixinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7522] = {n:"Minotoro",t:18,d:"Você pode se aproximar deste bebê Minotoro, domesticado e limpo, e acariciá-lo sem pôr suas mãos em risco. Entretanto, permaneça prudente, às vezes, a natureza pode tomar conta dele. Portanto, o instinto destrutivo desta criatura pode retornar quando você menos esperar. Para evitar surpresas ruins, crie-o como você criaria seus próprios filhos, ou seja, batendo neles com gravetos.",ep:3,g:21,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7523] = {n:"Miau Gengibre",t:18,d:"Nenhum gato consegue resistir a esta adorável criatura de gengibre... nem mesmo o mais entediado deles!\n(ESTE LENDÁRIO ANIMAL DE ESTIMAÇÃO NÃO PRECISA COMER).",ep:1,g:40,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7524] = {n:"Miau Malhado",t:18,d:"Esta surpreendente criatura é o resultado do cruzamento entre um Miau Branco e um Miau Preto.",ep:3,g:41,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7525] = {n:"Presente: Dragoone Rosa",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7526] = {n:"Presente: Croo",t:89,d:"Se você aproximar seu ouvido deste presente ou agitá-lo energicamente, talvez você ouça barulhos estranhos que revelarão a presença de uma criatura viva. Não perca mais tempo! Abra-o! Você encontrará um maravilhoso animal de estimação. Também deve haver um livro que explicará como criá-lo, alguns recursos com os quais você pode alimentá-lo e pós de Eniripsa que você precisará para curá-lo.\n(ATENÇÃO: este presente contém itens muito pesados. Talvez você fique sobrecarregado quando o abrir. Lembre-se de tirar seus itens pesados, ou pedir a algum amigo para lhe ajudar.)",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7527] = {n:"Presente: Minotoro",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
