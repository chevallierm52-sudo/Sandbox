I.u[7873] = {n:"Dragossauro Ameixa e Gengibre",t:97,d:"Este certificado lhe autoriza a pegar a sua montaria no curral.\nAdvertência! Este certificado será válido por apenas 20 dias. Quando esse tempo estiver acabado, sua montaria será enviada de volta para a natureza e o seu certificado já não será válido. Você não poderá pegar a sua montaria de volta. Não se esqueça de deixar a sua montaria em um curral se for ficar fora por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7874] = {n:"Dragossauro Ameixa e Turquesa",t:97,d:"Dragossauro Ameixa e TurquesaEste certificado lhe autoriza a pegar a sua montaria no curral.\nAdvertência! Este certificado será válido por apenas 20 dias. Quando esse tempo estiver acabado, sua montaria será enviada de volta para a natureza e o seu certificado já não será válido. Você não poderá pegar a sua montaria de volta. Não se esqueça de deixar a sua montaria em um curral se for ficar fora por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7875] = {n:"Dragossauro Ameixa e Orquídea",t:97,d:"Dragossauro Ameixa e OrquídeaEste certificado lhe autoriza a pegar a sua montaria no curral.\nAdvertência! Este certificado será válido por apenas 20 dias. Quando esse tempo estiver acabado, sua montaria será enviada de volta para a natureza e o seu certificado já não será válido. Você não poderá pegar a sua montaria de volta. Não se esqueça de deixar a sua montaria em um curral se for ficar fora por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7876] = {n:"Dragondino Ameixa e Carmesim",t:97,d:"Esse certificado o autoriza a pegar a sua montaria no curral.\nAdvertência! Esse certificado será válido por apenas 20 dias. Quando esse tempo estiver acabado, sua montaria será enviada de volta para a natureza e o seu certificado já não será válido. Você não poderá pegar a sua montaria de volta. Não se esqueça de deixar a sua montaria em um curral se for ficar fora por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7877] = {n:"Pedra de Jade",t:51,d:"Esta pedra jamais pertenceu a Jade, assim como a pedra de Agathe nunca pertenceu a Agathe.",ep:1,g:458,l:1,wd:true,fm:true,w:1,p:1};
I.u[7878] = {n:"Jade",t:50,d:"Esta pedra preciosa foi usada para criar pequenos itens decorativos, como testículos mágicos em miniatura de Boolobo feitos de jade, por exemplo.",ep:0,g:706,l:1,wd:true,fm:true,w:1,p:1};
I.u[7879] = {n:"Advento de Hyrkul",t:25,d:"Os Anais Colossais, Imorais e Banais de Domen congelarão sua espinha. Devem ser lidos de acordo com as prescrições. Efeitos colaterais: provocam suor frio e incontinência.",ep:16,g:19,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[7880] = {n:"Amuleto do Gobkool",t:1,d:"Este Amuleto costumava ser usado por todos os aventureiros que preferiam fazer amor a fazer a guerra. Cada um tem seu gosto.",ep:20,g:93,l:20,wd:true,fm:true,w:5,s:43,p:1300};
I.u[7881] = {n:"Anel do Gobkool",t:9,d:"Este anel lhe permitirá machucar ainda mais quando der surras bem merecidas em seus filhos.",ep:20,g:98,l:38,wd:true,fm:true,w:5,s:43,p:4000};
I.u[7882] = {n:"Martelo do Gobkool",t:7,d:"Este martelo é perfeito para expressar seu pacifismo nos crânios de seus inimigos.",ep:20,g:54,l:41,wd:true,fm:true,w:10,an:15,e:[5,5,1,1,40,40,false,false],s:43,p:4520};
I.u[7883] = {n:"Botas do Gobkool",t:11,d:"Cheias de lã de Gobkool, estas botas são simplesmente fantásticas. Leves e mornas para a estação fria, e frescas para a estação quente, elas vão satisfazer até o mais “entediado” dos aventureiros.",ep:20,g:66,l:38,wd:true,fm:true,w:15,s:43,p:3925};
I.u[7884] = {n:"Capa do Gobkool",t:17,d:"Se você é o tipo da pessoa que sempre pensa positivo, esta capa é perfeita para você. É tão espessa e confortável que pode ser usada como uma cama improvisada, quando você se sentir extremamente sonolento. Seu cheiro de Kaliptus até repele insetos e criaturas não desejadas.",ep:20,g:93,l:55,wd:true,fm:true,w:15,s:43,p:8030};
I.u[7885] = {n:"Cinto do Gobkool",t:10,d:"Usado em volta de seus quadris, este cinto fará você parecer com um aventureiro pacífico e lhe permitirá surpreender seus inimigos dando-lhes um golpe de espada nas costas.",ep:20,g:84,l:37,wd:true,fm:true,w:10,s:43,p:3800};
I.u[7886] = {n:"Elmo Gobkool",t:16,d:"Você certamente não parecerá mais esperto com este elmo. Entretanto, você parecerá muito ‘legal\' e no fim das contas, isto é tudo o que importa.",ep:20,g:119,l:47,wd:true,fm:true,w:15,s:43,p:6000};
I.u[7887] = {n:"Capacete Koolich",t:16,d:"Este capacete para cabeça pertenceu ao famoso Koolich, famoso por seus pés de argila e lendário bom humor.",ep:20,g:122,l:82,wd:true,fm:true,w:10,s:44,p:18375};
I.u[7888] = {n:"Sacola de Koolich",t:81,d:"O Koolich usa esta sacola para manter frescos seus Kaliptus ou para sufocar Koalaks mais ousados.",ep:20,g:2,l:69,wd:false,fm:true,w:10,s:44,p:12278};
I.u[7889] = {n:"Botas de Koolich",t:11,d:"Estas botas costumavam pertencer ao Koolich e, se você não acreditar, basta sentir o cheiro!! Estas botas são tão confortáveis que você poderá esquecer o quão miserável é a sua existência.",ep:20,g:69,l:73,wd:true,fm:true,w:10,s:44,p:13775};
I.u[7890] = {n:"Cajado de Koolich",t:4,d:"Este cajado é mesmo um osso oco de um ancestral de Koolich. Furado de ambos os lados, ele pode ser usado como um cano de Kaliptus, mas também como um bastão de pastor. Deus abençoe a tecnologia!",ep:20,g:62,l:75,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,20,50,false,false],s:44,p:14675};
I.u[7891] = {n:"Míni Wa",t:18,d:"Este pequeno Wabbit é na verdade um filho secreto do notório Wa Wabbit. Talvez um dia ele ascenderá ao trono.",ep:3,g:28,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7892] = {n:"Willy Peninzias",t:18,d:"Willy Peninzias é uma criatura suja. Teve uma infância muito difícil, pelo que parece. Desde então, se vinga comendo todos os animais empalhados que ele topa.",ep:3,g:29,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7893] = {n:"Fantasma de Míni Wa",t:90,d:"Este Míni Wa ainda não deixou o mundo dos vivos. Você pode encontrar um jeito de ressuscitá-lo ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:18,l:1,wd:true,fm:true,w:1,p:1};
I.u[7894] = {n:"Fantasma de Willy Peninzias",t:90,d:"Este Willy Peninzias ainda não deixou o mundo dos vivos. Você pode decidir achar um jeito de ressuscitá-lo ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:17,l:1,wd:true,fm:true,w:1,p:1};
I.u[7895] = {n:"Certificado do Canil: Mini Wa",t:77,d:"Este certificado descreve as características do Mini Wa que você pôs no Canil.",ep:3,g:34,l:1,wd:false,fm:true,w:1,p:100};
I.u[7896] = {n:"Certificado do Canil: Willy Peninzias",t:77,d:"Este certificado descreve as características do Willy Peninzias que você pôs no Canil.",ep:3,g:29,l:1,wd:false,fm:true,w:1,p:100};
I.u[7897] = {n:"Presente: Mini Wa",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso mascote, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7898] = {n:"Presente: Willy Peninzias",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7899] = {n:"O Míni Wa: Como criar seu animal favorito",t:25,d:"Este livro foi escrito por Oshimo Bigglip. Explica como criar um Míni Wa.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7900] = {n:"Willy Peninzias: Como criar o seu animal favorito",t:25,d:"Este livro foi escrito por Oshimo Bigglip. Explica como criar o Willy Peninzias.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7902] = {n:"Cinto da Dama Dourada",t:10,d:"Uma velha lenda extraída do famoso livro intitulado “Tudo Que Você Precisa Saber Sobre as Mulheres” diz que este cinto uma vez pertenceu a uma dama dourada, muito mais interessada em riqueza do que em poder. Na versão não censurada deste livro, também aprendemos que ela adorava piadas obscenas. Finalmente, ela não era tão diferente das outras mulheres...",ep:2,g:86,l:71,wd:true,fm:true,w:5,p:13300};
I.u[7903] = {n:"Flor de Kaliptus",t:36,d:"Enfiadas delicadamente nas narinas, estas folhas desentupirão qualquer nariz. Algumas lendas tribais dizem que esta técnica funciona para outros orifícios também.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7904] = {n:"Flor de Kaliptus",t:35,d:"Quando você a queima, esta flor libera uma densa fumaça. Quando mastigada, tende a torná-lo impotente. E se usada para uma infusão, terá ótimos efeitos laxantes. A melhor coisa a fazer é jamais tocá-la.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7905] = {n:"Lã do Gobkool",t:57,d:"Esta lã parece com a lã de Gobball, mas não é. Realmente, esta lã não tem cheiro.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7906] = {n:"Chifre do Gobkool",t:47,d:"De acordo com uma velha lenda, quando você mói este chifre, o pó parece ter poderes místicos. A mesma lenda especifica que ele também pode provocar surpreendentes efeitos, como dor de cabeça e tontura... Nem pense em provar.",ep:20,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[7907] = {n:"Couro do Gobkool",t:56,d:"Este couro multicolorido é perfeito para você fazer roupas íntimas multicoloridas. Você deixará com ciúmes o mais entediado dos Chafers.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7908] = {n:"Chave do Calabouço de Koolich",t:84,d:"Esta chave feita de osso permitirá que você entre no Calabouço de Koolich sem ter sido convidado.",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[7911] = {n:"Koalak Sanguinário",t:18,d:"Este pequeno Koalak parece inocente, mas ele esconde bem sua verdadeira personalidade. Infeliz quando era jovem, ele era golpeado por bumerangues no rosto ou no traseiro. É por isso que ele odeia bumerangues agora e os devora sem nem mesmo mastigá-los.",ep:3,g:30,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:46,p:1};
I.u[7913] = {n:"Animagi",t:9,d:"Este misterioso item esquecido por alguém costumava pertencer a um grande mago... Dizem que lhe permitia falar com certos animais...",ep:1,g:22,l:1,wd:false,fm:true,w:1,p:1};
I.u[7917] = {n:"Presente de Compensação",t:89,d:"A fim de se desculpar pelos recentes problemas que você encontrou, a Equipe ANKAMA lhe oferece esta caixa de presente incluindo:\n- 5 Doces de Compensação do Sábio\n- 5 Doces de Compensação do Sortudo\n- 10 Doces de Compensação de Energia\n- 10 Pós de Eniripsa",ep:1,g:32,l:1,wd:true,fm:true,w:1,c:"PO!7801&PO!7800",u:true,p:1};
I.u[7918] = {n:"Chave do Calabouço dos Tofus",t:84,d:"Esta chave confeccionada a partir de uma pena de Tofu pode fazer cócegas dentro de quaisquer fechaduras... Além disso, ela lhe permitirá acessar o Tofular de Farle Ingalsse.",ep:1,g:6,l:1,wd:true,fm:true,w:1,p:100};
I.u[7919] = {n:"Ficha do Mestre de Jogo",t:15,d:"Você provavelmente pode trocar esta bela ficha por preciosos presentes na Feira de Trool.",ep:1,g:737,l:1,wd:true,fm:true,w:1,p:100};
I.u[7920] = {n:"Varinha Mágica do Torneio",t:3,d:"Esta modesta varinha mágica permite aos Mestres de Jogo teletransportar aventureiros para uma área reservada a torneios.",ep:1,g:8,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],u:true,p:100};
I.u[7921] = {n:"Coroa de Tofu Real",t:16,d:"Esta coroa é bem difícil de pegar. Sempre escapa entre seus dedos. Sem dúvida! É a Coroa de Tofu Real! Entretanto, não parece servir em sua cabeça pequena, sem mencionar a de um Iop!",ep:13,g:154,l:128,wd:true,fm:true,w:10,p:42625};
I.u[7922] = {n:"Dopple Sacrier Empalhado",t:61,d:"Este Dopple Sacrier empalhado é perfeito para Sacriers jovens. É ótimo para limpar sangue e pode até mesmo ser lavado a altas temperaturas.",ep:0,g:1,l:1,wd:true,fm:true,w:10,p:1};
I.u[7923] = {n:"Pandawa Dopple Empalhado",t:61,d:"Este Pandawa Dopple empalhado cheira a energético e pêlo molhado, assim como mamá.",ep:1,g:2,l:1,wd:true,fm:true,w:10,p:1};
I.u[7924] = {n:"Chave do Labirinto do Minotoro",t:84,d:"Esta maravilhosa chave lhe permitirá entrar no Labirinto do Minotoro, mas não sair!",ep:13,g:7,l:1,wd:true,fm:true,w:1,p:100};
I.u[7925] = {n:"Madeira de Kaliptus",t:38,d:"Esta madeira perfumada pode ser usada para belas casas cheirosas, mesmo se os donos fedem. Infelizmente, esta madeira não é flexível o bastante para fazer roupas de baixo.",ep:20,g:1,l:50,wd:true,fm:true,w:2,p:0};
I.u[7926] = {n:"Chave do Calabouço do Lorde Corvo",t:84,d:"Com esta chave, você poderá se encontrar com o Lorde Corvo. Ele, provavelmente, o convidará para compartilhar um pedaço de queijo em sua companhia.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[7927] = {n:"Chave do Calabouço de Ckacler",t:84,d:"Esta chave é quase inquebrável, mas fica desgastada à medida que abre muitas portas. Parece que foi criada das partes íntimas de um Crackler. Simplesmente chocante!",ep:1,g:9,l:1,wd:true,fm:true,w:1,p:100};
I.u[7928] = {n:"Chave do Calabouço dos Animais de Estimação",t:84,d:"Com esta chave, você poderá entrar no Santuário dos Animais de Estimação. Lá encontrará animais de estimação que morreram de fome, exaustão e tristeza, ou então que foram devorados, morreram de cócegas, envenenados com Dragoleite, sufocados em um baú ou simplesmente abandonados na rua.",ep:1,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[7929] = {n:"Como ser um Mercenário Perfeito em Astrub",t:25,d:"Este livro, escrito pelo famoso Igor Ant, Chefe Mercenário de Astrub, é uma obra de cabeceira de quem respeita a lei tanto quanto quem se ilude com ela.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7930] = {n:"Como Fazer Amigos e Mantê-los",t:25,d:"Algumas dicas e conselhos para fazer amigos legais e leais, escritos por Acidrik Gutsplitter.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7931] = {n:"A Era dos Dragões - Fragmentos Recuperados III",t:25,d:"Parte III de Fragmentos da História do Mundo, achado pelo sábio Gutsplitter de Acidrik e reescrito por ele mesmo.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:50};
I.u[7932] = {n:"Pergaminho de Miss Astrub",t:25,d:"Este ano, a viçosa Miss Astrub revela seus charmes com os quais ela seduziu o júri.",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[7933] = {n:"Pergaminho Bandeja de Cavacos",t:25,d:"Estas dançarinas extraordinárias alegram as festas da moda da região.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:69};
