I.u[7606] = {n:"Manjedoura Clássica",t:93,d:"Esta manjedoura é um revitalizante local onde sua montaria pode comer para não morrer de fome ou vomitar se tiver náuseas depois de ingerir todos os doces que você tem dado para ela. Só leve sua montaria para a manjedoura quando ela começar a ficar fraca, ela achará lá toda a energia que precisa.",ep:1,g:2,l:1,wd:true,fm:true,w:10,ut:true,p:1};
