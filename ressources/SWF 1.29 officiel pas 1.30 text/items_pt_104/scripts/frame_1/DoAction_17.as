I.u[7552] = {n:"Turkocapa",t:17,d:"Às vezes, quando o verdadeiro amor une um guerreiro a um Dragossauro, coisas estranhas podem acontecer. Esta capa prova isto, já que possui asas de Dragossauro costuradas nela. O Dragossauro se sacrificou para a fabricação desta capa, oferecendo-a ao famoso trovador Pol Akartney no dia do casamento deles. Aparentemente, Jony Lenon até escreveu uma canção sobre isto.",ep:2,g:90,l:50,wd:true,fm:true,w:5,s:42,p:25000};
I.u[7553] = {n:"Turkochapéu",t:16,d:"Se você já sonhou parecer um Dragossauro, esta é sua oportunidade! Entretanto, se você quiser permanecer saudável, aconselhamos você a não usar este chapéu nas ruas de Amakna durante a época de Natal.",ep:2,g:118,l:50,wd:true,fm:true,w:10,s:42,p:15000};
I.u[7554] = {n:"Turkobotas",t:11,d:"Seus amigos definitivamente ficarão com ciúmes. Estas botas o levarão à festa do embaixador para conseguir um daqueles maravilhosos chocolatinhos dourados.",ep:2,g:65,l:50,wd:true,fm:true,w:3,s:42,p:5000};
I.u[7555] = {n:"Turkoanel",t:9,d:"Com este anel, seus amigos dirão de você ‘Ela é a tal perua\'.",ep:2,g:97,l:50,wd:true,fm:true,w:1,s:42,p:1000};
I.u[7556] = {n:"Presente: Turko",t:89,d:"Esta caixa de Presente contém uma parte de uma famosa fantasia. Isto certamente deixará seus amigos Dragossauros com ciúmes.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7557] = {n:"Chave do Calabouço Treechnid",t:84,d:"Esta chave feita de casca de Treechnid poderia germinar em qualquer lugar morno e úmido, como nas cuecas de um Bwork, por exemplo.",ep:1,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[7558] = {n:"Pêlos de Bworky",t:24,d:"Estes cabelos não permanecerão por muito tempo na sua sacola... Bem, eu realmente espero que não.",ep:14,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[7559] = {n:"Grendicinto",t:10,d:"A lenda diz que o primeiro dono deste cinto costumava girar e girar toda vez que ele o colocava.",ep:22,g:85,l:164,wd:true,fm:true,w:0,p:48200};
