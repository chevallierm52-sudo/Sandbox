I.u[7804] = {n:"Doce de Compensação Energético",t:42,d:"Este doce lhe permite ganhar uma quantidade considerável de energia depois de um grande esforço.",ep:1,g:137,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7805] = {n:"Dragossauro: Como criar sua montaria",t:25,d:"Este significativo livro lhe explicará como capturar, criar e montar um Dragossauro. Foi escrito por Oshar Marif, o que prova sua boa qualidade.",ep:16,g:19,l:1,wd:false,fm:true,w:1,u:true,p:500};
I.u[7806] = {n:"Certificado de Montaria",t:97,d:"Este certificado o autoriza a pegar a sua montaria em um celeiro.\nAtenção! Este certificado só é válido por 20 dias. Uma vez que o prazo terminar, sua montaria será solta na natureza e o certificado não será mais válido. Você não será capaz de recuperar a sua montaria. Não se esqueça de deixá-la em um celeiro, se for se ausentar por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7807] = {n:"Dragossauro Amêndoa Selvagem",t:97,d:"Este certificado autoriza a usar a montaria do curral. Aviso! Este certificado só é válido durante 20 dias. Uma vez expirado, sua montaria será retomada e seu certificado não terá mais validade. Você não poderá mais montar. Não se esqueça de deixar a sua montaria num curral se for sair por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
