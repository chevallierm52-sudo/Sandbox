I.u[7714] = {n:"Atooin",t:18,d:"Diz o rumor que esta tartaruga foi levantada por um Mestre nas Artes Marciais que parecia um Rato de Esgoto. Se alimentá-la com peixe, ela será boa com você e o ajudará a curar aventureiros feridos. Se alimentá-la com carne, ela ficará agressiva e o ajudará a lutar contra seus inimigos.",ep:2,g:17,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:9,p:1};
