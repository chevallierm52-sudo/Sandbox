I.u[7798] = {n:"Lança Relâmpago Clássico",t:93,d:"Esta apavorante máquina de madeira lança pequenos flashs de luz nas criaturas que se aproximam demais dela. Esta máquina não é só extremamente divertida quando em ação, como também aumenta a resistência de suas montarias fazendo-as correr ao redor.",ep:1,g:4,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[7799] = {n:"Apito Aperitivo",t:94,d:"Tenha um descanso no meio da natureza. Tire o seu apito aperitivo e a sua montaria correrá tão rápido quanto um Wabbit experimentando sintomas de Cenouwawa.",ep:20,g:1,l:60,wd:true,fm:true,w:1,u:true,p:1000};
I.u[7800] = {n:"Doce de Compensação do Sábio",t:28,d:"Este doce aumentará sua sabedoria em 100 pontos durante 30 lutas.",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7801] = {n:"Doces de Compensação do Sortudo",t:28,d:"Este doce aumentará sua prospecção em 100 pontos durante 30 lutas.",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7802] = {n:"Doce de Compensação do Sábio",t:42,d:"Este doce aumentará sua sabedoria em 100 pontos durante 30 lutas.\n(Atenção! Você só pode usar um doce de cada vez. Se seu personagem consumir vários doces diferentes, os efeitos deles não serão acumulados.)",ep:1,g:136,l:1,wd:false,fm:true,w:1,c:"PO!7800",u:true,p:1};
