I.u[7702] = {n:"Au-au de Caça",t:18,d:"Este Au-au é diferente de todos os outros. Ele foi criado para caçar. O extraordinário nariz dele o ajudará a encontrar as maiores caças ou ajudará as maiores caças a te encontrarem.",ep:1,g:0,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[7703] = {n:"Bebê Crowdzilla",t:18,d:"Este pássaro negro é especialmente famoso pelo seu amor por cemitérios e por aventureiros de pele branca. Ele adora quebrar ossos que encontra em túmulos com seu enorme bico.",ep:3,g:18,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:8,p:1};
I.u[7704] = {n:"Esquilo Travesso",t:18,d:"Este esquilo é um verdadeiro quebra-nozes. Deve-se admitir que isto possa ser tanto útil quanto doloroso.",ep:3,g:16,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7705] = {n:"Leopardo",t:18,d:"Esta esplêndida criatura é parente do famoso Lenalds da Ilha dos Wabbits. Mais precipitada e incontrolável, ela lhe ajudará durante suas lutas e provará ser bastante traiçoeira se você não a tratar bem.",ep:3,g:27,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7706] = {n:"Bilby",t:18,d:"Bilby, um apelido vindo do seu verdadeiro nome, Bilbiblabaloo, é uma pequena geléia à procura de aventura. Particularmente presa a Vald, tem notáveis poderes (pelo menos, proporcionais ao seu tamanho). Esse animal de estimação só come flores.",ep:3,g:43,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7707] = {n:"Javalizinho Selvagem",t:18,d:"Este javalizinho tem um focinho adaptado para procurar frutos de carvalho grandes. Por sorte, consegue achar facilmente.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7708] = {n:"Piwi Azul",t:18,d:"Este pequeno Piwi não é como os outros. Basta dar uma olhada para a cor dele para que isto fique claro. Entretanto, ele parece compartilhar com os outros o mesmo interesse em bicar traseiros. Diz o rumor que algumas pessoas realmente gostam disto...",ep:1,g:19,l:1,wd:true,fm:true,w:10,p:1};
I.u[7709] = {n:"Piwi Amarelo",t:18,d:"Este pequeno Piwi não é como os outros. Um simples olhar na sua cor e tudo fica claro. No entanto, ele parece compartilhar com os outros o mesmo interesse em bicar o traseiro. Dizem que há pessoas que são iguais a eles...",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7710] = {n:"Piwi Rosa",t:18,d:"Este pequeno Piwi não é como os outros. Uma simples olhada para a sua cor deixará isso claro. No entanto, ele parece compartilhar com os outros o mesmo interesse de bicar bundas. Dizem que algumas pessoas até gostam disso...",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7711] = {n:"Piwi Vermelho",t:18,d:"Este pequeno Piwi não é como os outros. Uma simples olhada na cor e isto fica claro. Entretanto, parece compartilhar com os outros o mesmo interesse em bicar. Dizem que algumas pessoas gostam disso...",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
