I.u[7864] = {n:"Dragossauro Dourado Selvagem",t:97,d:"Este certificado autoriza a usar a montaria do curral. Aviso! Este certificado só é válido durante 20 dias. Uma vez expirado, sua montaria será retomada e seu certificado não terá mais validade. Você não poderá mais montar. Não se esqueça de deixar a sua montaria num curral se for sair por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7865] = {n:"Dragossauro Esqueleto",t:97,d:"Este certificado autoriza você a pegar sua montaria em um galpão. Cuidado! Este certificado será válido por apenas 20 dias. Logo que esse tempo limite acabar, sua montaria será devolvida para a selva e seu certificado não será mais válido. Você não poderá pegar de volta sua montaria. Não se esqueça de deixar sua montaria em um galpão se você precisa ficar fora por um longo período.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7866] = {n:"Dragossauro Orquídea e Carmesim",t:97,d:"Este certificado lhe autoriza a pegar sua montaria em um celeiro.\nAtenção! Este certificado só será válido por 20 dias. Uma vez que o prazo terminar, sua montaria será solta na natureza e o certificado não será mais válido. Você não será capaz de recuperar sua montaria. Não se esqueça de deixar sua montaria em um celeiro se você for se ausentar por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
I.u[7867] = {n:"Dragossauro Ameixa e Amêndoa",t:97,d:"Este certificado lhe autoriza a pegar a sua montaria no curral.\nAdvertência! Este certificado será válido por apenas 20 dias. Quando esse tempo estiver acabado, sua montaria será enviada de volta para a natureza e o seu certificado já não será válido. Você não poderá pegar a sua montaria de volta. Não se esqueça de deixar a sua montaria em um curral se for ficar fora por muito tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
