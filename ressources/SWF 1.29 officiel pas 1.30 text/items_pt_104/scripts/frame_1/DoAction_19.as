I.u[8403] = {n:"Trança de Koolich",t:15,d:"Esta trança enorme foi feita pelo próprio Koolich, alguns anos atrás. Com o passar dos anos, ela se tornou tão rígida quanto uma rocha. Entretanto, ainda mantém um líquido feio e viscoso que atrai Moskitos toda hora. A coisa mais surpreendente é que esta trança ficava perfeita no Koolich. Como um idiota, você tem a idéia ridícula de roubá-lo.",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Pele de Skeunk",t:59,d:"Este pedaço de pele provavelmente vem do calcanhar de Skeunk, a qual explica a sua bonita cor amarelada. Apesar de esta pele velha não permitir a você fazer roupas modernas, você ainda poderá criar roupas ‘retrô\' que as gerações mais novas irão amar.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Pêlo de Skeunk",t:54,d:"Além de você, quem pensaria que Skeunk não estava depilando seu corpo inteiro?",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Lã de Minotot",t:57,d:"Esta lã é particularmente fina, tornando possível para o Minotot não ter pêlos crespos por todo o corpo. Ninguém sabe para quê serve. Talvez você devesse tentar fazer implantes de pêlos com esta lã, então você poderia exibir um crescimento abundante de pêlos marrons em seu peito. Até mesmo seus sonhos de infância podem se tornar realidade!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Couro de Minotot",t:56,d:"Quase tão raro quanto couro de Gobball, este couro é perfeito para criações que requerem costuras flexíveis, como máscaras de couro, por exemplo.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Caso de Minotot",t:47,d:"Este casco pisoteou muitos aventureiros, mas também enormes estercos aqui e no Labirinto Minotoro. Mas deve ser dito em defesa do Minotot que nem sempre é tão fácil fazer a diferença à primeira vista.",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
I.u[8409] = {n:"Chifre de Minotot",t:47,d:"De longe, este chifre se parece com um chifre de Gobball gigante e extramente poderoso. Surpreendentemente, de perto, se parece com um chifre de Minotot.",ep:21,g:655,l:400,wd:true,fm:true,w:1,p:10};
I.u[8410] = {n:"Fêmur de Minotot",t:47,d:"Este esplêndido osso suportou, durante séculos, o excessivo peso do Minotot. Uma façanha sempre merece ser assinalada.",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8411] = {n:"Amuleto Mumminotor",t:1,d:"Este amuleto amaldiçoado e coberto com bandagem pode ajudá-lo a superar a maldição do Labirinto do Minotoro, mas não há garantia... Pode ser apenas lixo de algum turista. Quem sabe.",ep:0,g:114,l:111,wd:false,fm:true,w:5,s:59,p:31300};
I.u[8412] = {n:"Anel Mumminotor",t:9,d:"Este anel feio e fedido é feito de bandagens de  Mumminotor. Ele faz um ótimo Band Aind quando você corta seus dedos nas portas do Labirinto do Minotoro - possivelmente o pior de todos os seus problemas, mas um conforto.",ep:0,g:119,l:111,wd:false,fm:true,w:10,s:59,p:31525};
I.u[8413] = {n:"Martelo Mumminotor",t:7,d:"A pedra no final deste martelo está enrolada em bandagens absorvente de Mumminotor para estes assassinatos caseiros.",ep:0,g:60,l:112,wd:false,fm:true,w:10,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>100&CI>200&CW>150",s:59,p:100};
I.u[8414] = {n:"Adagas de Dragonete",t:5,d:"Adagas muito bem forjadas que farão de você um valente lutador.",ep:20,g:58,l:128,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CS>150&CI>150&CA>100",p:39854};
I.u[8415] = {n:"Botas Mumminotor",t:11,d:"Acolchoadas e decoradas com bandagens de Mumminotor, estas botas são confortáveis e quentes. Podem até mesmo lembrá-lo das carícias de sua mãe.",ep:0,g:92,l:110,wd:false,fm:true,w:10,s:59,p:31255};
I.u[8416] = {n:"Capa Mumminotor",t:17,d:"Feita de bandagens dobradas de Mumminotor, esta capa dará a você um aspecto morto-vivo, triste e vagaroso. Você será a inveja da cidade.",ep:0,g:122,l:111,wd:false,fm:true,w:10,s:59,p:31780};
I.u[8417] = {n:"Pá de Bolo",t:8,d:"Esta pequena pá pequena foi dada a um jovem Enutrof. Ele gostou tanto dela que a usou até sua morte.",ep:20,g:43,l:131,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CC>250&CA>100",p:42514};
I.u[8418] = {n:"Cinto Mumminotor",t:10,d:"A origem desta grande bandagem Mumminotor é desconhecida. Seu uso é muitas vezes misterioso, já que na verdade está com decomposição acelerada. Ótimo para as mentiras de primeiro de abril. Certifique-se de manter uma lista de todos os bons amigos que você tem e diga a eles para arrancar a bandagem.",ep:0,g:108,l:112,wd:false,fm:true,w:10,s:59,p:32255};
I.u[8419] = {n:"Pá de Moh",t:8,d:"O capitão Machab destripou o grande Kralove Branco, conhecido como Grobill Dick, com esta pá.",ep:20,g:42,l:115,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>200",p:33653};
I.u[8420] = {n:"Pá de Dragonete",t:8,d:"Os Dragonetes gostam de cavar túneis mas eles não usam pás. A comunidade Enutrof estudou e tentou responder este enigma, mas concluiu que era menos importante saber de onde isto veio do que usá-lo para bater em outra pessoa.",ep:20,g:45,l:127,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,40,40,false,true],c:"CC>200&CS>100",p:42154};
I.u[8421] = {n:"Certificado do Canil: Crowling Feio",t:77,d:"Este certificado menciona as características do Crowling Feio que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8423] = {n:"Presente de Compensação",t:89,d:"...",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8424] = {n:"Presente de Compensação dos Criadores",t:89,d:"Este presente, destinado apenas aos Criadores, contém coisas suficientes para você equipar seu paddock com excelentes máquinas de procriação. (Atenção! Os artigos contidos neste presente são muito pesados. Você pode ficar sobrecarregado quando o abrir.)",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8425] = {n:"Bolsa de 10.000 Kamas",t:100,d:"Esta sacola é muito pesada. Provavelmente, contém uma fortuna. Mercadores ficarão felizes em trocá-la pelo seu valor em Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:100000};
I.u[8426] = {n:"Pequena Bomba de Fumaça",t:74,d:"Esta pequena bomba de fumaça cria uma pequena cortina de fumaça que, infelizmente, não oculta suas ações.",ep:1,g:30,l:1,wd:false,fm:true,w:1,c:"(PX=3)|(PX=4)",ut:true,p:1};
I.u[8428] = {n:"Poção de Invisiblidade Nublada",t:12,d:"Esta poção permite a você voltar para seu último ponto de salvamento sem uma trilha.",ep:0,g:26,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,ut:true,p:1};
I.u[8430] = {n:"Balão Amarelo Mágico",t:94,d:"Diferente das falsificações que você encontrará na Feira de Trool, este balão pode voar para longe com graça e facilidade. Foi um trabalho manual feito a partir de uma larva azul estripada, mas que foi possível inflá-la por um Trool, de acordo com a receita tradicional do poderoso mago Betsy Krokerr.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8431] = {n:"Poção de Fumaça Ciclônica",t:12,d:"Esta poção de fumaça cria uma cortina de fumaça que esconde tudo em ação com estilo.",ep:0,g:29,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,p:1};
I.u[8435] = {n:"Balão Vermelho Mágico",t:94,d:"Diferente das falsificações que você encontrará na Feira de Trool, este balão pode voar para longe com graça e facilidade. Foi um trabalho manual feito a partir de uma larva azul estripada, mas que foi possível inflá-la por um Trool, de acordo com a receita tradicional do grato mago Betsy Krokerr.",ep:1,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8436] = {n:"Chave do Calabouço do Carvalho Mole",t:84,d:"Esta chave lhe permitirá você acessar as mais íntimas partes da anatomia do Carvalho Mole sem entender para onde você está indo. Tão perturbador quanto excitante, esta viagem ao infinito e ao além não o deixará indiferente.",ep:1,g:236,l:1,wd:true,fm:true,w:1,p:100};
I.u[8437] = {n:"Chave do Calabouço de Areia",t:84,d:"Esta chave feita de detritos marinhos e conchas permitirá que você acesse a praia com a areia mais branca de toda a Costa do Mar de Asse!",ep:1,g:237,l:1,wd:true,fm:true,w:1,p:100};
I.u[8438] = {n:"Chave do Calabouço do Rato de Brakmar",t:84,d:"Esta chave lhe permitirá acessar o Calabouço dos Ratos, localizado nos esgotos de Brakma. Não há necessidade de se vestir bem, você passará despercebido mesmo que você não seja um Brakmariano.",ep:1,g:238,l:1,wd:true,fm:true,w:1,p:100};
I.u[8439] = {n:"Chave do Calabouço do Rato de Bonta",t:84,d:"Esta chave lhe permitirá acessar o Calabouço dos Ratos, localizado nos esgotos de Bonta. Não há necessidade de se vestir bem, você passará despercebido mesmo que não seja um Bontariano.",ep:1,g:239,l:1,wd:true,fm:true,w:1,p:100};
I.u[8441] = {n:"Billalo",t:16,d:"Bill queria uma auréola. Ele berrou tão alto, ficou com raiva e finalmente conseguiu. Um verdadeiro diabinho.",ep:22,g:159,l:100,wd:true,fm:true,w:1,p:25540};
I.u[8442] = {n:"Máscara de Rato Preto",t:16,d:"Brouce Boulgoure usou esta máscara para se infiltrar em uma guarida de ratos de Esgoto para cortar um olmo pelas raízes. Ele acabou matando todos os ratos da guarida já que ele não era tão discreto com seus tamancos de madeira.",ep:2,g:158,l:102,wd:true,fm:true,w:1,s:68,p:17222};
I.u[8443] = {n:"Capa de Rato Preto",t:17,d:"Esta capa pode ser feita com qualquer tipo de pêlo, contanto que eles sejam os mais sujos possíveis. Eles são trançados juntos e, então, fixados graças a várias secreções. O cheiro não é uma opção.",ep:13,g:123,l:105,wd:true,fm:true,w:5,s:68,p:18356};
I.u[8444] = {n:"Adagas de Rato Preto",t:5,d:"Tão afiadas quanto danificadas, as lâminas destas adagas permitirão fatiar os membros dos seus inimigos com uma facilidade desconcertante. E tenha certeza que você levará uma quantidade impressionante de tiras de carne. Pena que elas não são enferrujadas, envenenadas nem incandescentes quando você precisar usá-las.",ep:8,g:59,l:108,wd:true,fm:true,w:5,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CW>100&CV>300",s:68,p:19358};
I.u[8445] = {n:"Colar de Rato Preto",t:1,d:"O rato que possuiu este colar pensou que se tornaria o chefe do seu clã. Ele foi devorado por um furioso Lenald.",ep:18,g:115,l:103,wd:true,fm:true,w:5,s:68,p:17650};
I.u[8446] = {n:"Botas de Rato Preto",t:11,d:"Tenha cuidado ao colocar estas botas!! Ainda pode haver um pé ou dois do dono anterior dentro delas...",ep:13,g:93,l:101,wd:true,fm:true,w:10,s:68,p:18700};
I.u[8447] = {n:"Cinto de Rato Preto",t:10,d:"Diferentemente de seu primo branco Bontariano, o Rato Preto é discreto e usa um cinto de tecido simples. Mas ele também gosta de carregar muitas armas e isso faz um barulho terrível a cada passo que dá.",ep:13,g:109,l:101,wd:true,fm:true,w:5,s:68,p:18934};
I.u[8448] = {n:"Anel de Rato Preto",t:9,d:"Gire este anel para a direita, se você for dar um aperto de mão em um inimigo, e para a esquerda, se for apertar as mãos de um amigo. Em todos os casos, não é aconselhado bater palmas se estiver usando este anel.",ep:20,g:120,l:98,wd:true,fm:true,w:5,s:68,p:16980};
I.u[8449] = {n:"Transformação do Calabouço Treechnid",t:27,d:"Um Treechnid te mordeu e lhe passou uma estranha maldição.",ep:9,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8450] = {n:"Espada de Rato Branco",t:6,d:"Esta arma é o símbolo do Rato Branco. Sabe-se que sua capacidade de cortar em fatias tanto inimigos como aliados com facilidade é a mesma.",ep:16,g:71,l:109,wd:true,fm:true,w:10,an:14,tw:true,e:[5,5,1,1,40,50,false,false],c:"CA>150&CS>100",s:67,p:17542};
I.u[8451] = {n:"Chapéu de Rato Branco",t:16,d:"Com este chapéu, o Rato Branco parece um Rato Branco Real de Bonta. Sem ele, se parece com um Rato Branco Real de Bonta sem chapéu.",ep:13,g:160,l:105,wd:true,fm:true,w:10,s:67,p:18451};
I.u[8452] = {n:"Capa de Rato Branco",t:17,d:"Esta capa é o símbolo que identifica o rato branco da rede de esgotos de Bonta. É a recompensa que o rato recebe depois de um longo e difícil exame que, orgulhosamente, o utilizará até que a morte o faça... que normalmente não demora muito tempo.",ep:14,g:124,l:102,wd:true,fm:true,w:5,s:67,p:17025};
I.u[8453] = {n:"Colar de Rato Branco",t:1,d:"Se você usar como colar, ele o protegerá das emissões tóxicas dos esgotos. Mas, usando como um cinto, ele protegerá seus aliados das emissões tóxicas.",ep:18,g:116,l:103,wd:true,fm:true,w:5,s:67,p:18900};
I.u[8454] = {n:"Luva de Rato Branco",t:9,d:"Esta Luva pertencia a Julia Dilch, cozinheira do palácio de Bonta. Usou para enfrentar os Gobballs que resistiam antes de cortar suas gargantas, ou plantas selvagens que não entravam na tigela de salada, e os clientes que não comiam também.",ep:18,g:121,l:101,wd:true,fm:true,w:5,s:67,p:17150};
I.u[8455] = {n:"Cinto de Rato Branco",t:10,d:"Não é como Black Brakmariana pensa, que o Rato Branco é o mais discreto possível. Essa é a razão pela qual ele acolchoou os elos metálicos deste cinto com piche. Dessa maneira não faz qualquer barulho, a menos que a pessoa que o usar cair no chão, e isto acontece freqüentemente, já que este cinto é extremamente pesado.",ep:16,g:110,l:102,wd:true,fm:true,w:150,s:67,p:18850};
I.u[8456] = {n:"Botas de Rato Branco",t:11,d:"Com estas botas, o seu equilíbrio será perfeito... até mesmo durante uma tempestade de vento.",ep:3,g:94,l:99,wd:true,fm:true,w:10,s:67,p:17650};
I.u[8457] = {n:"Chapéu Cerimonial do Lorde Rato",t:16,d:"Este chapéu não tem nada a ver com um Dora... Absolutamente nada! É inútil espalhar falsos rumores sobre o seu criador ser frouxo ou sem inspiração!!! Este chapéu tem uma bela aparência.",ep:13,g:173,l:133,wd:true,fm:true,w:10,s:64,p:43300};
I.u[8458] = {n:"Capa Cerimonial do Lorde Rato",t:17,d:"Esta capa colorida o transforma em um alvo ideal. Só aventureiros rápidos e espertos podem usá-la por muito tempo.",ep:14,g:125,l:130,wd:true,fm:true,w:10,s:64,p:42030};
I.u[8459] = {n:"Colar Cerimonal do Lorde dos Ratos",t:1,d:"Este colar é posto em torno do pescoço do Senhor dos Ratos assim que ele nasce, para prevenir o roubo. Assim, quando ele se torna adulto, a única maneira de tirar o colar é decapitando-o. Bem, de alguma maneira, o colar ainda é roubado!",ep:18,g:117,l:134,wd:true,fm:true,w:5,s:64,p:45842};
I.u[8460] = {n:"Anel Cerimonial do Lorde dos Ratos",t:9,d:"Este anel foi projetado no período em que o Senhor dos Ratos só possuía um dedo, depois de mutilar todos os outros. Os desafortunados senhores seguintes possuíam todos os dedos.",ep:20,g:122,l:131,wd:true,fm:true,w:5,s:64,p:42542};
I.u[8461] = {n:"Cinto Cerimonal do Lorde dos Ratos",t:10,d:"Os desenhos neste cinto realmente lhe dão a impressão de que você está queimando! O engana-olho é tão bom que a maior parte das pessoas que o usam realmente acredita que está queimando e corre por toda a parte gritando! Por incrível que pareça, isto corresponde exatamente ao ritual de cerimônia.",ep:16,g:111,l:133,wd:true,fm:true,w:10,s:64,p:43358};
I.u[8462] = {n:"Botas Cerimoniais do Lorde Rato",t:11,d:"O primeiro Lorde Rato a morrer por se intrometer em uma piscina de lava derretida. Para prestar tributo a ele, seus lordes usavam estas botas. Tenha cuidado, elas não são à prova de fogo.",ep:13,g:95,l:134,wd:true,fm:true,w:10,s:64,p:43541};
I.u[8463] = {n:"Treecapacete Ancestral",t:16,d:"Os cogumelos incrementados neste capacete espalham um bom odor estimulante que faz você querer pegar raízes. Eles também são bastante gostosos, mas podem mandá-lo para um caixão.",ep:9,g:174,l:114,wd:true,fm:true,w:10,s:65,p:33150};
I.u[8464] = {n:"Treecapa Ancestral",t:17,d:"No verão, o Treechnid Ancestral gosta de pegar sol, mas como sua madeira é acostumada a florestas escuras, ele não fica muito tempo. Esta capa é feita de sua casca descascada.",ep:18,g:126,l:114,wd:true,fm:true,w:5,s:65,p:33524};
I.u[8465] = {n:"Torque Ancestral",t:1,d:"Ao redor de seu pescoço, este torque destacará sua barba. Se você não tiver barba, bem, a culpa é sua.",ep:20,g:118,l:110,wd:true,fm:true,w:10,s:65,p:31542};
I.u[8466] = {n:"Anel Ancestral",t:9,d:"Nas noites em que você bebe demais, pode ser que veja o Moskito embutido neste anel piscar para você. Mas não conte aos seus amigos, ele só estará fingindo.",ep:9,g:123,l:113,wd:true,fm:true,w:5,s:65,p:33241};
I.u[8467] = {n:"Protetores de Canela Ancestrais",t:11,d:"Com estes protetores de canela de madeira, suas pernas estarão altamente protegidas. Entretanto, você não pode usar botas com eles. Você pode usá-los quando estiver participando das competições de Gobbowl, eles o protegerão. Mas será difícil para você chutar a bola sem suas botas.",ep:20,g:96,l:110,wd:false,fm:true,w:10,s:65,p:31524};
I.u[8468] = {n:"Treecinto Ancestral",t:10,d:"Este cinto deveria lhe dar a virilidade ancestral. Se isso era verdade ou não, o efeito expirou.",ep:9,g:112,l:111,wd:true,fm:true,w:10,s:65,p:32101};
I.u[8469] = {n:"Talismã do Carvalho Mole",t:1,d:"Este pedaço de madeira extraído bem do interior do Carvalho Mole é extremamente poderoso. De fato, ele pode até mesmo enfurecer o Carvalho Mole.",ep:20,g:119,l:138,wd:true,fm:true,w:10,s:66,p:44521};
I.u[8470] = {n:"Anel de Carvalho Mole",t:9,d:"Este anel é de fezes de Carvalho Mole, em madeira, mas o cheiro permanece o mesmo.",ep:9,g:124,l:139,wd:true,fm:true,w:5,s:66,p:43014};
I.u[8471] = {n:"Calçados de Couro do Carvalho Mole",t:11,d:"Aos domingos, o Carvalho Mole tira um cochilo e, quando acorda, gosta que algum Trunknid obediente traga seus calçados de couro sem perguntas. Infelizmente, ele não tem nenhum pé, então eles ainda estão novinhos em folha.",ep:20,g:97,l:136,wd:true,fm:true,w:5,s:66,p:43521};
I.u[8472] = {n:"Capa Usada de Carvalho Mole",t:17,d:"Há 200 anos, alguns tecidos ficaram enfiados nos galhos de Carvalho Mole. Conforme as árvores cresciam, ficaram impregnando o tecido com a sua mágica. Este tecido agora é uma parte integrante deste grande pedaço de madeira e o torna difícil de manusear e inflamável;\r\n            seu poder não pode ser negado.",ep:18,g:127,l:142,wd:true,fm:true,w:10,s:66,p:44578};
I.u[8473] = {n:"Fio Dental de Outono de Carvalho Mole",t:10,d:"No outono, o Carvalho Mole veste seu fio-dental para proteger suas preciosas bolotas. No verão, ele gosta de ficar nu.",ep:9,g:113,l:141,wd:true,fm:true,w:10,s:66,p:44514};
I.u[8474] = {n:"Chapéu de Carvalho Mole",t:16,d:"Você pode usar este chapéu de todas as formas possíveis, ele ainda vai parecer estar de lado.",ep:9,g:166,l:145,wd:true,fm:true,w:10,s:66,p:45241};
I.u[8475] = {n:"Chave da Toca Werepeki",t:84,d:"Esta chave se transforma durante as noites de lua cheia numa terrível chave viva, e abre as portas das casas onde os proprietários têm alguma vergonha moral. Alguns aventureiros chegam a acreditar nisso.",ep:1,g:240,l:1,wd:true,fm:true,w:1,p:100};
I.u[8476] = {n:"Primeira Chave do Calabouço do Rato Rei",t:24,d:"Apenas esta chave não será suficiente para você entrar no calabouço do Rato Rei. Você também precisará de outra.",ep:1,g:502,l:1,wd:false,fm:true,w:0,p:100};
I.u[8477] = {n:"Segunda chave para o calabouço de Sphincter",t:24,d:"Esta única chave não será suficiente para você entrar no calabouço do Rei Rato. Você também precisará da outra.",ep:1,g:503,l:1,wd:false,fm:true,w:0,p:100};
I.u[8478] = {n:"Poção Bajulador",t:12,d:"Esta poção altamente ilegal é temida até mesmo pelos guerreiros Pandawa mais fortes. Um único gole e você estará obcecado com a idéia de lamber todos os calçados que ver. \nEstudantes que se preocupam com suas grades normalmente usam uma poção similar para seus professores. O bafo dirá tudo.",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:10};
I.u[8480] = {n:"Poção de Bajulação",t:24,d:"Esta poção altamente ilegal é temida até pelos mais fortes. Um único gole e a pessoa fica obcecada pela idéia de lamber as botas mais próximas. Diz o rumor que existe uma poção alternativa e que tem um alvo diferente. A única pista que você terá sobre este misterioso alvo será a terrível respiração dos bebedores azarados.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:10};
I.u[8481] = {n:"Chapéu de Rato do Esgoto",t:54,d:"Este chapéu é sujo e fedorento. Já passou por muitos esgotos da área. E mesmo assim continua brilhante.",ep:2,g:670,l:42,wd:true,fm:true,w:1,p:10};
I.u[8482] = {n:"Pele de Rato do Esgoto",t:59,d:"Esta pele é coberta com pequenas cicatrizes que são a prova da infância difícil do Rato Imundo do Esgoto. Você poderia ao menos sentir pena dele.",ep:2,g:621,l:42,wd:true,fm:true,w:1,p:10};
I.u[8483] = {n:"Pele de Xamã do Esgoto",t:59,d:"Depois de lavada, esta pele pode ser usada como tapete ou capacho.",ep:2,g:622,l:40,wd:true,fm:true,w:1,p:10};
I.u[8484] = {n:"Pêlo de Xamã do Esgoto",t:54,d:"Eles costumavam fazer bigodes falsos, mas também estavam falsificando os pêlos das axilas.",ep:2,g:671,l:40,wd:true,fm:true,w:1,p:10};
I.u[8485] = {n:"Tecido de Rato Preto",t:55,d:"Enrolado em uma macia tira de madeira, este tecido pode ser usado como uma esponja ou como um coça-bumbuns. Algumas necessidades para todos os gostos.",ep:2,g:725,l:100,wd:true,fm:true,w:1,p:10};
I.u[8486] = {n:"Tecido de Rato Branco",t:55,d:"Este tecido é tão gorduroso quanto um cabelo de Wabbit que foi mergulhado em graxa de Blop, assim protegendo-o do frio. Especialmente se você tacar fogo.",ep:2,g:726,l:100,wd:true,fm:true,w:1,p:10};
I.u[8487] = {n:"Tecido de Sphincter Cell",t:55,d:"Este tecido parece estar coberto com um estranho produto químico com efeitos colaterais desconhecidos. É melhor você não manter por muito tempo este tecido em suas mãos. ",ep:2,g:727,l:200,wd:true,fm:true,w:10,p:100};
I.u[8488] = {n:"Ulna de Rato Preto",t:47,d:"Este osso de rato pode ser esvaziado, perfurado e esculpido. Então, ele pode ser usado como um instrumento musical ou como um maçarico, se você não for tão bom em música.",ep:2,g:658,l:100,wd:true,fm:true,w:10,p:10};
I.u[8489] = {n:"Dente de Rato Branco",t:47,d:"Este dente é realmente uma terrível presa que capacita o Rato Branco a transmitir muitas doenças a suas vítimas quando ele as morde. Uma das maneiras seguras de que as suas vítimas morreriam mesmo que não as pudesse matar. E por isso merece ser respeitado.",ep:2,g:659,l:100,wd:true,fm:true,w:10,p:10};
I.u[8490] = {n:"Fêmur de Sphincter Cell",t:47,d:"Sphincter não era do tipo que se rendia e devia ser quebrado em dois, três, quatro e até mais partes quando encorajava pessoas adormecidas pelo tédio de uma luta.",ep:2,g:657,l:200,wd:true,fm:true,w:10,p:10};
I.u[8491] = {n:"Pele de Rato Preto",t:59,d:"O Rato Preto era conhecido por seu mau hálito mas também pela áspera pele de seu traseiro. Isto é muito útil para não se deslizar no assento do banheiro. Infelizmente, o Rato Preto nunca se deu ao trabalho de ir a banheiros, já que ele viveu justamente nos esgotos.",ep:2,g:623,l:100,wd:true,fm:true,w:1,p:10};
I.u[8492] = {n:"Pele de Rato Branco",t:59,d:"O Rato Branco adora andar deprimido debaixo dos esgotos e espera alguma pessoa amável vir confortá-lo. Então abusa da ingenuidade e credulidade das suas vítimas e esfola vivas e depois as recheia com nozes de caju. Nozes de caju pequenas.",ep:2,g:624,l:100,wd:true,fm:true,w:1,p:10};
I.u[8493] = {n:"Pele de Sphincter Cell",t:59,d:"Quem acreditaria que algum dia você estaria segurando a famosa pele de Sphincter? Bem, Sphincter que não. A autoconfidência dele o levou à morte.",ep:2,g:625,l:200,wd:true,fm:true,w:10,p:100};
I.u[8494] = {n:"Casca de Treechnid Ancestral",t:96,d:"Esta casca se desprendeu do Treechnid Ancestral sem você precisar arrancá-la com os dentes.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[8495] = {n:"Botão de Treechnid Ancestral",t:108,d:"A seiva deste broto seco foi extraída por uma criatura esfomeada. Se mergulhá-la na água, você a verá voltar à sua forma normal e, se esperar muito tempo, ela apodrece.",ep:9,g:755,l:200,wd:true,fm:true,w:1,p:10};
I.u[8496] = {n:"Raiz de Treechnid Ancestral",t:98,d:"Mesmo que você arranque-a de seu proprietário, esta raiz pode chicotear seu traseiro ou torcer seus tornozelos. Que coisa má!",ep:9,g:668,l:200,wd:true,fm:true,w:1,p:10};
I.u[8497] = {n:"Receita da Filtounga",t:24,d:"Este livro contém os segredos de Filtounga... O prato mítico criado por Mouss Bouff.",ep:16,g:95,l:1,wd:true,fm:true,w:0,u:true,p:10};
I.u[8498] = {n:"Carne de Kaniger",t:63,d:"Esta carne é tão macia quanto o cérebro de Mushd.",ep:13,g:375,l:80,wd:true,fm:true,w:1,p:1};
I.u[8499] = {n:"Carne de Koalak",t:63,d:"Na maior parte do tempo, a carne de Koalak é bem firme. Você pode deixá-la mais macia se bater nela com o tronco de um Kaliptus. Assim como é feito com uma criança desobediente.",ep:20,g:376,l:60,wd:true,fm:true,w:1,p:1};
I.u[8500] = {n:"Carne de Crocodyl",t:63,d:"Esta carne insípida pode ser preservada na lama por muitos anos, antes de apodrecer e, então, começar a ter gosto de algo.",ep:4,g:377,l:70,wd:true,fm:true,w:1,p:1};
I.u[8501] = {n:"Carne de Kaniger Conservada",t:64,d:"Essa carne de Kaniger agora pode ser conservada vários dias antes de ser usada em uma refeição.",ep:13,g:387,l:80,wd:true,fm:true,w:1,p:10};
I.u[8502] = {n:"Carne de Koalak Conservada",t:64,d:"Essa carne de Koalak agora pode ser conservada vários dias antes de ser usada em uma refeição.",ep:20,g:388,l:120,wd:true,fm:true,w:1,p:10};
I.u[8503] = {n:"Carne de Crocodyl Conservada",t:64,d:"Essa carne de Crocodyl agora pode ficar conservada por diversos dias, antes que seja usada em uma refeição.",ep:4,g:389,l:70,wd:true,fm:true,w:1,p:10};
I.u[8504] = {n:"Bife de Kaniger",t:69,d:"Este bife, quente ou mesmo frio, satisfará os apetites mais vorazes.",ep:13,g:132,l:80,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8505] = {n:"Bife de Koalak",t:69,d:"Este pedaço de carne encherá os estômagos mais vorazes.",ep:20,g:133,l:120,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8506] = {n:"Bife de Crocodyl",t:69,d:"Este impressionante pedaço de carne é, obviamente, extremamente difícil de digerir. Mas a ganância sempre prevalece sobre a razão.",ep:4,g:134,l:70,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8507] = {n:"Prato de Filtounga",t:69,d:"A Filtounga é um prato sem igual. Graças aos ingredientes que o compõem, mantém seu gosto especial. Servir morno.",ep:1,g:136,l:100,wd:true,fm:true,w:1,c:"Cv<100",u:true,ut:true,p:1};
I.u[8508] = {n:"Prato de Filtounga",t:24,d:"Este prato é para a bruxa Paindep.",ep:1,g:120,l:1,wd:true,fm:true,w:0,p:1};
I.u[8509] = {n:"Receita de Energético de Bwork",t:25,d:"O grande Mago Bworknroll revela aqui sua consagrada receita do energético de Bwork. Ele não omite nenhum segredo e até dá dicas de melhores maneiras de saboreá-lo. Um deleite para os amadores, um pesadelo para aqueles que já experimentaram este energético sem ter conhecimento.",ep:1,g:130,l:10,wd:false,fm:true,w:5,u:true,p:500};
I.u[8511] = {n:"",t:102,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:10,tw:true,e:[20,7,4,12,50,30,true,true],p:1};
I.u[8513] = {n:"Escalpo de Bworknroll",t:5,d:"Coletar ‘pedaços\' de criaturas com o bisturi de Bworknroll lhe assegurará um bom trabalho, já que ele preserva a vitalidade dos membros arrancados. Use-o em uma luta para coletar as partes que você deseja.",ep:1,g:60,l:40,wd:true,fm:true,w:10,an:13,e:[10,4,1,1,30,50,false,false],c:"Qa=166",p:100};
I.u[8514] = {n:"Cérebro de Vampiro",t:15,d:"Sempre sobrecarregado com glóbulos frescos, um cérebro de vampiro suga todas as células vermelhas do sangue que conseguir. Essa é a razão pela qual os vampiros são tão pálidos. A respeito dos Iops, seus pés sugam todas as células vermelhas do seu sangue, o que os faz saltar sem pensar...",ep:3,g:492,l:20,wd:true,fm:true,w:2,u:true,p:10};
I.u[8515] = {n:"Osso de Trool",t:47,d:"Se considerarmos o peso e a solidez de um osso de Trool, é fácil entender o motivo de machucar tanto quando eles o acertam durante os jogos de Trool.",ep:4,g:640,l:5,wd:true,fm:true,w:50,p:50};
I.u[8516] = {n:"Coração de Bworkcelhain",t:15,d:"Esta cruel Bworkette, que se livrou de seu filho Krazybwork lançando-o em uma cova, foi amaldiçoada por Bworknroll quando recusou o amor dele. Presa em um porão, ela se alimenta com seu próprio coração. Todas as noites, ele cresce e começa a bater novamente.",ep:4,g:518,l:33,wd:true,fm:true,w:33,p:33};
I.u[8517] = {n:"Mumussel",t:15,d:"Este belo e fresco Mumussel é um grande companheiro dos Bworks quando eles vão saquear longe de suas esposas.",ep:3,g:756,l:1,wd:true,fm:true,w:3,p:21};
I.u[8518] = {n:"Mumussel e Fritas",t:69,d:"Nas profundezas do Mar de Asse, Mumussels coletam algas marinhas que eles rolam debaixo de suas axilas. Uma vez que o material tem a forma de batatas fritas, eles vão à praia para bronzeá-las ao sol antes de comê-las.",ep:3,g:135,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:30};
I.u[8519] = {n:"Trooló",t:69,d:"Este tradicional pão de ló recheado com sujeira de Trool é uma velha receita Bwork. Só um Bwork que derrotou um Trool apenas com as mãos tem permissão para comer isto. Se ele sobrevivesse a tal luta, ele poderia comer quase qualquer coisa!",ep:1,g:136,l:5,wd:true,fm:true,w:20,u:true,p:200};
I.u[8520] = {n:"Gordurola",t:60,d:"Esta gordura espessa e nutritiva permite cozinhar a maior parte dos tipos de comida em panelas velhas sem arruinar o prato. Alguns Osamodas também a usam para deslizar Tofus em lugares que a moral Iop condena.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[8521] = {n:"A Capa Vermelha",t:17,d:"A capa vermelha é o artefato favorito dos megalomaníacos. Uma vez em seus delicados ombros, eles acreditam que são o Super-Homem ou um mágico ultrapoderoso, até que encontram um Minotoror.",ep:1,g:128,l:9,wd:false,fm:true,w:1,p:200};
I.u[8522] = {n:"Lançador de Efeito Mágico",t:74,d:"Este item surpreendente contém uma mágica negra concentrada e instável. Ninguém pode prever os efeitos, mas certamente você não deve esperar muito antes de usá-la.",ep:1,g:31,l:1,wd:false,fm:true,w:0,ut:true,p:1};
I.u[8523] = {n:"Relíquia de Família",t:24,d:"Este item de família é extremamente poderoso. Normalmente passado de geração em geração aos membros de sua família, ele não perdeu nenhum de seus poderes. Há muitos poucos artefatos que contêm tal poder. Pode até mesmo ter estado em contato com um Dofus...",ep:1,g:22,l:200,wd:true,fm:true,w:0,p:1};
I.u[8524] = {n:"Fantasma Pingüim-San",t:90,d:"Este Pingüim-San ainda não deixou o mundo dos vivos. Você pode decidir achar um jeito de ressuscitá-lo ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:45,l:1,wd:true,fm:true,w:1,p:1};
I.u[8525] = {n:"Ovo de Piwi",t:69,d:"Os ovos de Piwi são uma verdadeira ameaça para aqueles que têm dentes sensíveis! No entanto, eles chocam rapidamente quando estão perto de uma fonte de calor. Este é o motivo pelo qual você não o deve deixar em seu bolso ou em sua boca por muito tempo! De fato, em poucos minutos um míni-Piwi poderia sair de dentro dele. E, acredite em nós, ter um Piwi faminto entre os seus dentes ou entre as suas roupas não é o que você precisa se você for coceguento.",ep:4,g:38,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[8526] = {n:"Certificado do Canil: Koalak Sanguinário",t:77,d:"Este certificado menciona as características do Koalak Sanguinário que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8527] = {n:"Gobtrote",t:11,d:"Estas botas feitas de pele de Duende foram criadas por Planbworksek para carregar o inimigo (se possível pelas costas) extremamente depressa. Com estas botas, ele salvou muitos companheiros Bwork em dificuldade.",ep:4,g:98,l:14,wd:true,fm:true,w:20,p:400};
I.u[8528] = {n:"Receita de Panqueca",t:25,d:"Graças ao Pol Bokuz, você finalmente poderá produzir sua massa de panqueca para alimentar os seus netos e rapidamente colocá-los na cama. Qual é o ingrediente secreto dessa receita soporífera e que tanto farta? O energético de Astrub, é claro!",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[8529] = {n:"Martelo Zaap",t:24,d:"O nada melhor que reparar um martelo Zaap desequilibrado!",ep:1,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[8530] = {n:"Chapéu Ruskie",t:16,d:"Este chapéu mantém suas orelhas quentes e absorve o energético de seu bafo. O que mais você pode pedir?",ep:22,g:167,l:151,wd:true,fm:true,w:10,p:46280};
I.u[8531] = {n:"Chapéu de Coelho",t:16,d:"Ninguém ousaria usar um chapéu desses! Ou ousaria...?",ep:1,g:168,l:33,wd:true,fm:true,w:6,p:3000};
I.u[8532] = {n:"Capa de Coelho Indiferente",t:17,d:"Ao usar esta capa, você demonstrará sua total indiferença por aqueles que estiverem por perto. Perfeita para pessoas malvadas.",ep:1,g:129,l:14,wd:true,fm:true,w:1,p:775};
I.u[8533] = {n:"Flud",t:16,d:"O Flud não é realmente um chapéu. É mais um parasita que tende a se desenvolver nas cabeças de pessoas volúveis, barulhentas ou agressivas. Seu aspecto asqueroso faz as pessoas fugirem, forçando seu portador a gritar cada vez mais alto, o que é inútil, já que, de qualquer maneira, ele não tem nada a dizer.",ep:1,g:169,l:1,wd:true,fm:true,w:1,s:69,p:100};
I.u[8534] = {n:"Capa S\'loque",t:17,d:"Esta capa acolchoada absorve todos os barulhos ao redor e obriga seu portador a gritar o tempo todo.",ep:1,g:130,l:1,wd:true,fm:true,w:10,s:69,p:100};
I.u[8535] = {n:"Estilhaçadores",t:11,d:"Estas getas são tão leves que fazem seu proprietário correr e saltar por todos os lados quando uma luta começa. Aventureiros experientes simplesmente odeiam estas getas, que permitem a qualquer um entrar em uma luta sem ser convidado.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8536] = {n:"Spamette",t:10,d:"Este cinto deve ser usado extremamente apertado. Tão apertado, que ele força seu usuário a gaguejar, tremer e fazer nada enquanto for repetitivo.",ep:1,g:114,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8537] = {n:"Pluswan",t:9,d:"Este pequeno anel não tem utilidade a não ser deixá-lo extremamente ofuscante. Agora as pessoas sentirão vontade de estar perto de você.",ep:1,g:125,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8538] = {n:"S\'Mesme",t:1,d:"Após várias noites de trabalho duro, o mais famoso joalheiro de Astrub, também conhecido por crescer com Bworks, uma vez disse para uma multidão impressionada: ‘Vjo v6 dp com meu amu\'. Mesmo o conhecido historiador Champo Lhyon não conseguiu decifrar a mensagem do joalheiro.",ep:1,g:120,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8539] = {n:"Machado de Lenhador Aprendiz",t:19,d:"Até mesmo se você não souber manejar machados muito bem, você não se machucará com este já que sua lâmina está muito cega. Mas se você bater forte o bastante, pode até ser que você consiga cortar algumas árvores.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:0};
I.u[8540] = {n:"Gadanha de Fazendeiro Aprendiz",t:22,d:"Esta é uma foice de média qualidade, mas você não deveria reclamar já que lhe foi dada como presente. Além disso, colhe trigo corretamente e isto é tudo o que se espera que ela faça.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[8541] = {n:"Vara de Pescador Aprendiz",t:20,d:"Bem, esta vara costumava ser melhor. Embora a linha seja um pouco usada e a isca duvidosa, esta vara é perfeita para pescar gobiões.",ep:1,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,1,100,100,false,false],p:1};
I.u[8542] = {n:"Luvas de Alquimista Aprendiz",t:20,d:"Você pode dizer que estas luvas são de boa qualidade. Não há quase nenhum buraco nelas;\r\n            cheira a suor do antigo dono;\r\n            os dedos são muito curtos;\r\n            suporte inseguro... \nBem, não há o que questionar, estas luvas são muito ruins.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:1};
I.u[8543] = {n:"Energético de Incarnam",t:79,d:"Este energético fermentado pelos deuses é uma mistura de guaraná, alma e Teff. Ele revive as jovens almas que chegaram em Incarnam. Para as demais, é uma mera água brilhante dificilmente boa o bastante para praticar soluços.",ep:1,g:4,l:1,wd:true,fm:true,w:1,c:"PL<16",u:true,ut:true,p:1};
I.u[8544] = {n:"Certificado do Canil: Pingüim-San",t:77,d:"Este certificado menciona as características do Pingüim-San que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8545] = {n:"Chave do Calabouço de Incarnam",t:84,d:"Esta chave permite que você entre no calabouço de Incarnam, onde um terrível Snoolobo vive.",ep:1,g:19,l:1,wd:true,fm:true,w:1,p:10};
I.u[8546] = {n:"Pêlo de Snoolobo",t:59,d:"Levemente enrolada, esta pele será um maravilhoso tapete de cama. Alguém já estava procurando por tal pele faz um tempo. Encontre essa pessoa, e faça uma troca!",ep:1,g:3,l:1,wd:true,fm:true,w:10,p:1};
I.u[8547] = {n:"Trinsfirmitinik im Skiril",t:31,d:"Cirsid hizilnits irik nik gidik fir yik.",ep:1,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8548] = {n:"Twanfowmation em Wabbit",t:31,d:"Os malditos Cawwots parecem não gostar de você.",ep:8,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
