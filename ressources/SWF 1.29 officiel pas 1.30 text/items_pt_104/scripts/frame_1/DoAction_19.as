I.u[8557] = {n:"Pena de Batofu",t:53,d:"Esta pena arrancada diretamente das axilas do Batofu cheira como um Doobitchu ancestral marinado.",ep:3,g:120,l:20,wd:true,fm:true,w:1,p:10};
I.u[8558] = {n:"Chapéu Orelhudo",t:16,d:"Se você está planejando comunicar com Wabbits, isto pode ser o que você precisa. Se quer parecer bem, coloque em alguém próximo de você.",ep:1,g:170,l:6,wd:true,fm:true,w:10,p:12000};
I.u[8559] = {n:"O HmmMMmmMmmm",t:16,d:"Hummmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm‘m mmmmm mmmm mmmmmmm.",ep:2,g:171,l:42,wd:true,fm:true,w:1,p:420};
I.u[8561] = {n:"Bebê Pandawa",t:18,d:"Esse fofo Bebê Pandawa vai adorar viajar pelo mundo com você e ver com seus grandes olhos redondos. Este manso animal de estimação come arroz, mas também pode ser alimentado com avelãs.",ep:3,g:42,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8563] = {n:"Litol Goblait",t:32,d:"Litol deve ser seu futuro professor de mágica.",ep:1,g:18,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[8564] = {n:"Certificado do Canil: Pandawa Bebê",t:77,d:"Este certificado menciona as características do Pandawa Bebê que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8565] = {n:"Bebê Pandawa Fantasma",t:90,d:"Esse Bebê Pandawa ainda não saiu do mundo da vida. Você pode escolher entre ajudá-lo a ressuscitar ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[8566] = {n:"Transformação Pingüim-San",t:27,d:"Você foi transformado em um fantasma para poder entrar o Santuário Animal.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8567] = {n:"Transformação do Bebê Pandawa Fantasma",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8568] = {n:"Presente: Bebê Pandawa",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8569] = {n:"Doro le Blak",t:16,d:"Este gorro costumava pertencer a uma pequena Xelorett que tirava proveito da passagem do tempo. A lenda diz que ela roubava vários dias dos habitantes de Amakna. E tinha de distribuir alguns doces para compensar esta pequena trapaça.",ep:22,g:172,l:129,wd:true,fm:true,w:10,p:42512};
I.u[8570] = {n:"Pêlo do Rato de Bonta",t:54,d:"Este pêlo costumava pertencer aos ratos dos esgotos de Bonta. Realmente, eles eram os únicos a ter tufos de pêlos combinando com a cor da parede da cidade deles.",ep:2,g:672,l:40,wd:true,fm:true,w:1,p:10};
I.u[8571] = {n:"Pêlo do Rato de Brakmar",t:54,d:"Este pêlo costumava pertencer aos ratos dos esgotos de Brakmar. Realmente, eles eram os únicos a ter tufos de pêlos combinando com a cor da parede da cidade deles.",ep:2,g:673,l:40,wd:true,fm:true,w:1,p:10};
I.u[8572] = {n:"Poção do Esquecimento: ‘Domesticação de Montaria\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço: ‘Domesticação de Montaria\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8573] = {n:"Poção do Esquecimento: ‘Bumerange Pérfido\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço: ‘Bumerangue Pérfido\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8574] = {n:"Dofus Temperado",t:23,d:"Com ou sem bacon, este Dofus é delicioso.",ep:0,g:13,l:1,wd:false,fm:true,w:1,p:1};
I.u[8575] = {n:"Primeiro Cajado Sangrento",t:4,d:"Um famoso guerreiro Feca que viveu na selva de Pandala costumava dizer: ‘Para ganhar a guerra, você tem que ser a guerra\'.",ep:1,g:71,l:200,wd:false,fm:true,w:20,an:12,tw:true,e:[7,3,1,2,42,42,false,true],c:"PN~xxramboplxx",p:100000};
I.u[8576] = {n:"Pergaminho de recomendação Yse Vewybad",t:24,d:"Yse Vewybad lhe deu este rolo de papel em forma de agradecimento por seus favores.",ep:2,g:26,l:20,wd:false,fm:true,w:0,p:1};
I.u[8588] = {n:"Emblema Ladino",t:24,d:"Este emblema, dado por um ladino, pode ser a chave para entrar em sua caverna.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[8590] = {n:"Contrato entre Vil Smisse e Yse Vewybad",t:24,d:"Este contrato prova a traição de Yse Vewybad. Tudo que você tem de fazer agora é levar isso à pessoa certa.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[8593] = {n:"Poção de Transformação em Wa Wabbit",t:27,d:"Esta poção foi devolvida pelo Uba Tessé. Ele o transformará num Wabbit e isso o permitirá se livrar da pretendente Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8594] = {n:"Poção de Tlansfolmação Wa Wabbit",t:27,d:"Esta poção foi devolvida pelo Uba Tessé. Ele o transformará num Wabbit e isso lhe permitirá se livrar da pretendente Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8595] = {n:"Ovo de Tofu Obeso",t:24,d:"Este ovo contém um Tofu obeso... uma criatura que pode derrotar o Pwince de Wa no futuro.",ep:1,g:122,l:1,wd:true,fm:false,w:0,p:1};
I.u[8596] = {n:"Garra Carmesim",t:6,d:"Esta espada afiada ficou com uma cor carmesim elegante após estripar milhares de Bworks. Antes, era apenas purpurina.",ep:22,g:72,l:145,wd:true,fm:true,w:15,an:14,tw:true,e:[8,6,1,1,45,100,false,false],c:"CS>350&CV>400",p:52000};
I.u[8597] = {n:"Poção de Engorda",t:24,d:"Esta poção permitirá ao Vil Smisse alimentar à força o Tofu obeso que você trouxe para ele.",ep:3,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[8598] = {n:"Adagas Emment",t:5,d:"Estas lâminas têm buracos por toda a parte fazendo um belo barulho de assovio quando manuseada rapidamente. Os buracos também são úteis para tirar as entranhas de seus inimigos.",ep:22,g:61,l:67,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CA>100",p:10654};
I.u[8599] = {n:"Garrettes",t:5,d:"Estas adagas foram forjadas por uma Ecaflipette manicure. Ele não gostava de espadas pesadas que não se adaptavam perfeitamente às unhas envernizadas.",ep:22,g:62,l:69,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,30,false,true],c:"CA>100&CS>100",p:11254};
I.u[8600] = {n:"Preguiçoso demais para subir escadas",t:30,d:"Você está exausto por estar gritando há muito tempo e você não se sente mais capaz de subir aqueles inúmeros degraus por pelo menos 6 minutos...",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8603] = {n:"Uniforme de servente do Príncipe Wabbit",t:24,d:"Com este uniforme, o servente do Príncipe Wabbit estará super na moda.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8604] = {n:"Espada Caule",t:6,d:"Esta espada brilhante é perfeita para aparar flores, mesmo se elas se defenderem. Pode até mesmo cortar árvores.",ep:22,g:73,l:100,wd:true,fm:true,w:10,an:14,e:[15,8,1,1,40,50,false,false],c:"CS>250&CI<1",p:25654};
I.u[8605] = {n:"Espada de Borracha",t:6,d:"Esta lâmina foi lubrificada para entrar no estojo mais facilmente. Entretanto, não pode ser limpada após uso e deve ser jogada fora, especialmente se coberta de sangue. Leve em consideração que o uso principal é protegê-lo.",ep:22,g:74,l:73,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,40,50,false,true],c:"CS>80&CI>80&CA>80",p:14000};
I.u[8606] = {n:"Vestido de noiva",t:24,d:"O vestido de casamento da noiva foi cuidadosamente embrulhado neste embrulho deslumbrante. Ele precisa ser levado ao comissário de bordo São Lavalss.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8607] = {n:"Cajado Pregado",t:4,d:"É um grande cajado com pregos. Não espere por nada além de um simples cajado, ele arranca os dentes de seus inimigos.",ep:22,g:72,l:107,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,50,false,true],c:"CA>150&CI>150",p:29856};
I.u[8608] = {n:"Cajado de Briga",t:4,d:"Rumores dizem que um Sadida chamado Fraye costumava usar este cajado para proteger sua esposa e filho de um punhado de Gobballs irados. Que pena que ele também confundiu sua família com os monstros durante a luta.",ep:22,g:73,l:85,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,35,40,false,true],c:"CW>150&CV>200",p:20000};
I.u[8609] = {n:"Bushi\'Arco",t:2,d:"Este arco é leve, delicado, elegante e tem cheiro de flores de cerejeira. Mas se você abusar, pode também ser letal.",ep:22,g:56,l:81,wd:true,fm:true,w:15,an:10,tw:true,e:[5,4,3,7,30,50,false,true],c:"CA>200",p:16900};
I.u[8610] = {n:"Arco Liwood",t:2,d:"Se você mantiver este arco para cima e dizer alegremente \"Pampulilu!\", parecerá absolutamente ridículo.",ep:22,g:57,l:79,wd:true,fm:true,w:10,an:10,tw:true,e:[7,5,4,7,30,50,false,true],c:"CI>150&CC>150",p:15320};
I.u[8611] = {n:"Varinha Mágica o que?",t:3,d:"Esta varinha mágica pertence a um famoso Grinegay que faz um excelente café, mas não consegue umas garotas",ep:22,g:61,l:72,wd:true,fm:true,w:15,an:11,e:[5,3,2,4,15,50,false,true],c:"CI>100&CC>100",p:16500};
I.u[8612] = {n:"O Bidjiz",t:3,d:"Com o Bidjiz, você permanecerá vivo provavelmente devido aos seus oponentes começarem a dançar quando eles verem a bola de disco no final desta varinha.",ep:22,g:62,l:79,wd:true,fm:true,w:10,an:11,tw:true,e:[10,4,2,5,40,50,false,true],c:"CA>150",p:18000};
I.u[8613] = {n:"Pá do Convento",t:8,d:"Criado como uma obra-prima de um ferreiro mágico, estas pás são muito ruins para escavar, exceto quando é a cabeça de seus inimigos.",ep:22,g:46,l:70,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,30,50,false,false],c:"CC>100",p:13540};
I.u[8614] = {n:"Pá Tumba",t:8,d:"Esta pá é uma ótima invenção. Pode escavar um túmulo e ser deixado no topo como uma cruz, desde que só um aventureiro morre por vez.. Ou se você cavar para outros túmulos com suas mãos.",ep:22,g:47,l:66,wd:true,fm:true,w:1,an:16,tw:true,e:[5,4,1,1,20,30,false,false],c:"CI>100&CC>50",p:1};
I.u[8615] = {n:"Martelo Vermelho",t:7,d:"Este martelo esmaga facilmente crânios para alcançar o cérebro e agora está manchando com uma cor tomate vermelho.",ep:22,g:61,l:83,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100&CV>100",p:17560};
I.u[8616] = {n:"Martelo Zery",t:7,d:"Este martelo foi criado quando o Rei Stefan costumava reinar e aterrorizar milhões de pessoas.",ep:22,g:62,l:178,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,40,50,false,true],c:"CI>350&CW>180",p:10000};
I.u[8617] = {n:"Machado Purrin",t:19,d:"Seu animal de estimação, nossa paixão.",ep:22,g:45,l:62,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,20,30,false,false],c:"CV>150",p:10200};
I.u[8618] = {n:"Machado Eerie",t:19,d:"Este estranha machado é criado para decapitar facilmente Bworks. A tranqüilidade com que também pode decapitar habitantes de Astrub indica que há uma ligação entre estes dois povos. Mas ninguém descobriu o que é ainda.",ep:22,g:46,l:80,wd:true,fm:true,w:10,an:17,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>120&CA>60",p:16700};
I.u[8619] = {n:"Chapéu Ariutokinabot",t:16,d:"Graças a este chapéu de guerreiro, os Iops realmente são figuras simpáticas. O único problema é que ele esconde o campo de visão de evita de ouvir as palavras de seus inimigos. Este chapéu é desenvolvido para quem gosta de bater antes de pensar.",ep:22,g:175,l:40,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8620] = {n:"",t:28,d:"",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8621] = {n:"Cenouwawa Amaldiçoado",t:94,d:"Este apetitoso cenouwawa poderia ser normal, mas parece terrivelmente diabólico. Você resistirá à tentação de devorá-lo?",ep:8,g:6,l:21,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[8624] = {n:"Balão Azul Mágico",t:94,d:"Diferente das falsificações que você encontrará na Feira de Trool, este balão pode voar para longe com graça e facilidade. Foi um trabalho manual feito a partir de uma larva azul estripada, mas que foi possível inflá-la por um Trool, de acordo com a receita tradicional do grato mago Betsy Krokerr.",ep:1,g:7,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8625] = {n:"Balão Mágico Verde",t:94,d:"Este balão verde é uma iguaria feita de alimentação forçada de cogumelo Luidegit e larva verde. Os olhos de larva saltam para fora e são vendidos como aperitivos para Bworks. Esse balão inspirou Betsy Krokerr em algumas de suas receitas.",ep:1,g:8,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8626] = {n:"Hizilnit Cirsid",t:94,d:"Tis ippitiziknik hizilnik sims ti bik kitik nirmik bik is inik ficik ixtrimilik ivik. Wilik yik risiksitik tik timptitinik ti nibblik itik ik?",ep:6,g:9,l:21,wd:false,fm:true,w:1,u:true,ut:true,p:100};
I.u[8627] = {n:"Flauta de Sarr Ys",t:3,d:"Colega e amigo do famoso Guy-Guy (parente próximo do Carvalho Mole), Sarr Ys é um menestrel cujas melodias encantadoras estão gravadas na memória de Amakna. Infelizmente, este brilhante artista teve um trágico acidente com Quaquak após uma farra numa noite de verão.",ep:1,g:63,l:1,wd:false,fm:true,w:10,an:11,e:[10,6,2,3,100,30,false,true],p:1};
I.u[8628] = {n:"Chapéu Ukando",t:16,d:"Este capacete dá auto-confiança e temeridade a quem usa. Graças a isso, você sempre manterá pensando que foi na verdade uma proeza. Lembre-se de tirá-lo de vez em quando para não entrar em situações inextricáveis!",ep:22,g:185,l:40,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8629] = {n:"Chapéu Tsokey",t:16,d:"Sempre que um oponente vem para encarar este capacete, ele vira quieto como um túmulo. Ninguém ousa perguntar o que acontece. Mas tudo bem, Srams não são tão sensíveis.",ep:22,g:179,l:40,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8630] = {n:"Chapeleiro de Lírio",t:16,d:"Este chapéu parece com o chapéu de Paperb e Sulik. Mas já que é muito confortável e os Xelors nunca tiram-no - mesmo para dormir, ele é comodamente chamado Chapeleiro de Lírio. Solta uma agradável água de lírio cujo cheiro ajuda a dormir. Entretanto, também provoca ronco e insuportáveis canções de sapinho durante a época do cio.",ep:22,g:177,l:40,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8631] = {n:"Chapéu Wisholdoo",t:16,d:"Graças a este chapéu, Eniripsas sempre sabem como lidar com emergências. Assim, todas as dicas de primeiros socorros são discretamente escritas no forro. Ninguém normalmente usa um chapéu ridículo assim mesmo em uma cerimônia escolar!",ep:22,g:184,l:40,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8632] = {n:"Chapéu Ricott",t:16,d:"Dado o nome deste chapéu, nós poderíamos pensar que ele tem uma bela cor alaranjada. Bem, de modo algum! Além disso, este acessório da moda é mais uma máscara do que um chapéu. Então qual o motivo de os criadores chamarem desta forma? Para deixar o povo comentar!",ep:22,g:178,l:40,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8633] = {n:"Capa Raiante",t:16,d:"As pontas afiadas saem deste gorro não só permitem machucar seu inimigo, mas também aumenta suas chances de ser golpeado na cabeça por um raio durante uma tempestade, Sacriers é a raça que adora machucar os outros tanto quanto eles mesmos. Um belho cheiro de carne grelhada: nada melhor para começar seu dia!",ep:22,g:180,l:40,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8634] = {n:"Gorro Fresco",t:16,d:"Graças a este chapéu, você se parecerá com uma besta excitada. Pessoas se aproximarão para admira o grande par em sua cabeça. Este amplo item também pode manter a comida fresca como feno para Gobballs ou pão para Tofus.",ep:22,g:181,l:40,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8635] = {n:"Capacete Hicc",t:16,d:"Este capacete pode fazer o usuário fazer promessas que instantaneamente esquece. É devido à pressão que ele exerce em parte de seu cérebro como a memória ou fala? Ninguém sabe de verdade. O que importa é levar em conta as palavras menos extravagantes.",ep:22,g:176,l:40,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8636] = {n:"Capa Robbie Hoodie",t:16,d:"Robbie Hood era um famoso Craque viveu nas florestas. Isto explica a cor verde de seu gorro para se camuflar no cenário. Ele queria levar a lei por toda a parte roubando dinheiro dos ricos por uma boa causa: ele mesmo!",ep:22,g:186,l:40,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8637] = {n:"Capuz da Sorte",t:16,d:"Com este capuz, o Feca aumenta suas chances assim como a de seus aliados. Se seu grupo é guiado por um Feca usando um Capuz da Sorte, você estará realmente seguro para chegar a um lugar quase sem nenhum arranhão. E cheira tão ruim é perfeita para se proteger também.",ep:22,g:182,l:40,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8638] = {n:"Stcapuz",t:16,d:"Este capuz pode ser usado para se proteger do mau tempo assim como cozinhar bons pratos. O meio que este chapéu se move o bastante para trazer ar e manter o fogo cozinhando a altas temperaturas. E todos sabem, uma sopa é um prato que precisa ser cozinhado por um longo tempo ... agora sabemos o motivo dos Enutrofs terem pulso forte.",ep:22,g:183,l:40,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8639] = {n:"Manto Orporal",t:17,d:"A capa flutuante é essencial para dar uma aura de guerreiro, especialmente se virar as costas para um inimigo. Alguns pensam que é reforçada por uma lâmina de metal capaz de afastar ataques astutos.",ep:22,g:131,l:80,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8640] = {n:"Cash\'n Cape",t:17,d:"Cortada de um tecido liso e forte, esta capa dá aos Ecaflips a impressão de que são sempre os melhores, não importa o que acontece. Quando eles vencem, adoram usar esta peça de roupa e reivindicar a recompensa: \"E agora, dê-me o dinheiro!\"",ep:22,g:133,l:80,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8641] = {n:"F-Chap(é)u",t:17,d:"Esta capa é tão leve e fina que um pequeno vento (de todos os tipos de vendo) pode levá-la... Não é nada, porém tenha cuidado após uma refeição de vegetais e bebidas fermentadas.",ep:22,g:140,l:80,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8642] = {n:"Cap Capa",t:17,d:"A cor escura desta capa torna fácil separar de outras roupas, ou qualquer outra cor. Já que é uma capa muito ampla, também pode proteger sua cabeça e seu nariz.",ep:22,g:141,l:80,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8643] = {n:"Capa Sulitis",t:17,d:"A Capa Sulitis deve ser delicadamente colocada nos ombros do usuário para evitar ter tendinites e endurecimento das juntas. As propriedades curativas desta peça de roupa são invejadas pelos Pandawas quem passam muito tempo carregando inimigos e aliados. Eles adorariam uma peça de roupa também!",ep:22,g:134,l:80,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8644] = {n:"Capa Otbellied",t:17,d:"Este item é usado para esconder o problema de peso dos Sadidas. Devido a eles passagem muito do tempo dormindo ao invés de praticar esportes, os personagens desta raça tendem a se tornar gordos. Se as Sadidettes tivessem um suprimento anti-fome perante os olhos dos homens, os Sadidas usariam esta capa para esconder.",ep:22,g:139,l:80,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8645] = {n:"Capa Ytal",t:17,d:"Esta peça de roupa é parte essencial do estilo Sacrier. Eles usam como bandagem para as feridas, para limpar o sangue, para aquecer os pés durante as épocas frias. Não podemos dizer o suficiente - esta raça tem medo de terras geladas!",ep:22,g:138,l:80,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8646] = {n:"Capa Anama",t:17,d:"Esta capa suave é algumas vezes usada por Osamodettes como um chapéu de abas largas. Osamodas masculinos usam-na como uma capa. Graças ao desenho que decora esta peça de roupa, nesta raça de personagem foi herdada a reputação de franqueza. Assim, eles não podem rir de suas mangas, já que a graça é costurar esta capa!",ep:22,g:137,l:80,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8647] = {n:"Capa Wuera",t:17,d:"Pandawas usam esta capa como proteção ao mau tempo e acessório de dança. Eles colocam no chão, no meio do círculo das dançarinas. Então, começam uma coreografia improvisada enquanto seus pés não tocam o chão já que a área é limitada por uma peça de roupa.",ep:22,g:142,l:80,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8648] = {n:"Capa Hulco",t:17,d:"Esta capa leva o nome do Cra original que tinha um senso particular de direção. Ele podia se perder dentro de sua própria casa, mesmo que não fosse grande! Seu maior problema foi que ele tinha uma deformação nas funções cerebrais. Assim, para todos os lugares que ele olhava pareciam iguais: uma praia vasta, ao redor de palmeiras, banhado pela luz do sol.",ep:22,g:132,l:80,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8649] = {n:"Capa Adossia",t:17,d:"As cores quentes e confortáveis desta capa levam o usuário a uma viagem imaginária, em países brilhantes, cheio de canyons criados pela erosão e áreas rochosas. É extremamente útil para esquecer dos dias frios, cinzentos e chuvosos.",ep:22,g:136,l:80,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8650] = {n:"Capa Hernaum",t:17,d:"Enutrofs têm o hábito de desenhar um mapa em sua capa. Eles vivem em uma bagunça que dificilmente podem encontrar banheiros e isto é um problema, especialmente quando deve responder a um chamado urgente da natureza.",ep:22,g:135,l:80,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8651] = {n:"Cinto Sangrento",t:10,d:"Este belo cinto adiciona o prestígio da aparência dos Iops. Alguns dizem que a cruz no centro pode se tornar uma arma separável quando suas espadas não estão dentro de alcance. Obviamente é uma lenda. Só Srams são enganadores o bastante para estas práticas.",ep:22,g:116,l:130,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8652] = {n:"Cinto Sterous",t:10,d:"Quando um Ecaflip está entediado, ele normalmente leva suas cartas no cinto e começa a jogar solitária. Na luta, ele também pode usar as cartas como projéteis. Ele tira uma carta tão rápido quanto uma sombra, e sempre tem tempo para um joguinho!",ep:22,g:117,l:130,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8653] = {n:"Cinto Clinkin",t:10,d:"O nome deste cinto vem do barulho que ele faz. Os ossos decorativos deste cinto, evitam os Srams, mesmo que invisíveis, de serem notados. Então, você pode facilmente ouvir um diálogo: \"Surpreendente alguém usar o Cinto Clinkin? Você tem esperança!\"",ep:22,g:118,l:130,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8654] = {n:"Cinto Insônia",t:10,d:"O som incessante deste tique-taque do sistema de relógio deste cinto evita que os Xelors duram quando as lutas são eternas. É altamente recomendável que você tire este cinto antes de ir dormir.",ep:22,g:119,l:130,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8655] = {n:"Cinto Blub",t:10,d:"Embora acostumado a choradeira, este cinto permite a você carregar materiais médicos. As várias poções úteis para curar dor de garganta e infecções gerais são cuidadosamente dispostas. Assim, quando Eniripsas têm dor de garganta, eles não podem conjurar devidamente seus feitiços. E quando estão sem voz ... bem, são tão úteis quanto uma jaqueta de lã durante o calor.",ep:22,g:120,l:130,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8656] = {n:"Cinto Atio",t:10,d:"As razões que levaram os designers deste acessório fashion a colocar uma cabeça de boneca perto da virilha são desconhecidas.\nMuitas teorias \'tem sido propostas, mas todos sabem que é uma história já de conhecimento geral!",ep:22,g:121,l:130,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8657] = {n:"Strap Pado",t:10,d:"Guerreiros de uma tribo antiga famosa pela paixão pelo sangue, os Pados não poderiam ser os primeiros fiéis da deusa Sacrier. Embaixo desta aparência inofensiva, este cinto é um instrumento sofisticado real de tortura.",ep:22,g:122,l:130,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8658] = {n:"Cinto Diezzle",t:10,d:"Osamodas são conhecidos por serem impulsivos. Eles tendem a serem mais sensíveis. As numerosas fivelas deste cinto são o significado de ajudar, então diminua sua espontaneidade. \"Antes de liberar sua fúria e seus olhos expelirem sangue, toque todos os espinhos deste fantástico Cinto Diezzle!\"",ep:22,g:123,l:130,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8659] = {n:"Faixa Fedida",t:10,d:"Este cinto ajuda Pandawas a ficar de pé (ou quase) quando estão eufóricos, na maior parte do tempo. Nestes momentos, eles tendem a se sentir como presos ao chão embora a gravidade não tenha qualquer ligação com isso. A gravidade é uma forma de manter ocupados os cientistas fazendo experiências com maçãs.",ep:22,g:124,l:130,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8660] = {n:"Cinto Targ",t:10,d:"Este cinto permite a você segurar roupas largas (não se assuste com a sensibilidade das almas) e também oferece um alvo para aprendizes de Cras. Assim, eles aprenderáo a atirar direto no centro, mas nunca abaixo do cinto.",ep:22,g:125,l:130,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8661] = {n:"Cinto Espartilho",t:10,d:"Cuidadosos, Fecas mantêm seus suprimentos de sobrevivência em uma pequena sacola, que principalmente inclui pão de Crackrock. É por isso que esta comida pode durar muito tempo. O Cinto Sekuritee garante uma sacola em volta da cintura, devido a isto há muitos acidentes com a queda da sacola, por negligência ou apenas estupidez.",ep:22,g:126,l:130,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8662] = {n:"Cinto Urgid",t:10,d:"Este cinto é um acessório da moda muito útil usado por Enutrofs. Graças ao mapa costurado nele, eles podem esconder seus soluços quando estão perdidos e procurando um banheiro.",ep:22,g:127,l:130,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8663] = {n:"Bota-a-Aro",t:11,d:"Com essas botas, Iops são sempre os primeiros a chegar ao campo de batalha e a começar a vida em um lugar. É de um conhecimento comum que esses personagens dessa raça adoram divertir a multidão com as façanhas de guerreiros. Mas eles nunca levam a sério, pois sua negligência é inversamente proporcional à sua força.",ep:22,g:100,l:100,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8664] = {n:"Sonecabelo",t:11,d:"Dizem que os Sadidas nunca se sentem solitários, já que eles invocam muitas bonecas como companhia. Graças a estes sapatos, você também pode dizer adeus a este sentimento de solidão! Você será capaz de falar com elas, exceto se relatarem seu jogo. Após colocá-los, você se sentirá muito bem, mesmo se estiver envergonhado.",ep:22,g:105,l:100,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8665] = {n:"Botas Hox",t:11,d:"Impregnada com um produto firmador, estas botas serão perfeitas para suas pernas tortas e lutas contra a natureza morta da complexão Sram. Este creme tem efeitos especiais nas Sramettes, mas parece ser absolutamente inútil em Srams. Poderia ser um problema hormonal?",ep:22,g:102,l:100,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8666] = {n:"Botas Ero",t:11,d:"Criada por um artista Xelor, estas botas devem permitir pintar mais depressa. E bem, elas conseguem! Entretanto, tendem a distorcer a visão e especialmente o senso de distância. Com estas botas, tudo parece estar mais perto. Aprecidaas pelos Sadidas, as pinturas deste Xelor são feitas de curvas generosas da mulher popular mais gorda.",ep:22,g:103,l:100,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8667] = {n:"Botas Ulism",t:11,d:"Graças a estas botas, você sempre estará protegido de toxinas vindas do chão. Nós nunca suspeitamos de micróbios e outros germes. Alguns bons observadores dizem que estas botas parecem mais um dorminhoco do que botas. Mas bem, é o que os Eniripsas dizem. É devido ao seu pequeno tamanho que elas vêem tudo de um diferente ponto de vista?",ep:22,g:104,l:100,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8668] = {n:"Botas Hanik",t:11,d:"O amor pelas plantas faz os Sadidas usar os únicos sapatos equipados com reconhecimento floral. Graças a este sistema, os usuários evitam esmagar plantas raras. Entretanto, não evita de pisas em vários tipos de excrementos se não olhar por onde anda.",ep:22,g:101,l:100,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8669] = {n:"Correias Pregadas",t:11,d:"Diferente das outras raças, Sacries adoram viver com um espinho no pé e não gostam de retirar. A dor que sentem lembra que estão vivos e dá energia para caçar os inimigos. Além disso, o sangue deixado para trás permite que eles sempre encontrem o caminho de casa.",ep:22,g:106,l:100,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8670] = {n:"Botas Wana",t:11,d:"Com estes sapatos, Osamodas podem marchar por amplos continentes, incluindo os mais remotos. Além disso, nós não sabemos qual o uso principal. Alguns dizem que pode ser usada para fazer ninhos de Tofu ou belos vasos para tirar vantagem das flores selvagens. Mas não é bem convincente. De qualquer forma, Botas Wana são os sapatos principais.",ep:22,g:107,l:100,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8671] = {n:"Grande Relíquia de Coralator",t:24,d:"Essa relíquia impressionante poderá fazer que você esqueça todas as suas preocupações.",ep:22,g:152,l:1,wd:true,fm:true,w:0,p:1};
I.u[8672] = {n:"Relíquia Goulo o Terrível",t:24,d:"Esta relíquia impressionante poderá fazer que você se esqueça de todas as suas preocupações.",ep:22,g:153,l:31,wd:true,fm:true,w:0,p:1};
I.u[8673] = {n:"Relíquia Grande Bherb",t:24,d:"Esta relíquia impressionante poderá fazer que você se esqueça de todas as suas preocupações.",ep:22,g:154,l:61,wd:true,fm:true,w:0,p:1};
I.u[8674] = {n:"Relíquia Tynril",t:24,d:"Esta relíquia impressionante poderá fazer que você se esqueça de todas as suas preocupações.",ep:22,g:155,l:101,wd:true,fm:true,w:0,p:1};
I.u[8675] = {n:"Relíquia Kimbo",t:24,d:"Esta relíquia impressionante poderá fazer que você se esqueça de todas as suas preocupações.",ep:22,g:156,l:141,wd:true,fm:true,w:0,p:1};
I.u[8676] = {n:"Espada Malvada",t:6,d:"Vlad se apaixonou por esta maravilhosa espada. Ele participou da mais aterrorizante corrida Dragokart para conseguir dinheiro suficiente para comprá-la. Infelizmente, ele não sabia que esta espada era amaldiçoada...",ep:1,g:75,l:95,wd:true,fm:true,w:1,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8677] = {n:"Ross",t:18,d:"Este coelhinho é o bicho de estimação favorito do famoso Mestre Nero Jack. Não se deixe levar pelas aparências, ele pode ser terrível em luta. Ele só come Cenouwawa e plantas.",ep:3,g:44,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8678] = {n:"Chapéu de Satanass",t:16,d:"Há muito tempo, Satanass era um patinador artístico deslizando em Holyball on Ice nos rinques da segunda divisão. Enquanto se recuperava de um ferimento no coccyx, teve uma revelação que mudou a sua vida: estava predestinado a ser o mais talentoso piloto de Dragokart desta geração! Eventualmente uma pequena batida pode causar sérios estragos.",ep:1,g:187,l:36,wd:true,fm:true,w:20,p:3550};
I.u[8679] = {n:"Fantasma de Ross",t:90,d:"Este fantasma ainda não deixou o mundo dos vivos. Você pode encontrar um jeito de ressuscitá-lo ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:46,l:1,wd:true,fm:true,w:1,p:1};
I.u[8680] = {n:"Escama Viscosa",t:59,d:"Esta viscosa e escorregadia escama permitiu que seu dono não fosse pego facilmente por aventureiros que decidiram ir pescar com os dentes. Infelizmente para ele, a escama nunca o protegeu contra o golpe de uma espada enferrujada.",ep:1,g:626,l:10,wd:true,fm:true,w:1,p:1};
I.u[8681] = {n:"Pele de Raul Mops",t:59,d:"Raul Mops tem uma fraqueza. Ele ama untar-se com água, vinho ou mesmo vinagre. Mas gosta mesmo é de rolar em jarras de vidro com cebola em volta. Mais uma criatura com costumes estranhos e misteriosos.",ep:1,g:627,l:40,wd:true,fm:true,w:1,p:1};
I.u[8682] = {n:"Pele de Mob Esponja",t:59,d:"Esta pele pode ser usada de ambos os lados. O lado macio é usado para limpar superfícies sensíveis, e a parte áspera, para limpar suas partes anatômicas que eram inacessíveis até agora.",ep:1,g:628,l:10,wd:true,fm:true,w:1,p:1};
I.u[8683] = {n:"Presente: Pingüim-San",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8684] = {n:"Certificado do Canil: Ross",t:77,d:"Este certificado descreve as características do Ross que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8685] = {n:"Certificado do Canil: Bilby",t:77,d:"Este certificado menciona as características do Bilby que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8686] = {n:"Presente: Ross",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8687] = {n:"Presente: Bilby",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bichinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8688] = {n:"Transformação Fantasma de Ross",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Marca de Vitória",t:24,d:"Você derrotou facilmente o discípulo. Este pergaminho é o testemunho disso.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Formulação da Poção de Transformação",t:24,d:"Este livro contém as teorias elaboradas por vários alquimistas sobre a possibilidade de se transformar em um Wabbit. Isto só prova quanto trabalho eles têm para fazer.",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Fëanor",t:18,d:"Graças a este animal de estimação, todos do sexo oposto farão olhos de cachorrinho para você. Um conselho: não conte com os ovos antes da galinha! Você logo perceberá que sua amada está apenas hipnotizada pelo Fëanor. Nem pense que isto será uma vantagem: de agora em diante, sua pretendente comerá Dink cru e se esfregará em suas pernas... Você provavelmente viveu situações mais fascinantes, não é? Este animal de estimação só come peixe.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Pimenta Confeitada",t:42,d:"Esta pimenta confeitada é coberta por um doce vermelho superpoderoso. Esta explosiva mistura de açúcar e pimenta permitiu a um Dragossauro especial ganhar uma das mais famosas corridas de Dragokart. Você pode usar isto como um supositório se precisar ter fogo no traseiro ou como uma pílula se você estiver procurando por um hálito fedorento.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"Espada Hikk",t:6,d:"Como Brice disse: \"Tamanho não importa, só a forma que você lida com ele\".",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
I.u[8696] = {n:"",t:23,d:"",ep:0,g:14,l:1,wd:false,fm:true,w:1,p:1};
I.u[8697] = {n:"",t:23,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[8698] = {n:"",t:23,d:"",ep:0,g:16,l:1,wd:false,fm:true,w:1,p:1};
I.u[8699] = {n:"Chapéu de Tynril",t:16,d:"Com esse chapéu, você sempre terá uma aparência como se tivesse levantado da cama naquele instante, mesmo se passar horas penteado seu cabelo. Alguém notou que o cabelo tipo casca do Tynril enrola quando o tempo está úmido, isso demonstra como está a previsão do tempo no mundo. Entretanto, ele teme o fogo. Então, tenha muito cuidado e mantenha-o longe das chamas se não quiser se tornar uma verdadeira tocha humana.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Concha Esmeralda",t:16,d:"Este elmo parece ter sido feito de um Dofus Esmeralda quebrado. O Dofus ainda não está muito vazio e lhe dá a oportunidade de dar ao seu cabelo um ótimo xampu de ovo.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Espada Conhecida",t:6,d:"Esta suntuosa espada costumava pertencer a um famoso ladrão, conhecido por realizar crimes a todo o momento.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8702] = {n:"",t:4,d:"",ep:0,g:74,l:1,wd:false,fm:true,w:1,an:12,tw:true,e:[0,0,1,1,0,0,false,false],p:1};
I.u[8703] = {n:"",t:5,d:"",ep:0,g:63,l:1,wd:false,fm:true,w:1,an:13,e:[1,0,1,1,1,1,false,false],p:1};
I.u[8704] = {n:"Jester Chapéu",t:16,d:"Se você chacoalhar estes dois pequenos sinos, pdoerá ser capaz de jogar uma música.",ep:22,g:190,l:160,wd:true,fm:true,w:10,p:47625};
I.u[8706] = {n:"Fantasma Fëanor",t:90,d:"Este fantasma ainda não deixou o mundo dos vivos. Você pode encontrar um jeito de ressuscitá-lo ou covardemente abandoná-lo de uma vez por todas.",ep:3,g:48,l:1,wd:true,fm:true,w:1,p:1};
I.u[8707] = {n:"Certificado do Canil: Fëanor",t:77,d:"Este certificado descreve as características do Fëanor que você pôs no Canil",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8708] = {n:"Certificado do Canil: Atooin",t:77,d:"Este certificado menciona as características da Atooin que você pôs no Canil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Transformação Fantasma Fëanor",t:27,d:"Você foi transformado em um fantasma para poder entrar no Santuário dos Animais de Estimação.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Presente Fëanor",t:89,d:"Se você balançar esse presente e colocar o ouvido perto, irá ouvir uns barulhos bem estranhos... Como um pequeno animal chorando... É, você não deveria ficar balançando... Ahh, abra logo essa coisa! Dentro dela você vai encontrar um maravilhoso animal de estimação, e também alguns recursos que servirão para cuidar do seu novo bixinho de estimação! Alguma comida e Pó de Eniripsa para eventualmente curar seu amiguinho.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Pedaço de Goldemort",t:110,d:"Parabéns! Você conseguiu roubar um pedaço de corpo de Goldemort. Você deixaria um limpador orgulhoso!",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Getas Bernacles",t:11,d:"Em alguns países, parece que as Getas Bernacle são jogadas nos inimigos para insultar e provocar duelos. Mesmo que isto possa parecer familiar, não é diferente de bater em seu oponente com um par de luvas. A vantagem das Getas Bernacles é a invenção olfativa. Pandawas nunca foram famosos pela higiene dos pés...",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Anel de Honra",t:9,d:"Usar este anel é uma honra. Significa que você tem fé na deusa Cra, a única que sempre revelou como caçar com velocidade e eficiência.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Anel Blaber",t:9,d:"A tagarelice dos Ecaflips é bem conhecida. Eles podem falar com quase tudo para fazê-lo jogar. Este anel celebra esta tagarelice incansável. Também pode ser usado como dados de reserva!",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Anel Leão",t:9,d:"Osamodettes adoram este anel que dá um toque felino xtra ao seu caminhar. Assim, sempre que elas estão perto dos monstros, eles começam a se comportar como animais. Mas na verdade, são tão devotos quanto uma mãe leoa.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Anel Bellious",t:9,d:"Fofoqueiros malévolos reivindicam este anel que é um acessório muito útil no mundo. As asas anexadas pode ser uma dor quando você precisa tirar um tecido do bolso. Agora, Iops não tem tecidos e nem bolsos ... então, é ideal. Exceto que atualmente espancam o inimigo a cada vez que passam por perto.",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Memo Anel",t:9,d:"Fecas usam os mini escudos que estão neste anel como memorandos para escrever cartas de amor ou simplesmente lista de deveres. Esta jóia foi apelidada de escudo anti-esquecimento. Entretanto, não protege você de gaguejar ou sesear.",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Anel Lemb",t:9,d:"Graças a este item, Enutrofs podem se lembrar dos bons tempos quando quiserem. Eles só precisam extrair a pá de dentro. Para fazer a lembrança mais genuína, você precisa adicionar um cheiro específico.... Boa sorte!",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Anel Chee",t:9,d:"A deusa Eniripsa deu este item para seus fiéis como sinal da união espiritual durante a sessão de iniciação de feitiço de raça. Incidentalmente Eniripsas também pode usá-lo como um bracelete esponja para limpar o langu de seus aliados.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Anel Orelha",t:9,d:"Esta jóia tende a tornar Pandawas em serem zombadores, especialmente após o terceiro energético. Eles podem até mesmo ir tão rápido quanto os insultos dos outros. Mas não importa realmente... como diz o provérbio Pandawa \"Eufórico não ouve o demônio\".",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Anel Elkebi",t:9,d:"Esta jóia com uma caveira era tradicionalmente oferecida para todas as crianças Sram para recompensar as traições e golpes abaixo da cintura. As outras raças parecem duvidas desta prática que tende a excitar demais as crianças e transformá-las em verdadeiros diabinhos.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Anel Subma",t:9,d:"Este anel é só uma jóia que pode dar tempo e é perfeitamente à prova d\'água. Alguns acreditam que se você alargar e modificar os planos deste item, pode transformá-lo em um veículo capaz de se mover embaixo d\'água. De onde eles tiram estas idéias?",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Anel Relva",t:9,d:"Contrário ao rumor, os Sadias não deixam o cabelo cair... Este cabelo foi ajustado em torno deste maravilhoso anel para reforçar seus benefícios. Nunca corte! Graças ao Anel Relva, você será perfeito!",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"Anel Neinwonwon",t:9,d:"Se você vê um personagem que não é um Sacrier usando o Anel Ninewonwon, leve-o diretamente para um tratamento intensivo. Assim, esta jóia é extremamente nociva. Em geral, as pessoas perdem a paz de espírito quando encaram a piscina de sangue causada por este anel.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Sapatos Perda",t:11,d:"Estes sapatos permitem ao usuário dançar a noite toda, apesar de bolhas e pedras nos sapatos! Os sapatos dançam o ritmo da noite e faz o pequeno som de  \"beep beep\" quando estão próximos de minérios preciosos. Por isso os Enutrofs são chamados de \"Máquinas Musicais\".",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Botas de Alívio",t:11,d:"Quando Fecas estão envergonhados e desejam mudar de assunto, eles sempre mencionam as Botas de Ajuda. Eles falam sobre o caminho que pode marcar e todo tipo de terreno ideal para elas. Quando seus aliados estão com problemas no campo de batalha, estas confortáveis botas permitem evitar a ameaça.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Botas Veggie",t:11,d:"As várias faixas em torno destes sapatos podem ser usadas como cordas caso arrebentem as de seu arco. Jovens Craettes também usam para cozinhar vegetais.  Cheiro dos pés não parece incomodá-las.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Coral Usado",t:51,d:"O Coral só se solta do Coralator quando o clima está seco. Coral é realmente uma boa coisa e alguns mesmo fazem jóias. Alguns olhos, descuidados, comem... mas eles são raros e quando são comidos é por que foram confundidos com espetinhos de caranguejo.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Cóccix  de Coralator",t:47,d:"Estando em um local estratégico, este osso permite a Coralot sentar com dignidade. Agora que ele está morto, você pode ainda usá-lo para estabelecer sua autoridade sobre suas amigas criaturas.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Grande Coral",t:51,d:"A única diferença entre o Coral Usado e o Grande Coral é o tamanho e o que você pode fazer com eles. Entretanto, em geral um Coral Usado nunca pode ser substituido por um Grande Coral.",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Coral Kurasso",t:51,d:"A cor excelente deste coral vem de uma dieta não saudável de Craboral. Outro que um dia esqueceu de comer todas as 5 frutas e vegetais!",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Coral Malibu",t:51,d:"A cor excelente deste coral vem de uma dieta não saudável de Craboral. Outro que um dia esqueceu de comer todas as 5 frutas e vegetais!",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Coral Passaoh",t:51,d:"A cor excelente deste coral vem de uma dieta não saudável de Craboral. Outro que um dia esqueceu de comer todas as 5 frutas e vegetais!",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Coral Mojinho",t:51,d:"A cor excelente deste coral vem de uma dieta não saudável de Craboral. Outro que um dia esqueceu de comer todas as 5 frutas e vegetais!",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Coração de Pedra Polida",t:51,d:"The only thing that can differentiate a Crackler\'s heart from that of a polished Crackler is the delicacy with which the item can break between your toes when you least expect it.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Bola Polida",t:51,d:"De qual parte da anatomia de Crackrock veio esta bola? E por quê elas vêm em pares?",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Grande Sacrum",t:47,d:"O Coralator oferece a você um osso de suas costas. O Grande Coralator permite possuir uma outra parte de sua anatomia, mas na mesma área.",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Úmero de Sparo",t:47,d:"Embora este osso é chamado de úmero, nós não temos prova que ele veio do braço de Sparo. Desde que todo o esqueleto foi esmagado por espadas rolando de um barril, ele continua um pouco esfarelado.",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Pedaço de Tronco de Flib",t:47,d:"Se eu fosse você, não pegaria esta coisa que veio de uma boca de higiene duvidável. Mas bem, você é o aventureiro, conhece os riscos!",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Bico de Kido",t:47,d:"Este bico é tão frágil que os discípulos de Otomai usavam-no para fazer flechas de treinamento para não machucar ninguém.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Pinça Craboral",t:47,d:"Apenas evitar chacoalhar a pinça de Craboral! Você pode perder sua mão para este ser delicado.",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Pétala de Kurasso",t:35,d:"A cor desta pétala sugere uma origem duvidosa. O abuso de energético pode até mesmo ser notado nas criações dos discípulos de Otomai.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Pétala de Malibu",t:35,d:"A cor desta pétala sugere uma origem duvidosa. O abuso de energético pode até mesmo ser notado nas criações dos discípulos de Otomai.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8747] = {n:"Pétala de Passaoh",t:35,d:"A cor desta pétala sugere uma origem duvidosa. O abuso de energético pode até mesmo ser notado nas criações dos discípulos de Otomai.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Pétala de Mojinho",t:35,d:"A cor desta pétala sugere uma origem duvidosa. O abuso de energético pode até mesmo ser notado nas criações dos discípulos de Otomai.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Bulbo de Kurasso",t:36,d:"A Palmflor não cresce de uma semente, mas de um bulbo ensopado em energético. Por quê? Porque sim!",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Bulbo de Malibu",t:36,d:"A Palmflor não cresce de uma semente, mas de um bulbo ensopado em energético. Por quê? Porque sim!",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Bulbo de Passaoh",t:36,d:"A Palmflor não cresce de uma semente, mas de um bulbo ensopado em energético. Por quê? Porque sim!",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Bulbo de Mojinho",t:36,d:"A Palmflor não cresce de uma semente, mas de um bulbo ensopado em energético. Por quê? Porque sim!",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Juba Florescendo",t:36,d:"Esta juba é um resultado improvável da hibridização entre cabelos e pétalas de flores, que o torna um alergênico duvidoso. Então, fique longe se você é sensível já que um só espirro pode ejetar seu cérebro.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Barba Ridícula de Barbrossa",t:54,d:"Este pequeno tufo de cabelos te lembrará dos feriados graças ao cheiro de areia, protetor solar e energético. Que pena feder tanto quanto pólvora!",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Tufo Vermelho de Flib",t:54,d:"Ninguém sabe se a cor deste tufo é natural ou devido a incêndio florestal.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Kilibriss Morto",t:54,d:"Kilibriss morto é leve e muito procurados para fazer colchão. Enquanto espera por novas espécies de colchões vivos que pode ser mortos nos safáris, os artesãos caçam ativamente Kilibrisses.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Camisa de Barbrossa",t:15,d:"Você precisa de um repelente de insetos? Apenas coloque a camisa de Barbrossa! Mas você deve saber que também pode ser um repelente humano, então talvez desista de relacionamentos humanos.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Bermudas Destruídas de Gourlo",t:15,d:"Ninguém jamais encontrou um par de bermudas de Gourlo intactas como ele sempre acaba botando fogo com a pólvora que brinca.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Caixinha Amaldiçoada de Flib",t:15,d:"Esta caixa em a forma de Glib... A menos que é o oposto! Seja como for, ainda é um pequeno baú amaldiçoado.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Manta Sparo",t:15,d:"Esta manta é um acessório essencial para verão e inverno. Ela dará a você uma aparência original, embora um pouco cafona. Sua cor vibrante certamente excitará Gobballs masculinos, mas é isso mesmo que você quer?",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Pólvora Explosiva de Gourlo",t:48,d:"Para compensar o canhão que não poderia ser transplantado como um braço, Gourlo nunca sai sem sua arma. Ele não pode atirar rapidamente já que deve secar a pólvora primeiro, sinal de qualidade baixa.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Fragmento de Cérebro Polido",t:50,d:"Graças a este fragmento, você aprenderá as boas baneiras Cracklers: mão fechada para dizer oi.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Mufafah Mustache",t:15,d:"Mais grosso que um peixe gato, o bigode de Mufafah pode ser usado como escova para por Marylork, o pintor.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Sobrancelha do Grande Bherb",t:15,d:"Para provar que ele é o chefe, o Grande Bherb sempre franzi suas sobrancelhas, mesmo após morto.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Cajado de Kilibriss",t:15,d:"Graças ao seu comprimento, este cajado permitirá a você alcançar os locais mais difíceis para acessar e arranhar-se como quiser.",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Pena do Traseiro de Kido",t:53,d:"Uma das maiores charadas de Otomai foi inspirada neste recurso: O que é pesado? Uma centena de pods de penas de Kido ou uma centena de pods de Pyrute?",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Asa de Pikoko das Planícies",t:104,d:"O Pikoko nunca foi famoso pelo seu desempenho em vôo. Uma vez que você vê suas asas, bem, entenderá o motivo.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Orealha Rasgada de Pumbaa",t:106,d:"Se você colocar esta orelha, poderá ouvir os passos do javali das planícies ao invés do sopro do mar.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Noz de Pikoko das Planícies",t:111,d:"Não há leite neste Pikoko Nut, mas você encontrará um pouco suco de cérebro com um neurônios flutuantes.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Casca de Tynril",t:96,d:"Esta casca é curiosamente curva. Parece que foi raspada.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Casca de Floramor",t:96,d:"Esta casca é curiosamente curva. Parece que foi raspada.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Casca de Rotaflor",t:96,d:"Esta casca é curiosamente curva. Parece que foi raspada.",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Casca de Gwass",t:96,d:"Esta casca é curiosamente curva. Parece que foi raspada.",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Casca de Barkritter",t:96,d:"Esta casca é curiosamente curva. Parece que foi raspada.",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Casca de Warguerite",t:96,d:"Esta casca é curiosamente curva. Parece que foi raspada.",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Noz de Pikoko das Sombras",t:111,d:"Não há leite neste Noz de Pikoko, mas você encontrará um pouco suco de cérebro com neurônios flutuantes.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Pistilo de Tynril",t:36,d:"Flores correspondem aos órgãos sexuais das plantas. O pistilo é uma parte da flor. Agora, você decide o que quer.",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Estame deFloramor",t:36,d:"O estame é o órgão masculino da planta. Sim! Apesar das aparências, parece que Floramor é masculino...",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Carpelo de Rotaflor",t:36,d:"Uma pequena lição de biologia: as flores são órgãos sexuais das plantas e o pistilo é a parte da flor enquanto o carpelo é  a parte do pistilo... Deixarei você decidir o que faz cada coisa.",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Sépala Gwass",t:36,d:"Esta parte do corpo de Gwass é sempre vende, não importa. Isso é devido ao excesso de clorofila ou o que?",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Cálice Barkritter",t:36,d:"Não se incomode tentando usar o Cálice Barkritter para beber nada. Pode parecer uma taça, mas é tão sólido quanto uma peneira.",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Bráctea Warguerite",t:36,d:"O Bráctea Guerraguerite refere-se a uma área cuja decência evita que eu me expresse.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Amígdala de Pikoko das Sombras",t:15,d:"O Pikoko das Sombras não é como nozes eram, ele conseguiu remover suas amígdalas. Bem, não é uma surpresa que a cirurgia o matou.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Calcanhar de Aquiles de Treeckler Negro",t:15,d:"Você não derrotará o Treeckler Negro atirando uma flecha em seu calcanhar de Aquiles. Mas você sempre pode tentar...",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Semente de Treeckler Negro",t:58,d:"Com bastante paciência, tempo, água e fertilizante, você conseguirá fazer crescer um Treeckler em seu jardim, assim pode praticar lutas contra ele. De qualquer forma, será mais fácil ir para a ilha de Otomai e matá-los.",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Trança do Frengo",t:15,d:"Este cabelo duro e grosso pode ser usado como um sfregão ou para esconder sua calvície. Mas você terá de lavá-lo muitas vezes antes de usar.",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Cloaca do Frengo",t:15,d:"Não, não é um disfarce! É a natureza!",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Costas de Pikoko do Ar",t:15,d:"Estas costas permitirão a você criar itens que deve cobrir sua retaguarda.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Meia de Kimbo",t:15,d:"Apesar das aparências, o Kimbo usa meias, mas não nos pés. Ele prefere enrolá-las e colocar em locais estratégicos.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Moopet Empalhado",t:15,d:"A natureza tem sido apenas modestamente generosa a Moopet, este tem utilizando o artifício de passar por uma coisa viva. Às vezes, costumava fazer sua cama se passar por uma cama também.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Tecido Moopet",t:55,d:"Este tecido tem uma textura estranha, mas será rapidamente vestido por qualquer monstro modesto.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Pikoko Nut do Ar",t:111,d:"Não há leite neste Pikoko Nut, mas você encontrará um pouco suco de cérebro com neurônios flutuantes.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Concha de Snailmet",t:111,d:"x",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Peruca de Kimbo",t:54,d:"Para esconder sua calvície prematura, Kimbo colocou esta estúpida peruca. Felizmente para ele, o coco cobriu a maior parte.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Nó de Treeckler Luz",t:38,d:"Devido a este recurso e um aventureiro sádico que pronunciou errado, o Teeckler é normalmente apelidado de \"Cabeça de Maçaneta\".",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Pedaço de Tronco de Treeckler Luz",t:38,d:"Um pedaço de tronco diferente de todos os outros, e ainda, ele gira.",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Rabo Emplumado do Grande Bherb",t:65,d:"Uma a uma, ano após ano, as penas de Bherb são conectadas ao rabo. Você pode dizer que a idade pela plumagem do rabo.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Pêlo das Axilas de Pumbaa",t:54,d:"Mesmo se ele normalmente corta seu pêlo, ele cresce de volta grosso e fedorento. Então o cheiro não é devido ao calor.",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Tecido Zoth",t:55,d:"Feito de um material leve e resistente, este tecido é perfeito apto para a imagem de Zoths e esconde o essencial.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Tecido Ouassingue",t:55,d:"Esta roupa tem mais buracos que uma fatia de queijo suíço e absorve sujeira mais rápido que um Gobball epiléptico. Quando a roupa vem, a ralé foge.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Tíbia do Guerreiro Zoth",t:47,d:"Como todos os outros ossos do Guerreiro Zoth, esta tíbia quebrou muitas vezes. Curou perfeitamente e se tornou mais forte. Se pudesse falar, diria: \"O que não mata, deixa-o mais forte\".",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Rótulo do Discípulo Zoth",t:47,d:"Já que o Discípulo Zoth sempre bate com o joelho, sua rótula  tornou-se extremamente resistente e grande. Em breve, poderemos fazer uma tigela com ela!",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Vôo do Mestre Zoth",t:15,d:"O vôo do Mestre Zoth está excelente. Foi especialmente desenvolvido para ser destrutivo. Aventureiros que estavam traumatizados por vôos deverão entender.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Lenço da Garota Zoth",t:15,d:"A garota Zoth não usa este lenço para limpar suas lágrimas, mas para tirar o sangue de seus inimigos.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Etiqueta do Sargento Zoth",t:15,d:"Dado por sua mãe, esta etiqueta bordada em um tecido é mais uma memória de infância do que uma insígnia militar.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Suco Ouassingue",t:15,d:"A menos que você seja um eufórico queimado, não confundirá suco de Ouassingue com qualquer líquido que possa nomear. O cheiro nauseante deve dissuadir se beber tudo de uma vez.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
I.u[8808] = {n:"Tecido do Rei Mopy",t:55,d:"Esta roupa tem mais buracos que uma fatia de queijo suiço e absorve sujeira mais rápido que um Gobball epiléptico. Quando a roupa vem, a ralé foge.",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"Cuecas às avessas do Rei Mopy",t:15,d:"Parecidos com seu ancestral, Rei Mopy Dagobert, todosos Reis Mopy usam suas cuecas por fora. O que confunde é que não têm o estômago para dentro também.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Turfa Seca",t:15,d:"Feito de vegetais podes, esta turfa tem incríveis poderes de absorção. Mamãe Bworks poupô-los de várias visitas mensais à titia Floe.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Papada de Miremop",t:15,d:"O Bourbassingue passa muito tempo em banhos de lama na esperança de emagrecer. Ele nunca perdeu um quilo, mas pelo menos sua papada cobriu sua cara.",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Tinta de Kralamor Gigante",t:15,d:"Viscosa e densa, a tinta de Kralamor pode ser usada para escrever cartas românticas ou pintar seu quarto com um preto depressivo assim como sua vida amorosa.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Ventosa de Kralamor Gigante",t:15,d:"Dada o tamanho desta ventosa, não há dúvidas de sua captação. E quando você a move, e o barulho de mastigação é ensurdecedor.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Bolsa de 5.000 Kamas",t:100,d:"Esta pesada sacola, provavelmente, custa uma fortuna.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Bolsa de 1.000 Kamas",t:100,d:"Esta pesada sacola, provavelmente, custa uma fortuna. Um comerciante ficará feliz de trocá-la por seu valor em Kamas.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Presente: Espada Flatulenta",t:89,d:"Se você agitar vigorosamente este presente, descobrirá que ele não está vazio. Pelo menos uma vez, talvez os deuses não riam de você.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Presente: Chapéu do Satanass",t:89,d:"Se você agitar vigorosamente este presente, descobrirá que ele não está vazio. Pelo menos uma vez, talvez os deuses não riam de você.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"Capa de Lembrança do Rei Mopy King",t:17,d:"Feito de tecido de Rei Mopy, esta capa tem pequenos buracos permitindo uma melhor dissipação do calor no caso de esforço excessivo, como durante ataques agressivos no pântano. Mesmo que esta capa deixe a umidade sair, ela mantém o calor. Desta forma, você fica seco, não importa a situação. Que pena que o mau cheiro é tão forte!!!",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Capa de Ouassingue",t:17,d:"Mesmo que esta capa não seja tão poderosa quanto a do Rei Mopy, ainda tem o mesmo sistema de evacuação de calor. Você será capaz de encarar qualquer situação com esta capa, se puder lutar enquanto prende sua respiração... o fedor é insuportável!!",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Máscara do Discípulo de Zoth",t:16,d:"Graças a esta máscara, você encarará todos os tipos de perigo, sem medo! Mas é normal já que bloqueia sua visão.",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Chapéu do Discípulo de Zoth",t:16,d:"A distância, este chapéu parece com abajur com dois buracos para os olhos. E de perto... Também.",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Máscara Treeckler Luz",t:16,d:"Esta máscara não pode evitar nem curar dor de cabeça, mas pelo menos dá a você a oportunidade de se esconder elegantemente.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Máscara de Treeckler Negro",t:16,d:"Esta máscara não pode evitar nem curar dor de cabeça, mas pelo menos dá a você a oportunidade de se esconder elegantemente. O toque sombrio simplesmente indica que você está de mau humor.. e que você não deve ser irritado e está pronto para distribuir pancadas em todos que não o respeitar!",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Snailmet",t:16,d:"Com isto, você se parecerá com um Snailmet. É claro, vai proteger sua cabeça de pancadas, mas é razão suficiente para babar assim? Você não precisa disso, continue em frente!",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Maça do Grande Coralator",t:7,d:"Maior, mais pesado e mais poderoso, esta maça faz um barulho grande quando esmaga os inimigos. Mas curiosamente, é mais leve e tem melhor pegada. No Coralator, nós costumávamos fazer isso, mas não tínhamos uma boa razão!",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Martelo da Garota Zoth",t:7,d:"Apesar de seu pequeno tamanho a garota Zoth carrega um grande martelo. É a forma de reforçar sua estrutura muscular. Não precisa adicionar pesos para os pulsos e tornozelos para aumentar sua força. Arrastar este martelo já é o bastante!",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Machado do Guerreiro Zoth",t:19,d:"O Guerreiro Zoth é usado para carregar dois machados, pois ele não pode ser alcançar o lado esquerdo do inimigo com sua mão direita. É difícil dizer se é um problema na imagem de seu corpo ou ser desajeitado desde o nascimento!",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Peruca de Frengo",t:16,d:"O Fregon é uma criatura alada estranha que tem muita energia como se tivesse gripe aviária e tanta inteligência quanto um Tofu. Não precisa dizer que não é apto para sobrevivência. Entretanto, algumas pessoas parecer adorar seu estranho corte de cabelo que parece uma vassoura dobrada. A natureza humana tem infinitos mistérios!",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Chapéu de Brabrossa",t:16,d:"Este chapéu é grande o bastante para esconder a ridícula falta de cabelo da cabeça e da barba de Barbrossa. Mas não cobre cabeças muito grandes.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8830] = {n:"Peruca de Flib",t:16,d:"Sempre sonhou em ter o cabelo de Polly Darton? Apenas tenha esta impressionante, porém enfadonha, peruca em sua cabeça! Não só limpará a pista de dança do clube, mas amortecerá os golpes mortais em sua cabeça!",ep:0,g:198,l:1,wd:false,fm:true,w:1,p:1};
I.u[8832] = {n:"Saliva de Snailmet",t:15,d:"Esta saliva de Snailmet não quebrará ossos de um Pikoko, mas certamente te manterá grudado no chão.",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Maça de Coralator",t:7,d:"Este martelo pegou uma bela cor dos pedaços de Coralator usados para fazê-lo. Diferente do que as pessoas pensam, ele não foi originalmente usado para esmagar Iops ou inimigos. De fato, é um item feito à mão deixado por uma antiga civilização. Foi usado como aldrava, então as pessoas que tinham problemas de audição poderiam entender que alguém estava batendo na porta.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Ramo de Treeckler Negro",t:3,d:"Este ramo foi usado para escovar algumas partes do corpo antes inacessíveis. Mas não se preocupe, a cor escura é autêntica, sem ligação com os vários tipos de depósitos contidos em cavidades inacessíveis do Treeckler.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Ramo Leve de Treeckler",t:3,d:"Este ramo foi usado para escovar algumas partes do corpo antes inacessíveis. Isso poderia explicar o cheiro estranho impregnado.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Caule de Rotaflor",t:4,d:"Rotaflors usa seus caules para limpar as orelhas. Entretanto, escultores de cajados preferem usá-los como arma. A prova, se é necessário, é não haver explicação para gostos.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Cajado do Mestre Zoth",t:4,d:"O Mestre Zoth pode derrotar qualquer um com este cajado. Ele não teme nenhum inimigo! E isso é normal já que ele não pode ver nada com este chapéu! Embora ele é uma técnica de luta muito útil, pode ser um problema durante as refeições. Com uma linha de visão limitada, o Mestre Zoth sempre tem problemas de comer sem se sujar todo...",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Rizoma de Tynril",t:4,d:"Como ervas daninhas, o Tynril pode se multiplicar infinitamente graças um só pedaço de rizoma, após notar que alguns escultores criam um cajado de Tynril. Eles pensaram que podiam de forma fácil e barata vender os melhores licitantes. Mas não funcionou!",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Máscara de Thierry Voodoo",t:16,d:"Esta máscara vodu é especialmente usada para cobrir a cara dos amados Kanniballs (como Thierry)! Mas eles normalmente erram o alvo de por isso ficam facilmente loucos!",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Máscara de Jav Voodoo",t:16,d:"Jav Kanniballs normalmente se sentem \"azuis\" e tingem seus pêlos de azul. Isso é devido ao final de uma triste história de amor ou o que? Difícil saber com certeza. Mas seria ótimo se eles pudessem usar a máscara e parar de cantar essa coisa melancólica.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Máscara de Vodu de Sarbak",t:16,d:"Eles conseguiram tantos cartões amarelos pelos erros aos alvos que alguns Kanniballs decidiram pintar suas máscaras nesta cor.",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Máscara de Vodu de Arqueiro",t:16,d:"Kanniball arqueiros não podiam se concentram e mirar direito a menos que estivessem muito nervosos. Para fazê-los ver em vermelho todo o tempo, eles pintaram suas máscaras desta cor.",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Chapéu de Crocodyl Dandy",t:16,d:"Com este chapéu, o Crocodyl pensa que ele está muito na moda. Entretanto, se fosse possível, a moda nunca deveria ter sido tão insignificante. É melhor não tentar entender quão ridículo ele é, o Crocodyl é muito sensível...",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"Capuz do Soberano Rei Mopy",t:16,d:"Como um capuz real, este capuz tem as mesmas virtudes que a Capa do Rei Mopy. Tem micro-ventilação para melhorar drenagem do calor e sempre mantém sua cabeça fresca. Infelizmente, também tem os mesmos defeitos que a capa: cheiro nojento que alguém poderia cortá-lo com uma faca.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Capuz Ouassingue",t:16,d:"Embora seja menos eficiente que um capuz real, ele permite uma boa drenagem do suor. Talvez boa demais, na verdade. Como resultado, esteja você usando ou não, não faz nenhuma diferença.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Chapéu da Garota Zoth",t:16,d:"O chapéu da garota de Zoth tem uma particularidade estranha para fazer ver coisas em dobro, isso explica o motivo de ela cecear...",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Capacete do Guerreiro Zoth",t:16,d:"Este capacete tem as mesmas vantagens de outros chapéus Zoth: protege do sol, não importa o quão quente esteja, de pancadas na cabeça e evita o usuário de ver o perigo restringindo seu campo de visão. De qualquer forma, é um capacete perfeito para gurreiros.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Chapéu de Mestre Zoth",t:16,d:"O chapéu do Mestre Zoth tem uma grande vantagem para restringir o campo visual mesmo mais do que outros capacetes. Graças a isso, você pode ter acesso à famosa técnica de luta chamada \"doninha\". A grosso modo, você só precisa acertar em volta com toda a sua força. Então, você se torna complemente imprevisível e certamente derrotará seus oponentes (ou pelo menos os surpreenderá o bastante para infligir danos com os ataques que acertarem).",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Raiz Barkritter",t:4,d:"Esta vara é bem popular entre as mulheres-tronco. Entretanto, se você seduz melhor outros tipos de mulhres, também é possível (mesmo que menos eficiente).",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Raiz de Floramor",t:4,d:"Se você é superticioso e sempre precisa bater na madeira, escolha esta Raiz Floramor! Por outro lado, você também pode tentar ser cuidado, não ver o ramo que está sentando e especialmente não colocar seus dedos no caminho!",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"Mapa do Tesouro Usado",t:24,d:"Mesmo que os seus olhos estejam cheios de lágrimas de alegria, você pode ver que o tesouro está escondido em algum lugar ao longo da estrada de águas escravizadas.",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"Chapéu Encolhido de Crack Sparrow",t:16,d:"Você diz que um Kraken, com o hálito mais imundo que já se viu, o segue aonde quer que você vá? Bem, lide com isso: é só uma minúscula inconveniência que vem com o chapéu!",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"Escudo Sharkal",t:82,d:"Este escudo é certamente uma boa proteção, mas não seja todo. Não durará muito.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Cinto de Bherbal Bherb",t:10,d:"Quando Bherb pegava borboletas, ele colocava seu cinto Bherbal e as eliminava de forma saudável.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Botas Kwish",t:11,d:"Estas botas criam um disfarça o barulho a cada passo, lembrando uma Trool no cio. Uma dolorosa lembrança de que você podia viver facilmente sem ela.",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"Selo do Soberano Rei Mopy",t:9,d:"Este selo indica que o proprietário é um soberano da Turfeira Sem Fundo da ilha de Otomai. É difícil imaginar um reino mais pastoral...",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Anel Coral",t:9,d:"Este anel foi tirado do dedo (ainda quente) de um Coralator abatido na hora. Sua mãe estava esperando-o para o jantar, até que ela viu seu bebê sendo transformado em túmulo. Coral é sensível e nem sempre como uma rocha, como as pessoas pensam.",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Sandálias Redondas Kimbo",t:11,d:"Apenas Kimbos, com seus pés estranhos, podem se sentir confortáveis nestas sandálias. Entretanto, elas não são as únicas que podem se beneficiar de seus podereses. Mas tenha cuidado, não as usa de forma errada!",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Cinto de Parkinn Pan Pikokowal",t:10,d:"Parkinn Pan acreditava de verdade que ele podia voar graças a este cinto enfeitado com asas de Pikoko, mas não sabia que poucos Pikokos podem voar. Sempre que ele saltava da Árvore Keeholo se esborrachava no chão. Seu apelo \"Queca\" veio de \"cair plano como uma panqueca\".",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothulet",t:1,d:"Este amuleto é apenas um pedaço de madeira com um pedaço de tecido rasgado. Mas Zoth estão absolutamente convencidos de seus poderosos. Velhos tolos!",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Arco de Snailmet",t:2,d:"Esta corda de arco é feita de saliva de Snailmet, não tão seca e com uma elasticidade única. Entretanto, é viscosa e sua textura lembra ... bem, nada, é bem desagradável.",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Anel de Snailmet",t:9,d:"Esculpido em uma carapaça de Snailmet, este anel pode resistir a qualquer coisa ou qualquer um.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Manto Deslumbrante Poderoso",t:17,d:"Traçando de tecidos de Zeht, esta capa tem um poder extraordinário de origem desconhecida.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Capa Moopet",t:17,d:"Com esta capa, você será desejado para algumas vinagretes.",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Machado de Frengo",t:19,d:"O Bico de Frengo nesta arma é absolutamente inútil e pode ser mais um obstáculo do que outra coisa.\nFelizmente, ela é bem poderosa.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Botas de Treeckler de Madeira",t:11,d:"Estas botas são tão pesadas que devem ser categorizadas como armas. Assim, elas tornam letal o mais simples chute.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Cinto Treeckler Negro",t:10,d:"Esculpido em Treeclker Negro, este cinto não é flexível o bastante para deixar você livre para se movimentar, mas ao menos, protege bastante.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Cinto de Treeckler Luz",t:10,d:"Esculpido em Treeckler Luz, este cinto não te protege bem, mas pelo menos, é flexível o bastante para deixá-lo livre para se movimentar.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Anel Dikuloos",t:9,d:"Esta jóia não é preciosa, mas tem o tamanho perfeito para dosar a moorgale em uma bela belgroot saborosa com uma dica de Glaviooze.",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Kracinto",t:10,d:"Finalmente uma boa desculap para sentir o cheiro do mar!",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Ouassulet",t:1,d:"Esta jóia algumas vezes tentou roubar um pouco de sua comida quando você estava comendo, então fique mais atento.",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Véu de Tinta",t:17,d:"Esta capa estranha parecer ser feita de tinta preta, mas é bem estranha, comporta-se como tecido - não escorre. Parecem manchas, bem, isso não importa. Seu traseiro nunca ficará limpo novamente.",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Kringamor",t:9,d:"Uma vez em seu dedo, você não poderá retirá-lo jamais. Essas coisas são o caminho para o poder.",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kidormmer",t:7,d:"Este martelo não é útil, não é particularmente bom, não é muito ergonônico e não é poderoso. É tão leve, tão frágil, desbalanceado, brilhante demais e fedido. Mas pelo menos é colorido! Belas cores nunca machucaram ninguém neste mundo cruel!",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
