I.u[11190] = {n:"Presente: Amuleto YeCh\'Ti",t:89,d:"Se você chacoalhar esta caixa vigorosamente, irá descobrir que não está vazia. Parece que desta vez os deuses não estão brincando com você.\nAtenção: Este presente só pode ser aberto em servidores de DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11191] = {n:"Botas do Campeão dos Calabouços",t:11,d:"As solas podem estar gastas mas essas botas são muito confortáveis. Elas pisaram no solo da maioria dos calabouços perigosos e nas cabeças de terríveis monstros.",ep:0,g:162,l:73,wd:true,fm:true,w:10,an:0,p:13700};
I.u[11192] = {n:"Presente: Botas do Campeão dos Calabouços",t:89,d:"Se você chacoalhar esta caixa vigorosamente, irá descobrir que não está vazia. Parece que desta vez os deuses não estão brincando com você.\nAtenção: Este presente só pode ser aberto em servidores de DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11193] = {n:"Tábua de Alpino",t:95,d:"Um marceneiro poderia usar essa tábua para criar algo encantador - um caixão, por exemplo. Apenas tenha isso em mente.",ep:0,g:23,l:100,wd:false,fm:true,w:10,p:10};
I.u[11194] = {n:"Farinha de Frosteez",t:52,d:"Esta farinha dissolve em leleite, dando um delicioso sabor de chocolate. Os habitantes da ilha perdida, preferindo sobremesas congeladas, gostam de dissolvê-la em água.",ep:0,g:260,l:100,wd:false,fm:true,w:1,p:1};
I.u[11195] = {n:"Lurgi",t:30,d:"Você precisa encontrar algum tratamento antes que isso fique pior.",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11196] = {n:"Kama de Gelo",t:24,d:"Sem poder criar uma nova moeda devido a falta de metal, os Frigostianos esculpem Kamas em gelo e utilizam para trocar por vários objetos locais. Esta moeda não tem valor fora da ilha.",ep:0,g:825,l:1,wd:false,fm:true,w:0,p:1};
I.u[11197] = {n:"Sarapox",t:30,d:"A campanha de vacinação contra essa doença já custou a cidade de Frigost a modesta quantia de 2 bilhões de Kamas e não teve resultados significativos. Os Frigostianos poderiam ter jogado seus Kamas pela janela que daria na mesma.",ep:0,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11198] = {n:"Vacina Lurgi",t:24,d:"Esta vacina proporciona proteção efetiva da Lurgi, mas seus efeitos acabam muito rapidamente. Ela precisa ser renovada toda semana.",ep:0,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[11199] = {n:"Semente de Frosteez",t:58,d:"Esta semente, fria ao contato, solta um poderoso aroma de chocolate.",ep:0,g:406,l:100,wd:false,fm:true,w:1,p:1};
I.u[11200] = {n:"Presente: Escuro Hispânico",t:89,d:"Se você chacoalhar esta caixa com vigor, irá descobrir que não está vazia. Parece que finalmente os deuses não estão enganando você.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[11201] = {n:"Amostra de Sangue de Mastogob",t:24,d:"Você pegou essa amostra de um Mastogob que sofre de uma gripe grave.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11202] = {n:"Água do Mar Isotônica",t:24,d:"Albert Paisse precisa dessa água em sua pesquisa para uma cura da gripe comum.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[11203] = {n:"Arquimídia",t:24,d:"Essa erva é muito usada por alquimistas, Eniripsas e Eniripsas Alquimistas. Uma planta parecida com essa pode ser utlizada para criar uma bebida popular entre marinheiros, Enutrofs e Enutrofs marinheiros.",ep:0,g:103,l:1,wd:false,fm:true,w:0,p:1};
I.u[11204] = {n:"Amostra de Sangue de Besta",t:24,d:"Você andou uma boa distância para conseguir esta amostra de sangue. Esperamos que valha a pena.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11205] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 1:00 e 4:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11206] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 4:00 e 7:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11207] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 7:00 e 10:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11208] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 10:00 a 13:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11209] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 13:00 e 16:00",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11210] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 16:00 e 19:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11211] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 19:00 e 22:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11212] = {n:"Horário de Encontro",t:24,d:"Você tem um encontro com o Capitão Tankerous na pousada, qualquer hora entre 22:00 e 1:00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11213] = {n:"Carrapatos de Mastogob",t:24,d:"Mais resistente que um par de Calças de Capitão Chafer de Kriptonita, e mais agressivos que uma banda de Caçadores Astrubianos, esses carrapatos são um verdadeiro pesadelo para seus hospedeiros.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[11214] = {n:"Sangue Contaminado de Mastogob",t:24,d:"Essa amostra foi retirada de um Mastogob infectado com carrapatos.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11215] = {n:"Sangue Contaminado de Guerreiro Mastogob",t:24,d:"Essa amostra de sangue foi retirada de um Guerreiro Mastogob infestado com carrapatos.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11216] = {n:"Sangue Contaminado de Mastogob Lendário",t:24,d:"Essa amostra foi retirada de um Mastogob Lendário infectado com carrapatos.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11217] = {n:"Sangue Contaminado de Mastogobbly",t:24,d:"Essa amostra de sangue foi retirada de um Mastogobbly infectado com carrapatos.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11218] = {n:"Um envelope para Otomai",t:24,d:"Wogew, o Hewmitão, lhe pediu para entregar este envelope a Otomai. Ele contém vários documentos úteis sobre carrapatos que vivem em Mastogobs, mas também em Wabbits.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[11219] = {n:"Cauda de Mastogob Real",t:65,d:"O Mastogob Real usa seu rabo para espantar Mosquitos durante os meses de verão. Durante o resto do ano ele nunca mais a usa, e as vezes até chega a esquecer que está lá.",ep:0,g:755,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11221] = {n:"Lã de Mastogob Real",t:57,d:"Ninguém sabe ao certo quando os Mastogobs chegaram em frigost. O que é certo é que eles estão lá a muito tempo, porque os Frigostianos ainda passam roupas-de-baixo de Lã de Mastogob de geração pra geração, e existem vários exemplos centenários.",ep:0,g:213,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11222] = {n:"Bico de Pingwinkle",t:47,d:"Quando não é encontrado firme na mandíbula de um Pingwinkle, esse bico pode ser encontrado firme em suas costas.",ep:0,g:662,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11223] = {n:"Pena de Pingwinkle",t:53,d:"Nos tempos antigos, Pingwinkles apenas costumavam visitar as costas de Frigost durante alguns dias no inverno, mas agora que a ilha congelou totalmente, eles decidiram ficar - o que é uma boa desculpa para roubar suas penas durante o ano itneiro.",ep:0,g:646,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11224] = {n:"Asa de Pingwobble",t:104,d:"Frigostianos sempre se perguntaram sobre qual a utilidade dessas ridículas asas. Afinal de contas, um Pingwobble nunca poderia sonhar em voar.",ep:0,g:216,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11225] = {n:"Pele de Pingwobble",t:59,d:"É muito oleosa, não é lavada com muita frequência, e brilha. Não, não estou falando de sua peruca, mas dessa Pele de Pingwobble.",ep:0,g:49,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11226] = {n:"Óleo de Mamãe Pingwin",t:60,d:"Este óleo foi extraído de uma Mamãe Pingwin. Vai demorar um bom tempo para apagar da memória como exatamente você extraiu isso...",ep:0,g:72,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11227] = {n:"Roupas-de-baixo de Mama Pingwin",t:54,d:"Todos em Frigost adoram encher suas roupas-de-baixo com isso. Alguns acham que é para mantê-los aquecidos, mas apenas um Iop iria acreditar nisso.",ep:0,g:675,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11228] = {n:"Espinha de Peixe Gigante de Pingwin Xamã",t:47,d:"Existem várias questões sobre Frigost que não possuem respostas, e, ainda mais preocupante, várias respostas que não possuem questões. Você nunca saberá onde o Xamã Pingwin encontrou essa espinha de peixe gigante.",ep:0,g:663,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11229] = {n:"Barba de Pingwin Xamã",t:54,d:"A barba de Xamã Pingwin cheira a peixe. E a suor de cabra. Essa potente mistura é usada pelos bravos habitantes de Frigost como repelente de Mastogob.",ep:0,g:674,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11230] = {n:"Cauda de Pingwin Kung-Fu",t:65,d:"Não seja enganado pelo seu tamanho modesto, ela sabe exatamente aonde está indo.",ep:0,g:753,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11231] = {n:"Orelha de Pingwin Kung-Fu",t:106,d:"Normalmente escondida por um peixe, as orelhas de um Pingwin Kung-Fu escuta apenas uma coisa, os chamados de parceiros disponíveis durante a época de acasalamento. Então, você está livre para atormentar os Pingwins desde não se pareça com um parceiro em potencial.",ep:0,g:625,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11232] = {n:"Pena de Pingwin Real",t:53,d:"O Pingwin Real é muito respeitado pelos habitantes de Frigost, que, cegos pelo seu título nobre, pensam que são mais importantes do que realmente são, e não hesitam em derrotá-los como resultado.",ep:0,g:647,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11233] = {n:"Ovo de Pingwin Real",t:105,d:"Não finja que você não sabe exatamente de onde esse enorme ovo surgiu.",ep:0,g:643,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11234] = {n:"Red Richard",t:32,d:"Este sobrevivente da Trilha de Pinhos Solitários deve ser escoltado até o Chefe Anbifketf.",ep:0,g:31,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11235] = {n:"Sioux Stuarme",t:32,d:"Este sobrevivente da Trilha de Pinhos Solitários deve ser escoltado até o Chefe Anbifketf.",ep:0,g:32,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11236] = {n:"Jauni Staurme",t:32,d:"Este sobrevivente da Trilha de Pinhos Solitários deve ser escoltado até o Chefe Anbifketf.",ep:0,g:33,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11237] = {n:"Grimmben",t:32,d:"Este sobrevivente da Trilha de Pinhos Solitários deve ser escoltado até o Chefe Anbifketf.",ep:0,g:34,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11238] = {n:"Cauda de Skrato",t:65,d:"Skratos usam seus rabos para balançar quando estão rolando bolotas no chão. Skratos parecem insensíveis ao ridículo.",ep:0,g:754,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11239] = {n:"Bolota de Skrato",t:58,d:"Skratos passam seus primeiros anos de vida procurando pela melhor bolota possível. Eles passam o resto de suas vidas tentando lembrar onde as esconderam.",ep:0,g:68,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11240] = {n:"Dente de Sabredon",t:47,d:"Um estudo científico muito sério mostrou que dentes de Sabredon foram a primeira causa de nádegas perfuradas entre os habitantes de Frigost.",ep:0,g:664,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11241] = {n:"Pêlo de Sabredon",t:54,d:"Pêlos de Sabredon antes eram usados para estofar algumas roupas - o que alguns Frigostianos de higiene pessoal duvidosa poderiam usar como desculpa para mascarar o cheiro deles.",ep:0,g:676,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11242] = {n:"Presa de Javali Glacial",t:47,d:"Essa presa cheira como rouba-de-baixo de alguém. Não suas, claro.",ep:0,g:665,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11243] = {n:"Couro de Javali Glacial",t:56,d:"Couro de Javali Glacial cobre seus ossos angulares muito bem, o que significa que é bom para ser usado o ano todo.",ep:0,g:16,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11244] = {n:"Mensagem de Gerard",t:24,d:"Eu segui uma Mamãe Pingwin anciã e ela me levou até sua toca, onde centenas de outras Mamães Pingwins estavam escondidas. É uma oportunidade para não ser desperdiçada. Eu irei entrar lá e atirar em tudo o que se move, haverá carne para pelo menos a próxima década.\nGerard.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[11245] = {n:"Jóias da Família de Gerard",t:24,d:"Diferente daquelas de Moolobo, essas jóias de família não possuem valor nem utilidade.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11246] = {n:"Olho Maligno de Frighog",t:109,d:"Pouco antes de ir até o santuário dos Frighogs derrotados em batalha, este que você derrotou lhe deu um último olhar com tanta ferocidade que seu sangue correu frio. Como se não fosse frio o bastante em Frigost...",ep:0,g:591,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11247] = {n:"Orelha Furada de Frighog",t:106,d:"Orelhas de Frighogs são todas furadas. Será que isso ocorre porque eles gostam de piercings ou é porque você consegue ouvir as músicas de Jon Lemon em Frigost também?",ep:0,g:626,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11248] = {n:"Orelha de Kaniglu",t:106,d:"Essa orelha lembra você de uma das canções favoritas entre os jovens Frigostianos: \"Kaniglu glu glu, Greedoblop blop blop tadada tzum tzum\". Não tem muitas letras, claro, mas assim até um Iop pode memorizá-las.",ep:0,g:627,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11249] = {n:"Tecido Kaniglu",t:55,d:"Este tecido lembra você do segundo verso de uma das músicas favoritas dos jovens Frigostianos: \"Frighog hog hog...\" Infelizmente, você não se lembra do resto das palavras.",ep:0,g:730,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11250] = {n:"Pêlo de Miau Peludo",t:54,d:"Enquanto ainda estavam vivos, os adversários políticos da Prefeita de Frigost diriam a qualquer um que ela usava lingeries de Pêlo de Miau.",ep:0,g:677,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11251] = {n:"Esterno de Miau Peludo",t:47,d:"Ninguém sabe ao certo para o que esse esterno é utilizado.",ep:0,g:666,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11252] = {n:"Pata de Rato Atrofiado",t:103,d:"Pequenas crianças Frigostianos brincam de um jogo chamado \"Miau Ai Ai\", que envolve cortar a pata de um rato atrofiado e utilizá-la para simular pegadas na neve. Elas atraem Miaus da Neve em busca de alvos. Assim que o Miau é capturado, elas depilam seu pêlo e os transformam em luvas. Crianças não são uma maravilha?",ep:0,g:36,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11253] = {n:"Tecido de Rato Atrofiado",t:55,d:"Antes de Frigost congelar, Ratos Atrofiados eram caçados por causa do seu pêlo, que era vendido ao continente de Amakna com o nome \"Pele Exótica de Kitsou\".",ep:0,g:731,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11254] = {n:"Pinça de Crabolho",t:47,d:"Cabrolhos são caçados por pescadores de Frigost por duas razões: o temperamento ruim deles e sua tendência de cortar as redes dos pescadores. Os pescadores se vingam dos caranguejos cortando suas pinças fora.",ep:0,g:668,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11255] = {n:"Olho de Crabolho",t:109,d:"O olho contém um fluído que é utilizado em receitas tradicionais de Frigost, quando substitui vinagre - mas apenas se você deixar o olho fermentar o suficiente.",ep:0,g:592,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11256] = {n:"Bico de Gullipop",t:47,d:"Gullipops são muito estúpidos, criaturas mal-educadas, cujo estrume é acumulado em pilhas ao redor do porto de Frigost. Eles gostam de roubar peixes dos pescadores, mas assim que bem-treinados, eles podem pegar coisas de turistas distraídos e escondê-las em seus bicos.",ep:0,g:667,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11257] = {n:"Pena de Gullipop",t:53,d:"Estudantes de Frigost utilizam essas penas para escrever, o que explica o fato de mamães Gullipops sempre correrem quando passam pelas escolas com seus filhotes.",ep:0,g:648,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11258] = {n:"Receita do Chefe Anbifketf",t:24,d:"A data que os pinhos foram recebidos está marcada nessa receita. Mostre-a a Gormor para receber seu pagamento.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[11259] = {n:"Troncos de Pinho",t:24,d:"Chefe Anbifketf precisa desses troncos para o sistema de aquecimento encanado.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11260] = {n:"Gordura de Pingwin",t:24,d:"Essa gordura grudenta cria um excelente combustível que queima durante um longo tempo - o que explica porque os Pingwins nunca sentem frio.",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[11261] = {n:"Lista de Abastecimendo de Damar",t:24,d:"Esta lista mostra as peças perdidas dos pescadores do Lago Congelado, que precisam para reparar seu equipamento.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[11262] = {n:"Anel de Casamento de Damar",t:24,d:"Damar deu este anel a Valy Domidat trinta anos atrás.",ep:0,g:27,l:1,wd:false,fm:true,w:0,p:1};
