I.u[2998] = {n:"Lã de Minotoro",t:57,d:"Os pêlos que compõem esta lã excepcional são tão grossos que eles podem protegê-lo até dos golpes mais enganosos.",ep:2,g:654,l:125,wd:true,fm:true,w:30,p:12500};
