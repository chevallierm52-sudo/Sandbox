I.u[3203] = {n:"Anel Tribal",t:9,d:"A origem deste anel é duvidosa, para dizer o mínimo. Ele, aparentemente, pertenceu a um clã de Kanniballs do pior tipo, os comedores de samambaias. Certamente, uma história para assustar os jovens discípulos de Sadida.",ep:11,g:49,l:51,wd:true,fm:true,w:5,p:7000};
I.u[3204] = {n:"Cinto de Bonta",t:10,d:"Este é o cinto da hora nas ruas de Bonta. A insígnia de uma renomada fraternidade de sapateiros adorna a fivela.",ep:3,g:37,l:53,wd:true,fm:true,w:10,c:"Ps=1",p:7400};
I.u[3205] = {n:"Cinto de Brakmar",t:10,d:"É o cinto mais elegante dos esgotos de Brakmar. É perfeito para dar a impressão que você é um osso duro de roer. Só uma impressão entretanto.",ep:13,g:38,l:53,wd:true,fm:true,w:10,c:"Ps=2",p:7500};
I.u[3206] = {n:"O Xerbo",t:10,d:"Especialmente projetado para recompensar cavaleiros úteis, o Xerbo deve ser vestido sem roupa íntima e apenas no inverno.",ep:13,g:39,l:67,wd:true,fm:true,w:7,p:13000};
I.u[3207] = {n:"Botas de Satisfação",t:11,d:"Estas botas são confortáveis e leves para dar total satisfação. Ao olhar suas solas, mesmo seus oponentes darão um sorriso amarelo (e invejoso).",ep:1,g:38,l:17,wd:true,fm:true,w:10,p:950};
I.u[3208] = {n:"Cueca de Bwork Arqueiro",t:56,d:"O Bwork Arqueiro tinha o péssimo hábito de colocar as flechas dele em suas cuecas de couro. Isto talvez explique o motivo de dizerem que as flechas do Bwork Arqueiro são envenenadas.",ep:1,g:649,l:23,wd:true,fm:true,w:1,p:1};
I.u[3209] = {n:"Escalpo de Bwork Mago",t:15,d:"Logo em suas vidas, os jovens Enutrofs saem para caçar um Escalpo de Bwork Mago que pode ajudar a esconder sua calvície em desenvolvimento. Usar esta coisa em suas cabeças, parece deixá-los mais espertos, porém bastante incomuns! Ainda assim, o fedor que sai do escalpo é terrível e cobre seu bafo horrível impregnado de energético.",ep:4,g:653,l:23,wd:true,fm:true,w:1,p:1};
