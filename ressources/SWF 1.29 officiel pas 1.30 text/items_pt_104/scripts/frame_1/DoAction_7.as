I.u[3000] = {n:"Capacete de Bwork",t:15,d:"Na tribo Bwork, os Bworks Magos são encarregados da forja. Eles são equipados com um capacete desde o nascimento, para evitar qualquer tipo de acidente, como quedas e golpes de martelo.",ep:4,g:646,l:43,wd:true,fm:true,w:10,p:1};
I.u[3001] = {n:"Epaulette de Bwork",t:15,d:"A Dragona é essencial para a educação dos jovens Bworks, ainda que ‘treinamento\' seria uma palavra mais apropriada para descrever isto.",ep:4,g:647,l:43,wd:true,fm:true,w:10,p:1};
I.u[3002] = {n:"Botas de Bwork",t:15,d:"Você não pode usar botas como estas aqui. Uma vez que tiverem sido corretamente consertadas por um sapateiro experiente, você poderá achá-las úteis. Por enquanto, o cheiro delas pode ajudá-lo a afastar as pessoas que estão um pouco adiante.",ep:4,g:648,l:43,wd:true,fm:true,w:10,p:1};
