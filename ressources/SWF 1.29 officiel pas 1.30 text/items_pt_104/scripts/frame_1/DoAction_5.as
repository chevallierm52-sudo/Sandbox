I.u[2066] = {n:"Cajado de Kanigrou",t:4,d:"É uma réplica aproximada de um cajado de Kanigrou. Há muitas surpresas guardadas, mas nem todas são boas.",ep:13,g:22,l:54,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,50,false,false],c:"CS>50&CA>40&CC>30",p:5400};
