I.u[2155] = {n:"Colar de Jiva",t:1,d:"Amuleto usado por Silaisie.",ep:1,g:19,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2156] = {n:"Espada de Justiça",t:6,d:"Esta espada permite pregar as palavras sagradas.",ep:1,g:16,l:1,wd:false,fm:true,w:1,an:14,e:[30,5,1,1,30,50,false,false],c:"PN~Silaisie",p:1};
I.u[2157] = {n:"Clint",t:16,d:"O Clint é um simples, mas elegante chapéu. A última versão deste chapéu pode se ajustar tanto em delicadas aventureiras quanto em viris aventureiros. Qualidade garantida.",ep:1,g:38,l:50,wd:true,fm:true,w:10,c:"Ps=3",p:1};
I.u[2158] = {n:"Carta de Oto Mustam para Sbab",t:24,d:"O objetivo desta carta irônica é denegrir Sbab.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2159] = {n:"Pergaminho de Coragem",t:14,d:"Este pergaminho eleva sua Força. Pode ser útil quando um Kaniger furioso desafiá-lo.",ep:1,g:2,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2160] = {n:"Pergaminho Desencorajador",t:14,d:"Com este pergaminho você pode reduzir a Força de um único alvo. Isto pode ser útil quando um Kaniger furioso estiver agredindo seu inimigo.",ep:1,g:4,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2161] = {n:"Pergaminho de Flexibilidade",t:14,d:"Este pergaminho eleva sua Agilidade. Pode ser útil para escapar de um Moolobo.",ep:1,g:6,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2162] = {n:"Pergaminho de Inflexibilidade",t:14,d:"Este pergaminho reduz a Agilidade de um alvo individual. Pode ser útil para evitar que seu inimigo fuja diante de um Moolobo.",ep:16,g:5,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2163] = {n:"Armistice",t:31,d:"Você não pode ser atacado até a sua próxima luta.",ep:1,g:3,l:1,wd:true,fm:true,w:0,m:true,c:"Ps=0",p:1};
I.u[2164] = {n:"Amostra de Lava",t:24,d:"Esta amostra foi encontrada a Leste da mina.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2165] = {n:"Amostra de Lava",t:24,d:"Esta amostra foi encontrada a Oeste da mina.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2166] = {n:"Amostra de Lava",t:24,d:"Esta amostra foi encontrada perto da mina.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2167] = {n:"Amostra de Lava",t:24,d:"Esta amostra foi encontrada ao Sul da mina.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2168] = {n:"Início de relatório",t:24,d:"Este relatório começa a descrever as mudanças preocupantes na massa magmática de Brakmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2169] = {n:"Raaga",t:32,d:"Traga Raaga na caverna magmática.",ep:14,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2170] = {n:"Espada de Mercenário",t:6,d:"Esta espada longa é pesada e difícil de manusear. Mas tem um corte perfeito graças ao seu peso.",ep:1,g:25,l:1,wd:true,fm:true,w:1,an:14,tw:true,e:[30,5,1,1,25,50,false,false],p:1};
I.u[2171] = {n:"Relatório de Raaga",t:24,d:"Este relatório descreve as mudanças caóticas nas atividades vulcânicas em Brakmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2172] = {n:"Lista de Amostrar a Encontrar",t:24,d:"Raaga, grosso modo, escreveu a informação que você precisa para encontrar boas amostras de lava:\n‘Examine dentro de um raio de 5 milhas. Procure por pequenos picos‘.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2173] = {n:"Segredos da Linguagem dos Esquilos",t:25,d:"Este dicionário ensinará você como conversar com esquilos;\r\n            ou, pelo menos, tentar...",ep:2,g:6,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[2174] = {n:"Passe para a Área de Interrogação",t:24,d:"Com esse pedaço de papel, você pode entrar livremente na pequena área de interrogação da prisão.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2175] = {n:"Ameaça do Intendente",t:24,d:"Isto é uma ameaça que Danathor escreveu para não se esquecer de que precisava de algo como desculpa para se retirar em quaisquer circunstâncias.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2176] = {n:"Endereço de Rimaraf",t:24,d:"Rimaraf vive na casa de tijolos vermelhos na  Rua do Entalhe, 13, no quarteirão do Açougueiro.",ep:2,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[2177] = {n:"Broche de Danathor",t:24,d:"Danathor lhe deu este pequeno broche.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2178] = {n:"Formulário de Investigação n° 36",t:80,d:"Este formulário é uma boa maneira de identificar suspeitos em potencial de atos criminosos.\n(Clique nele, então em alguém para usá-lo)",ep:16,g:6,l:1,wd:true,fm:true,w:1,c:"PO!2181&PO!2177&Ps=1&Pa=27",ut:true,p:100};
I.u[2179] = {n:"Dente de Dragossauro",t:47,d:"Este dente parece ser muito afiado. Poderia se tornar uma arma perigosa nas mãos erradas. Felizmente, o Dragossauro só o usa para mastigar salada.",ep:2,g:419,l:20,wd:true,fm:true,w:2,p:1};
I.u[2180] = {n:"Interrogatório",t:24,d:"O álibi desta pessoa parece ser perfeito.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2181] = {n:"Interrogatório",t:24,d:"Esta pessoa é suspeita e seu álibi não a apóia.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2182] = {n:"Carta de um Oficial Envolvido na Investigação",t:24,d:"Um oficial da milícia o está observando atentamente. Você é suspeito de ter um infiltrador Rimaraf. Ele lhe deixou o cartão dele durante o interrogatório...",ep:2,g:71,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2183] = {n:"Poção de Esquecimento de Profissão: Pescador",t:44,d:"Com esta poção você esquecerá a profissão de Pescador.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2184] = {n:"Poção de Esquecimento de Profissão: Peixeiro",t:44,d:"Com esta poção você esquecerá a profissão de Peixeiro.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2185] = {n:"Poção de Esquecimento de Profissão: Caçador",t:44,d:"Com esta poção você esquecerá a profissão de Caçador.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2186] = {n:"Poção de Esquecimento de Profissão: Açougueiro",t:44,d:"Com esta poção você esquecerá a profissão de Açougueiro.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2187] = {n:"Dink de Competição",t:41,d:"Resultado do cruzamento de muitos outros peixes, este peixe só pode ser pego na piscina de Sufokia.",ep:7,g:400,l:1,wd:true,fm:true,w:20,p:1};
I.u[2188] = {n:"Vara de Pesca para Dink",t:20,d:"Esta vara de pesca é a única coisa que lhe permitirá pescar os dingas da piscina de Sufokia.",ep:7,g:8,l:1,wd:true,fm:true,w:2,an:18,e:[1,5,1,5,10,10,false,true],p:50};
I.u[2189] = {n:"Certificado de Bom Voto",t:24,d:"Este pequeno pedaço de papel assinado por Satirev Refibrom prova que você votou durante um julgamento... e votou bem.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2190] = {n:"Formulário de Investigação n° 33",t:80,d:"Este formulário é normalmente usado para fazer suspeitos confessarem seus atos criminosos.",ep:16,g:6,l:1,wd:true,fm:false,w:1,c:"PO=2177&Ps=1&Pa=27",u:true,p:100};
I.u[2191] = {n:"Certificado de Voto Ruim",t:24,d:"Este pequeno pedaço de papel assinado por Satirev Refibrom prova que você votou durante um julgamento... e que você mentiu.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2192] = {n:"Documentos Roubados",t:24,d:"Estes documentos super-secretos estão selados por uma glifo de morte. Mesmo se você romper a runa, nunca conseguirá ler os documentos.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2193] = {n:"Tufo de Cabelos de Puja",t:24,d:"Você deu uma boa surra no filho de Oto Mustam. Ele provavelmente não gostará disto!",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2194] = {n:"Nota",t:24,d:"Devolva 10 Cascas de Treechnid.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2195] = {n:"Dente",t:24,d:"Este dente deve ser certamente seu devido à boa surra que Oto Mustam lhe deu.\nA sabedoria lhe sugeriria esperar antes de ir conversar com ele novamente... a menos que você queira ser massacrado novamente.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2196] = {n:"Conhecimento",t:29,d:"Esta bênção fará você ganhar Inteligência para suas próximas lutas.",ep:18,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2197] = {n:"A Força do Divórcio",t:14,d:"Estes anéis podem quebrar os laços sagrados do matrimônio.",ep:1,g:13,l:1,wd:true,fm:true,w:0,ut:true,p:1};
I.u[2198] = {n:"Pergaminho de Conhecimento",t:14,d:"Este pergaminho eleva sua Inteligência. Você pode ficar calmo enquanto encara dois Bworks.",ep:1,g:7,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2199] = {n:"Pergaminho de Estupidez",t:14,d:"Este pergaminho reduz a Inteligência de um alvo individual. Pode ser útil para evitar que seu inimigo fuja quando enfrentar dois Bworks.",ep:1,g:8,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2200] = {n:"Ameaça de Satirev Refibrom",t:24,d:"O Grande Juiz de Brakmar não quer te ver novamente. Aparentemente, ele não é um aficionado por você... não se preocupe, ele tem um coração de pedra, de qualquer forma.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2201] = {n:"Serenidade",t:29,d:"Esta bênção permitirá você ganhar Sabedoria para a sua próxima luta.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2202] = {n:"Senilidade",t:30,d:"Esta maldição reduzirá sua Sabedoria durante sua próxima luta.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2203] = {n:"Pergaminho de Moderação",t:14,d:"Com este pergaminho, você pode elevar sua Sabedoria. É uma habilidade essencial para se igualar a Dark Vlad.",ep:1,g:9,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2204] = {n:"Pergaminho de Senilidade",t:14,d:"Este pergaminho reduz a Sabedoria de um alvo individual. É necessário quando seu inimigo tenta se igualar a Dark Vlad.",ep:1,g:10,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2205] = {n:"Mudança de Ordem",t:24,d:"Este papel indica que você já mudou de ordem.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2206] = {n:"Dádiva Divina",t:29,d:"Esta bênção fará você ganhar Sorte nas suas próximas lutas.",ep:18,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2207] = {n:"Papel de Detenção",t:24,d:"Você pode ler todos os crimes que cometeu neste papel, assim como a data em que você foi encarcerado...",ep:2,g:73,l:1,wd:true,fm:true,w:0,p:1};
I.u[2208] = {n:"Sorte Podre",t:30,d:"Esta maldição reduzirá sua sorte durante a próxima luta.",ep:1,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2209] = {n:"Pergaminho de Dádiva do Céu",t:14,d:"Este pergaminho aumenta sua Sorte. Você será sortudo o bastante para encontrar um Tofu em palheiro?",ep:1,g:11,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2210] = {n:"Pergaminho de Sorte Podre",t:14,d:"Este pergaminho pode reduzir a Sorte de um alvo individual;\r\n            pode ser útil quando seu inimigo tentar usufruir da sorte.",ep:1,g:12,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2211] = {n:"Traje Iopish",t:14,d:"Você será um sucesso na sociedade graças a este equipamento. O único problema é que as pessoas pensarão que você é tão esperto quanto um Iop.",ep:1,g:14,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2212] = {n:"Aparato Xelor",t:14,d:"Com este chapéu e alguns outros apetrechos não há como saber a diferença entre você e o Xelor.",ep:1,g:15,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2213] = {n:"Traje de Sadida",t:14,d:"Você não precisa de muito para se parecer com um Sadida. Um tapete de beira de cama e ficar na escuridão com sua cabeça presa em seu reto. Sucesso garantido!",ep:1,g:16,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2214] = {n:"Atitude de Iop",t:31,d:"Você tem a Atitude de Iop até a sua próxima luta.",ep:1,g:4,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2215] = {n:"Atitude Xelor",t:31,d:"Tenha a Atitude de Xelor até a sua próxima luta.",ep:1,g:5,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2216] = {n:"Atitude de Sadida",t:31,d:"Você tem a Atitude de Sadida até a sua próxima luta.",ep:1,g:6,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2217] = {n:"Peruca Fecahish",t:14,d:"Você tirou esta peruca de um armário, é óbvio por causa do estilo retrô dela. É perturbante ver que você parece com um feca quando a usa... (porque você quer isto)",ep:1,g:17,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2218] = {n:"Atitude de Feca",t:31,d:"Você tem a Atitude Feca até a sua próxima luta.",ep:1,g:7,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2219] = {n:"Traje Eniripsish",t:14,d:"Estas asas da Eniripsa não lhe permitirão voar. Então, não se gabe com este traje ou você parecerá ridículo aos olhos de todos na hora da aterrissagem.",ep:1,g:18,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2220] = {n:"Atitude de Eniripsa",t:31,d:"Você tem a Atitude de Eniripsa até a sua próxima luta.",ep:1,g:8,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2221] = {n:"Traje de Enutrofish",t:14,d:"Uma barba falsa que faz você parecer um Enutrof e que também lhe dá o hálito de um Enutrof que sai em um sábado à noite. É suficiente ter uma tremenda febre.",ep:1,g:19,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2222] = {n:"Atitude de Enutrof",t:31,d:"Você tem a Atitude de Enutrof até a sua próxima luta.",ep:1,g:9,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2223] = {n:"Traje de Sacrier",t:14,d:"Um pouco de sangue de Tofu e cicatrizes falsas, os olhos de um pirata psicótico, e lá vai você! Agora você pode participar das reuniões de sacriers sem levantar suspeitas.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2224] = {n:"Atitude de Sacrier",t:31,d:"Você tem a Atitude de Sacrier até a sua próxima luta.",ep:1,g:10,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2225] = {n:"Traje de Sram",t:14,d:"A Skully, um manto em sua cabeça e a ilusão está perfeita. Se você usar este traje, parecerá com um personagem oculto que saiu das profundezas de um cemitério... como um Sram!",ep:1,g:21,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2226] = {n:"Atitude de Sram",t:31,d:"Você tem uma Atitude de Sram até a sua próxima luta.",ep:1,g:11,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2227] = {n:"Traje Osamodish",t:14,d:"Algumas pessoas gostam, outras não, se você usar estes chifres e rabos bifurcados, você estará pronto para se convidar para as celebrações organizadas em segredo pelos seguidores de Osamodas.",ep:1,g:22,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2228] = {n:"Atitude de Osamodas",t:31,d:"Você tem a Atitude de Osamodas até a sua próxima luta.",ep:1,g:12,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2229] = {n:"Traje de Ecaflipish",t:14,d:"Você encontrará orelhas macias de Wabbit, um rabo malhado e uma caixa de pulgas agitadas. Sem dúvida, se você espalhar estes pequenos parasitas asquerosos, seu talento de mudança rápida será reconhecido.",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2230] = {n:"Atitude de Ecaflip",t:31,d:"Você tem a Atitude de Ecaflip até a sua próxima luta.",ep:1,g:13,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2231] = {n:"Traje Crahish",t:14,d:"Como você sabe, uma Cra sempre leva sua aljava consigo. Não é de se estranhar que pessoas pensem que você é um Cra quando você anda por aí com a sua. Mas isto é apenas uma ilusão e é uma sensação fantástica ver o quão fácil é enganar todo mundo.",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2232] = {n:"Atitude de Cra",t:31,d:"Você tem a Atitude de Cra até a sua próxima luta.",ep:1,g:14,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2233] = {n:"O Moedor",t:10,d:"Quando Xof, a Raposa, criou este cinto, ele teve a boa idéia de juntar todos os dentes que pôde achar em um campo de batalha de Wabbits. Agora, isto se tornou um hábito para ele.",ep:8,g:20,l:28,wd:true,fm:true,w:20,c:"CS<40&CI>80",p:2400};
I.u[2234] = {n:"Atitude de Bonta",t:31,d:"Você possui a atitude de Bonta até a sua próxima luta.",ep:1,g:15,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2235] = {n:"Atitude de Brakmar",t:31,d:"Você possui a atitude de Brakmar até a sua próxima luta.",ep:1,g:16,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2236] = {n:"Traje Bontish",t:14,d:"Com este traje, você atrairá viajantes que ou saudarão você ou lhe perguntarão o caminho.",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2237] = {n:"Equipamento de Brakmar",t:14,d:"Com isto, você será temido por todos.",ep:1,g:26,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2239] = {n:"Pó de Eniripsa",t:48,d:"Este pó é produzido com pequenas quantidades de asas de Eniripsas. Aparentemente, tem virtudes curativas em animais de estimação.",ep:3,g:260,l:1,wd:true,fm:true,w:1,p:1000};
I.u[2240] = {n:"Pequenas Fadas de Artifício Vermelhas 1",t:74,d:"Ideal para celebrar pequenos casamentos, perfeito para a Celebração das Ceroulas do Capitão Chafer.",ep:16,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:350};
I.u[2241] = {n:"Geléia Menta Real",t:110,d:"Esta Geléia Real uma vez foi o maior medo de muitos aventureiros devido a roubos. Tenha cuidado, não é recomendável comê-la, assim como você faz com uma Geléia de Menta.",ep:7,g:408,l:100,wd:true,fm:true,w:1,p:100};
I.u[2242] = {n:"Geléia Morango Real",t:110,d:"Concentrado de Geléia de Morango Real, pode tornar um Tabi pacífico em uma máquina-infiltradora sedenta por sangue. Então, evite dá-la a seus amigos como um aperitivo.",ep:7,g:409,l:150,wd:true,fm:true,w:1,p:100};
I.u[2245] = {n:"Pinça de Escorpião",t:47,d:"Usado para arranhar as costas de alguém, também pode ser muito útil para remover mantos que estiverem pendurados em um muro. Também funciona com você pendurado pelas costas, mas é um pouco doloroso...",ep:14,g:411,l:36,wd:true,fm:true,w:1,p:1};
I.u[2246] = {n:"Coroa de Tofu Real Quebrada",t:15,d:"Esta coroa foi quebrada por poderosos ataques mágicos ou pelo Tofu Real que tentou lhe dar uma cabeçada!",ep:3,g:412,l:100,wd:true,fm:true,w:10,p:250};
I.u[2247] = {n:"Pena de Tofu Real",t:53,d:"Só um Iop não acredita que esta pena vem das nádegas de um Tofu Real. E, ainda, seu tamanho torna bastante óbvio.",ep:3,g:413,l:100,wd:true,fm:true,w:11,p:250};
I.u[2248] = {n:"Cabelo de Ouginak",t:54,d:"Esse tipo de cabelo pode mantê-lo aquecido, desde que você esteja todo suado, após segurá-lo por algum tempo. A menos que esteja suado porque está com medo de encontrar outro Ouginak que pode ver você segurando um cabelo de Ouginak e queira vingar o seu amigo.",ep:14,g:414,l:51,wd:true,fm:true,w:1,p:1};
I.u[2249] = {n:"Folha de Trunknid",t:36,d:"Esta folha deve fornecer ao Trunknid força para lutar. Mas, para isto, é necessário saber como usá-la corretamente. Realmente, a primeira coisa que você pensaria é cortá-la e adicioná-la aos feijões. Uma delícia!",ep:2,g:415,l:35,wd:true,fm:true,w:1,p:1};
I.u[2250] = {n:"Madeira de Trunknid",t:38,d:"Este pedaço de madeira emite um som oco. A seiva verde saindo dele prova que isto é bem o nariz do Trunknid.",ep:9,g:416,l:35,wd:true,fm:true,w:1,p:100};
I.u[2251] = {n:"Mega Rocha de Crackler",t:51,d:"Eu não conjurarei a primeira Megapedra!",ep:5,g:417,l:45,wd:true,fm:true,w:15,p:150};
I.u[2252] = {n:"Dente Dourado de Crackler",t:47,d:"Você acabou de quebrar o dente de um crackler. Que pena que era o único dente dele! Uma dentadura teria facilmente coberto o custo mensal do Zaap.",ep:5,g:418,l:31,wd:true,fm:true,w:5,p:1};
I.u[2253] = {n:"Flor de Greedovore",t:35,d:"Esta Flor facilita a digestão. Consuma-a depois de passar pela cozinha e comer sua refeição favorita.",ep:12,g:420,l:42,wd:true,fm:true,w:1,p:100};
I.u[2254] = {n:"Folha de Emboscada",t:36,d:"A folha de Emboscada tem um gosto peculiar, entre avelã e salada não tão fresca. Se você ousar provar seus pratos, descobrirá que eles têm um pouco do sabor da traição...",ep:2,g:421,l:22,wd:true,fm:true,w:1,p:1};
I.u[2255] = {n:"Relatório do Espião",t:24,d:"Nenhuma atividade perigosa relatada recentemente. A organização dos homens da milícia está uma baderna desde a morte de seu pessoal. O acusado é aparentemente um bontariano.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2256] = {n:"Carcaça de Rato do Esgoto",t:24,d:"Este rato é agora carne morta... é menos um em volta da entrada do esgoto.",ep:2,g:121,l:1,wd:true,fm:true,w:0,p:1};
I.u[2257] = {n:"Pedaço de Muro do Esgoto",t:24,d:"Este pedaço do Muro de Esgoto foi encontrado no estômago de uma coisa.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2259] = {n:"Dente de Karne",t:47,d:"O que está em sua mão é o jogo mais antigo de Amakna. As regras são simples: jogue um dente e tente pegá-lo com a mesma mão enquanto pega outro dente de Karne no chão.",ep:4,g:13,l:16,wd:true,fm:true,w:1,p:20};
I.u[2260] = {n:"Carta de um brakmarino",t:24,d:"Alguém, aparentemente um Brakmariano, colocou discretamente este cartão em seu equipamento. Está escrito que os Guerreiros estão interessados em seus talentos de assassinato e ele sugere que você junte-se à louca aventura brakmariana.",ep:2,g:72,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2261] = {n:"Espírito Farejador",t:30,d:"Você foi possuído por um Espírito Aspirante. Seu cheiro e vitalidade são a sua principal dieta.",ep:1,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2262] = {n:"Descrição do Assassino",t:24,d:"Você encontrou um Bontariano que fedia a sangue. Todas as informações que você coletou a respeito deste personagem estão escritas neste pedaço de papel.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2263] = {n:"Cajado Farejador de Sangue",t:80,d:"Este cajado está possuído por espírito de farejador. Esse tipo de espírito assombra itens e pessoas com um odor especial antes de voltar para a Terra dos Espíritos...",ep:16,g:25,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[2264] = {n:"Pele de Gobelin",t:59,d:"Um Gobelin está freqüentemente zombando das pessoas, o que é bastante irritante... e deveria ser desmembrado da mesma forma.",ep:4,g:422,l:16,wd:true,fm:true,w:1,p:1};
I.u[2265] = {n:"Descrição de um Bontariano",t:24,d:"Você libertou um espírito farejador, mas ele não se fixou na pessoa almejada. Você escreveu algumas informações relativas à pessoa neste pedaço de papel para se lembrar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2266] = {n:"Leite de Porco",t:15,d:"Esse Leite de Porco vem de um Porco de Leite. Nunca se sabe, você deve ser avisado disso, só para garantir...",ep:1,g:423,l:18,wd:true,fm:true,w:1,p:1};
I.u[2267] = {n:"Dragoleite",t:15,d:"Este dragoleite é um gênero alimentício raro, porque ninguém no país já viu um Dragão Porco concordar em ser ordenhado. Podemos facilmente imaginar que requer pelo menos 7 pessoas para segurar a besta enquanto outra rapidamente o ordenha.",ep:2,g:424,l:70,wd:true,fm:true,w:2,p:1};
I.u[2268] = {n:"Escalpo de Bwork Arqueiro",t:15,d:"Aqui está um couro cabeludo que poderia começar uma nova moda para os Enutrofs: a peruca. Um pouco de poção antipiolhos e você estará pronto para participar da Competição ‘O Enutrof Mais Elegante do Mundo\'.",ep:4,g:425,l:24,wd:true,fm:true,w:1,p:1};
I.u[2269] = {n:"Olho de Larva Azul",t:24,d:"Este Olho está intacto. Olhos mexidos bem cozidos são uma delícia no café da manhã. Ao mesmo tempo, tê-lo em suas mãos prova ao Oto que você matou uma Larva Azul.",ep:1,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2270] = {n:"Monte de Ovos de Larva",t:24,d:"Este monte de ovos se parece com um grande cacho de uvas. Mas é melhor evitar comê-los.",ep:1,g:83,l:1,wd:true,fm:true,w:0,p:1};
I.u[2271] = {n:"Couro Violeta de Bwork",t:56,d:"O Artesanato Bwork permanece muito misterioso. Alguns aventureiros pensam que a cor purpúrea viria dos Gobelins. Mas a origem do couro ainda é desconhecida. Muito estranho.",ep:4,g:426,l:31,wd:true,fm:true,w:1,p:1};
I.u[2272] = {n:"Larva Dourada",t:32,d:"Esta está sendo encubada. A primeira coisa que ela ver vai considerar como sua mãe.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[2273] = {n:"Tecido Violeta",t:55,d:"As características principais deste estranho Tecido Púrpura é ser leve e liso. Há uma etiqueta com os dizeres ‘feito em talho um\'.",ep:2,g:427,l:23,wd:true,fm:true,w:1,p:1};
I.u[2274] = {n:"Vela do Mineiro das Sombras",t:15,d:"Pegue um Enutrof. Quando estiver escuro nas minas, ninguém conseguirá vê-lo. Considerando o Mineiro das Sombras na escuridão... bem, ele também não pode ser visto se você não tiver a vela dele.",ep:1,g:428,l:24,wd:true,fm:true,w:10,p:10000};
I.u[2275] = {n:"Couro de Porco Imundo",t:56,d:"O Porco Imundo está desaparecendo da cadeia alimentar. As pessoas dizem que acasalar javali com porcos gerará os Porcos Imundos nas Planícies de Cania novamente. Os Porcos Imundos estão zangados com todo o mundo e você nunca será amigável ao olho de um porco.",ep:2,g:429,l:40,wd:true,fm:true,w:10,p:1};
I.u[2277] = {n:"Lençol",t:55,d:"Para ganhar credibilidade, fantasmas enrolam-se em um Lençol. Este é um jeito de assustar aventureiros perdidos.",ep:14,g:430,l:65,wd:true,fm:true,w:1,p:1000};
I.u[2278] = {n:"Tecido Invisível",t:55,d:"Este tecido pertenceu a Harry Taupeur, um caçador de toupeiras. Ele se enrolava para capturar as toupeiras e evitar que elas escavassem seu jardim. O carismático Capitão Chafer pegou o tecido antes de desaparecer em circunstâncias estranhas...",ep:1,g:431,l:23,wd:true,fm:true,w:1,p:1};
I.u[2279] = {n:"Dente Pontudo",t:47,d:"Este dente pertencia a um Vampiro. Não pode ser de outro monstro. Pode-se perceber isso através da ponta extremamente afiada do dente.",ep:3,g:432,l:15,wd:true,fm:true,w:1,p:1};
I.u[2280] = {n:"Vampiro",t:15,d:"Nunca subestime um Vampiro, especialmente quando ele estiver segurando um canudo, ele pode chupar seu sangue até secá-lo.",ep:3,g:433,l:22,wd:true,fm:true,w:1,p:1};
I.u[2281] = {n:"Tecido de Sangue",t:55,d:"Este pano parece que está vivo;\r\n            Vampiros freqüentemente o usam para fazer belas fantasias para o baile de fantasias.",ep:3,g:434,l:15,wd:true,fm:true,w:1,p:1};
I.u[2282] = {n:"Tufo de Cabelos Brancos",t:15,d:"Aqui está a prova de que alguns monstros têm preocupações.",ep:1,g:435,l:24,wd:true,fm:true,w:1,p:1};
I.u[2283] = {n:"Olho de Kwoan",t:109,d:"Este Olho de Kwoan tem surpreendentes efeitos hipnóticos. Tente manter a cabeça tranqüila enquanto o usa.",ep:3,g:436,l:8,wd:true,fm:true,w:1,p:1};
I.u[2284] = {n:"Nota de Harry Stote",t:24,d:"A entrada para a lendária caverna de larva dourada está situada um pouco a oeste de Amakna. Os poderes latentes de sua larva dourada permitirão que você entre na caverna. Mas certifique-se de não machucá-la ou ela voltará para os braços do pai.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2285] = {n:"Tecido das Sombras",t:55,d:"Uma certeza absoluta sobre este pano é que ele é sarnento. É bastante compreensível quando você sabe que um Ouginak costumava usá-lo como lenço.",ep:3,g:437,l:50,wd:true,fm:true,w:1,p:1};
I.u[2286] = {n:"Bandagens",t:15,d:"Estas bandagens são revolucionárias: espessura tripla, ultra-resistência e perfumada com violeta. É realmente um produto de alta qualidade.",ep:2,g:438,l:51,wd:true,fm:true,w:1,p:1};
I.u[2287] = {n:"Couro Preto",t:56,d:"Este couro já é tratado. Sua origem permanece desconhecida, mas a cor provavelmente vem de uma tintura especial.",ep:1,g:439,l:74,wd:true,fm:true,w:1,p:1};
I.u[2288] = {n:"Pata de Wabbit",t:103,d:"Muitos turistas vêm à Ilha Wabbit especialmente para achar uma Pata de Wabbit que supostamente dá sorte. Infelizmente não é verdade, mas ela sustenta o turismo da ilha.",ep:8,g:440,l:18,wd:true,fm:true,w:1,p:1};
I.u[2290] = {n:"Carapaça de Scarador Branco",t:107,d:"Você pode ter um belo abajur em casa. A propósito, esta carapaça deve ter outro uso... ou pelo menos achamos que sim.",ep:3,g:441,l:32,wd:true,fm:true,w:1,p:1};
I.u[2291] = {n:"Escaraconha Azul",t:107,d:"Você pode facilmente ter um belo abajur em casa. A propósito, esta concha deve ter outra utilidade... nós esperamos que tenha...",ep:3,g:442,l:32,wd:true,fm:true,w:1,p:1};
I.u[2292] = {n:"Concha de Escarafolha Vermelha",t:107,d:"Você pode facilmente ter um belo abajur em casa. Mas esta concha certamente tem outro uso... bem, vamos esperar!",ep:3,g:443,l:32,wd:true,fm:true,w:1,p:1};
I.u[2293] = {n:"Concha de Escarafolha Verde",t:107,d:"Você pode facilmente ter um belo abajur em casa. A propósito, esta concha deve ter outro uso... bem, espero que...",ep:3,g:444,l:32,wd:true,fm:true,w:1,p:1};
I.u[2294] = {n:"Intestino de Escarafolhas",t:15,d:"À primeira vista, estes intestinos não dão água na boca. Entretanto, se você cortar bem fininho, molhá-los com limão e esquentar em uma frigideira, será um prato digno de gastrônomos.",ep:3,g:445,l:32,wd:true,fm:true,w:1,p:1};
I.u[2295] = {n:"Fragmento de Espada de Réptil",t:15,d:"Com este Fragmento de Espada sobre a lareira, você tem ao menos um bom motivo para exibir-se. Você derrotou o Crocodyl apesar de tudo, como o excêntrico Mikool J, também conhecido como Crocodyl Dandi, fez antes de você.",ep:4,g:446,l:69,wd:true,fm:true,w:10,p:1};
I.u[2296] = {n:"Escudo de Réptil",t:15,d:"Como você pode usar este velho escudo decorado com pedras preciosas? Enquanto você tenta encontrar a resposta, pode usá-lo como uma bandeja de chá para seus amigos.",ep:4,g:447,l:69,wd:true,fm:true,w:15,p:1};
I.u[2297] = {n:"Flecha de Arco",t:15,d:"Esta Flecha pode ser usada para fazer uma arma pequena, porém afiada. Também pode servir como um palito de dente, depende de você.",ep:1,g:125,l:34,wd:true,fm:true,w:1,p:1};
I.u[2298] = {n:"Rabo de Demônio",t:65,d:"Você puxou o demônio pelo rabo, o que deve ser muito desagradável.",ep:0,g:448,l:1,wd:true,fm:true,w:1,p:1};
I.u[2299] = {n:"Epaulette de Dark Vlad",t:15,d:"Esta dragona certamente suportou muitas batalhas. Ainda que ela não pareça ser muito resistente, é melhor não bater no ombro do Vlad das Sombras se você estiver preso à sua arma.",ep:2,g:449,l:120,wd:true,fm:true,w:5,p:80};
I.u[2300] = {n:"Fragmento de Osso",t:47,d:"Este Fragmento de Osso pode vir dos restos de um Chafer ou dos restos da comida de um Moolobo. Mas talvez este não tenha nada a ver com nenhum dos dois.",ep:9,g:450,l:43,wd:true,fm:true,w:1,p:1};
I.u[2301] = {n:"Bigodes de Kolerato",t:15,d:"Não muito resistentes, os bigodes de Kolerat permitem que você se exiba para seus amigos...",ep:2,g:451,l:9,wd:true,fm:true,w:1,p:1};
I.u[2302] = {n:"Língua de Caranguejo",t:15,d:"Os inteligentes pensadores de Amakna ainda estão se perguntando qual o uso que os caranguejos podem possivelmente fazer da língua deles. Eles ficariam chocados se soubessem.",ep:1,g:452,l:4,wd:true,fm:true,w:1,p:1};
I.u[2303] = {n:"Concha de Caranguejo Vazia",t:107,d:"Uma vez vazia, esta carapaça de caranguejo pode armazenar muitos itens diferentes. Entretanto, os tais itens cheirarão indefinidamente a caranguejo, o que pode ser mais ou menos perturbador.",ep:1,g:453,l:4,wd:true,fm:true,w:2,p:1};
I.u[2304] = {n:"Fragmento de Pedra Polida",t:51,d:"Este fragmento vem da nádega esquerda de um Crackler das Planícies. É ideal para esmagar um aracnídeo.",ep:5,g:454,l:45,wd:true,fm:true,w:5,p:1};
I.u[2305] = {n:"Fragmento de Pedra Pontuda",t:51,d:"Este fragmento vem da omoplata direita de um Crackler das Planícies. Ou talvez seja uma parte do abdômen inferior. De qualquer jeito, apenas tenha cuidado com o lugar em que o coloca.",ep:5,g:455,l:45,wd:true,fm:true,w:5,p:1};
I.u[2306] = {n:"Coração de Crackler",t:51,d:"Coração de pedra, você não vê o amor que sinto por você? Mas se você continuar, eu o deixarei completamente só, eu me permitirei ficar exausta não deixarei eu mesmo estar exausto por você.",ep:5,g:456,l:45,wd:true,fm:true,w:5,p:1};
I.u[2307] = {n:"Escudo do Lançador Chafer",t:24,d:"...",ep:2,g:75,l:1,wd:true,fm:true,w:0,p:1};
I.u[2308] = {n:"Crachá de Brakmar",t:24,d:"Este crachá permite a identificação de guerreiros que morreram no campo de batalha. Aparentemente algumas pessoas em Bonta os colecionam.",ep:2,g:76,l:1,wd:true,fm:true,w:0,p:1};
I.u[2309] = {n:"Vela Vermelha",t:24,d:"Esta vela vermelha não é como as outras...",ep:1,g:77,l:1,wd:true,fm:true,w:0,p:1};
I.u[2310] = {n:"Vela Verde",t:24,d:"...",ep:2,g:78,l:1,wd:true,fm:true,w:0,p:1};
I.u[2311] = {n:"Vela Azul",t:24,d:"...",ep:2,g:79,l:1,wd:true,fm:true,w:0,p:1};
I.u[2312] = {n:"Pó de Sangue",t:24,d:"...",ep:2,g:80,l:1,wd:true,fm:true,w:0,p:1};
I.u[2313] = {n:"Respirador Aquático",t:24,d:"...",ep:2,g:81,l:1,wd:true,fm:true,w:0,p:1};
I.u[2314] = {n:"Frasco de Jiva",t:24,d:"...",ep:2,g:82,l:1,wd:true,fm:true,w:0,p:1};
I.u[2315] = {n:"Pele Branca",t:54,d:"Broujitte Fardot antigamente tinha feito uma proibição de abater Lupis Brancos filhotes. Mas depois que entrou em exilo, a vida voltou ao normal e os alfaiates resumiram suas atividades à custa destas pobres criaturas.",ep:1,g:196,l:19,wd:true,fm:true,w:1,p:1};
I.u[2316] = {n:"Presa Amarela",t:47,d:"A Presa Amarela do Lupis Albino amedronta muitos aventureiros, principalmente pelo seu poder inestimável.",ep:1,g:458,l:19,wd:true,fm:true,w:1,p:1};
I.u[2317] = {n:"Orelhas de Lobo",t:106,d:"Quando se pára para ver o que tem dentro da orelha do Lupis Albino se notam vários insetos e porcarias, daí você se pergunta como é que ele consegue ouvir.",ep:1,g:459,l:19,wd:true,fm:true,w:1,p:1};
I.u[2318] = {n:"Pata de Urso",t:103,d:"Alguns Gobelins usam uma pata de Urso ao redor de seu pescoço. Ninguém recorda a origem e o significado desta superstição.",ep:1,g:460,l:12,wd:true,fm:true,w:1,p:1};
I.u[2319] = {n:"Cauda Espessa Branca",t:65,d:"Só desta vez, esta cauda não tem nada de estranho, talvez pelo fato de ninguém saber de onde ele veio. Talvez veio de um monstro com uma Cauda Espessa Branca, mas mesmo os especialistas não sabem o bastante para arriscarem um palpite.",ep:0,g:461,l:40,wd:true,fm:true,w:1,p:1};
I.u[2320] = {n:"Colar de Ouginak",t:15,d:"Esse colar lhe concede informações sobre o Ouginak. Há uma mensagem nele: “Estou perdido, minha moradia fica situada no caminho das Terras de Sidimotes, obrigado por me trazer de volta aos meus mestres Brakmarianos, você será recompensado”.",ep:14,g:462,l:51,wd:true,fm:true,w:5,p:1};
I.u[2321] = {n:"Mandíbula de Ouginak",t:15,d:"Passou pela sua cabeça que essa Mandíbula de Ouginak poderia salivar infinitamente? Bem, a parte assustadora é que ela provavelmente pode, já que os Ouginaks são bem conhecidos por sua gula incessante.",ep:14,g:463,l:51,wd:true,fm:true,w:1,p:1};
I.u[2322] = {n:"Dente de Rato",t:47,d:"Não entenda errado, estes pequenos dentes são afiados e fedorentos. São usados para substituir os dentes de ouro do Enutrof, que são muito mesquinhos.",ep:1,g:464,l:50,wd:true,fm:true,w:1,p:1};
I.u[2323] = {n:"Espinha",t:47,d:"Uma Espinha de boa qualidade. Evite torcer suas costas de qualquer forma.",ep:1,g:465,l:34,wd:true,fm:true,w:2,p:1};
I.u[2324] = {n:"Melancia",t:46,d:"...",ep:1,g:466,l:1,wd:true,fm:true,w:2,p:1};
I.u[2325] = {n:"Banana",t:46,d:"O famoso trovador KenLee Rodgers compôs, certa vez, uma ode para esta fruta: “Compre-me uma Banana”.",ep:1,g:467,l:1,wd:true,fm:true,w:1,p:1};
I.u[2326] = {n:"Laranja",t:46,d:"...",ep:1,g:468,l:1,wd:true,fm:true,w:1,p:1};
I.u[2327] = {n:"Maçã",t:46,d:"...",ep:1,g:469,l:1,wd:true,fm:true,w:1,p:1};
I.u[2328] = {n:"Pequena Pérola Dourada",t:15,d:"Esta pérola dourada é um presente da pequena larva que você acompanhou. Conseqüentemente, ela tem um grande valor sentimental... e monetário. Sua suavidade e cor a tornam um presente perfeito para qualquer pessoa que seja um pouco feminina.",ep:5,g:483,l:1,wd:true,fm:true,w:1,p:1};
