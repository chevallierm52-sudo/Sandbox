I.u[2330] = {n:"Cápsula Explosiva",t:15,d:"Esta cápsula contém extratos de frutas cítricas mágicas. É aconselhado agitá-la antes de abrir, de forma que a polpa não permaneça no fundo.",ep:4,g:711,l:23,wd:true,fm:true,w:1,p:1};
I.u[2331] = {n:"Berinjela",t:46,d:"Este não é um legume muito nutritivo e alguns comem isto com vários condimentos para deixá-lo um pouco mais saboroso. A berinjela tem uma reputação ruim, porém, é muito benéfica para você, exceto para Bworks, mas ninguém sabe o porquê.",ep:1,g:472,l:1,wd:true,fm:true,w:1,p:10};
I.u[2332] = {n:"Bala de Consolação",t:42,d:"Este doce parece ter passado do prazo de validade, ou foi deixado em um armário junto com uma lata aberta de ração para Miau, já que tem um sabor bem... Diferente.\nComê-la pode fazer você parar de chorar, pelo menos por alguns minutos.",ep:13,g:135,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2333] = {n:"Bombom Vermelho Possante",t:42,d:"Este bombom aumentará sua atenção durante lutas mas não é muito bom. (CLIQUE DUAS VEZES PARA USÁ-LO, bônus: 20 de Sabedoria e 10 de Percepção usável para as próximas 30 lutas).",ep:1,g:136,l:1,wd:true,fm:false,w:1,c:"PO!1723",u:true,p:1};
I.u[2334] = {n:"Doce de Geléia-Azul-Saborosa",t:42,d:"Este pequeno doce contém o friozinho refrescante da Geléia Azul. Essencial para quem tem um bafo de Bwork.",ep:0,g:137,l:1,wd:true,fm:true,w:1,u:true,p:1};
