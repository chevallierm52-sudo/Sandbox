I.u[2139] = {n:"Lista de Danathor",t:24,d:"‘-3 pedaços de Maçã Blop\n-1 tigela\n-2 cerejas\'",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2140] = {n:"Envelope",t:24,d:"...",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2141] = {n:"Pulmão das Planícies",t:24,d:"Um grande diamante verde decora este colar. Ele é tão brilhante que geralmente as pessoas se focalizam mais no diamante do que no próprio portador... Ele pode ser útil em algumas situações.",ep:1,g:66,l:1,wd:true,fm:true,w:0,p:1};
I.u[2143] = {n:"Chave `SRVT:MERCENARY_SHORT_NAME`",t:15,d:"Você poderá entrar nesta casa somente com a chave do `SRVT:MERCENARY_SHORT_NAME`.",ep:1,g:404,l:1,wd:true,fm:true,w:0,p:1};
I.u[2144] = {n:"Fedorat Padrão",t:24,d:"É um Fedorat padrão, mas, ao menos, protege os usuários do sol.",ep:2,g:68,l:1,wd:false,fm:true,w:0,p:1};
I.u[2145] = {n:"Broche de Sbab",t:24,d:"Sbab tinha lhe dado este pequeno broche como sinal de respeito por sua honra de demônio.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2146] = {n:"Confissão de Oni Tnec",t:24,d:"Oni Tnec descreve, em sua confissão, o modo cruel como ele matou Rimaraf.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2147] = {n:"Veneno de Escorpião",t:24,d:"Um pouco de veneno de Escorpião. A nota para a entrega está endereçada a Oni Tnec.",ep:2,g:39,l:1,wd:true,fm:true,w:0,p:1};
I.u[2148] = {n:"Relatório de Investigação",t:24,d:"Um relatório de investigação que revela os erros estúpidos de Oni Tnec.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2149] = {n:"Crachá de Oni Tnec",t:24,d:"Crachá do Oni Tnec, encontrado na casa de Rimaraf.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2150] = {n:"Sementes de Escorpião",t:58,d:"Estas sementes foram preparadas com veneno de Escorpião. Os efeitos deste veneno letal são exponenciais, de acordo com a dose que você toma...",ep:14,g:405,l:36,wd:true,fm:true,w:1,p:1};
I.u[2151] = {n:"Bolo de Blop Envenenado",t:33,d:"Este bolo é muito bom quando ninguém coloca sementes de Escorpião nele...",ep:3,g:406,l:30,wd:true,fm:true,w:5,p:1};
I.u[2152] = {n:"Coronel Lyeno",t:32,d:"Traga o Coronel Lyeno para Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
