I.u[2339] = {n:"Lista de Equipamentos Padrões",t:24,d:"Um guerreiro de nível médio deve usar qualquer coisa, exceto roupas de farrapos e muito exuberantes. Conseqüentemente, ele precisa:\n- Um monocromo no dedo médio\n- Uma bandana e um Cinto de Vitalidade\n- Botas de Kluh\n- Um manto brakmariano.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
