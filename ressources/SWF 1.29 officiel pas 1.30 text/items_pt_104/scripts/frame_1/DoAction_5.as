I.u[2070] = {n:"Shako",t:16,d:"Este capacete de osso ficou por um longo tempo no bolso de um Kanigrou. Usado e arranhado como parece estar, ele ainda tem boas características.",ep:9,g:58,l:34,wd:true,fm:true,w:15,p:3200};
I.u[2071] = {n:"Poção do Esquecimento: ‘Liberação\'",t:43,d:"Esta poção permite ao seu consumidor desaprender um nível do feitiço elementar: \'Liberação\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2072] = {n:"Poção do Esquecimento: ‘Fulminante\'",t:43,d:"Com esta poção, você pode desaprender um nível do feitiço elementar: \'Fulminante\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[2073] = {n:"Poção do Esquecimento: ‘\'Estraçalhar\'",t:43,d:"Esta poção lhe permite desprender um nível do feitiço especial: \'Estraçalhar\'.",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2074] = {n:"Bwak do Fogo",t:18,d:"Este pequeno Bwak fofinho se tornará um Kwak feio. Até lá, não há motivo para ter medo, então mantenha-o com você.",ep:1,g:3,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:2,p:1};
I.u[2075] = {n:"Bwak Água",t:18,d:"Este pequeno e gracioso Bwark vai, mais tarde, tornar-se um feio Kwak. Nenhuma razão para ter medo até então, mas mantenha-o perto de você.",ep:1,g:2,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:13,p:1};
I.u[2076] = {n:"Bwak de Ar",t:18,d:"Este pequeno Bwak fofinho se tornará um Kwak feio. Até lá, não há motivo para ter medo, então mantenha-o com você.",ep:1,g:4,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:15,p:1};
I.u[2077] = {n:"Bwak da Terra",t:18,d:"Este pequeno Bwak fofinho se tornará um Kwak feio. Até lá, não há motivo para ter medo, então mantenha-o com você.",ep:1,g:5,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:14,p:1};
I.u[2078] = {n:"Testamento de Ixa Mustam",t:24,d:"Este é o testamento do pai de Oto Mustam, foi escrito em brakmariano antigo. É uma pena que seu conhecimento sobre esta linguagem resume-se a uma única palavra \"Guo\'rhalys !\" .",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2079] = {n:"Vinho de Greedovore",t:24,d:"Parece que você precisará de 20 anos para destilar direito Suco de Greedovore. Ou então você fará vinho tóxico.",ep:2,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[2080] = {n:"Suco de Greedovore",t:24,d:"Suco de Greedovore é tão tóxico quanto suco de Escorpião, mas bem destilado, ganha um incomparável sabor assim como o vinho. Mas apenas algumas poucas pessoas podem destilar este suco e na maior parte das vezes são piratas.",ep:2,g:63,l:1,wd:true,fm:true,w:1,p:1};
I.u[2081] = {n:"Relatório de Finche Aticus",t:24,d:"Este relatório escrito pelo espião Finche Aticus descreve uma exaustiva lista das armas e o número exato de lutadores em Bonta.",ep:2,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[2082] = {n:"Javalizinho",t:32,d:"Quando um Javalizinho fica orfão, ele segue qualquer pessoa e implora para que o adotem.",ep:13,g:1,l:1,wd:true,fm:true,w:0,m:true,p:10};
I.u[2083] = {n:"Carta de Oto Mustam",t:24,d:"Uma carta do seu mestre endereçada a Vil Smisse. Foi escrita em um dialeto desconhecido, para evitar que bisbilhoteiros como você a leiam.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2084] = {n:"Resposta de Vil Smisse",t:24,d:"Esta é a resposta de Vil Smisse a Oto Mustam, não se preocupe, é totalmente incompreensível para meros mortais.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2085] = {n:"Energético da Taverna de Kikim",t:37,d:"Não é apenas sem gosto, mas também é excessivamente caro.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2086] = {n:"Energético de Alakarte",t:37,d:"Este energético aromatizado com cereja de Morello Blop é, às vezes, chamado de Manoca.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,p:3};
I.u[2087] = {n:"Energético da Taverna Bagrutte",t:37,d:"Este energético o faz ficar mais valente por um momento... mas tenha cuidado, quanto mais valente, maior o tombo!",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2088] = {n:"Caneca de Madeira de Energético",t:37,d:"É um energético clássico, mas a caneca é muito bem esculpida. Por sua vez, o recipiente tem mais valor e importância do que o conteúdo, de acordo com a imprensa popular e o Crânio dos Iops.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2089] = {n:"Energético Pinchaut",t:37,d:"Este energético é quente, o que o torna difícil de se beber no verão. Por outro lado, ele exala um prazeroso cheiro de pão torrado, ideal para se beber no café da manhã quando não há pão.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2090] = {n:"Energético da Taverna do Fanfarrão",t:37,d:"Este energético tem gosto de ferro-velho, o que é tão desagradável quanto revitalizante.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:7};
I.u[2091] = {n:"Cuidando de seu Bwak",t:25,d:"Este Livro explica como criar um Bwak.",ep:3,g:4,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2092] = {n:"Cuidando de seu Miau",t:25,d:"Este Livro explica como criar um Miau.",ep:3,g:3,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2093] = {n:"Cuidando de seu Wabbit",t:25,d:"Este Livro explica como criar um Wabbit.",ep:3,g:5,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2094] = {n:"Makroute Sombra",t:16,d:"O Makroute Sombra é um chapéu criado de um Makroute Mutilado cozido sem anestesia. Agora, seu mestre é a única pessoa a quem ele obedece e é realmente agressivo com estranhos.",ep:14,g:33,l:50,wd:true,fm:true,w:5,p:6600};
I.u[2095] = {n:"O Urso",t:16,d:"O Urso é um chapéu feito de uma cabeça de um urso morto. Seu pêlo ainda está sedoso. O alfaiate que fez isto devia ser muito habilidoso para ter conseguido manter o olhar de descontentamento no rosto do urso morto.",ep:14,g:34,l:35,wd:true,fm:true,w:5,p:10000};
I.u[2096] = {n:"Linegg de Brave",t:16,d:"Brave, o fantasma, foi o primeiro a entender como usar Wickerin Escuro em outros campos além da gastronomia.",ep:14,g:35,l:37,wd:true,fm:true,w:5,p:3800};
I.u[2097] = {n:"Champo",t:16,d:"O Champo pertenceu a um dos maiores Mestres Fungi de Amakna. Corajoso e brilhante, Gnion, o Boleto, foi o único de sua raça a ser respeitado pelos seres humanos.",ep:1,g:36,l:43,wd:true,fm:true,w:25,p:5000};
I.u[2098] = {n:"Certificado do Canil: Earth Bwak",t:77,d:"Este certificado menciona as características do Bwak da Terra que você pôs no Canil.",ep:3,g:21,l:1,wd:false,fm:true,w:1,p:100};
I.u[2099] = {n:"Certificado do Canil: Bwak de Fogo",t:77,d:"Este certificado menciona as características do Bwak do Fogo que você pôs no Canil.",ep:3,g:23,l:1,wd:false,fm:true,w:1,p:100};
I.u[2100] = {n:"Certificado do Canil: Bwak de Água",t:77,d:"Este certificado menciona as características do Bwak da Água que você pôs no Canil.",ep:3,g:22,l:1,wd:false,fm:true,w:1,p:100};
I.u[2101] = {n:"Certificado de Entrada no Canil: Bwak do Ar",t:77,d:"Este certificado descreve todas as características do Bwak do Ar que você pôs nos Canis de Arco.",ep:3,g:20,l:1,wd:false,fm:true,w:1,p:100};
I.u[2102] = {n:"Certificado do Canil: Wabbit",t:77,d:"Este certificado menciona as características do wabbit que você pôs no Canil.",ep:3,g:25,l:1,wd:false,fm:true,w:1,p:100};
I.u[2103] = {n:"Formulário de Welloy Cab",t:24,d:"Escrito por Welloy Cab, este relatório encantará todos os amantes de números e sentenças que não querem dizer nada.",ep:1,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2104] = {n:"Daudgee",t:16,d:"O Daudgee é um Capacete perturbador, feito de todos os tipos de restos e lixos. Usado por Gourlo, O Terrível, o Daudgee era a representação da desolação.",ep:14,g:37,l:48,wd:true,fm:true,w:30,p:6000};
I.u[2105] = {n:"Formulário de Relatório em Branco",t:24,d:"Formulário de relatório sem qualquer anotação.\nPronto ser preenchido pelo Táxi de Welloy.",ep:1,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2106] = {n:"Lista de Iscas para Pescadores",t:24,d:"Você precisa conseguir iscas o mais rápido possível.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2107] = {n:"Iscas Especiais",t:24,d:"Esta caixa de iscas especiais parece uma caixa ordinária de KittyCare.",ep:1,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[2108] = {n:"Crachá de Tabach",t:24,d:"O Crachá de Tabach, o Balconista da Ordem do Coração Valente.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2109] = {n:"Distintivo de Ybaul",t:24,d:"O Crachá de Ybaul, a Balconista da Ordem do Espírito Salvador.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2110] = {n:"Crachá de Aigurraf",t:24,d:"O Crachá de Aigurraf, o Clérigo da Ordem do Olho Observador.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2111] = {n:"A Alma do Pescador",t:25,d:"Este livro lhe ensinará os truques para se tornar um bom pescador.",ep:2,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2112] = {n:"A Alma do Caçador",t:25,d:"Este livro lhe ensinará os truques para se tornar um bom caçador.",ep:3,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2114] = {n:"Alimento Desconhecido",t:15,d:"Alimento desconhecido.",ep:1,g:0,l:1,wd:true,fm:true,w:10,p:1};
I.u[2116] = {n:"Receita de Nocabregor",t:24,d:"Como fazer pó de Nocabregor. Ingredientes: 3 medidas de Cura Mágica e 1 medida de Graxa de Cotovelo. Apenas um pirotécnico ou um encantador podem fazer esta receita usando um pouco de Sílex.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2117] = {n:"Dente de Lupis Claro Furioso",t:24,d:"Este dente foi corajosamente extraído de um lobo raivoso.",ep:2,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2118] = {n:"Manto de Brakmar",t:17,d:"Este manto lhe permite permanecer incógnito em um cemitério, ou se transformar em uma Chafera, quando você se sentir extremamente perverso.",ep:1,g:20,l:1,wd:true,fm:true,w:7,c:"Ps=2",p:800};
I.u[2119] = {n:"Capa Bontariana",t:17,d:"Este manto lhe dá asas. A fumaça que ele emitirá quando você o queimar, certamente o deixará alto.",ep:5,g:34,l:1,wd:true,fm:true,w:3,c:"Ps=1",p:800};
I.u[2120] = {n:"Palavras de Ixa Mustam",t:24,d:"‘Meu testamento está perto do Farol de Amakna, equipe-se com uma Pá Twiggy Pequena para desenterrar. E dê parte sobre isso ao meu filho\'.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2121] = {n:"Palavras de Tsog",t:24,d:"‘Escondi o tesouro no Litoral do Leste de Sufokia, dentro de um túnel, sob barris de vinho. Aconselho que, antes de ir, se equipar com uma Pá Twiggy Pequena para desenterrar.\'",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2122] = {n:"Convite para Cerimônia",t:24,d:"Esta carta está selada e deve ser bem indelicado abri-la.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2123] = {n:"Receita de Sonacixem",t:24,d:"Uma receita para facilmente criar Sonacixem, uma poção mágica mortal como parece ser.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2124] = {n:"Formulário de Inspeção Preenchido",t:24,d:"Um formulário de inspeção n° 243 preenchido por Leonzi Trool. À primeira vista, ele não tomou parte disto...",ep:2,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2127] = {n:"Carta de Zeurg",t:24,d:"Esta carta indica um feitiço capaz de destruir Holbaids.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2128] = {n:"Percepção",t:31,d:"Você terá uma melhor percepção até a próxima luta.",ep:6,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2129] = {n:"Tufo de Cabelos de Dike Tarak",t:24,d:"Este tufo de cabelos prova que você realmente maltratou Dike Tarak.",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2130] = {n:"Coronel Lyeno",t:32,d:"Escolte o Coronel Lyeno até um mago do calabouço para remover o encanto conjurado pelo Carvalho Mole.",ep:9,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2131] = {n:"Decreto da taxa 51-11b",t:24,d:"Esta carta insolente diz que todos os donos de bebidas energéticas devem pagar um imposto aos soldados. Sob o pretexto de pausa compulsória.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2132] = {n:"Atall Tramston",t:32,d:"Escolte Atall Tramston para fora da prisão de Brakmar e traga-o para Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2133] = {n:"Cheque da Taverna do Gato Chamuscado",t:24,d:"Este cheque cobre o novo imposto nas tavernas, anunciado por Oto Mustam.",ep:2,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2134] = {n:"Gnort Stonma",t:32,d:"Escolte Gnort Stonma para fora da prisão de Bonta e traga-o para Oto Mustam.",ep:16,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
