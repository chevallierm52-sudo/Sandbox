I.u[1610] = {n:"Casca de Treechnid das Sombras",t:96,d:"Esta casca vem do cadáver de um Treechnid das Sombras.",ep:9,g:231,l:78,wd:true,fm:true,w:1,p:50};
I.u[1611] = {n:"Botão de Treechnid das Sombras",t:108,d:"Este broto vem do cadáver de um Treechnid das Sombras.",ep:9,g:230,l:78,wd:true,fm:true,w:1,p:50};
I.u[1612] = {n:"Raiz de Treechnid das Sombras",t:98,d:"Esta raiz vem do cadáver de um Treechnid das Sombras.",ep:9,g:232,l:78,wd:true,fm:true,w:1,p:50};
I.u[1613] = {n:"Escama do Chefe Crocodyl",t:59,d:"Este fragmento de carapaça certamente será usado para fazer belas botas.",ep:4,g:547,l:69,wd:true,fm:true,w:5,p:100};
I.u[1614] = {n:"Dentes de Chefe Crocodyl",t:47,d:"Estes dentes extraídos com dificuldade da mandíbula de um Crocodyl devem ser úteis de alguma maneira...",ep:4,g:548,l:69,wd:true,fm:true,w:1,p:100};
I.u[1619] = {n:"O Treemu",t:1,d:"O Treemu é um tipo de amuleto refinado. Um pequeno conselho se você pretende usá-lo: dê um pequeno passeio tão nu quanto no dia em que você nasceu para realçar sua preciosa jóia. As damas adorarão, sem sombra de dúvida...",ep:9,g:16,l:46,wd:true,fm:true,w:2,p:5700};
I.u[1620] = {n:"Treearco",t:2,d:"Este arco parece estar vivo e quase pode atirar flechas sozinho como um rapazinho. Pode ser o arco perfeito para as pessoas que são desajeitadas com as mãos mas, infelizmente, a flecha sempre tem que ser encaixada do jeito certo.",ep:9,g:24,l:39,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,50,30,false,true],p:4200};
I.u[1621] = {n:"Botas de Perícia",t:11,d:"As Botas de Perícia aumentam a agilidade e a inteligência do usuário, em detrimento da força e da sorte. Ao contrário do que as pessoas acreditam, elas não permitem que você submeta o seu oponente.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1622] = {n:"Botas de Poder",t:11,d:"Essas botas de poder aumentam a força do portador e a chance, mas diminuem a inteligência e a agilidade. Ao contrário do que as pessoas acreditam, elas não podem dar um poder incrível.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1623] = {n:"Botas de Antecipação",t:11,d:"Estas botas de Antecipação aumentam a sua força e agilidade em detrimento da inteligência e sorte. Ao contrário do que a maioria das pessoas acredita, estas botas não permitem antecipar os movimentos dos seus inimigos.",ep:4,g:15,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1624] = {n:"Botas de Nexus",t:11,d:"Estas botas pertenceram a Nexus, um grande cavaleiro congelado pela eternidade.",ep:3,g:16,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1625] = {n:"A Lenda do Moedor",t:25,d:"Este livro relata a jornada do último Humano que precisou encontrar o Triturador.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1626] = {n:"Enciclopédia de Alquimia###Anexo A: Profissões",t:25,d:"Esta enciclopédia reúne receitas de alquimia que são úteis para esquecer profissões.",ep:1,g:2,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1628] = {n:"Artefato do Fogo",t:9,d:"A história deste artefato vem de uma lenda muito antiga. Mas, hoje em dia, seu verdadeiro poder ainda é desconhecido.",ep:1,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1629] = {n:"Artefato da Terra",t:9,d:"A história deste artefato vem de uma lenda muito antiga, mas, hoje em dia, seu verdadeiro poder ainda é desconhecido.",ep:1,g:19,l:1,wd:true,fm:true,w:10,p:1};
I.u[1630] = {n:"Artefato de Ar",t:9,d:"A história deste artefato provém de uma lenda muito antiga, mas seu verdadeiro poder ainda é desconhecido.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[1631] = {n:"Artefato Água",t:9,d:"A história deste artefato vem de uma lenda muito antiga. Mas, hoje em dia, seu poder real é ainda desconhecido.",ep:1,g:21,l:1,wd:true,fm:true,w:10,p:1};
I.u[1632] = {n:"Artefato Luminoso",t:9,d:"A história deste artefato vem de uma lenda muito antiga. Mas, atualmente, seu poder real é ainda desconhecido.",ep:1,g:22,l:1,wd:true,fm:true,w:10,p:1};
I.u[1633] = {n:"Artefato de Vida",t:9,d:"A história deste artefato vem de uma lenda muito antiga. Mas, atualmente, seu poder real é ainda desconhecido.",ep:1,g:23,l:1,wd:true,fm:true,w:1,p:1};
I.u[1634] = {n:"Esfera para Metarias",t:66,d:"Esta esfera é uma imitação perfeita da membrana isolante de uma metaria.",ep:9,g:240,l:1,wd:true,fm:true,w:1,p:100};
I.u[1635] = {n:"Pergaminho de \'Vento do Pânico\'",t:25,d:"(Clique duas vezes para aprender essa emoção)\nCom esse pergaminho você pode aprender como \"Quebrar o Vento\". Use com moderação já que ele pode ser perigoso para você e seus amigos.",ep:4,g:9,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[1636] = {n:"Pequena Estrela Noturna",t:6,d:"Esta espada foi criada pela glamourosa menina que queria fazer dela sua própria imagem;\r\n            com beleza graciosa e natureza apaixonada. O resultado fala por si...",ep:1,g:22,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>35&CV>35&CS>11",p:4000};
I.u[1637] = {n:"Estrela Noturna",t:6,d:"Esta espada foi criada por uma encantadora menina que quis fazê-la à sua própria imagem;\r\n            com uma graciosa beleza e um caráter ardente. O resultado fala por si mesmo...",ep:1,g:22,l:44,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>36&CV>36&CS>12",p:4000};
I.u[1638] = {n:"Estrela Noturna Brilhante",t:6,d:"Esta espada foi criada por uma encantadora menina que quis fazê-la a sua própria imagem;\r\n            com uma graciosa beleza e um caráter ardente. Confira o resultado...",ep:1,g:22,l:48,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>38&CV>38&CS>13",p:4000};
I.u[1639] = {n:"Estrela Noturna Imortal",t:6,d:"Esta espada foi criada por uma encantadora menina que quis fazê-la à sua própria imagem;\r\n            com uma graciosa beleza e um caráter ardente. Confira o resultado...",ep:1,g:22,l:52,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>40&CV>40&CS>15",p:4000};
I.u[1640] = {n:"Pequena Faca de Corte",t:6,d:"Esta espada é absolutamente perfeita para atacar pessoas legais. Rápida, útil e, acima de tudo, extremamente afiada. Portanto, ela foi banida das lojas há muitos anos. Mesmo assim, ela é agora permitida como meio de defesa anti-Bwork.",ep:14,g:23,l:46,wd:true,fm:true,w:12,an:14,e:[5,5,1,1,30,50,false,false],p:5000};
I.u[1641] = {n:"Faca de Corte",t:6,d:"Esta espada é absolutamente perfeita para atacar pessoas agradáveis. Rápida, útil e, acima de tudo, tem a ponta extremamente afiada. Por isso, sua venda foi proibida por muitos anos agora. Hoje, é tolerada como uma defesa anti-Bwork, quer dizer.",ep:14,g:23,l:52,wd:true,fm:true,w:12,an:14,e:[10,5,1,1,30,50,false,false],p:5200};
