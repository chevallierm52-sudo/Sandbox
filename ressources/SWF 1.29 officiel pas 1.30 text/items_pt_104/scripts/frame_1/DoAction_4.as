I.u[1426] = {n:"Cortadora de Thart",t:8,d:"Thart, o criador desta pá, era um discípulo de Iop. Um nome profético para um destes discípulos, não é?",ep:3,g:8,l:24,wd:true,fm:true,w:24,an:16,e:[5,5,1,1,50,50,false,true],p:1800};
I.u[1427] = {n:"Pá Zebuth",t:8,d:"Esta pá é usada pelos Grandes Sacerdotes Kanniball da Ilha da Lua para invocar o Zebuth, um de seus deuses freqüentemente descritos como um bovino. Somente pessoas vis podem usar esta arma.",ep:1,g:40,l:55,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,50,20,false,true],c:"Ps=2&CC>50",p:8000};
I.u[1428] = {n:"Flor Imortal",t:36,d:"Esta estranha plantinha cresce em ambientes áridos e exala um cheiro de caril. Parece que ela pode resistir ao envelhecimento. Se toda mulher conseguisse o mesmo...",ep:2,g:54,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1429] = {n:"Pequena Pá de Mechba",t:8,d:"Esta pá. Criada por Mechba, é usada pelos seguidores de Enutrof para pegarem frutas das árvores. É também uma assustadora arma de batalha.",ep:1,g:19,l:30,wd:true,fm:true,w:15,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>10&CI>10",p:1500};
I.u[1430] = {n:"Pá de Mechba",t:8,d:"Esta pá, criada por Mechba, é usada pelos discípulos de Enutrof para colher frutas das árvores. Também é uma terrível arma de batalha.",ep:1,g:19,l:45,wd:true,fm:true,w:23,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>15&CI>15",p:2300};
I.u[1431] = {n:"Grande Pá de Mechba",t:8,d:"Esta pá, criada por Mechba, é usada por discípulos de Enutrof para colher frutas das árvores. É também uma arma de guerra terrível.",ep:1,g:19,l:60,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>25&CI>25",p:3000};
I.u[1432] = {n:"Pá de Houze",t:8,d:"Gaston Houze, um jardineiro discípulo de Enutrof, fazia grandes amontoados para as plantas. Esta arma é uma boa prova disto;\r\n            poderosa, ela pregará peças em você e aquecerá sua inteligência.",ep:1,g:17,l:21,wd:true,fm:true,w:21,an:16,e:[2,4,1,1,50,50,false,true],c:"CC>27&CW<100&CS>10",p:2100};
I.u[1433] = {n:"Pá de Segurança",t:8,d:"Esta pá foi uma arma de defesa pessoal usada por um grupo pequeno de seguidoras de Enutrof. Uma vez que estas senhoras tinham esse poder em suas mãos, falavam para elas mesmas que a conquista do mundo não era apenas história dos homens.",ep:7,g:4,l:60,wd:true,fm:true,w:30,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>60&CS>30&CA>10",p:6500};
I.u[1434] = {n:"Poção do Esquecimento: \'Relógio\'",t:43,d:"Com esta poção, você pode desaprender um nível do feitiço de Xelor: \'Relógio\'.",ep:1,g:37,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1435] = {n:"A Pá Pesada",t:8,d:"Pá muito pesada. Para aventureiros gor... hum, robustos.",ep:9,g:11,l:80,wd:true,fm:true,w:150,an:16,e:[10,6,1,1,50,50,false,true],c:"CS>100",p:40000};
I.u[1436] = {n:"Pá Ikan",t:8,d:"Ikan era o peixinho de Chourros, o guerreiro. Note que o nome desta pá não tem relação com o peixe e sim com seu cheiro.",ep:7,g:8,l:50,wd:true,fm:true,w:50,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>30&CA>10",p:7800};
I.u[1437] = {n:"Poção do Esquecimento: \'Punição Forçada\'",t:43,d:"Com esta poção, você pode desaprender um nível do feitiço de Sacrier: \'Punição Forçada\'.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1438] = {n:"Boa Sorte",t:21,d:"Esta picareta é considerada um talismã da sorte.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,4,1,1,50,50,false,true],c:"CC>30",p:2500};
I.u[1439] = {n:"Má Sorte",t:21,d:"Esta picareta parece atrair mau-olhado. Entretanto, dizem que não demoraria muito para transformá-la em uma ótima picareta.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,6,1,1,50,10,false,true],p:250};
