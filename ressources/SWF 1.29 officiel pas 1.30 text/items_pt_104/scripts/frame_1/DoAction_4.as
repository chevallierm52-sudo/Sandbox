I.u[1844] = {n:"Truta",t:41,d:"A truta é fácil de se pescar. Os experientes pescadores as pescam de três em três.Eles freqüentemente decidem ao mesmo tempo se elas devem ser consumidas cozidas ou cruas.",ep:1,g:394,l:1,wd:true,fm:true,w:3,p:0};
I.u[1845] = {n:"Truta Estripada",t:62,d:"Esta truta agora pode ser usada como um ingrediente.",ep:1,g:396,l:1,wd:true,fm:true,w:2,p:1};
I.u[1846] = {n:"Truta Ancestral",t:41,d:"Uma das trutas mais antigas do mundo. Se o passar do tempo o deixa mais sábio, esta truta deve ser a mais sábia de todas... Mas algumas pessoas ainda duvidam...",ep:1,g:398,l:1,wd:true,fm:true,w:3,p:1};
I.u[1847] = {n:"Lúcio",t:41,d:"Este Lúcio é um peixe de água doce de tamanho médio. É o amigo de churrasco do pescador.",ep:2,g:400,l:10,wd:true,fm:true,w:3,p:1};
I.u[1848] = {n:"Lúcio Estripado",t:62,d:"Este Lúcio agora pode ser usado como um ingrediente.",ep:2,g:401,l:10,wd:true,fm:true,w:2,p:1};
I.u[1849] = {n:"Lúcio Tupe-Halett",t:41,d:"Esta nova espécie – resultante do cruzamento de vários Lúcios feito pelos cientistas Halett e Tupe – deveria ter propriedades mágicas. Destinados à experimentação, dois espécimes escaparam durante uma violenta discussão entre os dois cientistas.",ep:1,g:402,l:10,wd:true,fm:true,w:3,p:1};
I.u[1851] = {n:"Lúcio Tupe-Halett Estripado",t:62,d:"Este Lúcio Tupe-Halett agora pode ser usado como um ingrediente.",ep:1,g:403,l:10,wd:true,fm:true,w:2,p:1};
I.u[1852] = {n:"Tubarão-Martelo-foice Estripado",t:62,d:"Este tubarão-martelo-foice agora pode ser usado como um ingrediente.",ep:2,g:323,l:80,wd:true,fm:true,w:2,p:1};
I.u[1853] = {n:"Tubarão Mercado-Livre",t:41,d:"Um primo do Tubarão Focinho Cabeça de Martelo, ele é mais feroz e não obedece a nenhum regulamento. Pescar um Tubarão Mercado-Livre é o sonho de todo pescador – mais precisamente, pescar um E mantê-lo vivo.",ep:1,g:324,l:80,wd:true,fm:true,w:4,p:1};
I.u[1854] = {n:"Tubarão de Mercado-livre Estripado",t:62,d:"O tubarão de mercado-livre estripado agora pode ser usado como um ingrediente.",ep:1,g:325,l:80,wd:true,fm:true,w:3,p:1};
I.u[1855] = {n:"Garoupa",t:41,d:"Preguiçoso por natureza, este peixe dorme o tempo inteiro. É difícil pegá-lo nestas condições.",ep:1,g:0,l:1,wd:true,fm:true,w:2,p:1};
I.u[1856] = {n:"Garoupa Estripada",t:62,d:"Esta garoupa agora pode ser usada como um ingrediente.",ep:1,g:0,l:1,wd:true,fm:true,w:2,p:1};
I.u[1859] = {n:"Kralamor ****",t:49,d:"Este Kralamor grelhado exala um bom cheio... uma verdadeira tentação.",ep:1,g:91,l:1,wd:true,fm:true,w:1,c:"Ci<50",u:true,ut:true,p:50000};
I.u[1860] = {n:"Vara de Arpão",t:20,d:"Esta é uma vara de pescar muito resistente, especialmente criada para pegar tubarões, tem um anzol parecido com um arpão.",ep:1,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1861] = {n:"A Grande Vara",t:20,d:"Esta vara de pesca foi especialmente projetada para pescar Perch.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1862] = {n:"Cajado do Amor",t:20,d:"Esta madeira de vara exala um cheio de resina que impregna as iscas e os anzóis. Uma Kralamor tem mais ou menos o mesmo cheiro, o que explica o motivo de os Kralamors irem em direção do seu equipamento de pesca.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1863] = {n:"Vara de Pescar de Cho",t:20,d:"Cho era o cozinheiro mais famoso da mesa redonda. Ele sempre forneceu comida fresca para seus clientes. Esta vara permitiu que ele pegasse o peixe que precisava para seu famoso prato ‘Carpas ao Cho\'.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1864] = {n:"Agulha de Tricô",t:20,d:"A linha desta vara de pescar é exclusivamente composta de lã;\r\n            a isca é substituída por uma bola de lã. Apenas alguns poucos peixes-gato podem resistir a brincar com ela.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1865] = {n:"Vara de Pescar Cúbica",t:20,d:"Esta vara de pescar é especialmente projetada para se ajustar à... ‘exclusiva\' morfologia dos Peixe-pão.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1866] = {n:"Vara de Pescar Padrão",t:20,d:"Esta vara clássica permitirá a um jovem pescador pegar quase tudo desde que ele tenha paciência suficiente.",ep:2,g:8,l:1,wd:true,fm:true,w:3,an:18,e:[1,4,1,3,100,100,false,false],c:"PJ>36,9",p:1000};
I.u[1867] = {n:"Grande Vara de Pesca",t:20,d:"Apenas para os pescadores profissionais. É uma boa ferramenta para lançar a linha muito longe, mas requer certa habilidade para usá-la eficientemente.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,5,100,100,false,false],c:"PJ>36,39",p:2000};
I.u[1868] = {n:"Vara de Pescar Telescópica",t:20,d:"Esta vara de pesca pode alcançar distâncias incríveis. Apenas Pescadores Mestres sabem como usar seu potencial.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,7,100,100,false,false],c:"PJ>36,69",p:4000};
I.u[1869] = {n:"Extrator de Dentes",t:24,d:"Este extrator de dentes é especialmente projetado para Gobballs, mas você também pode usá-lo para extrair um de seus dentes podres... se você o sentir assim.",ep:2,g:34,l:1,wd:true,fm:true,w:0,p:1};
I.u[1870] = {n:"Dente de Gobball",t:24,d:"Este dente de Gobball e um de humano são tão semelhantes que é difícil de distinguir.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[1871] = {n:"Colar",t:24,d:"O colar que a filha do prefeito perdeu, infelizmente, está em um estado ruim desde a sua permanência no estômago de um Corvo...",ep:2,g:36,l:1,wd:true,fm:true,w:0,p:1};
I.u[1872] = {n:"Pólvora",t:24,d:"Pólvora. Há um rótulo com um simples lembrete impresso:\nPólvora + Chama = Explosão",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[1873] = {n:"Bloco de Rocha",t:24,d:"Um bloco de rocha da Planície de Crackler, similar à usada em prédios e fortificações de Bonta.",ep:2,g:38,l:1,wd:true,fm:true,w:0,p:1};
I.u[1874] = {n:"Peçonha de Escorpião",t:24,d:"Um pouco de veneno de Escorpião no qual não deverá cair em mãos estrangeiras.",ep:2,g:39,l:1,wd:true,fm:true,w:2,p:1};
I.u[1875] = {n:"Gadanha do Lorde Corvo",t:24,d:"Por que usar a gadanha para cortar trigo quando você pode usá-la para cortar granito?",ep:2,g:40,l:1,wd:true,fm:true,w:0,p:1};
I.u[1876] = {n:"Formulário de Inspeção",t:24,d:"Este formulário de inspeção do ato brakmariano nº 243 permite que você detecte se um homem faz parte ou não...",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[1877] = {n:"Capuz com Buracos",t:24,d:"O ancião proprietário deste chapéu, provavelmente, levou muitos golpes na cabeça, o que pode acontecer quando alguém se rebela contra a autoridade de Bonta.",ep:1,g:42,l:1,wd:true,fm:true,w:0,p:1};
I.u[1878] = {n:"Carta Especial",t:24,d:"Este card de jogo tem uma aparência particular perto da perfeição. Ele, aparentemente, é um card de colecionador.",ep:2,g:43,l:1,wd:true,fm:true,w:0,p:1};
I.u[1879] = {n:"Caixa de Armas Afiadas",t:24,d:"Uma caixa de armas afiadas repleta com todos os tipos de instrumentos cegos.",ep:2,g:44,l:1,wd:true,fm:true,w:500,p:1};
I.u[1880] = {n:"Lata de Kittycare",t:24,d:"Yum! Que fofo! Seu Kaniger vai ficar feliz!",ep:2,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[1881] = {n:"Lama",t:24,d:"Está feito!",ep:2,g:46,l:1,wd:true,fm:true,w:2,p:1};
I.u[1882] = {n:"Flores de Blop Esmagadas",t:24,d:"Você adquiriu uma polpa muito apetitosa.",ep:2,g:47,l:1,wd:true,fm:true,w:0,p:1};
I.u[1883] = {n:"Colar Reparado",t:24,d:"O colar da filha do prefeito está desaparecido, novinho em folha...",ep:2,g:48,l:1,wd:true,fm:true,w:0,p:1};
