I.u[1455] = {n:"Asa de Escarafolha Azul",t:104,d:"Estas asas de Escarafolha têm propriedades mágicas e são usadas na fabricação de poções do elemento água.",ep:3,g:212,l:32,wd:true,fm:true,w:2,p:100};
I.u[1456] = {n:"Asa de Escarafolha Branco",t:104,d:"Estas asas de Escarafolha têm propriedades mágicas e são usadas no desenvolvimento de poções elementares de ar.",ep:3,g:213,l:32,wd:true,fm:true,w:2,p:100};
I.u[1457] = {n:"Asa de Escarafolha Vermelha",t:104,d:"Estas asas de Escarafolha têm propriedades mágicas e são usadas para fazer poções elementares de fogo.",ep:3,g:214,l:32,wd:true,fm:true,w:2,p:100};
I.u[1458] = {n:"Asa do Escarafolha Verde",t:104,d:"Estas asas de Escarafolha têm propriedades mágicas e são usadas para fazer poções elementares de terra.",ep:3,g:215,l:32,wd:true,fm:true,w:2,p:100};
I.u[1459] = {n:"Tubo Delgado",t:71,d:"Este tubo foi especialmente desenhado para desenrolar facilmente com apenas uma mão.",ep:1,g:55,l:1,wd:true,fm:true,w:1,p:5};
I.u[1460] = {n:"Grande Frasco",t:71,d:"Um frasco especialmente concebido que pode ser aberto sem as mãos.",ep:3,g:56,l:1,wd:true,fm:true,w:1,p:10};
I.u[1461] = {n:"Poção Escaldante",t:15,d:"Este veneno feito de pernas de Aracne fará você perder sua cabeça. Literal e figurativamente você verá, após um período de insanidade, seu crânio explodir devido a uma alta pressão sangüínea.",ep:1,g:189,l:20,wd:true,fm:true,w:1,p:100};
I.u[1462] = {n:"Líquido Vampiresco",t:15,d:"Este líquido é uma mistura de vários sangues, tem o mau hábito de voar direto para a sua garganta.",ep:2,g:188,l:30,wd:true,fm:true,w:1,p:100};
I.u[1463] = {n:"Frasco para Elementos",t:71,d:"Este Frasco é especialmente projetado para aprisionar essências elementares.",ep:1,g:57,l:1,wd:true,fm:true,w:1,p:50};
I.u[1464] = {n:"Antenas de Escarafolha Azul",t:15,d:"Ninguém sabe para que servem estas antenas... A única certeza é que elas têm um cheiro realmente ruim.",ep:3,g:216,l:32,wd:true,fm:true,w:1,p:100};
I.u[1465] = {n:"Antenas de Escarafolha Vermelha",t:15,d:"Ninguém sabe do que estas antenas são feitas. A única certeza é que eles têm um cheiro ruim.",ep:3,g:217,l:32,wd:true,fm:true,w:1,p:1};
I.u[1466] = {n:"Antenas do Escarafolha Verde",t:15,d:"Ninguém sabe do que estas antenas são feitas... A única certeza é que cheiram muito mal.",ep:3,g:218,l:32,wd:true,fm:true,w:1,p:100};
I.u[1467] = {n:"Antenas de Escarafolha Branco",t:15,d:"Ninguém sabe do que estas antenas são feitas... A única certeza é que cheiram muito mal.",ep:3,g:219,l:32,wd:true,fm:true,w:1,p:100};
I.u[1468] = {n:"Jarro Grande",t:71,d:"Este jarro é multifuncional. Pode ser usado para a fabricação de poções assim como para o afogamento de peixes.",ep:1,g:58,l:1,wd:true,fm:true,w:1,p:100};
I.u[1469] = {n:"Pergaminho de Recomendação",t:24,d:"Uba Tesse deu-lhe este pergaminho. Ele recomendou bastante que você treine como um alquimista.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1470] = {n:"Pergaminho de Recomendação",t:24,d:"Você conseguiu este pergaminho de Uba Tesse. Ele o recomendou ao treinamento de alquimista. Há uma pequena nota de Boff Chalon.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1471] = {n:"Pergaminho de Recomendação com Flor",t:24,d:"Uba Tesse deu-lhe este pergaminho. Ele recomendou bastante que você treine como um alquimista. Há uma pequena nota de Boff Chalon. Uma flor em anexo prova que você estava presente na primeira lição.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1472] = {n:"Pergaminho de Requisição de Exame",t:24,d:"Este pergaminho indica que você terminou seu treinamento como alquimista e que agora, você é capaz de tentar o exame.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1473] = {n:"Dedos Verdes",t:20,d:"Com estas luvas, você poderá colher todos os tipos de flores.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:100};
I.u[1474] = {n:"Amuleto Xelor",t:1,d:"Este amuleto extremamente poderoso é o fruto do trabalho de um seguidor do velho Xelor nos tempos de maestria.",ep:1,g:28,l:52,wd:true,fm:true,w:10,p:7300};
I.u[1475] = {n:"Espada Elegante",t:6,d:"A Espada Elegante foi forjada pelo famoso ferreiro Dave-LoL, pouco antes de ele morrer por causa da menina mais bonita do reino, uma seguidora feminina de Iop. Diz-se que a eficiência dessa espada se adapta apenas à boa-vontade do portador.",ep:4,g:15,l:60,wd:true,fm:true,w:30,an:14,e:[10,4,1,1,30,50,false,false],c:"CS>100&CV>50",p:3000};
I.u[1476] = {n:"Amuleto de Crackler",t:1,d:"Este poderoso amuleto contém a vida do Crackler, quer dizer, todos os itens que ele juntou antes de morrer sob golpes de aventureiros que desejavam seus tesouros.",ep:2,g:25,l:47,wd:true,fm:true,w:5,p:5800};
I.u[1477] = {n:"Mulette da Sorte",t:1,d:"Mulette era uma pequena Ecaflip vencida pela má sorte, até que sua avó ofereceu este amuleto.",ep:1,g:26,l:44,wd:true,fm:true,w:5,p:5000};
I.u[1478] = {n:"Harmonia",t:1,d:"Este pingente fará você sentir uma paz com o mundo ao seu redor.",ep:1,g:122,l:47,wd:true,fm:true,w:1,p:6000};
I.u[1479] = {n:"Twot em Papelão",t:7,d:"Este lendário Martelo já demonstrou sua capacidade em Amakna. Ele pertenceu ao poderoso Twot em Papelão que o usou por vontade própria para transformar seus oponentes em confete e papel machê.",ep:13,g:6,l:46,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>50&CV>30",p:5600};
I.u[1480] = {n:"Paz",t:1,d:"Este pendente fará você se sentir em paz com o mundo.",ep:1,g:121,l:38,wd:true,fm:true,w:1,p:4000};
I.u[1481] = {n:"Entendimento",t:1,d:"Este pingente o fará se sentir em paz com o mundo à volta.",ep:1,g:11,l:26,wd:true,fm:true,w:1,p:2000};
I.u[1482] = {n:"Emblema Pálido",t:1,d:"Este amuleto é extremamente útil mesmo que faça o seu portador ficar tão branco quanto um Gobball.",ep:1,g:32,l:41,wd:true,fm:true,w:2,p:4500};
I.u[1483] = {n:"Kabbala",t:1,d:"Um símbolo misterioso de uma organização misteriosa... a propósito, não existe e você nunca ouviu falar, entendeu?",ep:11,g:13,l:29,wd:true,fm:true,w:2,p:2500};
I.u[1484] = {n:"Amuleto Itbe Modificado",t:1,d:"Um excelente exemplo do trabalho feito pela aprendiz de ourives Polma Kartnez, esta reprodução supera o original.",ep:1,g:31,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1485] = {n:"Maçã",t:1,d:"Este amuleto é o modelo modificado do Destino Dourado, o que é muito estranho quando você pensa que esses dois amuletos não têm nada em comum a não ser o seu aspecto ridículo.",ep:1,g:27,l:22,wd:true,fm:true,w:5,c:"CC>10",p:1500};
I.u[1486] = {n:"Medalha Sagrada",t:1,d:"Holy era uma seguidora de Iop, que tinha a intenção de derrubar o Mal por toda a parte. Conhecida por sua incrível compostura, ela nunca ficava furiosa, exceto quando comparavam-na com alguém chamado Oly.",ep:1,g:23,l:31,wd:true,fm:true,w:3,p:2800};
I.u[1487] = {n:"Adelus",t:10,d:"Este cinto não é apenas elegante, mas também relaxante. Realmente, ele massageia o seu portador. Mais feliz e bem menos estressado, o portador fica em melhores condições para pensar.",ep:1,g:12,l:48,wd:true,fm:true,w:30,p:6075};
I.u[1488] = {n:"Plimclik",t:1,d:"Este estranho nome vem de um estranho objeto feito, só Deus sabe, de amuletos prévios. Nós não sabemos nada das circunstâncias nas quais ele foi encontrado...",ep:11,g:123,l:130,wd:true,fm:true,w:24,p:1000};
I.u[1489] = {n:"Broche de Mhete",t:1,d:"Mhete foi um dos mais valentes guerreiros de Amakna. A lenda diz que a sua sabedória vinha do broche que usava.",ep:11,g:15,l:28,wd:true,fm:true,w:1,p:2300};
I.u[1490] = {n:"Corrente Nhanor Kibrill",t:1,d:"Seu criador, um tal Ken Aton, era famoso por seus hábitos estranhos. Ele gastou todo o seu tempo caçando o Minotoro para fazer uma proteção peitoral para si mesmo.",ep:1,g:12,l:13,wd:true,fm:true,w:2,p:650};
I.u[1491] = {n:"Corrente de Liche",t:1,d:"O Liche era uma criatura imunda conhecida por se infiltrar nos grupos de guerreiros valentes para roubar uma parte das pilhagens. Mas um dia os guerreiros descobriram este joguinho e o Liche fugiu...",ep:13,g:12,l:45,wd:true,fm:true,w:2,p:5400};
I.u[1492] = {n:"Kapa Tass",t:17,d:"Esta famosa capa foi costurada pela avó de Tasselhoff. A pobre vela estava longe de suspeitar que ele usava-a para aliviar todas as suas perversões e fantasias.",ep:0,g:23,l:30,wd:true,fm:true,w:11,p:800};
I.u[1493] = {n:"Ferimento de Sacrier",t:9,d:"Dizem que este anel é o resultado de vários ferimentos recebidos por um Sacrieur.",ep:1,g:13,l:15,wd:true,fm:true,w:2,p:800};
I.u[1494] = {n:"Sineiro",t:9,d:"A função principal deste belo anel é permitir que Osamodas reconheçam seus tofus durante as lutas.",ep:1,g:14,l:15,wd:true,fm:true,w:4,p:800};
I.u[1495] = {n:"Anel de Dhyn",t:9,d:"Este pequeno anel de aparência modesta foi criado por Degun. Ele era mais conhecido por gritar toda vez que podia e por sua aversão cruel a Liche do que por sua criatividade com jóias.",ep:1,g:37,l:36,wd:true,fm:true,w:3,p:3575};
I.u[1496] = {n:"Sorte de Ecaflip",t:9,d:"Este anel foi criado para aumentar a sorte de seu portador durante as brincadeiras com cards.",ep:1,g:32,l:20,wd:true,fm:true,w:4,p:1300};
I.u[1497] = {n:"Passado de Xelor",t:9,d:"Anéis forjados durante as viagens temporais dos Xelor.",ep:1,g:16,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1498] = {n:"Memento de Enutrof",t:9,d:"Estes anéis foram forjados das lágrimas do Enutrof, que havia perdido sua pá. Você pode dizer que o sujeito foi muito miserável naquele momento!",ep:1,g:15,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1499] = {n:"O Enutrofion",t:9,d:"Este anel é destinado a pertencer somente aos Enutrofs. Foi encantado pelo Deus deles, de forma que os discípulos fossem os únicos capazes de usá-lo. Permite a qualquer Enutrof que se preze ter mais sorte na caça ao tesouro.",ep:1,g:39,l:59,wd:true,fm:true,w:1,c:"PG=3",p:10000};
I.u[1500] = {n:"Mokette",t:17,d:"Este magnífico manto, feito com muitas fibras diferentes, é uma peça sem igual por causa de sua cor e do modo como a luz brinca em sua superfície.",ep:8,g:8,l:43,wd:true,fm:true,w:16,p:5000};
I.u[1501] = {n:"Aliança",t:9,d:"Graças a esta aliança, você poderá casar com a pessoa de seus sonhos... Mas cuidado, esse casamento poderá não ser as mil maravilhas.",ep:2,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[1503] = {n:"Varinha do Fogo Fátuo",t:3,d:"Na criação esta varinha foi posta num cadáver recente, e então rapidamente enfiada. Ninguém imaginaria como exatamente a varinha foi posta no corpo do morto.",ep:3,g:14,l:20,wd:true,fm:true,w:15,an:11,e:[5,3,2,3,30,50,false,true],c:"CI>30",p:1000};
I.u[1504] = {n:"Adagas de O\'Bert",t:5,d:"O\'Bert Pescoço Vermelho era famoso no país. Um dia, como ele estava cantando com toda a sua voz, alguém cortou sua cabeça, o que explica o apelido dele. A adaga do infiltrador foi encontrada, mas ninguém procurou seu proprietário. O\'Bert era famoso por cantar desafinado.",ep:1,g:1,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
