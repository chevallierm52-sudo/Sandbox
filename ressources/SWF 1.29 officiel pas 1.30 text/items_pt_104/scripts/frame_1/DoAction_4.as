I.u[1650] = {n:"A Grande Cortadora",t:6,d:"Esta espada é absolutamente perfeita para atacar pessoas indefesas. Rápida, útil e, acima de tudo, com a ponta extremamente afiada, ela foi banida das lojas por muitos anos. Apesar disso, ela foi tolerada por algum tempo para ser usada como uma defesa contra Bwork.",ep:14,g:23,l:58,wd:true,fm:true,w:12,an:14,e:[10,5,1,1,30,50,false,false],p:5200};
I.u[1651] = {n:"Talhadora Sanguinária",t:6,d:"Esta espada é absolutamente perfeita para atacar pessoas agradáveis. Rápida, útil e, acima de tudo, tem a ponta extremamente afiada. Por isso, sua venda foi proibida por muitos anos agora. Hoje, é tolerada como uma defesa anti-Bwork, quer dizer.",ep:14,g:23,l:64,wd:true,fm:true,w:12,an:14,e:[10,5,1,1,30,50,false,false],p:5200};
I.u[1652] = {n:"Pata de Aracne Adulta",t:103,d:"Uma perna peluda e fina normalmente usada para fazer perucas e vassouras exóticas.",ep:1,g:246,l:39,wd:true,fm:true,w:1,p:1};
I.u[1653] = {n:"Fé de Don Rouann",t:24,d:"Este Anel simboliza o fato de que você está procurando o segredo de Don Rouann. Neste momento, você aprendeu a coragem.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1654] = {n:"Fé de Don Rouann",t:24,d:"Este Anel simboliza o fato de que você está procurando o segredo de Don Rouann. Agora que coragem e comunicação fazem parte de suas perícias, você ainda tem de aprender a ser paciente.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1655] = {n:"Fé de Don Rouann",t:24,d:"Este Anel simboliza o fato de que você está procurando o segredo de Don Rouann.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1656] = {n:"Fecalizador Mago",t:9,d:"Este anel pode proteger seu possuidor de pequenos ataques mágicos e conseqüentemente proteger de pequenos monstros que usam a mágica para se exibir.",ep:1,g:40,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1657] = {n:"Fecalizer de Guerreiro",t:9,d:"Este anel o protege de ataques mágicos pequenos e com a extensão de monstros pequenos que usa suas aparências físicas vão surpreendê-lo.",ep:1,g:41,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1658] = {n:"Klaassy",t:22,d:"Você certamente terá muita classe com esta gadanha, e até mesmo um camponês de classe do mundo. Pelo menos, isso é que você acreditará. Um pequeno conselho: como monstros não apreciam seu senso de estética, você ficará melhor debaixo da terra.",ep:0,g:1,l:31,wd:true,fm:true,w:15,e:[10,5,1,1,50,45,false,false],c:"CA>40&CV>20",p:2670};
I.u[1659] = {n:"Gadanha de Mack Kormick",t:22,d:"Desde o amanhecer, Mack Kormick O Ceifador corta todos os campos de cereais,  e os monstros escondidos neles com uma gadanha. Agora é sua vez de provar que é digno de usar esta gadanha, então ao trabalho!",ep:0,g:1,l:56,wd:false,fm:true,w:15,an:12,e:[10,5,1,1,45,50,false,false],c:"CC>80&CA>40&CI>20",p:8345};
I.u[1660] = {n:"Âmbar de Treechnid das Sombras",t:50,d:"Este magnífico âmbar contém um inseto nojento preso na seiva de seu mestre. É uma espécie de sarcófago, que permite ao Treechnid das Sombras ter boas lembranças de suas invocações, uma vez que elas morrem.",ep:9,g:638,l:78,wd:true,fm:true,w:2,p:6000};
I.u[1661] = {n:"Ambamuleto Moskito",t:1,d:"Usar um colar com um Moskito envolto em um âmbar é a mesma coisa que mostrar aos seus oponentes que você é um perigoso caçador... de Moskitos. Inútil dizer que, uma vez fora do Berço, você ficará ridículo.",ep:1,g:17,l:40,wd:true,fm:true,w:5,p:4400};
I.u[1662] = {n:"Ambamuleto Aracne",t:1,d:"Usar um âmbar de Aracne ao redor do pescoço quando estiver atacando uma de suas irmãs, pode ser suficiente para desconcertá-las. Pobre inseto, embora isto seja o que chamamos de \"ironia do destino\".",ep:1,g:18,l:34,wd:true,fm:true,w:5,p:3225};
I.u[1663] = {n:"Escama de Crocodyl",t:59,d:"Esta escama de Crocodyl é como um pequeno troféu para todos os caçadores novatos de Crocodyl. Não hesite em mostrá-la aos eufóricos da taverna, eles obviamente ficarão impressionados e lhe oferecerão uma bebida para celebrar seu sucesso.",ep:4,g:233,l:36,wd:true,fm:true,w:5,p:50};
I.u[1664] = {n:"Dentes de Crocodyl",t:47,d:"Quando um Crocodyl tenta fincar seus dentes em você, a melhor solução é extrair um dente dele com determinação e vigor, assim como um severo dentista.",ep:4,g:234,l:36,wd:true,fm:true,w:1,p:50};
I.u[1665] = {n:"Botas de Aprendizado",t:11,d:"Estas estranhas botas foram primeiramente usadas por jovens discípulos Iops que não eram exatamente espertos, pois, então, eles poderiam ganhar inteligência. Por isso elas se encaixam perfeitamente em Iops.",ep:4,g:68,l:50,wd:true,fm:true,w:10,p:6675};
I.u[1666] = {n:"Botas do Invocador Aprendiz",t:11,d:"Estas botas foram feitas especialmente para aqueles que preferem deixar suas criaturas fazerem o trabalho duro durante as lutas.",ep:12,g:14,l:51,wd:true,fm:true,w:10,p:7000};
I.u[1667] = {n:"Cinto Luthuthu",t:10,d:"Este cinto tem o nome de quem o fez, Luthuthu, um sapateiro menos conhecido que Bowisse, mas ainda bastante criativo, apesar de sua idade.",ep:8,g:13,l:50,wd:true,fm:true,w:10,p:6700};
I.u[1668] = {n:"Cinto do Dodu Trêmulo",t:10,d:"O Dodu era um Sadida que insistia em assustar seus inimigos. Ele pediu a Bowisse para fazer um cinto combinando com a cor do seu cabelo... porque o Dodu não era apenas um indivíduo audacioso, mas também charmoso.",ep:4,g:14,l:55,wd:true,fm:true,w:8,p:8000};
I.u[1669] = {n:"Cintos dos Eventos",t:10,d:"Este cinto foi feito pela Cra mais popular que freqüentemente organizava muitas festas e eventos incomuns para entreter as pessoas. Tudo isso, entre dois atos de passar as Cuecas de Couro do Capitão Chafer.",ep:8,g:15,l:84,wd:true,fm:true,w:10,p:18300};
I.u[1670] = {n:"Pena Pontuda de Kwak do Vento",t:53,d:"Um Kwak do Vento às vezes pode ter uma pena pontuda diferente das outras;\r\n            geralmente é mágico, mas mesmo assim você pode colocá-lo para se disfarçar de Cacique.",ep:5,g:393,l:24,wd:true,fm:true,w:10,p:100};
I.u[1671] = {n:"Aveia Mágica",t:34,d:"Este punhado de palha de aveia mágica, uma vez, pertenceu a um simples camponês, encantado pelo aprendiz Bwork Mago, que o ajudou neste livro de ponta a ponta.",ep:1,g:550,l:20,wd:true,fm:true,w:10,p:0};
I.u[1672] = {n:"Pêlos de Darit",t:54,d:"Estes cabelos costumavam pertencer a Darit, um jovem e pretensioso bruxo que subestimou seu oponente. Ele realmente esqueceu-se de verificar o que o Prespic usou (e ele usou Contra), antes de conjurar seu feitiço \'Raio Espetacular\'.",ep:1,g:555,l:18,wd:true,fm:true,w:1,p:100};
I.u[1673] = {n:"Pata Mágica de Aracne",t:103,d:"Esta pata de Aracne é diferente das outras;\r\n            ela se move sozinha e parece estar bem e verdadeiramente viva, até mesmo quando arrancada de seu proprietário. Esta pata pode estar a ponto de começar uma nova vida já que, aparentemente, ela é atraída por costura.",ep:1,g:392,l:2,wd:true,fm:true,w:10,p:100};
I.u[1674] = {n:"Cogumelo Luidegît",t:15,d:"Como resultado de uma mágica incerta do travesso Carvalho Mole, este herói foi transformado em cogumelo. Como os Cogu-Cogu são bem estúpidos e os protegem como um de seus deuses.",ep:1,g:390,l:46,wd:true,fm:true,w:10,p:100};
I.u[1675] = {n:"Osso Surpresa de Chafer da Infantaria",t:47,d:"Este Osso mágico permite aos Chafers de Infantaria realizar feitos surpreendentes. Por exemplo, no meio de uma luta, eles podem tirar suas cuecas, botá-las nas cabeças sem usar as mãos, e ainda evitar ser golpeados pelos agressores. Você nunca conseguirá ficar cansado desta incrível performance.",ep:3,g:15,l:35,wd:true,fm:true,w:1,p:100};
I.u[1676] = {n:"Vime Encantado",t:15,d:"Este pedaço de Vime Encantado lhe permitirá fazer uma bela cesta para frutas mágicas, combinando elegância e poder... completamente o oposto de um Liche mau.",ep:2,g:123,l:69,wd:true,fm:true,w:10,p:100};
I.u[1677] = {n:"Poção de Dantegoulish",t:12,d:"Esta poção mágica é a única capaz de fazer mágica nas ceroulas de couro entrelaçado do Capitão Chafer...Fala-se muito sobre o poder de tal poção.",ep:2,g:139,l:50,wd:true,fm:true,w:10,p:1000};
I.u[1678] = {n:"Kokonoz Traumatizada",t:46,d:"Esta Kokonoz foi traumatizada durante sua infância. Ódio foi o motivo pelo qual ela se tornou tão poderosa quanto possível...",ep:12,g:552,l:42,wd:true,fm:true,w:2,p:100};
I.u[1679] = {n:"Pedra de Cristalobola",t:50,d:"É preciso a paciência de um santo, mas esta pedra pode ficar redonda e brilhante, como um pompom de chapéu mágico. Sua forma torna-a fácil de caber em quase todos os lugares.",ep:4,g:240,l:16,wd:true,fm:true,w:10,p:100};
I.u[1680] = {n:"Chifre Chamuscado de Minotoro",t:47,d:"Este chifre de Minotoro é um artefato mágico recomendado desde que foi queimado por uma magia muito poderosa. Infelizmente, assim como muitas outras coisas, ele é mais eficiente quando você possui o par.",ep:2,g:245,l:125,wd:true,fm:true,w:10,p:100};
I.u[1681] = {n:"Pele de Larva Verde Mágica",t:59,d:"Não seja enganado pela aparência viscosa, é um artefato precioso de verdade. Ele trará a você sorte de um demônio se o colocar perto de sua cabeça.",ep:1,g:391,l:7,wd:true,fm:true,w:10,p:100};
I.u[1682] = {n:"Casca de Liroye Merline",t:96,d:"Este pedaço de casca é da árvore da claridade encantada de Liroye Merline. \nEste fragmento caiu quando Brouce Boulgoure, o lenhador, quebrou seu Boulgourde contra a árvore encantada.",ep:9,g:542,l:78,wd:true,fm:true,w:1,p:100};
I.u[1683] = {n:"Sacola Brilhante de Pás",t:15,d:"Com esta sacola mágica, um astuto Sadida carregou incríveis quantidades de batatas descascadas para vendê-las aos prisioneiros. Quando ele morreu, sua sacola passou de Sadida astuto para Sadida astuto, como uma espécie de ritual.",ep:1,g:243,l:12,wd:true,fm:true,w:10,p:100};
I.u[1684] = {n:"Sacola de Batatas das Sombras",t:15,d:"O Saco de Batatas das Sombras compartilha muitas semelhanças com o Brilhante Saco de Batatas, exceto pelo fato de ter sido encharcado com a seiva de Treechnid das Sombras, o que lhe conferiu poderes adicionais.",ep:1,g:244,l:12,wd:true,fm:true,w:10,p:100};
I.u[1685] = {n:"Pena do Último Frengo",t:53,d:"Atenção! Você é dono da última pena do traseiro do último frengo de Amakna. Pode ser uma boa idéia afastá-la de seus amigos alfaiates, ou fanáticos cujo número só aumenta.",ep:3,g:247,l:32,wd:true,fm:true,w:1,p:100};
I.u[1686] = {n:"Tintura Mágica Vermelha",t:70,d:"Esta pequena poção mágica dá uma cor avermelhada magnífica aos cabelos. Também parece ter alguns efeitos mágicos.",ep:7,g:63,l:10,wd:true,fm:true,w:1,p:500};
I.u[1687] = {n:"Tintura Mágica Verde",t:70,d:"Esta pequena poção mágica dá uma cor esverdeada magnífica aos cabelos. Também parece ter alguns efeitos mágicos.",ep:1,g:64,l:10,wd:true,fm:true,w:1,p:500};
I.u[1688] = {n:"Tintura Mágica Azul",t:70,d:"Esta pequena poção mágica dá uma cor azulada magnífica aos cabelos. Também parece ter alguns efeitos mágicos.",ep:5,g:65,l:10,wd:true,fm:true,w:1,p:500};
I.u[1689] = {n:"Tintura Mágica Laranja",t:70,d:"Esta pequena poção mágica dá uma cor alaranjada magnífica aos cabelos. Também parece ter alguns efeitos mágicos.",ep:1,g:66,l:10,wd:true,fm:true,w:1,p:500};
I.u[1690] = {n:"Pêlos de Miliboolobo",t:54,d:"Esta pele é quase a mesma de um Boolofo, porém é mais curta, menos grossa e macia. \nInfelizmente, o cheiro é o mesmo.",ep:1,g:554,l:22,wd:true,fm:true,w:1,p:1};
I.u[1691] = {n:"Pêlos de Moolobo",t:54,d:"São raros os aventureiros sortudos o suficiente para tocar nestes pêlos vivos. De qualquer forma, isto não faz de você um herói... Caia na real!",ep:2,g:553,l:198,wd:true,fm:true,w:10,p:200};
I.u[1692] = {n:"Tintura Mágica Escura",t:70,d:"Esta pequena poção mágica dá uma cor escurecida magnífica aos cabelos. Também parece ter alguns efeitos mágicos.",ep:1,g:67,l:10,wd:true,fm:true,w:1,p:500};
I.u[1693] = {n:"Manto de Jules Yanos",t:17,d:"Jules Yanos, famoso alfaiate, era particularmente conhecido por ter trocado sua esposa por um dedal mágico. Pelo menos algumas pessoas ainda continuam no mundo dos negócios.",ep:8,g:8,l:54,wd:true,fm:true,w:1,p:7800};
I.u[1694] = {n:"Lã do Trool Furioso",t:57,d:"Este pedaço de Lã vem do Trool mais perigoso de Amakna que, aparentemente, foi transformado em uma colcha por um inescrupuloso alfaiate, o mesmo alfaiate que, se você acredita no que é publicamente espalhado, permutou sua esposa por um dedal mágico. Eu não vejo a relação.",ep:4,g:27,l:115,wd:true,fm:true,w:10,p:1};
I.u[1695] = {n:"Manto de Elya Wood",t:17,d:"Alguns dizem que o Capitão que Chafer tentou roubar este manto para substituir suas famosas ceroulas de couro. Mas não coube nele e não era pérfido nem pervertido o suficiente para seu gosto.",ep:8,g:9,l:80,wd:true,fm:true,w:10,s:39,p:16500};
I.u[1696] = {n:"Tecido de Moolobo",t:55,d:"Os alfaiates acharam há muito anos uma maneira de determinar o valor de um material;\r\n            quanto mais fede, mais poderoso é.",ep:2,g:14,l:198,wd:true,fm:true,w:20,p:300};
I.u[1697] = {n:"Pequena Sacola em Lã Gobball",t:81,d:"Não há nenhuma chance de você se tornar um herói com este pequeno saco, mas ele tem pelo menos a virtude de manter alguns de seus objetos pessoais em um lugar seguro.",ep:1,g:25,l:1,wd:true,fm:true,w:5,p:100};
I.u[1698] = {n:"Sacola de Pequeno Cultivador",t:81,d:"Este saco é especialmente projetado para conter recursos coletados por você. Apenas verdadeiros cultivadores podem carregá-lo (necessário nível 20 para cultivadores).",ep:1,g:26,l:5,wd:true,fm:true,w:5,c:"PJ>2,20|PJ>24,20|PJ>36,20|PJ>28,20|PJ>26,20|PJ>41,20",p:2000};
I.u[1699] = {n:"Sacola de Aventureiro Menor",t:81,d:"Esta sacola é ideal para aqueles que não vão para muito longe de suas casas e precisam levar coisas inúteis, como tábuas cinzentas, por exemplo.",ep:1,g:27,l:10,wd:true,fm:true,w:5,p:3000};
I.u[1700] = {n:"Cinto de Celebridade",t:10,d:"Este aerodinâmico cinto, projetado por Tengra Reufrus, o tornará tão ágil quanto um Tofu e tão livre quanto o ar. Ou vice-versa.",ep:4,g:17,l:27,wd:true,fm:true,w:15,p:2000};
I.u[1701] = {n:"Cinto de Utilidades",t:10,d:"Esse cinto tem alguns bolsos, permitindo que você coloque mais objetos em seu inventário.",ep:1,g:16,l:20,wd:true,fm:true,w:10,p:1300};
I.u[1702] = {n:"Sacola de Coletor",t:81,d:"Esta sacola é especialmente desenvolvida para guardar os recursos de sua coleta.\nApenas verdadeiros coletores podem usá-la. (requer nível 40 de coletor).",ep:8,g:28,l:15,wd:true,fm:true,w:10,c:"PJ>2,40|PJ>24,40|PJ>36,40|PJ>28,40|PJ>26,40|PJ>41,40",p:3000};
I.u[1703] = {n:"Sacola do Grande Coletor",t:81,d:"Esta sacola é especialmente desenvolvida para guardar os recursos que você coletou.\nApenas os verdadeiros coletores podem carregar recursos com ela (requer nível 60 de coletor).",ep:8,g:29,l:20,wd:true,fm:true,w:10,c:"PJ>2,60|PJ>24,60|PJ>36,60|PJ>28,60|PJ>26,60|PJ>41,60",p:2000};
I.u[1704] = {n:"Sacola de Staca Noviste",t:81,d:"Dizem que um famoso mineiro foi capaz de trabalhar por vários meses sem intervalo em 4 minas diferentes ao mesmo tempo... Deve ser uma lenda espalhada pela Guilda Martelo-Foice para encorajar mineiros a trabalhar mais.",ep:8,g:30,l:20,wd:true,fm:true,w:10,c:"PJ>2,90|PJ>24,90|PJ>36,90|PJ>28,90|PJ>26,90|PJ>41,90",p:10000};
I.u[1705] = {n:"Sacola de Aventureiro",t:81,d:"É a sacola ideal para guardar todos seus pães e poções quando você ficar ausente por vários meses... no labirinto, por exemplo.",ep:8,g:31,l:40,wd:true,fm:true,w:4,p:4000};
I.u[1707] = {n:"Sacola do Grande Aventureiro",t:81,d:"É uma sacola ideal para manter todos os seus pães e poções quando você estiver em um local exótico... como a Ilha da Lua.",ep:13,g:32,l:60,wd:true,fm:true,w:5,p:6000};
I.u[1709] = {n:"Nonoss",t:47,d:"‘Quem é o cachorrinho da vovó?\' foram as últimas palavras de uma Enutrof que confundiu um Boolobo com seu animal de estimação.",ep:1,g:15,l:1,wd:true,fm:true,w:2,p:1};
I.u[1710] = {n:"Crescente da Lua",t:1,d:"As origens deste amuleto, na forma de uma lua crescente, são desconhecidas para quase todo mundo...\nQuem sabe os segredos que esta jóia contém...",ep:1,g:19,l:1,wd:false,fm:true,w:10,p:1000};
I.u[1711] = {n:"Auau",t:18,d:"Com este cãozinho, você saboreará a alegria de levar o cachorro para fazer xixi. Ainda bastante selvagem, não é recomendado alimentá-lo, já que você poderia perder a sua mão no processo.\n(ESTE ANIMAL DE ESTIMAÇÃO NÃO GOSTA DE NENHUM RECURSO)",ep:1,g:6,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1712] = {n:"Poção Pahoa Raid",t:12,d:"Com esta poção, você irá recuperar alguns Pontos de Energia.",ep:1,g:140,l:20,wd:true,fm:true,w:1,u:true,p:50};
I.u[1713] = {n:"Poção Raide Bule",t:12,d:"Com esta poção, você recuperará alguns pontos de energia.",ep:1,g:141,l:40,wd:true,fm:true,w:1,u:true,p:100};
I.u[1715] = {n:"O Dom de Nowel",t:25,d:"Best-seller do final do ano 634, é uma leitura essencial. Um clássico!",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1716] = {n:"Família DuCiel",t:25,d:"Outro best-seller do Inverno 634, este livro já é uma referência.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1717] = {n:"Primeiro Natal",t:25,d:"Estranho ao início do ano 635, este livro realmente merece algum interesse.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1718] = {n:"Força de Crocoburio",t:9,d:"Este anel foi abençoado pelo Hálito Negro de Grougalorasalar, o que lhe deu grandes poderes, agora um pouco debilitados. Esta relíquia era destinada ao Crocoburio, o único capaz de dominá-la sem ser dominado.",ep:4,g:38,l:40,wd:true,fm:true,w:2,c:"CS>59",p:4000};
I.u[1719] = {n:"Espírito de Crocoburio",t:11,d:"Este par de botas aparentemente pertencia ao Crocoburio. Apenas algumas pessoas podem usá-las e estas imediatamente tornam-se maquiavélicas e mergulham em pensamentos engenhosos. A lenda diz que este feitiço do mal é devido aos numerosos crânios que as botas esmagaram.",ep:4,g:12,l:42,wd:true,fm:true,w:10,c:"CI>49",p:5000};
I.u[1720] = {n:"Poder de Crocoburio",t:10,d:"Grougalorasalar adorava colecionar fragmentos de ossos que costumavam pertencer a seus mais perigosos inimigos. Seu afeto pelo Crocoburio o fez usar os fragmentos para criar este ultrapoderoso cinto.",ep:4,g:18,l:34,wd:true,fm:true,w:15,c:"CV>119",p:3000};
I.u[1721] = {n:"Poção do Esquecimento: \'Relógio\'",t:43,d:"Esta poção permite ao seu consumidor desaprender um nível do feitiço de Xelor: \'Relógio\'.",ep:2,g:37,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1722] = {n:"Transformação Treechnid",t:27,d:"Você foi transformado em um treechnid por causa da maldição do Carvalho Mole. Para remover o encanto, você terá que derrotar um aventureiro perdido na floresta dos Treechnids.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1723] = {n:"Bombom vermelho possante",t:28,d:"Este bombomlhe dará mais energia por algum tempo.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1724] = {n:"Coragem",t:29,d:"Esta bênção fará você ganhar Força para suas próximas lutas.",ep:18,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1725] = {n:"Desencorajado",t:30,d:"Esta maldição reduzirá sua Força em sua próxima briga.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1726] = {n:"Tufo de Cabelos de Meavis",t:24,d:"Este tufo de cabelos prova sua vitória sobre Meavis. Você é uma estrela!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1727] = {n:"Carta Ameaçadora",t:24,d:"Carta ameaçadora endereçada à Senhorita Marmelada..",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1728] = {n:"Miau",t:18,d:"O sexo frágil é louco por esta bola de pêlos travessa e fofinha. Que animal perigoso!",ep:1,g:1,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1729] = {n:"Anel deMer",t:9,d:"Este anel pertenceu a Mer, um dos maiores preguiçosos de Amakna. Ele cultuava costelas...",ep:7,g:28,l:25,wd:true,fm:true,w:25,c:"CI<100&CC<100",p:1900};
I.u[1730] = {n:"Medida de Sal",t:48,d:"Esta medida de sal é a quantidade ideal para temperar a maioria dos pratos. Nenhuma refeição pode ser feita sem sal.",ep:1,g:261,l:1,wd:true,fm:true,w:1,p:1};
I.u[1731] = {n:"Dose de Suco Gostoso",t:15,d:"Este suco trará a você os sabores básicos para se ter um prato saboroso.",ep:1,g:262,l:1,wd:true,fm:true,w:1,p:4};
I.u[1732] = {n:"Tigela",t:15,d:"Não existe nada mais conveniente do que uma tigela para comer sopa corretamente, ainda que o fato de comer corretamente não altere o gosto. A menos que seus dedos estejam muito sujos...",ep:16,g:263,l:1,wd:true,fm:true,w:1,p:6};
I.u[1733] = {n:"Terrine",t:15,d:"Terrina é como carne, satisfaz plenamente. Três vivas para a Terrina ! Viva para a terrina !!!\n(Extraído do hino do açougueiro, 4º verso)",ep:16,g:264,l:1,wd:true,fm:true,w:1,p:6};
I.u[1734] = {n:"Cereja",t:46,d:"Esta fruta poderia ser facilmente confundida com um grande par de bolas saltitantes.",ep:1,g:265,l:1,wd:true,fm:true,w:1,p:1};
I.u[1735] = {n:"Certificado do Canil: Miau",t:77,d:"Este certificado menciona as características do Miau que você pôs no Canil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[1736] = {n:"Limão",t:46,d:"Este suco de fruta é perfeito para esconder o cheio ruim da carne podre. Sirva algumas sobras de peixe para seus convidados.",ep:1,g:266,l:1,wd:true,fm:true,w:1,p:2};
I.u[1737] = {n:"Pão dos Campos",t:33,d:"Este Pão do Campo é um tipo de pão muito pesado para se ter no bolso ou no esôfago. Mas, pelo menos, ele tem o sabor rústico que um bom pão deveria ter.",ep:1,g:68,l:40,wd:true,fm:true,w:3,u:true,ut:true,p:1};
I.u[1738] = {n:"Pão das Vilas",t:33,d:"Este pão certamente aguça seu apetite. Ele rapidamente dá uma sensação de saciedade.",ep:1,g:69,l:10,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[1739] = {n:"Varinha Mágica Fervente",t:3,d:"Esta varinha mágica ferve ao toque. Mas a coisa mais enigmática é o cheiro de freixo que faz você acreditar ter sobrevivido a uma floresta de fogo.",ep:13,g:24,l:80,wd:true,fm:true,w:1,an:11,e:[5,4,2,3,40,50,false,true],c:"CI>60&CV>40",p:1};
I.u[1740] = {n:"Transformação Crocoburio",t:27,d:"O Crocobur contém o espírito do Crocoburio. Então, o único modo de roubar isto do Crocoburio é matá-lo.",ep:4,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1741] = {n:"Sangue de Fênix",t:14,d:"Este sangue de fênix pode reviver um fantasma e dar a ele alguns pontos de vida.",ep:18,g:3,l:10,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:1000};
I.u[1742] = {n:"Grande Sangue de Fênix",t:14,d:"Este sangue de fênix pode reviver um fantasma e dar vários pontos de vida.",ep:18,g:3,l:50,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:2500};
I.u[1744] = {n:"Tufo de Cabelos de Mutthead",t:24,d:"Este tufo de cabelos prova sua vitória sobre Mutthead. Magnífico!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1745] = {n:"Seringa de veterinário",t:24,d:"Uma extremidade pontiaguda, uma ampola é uma seringa, sem sombra de dúvida... Você foi avisado.",ep:1,g:31,l:1,wd:true,fm:true,w:0,p:1};
I.u[1746] = {n:"Sangue de Wabbit GM",t:24,d:"Quem pensaria em se aproximar, com uma seringa, de Wabbits armados com o objetivo de extrair sangue da criatura mais geneticamente modificada da Ilha? Só você.",ep:8,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[1747] = {n:"Análise de Sangue de Wabbit GM",t:24,d:"As análises revelam claramente que o sangue identificado vem de um traseiro de Wabbit. Depois de um exame completo da amostra, o alquimista foi capaz de determinar que parte do traseiro foi picada. Apenas a título de informação, foi o lado direito.",ep:5,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[1748] = {n:"Wabbit",t:18,d:"Este wabbit pequeno é domesticado e não o morderá. Entretanto, para o outros...",ep:8,g:7,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:11,p:1};
I.u[1749] = {n:"Ficha da Feira do Trool",t:15,d:"Você comprou esta ficha para Leonzi Trool. Ele sonha que um dia poderá abrir um parque divertido ao ar livre para todos (Planícies de Cania).",ep:13,g:737,l:1,wd:true,fm:true,w:1,p:1};
I.u[1750] = {n:"Peixe-pão",t:41,d:"Este peixe cúbico é conhecido por sua mente particularmente quadrada. É até um peixe bastante estúpido, tornando fácil capturá-lo.",ep:2,g:269,l:1,wd:true,fm:true,w:3,p:10};
I.u[1751] = {n:"Peixe-pão Estripado",t:62,d:"O peixe-pão agora pode ser usado como um ingrediente.",ep:2,g:270,l:1,wd:true,fm:true,w:2,p:1};
I.u[1752] = {n:"Peixes Pão Frito **",t:49,d:"Este delicioso bastão é feito dos melhores pedaços light de vários peixes cúbicos. Seu gosto encanta crianças, embora tenha poucos valores nutritivos.",ep:2,g:71,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:60};
I.u[1753] = {n:"Peixe-pão Frito ***",t:49,d:"Este delicioso bastão é feito dos melhores pedaços light de vários peixes cúbicos. Seu gosto encanta crianças, embora tenha poucos valores nutritivos.",ep:2,g:72,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1754] = {n:"Peixe Iglu",t:41,d:"Esta espécie rara de peixe-pão costumava viver, como o nome indica, nas águas congeladas do extremo norte. Devido à sua dieta polar, é fresco e rico em fibras.",ep:1,g:271,l:1,wd:true,fm:true,w:3,p:100};
I.u[1755] = {n:"Peixe Iglu Estripado",t:62,d:"Este peixe iglu agora pode ser usado como um ingrediente.",ep:1,g:272,l:1,wd:true,fm:true,w:2,p:100};
I.u[1756] = {n:"Peixe-pão Frito ****",t:49,d:"Este Peixe de Iglu frito, além de ser realmente delicioso, tem bons valores nutritivos.",ep:1,g:73,l:1,wd:true,fm:true,w:1,c:"Ci<10",u:true,ut:true,p:10000};
I.u[1757] = {n:"Caranguejo Surimi",t:41,d:"Este caranguejo de forma peculiar é muito apreciado por sua grande quantidade de carne. Também é o único caranguejo que você consegue pegar com uma vara de pescar, porque ele tem o instinto natural de cortar linhas com suas garras... que não cortam nada!",ep:2,g:273,l:1,wd:true,fm:true,w:3,p:1};
I.u[1758] = {n:"Caranguejo Surimi Estripado",t:62,d:"Este caranguejo surimi agora pode ser usado como ingrediente.",ep:2,g:274,l:1,wd:true,fm:true,w:2,p:1};
I.u[1759] = {n:"Espeto de Caranguejo Exótico",t:41,d:"Ainda que seja um parente distante do Bastão de Caranguejo, este aqui é muito mais inteligente, o que obviamente torna-o mais raro. Às vezes, acontece de este caranguejo render-se aos seus instintos ruins depois de passar noites bebendo.",ep:1,g:275,l:1,wd:true,fm:true,w:3,p:20};
I.u[1760] = {n:"Caranguejo Surimi Exótico Estripado",t:62,d:"Este surimi exótico agora pode ser usado como ingrediente.",ep:1,g:276,l:1,wd:true,fm:true,w:2,p:20};
