I.u[233] = {n:"Kaiser",t:7,d:"Kaiser era o nome do Dragão Porco que destruiu a Vila de Bounkaïda há muito tempo. Quando a milícia já tinha conseguido extrair o melhor deste monstro, os ferreiros usam os restos de Kaiser para criar várias armas. Este martelo é uma delas.",ep:2,g:10,l:82,wd:true,fm:true,w:20,an:15,e:[20,4,1,1,30,200,false,false],c:"CS>80&CI>80&CA>50",s:58,p:10000};
