I.u[244] = {n:"Pequena Pá de Raspagem",t:8,d:"Uma pá extremamente bem forjada, a qual o tornará um corajoso combatente.",ep:1,g:5,l:13,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>3&CC>10",p:700};
I.u[245] = {n:"Pá Raspada",t:8,d:"Uma pá bem forjada que despertará um valente guerreiro adormecido em você.",ep:1,g:5,l:15,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>10&CC>5",p:850};
I.u[246] = {n:"Grande Pá Arranhada",t:8,d:"Uma pá extremamente bem forjada que despertará um valente combatente adormecido em você.",ep:1,g:5,l:17,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>7&CC>10",p:1000};
I.u[247] = {n:"Poderosa Pá Estridente",t:8,d:"Uma pá extremamente bem feita que o fará um combatente corajoso.",ep:1,g:5,l:19,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>9&CC>10",p:1150};
I.u[250] = {n:"Ares",t:8,d:"Algo entre um machado e uma pá, Ares foi uma das sete armas usadas pelo demônio Kajlir para dominar a Fraternidade dos Enutrofs coletores do Dofus Púrpuro.",ep:9,g:9,l:72,wd:true,fm:true,w:50,an:16,e:[10,4,1,1,50,50,false,false],c:"CC>200",p:14000};
I.u[251] = {n:"Barba Cinza",t:8,d:"Barba Grisalha foi a arma favorita do demônio anão Assan Cehef, que aterrorizou muitos moradores de vilarejos atacando de surpresa.",ep:1,g:11,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1250};
I.u[252] = {n:"Pequeno Cinto de Vitalidade",t:10,d:"Este cinto aumenta a vida do portador: ele se sentirá mais seguro no meio de uma luta.",ep:1,g:9,l:1,wd:true,fm:true,w:6,p:100};
I.u[253] = {n:"Cinto Vitalício",t:10,d:"Este cinto aumenta a vida de quem o usar. Isso certamente será para você se sentir mais seguro durante as lutas.",ep:1,g:9,l:2,wd:true,fm:true,w:9,p:200};
I.u[254] = {n:"Grande Cinto Vitalish",t:10,d:"Este cinto aumenta a vida de quem possuí-lo, para dar mais segurança durante uma luta.",ep:1,g:9,l:6,wd:true,fm:true,w:9,p:300};
I.u[255] = {n:"Imponente Cinto de Vitalidade",t:10,d:"Este cinto aumenta a vida de quem possuí-lo, para dar mais segurança durante uma luta.",ep:1,g:9,l:8,wd:true,fm:true,w:9,p:400};
I.u[256] = {n:"Pequeno Cinto de Força",t:10,d:"Este cinto aumenta a força de seu portador.",ep:1,g:11,l:1,wd:true,fm:true,w:6,p:100};
I.u[257] = {n:"Cinto de Força",t:10,d:"Este cinto aumenta a força de quem possuí-lo.",ep:1,g:11,l:2,wd:true,fm:true,w:12,p:200};
I.u[258] = {n:"Grande Cinto Forcish",t:10,d:"Este cinto aumenta a força de quem possuí-lo.",ep:1,g:11,l:6,wd:true,fm:true,w:12,p:300};
I.u[259] = {n:"Imponente Cinto de Força",t:10,d:"Este cinto aumenta a força de quem possuí-lo.",ep:1,g:11,l:8,wd:true,fm:true,w:12,p:400};
I.u[260] = {n:"Pequeno Cinto Ágil",t:10,d:"Este cinto aumenta a agilidade de seu usuário.",ep:1,g:8,l:1,wd:true,fm:true,w:6,p:100};
I.u[261] = {n:"Belt Nimblish",t:10,d:"Este cinto aumenta a agilidade do seu portador.",ep:1,g:8,l:3,wd:true,fm:true,w:10,p:200};
I.u[262] = {n:"Grande Cinto Ligeirish",t:10,d:"Este cinto aumenta a agilidade de quem possuí-lo.",ep:1,g:8,l:6,wd:true,fm:true,w:10,p:300};
I.u[263] = {n:"Imponente Cinto de Agilidade",t:10,d:"Este cinto aumenta a agilidade de quem possuí-lo.",ep:1,g:8,l:8,wd:true,fm:true,w:10,p:400};
I.u[264] = {n:"Pequeno Arco Desconcertante",t:2,d:"O Arco Desconcertante é um arco clássico, e mesmo assim, uma interessante arma.",ep:1,g:3,l:14,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>14&CS>4",p:750};
I.u[265] = {n:"Arco Desconcertante",t:2,d:"O Arco Desconcertante é uma arma clássica, mas ainda pode ser muito útil.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>16&CS>6",p:900};
I.u[266] = {n:"Grande Arco Desconcertante",t:2,d:"O Arco Perturbante é um clássico, porém uma arma muito poderosa.",ep:1,g:3,l:18,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>18&CS>8",p:1050};
I.u[267] = {n:"Poderoso Arco Perturbador",t:2,d:"O Arco Perturbador é uma arma básica mas isso não significa que ela não se deve ao interesse...",ep:1,g:3,l:19,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>19&CS>9",p:1200};
I.u[270] = {n:"Xaveur",t:2,d:"O Xaveur é um arco eficiente. Ele já pertenceu uma vez ao Grande Padeiro Xavier. Entre duas remessas, ele tomava o tempo de distribuir pão aos monstros que cercavam sua padaria.",ep:7,g:5,l:60,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,9,30,100,false,true],c:"CA>60&CV>15",p:9050};
I.u[271] = {n:"O Martelo de Chafer",t:7,d:"Uma bela, estranha e fascinante arma que lhe permitirá lutar corpo a corpo, da maneira como o melhor dos Chafers faria.",ep:1,g:9,l:21,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,40,30,false,false],c:"CS>10&CI>11",p:1350};
I.u[272] = {n:"Nomoon",t:2,d:"Este arco é poderoso o suficiente para disparar uma flecha na lua.",ep:7,g:9,l:28,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,12,30,50,false,true],c:"CA>28&CV>5",p:2350};
I.u[273] = {n:"A Corda de Yamato",t:2,d:"A Corda de Yamato tocou muitos corações de monstros. É uma boa arma, capaz de apontar a flecha na direção dos locais mais escondidos.",ep:7,g:10,l:33,wd:true,fm:true,w:18,an:10,tw:true,e:[10,4,2,7,30,50,false,false],c:"CA>33&CS>10",p:3000};
I.u[274] = {n:"O Pedaço do Quebra-Cabeça da Garra",t:51,d:"Um item raro proveniente do tesouro de Dodge, que foi um dos maiores discípulos de Ecaflip de Amakna.",ep:1,g:267,l:12,wd:true,fm:true,w:1,p:100};
I.u[276] = {n:"Peça de Tesouro Excêntrico",t:15,d:"Uma peça muito rara de um tesouro escondido pelo famoso Dodge, um dos maiores guerreiros Ecaflip de Amakna.",ep:1,g:268,l:12,wd:true,fm:true,w:1,p:100};
I.u[278] = {n:"Anel dos Rochedos",t:9,d:"Um anel com uma pedra rara. Deve seu nome às diferentes pedras usadas para criá-lo.",ep:1,g:4,l:15,wd:true,fm:true,w:4,p:800};
I.u[279] = {n:"Lágrima de Bouftou",t:1,d:"De acordo com um renomado aventureiro, este amuleto contém uma lágrima de Gobball, com as mesmas propriedades e cheiro daquelas obtidas das decocções de couro de Gobball.",ep:1,g:7,l:2,wd:true,fm:true,w:5,p:200};
I.u[280] = {n:"Colar de Arco-Íris",t:1,d:"Este colar é apreciado pelos colecionadores, você certamente conseguirá um excelente preço.",ep:1,g:11,l:6,wd:true,fm:true,w:6,p:300};
I.u[281] = {n:"Maçã",t:42,d:"Esta maçã lhe devolve alguns pontos de vida perdidos. Mas tenha cuidado, se você comer uma maçã quando estiver com PV máximo, a maçã será desperdiçada.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[282] = {n:"Frasco de Vida Superior",t:12,d:"Este frasco devolve um pouco de seus Pontos de Vida... Hem, pode ser uma boa idéia verificar se você já não tem todos os PV antes de bebê-lo, ou então você desperdiçará o frasco de vida...",ep:1,g:39,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[283] = {n:"Frasco de Vida",t:12,d:"Este frasco devolve um pouco de seus Pontos de Vida... Hem, pode ser uma boa idéia verificar se você já não tem todos os PV antes de bebê-lo, ou então você desperdiçará o frasco de vida...",ep:1,g:3,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[284] = {n:"Sal",t:48,d:"Em estado mineral, o sal deixa seu pão mais salgado e gostoso.",ep:2,g:260,l:1,wd:true,fm:true,w:1,p:10};
I.u[285] = {n:"Farinha de Trigo",t:52,d:"Esta farinha é obtida na moagem do trigo. É um ingrediente essencial para fazer pão, panquecas, waffles e bolos deliciosos, mas principalmente para jogar jogos ridículos com seus amigos de infância.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[286] = {n:"Fermento de Padeiro",t:48,d:"É um ingrediente essencial para a fermentação de pão.",ep:1,g:137,l:1,wd:true,fm:true,w:1,p:1};
I.u[287] = {n:"Semente de Gergelim",t:58,d:"Esta semente extremamente rica em proteína é um ingrediente seleto para o fabrico de pão saboroso, mas o cultivo de gergelim é especialmente delicado em nosso clima dofusiano. Como resultado, uma semente muito rara e cara.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[288] = {n:"Semente de Girassol Selvagem",t:58,d:"Esta semente é rica em proteína e tem um gosto peculiar ao aroma de Pão de fôrma. Para achá-la só se precisa matar um Girassol Selvagem ou comprar um!",ep:1,g:6,l:12,wd:true,fm:true,w:1,p:10};
I.u[289] = {n:"Trigo",t:34,d:"O trigo é, desde o inicio dos tempos, um ingrediente essencial na dieta de fibras dos habitantes de Amakna e Tofus.",ep:1,g:9,l:1,wd:true,fm:true,w:2,p:0};
I.u[290] = {n:"Cogumelo",t:15,d:"Com ou sem creme, cogumelos são muito gostosos. O jeito mais fácil de pegar alguns é matando um Cogu-Cogu.",ep:1,g:1,l:5,wd:true,fm:true,w:1,p:10};
I.u[291] = {n:"Pele de Boolobo",t:54,d:"Esta pele é diferente das outras, tem propriedades particulares que a fazem muito apreciada por alquimistas.",ep:1,g:8,l:70,wd:true,fm:true,w:1,p:1};
I.u[292] = {n:"Glândulas de Boolobo",t:15,d:"Estas enormes glândulas são cobertas com uma estranha penugem, particularmente suave e morna. É quase impossível recuperá-los intactos depois de uma luta contra um Boolobo, o que explica seu extravagante preço.",ep:1,g:12,l:70,wd:true,fm:true,w:20,p:50};
I.u[293] = {n:"Pequena Pá de Crackler",t:8,d:"A única coisa mais sólida que um Crackler é um próprio Crackler. Por isso que esta pá projetada para caçar Cracklers é feita de Pedra de Crackler.",ep:1,g:7,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1200};
I.u[294] = {n:"Pá de Crackler",t:8,d:"A única coisa tão sólida quanto um Crackler é um Crackler, é por isso que esta pá, projetada para a caça de Crackler, é feita de Pedra de Crackler.",ep:1,g:7,l:23,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>8&CC>15",p:1600};
I.u[295] = {n:"Grande Pá de Crackler",t:8,d:"A única coisa tão sólida quanto um Crackler é um Crackler, é por isso que esta pá, projetada para a caça de Crackler, é feita de Pedra de Crackler.",ep:1,g:7,l:26,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>11&CC>15",p:2000};
I.u[296] = {n:"Poderosa Pá de Crackler",t:8,d:"A única coisa tão sólida quanto um Crackler é um Crackler, é por isso que esta pá, projetada para a caça de Crackler, é feita de Pedra de Crackler.",ep:1,g:7,l:29,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>14&CC>15",p:2400};
I.u[297] = {n:"Botas de Pequeno Gobball",t:11,d:"Com estas botas feitas de Couro de Gobball, criadores podem facilmente se aproximar e matar outros Gobballs, graças ao odor que elas liberam.",ep:1,g:3,l:1,wd:true,fm:true,w:2,p:100};
I.u[298] = {n:"Sandálias de Tofu",t:11,d:"Estas sandálias são feitas das penas de Tofu cozido e a sola é feita de um bico de Tofu, um material muito resistente. Por razões inexplicáveis, elas às vezes fazem o portador... tão idiota quanto um Tofu de verdade.",ep:1,g:4,l:1,wd:true,fm:true,w:7,p:100};
I.u[299] = {n:"Botas de Faillette",t:11,d:"A melhor defesa é o ataque. Com estas botas antiagressão, você exterminará facilmente os agressores.",ep:1,g:8,l:24,wd:true,fm:true,w:30,p:1800};
I.u[300] = {n:"Sementes de Papoula",t:58,d:"Muitos mistérios cercam esta semente, mas nós sabemos que elas fazem um bolo DI-VI-NO!",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:1};
I.u[301] = {n:"Pena de Tofu",t:53,d:"As penas de um Tofu são usadas para acolchoar assentos ou fazer ombreiras. Mais uma coisa, só não se esqueça que um quilo de penas é igual a um quilo de chumbo.",ep:1,g:14,l:4,wd:true,fm:true,w:1,p:10};
I.u[302] = {n:"Abóbora",t:68,d:"As abóboras crescem nos campos. Dificilmente são maiores que as glândulas de um Boolobo, mas, certamente, têm um gosto melhor.",ep:4,g:12,l:15,wd:true,fm:true,w:5,p:10};
I.u[303] = {n:"Madeira de Freixo",t:38,d:"A madeira de Freixo não é uma madeira de qualidade, mas você pode achá-la em qualquer lugar e cresce em um ritmo relativamente rápido. Seja cuidadoso, não a armazene próxima a uma fonte forte de calor, ela é inflamável.",ep:1,g:17,l:1,wd:true,fm:true,w:5,p:0};
I.u[304] = {n:"Couro de Gobball",t:56,d:"Este couro muito resistente é o principal recurso de curtidores que fazem botas e cintos, e também correias de chicote. A única desvantagem é que ele cheira como um Gobball no cio... Difícil de se ter encontros agradáveis em tais condições.",ep:1,g:16,l:9,wd:true,fm:true,w:2,p:1};
I.u[305] = {n:"Dente de Wabbit",t:47,d:"Usado para comer cenouwawa, os dentes de Wabbit são muito úteis para fazer poções com propriedades para ressuscitar.",ep:8,g:13,l:20,wd:true,fm:true,w:1,p:1};
I.u[306] = {n:"Flor de Dandélio Diabólico",t:35,d:"Esta Flor perde suas propriedades tóxicas quando corretamente fervida e seca, dando um ótimo chá de ervas. Mas o Dandélio Diabólico é usado principalmente pelos jovens em busca de romance. Realmente, quem nunca soprou as sementes de um Dandélio Diabólico no pescoço de sua amada? Você sabe, estas suntuosas sementinhas tão suaves e mornas quanto um raio solar que desliza pelas folhas ainda cobertas de orvalho. Bem, talvez os Iops ainda não... já que eles inalam as sementes, em vez de soprarem, e acabam se sufocando lamentavelmente em terríveis convulsões.",ep:1,g:18,l:5,wd:true,fm:true,w:1,p:10};
I.u[307] = {n:"Asas de Moskito",t:104,d:"Uma característica muito distintiva destas asas muito finas é que elas encorajam o pensamento daqueles que ousam mastigá-las. Elas têm quase o mesmo gosto que os ovos podres de Kwak. É por isso que elas são essencialmente usadas na fabricação de poções de sabedoria.",ep:1,g:19,l:2,wd:true,fm:true,w:1,p:1};
I.u[308] = {n:"Casco de Dragonete Branco",t:111,d:"Este casco é quase inquebrável, mas, se for polido durante gerações, os melhores joalheiros podem usar suas propriedades mágicas para fazer amuletos com poderes excepcionais.",ep:11,g:21,l:64,wd:true,fm:true,w:5,p:1};
I.u[309] = {n:"Pétala de Rosa Demoníaca",t:35,d:"Estas pétalas são bonitas, eu diria que um presente ideal para conquistar sua amada. Todavia, é melhor não usar pétalas de rosa em infusão, o que causa efeito contrário...",ep:1,g:20,l:6,wd:true,fm:true,w:1,p:10};
I.u[310] = {n:"Osso de Chafer",t:47,d:"Este osso quase inquebrável torna-se macio em contato com a água, o que facilita as coisas para os alquimistas.",ep:1,g:15,l:34,wd:true,fm:true,w:5,p:1};
I.u[311] = {n:"Água",t:15,d:"A água é útil para muitas coisas, e dá mais gosto para o energético.",ep:1,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[312] = {n:"Ferro",t:39,d:"Ferro é essencial para ferreiros e pessoas que trabalham com metal em geral. Usam até mesmo para passar.",ep:1,g:24,l:1,wd:true,fm:true,w:5,p:0};
I.u[313] = {n:"Ouro",t:39,d:"Ouro é um metal precioso e raro. Graças às suas intrínsecas qualidades, ele é um elemento essencial na fabricação de armas ou itens belos e poderosos.",ep:1,g:22,l:80,wd:true,fm:true,w:5,p:0};
I.u[314] = {n:"Lã de Tabi",t:57,d:"Esta lã não é muito leve, mas os costureiros podem fazer tecidos magníficos com ela. A falha principal está na cor bege e em sua aspereza. Isso a torna inapropriada para fazer roupas debaixo.",ep:0,g:655,l:1,wd:true,fm:true,w:1,p:50};
I.u[315] = {n:"Diamante",t:50,d:"O diamante é o melhor amigo do joalheiro, mas ele requer grande habilidade para ser trabalhado. Para encontrar algum, você freqüentemente precisa se aventurar em perigosas minas. Felizmente, os diamantes são eternos.",ep:1,g:25,l:50,wd:true,fm:true,w:10,p:5000};
I.u[316] = {n:"Esmeralda",t:50,d:"Com seu verde vívido, esta magnífica pedra preciosa pode transformar facilmente uma mulher estúpida e corpulenta em uma princesa sem precisar de nenhuma magia oculta.",ep:1,g:23,l:50,wd:true,fm:true,w:10,p:5000};
I.u[317] = {n:"Pequeno Cajado de Tabi",t:4,d:"Este cajado costumava ser muito útil para criadores de Amakna que queriam manter seus rebanhos de Tabis juntos. Este cajado é tão leve que você pode correr facilmente atrás de seu Tabis perdido. Nenhum peso para carregar, sem cansaço. Perfeito!",ep:7,g:6,l:30,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:2650};
I.u[318] = {n:"Cajado de Tabi",t:4,d:"Este cajado costumava ser muito usado pelos criadores de Amakna, que queriam manter juntos seus rebanhos de Tabis. Este cajado é tão leve que você pode perseguir facilmente seu Tabis perdido. Sem peso para carregar, sem corridas cansativas. Perfeito!",ep:7,g:6,l:34,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:3200};
I.u[319] = {n:"Cajado do Grande Tabi",t:4,d:"Este cajado costumava ser muito útil para os criadores de Amakna, que queriam manter seus flocos de Tabis juntos. Este cajado é tão leve que pode se perder entre os Tabis. Por ser leve, não desgasta quem o manipula. Perfeito!",ep:7,g:6,l:37,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>25",p:3750};
I.u[320] = {n:"Poderoso Cajado Tabi",t:4,d:"Este cajado costumava ser muito útil para os domadores de Amakna que queriam manter os seus rebanhos de Tabis juntos. Este cajado é tão leve que você pode facilmente correr atrás dos seus Tabis perdidos. Nenhum peso para carregar, não ficando sem respiração. Perfeito!",ep:7,g:6,l:40,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>30",p:4300};
I.u[323] = {n:"Amuleto da Aura",t:1,d:"Esse tipo de amuleto dá habilidades especiais a quem possuí-lo;\r\n            ele pode deixá-lo fascinado por uma misteriosa aura que corre pelo seu corpo e normalmente aumenta dez vezes as habilidades físicas.",ep:1,g:4,l:43,wd:true,fm:true,w:5,p:5000};
I.u[324] = {n:"Amuleto de Krokette",t:1,d:"Este amuleto fica rosa quando você está de bom humor. Dizem que ele aumenta dez vezes as chances de seu personagem encontrar bons itens.",ep:1,g:7,l:6,wd:true,fm:true,w:5,p:300};
I.u[325] = {n:"Amuleto de Sram",t:1,d:"Este amuleto, feito à mão por um dos maiores joalheiros entre os discípulos de Sram, é composto de pequenos crânios cravados em osso. É, de fato, um amuleto exclusivo que permite ao possuidor escapar mais facilmente de situações perigosas.",ep:1,g:3,l:2,wd:true,fm:true,w:5,p:200};
I.u[326] = {n:"Amuleto Deulegarnoulle",t:1,d:"O amuleto de Deulegarnoulle vem das regiões nórdicas;\r\n            ele dá ao seu portador a capacidade de invocar criaturas mais facilmente.",ep:1,g:2,l:33,wd:true,fm:true,w:4,p:3000};
I.u[327] = {n:"Lâmina de Ginete Chato",t:6,d:"Esta lâmina foi primeiramente forjada para os Ginetes Karnes, mas infelizmente era muito pesada para estes fracos duendes. Mas ela é uma arma muito leve para humanos normais, leve o bastante para dar golpes rápidos.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,50,20,false,false],c:"CS>32",p:900};
I.u[328] = {n:"Koupe-koupe",t:6,d:"Esta estranha lâmina dupla foi originalmente usada para derrubar árvores e explorar florestas densas. Os lenhadores logo entenderam que ela também era uma arma excelente contra todos os tipos de ameaça.",ep:1,g:4,l:18,wd:true,fm:true,w:28,an:14,e:[6,5,1,1,20,60,false,false],c:"CS>36",p:1050};
I.u[329] = {n:"O Arco do Triunfo",t:2,d:"Como seu nome indica, este arco lhe ajudará a ganhar facilmente uma luta. Um grande arquiteto sem nenhum pingo de imaginação, usou o mesmo nome em um de seus monumentos.",ep:7,g:11,l:30,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,10,30,50,false,true],c:"CA>30&CC>5&CS>10",p:1950};
I.u[331] = {n:"Arco de Chuva",t:2,d:"É uma escolha de arco em Amakna. As pesoas dizem que você pode encontrar um tesouro onde as flechas caem. Estranhamente, só é eficiente quando os raios solares são refratados pela chuva...",ep:7,g:16,l:22,wd:true,fm:true,w:19,an:10,tw:true,e:[10,5,2,11,30,50,false,true],c:"CA>22&CC>15",p:1500};
I.u[332] = {n:"Arco de Joana",t:2,d:"Como Joana costumava ouvir soluços de Tabis em sua cabeça, as pessoas pensavam que ela era um pouco louca. E, para evitar que ela se ferisse, confiscaram seu arco e, finalmente, decidiram queimá-la para agitar as coisas duante a cerimônia de abertura da taverna.",ep:7,g:15,l:30,wd:true,fm:true,w:23,an:10,tw:true,e:[10,4,2,9,30,50,false,true],c:"CS>10&CA>30",p:2550};
I.u[333] = {n:"Bastão Bre Ad",t:3,d:"Originalmente feito para ser consumido, este bastão se tornou uma arma perigosa. Xavier, o Padeiro, o esqueceu em seu forno durante 234 anos, quando ele saiu para dar pão aos monstros ao redor da sua padaria.",ep:3,g:9,l:50,wd:true,fm:true,w:1,an:11,e:[5,3,3,5,50,50,false,true],c:"CW>40&CI>100",p:6650};
I.u[334] = {n:"Varinha Mágica de Liriel",t:3,d:"Esta varinha mágica uma vez pertenceu a Liriel, um discípulo de Eniripsa, que morreu por overdose de morango e perdeu suas asas em uma dor martirizante, um fim terrível que deve ter feito seu sangue gelar. Os coletores estão desesperados para conseguir esta varinha mágica;\r\n            dizem ser amaldiçoada.",ep:7,g:5,l:20,wd:true,fm:true,w:13,an:11,e:[5,5,2,3,50,50,false,true],c:"CI>40",p:1300};
I.u[335] = {n:"Cajado de Bwork Mago",t:4,d:"Sem este cajado, os Bworks Magos são tão indefesos quanto Tofus. Isso nos diz o quão poderosa é essa arma.",ep:7,g:1,l:58,wd:true,fm:true,w:28,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>58&CA>20",p:8900};
I.u[336] = {n:"Cajado do Avô do Wabbit",t:4,d:"Este Cajado faz o Cenouwawa levitar... Não é muito útil durante as lutas, mas pode ser de bom uso alguma hora.",ep:8,g:1,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",p:2900};
I.u[337] = {n:"Arco de Bwork Arqueiro",t:2,d:"O Arco de Bwork Arqueiro é simples de usar. Ele foi projetado para se adaptar aos Bwork Arqueiros não-muito-espertos, o que indica que um Tofu quase poderia usá-lo... Entretanto, você deve ser tão forte quanto um Crackler para curvá-lo.",ep:7,g:4,l:20,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>20&CA>20",p:1300};
I.u[338] = {n:"Lâmina de Pequeno Bwork",t:6,d:"Esta espada de aparência rudimentar satisfaz os Bworks mais idiotas, ou seja, os que são incapazes de usar um arco ou um cajado... Alguns deles até confundem a lâmina com o punho. Os inimigos não conseguem deixar de dar boas risadas.",ep:1,g:13,l:21,wd:true,fm:true,w:30,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>42",p:1400};
I.u[339] = {n:"Lâmina de Chafer",t:6,d:"Esta lâmina pertenceu a Metzger, o Açougueiro, que a usou para esculpir ossos. Porém, o Chafer conseguiu roubá-la do Açougueiro e, então, a lâmina caiu nas mãos dele como uma terrível arma, responsável por muitas amputações.",ep:1,g:5,l:27,wd:true,fm:true,w:20,an:14,e:[20,6,1,1,15,60,false,false],c:"CS>54&CC>10",p:2100};
I.u[340] = {n:"Leurnettes",t:5,d:"Estas adagas permitem que você roube qualquer coisa e, acima de tudo, de qualquer pessoa, ou vice-versa... ninguém lembra da história direito.",ep:1,g:9,l:12,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>12",p:600};
I.u[341] = {n:"Adagas de Eurfolles",t:5,d:"Estas lendárias adagas são verdadeiros itens de colecionador para qualquer Sram que se preze. Elas são tão veneradas que alguns Srams se recusam a roubá-las.",ep:7,g:10,l:46,wd:true,fm:true,w:10,an:13,e:[10,2,1,1,30,50,false,false],c:"CA>46",p:5600};
I.u[342] = {n:"Martelo Pickeur",t:7,d:"Este martelo muito especial foi feito de bicos de Kwaks. Por isso, ele é tão pontudo que pode cortá-lo ao meio!",ep:5,g:12,l:18,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>12&CS>6",p:1100};
I.u[345] = {n:"Pequena Pá de Teuze",t:8,d:"Um discípulo de Enutrof que bebeu muitos energéticos na taverna percebeu um dia que, originalmente designada para o trabalho de construção, era uma excelente arma.",ep:1,g:8,l:25,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>5&CC>20",p:1900};
I.u[346] = {n:"Anel de Ano Rak",t:9,d:"De acordo com algumas lendas, este anel fornece boa proteção contra tempos ruins. De fato, isto nunca foi provado, porque nunca houve um dia chuvoso em Amakna.",ep:1,g:34,l:17,wd:true,fm:true,w:4,p:1000};
I.u[347] = {n:"Rizoma Dourada",t:8,d:"Esta pá é uma ferramenta excelente para um jardineiro cortar rizomas, um tipo de erva daninha. Também é uma arma excelente para cortar qualquer coisa.",ep:1,g:10,l:40,wd:true,fm:true,w:30,an:16,e:[10,4,1,1,50,50,false,false],c:"CS>10&CC>30",p:4400};
I.u[348] = {n:"Botas de Aipo-Chá",t:11,d:"Estas botas pertenceram a um cozinheiro sempre muito apressado. Ele sempre corria por toda Amakna para encontrar aipo e chá.",ep:2,g:5,l:53,wd:true,fm:true,w:20,p:6700};
I.u[350] = {n:"Prata",t:39,d:"Prata é um metal brilhante bem apreciado pelos joalheiros. Diferente do que as pessoas falam e querem que você acredite, ela não tem efeito particular em vampiros. Ao menos que sejam vampiros miseráveis .... Ou vampiros de mentira.\nVampiros trabalham com jóias?... Eu.... Acho.... Que não..... De qualquer modo, seria desagradável se um vampiro, que só sai de casa para procurar sangue, tivesse um emprego.",ep:1,g:28,l:60,wd:true,fm:true,w:5,p:0};
I.u[351] = {n:"Energético de Amakna",t:37,d:"Este energético lhe permitirá recuperar pontos de vida. Aqui vai um conselho de pai: ‘É melhor engolir o energético, do que ele a você‘.",ep:2,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[352] = {n:"Pequena Espada Sagrada",t:6,d:"Uma espada sagrada dada a jovens guerreiros durante seu treinamento.",ep:1,g:1,l:13,wd:true,fm:true,w:30,e:[5,4,1,1,50,50,false,false],c:"CS>26&CV>5",p:700};
I.u[353] = {n:"Espada de Pequeno Cavaleiro",t:6,d:"A pequena espada de cavaleiro é eficiente e robusta. Se bem usada, causa sérios danos aos seus inimigos.",ep:7,g:9,l:21,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>42",p:1400};
I.u[354] = {n:"O Klebik",t:6,d:"Este tipo de espada foi forjado para os guarda-costas de um lojista famoso e rico. Seu principal uso consiste em amedrontar gatunos, mas ela também pode ser eficiente em acabar com corsários, ou com honestos, mas importunos clientes.",ep:1,g:11,l:25,wd:true,fm:true,w:20,e:[12,4,1,1,30,60,false,false],c:"CS>50&CW>5",p:1850};
I.u[355] = {n:"Anel Valuable",t:9,d:"Este anel dá força e coragem ao seu portador.",ep:1,g:7,l:12,wd:true,fm:true,w:4,p:600};
I.u[356] = {n:"Cinto de Resistência",t:10,d:"Este simples cinto aumenta a resistência de quem possuí-lo.",ep:1,g:3,l:27,wd:true,fm:true,w:16,p:2200};
I.u[357] = {n:"Cauda",t:6,d:"Esta Espada simboliza a parte do corpo que os seguidores de Ecaflip mais se orgulham. Ela resume bem o estado de espírito que os jogadores estão.",ep:1,g:18,l:13,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>26&CA>10",p:650};
I.u[358] = {n:"Cauda Infernal",t:6,d:"A Cauda Infernal é realmente infernal... Pode deixar loucos seus inimigos e companheiros de equipe. Tenha cuidado, pois isso pode tornar seus companheiros em inimigos, se você não souber usar corretamente. Apesar de tudo, o inverso nunca acontece.",ep:1,g:18,l:21,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>42&CA>10",p:1400};
I.u[359] = {n:"Ecalisor",t:9,d:"Há muito tempo, o Rei Alister Snoc deu este anel para Isidor, um gato esperto, famoso por sua agilidade incomparável.",ep:1,g:35,l:29,wd:true,fm:true,w:3,p:2400};
I.u[360] = {n:"Orelhas de Tiwabbit",t:106,d:"Estas peludas orelhinhas marrons emitem um cheiro de boolobo quando cozidas. Uma verdadeira delícia com recheio de geléia real.",ep:8,g:30,l:11,wd:true,fm:true,w:1,p:10};
I.u[361] = {n:"Cenouwawa",t:68,d:"É o único tipo de comida que um Tiwabbit Wosungree pode comer. É tão boa desculpa quanto qualquer uma para o seu grave retardamento.",ep:2,g:31,l:20,wd:true,fm:true,w:1,p:2};
I.u[362] = {n:"Pele de Larva Azul",t:59,d:"Esta pele muito lisa é um ótimo ingrediente para poções mágicas.",ep:1,g:32,l:2,wd:true,fm:true,w:1,p:2};
I.u[363] = {n:"Pele de Larva Laranja",t:59,d:"Esta pele muito lisa é um excelente ingrediente para poções mágicas.",ep:1,g:33,l:9,wd:true,fm:true,w:1,p:2};
I.u[364] = {n:"Pele de Larva Verde",t:59,d:"Esta pele bem lisa é um ingrediente excelente para poções mágicas.",ep:1,g:34,l:7,wd:true,fm:true,w:1,p:100};
I.u[365] = {n:"Pata de Aracne",t:103,d:"Uma pata muito fina, mas cabeluda. É muito estimada entre os alquimistas por suas propriedades revigorantes. É a pequena fraqueza que será a ruína deles.",ep:1,g:35,l:2,wd:true,fm:true,w:1,p:10};
I.u[366] = {n:"Bico de Tofu",t:47,d:"Não confie na ridícula aparência minúscula deste bico de Tofu, ele é bem afiado. Os arqueiros de Amakna os utilizam como pontas de flechas desde o início dos tempos.",ep:1,g:37,l:4,wd:true,fm:true,w:1,p:2};
I.u[367] = {n:"Ovo de Tofu",t:105,d:"Este ovo cheira a ovo podre até quando não está podre... apenas tente e imagine como ele cheira quando está realmente podre. Ainda por cima, ninguém sabe se foi o Tofu ou o ovo de Tofu que primeiro chegou em Amakna. Isto é bastante frustrante.",ep:1,g:38,l:4,wd:true,fm:true,w:1,p:1};
I.u[368] = {n:"Geléia de Morango",t:110,d:"Muitos aventureiros gananciosos estavam terrivelmente doentes devido a esta deliciosa Geléia. Como dizem, ‘tudo está envenenado, nada está envenenado, é a dose que importa\'. No caso da Geléia de Morango, evite a overdose.",ep:5,g:40,l:28,wd:true,fm:true,w:1,p:100};
I.u[369] = {n:"Geléia de Menta",t:110,d:"Muitos aventureiros gulosos ficaram terrivelmente doentes por causa desta deliciosa geléia de menta. Consumida com moderação, para prevenir mau hálito, por exemplo, ela terá propriedades calmantes na moral de suas tropas.",ep:5,g:41,l:10,wd:true,fm:true,w:1,p:100};
I.u[370] = {n:"Geléia Azulada Real",t:110,d:"Esta geléia deliciosa é o resultado da digestão e fermentação de mel da Geléia Real. Não comestível enquanto crua, apesar disso, é um ingrediente recomendado para doces.",ep:7,g:407,l:50,wd:true,fm:true,w:1,p:100};
I.u[371] = {n:"Sobrancelha de Moskito",t:15,d:"O Moskito tem sobrancelhas longas e finas que realçam a irresistível beleza dele. Pelo fato de ele ser tão sensível, suas sobrancelhas estão freqüentemente impregnadas com lágrimas dotadas de propriedades desconhecidas.",ep:1,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[372] = {n:"Bandana de Tiwabbit Preto",t:15,d:"Esta bandana deixa um Tiwabbit Preto com a aparência de um guerreiro feroz. O Wabbit Wambo está, aparentemente, por trás desse item personalizado.",ep:8,g:29,l:11,wd:true,fm:true,w:1,p:2};
I.u[373] = {n:"Caule de Dandélio Diabólico",t:36,d:"Este caule, tão flexível quanto uma cana, pode ser curvado, mas nunca quebra, o que faz dele uma boa opção na fabricação de chicotes ou outras correias, que são essenciais na educação dos filhos (ou então na de alguns pais...)",ep:1,g:45,l:6,wd:true,fm:true,w:1,p:10};
I.u[374] = {n:"Língua de Dandélio Diabólico",t:36,d:"A cor verde desta Língua decorre do consumo excessivo de geléia de menta, o que lhe mostra o quão viciado o Dandélio Diabólico é...",ep:1,g:555,l:5,wd:true,fm:true,w:1,p:2};
I.u[375] = {n:"Dente de Tofu Maléfico",t:47,d:"O Tofu Maléfico trocou seu ridículo biquinho por ridículo dentão. É difícil saber qual é o mais perigoso sem você mesmo testá-los.",ep:1,g:47,l:3,wd:true,fm:true,w:1,p:1};
I.u[376] = {n:"Asa de Tofu Maléfico",t:104,d:"Esta pequena e ridícula asa não é muito útil para o Tofu Maléfico. Ela só consegue soprar ar quente e, desse modo, desequilibrar os Moskitos.",ep:1,g:48,l:3,wd:true,fm:true,w:1,p:1};
I.u[377] = {n:"Espinho de Cogu-Cogu",t:15,d:"Este espinho venenoso protege o Cogu-Cogu de ataques corpo a corpo, mas também o proíbe de abraçar as pessoas que ele ama.",ep:1,g:49,l:5,wd:true,fm:true,w:1,p:1};
I.u[378] = {n:"Esporo de Cogu-Cogu",t:15,d:"O esporo é ‘a preciosa semente\' que permite ao Cogu-Cogu espalhar seus filhotes onde ele quiser, o que significa todos os lugares. Tenha cuidado porque os espormes são atraídos por pés fedorentos e pelo cheiro das Botas de Bowisse.",ep:1,g:50,l:5,wd:true,fm:true,w:1,p:1};
I.u[379] = {n:"Pinça de Caranguejo",t:47,d:"O Caranguejo pode facilmente exibir-se com estas enormes garras. É supostamente inquebrável.",ep:1,g:51,l:4,wd:true,fm:true,w:1,p:1};
I.u[380] = {n:"Folha de Menta Selvagem",t:36,d:"É o ingrediente principal da geléia verde, cheira a menta, não faz necessariamente nada se deduzindo que é uma simples menta...",ep:1,g:52,l:30,wd:true,fm:true,w:1,p:0};
I.u[381] = {n:"Morango",t:46,d:"É o ingrediente básico da Geléia de Morango. Então não fique contente ao pensar nestas frutas vermelhas deliciosas se sentir o cheiro de morango. Talvez você esteja apenas em sua área de caça.",ep:7,g:53,l:28,wd:true,fm:true,w:1,p:1};
I.u[382] = {n:"Unha Viajante de Karne",t:47,d:"Esta unha suja, que já passou por toda a parte, foi encontrada em locais não recomendáveis. Agora é sua vez de mantê-la distante destes tipos de lugares.",ep:3,g:54,l:16,wd:true,fm:true,w:1,p:1};
I.u[383] = {n:"Chifre de Gobball",t:47,d:"Os Chifres de Gobball são brilhantes e macios como couro. Por algumas razões obscuras, Osamodas os adoram...",ep:1,g:55,l:9,wd:true,fm:true,w:1,p:1};
I.u[384] = {n:"Lã de Gobball",t:57,d:"Esta espessa lã cheira como um Bwork que se menospreza. É, no entanto, muito morna e, ainda por cima, não irrita pele sensível. Os seguidores de Eniripsa confiam plenamente nisto, já que a usam em suas roupas íntimas.",ep:1,g:56,l:9,wd:true,fm:true,w:1,p:1};
I.u[385] = {n:"Saliva de Gobball",t:15,d:"Se esta purulenta baba cheira tão ruim, é porque os Gobballs passam a maior parte do tempo lambendo suas lãs...o que também dá aos Gobballs um terrível hálito. Isto não tem fim.",ep:1,g:57,l:9,wd:true,fm:true,w:1,p:1};
I.u[386] = {n:"Focinho de Javali",t:15,d:"Este focinho é uma ferramenta essencial para descobrir grandes bolotas na vegetação rasteira. Ao contrário do focinho de Dragão Porco, este aqui não pode ser consumido por causa de seu fedor asqueroso.",ep:1,g:58,l:14,wd:true,fm:true,w:1,p:1};
I.u[387] = {n:"Presa de Javali",t:47,d:"Esta presa permite ao Javali se proteger e se preciso, limpar seu focinho... Então, não se esqueça de limpar isto com água limpa antes de moê-lo.",ep:1,g:59,l:14,wd:true,fm:true,w:1,p:1};
I.u[388] = {n:"Pêlo de Javali",t:54,d:"Os pêlos de javali são naturalmente afilados, então eles são ideais para a fabricação de escovas e vassouras. Algumas pessoas desenvolveram sérias alergias a pêlos de javali, portanto, não se deve esfregá-los muito vigorosamente em você.",ep:1,g:60,l:14,wd:true,fm:true,w:1,p:1};
I.u[389] = {n:"Óleo de Girassol Selvagem",t:60,d:"Este óleo é altamente recomendado pelos dietistas por causa de sua alta proporção essencial de ácidos insaturados e polinsaturados gordurosos...",ep:1,g:61,l:12,wd:true,fm:true,w:1,p:100};
I.u[390] = {n:"Óleo de Noz",t:60,d:"Por causa de seu sabor suculento e sua proporção baixa de ácidos graxos saturados, o óleo de Noz é essencial para fazer massas de bolo. Pode ser mantido só alguns dias numa garrafa fechada.",ep:4,g:62,l:32,wd:true,fm:true,w:1,p:100};
I.u[391] = {n:"Noz de Cajueiro",t:58,d:"Esta Noz de Cajueiro pode ser usada para fazer óleo se for colhida verde. Uma vez seca, é igualmente usada como um brinquedo pelos ignorantes filhos dos Iops.",ep:4,g:63,l:32,wd:true,fm:true,w:1,p:10};
I.u[392] = {n:"Noz-Pecã",t:58,d:"A noz-pecã pode ser usada para fazer óleo, mas é melhor consumir ela seca se você não estiver interessado em suas propriedades laxativas.",ep:4,g:64,l:32,wd:true,fm:true,w:1,p:10};
I.u[393] = {n:"Bolota",t:58,d:"Os javalis adoram bolotas e quase todos se perguntam por quê.",ep:1,g:65,l:14,wd:true,fm:true,w:1,p:10};
I.u[394] = {n:"Avelã",t:58,d:"Quando combinada com uma barra de chocolate, esta pequena avelã é deliciosa. É uma pena não existir chocolate em Amakna!",ep:1,g:66,l:14,wd:true,fm:true,w:1,p:1};
I.u[395] = {n:"Trevo de Cinco Folhas",t:36,d:"Este trevo é um elemento básico da alimentação dos Tabis. No entanto, os criadores usam com cautela o trevo de cinco folhas porque ele causa flatulências nos Tabis.",ep:1,g:67,l:20,wd:true,fm:true,w:1,p:0};
I.u[396] = {n:"Óleo de Palma",t:60,d:"Graças ao seu gosto e aroma delicados, esse Óleo serve para qualquer tipo de desafio culinário;\r\n            desde comidas fritas até temperos franceses.",ep:3,g:68,l:32,wd:true,fm:true,w:1,p:100};
