I.u[10063] = {n:"Embelezador",t:31,d:"Um creme de beleza extremamente poderoso transformou você em.... uau! Apenas lembre-se que tanta beleza pode ser perigoso!",ep:0,g:13,l:1,wd:false,fm:false,w:0,m:true,p:1};
