I.u[10052] = {n:"Poção do Esquecimento: \'Laço Espiritual\'",t:43,d:"Esta poção lhe permite desaprender um nível do feitiço especial: \'Laço Espiritual\'.",ep:0,g:31,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[10053] = {n:"",t:9,d:"",ep:0,g:172,l:50,wd:false,fm:true,w:1,p:1};
I.u[10054] = {n:"Anel Vampyre",t:9,d:"Este anel ficou três anos imerso em excremento de Borcego. Pelo menos ainda é mágico.",ep:0,g:171,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4703};
I.u[10055] = {n:"Amuleto Vampyre",t:1,d:"Este amuleto deve evitar que Vampyres suguem o seu sangue. A idéia é que eles pensem que você é um Vampyre também.",ep:0,g:146,l:45,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:5500};
I.u[10056] = {n:"Cinto Vampyre",t:10,d:"Este cinto não somente brilha no escuro como também brilha no claro! Apesar de ser difícil de ter certeza.",ep:0,g:156,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4805};
I.u[10057] = {n:"Runa de Caça",t:78,d:"Nas palavras de Leza, o Sábio - \"Bem, caçadores ruins simplesmente vêem algo, certo, então atiram no alvo. Agora, bons caçadores, assim, eles vêem e atiram. Bons caçadores.\"\nVocê pode descobrir se tudo isso é verdade com esta runa.",ep:0,g:60,l:10,wd:false,fm:true,w:1,p:10};
I.u[10058] = {n:"Capa Vampyre",t:17,d:"Bram estava certo apesar de tudo, você deve tomar cuidado com pessoas excessivamente grandes que andam por aí com maquiagem e com capas compridas e brilhantes.",ep:0,g:168,l:41,wd:true,fm:true,w:5,c:"PO!10119",s:130,p:4550};
