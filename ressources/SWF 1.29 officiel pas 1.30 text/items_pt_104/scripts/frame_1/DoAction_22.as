I.u[10102] = {n:"Máscara Vampyre",t:16,d:"Esta máscara irá lhe proteger do sol pelo menos.",ep:0,g:244,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4725};
I.u[10103] = {n:"Carta para Fidji Merline",t:24,d:"Ebru Of El confiou a você esta carta para Fidji Merline. Você deverá seguir de maneira exata as instruções da artesã Brakmariana .",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[10104] = {n:"Manjedoura Modificada",t:24,d:"Esta majedoura foi modificada para oculatr as berinjelas. Você realmente não gostará de ficar preso nela, a não ser montado em cima de quem delas comeu. Os gases produzidos pelo consumo excessivo de berinjelas tem causado acidentes terríveis!",ep:0,g:759,l:1,wd:false,fm:true,w:0,p:1};
I.u[10105] = {n:"Perna Peluda",t:24,d:"Essa Pata da Aracne está coberta de pelos de Aracne e Miau e pode ser usada como uma arma amedrontadora quando Shush Tercesasti é confrontado com ela.",ep:0,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[10106] = {n:"Vampyrina",t:18,d:"Este monstro assustador e sem remorso suga o sangue de suas vítimas, e você será o próximo se não tomar cuidado. O que ela gosta acima de tudo é de terminar de comer a carne que ainda esteja grudada em qualquer osso que ela encontre. Nós avisamos que ela era assustadora.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10107] = {n:"Borcego",t:18,d:"Este mascote teve uma infância muito difícil e longa, começando pelo seu nome. Talvez isso tudo explique porque ele sempre ataca todos os Ouassingues que vê pela frente.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10108] = {n:"Vampyrina Fantasma",t:90,d:"Este Fantasma ainda não deixou o mundo dos vivos. Irá você encontrar uma maneira de ressuscitá-lo ou irá deixá-lo abandonado para todo o sempre?",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
