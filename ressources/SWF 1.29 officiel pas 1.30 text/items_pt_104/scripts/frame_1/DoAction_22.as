I.u[10118] = {n:"Canino Albino recém-treinado",t:32,d:"Esse Canino Albino foi treinado de acordo com o método de criação de Roy Sigfred.",ep:0,g:23,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10119] = {n:"Zumbificado",t:30,d:"De repente você se sente diferente...",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,c:"POX10055&POX10054&POX10056&POX10061&POX10058&POX10102",p:0};
