I.u[10168] = {n:"Botas de Chisp",t:11,d:"Ponch poliu suas botas todas as manhãs antes de montar em seu Dragossauro e sair em missões para salvar viúvas e orfãos. Principalmente viúvas... Ponch era muito charmoso.",ep:0,g:141,l:42,wd:true,fm:true,w:10,s:138,p:4850};
I.u[10169] = {n:"Escudo de Chisp",t:82,d:"Ponch usou este escudo orgulhosamente enquanto estava montado em seu Dragossauro, garantindo segurança para as ruas de Bonta.",ep:0,g:41,l:1,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10170] = {n:"Elmo de Chisp",t:16,d:"Este elmo protege muito bem a cabeça do seu usuário caso ele caia de um Dragossauro. Ele tambem faz você parecer um idiota, mesmo se não for.",ep:0,g:246,l:40,wd:true,fm:true,w:10,s:138,p:4400};
I.u[10171] = {n:"Luvas sem Dedos de Chisp",t:9,d:"Essas luvas de couro sem dedos são perfeitas pra uma surra de primeira-classe.",ep:0,g:173,l:44,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10172] = {n:"Amuleto Lesmoso",t:1,d:"Este amuleto irá alimentar uma lesma por dois, ou talvez três dias se acompanhado de um purê em sua cabeça.",ep:0,g:148,l:42,wd:true,fm:true,w:10,s:137,p:4900};
I.u[10173] = {n:"Botas Lesmosas",t:11,d:"As solas destas botas estão cobertas com uma meleca pegajosa e o interior com uma meleca escorregadia. Pelo menos não é o contrário.",ep:0,g:142,l:39,wd:true,fm:true,w:10,s:137,p:4105};
I.u[10174] = {n:"Capa Lesmosa",t:17,d:"Os poros nesta capa transpiram uma meleca pegajosa. Você irá parecer superior se deitar de costas e deixá-la carregá-lo pelo chão.",ep:0,g:169,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10175] = {n:"Chapéu Lesmoso",t:16,d:"Este capacete viscoso e úmido irá nutrir seu coro cabeludo e manter seu cabelo brilhante, se não saudáveis. Os dois olhos em seu topo podem ser conectados a seu crânio se você aceitar em inserir as pontas dos nervos em suas orelhas.",ep:0,g:247,l:42,wd:true,fm:true,w:10,s:137,p:4800};
