I.u[10121] = {n:"Rocha Pequena",t:51,d:"Esta pequena rocha serve para ativar os ladrilhos mágicos e acordar o espírito da água. É fácil de usar, simplesmente coloque a pedra no ladrilho e a mágica fará o resto. Simples e efetivo. Até mesmo um Iop poderia fazer, desde que não houvesse algum inimigo por perto pra ele arremesar a pedra.",ep:0,g:267,l:1,wd:false,fm:true,w:1,p:1};
I.u[10122] = {n:"Lista de Nurb",t:24,d:"Norb fez uma lista dos itens que você tem de trazer para Nara. Você precisará de 2 Baquelite, 10 unidades de Manganês, 20 Bauxitas, 15 Dolomitas e 20 Madeiras de Oliviolet.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
