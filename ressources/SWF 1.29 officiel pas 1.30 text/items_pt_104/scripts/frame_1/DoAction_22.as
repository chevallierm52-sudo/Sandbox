I.u[10124] = {n:"",t:32,d:"",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10125] = {n:"Arco do Bandido Arqueiro",t:2,d:"Este arco pertenceu a um bandido arqueiro que o usava para finalizar suas vítimas à distância, para não precisar sujar sua roupa. A mágica que dá vida a este item é tão poderosa que pode transformar a mais inocente das pessoas em um destemido bandido arqueiro.",ep:0,g:67,l:30,wd:true,fm:false,w:10,an:10,tw:true,e:[2,6,3,5,40,40,false,true],p:3000};
I.u[10126] = {n:"Espada do Bandido Duelista",t:6,d:"Esta espada pertenceu a um duelista lendário que não conseguia perseguir seus inimigos. Ele aprendeu a arte da furtividade, e com isso, passou a atacar seus inimigos de surpresa. A mágica que dá vida a este item é tão poderosa que pode transformar a mais inocente das pessoas em um destemido duelista.",ep:0,g:92,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,40,40,false,false],p:3000};
I.u[10127] = {n:"Cajado do Bandido Viajante",t:4,d:"O bandido viajante que possuía este cajado era formidável em suas fugas! Ele usava seu confiável bastão para se apoiar enquanto praticava sua arte preferida - roubar. A mágica que dá vida a este item é tão poderosa que pode transformar a mais inocente das pessoas em um bandido ousado.",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:12,e:[5,6,1,1,40,40,false,false],p:3000};
