I.u[10041] = {n:"",t:15,d:"",ep:0,g:56,l:1,wd:false,fm:true,w:50,p:1};
I.u[10042] = {n:"Fadas de Artifício Língua Áspera",t:74,d:"Quando estava vivendo na Torre do Amor Campestre, Mily ordenou que um grande número de Fadas de Artifício feito por um famoso artesão, iluminasse as suas festas no jardim. Ela ainda tem algumas e quando está de bom humor, os dá de graça!",ep:0,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10043] = {n:"Embelezador",t:30,d:"Um creme de beleza extremamente poderoso transformou você em.... uau! Apenas lembre-se que tanta beleza pode ser perigoso!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10044] = {n:"Creme de Beleza da Mily",t:12,d:"Mily passa esse creme todo dia de manhã para continuar com sua jovem e bela aparência. Apenas use-o e os resultados irão te impressionar! Só tome cuidado para não se envolver em brigas, porque com o menor dos esforços você já volta a parecer uma velhota.",ep:0,g:40,l:1,wd:false,fm:true,w:1,u:true,p:1};
