I.u[10061] = {n:"Botas Vampyre",t:11,d:"Dizem que a própria Condessa Bathory costumava usar estas botas. Conhecendo ela, estas botas devem ser macias e confortáveis... apenas espero que não tenha nenhuma surpresa nelas.",ep:0,g:139,l:41,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4550};
