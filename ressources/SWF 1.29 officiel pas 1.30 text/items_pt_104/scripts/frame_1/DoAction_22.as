I.u[10180] = {n:"O Esteban",t:1,d:"Este medalhão age como chave para uma misteriosa e esquecida cidade.",ep:0,g:149,l:42,wd:true,fm:true,w:10,s:136,p:4800};
I.u[10181] = {n:"Anel Solaris",t:9,d:"Este anel foi encontrado em uma cidade misteriosa onde ninguem sabia de sua existência até que começaram a procurar freneticamente.",ep:0,g:174,l:41,wd:true,fm:true,w:10,s:136,p:4600};
I.u[10182] = {n:"Escudo Solaris",t:82,d:"Este escudo irá refletir a luz do sol direto nos olhos de seu oponente. Ao invés de cegá-los com sua incrível sagacidade, cegue-os com esse escudo deslumbrante.",ep:0,g:42,l:1,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10183] = {n:"Máscara Solaris",t:16,d:"Essa máscara irá capturar a luz do sol e a concentrar no seu rosto assim você pode ficar atraente e moreno durante o ano todo, mesmo se viver no norte de Amakna.",ep:0,g:248,l:42,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10184] = {n:"Máscara Noke",t:16,d:"Noke adorava colocar essa máscara e se esconder no bosque para assustar os viajantes perdidos. Ela morreu pouco tempo depois de ver seu reflexo em uma poça.",ep:0,g:249,l:42,wd:true,fm:true,w:10,s:135,p:4700};
I.u[10185] = {n:"Capa Noke",t:17,d:"Noke sonhava em se tornar um grande lobo. Infelizmente, com essa capa, ela se parecia com um dos três porquinhos.",ep:0,g:170,l:41,wd:true,fm:true,w:10,s:135,p:4600};
I.u[10186] = {n:"Colar Noke",t:1,d:"Esse colar com dentes de javali assustará os javalis e, com sorte, a sua sogra também!",ep:0,g:150,l:41,wd:true,fm:true,w:10,s:135,p:4525};
I.u[10187] = {n:"Adagas de Noke",t:5,d:"Há muito tempo atrás, essas adagas foram usadas para acabar com um javali que sonhava em ser um cervo.",ep:0,g:76,l:41,wd:true,fm:true,w:10,an:13,tw:true,e:[12,3,1,1,30,45,false,false],c:"CS>50&CW>50&CV>80",s:135,p:4000};
I.u[10188] = {n:"Capacete Oxo",t:16,d:"Este capacete foi um equipamento muito útil que o ajudou a traduzir a linguagem de Oxo. É também à prova de som.",ep:0,g:250,l:43,wd:true,fm:true,w:10,s:133,p:5075};
I.u[10189] = {n:"Anel Oxo",t:9,d:"Este anel costumava pertencer ao Rei Oxo. Ele gostava de fazer brincadeiras usando os raios solares refletidos por este anel. Costumava dizer \"Olhe os raios lasers de Oxon!\"",ep:0,g:175,l:37,wd:true,fm:true,w:10,s:133,p:3875};
I.u[10190] = {n:"Botas Oxo",t:11,d:"Não esqueça de colocar estas botas quando estiver com a cabeça nas nuvens, elas a manterão lá. Sabendo o quão legais elas são, não as use para dançar se quiser se manter com os pés no chão.",ep:0,g:143,l:38,wd:true,fm:true,w:10,s:133,p:3925};
I.u[10191] = {n:"Cinto Oxo",t:10,d:"Este cinto é perfeito quando você precisa descansar e digerir seu velho Oxo Bucco.",ep:0,g:158,l:37,wd:true,fm:true,w:10,s:133,p:373};
