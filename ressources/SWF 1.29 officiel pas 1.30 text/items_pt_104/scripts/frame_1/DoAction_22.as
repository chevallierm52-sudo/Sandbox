I.u[10131] = {n:"Presente: Vampyrina",t:89,d:"Se você sacudir este objeto com bastante força e depois colocar perto do ouvido, você ouvirá um barulho estranho... como o de um pequeno animal chorando... ahm, tavlez você não queira sacudir isto... Ahhh, abra logo esta caixa!",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10132] = {n:"Presente: Borcego",t:89,d:"Se você sacudir este objeto com bastante força e depois colocar perto do ouvido, você ouvirá um barulho estranho... como o de um pequeno animal chorando... ahm, tavlez você não queira sacudir isto... Ahhh, abra logo esta caixa!",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10133] = {n:"Varinha do Bandido Feiticeiro",t:3,d:"Há muito, muito tempo essa varinha pertenceu a um bandido feiticeiro que o usava para transformar seus inimigos em cinzas. A mágica que dá vida a este item é tão poderosa que pode transformar a mais inocente das pessoas em um destemido bandido feiticeiro.",ep:0,g:72,l:30,wd:true,fm:false,w:10,an:11,tw:true,e:[2,5,2,4,40,40,false,true],p:3000};
I.u[10134] = {n:"Certificado de Canil: Vampyrina",t:77,d:"Este certificado descreve as características do animal de estimação que você deixou no Canil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
