I.u[9916] = {n:"Pergaminho de Feitiço Especial: \'Spiritual Leash\'",t:75,d:"Esse pergaminho te ensina o feitiço \'Spiritual Leash\' ... somente para Osamodas.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"PG=2",u:true,p:10000};
I.u[9917] = {n:"Pergaminho Bônus",t:24,d:"O pergaminho lhe diz quem é o alvo.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9919] = {n:"O anel da coruja",t:9,d:"Transformar-se em uma coruja",ep:0,g:7,l:1,wd:false,fm:false,w:0,p:0};
I.u[9920] = {n:"Pergaminho Bônus Recebido",t:24,d:"Este pergaminho é a prova que o alvo foi neutralizado com sucesso.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9921] = {n:"Bracelete Confusão",t:9,d:"Eles dizem que este bracelete é reluzente, mas somente quando você estiver em uma taverna no meio da noite.",ep:0,g:168,l:45,wd:true,fm:true,w:10,s:132,p:5525};
I.u[9922] = {n:"Cinto Confusão",t:10,d:"Este cinto possui um poder magnético que e fecha muito bem a fivela. É normalmente usada como poteção adicional ao cinto de castidade.",ep:0,g:154,l:38,wd:true,fm:true,w:10,s:132,p:4050};
I.u[9923] = {n:"Sapato Slamdance",t:11,d:"Os giradores de cabeça serão pouco úteis para estes sapatos, a menos que você utilize seus pés de vez em quando - aí sim serão exatamente do que você precisa.",ep:0,g:135,l:40,wd:true,fm:true,w:10,s:132,p:4300};
I.u[9924] = {n:"Chifres Reluzentes de Gren Dizer",t:16,d:"A lenda diz que esses chifres foram usados como condutor de eletricidade, concentrando eletricidade durante várias horas e depois projetando raios em qualquer pessoa que se aproximasse demais. Outra lenda diz que eles apenas fazem quem estiver vestindo ficar ridículo.",ep:0,g:239,l:42,wd:true,fm:true,w:10,s:139,p:4825};
I.u[9925] = {n:"Punho de Gren Dizer",t:9,d:"Este anel parece mais uma luva do que um anel de casamento, mas quem se importa, ninguem nunca mais irá mexer em sua mão da mesma maneira.",ep:0,g:169,l:44,wd:true,fm:true,w:10,s:139,p:4400};
I.u[9926] = {n:"Machado Hakken Duplo de Gren Dizer",t:19,d:"Esse machado de dois gumes pode derrotar duas cabeças com um golpe. O que equivale a um oitavo de uma hidra com dezesseis cabeças.",ep:0,g:57,l:39,wd:true,fm:true,w:10,an:17,e:[3,5,1,1,20,50,false,false],c:"CC>60&CV>50&CW>30",s:139,p:3900};
I.u[9927] = {n:"Botas de Gren Dizer",t:11,d:"Se você vestir essas botas enquanto estiver escalando o Monte Jifu, é quase certeza que você irá ver alguns estranhos OVNI\'s voando pelo céu.",ep:0,g:136,l:42,wd:true,fm:true,w:10,s:139,p:4805};
I.u[9928] = {n:"Botas Siks Wonn Ein",t:11,d:"Estas botas levam aproximadamente 12 horas para amarrar e um pouquinho mais de tempo para tirá-las. Isso lhe dará tempo suficiente para dormir um pouco quase todo dia, isso enquanto você for solteiro, desempregado e muito habilidoso com as mãos.",ep:0,g:137,l:42,wd:true,fm:true,w:10,s:131,p:4750};
I.u[9929] = {n:"Cinturão Siks Wonn Ein",t:10,d:"O tendão de Aquiles nem sempre fica embaixo dos joelhos, você sabe. De vez em quando fica logo abaixo da cintura. Neste caso, este pesado mas efetivo cinturão dará, a todos os fracos, uma mente serena e quilos de confiança.",ep:0,g:155,l:41,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9930] = {n:"Máscara Siks Wonn Ein",t:16,d:"Esta máscara não somente lhe deixará com a aparência de um canibal assassino e aterrorizante, como também irá proteger sua delicada e rósea buchecha de ventos fortes e do sol quente.",ep:0,g:240,l:38,wd:true,fm:true,w:10,s:131,p:4000};
I.u[9931] = {n:"Mullet Confusão",t:16,d:"Longo nas costas, curto em cima, este corte de cabelo tem uma má reputação, mas com certeza você mudará isso.",ep:0,g:241,l:39,wd:true,fm:true,w:10,s:132,p:4255};
I.u[9932] = {n:"Tufo de Cabelo do Hospedeiro de Bagrutte",t:24,d:"Este tufo de cabelo asqueroso foi arrancado de um dos sovacos do hospedeiro de Bagrutte. O fedor disso o faz não querer sentir cheiro algum nunca mais em sua vida.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[9933] = {n:"Capa Siks Wonn Ein",t:17,d:"Todo lutador sabe que a parte mais perigosa da luta livre é a platéia. Então quando cadeiras e garrafas vierem voando para o ringue, se cubra nesta capa de pelo de Pikoko e se encolha em posição fetal.",ep:0,g:167,l:42,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9934] = {n:"Chave do Padoque",t:24,d:"Os goblins estão equipados com ferramentas básicas, mas eles reciclam tudo que podem sem exceção. Quem pensaria que um simples osso poderia abriri seus padoques? Voce que não, claro!",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9935] = {n:"Corda de Escalada",t:15,d:"Este tipo de corda e foi escolhida como a melhor  pelos escaladores. O povo de Amakna sempre usa isso pegar porcos.",ep:0,g:170,l:1,wd:false,fm:true,w:5,p:1};
I.u[9936] = {n:"Capacete Imperial",t:16,d:"Este capacete é perfeito para as pessoas que têm uma aparência muito inofensiva. Isso pode ser muito perigoso no Mundo dos Doze.",ep:0,g:242,l:37,wd:true,fm:true,w:10,s:117,p:3825};
I.u[9937] = {n:"A Cartola",t:16,d:"Esta cartola vem junto com um bigode falso, o que é muito legal até que alguém lhe confunda com um grade ditador.",ep:0,g:243,l:37,wd:true,fm:true,w:10,s:116,p:3700};
I.u[9938] = {n:"Espadorenta",t:6,d:"A lâmina desta espada ficou mergulhada em suco de vaga-lume concentrado por 18 meses para que ela brilhasse no escuro. A propósito, agora ela fede no escuro também.",ep:0,g:91,l:38,wd:true,fm:true,w:10,an:14,tw:true,e:[5,4,1,1,50,50,false,false],c:"CV>30&CS>20&CW>20",s:117,p:3800};
I.u[9939] = {n:"A Bengala",t:4,d:"Esta bengala feita de bambú flexivel definitivamente não serve como apoio... Ao invés disso tente ficar girando ela no ar!",ep:0,g:88,l:37,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"CC>25",s:116,p:3700};
I.u[9940] = {n:"Madre-pérola em estado bruto",t:51,d:"Esta madre-pérola ficará bonita quando for polida.",ep:0,g:10,l:20,wd:true,fm:true,w:1,p:10};
I.u[9941] = {n:"Madre-pérola",t:50,d:"Este material é feito de cristais de aragonite e shellite. Era desconhecido até a descoberta da Ilha de Otomai e a shelite encontrada. Este elemento é precioso para os alquimistas, embora algumas receitas que usem o tal elemento sejam sempre muito bem protegidas.",ep:0,g:4,l:50,wd:true,fm:true,w:10,p:5000};
I.u[9942] = {n:"Anel da Morte",t:9,d:"Este anel é também conhecido como Anel da Escuridão, mas apesar de seus dois nomes, o anel não foi terminado. Mesmo assim, é poderoso o bastante para destruir um planeta de pequeno porte.",ep:0,g:170,l:36,wd:true,fm:true,w:10,s:117,p:3600};
I.u[9943] = {n:"Par de Sapatos",t:11,d:"Diz a lenda que estes sapatos foram comidos por um minerador de ouro e que foi costurado devolta ao ser recuperado um tempo depois. Deve ser por isso que ele brilha tanto.",ep:0,g:138,l:43,wd:true,fm:true,w:10,s:116,p:4975};
I.u[9944] = {n:"A Gravata",t:1,d:"Este talismã é ao mesmo tempo um amuleto e uma gravata. Ele vai lhe deixar com um ar de cavalheiro mesmo quando você estiver na pior.",ep:0,g:145,l:43,wd:true,fm:true,w:10,s:116,p:5000};
I.u[9945] = {n:"A Mochila do Profeta Newddha",t:81,d:"Newddha, o profeta, é famoso por recusar a herança de sua família para ir sentar embaixo de um coqueiro, esperando por iluminação espiritual. Ao invés disso, um côco gigante caiu em sua cabeça, onde ele se convenceu a deixar toda essa baboseira de lado.",ep:0,g:33,l:38,wd:true,fm:true,w:10,s:117,p:4050};
I.u[9946] = {n:"Cristal de Kain Daryn",t:24,d:"A fama de Kain Daryn como um caçador de tesouros foi amplamente difundida por Amakna. Ele descobriu muitos cristais com propriedades incríveis, incluindo o poder de desvendar seus olhos sem usar as mãos. Kain não contou a ninguém que os cristais foram descobertos e  muitos Enutrofs ainda procuram por eles.",ep:0,g:744,l:1,wd:false,fm:true,w:0,p:1};
I.u[9947] = {n:"Cristal Encantado de Kain Daryn",t:24,d:"Este Cristal de Kain Daryn foi encantado com o intuito de multiplicar a ganância de quem vê-lo.",ep:0,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9948] = {n:"Membro do Chefe dos Ladinos",t:24,d:"O Chefe Ladino terá uma longa caminhada pela frente. Bem, isso o ensinará uma boa lição.",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9949] = {n:"Pasta Tra Khben",t:110,d:"Esta pasta foi inventada pelo famoso Tra Khben, um geologista que é especializado em ecossistema e colheita, e  que sofria de artrite nas costas desde a mais tenra idade. Esta pasta é reconhecida por sua habilidade em fazer qualquer substância orgânica que entrar em contato com ela em sólida rocha. Tra Khben usou suas propriedades para ajudar a si mesmo a se curar. Quando ele morreu, esta pasta se tonou muito popular entre os Enutrofs, por diferentes razões. O lado ruim é o seu fedor,",ep:0,g:42,l:1,wd:false,fm:true,w:1,p:1};
I.u[9950] = {n:"Pedra Azul Impura Corrompida",t:51,d:"Estas pedras alcançarão seu poder total quando polidas.",ep:0,g:151,l:1,wd:false,fm:true,w:5,p:1};
I.u[9951] = {n:"Pedra Amarela Impura Corrompida",t:51,d:"Esta pedra alcançarão seu poder total quando polidas.",ep:0,g:145,l:1,wd:false,fm:true,w:5,p:1};
I.u[9952] = {n:"Pedra Verde Impura Corrompida",t:51,d:"Esta pedra alcança todo o seu potencial quando polida.",ep:0,g:76,l:1,wd:false,fm:true,w:5,p:1};
I.u[9953] = {n:"Pedra Azul Corrompida",t:50,d:"Esta pedra pode corromper até as almas indispostas, mas pode ser útil em transformar Tofus em Tofus Maléficos. Quando combinadas com outras Pedras Corrompidas, tem o potencial  de dar controle total sobre suas almas.",ep:0,g:460,l:50,wd:false,fm:true,w:10,p:100};
I.u[9954] = {n:"Pedra Amarela Corrompida",t:50,d:"Esta pedra pode corromper até as almas indispostas, mas pode ser útil em transformar Tofus em Tofus Maléficos. Quando combinadas com outras Pedras Corrompidas, tem o potencial  de dar controle total sobre suas almas.",ep:0,g:463,l:50,wd:false,fm:true,w:10,p:100};
I.u[9955] = {n:"Pedra Verde Corrompida",t:50,d:"Esta pedra pode corromper até as almas indispostas, mas pode ser útil em transformar Tofus em Tofus Maléficos. Quando combinadas com outras Pedras Corrompidas, tem o potencial  de dar controle total sobre suas almas.",ep:0,g:461,l:50,wd:false,fm:true,w:10,p:100};
I.u[9956] = {n:"Pedra de Almas Corrompidas",t:24,d:"Esta pedra veio do Poço das Almas Corrompidas. Ela pode ser usada para controlar as almas das criaturas que são capturadas.",ep:0,g:462,l:1,wd:false,fm:true,w:0,p:1};
I.u[9957] = {n:"",t:114,d:"",ep:0,g:6,l:40,wd:false,fm:false,w:15,an:14,tw:true,e:[3,5,1,1,45,90,false,true],p:1};
I.u[9958] = {n:"Caixa de equipamentos Bontarianos",t:24,d:"Essa caixa contém o kit do perfeito pequeno homem de milícia. Se o conteúdo for de qualidade similar ao da própria caixa, não será uma surpresa se levar menos de um dia para derrotar a milícia Bontarian.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9959] = {n:"Relatório Especialista",t:24,d:"Como você esperava, esse relatório confirma a baixa qualidade do equipamento da milícia Bontariana. Oto Mustam vai ficar sabendo das novidades.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9960] = {n:"Chaves do Depósito",t:24,d:"Esta tigela de vidro contém os restos que foram mantidos no estômago de um Sennuig. A boa notícia é que as chaves do depósito estão ali em algum lugar. Tudo que deverá fazer é colocar a sua mão e tirar as chaves de dentro da tigela. Não se esqueça de lamber os dedos depois.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9961] = {n:"Martelo Hurrian",t:7,d:"Esse martelo de pedra foi inventado para fazer os ferreiros acreditarem que estão com um martelo de ótima qualidade. É recomendado que você não o toque, mesmo que não vá fazer nada.",ep:0,g:2,l:1,wd:true,fm:false,w:5,an:15,e:[5,4,1,1,60,20,false,false],p:10};
I.u[9962] = {n:"Caixa de minérios",t:24,d:"Você pegou esta caixa de minérios para que Latem Sa possa forjar novos equipamentos para a Milícia Bontariana.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9963] = {n:"Martelo do Ferreiro",t:24,d:"Você pegou este martelo de Latem As e o substituiu por um falso. O ferreiro é tão incompetente que provavelmente nem perceberá a diferença.",ep:0,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9964] = {n:"Presente: Dragossauro Khameleron",t:89,d:"Se você balançar esse objeto e colocar perto do seu ouvido, você vai escutar uns barulhos estranhos... Como um pequeno animal chorando... É, talvez não seja uma boa idéia balançar isso, apenas abra logo.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9965] = {n:"Técnica de Domesticação de Caninos",t:24,d:"Esse método, desenvolvido pelo famoso treinador de Miau, Roy Sigfred, diz como você poderá domesticar um Canino Albino e faz que ele se torne seu melhor amigo. Ele ainda não vai pensar muito em mulheres depois disso.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9966] = {n:"Saque do Comboio",t:24,d:"Você conseguiu esse espólio por meio de um ataque ao comboio bontariano. Stampidor, o Bruto, que você poderá encontrar no Posto de Comando da milícia de Brakmar, seguramente o recompensará pelo seu esforço. Talvez até o deixe sair inteiro dessa.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9967] = {n:"Como fazer Greedoburg",t:24,d:"Laura Soho, garçonete da pousada de Amakna, escreveu nesse pedaço de papel como preparar uma garrafa de Glutoburg com a ajuda de um alquimista.\n- 5 Frascos de Pandaburg\n- 1 Refresco de Greedo\n- 10 Saladas",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9968] = {n:"Garrafa de Glutoburg",t:79,d:"Esta ultra-poderosa bebida rasga sua língua, estraga o seu paladar, queima seu esôfago e faz com que o seu estômago exploda antes de ferver seu cérebro. Em outras palavras, é uma bebida para Pandawas de verdade. Em pequeninas letras embaixo da garrafa você consegue ler o seguinte: \"O consumo pode causar problemas de saúde. Beba com moderação, exceto quando estiver em oferendas para os deuses\".",ep:0,g:177,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[9969] = {n:"Salada com Peixe Envenenada",t:15,d:"Acordar e sentir o cheiro de café, como diz o ditado. Bem, esta salada não cheira a café. Cheira a peixe. Peixe e pé suado. Isso é bem útil, de verdade, porque assim consegue mascarar o cheiro de veneno, que uma vez ingerido, induz projéteis de vômito. Ótimo para animar um casamento entediante ou pra pregar uma peça em seu líder de guilda favorito.",ep:0,g:80,l:1,wd:false,fm:true,w:1,p:1};
I.u[9970] = {n:"Receita de Salada com Peixe",t:24,d:"Gropinson Cruaule escreveu a receita para a Salada com Peixe na areia da praia e você a copiou em um pedaço de papel.\n- Um Peixeiro (colocá-lo no prato é opcional)\n- 2 Lobo-do-mar Rikain\n- 3 Espeto de Caranguejo***\n- 2 Limões\n- 4 Saladas\n- 1 Bolo de Blop Envenenado (seu toque pessoal)",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9971] = {n:"Chaves de Mulic Bere",t:24,d:"Essas chaves pertencem a Muric Bere. Elas abrem a porta para sua forja especial onde, além de outras coisas, ele cria itens extraordinários para pessoas muito extraordinárias, como você.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9972] = {n:"Martelo de Ferreiro de Coçador",t:7,d:"Este martelo, para ser usado em uma forja, foi criado para um propósito específico, o que faz o uso dele pra qualquer outra coisa bem difícil. Apenas alguem desesperado ou nas margens da sociedade o usaria para criar armas.",ep:0,g:2,l:1,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,50,false,false],c:"PJ>20,49",p:150};
I.u[9973] = {n:"Extremidade de Coçador-de-Costas",t:15,d:"Esta extremidade de coçador-de-costas possui várias articulações para tornar seu uso mais fácil. Ela tem vários ganchos, e tambem pode ser usada por um Osamodas como... Ei, quem escreve essas coisas?!",ep:0,g:716,l:1,wd:false,fm:true,w:1,p:1};
I.u[9974] = {n:"Talhador de Manivela",t:5,d:"Este talhador é para cortar manivelas, não velas. Você pode tentar pintar uma tela em sua cela, ",ep:0,g:17,l:1,wd:true,fm:true,w:5,e:[5,4,1,1,50,50,false,false],c:"PJ>19,49",p:150};
I.u[9975] = {n:"Manivela de Coçador-de-Costas",t:15,d:"Sozinha, esta manivela não é de uso algum para você. Você pode colocar um coçador em sua extremidade, mas isso não seria de muito uso pra você tambem. Você está correto em assumir que apenas alguem muito estranho saberia o que fazer com isso.",ep:0,g:52,l:1,wd:false,fm:true,w:5,p:1};
I.u[9976] = {n:"Coçador-de-Costas incompleto",t:15,d:"Esse coçador-de-costas está quase perfeito. Quase, mas não tanto. Apenas um ferreiro de alto nível poderia completar, e infelizmente, você não conhece um.",ep:0,g:52,l:1,wd:false,fm:true,w:10,p:1};
I.u[9977] = {n:"Coçador-de-Costas Spentox",t:24,d:"Esse coçador-de-costas bem pontudo irá tomar forma sozinho para os contornos do seu corpo, alcançando lugares que outros coçadores não conseguiriam. Sim, até lá.",ep:0,g:745,l:1,wd:false,fm:true,w:0,p:1};
I.u[9978] = {n:"Exército de Carrapatos de Javali das Planícies",t:24,d:"Maiores que carrapatos de Gobball, Carrapatos de Javalis das Planícies podem devorar até 100x o peso deles em sangue. Vampires e até mesmo Dark Vlad ficariam pálidos de inveja.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9979] = {n:"Poção da Longevidade",t:12,d:"Nileza o Alquimista criou esta poção na esperança de que lhe desse imortalidade. Infelizmente, ele morreu antes de poder usá-la, confundindo-a com um pouco de Sangue de Unikron (que estava em uma garrafa ao lado na prateleira).",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[9980] = {n:"Prato de Scrampi",t:49,d:"Este prato ilustra perfeitamente o ditado favorito de Donna Kerbabben: \"Se não é pra fritar, nem vale tentar\".",ep:0,g:82,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9981] = {n:"Farinha Esquisita",t:52,d:"Xavier, o Padeiro usava esta farinha para fazer pão servido em cada um dos funerais do famoso cantor Jon Lemon.",ep:0,g:7,l:1,wd:false,fm:true,w:1,p:1};
I.u[9982] = {n:"Salada Kerbbaben",t:69,d:"O nome desta salada é uma celebração ao dia em que foi criada. Ela foi servida pela primeira vez durante uma cerimônia da famosa Iopette Donna Kerbabben. Como todas as comidas destinadas a cavaleiros, é fortemente recomendado que vegetarianos fiquem bem longe.",ep:0,g:129,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9983] = {n:"Pão de Centeio Saltitante",t:33,d:"Servidos nos funerais do famoso cantor Jon Lemon, esse pão tem um sabor e um cheiro tão revoltante que faria os mortos voltarem, ou matar os vivos. Isso explica todos os incríveis retornos de Jon Lemon.",ep:0,g:13,l:1,wd:false,fm:true,w:2,u:true,ut:true,p:1};
I.u[9984] = {n:"Lista de Ingredientes do Ano Passado",t:24,d:"A lista que Oto Mustam entregou pra você:\n- 1 Pão de Centeio Saltitante\n- 1 Salada Kerbabben\n- 1 Prato de Scrampi\n- 1 Poção da Longevidade",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9985] = {n:"Receita de Pão de Centeio Saltitante",t:24,d:"2 Farinha Esquisita\n5 Água\n2 Fermento de Padeiro\n",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9986] = {n:"Receita de Farinha Esquisita",t:24,d:"1 Farinha Xavier de Padeiro\n1 Pó de Eniripsa\n4 Cebolas",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9987] = {n:"Receita de Salada de Kerbabben",t:24,d:"5 Salada de Focinho ***\n20 Pólen de Blop\n10 Broto de Treechnid",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9988] = {n:"Receita de Prato de Scrampi",t:24,d:"10 Pedacinhos de Grawn***\n5 Limões\n10 Saladas",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9989] = {n:"Receita de Poção da Longevidade",t:24,d:"2 Sangue de Unikron\n10 Poções da Velhice\n2 Poções de Memorização",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9990] = {n:"Broche da Cheeka",t:24,d:"Este Broche foi dado por Cheeka por sua valentia durante o ataque ao comboio. Isto também sela sua promessa de agradecê-lo pessoalmente quando você retornar a Bonta.",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9993] = {n:"Sabine",t:32,d:"Você precisa levar Sabine até o prédio da Milícia em Brakmar.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9995] = {n:"Pergaminho Seriano Enrolado",t:87,d:"Este pergaminho lhe dirá a localização de um alvo, permitindo que você o rastreie mais facilmente.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps=3",u:true,p:1};
I.u[9996] = {n:"",t:87,d:"",ep:0,g:3,l:10,wd:false,fm:true,w:100,ut:true,p:3500};
I.u[9997] = {n:"Chave para o Esconderijo dos Diabinhos",t:24,d:"Esta é a chave para o esconderijo dos DIabinhos. Grimpil falou algo sobre um mecanismo de fechamento automático da porta. Este é o motivo de todos os integrantes terem a sua própria cópia da chave.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9999] = {n:"Cópia da Chave do Esconderijo dos Diabinhos",t:84,d:"Está cópia da chave do Esconderijo dos Diabinhos Ecaflips está quase imprestável. Se você tentar usá-la do jeito que está, provavelmente quebrará. Além do mais, há o fato de que não há um certificado de garantia, o que o leva a crer que possa ser uma falsificação. Você pode estar certo.",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10000] = {n:"Tufo de Pêlo de Grimpil",t:24,d:"Quando você pega este tufo em suas mãos, pode sentí-lo como se estivesse vivo! Quando olha de perto, e sim...não...não são apenas pêlos, mas sim um enorme tufo de piolhos e carrapatos.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[10001] = {n:"",t:87,d:"",ep:0,g:3,l:10,wd:false,fm:true,w:10,ut:true,p:500};
I.u[10002] = {n:"",t:87,d:"",ep:0,g:1,l:10,wd:false,fm:false,w:1,ut:true,p:100};
I.u[10003] = {n:"Geléia de Nowaine",t:110,d:"Liroye Merline só sabe fazer esta receita de geléia artificial.  Interessante é que quando misturada com relva fresca, ela endurece e molda tudo que for nela colocada. Este produto é muito útil para criação de moldes.",ep:0,g:47,l:1,wd:false,fm:true,w:0,p:1};
I.u[10004] = {n:"Como usar Geléia de Nowaine",t:24,d:"Este documento mostra 1001 utilidades da Geléia de Nowaine e foi escrito por Liroye Merline. Aqui ela mostra como fazer cópias de chaves:                                            - 1 Geléia de Nowaine\n- 1 Grama Selvagem\n- 1 Baquelite",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10005] = {n:"Documentos Confidenciais",t:24,d:"Uma lista confidencial de documentos Bontarianos. Você deverá perguntar o que estes papéis secretos estão fazendo no esconderijo dos ladinos.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10006] = {n:"Reporte Suspeito",t:24,d:"Este reporte não é nada bom para você. Ele o acusa de ser desleal a Bonta. Apenas um especialista poderá dizer se este documento é autêntico ou não.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10007] = {n:"Frasco de Veneno Brakmariano",t:24,d:"Este frasco de veneno Brakmariano foi preparado como os antigos ostumavam prepará-lo. O rótulo diz \"mantenha longe do alcance de todos\". Menos dos Bontarianos.",ep:0,g:39,l:1,wd:false,fm:true,w:0,p:1};
I.u[10008] = {n:"Lista de Clientes",t:24,d:"Este registro lista todos os clientes quevisitaam recentemente a Oficina de Alquimistas de Brakmar nas últimas semanas. O problema é que estpa tudo escrito em Brakmariano - você não consegue entender uma só palavra sangrenta palavra escrita nela.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10009] = {n:"Xephires",t:32,d:"Traga o traidor Xephires antes de Amayiro. Eles têm algumas coisas para discutir.",ep:0,g:24,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10010] = {n:"Chave da Sala de Jogos",t:24,d:"Essa chave irá abrir a porta para a sala de jogos da pousada Gato Chamuscado.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[10011] = {n:"Coração de Petra",t:24,d:"Esse é o coração de Petra, ainda batendo. Ainda lhe incomoda que um discípulo de Sram não mostrou resistência quando você a derrotou, mas, após pensar nisso, você diz a si mesmo que o resultado teria sido o mesmo se ela o tivesse feito, então, com uma luz no coração, você leva este coração ao seu amado mestre.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10012] = {n:"Coração de Petra",t:24,d:"Esse é o coração de Petra, ainda batendo. Ainda lhe incomoda que um discípulo de Sram não mostrou resistência quando você a derrotou, mas, após pensar nisso, você diz a si mesmo que o resultado teria sido o mesmo se ela o tivesse feito, então, com uma luz no coração, você leva este coração ao seu amado mestre.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10013] = {n:"Coração de Petra",t:24,d:"Esse é o coração de Petra, ainda batendo. Ainda lhe incomoda que um discípulo de Sram não mostrou resistência quando você a derrotou, mas, após pensar nisso, você diz a si mesmo que o resultado teria sido o mesmo se ela o tivesse feito, então, com uma luz no coração, você leva este coração ao seu amado mestre.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10014] = {n:"Cheque de Petra",t:24,d:"Este cheque, feito para Oto Mustam, foi escrito por Petra. É uma pena não ser uma pilha de Kamas brilhantes, você poderia ter discretamente se ajudado um pouco.",ep:0,g:54,l:1,wd:false,fm:true,w:0,p:1};
I.u[10015] = {n:"Lista de compras de Oto Mustam",t:24,d:"Oto Mustam está fazendo você pagar o preço por falhar no teste de determinação tão miseravelmente. Ele quer que você encontre os seguintes itens:\n- 1 Sacola de Bronze\n- 1 Sacola de Malte\n- 1 Sacola de Flores de Sarraceno",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10016] = {n:"Machado Celta",t:24,d:"Essa machadinha parece ser bem simples, ela parece vir de outra era. Ela é de uma qualidade tão ruim que não cortaria nem um Trunknid.",ep:0,g:746,l:1,wd:false,fm:true,w:0,p:1};
I.u[10017] = {n:"Katana de Nara",t:24,d:"Essa Katana foi feita por Nara quando ele foi aprovado em seu teste final. Não há nenhuma outra como aquela... Em qualidade, equipara-se ao Machado Celta.",ep:0,g:53,l:1,wd:false,fm:true,w:0,p:1};
I.u[10018] = {n:"Plano para os Pregadores de Roupa",t:15,d:"Esse plano é tão simples que até um jovem Iop conseguiria entender. Bem... Nem tanto. Nas mãos de um Marceneiro, ele poderá ser utilizado para fazer objetos. Se o marceneiro for um Iop, prepare-se para os problemas. Você precisará para o plano: 10 Tábuas de Madeira de Kaliptu e 10 Aluminitas.",ep:0,g:767,l:1,wd:false,fm:true,w:1,p:1};
I.u[10019] = {n:"Balde para Pregadores de Roupa",t:15,d:"Esse balde contém pregadores de roupa suficientes para pendurar as roupas de toda Amakna. Você também pode usá-los para secar a pele de animais.",ep:0,g:768,l:1,wd:false,fm:true,w:10,p:1};
I.u[10020] = {n:"Boneca Medonha",t:24,d:"Foi difícil de acreditar que essa boneca feia e fedorenta um dia foi um Mago Bwork. Então, pode-se pensar: \"Os Bworks não são ainda mais horríveis do que essa boneca feia e fedorenta?",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10021] = {n:"Boneca Reformada",t:24,d:"Você se pergunta se esta boneca era melhor antes ou depois de reformada por Maskara. Uma coisa é certa... apenas um bom artesão de bonecas faria uma mais bonita do que a original. Agora, você sabe por que o Mago Bwork resolveu se trancar por anos e anos em sua caverna.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10022] = {n:"Boneca Encantada",t:24,d:"É encantador ver essa boneca encantada de volta às mãos daquele que a encantou às margens desse lago encantado. Se ainda estivesse vivo, o cantor Jon Lemon certamente escreveria uma canção nada amistosa sobre esse feito.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10023] = {n:"Registro das Rondas",t:24,d:"Diferentemente do que o nome sugere, esse registro não é sobre Mamães Bwork, mas sobre as rotas das patrulhas Brakmarianas. Nele, há várias opções de emboscadas.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10024] = {n:"Antigo Livro de Magias Bwork",t:24,d:"Esse antigo livro de magias pertence a um Mago Bwork das cavernas. As imagens dentro dele vão ser de difícil entendimento para um Mago Bwork das cavernas mais jovem, ainda mais para os Magos Bworks convencionais. Vamos torcer para que Danathor encontre alguma utilidade para isso. Seria uma vergonha ter tanto trabalho a troco de nada, não seria?",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10025] = {n:"Febre de Greedoburg",t:30,d:"Você foi alertado: o consumo de Greedoburg pode causar problemas de saúde.",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10026] = {n:"Receita de Salada com Peixe",t:24,d:"Gropinson Cruaule escreveu a receita para a Salada com Peixe na areia da praia e você a copiou em um pedaço de papel.\n- Um Peixeiro (colocá-lo no prato é opcional)\n- 3 Espeto de Caranguejo***\n- 2 Limões\n- 4 Saladas\n- 2 Vergeléia (seu toque pessoal)",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10028] = {n:"Receita de Remendo Mágico",t:24,d:"Esta receita foi desenvolvida pelo alfaiate Sosh para remendar roupas mágicas. Alfaiates experientes podem usá-la para criar um tecido que passa pelo teste do tempo e condições meteorológicas.\n- 5 Pêlos da Barba de Bwork Mago\n- 5 Pêlos de Tiwabbit Preto\n- 3 Pelos do Avô do Wabbit\n- 3 Pêlos de Miliboolobo\n- 1 Fio de Seda",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10029] = {n:"Receita de Tintura Laranja de Sangue Mágico",t:24,d:"Esta receita foi desenvolvida pelo famoso alquimista Uba Tesse. Ninguem nunca a utilizou antes porque Uba Tesse a esqueceu na casa de seu amigo Sosh. Sosh gentilmente a entregou para você.\n1 Tintura Mágica Vermelha\n1 Tintura Mágica Laranja\n10 Sangue de Gobball\n5 Sardinha Brilhante",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10030] = {n:"Remendo Mágico",t:55,d:"Este tecido sintético, inventado pelo alfaiate Sosh, permite que roupas mágicas sejam remendadas sem afetar seus poderes. Isso explica porque alfaiates experientes o valorizam tanto.",ep:0,g:434,l:1,wd:false,fm:true,w:1,p:1};
I.u[10031] = {n:"Tintura Laranja de Sangue Mágico",t:70,d:"Esta tintura mágica, inventada por Uba Tesse, é particularmente agressiva. Parece que ela tem força de vontade, que a leva a fazer mal. Você só não sabe porque é tão agressiva.",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
I.u[10032] = {n:"Bandana Restaurada",t:24,d:"Esta bandana está em um estado bem melhor do que quando você a encontrou. Ela cheira menos a cawwot e mais a peixe, o que mostra que ela voltou a ser como antes. Elturt ficará feliz em recebê-la em tão boas condições.",ep:0,g:749,l:1,wd:false,fm:true,w:0,p:1};
I.u[10033] = {n:"Garantia",t:24,d:"Essa garantia, assinada por Kaffra Keeper, diz que Brakmarianos devem entregar documentos para Seci Ves na base da Torre de Ordens Brakmariana.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10034] = {n:"Lista de Magus Ax",t:24,d:"Esta é a lista de itens para trazer ao Ritual de Revelação:\n- 5 Poções de Garoa\n- 10 Água\n- 10 Sementes de Pandkin\n- 4 Cura Mágica\n- 2 Madeira de Carpino\n- 4 Poção de Corrente de AR\n- 2 Amigos confiáveis\n- SEM enxofre",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10035] = {n:"Conclusão do Ritual de Revelação",t:24,d:"Magus Ax rabiscou o resultado do Ritual de Revelação neste pergaminho. Para utilizar o Chifre de Fogornleg, apenas coloque-o sobre seus ombros e cante \"Doo-DAH! Doo-DAH!\".",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10036] = {n:"Garras das Fadas de Artifício",t:74,d:"Quando ela estava vivendo na Torre Amor Rústico, Mily ordenou um grande número de Fadas de Artifício de um famoso artesão a iluminar as suas festas no jardim. Ela ainda tem algumas e quando ela está de bom humor, ela os dá de graça!",ep:0,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10038] = {n:"",t:24,d:"",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10039] = {n:"",t:51,d:"",ep:0,g:7,l:1,wd:false,fm:true,w:20,p:1};
