I.u[10069] = {n:"Barril de Shambrosia",t:24,d:"O barril contém um energético muito forte e potente, baseado em veneno de Cobra de Grama e cêra de ouvido de Moolobo. Beber nem que seja a menor das quantias causa severo dano cerebral. É muito popular entre Iops, que podem consumi-la sem nenhum dano.",ep:0,g:165,l:1,wd:false,fm:true,w:0,p:1};
I.u[10070] = {n:"",t:15,d:"",ep:0,g:165,l:1,wd:false,fm:true,w:5,p:1};
