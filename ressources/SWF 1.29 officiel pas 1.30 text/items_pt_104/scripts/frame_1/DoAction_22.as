I.u[10155] = {n:"Amlugo",t:1,d:"Este amuleto lhe protegerá de qualquer perigo que lhe ameace, mas aumenta suas chances de se enforcar por qualquer motivo.",ep:0,g:147,l:43,wd:true,fm:true,w:10,s:134,p:5030};
I.u[10156] = {n:"Slugo",t:11,d:"Estes chinelos são mais confortáveis do que seus calçados de costume, mas é difícil de dizer o porquê... Talvez os parasitas que a infestam massageiam seus pés.",ep:0,g:140,l:41,wd:true,fm:true,w:10,s:134,p:4575};
I.u[10157] = {n:"Belugo",t:10,d:"Este cinto foi feito usando-se as sobras de carretéis de linho. Ele amarra sacos de lixo também.",ep:0,g:157,l:43,wd:true,fm:true,w:10,s:134,p:5025};
