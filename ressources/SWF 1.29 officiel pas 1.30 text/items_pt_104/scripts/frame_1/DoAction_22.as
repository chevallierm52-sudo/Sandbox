I.u[10072] = {n:"",t:24,d:"",ep:0,g:754,l:1,wd:false,fm:true,w:0,p:1};
I.u[10073] = {n:"Escudo EspaÑol",t:82,d:"O legendário Dal-Uk-Went, aquele que unificou o reino Spamnico, tinha um escudo mágico! Sir-Dal, seu neto, forjou cópias para dar de recompensa aos seus melhores guerreiros. Este escudo é uma dessas cópias.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[10074] = {n:"Carta do Chefe dos Ladinos",t:24,d:"Isto foi encontrado em um combate contra o arrombador na casa de Milone. Este joalheiro acabou de criar uma valiosa jóia. Roubá-la parece ser algo inevitável. Felizmente, Milone deu a ele a cópia, mas não foi graças a você. No verso da mensagem, porém, havia um guia para o esconderijo. Vinganças à parte, saiba que você não será capaz de fazê-lo sozinho.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10075] = {n:"Lama Horrorosa",t:24,d:"Esta lama horrorosa apareceu em seu bolso como num nojento passe de mágica",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[10076] = {n:"Escudo Único EspaÑol",t:82,d:"O legendário Dal-Uk-Went, aquele que unificou o reino Spamnico, concentrou todo o seu poder neste escudo para a infelicidade de seus inimigos. Anos depois, Sir-Dal, seu neto, forjou cópias para dar de recompensa aos seus melhores guerreiros... Mas este é o original e o mais poderoso de todos os escudos.",ep:0,g:40,l:1,wd:false,fm:true,w:30,c:"PP>9",p:63200};
I.u[10077] = {n:"Terra Cogita",t:32,d:"Escolte Terra Cogita antes de levá-lo para encontrar-se com Jerhyn Gholein.",ep:0,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10078] = {n:"Deni Hoobe",t:32,d:"Você precisa escoltar e proteger Deni Hoobe. É quase como se os deuses estivessem lutando contra você desde que foram vistos juntos.",ep:0,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10079] = {n:"Pão Perseverante",t:33,d:"Esse pão é valorizado pela comunidade Iop por sua capacidade de proporcionar ao guerreiro uma coragem imensa. Os numerosos ataques causados pelo seu consumo provam que essa refeição funciona. Xavier, o Padeiro, parou de fazê-las quando uma companhia inteira de covardes aterrorizou a região durante todo o inverno.",ep:0,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[10080] = {n:"Mensagem de um Renegado",t:24,d:"Essa mensagem levará os renegados para o Calabouço do Escarafolha. Você deveria ir lá para descobrir mais pistas.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10081] = {n:"Mensagem do Chefe Renegado",t:24,d:"Nessa mensagem, o chefe dos renegados pede que você o encontre ao sul do território dos bandidos. Esta é a sua chance de se livrar desse traidor.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10082] = {n:"Coquetel Mojeetov",t:24,d:"O que você consegue quando coloca uma Pétala de Mojeeto? Ingredientes que podem ser usados em diversos coquetéis. Discípulos de Otomai adoram esses drinques e bebem muitos litros durante os festivais de verão.",ep:0,g:762,l:1,wd:false,fm:true,w:0,p:1};
I.u[10083] = {n:"Salada com Peixe",t:49,d:"Acordar e sentir o cheiro de café, como diz o ditado. Bem, esta salada não cheira a café. Cheira a peixe. Peixe e pé suado. Não a coma em frente a Porcos Imundos, a não ser que você seja uma Porca Imunda, claro.",ep:0,g:80,l:1,wd:false,fm:true,w:3,u:true,ut:true,p:1};
I.u[10084] = {n:"Apito de Aviso",t:24,d:"Esse apito foi desenvolvido por Roy Sigfred como método de treinamento canino e muito utilizado para domar Lupis Albino. No entanto, você poderá também imitar o mestre de um Lupis Albino, mesmo sem conhecê-lo. Isso também deve funcionar com Lupis Albinos Selvagens.",ep:0,g:755,l:1,wd:false,fm:true,w:0,p:1};
I.u[10085] = {n:"Ordem de Execução",t:87,d:"Não há nada de errado nas ordens. Vá e encontre o alvo.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:0};
I.u[10086] = {n:"Dente Canino do Diabinho das Planícies",t:24,d:"A luta na Planície dos Diabinhos foi tão violenta que um deles até perdeu um dente.",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:1};
I.u[10087] = {n:"Reunião de Xarthan",t:24,d:"Esta nota foi escrita por um Brakmariano. Ele fala que Xarthan está para vir para a Torre de Bonta depois de seu próximo encontro. Isso quer dizer que ele já pode estar lá.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10088] = {n:"Lenço usado",t:24,d:"Você encontrou este lenço durante sua batalha com Xephires. É um belo suvenir e pode até ser útil caso você pegue um resfriado! Poderá customizar, fazendo um chapéu de nós também - claro - se você não se importar em ser olhado como louco por aí!",ep:0,g:756,l:1,wd:false,fm:true,w:0,p:1};
I.u[10089] = {n:"Caixa dos Deuses",t:24,d:"Xephires pediu a você que entregasse esta caixa com mercadorias ao Conselheiro Boyowa, no Grandapan, demonstrando assim a sua \'boa vontade\'. Você sabe que não importa o que há dentro, pode estar certo que é bem valioso.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10090] = {n:"Lista de suprimentos de Nara",t:24,d:"Nara fez uma lista do que ele precisa para sua nova forja. 20 Madeiras de Carvalho, 1 Sacola de Enxofre, 30 Ferros, 1 Kouartz, 5 Baquelites e 10 Couros de Javali das Planícies.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10091] = {n:"Notas da Maldição de Erazal",t:24,d:"A maldição de Erazal indica como trazer uma alma de volta à vida contra sua própria vontade. Você precisará de de uma unidade de Sangue de Fênix, 5 unidades de Cura Mágica e 1 Amuleto de Lear, adquiridos de cadáveres de um Treechnid e um Treechnid das Sombras",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10092] = {n:"Ordem de Cancelamento",t:24,d:"Esta carta datada de poucas horas atrás indica que o assalto a Bonta foi cancelado por causa do melhoramento promovido no equipamento dos milicianos e da captura do traidor Xephires.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
