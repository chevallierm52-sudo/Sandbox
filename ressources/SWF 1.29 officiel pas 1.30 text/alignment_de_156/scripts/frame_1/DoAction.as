A.s[11] = {n:"Bewahrer des Wissens",d:"-",o:3,av:100,f:[[23,5]]};
A.s[13] = {n:"Silvosses Schüler",d:"Um ihren guten Ruf als fähige Spione zu verdienen, werden Silvosses Schüler darin geschult, nützliche Informationen zu sammeln und nicht entdeckt zu werden.",o:4,av:20,f:[[10,1]]};
A.s[14] = {n:"Spion",d:"Sich selbst einen Spion zu nennen, bedeutet noch gar nichts. Doch bewegungslos, wie eine Eiche dazusitzen, lautlos wie ein Felsen zu sein und alles zu hören, was es zu hören gibt, schon.",o:4,av:40,f:[[10,2]]};
A.s[15] = {n:"Jäger der Abtrünnigen",d:"-",o:4,av:60,f:[[10,3]]};
A.s[16] = {n:"Oberster Assassine",d:"-",o:4,av:80,f:[[10,4]]};
A.s[17] = {n:"Meister der Illusionen",d:"-",o:4,av:100,f:[[10,5]]};
A.s[18] = {n:"Neophyt",d:"Diese neuen Rekruten entstammen dem niedersten Abschaum. Ihre Heimtücke ist bereits gut entwickelt, doch verhindert ihre Unwürdigkeit ihren weiteren Aufstieg. Doch mit etwas Ausbildung und einer sorgfältigen Spezialisierung dürfte dem nichts mehr im Weg stehen..",o:5,av:0,f:[]};
A.s[19] = {n:"Djauls Schüler",d:"Djauls Schüler sind von der Liebe zu ihrem Hass besessen. Sie müssen erst noch lernen, dass es im Kampf keine Gegner zu besiegen gibt, sondern dass es einfach nur darum geht, Schädel zu zerschlagen.",o:6,av:20,f:[[22,1,[200]],[21,1]]};
A.s[20] = {n:"Surinor",d:"Ein Surinor im Dienste von Djaul zu sein, setzt erhebliche körperliche Fähigkeiten und unfehlbare Unbesiegbarkeit voraus.",o:6,av:40,f:[[21,2],[22,2,[400]]]};
A.s[21] = {n:"Ritter der Verzweiflung",d:"-",o:6,av:60,f:[[22,3,[600]],[21,3]]};
A.s[22] = {n:"Champion des Chaos",d:"-",o:6,av:80,f:[[21,4],[22,4,[800]]]};
A.s[23] = {n:"Held der Apokalypse",d:"-",o:6,av:100,f:[[22,5,[1000]],[21,5]]};
A.s[24] = {n:"Hécates Schüler",d:"Hécates Schüler sind von purer Bosheit besessen. Sie müssen ihre Fähigkeit unter Beweis stellen, Informationen zu sammeln und Desinformationen auszustreuen.",o:7,av:20,f:[[23,1]]};
A.s[25] = {n:"Schatteninitiat",d:"Wer ein echter Schatteninitiat sein will, der will erst einmal das Verzaubern von Lebenden, von Toten und von lebenden Toten erlernt haben.",o:7,av:40,f:[[23,2]]};
