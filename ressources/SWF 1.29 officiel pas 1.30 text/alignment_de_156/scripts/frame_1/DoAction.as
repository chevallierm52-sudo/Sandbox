A.b[0] = {s:0,e:10,n:"Existenzgefährdung",d:"Eure Gesinnung ist vom Aussterben bedroht."};
A.b[1] = {s:10,e:20,n:"Überlebenskampf",d:"Eure Gesinnung kämpft ums Überleben in einer feindlichen Umgebung."};
A.b[2] = {s:20,e:30,n:"Guerilla",d:"Eure Gesinnung leistet tapfer Widerstand gegen die Angreifer."};
A.b[3] = {s:30,e:40,n:"Minderheit",d:"Eure Gesinnung ist etwas eingebrochen, wird sich aber sicherlich wieder bald aufrichten."};
A.b[4] = {s:40,e:50,n:"Kohabitation",d:"Das Gleichgewicht der Kräfte liegt nicht auf der Seite eurer Gesinnung, kann aber leicht zurückschwingen."};
A.b[5] = {s:50,e:60,n:"Status quo",d:"Eure Gesinnung konnte das Gleichgewicht der Kräfte ein wenig zu den eigenen Gunsten entscheiden."};
A.b[6] = {s:60,e:70,n:"Herrschaft",d:"Eure Gegner trauen sich nicht mehr heraus und eure Gesinnung beherrscht das Feld."};
A.b[7] = {s:70,e:80,n:"Tyrannei",d:"Die Macht eurer Gesinnung ist derart groß, dass ihr kaum noch Gegner wahrnehmt."};
A.b[8] = {s:80,e:90,n:"Dominanz",d:"Niemand wagt es mehr, eurer Gesinnung entgegenzutreten und der Kampf ist beinahe gewonnen."};
A.b[9] = {s:90,e:100,n:"Nonplusultra",d:"Eure Gesinnung ist so gut wie allmächtig und es gibt keinen organisierten Widerstand mehr."};
A.s[0] = {n:"Neutral",d:"-",o:0,av:0,f:[]};
A.s[1] = {n:"Neophyt",d:"Diese neuen Rekruten haben sich dazu entschieden, Witwen und Waisen zu beschützen. Sie stehen noch am Anfang ihrer Ausbildung und haben noch keine Spezialisierung gewählt. Doch dies kommt bald noch.",o:1,av:0,f:[]};
A.s[2] = {n:"Menalts Schüler",d:"Stets darauf erpicht, ihre Kriegskunst zu verfeinern, müssen Menalts Schüler im Rahmen eines harten und schmerzhaften Trainings ihren Mut und ihre Kraft unter Beweis stellen.",o:2,av:20,f:[[22,1,[200]],[21,1]]};
A.s[3] = {n:"Knappe",d:"Ein Knappe, der diesen Namen wirklich verdient, kennt kein Zaudern und kein Zögern. Trotz großer Schmerzen durch sein tägliches langes und plagendes Training gibt er nicht auf.",o:2,av:40,f:[[22,2,[400]],[21,2]]};
A.s[4] = {n:"Ritter der Hoffnung",d:"-",o:2,av:60,f:[[21,3],[22,3,[600]]]};
A.s[5] = {n:"Wunderbarer Held",d:"-",o:2,av:80,f:[[22,4,[800]],[21,4]]};
A.s[6] = {n:"Legendärer Held",d:"-",o:2,av:100,f:[[21,5],[22,5,[1000]]]};
A.s[7] = {n:"Jivas Schüler",d:"Um ihre großen magischen Kräfte weiterzuentwickeln folgen die Schüler Jivas dem spirituellen Weg ihres Meisters, um tief in ihrem Inneren die geistige Kraft zu entdecken, mit der sie große magische Mächte kontrollieren können.",o:3,av:20,f:[[23,1]]};
A.s[8] = {n:"Initiat",d:"Wer den Titel eines Initiaten tragen will, muss erst einmal furchtlos alle Verletzten und Sterbenden inmitten eines umkämpften Schlachtfeldes betreuen und heilen.",o:3,av:40,f:[[23,2]]};
A.s[9] = {n:"Adept der Schriften",d:"-",o:3,av:60,f:[[23,3]]};
