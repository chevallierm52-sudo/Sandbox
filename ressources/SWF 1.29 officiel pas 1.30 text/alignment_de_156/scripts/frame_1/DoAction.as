A.s[30] = {n:"Schattenspion",d:"In seinen Mantel aus Schatten gehüllt, beherrscht der Schattenspion die Kunst, Tränen fließen zu lassen und seine Klinge in Blut zu tränken und nicht umgekehrt.",o:8,av:40,f:[[10,2]]};
