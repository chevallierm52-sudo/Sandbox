D.q[292] = "Esta é uma idéia revolucionária, mas ainda precisa de muitas experimentações. Atualmente, estou usando fêmur de Chafer Chefe. Transformado em pó, ele simula o gosto do caril. Essa mistura é realmente difícil de encontrar e estou com falta de fêmures.";
D.q[7739] = "";
D.q[5080] = "";
D.q[7697] = "";
D.q[3686] = "Tudo limpo, área segura.";
D.q[7740] = "";
D.q[3447] = "A Filtounga é uma receita um pouco gordurosa, mas é muuuuito deliciosa!";
D.q[6437] = "Olá! Meu nome é Cheeka e eu sou líder de um importante grupo de mercadores. Quando não estou vendendo, estou negociando. Eu sei exatamente como misturar trabalho com prazer!  Dizem que sou muito rígida quando se trata de negócios, mas acredite em mim: todos nós somos ferozes quando o assunto é negócio! O que você pensa sobre isso?";
D.q[7701] = "";
D.q[7699] = "";
D.q[7702] = "";
D.q[7700] = "";
D.q[3690] = "Tudo limpo, área segura.";
D.q[7741] = "";
D.q[1167] = "Olá! Para ver essa residência modesta rodeada de pedras e seixos, você deve ter a febre do pescador também! \nOu você só quer falar comigo sobre o amor e outras coisas?";
D.q[3342] = "Olá! Seja bem-vindo ao nosso servidor de testes!\n\nAqui está a lista de algumas novidades criadas para esta Versão BETA 1.17.0:\n\n- Treechnid e Calabouços do Carvalho Mole.\n- A interface de Ferreiro Mágico foi revisada.\n- Emoticons podem ser usados com o comando /me.\n- O problema do bloqueio de quadrado foi solucionado.\n- Um novo sistema de seleção automática de servidor.\n- Uma lista mais detalhada das características de seus personagens.\n\nEsta lista não está completa. Você pode encontrar mais detalhes no fórum na seção de Servidor de Teste. No canto superior direito da tela, ao lado do menu de opções, você encontrará um pequeno botão que permitirá enviar um problema encontrado para o suporte técnico. Você também pode discutir sobre ele no fórum.\n\nEntão... o que posso fazer por você?";
D.q[7698] = "";
D.q[6458] = "O que você quer? Não há leis contra andar pela cidade, há? Então, me deixe em paz.";
D.q[4975] = "O que você quer! Você está me interrompendo no meio da minha pesquisa.";
D.q[6585] = "Desculpe-me, eu pensei ser outra pessoa, ninguém o seguiu, não é? Você precisa ser mais cuidadoso, nunca se sabe o que se esconde por trás das sombras.\nPelo olhar de vocês, parecem que tiveram problemas pelo caminho. Espero que Norb tenha contado tudo sobre o atalho! Bem, se é só isso, voltarei ao trabalho.";
D.q[441] = "Olá, eu sou Hagal, o guardião do banco. Somente pessoas respeitáveis e que não infringem as leis podem entrar.";
D.q[174] = "Ssssssshhhhh... Vá embora, jovem idiota... Apenasss os maisss vissss de Amakna podem ssssser reccebidos por nosssssso Messsssstre, Vil Smisssse...\nSssshhhhhhh... Asssshhhhhh... Uuuuuusssshhh";
D.q[1354] = "*Papel*\nHeim, eu perdi, você está muito bom... Vamos jogar uma terceira partida.";
D.q[3693] = "Tenha cuidado, pois as criaturas podem ser realmente agressivas por aqui.";
D.q[81] = "Oi, sinto que você gostaria de saber mais sobre a minha história...";
D.q[2140] = "O que você quer? Eu não estou com paciência para falar sobre o clima, me deixe sozinho...";
D.q[1360] = "*Tesoura*\nHeim, mas como? Não é possível!... Trapaceiro!";
D.q[5321] = "";
D.q[5167] = "Olá, eu estava começando a acreditar que você nunca voltaria. Você encontrou um Xelor que pode jogar um feitiço nesse livro para revelar sua história?";
D.q[6745] = "Olá, eu sou um simples mercador. Eu apenas faço negócios entre Bonta e Astrub.";
D.q[6039] = "Olá, eu estou com um pouco de pressa então seja breve.";
D.q[5695] = "Olá, eu estou procurando pelos meus dois irmãos. Ohcuorg e Oprah. Eles não estão no seu melhor, estão se comportando como crianças. Eu estou com medo de que eles acabem se metendo em encrenca.";
D.q[175] = "Ssssshhhhhhh... nosso clãsshhhh nosssss diz... Ssshhhh... para falar asssssssimm. Nossssssssss fazzzz parecer maisssssssss perverssssssossssssshhhh...";
D.q[3711] = "Piwiiiiiiiiiiiiiiiiiiiiiiii";
D.q[3714] = "Cuidado! Estou carregando água para as ninfas.";
D.q[347] = "Para se tornar joalheiro, você precisa primeiro amar a joalheria, as pedras preciosas e os metais raros. Essa profissão requer muita meticulosidade e imaginação. Eu posso lhe ensinar a profissão se quiser, mas você terá de comprar a ferramenta certa para mim.\nJoalheiros usam um Montador.";
D.q[6368] = "Xiu, eu disse. Faça uma pergunta por vez, e mantenha sua voz baixa.\nEntão, existem rumores frequentes sobre um chifre mágico em Sufokia e você quer saber mais sobre isso? Eu não ouvi esses rumores, eu nunca saio daqui. Mas, eu conheço a história do chifre, gostaria de ouvi-la?";
D.q[6638] = "Não, eles são brancos como a casca de um Escarafolha Branco.";
D.q[6327] = "Então, você também gosta de animais?";
D.q[2556] = "Então... Caçador vil de Dofus, destruidor de mundos, turista caótico, você tem algo a dizer?";
D.q[2460] = "Impressionante! Estou começando a entender o mecanismo de mutação das plantas!\nEu temo o pior para o futuro, mas acho que até lá descobriremos um remédio...";
D.q[349] = "Odeio Moskitos, esses monstrinhos insuportáveis que sempre atacam sem nenhum motivo quando corto as árvores. \nSe me trouxer 10 Asas de Moskitos, eu lhe darei um machado de lenhador.\nSe me trouxer 100 delas, lhe darei  o meu amuleto de lenhador.\n\nMoskitos são fáceis de encontrar, principalmente perto das Árvores da Culpa perto do lago.";
D.q[4778] = "";
D.q[364] = "Oi, sou Ness Laye e a felicidade é minha. Sou a única pessoa capaz de fazer flocos de felicidade.\n";
D.q[405] = "Existem minas em toda a volta da montanha, mas algumas estão praticamente vazias ou infestadas de monstros. Ande ao lado da montanha e encontrará as entradas que levam a diferentes minas da província de Amakna.";
D.q[4779] = "";
D.q[1123] = "Teeheehee HEH HEH HEH HEH!\nVocê quer saber por que estou rindo? Dê-me 5 Kamas e lhe conto...\nTeeheehee HEH HEH HEH HEH!";
D.q[4808] = "Olá, é bom ver você de novo. Eu espero que a investigação do alegado traidor comece logo.";
D.q[4980] = "Olá, é bom ver você com um espírito tão bom. O Steward gostaria de te ver. Eu não sei aonde ele está, você já deve saber aonde ele está a uma altura dessas.";
D.q[6549] = "Olá, você quem encontrou os brakmarianos perto da Baia de Cania?";
D.q[5215] = "";
D.q[3950] = "Olá, mestre Wabbit, como posso ajudá-lo? Quer conferir se tudo está pronto para a chegada do seu príncipe?";
D.q[813] = "O dono da taverna Gato Chamuscado sumiu na noite passada. Descubra quem é o sequestrador e traga-me o seu nome!\nGostaria de lhe dar os parabéns e alistá-lo. Ele fez um grande trabalho!";
D.q[6009] = "Olá, meu nome é Professor Kalkulus.";
D.q[3740] = "Um lenhador encontrará ótimas árvores para derrubar na floresta de Amakna.";
D.q[1008] = "Finalmente, aqui está um colar brilhante. Você não foi muito rápido desta vez...";
D.q[360] = "Olá, meu nome é Lou, Lou Pachoups, e amo pirulitos. Aprendi como fazer alguns, mas não tenho ingredientes suficientes...";
D.q[5503] = "Olá, meu nome é Suebur Dirgah e eu guardo as chaves.\nNinguém conseguirá subir esses degraus até que me mostre a chave.";
D.q[4783] = "";
D.q[448] = "Se você não quiser praticar, ainda há os pergaminhos. Eu coleciono Anéis Nimbly. Traga-me aproximadamente cem deles e lhe darei um Pequeno Pergaminho da Agilidade.";
D.q[1702] = "O templo Osamodas fica localizado a Leste do vilarejo de Amakna. Fale com Lisa Modas para começar o seu treinamento.";
D.q[7400] = "";
D.q[7159] = "";
D.q[4784] = "";
D.q[3745] = "Coletar coisas é um simples e relativamente rápido meio de ganhar os primeiros Kamas.";
D.q[2515] = "Olá, você! Cidadão de outro lugar! Antes de tudo, esteja ciente de que a venda de produtos fermentados é estritamente regulada nesta ilha. Esses produtos devem ser ingeridos com moderação. Mas as nossas oficinas estão sempre abertas para você e os seus Kamas!";
D.q[5162] = "Olá, sua viagem à blibliotera valeu de algo?";
D.q[1395] = "O que você quer? Estamos em um lugar perigoso. Podemos ser atacados por esses malditos Bontarianos a qualquer momento! Seria melhor você sair.";
D.q[3750] = "Estripar um peixe é uma tarefa fácil, use somente esta bancada que está aqui. Você verá que consegue, mas não se esqueça de que você precisa ter a sua ferramenta em mãos, se pretende fazer algo relacionado à sua profissão.";
D.q[4802] = "";
D.q[2357] = "O que você quer?";
D.q[1061] = "O que você quer?";
D.q[4853] = "";
D.q[1839] = "Durante a minha pesquisa na cartografia, encontrei um manuscrito que indica a posição de algumas passagens subterrâneas. Uma delas começa no porão da Biblioteca, mas desde então, não fui capaz de entender como o mecanismo de abertura funciona. Duvido que alguém como você seja capaz de entrar!";
D.q[6090] = "O que importa quanto ao que os outros pensam, não é como se eles tivessem me aceito como um dos seus de qualquer maneira.";
D.q[5617] = "O que este pequeno miliciano quer conosco? Vá fazer isso, vá fazer aquilo, espere aqui, me encontre aqui. Quando falam \"pule\", ela pergunta \"que altura?\"Afff, que patético";
D.q[4689] = "Ah, finalmente você voltou. Você vai trazer para mim o que eu preciso para a minha espada - a Corruptite. Um nome muito bonito para um material muito raro. Ele só poderá ser encontrado no Calabouço do Ferreiro, no baú da última sala.";
D.q[7096] = "";
D.q[7160] = "";
D.q[3774] = "Você deseja voltar à sua estátua?";
D.q[2106] = "Quando eu estava no cemitério de Amakna uma noite por ... hmm, um motivo que não importa agora... De qualquer forma, enquanto estava caminhando no cemitério, ouvi vozes que pareciam vir do túmulo do meu avô. Elas diziam \"Yke Harou... o sótão... meu Gobball... Você encontrará o Golpe da Visão!\" Embora tenha iniciado o jogo Goh, eu não sabia desse golpe lendário até agora. Então fiz algumas pesquisas e descobri a seguinte história: \"Aquele que encontrar o Golpe da Visão do jogo de Goh será capaz de predizer o tempo e o espaço\". Sei que você acha que fiquei muito tempo nesta taverna, mas o episódio que se seguiu é ainda mais excitante...";
D.q[2926] = "Olá, amigo da cultura! Quer dizer que você adquiriu um pouco de educação? Bem, já não era sem tempo. Mas, como dizemos, nunca é tarde demais para começar... Se precisar de um livro, basta me pedir.";
D.q[318] = "Olá! Nós somos banqueiros. Se você abrir uma conta neste banco, terá um cofre para armazenar seus valores. Mas esteja ciente que cada vez que consultar a sua conta custará #1 Kamas...";
D.q[3779] = "Você deseja voltar à sua estátua?";
D.q[3778] = "Você deseja voltar à sua estátua?";
D.q[6470] = "Olá, você parece ainda mais infeliz que eu! Por que você está assim?";
D.q[5326] = "";
D.q[433] = "Olá, jovem aventureiro, sou um dos poucos criadores de Dragonetes desta terra... Eu crio e domo. Sou a única pessoa capaz de entendê-los e amansá-los.\nMas tive problemas durante alguns anos... Você poderia me ajudar?";
D.q[696] = "A alegria está me cegando de lágrimas,\ne isto graças a você.\nA semente do conhecimento encontrou o seu lugar em sua alma,\nAqui está o segredo tão esperado : o \"Beijo\"...";
D.q[5407] = "";
D.q[7097] = "";
D.q[7161] = "";
D.q[4288] = "Olá! Estou prestes a conseguir um raro momento de descanso, então eu realmente não quero conversar!";
D.q[7098] = "";
D.q[4409] = "Excelente. Perfeito! Era exatamente isso que eu precisava: um encontro na Torre de Bonta. Nós conseguiremos capturá-lo lá. Hmmm, eu acho que vou aumentar a segurança do perímetro também.";
D.q[1524] = "Excelente! Você mantém um bom domínio da luta agora. Pode ser de real ajuda a partir de agora, contatarei você, mas até lá temos de ser discretos.\nAo que parece, você também tem uma carta para mim, Obrigado, mas na próxima vez, tente não se esquecer.";
D.q[7214] = "";
D.q[7464] = "";
D.q[5531] = "Olá. Você é um defensor fervoroso de Bonta, estou grato em te conhecer. Meu nome é Jiva, eu sou o protetor do mês de Jivian e dessa cidade esplêndida.";
D.q[5170] = "Me ajude, por favor! Eu quero sair daqui! Os demônios estão me assustando... Mas esses Wabits estúpidos são ainda piores!";
D.q[2830] = "Hoje é dia de meditação. Não me perturbe!\n\n....zZZzzzz Zzz... zzz...";
D.q[130] = "As celebrações são, às vezes, organizadas na pousada. Os trovadores vêm para jogar e agitar as coisas e o preço do Tofu grelhado é geralmente reduzido à metade nesses dias... As reuniões também podem ser organizadas aqui pelos membros de uma guilda ou pelos grupos de amigos.";
D.q[1027] = "Hmm, o formulário 243... Você deve ter terríveis suspeitas sobre alguém para estar pensando em fazer aquele teste.";
D.q[576] = "Oh, oh, você ESTÁ sério! Tudo bem, eu o ajudarei. Para ser promovido, o servo Kanniball tem de lutar entre as castas. O vencedor pega a máscara do perdedor. Quando um tiver a máscara de cada uma das quatro castas, ele as combina para fazer uma nova máscara. Se me trouxer as quatro máscaras, eu as combinarei...";
D.q[7717] = "";
D.q[1550] = "Hmm, vejo Danathor em uma má posição. Seu rival Tedeor está ganhando terreno gradualmente nos corações Bontarianos... Mas também vejo um acidente terrível, algo misterioso, uma reviravolta na situação... Vejo Danathor coroado, sim, ele será adminstrador durante os próximos anos, com certeza!";
D.q[7761] = "";
D.q[2766] = "Mil e um grãos de arroz formaram os arrozais da nossa ilha desde o nosso último encontro. Sei que você sente estar pronto para se tornar um Danwa. Para qual nível você vai passar?";
D.q[592] = "Finalmente alguém me compreende. Para consertar aquele buraco, preciso de muitos potes de cola e placas de madeira. Se me trouxer 2 pranchas e um pote de cola, eu lhe darei uma garrafa de bom refresco, pois tenho várias delas!";
D.q[1443] = "Hem, você está procurando ajuda para a investigação?\nEu lhe falei do formulário de investigação n° 33, mas custa 700 Kamas uma cópia...";
D.q[7162] = "";
D.q[7762] = "";
D.q[5811] = "";
D.q[6107] = "Saudações. Você tem alguma informação que nos daria uma vantagem contra nossa cidade inimiga?";
D.q[1438] = "Hem, você está procurando ajuda para a investigação?\nEu lhe falei do formulário de investigação n° 36, mas custa 500 Kamas uma cópia...";
D.q[7763] = "";
D.q[5327] = "";
D.q[6108] = "Um Brakmariano me contou que ele descende de um primo meu que fica no Santuário de Hotomani. Eu tenho que libertá-lo.";
D.q[2204] = "Hmm... Não quero ser grosseiro, mas tirando o MacGiven, não conheço ninguém que possa fazer um arco com tão poucos materiais...";
D.q[1378] = "Hmm... Estou ocupado no momento.";
D.q[7764] = "";
D.q[7100] = "";
D.q[7216] = "";
D.q[1070] = "Hmm... Não vê que estou ocupado?";
D.q[1103] = "Diga-me amigo, você viu meus irmãos andando por aí?\nEu preciso encontrá-los o mais rápido possível. Eles tendem a quebrar tudo e atirar objetos em quem tenta impedi-los.";
D.q[7765] = "";
D.q[4500] = "Vendendo.\nEntão, eu tenho um amigo que poderia dar conta disso. Mas ele é uma pessoa estranha e tem tendência a ficar paranoico. Muito paranoico.\nEle está se escondendo na caverna de Bruce Boulgoure. Mas você não pode visitá-lo porque tem um monstro chamado Bellus Sel bloqueando a entrada. Você notará que isso vai atrapalhar o trabalho de Nara, e você sabe que ele odeia ser incomodado.";
D.q[6109] = "É a minha vez de ir. Eu não posso ficar sentado e deixar que ele se arrisque desse jeito.";
D.q[1558] = "Moo oom holp m\'om plos\'om moo oom.";
D.q[1361] = "*Papel*\nHeim, mas como? É impossível!...Trapaceiro!";
D.q[7766] = "";
D.q[6639] = "Eu apenas dei alguns minutos para Elturt vencer a batalha e enviá-lo de volta para onde você veio.";
D.q[3058] = "Aqui estão as tábuas. Eu usarei para a infra-estrutura. Agora, eu preciso de pedras para os muros.";
D.q[5346] = "";
D.q[7101] = "";
D.q[7767] = "";
D.q[1153] = "Antes de sair deste templo, eu gostaria que você fizesse um pequeno teste. Eu lhe farei algumas perguntas para ter certeza que você está pronto para descobrir o mundo. Se você passar com sucesso, eu lhe ensinarei uma técnica de meditação que poderá ser muito útil.";
D.q[760] = "Durante quase cem anos, abandonamos o cemitério do Leste de Bonta. Desde então, muitas criaturas entraram lá.\nUma delas é especialmente resistente: a múmia nova.\nTenha isso como um teste, mas se me trouxer algumas partes de sua faixa, eu o nomearei oficial da milícia de Bonta.";
D.q[6046] = "";
D.q[7102] = "";
D.q[1044] = "Aqui está! Novo em folha.";
D.q[4839] = "";
D.q[662] = "Oh! Alguém... Vá embora! Não, venha aqui!... Qual é o seu nome? Eu? Por 5 anos e você? \n\nPor que você está me olhando assim? Perdi minha memória e não consigo me lembrar como...\nComandante Chaferfu é meu Capitão?!? Eu guardo um segredo senhor, você quer saber?";
D.q[7768] = "";
D.q[4844] = "Aqui está você novamente! Você colocou a poção de Divad na mesa?";
D.q[7769] = "";
D.q[677] = "Parabéns! Você passou com grande sucesso pelo teste deste Calabouço.\n\nComo recompensa, eu lhe ofereço esse mascote. Ele pode ser muito útil em sua missão.";
D.q[3859] = "Você encontra presente para Bworknroll. Você vai com Litol.";
D.q[3855] = "Aah! Caminhar enquanto admiro Astrub, este é um sonho antigo. A única coisa que está faltando no retrato é um Dofus ou dois para colocar no alto da lareira.";
D.q[5889] = "";
D.q[1244] = "Aqui está você, pólvora fresca!";
D.q[3875] = "Então? E quanto às criptas?";
D.q[3131] = "Antes de começar a criar um Dragossauro, você deve capturá-lo. Para fazer isso, tente distraí-lo e hipnotizá-lo, só então use uma rede de captura. Como você provavelmente deve saber, a única maneira de hipnotizar um Dragossauro é conjurar um feitiço nele. E eu sou o único que pode ensinar isso a você. Eu lhe devo essa, embora aposte que você nunca será um criador de Dragossauros tão bom quanto eu.";
D.q[2696] = "Aí vai você! Pegue esta cópia magnífica de um Dofus em nome dos Enutrofs de Astrub. Estamos todos presos na quarentena.";
D.q[5087] = "";
D.q[7770] = "";
D.q[1669] = "Aqui está você! Você não é muito sortudo, mas talvez  possa ganhar um grande prêmio no próximo Quaquack.";
D.q[2457] = "Aqui está uma sombra que ficará na escuridão por um bom tempo.";
D.q[7771] = "";
D.q[335] = "Aqui está você! Agora sabe o necessário para começar nesta profissão. Uma última coisa antes de ir: saiba que você precisará de um instrumento apropriado para praticar, dê uma olhada naqueles que estou vendendo.";
D.q[484] = "Olhe, escrevi neste pergaminho uma lista de missões para serem cumpridas. Não hesite em me pedir novas informações.";
D.q[3017] = "Estranhos fenômenos estão perturbando a tranqüilidade daqueles que deveriam descansar aqui. Estou tentando entender o que está acontecendo... Se você não está com medo dos fantasmas e não tem receio de ficar doido, venha me ajudar!";
D.q[7772] = "";
D.q[3603] = "Olhe. Agora você sabe tudo que precisa para começar. Vá e converse com o chefe. Ele lhe dará um trabalho.";
D.q[2512] = "Aqui, pegue esta cópia magnífica de um Dofus em nome dos Enutrofs de Astrub.";
D.q[7783] = "";
D.q[3881] = "Por que ele quer os meus serviços? Ele não pode contratar outra pessoa?";
D.q[3474] = "Ei, Ei você! Venha, venha!";
D.q[7773] = "";
D.q[4671] = "Muito gentil você é, e deliciosa é a salada. Trouxe-me um Coçador-de-Costas Spentox? Hmm, aceitá-lo não devo. Capaz de coçar minhas costas por anos não fui. Então, um acordo com você eu farei.\nPelo coçador, a localização do Chifre de Fogornleg irei revelar.\nEncontrar o chifre a nordeste da ilha você irá, próximo a estátua de fênix.\nAgora ir pra cama preciso, muito sonolento a salada me deixou...";
D.q[4123] = "Ei dorífora! É meu! Capitão Haddock\'n\'roll! Eu posso levá-lo para o fim do mundo, principalmente se for para te afastar de mim!\nPosso levá-lo a uma bela ilha deserta, sem nenhum Kanniballs, se quiser.";
D.q[5887] = "";
D.q[1318] = "Isto é maravilhoso! Sou um homem rico hahahá! Liquide-o agora!";
D.q[7774] = "";
D.q[5935] = "Olá, pequeno monstrinho! Eu estou aqui para trocar todos os doces não comestíveis que você tiver por deliciosas guloseimas. Não me perguntei o porquê estou fazendo isso, é uma verdadeira história para boi durmir. E acredite, você não quer se encontrar com o boi.";
D.q[3646] = "Olá! Estou contente em ver uma cara! Vou me apresentar, meu nome é Tellih\'Gent. Esse não é um nome muito popular por aqui, embora possa me lembrar que encontrei um Sadida com o mesmo nome. Não nos falamos muito, mas posso dizer que ele é uma excelente pessoa. Infelizmente, tivemos de nos separar quando ele foi tirar uma soneca. Isso me lembra uma história engraçada que me aconteceu há muito tempo, enquanto eu dormia. Você quer ouvi-la?";
D.q[7785] = "";
D.q[5353] = "";
D.q[3162] = "Olá! Estou certo de que me conhece, #1! Eu sou Krunchie, o melhor caçador de Crackler que já existiu! Eu caço, quebro, desmancho, desmembro, aí eles fazem um som assim \"Craaackk\" e \"boom\"... De qualquer maneira, como pode ver, sou realmente o melhor caçador de Crackler que já existiu.";
D.q[7775] = "";
D.q[7786] = "";
D.q[4145] = "Você me trouxe tudo que preciso para criar devidamente minhas criaturas?";
D.q[7776] = "";
D.q[4277] = "Olá... Hehehe... Olha isso, esta floresta é qualquer coisa, menos quieta!";
D.q[2002] = "Ei você! Papai quer falar com você... Ele está lá adiante, vá para o Sul, passando pelo lago... Espere, eu lhe mostrarei no seu mapa, então basta seguir a sua bússola.";
D.q[3816] = "Você poderá tentar derrotá-lo de novo! Persista, jovem aventureiro!";
D.q[7787] = "";
D.q[1151] = "Você está em um canil. Esta construção é um tipo de santuário de animais de estimação. Nós os mantemos aqui quando seus donos querem sair para caçar Dragões. Nós cuidamos deles e logo seremos capazes de curá-los também. Podemos até pegar um animal de estimação fantasma e lhe dar um novo animal em troca.";
D.q[7777] = "";
D.q[5818] = "";
D.q[2069] = "Ei, preciso de uma pá. Woohoo! Uma pá... estou salvo! Cave... mais fundo, mais fundo... O subterrâneo é a proteção...";
D.q[3458] = "Ei! Você, hahahá, não! Não o Minotoror cor-de-rosa! Sim, você, hahahahá...";
D.q[3245] = "En... En... Então, você viu uma runa que é algo extremamente místico e ultrapoderoso, mas eu n... n... não tenho muita informação so... sobre isto. Tudo o que  sei é q... q...que as... as... assim que a usar, é como se você fo... fo... fosse posto na aura do Mundo... en... en... entende, algo assim. E qualquer um po... po... pode v... v... ver que você é um artesão! E lá vai você! Você é conhecido e renomado, e os Kamas são seus!";
D.q[7778] = "";
D.q[1129] = "Nós podemos ser diabólicos e continuar na moda, não podemos?";
D.q[238] = "O queeeê? Mas o quê...? Quem...? Mas...? Oh, Oh, parece que você está perdido... Caia fora! Eu tenho de passar! Não está vendo que estou trabalhando aqui?";
D.q[7779] = "";
D.q[7790] = "";
D.q[3660] = "Eu o reconheço, você já trabalhou para mim, não é? Você não poderia ter chegado em hora mais apropriada. Preciso de alguém digno de confiança, você pode levar esse instrumento para Xelorat Masket? Está muito longe e não tenho tempo para fazer isso neste momento.";
D.q[4119] = "E agora, aqui vai a última e mais importante pergunta: quantos Kokonuts traumatizados um Corvo pode carregar se ele tem 5 vezes menos a força que você, mas tem um Cinto Bherb e uma sacola feita de pêlo de Pikoko melhroado por um alfaiate mágico?";
D.q[7835] = "";
D.q[1698] = "Certo, certo... Apenas pegue um objeto nesta sacola grande. Alguns desses objetos são da valiosa fortuna real! Acredite em mim!";
D.q[3288] = "O que eu estava dizendo...\nCerto, eu estava preso na ilha e Otomai muitas vezes falhava nas suas trepanações e transplantes de cérebro em monstros. \nPor exemplo, você sabia que o cérebro de um Iop serve na cabeça de uma Aracne?\nDe qualquer forma, para ajudá-lo nessa tarefa nobre em busca do conhecimento, eu construí uma máquina de viagem no tempo que o ajudou a tentar novamente algumas das suas experiências.";
D.q[1038] = "Hey! Musa Caçador de Lobo disse que é fácil, mas NÃO é fácil! O manejo da arma de um caçador exige algumas habilidades. Deixe a Musa ter a sua prova de destreza e ela o nomeará caçador.";
D.q[4816] = "";
D.q[7781] = "";
D.q[7791] = "";
D.q[7146] = "";
D.q[8111] = "";
D.q[3806] = "Acalme-se... não tem como você conseguir esse colar por uma simples pele roída pelas traças.";
D.q[4867] = "Totalmente. O taverneiro pode ser bom em coletar subornos, mas cozinhar é uma outra história. Porque estamos nós, dois soldados, comendo a mesma comida que os prisioneiros? Isso é o que eu gostaria de saber!";
D.q[5187] = "Por que eles me acusaram? Você tinha todas as provas necessárias para me libertar. O que eu fiz para você?";
D.q[8112] = "";
D.q[1159] = "Parabéns! Você merece aprender a minha técnica de meditação.\nOs danos infligidos pelas criaturas deste mundo são normalmente superficiais.\nPara se curar através da meditação, você deve se sentar e deixar a magia eniripisana deste mundo dominar o seu corpo.\n\nAgora vá! O mundo o espera.";
D.q[8113] = "";
D.q[3947] = "Ah, incrível! Aqui estão os ingredientes. Dê-me um segundo, eu mexo assim, baixo a temperatura e agora você é um Wabbit!";
D.q[7747] = "";
D.q[5360] = "";
D.q[8114] = "";
D.q[1016] = "Oh, por favor, eles não estão todos aí. Amayiro me disse que você não era do tipo esperto, e devo admitir que ele estava certo...";
D.q[5175] = "";
D.q[8115] = "";
D.q[7215] = "";
D.q[4450] = "Ahh. Mas você é um Brakmariano! O que você quer de mim?";
D.q[1265] = "Hum, obrigado. Trarei esse Ture Inge para uma análise completa.";
D.q[8116] = "";
D.q[3139] = "O que esse ser desprezível está fazendo no esconderijo do nosso venerável mestre Skeunk? \nVocê não quer atravessar essa porta, quer? \nSó os aventureiros com a permissão das quatro irmãs discípulas de Skeunk podem atravessar essa porta.";
D.q[8117] = "";
D.q[1573] = "Olá, #1, você quer se divertir?";
D.q[5903] = "";
D.q[1194] = "Oi, camarada Brakmariano, como posso ajudá-lo?";
D.q[646] = "Que azar! Que traição! Onde estão meus preciosos Gobballs, ontem tão doces, tão úteis, tão protetores... e agora tão desagradáveis e estúpidos? \n\nEles mudaram completamente há alguns dias. Seus nomes nunca lhe serviram tão bem!\nEles atacam qualquer coisa que se movimente e devoram também qualquer coisa... Durante a última hora, 4 Eniripsas, 2 Ecaflips e até mesmo um Iop foram engolidos só pelo meu Gobball Real! Estou perturbado. Eles não estão mais me ouvindo! A única solução seria usar métodos violentos!\n\nAjude-me a acalmá-los! Por favor....\nA recompensa valerá pelo esforço!";
D.q[4285] = "Estou lhe falando a verdade. Eu nunca trairia Bonta. Eu estou longe de ser perfeito, mas eu nunca faria algo de ruim para a minha própria cidade. Por favor, não me machuque! Eu nunca mais comprarei comida de Brakmarianos novamente. Existem outros fornecedores que são mais caros, mas eu comprarei deles. Eu juro.";
D.q[7219] = "";
D.q[1368] = "A guarnição deve proteger os aldeões quando são atacados por guerreiros Orientais.";
D.q[1367] = "Oi, meu nome é Hertuen. Eu defendo a porta da guarnição de Amakna. Como posso ajudá-lo?";
D.q[2041] = "Oi! Deixe que me apresente, sou Libélula, o alquimista desta boa cidade. Em que posso ajudá-lo?";
D.q[7792] = "";
D.q[1377] = "Estranho, muito estranho. Um fluxo mágico tão poderoso que causa disrupções na corrente magnética. E ainda mais estranho, acho que mais à frente da porta há uma fortaleza e um mecanismo que aparentemente controla a abertura. Com um pouco mais de tempo, eu seria capaz de penetrar nesse mistério.";
D.q[4793] = "";
D.q[2083] = "Oi! Quer jogar comigo? Você é o alvo e eu, a caçadora. *Ela tira uma flecha e mira o arco em você*";
D.q[7793] = "";
D.q[306] = "Olá! Vejo que você conhece muito bem o tema de Tik Ueteco, o Defensor da Lei. Quando precisar da ajuda de um amigo, pode contar comigo. Tiro minhas energias da Manteiga de Avelã. Para fazê-la, preciso de avelãs e muito amor! Estou interessado em ambas as coisas. Posso lhe dar um Fêmur do Chafer Arqueiro em troca de 5 avelãs.";
D.q[389] = "Oi! Eu amo Manteiga de Avelã feita de Tik Ueteco, mas meu pai diz que é muito cara... Então, eu tentei fazer por conta própria... Se misturarmos 70 Bolotas com 70 Línguas de Dandélio Maléfico, obteremos uma mistura parecida com a do Senhor Tik Ueteco. Traga-me os ingredientes e lhe darei um Pergaminho de Agilidade.";
D.q[1334] = "Oi! Sou o Capitão Koda. Estou muito ocupado, preparando um ataque importante a Brakmar, com nove de meus homens.";
D.q[7794] = "";
D.q[945] = "Oi! Sou Kosuke, o ferreiro de lâmina. Como posso ajudá-lo?";
D.q[4358] = "Ecaflip? Hm... Sim, eu vi alguns deles não faz muito tempo. Eles pareciam espertalhões, por sinal.  Não que eu estava escutando a conversa deles, mas acho que ouvi um deles falando Lodax.";
D.q[5591] = "O que você fez comigo? Estou todo formigando... E a dor... Você seu pequeno híbrido, estou certo de que é por causa de seu xixi. Não importa, você realmente deve parar de beber, seu hálito fede.";
D.q[8076] = "";
D.q[6256] = "O que se passa com o Capitão Starky afinal? Aquele bobão nem mesmo chega aos meus tornozelos, eu o esmagaria e cortaria o seu pescoço. E depois, eu beberia... Suco de laranja logo depois!";
D.q[7795] = "";
D.q[7220] = "";
D.q[3546] = "Oi! Desculpe, eu não queria magoá-lo... ahahah desculpe por essa piadinha. Eu sei que com vocês Sacriers, é olho por olho. É uma boa coisa. Preciso de alguém que esteja pronto para apanhar e dar o troco.";
D.q[8077] = "";
D.q[7796] = "";
D.q[8078] = "";
D.q[1430] = "Você está em frente ao tanque de Caranhas. Minha criação.";
D.q[5885] = "";
D.q[5618] = "O que este pequeno miliciano quer conosco? Vá fazer isso, vá fazer aquilo, espere aqui, me encontre aqui. Quando falam \"pule\", ela pergunta \"que altura?\"Afff, que patético";
D.q[121] = "Oi, sou Bello, um jovem mestre Feca. Adoro fazer cócegas nos meus Gobballs para fazê-los rir.";
D.q[7797] = "";
D.q[8079] = "";
D.q[1433] = "Maldição! Você realmente aterrissou nisso! A melhor coisa a fazer é forjar provas falsas e encontrar um culpado, porque Amayiro não desistirá facilmente. Além de que você não deveria confiar nele. Posso sentir que ele tem inveja de você...";
D.q[4426] = "Novidades de Kaffra?";
D.q[1362] = "*Pedra*\nHeim, mas como? Não é possível!...Trapaceiro!";
D.q[7798] = "";
D.q[5228] = "";
D.q[8080] = "";
D.q[102] = "Oi, sou Laura Soho, garçonete desta taverna. O que posso fazer por você?";
D.q[7123] = "";
D.q[7103] = "";
D.q[946] = "Oi, sou Allen Tokar, quer um energético?\nVocê tem 4 Kamas para me emprestar? Eu lhe devolverei assim que me pagarem... Na verdade, 8 seriam melhor.";
D.q[8081] = "";
D.q[373] = "Oi, sou Ariz. Eu fiz doces de goma. Para fazer goma, preciso de muita geléia...";
D.q[7799] = "";
D.q[8082] = "";
D.q[7725] = "";
D.q[100] = "Oi, sou Rish Claymore, um respeitado mestre das armas em Amakna. Se estiver procurando uma Pedra para Amolar, está com sorte, pois estou vendendo uma.";
D.q[8083] = "";
D.q[1254] = "Quais tipos de mantos? Mantos Bontarianos, é claro. Os únicos usados em cerimônias oficiais na cidade.\nQualquer bom alfaiate pode fazer um manto com uma tinta azul mágica, uma pena de corvo e lã de Gobball branco.";
D.q[7800] = "";
D.q[295] = "Oi, meu nome é Jackall Breath. Sou aprendiz de Kwaker Vans e noivo de Edrige Valling. O problema é que ela está enjoada do meu bafo desde que comecei a comer pão de caril sem caril. Sempre que quero falar com ela, tenho de comer Geléia de Menta, mas cada dia é mais difícil encontrá-las. Poderia me ajudar?";
D.q[1240] = "Oi, o que posso fazer por você?";
D.q[275] = "O que você poderia saber sobre os poderes dos cogumelos? Você nem mesmo é um Eniripsa...";
D.q[4336] = "O que nós faremos com isso? Vender, é claro. Você achou que nós seguiriamos aquele \"contrato\"? Quando Xephires tiver completado a sua missão, vamos nos livrar dele.\nPor falar nisso, eu terei que me livrar de Milone também... ele tem sido muito irritante nos últimos tempos, e ele sabe de muita coisa também. Mas isso pode esperar.";
D.q[8084] = "";
D.q[3133] = "O que você quer de mim, aventureiro audacioso!\nEntendo... Você veio me dar o jogo de Koolich!\nNão!\nDo que você está falando?\nSua coisinha atrevida!";
D.q[918] = "Oi, meu nome é Ture Inge, especialista em espionagem e psicologia. Sei que deseja algo de mim.";
D.q[7801] = "";
D.q[3983] = "O que você quel de mim? Você não ve que estou cumplindo uma missão? Pleciso delotal uma cliatula melecedola da minha linhagem. De acoldo com um pelsonagem vestido de pleto, um Tofu se escondeu nesta fazenda e eu pleciso delotá-lo, se eu quisel tel acesso ao tlono um dia.";
D.q[7124] = "";
D.q[7104] = "";
D.q[8085] = "";
D.q[4474] = "Você encontrou o ferreiro?";
D.q[1298] = "Oi, nobre cidadão, sou o responsável pela cidade. Posso ajudá-lo?";
D.q[7802] = "";
D.q[1578] = "Hihi! Espero que ele se lembre desta lição!";
D.q[376] = "Oi, meu nome é Téha Chicks. Sou uma das adoradoras do Grande Guru. Quando perco o meu rebanho, ele me mostra o caminho. Sempre tenho fé nele, especialmente após comer um sonho de cogumelo... Skippy me deu a receita.";
D.q[6544] = "Você sabe como jogar e tem um apetite pelo risco, você não vive em Brakmar a toa.";
D.q[1380] = "Hillik! Iik ik ink skiril. Ciwio plinlis ailr yik?";
D.q[4842] = "";
D.q[8086] = "";
D.q[2256] = "O quê? Um Gobball? Nós não temos tempo! Temos de descer... Acho que eles sentiram alguma coisa que não era o gás... Alguns voltaram em estado deplorável, e duvido que um Subosycold possa fazer algo por eles. Alguns dos nossos foram procurar pelos Sniffallrats já há algum tempo... Encontre-os, por favor!";
D.q[7803] = "";
D.q[4737] = "Arg! Maldição, Brakmariano!";
D.q[1973] = "O quê?! Isto é um ASSALTO! Humm, bem, então por que você não coloca um pouco d\'água no energético?";
D.q[4735] = "Olá, meu nome é Kosuke o... Ehh, mas você é um Brakmariano sanguinário, o que você está fazendo aqui?";
D.q[3242] = "Estes discípulos eram habitantes deste vilarejo. Eles queriam muito reproduzir os Dragonetes do deus Osamodas e tiveram sucesso em domá-los. Mas eles eram um pouco mal intencionados. De fato, todo mundo sabe que aqueles Dofus se originaram dos Dragões. Então, por muitas gerações, eles continuaram reproduzindo os Dragões friamente, para ter cada vez mais Dofus. Eles deveriam ter em mente que esses ovos eram amaldiçoados e que aqueles Dragões não poderiam ser domados como as outras criaturas...";
D.q[8087] = "";
D.q[6281] = "O quê? Você deu aos assaltantes uma sacudida e os convenceu de ingressar na milícia? Muito bom! Nunca se esqueça que os enganadores um dia podem ser os enganados, mas um dia eles podem ser úteis para nós.";
D.q[4027] = "A fórmula não está completa? Mas eu já lhe disse tudo o que sabia...";
D.q[4470] = "O quê? É estranho que você tenha me perguntado isso. Um Bontariano passou por aqui há pouco tempo me perguntando se podia trabalhar para mim...\nNão, eu não trabalho para Bonta, mas eu tenho um amigo que começou a fazer isso.";
D.q[7804] = "";
D.q[1836] = "Hm não, ainda há algo faltando para você construir essa jangada...";
D.q[8088] = "";
D.q[7805] = "";
D.q[4449] = "Olá, por favor, não me incomode, estou ocupado com os meus livros.";
D.q[2527] = "Olá! Tenho todos os tipos de bebidas fermentadas, o que você quer?";
D.q[1304] = "Volte novamente às 9 da noite com todos os elementos descritos nessa lista... Eu lhe darei todos os detalhes da sua missão.";
D.q[8089] = "";
D.q[1739] = "Discípulo, você ainda tem muitas coisas para aprender, o que deseja saber?";
D.q[923] = "Oi, causa perdida! O que deseja?";
D.q[7806] = "";
D.q[4992] = "";
D.q[1715] = "Parabéns! Tem de ser rápido para pegar esse animal, você parece ser talentoso. Se quiser se tornar um lutador cada vez melhor, deixe-me dizer-lhe algo...";
D.q[7125] = "";
D.q[6133] = "E aquelas almas que eu pedi pra você?";
D.q[4657] = "Esses documentos são muito importantes para Brakmar. Qualquer erro de sua parte será severamente punido.";
D.q[8091] = "";
D.q[2831] = "Saudações, a entrada da torre é reservada aos habitantes mais fiéis de Bonta e aos membros da Ordem. Se quiser se juntar a nós, vá ver Amayiro nas barracas da milícia.";
D.q[4990] = "Hmm, um ataque significaria fazer Brakmar perder o controle da Vila dos Diabinhos? É verdade que nosso inimigo tem ficado cada vez mais agressivo. Vamos cortar o suprimento deles e ver o quão durões eles são.\nDiga ao Steward para aprovar o plano.";
D.q[1095] = "Hmm, vejo que você pertence à milícia de Bonta.\nAmayiro pediu-me um relatório e eu já terminei.\nAqui, e que a deusa Jiva o abençoe, #1.";
D.q[8092] = "";
D.q[1347] = "H\'m, se você ganhar a brincadeira, vou lhe ensinar como brincar com qualquer pessoa em qualquer lugar.";
D.q[3103] = "O quê? Viver com ele neste lugarzinho com cheiro de batata podre? Quem ele pensa que é para dizer o que devo fazer? Em vez disso, encontre seu velho esconderijo e volte para me dizer como ele é.";
D.q[6545] = "Bem, você não costuma mudar de idéia quando avança, não é? Ecaflips devem adorar apostar com você.";
D.q[1060] = "Hmm, foi uma lutinha interessante.\nBem, se já terminou de jogar, ainda tenho trabalho para você fazer para o clã.";
D.q[8093] = "";
D.q[204] = "Hm, desculpe, mas Wiss Catz me disse que ele nunca aposta se não tem total certeza de que vai ganhar. Ele então rejeitou a sua oferta... Aqui está o seu trevo.";
D.q[8090] = "";
D.q[5230] = "";
D.q[4043] = "Obrigado! Isso é tudo?";
D.q[280] = "Hmmm... Yeahh, eu sabia! Oh, sou mesmo um gênio, tão inteligente! Terminei um plano que devo qualificr como muito inspirado. Mas, por enquanto, preciso convencer as pessoas sobre a minha causa. Quarenta gatunos devem ser suficientes...";
D.q[2403] = "Hmm, o cheiro de couro queimado me anima, oh, desculpe! Não quis assustá-lo, meu nome é Ygat. Sou o melhor sapateiro da região. Cintos, sapatos, qualquer coisa, eu posso fazer!";
D.q[1065] = "Hmmm, deixe-me sozinho, você não vê que estou na minha folga?";
D.q[8094] = "";
D.q[1870] = "Ah Ah! Uma jovem garota. Talvez ela seja uma ladina ou pior... uma mágica que está com inveja dos meus poderes! Tudo está claro agora! Humm, deixe vazar. Vamos manter isto como uma mera suposição.";
D.q[7221] = "";
D.q[8095] = "";
D.q[1486] = "Hmmm. Não posso lhe ensinar o básico desse ofício. Você já está treinando para outro ofício. Volte aqui quando já estiver dominando os outros ofícios.";
D.q[820] = "Estou muito satisfeito com o seu trabalho, do que mais você precisa?";
D.q[4093] = "Certo, terminei esta poção... Pronto para se tornar um Wabbit?";
D.q[6542] = "Hmmff... Mmmmmmmmff!!";
D.q[1028] = "Hmmm... bem... de fato, não é... Não posso manusear meu sabre quando estou vestindo isso. Nunca considerei vender a um joalheiro.";
D.q[8096] = "";
D.q[6131] = "E aquelas almas que eu pedi pra você?";
D.q[1887] = "Bem, cada um de nós terá a sua função. Você poderia  comprar duas rosas para mim? Eu lhe mostrarei em qual vendedor você deverá ir, me dê o seu mapa. Enquanto isso, eu vou me preparar e analisar as marcas deixadas pelo gatuno.";
D.q[6269] = "Hmm,,, agora que eu penso sobre isso, deve ser possivel sem morrer. Sua missão continua a mesma, mas não há motivos para sair remando através do fosso de Brakmar e acabar se matando. Você é muito mais útil vivo.";
D.q[8097] = "";
D.q[7222] = "";
D.q[2639] = "O quê? Você quer me... Oh! Um desafio!\nCerto, vou esmagar você e dar seus restos à sua \"Chefe\" Pandawette, já que a desenhei na sua fonte! Nos encontramos no Dojo!";
D.q[1929] = "Pegue esse anel. Eu o aconselho a lutar com o Treechnid que está na floresta. As ondas mágicas que explodem quando ele morre parecem ser tão poderosas a ponto de ativar o anel. Boa sorte! Cuidado, os Treechnid podem ser muito perigosos. Você pode pedir ajuda. De qualquer forma, o anel é seu.";
D.q[8098] = "";
D.q[4777] = "";
D.q[7126] = "";
D.q[1935] = "Obrigado pelo relatório... Estou rodeado de idiotas. Deixe-me ver... De que diabos ele está falando? Eu mal consegui ler isso... “equipe de escavação”... “outra descoberta”... maldição! Quero saber do que se trata tudo isso !";
D.q[467] = "Whooahhh, você é glande! Eu devo aleltá-lo, eu sou Peawling Mowning... um dos Wabbits mais podelosos do mundo... Eu sou abençoado pela estlela cantante... Então pale de me olhal assim... Você não me atacalia, ou atacalia? Eu tive palticipação na destluição da glande Tolle Effete...\n\nPale de me olhal assim! Você não me atacalia, celto? Eu sou pequeno, estou sozinho e olhe pala os meus olhinhos... Você não pode machucal uma cliatura tão doce, e o mais folte não ataca o mais flaco... celto? Hmmm... e que tal se eu lhe del uma chave glande e você me deixa em paz, huh?";
D.q[8099] = "";
D.q[1218] = "Obrigado e bem-vindo, Bro!";
D.q[8100] = "";
D.q[2682] = "Olá! Você também gosta do perfume suave de bambu fermentado?! Vamos nos entender bem, então... O que você quer?";
D.q[5693] = "Senti uma aura negra e pensei em você na mesma hora. O que você quer?";
D.q[1938] = "O quê?! Eu? Parar meus negócios? Ele deve estar brincando! Você contou-lhe, certo?! Sem chance! Para causas beneficentes! Isto realmente seria o fim... ha-há! Se apresse, vá e diga aos meus homens que estamos enviando as pessoas! Oh... e pegue essa pá, tenho certeza que será útil! Então, boa sorte! Apenas um Sram pode sobreviver a um golpe de pá. Hahá!";
D.q[4058] = "Olá, sou Otomai, um dos mais famosos mágicos no Mundo dos Doze, o incontestável perito de tudo que anima e controla coisas vivas. Também tenho a reputação por minha alquimia que uso para misturar poções com vários efeitos diferentes. O que deseja saber?";
D.q[1220] = "Obrigado e bem-vindo, Bro!";
D.q[5048] = "";
D.q[4164] = "Nós precisávamos encontrar um novo mundo, viver uma nova vida e apaixonarmos de novo. \nNossa euforia era tão intensa quanto curta. Olha para mim agora... Tenho de fugir para fazer meu marido reagir... mesmo que eu saiba que estou ferindo me comportando assim. Por favor, explique isso a ele. Ele pode ser tão inocente quanto um Kaniger e tão teimoso quanto um Pikoko. Mas seu defeito é também parte dele e o amo assim como ele é. Por favor, converse com ele e com um pouco de sorte, ele entenderá e poderemos começar de novo.";
D.q[8101] = "";
D.q[1202] = "Agora você pode se juntar à Ordem do Espírito Salvador.\nVocê tem certeza da sua escolha?";
D.q[3172] = "Hoo Hoo Krabill madok! Huhuharg. Kirball wowo?";
D.q[1582] = "Honestamente, isso não funciona como uma família, portanto não pense que uma pessoa respeitável está escondida atrás de cada bontariano.";
D.q[3953] = "Matrimônio horrível? Mas Allisteria é assim... Ei! Espere um minuto! Você não fala como um Wabbit! Você não é o príncipe! Ajude-me, meu fiel Gobball!";
D.q[8102] = "";
D.q[3998] = "Honra está na batalha e não na escravidão!";
D.q[724] = "Nós temos um agente duplo na Milícia de Brakmar, seu nome é Bishom Pot. Infiltre-se na milícia e peça-lhe as informações que ordenei que conseguisse. \nPara entrar em contato com ele, basta dizer \"Brakmar é uma cidade pútrida nesta época do ano\".";
D.q[2169] = "Como você está de volta tão rápido? Você não está com medo da Aracne, não é?";
D.q[4905] = "";
D.q[2234] = "Como você espera adquirir um bom arco se não me dá a lã para modificar a corda?";
D.q[8103] = "";
D.q[1997] = "Você disse flor de Dizbi? Sim! Eu sou o cara certo! Tenho exatamente o que você precisa! Conheço muito bem os Eniripsas. Se preferir, pode ser feita como infusão e Libérula será capaz de fazer isso. A propósito, seria muito gentil de sua parte se me trouxesse um pouco...";
