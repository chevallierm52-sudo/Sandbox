D.q[246] = "Desculpe, mas não deixarei você entrar até que seja capaz de arrancar um prego Karne. Eu temo que VOCÊ possa perder seus pregos no labirinto, caso não consiga fazer isto...";
D.q[4254] = "";
D.q[5753] = "";
D.q[3674] = "Diga a Qwizitor que está tudo bem.";
D.q[6202] = "";
