D.q[1242] = "Nós vendemos qualquer coisa a qualquer hora para agradar a qualquer um. Por favor, fique à vontade.";
D.q[3996] = "O que você espera de mim? Que eu sirva um Wabbit? Eles são todos fracos, não sabem usar armas e todos falam estlanho!";
D.q[3867] = "Pnj(893) et Message(3865)";
D.q[3901] = "Pnj(893) et Message(3899)";
D.q[4053] = "Pnj(893) et Message(4051)";
D.q[4052] = "Pnj(893) et Message(4051)";
D.q[2637] = "Poochan? Poochan... Aqui está o pequeno Pandawette! Mas é uma garota! Realmente, qualquer coisa pode acontecer em Pandala... Akane deve estar chateado...\nDesculpe-me, eu não posso. Estou indo para Akane. Entenda-se com ela!";
D.q[2615] = "Poochan se sente melhor. Você vira. Pega. Bebe um pouco da fonte do Miau e procura alguém que se assuste com você. Se encontrar, conte a Poochan.";
D.q[7542] = "Qual Doploon você quer em troca?";
D.q[1918] = "Bem-vindo à minha humilde loja. Eu vendo poucas coisas aqui, mas treino aprendizes. Minhas criações são únicas e a maioria é feita apenas sob medida.";
D.q[6446] = "Como atreve-se mentir para mim? Você sabe o que fazemos com insubordinados aqui. Nosso Gobball está ficando faminto.";
D.q[254] = "Confrontar-me em um duelo é um privilégio que só dou aos membros de minha raça. Quando enfrento os outros, eu apenas desembainho para assustar.";
D.q[5534] = "Louvado seja Silvosse! Louvores ao pequeno Dreggon que ele ensinou a voar. Eu sou eternamente grato e estou certo de que o Deus Osamodas está ciente de suas ações.\nEu não posso ensinar mais. Está na hora de você dar os primeiros passos sozinho em Bonta.";
D.q[702] = "Vejo que já dominou a meditação curativa. Não há nada mais que eu possa lhe ensinar.\nVocê deve ser capaz de se cuidar sozinho de hoje em diante.";
D.q[1885] = "Todo meu estoque de metaria e runas desapareceu. Argh! Por que hoje? O que eu estava fazendo? Esta noite vai ser desastrosa... Eu não tenho como conseguir tudo de volta...";
D.q[3425] = "Você viu minhas crianças? Elas são tão atrevidas.";
D.q[1297] = "O QUÊ? Só se for sobre o meu cadáver!";
D.q[5498] = "Louvado seja Silvosse! Louvores ao pequeno Dreggon que ele ensinou a voar. Eu sou eternamente grato e estou certo de que a Deusa Feca está ciente de suas ações.\nEu não posso ensinar mais. Está na hora de você dar os primeiros passos sozinho em Bonta.";
D.q[3300] = "Que livro devo ler quando estiver na biblioteca? A Era do Dragão? O Manual do Monte?";
D.q[930] = "Foi você quem fez uma bagunça com a cara do meu irmãozinho? Tente fazer isso comigo e você verá...";
D.q[996] = "Mas como você conseguiu chegar aqui?";
D.q[5537] = "Louvado seja Silvosse! Louvores ao pequeno Dreggon que me ensinou a voar. Eu sou eternamente grato e estou certo de que a Deusa Xelor está ciente de suas ações.     \nEu não posso ensinar mais. Está na hora de você dar os primeiros passos sozinho em Bonta.";
D.q[3235] = "Não se aproveite da minha generosidade. Você ja é bastante rico.\nYiiiihooooo hooooo...";
D.q[1148] = "Aqui, dê isto ao seu mestre, ele ficará satisfeito.\nE aconselhe-o para que proteja a sua retaguarda, pois alguns dos meus discípulos não gostam dele, mwahaha.";
D.q[5077] = "Prepare-se um pouco, as coisas podem ficar perigosas. Volte e me diga quando estiver pronto e eu te levarei até lá.";
D.q[4077] = "Qual feitiço você quer desaprender?";
D.q[3815] = "Eeeeeiiiiii! Sabia que você iria longe!. Agora, preste atenção garoto... Se, devido a algum evento infeliz você perder esta chave ou quiser voltar para o calabouço, você poderá achá-las. Como? Algumas destas criaturas devoram aventureiros, então se estiver com sorte, poderá encontrar uma chave nas entranhas delas. Entendeu?";
D.q[3914] = "Conheço a maioria das damas e cavalheiros da corte. Nenhum deles merece o príncipe, em minha opinião.";
D.q[4079] = "Qual feitiço você quer desaprender?";
D.q[1369] = "Hmm, deixe-me trabalhar em paz.";
D.q[1569] = "Pooh, tome o meu atestado e nunca mais volte.";
D.q[5965] = "Trabalhar com Djaul é um martírio.";
D.q[4081] = "Qual feitiço você quer desaprender?";
D.q[1425] = "Já voltou? Pensei que Danathor lhe daria uma missão... mas, se tiver algum tempo livre, pergunte ao cozinheiro, pois ele precisa de ingredientes para o jantar de hoje à noite.";
D.q[1424] = "Toh! Meu anel!";
D.q[1428] = "Hemm, parece que você encontrou o culpado. Estarei aguardando os relatórios de outros oficiais. Enquanto isso, ficarei de olho nele.";
D.q[1300] = "Raahhh! Vá embora, você e o seu dinheiro! E diga a Oto que deste dia em diante, não lhe darei mais crédito!";
D.q[1511] = "Você tem certeza? Se você se recusar a falar comigo, significa que está se opondo a um dos líderes de Brakmar.";
D.q[3040] = "Rargh! Eu me sentia fraco! Eu não tinha mais forças! Essa luta poderia ter sido a minha última... E eu não tinha mais nenhuma poção de cura... Hehe, felizmente tomei a iniciativa e desisti!";
D.q[4416] = "Jura? Estou tão assustado... Estou tremendo. Você vai me ferir se eu não cooperar?";
D.q[2689] = "Sou o melhor ferreiro de escudos de Pandawaiian do mundo! Eu desafio meus aprendizes a me superarem. Esse é o melhor modo de fazer com que eles e eu nos esforcemos. Lembre-se disto!";
