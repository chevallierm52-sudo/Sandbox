D.q[3434] = "O Las crianças? Não. Eu não as vi.";
D.q[953] = "A porta desta torre fica a noroeste de Bonta. Ela contém todos os serviços civis da cidade.\nSe estiver procurando pelo tesoureiro do prefeito de Bonta, você certamente o encontrará lá.";
