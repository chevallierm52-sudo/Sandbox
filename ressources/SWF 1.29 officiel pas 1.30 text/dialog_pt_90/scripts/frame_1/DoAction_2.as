D.q[7299] = "";
D.q[5996] = "Eu espero que você tenha boas notícias.";
D.q[1462] = "Bom trabalho, #1! Eu sabia que você era confiável, mas assim que aceitar a sua missão, não poderá mais mudar de idéia...";
D.q[1766] = "Treinei alguns Dopples para que lutem igual aos Osamodas. Desse modo, eles se tornarão bons adversários de treinamento, independentemente do seu nível.";
D.q[241] = "Já disse que não vou dizer uma palavra! Nunca lhe direi o que está escondido na caverna e onde está a entrada, situada na sombra de um arbusto incandescente. Oopsy... bah, de qualquer forma, a entrada está selada e não consigo me lembrar onde aquele arbusto está...";
