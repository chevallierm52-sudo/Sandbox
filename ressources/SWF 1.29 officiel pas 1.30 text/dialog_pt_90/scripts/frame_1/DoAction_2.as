D.q[4904] = "Pnj(679) et Message(4903)";
D.q[4153] = "Graças a sua idéia genial, eu consegui poupar muito tempo e farinha de qualidade. Espero que agora você entenda o motivo de eu ser um dos melhores padeiros do Mundo dos Doze.";
