D.q[4708] = "";
D.q[859] = "49";
D.q[1838] = "...hmmm, mas tudo coincide, este velho manuscrito formaliza isso...\nOh, desculpe! Eu não notei que você está aqui, como posso te ajudar? Ou melhor, como você pode me ajudar?";
