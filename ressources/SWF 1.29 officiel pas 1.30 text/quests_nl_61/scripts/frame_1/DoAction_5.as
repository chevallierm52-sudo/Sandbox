Q.s[475] = {n:"Verdachte Zaken",d:"Xarthan is niet thuis. Neem deze mogelijkheid om zijn huis te doorzoeken. Je zult een handige klusjesman nodig hebben hiervoor.",r:[null,null,null,null,null,null]};
Q.s[924] = {n:"Naar de toren",d:"Sarthan gaat naar de Toren van Bonta om een Brakmariaan te ontmoeten na zijn ontmoeting met wat belangrijke mensen. Je moet je haasten, zodat je hem niet mist.",r:[95000,null,null,null,null,null]};
