Q.s[608] = {n:"Tolk? Vertolk!",d:"Om met de Wabbits te kunnen communiceren en hun te vertellen dat ze niet moeten graven, maar bouwen, heeft As\'Ruoy\'Dnim een tolk nodig.",r:[null,null,null,null,null,null]};
Q.s[607] = {n:"Gwoeiende Wowtels",d:"Wabbits moeten Cawwots telen om hun \'werk\' voort te zetten in de Tempel. Ze hebben 10 Cawwots, 2 eenheden kunstmest, 50 eenheden Water en een Hozuki Lampulet nodig.",r:[null,null,null,null,null,null]};
Q.s[534] = {n:"De Keuze",d:"Je hebt de spion op tijd gevonden. Ga je echter de bevelen opvolgen, de documenten pakken en hem hier achterlaten?",r:[205000,null,null,null,null,null]};
Q.s[144] = {n:"... of Xelors tanden.",d:"De Xelors lijken geïnteresseerd. Volgens Ant, is dat om hun zandloper in handen te krijgen... maar hij weet het niet zeker.",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Zoek de vogelvrijverklaarde",d:"Kil Bil is gesignaleerd bij de Sidimote vlaktes. Kil Bil wordt gezocht voor het uitrukken van menselijke ledematen. Hij is veroordeeld tot hechtenis in Astrub.",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"Her-inschrijven, zei hij.",d:"Snori Nairb heeft beloofd zijn Kamas en ervaring met je te delen als je je weer her-inschrijft bij de Brakmariaanse militie.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"Wie wind zaait, zal storm oogsten",d:"Om z\'n theorie te testen over het bestaan van carnivore bloemen, vraagt Trapchet om duistere rozenzaadjes te zaaien en ze daarna te plukken.",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"De stemloze en de flora",d:"Drie-Bloem, een vriend van Trapchet, woont in Amakna en kent de flora van zijn regio heel goed. Je moet hem om informatie vragen over de agressieve bloemen die hier zijn.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"De Epyss gaat ten onder",d:"Erty Trapchet wil paardenbloemzaadjes bestuderen om ze te vergelijken met de Epyss...",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"De sproeiende besproeier",d:"Erty Trapchet heeft vergeten z\'n planten te verzorgen, je moet naar z\'n huis om water te geven.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"Wat een onkruid!",d:"Voor zijn onderzoek moet Trapchet de geografische distributie van bloemen rond Astrub bestuderen.",r:[6500,500,null,null,null,null]};
Q.s[60] = {n:"Verdraaid nog an toe, da\'s waar!",d:"-",r:[null,null,null,null,null,null]};
Q.s[56] = {n:"Onderzoek naar een verdwenen... Huis",d:"",r:[null,null,null,null,null,null]};
Q.s[38] = {n:"Bestelling van Erty Trapchett",d:"",r:[null,null,null,null,null,null]};
Q.s[40] = {n:"Mijn Bestelling",d:"",r:[null,null,null,null,null,null]};
Q.s[39] = {n:"Bestelling van Genam Enarm",d:"",r:[null,null,null,null,null,null]};
Q.s[143] = {n:"Wilde jacht",d:"Duistere wezens verpesten de handel van Ant Emicheun. De oplossing is om ze uit de weg te ruimen... tenminste als hij weet wat ze hier doen...",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"Kunnen eieren zwemmen?",d:"Geen ziektekiemen meer in de veren van de zieke Tofus. In tegenstelling tot hun eieren, die zullen waarschijnlijk een spoor zijn voor de Eniripsa. Nog wat meer Kamas verdienen!",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"Dat wordt bloederig!",d:"Je hebt ineens behoeft om meer over jezelf te weten te komen en je besluit naar een bloedige plek te gaan... de slagerij.",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"Dat gaat fout!",d:"Je meester heeft gehoord dat een mijnwerker onlangs veranderd is in een duistere mijnwerker. Hij wil er het zijne van weten!",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"Stomme Enutrofs!",d:"De Enutrofs hebben iets ontdekt en ze hebben je hulp nodig.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Dizbi Extract",d:"De bloesem van deze bloem is niet genoeg, je hebt het getrokken extract ervan nodig!",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Spoedbestelling",d:"Je moet het getrokken extract naar je gildemeesteres brengen, zodat ze je staf kan maken! Als het kan en je hebt tijd, breng dan ook wat extract naar je bloemenleverancier, daarmee doe je hem een groot plezier.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Dizbi Bloem",d:"Je moet Dizbi bloemen zoeken, zodat je meesteres een staf kan maken die z\'n naam waardig is.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"Honger!",d:"De veelvraten van Allisteria hebben honger. Ze moeten allemaal gevoerd worden!",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Gekookte Veelvraat Bloedworst",d:"Red de traditie van de goede Gestoofde Veelvraat Bloedworst",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Vecht als een Feca",d:"De beroemde Fallenster heeft je gevraagd om z\'n dochter te trainen in het vechten.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"Het is verboden om water te verkopen aan mensen onder de leeftijd van...",d:"De water weg bestaat uit verzetten tegen elk middel van water absorberen of onderdompeling (gedeeltelijk of totaal ondergedompeld), niet opzettelijk drinken of jezelf wassen (tenzij het extreem noodzakelijk is). Vind de meester van de water weg: hij weet meer dan het lijkt.",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"Lenald de wijze",d:"Een Pandawaiian zachte drankjes verkoopster adviseert je om te praten met Lenald de Wijze. Volgens haar is hij de enige die de waarheid weet over Pandala en zijn mysteries.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"Het Standbeeld van de Godin",d:"Grandapan accepteert graag de gift van de Enutrof\'s. Als een vurig bewonderaar van de Dofus jagers, geeft hij je een warm welkom.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"Grandapan: Een aardige Pandawa",d:"De Enutrof die een behandeling heeft gehad door de Shaman adviseert je om Grandapan te bezoeken. Hij heeft veel kennis van het lokale folklore en de Pandawaiians legendes.",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Drankoffer voor de Godin",d:"Dankzij je hulp, kan de Shaman assistent het bedank-ritueel starten voor de Godin. Hij is gelijk klaar nadat jij hem een traditionele padawaiian gift aanbiedt.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"In dienst van de Koning",d:"De koning houdt van rijden, je moet Drakokalkoenen voor hem zoeken.",r:[75000,null,null,null,null,null]};
