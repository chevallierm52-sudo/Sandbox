Q.s[970] = {n:"Schat in het bos.",d:"Er is een Wyrmwell in een van de oude holen van Dardondakal\'s. De toegang tot dit hol is verborgen in het bos van Cania, en om het te vinden, moet je beschikken over de juiste items.",r:[296000,null,null,null,null,null]};
Q.s[969] = {n:"Souvenir, souvenir.",d:"Je moet sommige draak Memory Fragmenten vangen voor Danathor. Je weet niet waar je ze kan vinden, maar de kunst van waarzeggerij moeten kunnen helpen.",r:[null,null,null,null,null,null]};
Q.s[788] = {n:"Terra cogita\'s geheim .",d:"Terra cogita heeft informatie over de locatie van de beeldjes van Sumens. Elviana geeft je de opdracht om ze te vinden voor de Brakmarians dat doen.",r:[60000,null,null,null,null,null]};
Q.s[546] = {n:"Nog een Samenzwering",d:"Trev Pelsantery is beschuldigd van verraad, maar Amayiro denkt dat hij onschuldig is. Hij vertrouwt jou met de missie om met Trev te gaan praten. Trev is in de gevangenis op dit moment, en bekijk zijn versie van het verhaal.",r:[240000,null,null,null,null,null]};
Q.s[559] = {n:"Ondervraging in orde",d:"Amayiro heeft jou gevraagd om de getuige die Trev Pelsantery van verraad beschuldigde te ondervragen in de hoop dat hij interessante details loslaat. Je vindt hem in de Atyu Servis Herberg.",r:[null,null,null,null,null,null]};
Q.s[560] = {n:"Naspelen van de Misdaad",d:"Ga van de Boeren Markt naar de hoefsmid\'s werkplaats, dan naar de schoenmaker\'s werkplaats voordat je eindigt bij de Atyu Servis Herberg en ondervraag alle inwonders die je onderweg tegenkomt.",r:[null,null,null,null,null,null]};
