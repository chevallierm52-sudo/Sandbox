Q.s[557] = {n:"Rum, Vrouwen, Bier...",d:"In ruil voor het geven van meer tijd, wil de rechter Satirev Onovin een paar biertjes uit Astrub voor de gevangenen en een vrouw van Astrub om zijn lijf op te frissen.",r:[null,null,null,null,null,null]};
Q.s[551] = {n:"Onderhandel over meer Tijd",d:"De rechter Satirev Onivin houdt niet van onderzoeken die eeuwig duren. Amayiro heeft je naar hem gezonden om tijd te rekken. Hij spendeert de meeste tijd in het militie gebouw.",r:[null,null,null,null,null,null]};
Q.s[554] = {n:"Lastig om meer tijd te rekken",d:"Je hebt tijd weten te rekken. Amayiro zal daar blij mee zijn.",r:[248000,null,null,null,null,null]};
Q.s[593] = {n:"Vermoord de Agent",d:"Divad heeft je gevraagd één van Domen\'s agenten te vermoorden op de Begraafplaats van Helden, in ruil voor zijn hulp.",r:[null,null,null,null,null,null]};
Q.s[590] = {n:"Start en Einde van het Plan",d:"Je moet in Brakmar iemand vinden die capabel genoeg is om een Dreggon kostuum te maken .... Of in ieder geval die capabel genoeg is As\'Ruoy\'Dnim op andere gedachten te brengen.",r:[null,null,null,null,null,null]};
Q.s[594] = {n:"Een Betrouwbaarder Kostuum",d:"Hou de Dreggon Wachter voor de gek bij het Symbolen Huis, bij het centrum van Dreggon Dorp, en krijg een symbool voor As\'Ruoy\'Dnim.",r:[null,null,null,null,null,null]};
Q.s[591] = {n:"Een Ander Plan",d:"De schoenmaker heeft je verteld dat As\'Ruoy\'Dnim\'s plan een complete ramp wordt (wat een verassing!)... Nu moet je iemand vinden die je helpt in de taak die je is toevertrouwd.",r:[null,null,null,null,null,null]};
