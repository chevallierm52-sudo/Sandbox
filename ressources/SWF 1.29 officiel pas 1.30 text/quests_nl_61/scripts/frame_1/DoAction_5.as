Q.s[802] = {n:"Beter een Piwi in de hand dan tien in de lucht.",d:"Justfa Lafs heeft op magische wijze veranderd zaad nodig voor de Piwi fokkerij. Merlinmagus Ambrosius kent het recept.",r:[600000,null,null,null,null,null]};
Q.s[801] = {n:"Bewaak het beeldje.",d:"Justfa Lafs vreest dat Brakmar agenten heeft gestuurd om het Beeldje van Sumens te stelen die wordt bewaard in de toren van Bonta. Hij heeft je gevraagd om het te beschermen.",r:[null,null,null,null,null,null]};
Q.s[967] = {n:"Het magische cadeau",d:"Danathor heeft je nodig. Dit verhaal gaat over een magische gave, of iets dergelijks.",r:[null,null,null,null,null,null]};
Q.s[968] = {n:"Interview met een schavuit.",d:"Je moet praten met de schelmen en onderhandelen met hen over een fragment van tijd dat die demonen van de getijden gestolen hebben.",r:[288000,null,null,null,null,null]};
