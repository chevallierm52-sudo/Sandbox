Q.s[1122] = {n:"null",d:"",r:[100000,1000,null,null,null,null]};
Q.s[7] = {n:"Voevoer",d:"Vraag aan degenen die je tegenkomt wat een gemiddelde MiauwMiauw eet. En breng wat eten naar deze MiauwMiauw.",r:[1220,null,null,null,null,null]};
Q.s[9] = {n:"Miauwmiauw held?",d:"Zoek uit waarom deze frêle MiauwMiauw door z\'n partner beschouwd kan worden als een held.",r:[3060,null,null,null,null,null]};
Q.s[6] = {n:"Memelk voor een miauwmiauw",d:"Breng wat memelk naar de zielige MiauwMiauw",r:[1220,null,null,null,null,null]};
Q.s[8] = {n:"Miauzerige wandeling",d:"Ga met de MiauwMiaus wandelen in de stad",r:[1500,null,null,null,null,null]};
Q.s[13] = {n:"Geleende ring",d:"Bling heeft je een ring gegeven met verborgen krachten. Om ze te activeren, moet je een boomchnid doden.",r:[11000,1200,[[6793,1]],null,null,null]};
Q.s[12] = {n:"Een beetje stekelig",d:"Bling is vergeten om voldoende champ champ doorns mee te voor de test van morgen. Ga ze halen.",r:[2600,250,null,null,null,null]};
Q.s[11] = {n:"Reclycling van stinkwater",d:"Breng wat veelvraatspeeksel naar Bling Bling.",r:[1700,200,null,null,null,null]};
Q.s[10] = {n:"Een harig amulet?",d:"Breng wat arachneepoten naar de juwelierster, ze heeft ze nodig om een amulet te maken.",r:[1700,null,[[6773,1]],null,null,null]};
Q.s[24] = {n:"Zakkenroller",d:"Zoek een manier om het spionrapport te bemachtigen en breng het naar Ztiv Oztin.",r:[1200,null,[[6784,1]],null,null,null]};
Q.s[22] = {n:"De Drie Kamas Spion",d:"Zoek Ztiv Oztin en biedt hem je diensten aan...",r:[1200,null,null,null,null,null]};
Q.s[20] = {n:"Discretie verzekerd",d:"Zoek Ogivol Scalarcin. De ingang van zijn hol vind je door een geheim luik in de grond van de houtopslagplaats.",r:[600,null,null,null,null,null]};
Q.s[121] = {n:"Zoek en begeleid de vogelvrijverklaarde",d:"Waarschijnlijk bevindt Nomarow Transplent zich ten noordwesten van de Cania Vlaktes, naast het Egidraa bos. Hij is in Astrub veroordeeld tot hechtenis omdat hij huisveelvraten schade heeft toegebracht en voor nachtelijk geluidsoverlast.",r:[null,84500,null,null,null,null]};
Q.s[26] = {n:"Snelle Henkie Gezocht",d:"De Bakker heeft een spoedbestelling aan 4 personen. Leg de taarten zo snel mogelijk op hun plaats.",r:[1000,null,null,null,null,null]};
Q.s[29] = {n:"Nieuwe leverancier gezocht",d:"Zoek iemand die zowel sterk als lenig is om de nieuwe leverancier te vervangen.",r:[2000,250,null,null,null,null]};
Q.s[28] = {n:"Een rokkenjagerleverancier",d:"Ga na of de leverancier Louc Drif wel echt ziek is.",r:[2000,500,null,null,null,null]};
Q.s[30] = {n:"Laatste levering",d:"Breng de taart naar grootmoeder.",r:[5000,null,null,null,null,null]};
Q.s[103] = {n:"Babby\'s huis",d:"Huil Babby weet niet meer waar haar huis is, ze is heel bang en durft niet alleen de stad in...",r:[5750,250,null,null,null,null]};
Q.s[33] = {n:"Een boeketje vlas",d:"Je moet vlasbloemen plukken voor Huil Babby\'s moeder. Alleen alchemisten kunnen deze bloemen plukken...",r:[2000,200,null,null,null,null]};
Q.s[31] = {n:"De Eenarmige Bandieten",d:"Het kamp van de Eenarmige Bandieten ligt in het noorden van het bos van Astrub, het pluche beest bevindt zich waarschijnlijk op een van de bandieten...",r:[2000,null,null,null,null,null]};
Q.s[37] = {n:"En garde Beren Man",d:"Volgens Abrazelon moet je de Berenman herhaaldelijk aanvallen om er zeker van te zijn dat hij z\'n manuscript in het gevecht gebruikt. Daarna moet je het naar hem toebrengen zodat hij het kan waarmerken.",r:[9000,2500,null,null,null,null]};
Q.s[35] = {n:"Osamodas verslag",d:"Abrazelon Hexaklauw heeft met de Berenman gepraat die de macht heeft over zeer krachtige wezens. Voordat je hem achtervolgt, moet je Nie Teten over je ontdekking vertellen...",r:[3000,null,null,null,null,null]};
Q.s[34] = {n:"Het harige beest",d:"De herder Nie Teten heeft problemen met een harig beest, dus hij zoekt iemand die meer over dit wezen weet.",r:[750,null,null,null,null,null]};
Q.s[36] = {n:"De Beer op het spoor",d:"Je moet de sporen van de beer volgen en z\'n hol vinden...",r:[3000,null,null,null,null,null]};
Q.s[53] = {n:"Stinkende voering",d:"Alit raadt je aan om een zoom in je cape te maken. Maar om dat te doen, moet je hem wat veelvraatwol brengen.",r:[3500,null,[[6801,1]],null,null,null]};
Q.s[54] = {n:"Al die ophef voor een oorbeschermer",d:"Zorg voor de benodigde materialen om een oorbeschermer te maken. Doordat sommige moeilijk verkrijgbaar zijn, heb je hierbij hulp nodig.",r:[11000,500,[[6802,1]],null,null,null]};
Q.s[52] = {n:"Wol gezocht",d:"De kleermaker Alit heeft witte en zwarte vreetzakjeswol nodig. Als je hem dat brengt, zal hij vast iets voor je op maat maken.",r:[2500,null,[[6800,1]],null,null,null]};
Q.s[49] = {n:"Versterking gezocht",d:"Ga hulp zoeken bij de Feca en Eniripsa",r:[1200,null,null,null,null,null]};
Q.s[51] = {n:"Schep gezocht",d:"Ga naar Joe en doe verslag om je beloning te krijgen.",r:[1200,null,[[6786,1]],null,null,null]};
Q.s[45] = {n:"Arbeidskrachten gezocht",d:"Zoek Howard de Jamaarnee en geef hem de brief van Joe Steenknoeier.",r:[600,null,null,null,null,null]};
Q.s[55] = {n:"De Wabbit GM\'s bloed",d:"",r:[null,null,null,null,null,null]};
Q.s[57] = {n:"Bloed Test",d:"",r:[null,null,null,null,null,null]};
Q.s[58] = {n:"Wogew Wabbit",d:"",r:[null,null,null,null,null,null]};
Q.s[76] = {n:"De noodzaak te weten hoe te gebruiken",d:"Om te leren met je nieuwe wapen om te gaan, moet je een paar insecten aanvallen",r:[900,null,null,null,null,null]};
Q.s[67] = {n:"Hoe smeed je een zwaard\' voor sukkels",d:"Je hebt een smid nodig om een zwaard te maken",r:[null,null,null,null,null,null]};
Q.s[68] = {n:"Het nut van een goede zwaardgreep",d:"Zoek een greep voor je zwaard.",r:[1200,null,null,null,null,null]};
Q.s[69] = {n:"Het belang van afwerking",d:"Breng je pas gesmede zwaar naar je meester",r:[900,null,[[6780,1]],null,null,null]};
Q.s[63] = {n:"... twijfel!",d:"Breng het zwaard terug naar je gildemeester. Hij zal het teken van jouw klasse erop zetten.",r:[1200,null,null,null,null,null]};
Q.s[61] = {n:"Een dubieus metaal",d:"Breng je tas met dubieuze kamas naar iemand die er iets interessants van kan maken.",r:[600,null,null,null,null,null]};
Q.s[62] = {n:"Dubieuze verfijning",d:"Verwerk dubieus metaal.",r:[1200,null,null,null,null,null]};
Q.s[72] = {n:"Hartendief",d:"De kiezelsteentjes komen uit de omgeving van de mijnen ten noordoosten van het dorp. Zoek Louc\'s kist daar.",r:[4000,null,null,null,null,null]};
Q.s[150] = {n:"De beloning",d:"Ga je beloning halen bij het huis van Louc Drif.",r:[5000,null,[[1519,1]],null,null,null]};
Q.s[71] = {n:"Op zoek naar kiezelsteentjes",d:"Onderzoek de kiezelsteentjes en vergelijk ze met die je bij Louc gevonden hebt. Om dit te doen, moet je naar verschillende verdachte plekken.",r:[1500,250,null,null,null,null]};
Q.s[70] = {n:"Ruil metaria tegen een afspraak",d:"Louc moet het probleem met z\'n kist oplossen en zich tegelijktijd opmaken voor z\'n eerste afspraak. Zoek en breng hem twee rozen, voor elk meisje één.",r:[1500,500,null,null,null,null]};
Q.s[73] = {n:"Ren Forest!",d:"Hou je van kinderen? Deze haat je...",r:[600,50,null,null,null,null]};
Q.s[75] = {n:"Ah-Boog-Cra-Dabra",d:"Ha... wat mooi dat je je eerste boog laat maken.",r:[1200,null,[[6783,1]],null,null,null]};
Q.s[78] = {n:"Cratastrofe",d:"Nu leer je pijl en boog schieten",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Zoek de vogelvrijverklaarde",d:"Frakacia Leukocytine is gesignaleerd bij het dorp van de Eenarmige Bandieten. Ze wordt gezocht vanwege het illegaal prikken met hemoglobine en is veroordeeld tot hechtenis in Astrub.",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Zoek de vogelvrijverklaarde",d:"Nervoes Breekdoun is gesignaleerd bij het Boomchnid bos.                                                                                 Gezocht voor juwelenroof. Veroordeeld tot hechtenis in Astrub",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Zoek de vogelvrijverklaarde",d:"Hij is gesignaleerd bij de Sidimote vlaktes. Hij wordt gezocht voor het verstoren van de kosmische orde. Brumen Tinctorias is veroordeeld tot hechtenis in Astrub.",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Zoek de vogelvrijverklaarde",d:"Eikelhorn trekt de stad door op zoek naar lekkere eikels om in te bijten.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Zoek de vogelvrijverklaarde",d:"Ogivol is gesignaleerd in de buurt van Brakmar. Hij wordt gezocht voor diefstal van een groot aantal dingen, vooral geheime documenten. Hij is veroordeeld tot hechtenis in Astrub.",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Gemengde Escorte",d:"Bir Tju, de herbergier, is genoodzaakt zijn bier te verdunnen met water, want hij wordt bestolen. Zoek de leverancier in het zuidwesten en ga met \'m mee.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"Einde van de onderdrukking?",d:"Maak een eind aan de diefstal van het bier",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Een goede kijk op dingen",d:"Verzamel diverse middelen zodat Kwartsuur in de toekomst kan kijken",r:[600,null,null,null,null,null]};
Q.s[92] = {n:"De toekomst is geen lachertje!",d:"Kwartsuur vertelt je meer over je nabije toekomst.",r:[1200,null,null,null,null,null]};
Q.s[91] = {n:"De toekomst is het avontuur!",d:"Kwartsuur heeft een blauwe larvehuid nodig om haar machine af te maken.",r:[1200,null,null,null,null,null]};
Q.s[94] = {n:"Bestelling",d:"Breng de remedie naar Clint Pot. Of om de Tofus of de Enutrofs te verzorgen, dat heb ik niet goed begrepen. Vergeet niet om een rapport te maken voor je gildemeester.",r:[1800,null,[[6785,1]],null,null,null]};
Q.s[93] = {n:"Subosykou...",d:"Help je gildemeester om een remedie te vinden om zijn tofus te verzorgen.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"Eerste kamer",d:"Zoek uit hoe je de drie dofus moet gebruiken",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Tweede kamer",d:"Zoek de sleutel",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"Tik Tak!",d:"...",r:[2500,20,null,null,null,null]};
Q.s[145] = {n:"... schaar",d:"Pak zal heel blij zijn met de nieuwe schaar die je gehaald hebt.",r:[1750,null,null,null,null,null]};
Q.s[133] = {n:"Een mooie...",d:"Pak Rep zoekt haar gesmede schaar, ze raadt je aan om naar de smid op de marktplaats te gaan om er eentje voor haar te kopen...",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Haar... en nog eens haar",d:"Pak probeert alle soorten haar te verzamelen onder de inwoners van Astrub, om er haarstukken van te maken.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"Op het spoor",d:"De Enutrofs, die op zoek zijn naar snuffelratten, zijn waarschijnlijk verdwaald in de diepten van de gewelven. Het wemelt hier van milirioolratten...",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"Beter een vogel in de hand dan twee ratten in het bos",d:"Ontdoe je van deze Riool Rat... hij ziet er niet uit, dat is toch niet zo moeilijk... Nou ja, voor sommigen wel.",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"Het begin van de rijkdom",d:"Verzamel 10 Arachneepoten voor Ant Emicheun. Of voor jezelf... wie weet? Het is in ieder geval de moeite waard.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Zieke veren",d:"Met twintig veren moet je een plumeau kunnen maken. Maar met deze veren...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Verdiende beloning",d:"Praat nog eens met grootmoeder en laat haar de muimuizenkop zien",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"De geteisterde kelder",d:"Ga naar de kelder van grootmoeder en vernietig het gevaar.",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Versla de Militieleden",d:"Versla Tarche het militielid in de kamer naast deze.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Geef Broden",d:"Je moet Amayiro 20 maaltijd broden brengen.",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"Veelvraat Tanden",d:"Je moet Veelvraat tanden trekken - zoveel als nodig zijn om mensachtig kunstgebit te maken, en ze dan naar Ned brengen, ten zuid-westen van de stad.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"Broer\'s Schoen",d:"Je moet Torche verslaan en bewijs van je overwinning naar Amayiro brengen.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Vind de Kraai",d:"Je moet de kraai vinden die de ketting van de dochter van de Burgemeester heeft gestolen, hem verslaan en de ketting pakken. De kraai moet dicht bij de toren zijn.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Everzwijnjacht",d:"Je moet het aggressieve zwijn ten zuiden van Bonta vinden en hem verslaan.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"Repareer de Katana",d:"Je moet Kosuke de wapensmid vragen om Amayiro\'s zwaard te repareren in ruil voor een bon.",r:[4600,null,null,null,null,null]};
Q.s[690] = {n:"Schop de geld verschuldigde",d:"De Kikim Kroeghouder is Amayiro veel geld schuldig. Je moet hem overtuigen - hoe dan ook - om het terug te geven.",r:[null,null,null,null,null,null]};
Q.s[692] = {n:"Communiceer met een Spion",d:"Je moet Bishom Pot vinden in Brakmar en de informatie uit hem trekken waar Amayiro om gevraagd heeft.",r:[5200,null,null,null,null,null]};
Q.s[694] = {n:"Sluit het Gat",d:"Shere Hacanon, bij de ingang van Bonta, heeft 4 Vlakte Crackler\'s rotsblokken nodig om de gaten in de muur te dichten.",r:[6400,null,null,null,null,null]};
Q.s[696] = {n:"Helmverzameling",d:"Je moet 15 Elite Chafer Helmen naar Amayiro brengen.",r:[7600,null,null,null,null,null]};
Q.s[698] = {n:"Pulp voor Tabi",d:"Breng een Blop bloem pulp naar Amayiro. Om pulp te maken moet je alleen maar 4 verschillende Blop bloemen samenpersen met een Munster Perser!",r:[8800,null,null,null,null,null]};
Q.s[700] = {n:"Behendigheid voor Amayiro",d:"Amayiro vroeg je hem 20 Behendigheidsringen te brengen.",r:[10000,null,null,null,null,null]};
Q.s[702] = {n:"Breng de Mantels",d:"Amayiro vroeg je om 10 Bontariaanse Mantels naar Kapitein Koda, hiernaast, te brengen. Ze zijn gemaakt van blauwe magische verf, een kraaienveer en witte Veelvraatjeswol.",r:[11400,null,null,null,null,null]};
Q.s[705] = {n:"21 uren",d:"Danathor vroeg je hem om 9 pm te ontmoeten met alle ingrediënten die hij in zijn lijst genoemd heeft.",r:[13500,null,null,null,null,null]};
Q.s[708] = {n:"Vlees voor de Kok",d:"De kok van de Bontariaanse militie, Kooc Fehc, heeft 10 Tofu pootjes nodig.",r:[13500,null,null,null,null,null]};
Q.s[707] = {n:"Moord Ontkent",d:"Ga terug naar Amayiro.",r:[null,null,null,null,null,null]};
Q.s[712] = {n:"Breng Vergif",d:"In de gevangenis van Bonta, heeft Kapitein Essacarf 30 stuks Scheurbuik Vergif nodig.",r:[15600,null,null,null,null,null]};
Q.s[714] = {n:"Vecht... voor de grap?",d:"Je moet Dike Tarak vinden in de buurt, hem uitdagen en hem verslaan.",r:[null,null,null,null,null,null]};
Q.s[713] = {n:"Vecht... voor de grap",d:"Je moet Dike Tarak vinden in de noordelijke buurt, hem uitdagen en verliezen.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Vind een Foutje",d:"Amayiro vroeg je de Begraafplaats van de Gemartelden, ten oosten van Brakmar, te bezoeken en te kijken of er een fout in hun verdediging is. Je zult zeker specifiek materiaal nodig hebben.",r:[19000,null,null,null,null,null]};
Q.s[717] = {n:"Baan van je keuze",d:"Je moet 20 Esdoorn planken of 10 Treechnid wortels naar Amayiro brengen.",r:[21000,null,null,null,null,null]};
Q.s[721] = {n:"Plunder in Brakmar",d:"Amayiro vroeg je om Brakmariaanse strijders te verslaan en tien van hun badges te pakken.",r:[28000,null,null,null,null,null]};
Q.s[723] = {n:"Een les te Leren",d:"Ene William Lenglad valt de inwoners van Bonta lastig. Je moet hem kalmeren door je kracht te gebruiken.",r:[34000,null,null,null,null,null]};
Q.s[724] = {n:"In het Hol van Brakmar",d:"Amayiro vroeg je Atall Tramston te bevrijden uit de gevangenis van Brakmar en hem terug te brengen naar de Bontariaanse militie.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"McSheth voor onze deur!",d:"Vind een reizende verkoper. Daar zul je de McSheth heffing kunnen betalen. Aarzel niet te sterk, al zullen ze het niet snel toegeven, ze vinden het erg goed.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"Laat de zon schijnen in Pandala!",d:"Bij je aankomst in Pandala moet je je papieren in orde maken bij de administratie. Plus, je zult de gehaatte McSheth heffing moeten betalen.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"Mijn eerste Shaman feest!",d:"Vraag help aan de Shaman! Haast je!",r:[4700,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[170] = {n:"Een bericht van wijsheid",d:"Een boodschapper brengt een bericht, praat met hem!",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Schildgebruik training voor nieuwelingen",d:"Om je te bedanken voor de bezorging, bied de schildsmid je een gift aan: een klein oefen schild. Praat met de Dojo meester voor een training.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"Een vreemd ongeluk",d:"Lenald de Wijze vraagt je om naar het Aerdala dorp te gaan... of misschien Terrdala: onmogelijk om te verstaan met zo\'n raar accent! Als je er eenmaal bent praat dan met Meester Pandawushu.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"Namens de Schildsmid",d:"In Terrdala is er niemand beschikbaar om ruwe materialen naar de schildsmids werkplaats te brengen. Schild smeden is essentieel voor de Pandawa strijders. Gelukkig ben jij hier om de taak te doen.",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Wie bang wordt van de Bowmeow",d:"Poochan is op zoek voor een toekomstige echtgenoot maar de enige aanwijzingen die ze heeft zijn dat hij leeft in Pandala en dat hij bang is voor Bowmeow. De makkelijkste manier is om haarzelf te veranderen in Bowmeow en op iedereen te springen of niet?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Informele overeenkomst",d:"Hier vertelt de traditie dat de vader beslist met wie zijn zoon of dochter gaat trouwen. Je moet de vader overtuigen om zijn zoon te laten gaan. Je zult je best moeten doen om hem te overtuigen.",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Verovering van de Dento",d:"Om Lanma te verlossen van zijn taken zul je zijn trouwbelofte moeten verbreken die hij maakte met een meisje van Dojo Dento.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"Belonging ?",d:"Poochan wacht op je.",r:[7000,null,null,null,null,null]};
Q.s[174] = {n:"Balade over de Evolutie en het Tijdperk Amakna",d:"Deze tijdreis, Balade over de Evolutie en het Tijdperk Amakna (B.E.T.A.), zal de wereld redden!",r:[null,null,null,null,null,null]};
Q.s[173] = {n:"Een Kouartz en dan is \'t goed",d:"Amine stelt Henual voor om het laatste redmiddel in te zetten... Kouartz!",r:[null,null,null,null,null,null]};
Q.s[172] = {n:"Amine, geen dank!",d:"Je moet een brief van Henual aan Amine geven bij de Xelor Tempel.",r:[null,null,null,null,null,null]};
Q.s[178] = {n:"Zachte drankjes...",d:"Een reizende verkoper zou in staat moeten zijn om je één van die vergistte drankjes te bezorgen welke zo beroemd zijn in Pandal. Je moet er alleen een vinden!",r:[null,null,null,null,null,null]};
Q.s[185] = {n:"Level behalen: Rokwa",d:"Je moet Zaterdag verschijnen om te slagen in de Rokwa level evaluatie",r:[30000,null,null,null,null,null]};
Q.s[184] = {n:"Level behalen: Gokwa",d:"Je moet Zaterdag verschijnen om te slagen in de Gokwa level evaluatie",r:[30000,null,null,null,null,null]};
Q.s[183] = {n:"Level behalen: Yonkwa",d:"Je moet Zaterdag verschijnen om te slagen in de Yonkwa level evaluatie",r:[20000,null,null,null,null,null]};
Q.s[180] = {n:"Level behalen: Ikwa",d:"Je moet Zaterdag verschijnen om te slagen in de Ikwa level evaluatie",r:[5000,null,null,null,null,null]};
Q.s[187] = {n:"Training: de basis",d:"Voordat je de training begint, zul je een shamaans certificaat en een Pandawushuka kostuum moeten hebben.",r:[null,null,[[7313,1]],null,null,null]};
Q.s[182] = {n:"Level behalen: Sankwa",d:"Je moet Zaterdag verschijnen om te slagen in de Sankwa level evaluatie",r:[15000,null,null,null,null,null]};
Q.s[181] = {n:"Level behalen: Nikwa",d:"Je moet Zaterdag verschijnen om te slagen in de Nikwa level evaluatie",r:[10000,null,null,null,null,null]};
Q.s[191] = {n:"Yondanwa",d:"Je moet Zaterdag verschijnen om te slagen in de Yodanwa level evaluatie",r:[60000,null,null,null,null,null]};
Q.s[190] = {n:"Sandanwa",d:"Je moet Zaterdag verschijnen om te slagen in de Sandanwa level evaluatie",r:[50000,null,null,null,null,null]};
Q.s[186] = {n:"Shodanwa",d:"Je moet Zaterdag verschijnen om te slagen in de Shodanwa level evaluatie",r:[30000,null,null,null,null,null]};
Q.s[189] = {n:"Nidanwa",d:"Je moet Zaterdag verschijnen om te slagen in de Nidanwa level evaluatie",r:[40000,null,null,null,null,null]};
Q.s[175] = {n:"Lenald legende",d:"Eindelijk! Je bent er bijna! Hoewel je verrassingen zijn nog steeds niet voorbij.. De Lenald van Wabbit Eiland zal iets onthullen wat tot nu toe verborgen was.",r:[7500,null,null,null,null,null]};
Q.s[188] = {n:"In de tempel van onze God",d:"Na de adviezen van Lenald de Wijze, plan je jouw nieuwe expeditie. Je zult naar je God zijn tempel moeten gaan in Amakna.",r:[7500,null,null,null,null,null]};
Q.s[176] = {n:"Dark Vlad, wat een vent!",d:"Zuiver je ziel en was je oren: Lenald de Wijze gaat je de waarheid vertellen over de Dofus van Pandala.",r:[40000,null,null,null,null,null]};
Q.s[193] = {n:"Dofus verzamelbak",d:"Grandapan accepter graag de gift van de Enutrof\'s. Als een vurige bewonderaar van de Dofus jagers geeft hij je een warm welkom. Om je ontdekkers nieuwsgierigheid tevreden te stellen neemt hij je mee naar Dofus zijn vergaarbak.",r:[1500,null,null,null,null,null]};
Q.s[192] = {n:"Kus van Astrub",d:"De Shaman is extreem druk en heeft geen tijd om jou op te zoeken. De Pandikazes, de ziekte van de Enutrofs en dit zijn nog maar twee problemen welke hij moet afhandelen van de duizenden anderen. Als je hem wilt helpen adviseert hij je om te praten met Pyrite, een Enutrof in quarantaine.",r:[1500,null,null,null,null,null]};
Q.s[194] = {n:"Water om gematigd te drinken",d:"De water weg bestaat uit verzetten tegen elk middel van water absorberen of onderdompeling (gedeeltelijk of totaal ondergedompeld), niet opzettelijk drinken of jezelf wassen (tenzij het extreem noodzakelijk is). Vind de meester van de water weg: hij weet meer dan het lijkt.",r:[10000,null,null,null,null,null]};
Q.s[207] = {n:"Grandapan",d:"Breng de valse Dofus naar Grandapan.",r:[2200,null,null,null,null,null]};
Q.s[195] = {n:"Ridder, Echtgenoot... hetzelfde gevecht",d:"Brakmarianen hebben Bontariaanse schuren vernietigd. Je moet een manier vinden om de voorraad rijdieren aan te vullen. Bezoek Merlinmagus in de Alchemistenwerkplaats, hij zal je een oplossing helpen vinden.",r:[50000,null,null,null,null,null]};
Q.s[196] = {n:"In de Schoenen van een Spion",d:"Na de brand in de voedselopslag van Brakmar, wil Ebru van El weten wat zijn vijanden van plan zijn.",r:[50000,null,null,null,null,null]};
Q.s[197] = {n:"Sta op en Loop",d:"Eliana Tirips wil Bontariaanse vogelvrij verklaarden ondervragen maar eerst moet hij ze reanimeren.",r:[50000,null,null,null,null,null]};
Q.s[782] = {n:"Gevaarlijke Landbouw",d:"Kaffra heeft gehoord van Bonta\'s plannen om hun graanproductie te verhogen. Hij heeft 20 Scheurbuikzaden nodig om deze productie gunstig te maken voor Brakmar.",r:[50000,null,null,null,null,null]};
Q.s[200] = {n:"De schilden van Terrdala",d:"Eén van de specialismen van de Pandala is het maken van schilden. Brakmar is zeer geïnteresseerd in dit gereedschap om zich te weren tegen de krachten van Bonta.",r:[null,null,null,null,null,null]};
Q.s[783] = {n:"Voedselvergiftiging",d:"Shush vertrouwde je met 20 Scheurbuikzaden om achter te laten in de Alchemistenwerkplaats in Bonta. Je moet je missie volbrengen in de nacht als Merlinmagus Ambrosius slaapt.",r:[50000,null,null,null,null,null]};
Q.s[198] = {n:"De Duivelse Bronnen van Akwadala",d:"Op Pandala zijn er waterbronnen waardoor je kunt veranderen. Dat kan handig zijn als je je vijand voor de gek wilt houden...",r:[null,null,null,null,null,null]};
Q.s[787] = {n:"Ik zei: Sta op en Loop",d:"\"Erazal\'s Verwensing\" leerde je hoe je een ziel tegen zijn wil in weer tot leven kunt wekken. Om dit te doen, met je een specifiek drankje maken en het ritueel volgen. ",r:[50000,null,null,null,null,null]};
Q.s[199] = {n:"Zielstenen",d:"Een zielsteen kan een groep wezens bevatten, die weer opgeroepen kunnen worden... Maar je moet wel van tevoren weten hoe je dit moet doen!",r:[null,null,null,null,null,null]};
Q.s[201] = {n:"Zoek de vogelvrijverklaarde",d:"Rok is gesignaleerd in het noorden van Pandala. Hij is veroordeeld tot hechtenis in Astrub.",r:[null,6250,null,null,null,null]};
Q.s[202] = {n:"Zoek de vogelvrijverklaarde",d:"Musha is gesignaleerd in het zuiden van Pandala. Hij is veroordeeld tot hechtenis in Astrub.",r:[null,64000,null,null,null,null]};
Q.s[203] = {n:"Zoek de vogelvrijverklaarde",d:"Marzwel is gesignaleerd in de buurt van Aerdala. Hij is veroordeeld tot hechtenis in Astrub.",r:[null,25000,null,null,null,null]};
Q.s[206] = {n:"Zoek de vogelvrijverklaarde",d:"Aermyne is gesignaleerd in de buurt van Terrdala. Ze is veroordeeld tot hechtenis in Astrub.",r:[null,16000,null,null,null,null]};
Q.s[785] = {n:"Snelle Vragen",d:"Elviana Tirips wil weten wat voor informatie de Bontariaanse voortvluchtigen aan de Brakmarianen geven. Je moet ze ondervragen.",r:[200000,null,null,null,null,null]};
Q.s[786] = {n:"Jacht op de vogelvrije is geopend",d:"Bontariaanse voortvluchtigen zochten onderdak in Brakmar. Je moet ze vinden en vermoorden voordat je hun lichamen naar Bonta brengt.",r:[200000,null,null,null,null,null]};
Q.s[209] = {n:"Zombificatie",d:"Als je een Hecate Discipel wilt worden, moet je  weten hoe je een dode moet overtuigen om terug te gaan naar het slagveld. Om in deze orde te integreren, moet je bewijzen dat je een groot aantal demonen zo snel mogelijk terug kunt halen uit de dood. Het is aan jou om uit te zoeken waar de lijken liggen.",r:[200000,null,null,null,null,null]};
Q.s[208] = {n:"Als een schaduw",d:"Je hebt een schaduw onder de schaduwen nodig, om een Brumaire Discipel te worden. Het doel van de test is simpel: je moet in het Roversdorp infilteren zonder gezien te worden en met de instructeur praten.",r:[200000,null,null,null,null,null]};
Q.s[214] = {n:"Praat met Igor Ant, Huurbaas van Astrub",d:"Igor Ant kent de wetten van de Dofawa handelaars.",r:[1000,45,[[7929,1]],null,null,null]};
Q.s[213] = {n:"Praat met Magus Ax",d:"De Magus X moet de Tofu eieren kunnen analyseren en de Dofus.",r:[1000,null,null,null,null,null]};
Q.s[212] = {n:"Tofu Eieren voor Nowa",d:"Breng Nowa: x2 Tofu eieren",r:[1000,5,null,null,null,null]};
Q.s[217] = {n:"Breng een Paarse Piwi Veer terug naar Acidrik",d:"Hij moet Acidrik\'s boek bevrijden van Herdegrize\'s betovering.",r:[1500,100,[[7930,1]],null,null,null]};
Q.s[216] = {n:"Pak Acidrik\'s nepboek",d:"De titel van dit boek is \"het tijdperk van de draken\" en niet \"het Tijdperk van de Draken\".",r:[1000,200,null,null,null,null]};
Q.s[215] = {n:"Een biertje voor Acidrik",d:"Hij kan je toekomst in het schuim van een lekker biertje lezen.",r:[500,null,null,null,null,null]};
Q.s[219] = {n:"Ga naar de plek waar het Oneindige en het Niets samenkomen",d:"Hier vind je een antwoord met betrekking tot Menalt\'s ziel.",r:[1500,50,[[7934,1]],null,null,null]};
Q.s[234] = {n:"Symbool en Symbolisme",d:"Ga terug naar Nistracolamus om uit te zoeken wat dit beroemde symbool betekent.",r:[1000,null,null,null,null,null]};
Q.s[218] = {n:"Zoek Xelor\'s standbeeld",d:"Onthou het symbool dat gegraveerd is op god\'s hamer.",r:[500,null,null,null,null,null]};
Q.s[220] = {n:"De grot van Koolich",d:"Men zegt dat de Koolich jaren in dit hol geleefd heeft. De opvoeder die zich hier binnen waagde, is nooit meer teruggekomen...",r:[null,null,null,null,null,null]};
Q.s[221] = {n:"Een blik op de gedetineerden",d:"De gevangenen van Astrub lijken onrustig. Een huurling vraagt je om ze in de gaten te houden.",r:[1000,null,[[133,1]],null,null,null]};
Q.s[233] = {n:"Gedetineerden Schoppen",d:"Je hebt de gevangenen van Astrub in het gareel gekregen. Praat met Edgg Komb hierover.",r:[1000,50,null,null,null,null]};
Q.s[222] = {n:"Bezoek aan Allister\'s Kasteel",d:"Degui Quetiristou stelt je voor om de nieuwe indeling van het kasteel en z\'n haven te bezichtigen.",r:[7000,50,null,null,null,null]};
Q.s[224] = {n:"Planken voor de constructie",d:"Breng de essenhouten planken terug naar Kartier Stermee om de daken van Allister\'s kasteel af te maken.",r:[3000,876,null,null,null,null]};
Q.s[227] = {n:"Larvenvlees",d:"Breng stukjes larve terug naar Kartier Stermee, want hij moet z\'n arbeiders te eten geven.",r:[10000,1012,null,null,null,null]};
Q.s[226] = {n:"Tarwe voor de arbeiders",d:"Breng tarwe terug naar Kartier Stermee, want hij moet z\'n arbeiders te eten geven.",r:[3500,599,null,null,null,null]};
Q.s[225] = {n:"Kiezelstenen om de gaten te dichten",d:"Breng de vuurstenen terug naar Kartier Stermee om de muren van Allister\'s kasteel af te maken.",r:[3500,1022,null,null,null,null]};
Q.s[232] = {n:"Kartier Stermee klinkt liever met een vriend",d:"Je hebt enkel bier en een vriend nodig voor een leuke avond.",r:[7500,3000,null,null,null,null]};
Q.s[228] = {n:"Een mooie tafel",d:"Kartier Stermee wil indruk maken op z\'n toekomstige verloofde met een mooie goed gevulde tafel.",r:[4000,4000,null,null,null,null]};
Q.s[230] = {n:"Een ring voor Monabella",d:"Kartier Stermee wil Monabella uitnodigen voor een diner om haar ten verloving te vragen.",r:[2500,null,null,null,null,null]};
Q.s[229] = {n:"Een ring als toetje",d:"Kartier Stermee wil een verlovingsring.",r:[8500,3000,null,null,null,null]};
Q.s[231] = {n:"Kartier Stermee en Wartella",d:"Hij nodigt Wartella uit om met hem te eten.",r:[2500,null,null,null,null,null]};
Q.s[237] = {n:"De Grote Tanden der Corruptie",d:"De haai geeft kamas aan Wartella.",r:[10500,null,null,null,null,null]};
Q.s[235] = {n:"In het kielzog",d:"Wartella zoekt een haai.",r:[2100,null,null,null,null,null]};
Q.s[238] = {n:"Melk Tanden",d:"Wartella wil wat melk.",r:[12600,null,[[992,8],[989,8],[991,4]],null,null,null]};
Q.s[239] = {n:"Haaitelijk Gelach",d:"Haaiege is blij met het verloop van de gebeurtenissen.",r:[4800,null,null,null,null,null]};
Q.s[236] = {n:"De echte Haai",d:"Wartella wil dat ik de \"Haailijk\" uit de haven verjaag.",r:[null,null,null,null,null,null]};
Q.s[242] = {n:"Hielenlikkers Drankje voor een sappig zaakje",d:"Haraquiri wil dit drankje misschien hebben voor z\'n zaken met Allister.",r:[16500,1000,null,null,null,null]};
Q.s[240] = {n:"Ingrediënten voor een Hielenlikkers Dranke",d:"Om een perfect Hielenlikkers Drankje te maken heb je nodig: Veelvraat Hoorn, Bloemblad van de Duivelse Roos, Uitgeholde Krakamor en Papaver Graan.",r:[6000,6000,null,null,null,null]};
Q.s[241] = {n:"Hielenlikkers Drankje voor een melkplaag",d:"Je moet het drankje naar Monabella brengen.",r:[7500,689,null,null,null,null]};
Q.s[243] = {n:"Bierschuim Brouwen",d:"Walt Apain moet eerst een biertje drinken voordat hij de haai trotseert.",r:[7000,30,null,null,null,null]};
Q.s[244] = {n:"Water bij de Hop",d:"Walt Apain heeft enorme hoofdpijn door al die verschillende biertjes.",r:[2000,40,null,null,null,null]};
Q.s[245] = {n:"Wat Bier",d:"De dokwerker moet flink wat drinken om z\'n moraal op te vijzelen.",r:[1000,30,null,null,null,null]};
Q.s[249] = {n:"Een MiauwMiauw voor een TruTrutje",d:"Monabella wil een witte MiauwMiauw, alsof ze dat allemaal nodig heeft om op vakantie te kunnen gaan.",r:[150000,5000,null,null,null,null]};
Q.s[248] = {n:"Rijdier en Zonnebrand voor op Vakantie",d:"Monabella heeft een Drakokalkoen en wat Zonnebloem Olie nodig om lekker te kunnen zonnen in haar toekomstige strohut.",r:[140000,5000,null,null,null,null]};
Q.s[246] = {n:"Gevangenis en Makelaar",d:"Monabella wil graag de oude schuilplaats van een bajesklant overnemen om het naar haar eigen smaak in te delen.",r:[20000,null,null,null,null,null]};
Q.s[247] = {n:"Strohut",d:"Monabella wil een huis dat ver afgelegen ligt van de rechtbank.",r:[50000,null,null,null,null,null]};
Q.s[250] = {n:"De Aardappel Deal",d:"Je moet aardappelzakken brengen naar de gevangenis bij de haven.",r:[2000,null,null,null,null,null]};
Q.s[252] = {n:"Arme Aardappel",d:"Bhen Ernie wil dat je Rocco Fidelio bedankt voor z\'n aardappels.",r:[2500,1200,null,null,null,null]};
Q.s[251] = {n:"Een Aardappel Schop",d:"Bhen Ernie wil z\'n eigen aardappels telen voor z\'n eigen plezier.",r:[3000,null,[[538,12]],null,null,null]};
Q.s[253] = {n:"Drakokalkoen Steak",d:"Haraquiri, de officiële slager van Allister, heeft warm jong vlees nodig.",r:[5000,2500,[[10384,15]],null,null,null]};
Q.s[256] = {n:"Bezoek de bibliotheek",d:"Bezoek de bibliotheek",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[258] = {n:"Bezoek de bibliotheek",d:"Bezoek de nieuwe bibliotheek",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[261] = {n:"Mounts voor Boors",d:"De militieman praatte er niet omheen. Hij wil Dragoturkeys! En snel!",r:[75000,null,null,null,null,null]};
Q.s[262] = {n:"Het Koalakgebergte in kaart brengen",d:"Sjauwr, de cartograaf is te oud om verre reizen te maken.",r:[12000,50,[[7934,1]],null,null,null]};
Q.s[263] = {n:"Een Makkelijke Oogst",d:"Orchideeën groeien in de Koalak bergen. Je moet een mooi groot boeket plukken en naar Maskara brengen.",r:[7500,4000,null,null,null,null]};
Q.s[264] = {n:"Een Beladen Lijst",d:"Koka Dekolak heeft verschillende bepaalde grondstoffen nodig.",r:[30000,null,[[989,10],[281,2]],null,null,null]};
Q.s[265] = {n:"Een Gecompliceerde Bestelling",d:"Koka Dekolak wil nog meer bepaalde middelen. Je vindt ze in het Koalak gebied.",r:[120000,6000,[[283,10],[548,5],[580,10]],null,null,null]};
Q.s[266] = {n:"Een Laatste Gunst voor Koka",d:"Koka heeft nog één keer je oogstkunsten nodig.",r:[350000,11000,[[539,30],[991,10],[548,5],[6964,5],[6965,5]],null,null,null]};
Q.s[267] = {n:"De Toren Sleutel",d:"Toon Veelvraateater je vastberadenheid en verdien de sleutel van de Veelvraat Toren.",r:[7500,200,[[1568,1]],null,null,null]};
Q.s[268] = {n:"De Wereldreis",d:"Metag de Krijger heeft je verteld over een fantastisch machtig relikwie. Maar je moet hem laten zien wat je waard bent voor je verder kunt.",r:[5000,null,null,null,null,null]};
Q.s[281] = {n:"Ga naar de Meester",d:"Metag wil je testen. Hij stuurt je naar de mysterieuze Sleutelmeester.",r:[10000,null,null,null,null,null]};
Q.s[271] = {n:"Vervolg het Avontuur",d:"Stop niet met je vastberadenheid te tonen.",r:[30000,null,null,null,null,null]};
Q.s[280] = {n:"Vervolg",d:"De Sleutel Meester stuurt je om een van zijn vrienden te bezoeken.",r:[null,null,null,null,null,null]};
Q.s[270] = {n:"Vervolg het Avontuur",d:"Stop niet met je vastberadenheid te tonen.",r:[30000,null,null,null,null,null]};
Q.s[269] = {n:"Gevecht in de Eerste Dungeon",d:"De quest voor het artifact is begonnen. Confronteer de monsters van de Veld Dungeon.",r:[15000,null,null,null,null,null]};
Q.s[272] = {n:"Vervolg het Avontuur",d:"Stop niet met je vastberadenheid te tonen.",r:[40000,null,null,null,null,null]};
Q.s[273] = {n:"Voor de Titel",d:"Jumbo is scheidsrechter bij dit gedeelte van de mssie.",r:[45000,null,null,null,null,null]};
Q.s[279] = {n:"Wordt vervolgd",d:"Jumbo Mumbo stuurt je naar de volgende persoon die je kan helpen met het bewijzen van je kunnen.",r:[null,null,null,null,null,null]};
Q.s[278] = {n:"Voor de Titel",d:"Jumbo blijft naar je kijken.",r:[75000,null,null,null,null,null]};
Q.s[276] = {n:"Voor de Titel",d:"Jumbo slaat je van dichtbij gade.",r:[55000,null,null,null,null,null]};
Q.s[275] = {n:"Voor de Titel",d:"Jumbo zal je kundigheid beoordelen.",r:[45000,null,null,null,null,null]};
Q.s[277] = {n:"Voor de Titel",d:"Jumbo\'s ogen zijn op je gericht.",r:[65000,null,null,null,null,null]};
Q.s[274] = {n:"Voor de Titel",d:"Jumbo is deze ronde scheidsrechter.",r:[45000,null,null,null,null,null]};
Q.s[288] = {n:"Een Hik",d:"Op het lange en harde vechten van vandaag na, waren ze maar een kleine hobbel op weg.",r:[null,null,null,null,null,null]};
Q.s[283] = {n:"Haast je",d:"Kris voelt zich niks beter. Schiet op voordat zijn status slechter wordt.",r:[135000,null,null,null,null,null]};
Q.s[284] = {n:"Snel Snel Snel",d:"Ondanks zijn stemming helpt Kris je echt met je relieken jacht.",r:[145000,null,null,null,null,null]};
Q.s[287] = {n:"De Allerlaatste?",d:"Je begreep dat dit je laatste gevecht werd voordat de overwinning op je neer kwam als een verregende kat.",r:[175000,null,null,null,null,null]};
Q.s[282] = {n:"Ga ergens anders heen",d:"Kris is lichtelijk gestressed. Je kunt beter snel doen wat hij vraagt.",r:[125000,null,null,null,null,null]};
Q.s[285] = {n:"Een echte uitdaging",d:"Kris stuurt je naar meer en meer gevaarlijke plekken",r:[155000,null,null,null,null,null]};
Q.s[286] = {n:"Een Andere",d:"Je zoektocht boekt vooruitgang... langzaam.",r:[165000,null,null,null,null,null]};
Q.s[296] = {n:"De Laatste Sleutel",d:"Colm gaf je de allerlaatste sleutel. Je bent dicht bij het einde.",r:[450000,null,null,null,null,null]};
Q.s[297] = {n:"Inwijding?",d:"Colm heeft niks om je te geven. Ga terug naar de Sleutel Meester",r:[null,null,null,null,null,null]};
Q.s[289] = {n:"Een Zeer Duidelijk Bericht",d:"Colm een soort van machine zal je helpen de zoektocht verder te zetten. Deze man verteld je tenminste wat je moet doen.",r:[250000,null,null,null,null,null]};
Q.s[291] = {n:"Technische Fout",d:"Colm heeft zijn probleem nog niet gerepareerd maar je gaat door met je zoektocht.",r:[350000,null,null,null,null,null]};
Q.s[295] = {n:"Een Bout is Kwijt",d:"Colm zit vast maar geeft jou de sleutel",r:[400000,null,null,null,null,null]};
Q.s[290] = {n:"Problemen?",d:"Colm kon zijn bericht niet volledig verzenden. Maar nu je de sleutel hebt kun je wel raden wat je moet doen.",r:[300000,null,null,null,null,null]};
Q.s[299] = {n:"Meester Minator",d:"De meester gelooft dat je een echt instrument van de oorlog bent;\r\n            er is een andere beproeving voor je.",r:[725000,null,null,null,null,null]};
Q.s[298] = {n:"Meester Mijt",d:"De meester beslist om je wat meer beproeveningen op te leggen. Dit wordt saai.",r:[500000,null,null,null,null,null]};
Q.s[301] = {n:"Meester Minus",d:"Alsjeblieft, de Sleutel Meester geeft je zijn laatste beproeving",r:[875000,null,null,null,null,null]};
Q.s[300] = {n:"Meester Restrial",d:"Het lijkt erop dat je er niet toe in staat bent om aan deze eindeloze lijst van moorden te kunnen ontsnappen. Maar als dat is wat er gedaan moet worden.",r:[800000,null,null,null,null,null]};
Q.s[307] = {n:"Game Master",d:"Alweer een vijnadelijk gebied waar je door moet.",r:[650000,null,null,null,null,null]};
Q.s[306] = {n:"Meester of geen Meester",d:"Deze keer stuurt de meester je naar het hart van conflict-geplaagde landen.",r:[575000,null,null,null,null,null]};
Q.s[302] = {n:"Eindelijk!",d:"Je hebt het gehaald! Het is eindelijk over. Metamunch moet nou zijn belofte nakomen. Het ultieme familie reliek is van jou!",r:[1000000,null,null,null,null,null]};
Q.s[315] = {n:"Snelle service",d:"De Filtounga van Pol moet nu klaar zijn.",r:[null,null,null,null,null,null]};
Q.s[312] = {n:"En koken maar!",d:"Jij hebt het recept van de Filtounga in handen. Het enige wat je moet doen is alle ingrediënten verzamelen voor Pol, zodat hij z\'n beroemde maaltijd kan maken.",r:[115000,5000,null,null,null,null]};
Q.s[311] = {n:"Een uniek gerecht",d:"De meedogenloze Paindep dreigt om El\'s kinderen op te eten, als ze niks beters vindt om te eten.",r:[75000,null,null,null,null,null]};
Q.s[313] = {n:"De ingrediënten",d:"Pol, de kok, zal dit recept klaar maken, als je hem alle ingrediënten brengt.",r:[115000,null,null,null,null,null]};
Q.s[316] = {n:"De bevrijding",d:"Pol is klaar met de Filtounga, Paindep zal tevreden zijn.",r:[120000,null,null,null,null,null]};
Q.s[310] = {n:"De kleine hut in het bos",d:"De jonge Jorg heeft \'t gehad over een geheime hut in het Drakokalkoenbos.",r:[25000,null,null,null,null,null]};
Q.s[309] = {n:"Een rondje door het dorp",d:"De dorpelingen hebben El\'s kinderen absoluut gezien. Ondervraag ze om meer te weten te komen.",r:[35000,null,null,null,null,null]};
Q.s[308] = {n:"Een radeloze moeder",d:"Madam El is in paniek. Ze zoek haar kinderen in het Amakna dorp.",r:[null,null,null,null,null,null]};
Q.s[314] = {n:"Snelle bereiding",d:"Pol heeft nu alles om een Filtounga klaar te maken. Dus even wachten nog.",r:[15000,null,null,null,null,null]};
Q.s[321] = {n:"Dood door Bwork",d:"Gobatchef wil dat de Bworks afgeslacht worden voordat ze de Goblins afslachten.",r:[20000,1000,null,null,null,null]};
Q.s[322] = {n:"Krazybwork wil weer achterlijk worden.",d:"Krazybwork heeft te veel Goblins gegeten tijdens de slag om Bworkdrift. Hij is slim geworden en wil weer achterlijk worden. Het beste is om hem een klap op z\'n kop te geven!",r:[null,500,[[8527,1]],null,null,null]};
Q.s[323] = {n:"Bworkidais de paxifik",d:"Slaag of geen slaag?",r:[15000,null,null,null,null,null]};
Q.s[325] = {n:"Uitsnijden en dan uitpunten",d:"Bworknroll moet zijn wezen vullen met verse organen (en sappig).",r:[150000,null,null,null,null,null]};
Q.s[326] = {n:"Vergeet het belangrijkste niet: het vergiet!",d:"Bworknroll heeft een vergiet nodig om z\'n droomwezen af te maken.",r:[230000,5000,null,null,null,null]};
Q.s[324] = {n:"Een handige scalpel",d:"Bworknroll heeft stukken vlees nodig om zijn ideale partner samen te stellen.",r:[120000,null,null,null,null,null]};
Q.s[375] = {n:"Wat Heb Je Een Grote Tanden",d:"Een Boowolf maakt je een verleidelijk aanbod.",r:[null,null,null,null,null,null]};
Q.s[376] = {n:"Inschrijvingskosten",d:"Als Bworknroll de betaling accepteert is Litol in staat om een magus te worden.",r:[null,null,null,null,null,null]};
Q.s[328] = {n:"Titi begeleiden",d:"De vader van Titi zou graag magiër worden. Daarvoor moet je hem met wat eten naar de machtigste Bworks Magus brengen.",r:[null,null,null,null,null,null]};
Q.s[374] = {n:"Litol krijgt zijn studiebeurs",d:"Bworknroll accepteerde om magie te leren aan Litol. Ga en vertel het aan zijn vader.",r:[null,null,null,null,null,null]};
Q.s[330] = {n:"Groene huiden",d:"Bworkepik wil de huid van de goblins voor zijn vrouwtjes.",r:[45000,30000,null,null,null,null]};
Q.s[331] = {n:"Een stok en een uitrusting",d:"Chef Bworkestre moet zijn tedere mannelijkheid bewijzen door kdo\'s te vragen aan de bezoekers die op doorreis zijn in zijn charmante dorp. Met een Prespic uitrusting, hoopt hij de degenrolslagen van zijn geliefde bworkette te kunnen afweren. ",r:[45000,35000,null,null,null,null]};
Q.s[340] = {n:"Nog Meer Woorden",d:"Pinkgob verkiest om een slaaf te zijn en Piwis te broeden. Wat een zielige realiteit voor haar kandidaad...",r:[20000,null,null,null,null,null]};
Q.s[339] = {n:"Pinkgob Plukken",d:"Gobritor is jaloers op Pinkgob\'s Piwis. Alleen de vibraties van zijn kleine groene Goblinhart kunnen die van Pinkgob laten slaan.",r:[3000,null,null,null,null,null]};
Q.s[337] = {n:"Jezelf Vullen",d:"Bworkcine is klaar om haar slaaf te ruilen voor haar gewicht in Bwork bier.",r:[12000,null,null,null,null,null]};
Q.s[338] = {n:"De Kandidaad Aanpassen",d:"Zullen Pinkgob en Gobritor zich samenvoegen?",r:[null,3000,null,null,null,null]};
Q.s[336] = {n:"Vind Bworkcine\'s Den",d:"Dat is waar Pinkgob is opgesloten",r:[1000,null,null,null,null,null]};
Q.s[354] = {n:"Vecht voor de Wacht",d:"De kapitein vertrouwde je een makkelijke maar nuttige taak toe.",r:[195,null,null,null,null,null]};
Q.s[345] = {n:"De Wisseling van de Wacht",d:"Qwizitor vraagt je om er zeker van te zijn dat alle wachters hun werk doen.",r:[230,null,null,null,null,null]};
Q.s[362] = {n:"Terug in Vorm",d:"Brett Ernal heeft je in een spook veranderd. Gebruik de feniks om je kracht terug te krijgen.",r:[null,null,null,null,null,null]};
Q.s[363] = {n:"Daag Osamodas Uit!",d:"Deze verwaande Osamodas zouden eens flink aangepakt moeten worden!",r:[500,null,[[8534,1]],null,null,null]};
Q.s[368] = {n:"Vecht voor de Wacht",d:"De kapitein vertrouwde je een makkelijke maar nuttige taak toe.",r:[195,null,null,null,null,null]};
Q.s[369] = {n:"Vecht voor de Wacht",d:"De kapitein vertrouwde je een makkelijke maar nuttige taak toe.",r:[195,null,null,null,null,null]};
Q.s[370] = {n:"Vecht voor de Wacht",d:"De kapitein vertrouwde je een makkelijke maar nuttige taak toe.",r:[195,null,null,null,null,null]};
Q.s[372] = {n:"Vind de gouache",d:"Ondanks zijn rare accent, snap je precies wat Marylork je gevraagd heeft.",r:[75,75,null,null,null,null]};
Q.s[373] = {n:"Brabbelende Lykhen",d:"Lykhen vertelt je over zijn avonturen lang geleden.",r:[10,null,null,null,null,null]};
Q.s[385] = {n:"Vind de Rogues\' Den.",d:"Yse Vewybad heeft je informatie gegeven over de Rogues locatie. Ga en bezoek de begraafplaats.",r:[9000,null,null,null,null,null]};
Q.s[384] = {n:"Vind de Sram.",d:"Yse Vewybad vertelde je over een belangrijke Sram in Amakna... Maar waar vinden we de Sram in Amakna?",r:[1000,null,null,null,null,null]};
Q.s[394] = {n:"Vind de kandidaad.",d:"Je moet een kandidaad vinden voor Allisteria, de dochter van de koning z\'n broer.",r:[15000,null,null,null,null,null]};
Q.s[395] = {n:"Vissen naar informatie.",d:"Vil Smisse wil dat je informatie verzameld over wat er aan de hand is in het kasteel. Daarvoor, moet je iemand vinden die je dit kan vertellen.",r:[3000,null,null,null,null,null]};
Q.s[396] = {n:"Vitterig",d:"Nu weet je dat de koning met zijn nichtje wil trouwen... maar met wie?",r:[12000,null,null,null,null,null]};
Q.s[402] = {n:"Valse Identiteit",d:"Zoals je kan zien, heeft Uba Tesse je getransformeerd in een Wabbit. Je moet alleen nog naar het kasteel gaan en deze bruiloft verpesten.",r:[50000,25000,null,null,null,null]};
Q.s[401] = {n:"Na het recept, zoek de ingrediënten!",d:"Nu Uba de formule heeft, heeft hij alleen de ingrediënten nog nodig.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"Een formule!",d:"Je moet de alchemisten verspreid over Amakna vinden.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit Kwacht",d:"Vind een manier om jezelf in een Wabbit te veranderen.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"Druk-voeren",d:"Je hebt een zwaarlijvig tofu ei, maar een ei zal de pwins geen schade doen... Je moet iets zoeken om de jonge vogel snel te voeren.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Bedel voor een Ei",d:"Vil Smisse vroeg je om hem een zwaarlijvig tofu ei te brengen. Het enige wat je moet doen is het nest vinden.",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"Huurmoordenaren inhuren",d:"Vil Smisse is niet in staat om te vergiftigde blop taart te gebruiken. Hij komt terug op de directe aanval. Daarvoor, wil hij moordenaars inhuren en heeft hij geld nodig.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"Een vergiftigde beker",d:"Vil Smisse kiest voor de manier van een Rogue: geslepenheid.",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Feest Verstoorder",d:"Het is de moordenaars niet gelut om de prins te vermoorden... Vil Smisse vraagt je om te gaan en een Lenald te huren om het werk te doen.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"Dood aan de Tofu!",d:"Jij weet waar de pwins van Wa naar toe gegaan is om te jagen. Nou... ergens ten zuiden van Bonta. De pwins moet nog gevonden worden.",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"Ga aan het Werk",d:"Vraag de voorman wat je moet doen.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Bedienen of plezieren?",d:"Bediende San Lavalss vraagt je om te helpen bij het klaarmaken voor de bruiloft.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"1e stap",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"Een Kostuum voor Emeralda",d:"Emeralda is wanhopig op zoek naar een Koalak set.",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Beantwoord de Vrager",d:"De Dode Brugbewaker eist dat je zijn vragen juist beantwoord.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Maak je klaar voor je Reis",d:"Kapitein Haddock\'n\'roll vraagt je bepaalde voorwerpen naar hem te brengen zodat je op zijn schip kan.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"Flib\'s Vervloekte Kleine Doos",d:"Kapitein Haddock\'n\'roll is vreselijk gestrand op het Castaways\' Eiland. Je moet Flib\'s vervloekte kist en een paar andere voorwerpen vinden om het schip te repareren.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"Je zult niet verder komen!",d:"De Zwart met Roze Ridder wil je niet doorlaten. Dit is het goede moment om kracht te gebruiken voor hetgene wat je wilt.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"Een potion voor een Professor",d:"Professor Kalkulus heeft een Bulbish drankje nodig, voordat hij weer aan het werk kan.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Fok Machines",d:"Polka Merer heeft broedmachines nodig voor haar wezens.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"Een Bloem Verhaal",d:"Stella Stukup, de bakker, wil goedkope bloem toevoegen bij het bloem van Xavier de bakker. Ze heeft het idee, nu moet jij de bloem vinden.",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"Zoeken voor de Verborgen Zoon",d:"Dokter Nauh is zijn zoon kwijtgeraakt in een lab vol met vreselijke wezens. Je moet hem vinden en ervoor zorgen dat hij nog steeds leeft.",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"De Dokter voelt zich Somber",d:"Arme Dokter Morose is zijn vrouw kwijt. Help hem haar te vinden in de Donkere Jungle en probeer haar te overtuigen mee terug naar haar man te gaan zodat de dokter zijn onderzoek weer kan starten",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"Verbeterde Uitrusting",d:"Speet Fyer zoekt een verbeterde pilotenhelm en mantel. Alleen een ervaren kleermaker kan je helpen.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Twee Dragoturkeys voor Flip Flap",d:"Flip Flap wil dat je haar een certificaat voor een Ginger Dragoturkey en één voor een Almond Dragoturkey brengt.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Donker Oerwoud Jacht",d:"Crocodyl Dandy wil dat je op een paar wezens bij de Donkere jungle jaagt.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Vlakte Jacht",d:"Crocodyl Dandy wil dat je op een paar wezens op de vlakte jaagt.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Strand Jacht",d:"Crocodyl Dandy wil dat je een paar wezens op het koraalstrand vermoord.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Boom Keeholo Jacht",d:"Crocodyl Dandy wil dat je op een paar wezens bij de Keeholo boom jaagt.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Bodemlose Turf Moeras Jacht",d:"Crocodyl Dandy wil dat je op een paar wezens bij het Bodemloze turfmoeras jaagt.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"Een Voorbeeld voor de Piraten",d:"Kito vraagt je de Piraten te laten zien wat je kan. Dat zou een goed voorbeeld zijn voor iedereen die er ook maar aan denkt om kanonskogels te schieten.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"De Zwarte en de Roze Ridder",d:"Mevrouw Lousy Piggy wil dat jij het tegen de vreselijke Zwarte en Roze Ridder opneemt voor haar.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"De Vervloekte Ruil",d:"Farle Ingalsse is waarschijnlijk de enige in heel Amakna die jouw vervloekte zwaard kan reparen...",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"Snel! Snel!",d:"Milone\'s huis staat op het punt om bij ingebroken te worden. Schiet op en hou dit tegen!",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Slecht aas?",d:"De reis verliep voorspoedig. Bandieten hebben niet aangevallen.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"Munt voor Ecaflips",d:"Amayiro heeft Marge\'s juweel nodig voor zijn plan.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Begeleiden",d:"Jouw missie, als je deze accepteert, is een groep handelaren begeleiden naar Astrub.",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"Handen, Bliks",d:"Het konvooi was aangevallen door Ecaflip bandieten die erg leken op het kamp dat je ontdekt hebt. Amayiro wacht op je verslag zodat hij het bestuur kan overtuigen om actie te ondernemen.",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Rigal de Gladjanus",d:"In de Sram tempel, heeft Rigal Haakhand informatie over Xarthan - de verdachte.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"Verdenkingen Bevestigd",d:"Xarthan ontmoet iedere nacht iemand in de Toren van Bonat. Amayiro zal geïnteresseerd zijn in deze informatie.",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"Alchemie voor beginners",d:"Je moet het klantenbestand van de alchemistenwerkplaats in Brakmar stelen en het naar Rigal Hookhand brengen.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Afscheiding van de modderpoel",d:"Je hebt hulp nodig van een Sram of een bekwame spion om in de vergifvoorraden van Brakmar te komen.",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Bijeenkomst bij de Toren",d:"Een ontmoeting tussen een Brakmariaan en een omgekochte Bontariaan staat op het punt om plaats te vinden in de Toren van Bonta. Je moet ze beiden gevangen nemen als dat mogelijk is.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"Verdraaid, gokken",d:"Je moet wat militieleden vinden om bij de Toren van Bonta neer te zetten.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"Bwork, wat een stank!",d:"Epuop Tik weet het niet meer of wil het niet zeggen. Hoe dan ook, moeten Bwork Magiers minder snel iemand van zichzelf verraden.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Danathor is verraderlijk",d:"Danathor schijnt je een nieuw bod te willen doen. Maar waarschijnlijk is het een verdacht bod.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"De betoverde pop",d:"Je moet vier Sadidas vinden die ervaring genoeg hebben om Opblaasbare te bezweren voor een ritueel met de betoverde wateren van de Koalak meren.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Wilde",d:"Als je de vloek opheft van....... Zal hij je zeker alles vertellen wat hij weet. Hij raadt je ook aan naar een bibliotheek te gaan om meer uit te zoeken.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"Op zoek naar de belabberde Klerk",d:"Aigurraf, Klerk van de Orde van het Scherpe Oog, heeft de kroegen afgezocht sinds zijn muis verdween. Breng hem terug naar Ebru van El.",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Uitbraak uit de Gevangenis",d:"Je moet een krijger bevrijden die gevangen is genomen door Bonta. Hij is in de kerker van de Bontariaanse militie gevangenis.",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"De vijand met hem",d:"Vind en roei je vijand uit.",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Win het gevecht.",d:"Ga door met je aanval om het gevecht te winnen.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Beëindig de strijd.",d:"Versla het monster. Wees voorzichtig, Beurten hebben nu een beperkte duur. De  {ui,banner,tx_artwork,3::remaining time gauge} geeft aan hoeveel tijd je nog hebt voordat je beurt eindigt.",r:[null,null,null,null,null,null]};
Q.s[1042] = {n:"Zet jezelf neer op de kaart.",d:"Welkom bij de begeleide tutorial. Klik rond je karakter om hem neer te zetten.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Sla je beurt over.",d:"Als je klaar bent, klik je op de {ui,banner,btn_skipTurn::Einde Beurt} knop om verder te gaan in het gevecht.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Rust je uit met een voorwerp.",d:"Open je {ui,banner,btn_character,1::karakteristieken} menu. Sleep de {ui,storage,grid::Beginners Ring} die je net gewonnen hebt naar het {ui,characterSheetUi,slot_2,2::ring slot}",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"uitrusten met je items",d:"Open de {ui,banner,btn_character,1::characteristics}  interface om je personage uit te rusten met de items die je hebt ontvangen.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Zet jezelf neer tijdens een gevecht.",d:"Je karakter gebruikt {ui,banner,lbl_pm,2::Bewegings Punten} (MP) om te bewegen. 1 Vak bewegen kost 1MP. Beweeg je karakter door op een vak te klikken.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Gebruik een spreuk.",d:"Kies {ui,banner,gd_spellitemotes,0::een spreuk} en kies je doelwit. Sommige spreuken worden gebruikt op vijanden, andere op vrienden of jezelf. Het bereik van de spreuk wordt getoond door de blauwe vakken. Spreuken hebben {ui,banner,lbl_pa,2::actie punten} (AP) nodig om gebruikt te worden. Je krijgt deze punten terug bij de start van je beurt.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Kies je startpositie.",d:"Klik op een van de blauwe cellen om je startpositie te kiezen en klik op de {ui,banner,btn_skipTurn::Klaar knop} om het gevecht te starten.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Verander van kaart.",d:"Om van kaart te wisselen, beweeg je cursor naar de {cell,335::rand van het scherm} en klik als hij verandert in een pijl.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Beëindig een missie.",d:"Om je missie te beëindigen, moet je naar de volgende kamer gaan, het wezen verslaan en met {cell,214::Ganymede Yalpot} praten.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Beëindig je training.",d:"Ga en vertel {npc,1222::Ganymede Yalpot} over je winst.",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Begin een missie.",d:"Praat met {npc,1222::Ganymede Yalpot} om een missie te starten (een NPC met een missie voor je heeft een uitroepteken boven zijn hoofd).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Praat met een NPC.",d:"Klik op {npc,1222::Ganymede Yalpot} om met hem te praten.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Start een gevecht.",d:"Klik op {cell,313::Incarnam Vogelverschrikker} om het gevecht te starten.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"Een gecompliceerd leven.",d:"Je had het advies van Het Dawa moeten volgen en uit moeten kijken. Nu staat je leven op de lijn. Ach, het leven is niet zo simpel als men zou denken.",r:[null,null,null,null,null,null]};
Q.s[1058] = {n:"We zullen allemaal slagen.",d:"Met jouw hulp moet het lukken, Het Dawa moet in staat zijn om de ziekte, die invloed heeft op de Pandawan drank markt uit te roeien, mits een tegengif kan worden gevonden.",r:[3000,null,[[10818,1]],null,null,null]};
Q.s[1056] = {n:"Het goede leven.",d:"Je hebt net aangekomen, en ze hebben je al een manier om je leven gemakkelijker en zonder veel inspanning te maken aangeboden, hetzij. Wat wil je nog meer?",r:[null,null,null,null,null,null]};
Q.s[1091] = {n:"Speelgoedfabriek",d:"Weerzinwekkende wezens hebben ingebroken in de werkplaats van Vader Kwismas . Je moet de cadeau\'s terugvorderen die zij hebben gestolen, met of zonder hun toestemming, en ze daarna aan Harry Kwismas geven.",r:[null,1000,[[10920,1]],null,null,null]};
