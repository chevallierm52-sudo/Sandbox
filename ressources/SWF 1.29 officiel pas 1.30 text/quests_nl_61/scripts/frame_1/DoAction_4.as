Q.s[639] = {n:"Vind Arpagnagrobis",d:"Jiva weet niet waar het magische standbeeld is, dat toegang geeft tot Nilevaj\'s cel. Arpagnagrobis de centaurion weet misschien iets.",r:[null,null,null,null,null,null]};
