Q.s[578] = {n:"Ga bij het Leger",d:"Een verontrustend rapport laat troepen van Brakmar op het land van Amakna zien. Amayiro vraagt je, om je aan te sluiten bij de elite troepen van Bonta die daar al zijn.",r:[null,null,null,null,null,null]};
Q.s[579] = {n:"Waar is de 7e patroille?",d:"De commandant Imagiro vraagt je naar de verlaten spoorweg te gaan om de 7e patroulle die vermist is geraakt te zoeken.",r:[null,null,null,null,null,null]};
Q.s[581] = {n:"Overwinning",d:"Elite Bontariaanse Troepen gaven de Brakmariaanse Troepen goede dekking. Je kan nu zorgeloos weggaan.",r:[320000,null,null,null,null,null]};
