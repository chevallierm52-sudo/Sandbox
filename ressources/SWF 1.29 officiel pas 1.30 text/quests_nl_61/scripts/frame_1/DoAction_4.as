Q.s[565] = {n:"De Waarheid over de Hoorn",d:"Oto wil meer informatie over de hoorn. Hij vroeg je te gaan praten met zijn spion, Finche Aticus, in Bonta.",r:[null,null,null,null,null,null]};
Q.s[576] = {n:"Vermist",d:"Nu dat hij de hamer heeft, vraagt Ebru van El de daarbij horende Lichte Geest te  vinden. Klasse meesters weten hier misschien meer over.",r:[null,null,null,null,null,null]};
Q.s[577] = {n:"Overtuigende Lichtgeest",d:"Je hebt de Lichtgeest gevonden die bij de hamer hoort. Nu moet je hem overtuigen jou te volgen naar Bonta. Omdat hij niet langer een opgezet speeltje is, zal de hulp van Sadidas bruikbaar zijn.",r:[280000,null,null,null,null,null]};
Q.s[966] = {n:"Een gehamerde Geest.",d:"Blijkbaar heeft Ebru van El nog steeds jouw hulp nodig met de hamer van Licht en de geest ervan.",r:[null,null,null,null,null,null]};
Q.s[567] = {n:"Werk Hard en Speel Hard",d:"Je hebt deelgenomen aan Trev Pelsentery\'s rechtszaak en jouw getuigenis heeft het uiteindelijke vonnis beïnvloedt. Je kan je weer concentreren op je vorige zaken.",r:[264000,null,null,null,null,null]};
Q.s[562] = {n:"Een Hamer voor de Rechter",d:"Satirev Onivin heeft zijn hamer gebroken en heeft je gevraagd om een nieuwe. Omdat hij een kieskeurig persoon is, gebruikt hij niets anders dan een Geschuurde Hamer.",r:[null,null,null,null,null,null]};
Q.s[563] = {n:"Danathor\'s Interview",d:"Danathor wil met je praten voor de rechtszitting. Het schijnt nogal belangrijk te zijn.",r:[null,null,null,null,null,null]};
Q.s[561] = {n:"Volg de Geur",d:"Amayiro heeft je gevraagd de Sram te vinden die Trev Pelsentery volgde op de dag dat Trev werd gearresteerd. De enige aanwijzing die je hebt is dat hij naar vis stinkt. Dus ga op onderzoek uit bij het visboeren district.",r:[null,null,null,null,null,null]};
Q.s[962] = {n:"Je hebt een slaperig gevoel, erg slaperig.",d:"Je moet een Hypnomeow vinden om te gebruiken in de ondervraging van Gnirreh voordat het proces begint.",r:[null,null,null,null,null,null]};
Q.s[566] = {n:"Getuigenis van de Onderzoeker",d:"Als hoofdonderzoeker voor Trev Pelsentery\'s verraad word je gevraagd te getuigen. Kies je kant.",r:[null,null,null,null,null,null]};
Q.s[973] = {n:"overweeg jager",d:"Je moet Greu Nouille overtuigen om je te helpen met het veroveren van een trillende gedachte gekoppeld aan Solar, om aan Danathor te geven.",r:[304000,null,null,null,null,null]};
Q.s[972] = {n:"Een remedie voor geheugenverlies.",d:"Meuh Sieurchance lijdt aan geheugenverlies. Je moet Shaman Surivitna\'s instructies volgen als je erop hoopt om hem te genezen.",r:[null,null,null,null,null,null]};
Q.s[971] = {n:"MC Solar.",d:"Je moet in het bezit komen van een Verloren gedachte behorend tot de laatste beschermer, Solar. Alchemisten kunnen in staat zijn om je te helpen.",r:[null,null,null,null,null,null]};
Q.s[675] = {n:"",d:"As\'Ruoy\'Dnim wil 5 eenheden Vampier Bloed, 5 stenen van Eroded Kriball (Crackler Kerker), een levende Farle\'s Varken (DraakVarken Kerker), en 4 Agride bijlen.",r:[480000,null,null,null,null,null]};
Q.s[674] = {n:"",d:"As\'Ruoy\'Dnim wil je onmoeten. Hij wacht op je bij de gebruikelijke plaats in de Toren van Gisgoul.",r:[null,null,null,null,null,null]};
Q.s[622] = {n:"Verklaringen",d:"De Rogue kotste het Waarheids Serum. Amayiro heeft je opnieuw gevraagd te kijken bij Merlinmagus Ambrosius om verklaringen te verkrijgen.",r:[null,null,null,null,null,null]};
Q.s[623] = {n:"Een Interessante Ondervraging",d:"Rogues staan bekend om hun zwijgzame aard, zelfs tijdens martelingen. Daarom werkt Amayiro aan een nieuwe methode en hij wil dat jij hem brengt: 1 Magische Wabbit Snijtand, 1 Haar van Wilde Dragoturkey, 1 Kwoan Kraan, 1 Irriterende Tofu Veer, 1",r:[374000,null,null,null,null,null]};
Q.s[621] = {n:"Waarheidsserum",d:"Amayiro vroeg je contact op te nemen met Merlinmagus Ambrosius bij de Alchemisten werkplaats om een Waarheids Serum te maken.",r:[null,null,null,null,null,null]};
Q.s[64] = {n:"Ik Wil alles nu meteen!",d:"Word koning van de wereld",r:[500,1000,[[968,1],[948,5]],[11,10],[27,47],[453,3,437]]};
Q.s[65] = {n:"Ik wil niks meer!",d:"Ik wil minder XPs en minder kamas",r:[null,null,null,null,null,null]};
Q.s[653] = {n:"Woeste Goblins",d:"Troepen Goblins met insignes uit Brakmar zijn gespot op weg naar de Bonta buitenposten. Amayiro heeft je gevraagd Kapitein Malfe een hand te geven.",r:[null,null,null,null,null,null]};
Q.s[587] = {n:"Danathor\'s Verontwaardiging",d:"Danathor wil met je praten. Je doet er goed aan op te schieten.",r:[null,null,null,null,null,null]};
Q.s[656] = {n:"Vechtrapport",d:"De gevechten bij de zuidelijke poorten van de stad zijn immens. Je moet rapport uitbrengen aan Amayiro.",r:[401000,null,null,null,null,null]};
Q.s[1016] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[588] = {n:"Ondersteuning van de Raad",d:"Danathor moet de steun van de raad hebben om de troepen op te roepen en ze naar het front te sturen. Je moet de steun van de volgende leden van de raad winnen: Elviana Tirips, Jerhyn Gholein en Ebru van El. Ze zijn allen in de Toren van Bonta.",r:[null,null,null,null,null,null]};
Q.s[592] = {n:"Imp Verslag",d:"Het gevecht tegen Brakmar in het Imp Dorp is voorbij. Je moet je rapport aan Danathor geven.",r:[null,null,null,null,null,null]};
Q.s[655] = {n:"Slechts een Afleiding",d:"De aanval op de buitenpost was slechts een afleiding, en de Brakmariaanse troepen vallen in werkelijkheid de zuidelijke poorten van de stad aan. Je moet ze terug drijven!",r:[null,null,null,null,null,null]};
Q.s[589] = {n:"Dorp in Gevaar",d:"Nu hij de steun van de raad heeft, stuurt Danathor je naar het Imp Dorp waar Bonta en Brakmar elkaar gewoonlijk confronteren.",r:[null,null,null,null,null,null]};
Q.s[766] = {n:"Bontariaanse Aanval",d:"Je moet naar het oosterlijke gedeelte van de omheining en Bontarianen verslaan.",r:[37000,null,null,null,null,null]};
