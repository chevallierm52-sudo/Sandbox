Q.s[365] = {n:"Sleutel tussen de Tanden",d:"Als je de sleutel van de kerker wilt, moet je een grote agressieve Gobball verslaan.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"De Toren infiltreren",d:"Brakmar bereid een aanval op Bonta voor. Deze informatie moet bevestigd worden. De Toren van Brakmar is waarschijnlijk de plaats om dit soort informatie te krijgen.",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Sadidisti",d:"Rouh Flowa heeft je de ingang van de begroeide gevangenis laten zien. Hij liep met zijn hoofd in de wolken. Je mag hopen dat hij niets vergeten is!",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"Een Sleutel op een Eekhoorn",d:"Je moet een eekhoorn vinden in Brakmar die een belangrijke sleutel heeft gestolen. Breng de sleutel terug naar Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Breng de Dozen",d:"Je moet de kisten met wapens naar Oto brengen, in de Toren van Brakmar.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Getas voor Milone",d:"Omdat je de inbraak niet kon voorkomen, heeft hij je gevraagd hem Feudela Getas te brengen.",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Mak Nogmaals Verslaan",d:"De Chafer Mak Gahan wil wraak nemen.",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Lenglad is klaar voor een nieuwe sessie",d:"William Lengland moet opnieuw een lesje worden geleerd.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"Tac en Tic",d:"Je moet een tacticus vinden en hem overtuigen om bij Bonta te gaan.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Kaffra Wachter",d:"Oto wil de mening van de Kaffa Wachter weten aangaande zijn aanvalsplan tegen Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Terug naar Oto",d:"Het gevecht is voorbij. Oto wacht op jouw verslag.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Gevecht",d:"Er is een gevecht aan de gang naast Cania Baai, tussen Bonta en Brakmar. Je moet meevechten en zorgen dat Brakmar wint.",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Hamer Oefening",d:"Oto heeft 10 Twiggy Hamers nodig om zijn troepen te trainen.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"De duistere kristal",d:"Je moet via de geheime doorgaan naar de alchemisten werkplaats gaan met meesters van het beroep. Je hebt ook een Gust drankje, Harmonie en Kobalit nodig",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"Misdaad loont niet",d:"Het bericht is verstuurd naar Kapitein Starky. Kijk of Sabine rustig is gebleven terwijl je op een antwoord wacht.",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"Het losgeld",d:"Sabine wordt goed bewaakt, dus je moet een manier vinden om Kapitein Starky een bericht te sturen om een Kain Dharyn Kristal als losgeld te krijgen.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"Goed gedrag",d:"Breng Sabine naar Oto Mustam. Je moet zorgen dat ze niet zal kunnen ontsnappen.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"Koninklijke Veelvraat",d:"Je moet wat Koninklijke Veelvraat Kwijl vinden voor Milone. Je vindt dit slijm bij de Koninklijke Veelvraten, in de Veelvraat Grot.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"Misdaad loont wel, door Brakmar",d:"De Bontarianen hebben geprobeerd Sabine te redden. Daar kun je ze niet mee weg laten komen! Laat ze zien wie de baas is.",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Daag Puja uit",d:"Je moet de uitdaging tegen Puja Mustam, Oto\'s zoon verliezen. Laat je hem jou echt vermoorden? Die snotneus?",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"Nieuw Gebit",d:"Je moet Veelvraat tanden trekken - zoveel als nodig zijn om mensachtig kunstgebit te maken.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"De Grote Schilling",d:"Je moet aardappels schillen voor het eten. De keuken is beneden in de militie.",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"Versla de Manitou Zoth",d:"Je moet Manitou Zoth verslaan en een bewijs van je overwinning meenemen naar Bob de Enutrof.",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Vind de Schildpad.",d:"Je moet een manier vinden om de Fogornleg Hoorn uit Elturt\'s handen te krijgen. De bewoners van Moon Eiland zouden moeten kunnen helpen.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"Terug naar Oto",d:"De tacticus heeft de stad verlaten en dus kan je Oto makkelijk laten geloven dat je hem vermoord hebt.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Temmen van het beest en het dier ook.",d:"Oto Mustam wil het geheim weten om de Witte Tanden te temmen. Ga naar de Bonta Bibliotheek en zoek naar informatie.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"Het neersteken van de haggis",d:"Oto Mustam is overtuigt dat je hem een loer wilde draaien. Je moet dat juweel snel vinden als je de rest van je leven nog wilt meemaken.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"Overwinning!",d:"Xephires accepteert de omstandigheden en is klaar om Bonta te verraden wanneer het moment daar is. Oto zal blij zijn dit te horen.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"Interview",d:"Alles is gereed. Je moet alleen Xephires bezoeken in de Dronken Pandawa kroeg, hem de brief geven en een afspraak maken voor zijn antwoord.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Wraak, mwahahaha.",d:"De schuilplaats van bandieten heeft een val. Je moet een klusjesman van minimaal level 30 meenemen om je te helpen ze te deactiveren.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"Terug naar Amayiro",d:"Het gevecht is voorbij. Amayiro wacht op jouw rapport.",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Schermutseling",d:"Er is een gevecht aan de gang naast Cania Baai, tussen Bonta en Brakmar. Je moet meevechten en zorgen dat Bonta wint.",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Werkaanbod",d:"Oto Mustam wil weten wie de eigenaar van de Verbrande Kat Herberg heeft vermoord.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"Blop Pulp",d:"Je moet Blop Pulp naar Oto brengen. Hij kan je het recept geven.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Vind de Erfenis",d:"Je moet Oto\'s testament vinden in zijn vaders graf - welke je kan herkennen op de begraafplaats aan de bloemen eromheen. Je moet een geest zijn om de begraafplaats op te mogen.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"Contra-Gevecht",d:"Oto heeft je gevraagd hem te ontmoeten op de vlaktes van Cania, vlakbij de ingang van Bonta.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Totale terugeising (slechte gedeeltes)",d:"Er is een Sram die Oto Mustam nog geld schuldig is. Ze heeft hem nog niet terug betaald, dus Oto heeft besloten haar te elimineren. Ze is waarschijnlijk in de illegale gokkamer.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Krijgers Aankleden",d:"Oto vreest een aanval van Bonta en heeft jou gevraagd enkele krijgers uit Brakmar uit te rusten met een specifieke uitrusting.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Vriendjespolitiek",d:"Kosuke Ichazum had gelijk - Latem Sa heeft een contract om de Bontariaanse Militie uit te rusten gekregen door vriendjespolitiek en niet door zijn bekwaamheid als smid.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Breng de Zwaarden",d:"Amayiro heeft gevraagd om 10 Kleine Ridder Zwarden om zijn milities mee uit te rusten.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"Bron van het gefluister",d:"Je moet uitvinden waar de Bron van de Corrupte Zielen is om de volledige kracht van de Corruptah Stenen te ontdekken. Divad Dleifrepok, meester van de Orde van het Gestoorde Geest, kan je helpen.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Gemene alchemie",d:"Je moet een paar Corruptah Stenen bemachtigen. Mijnwerkers zijn de enigen die ze kunnen maken door de onbewerkte creaties van wilde alchemisten te gebruiken.",r:[null,null,null,null,null,null]};
Q.s[903] = {n:"Zeven zielen of geen van allen",d:"Je moet de zielen bemachtigen van zeven bandieten en ze naar de Bron van de Corrupte Zielen brengen. Je moet een paar Brakmarianen vinden die zo gemeen zijn dat ze zich willen specialiseren.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Vind de Spion",d:"Je moet snel de gewonde spion op de weg naar Bonta vinden en de documenten pakken. De spion moet nu dichterbij Bonta dan Brakmar zijn.",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Kroegtijgeren",d:"De Bandiet die dit zwaar bezat is waarschijnlijk naar één van de herbergen gegaan. Daarom moeten de herbergiers meer weten.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Belangrijk Onderzoek",d:"Check de activiteiten van de Brakmariaanse wachters en maak een rapport over degene die geen pauze nemen.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Temmen van het beest en het dier ook.",d:"Oto Mustam wil het geheim weten om de Witte Tanden te temmen. Ga naar de Bonta Bibliotheek en zoek naar informatie.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Op naar Brakmar",d:"De tacticus zal je volgen naar Brakmar.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Nog een verslag",d:"Je moet Trojen Tihpor vinden en naar zijn verslag vragen. Hij is bij de randen van Bonta.",r:[19000,null,null,null,null,null]};
Q.s[859] = {n:"Een Eeuwige Oogst",d:"Je hebt de lijst met wezens... Ga nu en vind ze!",r:[3440000,null,[[9688,18]],null,null,null]};
