Q.s[963] = {n:"Met de sleutel",d:"Oto Mustam wil de uitrusting van Bonta saboteren, dus wil hij het gereedschap van de maker vervangen door 5 Sham Hamers.",r:[null,null,null,null,null,null]};
Q.s[904] = {n:"Met de schep",d:"Oto Mustam is blij met de smid die de Bontariaanse militie van uitrusting voorziet en wil dat je zorgt dat alles door blijft gaan als nu.",r:[null,null,null,null,null,null]};
Q.s[905] = {n:"Met de hand",d:"Latem Sa heeft net nieuwe materialen en nieuw gereedschap gekregen. Je moet snel zijn nu hij weg is. Hij is weg tussen vijf en negen uur, dan kun je naar binnen om de materialen te stelen en het gereedschap te verruilen.",r:[122000,null,null,null,null,null]};
