Q.s[720] = {n:"Grace\'s Tabi",d:"Grace Malcean heeft problemen met haar Tabi, in Bonta.",r:[25000,null,null,null,null,null]};
Q.s[919] = {n:"Flip die Eca als een pannenkoek",d:"Nu kun je de sleutels maken en de schuilplaats van de bandieten onderzoeken naar hints. Je zult een klimtouw nodig hebben om daar te komen.",r:[80000,null,null,null,null,null]};
Q.s[916] = {n:"Dicht bij de afsluiting",d:"Je moet de sleutel naar de schuilplaats vinden, wat betekent dat je de bandiet moet vinden die de sleutel heeft. Hersa\'s ex-geliefde kan degene zijn.",r:[null,null,null,null,null,null]};
Q.s[917] = {n:"Breek de mal niet",d:"Maak kopieën van de sleutel van de schuilplaats van de bandieten, ga dan met een groep naar binnen en pak alle documenten die gebruikt kunnen worden voor het onderzoek.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Illegale Activiteiten",d:"Er gebeuren vreemde dingen in het Bakkers district. Amayiro vroeg je het te onderzoeken.",r:[17000,null,null,null,null,null]};
Q.s[689] = {n:"Staf Training",d:"Amayiro vroeg je om hem 20 Twiggy Staffen te brengen om zijn troepen te trainen.",r:[4000,null,null,null,null,null]};
Q.s[718] = {n:"Danathor\'s Verzoek",d:"Danathor heeft naar je geschreven en vroeg je om hulp.",r:[11500,null,null,null,null,null]};
Q.s[719] = {n:"Larry Poller",d:"Larry Poller vroeg je om hulp. Je kunt hem dicht bij de Toren van Bonta vinden.",r:[11500,null,null,null,null,null]};
Q.s[1035] = {n:"Ontdek het geheim van het standbeeld",d:"Percimol heeft het geheim bij de voet van het standbeeld verstopt. Kruip op je handen en knieën en zoek er naar.",r:[null,null,null,null,null,null]};
Q.s[751] = {n:"Help Raaga",d:"Vind Raaga in de mijnen naar het noorden en vraag om zijn verslag.",r:[13500,null,null,null,null,null]};
Q.s[738] = {n:"Het Spionnen Verslag",d:"Oto vroeg of je de spion Finche Aticus in Bonta wilde zoeken en zijn rapport wilde brengen.",r:[5200,null,null,null,null,null]};
Q.s[743] = {n:"Zoektocht voor Magisch Gif",d:"Je moet iemand vinden in Brakmar die weet hoe je een magische gifdrank moet maken.",r:[8200,null,null,null,null,null]};
Q.s[335] = {n:"Aan het werk",d:"Vraag aan de opzichter wat je moet doen.",r:[250,250,null,null,null,null]};
Q.s[382] = {n:"Ga aan het Werk",d:"Vraag de voorman wat je moet doen.",r:[250,250,null,null,null,null]};
Q.s[383] = {n:"Ga aan het Werk",d:"Vraag de voorman wat je moet doen.",r:[250,250,null,null,null,null]};
Q.s[784] = {n:"Niets is Onmogelijk voor een Hart dat wil",d:"Je moet een lid van de Terra familie vinden en ze naar Jerhyn Gholein brengen. Setag - meester van de Enutrof klasse - kan je helpen.",r:[200000,null,null,null,null,null]};
Q.s[956] = {n:"Bevelen of Terugroepen?",d:"Het huidige plan van aanvallen is nog niet bevestigd. Zoek naar bevestiging of verander de plannen van Kapp Tenn en rapporteer aan Amayiro.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Plan van aanval",d:"Amayiro heeft je gevraagd de diefstal van Vilard\'s document te onderzoeken. Kikim, de waard, heeft misschien informatie.",r:[null,null,null,null,null,null]};
Q.s[358] = {n:"Training",d:"Je moet alle stro uit de levende vogelverschrikker slaan.",r:[25,null,null,null,null,null]};
Q.s[755] = {n:"Hout voor Oto",d:"Oto wil 10 Treechnid barsten als brandhout.",r:[16300,null,null,null,null,null]};
Q.s[946] = {n:"Inschrijven, zei hij.",d:"Snori Nairb heeft je in de Brakmariaanse Militie gekregen, maar hij heeft het onofficieel gedaan. Om het officieel te maken, moet je met Oto Mustam praten.",r:[null,null,null,null,null,null]};
Q.s[945] = {n:"Inschrijven, zei hij.",d:"Snori Nairb heeft je in de Bontariaanse Militie gekregen, maar hij heeft het onofficieel gedaan. Om het officieel te maken, moet je met Amayiro praten.",r:[null,null,null,null,null,null]};
Q.s[752] = {n:"Vind de Spion",d:"Een spion is Brakmar ontvlucht met vertrouwelijke documenten. Een van de wachters ten noorden kan hem gezien hebben.",r:[14200,null,null,null,null,null]};
Q.s[979] = {n:"Versla de Dopple",d:"Als je de Dopple verslaat, zal de gevechtsmeester je belonen.",r:[null,null,null,null,null,null]};
Q.s[503] = {n:"Zilver, Hout en Gereedschap",d:"In de mijn van Porco\'s Territorium, heeft Nara de hoefsmid 20 silvereenheden nodig, 20 stukken Ebbenhout en een werktuig dat gevonden kan worden in Norb\'s werkplaats",r:[140000,null,null,null,null,null]};
