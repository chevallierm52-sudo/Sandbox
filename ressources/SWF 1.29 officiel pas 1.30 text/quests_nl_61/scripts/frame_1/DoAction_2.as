Q.s[704] = {n:"Lyeno Redden",d:"Je moet Kolonel Lyeno redden. Hij verdween in het oosterlijke gedeelte van het Treechnid Woud.",r:[12800,null,null,null,null,null]};
Q.s[722] = {n:"Nog een Verzoek van de Kok",d:"De kok van de militie heeft je hulp weer nodig.",r:[31000,null,null,null,null,null]};
Q.s[1088] = {n:"Speelgoedfabriek",d:"Weerzinwekkende wezens hebben ingebroken in de werkplaats van Vader Kwismas . Je moet de cadeau\'s terugvorderen die zij hebben gestolen, met of zonder hun toestemming, en ze daarna aan Harry Kwismas geven.",r:[null,1000,[[10920,1]],null,null,null]};
