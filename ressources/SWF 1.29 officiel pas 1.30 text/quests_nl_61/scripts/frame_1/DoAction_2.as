Q.s[726] = {n:"Mak Verslaan",d:"Versla Mak Gahan en breng zijn botten naar Oto Mustam.",r:[50,null,null,null,null,null]};
Q.s[536] = {n:"Vang de Spion",d:"Een spion uit Bonta is in de Toren geïnfiltreerd en heeft de documenten gestolen. Gebruik een Zaap en onderschep hem. Hij moet ergens op de oostelijke weg naar Bonta zijn, maar nog wel dichtbij Brakmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Alles is goed voor de Rogues.",d:"Nu je precies weet waar de schuilplaats van de Rogues is, hoef je alleen de informatie nog maar na te kijken.",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"Verhalen van de Tombe.",d:"Je moet de vijf tombes op de begraafplaats van Amakna bezoeken.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"Voor een paar Rogues meer...",d:"Je moet infiltreren tussen de Rogues en met Vil Smisse praten.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"Hete Aardappel",d:"Oto heeft je gevraagd 10 aardappelen te schillen en ze hem te brengen.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"Aankleden van Magier",d:"Oto heeft je gevraagd 2 Knuppels Tmosfer te brengen om zijn magiërs mee uit te rusten.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"Brakmariaanse Mantels",d:"Oto vroeg om 5 Brakmariaanse mantels. Hij kan je vertellen hoe je ze maakt.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Water Verhalen",d:"Danaida is water nodig voor haar nymphettes",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"Onderzoek naar een Hoorn",d:"Oto wil dat je wat onderzoek doet naar de hoorn, op Maan Eiland.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"Informatie over de Kapitein",d:"Je moet een manier vinden om met de overleden kapitein Tsog te praten om de informatie te krijgen die hij door wil geven. Kapitein Alrok weet waar Tsog zijn graf is.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Vind de Schuldige",d:"Vind de moordenaar Rimaraf en breng het ingevulde formulier naar Amayiro.",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Vals Bewijs",d:"Vind een manier om Amayiro te misleiden door hem vals bewijs te tonen. Danathor kan je hier mee helpen.",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"Rattenbloed",d:"Amayiro vroeg je 4 Hyoactieve Ratten te vermoorden in de riolen van Bonta.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Betrouwbare Mensen",d:"Amayiro heeft betrouwbare mensen nodig om deel te nemen in de presentatie van de valse krachten van de magische hoorn.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"Een Nauwgezette Prestatie",d:"Amayiro vraagt om je hulp om deze presentatie af te maken. Hij heeft Miteters nodig, deze vind je bij Cracklers en Koninklijk Jelly Vet (ongeacht welk soort).",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"Nog meer verzamelen...",d:"De Cras trekken zich handig terug, of beter gezegd, hun pijlen. Zieke Arachneepoten bevatten blijkbaar een bepaalde substantie om gif te maken... zaken zijn zaken...",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"De schreeuw van de gek",d:"Toz vraagt om een woodywood schop om z\'n anti-apocalypse hol te bouwen.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"Brood op de plank",d:"Om z\'n onverwoestbare hol te bouwen, vraagt Toz om twee kastanjehouten planken en een paar broden om ten minste voor 3 dagen de ramp te kunnen overleven...",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Ratatouille",d:"Je moet de benodigde ingrediënten combineren in de prehistorische ketel: een voorwerp van elk type en een alchemist, een bakker, een boer, een slager en een vishandelaar.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"Salade Zoeken",d:"Je moet 10 sla blaadjes naar Oto brengen om ze te vullen met stuifmeel.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Dieren zijn ook vrienden.",d:"Amayiro wil meer weten over Elturt. Oshimo, de wachter van de Kennel, zal vast meer informatie over de schildpad hebben.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Iedereen houdt van lenald.",d:"Elturt heeft in het verleden wat tijd doorgebracht met de Lenalds. De Lenalds, ten zuiden van Wabbit Eiland, herinneren hem misschien nog steeds.",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Verzamel Ondergoed",d:"Je moet Bontariaanse militieleden verslaan en... hun ondergoed afnemen. Oto heeft er 5 van nodig.",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Haast Hout",d:"Haal wat Haasthout: door jezelf op te offeren voor de natuur, krijg je er een band mee.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Ritueel",d:"Zoek de persoon die je kan helpen met het maken van je nieuwe staf.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Je talenten tonen",d:"Je talenten ontwikkelen zich, maar daar is nog niet iedereen van overtuigd.",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"Terug naar Moon.",d:"De zogenoemde wachter van de Fogornleg Hoorn bevindt zich diep in de Moon Eiland jungle. Volgens de geruchten, moet je een Ambushheadgear en wat Greedoburg dragen voor hij verschijnt.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"Kanigers en Saffier",d:"Je moet bepaalde ingrediënten verzamelen om het juweel te maken, inclusief 15 Kaniger Nagels en een Saffier, die kun je vinden bij Krakrotsen.",r:[80000,null,null,null,null,null]};
Q.s[1063] = {n:"Speelgoedfabriek",d:"Weerzinwekkende wezens hebben ingebroken in de werkplaats van Vader Kwismas . Je moet de cadeau\'s terugvorderen die zij hebben gestolen, met of zonder hun toestemming, en ze daarna aan Harry Kwismas geven.",r:[null,1000,[[10920,1]],null,null,null]};
