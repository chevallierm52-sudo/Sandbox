Q.s[409] = {n:"Volg Me als je van me houdt!",d:"De pwince van Wa vroeg je om een suite goed genoeg voor hem klaar te maken... In gedachte van zijn mogelijkheden, zijn particuliere dieet en zijn ehtische betekenis, hij heeft op zijn minst vier personen nodig om hem te assisteren.",r:[45000,null,null,null,null,null]};
Q.s[693] = {n:"Breng het Poeder",d:"Je moet tien eenheden buskruit naar Amayiro brengen. Je kunt het kopen van Moob Tsinhcetoryp in Bonta.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"Onbekende Bezwering",d:"Amayiro vroeg je om Zeurg (meester van de Osamodas klasse) te vinden en met hem te praten over een onbekende bezwering van Brakmar.",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Vind een Gebrek",d:"Je moet een interessant gebrek vinden in de mechanismes van de poort naar Brakmar.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"Bezoek de Aanvalscommandant",d:"De aanvalscommandant wacht op jou om de aanval te beginnen. Hij wacht naast de ingang van de Begraafplaats van de Gemartelden.",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Terechte Paranoia",d:"Als laatste redmiddel, heeft Oto je gevraagd Nara - de hoefsmid te vermoorden, op het grondgebied van Porco.",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"Milone de Juwelier",d:"Volgens Bishom Pot, weet Milone Corichel - de juwelier van Brakmar iets.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"Bishom Pot keert terug",d:"Amayiro verdenkt Brakmar er van de bron van Bonta\'s problemen te zijn. Als spion voor de milities in Brakmar heeft Bishom Pot misschien wat geleerd.",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Weerzinwekkend gewelf",d:"Slechts acht moedige avonturiers zijn in staat om het eind van dit gewelf te bereiken!",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Mysterieus gewelf",d:"Een steen hoog in een berg en een geheime deur... Je hebt vrijwilligers nodig om aan het eind van deze galerij te komen...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"De kelder van de Bibliotheek",d:"Zoals bij alle bibliotheekkelders, vind je er allerlei soorten boeken en arachnee-spinnenwebben... maar in deze hangt een mysterieus sfeertje...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Donker gewelf",d:"Een geheime deur in de berg geeft toegang tot een gewelf. Maar je moet nog wel uitzoeken hoe...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Ontoegankelijk gewelf",d:"Pas op de Drakei! Je moet hun terrein over om bij deze nieuwe grot te komen...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Gevaarlijk gewelf",d:"Van dit gewelf kun je je geduld verliezen!",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Bezoek de Herbergier",d:"Je moet Amayiro\'s kaart en een bier halen bij de Feubuk Kroeg.",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"Hete Aardappel",d:"Je moet 200 aardapeels schillen en ze naar de kok van de militie brengen.",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"Een Champo voor Amayiro",d:"Amayiro vroeg je hem een Standaard Champo te brengen. Je kunt ze vinden bij Fungi Meesters.",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Pinta Gone wil het recept lezen",d:"Alle materialen voor het brouwen van z\'n bier zijn gekocht. Nu alleen het recept nog.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Zoek het Bwork bierrecept",d:"Pinta Gone zoekt het recept van het beroemde Bwork bier. Volgens hem ligt dat in een vreemde kamer in het Bwork gebied.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Oppakken van de Sla",d:"Je moet teruggaan en deschildpad bandana ophalen die bewaakt wordt door Wobots in de Wa Wabbit Kerker.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"Hoog Risico Mode",d:"Je moet een manier vinden om de bandana weer in ere te herstellen. Een kleermaker moet kunnen helpen.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Ruw Herstel.",d:"Je hebt de spion op tijd gevonden, maar de Brakmarianen vinden het niet fijn dat jij de documenten hebt. Bezorg ze bij  Amayiro, wat het ook kost.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"Een klein grapje tussen vijanden.",d:"De Brakmarianen moeten de documenten aan hun leiders geven. Je hebt wat valse documenten opgesteld om ze te vervangen en stuurt je vijanden het bos in.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Race tegen de klok.",d:"Een spion uit Bonta ontsnapt uit de oosterlijke weg van Brakmar. Je moet hem vinden en escorteren. Schiet op! Je tijd is geteld!",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Onfatsoenlijk verslag",d:"Iemand heeft een verslag geschreven dat je zwaar bekritiseerd. Het is in de Bonta Toren van Ordes. Je moet het zo snel mogelijk in handen krijgen om je onschuld te bewijzen.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"Je hebt goederen nodig om te leven",d:"Amayiro heeft je gevraagd om goederen te brengen aangezien de voorraad kleiner en kleiner wordt (10 Kaniger Oren en 3 Blop in elke kleur).",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Torende gelijkheid",d:"Vind een medeplichtige om de wachters af te leiden terwijl jij de documenten steelt.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"Speelgoedfabriek",d:"Weerzinwekkende wezens hebben ingebroken in de werkplaats van Vader Kwismas . Je moet de cadeau\'s terugvorderen die zij hebben gestolen, met of zonder hun toestemming, en ze daarna aan Harry Kwismas geven.",r:[null,1000,[[10920,1]],null,null,null]};
