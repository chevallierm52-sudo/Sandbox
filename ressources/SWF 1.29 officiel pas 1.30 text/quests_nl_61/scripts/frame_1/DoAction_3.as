Q.s[461] = {n:"Informatie in de Bagrutte",d:"De lokale wijnhandelaar is verdwenen. De herbergier Bargrutte heeft misschien wat informatie.",r:[null,null,null,null,null,null]};
Q.s[462] = {n:"Onderzoek verder naar het Oosten",d:"Volgens Bagrutte, was de handelaar gewend om naar huis te gaan, een klein stukje naar het oosten.",r:[60000,null,null,null,null,null]};
Q.s[575] = {n:"Zoektocht naar de Hamer",d:"Ebru van El herinnert zich een Hamer van het Licht dat verlaten in één van de grafkelders van de Begraafplaats van Amakna ligt.",r:[272000,null,null,null,null,null]};
Q.s[574] = {n:"Info over de Hamer",d:"Ebru van El zoekt een Hamer van het Licht en heeft jou gevraagd te praten met de volgende klas meesters in hun tempels: Cra, Ecaflip, Eniripsa, Feca, Iop en Sacrier.",r:[null,null,null,null,null,null]};
Q.s[584] = {n:"In Dienst van Ebru",d:"Amayiro heeft je geïnformeerd dat Ebru van El je nodig heeft. Je vindt hem in de Toren van Bonta.",r:[null,null,null,null,null,null]};
Q.s[512] = {n:"Sufokia.",d:"Het gerucht gaat dat er een hoorn met magische krachten is. De inwoners van Sufokia hebben er meer informatie over.",r:[null,null,null,null,null,null]};
Q.s[513] = {n:"Schildpaddenschilden.",d:"De waard van de Ripate Herberg wil dat je hem schildpaddenschilden brengt van Moon - één in elke kleur. Maar misschien werkt een grote hoeveelheid Kamas ook wel...",r:[null,null,null,null,null,null]};
Q.s[935] = {n:"Kokojongen.",d:"Het zou een aardig gebaar zijn om Kokonuts te vergaren voordat we naar Amayiro gaan, vind je niet?",r:[170000,null,null,null,null,null]};
Q.s[934] = {n:"Hoorn om wild van te worden.",d:"Volgens de waard van de Ripate Herberg, kan de hoorn worden gevonden op een eiland. De leraren moeten je meer kunnen vertellen.",r:[null,null,null,null,null,null]};
Q.s[697] = {n:"Onderzoek op de Kermis",d:"Je moet een formulier vragen aan Ture Inge, in de militie, en dan de baas van de Trool Kermis ondervragen om te zien of hij een Brakmariaan is of niet.",r:[8200,null,null,null,null,null]};
