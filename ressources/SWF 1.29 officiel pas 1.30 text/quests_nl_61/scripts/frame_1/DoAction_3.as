Q.s[758] = {n:"Vind een duistere Bontariaan",d:"Je moet een Bontariaanse huurmoordenaar vinden. Om deze missie af te ronden, heb je een van Fryda\'s Snuivende Staffen nodig. Gebruik het op alle Bontarianen die je tegenkomt tot je de juiste vindt.",r:[21000,null,null,null,null,null]};
