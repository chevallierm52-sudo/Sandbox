Q.s[171] = {n:"skedaddling...",d:"Het lijkt er op dat je niet welkom bent in Aerdala... Ben je er toe in staat om door deze moeilijke bestemming te komen? Dit moet wel zo zijn...",r:[10000,null,null,null,null,null]};
Q.s[169] = {n:"Aerdala bezoeken",d:"De boodschapper van Lenald de Wijze verzoekt je om naar de rand van het dorp Aerdala te gaan. Onderweg zul je zijn laatste woorden mediteren: “Vele avonturiers zijn niet zo vriendelijk ontvangen in Aerdala. Het is gezegd dat de mensen daar bondgenoten zijn met de Pandawas rebellen welke elke toegang saboteren tot het eiland.\"",r:[2000,null,null,null,null,null]};
