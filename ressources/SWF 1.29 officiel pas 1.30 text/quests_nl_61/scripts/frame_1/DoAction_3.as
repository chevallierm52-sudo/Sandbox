Q.s[976] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[570] = {n:"",d:"Divad weet van Domen\'s plannen, maar hij kan het nog steeds proberen bij Kaffra. Kaffra moet de gifdrank drinken in de veronderstelling dat het een eenvoudige Bloody Mary is.",r:[null,null,null,null,null,null]};
Q.s[569] = {n:"",d:"Laat de gifdrank op David\'s tafel staan zolang hij er niet is of wat anders aan het doen is.",r:[304000,null,null,null,null,null]};
Q.s[672] = {n:"Divad Achterhalen",d:"Oto vroeg of je Divad kon observeren en bevragen, in de Toren van Brakmar.",r:[null,null,null,null,null,null]};
Q.s[673] = {n:"",d:"Oto vroeg je om Divad te beroven van Dleifrepok\'s ring en Shush Tercesasti\'s hanger door slaap rollen te gebruiken.",r:[null,null,null,null,null,null]};
Q.s[651] = {n:"Onderzoek naar de Onruststoker",d:"Oto vroeg je terug naar de grot te gaan om het voorwerp dat je achterliet, om bewijzen te vinden over de indringer die zich mengde in het geschil.",r:[338000,null,null,null,null,null]};
Q.s[583] = {n:"Doorzoeken van het Kasteel",d:"As\'Ruoy\'Dnim heeft je opgedragen in het kasteel van Amakna te zoeken naar informatie over zijn kettingen.",r:[null,null,null,null,null,null]};
Q.s[582] = {n:"De Toren van Gisgoul",d:"Ga naar de Toren van Gisgoul, plaats een Gobball Maag op het altaar, en ga naar het zuid-oostelijke punt in de kamer (tussen de twee pilaren) om zo de persoon te vinden die met je wilt praten.",r:[null,null,null,null,null,null]};
Q.s[601] = {n:"Ontvoeren",d:"Fallanster is weg. Je missie is om Allisteria te ontvoeren. Ze zorgt voor haar Gobballs naast Astrub.",r:[null,null,null,null,null,null]};
Q.s[602] = {n:"Mislukte Ontvoering",d:"Allisteria is ontsnapt en heeft de wachter tijdens het gevecht gewaarschuwd. Laten we ervandoor gaan!",r:[410000,null,null,null,null,null]};
Q.s[595] = {n:"Onderzoek van Fallanster",d:"As\'Ruoy\'Dnim stuurde je naar Astrub om informatie te vinden over Fallanster. Zoals gewoonlijk, vertelde hij je er niet meer dan nodig is over. Wie kan je meer informatie geven?",r:[null,null,null,null,null,null]};
Q.s[677] = {n:"Finche Achtervolgen",d:"Fince Aticus heeft een tijdje geen rapporten meer uitgebracht. Oto vroeg of je hem wilde gaan zoeken en wil uitzoeken wat er aan de hand is in Bonta.",r:[null,null,null,null,null,null]};
Q.s[780] = {n:"null",d:"",r:[500000,250000,null,null,null,null]};
Q.s[586] = {n:"Vind Mankracht",d:"Je moet de benodigde mankracht vinden om de tempel te bouwen. Een specifiek naief volk het liefst.",r:[420000,null,null,null,null,null]};
Q.s[585] = {n:"Materiaal voor de Tempel",d:"As\'Ruoy\'Dnim heeft je opgedragen hem 50 eenheden ijzer, 10 eenheden kool, 10 Crackler Stenen en 20 eenheden tin te brengen om zijn tempel te bouwen.",r:[null,null,null,null,null,null]};
Q.s[657] = {n:"Verover Gebieden",d:"Je moet de territoria veroveren die op Oto\'s notitie staan.",r:[240000,null,null,null,null,null]};
Q.s[649] = {n:"Confrontatie",d:"Oto Mustam kleineerde je! Duidelijk, dit moet een grapje zijn!",r:[null,null,null,null,null,null]};
Q.s[737] = {n:"Vergif Verzamelen",d:"Oto Mustam heeft 20 stuks nodig voor zijn Scheurbuik gif.",r:[4600,null,null,null,null,null]};
Q.s[485] = {n:"Vergif Verzamelen",d:"Spionnen in Bonta hebben een speciaal en zeldzaam gif nodig dat alleen Bwork Magi heeft.",r:[null,null,null,null,null,null]};
Q.s[906] = {n:"Waar de zon niet schijnt",d:"Vind een schuilplaats voor de spionnen tussen hun huidige schuilplaats en de bibliotheek. Verwijder de huidige bewoners als dat nodig is.",r:[128000,null,null,null,null,null]};
Q.s[535] = {n:"Kleine Mislukking",d:"Sporen van een recent gevecht, twee wapens op de grond, een dode Sram... Het bewijs zegt dat je het niet op tijd gered hebt.",r:[205000,null,null,null,null,null]};
Q.s[918] = {n:"Exoram de Sram",d:"Je hebt Exoram naar de Sram tempel gebracht. Deze keer kun je ze beter vertellen wat je beloofd hebt te doen.",r:[70000,null,null,null,null,null]};
Q.s[892] = {n:"Sommige Srams hebben ze",d:"Exoram heeft zich weer in moeilijkheden gebracht. Als je informatie over Xephires zoekt, zul je hem weer moeten helpen.",r:[null,null,null,null,null,null]};
Q.s[447] = {n:"Dankbaarheid",d:"Exoram zag vreemde mensen in het noorden en wil zeker weten dat zij weg zijn voordat hij meer vertelt.",r:[null,null,null,null,null,null]};
Q.s[448] = {n:"Vermissend!",d:"Exoram blijkt verdwenen te zijn in het bos. Je enige mogelijkheid is terug te gaan naar Oto.",r:[null,null,null,null,null,null]};
Q.s[493] = {n:"In de Porcos\' Grot",d:"Oto wil de hoefsmid van Porco\'s grot voor zich winnen in de Brakmariaanse strijd.",r:[152000,null,null,null,null,null]};
Q.s[759] = {n:"Leer Nederigheid",d:"Oto vroeg je hem 40 Blauwe Larve ogen te brengen.",r:[23000,null,null,null,null,null]};
Q.s[760] = {n:"Raak de Gouden Larve kwijt",d:"Je moet een manier vinden om van deze aanklevende Gouden Larve af te komen die je altijd volgt.",r:[25000,null,null,null,null,null]};
Q.s[452] = {n:"Een tijdelijke... misser",d:"Xephires weigert je bod, maar niet alle hoop is verloren. Via een juweel kun je alsnog krijgen wat je wilt. Ga naar de juwelier Milone, hij kan je helpen.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"Bijeenkomst",d:"Nu je ontdekt hebt waar Xephires is, moet je naar de Dronken Pandawa Kroeg gaan en hem een bod doen. Hij is daar vanaf 4 uur vanmiddag.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"Een Bericht om door te geven",d:"Oto wil dat je zijn boodschap overbrengt aan Vil Smisse, in het Gladjanussen Hol - wat op de Begraafplaats van Amakna is.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"Nieuw Gevaar",d:"Verschillende krijgers uit Brakmar zijn gevallen en dood achtergelaten op de weg naar Astrub. Ga dit onderzoeken.",r:[140000,null,null,null,null,null]};
Q.s[747] = {n:"In de Belasting",d:"Je moet Oto\'s nieuwe belasting gaan innen in iedere Brakmariaanse herberg. En als het lukt moet je de herbergiers laten betalen.",r:[10700,null,null,null,null,null]};
Q.s[889] = {n:"Een X Brief",d:"Achterhaal de identiteit van deze beroemde X. De brief vertelt een plek waar die vaak kwam. Als je deze plek vindt, zul je meer informatie vinden.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Terug naar Oto",d:"Je moet een interessant stuk papier vinden en dit aan Oto laten zien.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"Doorzoek de Toren",d:"Je moet in Bonta een zeer belangrijk persoon vinden die corrupt schijnt te zijn. Oto stelde voor dat je zoekt in de Toren.",r:[null,null,null,null,null,null]};
Q.s[792] = {n:"Op zoek naar de blauwe Klerk",d:"Ybaul, Klerk van de Orde van het Moedige Hart, heeft de kroegen afgezocht sinds zijn kat verdween. Breng hem terug naar Jerhyn Gholein.",r:[null,null,null,null,null,null]};
Q.s[793] = {n:"Op zoek naar de Klerk",d:"Ybaul, Klerk van de Orde van de Heilige Geest, heeft de kroegen afgezocht sinds zijn broer verdween. Breng hem terug naar Elviana Tirips.",r:[null,null,null,null,null,null]};
Q.s[795] = {n:"Hart Bot",d:"Kaffra Kyper heeft je gevraagd hem 1 Chafer Bot te brengen om je waarde te bewijzen.",r:[null,null,null,null,null,null]};
Q.s[797] = {n:"Zijwaarts Kijken",d:"Shush Tercesasti vroeg je om hem 1 Kraaienoog te brengen om je waarde te bewijzen.",r:[null,null,null,null,null,null]};
Q.s[210] = {n:"Overtref Jezelf",d:"Zonder gezag is het meesterschap waardeloos. Dat is de voorwaarde op een Djaul Discipel te worden. Het doel van de test is simpel. Je moet je machtstegenstander, die zich verschuilt in het Dopple dorp, verslaan.",r:[200000,null,null,null,null,null]};
Q.s[796] = {n:"Fantashtisch",d:"Divad Dleifrepok vroeg je om hem 1 Bwork Magiers Baardhaar te brengen om je waarde te bewijzen.",r:[null,null,null,null,null,null]};
Q.s[1071] = {n:"Speelgoedfabriek",d:"Weerzinwekkende wezens hebben ingebroken in de werkplaats van Vader Kwismas . Je moet de cadeau\'s terugvorderen die zij hebben gestolen, met of zonder hun toestemming, en ze daarna aan Harry Kwismas geven.",r:[null,1000,[[10920,1]],null,null,null]};
