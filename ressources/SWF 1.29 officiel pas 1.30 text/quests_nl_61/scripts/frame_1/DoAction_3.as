Q.s[619] = {n:"Wachters Gewenst!",d:"Ga naar Brakmar en probeer een oplossing te vinden voor As\'Ruoy\'Dnim\'s wachtersprobleem. Oto Mustam of de Magiër van de Toren kunnen je misschien helpen.",r:[null,null,null,null,null,null]};
Q.s[624] = {n:"Ziel Gevangen nemen",d:"Gebruik Shush\'s zielsteen om dit te vangen: 5 Cracklers, 2 Donkere Treechnids, 2 Kanigers, 4 Ouginaks, 5 Neyes en 3 Crocodyls. Ze zullen automatisch gevangen worden.",r:[450000,null,null,null,null,null]};
