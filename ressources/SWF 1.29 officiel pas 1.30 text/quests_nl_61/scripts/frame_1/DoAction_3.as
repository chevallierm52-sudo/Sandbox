Q.s[632] = {n:"Een Bijdetijds Verhaal",d:"Je bent er eindelijk in geslaagd het betoverde boek van Xelor Magus te vinden. Breng het nu naar Elviana Tips bij de Toren van Bonta.",r:[410000,null,null,null,null,null]};
Q.s[630] = {n:"Op het Bad van het Artefact",d:"Elviana Tips vraagt je naar de bibliotheek te gaan en informatie over één of meerdere boeken te verzamelen die over het onderwerp gaan.",r:[null,null,null,null,null,null]};
Q.s[631] = {n:"Betoverd Boek",d:"Elviana Tips heeft een idee. Ze wil het boek hebben dat door een Xelor meester is betoverd zodat het,het resultaat van het verhaal onthult.",r:[null,null,null,null,null,null]};
