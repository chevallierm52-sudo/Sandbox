Q.s[798] = {n:"De ontvoering van Dike Tarak.",d:"Ebru van El heeft je gevraagd Dike Tarak, de neef van Amayiro die werd ontvoerd tijdens een excursie naar de Cania Plains te vinden.",r:[null,null,null,null,null,null]};
Q.s[799] = {n:"Area 51",d:"Je bent ervan overtuigd dat het vreemde object dat je gevonden hebt in het kamp is gekoppeld aan de ontvoering van Dike Tarak. Nu alleen nog uit vinden hoe.",r:[null,null,null,null,null,null]};
