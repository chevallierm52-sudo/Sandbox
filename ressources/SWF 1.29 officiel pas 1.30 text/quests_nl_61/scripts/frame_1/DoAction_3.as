Q.s[604] = {n:"Bezettingsleger",d:"Na jouw rapport, heeft Danathor troepen gestuurd om de beste mijnen van het gebied te bezetten. Je moet de Chef van de Amakneaanse Militie inlichten dat de mijnen onder Bontariaanse controle zijn.",r:[null,null,null,null,null,null]};
Q.s[603] = {n:"De Mijn is van Mij...",d:"Vrezend voor nieuwe acties van de Brakmariaanse troepen, heeft Danathor besloten de mijnen van Amakna te bezetten en de opbrengsten te gebruiken om zijn troepen te versterken.",r:[null,null,null,null,null,null]};
Q.s[993] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[606] = {n:"Kies je Kant - Deel II",d:"Sergeant Graccia gaf jou een brief om aan Amayiro te geven. Maar je kunt ook beslissen deze brief aan Danathor te geven. Welke kant kies je?",r:[329000,null,null,null,null,null]};
Q.s[609] = {n:"Identificatie",d:"Amayiro heeft je gevraagd het gif te identificeren in de Rasputin Cake. Magus Ax kan je misschien helpen.",r:[null,null,null,null,null,null]};
Q.s[610] = {n:"Onderzoek binnen de Militie",d:"Amayiro heeft je gevraagd de moordpoging te onderzoeken. Hij wil weten wie het gif in de cake heeft gestopt.",r:[356000,null,null,null,null,null]};
