Q.s[627] = {n:"Iets Rottends in Gisgoul",d:"De spion rapporteert over vreemde activiteiten in de ruïnes van Gisgoul. Amayiro vraagt je met de verkenners te gaan en uit te zoeken wat er werkelijk gaande is.",r:[null,null,null,null,null,null]};
Q.s[628] = {n:"Vreemde Gebeurtenissen bij de Toren van Gisgoul",d:"Een Brakmariaan komt spontaan te voorschijn in de offerkamer. Het is vreemd. Onderzoek de plaats en ga terug naar Amayiro om je rapport uit te brengen.",r:[null,null,null,null,null,null]};
Q.s[664] = {n:"Aardige Oude Jerhyn!",d:"Jerhyn wil je zien (bij de Toren van Bonta). Haar kennende, kun je maar beter opschieten.",r:[null,null,null,null,null,null]};
Q.s[663] = {n:"Bontariaanse Hegemonie",d:"Om de Bontariaanse hegemonie te versterken, moet je de territoria controleren die op de notitie staan die Jerhyn je gaf.",r:[470000,null,null,null,null,null]};
