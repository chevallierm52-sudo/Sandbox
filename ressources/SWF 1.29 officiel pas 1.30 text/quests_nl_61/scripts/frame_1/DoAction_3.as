Q.s[334] = {n:"Knoflookpakket",d:"Gobriel heeft er genoeg van dat de andere Goblins hem bekogelen met stenen vanwege zijn huidskleur. Hij zou graag een engel willen zijn.",r:[30000,null,null,null,null,null]};
Q.s[351] = {n:"De Verhaal Connectie",d:"Als je meer wilt leren over het verhaal van lop\'s zwaard, vraag het aan Danaida in de Tempel.",r:[75,null,null,null,null,null]};
Q.s[348] = {n:"Welkom",d:"Welkom",r:[null,null,null,null,null,null]};
Q.s[349] = {n:"Piwi",d:"Piwi piwi piwi piwi piwi!",r:[250,null,[[6897,2],[8537,1]],null,null,null]};
Q.s[346] = {n:"Shaa Kwira",d:"Ga kijken waar Shaa Kwira is.",r:[25,null,null,null,null,null]};
Q.s[332] = {n:"Vroege wol",d:"Jicé is slim, hij weet nu dat je met wol... wol kunt maken.",r:[120,150,null,null,null,null]};
Q.s[344] = {n:"Nog een Bezorging",d:"Deze keer moet je een voorwerp naar Xelor brengen die aan een Zaap werkt.",r:[150,null,null,null,null,null]};
Q.s[416] = {n:"Konijnenpak",d:"De pwins van Wa vraagt jou om zijn plek over te nemen en de moordenaars te ontmaskeren. Maar eerst moet je iemand zien te vinden die jou in een Wabbit kan veranderen.",r:[15000,null,null,null,null,null]};
Q.s[415] = {n:"Help!",d:"De pwins van Wa wordt aangevallen. Bescherm hem!",r:[5000,null,null,null,null,null]};
Q.s[417] = {n:"Winkelen",d:"Nu de formule compleet is, heb je de ingrediënten nodig",r:[120000,null,null,null,null,null]};
Q.s[390] = {n:"Dilemma...",d:"Nu je weet dat Yse Vewybad samenspant tegen de Koning, moet je een kant kiezen.",r:[2000,null,null,null,null,null]};
Q.s[665] = {n:"William Lenglad, de Wederkomst",d:"William Lengland grijpt de gelegenheid om met hem te praten en om ieders hart met haat te vullen. En deze keer helpt zelfs een vreemde Eniripsa hem. Kijk uit voor die Eniripsa.",r:[null,null,null,null,null,null]};
Q.s[666] = {n:"",d:"Vele milities zijn boos sinds de laatste aanval van Brakmar en vragen om gevarengeld. Amayiro vraagt je een bonus aan de boze mensen uit te keren.",r:[347000,null,null,null,null,null]};
Q.s[254] = {n:"Een Lekker Maaltje",d:"Lorkos zal je een sleutel van het labyrinth geven, als je hem alle ingrediënten geeft voor een lekkere maaltijd.",r:[null,null,null,null,null,null]};
Q.s[255] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[645] = {n:"Vanuit de Dieptes van de Cel",d:"Oto vroeg je een offer aan Kalfen te maken in de gevangenis. Zijn vrijheid voor pro-Djaul propaganda.",r:[null,null,null,null,null,null]};
Q.s[648] = {n:"Het Gerucht verspreiden",d:"Je moet de Djaul, Astrub en Ripate Herbergen bezoeken om Oto\'s bericht te verspreiden. Vraag Finche Aticus hetzelfde te doen in Bonta.",r:[320000,null,null,null,null,null]};
Q.s[646] = {n:"Bedreiging is zojuist Gegroeid",d:"Je moet gaan en David in de Toren van Brakmar ontmoeten en Oto\'s bericht aan hem doorgeven.",r:[null,null,null,null,null,null]};
Q.s[647] = {n:"Laat het Geheime Voorwerp achter",d:"Je moet het geheime voorwerp dat Oto aan je gaf in de grot in de lage Crackler Bergen achterlaten.",r:[null,null,null,null,null,null]};
