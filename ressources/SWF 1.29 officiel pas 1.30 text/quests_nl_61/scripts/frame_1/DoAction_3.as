Q.s[614] = {n:"",d:"Amayiro en jijzelf verdenken de dienstdoende militieman en Amayiro heeft je gevraagd hem te vinden. Hij is het laatst gezien in het Bakkers district.",r:[null,null,null,null,null,null]};
Q.s[616] = {n:"",d:"Het is tijd dat je, je rapport uitbrengt aan Amayiro.",r:[null,null,null,null,null,null]};
Q.s[617] = {n:"",d:"Om zijn goede wil te tonen, heeft Danathor je de naam en de locatie van de Rogue gegeven. Zijn naam is Rogue Inkgo en je kan hem vinden in de Pinchaut Herberg.",r:[null,null,null,null,null,null]};
Q.s[615] = {n:"Weer een Truc van Danathor",d:"Opnieuw blijkt Danathor betrokken te zijn met een duister verhaal. Je moet uitzoeken wat er aan de hand is.",r:[374000,null,null,null,null,null]};
Q.s[1032] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[676] = {n:"Fakoracle",d:"As\'Ruoy\'Dnim heeft een laatste ingrediënt nodig;\r\n            Fakoracle. Blijkbaar kun je er één vinden in een grot bij het Dragoturkey territory.",r:[490000,null,null,null,null,null]};
Q.s[556] = {n:"Exorcisme",d:"De hamer moet boze geesten uitdrijven om de Lichte Geest te bevrijden. Kaffra Keeper kan het doen. Je vindt hem in de Toren van Brakmar.",r:[264000,null,null,null,null,null]};
Q.s[555] = {n:"Steel de Hamer",d:"Oto heeft een speciale hamer nodig voor zijn zwaard. Deze hamer is momenteel in handen van een hoefsmid uit Bonta. Daarom moet jij die van hem gaan stelen.",r:[null,null,null,null,null,null]};
Q.s[944] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[547] = {n:"Eerste Materiaal",d:"Oto heeft wat Corruptite nodig. Dit erts kan in de Kist gevonden worden, diep in de Hoefsmid\'s Kerker. Dan moet je opschieten en het naar Divad of Domen brengen voor het verdwijnt.",r:[null,null,null,null,null,null]};
Q.s[545] = {n:"Waarschuwing",d:"Domen vraagt of je hem wilt ontmoeten in de Toren van Brakmar.",r:[null,null,null,null,null,null]};
Q.s[940] = {n:"null",d:"",r:[240000,null,null,null,null,null]};
Q.s[542] = {n:"Verdwijning",d:"Je kunt je zoektocht nu afsluiten en naar Oto Mustam gaan.",r:[226000,null,null,null,null,null]};
Q.s[539] = {n:"Salade voor een Schildpad",d:"Geef de gevulde blaadjes aan Elturt om hem over te halen jou te vertellen waar de hoorn is.",r:[null,null,null,null,null,null]};
Q.s[540] = {n:"Noord-oosterlijke Zoektocht",d:"Elturt heeft je verteld dat de magische hoorn begraven ligt in het noord-oostelijke deel van het eiland, naast een standbeeld.",r:[null,null,null,null,null,null]};
Q.s[541] = {n:"Het Moordplezier",d:"Je zoektocht werd onderbroken door de aankomst van een Sadida.",r:[null,null,null,null,null,null]};
Q.s[260] = {n:"Lichte Cavalerie",d:"Geef de militia wat jonge verse mounts.",r:[75000,null,null,null,null,null]};
Q.s[558] = {n:"Impregneer het Zwaard",d:"Lagren Doowil ka je helpen het zwaard te impregneren met kracht. Je vindt hem in de barakken van de milities.",r:[null,null,null,null,null,null]};
