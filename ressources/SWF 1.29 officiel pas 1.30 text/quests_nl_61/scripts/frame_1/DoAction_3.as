Q.s[670] = {n:"Kalmeer de Goblin",d:"Raga heeft je nodig. Ronan en hij zijn in de Verbrandde Kat Herberg.",r:[null,null,null,null,null,null]};
Q.s[638] = {n:"Bevrijd de Goblin",d:"Een convooi uit Bonta is door een Goblin Chef, genaamd Ronan overmeesterd. Je missie is het convooi te onderscheppen en Ronan naar Oto te brengen. Het convooi heeft zojuist het Goblin Kamp verlaten.",r:[null,null,null,null,null,null]};
Q.s[641] = {n:"Praat met Raaga",d:"Raaga weet dingen die Oto nodig heeft. Je vindt hem in de bibliotheek.",r:[null,null,null,null,null,null]};
Q.s[671] = {n:"Raaga\'s Drankje",d:"Ragaa heeft de volgende ingrediënten nodig: 1 eenheid Gobball Bloed, 10 eenheden Magisch Geneesmiddel, 10 eenheden Hennep, 2 Kaliptus Bloemen. En je moet ook zijn collega in Kwekers Dorp vinden.",r:[347000,null,null,null,null,null]};
