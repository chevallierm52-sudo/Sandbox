Q.s[898] = {n:"De bevestiging",d:"Pandalida is gevlucht terwijl we aan het vechten waren, ze moet naar haar huis gegaan zijn. Je MOET haar overtuigen om de brief aan Xephires te geven.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intieme intimidering",d:"Pandalida\'s huis doorzoeken zou haar bang moeten maken. Je hebt 3 Tra Khben Lijm nodig, wat gemaakt wordt door 5 Jellidice Jellies, 5 Potten Greedovore en 1 Quetsnakiatl Veer met elkaar te mengen.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"Boodschapper",d:"Je moet een manier vinden om de brief aan Xephires te brengen. Hij is vaak in de Dronken Pandawa Kroeg, maar weigert om met je te praten.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"De Overname",d:"Je moet de krijger Tink Berval vinden en hem vragen of hij de krijger Brank Thoof wilt vervangen.",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"Een maaltijd het best koud geserveerd.",d:"Nu Elturt honger heeft en jouw vechttactieken niet werken, moet je een manier verzinnen om hem te vergiftigen. Iemand op het eiland moet weten wat het favorieten eten van een schildpad is.",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Schildpad door Elkaar Schudden",d:"Omdat aardig vragen niet helpt, moet je een beetje anders handelen als je deze informatie wilt hebben.",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Transformatie",d:"Poss\'Ybel wil dat je hem een paar middelen geeft die je zelf geoogst hebt.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Transformatie",d:"Poss\'Ybel wil een klein helend drankje gemaakt van een Flax bloed en een beetje water.",r:[50,null,null,null,null,null]};
Q.s[379] = {n:"Transformatie",d:"Poss\'Ybel wil dat je hem een paar middelen geeft die je zelf geoogst hebt.",r:[50,15,null,null,null,null]};
Q.s[380] = {n:"Transformatie",d:"Poss\'Ybel wil dat je hem een paar middelen geeft die je zelf geoogst hebt.",r:[50,15,null,null,null,null]};
Q.s[686] = {n:"Achterhaal Drinkers",d:"Je zult van kroeg naar kroeg moeten gaan om militieleden te vinden die niet werken en hen om hun badges vragen.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Voorwaarden van Handel",d:"Telma heeft je een lijst gegeven met wat ze allemaal wil voor haar magische ketting.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"Ik ben een Sociaal Werker",d:"Qwizitor wil weten of er een bewoner is die iets ongewoons gezien heeft",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Shaman connectie",d:"De Shaman is een Pandawa wie veel weet van de plannetjes van sommige mensen... Het lijkt er op dat het geen bed van rozen is in Pandala!",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"Goede gezondheid voor de Godin!",d:"Net aangekomen in Pandala, verzoekt de Shaman assistent je dat je van waarde bent voor je Godin: een spiritueel offer zou erg aardig van je zijn... Je inwijding kan beginnen.",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Vind een Baan",d:"Postor Nhin heeft waarschijnlijk iets te doen voor je.",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"Een Recept voor Babblera",d:"Babblera wacht op het Astrub pannenkoeken recept zodat ze iets klaar kan maken voor haar kleinkinderen.",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"Berghanger",d:"Ga naar de schuilplaats van de bandieten door een touw te gebruiken. En ga niet alleen!",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"Terug naar Amayiro",d:"Je hebt scouts van de bandieten gevonden, wat betekent dat hun schuilplaats dichtbij moet zijn. Amayiro zal geïnteresseerd zijn in deze informatie.",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"Vind de Schuilplaats",d:"Amayiro heeft je gevraagd de vlaktes van Cania te onderzoeken en de schuilplaats van de Bandieten te vinden. Het schijnt dicht bij de markt te zijn.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Mooie Nara",d:"Nara gaf je een lijst met materialen die hij nodig heeft om de uitrusting van de Bontariaanse militie te maken. Je moet ze naar hem brengen in de Porco\'s Mijn.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Vastgoed",d:"Je bent bij alle plaatsen geweest die Setag je gezegd had. Nu moet je Nara nog overtuigen om naar een van die te gaan.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"Waar is hij?",d:"Amayiro vroeg je de hoefsmid te vinden die Bonta kan helpen. Blijkbaar is hij in een mijn of grot in de buurt van Norb\'s werkplaats.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Doos Verplaatsing",d:"Je moet 4 kisten vanaf Amayiro naar de zuiderlijke uitkijkpost van Bonta brengen.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Jezelf bewijzen",d:"Omdat je nog niet zo bekend in de omgeving, weten de oorspronkelijke bewoners nog niet of ze je wel kunnen vertrouwen.",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"Licentie Vier",d:"Je hebt de Ginger Ale. Als je hem aan Brett geeft, zou je al je kracht terug moeten krijgen.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Ginger Hulp",d:"Brett wil Ginger Ale. Waarom gaat hij het zelf niet halen?",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"De Bijeenkomst",d:"Oto maakt eigen plannen om Elturt aan het praten te krijgen. In de tussentijd gaf hij jou een lijst met dingen die je hem binnen 24 uur moet brengen.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"De wabbit en de schildpad.",d:"Volgens Oshimo, heeft Elturt een aartsvijand Herr Palp Itane die een contract heeft getekend met demonen om zijn krachten te vergroten. Hij woont op Skeletten Wabbit Eiland.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Adresboek",d:"Voeg een speler toe aan je vriendenlijst",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"Van wie is de puppy?",d:"Onmast\'her heeft je uitgedaagd om het monster verborgen in de kennel te verslaan",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Spelregels gevorderden Trool Spel",d:"Raxitik wordt geterroriseerd. Hij weet dat de Bworks hem aan Trool willen uitleveren om een partijtje Troolspel voor gevorderden met hem te doen. Deze Trool, die de fysieke integriteit van Raxitik bedreigt, moet absoluut uitgeschakeld worden.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"Bloederige Kruistochten",d:"Confronteer de Dopple in elke van de klasse tempels.",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Vernietig Schildpadden",d:"Oto vroeg je om tien schildpadden van Moon Eiland te vermoorden. Haal hun ogen er uit en hou ze als bewijs.",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Wijn voor Oto",d:"Je moet Oto Greedovore wijn brengen. Maar waar vind je zulke dingen?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"Interview",d:"Een Brakmariaanse beroemdheid heeft naar je gevraagd. Bezoek haar in de kelder van de toren van Brakmar.",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Enerverende Drankjes",d:"Oto Mustam heeft drie Pahoa Plunder Gifdranken nodig.",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"Redden",d:"Exoram is gegegijzeld door een groep Goblins die hem naar hun kamp hebben meegenomen. Je moet hem redden zodat hij je alles kan vertellen over wat er gebeurd is.",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"Koop de uitrusting",d:"Je moet de uitrusting kopen en aantrekken, die Oto je vroeg om te halen voor hem weer te bezoeken.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"32 Gouden Tanden",d:"Breng Mak een gouden gebit. Je kunt ze vinden bij Elite Chafers, maar de wapensmid in Brakmar kan je er ook een paar geven.",r:[28000,null,null,null,null,null]};
Q.s[487] = {n:"Ga naar de bibliotheek",d:"Spionnen in Bonta hebben gefaald in hun moordpoging. Jij moet het voor hun doen. Het doelwit is de tacticus die in de bibliotheek van Bonta leeft.",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Moordenaar",d:"Je kan nu de bibliotheek in om voor de tacticus te zorgen.",r:[null,null,null,null,null,null]};
Q.s[750] = {n:"Verneder Sbab",d:"Oto vroeg je om Sbab 10 Tiwabbitoren te brengen om haar de laten schrikken. Maar misschien is er een manier om dat niet te doen als je dat niet wilt...",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Bontarianen Verslaan",d:"Oto vroeg om Kikim Herberg bier. Het probleem is ... het is in Bonta!",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Vind de Documenten",d:"De spion had de vertrouwelijke documenten niet bij zich. De wezens van de Sidimote hebben het misschien te pakken gekregen.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"De Onthulling",d:"Achter de Alchemisten Marktplaats is een kast. Je moet voor het staan om de geheime doorgang te openen. Magier Ax wacht daar op je.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"Magier Ax",d:"Amayiro heeft je gevraagd Magier Ax te ondervragen zodat je een beter begrip krijgt van hoe de krachten van de Fogornleg Hoorn op te roepen.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"Terugkeer naar de Groep.",d:"Het is tijd om terug naar Bonta te gaan en de situatie met Amayiro op te lossen.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"Algemene Kennis",d:"Ga en leer hoe je zielen moet vangen. De dungeon sleutel moet bij wezens uit de regio zijn.",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Chafer Helmen",d:"Oto wil 10 Chafer Helmen, die kun je vinden op de Begraafplaats van de Gemartelden.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Brakmariaanse Aanwezigheid",d:"Je bent aangevallen door een Brakmariaa die daar al was, maar de Fogornleg Hoorn niet hadden. Als Ecaflip aan jouw kant staat, moet je de Fogornleg Hoorn kunnen vinden voor de Brakmarianen dat doen.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"Elturt\'s Beslissing",d:"Overtuig Elturt om de Fogornleg Hoorn te ruilen voor de Opgeknapte Bandana. Je zult een Ambushheadgear en een fles Greedoburg nodig hebben om hem te laten verschijnen.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Wolvenjacht",d:"Oto vroeg je om een loerende wolf weg te jagen uit Brakmar.",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"Geloceerde Locatie",d:"Amayiro heeft interesse in wat Norb je heeft verteld.",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Werkplaatsen",d:"Je moet een bekwame hoefsmid vinden diede uitrusting voor Bonta wil maken. Amayiro stelt voor dat je begint met zoeken in de werkplaatsen (die van de hoefsmeden en mijnwerkers)",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Nog een Herbergier",d:"Volgens Oto, heeft de waard in Sufokia meer informatie over de krachtige magische hoorn.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"Als je wilt dat iets goed gedaan wordt...",d:"De informatie die de Ripate Herbergier heeft gegeven, is niet bruikbaar in de huidige situatie. Een gesprek met een geleerder persoon zou nuttig kunnen zijn.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, koko?",d:"Je hebt een grof idee wat Oto Mustam gepland heeft voor je volgende missie. Daarom is het nu verstandig om een paar Kokonuts te verzamelen.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Schilden",d:"Ripate, de waard, wil dat je hem schildpaddenschilden brengt van Maan - één in elke kleur. Maar je kan misschien iets sneller en eenvoudiger doen...",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Versla de lupus minimus.",d:"Een gevecht dat je nieuwe vaardigheden zal testen.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Onafgeronde missie",d:"Het pad is nu vrij, alhoewel de goblins ook onschadelijk waren. Exoram kan je eindelijk vertellen wat hij weet wat Oto Mustam blij moet maken.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"De Informant",d:"Oto hoorde dat een Sram in het Treechnid Bos Xephires kent.",r:[null,null,null,null,null,null]};
Q.s[445] = {n:"Met lege handen terugkeren",d:"Kroeghouders hebben nog nooit van Xephires gehoord. Je moet Oto het slechte nieuws brengen.",r:[null,null,null,null,null,null]};
Q.s[891] = {n:"Ver van afgeronde missie",d:"Sporen van een gevecht en overblijfselen van Karnes laten zien dat Exoram gevangen genomen is - en dat hij zich heeft verweerd! Oto Mustam zal niet blij zijn als hij hier achter komt.",r:[65000,null,null,null,null,null]};
Q.s[444] = {n:"Informatie",d:"Je moet informatie over Xephires vinden. De waarden kunnen je misschien helpen.",r:[null,null,null,null,null,null]};
Q.s[1025] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[1024] = {n:"null",d:"",r:[null,null,null,null,null,null]};
