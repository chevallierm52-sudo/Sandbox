VERSION = 62;
SR = new Object();
SR[1] = {n:"Jiva",d:"Jiva è la protettrice del mese di Gevian. Sostituì Solar nel suo compito quando egli fu assassinato da Djaul. Ha dato origine a Bonta, che decise di costruire con Puchecot e Menalt per far fronte al crescente potere di Brakmar.",l:"fr",p:"4",t:0,c:"0",date:"1093298400000",rlng:[]};
SR[2] = {n:"Rushu",d:"Rushu è il Signore Demone che sogna di diventare un Dio. È riuscito ad imporre il fedele Djaul come protettore del mese di Desembel. È geloso della dea Sàcrido e l\'accusa di avergli rubato il posto.",l:"en",p:"2",t:0,c:"2",date:"1125525600000",rlng:[]};
SR[3] = {n:"Djaul",d:"Djaul è un demone fedele a Rushu ed è anche e soprattutto il protettore del mese di Desembel. Odia ferocemente gli altri protettori al punto di averne addirittura ucciso uno e non certamente il più debole: il compianto Solar, ex-protettore di Gevian.",l:"fr",p:"4",t:0,c:"0",date:"1132527600000",rlng:[]};
SR[4] = {n:"Raval",d:"Raval il Terribile è il protettore del mese di Septembel. Nessuno sa quello che vuole veramente. Raval aiutò i Brakmariani a costruire l\'oscura città di Brakmar, ma durante la battaglia dell\'Aurora Purpurea diede loro il colpo di grazia. I Ladrurbi lo venerano segretamente nella loro setta.",l:"fr",p:"4",t:0,c:"0",date:"1140562800000",rlng:[]};
SR[5] = {n:"Hecate",d:"Hecate è la protettrice del mese di Lullier. È una demone che obbedisce solo a se stessa. Salvò la vita di Ulgrud, il protettore di Marten, dopo che ebbe combattuto contro Djaul. Hecate è segretamente innamorata di Ulgrud.",l:"fr",p:"4",t:0,c:"0",date:"1145916000000",rlng:[]};
SR[6] = {n:"Sumens",d:"Sumens è un fervente servitore del dio Anutrof ed è anche il protettore del mese di Giundor. Quando digerisce produce sempre degli eventi straordinari, infatti, tutto ciò che mangia viene espulso ogni giorno sotto forma di pietre preziose.",l:"fr",p:"4",t:0,c:"0",date:"1149717600000",rlng:[]};
SR[7] = {n:"Menalt",d:"Menalt era un potente guerriero centauro, nonché comandante dell\'ordine del Cuore Valoroso. Era anche il protettore del mese di Marten. Malgrado il suo eroismo, però, morì sotto i fendenti dei Brakmariani durante la battaglia dell\'Aurora Purpurea.",l:"fr",p:"4",t:0,c:"0",date:"1156802400000",rlng:[]};
SR[8] = {n:"Rosal",d:"Rosal è il maestro dei fiori e il protettore del mese di Magil. Non bisogna fidarsi della sua dolcezza apparente. È dotato del dono della telepatia ed è capace di sondare gli spiriti dei mortali: svelare i più intimi segreti o le menzogne è un gioco da ragazzi per lui. Non ha nessuna pietà per coloro che non sono puri d\'animo.",l:"en",p:"1",t:0,c:"2",date:"1159221600000",rlng:[]};
SR[9] = {n:"Maimane",d:"Maimane lo stabilizzatore è il protettore del mese di Octobel. Stanco delle continue battaglie che agitavano il Mondo, decise di sigillare le emozioni seppellendole magicamente nel suolo. L\'amore e l\'odio rimasero nascosti, fino a quando non vennero (fortunatamente o no, chi può dirlo) ritrovati per caso...",l:"fr",p:"4",t:0,c:"0",date:"1159826400000",rlng:[]};
SR[10] = {n:"Silvosse",d:"Silvosse, Signore delle Talee, è il protettore del mese di Febral. Quando si tratta di proteggere dei vegetali, può arrabbiarsi ferocemente. Tempo addietro, infatti, s\'impadronì delle anime di taglialegna imprudenti e, imprigionandole nei tronchi degli alberi, creò la specie degli Alberagni.",l:"fr",p:"4",t:0,c:"0",date:"1165273200000",rlng:[]};
SR[11] = {n:"Brumario",d:"Brumario, il macabro dissanguatore, è il protettore di Novembel. Lottò al fianco di Djaul durante la sconfitta dell\'Aurora Purpurea. Da allora medita la sua vendetta e disprezza Djaul, che considera un villano incapace.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[12] = {n:"Puchecot",d:"Il grande e fertile Puchecot è il protettore di Agustor. Partecipò alla fondazione della città di Bonta. Spirito illuminato, grande estimatore di arte e musica, è conosciuto tra gli dei ed i mortali per le sue barzellette capaci di piegare dalle risate una Quercia Molle.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[13] = {n:"Siluate",d:"Siluate è un Minotoror divenuto protettore di Aperir grazie alla sua saggezza. È lui che si affretta a far allontanare il freddo dell\'inverno. Amico di Sumens, si dice che Siluate sia uno dei saggi che presero la decisione di nascondere i Dofus alla bramosia degli avventurieri.",l:"fr",p:"4",t:0,c:"0",date:"1171321200000",rlng:[]};
SR[14] = {n:"Domen",d:"Domen è uno dei tre potenti di Brakmar. Fedele a Brumario e di indole fondamentalmente malvagia, egli è il protettore dell\'amarezza della sconfitta dopo la battaglia dell\'Aurora Purpurea. Egli adotta di solito l\'aspetto di uno spirito errante.",l:"fr",p:"4",t:0,c:"0",date:"1175724000000",rlng:[]};
SR[15] = {n:"Amayiro",d:"Amayiro fa parte del grande consiglio di Bonta. Agguerrito maestro d\'armi, è stato lui a decidere di creare la milizia, per la difesa e la sicurezza della città. Nonostante la sua età avanzata, infatti, è tuttora al comando della milizia.",l:"fr",p:"4",t:0,c:"0",date:"1179784800000",rlng:[]};
SR[16] = {n:"Rykke-Errel",d:"Rykke Errel era un giovane discepolo Yop, il solo ad aver avuto il coraggio di sfidare il drago Bolgrot. Quando ebbe la vittoria in mano, decise di risparmiare la creatura e divennero amici. Ma Rykke in seguito fu costretto a uccidere Bolgrot per vendicare la morte della sua amata. Infatti il drago, anch\'egli innamorato della bella Helsefina, pazzo di gelosia, la uccise.",l:"fr",p:"4",t:0,c:"0",date:"1182808800000",rlng:[]};
SR[17] = {n:"Hyrkul",d:"Hyrkul è un devoto servitore di Djaul. Tanto cattivo e crudele quanto il demone che serve, egli è anche un potente guerriero. È stato reso immortale dal demone Rushu come ricompensa per i servizi resi.",l:"fr",p:"4",t:0,c:"0",date:"1183413600000",rlng:[]};
SR[18] = {n:"Helsefina",d:"Helsefina era una maga tanto bella quanto dolce. La sua bellezza stregò il cuore del celebre eroe Rykke Errel, ma anche il cuore del drago Bolgrot, amico di Rykke. Sfortunatamente Bolgrot, non potendola far bruciare della sua stessa passione, la fece bruciare viva in un eccesso di gelosia. Rykke Errel in seguito uccise Bolgrot per vendicare la morte del suo grande amore.",l:"fr",p:"4",t:0,c:"0",date:"1192485600000",rlng:[]};
SR[19] = {n:"Allister",d:"Allister è il benamato re di Amakna. Pastore di professione, questo Feca è diventato celebre dopo la cattura del demone Uk\' Not\' Allag. Fu in quel periodo che fondò la prima gilda della storia del Mondo dei Dodici. Dopo essere rimasto isolato per molto tempo nel suo castello cerca ora di riprendere le redini del regno.",l:"fr",p:"4",t:0,c:"0",date:"1196722800000",rlng:[]};
SR[20] = {n:"Otomai",d:"Otomai è un potente Alchimista, creatore della celebre pozione contro la myxomawosis. Incantatore specializzato nello studio delle creature viventi, a lui si deve la scoperta dell\'isola che oggi porta il suo nome. Su tale isola ha tentato di riunire tutte le specie animali del Mondo dei Dodici, per praticare misteriosi esperimenti...",l:"fr",p:"4",t:0,c:"0",date:"1201215600000",rlng:[]};
SR[21] = {n:"Lily",d:"Famosa navigatrice, Lily è conosciuta per aver fatto il giro del mondo in 80 giorni e fu durante questo viaggio che maturò una vera passione per i Wabbit... soprattutto per i wabbit allo spiedo! Da allora si reca regolarmente sull\'isola per concedersi una piccola \"vacanza gastronomica\" e vendere qualche leccornia agli avventurieri per pochi kama... Infatti, oltre ad avere un senso dell\'orientamento infallibile, Lily ha anche il senso degli affari!",l:"fr",p:"2",t:0,c:"0",date:"1203030000000",rlng:[]};
SR[22] = {n:"Oto Mustam",d:"Oto Mustam è il Capo della milizia Brakmariana. Impulsivo, violento e crudele, è fedele a Djaul e disprezza gli esseri umani. Rushu, il loro Signore, ha notato la sua lealtà verso i Demoni e gli ha affidato questa missione: vegliare su un Mondo dei Dodici sempre più violento e caotico. Il suo scopo? Selezionare degli eroi che integreranno la Grande Armata Demoniaca, quella che invaderà il mondo per vincere la battaglia finale contro gli Dei.",l:"en",p:"0",t:1,c:"2",date:"1222120800000",rlng:[]};
SR[23] = {n:"Hel Munster",d:"Considerato dai suoi pari come il miglior mago di Amakna, Hel Munster insegna la Forgimagia agli avventurieri che se ne mostrano degni. È anche l\'autore del bestseller \"La creazione di oggetti magici per dummies\", dove espone, tra l\'altro, la sua teoria sull\'apparizione della Brezza Quadramentale.",l:"fr",p:"2",t:0,c:"0",date:"1205794800000",rlng:[]};
SR[24] = {n:"Danathor",d:"Danathor è l\'intendente di Bonta, designato da Jiva in persona. Fedele alla protettrice del mese di Gevian, è pronto a tutto per radere al suolo la città di Brakmar, anche ad utilizzare metodi poco raccomandabili. Nemico di Amayiro, è avido di potere e vuole farsi posto ad ogni costo nella gerarchia del mondo...",l:"fr",p:"2",t:0,c:"0",date:"1208469600000",rlng:[]};
SR[25] = {n:"Kuri",d:"Kuri è una delle tre celebri sacerdotesse dell\'amore, che sono responsabili della febbre libidinosa che un tempo colpì le Gelatine di Amakna. Braccio sinistro della terribile Mamie Bonbon, fisicamente la contraddistinguono il suo leggendario arco e il suo copricapo, grande tanto quanto il suo ego.",l:"fr",p:"1",t:0,c:"0",date:"1211839200000",rlng:[]};
SR[26] = {n:"Mylaise",d:"Prima di diventare sacerdotessa dell\'amore, Mylaise è stata una discepola di Ecaflip come tante. Dalle curve generose e sempre in perfetta forma, ella fu a due passi da vincere Miss Dofus. Fu Mamie Bonbon ad assumerla, infine, come guardiana della Torre del Maschio Infernale.",l:"fr",p:"1",t:0,c:"0",date:"1223330400000",rlng:[]};
SR[27] = {n:"Gultard",d:"Anche se Gultard ha vagamente il profilo di uno Yop, non ha più un granché d\'umano... Un tempo il guerriero aveva il cuore gonfio d\'amore quanto i suoi muscoli, ma delle vicende tragiche l\'hanno portato sulla strada del caos e della distruzione. Gultard è senza dubbio, ancora oggi, il guerriero più potente del Mondo dei 12.",l:"fr",p:"0",t:0,c:"0",date:"1227135600000",rlng:[]};
SR[28] = {n:"Uletta",d:"Uletta è un\'Ecaflip dalla bellezza leggendaria. Seduttrice dalle zampe di velluto e dagli artigli di ferro, ha fatto girare la testa a più di un uomo! A forza di tête-à-tête, Uletta ha finito per perdere la sua (di testa). Infatti, Dodge l\'Ecaflip, eroe che non è più necessario presentare, è una delle sue conquiste. In un eccesso di goffaggine rabbiosa Dodge tagliò la bella Ulette a pezzettini - e d\'altronde pure Vald, ma questa è un\'altra storia.",l:"fr",p:"0",t:0,c:"0",date:"1230505200000",rlng:[]};
SR[29] = {n:"Vil Smis",d:"Vil Smis ha attraversato le epoche, evolvendo da semplice brigante a vero simbolo del male. Capo del clan dei Ladrurbi, è tanto misterioso quanto inafferrabile.",l:"fr",p:"1",t:0,c:"0",date:"1234479600000",rlng:[]};
SR[30] = {n:"Many",d:"Many è lo Xelor di mano più abile di Djaul, diventato un maestro nell\'arte di strappare informazioni. Non si contano più gli innocenti che hanno confessato la loro colpa tra le sue lancette. Bisogna dire che si diverte tantissimo, una grande qualità nel mestiere!",l:"fr",p:"0",t:0,c:"0",date:"1236898800000",rlng:[]};
SR[31] = {n:"Solar",d:"Solar era un guerriero Yop leggendario, primo protettore del mese di Gevian. Per sua sfortuna, Djaul, desideroso di raddoppiare il suo tempo di lavoro, lo uccise il 31 Desembel 11 per tentare in seguito di prendersi anche Febral, ma Silvosse lo respinse. Allora Solar fu sostituito da Jiva il 12 Febral 12.",l:"en",p:"0",t:0,c:"2",date:"1214258400000",rlng:[]};
SR[32] = {n:"Crocobarro",d:"Figlio di Crocabulia e Grugalorasalar, Crocobarro divenne il capo di guerra della razza dei Coccodrail.\nCombattente senza uguali, si mise in mostra in numerose battaglie, fino a che perse finalmente la vita in una battaglia contro la città di Bonta, ucciso dai cavalieri della città. Di lui non esiste nulla se non La Crocobar, la sua mitica spada.",l:"fr",p:"0",t:0,c:"0",date:"1259017200000",rlng:[]};
SR[33] = {n:"Li Crounch",d:"Discepolo di Sadida e pittore, Li Crounch ha passato la sua vita a mettere in pratica, con rigore implacabile, i dogmi del suo dio: meditazione e amore per la natura. Il giovane artista si applicava a dormire almeno 20 ore su 24, e a dipingere fiori per la restante parte del suo tempo. E\' rimasto, malgrado tutto, un modello per numerosi Sadida.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[35] = {n:"Farle",d:"Celebre contadino, Farle Ingals è conosciuto per la sua pazienza e il suo amore per la terra. Tutti i giorni coltiva i suoi campi nel cuore di Amakna con cura, anche quando orde di avventurieri calpestano i suoi appezzamenti di cereali. Farle è anche ammirato per essere riuscito a sedurre e placare la sete di avventura di una bella donna: la celebre avventuriera Shika Ingals.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[36] = {n:"Agrida",d:"Alcuni taglialegna di Amakna, come Bruce Bulgur, sono entrati nella leggenda con le loro azioni temerarie, mentre altri sono rimasti più modesti ed anonimi. E\' il caso di Agrid. Fortunatamente nè il valore nè il merito sono legati alla gloria, e ad Agrid non mancano nè l\'uno nè l\'altra dal momento che si impegna molto per trasmettere gli arcani dell\'arte del taglio a chiunque glielo chieda.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[37] = {n:"Bowis",d:"Bowis è un ciabattinto talentuoso e rispettato, a lui si deve la creazione delle più belle cinture e dei più originali stivali del Mondo dei Dodici. E\' particolarmente famoso per la sua capacità unica di concepire abiti che calzano a pennello su colui che glieli ha ordinati. Numerosi avventurieri si sono fatti prendere a calci da lui, e nessuno s\'è mai lamentato.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[38] = {n:"Ogivol",d:"",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[39] = {n:"Lethaline",d:"",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[40] = {n:"Aermyne",d:"Aermyne ha a lungo avuto una elogiata reputazione fra le mamme di Amakna. Cullare, lavare, dare il biberon, era quello che sapeva fare meglio, e meglio di chiunque altro.\nSolo che un giorno una voce si mise a parlarle, direttamente nella sua testa, e tutto cambiò. Finiti i panni da lavare e i biberon, Aermyne si mise a spedire i bambini fuori di casa a colpi di mattarello. Nessuno ha mai compreso il suo gesto, e Aermyne si é dovuta esiliare su Pandala.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[41] = {n:"Zatoishwan",d:"Giocatore incallito, cosa insolita per un Pandawa per di più cieco, Zatoishwan aveva una reputazione tale da essere invidiato persino dai più grandi giocatori Ecaflip. Colpito un giorno da un fulmine, fu illuminato dalla dea Pandawa: divenne maestro nell\'arte ancestrale del Pandawushu. In seguito diventò un giustiziere... Fino a diventare il bandito ricercato che conosciamo.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[99] = {n:"Tournaments",d:"-",l:"fr",p:"4",t:2,c:"2",date:"1355266800000",rlng:[]};
