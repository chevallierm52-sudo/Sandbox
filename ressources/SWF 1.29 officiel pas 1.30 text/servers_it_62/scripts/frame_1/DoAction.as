SR[902] = {n:"Beta Dofus 2.0 INTL",d:"",l:"en",p:"0",t:0,c:"2",date:"1228950000000",rlng:[]};
SR[903] = {n:"Salone Dofus 2",d:"",l:"fr",p:"0",t:0,c:"0",date:"1251324000000",rlng:[]};
SR[904] = {n:"Beta Dofus 2.0 FR",d:"",l:"fr",p:"0",t:0,c:"0",date:"1253829600000",rlng:[]};
SR[905] = {n:"Beta Dofus 2.0 JA",d:"",l:"ja",p:"0",t:0,c:"10",date:"1255039200000",rlng:[]};
SR[1001] = {n:"Shika",d:"Shika, la bella moglie del famoso Farle Ingals e amica di sempre di re Allister, è conosciuta per la sua partecipazione alla cattura di Uk\' Not\' Allag, un terribile e perfido demone. Si dice che sia incredibilmente forte, tanto da poter eliminare con le sue manine le creature che la molestano.",l:"en",p:"0",t:0,c:"1",date:"1175724000000",rlng:["en"]};
SR[3001] = {n:"Nehra",d:"Nehra è una potente maga, che molto tempo fa salvò dalla distruzione il primo villaggio degli abitanti di Amakna, ed ancora oggi la si vede prestare soccorso agli avventurieri in pericolo. È di poche parole e scompare subito dopo essere apparsa, per questo motivo neanche i saggi sanno molto sul suo conto, ma questo non impedisce a numerosi avventurieri di adorarla come la loro santa patrona.",l:"de",p:"0",t:0,c:"3",date:"1184104800000",rlng:["de"]};
SR[3002] = {n:"Katar",d:"Katar era un guerriero Sàcrido eccezionale. Forte come un Buulupo, agile come Moon, la sua fama di guerriero eccezionale superò le frontiere per arrivare alle orecchie di un Demone collezionista di... guerrieri eccezionali. Il Demone vinse la resistenza del Sàcrido e Katar venne posseduto, anima e corpo. Da quel momento Katar erra alla ricerca di un guerriero in grado di sconfiggerlo e di liberarlo dalla sua maledizione.",l:"de",p:"0",t:0,c:"3",date:"1259103600000",rlng:[]};
SR[4001] = {n:"Alma",d:"Alma è la protettrice dei provetti esploratori. Una leggenda racconta che abbia trovato un Nuovo Mondo e ne abbia disegnato la mappa con le coordinate per arrivarci. Un\'altra leggenda, invece, narra che tutti coloro che partirono all\'avventura aldilà dei mari, senza far più ritorno, abitino ora in un Mondo Migliore... Alcuni esploratori dicono di averla vista apparire mentre si erano persi in luoghi poco ospitali e che lei li abbia aiutati a ritrovare il cammino...",l:"es",p:"4",t:0,c:"4",date:"1184104800000",rlng:["es"]};
SR[4002] = {n:"Aguabrial",d:"Aguabrial è un Drago incaricato di vegliare su uno dei quattro elementi. È il guardiano dell\'Acqua. Quando il mondo era agli albori, egli generò il primo Dofus Turchese, ma poi Aguabrial fu tradito da Djaul e da allora cerca il modo di vendicarsi del demone. Infatti, nonostante la sua calma e la sua moderazione, Aguabrial è capace di scagliarsi rabbiosamente contro i nemici. Il proverbio non dice forse che bisogna stare attenti alle acque chete?",l:"es",p:"2",t:0,c:"4",date:"1195772400000",rlng:["es"]};
SR[4003] = {n:"Buhorado",d:"Buhorado è il Maestro scomparso dalla famosa “Società” che riunisce tutti i gufi del Mondo dei Dodici: eruditi, contabili, ecc... Sono i guardiani delle banche e della storia di Amakna. Buhorado era il più saggio tra di loro fino a quando non si lasciò prendere troppo la mano dal “Gioco del Dwago”. Si dice che il suo fantasma sia apparso un\'ultima volta qualche secolo dopo, ma questa voce viene smentita dai fedeli di Allister, che vedono in Buhorado un simbolo dell\' “Era dei Padrini” e, quindi, una potenziale minaccia all\'autorità del Re.",l:"es",p:"2",t:0,c:"4",date:"1212357600000",rlng:["es"]};
SR[4004] = {n:"Tenebra",d:"Tenebra è tristemente famoso per i massacri e l\'arma leggendaria a cui è associato. Quest\'arma si chiama “Tormentatore”. Essa fu creata per il suo padre adottivo, Senzasegatura, il tuttofare, e lo aiuta a rivelare tutta la forza dei suoi poteri. Congiunti l\'uno all\'altra, essi divengono il Cavaliere Nero, il cui nome fa tremare chi lo pronuncia.",l:"es",p:"1",t:0,c:"4",date:"1224108000000",rlng:["es"]};
SR[4005] = {n:"Bolgrot",d:"Bolgrot è un drago misterioso il cui destino ha sconvolto la storia del Mondo dei Dodici. Generato da Aguabrial, scomparve nei primi secoli della sua esistenza fino al giorno in cui incontrò Rykke Errel alle porte d\'Amakna. Rykke venne ad affrontare Bolgrot, ma tra i due, invece di un combattimento, cominciò una grande amicizia che terminò il giorno in cui, diventato pazzo, Bolgrot uccise Helsefina, cara al cuore di Rykke. Iniziò quindi una battaglia titanica che si concluse con la morte dei due protagonisti. Nelle viscere di Bolgrot, sconfitto, i saggi d\'Amakna scoprirono sei Uova dai colori strani, da cui nacque la leggenda dei Dofus.",l:"es",p:"0",t:0,c:"4",date:"1238709600000",rlng:[]};
SR[4006] = {n:"Nomekop",d:"Gli amici, come pure i nemici, lo soprannominano «L\'Urlante». Di amici ne ha solo due: Eratz il Rivendicatore e Edàs il Guastafeste. I suoi nemici, invece, sono molto più numerosi dei fili d\'erba delle Lande di Cania! Dove passa Nomekop, i nemici trapassano... e l\'erba non ricresce.",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4007] = {n:"Edàs",d:"Il Guastafeste, questo è il suo soprannome. Eppure a lui le feste piacciono... Lo ripete spessissimo: «Avvicinati, te la farò io la festa!». Cos\'è a renderlo così giocondo? Si dice che possieda un Dofus. O si tratta di uno dei due suoi compari Nomekop e Eratz? Bisognerebbe andarglielo a chiedere per togliersi il dubbio...",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4008] = {n:"Eratz",d:"Eratz è uno dei tre Banditi leggendari di Cania. Quando se ne incrocia uno, gli altri due di sicuro non sono molto lontani. L\'ultimo ad averli visti, non è più qui per poterne parlare! Bisogna proprio aver un cuor di leone per avvicinarsi ad Eratz il Rivendicatore. D\'altronde se lo incontri, molto probabilmente starai esalando il tuo ultimo respiro.",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[6001] = {n:"Spiritia",d:"Drago cangiante dai riflessi multicolore, simboleggia lo spirito divino che scende nella materia e nell\'animo di tutte le creature del mondo. Rappresenta anche la Brezza Quadramentale e viene chiamato così dal maestro alchimista Hel Munster nei suoi libri.",l:"pt",p:"0",t:0,c:"6",date:"1206572400000",rlng:["en","pt"]};
SR[6002] = {n:"Helioboros",d:"Helioboros è uno dei tre Draghi venerati dai fedeli del Dio Osamodas. Secondo la leggenda questo Grande Drago Bianco avrebbe partecipato alla creazione del Mondo soffiandoci la luce dentro! Gli Etram, invece, credono che sia stato Uronigride, il Grande Drago Nero, che aveva morso la coda ad Helioboros, a causarne la creazione e che i due draghi, alla fine, lo avessero creato contemporaneamente per caso mentre stavano combattendo. Quale sarà mai la verità? Chi lo sa! Per due kama, il Mago Ax ti racconterà tutte le leggende che vorrai...",l:"pt",p:"0",t:0,c:"6",date:"1253484000000",rlng:["en","pt"]};
SR[7001] = {n:"Dark Vlad",d:"Dark Vlad è uno Yop sfortunatamente famoso in tutta Amakna, Bonta e Brakmar. È il primo ed unico Yop ad aver cavalcato un Karne volante e la sua spada fiammeggiante è invidiata da molti avventurieri. Non sorprende che chiami \"casa\" un posto come la Foresta Malefica. Egli vive lì e attende il primo sprovveduto che osi addentrarsi nella sua tana per farlo a brandelli.",l:"nl",p:"0",t:0,c:"7",date:"1219788000000",rlng:["nl"]};
SR[9001] = {n:"Ereziah",d:"Ereziah è un alchimista dei tempi antichi ed un esorcista di talento, noto anche per la sua amicizia con il drago dell\'acqua Aguabrial. La sua padronanza della magia non ha eguali se non nella sua perspicacia e le sue doti lo hanno reso noto ai quattro angoli del mondo. Amico del Drago Aguabrial, l\'ha salvato da una trappola tesagli dal demone Djaul. Pochi sono gli alchimisti che si possono vantare di aver sventato gli intrighi di Djaul!\n\nLa leggenda racconta, infatti, che questo semplice mortale avrebbe salvato l\'onnipotente Drago da un maleficio del demone Djaul, il Grande Sguazzatore. Questo evento portò alla nascita di un Dofus: il drago Bolgrot.",l:"it",p:"0",t:0,c:"9",date:"1212357600000",rlng:["it"]};
