SR[1001] = {n:"Shika",d:"Shika, a bela esposa do famoso Farle Ingalsse, e velha amiga do rei Allister, é mais conhecida por sua participação na captura de As\'Ruoy\'Dnim, um demônio muito cruel. Dizem que ela é extremamente forte, capaz de mandar para o além qualquer criatura!",l:"en",p:"0",t:0,c:"1",date:"1175724000000",rlng:["en"]};
SR[3001] = {n:"Nehra",d:"Nehra é uma maga poderosa. Há muito tempo, ela salvou uma das primeiras vilas de Amakna da destruição. Nos dias atuais, ela aparece para resgatar os aventureiros de bom coração em perigo. Como ela fala apenas uma palavra e rapidamente desaparece, nem os mais sábios não conhecem muito sobre ela. Mesmo assim, muitos aventureiros idolantram-na como santa.",l:"de",p:"0",t:0,c:"3",date:"1184104800000",rlng:["de"]};
SR[3002] = {n:"null",d:"",l:"de",p:"0",t:0,c:"3",date:"1259103600000",rlng:[]};
SR[4001] = {n:"Alma",d:"Alma protege aventureiros experientes. A lenda diz que ela encontrou um Novo Mundo e enviou um misterioso mapa náutico para que os aventureiros chegassem lá. O boato também diz que os mais corasojos agora vivem em um mundo melhor. Viajantes dizem que a avistaram quando se perderam em locais inóspitos e que, graças a ela, conseguiram encontrar o caminho.",l:"es",p:"4",t:0,c:"4",date:"1184104800000",rlng:["es"]};
SR[4002] = {n:"Aguabrial",d:"Aguabrial, o Dragão, está carregado com a proteção de um dos quatro elementos. Ele guarda a Água. Foi ele quem criou o primeiro Dofus Turquesa quando o Mundo ainda era novo. Há muito tempo, Aguabrial foi enganado por Djaul e desde este dia, o Dragão busca vingança ao demônio. Apesar de sua calma e ternura, Aguabrial também pode expressar terror aos seus inimigos. Depois de tudo, um velho provérbio nos diz que onde a água é mais calma está o maior perigo?",l:"es",p:"2",t:0,c:"4",date:"1195772400000",rlng:["es"]};
SR[4003] = {n:"Buhorado",d:"Buhorado é um famoso Mestre que desapareceu da Firma onde todas as corujas do Mundo dos Doze se reuniam: eruditas, calculistas... Eram elas que guardavam os segredos da história das contas de Amakna!! Buhorado era o mais sábio de todos até o dia em que se esqueceu como jogar por causa dos \"Presentes do Padrinho\".  Diz a lenda que o seu fantasma apareceu pela última vez há mutos séculos... Mas os discípulos de Allister esconderam a lenda assim como Buhorado, que foi um dos últimos Padrinhos dos tempos dos \"Tempos dos Mafiosos\", e portanto, com um potencial de rejeição das autoridades competentes.",l:"es",p:"2",t:0,c:"4",date:"1212357600000",rlng:["es"]};
SR[4004] = {n:"Escuridão",d:"Escuridão é conhecido pela destruição que causou no Mundo dos Doze, e a arma que o auxiliou nessa tragédia é igualmente lendária.\nConhecida como “A Carrasca”, essa arma foi forjada por seu pai adotivo, Issering, o Criador. E com esta poderosa ferramenta de destruição, Escuridão atinge o poder supremo, tornando-se a entidade conhecida como “O Cavaleiro das Trevas”.",l:"es",p:"1",t:0,c:"4",date:"1224108000000",rlng:["es"]};
SR[4005] = {n:"Bolgrot",d:"Bolgrot é um misterioso dragão cujo destino abalou o Mundo dos Doze. Filho de Aguabrial, Bolgrot se escondeu pelos primeiros séculos de sua existência até o dia que encontrou Rykke Errel nos portões de Amakna. A intenção de Rykke era desafiá-lo, mas ao invés disso, se tornaram melhores amigos. A amizade dos dois terminou abrubtamente quando, em um ataque de fúria, Bolgrot puniu Helséphine, o amor de Rykke. Um duelo titânico então se iniciou e terminou com a derrota de ambos. Os sábios de Amakna descobriram nas entranhas de Bolgrot 6 ovos de cores estranhas. Foi assim que se iniciou a lenda dos Dofus.",l:"es",p:"0",t:0,c:"4",date:"1238709600000",rlng:[]};
SR[4006] = {n:"null",d:"",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4007] = {n:"null",d:"",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4008] = {n:"null",d:"",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[6001] = {n:"Spiritia",d:"Diz a lenda que esse é o dragão cromático que simboliza o espírito divino, e que ao soprar cor no mundo, criou vida e deu origem aos Dofus. Representa igualmente a brisa dos quatro elementos, assim chamado nos seus livros pelo mestre alquimista Hel Munster.",l:"pt",p:"0",t:0,c:"6",date:"1206572400000",rlng:["en","pt"]};
SR[6002] = {n:"Helioboros",d:"“Helioboros é um dos três dragões venerados pelos discípulos de Osamodas. De acordo com as lendas, assim que o mundo foi criado, esse Grande Dragão Branco teria soprado luz nele. Os Srams, no entanto, acreditam que o mundo foi criado por acidente, durante uma briga entre Ouronigride, o Grande Dragão Negro, e Helioboros. Ao que parece, Ouronigride teria iniciado o conflito depois de morder o rabo do Dragão Branco. Qual versão é a verdadeira? Aquela em que você decidir acreditar! Afinal de contas, por alguns Kamas, Magus Ax irá lhe contar qualquer conto como esse...”",l:"pt",p:"0",t:0,c:"6",date:"1253484000000",rlng:["en","pt"]};
SR[7001] = {n:"Dark Vlad",d:"Dark Vlad é o ser mais infame de toda Amakna, Bonta e Brakmar. Até hoje, ele ainda é o único que montou em um Karne Voador e usou certas armas no \"Mundo dos Doze\" que perfuraram tantos mortais quanto a sua espada flamejante. Não é uma surpresa que ele chame um local como a Floresta Maléfica de casa. É nela que ele espera ansiosamente pelo próximo tolo que irá passar pelo seu nebuloso lar.",l:"nl",p:"0",t:0,c:"7",date:"1219788000000",rlng:["nl"]};
SR[9001] = {n:"Ereziah\r\n",d:"Ereziah é um antigo alquimista e um talentoso exorcista que era conhecido também pela sua amizade com Aquabrial, o dragão das águas. Ele foi reconhecido por todos no Mundo por sua habilidade e perspicácia. Ele salvou seu amigo Dragão Aquabrial de Djaul, o demônio. Poucos alquimistas pode atualmente orgulhar-se de frustar os planos de Djaul!!\n\nDiz a lenda que um mero mortal foi salvo por um poderoso Dragão da magia do demônio, Djaul o Respingador. Este fato fez com que os Dofus chocassem, e assim nasceu  Bolgrot, o Dragão.",l:"it",p:"0",t:0,c:"9",date:"1212357600000",rlng:["it"]};
