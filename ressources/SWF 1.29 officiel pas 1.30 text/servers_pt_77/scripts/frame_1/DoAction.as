SR = new Object();
SR[1] = {n:"Jiva",d:"Jiva é a protetora de Javian. Ela substituiu Solar após sua morte nas mãos de Djaul. Foi Jiva, junto com Pouchecot e Menalt, que decidiu criar Bonta para conter o aumento crescente do poder de Brakmar.",l:"fr",p:"4",t:0,c:"0",date:"1093298400000",rlng:[]};
SR[2] = {n:"Rushu",d:"Rushu é um lorde demônio que sonha em igualar-se aos deuses. Ele conseguiu colocar Djaul, seu escudeiro, como protetor de Descendre. Rushu tem ciúmes da deusa Sacrier e a acusa de roubar seu local merecido entre os deuses.",l:"en",p:"2",t:0,c:"2",date:"1125525600000",rlng:[]};
SR[3] = {n:"Djaul",d:"Djaul é um fiel seguidor de Rushu. Ele também é o protetor de Descendre. Odeia muito todos os outros protetores e até matou um deles por meio de suas traições. A vítima foi Solar, o ex-protetor de Javian.",l:"fr",p:"4",t:0,c:"0",date:"1132527600000",rlng:[]};
SR[4] = {n:"Raval",d:"Raval, o terrível, é o protetor de Septangel. Ninguém sabe realmente o que ele quer. Raval ajudou os brakmarianos a construir a cidade negra de Brakmar... Entretanto, também foi ele quem virou a luta a favor de Bonta na batalha da Aurora Rubra. Os Ladinos são misteriosamente devotos a ele.",l:"fr",p:"4",t:0,c:"0",date:"1140562800000",rlng:[]};
SR[5] = {n:"Hecate",d:"Hecate é a protetora de Jullier. Ela é um demônio poderoso e não obedece a ninguém. Salvou Ulgrude, o protetor de Martalo, depois ele lutou contra Djaul. Apesar de negar, ela nutre uma paixão imensa por Ulgrude.",l:"fr",p:"4",t:0,c:"0",date:"1145916000000",rlng:[]};
SR[6] = {n:"Sumens",d:"Sumens é um caloroso servo do deus Enutrof. Ele também é o protetor de Junssidor. Quando ele faz digestão, coisas extraordinárias acontecem. De fato, tudo que ele come se transforma em pedras preciosas mais cedo ou mais tarde.",l:"fr",p:"4",t:0,c:"0",date:"1149717600000",rlng:[]};
SR[7] = {n:"Menalt",d:"Menalt foi o poderoso guerreiro centauro e o comandante da Ordem do Coração Valente. Ele também foi o protetor de Martalo. Mesmo com seu heroísmo, ele foi morto pelos brakmarianos durante a batalha da Aurora Rubra.",l:"fr",p:"4",t:0,c:"0",date:"1156802400000",rlng:[]};
SR[8] = {n:"Rosal",d:"Rosal é o mestre das flores e o protetor de Maysial. Porém, você não deve crer em sua doçura aparente. Como ele é um telepata, sabe como conversar e revelar segredos e mentiras íntimas;\r\n            é um brinquedo de criança para ele. Também não tem piedade pelos que não são puros de coração.",l:"en",p:"1",t:0,c:"2",date:"1159221600000",rlng:[]};
SR[9] = {n:"Maimane",d:"Maimane, o pacificador, é o protetor de Octolliard. Cansado da constante batalha acontecendo no Mundo, ele decidiu enterrar todas as suas emoções graças à sua mágica. Amor e ódio foram enterrados. Mas por quanto tempo?",l:"fr",p:"4",t:0,c:"0",date:"1159826400000",rlng:[]};
SR[10] = {n:"Silvosse",d:"Silvosse é o protetor de Flovor. Quando as plantas sob sua guarda são perturbadas, uma fúria incrível toma conta dele. Ele aprisiona as almas dos lenhadores malvados nas árvores, dando origem aos treechnids.",l:"fr",p:"4",t:0,c:"0",date:"1165273200000",rlng:[]};
SR[11] = {n:"Brumaire",d:"Brumaire, o lorde macabro, é o protetor de Novamaire. Ele estava próximo a Djaul quando perdeu a batalha de Aurora Rubra. Desde então, ele trama vingança e acredita que Djaul não passa de um trapalhão incapaz.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[12] = {n:"Pouchecot",d:"Pouchecot, o fértil, é o protetor de Frauguctor. Ele participou da fundação da cidade de Bonta. Com um espírito alegre, amante da música e da arte, também é famoso entre deuses e mortais por fazer algumas piadas;\r\n            poderia dobrar um carvalho mole de tantas risadas.",l:"fr",p:"4",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[13] = {n:"Silouate",d:"Silouate é um Minotoro e, graças à sua sabedoria, ele se tornou o protetor de Aperirel. Seu objetivo é afastar o frio congelante do inverno para sempre. Ele guarda um dos Dofus e o protege da cobiça dos aventureiros.",l:"fr",p:"4",t:0,c:"0",date:"1171321200000",rlng:[]};
SR[14] = {n:"Domen",d:"Domen é um dos três líderes de Brakmar. Fiel a Brumaire e a seu significado fundamentalista, seu coração é cheio de amargura desde a Aurora Rubra. Basta olhar para ele para ver que seu coração agora é feito da mais pura pedra.",l:"fr",p:"4",t:0,c:"0",date:"1175724000000",rlng:[]};
SR[15] = {n:"Amayiro",d:"Amayiro é um membro do Conselho de Bonta. Mestre de esgrima experiente, ele cirou a Milícia para proteger a cidade. Embora seja velho, ele ainda mantém o controle da milícia e o respeito do povo.",l:"fr",p:"4",t:0,c:"0",date:"1179784800000",rlng:[]};
SR[16] = {n:"Rykke-Errel",d:"Rykke Errel era um jovem discípulo Iop, o único a ser corajoso o bastante para desafiar o apavorante dragão Bolgrot. Quando alcançou a vitória, ele decidiu poupar a criatura e torná-la sua amiga. Entretanto, Rykke teve de matar o dragão depois, quando o dragão com ciúmes matou sua noiva.",l:"fr",p:"4",t:0,c:"0",date:"1182808800000",rlng:[]};
SR[17] = {n:"Hyrkul",d:"Hyrkul é um dos fiéis escudeiros de Djaul. Ele é cruel como o demônio que serve e também um poderoso guerreiro. Rushu tornou-o imortal em agradecimento aos serviços prestados ao lorde demônio.",l:"fr",p:"4",t:0,c:"0",date:"1183413600000",rlng:[]};
SR[18] = {n:"Helsephine",d:"Helsephine foi uma mágica cuja beleza equivalia somente a sua bondade. Ela roubou os corações do famoso herói Rykke Errel e seu amigo dragão Bolgrot. Ao invés de inflamar o coração da jovem mulher, Bolgrot ficou louco de ciúmes e colocou fogo nela... Rykke Errel matou o dragão para vingar sua amada.",l:"fr",p:"4",t:0,c:"0",date:"1192485600000",rlng:[]};
SR[19] = {n:"Allister",d:"Rei Allister é o governante bem amado de Amakna. Este Feca teve uma origem humilde como pastor, mas alcançou os holofotes quando capturou o demônio As\' Ruoy\' Dnim. Foi então que ele fundou a primeira guilda na história do Mundo dos Doze. Após confinar-se no castelo por muito tempo, Allister está tentando pouco a pouco interessar-se por assuntos do reinado mais uma vez.",l:"fr",p:"4",t:0,c:"0",date:"1196722800000",rlng:[]};
SR[20] = {n:"Otomai",d:"Otomai é um poderoso alquimista que criou a famosa poção anti-myxomawosis. Este mago se especializou no estudo de criaturas vivas, e foi responsável pela descoberta da ilha que hoje leva o seu nome. Este foi o lugar onde ele tentou reunir todas as criaturas do Mundo dos Doze para seus misteriosos experimentos.",l:"fr",p:"4",t:0,c:"0",date:"1201215600000",rlng:[]};
SR[21] = {n:"Lily",d:"Lily, uma famosa viajante, deu a volta ao mundo em 80 dias. Foi então que ele conheceu e adorou os Wabbits... especialmente quando estão na forma de comida! Ela muitas vezes vai até a Ilha dos Wabbits para desfrutar de uma \"viagem gastronômica\", e ela ainda leva alguns aventureiros com ela por alguns Kamas ... Lily possui não somente um senso de direção apurado, mas também um ótimo senso para os negócios!",l:"fr",p:"2",t:0,c:"0",date:"1203030000000",rlng:[]};
SR[22] = {n:"Oto Mustam",d:"Oto Mustam é o chefe da milícia Brakmariana. Impulsivo, violento e cruel, ele é leal à Djaul e repudia os seres humanos. Sua lealdade aos demônios chegou aos ouvidos de Rushu, o líder dos demônios, que confiou a ele uma missão: tomar conta de uma versão mais agressiva e caótica do Mundo dos Doze. Oto deverá escolher seus heróis, que entrarão para o grande exército do mau, e invadir o mundo e derrotar os deuses, quando a hora chegar.",l:"en",p:"0",t:1,c:"2",date:"1222120800000",rlng:[]};
SR[23] = {n:"Hel Munster",d:"Considerado um dos melhores magos de toda Amakna, Hel Munster ensina criação mágica para aventureiros com a condição de serem merecedores do aprendizado desta arte. Ele também é o autor do best-seller \"Criação de Objetos Mágicos para Leigos\", onde mostra sua teoria sobre a origem do mundo mágico em Amakna.",l:"fr",p:"2",t:0,c:"0",date:"1205794800000",rlng:[]};
SR[24] = {n:"Danathor",d:"Jiva escolheu pessoalmente Danathor para chefiar a milícia de Bonta. Ele é leal protetor de Javian e nada irá o impedir de derrotar a cidade de Brakmar garantir um lugar para si próprio na hierarquia do Mundo dos Doze. Danathor é um inimigo antigo de Amayiro.",l:"fr",p:"2",t:0,c:"0",date:"1208469600000",rlng:[]};
SR[25] = {n:"Kuri",d:"Kuri é um dos mais reconhecidos sacerdotes do amor. Eles são responsáveis pela epidemia emocional que derrubou as Geléias de Amakna muitos anos atrás. Ela é a Vovó-Doçura, senhota mão-direita e você a reconhecerá pelo seu legendário laçarote e seu ridículo chapéus que sempre carrega por aí.",l:"fr",p:"1",t:0,c:"0",date:"1211839200000",rlng:[]};
SR[26] = {n:"Mylaise",d:"Antes de se tornar uma Sacerdotisa do Amor, Mily era uma simples Ecaflip. Ela quase foi escolhida para participar do programa Ídolos do DOFUS quando a Vovó Bombom a viu e a recrutou para ser uma das guardiãs de sua Torre Amor Rústico.",l:"fr",p:"1",t:0,c:"0",date:"1223330400000",rlng:[]};
SR[27] = {n:"Goultard",d:"Goultard pode até parecer com um Iop, mas não se engane. Ele está longe de ser um humano. O coração desse guerreiro já foi tão grande quanto seus músculos mas em uma noite trágica sua vida mudou, e desde então ele só tem causado caos e destruição. Goultard é sem sombra de dúvida  o mais poderoso guerreiro do Mundo dos Doze.",l:"fr",p:"0",t:0,c:"0",date:"1227135600000",rlng:[]};
SR[28] = {n:"Ruliet",d:"A beleza de Ruliet é famosa em toda parte. Ela trata seus amores com uma garra de veludo, mas com unhas de ferro. Por onde ela passa todos sentem a sua presença. Dodge, o Ecaflip, foi um dos companheiros mais famosos de Ruliet, mas tudo acabou em tragédia, com o coração de Ruliet em mil pedaços e com o próprio Dodge também. Esse foi um acidente isolado, mas que mostra o quanto Ruliet pode ser igualmente linda e perigosa.",l:"fr",p:"0",t:0,c:"0",date:"1230505200000",rlng:[]};
SR[29] = {n:"Vil Smisse",d:"A vida de Vil Smisse foi longa, e ele não a desperdiçou! Desde a sua mais tenra juventude ladina, o Chefe do Clã dos Ladinos se envolveu em um misterioso símbolo demoníaco insaciável.",l:"fr",p:"1",t:0,c:"0",date:"1234479600000",rlng:[]};
SR[30] = {n:"Many",d:"Many é o Xelor mais útil de Djaul, e não é difícil saber o porquê - ele consegue arrancar dos mais relutantes espiões seus mais profundos segredos. Inúmeros espectadores inocentes teriam confessado os mais horríveis crimes sob a influência do relógio bem ajustado de Many;\r\n            e embora ele trabalhe duro, este discípulo do tempo consegue aproveitar todo os momentos possíveis.",l:"fr",p:"0",t:0,c:"0",date:"1236898800000",rlng:[]};
SR[31] = {n:"Solar",d:"Solar foi um lendário guerreiro Iop e o primeiro protetor do mês de Javian. Seu inacreditável poder se eleva com a luz do sol. Do nascer do sol até o meio-dia, seu poder se eleva. Depois disso e até o entardecer, seu poder se enfraquece. Solar foi derrotado por Djaul no dia 31 de dezembro, 11 e substituído por Jiva no dia 12 de Flovor, 12.",l:"en",p:"0",t:0,c:"2",date:"1214258400000",rlng:[]};
SR[32] = {n:"Crocoburio",d:"",l:"fr",p:"0",t:0,c:"0",date:"1259017200000",rlng:[]};
SR[33] = {n:"Li Crounch",d:"Um discípulo de Sadida e pintor de profissão, Li Crounch passou sua vida colocando em prática os preceitos de seu Deus com o mais implacável rigor: meditação e amor pela natureza. O jovem artista se dedica a dormir pelo menos 20 horas a cada 24 e pinta flores durante o resto do tempo, embora poucas pessoas acreditem nisso. Ele continua a ser um modelo para muitos Sadidas.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[35] = {n:"Farle",d:"",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[36] = {n:"Agride",d:"Enquanto outros lenhadores de Amakna como Brouce Boulgoure entraram nas páginas da história pelos seus atos brutos, outros se mantiveram mais modestos e anônimos, como no caso de Agride. Felizmente, nem valor nem mérito estão relacionados com glória. Sem ter ambos, Agride se esforça para transmitir lições sobre a arte dos lenhadores para quem lhe pede ajuda.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
