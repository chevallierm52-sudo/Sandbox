VERSION = 308;
SR = new Object();
SR[1] = {n:"Jiva",d:"Jiva es la protectora del mes de javián. Ella reemplazó a Solar cuando este fue asesinado por Djaul. Ella decidió construir Bonta con Pouchecot y Menalt para contrarrestar el creciente poder de Brakmar.",l:"fr",p:"2",t:0,c:"0",date:"1093298400000",rlng:[]};
SR[2] = {n:"Rushu",d:"Rushu es un demonio que sueña con convertirse en dios. Consiguió imponer a Djaul, su vasallo, como protector del mes de desiembro. Le tiene envidia a la diosa Sacrógrito y la acusa de ocupar el lugar que le estaba destinado.",l:"en",p:"2",t:0,c:"2",date:"1125525600000",rlng:[]};
SR[3] = {n:"Djaul",d:"Djaul es un demonio fiel a Rushu. Además es el protector del mes de desiembro. Odia ferozmente a los demás protectores hasta el punto de haber matado a uno de ellos y no precisamente al menos fuerte: el añorado Solar, ex-protector de javián.",l:"fr",p:"2",t:0,c:"0",date:"1132527600000",rlng:[]};
SR[4] = {n:"Raval",d:"Raval el terrible es el protector del mes de septango. Nadie sabe lo que quiere realmente. Raval ayudó a los brakmarianos a construir la ciudad oscura de Brakmar, sin embargo, durante la batalla de la Aurora Púrpura, fue el que los remató. Los tymadores le rinden un culto misterioso.",l:"fr",p:"2",t:0,c:"0",date:"1140562800000",rlng:[]};
SR[5] = {n:"Hécate",d:"Hécate es la protectora del mes de juliero. Es una demonia que no le hace caso a nadie. Salvó a Ulgrud, el protector de martalo, después de que hubiera luchado contra Djaul. Está secretamente enamorada de Ulgrud.",l:"fr",p:"2",t:0,c:"0",date:"1145916000000",rlng:[]};
SR[6] = {n:"Sumens",d:"Sumens es un ferviente servidor del dios Anutrof. También es el protector del mes de juninsidor. Cuando está digiriendo, a menudo se producen cosas extraordinarias. Pues todo aquello que se come se convierte en piedras preciosas...",l:"fr",p:"2",t:0,c:"0",date:"1149717600000",rlng:[]};
SR[7] = {n:"Menalt",d:"Menalt era un poderoso guerrero centauro comandante de la orden del Corazón Valiente. También era el protector del mes de martalo. A pesar de su heroísmo, cayó bajo los golpes de los brakmarianos durante la batalla de la Aurora Púrpura.",l:"fr",p:"2",t:0,c:"0",date:"1156802400000",rlng:[]};
SR[8] = {n:"Rosal",d:"Rosal es el amo de las flores y el protector del mes de maisial. No hay que fiarse de su aparente fragilidad. Es telépata y sabe ver en la mente de los mortales: puede desvelar sus secretos íntimos y para él, descubir las mentiras es como coser y cantar. No tiene piedad alguna con las almas impuras.",l:"en",p:"1",t:0,c:"2",date:"1159221600000",rlng:[]};
SR[9] = {n:"Maimane",d:"Maimane, el estabilizador, es el protector del mes de octobrero. Cansado por las sempiternas batallas que asotaban al Mundo de los Doce, decidió sellar las emociones enterrándolas mágicamente. Tanto el amor como el odio han sido ocultados, hasta que se encontraron por casualidad...",l:"fr",p:"2",t:0,c:"0",date:"1159826400000",rlng:[]};
SR[10] = {n:"Silvosse",d:"Silvoss, amo de los esquejes, es el protector del mes de flovor. Cuando se trata de proteger los vegetales que están bajo su custodia, puede dejarse llevar por su ira feroz. Antiguamente capturó almas de leñadores imprudentes, aprisionándolas en los troncos de los árboles. Él creó la especie abráknida.",l:"fr",p:"2",t:0,c:"0",date:"1165273200000",rlng:[]};
SR[11] = {n:"Brumario",d:"Brumario, el desangrador macabro, es el protector de novimiembro. Él estaba del lado de Djaul durante su fracaso en la Aurora Púrpura. Desde entonces, prepara su venganza y menosprecia a Djaul ya que piensa que no vale para nada y que además es un paleto.",l:"fr",p:"2",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[12] = {n:"Pouchecot",d:"Pouchecot, el gran afrutado, es el protector de agusto. Participó en la fundación de la ciudad de Bonta. Sabio, gran aficionado del arte y de la música, también es famoso entre los dioses y los mortales por sus chistes capaces de partir a los robles blandos de la risa.",l:"fr",p:"2",t:0,c:"0",date:"1166482800000",rlng:[]};
SR[13] = {n:"Siluate",d:"Siluate es un minotauroro cuya sabiduría le permitió convertirse en protector de aperirel. Él es el que hace desaparecer el frío del invierno. Es amigo de Sumens. Cuentan que Siluate es uno de los sabios que tomaron la decisión de poner los Dofus a salvo de la codicia de los aventureros.",l:"fr",p:"2",t:0,c:"0",date:"1171321200000",rlng:[]};
SR[14] = {n:"Domen",d:"Domen es un de los tres dirigentes de Brakmar. Son fieles a Brumario y fundamentalmente malos. Él es el protector lleno de la amargura propiciada por la derrota en la Aurora Púrpura. Generalmente adopta la apariencia de un espíritu vagabundo.",l:"fr",p:"2",t:0,c:"0",date:"1175724000000",rlng:[]};
SR[15] = {n:"Amayiro",d:"Amayiro forma parte del gran consejo de Bonta. Es un maestro de armas experimentado y fue el que tomó la iniciativa de crear la milicia para la defensa y la seguridad de la ciudad. A pesar de su avanzada edad sigue hoy en día siendo el jefe de la milicia.",l:"fr",p:"2",t:0,c:"0",date:"1179784800000",rlng:[]};
SR[16] = {n:"Rykke-Errel",d:"Rykke-Errel era un joven discípulo de Yopuka, el único en haber tenido el valor suficiente para desafiar al terrible dragón Bolgrot. Cuando consiguió derrotarlo, decidió dejarlo en vida y acabó convirtiéndose en su amigo. Sin embargo, tuvo que matarlo más tarde, ya que la criatura, loca de ira y de celos matara a la amada del Yopuka.",l:"fr",p:"2",t:0,c:"0",date:"1182808800000",rlng:[]};
SR[17] = {n:"Hyrkul",d:"Hyrkul es un fiel servidor de Djaul. Es tan malo y cruel como su amo, también es un poderoso guerrero. Ha sido consagrado inmortal por Rushu en agradecimiento a los favores que le hizo al demonio.",l:"fr",p:"2",t:0,c:"0",date:"1183413600000",rlng:[]};
SR[18] = {n:"Helsephine",d:"Helsefina era una maga hermosa y dulce. Su belleza embrujó el corazón de Rykke Errel, el famoso héroe, pero también el de su amigo el dragón Bolgrot. Éste, ya que no era capaz de avivar la llama del corazón de la jovencita, acabó abrasándola en un arrebato de celos. Rykke Errel mató a Bolgrot para vengar al amor de su vida.",l:"fr",p:"2",t:0,c:"0",date:"1192485600000",rlng:[]};
SR[19] = {n:"Allister",d:"Allister es el adorado rey de Amakna. Pastor de profesión, este feca se hizo famoso capturando al demonio Uk\'Not\'Allag. Fue en esta ocasión cuando fundó el primer gremio de la historia del Mundo de los Doce. Tras largos años aislado en su castillo, quiere volver a reinar como ya lo hizo antaño.",l:"fr",p:"2",t:0,c:"0",date:"1196722800000",rlng:[]};
SR[20] = {n:"Otomai",d:"Otomai es un poderoso alquimista, creador de la famosa pócima contra la mixomawosis. Especialista en el estudio de los seres vivos, a él se debe el descubrimiento de la isla que hoy lleva su nombre. Allí es donde intentó reunir todas las especies animales del Mundo de los Doce, para dedicarse a practicar misteriosos experimentos con ellas...",l:"fr",p:"2",t:0,c:"0",date:"1201215600000",rlng:[]};
SR[21] = {n:"Lily",d:"Famosa navegante, Lily se hizo un nombre al conseguir dar la vuelta al Mundo de los Doce en 80 días. Durante este mismo viaje nació su auténtica pasión por los wabbits... ¡Sobre todo en brochetas con zanahowia! Por este motivo acude regularmente a la isla y ofrece un poco de \"turismo gastronómico\" a los aventureros con algo de kamas... ya que además de tener Lily ojo de cazadora, gusto para la cocina,  posee un ¡excelente olfato para los negocios!",l:"fr",p:"2",t:0,c:"0",date:"1203030000000",rlng:[]};
SR[22] = {n:"Oto Mustam",d:"Oto Mustam es el jefe de la milicia brakmariana. Es impulsivo, violento y cruel y, como todos los fieles a Djaul, desprecia a los humanos. El mismísimo Rushu, su señor, para agradecerle su lealtad a los demonios, le ha confiado la siguiente misión: hacer que el Mundo de los Doce sea más violento y caótico de lo que jamás ha sido. Para ello tiene que seleccionar a los héroes que formarán parte del Gran Ejército Demoníaco, el mismo que arrasará el mundo para ganar la batalla final contra los dioses.",l:"en",p:"0",t:1,c:"2",date:"1222120800000",rlng:[]};
SR[23] = {n:"Hel Munster",d:"Hel Munster, al que muchos consideran como el mejor mago de Amakna, enseña la forjamagia a los aventureros que se demuestan ser mínimamente dignos. También es el autor del best-seller \"La Creación de Objetos Mágicos para Tontos\", donde expone, entre otras, su teoría sobre la aparición de la brisa cuadramental.",l:"fr",p:"2",t:0,c:"0",date:"1205794800000",rlng:[]};
SR[24] = {n:"Danathor",d:"Danathor es el intendente de Bonta, nombrado por la propia Jiva. Fiel a la protectora del mes de javián, está dispuesto a todo con tal de acabar con la ciudad de Brakmar, incluso si para ello recurrir a medios poco recomendables.\nEnemigo de Amayiro, está sediento de poder y tiene la intención de hacerse con un sitio en la jerarquía del mundo...",l:"fr",p:"2",t:0,c:"0",date:"1208469600000",rlng:[]};
SR[25] = {n:"Kuri",d:"Kuri es una de las tres famosas sacerdotisas del amor, responsables de la fiebre lúbrica que antaño golpeó a las gelatinas de Amakna. Es la mano izquierda de la temible Abuelita Bombón, y se la puede reconocer facilmente gracias a su arco legendario y a su sombrero, que es casi tan grande como su ego.",l:"fr",p:"1",t:0,c:"0",date:"1211839200000",rlng:[]};
SR[26] = {n:"Mylesa",d:"Antes de ser sacerdotisa del amor, Mylesa tan sólo era una simple discípula de Zurcarák, como tantas otras. Al estar siempre en muy buena forma y por tener unas formas generosas, estuvo casi a punto de que la Operación Dofus la seleccionara. Pero fue finalmente Abuelita Bombón la que la reclutó como guardiana de la Torre Ente.",l:"fr",p:"1",t:0,c:"0",date:"1223330400000",rlng:[]};
SR[27] = {n:"Gúltar",d:"Aunque Gúltar pueda parecerse en el físico a un yopuka, puedes estar seguro que no le queda nada de humano... Antaño era un guerrero con un corazón tan grande como sus músculos, pero algunos hechos trágicos que ocurrieron en su vida le han llevado por el camino del caos y de la destrucción. En cualquier caso, no cabe la menor duda de que Gúltar sigue siendo el guerrero más poderoso del Mundo de los Doce.",l:"fr",p:"0",t:0,c:"0",date:"1227135600000",rlng:[]};
SR[28] = {n:"Ulette",d:"Ulette es una zurcarakita de belleza sin par, una seductora de patas sedosas y zarpas de hierro que ha sabido atraer la mirada de más de uno. Pero a fuerza de hacer perder tantas cabezas, Ulette acabó perdiendo la suya. Efectivamente, Dodge (héroe zurcarák que no necesita ser presentado) fue una de sus conquistas. En una torpe rabieta, Dodge cortó a la linda Ulette en pedazos... al igual que a Vald, por cierto, pero ésta ya es otra historia.",l:"fr",p:"0",t:0,c:"0",date:"1230505200000",rlng:[]};
SR[29] = {n:"Vil Smis",d:"A lo largo de los tiempos, Vil Smis ha evolucionado y ha pasado de ser un simple asalta caminos a convertirse en un verdadero símbolo del mal. El jefe del clan de los tymadores es un personaje tan misterioso como escurridizo.",l:"fr",p:"1",t:0,c:"0",date:"1234479600000",rlng:[]};
SR[30] = {n:"Many",d:"Many es un fiel servidor de Djaul experto en el arte de arrancar confensiones. La historia ha perdido la cuenta de cuantos inocentes han confesado su culpabilidad entre las agujas de este xelor. Le encanta su trabajo... ¡lo que es una gran ventaja en su oficio!",l:"fr",p:"0",t:0,c:"0",date:"1236898800000",rlng:[]};
SR[31] = {n:"Solar",d:"Solar era un legendario guerrero yopuka, el primer protector del mes de javián. Desgraciadamente para él, Djaul, que quería aumentar su tiempo de trabajo, lo asesinó en el crepúsculo del 31 de desiembro del año 11 para luego intentar controlar flovor. Silvosse consiguió deshacer sus planes y Jiva paso a ocupar el puesto de protector de javián el 12 de flovor del año 12.",l:"en",p:"0",t:0,c:"2",date:"1214258400000",rlng:[]};
SR[32] = {n:"Cocoburio",d:"Hijo de Crocabulia y Grugalorasalar, Crocoburio llegó a ser jefe de guerra de los cocodrails. Era un luchador inigualable que había forjado su fama en numerosas batallas, hasta que finalmente perdió la vida en una batalla contra Bonta, matado por los caballeros de dicha ciudad. Hoy día de él sólo queda la Cocobur, su mítica espada.",l:"fr",p:"0",t:0,c:"0",date:"1259017200000",rlng:[]};
SR[33] = {n:"Li Crounch",d:"Li Crounch es un pintor discípulo de Sadida que se ha pasado la vida practicando rigurosamente los preceptos de su dios: meditación y amor por la naturaleza. El joven artista se toma muy en serio el dormir, como mínimo, 20 horas al día. Las otras 4 (o menos) las pasa pintando flores. Por eso poca gente se encuentra con él, pero así y todo sigue siendo un modelo para muchos sadidas.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[35] = {n:"Farle",d:"Farle Ingals es el campesino más famoso de Amakna. Su paciencia y su amor por la tierra no tienen par. Siempre ha cultivado sus campos en el corazón de Amakna con cuidado y respeto, incluso cuando hordas de aventureros pisotean sus parcelas de cereales. A Farle también se le reconoce el mérito de haber domesticado y calmado la sed de aventura de otra bella flor: la famosa Shika Ingals",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[36] = {n:"Agrid",d:"Mientras que algunos leñadores de Amakna -como Brus Bulguro- han entrado en la leyenda gracias a sus actos temerarios, otros son mas discretos y modestos. Tal es el caso de Agrid. Por suerte, ni el valor ni el mérito tienen que ver con la fama, porque a Agrid no le falta ni lo uno ni lo otro como demuestra esforzándose en transmitir los arcanos de la tala a quien quiera que se lo pida.",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[37] = {n:"Bowis",d:"Bowis es un respetado zapatero de mucho talento. A él le debemos las botas y los cinturones más bonitos y originales del Mundo de los Doce. Parte de su fama se debe al hecho de que es capaz de inventar ropa que le queda como un guante a todo el mundo. De hecho, muchos son los aventureros que calzan sus botas y todavía ni uno se ha quejado de que le aprieten el pie o le hagan rozaduras...",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[38] = {n:"Ogivol",d:"",l:"fr",p:"0",t:0,c:"0",date:"1259103600000",rlng:[]};
SR[39] = {n:"Lethalina",d:"",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[40] = {n:"Aermyn",d:"Aermyn siempre gozó de una excelente reputación para las mamás de Amakna. Cambiar pañales, lavar ropitas, preparar biberones... así era su día a día y lo hacía mejor que nadie. Pero de repente, un día una voz se puso a hablarle en la cabeza, y entonces todo cambió. Se acabaron los pañales y biberones, Aermyn echo de su casa a los niños a palazos. Nadie comprendía lo que pasaba, y ella tuvo que exiliarse en Pandala.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[41] = {n:"Zatoïshwan",d:"Zatoïshwan era un jugador empedernido, lo que resulta bastante raro para un pandawa. Estaba ciego, pero su reputación era tal que incluso los mejores zurcaráks lo temían. Un día le cayó un rayo, y salió como iluminado por la diosa Pandawa: de repente dominaba el arte ancestral de pandawushu. Tras esto se convirtió en justiciero antes de volverse el bandido que todos conocemos.",l:"en",p:"0",t:0,c:"2",date:"1259103600000",rlng:[]};
SR[99] = {n:"Torneos",d:"Este servidor está disponible en circunstancias puntuales, para la organización de torneos.",l:"fr",p:"2",t:2,c:"2",date:"1355266800000",rlng:[]};
SR[601] = {n:"Eratz",d:"Eratz es uno de los tres bandidos legendarios de Cania. Cuando se ve a uno de ellos, los otros dos no andan lejos. En cuanto al último que los vio... ¡Ya no está aquí para contarlo! Y es que para enfrentarse a Eratz hay que tener algo más que valor... ¡o no tenerle mucho apego a la vida!",l:"es",p:"0",t:0,c:"4",date:"1278972000000",rlng:["es"]};
SR[602] = {n:"Henual",d:"Henual es un guardián del tiempo. Nombrado por el mismísimo dios Xelor, debe permanecer en la mansión de los relojes del pueblo de Amakna con la mirada fija en las agujas, para prevenir hasta los menores incidentes que podrían rasgar la trama temporal. ¡El Gran Cronomaestro cuenta con él! Un rumor dice que cada año, Henual inmoviliza la gran aguja de las horas durante una semana para tomar vacaciones. Ninguna persona tiene el más mínimo recuerdo de tal evento, pero es verdad que en ciertos momentos no vemos el tiempo pasar. ¿Será Henual el responsable?",l:"es",p:"0",t:0,c:"4",date:"1327050000000",rlng:["es"]};
SR[900] = {n:"Test",d:"-",l:"fr",p:"0",t:0,c:"0",date:"1207173600000",rlng:[]};
SR[901] = {n:"Test Heroico",d:"-",l:"fr",p:"0",t:1,c:"2",date:"1355266800000",rlng:[]};
SR[902] = {n:"Beta Dofus 2.0 INTL",d:"",l:"en",p:"0",t:0,c:"2",date:"1228950000000",rlng:[]};
SR[903] = {n:"Salón Dofus 2",d:"",l:"fr",p:"0",t:0,c:"0",date:"1251324000000",rlng:[]};
SR[904] = {n:"Beta Dofus 2.0 FR",d:"",l:"fr",p:"0",t:0,c:"0",date:"1253829600000",rlng:[]};
SR[905] = {n:"Beta Dofus 2.0 JA",d:"",l:"ja",p:"0",t:0,c:"10",date:"1255039200000",rlng:[]};
SR[1001] = {n:"Shika",d:"Shika, la hermosa mujer del famoso Farle Ingals y amiga del rey Allister es conocida por haber participado en la captura de Uk\'Not\'Allag, un terrible y pérfido demonio. Cuentan que tiene una fuerza increíble y que con sus simples manitas es capaz de eliminar cualquier criatura que venga a molestarla.",l:"en",p:"0",t:0,c:"1",date:"1175724000000",rlng:["en"]};
SR[3001] = {n:"Nehra",d:"Nehra es una poderosa maga que hace mucho tiempo salvó de la destrucción al primer pueblo de los habitantes de Amakna. Incluso hoy en día sigue apareciendose para salvar a aventureros en peligro. Como nunca habla y desaparece enseguida ni siquiera los sabios conocen su historia. Pero eso no impide a muchos aventureros rendirle culto como su santa patrona.",l:"de",p:"0",t:0,c:"3",date:"1184104800000",rlng:["de"]};
SR[3002] = {n:"Katar",d:"Katar era un guerrero sacrógrito excepcional. Tan fuerte como un mediulubo y tan ágil como Moon, su fama traspasó las fronteras hasta llegar a oídos del demonio coleccionista de... guerreros excepcionales. El demonio pudo más que la bracura del sacrógrito y Katar fue poseído. Desde entonces, Katar erra por el mundo en busca de otro guerrero excepcional que pueda vencerlo para sí librarse de su maldición.",l:"de",p:"0",t:0,c:"3",date:"1259103600000",rlng:[]};
SR[4001] = {n:"Alma",d:"Alma es la protectora de los más valientes exploradores. Cuenta una leyenda que tras descubrir un nuevo mundo, envió desde este un enigmático mapa náutico donde vienen marcadas sus coordenadas. Se rumorea que todos aquellos que intentan cruzar el mar en busca de esas lejanas tierras no vuelven nunca porque encontraron un mundo mejor...\nOtros aseguran que Alma se les apareció cuando estaban perdidos en lugares poco hospitalarios y que gracias a ella consiguieron encontrar su camino...",l:"es",p:"2",t:0,c:"4",date:"1184104800000",rlng:["es"]};
SR[4002] = {n:"Aguabrial",d:"Aguabrial es uno de los dragones encargados de vigilar uno de los cuatro elementos. Él es el guardián del elemento agua. Cuando el Mundo de los Doce era todavía joven, engendró el primer Dofus Turquesa. Entonces Djaul intentó engañarlo y, desde aquel entonces, el dragón busca vengarse del demonio. Ya que aunque sea tranquilo y moderado, Aguabrial también puede enfurecerse contra sus enemigos... ¿No dice el refrán que hay que cuidarse de las aguas tranquilas?",l:"es",p:"2",t:0,c:"4",date:"1195772400000",rlng:["es"]};
SR[4003] = {n:"Buhorado",d:"Buhorado es el desaparecido Maestro de la famosa \'\'Corporación\'\' que reúne a todos los búhos del Mundo de los Doce: eruditos y contables, son los guardianes de los bancos y de la historia de Amakna. Buhorado era el más sabio de todos ellos, hasta que se perdió para siempre en el camino del \'\'Juego de la Lechuza\'\'. Se cuenta que su fantasma se apareció siglos más tarde, pero este rumor fue desmentido por los fieles seguidores de Allister, que piensan que Buhorado no es sino un vestigio de la \'\'Era de los Padrinos\'\', una oposición en potencia al poder del rey.",l:"es",p:"2",t:0,c:"4",date:"1212357600000",rlng:["es"]};
SR[4004] = {n:"Tinieblas",d:"Tinieblas es tristemente famoso por sus masacres y el arma legendaria a la que se le asocia. Esta arma se llama \'atormentador\', fue creada por su padre adoptivo, Sinserrín el Manitas, y le ayuda a revelar el auténtico alcance de su poder. Juntos, el uno y la otra forman el Caballero Negro, el personaje cuyo nombre no se pronuncia sin temblar.",l:"es",p:"1",t:0,c:"4",date:"1224108000000",rlng:["es"]};
SR[4005] = {n:"Bolgrot",d:"Bolgrot es un misterioso dragón que fue engendrado por Aguabrial y que cambió la historia del Mundo de los Doce. Desapareció durante los primeros siglos de su existencia hasta que un día se encontró con Rykke Errel en la puertas de Amakna. Rykke pretendía enfrentarse a Bolgrot, pero en vez de luchar, se hicieron amigos. Una gran amistad que terminó el día en que, dominado por los celos, Bolgrot mató a Helsefina, la amada de Rykke. Entonces, se desató una batalla titánica que terminó con la muerte de los dos protagonistas. En las entrañas del cuerpo de Bolgrot, los sabios de Amakna descubrieron seis huevos de extraños colores, que dieron comienzo a la leyenda de los Dofus.",l:"es",p:"0",t:0,c:"4",date:"1238709600000",rlng:[]};
SR[4006] = {n:"Nomekop",d:"Tanto sus amigos como sus enemigos lo apodan «El Crío». Sólo tiene dos amigos: Eratz, el Reivindicador, y Edasse, el Aguafiestas. Y enemigos... ¡son más numerosos que la hierba en las llanuras de Cania! Por donde pasa Nomekop, sus enemigos mueren... y la hierba no vuelve a crecer.",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4007] = {n:"Edass",d:"El Aguafiestas, ese es su mote. Y sin embargo le encantan la fiestas... A menudo se le oye decir: «¡Acércate! Ya verás que fiestecilla te hago» ¿Qué será lo que le pone tan contento? Los rumores dicen que tiene un Dofus. ¿O será uno de sus dos compañeros, Nomekop y Eratz? Habría que ir a preguntarle para estar seguro...",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[4008] = {n:"Eratz",d:"Eratz es uno de los tres bandidos legendarios de Cania. Cuando se ve a uno de ellos, los otros dos no andan lejos. En cuanto al último que los vio... ¡Ya no está aquí para contarlo! Y es que para enfrentarse a Eratz hay que tener algo más que valor... ¡o no tenerle mucho apego a la vida!",l:"es",p:"0",t:0,c:"4",date:"1259276400000",rlng:[]};
SR[6001] = {n:"Spiritia",d:"Dragón tornasolado con reflejos multicolores, simboliza el espíritu divino que desciende hasta la materia y anima a todas las criaturas del mundo. También representa la brisa cuadramental, de la que Hel Munster, el alquimista, tanto habló en sus libros.",l:"pt",p:"0",t:0,c:"6",date:"1206572400000",rlng:["en","pt"]};
SR[6002] = {n:"Helioboros",d:"Helioboros es uno de los tres dragones venerados por los discípulos de Osamodas.  Según cuenta una de sus leyendas, este gran dragón blanco podría haber sido uno de los que creó el Mundo de los Doce al ¡insuflar la luz! Los srams creen que fue Uronigrido, el gran dragón negro, que mordió la cola de Helioboros. Los dos dragones pudieron haber creado el mundo al hacerse un ovillo mientras luchaban... ¿Quién tiene razón? ¡Qué más da! Por un par de kamas, el Mago de Zo os cuenta un montón de leyendas del mismo estilo...",l:"pt",p:"0",t:0,c:"6",date:"1253484000000",rlng:["en","pt"]};
SR[7001] = {n:"Dark Vlad",d:"Dark Vlad es un yopuka tristemente conocido en los alrededores de Amakna, Bonta y Brakmar... Es el único yopuka que ha montado a lomos de karne volante. Maneja una espada flamígera que es la envidia de más de un aventurero. Su hogar es el Bosque Maléfico, y corta en lonchitas a los temerarios que se atreven a entrar en él.",l:"nl",p:"0",t:0,c:"7",date:"1219788000000",rlng:["nl"]};
SR[9001] = {n:"Ereziah\r\n",d:"Ereziah es un alquimista de los tiempos antiguos, y un exorcista con talento, su dominio de la magia sólo se vé igualado por su perspicacia. Tanto es así que su talento lo han hecho famoso en todo el Mundo. También se le conoce por su gran amistad con Aguabrial, el dragón del agua, al que salvo de una trampa que el demonio Djaul le había tendido. ¡Raros son los alquimistas que logran desbaratar los planes de Djaul!\n\nEfectivamente, la leyenda cuenta que un simple mortal habría salvado al todopoderoso dragón, de un embrujo de Djaul, el Gran Chapoteador. Este suceso causó la eclosión de un Dofus, y así nació Bolgrot.",l:"it",p:"0",t:0,c:"9",date:"1212357600000",rlng:["it"]};
