KBT[3] = {i:3,c:"Klik op een <a href=\"asfunction:onHref,SpriteIndicator,-1,9059\">Non Playable Character</a> (NPC) als je met ze wilt praten of interactie wilt hebben.",l:1};
KBT[4] = {i:4,c:"Klik op een  <a href=\"asfunction:onHref,SpriteIndicator,-1,1219\">monster</a> als je een gevecht wilt starten.",l:10};
KBT[5] = {i:5,c:"Klik op een rood blokje om je startpositie te kiezen.\nKlik dan op de <a href=\"asfunction:onHref,UiIndicator,ChallengeMenu,_lblReady\">\"Klaar\"</a> knop.",l:10};
KBT[7] = {i:7,c:"<a href=\"asfunction:onHref,UiIndicator,Banner,_pvMP\">Bewegingspunten</a> (MP) laten je bewegen in een gevecht.",l:10};
KBT[8] = {i:8,c:"<a href=\"asfunction:onHref,UiIndicator,Banner,_pvAP\">Actiepunten</a> (AP) laten je <a href=\"asfunction:onHref,UiIndicator,Banner,_msShortcuts,_ctr1\">spreuken</a> oproepen of <a href=\"asfunction:onHref,UiIndicator,Banner,_msShortcuts,_ctrCC\">close combat aanvallen</a> starten.\nAls je klaar bent met je beurt, vergeet dan niet om op de <a href=\"asfunction:onHref,UiIndicator,Banner,_btnNextTurn\">\"Eind van de beurt\" knop</a> te drukken.",l:10};
KBT[11] = {i:11,c:"Je krijgt je <a href=\"asfunction:onHref,UiIndicator,Banner,_hHeart\">Levenspunten</a> (HP) weer door de \"<a href=\"asfunction:onHref,UiIndicator,Banner,_btnSitDown\">zitten</a>\" emoticon te gebruiken, brood te eten, potions te drinken drinking of een <a href=\"asfunction:onHref,PictoIndicator,-1,7004\">fontein van de jeugd</a> te gebruiken.",l:11};
KBT[12] = {i:12,c:"Aan het einde van elk gevecht zal een tabel je de details weergeven van alle voorwerpen en ervaring die je hebt opgedaan.",l:10};
KBT[13] = {i:13,c:"Als je een gevecht verliest, zul je geteleporteerd worden naar je laatste opgeslagen punt.",l:23};
KBT[14] = {i:14,c:"Als je geen energie meer over hebt, zul je in een geest veranderen. Als je terug tot leven wilt worden gebracht moet je enkel een Phoenix standbeeld vinden.\nOpen je <a href=\"asfunction:onHref,UiIndicator,Banner,_btnMap\">kaart</a> om te zien waar de Phoenix standbeelden zijn.",l:23};
KBT[15] = {i:15,c:"<a href=\"asfunction:onHref,PictoIndicator,-1,7000\">Zaaps</a> geeft je de mogelijkheid om je positie op te slaan en te reizen tussen de verschillende <a href=\"asfunction:onHref,PictoIndicator,-1,7000\">Zaaps</a> waar je karakter al is geweest.",l:46};
KBT[16] = {i:16,c:"Als je goederen wilt kunnen verzamelen, moet je je beroep oefenen, het adequate level hebben en het juiste gereedschap hebben.",l:44};
KBT[17] = {i:17,c:"Klik op de arend Ganymede om met hem te praten.\n\nHet uitroepteken boven zijn hoofd betekend dat hij je een missie aan kan bieden.",l:1};
KBT[18] = {i:18,c:"Als je een level omhoog gaat krijg je een nieuwe spreuk.\n\nOm het te gebruiken, open je <a href=\"asfunction:onHref,UiIndicator,Banner,_bntSpells\">Boek der Spreuken</a> en verplaats het naar je <a href=\"asfunction:onHref,UiIndicator,Banner,_msShortcuts,_ctr4\">Spreukbalk</a>.",l:18};
KBT[19] = {i:19,c:"Je karakter is zojuist een level omhoog gegaan.\nJe kunt nu de <a href=\"asfunction:onHref,UiIndicator,Banner,_btnStatsJob\">karakteristieke punten</a> en de  <a href=\"asfunction:onHref,UiIndicator,Banner,_btnSpells\">Spreukpunten</a> verdelen.",l:27};
KBT[20] = {i:20,c:"Als je het juiste beroep en gereedschap hebt, kun je de goederen verzamelen.",l:44};
KBT[21] = {i:21,c:"Sommige <a href=\"asfunction:onHref,SpriteIndicator,-1,9037\">Non Playable Characters</a> (NPC) kunnen je beroepen leren, aarzel niet om met ze te praten.",l:44};
KBT[22] = {i:22,c:"Cursussen zullen het mogelijk maken voor je om gereedschappen en machines te gebruiken om voorwerpen te verwerken.",l:45};
KBT[23] = {i:23,c:"<a href=\"asfunction:onHref,SpriteIndicator,-1,9059\">Non Playable Characters </a> (NPC) met een groen uitroepteken boven hun hoofd kunnen je missies geven om te doen.\nAarzel niet om met ze te praten voor meer details.",l:1};
KBT[24] = {i:24,c:"Je kunt al je levenspunten herstellen door te drinken bij de fontein van de jeugd. Karakters van level 15 en hoger kunnen ze niet gebruiken.",l:11};
KBT[25] = {i:25,c:"Klik op je <a href=\"asfunction:onHref,SpriteIndicator,-1,53\">grafsteen</a> om je geest vrij te laten als je niet op de priester wilt wachten om je te herrijzen.",l:23};
KBT[26] = {i:26,c:"Je hebt een nieuw opgeslagen punt. Als je karakter dood gaat, zul je geteleporteerd worden naar dit punt.",l:23};
KBT[27] = {i:27,c:"Deze interface laat je je <a href=\"asfunction:onHref,UiIndicator,Quests,_dgQuests,_lstList,_mcContent,row0\">quests</a> bekijken.\nJe kunt op en van je <a href=\"asfunction:onHref,UiIndicator,Quests,_dgQuests,_lstList,_mcContent,row0\">quests</a> klikken om de verschillende stappen daarvan te zien.",l:60};
KBT[28] = {i:28,c:"Deze interface maakt het mogelijk je spreuken te zien en ze te verbeteren.\nJe kunt je spreuken van deze interface naar de <a href=\"asfunction:onHref,UiIndicator,Banner,_msShortcuts,_ctr4\">spreukenbalk</a> verplaatsen om ze makkelijker te kunnen gebruiken tijdens gevechten.",l:58};
KBT[29] = {i:29,c:"Deze interface laat je de kaart van het gebied waar je karakter is zien.\nJe kunt de belangrijke plaatsen van je keuze laten zien door de verschillende <a href=\"asfunction:onHref,UiIndicator,MapExplorer,_mcFilter4\">filters</a> te zien.",l:61};
KBT[30] = {i:30,c:"Deze interface laat je je karakteristieke punten zien en verdelen.\nJe kunt ook je ervaring (XP) en energiepunten zien.",l:31};
KBT[31] = {i:31,c:"Deze interface laat je de stappen in je quest zien. \nKlik op een <a href=\"asfunction:onHref,UiIndicator,Quests,_mcTab,_lstObjectives\">stap</a> met een compas ernaast om te zien waar je naartoe moet gaan.",l:60};
KBT[32] = {i:32,c:"Als je vermoed dat de veiligheid van je account is gecomprimeerd is kun je de tijd van de laatste connectie en het IP-adres wat er op zat controleren.",l:65};
KBT[33] = {i:33,c:"Je Verzamelaar is verlegen: tussen twee verzamelingen moet je hem een uur laten rusten voor elk level van je guild.",l:63};
