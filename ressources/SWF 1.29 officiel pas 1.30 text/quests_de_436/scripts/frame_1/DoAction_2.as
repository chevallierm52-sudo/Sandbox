Q.s[1093] = {n:"Eine Lücke in Goultards Biographie",d:"In Goultards Biographie steht nicht alles. Wenn man ein wenig in seiner Kindheitsgeschichte bohrt, dann treten Lücken und wer weiß, vielleicht sogar dunkle Geheimnisse zutage...",r:[null,null,null,null,null,null]};
Q.s[963] = {n:"Die vertauschten Hammer",d:"Um die Ausrüstung von Bonta zu sabotieren, verlangt Oto Mustam von euch, dass ihr die Werkzeuge der Schmiede durch 5 Martellhammer ersetzt.",r:[null,null,null,null,null,null]};
Q.s[904] = {n:"Sabotage",d:"Oto Mustam ist mit der Arbeit des Schmieds, der die Miliz von Bonta ausrüstet, sehr zufrieden. Er beauftragt euch damit, dafür zu sorgen, dass das so bleibt.",r:[null,null,null,null,null,null]};
Q.s[905] = {n:"Erzschmerz",d:"Matra hat gerade eine Lieferung an Erzen und neuen Werkzeugen erhalten. Nutzt seine Abwesenheit zwischen 17 Uhr und 21 Uhr aus, um das Erz zu stehlen und seine Werkzeuge auszutauschen.",r:[122000,null,null,null,null,null]};
Q.s[204] = {n:"Finde den Übeltäter",d:"Zatoïschwan wurde im Norden Pandalas gesichtet. Er wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,112500,null,null,null,null]};
