Q.s[409] = {n:"Wer mich mag, soll mir nun folgen!",d:"Der Wa-Pwinz hat dich darum gebeten, ihm ein Gefolge zu verschaffen, welches seinem Status angemessen ist. Im Hinblick auf seine Tüchtigkeit im Kampf, seine Spezialdiät und seinen Sinn für Schönheit, werden mindestens vier Personen benötigt, um ihn zu begleiten.",r:[45000,null,null,null,null,null]};
Q.s[693] = {n:"Das Schießpulver bringen",d:"Bringt Amayiro 10 Pods Schießpulver. Ihr könnt es bei Moob Kerwerefeu in Bonta kaufen.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"Die unbekannte Beschörung",d:"Amayiro hat euch damit beauftragt, bei Zeurks, dem Osamodameister, wegen einer unbekannten Beschwörung nachzufragen, die von Brâkmar benutzt wurde.",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Findet die Schwachstelle",d:"Ihr müsst etwas Interessantes über das Räderwerk des großen Tors von Brâkmar herausfinden.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"Einer flog ins Kukucksnest",d:"Amayiro will einen Hinterhalt für die Brâks legen, um die neue Ausrüstung und den Zusammenhalt der Milizionäre zu testen",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Unverblümtes Abfangen",d:"Ihr müsst eine Waffenladung abfangen, die sich irgendwo zwischen dem Rand des Astaknydenwaldes und dem Dorf der Brigandiner befinden müsste. Verstärkung wäre keine schlechte Idee.",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"Der alte Juwelier",d:"Der Anführer der Diebe meint, dass der Juwelier von Brâkmar, Milone Corichel, mehr Informationen hätte.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"Die Rückkehr Bishom Pots",d:"Amayiro vermutet, dass wie immer Brâkmar der Ursprung aller Probleme von Bonta sein könnte. Bishom Pot, Spion in der Miliz von Brâkmar weiß vielleicht etwas mehr...",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Ein unerbittlicher Untergrund",d:"Nur acht tapfere Abenteurer werden in der Lage sein, diesen Untergrund erfolgreich zu meistern!",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Ein mysteriöser Untergrund",d:"Ein Trittstein auf dem Gipfel eines Berges und eine versteckte Tür, die langsam zur Seite schwingt – das ist höchst mysteriös! Nun braucht man nur noch willige Abenteurer, um dem Geheimnis auf die Spur zu kommen...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"Der Untergrund der Bibliothek",d:"Wie überall im Keller einer Bibliothek, sind auch hier jede Menge Spinnweben und allerlei Bücher zu finden... Doch herrscht hier zudem noch eine merkwürdige Atmosphäre...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Ein finsterer Untergrund",d:"Eine versteckter Eingang tief im Gebirge gibt den Weg zu einem finsteren Untergrund frei – wenn man nur wüsste,  wie...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Ein uneinnehmbarer Untergrund",d:"Vorsicht vor den Dracheiern! Um zu dieser neuen Grotte zu kommen, musst du nämlich ihr Gebiet durchqueren...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Ein gefährlicher Untergrund",d:"Dieser Untergrund hat schon viele an den Rand der Verzweiflung gebracht!",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Ein Besuch beim Wirt",d:"Ihr müsst Amayiros Karte und ein Bier vom Feubk-Wirt besorgen.",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"Heisse Kartoffel",d:"Schält 200 Pods Kartoffeln und bringt sie dem Koch der Miliz.",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"Ein Pilzhut für Amayiro",d:"Bringt Amayiro einen gewöhnlichen Pilzhut. Den findet ihr auf den Meister Röhrling.",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Ein Rezept für Penta Gone",d:"Penta Gone hat bereits das gesamte Material zum Bierbrauen beisammen. Nun fehlt ihm nur noch das Rezept.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Auf der Suche nach dem Bwork-Bierrezept",d:"Pinta Gone sucht nach dem Rezept zum Brauen des berühmten Bwork-Bieres. Er meint, es könnte sich in einem seltsamen Raum im Bwork-Gebiet befinden.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Angriff auf das Schloss des Wa",d:"Ihr müsst Tökredilschs Bandana wiederfinden, das im Besitz der Wobots des Wa Wabitt-Dungeons ist.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"Das riskante Schneiderlein",d:"Ihr müsst ein Mittel finden, dem Löchrigen Bandana seinen ehemaligen Glanz zu verleihen und ihn in seinen früheren Zustand zu versetzen. Ein Schneider könnt euch dabei behilflich sein.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Hektische Wiederbeschaffung",d:"Ihr habt den Spion zwar rechtzeitig gefunden, aber die Brâks denken gar nicht daran, euch die Dokumente zu überlassen. Ihr müsst sie aber Amayiro bringen, koste es, was wolle.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"Kleiner Scherz zwischen Feinden",d:"Die Brâks sollten ihren Vorgesetzten die Dokumente übergeben. Ihr habt zum Vertauschen Fälschungen angefertigt, die eure Gegner auf die falsche Fährte locken sollen.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Rennen gegen die Zeit",d:"Ein Bonta-Spion ist dabei, Brâkmar über die östliche Route zu verlassen. Findet ihn und gebt ihm Geleit. Schnell! Die Zeit drängt!",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Ein belastender Bericht",d:"Im Ordensturm von Bonta befindet sich im Moment ein Bericht, der euch belastet. Ihr müsst unbedingt diesen Bericht in eure Hände kriegen, um eure Unschuld zu beweisen.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"Essen muss jeder.",d:"Unter dem Druck des Rates, hat Amayiro euch die Ermittlung entzogen und ihr seid nun für den Nachschub zuständig.",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Diebstahl im Turm",d:"Findet einen Komplizen, der die Wache ablenkt, während ihr einen kleinen Diebstahl durchführt.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"Spielzeugfabrik",d:"Scheußliche Kreaturen haben das Lager des Weißnachtsmannes ausgeraubt. Ihr müsst die gestohlenen Geschenkpakete wieder beschaffen, koste es was es wolle und sie zu Harry Kwismas bringen.",r:[null,1000,[[10920,1]],null,null,null]};
