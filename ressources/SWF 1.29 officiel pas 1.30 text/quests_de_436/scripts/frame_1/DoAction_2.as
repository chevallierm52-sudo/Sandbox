Q.s[704] = {n:"Lyenos Rettung",d:"Rettet Oberst Lyeno: Er wurde zuletzt im östlichen Teil des Astaknydenwalds gesichtet.",r:[12800,null,null,null,null,null]};
Q.s[722] = {n:"Noch eine Bitte des Kochs",d:"Der Koch der Miliz bittet euch erneut um eure Dienste.",r:[31000,null,null,null,null,null]};
Q.s[1088] = {n:"Spielzeugfabrik",d:"Scheußliche Kreaturen haben das Lager des Weißnachtsmannes ausgeraubt. Ihr müsst die gestohlenen Geschenkpakete wieder beschaffen, koste es was es wolle und sie zu Harry Kwismas bringen.",r:[null,1000,[[10920,1]],null,null,null]};
