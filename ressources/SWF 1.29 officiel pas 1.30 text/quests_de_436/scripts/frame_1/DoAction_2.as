Q.s[898] = {n:"Die Bestätigung",d:"Pandalida hat euren Kampf dazu genutzt, sich aus dem Staub zu machen. Sie ist bestimmt zu sich nach Hause gerannt. Ihr MÜSST sie dazu überreden, Xephirex den Brief zu bringen.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intime Einschüchterung",d:"Ihr müsst Pandalida einschüchtern, indem ihr ihr Haus verwüstet. Dazu braucht ihr 3x Kart Ben-Teig. Für den Teig zerstampft ihr 15 Keiler-Rüssel, 5 Becher Omnischlund und 1 Federboahfeder.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"Der Briefträger",d:"Findet einen Weg, Xephirex den Brief zu übermitteln. Er ist oft in der Taverne zum betrunkenen Pandawa, weigert sich aber nun, mit euch zu reden.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"Die Ablösung",d:"Ihr müsst den Krieger Tink Berval finden und ihn bitten Brank Thoof abzulösen.",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"Giftkröte",d:"Da Tökredilsch hungrig ist und die gewaltsame Methode ein Fehlschlag war, muss ein Weg gefunden werden, ihn zu vergiften. Ein Einwohner der Insel kennt bestimmt die Ernährungsgewohnheiten der Schildkröten.",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Es geht auch anders",d:"Da ihr mit einfachem Fragen keine Informationen herausbekommt, werdet ihr wohl andere, direktere Saiten aufziehen müssen...",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Verwandlung",d:"Imp Osiböl benötigt die Früchte deiner Arbeit.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Verwandlung",d:"Imp Osiböl benötigt die Früchte deiner Arbeit. Bringe ihm einen Mini-Heiltrank. Diesen kannst du aus Flachsblüten und etwas Wasser herstellen.",r:[50,null,null,null,null,null]};
Q.s[379] = {n:"Verwandlung",d:"Imp Osiböl benötigt die Früchte deiner Arbeit.",r:[50,15,null,null,null,null]};
Q.s[380] = {n:"Verwandlung",d:"Imp Osiböl benötigt die Früchte deiner Arbeit.",r:[50,15,null,null,null,null]};
Q.s[686] = {n:"Die Trinker verfolgen",d:"Durchforstet die Kneipen von Bonta auf der Suche nach Milizionären, die nicht auf ihrem Posten sind und verlangt nach ihren Abzeichen.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Tauschbedingungen",d:"Mödel hat dir eine Liste von Dingen erstellt, die sie im Austausch gegen ihre magische Halskette haben will.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"Eine soziale Tätigkeit",d:"Imp Iskret möchte wissen, ob die Dorfbewohner nicht irgendetwas Ungewöhnliches bemerkt haben.",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Tschaman Connection",d:"Der Tschamane ist ein Pandawa, der sehr viel über die subversiven Tätigkeiten bestimmter Einwohner weiß... Anscheinend ist auch hier nicht alles so rein, wie es scheint!",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"Ein Prosit auf die Göttin!",d:"Da du gerade frisch in Pandala angekommen bist, bittet dich der Tschamanen-Assistent, der Göttin zu huldigen – und zwar durch ein spirituelles Opfer... Deine Einweihung beginnt!",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Gelegenheitsarbeit - eine Gelegenheit zum Arbeiten?",d:"Imp Ost hat sicherlich einen Lieferauftrag für dich.",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"Ein Rezept für",d:"Imp Lanta wartet auf das Crêpes-Rezept, um die Ankunft ihrer Enkelkinder vorzubereiten.",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"Felsiger Abgang",d:"Steigt mit Hilfe eines Seils ins Versteck der Banditen hinunter. Geht nicht alleine!",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"Niedlich, niedlich",d:"Beim Zusammentreffen mit den Banditen habt ihr herausgefunden, dass Hersa Schattenklaue mehr weiß, als sie zugibt. Jetzt müsst ihr nur noch mit ihr reden, ohne dass sie euch das Gesicht zerkratzt.",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"Das auffindbare Versteck",d:"Amayiro hat euch beauftragt, in den Ebenen von Cania nach dem Versteck der Banditen zu suchen. Nach euren Informationen ist es nicht weit vom Jahrmarkt des Trools, ein bisschen im Westen.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Pretty Nara",d:"Nara hat euch eine lange Liste mit Dingen gegeben, die er zum Schmieden der Ausrüstung für Bonta-Milizionäre benötigt. Diese müsst ihr ihm in die Mine der Schweinios bringen.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Immobilienmakler",d:"Ihr habt mehrere verschieden Orte besichtigt, die euch Setag gezeigt hat. Jetzt müsst ihr Nara nur noch davon überzeugen, in einen dieser Orte umzuziehen.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"Immobilienerwerb",d:"Nara hat euch gebeten, einen einsamen Ort zu finden, wo er seine Schmiede einrichten kann.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Kisten transportieren",d:"Ihr müsst vier Kisten zwischen Amayiro und dem Vorposten von Bonta im Süden der Stadt befördern.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Die Bewährungsprobe",d:"Da du noch nicht sehr viel hier herumgekommen bist, wissen die Eingeborenen nicht, ob sie dir vertrauen können oder nicht...",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"Bier gewinnt",d:"Endlich hast du das Bier bekommen. Wenn du es Ewegi gibst, wirst du deine Energie wiedergewinnen.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Bier her!",d:"Ewegi will Bier. Warum geht er es dann nicht selbst holen?",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"Der Tierfreund",d:"Ihr müsst herausbekommen, wo Tökredilsch herstammt. Ein Tierspezialist wird euch bei euren Nachforschungen bestimmt weiterhelfen können. Oshimo, der Verantwortliche des Tierheims, wäre ein guter Anfang.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"Der Wabbit und die Schildkröte",d:"Oshimo meint, dass Tökredilsch sich einen tödlichen Feind gemacht hat. Angeblich hat Palp Hastin einen Pakt mit den Dämonen geschlossen, um mehr Macht zu bekommen. Er lebt auf der Insel der Wabbitskelette.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Das Adressbuch",d:"Füge einen Spieler zu deiner Freundesliste hinzu.",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"Monsterecke oder Eckenmonster?",d:"Meister Ding Dong hat dich aufgefordert, das Monster in seiner Ecke zu bekämpfen.",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Trool-Spiel mit Zusatzregeln",d:"Raxitik hat Angst. Er weiß, dass ihn die Bworks an die Troole ausliefern werden, damit er an einem Trool-Spiel mit Zusatzregeln teilnimmt. Darum muss der Trool, der die physische Integrität Raxitiks bedroht, aus dem Verkehr gezogen werden.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"Blutige Pilgerreise",d:"Stellt euch jedem Dubbel in den Klassentempeln",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Schildkröten erledigen",d:"Oto hat euch damit beauftragt, 10 Schildkröten der Moon-Insel zu töten. Bringt ihre Augen als Beweis.",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Wein für Oto",d:"Ihr sollt Oto einen 74er Omnischlundeau, Spätlese bringen. Wo kann man das bloß finden?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"Die Unterhaltung",d:"Eine wichtige Persönlichkeit aus Brâkmar möchte euch sehen. Sie befindet sich in den Kellergeschossen des Turms von Brâkmar.",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Kräftigende Tränke",d:"Oto Mustam braucht drei Bauermaid-Tränke.",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"Das aufgedeckte Versteck",d:"Dank der Nachricht des Anführers der Diebe könnt ihr nun sein Versteck finden. Wie wär\'s mit einem kleinen Ausflug dorthin, bevor ihr zur Miliz zurückkehrt?",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"Ausrüstung kaufen",d:"Ihr müsst die Ausrüstung auf Otos Liste kaufen und diese ausrüsten, bevor ihr zu ihm zurück geht.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"32 Goldzähne!",d:"Ihr müsst Mak ein goldenes Gebiss bringen. Ihr könnt eins bei den Elite-Chafern finden, aber der Schmied von Brâkmar kann euch bestimmt ebenfalls eins besorgen.",r:[28000,null,null,null,null,null]};
