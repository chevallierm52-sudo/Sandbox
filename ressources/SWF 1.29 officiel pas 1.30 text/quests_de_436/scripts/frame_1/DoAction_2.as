Q.s[907] = {n:"Das Geheimnis des Tierbändigers",d:"Oto Mustam will das Geheimnis zum Bezähmen von Blutwölfen kennen. Ihr müsst in die Bibliothek von Bonta zurückkehren, um dort Hinweise zu finden.",r:[134000,null,null,null,null,null]};
Q.s[1021] = {n:"Den Taktiker für immer verschwinden lassen.",d:"Ihr habt euch für die extremste aller Lösungen entschieden. Die für einen Brâk typischste Lösung.",r:[null,null,null,null,null,null]};
