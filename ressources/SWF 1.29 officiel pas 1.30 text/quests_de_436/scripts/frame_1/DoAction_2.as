Q.s[365] = {n:"Mit dem Schlüssel zwischen den Zähnen",d:"Für den Schlüssel zum Dungeon muss ein großer, dicker und vor allem kampferprobter Fresssack besiegt werden.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"Sadiwas?",d:"Danathor benötigt noch eure Dienste, um den Grimoire des Bwork Magus der dunklen Höhlen in die Hände zu bekommen. Es heißt, er hätte den Zauber Grafiozz auf die Welt losgelassen.",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Sadidannwollnwirmal",d:"Zweiblüm hat euch gezeigt, wo sich der Eingang zum Vegetarischen Gefängnis befindet. Da er ein bisschen benebelt war, kann man nur hoffen, dass er keine wichtigen Informationen vergessen hat..",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"Ein Schlüssel zum Eichhorn",d:"Ihr müsst ein Eichhörnchen in Brâkmar finden: es hat einen wichtigen Schlüssel gestohlen. Bringt ihn zu Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Die Kisten bringen",d:"Ihr müsst Oto die Kisten mit den Stichwaffen bringen, die sich im Turm von Brâkmar befinden.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Getas für Milone",d:"Als Strafe dafür, dass ihr die Diebe nicht aufhalten konntet, hat euch Milone befohlen, ihm Feudala Getas zu besorgen.",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Mak noch einmal entbeinen",d:"Mak Gahan, der Chafer, will seine Revanche.",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Lenglads Lektion",d:"William Lenglad muss eine neue Lektion erteilt werden.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"Tac und Tic",d:"Ihr müsst einen Taktiker finden und ihn dazu überreden, sich den Rängen Bontas anzuschließen.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Gerti Gertisorf",d:"Oto Mustam will Gerti Gertisorfs Meinung zu seiner Offensive gegen Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Zurück zu Oto",d:"Die Schlacht ist zu Ende, Oto Mustam wartet auf euren Bericht.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Scharmützel",d:"Auf dem Weg zwischen Bonta und Brâkmar findet im Moment ein Kampf in der Nähe der Bucht von Cania statt. Ihr müsst dazu stoßen und Brâkmar zum Sieg verhelfen!",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Hammertraining",d:"Oto braucht zehn Hölzerne Hämmer für das Training seiner Truppen.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"Der dunkle Kristall",d:"Ihr müsst mit den Handwerksmeistern den Geheimgang in der Alchemistenwerkstatt nehmen. Außerdem benötigt ihr  eine Harmonie, den Elementartrank Windbö und einen Kobalit.",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"Verbrechen zahlen sich nicht aus",d:"Die Nachricht wurde an Käpt\'n Starky geschickt. Während ihr auf seine Antwort wartet, solltet ihr nachsehen, ob sich Sa Biene auch ruhig verhält.",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"Das Lösegeld",d:"Ihr müsst einen Weg finden, Käpt\'n Starky zu kontaktieren und den Kristall des Kain Dharyn als Lösegeld zu fordern.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"Ab ins gefängnis",d:"Bringt Sa Biene gewaltsam zu Oto Mustam. Passt auf, dass sie euch nicht bei der erstbesten Gelegenheit entwischt.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"Sa Bienes Entführung",d:"Entführt Sa Biene und bringt sie an einen Ort, von dem sie nicht entkommen kann.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"Verbrechen werden sich auszahlen, verbrâkt noch mal!",d:"Die Bonta haben versucht, Sa Biene zu befreien. SO geht das aber nicht! Zeigt ihnen, wer hier das Sagen hat.",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Puja herausfordern",d:"Ihr sollt Puja Mustam, Otos Sohn, herausfordern und verlieren. Aber ihr werdet euch doch nicht etwa von so einem kleinen Pimpf töten lassen?",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"Ein neues Gebiss",d:"Ihr müsst Fresssackzähne herausreißen, um ein Gebiss fertigzustellen. Ihr benötigt genügend Zähne, um ein menschliches Gebiss zu fabrizieren...naja, ein humanoides Gebiss.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"Das grosse Schälen",d:"Ihr müsst Kartoffeln fürs Abendessen schälen. Die Küche ist unten.",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"Manitu Zoth besiegen",d:"Ihr müsst Manitu Zoth besiegen und den Beweis dafür Bob dem Enutrof überbringen",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Süssholzgeraspel mit Mayo",d:"Um das Horn des Ih-Fritts in eure Hände zu kriegen, müsst ihr einen Weg finden, euch bei Tökredilsch einzuschmeicheln. Die Bewohner der Moon-Insel können euch dabei helfen.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"Rückkehr zu Oto",d:"Da der Taktiker die Stadt verlassen hat, könnt ihr Oto Mustam glauben lassen, dass ihr ihn umgebracht habt.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Das Geheimnis des Tierbändigers",d:"Oto Mustam will das Geheimnis zum Bezähmen von Blutwölfen kennen. Ihr müsst in die Bibliothek von Bonta zurückkehren, um dort Hinweise zu finden.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"Das Gewurstel der Wurstfüllung",d:"Da Oto Mustam davon überzeugt ist, dass ihr ihn täuschen wollt, müsst ihr unbedingt das Juwel finden, bevor ihr in Wurstfüllung verwandelt werdet.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"Endlich!",d:"Xephirex hat die Bedingungen akzeptiert und ist bereit, Bonta zu gegebener Zeit zu verraten. Oto wird sich über diese Neuigkeit freuen.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"Die Unterhaltung",d:"Alles ist bereit, ihr müsst nur noch Xephirex in der Taverne zum betrunkenen Pandawa finden, ihm den Brief übergeben und ein Treffen für seine Antwort vereinbaren.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Rache! Muwhahaha!",d:"Das Versteck der Banditen ist mit Fallen gespickt. Ihr müsst einen Bastler der Mindeststufe 30 finden, der euch begleitet und euch hilft, die Fallen zu entschärfen.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"Berichterstattung",d:"Die Schlacht ist zu Ende. Hannes Schnalltgetin wartet auf euren Bericht.",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Scharmützel",d:"Im Augenblick findet auf halber Strecke zwischen Bonta und Brâkmar ein Kampf in der Nähe der Bucht von Cania statt. Ihr müsst hineilen und Bonta zum Sieg verhelfen!",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Ein Job",d:"Oto Mustam will wissen, wer den Chef des Gasthauses \"Zur Brennenden Katze\" ermordet hat.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"Blopbrei",d:"Bringt Oto zerstampften Blopbrei. Er kann euch das Rezept dafür geben.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Das Testament finden",d:"Ihr müsst Otos Testament im Grab seines Vaters auf dem Friedhof finden. Ihr erkennt das Grab am Blumengebinde drumherum. Damit ihr eintreten könnt, müsst ihr in einen Geist verwandelt sein.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"Piraten am Hafen",d:"Dank Xephirex wisst ihr, dass das Bonta-Schiff Korch Fok zahlreiche magische Gegenstände in seinem Frachtraum mit sich trägt. Findet das Schiff und vergreift euch an der Ware.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Eliminieren",d:"Eine Sram schuldet Oto Mustam Geld. Da sie ihm nichts zurückgezahlt hat, hat er beschlossen an ihr ein Exempel zu statuieren und sie zu eliminieren. Ihr findet sie wahrscheinlich in einer illegalen Spielhalle.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Die Krieger ausrüsten",d:"Oto befürchtet einen Angriff von Bonta und hat euch beauftragt, einige Brâk-Krieger mit Spezialausrüstungen zu beliefern.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Vetternwirtschaft",d:"Lloth Cini Bhaoh hatte recht: Matra Se hat den Vertrag zum Ausrüsten der Bonta-Miliz über Beziehungen bekommen und nicht etwa wegen seines Könnens als Schmied.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Ein Schmied mit linken Füssen",d:"Stellt Nachforschungen über den Lieferanten für Miliz-Ausrüstungen an und stellt den Schmied, der sie herstellt auf die Probe.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"Der Brunnen des Wahnsinns",d:"Ihr müsst den Brunnen der Besudelten Seelen finden, damit das volle Potential der Sudelsteine offenbart werden kann. Der Meister des Ordens des Kranken Geistes, Divad Dleifrepok, wird euch helfen können.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Böse Alchemie",d:"Besorgt euch Sudelsteine. Nur Bergmänner können diese aus Rohanfertigungen verrückter Alchemisten herstellen.",r:[null,null,null,null,null,null]};
Q.s[903] = {n:"Die sieben Seelen",d:"Fangt sieben Banditenseelen ein und bringt sie zum Brunnen der Besudelten Seelen, um sie zu unterwerfen. Ihr braucht auch Brâks, die ruchlos genug sind, um sich zu spezialisieren.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Den Spion finden",d:"Ihr müsst so schnell wie möglich den verletzten Spion auf der sich auf der Straße Richtung Bonta finden und die Dokumente an euch nehmen. Der Spion müsste näher an Bonta, als an Brâkmar sein.",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Herumstreifen in Kneipen",d:"Der Bandit dem dieses Schwert gehörte, ist wahrscheinlich in einer der Tavernen gewesen. Die Wirte wissen bestimmt etwas darüber.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Enorm wichtige Ermittlung",d:"Macht eure Runde bei den Wachen von Brâkmar und erstellt ein Protokoll über Wachen, die keine Pause machen.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Das Geheimnis des Tierbändigers",d:"Oto Mustam will das Geheimnis zum Bezähmen von Blutwölfen kennen. Ihr müsst in die Bibliothek von Bonta zurückkehren, um dort Hinweise zu finden.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Bis nach Brâkmar",d:"Der Taktiker hat eingewilligt, euch bis nach Brâkmar zu folgen.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Ein anderer Bericht",d:"Findet Niewsches Beilzang bei den Stadtmauern von Bonta und nehmt seinen Bericht.",r:[19000,null,null,null,null,null]};
Q.s[859] = {n:"Die Ewige Ernte",d:"Ihr habt die Kreaturenliste, jetzt müsst ihr sie nur noch finden.",r:[3440000,null,[[9688,18]],null,null,null]};
