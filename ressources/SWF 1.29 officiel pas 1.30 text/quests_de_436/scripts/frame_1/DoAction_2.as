Q.s[720] = {n:"Söbse Flichtens Tabi",d:"Söbse Flichten aus Bonta hat Probleme mit seinem Tabi.",r:[25000,null,null,null,null,null]};
Q.s[919] = {n:"Ein Eca flippt schon mal aus",d:"Ihr könnt jetzt Schlüssel anfertigen und das Banditenversteck nach Indizien durchsuchen. Ein Kletterseil kann euch beim hinunterklettern bestimmt nützlich sein.",r:[80000,null,null,null,null,null]};
Q.s[916] = {n:"Miez, miez!",d:"Ihr müsst den Schlüssel zum Versteck in eure Hände bekommen, was bedeutet, dass ihr einen Banditen in eure Hände bekommen müsst, der einen Schlüssel hat. Hersas Ex-Freund vielleicht...",r:[null,null,null,null,null,null]};
Q.s[917] = {n:"Schlüssig",d:"Ihr müsst von Kopien vom Schlüssel zum Banditenversteck anfertigen, bevor ihr zu mehreren hinein geht, um Dokumente an euch zu nehmen, die mit euren Ermittlungen in Verbindung stehen.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Seltsame Handlungen",d:"Im Viertel der Bäcker brauen sich seltsame Ereignisse zusammen. Amayiro befiehlt euch nachzuforschen.",r:[17000,null,null,null,null,null]};
Q.s[689] = {n:"Stöckchentraining",d:"Amayiro hat euch um 20 Hölzerne Stöckchen gebeten, um seine Truppen zu trainieren.",r:[4000,null,null,null,null,null]};
Q.s[718] = {n:"Danathors Bitte",d:"Danathor hat euch einen Brief geschickt, in dem er euch um Hilfe bittet.",r:[11500,null,null,null,null,null]};
Q.s[719] = {n:"Larry Poller",d:"Larry Poller bittet euch um eure Hilfe. Er befindet sich in der Nähe des Turms von Bonta.",r:[11500,null,null,null,null,null]};
Q.s[1035] = {n:"Das Geheimnis der Statue lüften.",d:"Parziweich hat sein Geheimnis am Fuß der Statue vergraben. Bückt euch, um es aufzuheben.",r:[null,null,null,null,null,null]};
Q.s[751] = {n:"Raaga helfen",d:"Findet Raaga in den Minen im Norden und fragt nach seinem Bericht.",r:[13500,null,null,null,null,null]};
Q.s[738] = {n:"Bericht des Spions",d:"Oto hat euch damit beauftragt, in Bonta den Spion Finch Aticus zu finden und ihn nach seinem Bericht zu fragen.",r:[5200,null,null,null,null,null]};
Q.s[743] = {n:"Auf der Suche nach dem magischen Gift",d:"Ihr müsst jemanden in Brâkmar finden, der sich mit magischen Giften auskennt.",r:[8200,null,null,null,null,null]};
Q.s[335] = {n:"An die Arbeit",d:"Frage den Vorarbeiter nach deinen Aufgaben.",r:[250,250,null,null,null,null]};
Q.s[382] = {n:"An die Arbeit",d:"Frage den Vorarbeiter nach deinen Aufgaben.",r:[250,250,null,null,null,null]};
Q.s[383] = {n:"An die Arbeit",d:"Frage den Vorarbeiter nach deinen Aufgaben.",r:[250,250,null,null,null,null]};
Q.s[784] = {n:"Mit einem Eisenherz ist nichts unmöglich.",d:"Ihr müsst ein Mitglied der Terra Familie finden und ihn zu Hannes Schnalltgetin bringen. Setag, der Klassenmeister der Enutrof kann euch bestimmt helfen.",r:[200000,null,null,null,null,null]};
Q.s[956] = {n:"Befehl oder Gegenbefehl?",d:"Da der gegenwärtige Angriffsbefehl nicht bestätigt wurde, müsst ihr die Bestätigung (oder die Abänderung) des Befehls beim Offizier Käppi Tähn einholen und diese Informationen anschließend zu Amayiro bringen.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Angriffsplan",d:"Amayiro fürchtet einen bevorstehenden Angriff der Brâks. Findet ihren Angriffsplan, damit Amayiro einen gebührenden Empfang für sie vorbereiten kann.",r:[null,null,null,null,null,null]};
Q.s[358] = {n:"Training",d:"Entledigt eine belebte Vogelscheuche ihrer Strohfüllung.",r:[25,null,null,null,null,null]};
Q.s[755] = {n:"Holz für Oto",d:"Oto möchte 10 Astaknydenrinden zum Heizen.",r:[16300,null,null,null,null,null]};
Q.s[946] = {n:"Tretet ein, haben sie gesagt...",d:"Snori Nairb hat euch illegal Eintritt in die Miliz von Bonta verschafft. Jedoch müsst ihr euch noch Amayiro vorstellen, um die Sache offiziell zu machen.",r:[null,null,null,null,null,null]};
Q.s[945] = {n:"Tretet ein, haben sie gesagt...",d:"Snori Nairb hat euch illegal Eintritt in die Miliz von Brâkmar verschafft. Jedoch müsst ihr euch noch Oto Mustam vorstellen, um die Sache offiziell zu machen",r:[null,null,null,null,null,null]};
Q.s[752] = {n:"Den Spion finden",d:"Ein Spion hat es geschafft, mit wichtigen Dokumenten aus Brâkmar zu entkommen. Vielleicht hat ihn eine der Wachen im Norden Brâkmars gesehen.",r:[14200,null,null,null,null,null]};
Q.s[979] = {n:"Dubbel besiegen",d:"Wenn ihr das Dubbel besiegt, bekommt ihr vom Kampfmeister eine Belohnung.",r:[null,null,null,null,null,null]};
Q.s[503] = {n:"Rohe Rohstoffe",d:"Nara, der Schmied, in der Mine des Territoriums der Schweinios, braucht Rohstoffe, um eine Standardausrüstung für die Bonta-Milizionäre anzufertigen.",r:[140000,null,null,null,null,null]};
