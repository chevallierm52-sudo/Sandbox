Q.s[726] = {n:"Mak entbeinen",d:"Besiegt Mak Gahan, den Chafer und bringt einen seiner Knochen zu Oto Mustam.",r:[50,null,null,null,null,null]};
Q.s[536] = {n:"Den Spion einholen",d:"Ein Spion aus Bonta hat sich in den Turm eingeschleust und Dokumente gestohlen. Benutzt ein Zaap, um ihn aufzuhalten. Er befindet sich östlich der Straße die nach Bonta führt, aber noch nahe bei Brâkmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Es geht voran mit den Halsabschneidern",d:"Nun hast du einen recht genauen Eindruck, wo sich der Unterschlupf der Halsabschneider befinden müsste. Überprüfe deine Hypothese!",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"Schicke Krypten",d:"Es gilt, die 5 Krypten des Friedhofes von Amakna zu erkunden.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"Für eine Handvoll Halsabschneider...",d:"Infiltriere die Halsabschneider und sprich mit Vil Smiss.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"Auf feindlichem Gebiet",d:"Ihr müsst euch in das Miliz-Gebäude von Bonta einschleusen und herausfinden, wo eure Gegner ihre Waffen lagern.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"Eine fette Kiste",d:"Ihr müsst die Wachsamkeit des Wächters zerstreuen, um ihm die Schlüssel zum Lager abzunehmen. Anschließend müsst ihr eine Kiste mit Ausrüstungen entwenden und diese zu Mulic Bere zum Begutachten bringen.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"Brâk-Umhänge",d:"Oto verlangt fünf Brâk-Umhänge von euch. Er kann euch sagen, wie man diese herstellt.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Wassergeschichten",d:"Gea Krugbrunner braucht Wasser für die Nymphen.",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"Auf der Suche nach dem Horn",d:"Der sogenannte Wächter des Ih-Fritt Horns soll sich angeblich im tiefen Dschungel der Moon-Insel befinden. Den Gerüchten zufolge, müsst ihr eine Heckenschutzmütze und Omniberg bei euch tragen, damit er erscheint.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"Die Informationen des Kapitäns",d:"Findet ein Mittel um mit dem verstorbenen Kapitän Tsog in Verbindung zu treten und die Informationen von ihm zu bekommen. Kapitän Hardblock weiß, wo Tsogs Grab liegt.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Findet den Schuldigen",d:"Findet Rimarafs Mörder und bringt das ausgefüllte Formular zu Amayiro.",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Falsche Beweise",d:"Findet ein Mittel, um Amayiro mit falschen Beweisen zu täuschen. Danathor kann euch bestimmt dabei helfen.",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"Rattenblut",d:"Amayiro hat euch befohlen, vier hyoaktive Ratten in der Kanalisation von Bonta zu erledigen.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Vertrauen ist gut...",d:"Amayiro will falsche Kräfte des Ih-Fritt Horns vortäuschen und braucht für diese Inszenierung vertrauenswürdige Leute.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"Wie im Theater",d:"Für die Inszenierung der falschen Kräfte benötigt Amayiro noch Miteter, die auf Krachlern zu finden sind und  Königliches Geleefett, egal welches.",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"Schon wieder eine Kollekte...",d:"Die Crâs brauchen Klauen von kranken Arachneen für ihre Pfeile, da diese anscheinend ein starkes Gift enthalten... Geschäft ist Geschäft.",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"Der Wunsch des Verrückten",d:"Sessi benötigt eine hölzerne Schaufel, um seinen post-apokalyptischen Schutzbunker zu bauen.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"Wasser und Brot für Eilof",d:"Um seinen unzerstörbaren Bunker zu bauen, bittet dich Sessi um zwei Kastanienbretter und genug Brote, um nach der Katastrophe mindestens 3 Tage lang überleben zu können.",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Eintopf",d:"Man muss die benötigten Zutaten im Hauptkessel zusammenmengen: Einen Gegenstand von jeder Art und einen Alchemisten, einen Bäcker, einen Bauer, einen Metzger und einen Fischhändler.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"Die Kunst zu Kochen, ohne müde zu werden- oder zumindest fast.",d:"Ihr müsst die Rezepturen der Zutaten finden, die auf der Liste stehen, die Oto Mustam euch gegeben hat.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Haarige Freunde",d:"Amayiro möchte mehr über Tökredilsch erfahren. Oshimo, der Tierheimwärter, weiß bestimmt mehr über diese Schildkröte.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Mehl Infos von den Lenalds",d:"Tökredilsch hat in der Vergangenheit mit den Lenalds verkehrt und sie verteidigt. Die Lenalds im Süden der Wabbit-Insel erinnern sich wahrscheinlich noch daran.",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Unterhosen einsammeln",d:"Besiegt die Milizionäre von Bonta und... nehmt ihre Unterhosen an euch. Oto will fünf davon.",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Arashholz",d:"Beschaffe dir Arashholz! Nur durch ein Opfer kannst du dich mit der Natur in Gleichklang bringen.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Das Ritual",d:"Finde jemanden, der dir dabei helfen kann, den Stecken des Initiaten anzufertigen.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Talent beweisen",d:"Du zeigst Talent. Leider sind noch nicht alle dieser Meinung...",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"Komm doch mit auf den Moonderberg",d:"Der sogenannte Wächter des Ih-Fritt Horns befindet sich angeblich im tiefsten Dschungel der Moon-Insel. Den Gerüchten nach müsst ihr eine Heckenschutzmütze tragen und Omniberg bei euch haben, damit er euch erscheint.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"Speichel, um ein Juwel zu fertigen?",d:"Um ein Juwel herzustellen, braucht ihr folgendes Material: 5 Goldbarren, 1x Perlmutt und 1x Königlichen Fresssackspeichel. Perlmutt erhält man, indem man 10 unbearbeitete Stücke Perlmutt poliert, die von Schalentieren und Mollusken auf Otomaïs Insel stammen. ",r:[80000,null,null,null,null,null]};
Q.s[1063] = {n:"Spielzeugfabrik",d:"Scheußliche Kreaturen haben das Lager des Weißnachtsmannes ausgeraubt. Ihr müsst die gestohlenen Geschenkpakete wieder beschaffen, koste es was es wolle und sie zu Harry Kwismas bringen.",r:[null,1000,[[10920,1]],null,null,null]};
