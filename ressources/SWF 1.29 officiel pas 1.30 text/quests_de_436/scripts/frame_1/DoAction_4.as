Q.s[970] = {n:"Der Schatz im Wald",d:"Das frühere Versteck des Dardondakal beherbergt angeblich ein Psychin. Der Eingang zu diesem Schlupfwinkel ist im Wald von Cania versteckt, aber man muss die richtigen Ressourcen besitzen, um ihn zu finden.",r:[296000,null,null,null,null,null]};
Q.s[969] = {n:"Erinnerungen",d:"Ihr sollt für Danathor Erinnerungssplitter eines Drachen einfangen. Ihr wisst zwar nicht, wo ihr welche finden könnt, aber die Wahrsagekunst dürfte euch hierbei behilflich sein.",r:[null,null,null,null,null,null]};
Q.s[788] = {n:"Das Geheimnis von Terra Cogita",d:"Terra Cogita besitzt Informationen über den Standort der Sumens-Statuen. Elviana hat euch damit beauftragt, sie noch vor den Brâks in die Hände zu bekommen.",r:[60000,null,null,null,null,null]};
Q.s[546] = {n:"Für eine Schüssel Komplott",d:"Sulsch Tim Sliglu Terpeh ist des Verrats angeklagt, aber Amayiro ist von seiner Unschuld überzeugt. Er beauftragt euch, Tims Version der Angelegenheit in Erfahrung zu bringen und auf den Wahrheitsgehalt zu prüfen. Er sitzt im Moment im Gefängnis.",r:[240000,null,null,null,null,null]};
Q.s[559] = {n:"Ein Verhör nach Vorschrift",d:"Amayiro hat euch damit beauftragt, den Zeugen, der Sulsch Tim Sliglu Terpeh des Verrats bezichtigt hat, so lange zu befragen, bis er etwas Interessantes enthüllt. Ihr findet ihn sicher im \"Alakarte\".",r:[null,null,null,null,null,null]};
Q.s[560] = {n:"Tatrekonstruktion",d:"Ihr müsst den Weg zurückverfolgen, den Sulsch Tim Sliglu Terpeh am Tag seiner Verhaftung zurückgelegt hat und all die Einwohner befragen, die ihr dabei trefft.",r:[null,null,null,null,null,null]};
Q.s[958] = {n:"Auf den Spuren des Sram",d:"Der Sram der Gnil Schirf bedroht hat, scheint ein regelmäßiger Gast bei Heticili Ufot zu sein. Geht da mal vorbei.",r:[256000,null,null,null,null,null]};
Q.s[475] = {n:"Eine faule Angelegenheit",d:"Ihr nutzt Xarthans Abwesenheit aus, um euch diskret Einlass in sein Haus zu verschaffen und es zu durchsuchen. Ihr werdet die Dienste eines fähigen Bastlers nötig haben.",r:[null,null,null,null,null,null]};
Q.s[924] = {n:"Zum Turm",d:"Xarthan trifft sich nach der Notablenversammlung mit einem Brâk im Turm von Bonta. Beeilt euch, damit ihr ihn nicht verpasst.",r:[95000,null,null,null,null,null]};
