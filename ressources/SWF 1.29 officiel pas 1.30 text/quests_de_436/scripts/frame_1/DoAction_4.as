Q.s[717] = {n:"Arbeit nach Wahl",d:"Ihr müsst Amayiro entweder 20 Bretter aus Eschenholz oder 10 Astaknydenwurzeln bringen.",r:[21000,null,null,null,null,null]};
Q.s[721] = {n:"Überfall bei Brâkmar",d:"Amayiro hat euch befohlen, Brâk-Krieger zu besiegen und 10 Abzeichen von ihnen zu sammeln.",r:[28000,null,null,null,null,null]};
Q.s[723] = {n:"Eine Lektion erteilen",d:"Ein gewisser William Lenglad stört die Bewohner von Bonta: Ihr müsst ihn ruhig stellen, wenn nötig, mit Gewalt.",r:[34000,null,null,null,null,null]};
Q.s[724] = {n:"In den Kerkern Brâkmars",d:"Amayiro hat euch befohlen, Nibb Tchel\'Schoso aus dem Gefängnis von Brâkmar zu retten und ihn zur Miliz von Bonta zurückzubringen.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"Pandrista bis zum Abwinken!",d:"Finde einen fahrenden Händler. An ihn kannst du die Pandristasteuer entrichten. Du musst allerdings mit Nachdruck darauf bestehen.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"Unter der Sonne von Pandala",d:"Gleich bei eurer Ankunft auf Pandala bist du von der Verwaltung ermahnt worden, dein Pandristasteuer zu entrichten.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"Meine erste Tschamanen-Party",d:"Bittet den Tschamanen um Beistand... Schnell!",r:[4700,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[170] = {n:"Eine neue Nachricht des Weisen",d:"Ein Bote bringt dir eine Nachricht. Höre, was er zu sagen hat.",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Das kleine Schildtraining",d:"Um dir für die Lieferung zu danken, hat dir der Schildschmied einen kleinen Trainingsschild zur Verfügung gestellt. Rede mit dem Meister des Dojos, um einen kleinen Trainingskampf zu absolvieren.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"Der Reiseschwierigkeiten erster Teil. Heute: Dialekte",d:"Der weise Lenald hat dich gebeten, zum Dorf Aerdala zu gehen... oder war es Teradala? Bei seinem Dialekt war es unmöglich, ihn deutlich zu verstehen... Rede mit dem dortigen Pandawushu-Meister.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"Beim Schildschmied",d:"In Teradala gibt es derzeit niemanden, der die benötigten Ressourcen zum Schildschmied bringen kann. Dabei ist das Schmieden neuer Schilde doch absolut überlebenswichtig für alle Pandawakrieger... Zum Glück gibt es ja noch dich!",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Wer hat Angst vor der bösen Maunzmiez?",d:"Poochan sucht ihren zukünftigen Ehemann. Sie hat nur zwei Hinweise: nämlich dass er sich erstens immer noch auf Pandala befinden soll und zweitens, dass er Angst vor Maunzmiezen habe. Vielleicht wäre es daher ratsam, dich in eine Maunzmiez zu verwandeln und als solche allen Einwohnern Pandalas in die Arme zu springen?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Freundschaftliche Übereinkunft",d:"Nach den hiesigen Sitten und Gebräuchen bestimmt der Familienvater, wen der Sohn oder die Tochter heiraten soll. Darum wirst du wohl den Vater überreden müssen, seinen Sohn gehen zu lassen. Das wird sicherlich nicht einfach...",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Eine Dento-Umstimmung mit Tücken",d:"Um Lanma von seinen Verpflichtungen zu befreien, wirst du sein Hochzeitsversprechen mit der Tochter des Dento-Dojos lösen müssen.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"Gibt\'s \'ne Belohnung?",d:"Poochan erwartet euch schon.",r:[7000,null,null,null,null,null]};
Q.s[174] = {n:"Bestaunen der Evolution und Transformation von Amakna",d:"Beim Bestaunen der Evolution und Transformation von Amakna (B.E.T.A) kannst du nebenbei auch noch die Welt, das Universum und den ganzen Rest retten!",r:[null,null,null,null,null,null]};
Q.s[173] = {n:"Ein Kwuarz und schon geht es weiter...",d:"Amine schlägt Henual vor, als letzten Ausweg das unübertroffene aller Hilfsmittel einzusetzen... Kwuarz!",r:[null,null,null,null,null,null]};
Q.s[172] = {n:"Amine, Vorsicht!",d:"Ein Brief vom Wächter Henual soll an Amine beim Xélor-Tempel überbracht werden.",r:[null,null,null,null,null,null]};
Q.s[178] = {n:"Tränke und Enttäuschungen",d:"Ein fahrender Händler wird dir sicherlich gern eines dieser fermentierten Getränke verkaufen, die den Ruf der Insel begründen. Jetzt musst du nur noch einen finden!",r:[null,null,null,null,null,null]};
Q.s[185] = {n:"Der Rokwa-Rang",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Rokwa-Rang.",r:[30000,null,null,null,null,null]};
Q.s[184] = {n:"Der Gokwa-Rang",d:"Jeden Samstag testet der Meister potentielle Kandidaten für den Gokwa-Rang.",r:[30000,null,null,null,null,null]};
Q.s[183] = {n:"Der Yonkwa-Rang",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Yonkwa-Rang.",r:[20000,null,null,null,null,null]};
Q.s[180] = {n:"Der Ikwa-Rang",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Ikwa-Rang.",r:[5000,null,null,null,null,null]};
Q.s[187] = {n:"Trainingsbeginn",d:"Um dein Training zu beginnen, benötigst du ein Zertifikat des Schamenen sowie geeignete Pandawushuka-Kleidung.",r:[null,null,[[7313,1]],null,null,null]};
Q.s[182] = {n:"Der Sankwa-Rang",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Sankwa-Rang.",r:[15000,null,null,null,null,null]};
Q.s[181] = {n:"Der Nikwa-Rang",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Nikwa-Rang.",r:[10000,null,null,null,null,null]};
Q.s[191] = {n:"Yondanwa",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Yondanwa-Rang.",r:[60000,null,null,null,null,null]};
Q.s[190] = {n:"Sandanwa",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Sandanwa-Rang.",r:[50000,null,null,null,null,null]};
Q.s[186] = {n:"Shodanwa",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Shodanwa-Rang.",r:[30000,null,null,null,null,null]};
Q.s[189] = {n:"Nidanwa",d:"Jeden Samstag testet der Meister potentielle Kanditaten für den Nidanwa-Rang.",r:[40000,null,null,null,null,null]};
Q.s[175] = {n:"Die Legende der Lenalds",d:"Endlich ist das Ziel in Sicht! Doch warten noch viele Überraschungen auf dich... Der Lenald der Wabbit-Insel ist nämlich gerade im Begriff, dir ein lange Zeit vergessenes geratenes Geheimnis anzuvertrauen.",r:[7500,null,null,null,null,null]};
Q.s[188] = {n:"Im Tempel der Gottheit",d:"Die Ratschläge des Weisen Lenalds befolgend, bereitest du deine nächste Expedition vor. Suche als nächstes den Tempel deiner Gottheit in Amakna auf.",r:[7500,null,null,null,null,null]};
Q.s[176] = {n:"Dark Vlad, ein Mann mit vielen Qualitäten...",d:"Reinige deine Seele und wasche deine Ohren! Der Weise Lenald enthüllt dir die Wahrheit über den Dofus von Pandala.",r:[40000,null,null,null,null,null]};
Q.s[193] = {n:"Der Dofus-Behälter",d:"Der Grandapan hat das Geschenk der Enutrofs mit Freuden angenommen. Als großer Bewunderer der Abenteurer auf der Jagd nach den Dofus heißt er dich mit offenen Armen bei ihm willkommen. Um deine Neugier bezüglich der Dofus zu stillen, lädt er dich ein, die Dofus-Behälter zu bestaunen.",r:[1500,null,null,null,null,null]};
Q.s[192] = {n:"Liebesgrüße aus Astrub",d:"Der Tschamane ist völlig überarbeitet. Mit all den Pandikazen, der rätselhaften Krankheit der Bergleute von Astrub und dem ganzen Rest... hat er leider keine Zeit für dich. Darum rät er dir, mit Piryt zu sprechen, dem Enutrof in Quarantäne hier.",r:[1500,null,null,null,null,null]};
Q.s[194] = {n:"Besser das Bier in der Hand, als das Fass auf dem Dach",d:"Der Weg des Wasser besteht darin, der Aufnahme von und dem Untertauchen in Wasser zu entgehen. Das bedeutet, niemals Wasser zu trinken und sich nur dann zu waschen, wenn es absolut notwendig ist. Finde den Meister des Weges des Wassers! Er weiß sehr viel mehr, als es scheint.",r:[10000,null,null,null,null,null]};
Q.s[207] = {n:"Der Grandapan",d:"Bringe diesen falschen Dofus zum Grandapan.",r:[2200,null,null,null,null,null]};
Q.s[195] = {n:"Stallknecht, Reitknecht, Jacke wie Hose",d:"Die Brâks haben die Vorratslager von Bonta zerstört. Findet einen Weg, die Reittiere der Miliz wieder mit Nachschub zu versorgen. Eine Lösung gibt es bei Merlaun, in der Werkstatt der Alchemisten.",r:[50000,null,null,null,null,null]};
Q.s[196] = {n:"In der Haut eines Spions",d:"Nachdem die Brâk die Lebensmittellager angezündet haben, will Tück\'n\'Stück wissen, was die Feinde aushecken.",r:[50000,null,null,null,null,null]};
Q.s[197] = {n:"Steht auf und geht!",d:"Elviana Tirips will die abtrünnigen Bontas verhören, aber vorher müssen diese wiedererweckt werden.",r:[50000,null,null,null,null,null]};
Q.s[782] = {n:"Riskante Landwirtschaft",d:"Gerti hat von Bontas Plänen Wind bekommen, ihre Getreideproduktion zu erhöhen. Er braucht 20 Skorpiutkörner, damit diese Produktion Brâkmars Schicksal dienlich ist.",r:[50000,null,null,null,null,null]};
Q.s[200] = {n:"Brâks linke Hände",d:"Da die Brâks unfähig sind, hat Gerti euch damit beauftragt, nach Astrub zu gehen und den Raymond Santho, den Händler aus Bonta, zu überreden, Brâkmar zu beliefern.",r:[null,null,null,null,null,null]};
Q.s[783] = {n:"Lebensmittelvergiftung",d:"Im Naschluss auf euren Bericht hat euch Heimgeh 20 präparierte Skorpiutkörner anvertraut, die ihr in der Werkstatt der Alchemisten von Bonta hinterlegen sollt. Ihr müsst sie nachts deponieren, wenn Merlaun der Ziberer schläft.",r:[50000,null,null,null,null,null]};
Q.s[198] = {n:"Sorge bei den Brâk",d:"Heimgeh fragt sich, was sich im Augenblick in Bonta zusammenbraut. Er schickt euch direkt vor Ort, damit ihr mit dem Spion Finch Aticus Kontakt aufnehmen könnt.",r:[null,null,null,null,null,null]};
Q.s[787] = {n:"Ich hab gesagt: Steh auf und geh!",d:"Erazals Fluch hat euch beigebracht, wie man eine Seele gegen ihren Willen dazu zwingen kann, wieder Fleisch zu werden. Dazu müsst ihr einen besonderen Trank herstellen und ein bestimmtes Ritual befolgen.",r:[50000,null,null,null,null,null]};
Q.s[199] = {n:"Steh auf und geh!",d:"Divad schafft es nicht, Terra Tibya für das Verhör wiederzubeleben. Man muss also einen Zauber zum Wiedererwecken improvisieren. Das ist eure Mission.",r:[null,null,null,null,null,null]};
Q.s[201] = {n:"Finde den Übeltäter",d:"Rok wurde im Norden Pandalas gesichtet. Er wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,6250,null,null,null,null]};
Q.s[202] = {n:"Finde den Übeltäter",d:"Musha wurde im Norden Pandalas gesichtet. Er wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,64000,null,null,null,null]};
Q.s[203] = {n:"Finde den Übeltäter",d:"Marzwel wurde im Norden Pandalas gesichtet. Er wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,25000,null,null,null,null]};
Q.s[206] = {n:"Finde den Übeltäter",d:"Aermyne wurde im Norden Pandalas gesichtet. Er wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,16000,null,null,null,null]};
Q.s[785] = {n:"Überraschungsverhör.",d:"Elviana Tripps will wissen, welche Informationen die Bonta-Renegaten den Brâks geliefert haben. Ihr seid mit dem Verhör beauftragt.",r:[200000,null,null,null,null,null]};
Q.s[786] = {n:"Die Renegatenjagd ist eröffnet!",d:"Einige Bonta-Renegaten haben sich nach Brâkmar geflüchtet. Findet sie, eliminiert sie und bringt ihre sterblichen Überreste nach Bonta.",r:[200000,null,null,null,null,null]};
Q.s[209] = {n:"Terra Tibyas Geheimnis",d:"Terra Tibya ist endlich wieder erweckt. Jetzt müsst ihr sie nur noch davon überzeugen, euch ihr Geheimnis anzuvertrauen.",r:[200000,null,null,null,null,null]};
Q.s[208] = {n:"Die Brücke führt zu Terra Tibya.",d:"Heimgeh Dammvert will die Sumens-Statuen in seine Hände bekommen und hat euch damit beauftragt, deren Wächter zu fangen.",r:[200000,null,null,null,null,null]};
Q.s[214] = {n:"Rede mit Igor Ant, Chef der Miliz von Astrub",d:"Igor Ant kennt alle Gesetze über den Schmuggel von Dofawa.",r:[1000,45,[[7929,1]],null,null,null]};
Q.s[213] = {n:"Rede mit Magus X",d:"Magus X ist in der Lage, die Tofueier und den Dofus näher zu untersuchen.",r:[1000,null,null,null,null,null]};
Q.s[212] = {n:"Tofueier für Nowa",d:"Bringe Nowa 2 Tofueier.",r:[1000,5,null,null,null,null]};
Q.s[217] = {n:"Eine eine violette Piepmatz-Feder für Acidrik",d:"Acidrik braucht diese Feder, um die Magie von Herdegriz zu bannen, die auf dem Plagiat seines Buches liegt.",r:[1500,100,[[7930,1]],null,null,null]};
Q.s[216] = {n:"Das gefälschte Buch Acidriks",d:"Das Buch heißt: \"Die Zeit der Drachen\" und nicht \"Die Zeiten der Drachen\"!",r:[1000,200,null,null,null,null]};
Q.s[215] = {n:"Ein Bier für Acidrik",d:"Acidrik ist in der Lage, aus dem Schaum eines guten Bieres die Zukunft vorherzusagen.",r:[500,null,null,null,null,null]};
Q.s[219] = {n:"Wo die Unendlichkeit und das Nirgendwo ineinander übergehen",d:"Hier findest du die Erleuchtung bezüglich Ménalts Seele.",r:[1500,50,[[7934,1]],null,null,null]};
Q.s[234] = {n:"Symbole und Symbolik",d:"Kehr zu Nistracolamus zurück, um die Bedeutung dieses Symbols zu erfahren.",r:[1000,null,null,null,null,null]};
Q.s[218] = {n:"Die Xélor-Statue",d:"Finde die Xélor-Statue. Du brauchst das Symbol, welches auf dem Hammer der Gottheit zu sehen ist.",r:[500,null,null,null,null,null]};
Q.s[220] = {n:"Die Höhlen des Kuhlosses",d:"Es heißt, der Kuhloss hause bereits seit Urzeiten in diesen Höhlen. Alle Züchter, die sich dort hineingewagt haben, sind niemals wieder gesehen worden.",r:[null,null,null,null,null,null]};
Q.s[221] = {n:"Ein Blick auf die Zwangsarbeiter",d:"Die Gefangenen von Astrub scheinen aufmüpfig zu sein. Ein Söldner bittet dich um Hilfe, um sie zu bewachen.",r:[1000,null,[[133,1]],null,null,null]};
Q.s[233] = {n:"Ein Tritt auf die Zwangsarbeiter",d:"Du hast die Gefangenen von Astrub wieder unter Kontrolle gebracht. Rede nun mit Edgg Komb.",r:[1000,50,null,null,null,null]};
Q.s[222] = {n:"Rundgang durch Allisters Schloss",d:"Degui Quetiristou schlägt dir vor, die neuen Bauvorhaben am Hafen und am Schloss zu besichtigen.",r:[7000,50,null,null,null,null]};
Q.s[224] = {n:"Lieber Holz auf dem Dach, als ein Brett vor dem Kopf",d:"Bringe Kartier Tremai frische Bretter aus Eschenholz, damit er das Dach von Allisters Schloss fertigstellen kann.",r:[3000,876,null,null,null,null]};
Q.s[227] = {n:"Leckeres Larvenfleisch",d:"Bringe Kartier Tremai Larvenstücke, damit er damit die Arbeiter ernähren kann.",r:[10000,1012,null,null,null,null]};
Q.s[226] = {n:"N\' Weizen für die müden Arbeiter",d:"Bringe Kartier Tremai Weizen, damit er damit die Arbeiter ernähren kann.",r:[3500,599,null,null,null,null]};
Q.s[225] = {n:"Feuerstein macht Mauer ganz",d:"Bringe Kartier Tremai Feuerstein, damit die Mauern von Allisters Schloss endlich fertiggestellt werden können.",r:[3500,1022,null,null,null,null]};
Q.s[232] = {n:"Kartier Tremai sucht Trinkbruder",d:"Kartier Tremai braucht Bier und einen Freund, um einen schönen Abend zu verbringen.",r:[7500,3000,null,null,null,null]};
Q.s[228] = {n:"Ein hübsch gedeckter Tisch",d:"Kartier Tremai will seine zukünftige Verlobte mit einer schön gedeckten Tafel verwöhnen.",r:[4000,4000,null,null,null,null]};
Q.s[230] = {n:"Ein Trauring für Monabella",d:"Kartier Tremai will Monabella zum Essen einladen und dabei um ihre Hand anhalten.",r:[2500,null,null,null,null,null]};
Q.s[229] = {n:"Einen Ring zum Dessert",d:"Kartier Tremai braucht einen Trauring.",r:[8500,3000,null,null,null,null]};
Q.s[231] = {n:"Kartier Tremai und Verumacha",d:"Kartier Tremai lädt Verumacha zu einem gemeinsamen Mahl ein.",r:[2500,null,null,null,null,null]};
Q.s[237] = {n:"Der lange Zahn der Korruption",d:"Der Hai bietet Verumacha Kamas an.",r:[10500,null,null,null,null,null]};
Q.s[235] = {n:"Im Kielwasser",d:"Verumacha sucht einen Hai.",r:[2100,null,null,null,null,null]};
Q.s[238] = {n:"Milchzähnchen",d:"Verumacha hat Lust auf Milch.",r:[12600,null,[[992,8],[989,8],[991,4]],null,null,null]};
Q.s[239] = {n:"Ein hai-liges Lächeln",d:"Sqale ist zufrieden mit der Wendung der Dinge.",r:[4800,null,null,null,null,null]};
Q.s[236] = {n:"Der wahre Hai",d:"Verumacha beauftragt dich, den \"Hailigen\" des Hafens zu jagen.",r:[null,null,null,null,null,null]};
Q.s[242] = {n:"Ein Stiefelleckertrank für eine schlüpfrige Angelegenheit",d:"Haraquiri hätte vielleicht auch gern einen solchen Trank für interne Hofangelegenheiten.",r:[16500,1000,null,null,null,null]};
Q.s[240] = {n:"Alle Zutaten für einen Stiefelleckertrank",d:"Für die Anfertigung eines Stiefelleckertrankes braucht man: Fresssackhörner, Blütenblätter von Dämonenrosen, gesäuberte Krakamors und Mohnkörner.",r:[6000,6000,null,null,null,null]};
Q.s[241] = {n:"Ein Stiefelleckertrank für eine Milchtussi",d:"Bring diesen Trank zu Monabella.",r:[7500,689,null,null,null,null]};
Q.s[243] = {n:"Rühren bis es schäumt",d:"Douglas Adamo Urethas benötigt viel Bier, um gegen den Hai anzutreten.",r:[7000,30,null,null,null,null]};
Q.s[244] = {n:"Wasser im Hopfen",d:"Douglas Adamo Urethas hat nun Kopfweh, da er zu viele Biersorten durcheinander getrunken hat.",r:[2000,40,null,null,null,null]};
Q.s[245] = {n:"Ein bissel Bier",d:"Der Dockarbeiter würde gern etwas trinken gehen, um seine düstere Stimmung etwas aufzubessern.",r:[1000,30,null,null,null,null]};
Q.s[249] = {n:"Eine Maunzmiez für die Tussi",d:"Monabella sucht eine kleine, weiße Maunzmiez. Wenn man sie so hört, könnte man glatt den Eindruck erhalten, sie würde eine ganze Menagerie benötigen, nur um in die Ferien zu verreisen.",r:[150000,5000,null,null,null,null]};
Q.s[248] = {n:"Ein passendes Reittier und etwas Öl",d:"Monabella braucht einen Dracotruter und etwas Sonnenblumenöl, um Ferien in ihrem Strohhaus im warmen Süden zu verbringen.",r:[140000,5000,null,null,null,null]};
Q.s[246] = {n:"Das Gefängnis im Visier der Immobilienmakler",d:"Monabella hat vor, das alte Versteck eines Gefängnisinsassen zu übernehmen, um es nach ihrem Geschmack einzurichten.",r:[20000,null,null,null,null,null]};
Q.s[247] = {n:"Die Strohhütte",d:"Monabella sucht ein freistehendes Haus, fernab vom Hofe.",r:[50000,null,null,null,null,null]};
Q.s[250] = {n:"Der Kartoffeldeal",d:"Diese Säcke voller Kartoffeln sollen zum Gefängnis am Hafen geliefert werden.",r:[2000,null,null,null,null,null]};
Q.s[252] = {n:"Arme Kartoffeln",d:"Ahus G\'pflogn bittet dich, Rocco Fidelio für die Kartoffeln zu danken.",r:[2500,1200,null,null,null,null]};
Q.s[251] = {n:"Ein Schaufel für Kartoffeln",d:"Ahus G\'pflogn würde gern eine kleines privates Kartoffelbeet anlegen.",r:[3000,null,[[538,12]],null,null,null]};
Q.s[253] = {n:"Dracotrutersteaks",d:"Haraquiri, der Hofmetzger Allisters, braucht Frischfleisch!",r:[5000,2500,[[10384,15]],null,null,null]};
Q.s[256] = {n:"Ein Besuch in der Bibliothek",d:"Geh die Bibliothek besuchen.",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[258] = {n:"Ein Besuch in der Bibliothek",d:"Geh die neue Bibliothek besuchen.",r:[5000,null,[[7805,1]],null,null,null]};
Q.s[261] = {n:"Trampel für die Trampel",d:"Der Milizionär hat sich klar und deutlich ausgedrückt: Es werden Dracotruter benötigt, und zwar schnell!",r:[75000,null,null,null,null,null]};
Q.s[262] = {n:"Die vollständige Kartographierung des Koalakgebirges",d:"Der Kartograph Lah Matreta ist nicht mehr der Jüngste, darum vertraut er dir diese heikle Aufgabe an.",r:[12000,50,[[7934,1]],null,null,null]};
Q.s[263] = {n:"Eine leichte Ernte",d:"Seltene Orchideen wachsen im Koalakgebirge. Es gilt, Maskara eine gute Ladung davon mitzubringen.",r:[7500,4000,null,null,null,null]};
Q.s[264] = {n:"Eine lange Liste",d:"Koka Dekolak braucht ganz bestimmte Ressourcen.",r:[30000,null,[[989,10],[281,2]],null,null,null]};
Q.s[265] = {n:"Die Lieferung der Reagentien",d:"Koka Dekolak braucht ganz bestimmte Ressourcen. Sie befinden sich alle im Gebiet der Koalaks.",r:[120000,6000,[[283,10],[548,5],[580,10]],null,null,null]};
Q.s[266] = {n:"Ein letzter Einkauf für Koka",d:"Koka braucht wieder einmal eure Hilfe...",r:[350000,11000,[[539,30],[991,10],[548,5],[6964,5],[6965,5]],null,null,null]};
Q.s[267] = {n:"Der Schlüssel zum Dungeon",d:"Beweise Fresssackofress deine Entschlossenheit, den Schlüssel zum Fresssack-Dungeon zu erlangen.",r:[7500,200,[[1568,1]],null,null,null]};
Q.s[268] = {n:"Die Weltreise",d:"Metam, der Krieger, hat dir etwas von einer Wunderreliquie mit fabelhaften Kräften erzählt. Doch musst du ihm erst deine Entschlossenheit beweisen.",r:[5000,null,null,null,null,null]};
Q.s[281] = {n:"Jeder findet seinen Meister",d:"Metam hat zugestimmt, dich auf die Probe zu stellen. Dazu schickt er dich zum rätselhaften Meister der Schlüssel.",r:[10000,null,null,null,null,null]};
Q.s[271] = {n:"Und weiter geht das Abenteuer",d:"Sei beharrlich und beweise deine Entschlossenheit.",r:[30000,null,null,null,null,null]};
Q.s[280] = {n:"Weiter geht\'s",d:"Der Herr der Schlüssel hat dich zum Ersten seiner Freunde losgeschickt.",r:[null,null,null,null,null,null]};
Q.s[270] = {n:"Und weiter geht das Abenteuer",d:"Sei beharrlich und beweise deine Entschlossenheit.",r:[30000,null,null,null,null,null]};
Q.s[269] = {n:"Kampf im ersten Dungeon",d:"Die Artefakt-Queste hat begonnen. Besiege die Monster des Dungeons!",r:[15000,null,null,null,null,null]};
Q.s[272] = {n:"Und weiter geht das Abenteuer",d:"Sei beharrlich und beweise deine Entschlossenheit.",r:[40000,null,null,null,null,null]};
Q.s[273] = {n:"Nur der Titel zählt",d:"Jumbo spielt diese Runde den Schiedsrichter.",r:[45000,null,null,null,null,null]};
Q.s[279] = {n:"Weiter geht\'s",d:"Jumbo Mumbo hat dich an die nächste Person weitergewiesen, die deine Fähigkeiten testen will.",r:[null,null,null,null,null,null]};
Q.s[278] = {n:"Nur der Titel zählt",d:"Jumbo lässt dich nicht aus den Augen.",r:[75000,null,null,null,null,null]};
Q.s[276] = {n:"Nur der Titel zählt",d:"Jumbo beobachtet dich genau.",r:[55000,null,null,null,null,null]};
Q.s[275] = {n:"Nur der Titel zählt",d:"Jumbo wird deine Fähigkeiten genauestens testen.",r:[45000,null,null,null,null,null]};
Q.s[277] = {n:"Nur der Titel zählt",d:"Jumbo hält seine Augen auf dich gerichtet.",r:[65000,null,null,null,null,null]};
Q.s[274] = {n:"Nur der Titel zählt",d:"Jumbo ist der Schiedsrichter für diesen Teil der Queste.",r:[45000,null,null,null,null,null]};
Q.s[288] = {n:"Eine einfache Etappe",d:"Trotz der Schwere der vergangenen Kämpfe waren diese nur ein einziger weiterer Schritt zum Ziel.",r:[null,null,null,null,null,null]};
Q.s[283] = {n:"Nicht trödeln",d:"Kris scheint es kein wenig besser zu gehen. Drum wäre es wohl besser zu gehen, bevor sich sein Zustand noch verschlimmert.",r:[135000,null,null,null,null,null]};
Q.s[284] = {n:"Schnell, schneller und noch schneller!",d:"Trotz seines gestressten Zustandes hat dich Kris bei deiner Artefakt- Queste weitergebracht.",r:[145000,null,null,null,null,null]};
Q.s[287] = {n:"Noch eine Allerletzte...",d:"Du dachtest wahrscheinlich schon, dies sei die letzte Schlacht vor dem Sieg.",r:[175000,null,null,null,null,null]};
Q.s[282] = {n:"Such woanders weiter",d:"Kris scheint ein wenig im Stress zu sein. Es wäre wohl besser zu tun, was er sagt.",r:[125000,null,null,null,null,null]};
Q.s[285] = {n:"Eine echte Herausforderung",d:"Kris schickt dich an zunehmend gefährlichere Orte...",r:[155000,null,null,null,null,null]};
Q.s[286] = {n:"Noch Einer...",d:"Du spürst, wie du mit deiner Queste vorankommst... gaaanz... gaanz... langsam...",r:[165000,null,null,null,null,null]};
Q.s[296] = {n:"Der letzte Schlüssel",d:"Glah hat dir nun den letzten seiner Schlüssel anvertraut. Du näherst dich dem Ziel.",r:[450000,null,null,null,null,null]};
Q.s[297] = {n:"Weihung?",d:"Glah hat nichts mehr, was er dir anvertrauen könnte. Kehre zum Herrn der Schlüssel zurück.",r:[null,null,null,null,null,null]};
Q.s[289] = {n:"Eine deutliche Nachricht",d:"Glah, eine Art Maschine, wird dir helfen, deine Queste fortzusetzen. Bei ihm sind die Ziele wenigstens klar und deutlich definiert.",r:[250000,null,null,null,null,null]};
Q.s[291] = {n:"Technisches Versagen",d:"Glah hat seine Probleme noch nicht lösen können, doch wird dich das bei deiner Queste nicht weiter aufhalten.",r:[350000,null,null,null,null,null]};
Q.s[295] = {n:"Es fehlt eine Mutter",d:"Glah bleibt weiterhin blockiert, doch gibt er dir den Schlüssel.",r:[400000,null,null,null,null,null]};
Q.s[290] = {n:"Probleme?",d:"Glah konnte dir nicht die ganze Nachricht übermitteln. Doch mit dem Schlüssel solltest du genug erraten können, um zu wissen, was zu tun ist.",r:[300000,null,null,null,null,null]};
Q.s[299] = {n:"Meister am laufenden Band",d:"Der Herr der Schlüssel hält dich anscheinend für eine echte Kampfmaschine. Eine weitere Prüfung erwartet dich.",r:[725000,null,null,null,null,null]};
Q.s[298] = {n:"Meister am laufenden Meter",d:"Der Herr der Schlüssel hat entschieden, dich weiteren Prüfungen zu unterziehen. Langsam wird es wirklich langwierig.",r:[500000,null,null,null,null,null]};
Q.s[301] = {n:"Der Meister hebt ab",d:"Endlich geschafft! Der Herr der Schlüssel hat dir eine allerletzte Aufgabe aufgetragen.",r:[875000,null,null,null,null,null]};
Q.s[300] = {n:"Meister am Stück",d:"Es scheint, als könntest du niemals dieser nicht enden wollenden Reihe an Massakern entrinnen. Naja, noch eins mehr oder weniger...",r:[800000,null,null,null,null,null]};
Q.s[307] = {n:"Der Meister aller Katastrophen",d:"Es gilt, ein weiteres feindliches Gebiet zu durchqueren.",r:[650000,null,null,null,null,null]};
Q.s[306] = {n:"Damit der Meister nicht aus allen Wolken fällt",d:"Dieses Mal schickt dich der Herr der Schlüssel mitten ins umkämpfte Grenzgebiet!",r:[575000,null,null,null,null,null]};
Q.s[302] = {n:"Endlich!",d:"Endlich am Ziel! Nun muss Metag sein Versprechen halten und die Familienreliquie herausrücken.",r:[1000000,null,null,null,null,null]};
Q.s[315] = {n:"Expresslieferung",d:"Das Filtounga-Gericht von Pol ist jetzt fertig.",r:[null,null,null,null,null,null]};
Q.s[312] = {n:"An den Ofen, fertig, los!",d:"Das Filtounga-Rezept befindet sich nun in deinen Händen. Jetzt musst du nur noch die benötigten Zutaten zusammensuchen, damit Pol loslegen kann.",r:[115000,5000,null,null,null,null]};
Q.s[311] = {n:"Die Hauptspeise",d:"Die grausame Bel Nechuk droht damit, Els Kinder aufzuessen, wenn sie nichts Besseres zwischen die Zähne bekommt.",r:[75000,null,null,null,null,null]};
Q.s[313] = {n:"Die Zutaten",d:"Pol, der Meisterkoch, wird dir dieses Gericht zubereiten, vorausgesetzt, du bringst ihm alle nötigen Zutaten.",r:[115000,null,null,null,null,null]};
Q.s[316] = {n:"Die Befreiung",d:"Pols Filtounga ist fertig. Bel Nechuk wird nun hoffentlich zufrieden sein.",r:[120000,null,null,null,null,null]};
Q.s[310] = {n:"Die kleine Hütte im Wald",d:"Der kleine Jorg hat eine versteckte Hütte erwähnt, die sich tief im Wald der Dracotruter befinden soll.",r:[25000,null,null,null,null,null]};
Q.s[309] = {n:"Ein Rundgang durch das Dorf",d:"Die Dorfbewohner müssen doch sicherlich irgendwo die El-Kinder gesehen haben. Befrag sie, um an weitere Informationen zu kommen.",r:[35000,null,null,null,null,null]};
Q.s[308] = {n:"Eine Mutter sieht rot",d:"Frau El ist in Panik. Sie sucht im Dorf Amakna nach ihren Kindern.",r:[null,null,null,null,null,null]};
Q.s[314] = {n:"Schnellimbiss",d:"Pol hat nun alles, was er braucht, um das Filtounga-Gericht zuzubereiten. Nun hilft nur noch etwas Geduld.",r:[15000,null,null,null,null,null]};
Q.s[321] = {n:"Bworkis Mord",d:"Gobatchef will, dass alle Bworks massakriert werden, bevor sie daran gehen, die Goblins zu massakrieren.",r:[20000,1000,null,null,null,null]};
Q.s[322] = {n:"Krazybwork von Intelligenz gebissen!",d:"Krazybwork hat in der Bworkdrift-Schlacht zu viele Goblins gegessen. Dadurch ist er intelligent geworden und sehnt seinen früheren Zustand wieder herbei. Am Besten ziehst du ihm kräftig eine über den Schädel.",r:[null,500,[[8527,1]],null,null,null]};
Q.s[323] = {n:"Bworkidäh, der Pazifix",d:"Prügeln oder nicht prügeln, das ist hier die Frage!",r:[15000,null,null,null,null,null]};
Q.s[325] = {n:"Folge dem Schnittmuster",d:"BworknRoll muss nun seine Kreatur mit frischen, saftigen Organen füllen.",r:[150000,null,null,null,null,null]};
Q.s[326] = {n:"Und das Wichtigste: miese Muscheln!",d:"Um seine Traumkreatur fertig zu stellen, benötigt BworknRoll nur noch eine miese Muschel, die gerade aus dem Wasser kriecht.",r:[230000,5000,null,null,null,null]};
Q.s[324] = {n:"Ein nützliches Skalpell",d:"BworknRoll braucht Teile, um den idealen Lebensbegleiter zu erschaffen.",r:[120000,null,null,null,null,null]};
Q.s[375] = {n:"Was für große Zähne du hast...",d:"Ein WuWulf macht dir ein verlockendes Angebot.",r:[null,null,null,null,null,null]};
Q.s[376] = {n:"Anmeldung",d:"Wenn BworknRoll die Zahlung annimmt, kann Juppi seinen Magie-Unterricht aufnehmen.",r:[null,null,null,null,null,null]};
Q.s[328] = {n:"In Begleitung eines Juppis",d:"Juppis Vater will, dass sein Sohn ein Magus wird. Aus diesem Grund sollst du in nun zum mächtigsten aller Bwork Magi bringen, zusammen mit einigen Nahrungsmitteln.",r:[null,null,null,null,null,null]};
Q.s[374] = {n:"Juppi wurde angenommen",d:"BworknRoll hat zugestimmt, Juppi die Künste der Magie beizubringen. Berichte seinem Vater diese Neuigkeit.",r:[null,null,null,null,null,null]};
Q.s[330] = {n:"Grünhäute",d:"Bworkepiek braucht einige Goblinhäute für seine Weibchen.",r:[45000,30000,null,null,null,null]};
Q.s[331] = {n:"Ein Stab und ein Set",d:"Der Bworkester-Chef will seine Männlichkeit und Tapferkeit vor seinem Weibchen zur Schau stellen. Das macht er, indem er von jedem Reisenden, der durch sein Dorf möchte, ein G\'scheng fordert. \nMit einem Prespik-Set will er nun die harten Nudelholzschläge seiner Bwork-Liebsten ein wenig abmildern.",r:[45000,35000,null,null,null,null]};
Q.s[340] = {n:"Ein paar Palaver später",d:"Gobrosa zieht es vor, Sklavin zu bleiben und Piepmätze aufzuziehen. Ob ihr Freier diese Nachricht verkraften wird?",r:[20000,null,null,null,null,null]};
Q.s[339] = {n:"Gobrosa rupfen",d:"Gobrator ist eifersüchtig auf die Piepmätze von Gobrosa. Denn nur das Flattern seines kleinen, grünen Goblinherzens sollte als Einziges dasjenige von Gobrosa zum Erklingen bringen.",r:[3000,null,null,null,null,null]};
Q.s[337] = {n:"Ein voller Bierbauch",d:"Bworksweina ist bereit, ihren Sklaven gegen sein Gewicht in Bier einzutauschen.",r:[12000,null,null,null,null,null]};
Q.s[338] = {n:"Eine feierliche Feier für den Freier?",d:"Werden Gobrosa und Gobrator endlich vereint sein?",r:[null,3000,null,null,null,null]};
Q.s[336] = {n:"Auf der Suche nach dem Unterschlupf von Bworksweina",d:"Genau dort wird Gobrosa festgehalten.",r:[1000,null,null,null,null,null]};
Q.s[354] = {n:"Kampf auf der Seite der Wächter",d:"Der Hauptmann hat dir eine einfache, aber nützliche Aufgabe aufgetragen.",r:[195,null,null,null,null,null]};
Q.s[345] = {n:"Wachablösung",d:"Imp Iskret hat dich darum gebeten, zu überprüfen, dass die Wächter ordentlich ihre Arbeit verrichten.",r:[230,null,null,null,null,null]};
Q.s[362] = {n:"An Form gewinnen...",d:"Ewegi Leese hat dich in einen Geist verwandelt. Nutze eine Phönixstatue, um deine ursprüngliche Gestalt wiederzuerlangen.",r:[null,null,null,null,null,null]};
Q.s[363] = {n:"Ein osaheblicher Osamodas",d:"Dieser aufgeblasene Osamodas braucht eine tüchtige Abreibung. Dringend!",r:[500,null,[[8534,1]],null,null,null]};
Q.s[368] = {n:"Kampf auf der Seite der Wächter",d:"Der Hauptmann hat dir eine einfache, aber nützliche Aufgabe aufgetragen.",r:[195,null,null,null,null,null]};
Q.s[369] = {n:"Kampf auf der Seite der Wächter",d:"Der Hauptmann hat dir eine einfache, aber nützliche Aufgabe aufgetragen.",r:[195,null,null,null,null,null]};
Q.s[370] = {n:"Kampf auf der Seite der Wächter",d:"Der Hauptmann hat dir eine einfache, aber nützliche Aufgabe aufgetragen.",r:[195,null,null,null,null,null]};
Q.s[372] = {n:"Gib dem Günstler Guasch",d:"Trotz des starken Akzents hast du verstanden, was Marylork wollte.",r:[75,75,null,null,null,null]};
Q.s[373] = {n:"Ein Plausch mit Lykhen",d:"Lykhen erzählt von seinem Abenteurerleben.",r:[10,null,null,null,null,null]};
Q.s[385] = {n:"Finde den Unterschlupf der Halsabschneider",d:"Yse Vewybad hat dir Hinweise für die Position der Halsabschneider gegeben. Schau doch einmal in der Nähe des Friedhofs nach.",r:[9000,null,null,null,null,null]};
Q.s[384] = {n:"Finde den Sram",d:"Yse Vewybad hat dir etwas über einen sehr wichtigen Sram in Amakna erzählt... Doch wo bloß könnte man diesen finden?",r:[1000,null,null,null,null,null]};
Q.s[394] = {n:"Wer wird Werbär?",d:"Dein Auftrag ist es nun, einen passenden Werber für die Hand Allisterias, der Tochter des Königs Bruders, ausfindig zu machen.",r:[15000,null,null,null,null,null]};
Q.s[395] = {n:"Angeln nach Infos",d:"Vil Smiss will, dass du Informationen über das Geschehen am Hof des Königs sammelst. Drum musst du jemanden finden, der dir die neuesten Gerüchte mitteilen kann.",r:[3000,null,null,null,null,null]};
Q.s[396] = {n:"Auf der Suche nach dem kleinen Biest",d:"Du weißt nun, dass der König seine Nichte verheiraten will. Bloß mit wem?",r:[12000,null,null,null,null,null]};
Q.s[402] = {n:"Falsche Identität",d:"Salg Zangaer hat dich in einen Wabbit verwandelt. Jetzt gilt es, ins Schloss hereinzukommen, um diese Heirat zu verhindern.",r:[50000,25000,null,null,null,null]};
Q.s[401] = {n:"Nach der Rezeptur, nun die Zutaten",d:"Nun, da Salg die Rezeptur in den Händen hält, fehlen ihm nur noch die Zutaten dazu.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"Auf der Spur der Rezeptur",d:"Finde die Alchimisten, die über ganz Amakna verstreut sind.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit Powwa",d:"Finde einen Weg, dich in einen Wabbit zu verwandeln.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"Maul stopfen mal anders...",d:"Nun hast du das Ei eines fetten Tofus. Doch ein einzelnes Ei an sich wird dem Pwinzen sicherlich nicht schaden... Also musst du einen Weg finden, das Küken darin zu mästen.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Ein frisches Ei",d:"Vil Smiss hat dich beauftragt, ein Ei eines fetten Tofus zu besorgen. Bloß wo haben diese Biester ihr Nest?",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"Jagd nach einem Kopfgeldjäger",d:"Vil Smiss kann seinen vergifteten Blobkuchen nicht einsetzen. Daher will er nun doch einen Frontalangriff wagen. Besorge ihm genug Geld, um einen Attentäter anzuwerben.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"Ein vergiftetes Geschenk",d:"Vil Smiss hat sich dazu entschieden, statt einer frontalen Konfrontation lieber die traditionelle Vorgehensweise der Halsabschneider anzuwenden – nämlich List und Tücke!",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Ein Störenfried!",d:"Die Attentäter haben bei ihrem Anschlag auf den Pwinzen versagt... Vil Smiss hat dich nun beauftragt, einen Lenald zu engagieren, um ihn endlich auszuschalten.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"Tod dem Tofu!",d:"Du weißt jetzt, wo der Wa-Pwinz mit seiner Jagdgesellschaft unterwegs ist. Zumindest ungefähr... Irgendwo im Süden von Bonta. Finde ihn!",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"An die Arbeit",d:"Frage den Vorarbeiter nach deinen Aufgaben.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Dienen oder einen Dienst leisten?",d:"Der Intendant San Lavalss hat dich gebeten, bei der Fertigstellung der letzten Vorbereitungen für die Hochzeit mitzuhelfen.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"1. Schritt",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"Smaragda sucht eine Verkleidung",d:"Smaragda versucht verzweifelt, an ein Koalak-Set zu kommen.",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Fragen und Antworten",d:"Der Wächter der Brücke des Todes verlangt, dass du ordentlich auf seine Fragen antwortest.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Reisevorbereitungen",d:"Kapitän Hardrock braucht eine Reihe von Gegenständen, damit er dich auf seinem Schiff mitnehmen kann.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"Flipps verflippte Kiste",d:"Kapitän Hardrock ist jämmerlicherweise auf der Insel der Schiffbrüchigen gestrandet. Bringe Flipps verflippte Kiste her und besorgt ein paar Gegenstände für die Schiffsreparatur.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"Volle Kraft voraus!",d:"Der schwarze Ritter mit dem rosa Rand ist fest entschlossen, dich nicht passieren zu lassen. Wahrscheinlich ist es an der Zeit, ihm zu zeigen, was gehauen und gestochen ist.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"Ein Trank für den Professor",d:"Professor Sonnenschein braucht einen Knollentrank, bevor er sich wieder seiner Arbeit widmen kann.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Aufzucht und Ordnung",d:"Polka Mehrer braucht unbedingt Aufzuchtgeräte für ihre Kreaturen.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"Mehr Mehl!",d:"Sella Schlei, die Bäckerfee, will das von Xaver erfundene Mehl mit Billigmehl strecken. Sie hatte die Idee, und du sollst sie umsetzen. Kann man einer Fee wirklich etwas abschlagen?",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"Auf der Suche nach dem verlorenen Sohn",d:"Doktor Wô hat seinen Sohn in einem Laboratorium gelassen, in dem es von schrecklichen wilden Kreaturen wimmelt. Finde ihn und vergewissere dich, dass er noch am Leben ist!",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"Kuschelpause",d:"Doktor Kuschel ist arm dran, denn ihm ist seine Gattin abhanden gekommen. Hilf ihm, sie im düsteren Dschungel wiederzufinden, und überzeug sie, dass sie zu ihrem Mann zurückkehrt, damit er seine Forschungen wiederaufnehmen kann.",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"Die verbesserte Ausrüstung",d:"Spiet Feiar benötigt einen verbesserten Pilotenhelm. Nur ein erfahrener Schneider kann dir einen solchen fertigen.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Zwei Dracotruter für Flipp Flapp",d:"Flipp Flapp möchte, dass du ihm ein ein Tierheimzertifikat für einen Rot- und Mandel-Dracotruter bringst.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Eine Jagd durch den düsteren Dschungel",d:"Crocodyll Dundy will, dass du ihm ein paar Kreaturen des düsteren Dschungels bringst.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Eine Jagd in den Ebenen",d:"Crocodyll Dundy will, dass du ihm ein paar Kreaturen der Ebenen bringst.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Eine Strandjagd",d:"Crocodyll Dundy will, dass du ihm ein paar Kreaturen des Korallenstrandes bringst.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Eine Jagd im Stammbaum",d:"Crocodyll Dundy will, dass du ihm ein paar Kreaturen des Stammbaumes bringst.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Eine Jagd durch das bodenlose Moor",d:"Crocodyll Dundy will, dass du ihm ein paar Kreaturen des bodenlosen Moores bringst.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"Das Exempel an den Piraten",d:"Kito verlangt von dir, dass du ein Exempel an den Piraten statuierst, die ihn mit Kugeln beschießen.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"Der Schwarze Ritter mit dem rosa Rand",d:"Aimy Airwutz möchte, dass du an ihrer Statt gegen den furchtbaren schwarzen Ritter mit dem rosa Rand kämpfst.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"Ein verfluchter Tausch",d:"Farle Ingalsse ist mit Sicherheit die einzige Person in ganz Amakna, die den Fluch dieser Sense aufheben kann.",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"Schnell, schnell!",d:"Anscheinend wird Milone gerade ausgeraubt. Verhindert dies schnell.",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Schlechter Köder?",d:"Die Reise verlief ohne Zwischenfälle. Die Banditen haben nicht angegriffen... Amayiro wartet auf euren Bericht.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"Ecaflip-Falle",d:"Amayiro will die Banditen in einen Hinterhalt locken. Damit sie in die Falle tappen, braucht er ein wertvolles Juwel.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Cheekahs Eskorte",d:"Ihr habt die Aufgabe die Händlertruppe von Cheekah nach Astrub zu eskortieren",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"Ein gewichtiger Bericht",d:"Der Konvoi wurde von Ecaflip-Banditen überfallen, die denen im Camp ähneln. Amayiro erwartet nun dringend euren Bericht, um den Rat zum schnellen Handeln zu überzeugen",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Wo ist da der Haken?",d:"Rigal Hakenhand im Sramtempel ist berühmt dafür, zahlreiche Informationen zu besitzen, aber das hat seinen Preis. Jetzt müsst ihr nur noch herausbekommen wie hoch der Preis für euch sein wird.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"Frisches Gift gibt Frische ",d:"Ihr sollt die Giftreserven von Brâkmar finden und die Kundendaten der Alchimistenwerkstatt entwenden. Vielleicht kann euch dabei Bishom Pot helfen",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"Alchemie für Dummies",d:"Ihr müsst das Kundenregister in der Alchemistenwerkstatt von Brâkmar stehlen und diesen Rigal Hakenhand bringen.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Mit Tätern geschafft?",d:"Um die Giftreserven von Brâkmar erfolgreich zu erreichen, werdet ihr die Hilfe eines gewieften Spions oder eines Srams benötigen",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Bauernfänger",d:"Zwischen einem Brâk und einem korrupten Bonta findet im Turm von Bonta ein Treffen statt. Nehmt beide gefangen, wenn möglich.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"Kein Ausweg für Verräter",d:"Ihr müsst bei allen Milizionären nachfragen, um sie am Turm von Bonta aufzustellen.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"Störrischer Bwork.",d:"Entweder Epuop Tik weiß nicht mehr darüber oder er will euch einfach nicht mehr verraten. Wie dem auch sei, die Bwork Magus sind sicher weniger zimperlich, wenn es darum geht, einen von ihnen zu verraten.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Danathor, was braust du uns da zusammen?",d:"Danathor möchte euch anscheinend ein neues Angebot machen. Wahrscheinlich ist was faul dran.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"Die verzauberte Puppe",d:"Ihr müsst vier Sadidas für ein Ritual in den verzauberten Gewässern der Koalak-Seen finden. Sie müssen erfahren genug sein, um Aufblaspüppchen beschwören zu können.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Einfach nur genial",d:"Wenn ihr den Fluch aufhebt, der auf Ji-Beh Grennudel lastet, dann wird er euch aus Dankbarkeit bestimmt alles verraten, was er weiß. Er hat empfohlen, eine Bibliothek aufzusuchen.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"Auf der Suche nach dem traurigen Amtsschreiber",d:"Aidurraff, Amtsschreiber des Ordens des Allsehenden Auges durchstöbert die Tavernen auf der Suche nach seiner Maus. Er muss dringend zu Tück\'n\'Stück gebracht werden.",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Raus aus dem Gefängnis",d:"Ihr müsst einen Krieger retten, der von den Bonta gefangen wurde: er ist im Keller des Milizgefängnisses der Bonta.",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"Geliebter Feind",d:"Findet und eliminiert euer Ziel",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Einen Kampf gewinnen",d:"Greift euer Ziel weiter an, um den Kampf zu gewinnen. \nKlickt auf den Button {ui,banner,btn_skipTurn::Runde beenden} um den Ablauf des Kampfes zu beschleunigen. Am Ende jeder Kampfrunde regenerieren sich eure {ui,banner,lbl_pa,2::AP} und {ui,banner,lbl_pm,2::BP}.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Den Kampf beenden",d:"Gewinnt den Kampf gegen das Monster. Hinweis: Kampfrunden haben nun, wie im Spiel üblich, eine begrenzte Dauer. Die {ui,banner,tx_artwork,3::Zeitanzeige} gibt an, wieviel Spielzeit noch zur Verfügung steht, bevor die Runde zu Ende geht.",r:[null,null,null,null,null,null]};
Q.s[1042] = {n:"Fortbewegen auf der Karte",d:"Willkommen im begleiteten Tutorial. Klickt mit der linken Maustaste ein Feld an. Dann wird euer Charakter dorthin laufen. Ist das Feld in der Nähe, geht der Charakter dorthin. Liegt es weiter weg, beginnt er zu rennen.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Runde beenden",d:"Wenn ihr mit euren Aktionen fertig seid, klickt auf den Button {ui,banner,btn_skipTurn::Runde beenden} um den Ablauf des Kampfes zu beschleunigen. Am Ende jeder Kampfrunde regenerieren sich eure {ui,banner,lbl_pa,2::AP} und {ui,banner,lbl_pm,2::BP}.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Sich mit einem Gegenstand ausstatten",d:"Öffnet die Benutzeroberfläche  {ui,banner,btn_character,1::Eigenschaftswerte}. Verschiebt den soeben erhaltenen {ui,storage,grid::Anfänger-Ring} in den {ui,characterSheetUi,slot_2,2::Ring-Slot} eurer Charkterübersicht. Dabei müsst ihr die linke Maustaste gedrückt halten.\nEs ist auch möglich den Gegenstand auszurüsten, indem man den {ui,storage,grid::Anfänger-Ring} einfach mit links doppelklickt.",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"Den Charakter ausrüsten",d:"Öffnet die Benutzeroberfläche  {ui,banner,btn_character,1::Eigenschaftswerte}. Dort könnt ihr die Gegenstände anlegen, die ihr gewonnen habt.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Sich im Kampf fortbewegen",d:"Euer Charakter verfügt über {ui,banner,lbl_pm,2::Bewegungspunkte} (BP) um sich Fortzubewegen. Das Rücken auf ein Nachbarfeld kostet 1 BP. Bewegt euren Charakter, indem ihr mit der linken Maustaste ein Feld anklickt. \nAusgegebene {ui,banner,lbl_pm,2::BP} werden zu Beginn der folgenden Runde wieder zurückgewonnen.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Einen Zauber benutzen",d:"Wählt {ui,banner,gd_spellitemotes,0::einen Zauberspruch} aus und macht einen Linksklick auf das gewünschte Ziel. Manche Zauber können auf Feinde, andere nur auf Verbündete oder auf euren Charakter gewirkt werden. Die Reichweite des Zaubers wird über die blauen Felder angezeigt. Zauber benötigen {ui,banner,lbl_pa,2::Aktionspunkte} (AP) um gewirkt werden zu können. Die {ui,banner,lbl_pa,2::AP} werden zu Beginn jeder Runde aufgefüllt.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Seine Anfangsposition wählen",d:"Klickt mit der linken Maustaste auf eines der {cell,272::blauen Felder}, um eure Startposition festzulegen und klickt auf den {ui,banner,btn_ready::Button Los!} um den Kampf zu beginnen.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Karte wechseln",d:"Zum Wechseln der Karte, bewegt euren Cursor an den {arrow,1280,520,0,0::Bildschirmrand} und linksklickt mit der Maus, sobald sich der Cursor in einen Pfeil verwandelt.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Das Monster besiegen",d:"Um diese Queste zu erfüllen, müsst ihr in den {arrow,700,870,0,1::nächsten Saal} gehen und einen Kampf gegen {monster,2781::das Monster} dort beginnen.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Die Lehre beenden",d:"Um das Questziel zu erreichen, müsst ihr {npc,1222::Ganymed Izina} von eurem Sieg berichten.",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Eine Quest beginnen",d:"Redet mit {npc,1222::Ganymed Izina} um eine Quest zu starten (NSCs die Questen anbieten, tragen ein Ausrufezeichen über ihrem Kopf).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Mit einem NSC reden",d:"Klickt mit der linken Maustaste auf {npc,1222::Ganymed Izina} und wählt die Aktion \"Reden\" aus, um ein Gespräch mit ihm anzufangen.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Einen Kampf auslösen",d:"Klickt mit der linken Maustaste auf die {monster,2785::Incarnam-Vogelscheuche} um einen Kampf zu beginnen.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"Ein beschwerliches Leben",d:"Hättest du mal besser auf den Rat von Itze Dawa gehört und hättest der Sache mißtraut... Jetzt sieht es ganz so aus, als wolle man dir ans Leder! Schluss mit einem beschaulichen, unbeschwerten Leben.",r:[null,null,null,null,null,null]};
Q.s[1058] = {n:"Gegenmittel übermittelt?",d:"Mit deiner Hilfe ist Itze Dawa sicher in der Lage, das Übel zu beseitigen, das den Markt für Pandawa-Getränke befallen hat. Vorausgesetzt du findest rechtzeitig das Gegenmittel!",r:[3000,null,[[10818,1]],null,null,null]};
Q.s[1056] = {n:"Ein unbeschwertes Leben",d:"Kaum eingetroffen, schon erhältst du ein Angebot, ohne große Mühe deinen Lebensunterhalt zu verdienen. Was will man mehr?",r:[null,null,null,null,null,null]};
Q.s[1091] = {n:"Spielzeugfabrik",d:"Scheußliche Kreaturen haben das Lager des Weißnachtsmannes ausgeraubt. Ihr müsst die gestohlenen Geschenkpakete wieder beschaffen, koste es was es wolle und sie zu Harry Kwismas bringen.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1054] = {n:"Ne pas traduire",d:"Ne pas traduire ! Quête utilisée pour faire apparaître un point d\'exclamation en permanence au-dessus du PNJ Fée Risette.",r:[null,null,null,null,null,null]};
Q.s[790] = {n:"Wie eine Nadel im Tofustall",d:"Brâkmar hat bereits die erste Sumens-Statue an sich genommen. Heimgeh Dammvert beauftragt euch damit, die zweite Statue ausfindig zu machen, die irgendwo im Tofustall versteckt ist.",r:[null,null,null,null,null,null]};
Q.s[791] = {n:"Die Statue in Sicherheit bringen",d:"Heimgeh Dammvert verlangt von euch, die Sumens-Statue für Wahrsagerei unempfänglich zu machen, bevor ihr sie auf den Opferaltar des Turms von Gisgoul abstellt.",r:[600000,null,null,null,null,null]};
Q.s[977] = {n:"Zu gutem Ende bringen",d:"Ihr habt es geschafft, Briango Brularte zu befreien. Jetzt müsst ihr ihn nur noch bis zu Oto Mustam eskortieren, ohne von den Söldnern Astrubs gefangen zu werden.",r:[312000,null,null,null,null,null]};
Q.s[571] = {n:"Schläfrige Wachsamkeit",d:"Findet ein Mittel, um die Wachen im Gefängnis von Astrub in den Schlaf zu versetzen, damit ihr Briango Brularte zur Flucht verhelfen und ihn zu Oto Mustam bringen könnt.",r:[null,null,null,null,null,null]};
Q.s[948] = {n:"Weil Sotzio Paht es sich wert ist",d:"Um die Hilfe von Sotzio Paht zu bekommen, müsst ihr ihm Aerol-Lotion bringen. Mit dieser Lotion sind seine Haare gegen die schwefelige Luft von Brâkmar geschützt.",r:[null,null,null,null,null,null]};
Q.s[564] = {n:"In sumpfigen Tiefen",d:"Um ein Unheilvolles Schwert schmieden zu können, benötigt man Moderwasser. Die Chef-Crocodylls in den Bodenlosen Sümpfen tragen oft welches bei sich.",r:[null,null,null,null,null,null]};
Q.s[949] = {n:"In die Schwertschmiede",d:"Zum Schmieden des unheilvollen Schwertes von Oto Mustam ist alles bereit. Um es abzuholen, müsst ihr euch in die Spezialschmiede von Mulic Bere begeben.",r:[272000,null,null,null,null,null]};
Q.s[947] = {n:"Zauber und Schwerter",d:"Mulic besitzt zwar alles, was zum Schmieden des Schwerts benötigt wird, aber es müssen noch drei Ordensmeister und der Schmiedmagier Sotzio Paht dabei sein.",r:[null,null,null,null,null,null]};
Q.s[996] = {n:"Zum Tempel gehen",d:"Geht in euren Klassentempel und kämpft dort gegen das Dubbel.",r:[5000,null,null,null,null,null]};
Q.s[884] = {n:"Tretet ein, haben sie gesagt...",d:"Snori Nairb hat versprochen all seine Erfahrung und seine Kamas mit euch zu teilen, falls ihr euch in der Miliz von Bonta verpflichtet.",r:[null,null,null,null,null,null]};
