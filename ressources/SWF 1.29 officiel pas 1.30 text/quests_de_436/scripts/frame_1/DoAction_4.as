Q.s[534] = {n:"Die Wahl",d:"Ihr habt den Spion noch rechtzeitig gefunden. Aber werdet ihr die Befehle befolgen und die Dokumente an euch nehmen und ihn zurücklassen?",r:[205000,null,null,null,null,null]};
Q.s[144] = {n:"... und Xélorzähne",d:"Auch die Xélors scheinen daran interessiert zu sein. Ohm haben sie gesagt, sie bräuchten sie als Zeiger für ihre Sanduhren... oder so ähnlich.",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Finde den Übeltäter",d:"Qil Bil wurde im Sidimot-Gebiet gesichtet. Er wird wegen mutwilligen Ausreißens von Gliedmaßen gesucht und wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"Tretet ein, haben sie gesagt...",d:"Snori Nairb hat versprochen all seine Erfahrung und seine Kamas mit euch zu teilen, falls ihr euch in der Miliz von Brâkmar verpflichtet.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"Wer Vhan sät, wird Artempeth ernten!",d:"Um seine Theorien über das Erscheinen fleischfressender Blumen zu überprüfen, bittet dich Trapchet darum, einige Schattenrosensamen zu säen und sie dann zu ernten.",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"Der Stimmlose und die Flora",d:"Dreiblum, ein Freund von Trapchet, der in Amakna wohnt, soll angeblich wie kein anderer die Flora des Landes kennen. Befrage ihn nach allen möglichen aggressiven Pflanzen.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"Epilierung des Epyss",d:"Erty Trapchet braucht Löwenzahnsamen, um sie mit denen des Epyss zu vergleichen.",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"Der Pflanzen gießende Pflanzengießer",d:"Erty Trapchet hat vergessen, seine Pflanzen zu gießen... Darum muss du dich jetzt auf den Weg zu seinem Heim machen, um dies für ihn nachzuholen.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"Gefährliches Gewächs",d:"Für seine Untersuchungen benötigt Trapchet eine Übersicht über die Blumenverteilung in der Umgebung von Astrub.",r:[6500,500,null,null,null,null]};
Q.s[60] = {n:"Verdammt, genau so war es!",d:"-",r:[null,null,null,null,null,null]};
Q.s[56] = {n:"Fahndung nach dem verschwundenen... Haus!",d:"",r:[null,null,null,null,null,null]};
Q.s[38] = {n:"Eine Lieferung von Erty Trapchett",d:"",r:[null,null,null,null,null,null]};
Q.s[40] = {n:"Eine Lieferung aus dem Bergwerk",d:"",r:[null,null,null,null,null,null]};
Q.s[39] = {n:"Eine Lieferung von Podbra, dem Einarmigen",d:"",r:[null,null,null,null,null,null]};
Q.s[143] = {n:"Eine wilde Jagd",d:"Dunkle Kreaturen stören die Einkünfte von Ohm Atranchie. Darum hat er beschlossen, sie loszuwerden... Zumindest solange, bis jemand versteht, was sie hier machen.",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"Können Eier schwimmen?",d:"Nun gibt es keine Krankheitskeime mehr in den Federn der kranken Tofus. Doch könnten ihre Eier ebenfalls kontaminiert sein. Nur ein Eniripsa kann dies genau feststellen. Eine gute Kamaquelle für dich!",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"Jetzt wird es blutig!",d:"Plötzlich überkommt dich das Verlangen, mehr über dich selbst zu erfahren, und das am Besten an einem höchst blutigen Ort... der Metzgerei!",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"Das klingt ja ungeheuerlich!",d:"Dein Meister hat dir erzählt, dass sich kürzlich ein Bergmann in ein großes Ungeheuer verwandelt hat – nämlich in einen Schattenbergmann! Nun sollst du der Sache nachgehen.",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"Betroffene Enutrofs!",d:"Die Enutrofs haben anscheinend etwas Wichtiges entdeckt. Nun brauchen sie deine Hilfe.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Der Dizbi-Extrakt",d:"Die reine Blüte der Dizbiblume reicht noch nicht aus! Benötigt wird der daraus gewonnene Tee!",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Eine Express-Lieferung",d:"Bringe den Tee so schnell wie möglich zu deiner Meisterin, damit sie dir deinen Stecken fertigstellen kann. Wenn du zufällig ein wenig Tee für denjenigen übrig hättest, der dir die Blume gegeben hat, so würdest du ihm eine große Freude machen.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Eine Dizbiblume",d:"Finde eine Dizbiblume, damit dir deine Meisterin einen Stecken anfertigen kann, der diesen Namen auch zu Recht trägt.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"Hunger... Hunger... Hunger...",d:"Die Fresssäcke von Allisteria sind hungrig. Füttere sie!",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Brat die Blutwurst des blutigen Fresssacks",d:"Rette die Tradition der gebratenen Blutwurst des blutigen Fresssacks.",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Kämpfe wie ein Féca!",d:"Der berühmte Fallanster hat dich gebeten, seine Tochter im Kampf zu schulen.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"Besser das Bier in der Hand, als das Fass auf dem Dach",d:"Der Weg des Wasser besteht darin, der Aufnahme von und dem Untertauchen in Wasser zu entgehen. Das bedeutet, niemals Wasser zu trinken und sich nur dann zu waschen, wenn es absolut notwendig ist. Finde den Meister des Weges des Wassers! Er weiss sehr viel, mehr als es scheint.",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"Der weise Lenald",d:"Eine Erfrischungsgetränkeverkäuferin auf Pandala hat dir geraten, den weisen Lenald zu befragen. Wie sie meint, soll dieser alles über Pandala und dessen Geheimnisse wissen.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"Die Statue der Göttin",d:"Der Grandapan hat das Geschenk der Enutrofs mit Freuden angenommen. Als großer Bewunderer der Abenteurer auf der Jagd nach den Dofus heißt er dich mit offenen Armen bei ihm willkommen.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"Der Grandapan – ein sympatischer Pandawa",d:"Die Enutrofs, die vom Tschamanen behandelt werden, haben dir geraten, den Grandapan aufzusuchen. Er sei nicht nur sehr versiert in den lokalen Gebräuchen, sondern verfüge auch über großes Wissen über alle Pandala-Legenden.",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Trankopfer für die Göttin!",d:"Dank deiner Hilfe konnte der Tschamanen-Assistent mit seinem Dankesritual an die Göttin beginnen. Das heißt, er wird es beginnen können, sobald du ihm die notwendigen Opfergaben besorgt habt.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"Im Dienste des Königs",d:"Der König reitet gern aus. Finde ihm ein paar Dracotruter.",r:[75000,null,null,null,null,null]};
