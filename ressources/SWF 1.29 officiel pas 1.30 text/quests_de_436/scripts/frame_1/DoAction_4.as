Q.s[964] = {n:"Tod den Verrätern",d:"Es gibt da Verräter in Brâkmar, die Erze an Bonta verkaufen. Nehmt das Erz an euch und eliminiert die Verräter.",r:[288000,null,null,null,null,null]};
Q.s[565] = {n:"Nichts als die Wahrheit über das Horn",d:"Oto Mustam will zusätzliche Informationen über das Horn des Ih-Fritts. Er hat euch befohlen, mit seinem Spion Finch Aticus in Bonta zu reden.",r:[null,null,null,null,null,null]};
Q.s[576] = {n:"Vermisst",d:"Elviana Tirips meint, dass ein Medium euch helfen könnte, den Lichtgeist ausfindig zu machen. Da das Medium verschwunden ist, müsst ihr sie zuerst wiederfinden.",r:[null,null,null,null,null,null]};
Q.s[577] = {n:"Den Lichtgeist finden und überreden",d:"Findet den Lichtgeist, der zu dem Hammer gehört und überzeugt ihn davon, euch bis nach Bonta zu folgen.",r:[280000,null,null,null,null,null]};
Q.s[966] = {n:"Ein behämmerter Geist",d:"Es sieht so aus, als ob euch Tück\'n\'Stück in Bezug auf den Lichthammer und seinen Geist noch brauchen würde.",r:[null,null,null,null,null,null]};
Q.s[567] = {n:"Die Ruhe nach dem Sturm",d:"Ihr habt am Prozess von Sulsch Tim Sliglu Terpeh teilgenommen und eure Meinung hat den Ausgang des Prozesses beeinflusst. Ihr könnt nun wieder euren Beschäftigungen nachgehen.",r:[264000,null,null,null,null,null]};
Q.s[562] = {n:"Ein hammerharter Richter",d:"Satirev Onivin hat seinen Hammer zerbrochen und verlangt einen neuen von euch. Da er dickköpfig ist, weigert er sich, etwas anderes zu benutzen, als einen Abkratzhammer.",r:[null,null,null,null,null,null]};
Q.s[563] = {n:"Ein Gespräch mit Danathor",d:"Danathor möchte euch vor Beginn des Prozesses sprechen, es klingt dringend.",r:[null,null,null,null,null,null]};
Q.s[561] = {n:"Immer der Nase nach",d:"Amayiro hat euch damit beauftragt, den Sram wiederzufinden, der Gnil Schirf bedroht hat. Der einzige Hinweis: Er begibt sich regelmäßig in die Abwasserkanäle und zwar über den Gully im Süd-Osten der Stadt.",r:[null,null,null,null,null,null]};
Q.s[962] = {n:"Miez, miez, Gaunzmiez",d:"Um Gnireh verhören zu können, müsst ihr vor Beginn des Prozesses einen Gaunzmiez finden.",r:[null,null,null,null,null,null]};
Q.s[566] = {n:"Ein gerechter Prozess",d:"Da ihr über die Verratsgeschichte von Sulsch Tim Sliglu Terpeh ermittelt habt, werdet ihr als Zeuge aufgerufen. Ihr müsst nun euer Lager wählen.",r:[null,null,null,null,null,null]};
Q.s[973] = {n:"Gedankenjäger",d:"Ihr müsst Greu Nouille dazu überreden, euch beim Einfangen eines Denkerlings behilflich zu sein, der mit Solar in Verbindung steht. Bringt ihn dann zu Danathor.",r:[304000,null,null,null,null,null]};
Q.s[972] = {n:"Ein Mittel gegen Gedächtnisschwund",d:"Meuh Sieurchance leidet unter Gedächtnisschwund. Um ihn heilen zu können, müsst ihr die Anweisungen von Surivitna, dem Schamanen befolgen.",r:[null,null,null,null,null,null]};
Q.s[971] = {n:"MC Solar",d:"Ihr müsst einen Verlorenen Gedanken des verstorbenen Beschützers Solar in die Hände bekommen. Vielleicht können euch die Alchemisten helfen.",r:[null,null,null,null,null,null]};
