Q.s[552] = {n:"Ein guter Holzfäller",d:"Oto braucht Schattenhainbuchenholz: ihr müsst in der Werkstatt der Holzfäller suchen, um jemanden zu finden, der weiß, wie man sich welches besorgen kann.",r:[null,null,null,null,null,null]};
Q.s[942] = {n:"Nett und dunkel",d:"Der unterirdische Gang in der Werkstatt von Salg Zengaer führt zum letzten Hainbuchenwäldchen. Ihr habt Oli Venders Informationen auf einem Blatt Papier notiert.",r:[null,null,null,null,null,null]};
Q.s[943] = {n:"Im Dunkeln ist gut munkeln",d:"Mulic Bere möchte, dass ihr ihm Schattenhainbuchenholz bringt, damit er ein Unheilvolles Schwert schmieden kann.",r:[256000,null,null,null,null,null]};
Q.s[553] = {n:"Auf kleiner Flamme",d:"Oli Venders verheimlicht euch etwas, aber weigert sich, euch zu helfen und klassische Drohungen bringen nichts. Vielleicht überlegt er es sich, wenn seine Werkstatt in Brand steht?",r:[null,null,null,null,null,null]};
