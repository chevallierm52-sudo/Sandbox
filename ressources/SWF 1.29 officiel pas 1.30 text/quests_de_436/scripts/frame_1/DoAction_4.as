Q.s[557] = {n:"Rum, Weib und Bier",d:"Für einen zusätzlichen Aufschub bei den Ermittlungen, verlangt der Richter Satirev Onivin ein Fass KO-Met als Erfrischung für die Gefangenen und eine Frau aus Astrub, um seinen Körper zu erfrischen.",r:[null,null,null,null,null,null]};
Q.s[551] = {n:"Bitte um Aufschub",d:"Der Richter Satirev Onivin mag keine Ermittlungen, die sich in die Länge ziehen und dennoch schickt euch Amayiro zu ihm, um einen Aufschub zu erbitten. Er verbringt seine Zeit meistens im Milizgebäude.",r:[null,null,null,null,null,null]};
Q.s[554] = {n:"Ein hart erworbener Aufschub",d:"Ihr habt einen zusätzlichen Aufschub erhalten. Das wird Amayiro freuen.",r:[248000,null,null,null,null,null]};
