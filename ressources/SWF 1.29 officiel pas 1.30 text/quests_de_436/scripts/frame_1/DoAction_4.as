Q.s[802] = {n:"Ein Piepmatz",d:"Hannes Schnalltgetin braucht für die Aufzucht seiner Piepmätze magietechnisch veränderte Körner. Merlaun der Ziberer kennt die Rezeptur.",r:[600000,null,null,null,null,null]};
Q.s[801] = {n:"In der Abstellkammer",d:"Hannes Schnalltgetin fürchtet, dass Brâkmar seine Leute aussendet, um die Sumens-Statue zu stehlen, die im Turm von Bonta aufbewahrt wird.",r:[null,null,null,null,null,null]};
Q.s[967] = {n:"Gegenwärtige Zukunft",d:"Danathor braucht euch. Es betrifft eine Angelegenheit mit einem magischen Geschenk oder irgend sowas.",r:[null,null,null,null,null,null]};
Q.s[968] = {n:"Interview mit einem Halsabschneider",d:"Ihr müsst mit den Halsabschneidern reden, damit ihr über ein Zeitfragment verhandeln könnt, das den Stundenglasdämonen gestohlen wurde.",r:[288000,null,null,null,null,null]};
