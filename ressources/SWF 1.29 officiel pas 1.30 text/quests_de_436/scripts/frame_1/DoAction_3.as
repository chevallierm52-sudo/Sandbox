Q.s[976] = {n:"Domens Mädchen für alles",d:"Domen droht euch damit, euch bei Oto Mustam zu verraten, wenn ihr nicht kooperiert. Jetzt müsst ihr wohl oder übel seine Einkäufe erledigen.",r:[null,null,null,null,null,null]};
Q.s[570] = {n:"Noch ein Schlückchen in Ehren",d:"Ihr müsst Gerti Gertisorf dazu bringen, Domens Trank zu schlucken.",r:[null,null,null,null,null,null]};
Q.s[569] = {n:"Ein Schlückchen in Ehren",d:"Begebt euch auf die Otomaïs Insel und erfahrt, wer der Tränkelieferant von Divad Dleifrepok ist.",r:[304000,null,null,null,null,null]};
