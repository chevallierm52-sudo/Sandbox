Q.s[549] = {n:"Der Fluch der Osamodas",d:"Eine Osamodas-Anhängerin wäre imstande, die Verwünschung auszusprechen, die ihr braucht. Sie sucht nach einem Mittel, Tote auf dem Friedhof von Bonta zu beschwören.",r:[null,null,null,null,null,null]};
Q.s[941] = {n:"Der Lavageist",d:"Ihr habt das Verfluchte Eisen, jetzt müsst ihr nur noch einen Lavageist einfangen, den man im Inneren des Sidimote-Gebietes findet. Raaga weiß vielleicht, wo man sie findet.",r:[248000,null,null,null,null,null]};
Q.s[548] = {n:"Verfluchtes Eisen",d:"Oto Mustam benötigt für seine Klinge Verfluchtes Eisen. Anscheinend weiß Divad Dleifrepok, wie man normales Eisen in Verfluchtes Eisen verwandelt.",r:[null,null,null,null,null,null]};
Q.s[550] = {n:"Der Fluch des Eisens",d:"Ihr müsst Divad Dleifrepok in den Kellergewölben des Turms von Brâkmar treffen.",r:[null,null,null,null,null,null]};
