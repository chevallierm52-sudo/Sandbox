Q.s[487] = {n:"In die Bibliothek eindringen.",d:"Der Mordanschlag der Spione in Bonta ist fehlgeschlagen, ihr müsst die Arbeit wohl an ihrer Stelle erledigen. Das Ziel ist ein Taktiker, der in der Bibliothek von Bonta wohnt, aber gebt auf die Wachhunde acht.",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Mordsgedanke",d:"Ihr könnt nun in die Bibliothek eintreten und euch um den Taktiker kümmern.",r:[null,null,null,null,null,null]};
Q.s[750] = {n:"Sbab demütigen?",d:"Oto hat euch damit beauftragt, Sbab zehn Tiwabbit-Ohren zum Abschrecken zu bringen. Aber wenn ihr das nicht tun möchtet, gibt es vielleicht eine andere Lösung.",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Bonta verprügeln",d:"Oto hat euch um ein Bier aus der Kneipe \"Zum Knüppel\" gebeten. Der \"Knüppel\" ist in Bonta.",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Die Dokumente finden",d:"Der Spion hatte die Geheimdokumente nicht bei sich. Vielleicht hat sich die Tierwelt des Sidimote-Gebiet der Dokumente bemächtigt.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"Die Offenbarung",d:"Unter dem Verkaufsraum der Alchemisten befindet sich ein Schrank. Ihr braucht euch nur davor zu stellen, um den Geheimgang zu öffnen. Magus X erwartet euch dort.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"Magus X",d:"Amayiro hat euch aufgetragen, Magus X zu befragen, um die Funktionsweise und die Kräfte des Ih-Fritt Hornes herauszufinden.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"Zurück nach Hause",d:"Es ist an der Zeit, nach Bonta zurückzukehren und mit Amayiro Bilanz zu ziehen.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"Allgemeinwissen",d:"Erlernt die Seelenfängertechnik. Den Schlüssel zum Dungeon findet ihr bei den Kretauren der Region.",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Chafer-Helme",d:"Oto möchte zehn Chafer-Helme, die man auf dem Friedhof der Verdammten finden kann.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Alle Brâks sind schon da",d:"Ihr habt einen Brâk angegriffen, der zwar bereits zur Stelle war, der aber das Ih-Fritt Horn noch nicht in Besitz hatte. Wenn Ecaflip auf eurer Seite ist, findet ihr das Ih-Fritt Horn vielleicht noch vor den Brâks.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"Tökredilsch Entscheidung",d:"Tökredilsch dazu überreden, den Flicken-Bandana gegen das Ih-Fritt Horn einzutauschen. Ihr braucht eine Heckenschutzmütze und eine Flasche Omniberg, damit die Schildkröte für euch erscheint.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Wolfsjagd",d:"Oto verlangt von euch, Brâkmar von einem Wolf zu befreien, der in der Gegend herumstreicht.",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"So nah am Ziel",d:"Norb weiß, wohin sich der Einsiedler-Schmied zurückgezogen hat. Jetzt müsst ihr ihn bloß noch davon überzeugen, euch den Ort zu nennen. Vielleicht kann euch Amayiro dabei helfen",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Glückes Schmied...",d:"Ihr müsst einen fähigen Schmied finden, der bereit wäre, Ausrüstungen für Bonta anzufertigen.",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Eine andere Stammtischgeschichte",d:"Euren Quellen zufolge hat der Wirt von Sufokia angeblich Informationen über ein mächtiges magisches Horn.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"Selbst ist der Mann...oder die Frau",d:"Die vom Ripaten-Wirt preisgegebene Information ist so nicht verwertbar. Eine Nachforschung bei den Weisen könnte sich als fruchtbar erweisen.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, koko?",d:"Da ihr vorausahnt, wie Oto Mustams nächste Mission für euch aussieht, wäre es besser, wenn ihr eure Vorbereitungen trefft und einige Kokokosnüsse besorgt.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Knusperpanzer",d:"Der Ripaten-Wirt verlangt von euch Panzer der Schildkröten von Moon, einen in jeder Farbe. Aber vielleicht findet ihr ja eine schnellere Methode...",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Gegen den Lupus Minimus kämpfen.",d:"Ein Kampf, der eure Fähigkeiten auf eine harte Probe stellen wird.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Eine (fast) abgeschlossene Mission",d:"Der Weg ist frei, auch wenn die Goblins keine echte Gefahr darstellen. Endlich wird euch Exoram verraten, was er weiß und Oto Mustam kann stolz auf euch sein.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"Abrakadabra, ich bin\'s schon wieder.",d:"Exoram ist nicht beruhigt, da er weiter nördlich verdächtige Geräusche und spöttisches Lachen gehört hat. Wenn ihr ihm versichern könnt, dass der Weg frei ist, wird er euch die gesuchten Informationen über Xephirex herausgeben.",r:[null,null,null,null,null,null]};
Q.s[445] = {n:"Abrakadabra, und schon bin ich da",d:"Ihr habt Oto Mustam mit nützlichen Informationen versorgt. Er verlangt von euch, einen Milizionär abzulösen und im Astaknydenwald einen Sram zu suchen, der Xephirex kennt.",r:[null,null,null,null,null,null]};
Q.s[891] = {n:"Eine (noch lange nicht) abgeschlossene Mission",d:"Kampfspuren und die traurigen Reste eines Kleppripp-Reittiers sind ein Hinweis darauf, dass Exoram in einen Kampf verwickelt war und gefangen oder getötet wurde. Oto Mustam wird ganz schön sauer sein.",r:[65000,null,null,null,null,null]};
Q.s[444] = {n:"Die netten Bars von Bonta",d:"Findet Informationen über Xephirex. Die Wirte in Bonta können euch vielleicht eine Spur liefern.",r:[null,null,null,null,null,null]};
