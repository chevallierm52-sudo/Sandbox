Q.s[1126] = {n:"Ein Stich ins Blaue",d:"Kapitän Ardier bietet euch eine wunderschöne Kreuzfahrt auf seinem Traumschiff an und zwar bis zur fernen und geheimnisvollen Insel Frigost!",r:[34000,null,null,null,null,null]};
Q.s[1124] = {n:"Meisterhafte Hilfe einer wahren Meisterin!",d:"Der Schiffsjunge Sundheit hat euch gesagt, wo ihr die Bürgermeisterin treffen könnt. Sie wird euch Informationen zum Stillen Örtchen und dessen Einwohnern geben können.",r:[17000,null,null,null,null,null]};
Q.s[1125] = {n:"Begegnungen...",d:"Um euch einzuleben, hat euch Meisterin Bürgherr vorgeschlagen, mehrere berühmte Persönlichkeiten von Frigost zu besuchen.",r:[170000,null,null,null,null,null]};
Q.s[1139] = {n:"Zähmt das Biest!",d:"Günther Pesser hat euch den Auftrag gegeben, seinem \"Versuchskaninchen\" eine Blutprobe abzunehmen.",r:[340000,null,[[11198,1]],null,null,null]};
Q.s[1138] = {n:"Was Wasser!",d:"Günther Pesser benötigt dringend Isotonisches Meerwasser. Nur Käpt\'n Schluck weiß, wie man das gewinnt.",r:[null,null,null,null,null,null]};
Q.s[1137] = {n:"Was eim Schmubfem",d:"Ihr sollt Günther Pesser Blutproben von infizierten Fressmuts bringen.",r:[null,null,null,null,null,null]};
Q.s[1148] = {n:"Unter Kiefern",d:"Chef Sietas benötigt eine gigantische Menge an Holz zum Unterhalten der Dampfmaschine.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1147] = {n:"Verlorene Kiefern geben gutes Holz ab",d:"Chef Sietas benötigt eine gigantische Menge an Holz zum Unterhalten der Dampfmaschine.",r:[null,null,null,null,null,null]};
