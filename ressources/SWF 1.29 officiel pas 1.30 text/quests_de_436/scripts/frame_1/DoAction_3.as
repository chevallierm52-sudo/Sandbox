Q.s[737] = {n:"Gifternte",d:"Oto Mustam braucht 20 Pods Skorpiutgift.",r:[4600,null,null,null,null,null]};
Q.s[485] = {n:"Zutat für die Gifteküche",d:"Die Spione von Bonta brauchen ein seltenes Gift, das sich einzig und allein im Besitz der Bwork Magi befindet. Die Spione verstecken sich im Südwest-Viertel Bontas.",r:[null,null,null,null,null,null]};
Q.s[906] = {n:"Auf der Suche nach einem neuen Versteck.",d:"Findet zwischen ihrem jetzigen Standort und der Bibliothek ein neues Versteck für die Spione. Wenn nötig, müsst ihr eventuelle Bewohner neutralisieren.",r:[128000,null,null,null,null,null]};
Q.s[535] = {n:"Eine kleine Niederlage",d:"Kampfspuren, zwei Waffen am Boden, ein toter Sram. Es sieht so aus, als wärt ihr zu spät gekommen.",r:[205000,null,null,null,null,null]};
Q.s[918] = {n:"Exoram, der Sram",d:"Ihr habt Exoram in den Sram-Tempel gebracht. Diesmal täte er gut daran, die versprochenen Informationen herauszurücken.",r:[70000,null,null,null,null,null]};
Q.s[892] = {n:"Ein Sram dümmer als die Natur es erlaubt",d:"Exoram ist schon wieder in Schwierigkeiten. Wenn ihr Informationen über Xephirex wollt, müsst ihr ihm erneut helfen.",r:[null,null,null,null,null,null]};
Q.s[447] = {n:"Reinschleichen oder draufschlagen, das ist hier die Frage",d:"Eure Nachforschungen haben ergeben, dass Exoram im Goblin-Lager gefangen gehalten wird. Es sei denn er ist bereits tot.",r:[null,null,null,null,null,null]};
Q.s[448] = {n:"Auf Srams Spuren",d:"Exoram wurde von den Goblins frei gelassen. Ihr müsst erneut seine Spuren verfolgen, um ihn zu erwischen.",r:[null,null,null,null,null,null]};
Q.s[493] = {n:"In der Höhle der Schweinios.",d:"Ihr müsst versuchen, den Schmied in der Höhle der Schweinios für Brâkmar zu gewinnen.",r:[152000,null,null,null,null,null]};
Q.s[759] = {n:"Lektion in Bescheidenheit",d:"Oto hat euch befohlen, ihm 40 blaue Larvenaugen zu besorgen.",r:[23000,null,null,null,null,null]};
Q.s[760] = {n:"Die Goldene Larve loswerden",d:"Findet ein Mittel, um die Goldene Larve loszuwerden, die euch folgt.",r:[25000,null,null,null,null,null]};
Q.s[452] = {n:"Ein Fehlschlag...vorerst",d:"Xephirex hat das Angebot abgelehnt, aber noch ist nicht alles verloren. Ein Juwel wird ihn umstimmen.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"Das Treffen",d:"Jetzt, wo ihr wisst, wo sich Xephirex befindet, müsst ihr nur noch die Taverne zum betrunkenen Pandawa finden und ihm ein Angebot machen. Er ist dort ab 16 Uhr.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"Nachricht weitergeben",d:"Oto möchte, dass ihr seine Nachricht an Vil Smiss überbringt. Er ist im Versteck der Halsabschneider, auf dem Friedhof von Amakna.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"Gefahr im Verzug",d:"Mehrere Brâk-Krieger wurden besiegt und sterbend auf der Straße nach Astrub liegen gelassen. Ihr müsst dort Nachforschungen anstellen, aber Oto Mustam will vorher die Seele eines Blutwolfs.",r:[140000,null,null,null,null,null]};
Q.s[747] = {n:"Steuer eintreiben",d:"Ihr müsst Otos neue Steuer in jeder Kneipe von Brâkmar eintreiben. Ihr habt grünes Licht zum Verprügeln von Wirten, die nicht zahlen wollen.",r:[10700,null,null,null,null,null]};
Q.s[889] = {n:"Akte X",d:"Ihr müsst die Identität dieses geheimnisvollen X herausfinden. Der Brief erwähnt einen Ort, wo er sich gewöhnlich aufhält. Findet diesen Ort und ihr werdet mehr erfahren.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Zurück zum Turm",d:"Ihr habt ein sehr interessantes Stück Papier gefunden. Das müsst ihr Oto zeigen.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"Ein Stelldichein im Turm",d:"Findet eine wichtige Persönlichkeit in Bonta, die wahrscheinlich bestechlich ist. Oto hat euch empfohlen, im Turm zu suchen.",r:[null,null,null,null,null,null]};
Q.s[792] = {n:"Auf der Suche nach dem deprimierten Amtsschreiber",d:"Tabach, Amtsschreiber des Ordens des Tapferen Herzens durchstöbert die Tavernen auf der Suche nach seiner Katze. Er muss dringend zu Hannes Schnalltgetin gebracht werden.",r:[null,null,null,null,null,null]};
Q.s[793] = {n:"Auf der Suche nach dem weiblichen Amtsschreiber",d:"Yba Uhl, Amtsschreiberin des Ordens des Rettenden Geistes durchstöbert die Tavernen auf der Suche nach ihren Brüdern. Sie muss dringend zu Elviana Tirips gebracht werden.",r:[null,null,null,null,null,null]};
Q.s[795] = {n:"Knochenherz",d:"Bringt Gerti Gertisorf  1 Chaferknochen, als Beweis eurer Tüchtigkeit.",r:[null,null,null,null,null,null]};
Q.s[797] = {n:"Der böse Blick",d:"Bringt Heimgeh Dammvert 1 Rabling-Auge, als Beweis eurer Tüchtigkeit.",r:[null,null,null,null,null,null]};
Q.s[210] = {n:"Mit viel Blut im Herzen ist nichts unmöglich.",d:"Ihr müsst die Statuen an euch reißen, die das Gute und das Schlechte der Menschheit symbolisieren und diese dann Gerti übergeben. Sie sind in einer verlassenen Mine versteckt, in der Nähe des Enutrof-Tempels.",r:[200000,null,null,null,null,null]};
Q.s[796] = {n:"Behaartes Kinn",d:"Bringt Divad Dleifrepok 1 Bwork Magus - Barthaar, als Beweis eurer Tüchtigkeit.",r:[null,null,null,null,null,null]};
Q.s[1071] = {n:"Spielzeugfabrik",d:"Scheußliche Kreaturen haben das Lager des Weißnachtsmannes ausgeraubt. Ihr müsst die gestohlenen Geschenkpakete wieder beschaffen, koste es was es wolle und sie zu Harry Kwismas bringen.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1106] = {n:"null",d:"",r:[10000,10000,null,null,null,null]};
Q.s[1113] = {n:"Getreide mähen",d:"Anett\' O\'Reuets hat sich, wie so oft, ein Nickerchen gegönnt, statt zu arbeiten und Frigostinchen zu beliefern. Die Bäckerin hat euch daher gebeten, ihre Angestellte zu vertreten.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1114] = {n:"Blümchen pflücken",d:"Da er auf die Werkstatt aufpassen muss, hat euch Sumynore Ih\'Kob gebeten, ihn mit den nötigen Zutaten zu beliefern.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1115] = {n:"Fische angeln",d:"Jetzt, wo sich so viele Abenteurer auf Frigost tummeln, sinken die Eisfisch-Vorräte mit bedenklicher Geschwindigkeit. Clarissa Toloshia hat euch deshalb gebeten für Nachschub zu sorgen.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1117] = {n:"Erz schürfen",d:"Die Minenaktivität ist schon seit längerer Zeit zum Stillstand gekommen und die Obsidianreserven zur Herstellung von Speziallegierungen sind aufgebraucht. Laurent Gebleuh möchte daher, dass ihr ihn mit Obsidian versorgt.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1116] = {n:"Fleisch erjagen",d:"Jetzt, wo sich so viele Abenteurer auf Frigost tummeln, sinken die Fleisch-Vorräte mit bedenklicher Geschwindigkeit. Al Shab hat euch deshalb gebeten für Nachschub zu sorgen.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1118] = {n:"Holz sammeln",d:"Chef Sietas benötigt eine gigantische Menge an Holz zum Unterhalten des Abtau-Systems des Hafens. Darum bittet er euch um ein wenig Unterstützung.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1107] = {n:"Mutige Fressmutjäger",d:"Clyde Parker hat euch beauftragt, die Eisfelder von Fressmuts zu säubern.",r:[170000,null,[[11196,1]],null,null,null]};
Q.s[1108] = {n:"Jagt die Waldviecher",d:"Clyde Parker hat euch beauftragt, den Wald der verlorenen Kiefern von Kreaturen zu säubern.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1109] = {n:"Ping zur Jagd gegeben",d:"Clyde Parker hat euch beauftragt, den Zugefrorenen See  von Pings zu säubern.",r:[223000,null,[[11196,1]],null,null,null]};
Q.s[1110] = {n:"Phantomjagd mit Piraten",d:"Clyde Parker hat euch beauftragt, Almas Wiege von Piratengeistern zu säubern.",r:[null,null,null,null,null,null]};
Q.s[1111] = {n:"Kraptorenjagd",d:"Clyde Parker hat euch beauftragt, Ouronigrids Tränen von Kreaturen zu säubern.",r:[null,null,null,null,null,null]};
Q.s[1112] = {n:"Jagt die Lavamonster",d:"Clyde Parker hat euch beauftragt, die Lava-Tunnel von Kreaturen zu säubern.",r:[null,null,null,null,null,null]};
Q.s[1121] = {n:"Eine verdiente Belohnung",d:"",r:[80000,3000,null,null,null,null]};
Q.s[1120] = {n:"Säuberungsaktion",d:"Geht in den Keller des Großvaters und säubert diesen von Monstern.",r:[20000,null,null,null,null,null]};
