Q.s[334] = {n:"Das Flügelkit",d:"Gobriel hat die Nase voll davon, dass ihn die anderen wegen seiner seltsamen Hautfarbe mit Steinen bewerfen. Er will daher ein Engel werden.",r:[30000,null,null,null,null,null]};
Q.s[351] = {n:"Der Geschichtsfluss",d:"Gehe Gea im Tempel besuchen, um die vollständige Geschichte des Iopschwertes zu erfahren.",r:[75,null,null,null,null,null]};
Q.s[348] = {n:"Willkommen",d:"Willkommen!",r:[null,null,null,null,null,null]};
Q.s[349] = {n:"Piepmatz",d:"Piep Piep Piep Tschiep Piep!",r:[250,null,[[6897,2],[8537,1]],null,null,null]};
Q.s[346] = {n:"Eltrude Chuwusch",d:"Finde heraus, wo sich Eltrude Chuwusch aufhält.",r:[25,null,null,null,null,null]};
Q.s[332] = {n:"Morgendliche Scherung",d:"Ji Zeh ist ein Genie. Er hat verstanden, dass man aus Wolle... Wolle machen kann!",r:[120,150,null,null,null,null]};
Q.s[344] = {n:"Noch eine Lieferung",d:"Dieses Mal gilt es, einem Xélor, der sich um einen der Zaaps kümmert, einen bestimmten Gegenstand zu bringen.",r:[150,null,null,null,null,null]};
Q.s[416] = {n:"Bunny suit",d:"Der Wa-Pwinz hat dich darum gebeten, als sein Double zu fungieren, um die Attentäter zu enttarnen. Doch wer könnte dich jetzt schnell in einen Wabbit verwandeln?",r:[15000,null,null,null,null,null]};
Q.s[415] = {n:"Ein Überfall!",d:"Der Wa-Pwinz wird angegriffen... Beschütze ihn!",r:[5000,null,null,null,null,null]};
Q.s[417] = {n:"Einkäufe",d:"Nun, da du die vollständige Rezeptur hast, fehlen dir bloß noch die Zutaten dazu.",r:[120000,null,null,null,null,null]};
Q.s[390] = {n:"Welch ein Dilemma...",d:"Nun weißt du, dass Yse Vewybad an einem Komplott gegen den König beteiligt ist. Drum musst du nun entscheiden, auf wessen Seite du stehst.",r:[2000,null,null,null,null,null]};
