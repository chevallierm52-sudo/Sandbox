Q.s[1103] = {n:"Das Zertifikat",d:"Geht zum Alchimisten-Prüfer, der im Moment gerade Forschung über die post-mortale Calcium-Verteilung im Nasenknorpel betreibt.",r:[null,null,null,null,null,null]};
Q.s[1102] = {n:"Alch\'ti mi.",d:"Eli Bell hat euch gesagt, wo ihr den Koordinator der Alchimisten-Lehrmeister finden könnt, um eure Ausbildung zu beginnen.",r:[null,null,null,null,null,null]};
Q.s[461] = {n:"Infos à la Bagrutt",d:"Der Weinhändler des Viertels ist verschwunden. Vielleicht weiß der Wirt der Bagrutt-Taverne etwas darüber.",r:[null,null,null,null,null,null]};
Q.s[462] = {n:"Nachforschungen im Osten",d:"Der Bagrutt-Wirt meint, der Händler ging gewöhnlich zu sich nach Hause, ein wenig gen Osten.",r:[60000,null,null,null,null,null]};
Q.s[575] = {n:"Auf der Suche nach dem Hammer",d:"Das Buch verrät den Fundort des Lichthammers, in einer Krypta auf dem Friedhof von Amakna. Findet ihn und bringt ihn zu Tück\'n\'Stück.",r:[272000,null,null,null,null,null]};
Q.s[574] = {n:"Infos über den Hammer",d:"Auf der Suche nach einem Lichthammer, hat euch  Tück\'n\'Stück gebeten, die Klassenmeister folgender Tempel zu befragen: Crâ, Ecaflip, Eniripsa, Féca, Iop und Sacrieur.",r:[null,null,null,null,null,null]};
Q.s[584] = {n:"Tück\'n\'Stück zu Diensten",d:"Amayiro setzt euch davon in Kenntnis, dass Tück\'n\'Stück eure Dienste braucht. Ihr könnt ihn beim Turm von Bonta finden.",r:[null,null,null,null,null,null]};
Q.s[512] = {n:"Sufokia",d:"Einem Gerücht nach gibt es ein Horn mit magischen Kräften. Die Einwohner von Sufokia haben angeblich mehr Informationen darüber.",r:[null,null,null,null,null,null]};
Q.s[513] = {n:"Schildkrötenpanzer",d:"Der Ripaten-Wirt verlangt von euch Schildkrötenpanzer von Moon, einen in jeder Farbe. Aber vielleicht können sie durch ein nettes Sümmchen Kamas ersetzt werden.",r:[null,null,null,null,null,null]};
Q.s[935] = {n:"Kokokoboy",d:"Es wäre besser, vorzusorgen und einen beachtlichen Vorrat an Kokokosnüssen anzulegen, bevor ihr zu Amayiro zurückkehrt.",r:[170000,null,null,null,null,null]};
Q.s[934] = {n:"Horn über Bord",d:"Der Ripaten-Wirt meint, dass sich das Horn auf einer Insel befände. Die Weisen können dir ohne Zweifel mehr darüber sagen.",r:[null,null,null,null,null,null]};
Q.s[697] = {n:"Nachforschungen über den Jahrmarkt",d:"Besorgt in der Miliz ein Formular bei Inge Ture, verhört anschließend den Leiter des Jahrmarkt des Trools, um herauszufinden, ob er ein Brâk ist oder nicht.",r:[8200,null,null,null,null,null]};
