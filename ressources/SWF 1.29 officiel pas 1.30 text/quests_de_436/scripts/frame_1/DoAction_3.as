Q.s[1143] = {n:"Eisiges Gluckerwasser",d:"Jean-Pierre Kofkof ist bei einer Konfrontation zwischen Vali Dummidatt und einer Fremden eingeschritten. Vielleicht hat er dabei irgendetwas Ungewöhnliches bemerkt.",r:[340000,5000,[[11196,1]],null,null,null]};
Q.s[1142] = {n:"Eine lange Leitung...",d:"Vali Dummidatt ist verschwunden, seitdem sie das Rohrsystem in der Werkstatt der Bauern reparieren wollte. Fränky, ihr Angestellter, macht sich Sorgen und bittet euch sie zu suchen.",r:[null,null,null,null,null,null]};
Q.s[1145] = {n:"Die Rückkehr der Fantastischen Vier",d:"Ihr habt die verschwundenen Angestellten gefunden. Sie waren alle Opfer einer seltsamen Verzauberung. Nun müsst ihr sie noch einen nach dem anderen in die Stadt eskortieren.",r:[603000,10000,[[11196,1]],null,null,null]};
Q.s[1144] = {n:"Ein fantastischer Waldspaziergang",d:"Mehrere Angestellte Chef Sietas sind im Wald der verlorenen Kiefern verloren gegangen. Findet heraus was ihnen widerfahren ist.",r:[null,null,null,null,null,null]};
Q.s[1146] = {n:"Guter Jäger, schlechter Jäger!",d:"Clyde Parker, der Chef der Miliz, hat euch gebeten, den verschwundenen Jäger Gérard zu suchen.",r:[669000,15000,[[11196,2]],null,null,null]};
