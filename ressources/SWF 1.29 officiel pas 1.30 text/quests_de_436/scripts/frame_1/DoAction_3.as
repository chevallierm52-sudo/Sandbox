Q.s[1140] = {n:"Flohgemute Fresssackbrut",d:"Ihr müsst einen Weg finden, der Flohinvasion, die die Fressmuts befallen hat, wieder Herr zu werden.",r:[null,null,null,null,null,null]};
Q.s[1119] = {n:"Was ist stärker, die Feder oder... der Apewicubus?",d:"Ihr habt eine vibrierende Ping-Feder gefunden. Tolle Sache! Doch niemand weiß, wozu man diese nutzen könnte. Glücklicherweise habt ihr einige Fischer gehört, die sich über Kyrie Lawasch unterhalten haben. Vielleicht weiß diese ja etwas...",r:[5000,null,[[11134,1]],null,null,null]};
Q.s[1127] = {n:"Eissamen gefeldig?",d:"Frauke Ernbau hat euch gebeten, ihr mehrere Arten von Samenkörnern zu bringen, aus denen sie neue, kälteresistentere Getreidesorten kreuzen möchte.",r:[510000,10000,[[11196,1]],null,null,null]};
Q.s[492] = {n:"Zwischen Hammer und Amboss",d:"Oto Mustam glaubt, dass Bonta Hilfe von einem Söldner-Schmied erhält. Durchsucht die Werkstätten der Schmiede und Bergleute nach Indizien.",r:[146000,null,null,null,null,null]};
