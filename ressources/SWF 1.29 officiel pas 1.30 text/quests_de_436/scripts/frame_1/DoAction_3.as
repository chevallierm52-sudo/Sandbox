Q.s[1099] = {n:"Die Chaostheorie",d:"Die Quelle alles Bösen finden.",r:[null,null,null,null,null,null]};
Q.s[1100] = {n:"Ein schlechter Plan",d:"Verhindert den Plan der Brâks.",r:[null,null,null,null,null,null]};
