Q.s[556] = {n:"Exorzismus",d:"Ihr müsst den Geist des Lichts der in dem Hammer innenwohnt, austreiben. Gerti Gertisorf im Turm von Brâkmar könnte sich darum kümmern.",r:[264000,null,null,null,null,null]};
Q.s[555] = {n:"Hammerdiebstahl",d:"Oto benötigt einen besonderen Hammer, um seine Klinge zu schmieden. Dieser Hammer befindet sich im Moment im Besitz eines Bonta-Schmiedes: Ihr müsst ihn also stehlen, aber gebt auf die Wachen acht.",r:[null,null,null,null,null,null]};
Q.s[944] = {n:"Gefallen oder gestürzt?",d:"Ihr müsst euch in der Bibliothek und in den Werkstätten der Schmiede über den Phosphoros-Hammer erkundigen.",r:[null,null,null,null,null,null]};
Q.s[547] = {n:"Allererstes Material",d:"Oto Mustam benötigt Korruptit: er weiß nicht, wo man welches findet und ihr sollt ihm welches bringen.",r:[null,null,null,null,null,null]};
Q.s[545] = {n:"Die Warnung",d:"Domen hat verlangt, euch zu sehen und zwar beim Ordensturm von Brâkmar.",r:[null,null,null,null,null,null]};
Q.s[940] = {n:"Korruptit",d:"Das Korruptit befindet sich im Innersten des Dungeon der Schattenschmiede, aber ihr braucht einen Behälter für den Transport.",r:[240000,null,null,null,null,null]};
Q.s[542] = {n:"Verschwunden",d:"Ihr könnt nun eure Nachforschungen beenden und Oto Mustam Bericht erstatten.",r:[226000,null,null,null,null,null]};
Q.s[539] = {n:"Die dunkle Seite des Wabbits",d:"Ihr müsst das Versteck des Ih-Fritt Horns gegen einen Spontex-Rückenkratzer mit Tökredilsch aushandeln, aber wer weiß, was euch im tiefsten Dschungel von Moon erwartet?",r:[null,null,null,null,null,null]};
Q.s[540] = {n:"Die Grabung",d:"Tökredilsch hat euch verraten, dass das Horn des Ih-Fritts im Nordosten der Insel vergraben ist, in der Nähe einer Phönix-Statue.",r:[null,null,null,null,null,null]};
Q.s[541] = {n:"Der Spielverderber",d:"Eure Ausgrabungen wurden durch das Erscheinen eines Sadida unterbrochen. Ihr könnt ihm zeigen, was passiert, wenn man sich einem Brâk entgegenstellt.",r:[null,null,null,null,null,null]};
Q.s[260] = {n:"Leichte Kavallerie",d:"Die Miliz braucht frische Reittiere.",r:[75000,null,null,null,null,null]};
Q.s[558] = {n:"Bei der Macht des Unheilvollen Schwertes",d:"Lagren Doowil, der in den Schlafsälen der Miliz herumläuft, könnte euch dabei helfen, die Klinge mit noch mehr Macht zu tränken.",r:[null,null,null,null,null,null]};
Q.s[950] = {n:"Möge die Macht mit mir sein",d:"Ihr müsst Oto Mustams Schwert noch den letzten Schliff verpassen, indem ihr sein Macht versiegelt. Schmiedemagie könnte hier ganz nützlich sein.",r:[280000,null,null,null,null,null]};
