Q.s[746] = {n:"Otos Pleite",d:"Oto hat keinen Pfennig mehr übrig. Was kann man da tun?",r:[10000,null,null,null,null,null]};
Q.s[748] = {n:"Lunge stehlen",d:"Oto will, dass ihr die Lunge der Ebenen von Azra Lazarus, der Juwelierin stehlt. Sie hat eine Wache, aber vielleicht kann man einen Kampf vermeiden.",r:[11400,null,null,null,null,null]};
Q.s[758] = {n:"Einen nicht ganz unschuldigen Bonta finden",d:"Findet einen Bonta, der des Mordes schuldig ist. Dazu müsst ihr euch bei Fryda eine Wünschelrute besorgen und diese dann bei den Bonta ausprobieren, bis ihr jemand Passenden findet.",r:[21000,null,null,null,null,null]};
Q.s[1094] = {n:"Gisgoul, meine Heimat",d:"Der Ehrgeiz der Brâks kennt keine Grenzen!",r:[null,null,null,null,null,null]};
Q.s[1096] = {n:"Ein schlechter Plan",d:"Verstreue kleine weiße Steinchen im Labyrinth des Dark Vlad.",r:[null,null,null,null,null,null]};
Q.s[1095] = {n:"Orci Touris, Tee salutant",d:"Bringt Lethalina das Gewünschte.",r:[null,null,null,null,null,null]};
Q.s[1097] = {n:"Goultard-Z",d:"Alle Steine liegen nun verteilt. Auf zum Schachmatt!",r:[null,null,null,null,null,null]};
Q.s[974] = {n:"Tränenreich",d:"Findet Sacrieurs Tränen und bringt sie zu Danathor, damit die Schimmernde Morgendämmerung geschmiedet werden kann.",r:[null,null,null,null,null,null]};
Q.s[975] = {n:"Das Schmieden der Schimmernden Morgendämmerung",d:"Danathor möchte, dass ihr auf euch auf die Insel Eiland Där begebt, damit dort die Schimmernde Morgendämmerung geschmiedet werden kann. Ihr müsst seinen Anweisungen genauestens folgen.",r:[312000,null,null,null,null,null]};
Q.s[1098] = {n:"Gisgoul, meine Heimat",d:"Der Ehrgeiz der Brâks kennt keine Grenzen!",r:[null,null,null,null,null,null]};
