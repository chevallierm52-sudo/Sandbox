Q.s[532] = {n:"Luxusschmiede",d:"Ihr müsst einen Rückenkratzer herstellen, den Tökredilsch benutzen kann. Da er der beste Schmied von Brâkmar ist, wird euch Mulic Bere dabei helfen, dieses besondere Werkzeug herzustellen.",r:[null,null,null,null,null,null]};
