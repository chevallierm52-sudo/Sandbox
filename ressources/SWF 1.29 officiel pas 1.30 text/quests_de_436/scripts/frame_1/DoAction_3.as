Q.s[800] = {n:"Einbruch im Herzen von Brâkmar",d:"Die Brâks haben die zweite Sumens-Statue in ihre Hände bekommen. Ortet sie und nehmt sie an euch.",r:[600000,null,null,null,null,null]};
Q.s[798] = {n:"Die Entführung Dike Taraks",d:"Tück\'n\'Stück hat euch gebeten, Dike Tarak, Amayiros Neffen zu finden, der auf einem Klassenausflug zu den Ebenen von Cania entführt wurde.",r:[null,null,null,null,null,null]};
Q.s[799] = {n:"Zone 51",d:"Ihr seid fest davon überzeugt, dass der seltsame Gegenstand den ihr im Lager gefunden habt, mit der Entführung von Dike Tarak zusammenhängt",r:[null,null,null,null,null,null]};
Q.s[965] = {n:"Vorratsdiebstahl",d:"Ihr sollt eine Kiste mit Gift aus den Vorräten von Brâkmar entwenden. Dazu braucht ihr die Hilfe eines Srams oder eines Mitglieds des Orden des Eitrigen Auges, der aber höheren Ranges sein muss, als ein Schüler Brumaires.",r:[296000,null,null,null,null,null]};
Q.s[568] = {n:"Mehr Schmiede sind besser als garnichts",d:"Ihr müsst die Schmiede davon überzeugen, euch so schnell wie möglich mehrere Dutzend Schwerter anzufertigen.",r:[null,null,null,null,null,null]};
