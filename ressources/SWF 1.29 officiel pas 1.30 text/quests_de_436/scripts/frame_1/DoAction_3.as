Q.s[803] = {n:"Das Mobiliar bewahr",d:"Gerti befürchtet, dass Bonta seine Leute aussendet, um die Sumens-Statue zu stehlen, die im Turm von Brâkmar aufbewahrt wird.",r:[null,null,null,null,null,null]};
