Q.s[7] = {n:"Maunzmiezens Mamampf",d:"Befrage andere Abenteurer nach der passenden Nahrung für eine gewöhnliche Maunzmiez und bring ihr ein wenig davon.",r:[1220,null,null,null,null,null]};
Q.s[9] = {n:"Mächtige Mieze der Macht – Gib acht!",d:"Finde einen Weg, diese mickrige Maunzmiez in den Augen seiner Gefährtin zu einem Helden zu machen.",r:[3060,null,null,null,null,null]};
Q.s[6] = {n:"Mimilch für eine Maunzmiez",d:"Bringe einem armen kleinen Kätzchen etwas Mimilch.",r:[1220,null,null,null,null,null]};
Q.s[8] = {n:"Ein mieziger Spaziergang",d:"Mache mit der Maunzmiez einen kleinen Spaziergang durch die Stadt.",r:[1500,null,null,null,null,null]};
Q.s[13] = {n:"Der geliehene Ring",d:"Shani hat dir einen Ring mit latenten Kräften gegeben. Um diesen zu aktivieren, muss ein Astaknyde getötet werden.",r:[11000,1200,[[6793,1]],null,null,null]};
Q.s[12] = {n:"Noch ein wenig Würze",d:"Shani hat vergessen, für die morgige Prüfung genug Pilzlingstacheln vorzubereiten. Darum liegt es nun an dir, ihm welche zu besorgen.",r:[2600,250,null,null,null,null]};
Q.s[11] = {n:"Abwasseraufbereitung",d:"Bringe Shani Sings etwas Fresssackspucke.",r:[1700,200,null,null,null,null]};
Q.s[10] = {n:"Ein haariges Amulett?",d:"Bringe frische Arachneenklauen zum Juweliergeschäft. Sie werden für die Erschaffung eines Amuletts benötigt.",r:[1700,null,[[6773,1]],null,null,null]};
Q.s[24] = {n:"Gaunerei!",d:"Beschaffe dir den Spionagebericht und gib ihn Ztif Oztin.",r:[1200,null,[[6784,1]],null,null,null]};
Q.s[22] = {n:"Der 3-Kama-Spion",d:"Finde Ztiv Oztin und biete ihm deine Dienste an.",r:[1200,null,null,null,null,null]};
Q.s[20] = {n:"Diskretion garantiert",d:"Finde Ogivol Scalarcin in der Nähe seines Unterschlupfes, wlchen du durch eine Falltür im Holzlager betreten kannst.",r:[600,null,null,null,null,null]};
Q.s[121] = {n:"Finde den Übeltäter",d:"Es ist anzunehmen, dass sich der knöcherne Mark von Kainsdaf Ürmisch in der Nähe des Litneg-Waldes im Nordosten der Ebenen von Cania aufhält. Kainsdaf Ürmisch wurde in Astrub zu einer Gefängnisstrafe verurteilt, und zwar wegen Mißhandlung von zahmen Fresssäcken und nächtlicher Ruhestörung.",r:[null,84500,null,null,null,null]};
Q.s[26] = {n:"Suche flotte Beine",d:"Der Bäcker hat eine Eilbestellung für 4 Personen offen, findet jedoch keinen Lieferjungen. Bringe die ofenfrischen Torten schnellstmöglich zum jeweiligen Kunden.",r:[1000,null,null,null,null,null]};
Q.s[29] = {n:"Auf der Suche nach einem neuen Botenjungen",d:"Finde einen starken und geschickten Abenteurer, der die Stelle des alten Lieferjungen einnehmen kann.",r:[2000,250,null,null,null,null]};
Q.s[28] = {n:"Isses ein Flirtjunge?",d:"Überprüfe, ob der Lieferjunge Louc Drif auch wirklich krank ist.",r:[2000,500,null,null,null,null]};
Q.s[30] = {n:"Die letzte Lieferung",d:"Liefere Großmutter einen Kuchen aus.",r:[5000,null,null,null,null,null]};
Q.s[103] = {n:"Kate J. Zenhammers Haus",d:"Kate hat vergessen, wo ihr Haus steht. Voller Angst traut sie sich nicht mehr allein durch die Stadt.",r:[5750,250,null,null,null,null]};
Q.s[33] = {n:"Der Flachsblütenstrauß",d:"Sammle einen Flachsblütenstrauß für die Mutter von Kate J. Zenhammer. (Nur Alchimisten können diese Blüten pflücken.)",r:[2000,200,null,null,null,null]};
Q.s[31] = {n:"Einarmige Banditen",d:"Das Lager der einarmigen Banditen befindet sich mitten im Wald, nördlich von Astrub. Den Teddybären hat sicherlich einer der Banditen.",r:[2000,null,null,null,null,null]};
Q.s[37] = {n:"Ab in die Höhle des Bären",d:"Laut Abrazelor muss man den Bärenmann zusammen mit anderen Abenteurern angreifen, damit er sein Manuskript im Kampf einsetzt. Anschließend sollst du dieses Manuskript Abrazelor bringen, damit er es authentifizieren kann.",r:[9000,2500,null,null,null,null]};
Q.s[35] = {n:"Die Meinung eines Osamodas",d:"Abrazelor Hexacrallruar hat dir vom Bärenmann erzählt, der angeblich in der Lage ist, mächtige Kreaturen zu beschwören. Bevor du dich an seine Fersen heftet, solltest du besser Datni Taufes informieren.",r:[3000,null,null,null,null,null]};
Q.s[34] = {n:"Das haarige Wesen",d:"Der Hirte Datni Taufes hat kürzlich großen Ärger mit einem großen, behaarten Tier gehabt. Darum sucht er nun nach jemandem, der Näheres über dieses Wesen wissen könnte.",r:[750,null,null,null,null,null]};
Q.s[36] = {n:"Auf den Spuren des Bären",d:"Folge den Bärenspuren und finde den Unterschlupf dieses Monsters.",r:[3000,null,null,null,null,null]};
Q.s[53] = {n:"Ein stinkendes Innenfutter",d:"Alit rät dir, deinen Mantel mit einem Innenfutter zu versehen. Bringe ihm dafür etwas Fresssackwolle.",r:[3500,null,[[6801,1]],null,null,null]};
Q.s[54] = {n:"All dies für einen Ohrenschützer",d:"Beschaffe die benötigten Materialien für die Anfertigung eines Ohrschützers. Bitte gegebenenfalls andere Abenteurer um Hilfe, denn einige der benötigten Ressourcen sind nur schwer zu bekommen.",r:[11000,500,[[6802,1]],null,null,null]};
Q.s[52] = {n:"Wolle gesucht",d:"Der Schneider Alit benötigt dringend schwarze und weiße Fresssäckchenwolle. Bringe ihm welche, und er fertigt dir zum Dank maßgeschneiderte Kleidung an.",r:[2500,null,[[6800,1]],null,null,null]};
Q.s[49] = {n:"Unterstützung benötigt",d:"Bitte die Fécas und Eniripsas um Unterstützung.",r:[1200,null,null,null,null,null]};
Q.s[51] = {n:"Schaufel benötigt!",d:"Kehre zu Joe zurück, um dir deine Belohnung abzuholen.",r:[1200,null,[[6786,1]],null,null,null]};
Q.s[45] = {n:"Arbeitskräfte gesucht",d:"Finde Howard, den Simserianer, und gib ihm den Brief von Joe Pierlevet.",r:[600,null,null,null,null,null]};
Q.s[55] = {n:"Das Blut des Wabbit GM",d:"",r:[null,null,null,null,null,null]};
Q.s[57] = {n:"Eine Blutprobe",d:"",r:[null,null,null,null,null,null]};
Q.s[58] = {n:"Wogew Wabbit",d:"",r:[null,null,null,null,null,null]};
Q.s[76] = {n:"Jetzt müsste man es nur noch führen können...",d:"Erlerne die Handhabung deines neuen Schwertes im Kampf gegen ein paar Insekten.",r:[900,null,null,null,null,null]};
Q.s[67] = {n:"Schwerter schmieden für Dummies",d:"Du bist auf die Hilfe eines Schmiedes angewiesen, um ein Schwert zu schmieden.",r:[null,null,null,null,null,null]};
Q.s[68] = {n:"Ein Heft am Schwert ist wichtig, ein Heft am Schwert ist gut!",d:"Finde ein Heft für dein Schwert.",r:[1200,null,null,null,null,null]};
Q.s[69] = {n:"Der letzte Schliff",d:"Bringe deinem Meister das frisch geschmiedete Schwert.",r:[900,null,[[6780,1]],null,null,null]};
Q.s[63] = {n:"...Zweifel!",d:"Bringe das Schwert zu deinem Meister. Er wird das Markenzeichen deiner Klasse darin eingravieren.",r:[1200,null,null,null,null,null]};
Q.s[61] = {n:"Ein seltsames Metall",d:"Bringe den Sack mit den rätselhaften Kamas zu jemandem, der etwas damit anfangen kann.",r:[600,null,null,null,null,null]};
Q.s[62] = {n:"Raffinierte Zweifel",d:"Raffiniere das seltsame Metall.",r:[1200,null,null,null,null,null]};
Q.s[72] = {n:"Herzensräuber",d:"Dieses kleinen Steinchen stammen eindeutig aus dem Bergwerk im Nordosten des Dorfes. Mach dich auf und suche dort Loucs Schatztruhe.",r:[4000,null,null,null,null,null]};
Q.s[150] = {n:"Die Belohnung",d:"Hol dir deine Belohnung bei Louc Drif ab.",r:[5000,null,[[1519,1]],null,null,null]};
Q.s[71] = {n:"Auf der Suche nach kleinen Steinchen",d:"Vergleiche die kleinen Steinchen mit denen, die bei Louc gefunden wurden. Besuche dafür alle verdächtigen Orte.",r:[1500,250,null,null,null,null]};
Q.s[70] = {n:"Tausche Metaria gegen ein Rendezvous!",d:"Louc muss sein Schatzkistenproblem lösen und sich gleichzeitig für sein erstes Rendezvous zurecht machen. Hilf ihm, indem du ihm zwei Rosen bringst. (Eine pro Mädchen.)",r:[1500,500,null,null,null,null]};
Q.s[73] = {n:"Lauf Forest, lauf!",d:"Was? Du magst Kinder? Mit diesem einen hier wirst du deine Meinung sicherlich bald ändern...",r:[600,50,null,null,null,null]};
Q.s[75] = {n:"Eines Crâs erster Bogen",d:"Ha, wie schön ist es, seinen eigenen Bogen herzustellen!",r:[1200,null,[[6783,1]],null,null,null]};
Q.s[78] = {n:"Eine Crâtastrophe",d:"Nun musst du erst einmal den Umgang mit dem Bogen erlernen.",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Finde den Übeltäter",d:"Laut Zeugenaussagen soll Frakassurus Leukocytinas beim Dorf der einarmigen Banditen gesichtet worden sein. Sie wurde in Astrub zu einer Gefängnisstrafe verurteilt, und zwar wegen illegaler und ungefragter Durchführung von Punktionen bei Hemoglobina.",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Finde den Übeltäter",d:"Gewisse Leute behaupten, Nervoes Brâkdaun in der Näh des Astaknydenwalds gesehen zu haben. Er wird wegen Juwelenraub gesucht und wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Finde den Übeltäter",d:"Brumen Tinctorias wurde zu einer Gefängnisstrafe in Astrub verurteilt, da er sich den kosmischen Kräften widersetzt hat. Er dürfte sich im Sidimot-Gebiet aufhalten.",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Finde den Übeltäter",d:"Scratsahorntas macht Astrub unsicher und ist stets auf der Suche nach schmackhaften Eicheln zum Abnagen.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Finde den Übeltäter",d:"Ogivol wurde in Brâkmar gesichtet. Er wird wegen tückischen Diebstahls gesucht, unter anderem wegen Entwendung von Geheimdokumenten. Er wurde zu einer Gefängnisstrafe in Astrub verurteilt.",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Beschütze das Gebräu",d:"Biztek Gitsurf, der Bierschänk des Dorfes, ist gezwungen, sein Bier zu verwässern, da ihm seine Biervorräte gestohlen wurden. Finde den Lieferanten im Südosten, indem du seiner Route folgst, und eskortiere ihn.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"Lässt sich die Unterdrückung unterdrücken?",d:"Stoppe den Bierdiebstahl!",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Eine gute Sicht auf die Dinge",d:"Sammle verschiedene Ressourcen, damit Kwuarzuahr einen Blick in die Zukunft tun kann.",r:[600,null,null,null,null,null]};
Q.s[92] = {n:"Die Zukunft ist gar nicht lustig!",d:"Kwuarzuahr sagt dir die nahe Zukunft voraus.",r:[1200,null,null,null,null,null]};
Q.s[91] = {n:"Die Zukunft ist ein großes Abenteuer!",d:"Kwuarzuahr benötigt noch eine blaue Larvenhaut, um seine Maschine fertigzustellen.",r:[1200,null,null,null,null,null]};
Q.s[94] = {n:"Die Lieferung",d:"Bringe Clint Pot das Heilmittel, das du erhalten hast. (Hmmm, war das nun zum Heilen von Tofus oder Enutrofs? So genau weißt du das wahrscheinlich nicht mehr.) Erstatte anschließend deinem Klassenmeister Bericht.",r:[1800,null,[[6785,1]],null,null,null]};
Q.s[93] = {n:"Antischnuzapfs...",d:"Hilf deinem Meister, ein Heilmittel für seine Tofus zu finden.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"Erster Raum",d:"Wie setzt man am besten drei Dofus ein?",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Zweiter Raum",d:"Finde den passenden Schlüssel.",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"Tac Tic!",d:"...",r:[2500,20,null,null,null,null]};
Q.s[145] = {n:"... und Scheren",d:"Über diese Schere, die du gerade ergattert hast, wird sich Rhaa sicherlich sehr freuen.",r:[1750,null,null,null,null,null]};
Q.s[133] = {n:"Ein schönes Päarchen...",d:"Rhaa Reschneid sucht dringend eine frisch geschmiedete Schere. Sie bittet dich, ihr eine solche beim Schmied am Verkaufsstand zu besorgen.",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Haare... Haare... noch mehr Haare...",d:"Rhaa hat vor, alle Haartypen der Bewohner Astrubs zu sammeln, um Perücken aus ihnen zu fertigen.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"Auf der Spur...",d:"Die Enutrofs, die sich auf die Suche nach den Schnüffelratten gemacht haben, scheinen sich in den Tiefen des Bergwerkes verlaufen zu haben. Dumm nur, dass diese Gänge auch noch mit Kanalkweratten verseucht sind.",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"Besser Rattenzähne in der Hand, als viele Ratten im Schacht",d:"Entledige dich dieser Kanalkweratte! Sie sieht kränklich aus, also dürfte das ja nicht allzu schwierig sein... Naja, zusammen mit einer Gruppe anderer Abenteurer eben.",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"Der Beginn des Reichtums",d:"Sammle 10 Arachneenklauen für Ohm Atranchie. Es scheint sich zu lohnen.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Kranke Feder",d:"Aus zwanzig Federn lässt sich ein Staubwedel herstellen. Doch bei diesen Federn...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Eine wohlverdiente Belohnung",d:"Rede mit der Großmutter und zeige ihr den Kopf der Hausmaus.",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"Die verseuchten Höhlen",d:"Geh in Großmutters Keller und schalte die Bedrohung aus.",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Milizionär besiegen",d:"Ihr müsst Tarche den Milizionär im Nebensaal besiegen.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Brotzeit",d:"Ihr müsst Amayiro 20 Vollkornbrote bringen.",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"Die Fresssackzähne",d:"Ihr müsst den Fresssäcken die Zähne ausreißen und zwar genau die Anzahl, die einem menschlichen Gebiss entspricht. Bringt das Ganze anschließend zu Ned im Süd-Westen der Stadt.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"Ein Schlappen für\'s Brüderchen",d:"Besiegt den Milizionär Torche und bringt Amayiro einen Beweis.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Den Rabling finden",d:"Findet den Rabling, der die Halskette der Bürgermeistertochter gestohlen hat, besiegt ihn und nehmt die Halskette. Der Rabling ist in Richtung Turm.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Keilerjagd",d:"Findet den Aggressiven Keiler im Süden Bontas und besiegt ihn.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"Die Reparatur des Katana",d:"Bittet Lloth Cini Bhaoh den Schmied, Amayiros Klinge im Tausch für den Scheck zu reparieren.",r:[4600,null,null,null,null,null]};
Q.s[690] = {n:"Den schlechten Schuldner verprügeln",d:"Der Wirt des \"Knüppels\" schuldet Amayiro eine ziemlich hohe Summe: Überzeugt ihn mit allen Mitteln, zu bezahlen.",r:[null,null,null,null,null,null]};
Q.s[692] = {n:"Mit dem Spion kommunizieren",d:"Findet Bishom Pot in Brâkmar und lockt aus ihm die Informationen heraus, die Amayiro von euch verlangt hat.",r:[5200,null,null,null,null,null]};
Q.s[694] = {n:"Lücken schliessen",d:"Nenonak Rettuff, am Eingang von Bonta, benötigt 4 Krachlergesteine der Ebenen, um die Risse in den Mauern zu verstopfen.",r:[6400,null,null,null,null,null]};
Q.s[696] = {n:"Helmesammlung",d:"Bringt Amayiro 15 Elitechafer-Helme.",r:[7600,null,null,null,null,null]};
Q.s[698] = {n:"Brei für den Tabi",d:"Bringe Amayiro Blopblütenbrei. Dafür müsst ihr 4 Blopblüten von verschiedener Farbe in einem Münster Zerkleinerer zerstampfen.",r:[8800,null,null,null,null,null]};
Q.s[700] = {n:"Flinkheit für Amayiro",d:"Amayiro hat von euch 20 Ringe der Flinkheit verlangt.",r:[10000,null,null,null,null,null]};
Q.s[702] = {n:"Bringt die Umhänge",d:"Amayiro hat euch damit beauftragt, dem Kapitän Koda von nebenan, 10 Bonta-Umhänge zu bringen. Sie werden aus einem magischen blauen Färbemittel, einer Rabling-Feder und weißer Fresssackwolle hergestellt.",r:[11400,null,null,null,null,null]};
Q.s[705] = {n:"21 Uhr",d:"Danathor hat euch befohlen, ihn um 21 Uhr mit den Zutaten auf seiner Liste zu treffen.",r:[13500,null,null,null,null,null]};
Q.s[708] = {n:"Fleisch für den Koch",d:"Bontas Küchenmeister der Miliz, Stermei Schenküh, braucht 10 Tofu-Schlegel.",r:[13500,null,null,null,null,null]};
Q.s[707] = {n:"Mord abgelehnt",d:"Geht zu Amayiro.",r:[null,null,null,null,null,null]};
Q.s[712] = {n:"Bringt das Gift",d:"Kapitän Essacirf, im Gefängnis von Bonta, braucht 30 Pods  Skorpiutgift.",r:[15600,null,null,null,null,null]};
Q.s[714] = {n:"Ein Kampf...zum Lachen?",d:"Findet Dike Tarak im Nordviertel, fordert ihn heraus und besiegt ihn.",r:[null,null,null,null,null,null]};
Q.s[713] = {n:"Ein Kampf...zum Lachen.",d:"Findet Dike Tarak im Nordviertel, fordert ihn heraus und verliert.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Findet eine Schwachstelle",d:"Amayiro hat euch befohlen, den Friedhof der Verdammten, im Osten von Brâkmar, zu erforschen und nachzusehen, ob es in der Verteidigung der Stadt eine Schwachstelle gibt. Ihr braucht bestimmt besonderes Material dazu.",r:[19000,null,null,null,null,null]};
