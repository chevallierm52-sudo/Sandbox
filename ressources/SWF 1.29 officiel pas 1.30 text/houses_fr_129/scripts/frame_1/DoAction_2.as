H.h[513] = {n:"Gigantesque maison de boucher",d:"Cette imposante bâtisse comporte trois étages dans lesquels sont disséminés de nombreux coffres. Le dernier étage contient une machine de boucher. Vous ne trouverez pas plus spacieux dans tout Bonta."};
H.h[514] = {n:"Moyenne maison de bijoutier",d:"Cette maison dispose de deux étages, ce qui plaira à ceux qui aiment organiser de grandes fêtes, mais ne conviendra pas à ceux qui n\'aiment pas monter les escaliers."};
H.h[515] = {n:"Grande Maison de Boucher",d:"Avec cette maison, vous pourrez vous livrer à votre passion du dépeçage en toute tranquillité. "};
H.h[516] = {n:"Moyenne Maison de Boucher",d:"Ben là, je sais plus trop quoi dire...C\'est une Moyenne Maison de Boucher quoi..."};
H.h[517] = {n:"Très Grande Maison de Brâkmar",d:"Achète cette  très grande maison et tu  réaliseras enfin ton rêve de regarder de haut, le peuple de Brâkmar."};
