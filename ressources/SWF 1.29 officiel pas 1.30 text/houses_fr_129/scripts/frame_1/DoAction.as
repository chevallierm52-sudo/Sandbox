H.h[66] = {n:"Petite maison de chaume",d:"Cette petite maison au toit de chaume proche de la rivière ravira les amateurs de pêche. Elle dispose d\'un étage, mais il faudra utiliser l\'échelle mise gratuitement à disposition du propriétaire, car l\'escalier n\'est pas fourni en standard avec ce type de maison."};
H.h[67] = {n:"Petite maison de chaume",d:"Cette petite maison au toit de chaume située à proximité de la rivière, ravira les amateurs de pêche. Elle dispose d\'un étage, mais l\'escalier n\'est pas fourni, il faudra utiliser l\'échelle gracieusement offerte."};
H.h[68] = {n:"Petite maison",d:"Cette petite maison, ne dispose que d\'un seul étage habitable, le grenier n\'est plus accessible depuis qu\'une famille de rats y habite."};
H.h[69] = {n:"Maison à deux étages",d:"Cette maison dispose de deux étages, ce qui plaira à ceux qui aiment organiser de grandes fêtes, mais ne conviendra pas à ceux qui n\'aiment pas monter les escaliers.\n"};
H.h[70] = {n:"Maison à un étage",d:"Cette maison  est proche de la rivière et du village, ce qui compense le fait qu\'elle ne dispose que d\'un seul étage. Attention cependant, lorsque la rivière est en crue, le rez-de-chaussée est souvent inondé."};
H.h[74] = {n:"Maison près du magasin",d:"Cette petite maison dispose d\'un étage, mais son principal avantage est d\'être située à côté du magasin de Séline et Charlotte et à quelques pas du centre du village. Elle ravira les couples qui aiment garder un peu d\'intimité avec ses deux lits séparés à l\'étage."};
H.h[75] = {n:"Chaumière de la fontaine",d:"Cette chaumière ne dispose que d\'un seul étage, mais elle est située sur la place de la fontaine, ce qui en fait une maison de choix pour ceux qui aiment montrer leurs possessions au peuple."};
H.h[76] = {n:"Bâtisse de la Fontaine",d:"Cette  bâtisse qui comporte tout de même deux étages, appartenait à un richissime  notaire, qui a disparu dans d\'étranges circonstances, laissant sa maison abandonnée."};
H.h[77] = {n:"Bâtisse près de la Taverne",d:"Cette bâtisse qui dispose d\'un unique étage, est très appréciée des buveurs de bière qui peinent à retrouver leur chemin après avoir séjourné trop longtemps à la Taverne. En effet, cette bâtisse n\'est qu\'à quelques pas de la Taverne."};
H.h[78] = {n:"Grande Maison de Maître",d:"Cette maison de maître, qui comporte trois pièces et un étage, est de toute évidence réservée aux personnes les plus riches d\'Amakna. Elle est cependant assez grande pour accueillir  plusieurs familles différentes à condition qu\'elles acceptent de vivre en communauté, un peu comme les fourmis."};
H.h[79] = {n:"Bâtisse de la Boulangerie",d:"Cette bâtisse qui comporte un étage, servait autrefois à une célèbre boulangère, de magasin pour vendre ses pains.  Aujourd\'hui, cette bâtisse a été réhabilitée, tout est  aux normes, et elle n\'a rien à envier aux autres maisons en terme de confort."};
H.h[80] = {n:"Chaumière de la  Boulangère",d:"Cette chaumière qui comporte un étage appartenait à une illustre boulangère dont le nom est encore inconnu. Cette chaumière est de loin la maison idéale pour tout Boulanger ou Boulangère qui se respecte."};
H.h[81] = {n:"Maison près du temple Xélor",d:"Cette petite maison ne comporte qu\'une seule pièce, mais a l\'avantage d\'être proche du temple Xélor et proche de la boulangerie."};
H.h[82] = {n:"Chaumière près du temple Xélor",d:"Cette chaumière qui comporte un étage, est située juste en face du temple Xélor, ce qui en fait une chaumière de choix pour les Xélors."};
H.h[83] = {n:"Chaumière du Tailleur",d:"Cette chaumière qui dispose d\'un étage appartenait au Tailleur le plus populaire d\'Amakna, Elvis Trosse qui était spécialisé dans la confection de pantalons bleus."};
H.h[84] = {n:"Maisonnette du Bowisse",d:"Cette splendide petite maison a été construite par Bowisse le cordonnier en personne, ce qui en fait un des bâtiments les plus populaires de tout Amakna. C\'est certainement un des lieux touristiques les plus visités juste après  la boulangerie de Xavier le Boulanger."};
H.h[85] = {n:"Chaumière des Bouftous",d:"Cette charmante chaumière comporte un étage. Elle a beau être souvent entourée de Bouftous affamés, le fait qu\'elle soit proche d\'un temple Kanojedo lui redonne tout de suite beaucoup de valeur auprès des aventuriers débutants."};
H.h[87] = {n:"Chaumière près du magasin Crâ",d:"Cette chaumière qui comprend un étage, servait de maison à Edridge Valling avant qu\'elle n\'aménage le grenier de son magasin pour pouvoir y vivre. Les murs sont encore recouverts d\'impacts de flèches, mais cela donne un certain charme à cette chaumière."};
H.h[88] = {n:"Maison près du magasin Crâ",d:"Cette petite maison qui ne comporte qu\'une seule pièce, vaut cependant très cher du fait de sa proximité avec le magasin d\'Edridge Valling. En effet, nombreux sont les courtisans d\'Edridge qui ont acheté cette maison pour la cotoyer plus souvent."};
H.h[89] = {n:"Chalet de la Fonderie",d:"Ce chalet en bois, comporte un étage et est situé à proximité de la fonderie. Les amateurs de métaux en fusion en auront pour leur compte avec cette maison. Attention cependant, la zone est parfois infestée de Bouftous."};
H.h[90] = {n:"Cahute du Marin",d:"Cette cahute qui ne comporte qu\'une seule pièce, est en revanche très bien  exposée, à l\'abri des vents dominants, elle profite tout de même des rayons de soleil matinaux. Et sentir les rayons du soleil vous caresser la peau au réveil, n\'a pas de prix, c\'est bien connu."};
H.h[91] = {n:"Cabane du Pêcheur",d:"Cette cabane qui ne comporte q\'une seule pièce, est un bâtiment classé bâtiment historique. C\'est ici que le célèbre Ménestrel Forgeur de Haches , Francisque Kabroule a écrit la majeure partie de ses chansons. "};
H.h[92] = {n:"Demeure du Pêcheur",d:"Cette demeure qui ne comporte qu\'une seule pièce, n\'a rien d\'original si ce n\'est que c\'est dans cette demeure, que le célèbre Bowisse a passé la plus grande partie de son enfance."};
H.h[93] = {n:"Maisonnette du Pêcheur",d:"Cette petite maison de pêcheur ne comporte qu\'une seule pièce et la façade aurait besoin d\'être refaite, mais c\'est aussi cela qui fait tout son charme."};
H.h[94] = {n:"Chaumière du Pêcheur",d:"Cette chaumière de pêcheur comporte un étage. Elle servait il y a longtemps d\'entrepôt à crabes."};
H.h[95] = {n:"Bâtisse Coque",d:"Cette ancienne bâtisse dispose d\'un étage. Elle appartenait au Captain Iglout, avant d\'obtenir un logement de fonction directement dans l\'enceinte de la prison."};
H.h[96] = {n:"Petite cahute près du port",d:"Cette petite cahute ne comporte qu\'une seule pièce, mais elle est contre la mer, il est donc possible d\'entendre le ressac de la mer  à longueur de journée pour se distraire."};
H.h[97] = {n:"Grande Maison Coque du port",d:"Cette grande maison au toit en coque de bateau, dispose de trois pièces, ce qui en fait une maison de Maître. Le fait qu\'elle soit au bord de l\'eau, permet de surcroît, de déverser ses ordures directement à la mer sans se soucier des jours de ramassage des ordures. Une certaine vision du confort en somme."};
H.h[109] = {n:"Maison du chemin de fer",d:"Cette petite maison ne comporte qu\'une seule pièce. Elle appartenait à un ancien chef de gare, Hassan Séhef, qui a quitté sa maison, une fois que la voie ferrée a été abandonnée."};
H.h[110] = {n:"Petite maison près des rails",d:"Cette petite maison ne comporte qu\'une seule pièce. \nElle appartenait à un ancien mineur qui allait au travail dans son petit wagon à minerai."};
H.h[111] = {n:"Bâtisse des Bouftous",d:"Cette maison au toit de chaume, comporte un étage plutôt bien aménagé, il faut le reconnaître. Son ancien propriétaire avait l\'habitude de nourrir les Bouftous qui passaient devant sa maison pour les engraisser pendant plusieurs mois, pour ensuite les égorger avec de vieilles dagues rouillées. Une sorte de rituel assez particulier."};
H.h[112] = {n:"Maisonnette des Bouftous",d:"Cette maisonnette ne comporte qu\'une unique pièce, et pourtant, elle est très convoitée, en effet , la présence de troupeaux de Bouftous sauvages la rend très intéressante pour les amateurs de Bouftous."};
H.h[113] = {n:"Maison des Champignons",d:"Cette petite maison, ne comporte qu\'une seule pièce. Elle appartenait avant à un vieil Alchimiste qui utilisait énormément de champignons pour ces potions aux effets trop souvent sous-estimés. Attention, les champignons qui poussent autour sont parfois dangereux, voire même agressifs."};
H.h[114] = {n:"Petite maison près de la place",d:"Cette petite maison de marin est située à un endroit très fréquenté par les touristes, ce qui peut poser quelques problèmes aux personnes qui recherchent la tranquillité, mais elle peut se révéler être une maison de choix, pour les personnes en manque d\'amis de passage."};
H.h[115] = {n:"Petite maison près de la place",d:"Cette petite maison de marin ne comporte qu\'une modeste pièce, elle conviendra parfaitement, aux personnes peu matérialistes qui savent se satisfaire de peu et ne recherchent pas en premier lieu le confort, lorsqu\'ils achètent une maison."};
H.h[116] = {n:"Petite maison près de la place",d:"Cette maison de marin ne comporte qu\'une unique pièce, mais elle a la réputation de faciliter la fécondité des couples qui y vivent, pour des raisons inconnues. Le lit unique et la petitesse de ce dernier jouent  de toute évidence un rôle important dans cette histoire."};
H.h[117] = {n:"Petite maison près de la place",d:"Cette petite maison de pêcheur, est bien située, elle est juste à côté de la fontaine du port. Il est cependant regrettable qu\'elle ne comporte qu\'une seule pièce, ce qui est compensé par son prix relativement abordable pour une maison de ce type."};
H.h[118] = {n:"Maison Coque près de la place",d:"Cette maison au toit en coque de bateau qui comporte un étage, est située autour de la place du port, juste en face de la fontaine, ce qui ne manquera pas d\'intéresser les marchands, qui n\'auront pas beaucoup de chemin à parcourir pour vendre à la criée sur le port."};
H.h[119] = {n:"Maison Coque du port",d:"Cette maison au toit en coque de bateau, comporte un étage qui offre une vue sur  le phare, ce qui ne manquera pas de plaire aux plus grands romantiques d\'Amakna qui aiment séduire en profitant de la lumière du phare pour faire des ombres chinoises explicites, et dieu sait qu\'ils sont nombreux."};
H.h[120] = {n:"Petite maison du port",d:"Cette petite maison, ne comporte qu\'une seule pièce, et pourtant, elle est si charmante, que peu de touristes résistent à l\'envie de l\'acheter. Le fait que les sanitaires donnent directement sur la mer y est de toute évidence pour beaucoup."};
H.h[122] = {n:"Maison du gardien de Kanojedo",d:"Cette maison ne comporte qu\'une seule pièce habitable (le grenier étant condamné depuis une invasion de termites mangeuses de tuiles). Située juste à côté d\'un temple Kanojedo, elle est en général réservée aux gardiens du temple. "};
H.h[123] = {n:"Petite maison près du pont",d:"Cette maison ne comporte qu\'une seule mais vaste pièce. Elle est située sur une île de taille respectable à l\'écart de toute civilisation tout en étant près d\'un pont, et n\'est qu\'à quelques pas d\'une fonderie. Les charges ne sont pas comprises."};
H.h[124] = {n:"Maison du Jardinier",d:"Cette petite maison, ne comporte qu\'une seule pièce. Elle dispose en revanche d\'un petit potager, et est proche de la côte, ce qui en fait la maison rêvée de tous les paysans peu fortunés qui aiment prendre des vacances dans un endroit tranquille."};
H.h[125] = {n:"Chaumière près du lac",d:"Cette chaumière comporte un étage classique, ainsi  qu\'une petite dépendance à côté, à acheter séparément. Ce qui vous permettra de loger facilement un gardien ou vos servants."};
H.h[126] = {n:"Maisonnette près du lac",d:"Cette maisonnette ne comporte qu\'une seule pièce, mais elle est à la fois proche du lac et proche de la côte, ce qui ravira les amateurs de pêche en eau douce et en eau salée."};
H.h[127] = {n:"Petite maison près du lac",d:"Cette petite maison d\'apparence modeste, ne comporte qu\'une seule pièce, mais cette dernière est spacieuse et bien aménagée. Les amateurs de pêche en eau douce et de baignades, apprécieront  le fait qu\'elle soit proche du lac."};
H.h[128] = {n:"Chaumière avec allée",d:"Cette chaumière comporte un étage, mais les deux pièces sont très vastes, suffisamment pour organiser d\'importantes parties de Tragic The Gardening.  L\'entretien des arbres de l\'allée est laissé à la charge du propriétaire."};
H.h[129] = {n:"Maison de MAX-LoL",d:"Cette petite maison ne comporte qu\'un seul étage, mais elle a l\'avantage d\'être située sur une petite île, ce qui la rend facilement défendable en cas d\'attaque de Roublards par exemple."};
H.h[130] = {n:"Maison Coque de Bateau",d:"Cette maison à un étage, dispose en guise de toiture, d\'une vieille coque de bateau échoué, ce qui peut toujours se révéler utile en cas d\'importantes montées des eaux ou de marées spectaculaires."};
H.h[131] = {n:"Petite maison de marin",d:"Cette petite maison, comporte un étage. A la fois à proximité du port et d\'un bras de mer vaseux, elle saura séduire les éleveurs de crabes qui savent tolérer la présence de voisins."};
H.h[132] = {n:"Maisonnette de Pêcheur",d:"Cette  maisonnette de pêcheur, ne comporte qu\'une seule pièce et au fil du temps, la mer s\'en est éloignée, ce qui tout de suite a rendu cette maison moins intéressante. Les personnes un peu moins riches que les autres sauront tout de même s\'en contenter, le temps de faire quelques économies."};
H.h[133] = {n:"Maison au toit de coque",d:"Cette maison très originale dispose d\'une coque de bateau en guise de toiture, ce qui évitera à son propriétaire de changer les tuiles de la toiture après chaque tempête. Cette maison dispose de deux étages correctement aménagés."};
H.h[134] = {n:"Petite maison de la rivière",d:"Cette petite maison ne comporte qu\'une modeste pièce, ce qui la destine plutôt aux aventuriers solitaires ou aux colocataires de très petite taille."};
H.h[135] = {n:"Petite maison du Pêcheur",d:"Cette toute petite maison de pêcheur qui ne comporte qu\'une seule pièce, est très convoitée par les amateurs de poissons, qui peuvent à loisir pêcher tout en restant chez eux."};
H.h[136] = {n:"Maison des Bouftous",d:"Cette maison comporte un étage plutôt vaste, suffisamment grand pour acceuillir les réceptions de l\'Ambassadeur. La charrette de foin est offerte à l\'achat de cette maison. Attention cependant, l\'ancien propriétaire élevait des Bouftous, et ces derniers ont été libérés autour de cette maison."};
H.h[137] = {n:"Chaumière près du Merisier",d:"Cette maison dispose d\'un étage, et d\'un magnifique escalier en bois de chêne. Son toit de chaume et le merisier qui pousse en face de la porte, en font une maison très rustique, mais très appréciée des personnes qui aiment se démarquer des autres."};
H.h[138] = {n:"Petite maison près du Merisier",d:"Cette maison n\'est constituée que d\'une seule pièce, mais cette dernière est vaste. Un magnifique merisier procure de l\'ombre en été aux propriétaires de cette charmante demeure."};
H.h[139] = {n:"Maison de la scierie",d:"Cette petite maison dispose tout de même d\'un étage. Sa proximité avec la scierie, en fait la maison idéale pour le propriétaire de la scierie."};
H.h[140] = {n:"Chaumière de la scierie",d:"Cette petite maison dispose d\'un étage classique, mais est située près de la scierie, ce qui ne manquera pas de plaire aux Bûcherons, qui détestent  perdre du temps pour aller jusqu\'à leur lieu de travail."};
H.h[141] = {n:"Maison d\'Aria Knofob ",d:"Maison de PNJ."};
H.h[142] = {n:"Maison montagnarde",d:"Cette maison ne comporte qu\'une seule pièce, mais cette dernière est spacieuse et bien aménagée."};
H.h[143] = {n:"Grande Maison Coque du port",d:"Cette grande maison au toit en coque de bateau, dispose de deux étages, ce qui en fait une maison de Maître. Sa proximité avec le port en fait la demeure idéale pour ceux qui aiment voyager. En revanche, le grenier est lugubre et regorge de toiles d\'araignée."};
H.h[144] = {n:"Maison Sufokia",d:"Noble habitat, vue sur mer et haut confort intérieur. Cette maison saura vous séduire par la richesse de son ameublement."};
H.h[145] = {n:"Grande Maison Sufokia",d:"Une maison isolée dont l\'architecture étonne par sa luminosité et son confort. Son étage possède un magnifique jardin intérieur, fort appréciable pour se détendre bercé par le son de l\'océan."};
