Q.s[784] = {n:"A coeur vaillant, rien d\'impossible.",d:"Vous devez trouver un membre de la famille Terra et l\'emmener auprès de Jerhyn Gholein. Setag, le maître de classe Enutrof, pourra sans doute vous aider.",r:[200000,null,null,null,null,null]};
Q.s[956] = {n:"Ordre ou contrordre ?",d:"Le plan d\'attaque actuel n\'étant pas confirmé, vous devez trouver sa confirmation ou ses modifications auprès de l\'officier Kapi Taigne et rapporter ces informations à Amayiro.",r:[164000,null,null,null,null,null]};
Q.s[510] = {n:"Plan d\'attaque.",d:"Amayiro craint un assaut imminent des Brâkmariens. Vous devez trouver leur plan d\'attaque pour permettre à Amayiro de leur préparer un comité d\'accueil digne de ce nom.",r:[null,null,null,null,null,null]};
Q.s[358] = {n:"Entraînement",d:"Il faut faire perdre toute sa paille à un épouvantail animé.",r:[25,null,null,null,null,null]};
Q.s[755] = {n:"Du bois pour Oto.",d:"Oto veut 10 écorces d\'abraknyde pour faire du bois de chauffage.",r:[16300,null,null,null,null,null]};
Q.s[946] = {n:"Engagez-vous, qu\'il disait.",d:"Snori Nairb vous a fait entrer illégalement dans la milice de Bonta. Pour officialiser la chose, vous devez rendre visite à Amayiro.",r:[null,null,null,null,null,null]};
Q.s[945] = {n:"Engagez-vous, qu\'il disait.",d:"Snori Nairb vous a fait entrer illégalement dans la milice de Brâkmar. Pour officialiser la chose, vous devez rendre visite à Oto MUstam.",r:[null,null,null,null,null,null]};
