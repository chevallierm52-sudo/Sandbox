Q.s[704] = {n:"A la rescousse de Lyeno.",d:"Vous devez sauver le colonel Lyeno : il a disparu dans la partie Est de la forêt des Abraknydes.",r:[12800,null,null,null,null,null]};
Q.s[722] = {n:"Une autre demande du cuistot.",d:"Le cuisinier de la milice a de nouveau demandé vos services.",r:[31000,null,null,null,null,null]};
Q.s[1088] = {n:"Usine à jouets.",d:"D\'abominables créatures ont cambriolé l\'entrepôt du Père Nowel. Vous devez récupérer les caisses de cadeaux qu\'elles ont volées, avec ou sans leur consentement, et les apporter à Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
