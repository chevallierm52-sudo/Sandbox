Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[519] = {n:"L\'espion blessé.",d:"Vous devez rattraper l\'espion blessé qui fait route vers Brâkmar et lui reprendre les documents. \nCependant, vous avez trouvé une lettre dans votre sac...",r:[205000,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[1192] = {n:"Ginette, l\'imperfection au féminin.",d:"Ginette a été enlevée par un kaniglou. Groméo a tenté de la sauver, en vain. Il vous supplie de la délivrer.",r:[804000,25000,[[11196,2]],null,null,null]};
Q.s[1191] = {n:"Réconciliation houleuse.",d:"Les Capoués semblent n\'avoir rien à se reprocher concernant le vol de céréales, mais quelque chose cloche. Reste à découvrir quoi.",r:[null,null,null,null,null,null]};
Q.s[1190] = {n:"La vérité sort aussi de la bouche des adultes.",d:"Ginette a un plan pour découvrir ce qui s\'est réellement passé concernant le vol et c\'est vous qui allez le découvrir.",r:[null,null,null,null,null,null]};
Q.s[1189] = {n:"Amour impossible.",d:"Groméo et Ginette ne peuvent pas se marier à cause d\'un différent opposant leurs familles. Ils vous implorent de trouver une solution.",r:[null,null,null,null,null,null]};
Q.s[1184] = {n:"Extrait d\'une inspection.",d:"Larry Tutthe est débordé et a besoin d\'un coup de main.",r:[null,null,null,null,null,null]};
Q.s[1183] = {n:"Mets tes bottes.",d:"Larry Tutthe a besoin d\'un nouvel assistant et il vous a chargé du recrutement.",r:[null,null,null,null,null,null]};
Q.s[488] = {n:"Retour vers Oto",d:"Vous vous êtes occupé du tacticien, il faut retourner voir Oto.",r:[null,null,null,null,null,null]};
Q.s[907] = {n:"Dompteur de bêtes, mais aussi d\'animaux.",d:"Oto Mustam veut connaître le secret du domptage des crocs glands. Vous devez retourner à la bibliothèque de Bonta pour y trouver des indices.",r:[134000,null,null,null,null,null]};
Q.s[1021] = {n:"Abattre le tacticien.",d:"Vous avez décidé de recourir à la solution la plus extrême. La plus Brâkmarienne en somme.",r:[null,null,null,null,null,null]};
Q.s[1177] = {n:"Escorter le blessé.",d:"Vous devez escorter un chasseur blessé jusqu\'à la bourgade de Frigost, pour qu\'il soit pris en charge par le médecin Albert Paisse.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1178] = {n:"Escorter le pas doué.",d:"Vous devez escorter un chasseur blessé jusqu\'à la bourgade de Frigost, pour qu\'il soit pris en charge par le médecin Albert Paisse.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1179] = {n:"Escorter le mauvais chasseur.",d:"Vous devez escorter un chasseur blessé jusqu\'à la bourgade de Frigost, pour qu\'il soit pris en charge par le médecin Albert Paisse.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1180] = {n:"A vive allure.",d:"Pendant que Djauns surveille son trésor, vous devez récupérer un attelage de chienchiens des neiges et le lui apporter. Le temps vous est compté.",r:[null,25000,[[11196,1]],null,null,null]};
Q.s[1186] = {n:"Un être s\'éveille.",d:"Un alchimiste pourra vous aider à mieux cerner l\'identité de la créature trouvée dans les larmes d\'Ouronigride.",r:[null,null,null,null,null,null]};
Q.s[1185] = {n:"L\'eau d\'Ogivol Victor est une chance.",d:"Ogivol Victor a besoin de votre aide pour prélever de l\'eau minérale afin de l\'analyser et de la rendre potable.",r:[null,null,null,null,null,null]};
Q.s[1181] = {n:"YeCh\'Ti Bodoudou.",d:"Les Frigostiens ont monté une expédition punitive pour se débarrasser du YeCh\'Ti. Ils ont besoin de Fourrures intactes de Givrefoux pour tromper sa vigilance.",r:[null,null,null,null,null,null]};
Q.s[1182] = {n:"Concours d\'affreux bonmonstres.",d:"le petit Nico et ses amis font un concours dont vous êtes le jury. Il vous faut choisir lequel des bonmonstres de neige est le plus affreux.",r:[null,null,null,null,null,null]};
Q.s[1188] = {n:"Meurtre de sang-froid.",d:"L\'esprit Zonier veut se venger de l\'agriculteur qui l\'a assassiné. Il vous a demandé d\'être son bras vengeur.",r:[null,null,null,null,null,null]};
Q.s[1187] = {n:"Givrefoux givrés.",d:"Des givrefoux complètement givrés s\'en prennent aux voyageurs. Vous devez les vaincre.",r:[null,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[409] = {n:"Qui m\'aime me suive!",d:"Le pwince d\'Wa vous a demandé de lui constituer une suite digne de sa stature... Vu ses prouesses au combat, son régime particulier et son sens de l\'esthétisme, il faut bien quatre personnes pour l\'assister.",r:[45000,null,null,null,null,null]};
Q.s[693] = {n:"Apporter la poudre.",d:"Vous devez apporter dix pods de poudre à canon à Amayiro. Vous pourrez les acheter à Moub Reicifitra, dans Bonta.",r:[5800,null,null,null,null,null]};
Q.s[701] = {n:"L\'invocation inconnue.",d:"Amayiro vous a demandé de vous renseigner auprès de Zeurg (maître de classe Osamodas) à propos d\'une invocation inconnue employée par Brâkmar.",r:[10700,null,null,null,null,null]};
Q.s[687] = {n:"Trouver la faille.",d:"Vous devez trouver quelque chose d\'intéressant sur les engrenages de la grande porte de Brâkmar.",r:[3000,null,null,null,null,null]};
Q.s[509] = {n:"Vol dans un nid de coucou.",d:"Amayiro veut tendre une embuscade aux Brâkmariens pour tester le nouveau matériel et la cohésion des miliciens.",r:[152000,null,null,null,null,null]};
Q.s[494] = {n:"Interception brutale.",d:"Vous devez intercepter un convoi d\'armes qui va passer par l\'orée de la Forêt des Abraknydes pour rejoindre le Village des Brigandins. Des renforts seront les bienvenus.",r:[158000,null,null,null,null,null]};
Q.s[477] = {n:"Le vieux bijoutier.",d:"Selon le chef des voleurs, le bijoutier de Brâkmar - Milone Corichel - aurait des informations.",r:[100000,null,null,null,null,null]};
Q.s[476] = {n:"Bishom Pot, le retour.",d:"Amayiro soupçonne Brâkmar d\'être à l\'origine des problèmes de Bonta. Bishom Pot, espion milicien à Brâkmar, a peut-être appris quelque chose.",r:[null,null,null,null,null,null]};
Q.s[211] = {n:"Souterrain rigoureux",d:"Seul huit courageux seront capables de venir à bout de ce souterrain !",r:[5000,1000,null,null,null,null]};
Q.s[81] = {n:"Souterrain mystérieux",d:"Une dalle perchée en haut d\'une montagne et une porte derobée... il va falloir trouver des volontaires pour arriver au bout de cette galerie...",r:[2500,null,null,null,null,null]};
Q.s[74] = {n:"Le sous-sol de la Bibliothèque",d:"Comme tous les sous-sols de bibliothèque, on y trouve toute sorte de livres et des toiles d\'araknes... mais dans celle-ci, il y a comme une atmosphère mystérieuse qui y rôde...",r:[2500,null,null,null,null,null]};
Q.s[80] = {n:"Souterrain ténébreux",d:"Une porte dérobée dans la montagne donne accès à un souterrain, encore faut il trouver comment...",r:[2500,null,null,null,null,null]};
Q.s[163] = {n:"Souterrain impénétrable",d:"Gare au Dragoeuf ! Il va falloir traverser leur territoire pour accèder à cette nouvelle grotte...",r:[2500,null,null,null,null,null]};
Q.s[164] = {n:"Souterrain hasardeux",d:"Ce souterrain risque de vous faire perdre patience!",r:[2500,null,null,null,null,null]};
Q.s[684] = {n:"Visite chez le tavernier.",d:"Vous devez récupérer la carte d\'Amayiro et une bière auprès du tavernier Feubuk.",r:[1500,null,null,null,null,null]};
Q.s[703] = {n:"Patate chaude.",d:"Vous devez peler 200 pods de patates et les amener au cuisinier de la milice.",r:[12100,null,null,null,null,null]};
Q.s[709] = {n:"Un champo pour Amayiro.",d:"Amayiro vous a demandé de lui apporter un Champo ordinaire. Vous en trouverez sur les Maîtres Bolets.",r:[14200,null,null,null,null,null]};
Q.s[327] = {n:"Pinta Gone veut lire la recette",d:"Il a déjà acheté tout le matériel pour sa brasserie de bière. Il ne lui manque que la recette.",r:[7500,5000,[[8145,10]],null,null,null]};
Q.s[319] = {n:"Trouver la recette de la bière Bwork",d:"Pinta Gone recherche la recette de la fameuse bière Bwork. Il pense qu\'elle se trouve dans une salle étrange dans le territoire Bwork.",r:[2500,null,null,null,null,null]};
Q.s[523] = {n:"Assaut sur le château du Wa.",d:"Vous devez récupérer le bandana de Turorte, qui est détenu par les Wobots dans le donjon du Wa Wabbit.",r:[null,null,null,null,null,null]};
Q.s[937] = {n:"Couture à haut risque.",d:"Il faut trouver un moyen de rendre au Bandana Troué son éclat et son état d\'antan. Un Tailleur pourra vous aider.",r:[198000,null,null,null,null,null]};
Q.s[521] = {n:"Récupération mouvementée.",d:"Vous avez trouvé l\'espion à temps mais les Brâkmariens ne comptent pas vous laisser les documents. Il vous faut les amener à Amayiro coûte que coûte.",r:[null,null,null,null,null,null]};
Q.s[952] = {n:"Petite blague entre ennemis.",d:"Les Brâkmariens devaient remettre les documents à leur supérieur. Vous en avez rédigés des faux pour les remplacer et entraîner vos ennemis sur une fausse piste.",r:[212000,null,null,null,null,null]};
Q.s[520] = {n:"Course contre la montre.",d:"Un espion bontarien est en train de fuir Brâkmar par l\'Est de la route. Il faut le retrouver et l\'escorter. Le temps vous est compté !",r:[null,null,null,null,null,null]};
Q.s[920] = {n:"Rapport protégé.",d:"Un rapport vous accablant de reproches serait actuellement rangé dans la Tour des Ordres de Bonta. Vous devez impérativement mettre la main dessus pour prouver votre innocence.",r:[null,null,null,null,null,null]};
Q.s[472] = {n:"Pour vivre, il faut des vivres.",d:"Sous la pression du conseil, Amayiro vous a retiré l\'enquête et vous êtes désormais de corvée de ravitaillement.",r:[null,null,null,null,null,null]};
Q.s[921] = {n:"Vol à la tour.",d:"Trouvez un complice pour détourner l\'attention du garde pendant que vous effectuerez le larcin.",r:[85000,null,null,null,null,null]};
Q.s[1087] = {n:"Usine à jouets.",d:"D\'abominables créatures ont cambriolé l\'entrepôt du Père Nowel. Vous devez récupérer les caisses de cadeaux qu\'elles ont volées, avec ou sans leur consentement, et les apporter à Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[720] = {n:"Le tabi de Grace.",d:"Grace Malcean, dans Bonta, a des problèmes avec son tabi.",r:[25000,null,null,null,null,null]};
Q.s[919] = {n:"Un Eca ça flippe énormément.",d:"Vous pouvez à présent fabriquer des clefs et inspecter le repaire des bandits à la recherche d\'indices. Une corde d\'escalade ne sera pas de trop pour descendre dans le repaire.",r:[80000,null,null,null,null,null]};
Q.s[916] = {n:"Minou minou.",d:"Vous devez mettre la main sur la clef du repaire, ce qui induit forcément de mettre la main sur un bandit la possédant. L\'ex-amant d\'Hersa devrait faire l\'affaire.",r:[null,null,null,null,null,null]};
Q.s[917] = {n:"Clef, sans molette.",d:"Vous devez faire des copies de la clef du repaire des bandits avant de pouvoir y pénétrer à plusieurs et d\'y récupérer tout document relatif à l\'enquête.",r:[null,null,null,null,null,null]};
Q.s[715] = {n:"Activités illicites.",d:"Des évènements louches se trament dans le quartier des boulangers. Amayiro vous a demandé d\'enquêter.",r:[17000,null,null,null,null,null]};
Q.s[689] = {n:"Entraînement au bâton.",d:"Amayiro vous a demandé vingt bâtons de boisaille pour entraîner ses troupes.",r:[4000,null,null,null,null,null]};
Q.s[718] = {n:"Une requête de Danathor.",d:"Danathor vous a envoyé une lettre pour vous demander assistance.",r:[11500,null,null,null,null,null]};
Q.s[719] = {n:"Larry Poller.",d:"Larry Poller a demandé votre aide. Il se trouve près de la tour de Bonta.",r:[11500,null,null,null,null,null]};
Q.s[1035] = {n:"Percer le secret de la statue.",d:"Percimol a enfoui son secret au pied de la statue. Penchez-vous pour le ramasser.",r:[null,null,null,null,null,null]};
Q.s[751] = {n:"Aider Raaga.",d:"Trouvez Raaga dans les mines du nord et demandez-lui son rapport.",r:[13500,null,null,null,null,null]};
Q.s[738] = {n:"Le rapport de l\'espion.",d:"Oto vous a demandé de trouver l\'espion Finche Aticus, à Bonta, et de lui demander son rapport.",r:[5200,null,null,null,null,null]};
Q.s[743] = {n:"A la recherche de poison magique.",d:"Vous devez trouver quelqu\'un dans Brâkmar qui sache préparer des poisons magiques.",r:[8200,null,null,null,null,null]};
Q.s[335] = {n:"Au travail",d:"Allez demander au contremaître ce que vous devez faire.",r:[250,250,null,null,null,null]};
Q.s[382] = {n:"Au travail",d:"Allez demander au contremaître ce que vous devez faire.",r:[250,250,null,null,null,null]};
