Q.s[365] = {n:"La clef entre les dents",d:"Si tu veux la clef du donjon, il faut battre un gros bouftou hargneux.",r:[55,null,[[8545,1]],null,null,null]};
Q.s[508] = {n:"Sadikoi ?",d:"Danathor a encore besoin de vos services pour mettre la main sur le grimoire du bwork mage des cavernes réputé pour avoir lancé l\'envoûtement de la Grafioze.",r:[null,null,null,null,null,null]};
Q.s[933] = {n:"Sadidarne.",d:"Touh Flowa vous a indiqué où se trouve l\'entrée de la prison végétale. Comme il avait l\'esprit quelque peu embrumé, il faut espérer qu\'il n\'a rien omis de vous dire.",r:[158000,null,null,null,null,null]};
Q.s[732] = {n:"Une clé sur un écureuil.",d:"Vous devez retrouver un écureuil dans Brâkmar : il a volé une clé importante. Rapportez-la à Oto.",r:[2000,null,null,null,null,null]};
Q.s[731] = {n:"Amener les caisses.",d:"Il faut amener à Oto les caisses d\'armes blanches qui se trouvent dans la tour de Brâkmar.",r:[1500,null,null,null,null,null]};
Q.s[457] = {n:"Des getas pour Milone.",d:"Pour vous punir de ne pas avoir pu empêcher les voleurs de dérober le bijou, Milone vous a demandé de lui amener des Getas Feudala.",r:[90000,null,null,null,null,null]};
Q.s[730] = {n:"Redésosser Mak Gahan.",d:"Mak Gahan le Chafer veut sa revanche.",r:[1000,null,null,null,null,null]};
Q.s[502] = {n:"Lenglad en prend pour son grade.",d:"William Lenglad a de nouveau besoin d\'une leçon.",r:[null,null,null,null,null,null]};
Q.s[929] = {n:"Tac et Tic.",d:"Vous devez trouver un tacticien et le convaincre de rejoindre les rangs de Bonta.",r:[134000,null,null,null,null,null]};
Q.s[481] = {n:"Kaffra Kyper.",d:"Oto Mustam veut avoir l\'avis de Kaffra Kyper pour son offensive contre Bonta.",r:[110000,null,null,null,null,null]};
Q.s[480] = {n:"Retour vers Oto.",d:"La bataille est terminée, Oto Mustam attend votre rapport.",r:[null,null,null,null,null,null]};
Q.s[479] = {n:"Escarmouche.",d:"Un combat a actuellement lieu près de la Baie de Cania, sur la route à mi-chemin entre Bonta et Brâkmar. Il faut le rejoindre et aider Brâkmar à vaincre !",r:[null,null,null,null,null,null]};
Q.s[735] = {n:"Entraînement au marteau.",d:"Oto a besoin de dix Marteaux de Boisaille pour l\'entraînement de ses troupes.",r:[3500,null,null,null,null,null]};
Q.s[896] = {n:"Le cristal sombre.",d:"Vous devez prendre le passage secret dans l\'atelier des alchimistes avec des maîtres dans leur métier. Il vous faut en plus une Potion de Rafale, une Harmonie et une Kobalite.",r:[85000,null,null,null,null,null]};
Q.s[894] = {n:"Le crime ne paie pas.",d:"Le message a été envoyé au Captain Starky. En attendant sa réponse, vous devriez aller voir si Sabine s\'est tenue tranquille.",r:[null,null,null,null,null,null]};
Q.s[893] = {n:"La rançon.",d:"Sabine étant sous bonne garde, vous devez trouver un moyen de contacter le Captain Starky pour exiger un Cristal de Kain Dharyn comme rançon.",r:[null,null,null,null,null,null]};
Q.s[953] = {n:"Conduite en prison.",d:"Vous devez emmener Sabine de force devant Oto Mustam. Vous devez faire attention à ce qu\'elle ne s\'échappe pas à la première occasion.",r:[null,null,null,null,null,null]};
Q.s[455] = {n:"L\'enlèvement de Sabine.",d:"Vous devez enlever Sabine et la mettre dans un endroit d\'où elle ne pourra pas s\'échapper.",r:[null,null,null,null,null,null]};
Q.s[895] = {n:"Le crime va payer, foi de Brâkmarien.",d:"Les Bontariens ont essayé de délivrer Sabine. Ca ne se passera pas comme ça ! Vous devez leur montrer qui commande.",r:[null,null,null,null,null,null]};
Q.s[754] = {n:"Défier Puja.",d:"Vous êtes censé défier Puja Mustam, le fils d\'Oto, et perdre. Mais vous n\'allez quand même pas vous laisser tuer par ce mioche ?",r:[15600,null,null,null,null,null]};
Q.s[729] = {n:"Un nouveau dentier.",d:"Vous devez arracher des dents de Bouftou pour confectionner un dentier. Vous devez en amener exactement assez pour faire un dentier d\'humain... enfin, d\'humanoïde.",r:[500,null,null,null,null,null]};
Q.s[749] = {n:"Le grand épluchage.",d:"Vous devez éplucher des patates pour le dîner. La cuisine se trouve en bas de la milice.",r:[12100,null,null,null,null,null]};
Q.s[1062] = {n:"Vaincre le Manitou Zoth.",d:"Vous devez vaincre le Manitou Zoth et apporter une preuve de votre victoire à Bob l\'Enutrof.",r:[null,null,[[10899,1]],null,null,null]};
Q.s[515] = {n:"Amadoudoudou c\'est bon.",d:"Il faut trouver un moyen d\'amadouer Turorte pour mettre la main sur la Corne Edfrit. Les résidents de l\'île de Moon peuvent vous aider.",r:[184000,null,null,null,null,null]};
Q.s[489] = {n:"Retour vers Oto.",d:"Le tacticien ayant quitté la ville, vous pouvez raisonnablement laisser penser à Oto Mustam que vous l\'avez tué.",r:[null,null,null,null,null,null]};
Q.s[908] = {n:"Dompteur de bêtes, mais aussi d\'animaux.",d:"Oto Mustam veut connaître le secret du domptage des crocs glands. Vous devez retourner à la bibliothèque de Bonta pour y trouver des indices.",r:[134000,null,null,null,null,null]};
Q.s[899] = {n:"Les andouillettes d\'une andouille.",d:"Oto Mustam étant persuadé que vous cherchez à le tromper, il faut impérativement retrouver le joyau avant d\'être transformé en andouillettes.",r:[null,null,null,null,null,null]};
Q.s[460] = {n:"Victoire !",d:"Xephirès a accepté les conditions et est prêt à trahir Bonta le moment venu. Oto sera satisfait d\'apprendre la nouvelle.",r:[null,null,null,null,null,null]};
Q.s[459] = {n:"L\'entretien.",d:"Tout est prêt, il ne reste plus qu\'à retrouver Xephirès à la Taverne du Pandawa Ivre pour lui remettre la lettre et fixer un rendez-vous pour sa réponse.",r:[null,null,null,null,null,null]};
Q.s[900] = {n:"Vengeance, mouahaha.",d:"Le repaire des bandits est piégé. Il vous faut trouver de l\'aide pour vous accompagner et vous aider à désamorcer les pièges protégeant leur cachette.",r:[100000,null,null,null,null,null]};
Q.s[497] = {n:"Au rapport.",d:"La bataille est terminée, Jerhyn Gholein attend votre rapport.",r:[110000,null,null,null,null,null]};
Q.s[496] = {n:"Escarmouche.",d:"Un combat a actuellement lieu près de la Baie de Cania, sur la route à mi-chemin entre Bonta et Brâkmar. Il faut le rejoindre et aider Bonta à vaincre !",r:[null,null,null,null,null,null]};
Q.s[727] = {n:"Offre d\'emploi.",d:"Oto Mustam veut savoir qui a assassiné le patron de la Taverne du Chabrulé.",r:[125,null,null,null,null,null]};
Q.s[742] = {n:"La bouillie de blops.",d:"Il faut apporter de la bouillie de blop concassés à Oto. Il peut vous donner la recette.",r:[7600,null,null,null,null,null]};
Q.s[745] = {n:"Trouver le testament.",d:"Vous devez trouver le testament d\'Oto dans la tombe de son père, dans le cimetière - elle se reconnait par la gerbe de fleurs qui l\'entoure. Vous devez être transformé en esprit pour y entrer.",r:[9400,null,null,null,null,null]};
Q.s[495] = {n:"Pirate à quai.",d:"Grâce à Xephirès, vous savez que le navire bontarien La Descemer transporte de nombreux objets magiques dans ses cales. Vous devez le trouver et faire main-basse sur sa marchandise.",r:[164000,null,null,null,null,null]};
Q.s[926] = {n:"Liquidation totale.",d:"Une Sram doit de l\'argent à Oto Mustam. Comme elle ne l\'a pas remboursé, il a décidé de l\'éliminer à titre d\'exemple. Vous pourrez probablement la trouver dans une salle de jeux clandestine.",r:[233000,null,null,null,null,null]};
Q.s[544] = {n:"Equiper les guerriers.",d:"Oto craint une attaque de Bonta et vous a demandé d\'équiper certains des guerriers de Brâkmar avec de l\'équipement spécial.",r:[null,null,null,null,null,null]};
Q.s[927] = {n:"Copinage.",d:"Kosuke Ichazum avait raison : Latem Sa a obtenu le contrat pour équiper la milice de Bonta par copinage et non pour ses compétences de forgeron.",r:[116000,null,null,null,null,null]};
Q.s[498] = {n:"Forger avec ses pieds.",d:"Vous devez enquêter sur le fournisseur de l\'équipement de la milice et mettre à l\'épreuve le forgeron qui le fabrique.",r:[null,null,null,null,null,null]};
Q.s[902] = {n:"Le puits du fou.",d:"Vous devez trouver l\'emplacement du Puits des Âmes Souillées afin de révéler le plein potentiel des pierres de souillure. Le maître de l\'Ordre de l\'Esprit Malsain, Divad Dleifrepok, pourra vous aider.",r:[null,null,null,null,null,null]};
Q.s[901] = {n:"Alchimie malfaisante.",d:"Vous devez vous procurer des pierres de souillures. Seuls les mineurs sont capables d\'en fabriquer à partir des créations brutes d\'un alchimiste déjanté.",r:[null,null,null,null,null,null]};
Q.s[903] = {n:"Sept âmes sinon rien.",d:"Vous devez capturer les âmes de sept bandits et les amener au Puits des Âmes Souillées pour les asservir. Vous aurez besoin de Brâkmariens vils au point de pouvoir se choisir une spécialité.",r:[105000,null,null,null,null,null]};
Q.s[533] = {n:"Retrouver l\'espion.",d:"Vous devez rapidement retrouver l\'espion blessé sur la route menant à Bonta, et récupérer les documents. L\'espion doit être plus proche de Bonta que de Brâkmar.",r:[null,null,null,null,null,null]};
Q.s[463] = {n:"Tournée des tavernes.",d:"Le bandit à qui appartenait l\'épée est probablement passé dans l\'une des tavernes. Par conséquent, les taverniers doivent savoir quelque chose.",r:[65000,null,null,null,null,null]};
Q.s[733] = {n:"Enquête importante.",d:"Faites le tour des gardes de Brâkmar et réalisez un compte-rendu des gardes qui ne prennent pas de pause.",r:[2500,null,null,null,null,null]};
Q.s[909] = {n:"Dompteur de bêtes, mais aussi d\'animaux.",d:"Oto Mustam veut connaître le secret du domptage des crocs glands. Vous devez retourner à la bibliothèque de Bonta pour y trouver des indices.",r:[134000,null,null,null,null,null]};
Q.s[490] = {n:"Jusqu\'à Brâkmar.",d:"Le tacticien a accepté de vous suivre jusqu\'à Brâkmar.",r:[null,null,null,null,null,null]};
Q.s[757] = {n:"Un autre rapport.",d:"Vous devez trouver Trojen Tihpor vers les remparts de Bonta et récupérer son rapport.",r:[19000,null,null,null,null,null]};
