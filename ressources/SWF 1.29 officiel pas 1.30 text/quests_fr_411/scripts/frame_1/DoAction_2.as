Q.s[979] = {n:"Vaincre le dopeul.",d:"En cas de victoire contre le dopeul, le maître des combats vous récompensera.",r:[null,null,null,null,null,null]};
Q.s[503] = {n:"Matières premières.",d:"Nara le forgeron, dans la mine du territoire Porcos, a besoin de matières premières pour forger un équipement standard destiné aux miliciens de Bonta.",r:[140000,null,null,null,null,null]};
