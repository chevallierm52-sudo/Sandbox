Q.s[536] = {n:"Attraper l\'espion.",d:"Un espion bontarien s\'est infiltré dans la tour et a volé des documents. Il faut utiliser un Zaap pour l\'intercepter, à l\'Est de la route menant à Bonta, du côté de Brâkmar.",r:[212000,null,null,null,null,null]};
Q.s[387] = {n:"Ca roule pour les Roublards.",d:"Vous avez maintenant une idée très précise de la cachette des Roublards. Reste à vérifier vos informations.",r:[2000,null,null,null,null,null]};
Q.s[386] = {n:"La crypte, c\'est chic.",d:"Vous devez visiter les cinq cryptes du cimetière d\'Amakna.",r:[3000,null,null,null,null,null]};
Q.s[388] = {n:"Pour quelques Roublards de plus...",d:"Vous devez vous inflitrer chez les Roublards et aller parler à Vil Smisse.",r:[15000,null,null,null,null,null]};
Q.s[482] = {n:"En territoire ennemi.",d:"Vous devez vous infiltrer dans le bâtiment de la milice de Bonta et découvrir où vos ennemis entreposent leurs armes.",r:[null,null,null,null,null,null]};
Q.s[483] = {n:"Une bien belle grosse caisse.",d:"Vous devez tromper la vigilance du gardien pour lui prendre les clefs de l\'entrepôt. Il vous faut ensuite dérober une caisse d\'équipement et l\'apporter à Mulic Bere pour expertise.",r:[116000,null,null,null,null,null]};
Q.s[744] = {n:"Les capes brâkmariennes.",d:"Oto vous a demandé cinq capes brâkmariennes. Il peut vous indiquer comment les fabriquer.",r:[8800,null,null,null,null,null]};
Q.s[350] = {n:"Histoire d\'eau",d:"Tenva Lakruche a besoin d\'eau pour ses nymphettes.",r:[75,25,null,null,null,null]};
Q.s[529] = {n:"Recherches pour une corne.",d:"Le soi-disant gardien de la Corne Edfrit serait dans la jungle profonde de l\'île de Moon. D\'après les rumeurs, vous devez porter une Fourbacoiffe et avoir du Gloutoburg pour qu\'il apparaisse.",r:[177000,null,null,null,null,null]};
Q.s[699] = {n:"Les informations du capitaine.",d:"Vous devez trouver un moyen pour entrer en communication avec feu le capitaine Tsog, afin d\'obtenir les informations qu\'il doit faire passer. Le capitaine Alrok connait l\'emplacement de la tombe de Tsog.",r:[9400,null,null,null,null,null]};
Q.s[710] = {n:"Trouver le coupable.",d:"Trouvez l\'assassin de Rimaraf et amenez le formulaire rempli à Amayiro.",r:[14900,null,null,null,null,null]};
Q.s[711] = {n:"Fausses preuves.",d:"Trouvez un moyen de berner Amayiro en lui montrant des fausses preuves. Danathor pourra sans doute vous y aider.",r:[14900,null,null,null,null,null]};
Q.s[725] = {n:"Le sang des rats.",d:"Amayiro vous a demandé d\'anéantir quatre Rats d\'Hyoactif dans les égoûts de Bonta.",r:[40000,null,null,null,null,null]};
Q.s[572] = {n:"Des personnes de confiance.",d:"Amayiro a besoin de personnes de confiance pour participer à la mise en scène des faux pouvoirs de la Corne Edfrit.",r:[null,null,null,null,null,null]};
Q.s[573] = {n:"Une mise en scène minutieuse.",d:"Pour finaliser la mise en scène, Amayiro a besoin de Miteters présentes sur des Craqueleurs et de la Graisse de Gelée Royale, n\'importe laquelle fera l\'affaire.",r:[233000,null,null,null,null,null]};
Q.s[142] = {n:"Encore de la collecte...",d:"Les Crâs tirent leur épingle du jeu, ou plus précisement, leurs flèches. Les Araknes malades semble contenir dans leurs pattes de quoi faire du poison... business is business...",r:[750,75,null,null,null,null]};
Q.s[23] = {n:"L\'appel du fou",d:"Eilof demande une pelle de boisaille pour construire son abri anti-apocalypse.",r:[4000,50,null,null,null,null]};
Q.s[27] = {n:"Du pain sur la planche",d:"Pour construire sa cabane indestructible, Eilof demande deux planches de Châtaignier, ainsi que quelques pains pour survivre au moins 3 jours au désastre...",r:[8000,450,null,null,null,null]};
Q.s[538] = {n:"Ratatouille.",d:"Il faut réunir les ingrédients nécessaires dans le chaudron primordial : un objet de chaque type et un alchimiste, un boulanger, un paysan, un boucher, un poissonnier.",r:[219000,null,null,null,null,null]};
Q.s[537] = {n:"L\'art de cuisiner sans se fatiguer, ou presque.",d:"Vous devez trouver les recettes des ingrédients listés sur le papier remis par Oto Mustam.",r:[null,null,null,null,null,null]};
Q.s[936] = {n:"Nos amies les bêtes.",d:"Amayiro souhaite en savoir plus sur Turorte. Oshimo, le gardien du Chanil, détient sûrement des informations sur cette tortue.",r:[null,null,null,null,null,null]};
Q.s[516] = {n:"Lenseignements auplès des Lenalds.",d:"Turorte a côtoyé et défendu les Lenalds par le passé. Les Lenalds, au sud de l\'île des Wabbits, s\'en souviennent peut-être encore.",r:[191000,null,null,null,null,null]};
Q.s[762] = {n:"Récolte de caleçons.",d:"Vous devez vaincre des miliciens de Bonta et... récupérer leurs caleçons. Oto en veut cinq.",r:[31000,null,null,null,null,null]};
Q.s[102] = {n:"Bois d\'Arash",d:"Procurez-vous du bois d\'Arash : en sacrifiant la nature, vous pourrez vous lier avec elle.",r:[1200,null,[[6853,1]],null,null,null]};
Q.s[104] = {n:"Rituel",d:"Trouvez la personne qui vous aidera à confectionner votre bâton d\'initié.",r:[1800,null,[[6782,1]],null,null,null]};
Q.s[333] = {n:"Montrer ses talents",d:"Vos talents se développent mais tout le monde n\'en est pas convaincu.",r:[370,null,[[8536,1]],null,null,null]};
Q.s[514] = {n:"C\'est l\'or, Moon.",d:"Le soi-disant gardien de la Corne Edfrit serait dans la jungle profonde de l\'île de Moon. D\'après les rumeurs, vous devez porter une Fourbacoiffe et avoir du Gloutoburg pour qu\'il apparaisse.",r:[177000,null,null,null,null,null]};
Q.s[453] = {n:"De la bave pour confectionner un bijou ?",d:"Vous devez récupérer des matériaux pour confectionner un joyau : 5 Lingots d\'Or, 1 Bave du Bouftou Royal et 1 Nacre. La Nacre s\'obtient en polissant 10 Nacres brutes que l\'on trouve sur les crustacés et mollusques de l\'île d\'Otomaï.",r:[80000,null,null,null,null,null]};
Q.s[1063] = {n:"Usine à jouets.",d:"D\'abominables créatures ont cambriolé l\'entrepôt du Père Nowel. Vous devez récupérer les caisses de cadeaux qu\'elles ont volées, avec ou sans leur consentement, et les apporter à Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1064] = {n:"Usine à jouets.",d:"D\'abominables créatures ont cambriolé l\'entrepôt du Père Nowel. Vous devez récupérer les caisses de cadeaux qu\'elles ont volées, avec ou sans leur consentement, et les apporter à Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
