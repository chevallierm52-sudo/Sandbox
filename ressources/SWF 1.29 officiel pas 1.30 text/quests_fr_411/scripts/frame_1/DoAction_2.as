Q.s[1093] = {n:"L\'histoire cachée.",d:"La légende de Goultard ne raconte pas toute sa vie. Suivez son histoire depuis son enfance pour percer ses secrets.",r:[null,null,null,null,null,null]};
Q.s[963] = {n:"Un coup fourré.",d:"Afin de saboter l\'équipement de Bonta, Oto Mustam veut que vous remplaciez les outils de ses forgerons par 5 Marteaux Martel.",r:[null,null,null,null,null,null]};
Q.s[904] = {n:"Un coup de pouce.",d:"Oto Mustam est très satisfait du travail du forgeron équipant la milice de Bonta et vous charge de faire en sorte qu\'il continue dans cette voie.",r:[null,null,null,null,null,null]};
Q.s[905] = {n:"Un coup de main.",d:"Latem Sa vient de recevoir du minerai et de nouveaux outils. Vous devez profiter de son absence, entre 17 heures et 21 heures, pour dérober le minerai et échanger ses outils.",r:[122000,null,null,null,null,null]};
Q.s[204] = {n:"Trouver le hors-la-loi",d:"Zatoïshwan a été aperçu du côté de Terrdala.  \nIl est condamné à l\'emprisonnement à Astrub. \n",r:[null,112500,null,null,null,null]};
