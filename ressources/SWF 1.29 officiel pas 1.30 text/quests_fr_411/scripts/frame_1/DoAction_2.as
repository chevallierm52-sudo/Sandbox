Q.s[334] = {n:"Ailes en kit",d:"Gobriel en a assez que les autres Gobelins lui jettent des pierres à cause de la couleur de sa peau. Il voudrait devenir un ange.",r:[30000,null,null,null,null,null]};
Q.s[351] = {n:"Le fil de l\'histoire.",d:"Pour apprendre l\'histoire de l\'épée de Iop vous pouvez aller voir Tenva au temple.",r:[75,null,null,null,null,null]};
Q.s[348] = {n:"Bienvenue",d:"Bienvenue",r:[null,null,null,null,null,null]};
Q.s[349] = {n:"Piou",d:"Piou piou piou piou piou !",r:[250,null,[[6897,2],[8537,1]],null,null,null]};
Q.s[346] = {n:"Arietta Fiolle",d:"Allez voir où se trouve Arietta Fiolle.",r:[25,null,null,null,null,null]};
Q.s[332] = {n:"Tonte matinale",d:"Jicé est un type génial, il a compris qu\'avec de la laine on pouvait faire... de la laine",r:[120,150,null,null,null,null]};
Q.s[344] = {n:"Encore une livraison",d:"Cette fois il faut porter un objet à un Xelor qui s\'occupe d\'un Zaap.",r:[150,null,null,null,null,null]};
Q.s[416] = {n:"Bunny suit",d:"Le pwince d\'Wa vous a demandé de prendre sa place pour démasquer les assassins. Encore faut-il trouver quelqu\'un qui puisse vous tranformer en Wabbit.",r:[15000,null,null,null,null,null]};
Q.s[415] = {n:"Au meurtre!",d:"Le pwince d\'Wa se fait attaquer, protégez-le!",r:[5000,null,null,null,null,null]};
Q.s[417] = {n:"Courses",d:"Maintenant que la formule est complète, il faut les ingrédients.",r:[120000,null,null,null,null,null]};
Q.s[390] = {n:"Dilemme dilemme..",d:"Vous savez maintenant qu\'Yse Vewybad complote contre le Roi. Il va falloir prendre parti pour l\'un ou l\'autre.",r:[2000,null,null,null,null,null]};
Q.s[254] = {n:"Un bon repas",d:"Lorkos vous offrira une clef du labyrinthe si vous lui rapportez de quoi préparer un bon repas.",r:[null,null,null,null,null,null]};
Q.s[542] = {n:"Disparition.",d:"Vous pouvez à présent finir vos recherches et faire votre rapport à Oto Mustam.",r:[226000,null,null,null,null,null]};
Q.s[539] = {n:"Le côté obscur du wabbit.",d:"Vous devez négocier l\'emplacement de la Corne Edfrit contre un Grattoir à dos Spontex auprès de Turorte, mais qui c\'est ce qui vous attend dans la jungle profonde de Moon ?",r:[null,null,null,null,null,null]};
Q.s[540] = {n:"La fourfouille.",d:"Turorte vous a révélé que la Corne Edfrit était enterrée au nord-est de l\'île, près d\'une statue de phénix.",r:[null,null,null,null,null,null]};
Q.s[541] = {n:"Le trouble-fête.",d:"Vos fouilles ont été interrompues par l\'arrivée d\'un Sadida. A vous de lui montrer ce qu\'il arrive lorsqu\'on ose s\'opposer à Brâkmar.",r:[null,null,null,null,null,null]};
Q.s[260] = {n:"Cavalerie légère",d:"Fournir quelques montures fraîches pour la milice.",r:[75000,null,null,null,null,null]};
Q.s[914] = {n:"Spentox, ça gratouille et ça chatouille.",d:"Mulic Bere vous a donné accès à sa forge spéciale pour fabriquer un grattoir à dos Spentox.",r:[198000,null,null,null,null,null]};
Q.s[532] = {n:"La forge de luxe.",d:"Il faut fabriquer un grattoir à dos que Turorte puisse utiliser. Etant le meilleur forgeron de Brâkmar, Mulic Bere pourra vous aider à réaliser cet outil particulier.",r:[null,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
