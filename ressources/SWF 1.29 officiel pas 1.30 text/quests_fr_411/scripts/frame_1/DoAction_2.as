Q.s[898] = {n:"La confirmation.",d:"Pandalida a profité de votre combat pour s\'enfuir, elle s\'est sans doute réfugiée chez elle. Vous DEVEZ la convaincre de remettre la lettre à Xéphirès.",r:[95000,null,null,null,null,null]};
Q.s[897] = {n:"Intimidation intime.",d:"Il faut intimider Pandalida en saccageant sa maison. Vous avez besoin de 3 Pâtes à Tra Khben, pâte obtenue en concassant 15 Groins du Sanglier, 5 Pots de Gloutovore et 1 Plume de Serpiplume.",r:[null,null,null,null,null,null]};
Q.s[458] = {n:"Le facteur.",d:"Il faut trouver un moyen de faire passer la lettre à Xephirès. Il est souvent à la taverne du Pandawa Ivre mais refuse désormais de vous parler.",r:[null,null,null,null,null,null]};
Q.s[739] = {n:"La relève.",d:"Vous devez trouver le guerrier Tink Berval et lui demander de relever Brank Thoof.",r:[5800,null,null,null,null,null]};
Q.s[912] = {n:"Le tort tue.",d:"Turorte ayant faim et la manière forte étant un échec, il faut trouver un moyen de l\'empoisonner. Un habitant de l\'île connaît sûrement l\'alimentation des tortues.",r:[184000,null,null,null,null,null]};
Q.s[530] = {n:"Mettre la tortue sur le dos.",d:"Puisque vous n\'arrivez pas à soutirer des informations juste en demandant, il va falloir y aller d\'une façon plus directe...",r:[null,null,null,null,null,null]};
Q.s[352] = {n:"Transformation",d:"Poss\'Ybel veut que vous lui fournissiez quelques produits finis issus du fruit de vos récoltes.",r:[50,15,null,null,null,null]};
Q.s[378] = {n:"Transformation",d:"Poss\'Ybel veut une mini potion de soins faite d\'une fleur de lin et d\'un peu d\'eau.",r:[50,null,null,null,null,null]};
Q.s[379] = {n:"Transformation",d:"Poss\'Ybel veut que vous lui fournissez quelques produits finis issus du fruit de vos récoltes.",r:[50,15,null,null,null,null]};
Q.s[380] = {n:"Transformation",d:"Poss\'Ybel veut que vous lui fournissez quelques produits finis issus du fruit de vos récoltes.",r:[50,15,null,null,null,null]};
Q.s[686] = {n:"Traquer les buveurs.",d:"Vous devez faire le tour des tavernes de Bonta pour trouver les miliciens qui ne sont pas à leur poste et leur demander leur badge.",r:[2500,null,null,null,null,null]};
Q.s[364] = {n:"Conditions d\'échange",d:"Anta vous a fait une liste de ce qu\'elle veut en échange de son collier magique.",r:[null,null,null,null,null,null]};
Q.s[347] = {n:"Je fais du social",d:"Disskray veut savoir si les villageois n\'ont rien remarqué d\'étrange ou d\'inhabituel",r:[150,null,[[8535,1]],null,null,null]};
Q.s[179] = {n:"Shaman connexion",d:"Le shaman est un Pandawa qui en sait beaucoup sur les agissements de certains... Apparemment, tout n\'est pas rose à Pandala !",r:[3000,null,null,null,null,null]};
Q.s[177] = {n:"A la santé de la déesse !",d:"Nouvel arrivé à Pandala, l\'Assistant Shaman vous demande de faire honneur à votre déesse : une offrande spiritueuse serait la bienvenue... Votre initiation commence.",r:[500,null,null,null,null,null]};
Q.s[343] = {n:"Trouver un petit boulot",d:"Posteur Ninh a surement une commission à vous confier. ",r:[50,null,null,null,null,null]};
Q.s[342] = {n:"Une recette pour Pipelette",d:"Pipelette attend la recette des crêpes d\'Astrub pour préparer la venue de ses petits enfants. ",r:[null,75,null,null,null,null]};
Q.s[915] = {n:"La valse des rocheuses.",d:"Descendez dans le repaire des bandits à l\'aide d\'une corde. N\'y allez pas seul !",r:[70000,null,null,null,null,null]};
Q.s[465] = {n:"Jolie minette.",d:"Votre rencontre avec les bandits vous a appris que Hersa Griffe Sombre en sait plus qu\'elle ne veut l\'admettre. Reste à lui parler sans se faire défigurer.",r:[null,null,null,null,null,null]};
Q.s[464] = {n:"Repaire pépère.",d:"Amayiro vous a demandé d\'enquêter dans les plaines de Cania pour trouver le repaire des bandits. D\'après vos informations il serait non loin de la foire du trooll, un peu à l\'Ouest.",r:[null,null,null,null,null,null]};
Q.s[928] = {n:"Pretty Nara.",d:"Nara vous a fournit la longue liste de fournitures dont il a besoin pour forger l\'équipement de la milice de Bonta. Vous devez les lui amener dans la Mine des Porcos.",r:[128000,null,null,null,null,null]};
Q.s[955] = {n:"Agence immobilière.",d:"Vous avez visité les différents lieux indiqués par Setag. Reste à convaincre Nara de déménager dans l\'un d\'eux.",r:[null,null,null,null,null,null]};
Q.s[501] = {n:"Prospection immobilière.",d:"Nara vous a demandé de trouver un endroit isolé où installer sa forge et son matériel.",r:[null,null,null,null,null,null]};
Q.s[695] = {n:"Transport de caisses.",d:"Vous devez acheminer quatre caisses entre Amayiro et l\'avant-poste de Bonta, au sud de la cité.",r:[7000,null,null,null,null,null]};
Q.s[329] = {n:"Faire ses preuves",d:"Comme vous n\'êtes pas très connu alentours, les autochtones ne savent pas encore s\'ils peuvent vous faire confiance.",r:[105,null,null,null,null,null]};
Q.s[367] = {n:"Licence quatre",d:"Vous avez la bière, en la donnant à Aymé, vous devriez recouvrer toute votre énergie.",r:[null,null,null,null,null,null]};
Q.s[366] = {n:"Se mettre en bière",d:"Aymé veut de la bière, pourquoi ne va-t-il pas la chercher tout seul ?",r:[15,10,null,null,null,null]};
Q.s[531] = {n:"L\'ami des bêtes.",d:"Vous devez trouver d\'où vient Turorte. Un spécialiste des animaux pourra vous aiguiller dans vos recherches. Oshimo, responsable du chanil, est un bon point de départ.",r:[null,null,null,null,null,null]};
Q.s[913] = {n:"Le wabbit et la tortue.",d:"D\'après Oshimo, Turorte se serait fait un ennemi mortel. Lelievwe Pâle Pitane aurait signé un pacte avec les démons pour avoir plus de puissance. Il réside sur l\'île des wabbits squelettes.",r:[191000,null,null,null,null,null]};
Q.s[361] = {n:"Carnets d\'adresse",d:"Ajouter un joueur dans votre liste d\'amis.",r:[20,null,null,null,null,null]};
Q.s[371] = {n:"Il est à qui le Kiki ?",d:"Ma\'Ster vous a mis au défi de battre le monstre tapi dans sa niche.",r:[null,null,null,null,null,null]};
Q.s[320] = {n:"Jeu Trooll règles avancées",d:"Raxitik est terrorisé. Il sait que les Bworks vont le livrer au Trooll pour qu\'il pratique une partie de jeu Trooll règles avancées avec lui. Il faut absolument éliminer ce Trooll qui menace l\'intégrité physique de Raxitik.",r:[30000,null,[[2562,1]],null,null,null]};
Q.s[995] = {n:"Pélerinage sanglant.",d:"Affrontez le dopeul de chacun des temples de classe.",r:[null,null,null,null,null,null]};
Q.s[765] = {n:"Anéantir les tortues.",d:"Oto vous a demandé de tuer dix tortues de l\'île de Moon. Leurs yeux feront une bonne preuve.",r:[17000,null,null,null,null,null]};
Q.s[764] = {n:"Du vin pour Oto.",d:"Vous devez amener à Oto du vin de Gloutovore. Où pourrait-on trouver ça ?",r:[17000,null,null,null,null,null]};
Q.s[763] = {n:"L\'entretien.",d:"Une personnalité importante de Brâkmar a demandé à vous voir. Elle se trouve dans les sous-sols de la tour de Brâkmar.",r:[17000,null,null,null,null,null]};
Q.s[728] = {n:"Des potions énergétisantes.",d:"Oto Mustam a besoin de trois potions Pahoa Raide.",r:[250,null,null,null,null,null]};
Q.s[449] = {n:"Le repaire repéré.",d:"Grâce au message du chef des voleurs vous êtes en mesure de trouver son repaire. Pourquoi ne pas y faire un tour avant de rentrer à la milice ?",r:[90000,null,null,null,null,null]};
Q.s[756] = {n:"Acheter l\'équipement.",d:"Vous devez acheter l\'équipement qu\'Oto a indiqué sur sa liste et l\'équiper avant de retourner le voir.",r:[17000,null,null,null,null,null]};
Q.s[761] = {n:"32 dents en or !",d:"Vous devez apporter un dentier en or pour Mak. Vous pourrez en trouver sur des Chafers d\'élite, mais le forgeron de Brâkmar peut sans doute vous en fournir un aussi.",r:[28000,null,null,null,null,null]};
Q.s[487] = {n:"Pénétrer dans la bibliothèque.",d:"Les espions à Bonta ont échoué dans leur assassinat, il faut donc le faire à leur place. La cible est un tacticien qui réside dans la bibliothèque de Bonta mais gare aux chiens de garde.",r:[null,null,null,null,null,null]};
Q.s[486] = {n:"Assassinat.",d:"Vous pouvez maintenant entrer dans la bibliothèque pour vous occuper du tacticien.",r:[null,null,null,null,null,null]};
Q.s[750] = {n:"Humilier Sbab ?",d:"Oto vous a demandé d\'amener dix oreilles de Tiwabbits à Sbab pour l\'horrifier. Mais il y a peut-être une autre solution si vous ne souhaitez pas le faire.",r:[12800,null,null,null,null,null]};
Q.s[734] = {n:"Tabasser les Bontariens.",d:"Oto vous a demandé une bière de la Tabasse. La taverne de la Tabasse se trouve à Bonta.",r:[3000,null,null,null,null,null]};
Q.s[753] = {n:"Retrouver les documents.",d:"Les documents secrets n\'étaient pas sur l\'espion. La faune des landes de Sidimote s\'en est peut-être emparée.",r:[14900,null,null,null,null,null]};
Q.s[938] = {n:"La Révélation.",d:"Sous l\'hôtel de vente des alchimistes il y a une armoire. Il vous suffit de vous placer devant pour ouvrir le passage secret. Le Mage Ax vous attend là-bas.",r:[null,null,null,null,null,null]};
Q.s[526] = {n:"Le Mage Ax.",d:"Amayiro vous a demandé d\'interroger le Mage Ax pour connaître le mode d\'emploi de la Corne Edfrit et ses pouvoirs.",r:[null,null,null,null,null,null]};
Q.s[939] = {n:"Retour au bercail.",d:"Il est temps de rentrer à Bonta et de faire le point avec Amayiro.",r:[226000,null,null,null,null,null]};
Q.s[882] = {n:"Le savoir basique.",d:"Allez apprendre la technique de la capture d\'âme. La clef du donjon doit se trouver sur les créatures de la région.",r:[35000,null,null,null,null,null]};
Q.s[740] = {n:"Les casques de Chafer.",d:"Oto veut dix casques de Chafer qu\'on trouve au Cimetière des Torturés.",r:[6400,null,null,null,null,null]};
Q.s[525] = {n:"Présence brâkmarienne.",d:"Vous avez attaqué un Brâkmarien qui était déjà sur place mais qui ne possédait pas encore la Corne Edfrit. Si Ecaflip est de votre côté peut-être trouverez-vous la Corne Edfrit avant les Brâkmariens.",r:[219000,null,null,null,null,null]};
Q.s[524] = {n:"La décision de Turorte.",d:"Convaincre Turorte d\'échanger le Bandana Rapiécé contre la Corne Edfrit. Vous avez besoin d\'une Fourbacoiffe et d\'une Bouteille de Gloutoburg pour qu\'elle vous apparaisse.",r:[null,null,null,null,null,null]};
Q.s[741] = {n:"Chasse au loup.",d:"Oto vous a demandé de débarrasser Brâkmar d\'un loup qui rôde autour de la façade.",r:[7000,null,null,null,null,null]};
Q.s[500] = {n:"Si près du but.",d:"Norb sait où se trouve le forgeron ermite, il vous reste à le convaincre de divulguer sa cachette. Peut-être qu\'Amayiro pourra vous aider.",r:[122000,null,null,null,null,null]};
Q.s[499] = {n:"Ainsi forgeront...",d:"Il faut trouver un forgeron compétent qui accepterait de faire de l\'équipement pour Bonta.",r:[null,null,null,null,null,null]};
Q.s[527] = {n:"Une autre histoire de poivrot.",d:"D\'après vos sources, le tavernier de Sufokia aurait des informations sur une puissante corne magique.",r:[null,null,null,null,null,null]};
Q.s[910] = {n:"Jamais mieux servi que par soi-même.",d:"L\'information révélée par le Tavernier du Ripate n\'est pas exploitable telle quelle. Une recherche auprès des érudits pourrait s\'avérer plus fructueuse.",r:[null,null,null,null,null,null]};
Q.s[911] = {n:"Kokoko, koko ?",d:"Pressentant la prochaine mission que vous confiera Oto Mustam, mieux vaut préparer le terrain et acquérir quelques noix de kokoko.",r:[170000,null,null,null,null,null]};
Q.s[528] = {n:"Carapaces.",d:"Le tavernier du Ripate vous a demandé une carapace de tortue de Moon de chaque couleur. Mais peut-être allez-vous opter pour une méthode plus rapide.",r:[null,null,null,null,null,null]};
Q.s[1055] = {n:"Combattre le lupus minimus.",d:"Un combat qui met à l\'épreuve toutes vos capacités.",r:[null,null,null,null,null,null]};
Q.s[890] = {n:"Une mission presque achevée.",d:"Le chemin est à présent dégagé, même si les gobelins ne constituaient pas une réelle menace. Exoram va enfin pouvoir vous révéler ce qu\'il sait et Oto Mustam sera fier de vous.",r:[null,null,null,null,null,null]};
Q.s[446] = {n:"Abrakadabra, c\'est encore moi.",d:"Exoram n\'est pas rassuré car il a entendu des bruits suspects et des rires narquois plus au nord. Si vous pouvez lui assurer que le chemin est dégagé, il vous donnera les informations prisées sur Xephirès.",r:[null,null,null,null,null,null]};
Q.s[445] = {n:"Abrakadabra, me voilà.",d:"Vous avez rapporté des informations utiles à Oto Mustam, qui vous a demandé de prendre la relève d\'un milicien. Vous devez chercher un Sram connaissant Xephirès, dans la forêt des Abraknydes.",r:[null,null,null,null,null,null]};
Q.s[891] = {n:"Une mission loin d\'être achevée.",d:"Des traces de lutte et des restes de karne indiquent qu\'Exoram s\'est battu et a été capturé ou tué. Oto Mustam sera furieux de l\'apprendre.",r:[65000,null,null,null,null,null]};
Q.s[444] = {n:"Les bons bars de Bonta.",d:"Il faut trouver des informations sur Xephirès. Les taverniers de Bonta pourraient peut-être fournir une piste.",r:[null,null,null,null,null,null]};
Q.s[737] = {n:"La récolte de poison.",d:"Oto Mustam a besoin de 20 pods de venin de Scorbute.",r:[4600,null,null,null,null,null]};
Q.s[485] = {n:"Récolte de poison.",d:"Les espions à Bonta ont besoin de poison : un poison rare détenu uniquement par les Bworks Mages. Les espions se cachent dans le quartier sud-ouest de Bonta.",r:[null,null,null,null,null,null]};
Q.s[906] = {n:"La bonne planque.",d:"Vous devez trouver une nouvelle planque pour les espions entre leur emplacement actuel et la bibliothèque. Au besoin, vous devez neutraliser ses éventuels occupants.",r:[128000,null,null,null,null,null]};
Q.s[535] = {n:"Un petit échec.",d:"Des traces de combat, deux armes laissées au sol, un Sram décédé : tout porte à croire que vous n\'êtes pas arrivé à temps.",r:[205000,null,null,null,null,null]};
Q.s[918] = {n:"Exoram le Sram.",d:"Vous avez ramené Exoram au temple Sram. Cette fois-ci il a intérêt à vous donner les informations qu\'il s vous a promis.",r:[70000,null,null,null,null,null]};
Q.s[892] = {n:"Un Sram plus bête que nature.",d:"Exoram s\'est encore mis dans de sales draps. Si vous voulez les informations sur Xephirès, il va falloir l\'aider une nouvelle fois.",r:[null,null,null,null,null,null]};
Q.s[447] = {n:"S\'infiltrer ou foncer dans le tas, telle est la question.",d:"D\'après vos découvertes, il semblerait qu\'Exoram soit retenu prisonnier dans le campement gobelin sauf s\'il est déjà mort.",r:[null,null,null,null,null,null]};
Q.s[448] = {n:"Sur les traces du Sram.",d:"Exoram a été relâché vivant par les gobelins. Vous devez à nouveau partir sur ces traces pour lui mettre la main dessus.",r:[null,null,null,null,null,null]};
Q.s[493] = {n:"Dans la grotte Porcos.",d:"Vous devez tenter de rallier le forgeron de la grotte Porcos à la cause de Brâkmar.",r:[152000,null,null,null,null,null]};
Q.s[759] = {n:"Leçon d\'humilité.",d:"Oto vous a ordonné de lui amener 40 yeux de larves bleues.",r:[23000,null,null,null,null,null]};
Q.s[760] = {n:"Se débarrasser de la larve dorée.",d:"Vous devez trouver un moyen de vous débarrasser de la larve dorée qui vous suit.",r:[25000,null,null,null,null,null]};
Q.s[452] = {n:"Un échec... temporaire",d:"Xephirès a refusé l\'offre, mais tout n\'est pas perdu. Un bijou saura l\'amadouer.",r:[75000,null,null,null,null,null]};
Q.s[451] = {n:"La rencontre.",d:"Maintenant que l\'endroit où Xephirès se trouve a été identifié, il faut le trouver à la taverne du Pandawa Ivre et lui faire la proposition. Il y est à partir de 16 heures.",r:[null,null,null,null,null,null]};
Q.s[736] = {n:"Un message à faire passer.",d:"Oto veut que vous passiez son message à Vil Smisse, dans le repaire des Roublards qui se situe dans le cimetière d\'Amakna.",r:[4000,null,null,null,null,null]};
Q.s[491] = {n:"Nouveau danger qui fait peur.",d:"Plusieurs guerriers brâkmariens ont été vaincus et laissés pour morts sur la route menant à Astrub. Il faut aller enquêter là-bas mais avant, Oto Mustam veut une âme de Croc Gland.",r:[140000,null,null,null,null,null]};
Q.s[747] = {n:"Récolter la taxe.",d:"Vous devez récolter la nouvelle taxe d\'Oto dans chaque taverne de Brâkmar. Carte blanche pour tabasser les taverniers qui ne veulent pas payer.",r:[10700,null,null,null,null,null]};
Q.s[889] = {n:"Une lettre classée X.",d:"Il vous faut trouver l\'identité de ce fameux X. Là lettre fait référence à un lieu où il a l\'habitude d\'aller. Trouver ce lieu permettra d\'en savoir plus.",r:[null,null,null,null,null,null]};
Q.s[443] = {n:"Retour de la tour.",d:"Vous avez trouvé un morceau de papier très intéressant. Il faut le montrer à Oto.",r:[60000,null,null,null,null,null]};
Q.s[442] = {n:"La tour désordre.",d:"Trouvez dans Bonta un personnage important qui serait susceptible d\'être corrompu. Oto a suggéré de chercher dans la tour.",r:[null,null,null,null,null,null]};
Q.s[792] = {n:"A la recherche du greffier déprimé.",d:"Tabach, Greffier de l\'Ordre du Coeur Vaillant, écume les tavernes depuis la disparition de son chat. Il faut le ramener auprès de Jerhyn Gholein.",r:[null,null,null,null,null,null]};
Q.s[793] = {n:"A la recherche de la greffière.",d:"Ybaul, Greffière de l\'Ordre de l\'Esprit Salvateur, écume les tavernes à la recherche de ses frères. Il faut la ramener auprès d\'Elviana Tirips.",r:[null,null,null,null,null,null]};
Q.s[795] = {n:"Os de coeur.",d:"Kaffra Kyper vous a demandé de lui apporter 1 Os de Chafer pour lui prouver votre valeur.",r:[null,null,null,null,null,null]};
Q.s[797] = {n:"Mauvais oeil.",d:"Ledrob Terceséc vous a demandé de lui apporter 1 Œil de Corbac pour lui prouver votre valeur.",r:[null,null,null,null,null,null]};
Q.s[210] = {n:"A coeur saignant, rien d\'impossible.",d:"Vous devez vous emparer des statuettes symboles des biens et des maux de l\'humanité et les remettre à Kaffra. Elles sont cachées dans une mine abandonnée près du temple Enutrof.",r:[200000,null,null,null,null,null]};
Q.s[796] = {n:"Poils au menton.",d:"Divad Dleifrepok vous a demandé de lui apporter 1 Poils de Barbe de Bwork Mage pour lui prouver votre valeur.",r:[null,null,null,null,null,null]};
Q.s[1071] = {n:"Usine à jouets.",d:"D\'abominables créatures ont cambriolé l\'entrepôt du Père Nowel. Vous devez récupérer les caisses de cadeaux qu\'elles ont volées, avec ou sans leur consentement, et les apporter à Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1113] = {n:"Collecte de céréales.",d:"Fidèle à son habitude, Annette Daimpeau est partie dormir au lieu de ravitailler Frigostine. La boulangère vous a donc demandé de remplacer son employée.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1114] = {n:"Collecte de fleurs.",d:"Ne pouvant laisser son atelier sans surveillance, Eric Azaraille vous a demandé de lui servir de fournisseur.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1115] = {n:"Collecte de poissons.",d:"Avec l\'arrivée massive d\'aventuriers, les réserves de poisskailles diminuent à vue d\'oeil. C\'est pourquoi Clarisse Tosha vous a demandé de la ravitailler.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1117] = {n:"Collecte de minerai.",d:"L\'exploitation des mines a pratiquement cessé depuis plusieurs décennies, et les réserves d\'obsidienne servant à la fonte d\'alliage sont à sec. Laurent Gebleuh vous a donc proposé de l\'aider à renflouer ses stocks.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1116] = {n:"Collecte de viandes.",d:"Avec l\'arrivée massive d\'aventuriers, les stocks de viandes diminuent à vue d\'oeil. C\'est pourquoi Al Shab vous a demandé de le ravitailler.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1118] = {n:"Collecte de bois.",d:"Le Chef Rhonté a besoin d\'une quantité astronomique de bois pour servir de combustible au système de dégel du port. Il vous a demandé un petit coup de main.",r:[85000,10000,[[11196,1]],null,null,null]};
Q.s[1107] = {n:"Chasse aux boufmouths.",d:"Clyde Parker vous a demandé de vous débarrasser des boufmouths, dans les champs de glace.",r:[170000,null,[[11196,1]],null,null,null]};
Q.s[1108] = {n:"Chasse aux créatures de la forêt.",d:"Clyde Parker vous a demandé de vous débarrasser des créatures de la forêt, dans la forêt des pins perdus.",r:[201000,null,[[11196,1]],null,null,null]};
Q.s[1109] = {n:"Chasse aux mansots.",d:"Clyde Parker vous a demandé de vous débarrasser des mansots, dans le lac gelé.",r:[223000,null,[[11196,1]],null,null,null]};
Q.s[1110] = {n:"Chasse aux fantômes de pirates.",d:"Clyde Parker vous a demandé de vous débarrasser des fantômes de pirates, dans le berceau d\'Alma.",r:[null,null,null,null,null,null]};
Q.s[1111] = {n:"Chasse aux crapeurs.",d:"Clyde Parker vous a demandé de vous débarrasser des crapeurs, dans les larmes d\'Ouronigride.",r:[null,null,null,null,null,null]};
Q.s[1112] = {n:"Chasse aux créatures de lave.",d:"Clyde Parker vous a demandé de vous débarrasser des créatures de lave, dans les tunnels de lave.",r:[null,null,null,null,null,null]};
Q.s[1121] = {n:"Récompense méritée.",d:"Reparler à Grand-père et lui montrer les restes de rat bougri.",r:[80000,3000,null,null,null,null]};
Q.s[1120] = {n:"La cave infestée.",d:"Aller dans la cave de Grand-père et exterminer la menace.",r:[20000,null,null,null,null,null]};
Q.s[1175] = {n:"Mansoétude.",d:"Craignant son extinction, Ken Tucky souhaite recuellir des mamansots afin de préserver l\'espèce.",r:[892000,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[1173] = {n:"Trouver et ramener la créature.",d:"Certains prétendent avoir vu Monsieur Pingouin au milieu des mansots. Il est recherché pour vol de poisskaille et dégradation volontaire de pêcheur.",r:[null,260000,[[11196,1]],null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[1172] = {n:"Trouver et ramener la créature.",d:"Certains prétendent l\'avoir aperçue en compagnie de fantômes. Elle est recherchée pour vol d\'un masque d\'argent et agressions répétées sur des furets domestiques.",r:[null,320000,[[11196,3]],null,null,null]};
Q.s[1171] = {n:"Trouver et ramener la créature.",d:"Certains prétendent avoir été attaqués près des sources thermales des larmes d\'Ouronigride. La Vengeuse Masquée est recherchée pour trouble de l\'ordre public et vengeance injustifiée.",r:[null,350000,[[11196,3]],null,null,null]};
Q.s[1170] = {n:"Trouver et ramener la créature.",d:"Certains disent l\'avoir vu se diriger vers la Crevasse Perge après l\'un de ses forfaits, au nord de l\'île. Il doit être mis en cage à la Bourgade pour ses expéditions carnassières envers les Boufmouths d\'élevage.",r:[null,380000,[[11196,3]],null,null,null]};
