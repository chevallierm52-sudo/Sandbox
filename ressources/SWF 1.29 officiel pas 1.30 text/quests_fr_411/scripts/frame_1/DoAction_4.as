Q.s[475] = {n:"Affaire louche.",d:"Vous allez profiter de l\'absence de Xarthan pour vous introduire discrètement dans sa maison et la fouiller. Les services d\'un bricoleur compétent seront nécessaires.",r:[null,null,null,null,null,null]};
Q.s[924] = {n:"A la tour.",d:"Xarthan a rendez-vous avec un Brâkmarien dans la Tour de Bonta après la réunion des notables. Il vaut mieux vous dépêcher pour ne pas le rater.",r:[95000,null,null,null,null,null]};
Q.s[534] = {n:"Le choix.",d:"Vous avez trouvé l\'espion à temps. Mais allez-vous suivre les ordres et récupérer les documents en le laissant là ?",r:[205000,null,null,null,null,null]};
Q.s[144] = {n:"... ou crocs de Xelors.",d:"Les Xélors semblent intéressés. D\'après Ant, ce serait pour mettre des aiguilles sur leurs sabliers... enfin il n\'est pas sûr. ",r:[3000,500,null,null,null,null]};
Q.s[115] = {n:"Trouver le hors-la-loi",d:"Certains disent avoir vu Qil Bil vers les plaines de Sidimote. \nQil Bil est recherché pour arrachage de membres. \nIl est condamné à l\'emprisonnement à Astrub. \n",r:[null,19200,null,null,null,null]};
Q.s[883] = {n:"Réengagez-vous, qu\'il disait.",d:"Snori Nairb a promis de partager ses kamas et son expérience avec vous si vous vous engagez dans la milice de Brâkmar.",r:[null,null,null,null,null,null]};
Q.s[32] = {n:"Qui sème le vhan, récolte l\'Artempeth",d:"Pour tester sa théorie sur l\'apparition des fleurs carnivores, Trapchet demande de semer des graines de rose obscures, puis de les récolter...",r:[15000,2500,null,null,null,null]};
Q.s[5] = {n:"L\'aphone et la flore",d:"Trois-Fleurs, un ami de Trapchet réside à Amakna et connait parfaitement la flore de sa région. Il faut lui demander des renseignements sur les fleurs agressives qui s\'y trouvent.",r:[12500,null,null,null,null,null]};
Q.s[3] = {n:"L\'epyss s\'enlise",d:"Erty Trapchet veut étudier des graines de pissenlit, pour les comparer avec de l\'Epyss...",r:[6000,null,null,null,null,null]};
Q.s[2] = {n:"L\'arroseur arrosant ",d:"Erty Trapchet a oublié de s\'occuper de ses plantes, il faut se rendre à son domicile pour les arroser.",r:[3000,null,null,null,null,null]};
Q.s[4] = {n:"Mais quel herbier !",d:"Pour ses recherches, Trapchet a besoin d\'étudier la répartition géographique des fleurs aux alentours d\'Astrub.",r:[6500,500,null,null,null,null]};
Q.s[60] = {n:"Bon sang, mais c\'est bien sûr!",d:"-",r:[null,null,null,null,null,null]};
Q.s[56] = {n:"Enquête sur une disparition... de Maison",d:"",r:[null,null,null,null,null,null]};
Q.s[38] = {n:"Livraison de Erty Trapchett",d:"",r:[null,null,null,null,null,null]};
Q.s[40] = {n:"Livraison de la mine",d:"",r:[null,null,null,null,null,null]};
Q.s[39] = {n:"Livraison de Podbra Manchot",d:"",r:[null,null,null,null,null,null]};
Q.s[143] = {n:"Chasse sauvage",d:"De sombres créatures ruinent les affaires d\'Ant Emicheun, s\'en débarasser lui semble être une solution... du moins en attendant de comprendre ce qu\'elles font ici...",r:[5000,750,null,null,null,null]};
Q.s[141] = {n:"Les oeufs peuvent-ils nager ?",d:"Plus d\'agent infectieux dans les plumes de Tofus malades. Par contre leurs oeufs en seraient probablement une piste pour les Eniripsa. Encore des Kamas à se faire !",r:[2500,375,null,null,null,null]};
Q.s[21] = {n:"Ca va saigner !",d:"Il vous prend le besoin d\'en savoir plus sur vous-même et vous décidez d\'aller dans un endroit sanglant... la boucherie.",r:[600,null,null,null,null,null]};
Q.s[25] = {n:"Ca sang le roussis !",d:"Votre maître a entendu qu\'un mineur a récemment été changé en mineur sombre. Il veut en avoir l\'artère net !",r:[1200,null,null,null,null,null]};
Q.s[41] = {n:"Stupides Enutrofs !",d:"Les Enutrof ont découvert quelque chose, ils auront besoin de toi.",r:[1200,null,null,null,null,null]};
Q.s[46] = {n:"Extrait de Dzibi",d:"La fleur telle quelle ne conviendra pas, il vous faut une infusion !",r:[1200,null,null,null,null,null]};
Q.s[47] = {n:"Livraison express",d:"Vous devez rapporter l\'infusion à votre maîtresse de guilde pour qu\'elle puisse fabriquer votre bâton ! \nSi au passage vous avez le temps et les moyens d\'aller apporter de l\'infusion à votre fournisseur de fleur, cela lui fera grandement plaisir.",r:[1200,null,[[6781,1]],null,null,null]};
Q.s[44] = {n:"Fleur de Dzibi",d:"Pour que votre maîtresse de classe puisse vous confectionner un bâton digne de ce nom, vous devez trouver de la fleur de Dizbi.",r:[600,null,[[6798,1]],null,null,null]};
Q.s[118] = {n:"On a faim !",d:"Les bouftous d\'Allisteria ont faim. Il va falloir tous les nourrir !",r:[600,null,null,null,null,null]};
Q.s[127] = {n:"Boudin Bouilli de Bouftou",d:"Sauver la tradition du bon Boudin Bouilli de Bouftou",r:[1200,null,null,null,null,null]};
Q.s[132] = {n:"Bats toi si t\'es une Feca",d:"Le célèbre Fallanster vous a demandé d\'entraîner sa fille au combat.",r:[1200,null,null,null,null,null]};
Q.s[160] = {n:"Un tiens vaut mieux que deux tu boiras",d:"La voie de l\'eau consiste à résister à... l\'absorption et à l\'immersion (partielle et totale) d\'eau par tous les moyens. Ne jamais en boire, se laver uniquement en cas de nécessité. Trouvez le maître de la voie de l\'Eau : il en sait plus qu\'il n\'y paraît",r:[9000,null,null,null,null,null]};
Q.s[159] = {n:"Le sage Lenald",d:"Une vendeuse de rafraîchissement Pandawaïenne vous conseille de rencontrer le sage Lénald. Selon elle, lui seul détient la vérité sur Pandala et ses secrets.",r:[1000,null,null,null,null,null]};
Q.s[157] = {n:"La statue de la déesse",d:"Le Grandapan a accepté le cadeau des Enutrofs avec joie. Fervent admirateur des chercheurs de Dofus, il vous accueille à bras ouverts.",r:[750,null,null,null,null,null]};
Q.s[156] = {n:"Le Grandapan : Un pandawa sympa",d:"Les Enutrofs en cure chez le Shaman vous conseillent d\'aller voir le Grandapan. Très au fait des coutumes locales, il est aussi un fin connaisseur des légendes Pandawaïennes.",r:[500,null,null,null,null,null]};
Q.s[158] = {n:"Libations pour la déesse",d:"Grâce à vous, l\'Assistant du Shaman peut commencer son rituel de remerciement à la déesse. Il sera fin prêt dès que vous lui aurez remis une offrande pandawaïenne traditionnelle.",r:[750,null,null,null,null,null]};
Q.s[259] = {n:"Au service du roi",d:"Le roi aime monter, il faut lui trouver des dragodindes",r:[75000,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
