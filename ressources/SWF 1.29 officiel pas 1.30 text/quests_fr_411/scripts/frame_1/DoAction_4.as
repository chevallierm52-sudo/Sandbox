Q.s[1042] = {n:"Déplacement sur la carte.",d:"Bienvenue dans le tutorial guidé. Cliquez avec le bouton gauche de votre souris autour de votre personnage pour le déplacer. Si vous cliquez loin de votre personnage il courra, sinon il marchera.",r:[5,null,[[10792,1]],null,null,null]};
Q.s[1050] = {n:"Passer son tour.",d:"Lorsque vous avez terminé vos actions, cliquez sur le bouton {ui,banner,btn_skipTurn::fin de tour} avec le bouton gauche de votre souris pour accélérer le déroulement du combat et regagner vos {ui,banner,lbl_pa,2::PA} et vos {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10799,1]],null,null,null]};
Q.s[1044] = {n:"Equiper un objet.",d:"Ouvrez votre interface de {ui,banner,btn_character,1::caractéristiques}. Sélectionnez l\'{ui,storage,grid::Anneau du débutant} que vous avez gagné en maintenant enfoncé le bouton gauche de votre souris et déposez-le  dans l\'{ui,characterSheetUi,slot_2,2::emplacement réservé à l\'anneau} de votre fiche de personnage. \nVous pouvez également l\'équiper en effectuant un double clic avec le bouton gauche de votre souris sur l\'{ui,storage,grid::Anneau du débutant}.",r:[5,null,[[10793,1]],null,null,null]};
Q.s[1060] = {n:"Equiper ses objets.",d:"Ouvrez l\'interface des {ui,banner,btn_character,1::caractéristiques} et équipez sur votre personnage les objets que vous avez gagné.",r:[null,null,[[10793,1]],null,null,null]};
Q.s[1048] = {n:"Se déplacer en combat.",d:"Votre personnage possède des {ui,banner,lbl_pm,2::points de mouvement} (PM) pour se déplacer. Se déplacer d\'une case coûte 1 PM. Déplacez votre personnage en cliquant sur une case avec le bouton gauche de votre souris. Vous récupérez vos {ui,banner,lbl_pm,2::PM} au début de votre prochain tour.",r:[5,null,[[10797,1]],null,null,null]};
Q.s[1049] = {n:"Utiliser un sort.",d:"Sélectionnez {ui,banner,gd_spellitemotes,0::un sort} et cliquez avec le bouton gauche de votre souris sur une cible. Certains sorts se lancent sur les ennemis, et d\'autres sur les alliés ou sur votre personnage. La portée du sort est indiquée grâce aux cases bleues. Les sorts nécessitent des {ui,banner,lbl_pa,2::points d\'action} (PA) pour être lancés. Vous récupérez vos {ui,banner,lbl_pa,2::PA} au début de votre prochain tour.",r:[5,null,[[10798,1]],null,null,null]};
Q.s[1047] = {n:"Choisir sa position de départ.",d:"Cliquez sur une des {cell,272::cases bleues} avec le bouton gauche de votre souris pour choisir votre position de départ et cliquez sur le {ui,banner,btn_ready::bouton prêt} pour commencer le combat.",r:[5,null,[[10796,1]],null,null,null]};
Q.s[1045] = {n:"Changer de carte.",d:"Pour changer de carte, déplacez votre curseur sur un des {arrow,1280,520,0,0::bords de l\'écran} et cliquez avec le bouton gauche de votre souris lorsque le curseur se transforme en flèche.",r:[5,null,[[10794,1]],null,null,null]};
Q.s[1053] = {n:"Vaincre le monstre",d:"Pour continuer votre quête, vous devez commencer par aller dans la {arrow,700,870,0,1::salle suivante} et lancer un combat contre {monster,2781::le monstre}.",r:[5,null,[[10801,1]],null,null,null]};
Q.s[1059] = {n:"Conclure l\'apprentissage.",d:"Pour valider votre quête, vous devez parler à {npc,1222::Maître Pifo}.",r:[5,null,null,null,null,null]};
Q.s[1052] = {n:"Commencer une quête.",d:"Parlez à {npc,1222::Maître Pifo} pour lancer une quête (les PNJ qui proposent des quêtes ont un point d\'exclamation au dessus de leur tête).",r:[5,null,[[10800,1]],null,null,null]};
Q.s[1043] = {n:"Parler à un pnj.",d:"Cliquez sur {npc,1222::Maître Pifo} avec le bouton gauche de votre souris et sélectionnez l\'action \"Parler\" pour dialoguer avec lui.",r:[5,null,[[10785,1]],null,null,null]};
Q.s[1046] = {n:"Déclencher un combat.",d:"Cliquez sur {monster,2785::Epouvantail d\'Incarnam} avec le bouton gauche de votre souris pour lancer un combat.",r:[5,null,[[10795,1]],null,null,null]};
Q.s[1057] = {n:"Une vie compliquée.",d:"Vous auriez dû suivre les conseils de Sel Dawa et vous méfier. A présent, il semblerait qu\'on veuille votre peau. Hélas, la vie n\'est pas aussi simple qu\'on voudrait le croire.",r:[null,null,null,null,null,null]};
Q.s[1058] = {n:"On en viendra tous à bout.",d:"Grâce à votre aide, Sel Dawa est en mesure d\'éradiquer le mal qui frappe le marché des boissons pandawas, à condition de trouver un antidote.",r:[3000,null,[[10818,1]],null,null,null]};
Q.s[1056] = {n:"La vie facile.",d:"A peine arrivé, on vous propose déjà un moyen de gagner votre vie facilement et sans trop d\'effort. Que demander de plus ?",r:[null,null,null,null,null,null]};
Q.s[1091] = {n:"Usine à jouets.",d:"D\'abominables créatures ont cambriolé l\'entrepôt du Père Nowel. Vous devez récupérer les caisses de cadeaux qu\'elles ont volées, avec ou sans leur consentement, et les apporter à Félix Nowel.",r:[null,1000,[[10920,1]],null,null,null]};
Q.s[1054] = {n:"Ne pas traduire",d:"Ne pas traduire ! Quête utilisée pour faire apparaître un point d\'exclamation en permanence au-dessus du PNJ Fée Risette.",r:[null,null,null,null,null,null]};
Q.s[996] = {n:"Se rendre au temple.",d:"Allez au temple de votre classe, profitez-en pour combattre le dopeul qui s\'y trouve.",r:[5000,null,null,null,null,null]};
Q.s[884] = {n:"Réengagez-vous, qu\'il disait.",d:"Snori Nairb a promis de partager ses kamas et son expérience avec vous si vous vous engagez dans la milice de Bonta.",r:[null,null,null,null,null,null]};
Q.s[64] = {n:"Je veux tout tout de suite",d:"Devenir le roi du monde",r:[500,1000,[[968,1],[948,5]],[11,10],[27,47],[453,3,437]]};
Q.s[65] = {n:"Je veux plus rien !",d:"Je veux moins d\'xp et moins de kamas",r:[null,null,null,null,null,null]};
Q.s[766] = {n:"L\'attaque bontarienne.",d:"Vous devez vous rendre au rempart Est et y vaincre les Bontariens.",r:[37000,null,null,null,null,null]};
Q.s[84] = {n:"Bien jolie cobaye",d:" ",r:[null,null,null,null,null,null]};
Q.s[82] = {n:"Un remède de Tabi",d:"  ",r:[null,null,null,null,null,null]};
Q.s[86] = {n:"Stabiliser le patient",d:" ",r:[null,null,null,null,null,null]};
Q.s[77] = {n:"Bien jolie cobaye",d:" ",r:[null,null,null,null,null,null]};
Q.s[83] = {n:"Stabiliser le patient",d:" ",r:[null,null,null,null,null,null]};
