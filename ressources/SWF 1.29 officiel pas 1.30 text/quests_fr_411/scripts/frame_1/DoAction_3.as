Q.s[323] = {n:"Bworkidais le paxifik",d:"Baston ou pas baston ?",r:[15000,null,null,null,null,null]};
Q.s[325] = {n:"A découper en suivant les pointillés",d:"Bworknroll a besoin de remplir sa créature d\'organes frais (et juteux).",r:[150000,null,null,null,null,null]};
Q.s[326] = {n:"Ne pas oublier l\'essentiel : la moule !",d:"Bworknroll a besoin d\'une moule qui sort de l\'eau pour finir sa créature de rêve.",r:[230000,5000,null,null,null,null]};
Q.s[324] = {n:"Un scalpel utile",d:"Bworknroll a besoin de morceaux pour composer sa compagne idéale.",r:[120000,null,null,null,null,null]};
Q.s[375] = {n:"Comme vous avez de grandes dents.",d:"Un Mulou vous fait une proposition alléchante.",r:[null,null,null,null,null,null]};
Q.s[376] = {n:"Inscription.",d:"Si Bworknroll accepte le paiement, Titi pourra devenir mage.",r:[null,null,null,null,null,null]};
Q.s[328] = {n:"Chaperonner Titi",d:"Le père de Titi aimerait qu\'il devienne mage. Pour cela, il faut l\'amener chez le plus puissant des Bworks Mages avec de quoi manger.",r:[null,null,null,null,null,null]};
Q.s[374] = {n:"Titi a sa bourse d\'étude.",d:"Bworknroll a accepté d\'enseigner la magie à Titi. Annoncer la nouvelle à son père.",r:[null,null,null,null,null,null]};
