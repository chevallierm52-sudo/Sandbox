Q.s[746] = {n:"La dèche d\'Oto.",d:"Oto n\'a plus un sou. Comment y remédier ?",r:[10000,null,null,null,null,null]};
Q.s[748] = {n:"Voler le Poumon.",d:"Oto veut que vous voliez le Poumon de la plaine à Azra Lazarus, la bijoutière. Il semble qu\'elle ait un garde, mais peut-être est-il possible d\'éviter de le combattre...",r:[11400,null,null,null,null,null]};
Q.s[758] = {n:"Trouver un Bontarien pas net.",d:"Vous devez trouver un Bontarien coupable d\'assassinat. Pour cela, il faut se procurer un bâton renifleur à Fryda, puis l\'essayer sur des Bontariens jusqu\'à en trouver un qui convienne.",r:[21000,null,null,null,null,null]};
Q.s[1094] = {n:"Gisgoul, ma patrie.",d:"L\'ambition des Brâkmariens n\'a pas de limite.",r:[null,null,null,null,null,null]};
Q.s[1096] = {n:"Mauvais plan.",d:"Allez semer des petits caillous blancs dans le labyrinthe du Dark vlad.",r:[null,null,null,null,null,null]};
Q.s[1095] = {n:"L\'Orc qui tu rie, te saluant.",d:"Faites les courses de Léthaline.",r:[null,null,null,null,null,null]};
Q.s[1097] = {n:"Goultard-Z",d:"Toutes les pièces sont placées, il faut porter le dernier coup.",r:[null,null,null,null,null,null]};
Q.s[1098] = {n:"Gisgoul, ma patrie.",d:"L\'ambition des Brâkmariens n\'a pas de limite.",r:[null,null,null,null,null,null]};
Q.s[1101] = {n:"Goultard-Z",d:"S\'échapper du traquenard Brâkmarien.",r:[null,null,null,null,null,null]};
Q.s[1099] = {n:"La théorie du chaos.",d:"Trouver la source du mal.",r:[null,null,null,null,null,null]};
Q.s[1100] = {n:"Mauvais plan.",d:"Contrecarrez les plans des Brâkmariens.",r:[null,null,null,null,null,null]};
Q.s[1103] = {n:"Certification.",d:"Allez voir l\'Alchimiste Examinateur, faisant actuellement des recherches sur le calcium du cartilage intranasal post-mortem.",r:[null,null,null,null,null,null]};
Q.s[1102] = {n:"Alch\'ti mi.",d:"Nibé Lulle vous a indiqué où trouver le chef des instructeurs pour commencer votre formation d\'alchimiste.",r:[null,null,null,null,null,null]};
Q.s[461] = {n:"Renseignements à la Bagrutte",d:"Le marchand de vin local a disparu. Le tavernier de la Bagrutte a peut-être des renseignements.",r:[null,null,null,null,null,null]};
Q.s[462] = {n:"Enquête à l\'Est.",d:"D\'après le tavernier Bagrutte, le marchand avait l\'habitude de rentrer chez lui, un peu plus à l\'Est.",r:[60000,null,null,null,null,null]};
Q.s[512] = {n:"Sufokia.",d:"Une rumeur affirme qu\'il existe une corne disposant de puissants pouvoirs magiques. Les habitants de Sufokia auraient des informations supplémentaires.",r:[null,null,null,null,null,null]};
Q.s[513] = {n:"Carapaces de tortue.",d:"Le tavernier du Ripate veut que vous lui apportiez des carapaces de tortue de Moon, une de chaque couleur, mais peut-être qu\'une grosse somme de Kamas pourrait les remplacer.",r:[null,null,null,null,null,null]};
Q.s[935] = {n:"Kokoboy.",d:"Mieux vaut être prévenant et acquérir un stock de Noix de Kokoko conséquent avant de retourner auprès d\'Amayiro.",r:[170000,null,null,null,null,null]};
Q.s[934] = {n:"Une corne à la mer.",d:"Selon le Tavernier du Ripate la corne se trouverait sur une île. Des érudits pourront sans doute vous renseigner davantage.",r:[null,null,null,null,null,null]};
Q.s[697] = {n:"Enquête sur la foire.",d:"Il faut chercher un formulaire auprès de Ture Inge, dans la milice, puis interroger le chef de la foire du Trool afin de détecter s\'il est un Brâkmarien ou non.",r:[8200,null,null,null,null,null]};
Q.s[171] = {n:"S\'évader c\'est la santé",d:"Apparemment, vous n\'êtes pas le bienvenu à Aerdala... saurez-vous échapper à votre destinée ? Il vaudrait mieux...",r:[10000,null,null,null,null,null]};
Q.s[169] = {n:"Zero Dofus",d:"Le messager du sage Lenald vous envoie à la lisière du village d\'Aerdala. Sur le chemin, vous méditez ses derniers mots : \"Plus d\'un aventurier s\'est fait mal accueillir en allant à Aerdala. On les dit alliés des Pandawas rebelles, ceux qui sabotent tous les accès de l\'île...\" ",r:[2000,null,null,null,null,null]};
Q.s[1041] = {n:"Miaou.",d:"Oshimo exige un chacha en échange de son secret pour accéder au Sanctuaire des Familiers.",r:[2500,null,null,null,null,null]};
Q.s[1141] = {n:"Tique psychodyslep.",d:"Wogew l\'hewmite pense qu\'Otomaï peut l\'aider dans ses recherches et vous envoie lui apporter des documents pour se faire.",r:[1020000,5000,[[11196,1]],null,null,null]};
Q.s[1140] = {n:"Thérapeutique.",d:"Vous devez trouver une solution à l\'invasion de tiques qui parasitent les boufmouths.",r:[null,null,null,null,null,null]};
Q.s[1119] = {n:"C\'est l\'heure de l\'apéwicube.",d:"Vous avez trouvé une Plume Vibrante de mansot, mais impossible de connaître son utilité. Heureusement, vous avez entendu certains pêcheurs en parler en citant Kyrie Lawache. Peut-être pourra-t-elle vous en dire plus.",r:[5000,null,[[11134,1]],null,null,null]};
Q.s[1127] = {n:"Graines des champs.",d:"Afin de créer des espèces de céréales plus résistantes au froid, Cassiopée Hisane vous a demandé de lui apporter plusieurs types de graines.",r:[510000,10000,[[11196,1]],null,null,null]};
Q.s[492] = {n:"Marteau et enclume.",d:"Oto Mustam pense que Bonta est aidée par un forgeron mercenaire. Vous devez chercher dans les ateliers de forgerons ou de mineurs pour trouver des indices.",r:[146000,null,null,null,null,null]};
Q.s[1128] = {n:"Pin ou baguette ?",d:"Cassioppée Hisane souhaite diversifier la production issue de la culture de céréales et a besoin de nouvelles variétés de graines.",r:[603000,20000,[[11196,1]],null,null,null]};
Q.s[1129] = {n:"Une santé de fer.",d:"Les mansots semblent plus résistants grâce à une alimentation riche en fer. Cassiopée Hisane vous a demandé d\'en massacrer plein pour récupérer leur réserve de graines.",r:[669000,30000,[[11196,2]],null,null,null]};
Q.s[1130] = {n:"Le sel de la terre.",d:"Le manque de sel a entraîné de nombreux cas d\'astrubisme chez les Frigostiens. Afin d\'endiguer ce fléau, Cassiopée Hisane veut essayer de cultiver des grains de sel dans une serre adaptée.",r:[null,null,null,null,null,null]};
Q.s[1131] = {n:"Altercations céréalières.",d:"Cassiopée Hisane veut croiser les frostizs avec les graines hades et hayes pour résister naturellement contre les parasites et les mauvaises herbes.",r:[null,null,null,null,null,null]};
Q.s[1132] = {n:"Renforcement génétique.",d:"Cassiopée Hisane veut des graines de basalte pour renforcer la résistance aux changements brusques de température des frotstizs, et des graines houilles pour les croiser avec des grains de sel.",r:[null,null,null,null,null,null]};
Q.s[1133] = {n:"",d:"",r:[null,null,null,null,null,null]};
Q.s[1158] = {n:"Champs boulet.",d:"Bisale Vinlenta a besoin de fleurs en grande quantité pour son projet alternatif à l\'agriculture.",r:[510000,10000,[[11196,1]],null,null,null]};
Q.s[1159] = {n:"S\'en aller, tout simplement.",d:"Bisale Vinlenta est à la recherche de plantes pré-glaciation pour faire des croisements.",r:[603000,20000,[[11196,1]],null,null,null]};
Q.s[1160] = {n:"La famille des rhubarbes à papa.",d:"Pour améliorer le goût des plantes, Bisale Vinlenta veut utiliser de la rhubarbe à papa, que seuls les mansots détiennent.",r:[669000,30000,[[11196,2]],null,null,null]};
Q.s[1197] = {n:"Marée basse.",d:"Pour donner un coup de main au médecin de Frigost, Bisale Vinlenta a besoin de 70  Saules en si.",r:[null,null,null,null,null,null]};
Q.s[1198] = {n:"Rose à lys, Rose à lys, ah !",d:"Bisale Vinlenta a besoin de nouvelles plantes qui poussent uniquement dans les larmes d\'Ouronigride.",r:[null,null,null,null,null,null]};
Q.s[1199] = {n:"Voyage au centre du tunnel.",d:"Pour anticiper une éventuelle période chaude, Bisale Vinlenta veut croiser les espèces de plantes actuelles avec celles des tunnels de lave.",r:[null,null,null,null,null,null]};
