Q.s[338] = {n:"Accorder le prétendant",d:"Gobrose et Gobmichet vont ils se réunir ?",r:[null,3000,null,null,null,null]};
Q.s[336] = {n:"Trouver la tanière de Bworkcine",d:"C\'est là qu\'est retenue Gobrose.",r:[1000,null,null,null,null,null]};
Q.s[354] = {n:"Combattre pour la garde.",d:"Le capitaine vous a confié une tâche simple mais utile.",r:[195,null,null,null,null,null]};
Q.s[345] = {n:"Relève de la garde",d:"Disskray vous a demandé d\'aller contrôler que les gardes font bien leur travail.",r:[230,null,null,null,null,null]};
Q.s[362] = {n:"Reprendre forme",d:"Aymé Tairnaile vous a transformé en fantôme, utilisez le phénix pour recouvrer vos forces.",r:[null,null,null,null,null,null]};
Q.s[363] = {n:"Osons l\'Osa !",d:"Cet Osa vaniteux mérite une bonne correction !",r:[500,null,[[8534,1]],null,null,null]};
Q.s[368] = {n:"Combattre pour la garde.",d:"Le capitaine vous a confié une tâche simple mais utile.",r:[195,null,null,null,null,null]};
Q.s[369] = {n:"Combattre pour la garde.",d:"Le capitaine vous a confié une tâche simple mais utile.",r:[195,null,null,null,null,null]};
Q.s[370] = {n:"Combattre pour la garde.",d:"Le capitaine vous a confié une tâche simple mais utile.",r:[195,null,null,null,null,null]};
Q.s[372] = {n:"Trouver de la ouache.",d:"Malgré un accent prononcé vous avez saisi la demande de Marylork.",r:[75,75,null,null,null,null]};
Q.s[373] = {n:"Lykhen radote",d:"Lykhen raconte sa vie d\'ancien aventurier.",r:[10,null,null,null,null,null]};
Q.s[385] = {n:"Trouver le repaire des Roublards.",d:"Yse Vewybad vous a donné des indications sur la position des Roublards. Allez donc voir du côté du cimetière.",r:[9000,null,null,null,null,null]};
Q.s[384] = {n:"Trouver le Sram.",d:"Yse Vewybad vous a parlé d\'un Sram important en Amakna... Où trouve-t-on des Srams en Amakna?",r:[1000,null,null,null,null,null]};
Q.s[394] = {n:"Trouver le prétendant.",d:"Il vous faut trouver un prétendant pour Allisteria, la fille du frère du roi.",r:[15000,null,null,null,null,null]};
Q.s[395] = {n:"A la pêche aux infos.",d:"Vil Smisse veut que vous recueillez des renseignements sur ce qui se prépare au château. Il faut donc trouver la personne qui saura vous dire ça.",r:[3000,null,null,null,null,null]};
Q.s[396] = {n:"Chercher la petite bête.",d:"Maintenant, vous savez que le roi doit marier sa nièce... mais avec qui?",r:[12000,null,null,null,null,null]};
Q.s[402] = {n:"Fausse identité",d:"Comme vous pouvez le voir, Uba Tessé vous a transformé en Wabbit. Il n\'y a plus qu\'à aller voir au château si vous pouvez faire capoter ce mariage.",r:[50000,25000,null,null,null,null]};
Q.s[401] = {n:"Après la recette, les ingrédients.",d:"Maintenant qu\'Uba a la formule, il ne lui manque plus que les ingrédients.",r:[25000,null,null,null,null,null]};
Q.s[400] = {n:"Et une formule, une!",d:"Vous devez retrouver des alchimistes disséminés en Amakna.",r:[15000,null,null,null,null,null]};
Q.s[399] = {n:"Wabbit powa",d:"Trouver un moyen de se tranformer en Wabbit.",r:[10000,null,null,null,null,null]};
Q.s[404] = {n:"Gavage",d:"Vous avez l\'oeuf de Tofu obèse, mais un oeuf ne va pas faire grand mal au pwince... Il faut trouver de quoi gaver l\'oisillon à naître.",r:[40000,null,null,null,null,null]};
Q.s[403] = {n:"Un oeuf tout neuf",d:"Vil Smisse vous a demandé de lui rapporter un oeuf de tofu obèse. Encore faut-il trouver le nid...",r:[5000,null,null,null,null,null]};
Q.s[406] = {n:"Tueurs à gage à engager",d:"Vil Smisse ne pourra utiliser le blopisier empoisonné. Il se rabat donc sur l\'attaque de front. Pour cela, il veut engager des assassins, il a donc besoin d\'argent.",r:[76000,null,null,null,null,null]};
Q.s[405] = {n:"Un cadeau empoisonné",d:"Vil Smisse a décidé d\'éviter l\'approche directe et de faire les choses plus à la façon traditionnelle des Roublards - sournoisement.",r:[10000,null,null,null,null,null]};
Q.s[407] = {n:"Trouble-fête",d:"Les assassins ont échoué à tuer le prince... Vil Smisse vous demande d\'aller engager un Lenald pour le trucider.",r:[140000,null,null,null,null,null]};
Q.s[408] = {n:"Sus au tofu!",d:"Vous savez où le pwince d\'Wa est parti chasser, enfin à peu près... c\'est au sud de Bonta en tout cas. Reste à trouver ce fameux pwince.",r:[100000,null,null,null,null,null]};
Q.s[381] = {n:"Au travail",d:"Allez demander au contremaître ce que vous devez faire.",r:[250,250,null,null,null,null]};
Q.s[414] = {n:"Servir ou rendre service?",d:"L\'intendant San Lavalss vous demande d\'aider aux derniers préparatifs du mariage.",r:[86000,null,null,null,null,null]};
Q.s[418] = {n:"1er étape",d:"test",r:[null,null,[[8359,10],[376,10],[8141,10],[8141,10],[2087,10]],null,null,null]};
Q.s[420] = {n:"Un déguisement pour Emeraude",d:"Emeraude cherche désespérément une panoplie Koalak.",r:[null,null,null,null,null,null]};
Q.s[421] = {n:"Répondre au questionnaire",d:"Le Gardien du Pont de la Mort exige que vous répondiez correctement à ses questions.",r:[30000,null,null,null,null,null]};
Q.s[422] = {n:"Bien préparer son voyage",d:"Le Capitaine Kradoc a besoin que vous lui rapportiez plusieurs objets pour qu\'il puisse vous emmener dans son bateau.",r:[30000,null,null,null,null,null]};
Q.s[423] = {n:"Le Coffret Maudit du Flib",d:"Le bateau du Capitaine Kradoc s\'est lamentablement échoué sur l\'île des naufragés. Vous devez retrouver le Coffret Maudit du Flib et quelques objets pour réparer le bateau.",r:[30000,2500,null,null,null,null]};
Q.s[424] = {n:"Vous ne passerez pas !",d:"Le Chevalier Noir et Rose est fermement décidé à ne pas vous laisser passer. C\'est peut-être le bon moment d\'employer la force.",r:[45000,null,null,null,null,null]};
Q.s[425] = {n:"Une potion pour le professeur",d:"Le Professeur Fournesol a besoin d\'une Potion Bulbique pour se remettre au travail.",r:[30000,1000,null,null,null,null]};
Q.s[426] = {n:"Les machines d\'élevage",d:"Polka Merer a besoin de machines d\'élevage pour ses créatures.",r:[30000,2000,null,null,null,null]};
Q.s[427] = {n:"Une histoire de farines",d:"Paulette Pain-bèche la boulangère a l\'intention de recouper sa farine de Xavier le Boulanger avec différentes farines bon marché. Elle a eu l\'idée, à vous de trouver les farines !",r:[30000,1500,null,null,null,null]};
Q.s[428] = {n:"A la recherche du fils caché",d:"Le Docteur Nauh a perdu son fils dans un laboratoire infesté de terribles créatures sauvages. Vous devez le retrouver et vous assurer qu\'il est encore en vie !",r:[30000,1000,null,null,null,null]};
Q.s[429] = {n:"Le docteur est morose",d:"Le pauvre Docteur Morose a perdu sa femme. Aidez-le à la trouver dans la Jungle Sombre et tentez de la persuader à retrouver son mari pour qu\'il puisse reprendre ses recherches.",r:[30000,1000,null,null,null,null]};
Q.s[430] = {n:"L\'équipement amélioré",d:"Spitte Fayeur recherche un casque et une cape de pilote améliorés. Seul un tailleur expérimenté pourra vous aider.",r:[30000,4000,null,null,null,null]};
Q.s[431] = {n:"Deux Dragodindes pour Flip Flap",d:"Flip Flap voudrait que vous lui rameniez un certificat de Dragodinde Rousse ainsi qu\'un certificat de Dragodinde Amande.",r:[30000,30000,null,null,null,null]};
Q.s[435] = {n:"Chasse dans la Jungle Sombre",d:"Crocodaille Dandi aimerait que vous chassiez pour lui quelques créatures de la Jungle Sombre.",r:[250000,null,null,null,null,null]};
Q.s[433] = {n:"Chasse dans les Plaines",d:"Crocodaille Dandi aimerait que vous chassiez pour lui plusieurs créatures des Plaines.",r:[150000,null,null,null,null,null]};
Q.s[432] = {n:"Chasse sur la plage",d:"Crocodaille Dandi aimerait que vous éliminiez certaines créatures sur la plage de Corail.",r:[50000,null,null,null,null,null]};
Q.s[436] = {n:"Chasse dans l\'Arbre Hakam",d:"Crocodaille Dandi aimerait que vous chassiez pour lui quelques créatures de l\'Arbre Hakam.",r:[500000,null,null,null,null,null]};
Q.s[434] = {n:"Chasse dans la Tourbière sans fond",d:"Crocodaille Dandi aimerait que vous chassiez pour lui quelques créatures de la Tourbière sans Fond.",r:[250000,null,null,null,null,null]};
Q.s[437] = {n:"Un exemple pour les Pirates",d:"Kito vous a demandé de faire un exemple pour les Pirates qui lui lancent des boulets.",r:[30000,1000,null,null,null,null]};
Q.s[438] = {n:"Le Chevalier Noir et Rose",d:"Peggy la Porkass aimerait que vous affrontiez le terrible Chevalier Noir et Rose à sa place.",r:[30000,2000,null,null,null,null]};
Q.s[440] = {n:"L\'échange maudit",d:"Farle Ingalsse est sûrement la seule personne d\'Amakna capable de rendre utilisable cette épée maudite...",r:[null,null,[[8992,1]],null,null,null]};
Q.s[456] = {n:"Vite, vite !",d:"Milone serait apparemment sur le point d\'être cambriolé. Il faut vite aller empêcher cela.",r:[null,null,null,null,null,null]};
Q.s[469] = {n:"Mauvais hameçon ?",d:"Le voyage s\'est passé sans encombre. Les bandits n\'ont pas attaqué... Amayiro attend votre rapport.",r:[75000,null,null,null,null,null]};
Q.s[468] = {n:"Piège pour Ecaflips.",d:"Amayiro veut tendre une embuscade aux bandits, pour cela il a besoin d\'un bijou de grande valeur afin de les attirer dans son piège.",r:[null,null,null,null,null,null]};
Q.s[466] = {n:"Escorte Gueurle.",d:"Votre mission est d\'escorter la troupe de marchands de Gueurle jusqu\'à Astrub.",r:[null,null,null,null,null,null]};
Q.s[470] = {n:"Au rapport.",d:"Le convoi a été attaqué par des bandits Ecaflips semblables à ceux dont vous avez découvert le campement. Amayiro attend votre rapport pour convaincre le conseil d\'agir.",r:[null,null,null,null,null,null]};
Q.s[473] = {n:"Une bonne Rigalade",d:"Rigal Main Crochue, au temple Sram, est réputé pour détenir de nombreuses informations, mais toute information à un prix. Reste à savoir à combien s\'élève la vôtre.",r:[null,null,null,null,null,null]};
Q.s[474] = {n:"Il est frais mon poison.",d:"Vous devez trouver les réserves de poison de Brâkmar et dérober le registre des clients de l\'atelier des alchimistes. Bishom Pot pourra peut-être vous aider.",r:[null,null,null,null,null,null]};
Q.s[923] = {n:"L\'alchimie pour les nuls.",d:"Vous devez voler le registre des clients dans l\'atelier des alchimistes de Brâkmar et l\'apporter à Rigal Main Crochue.",r:[90000,null,null,null,null,null]};
Q.s[922] = {n:"Complicité accrue.",d:"Afin de pénétrer dans les réserves de poison de Brâkmar, vous aurez besoin des services d\'un Sram ou d\'un espion qualifié.",r:[null,null,null,null,null,null]};
Q.s[478] = {n:"Attrape-nigaud.",d:"Un rendez-vous entre un Brâkmarien et le Bontarien corrompu va avoir lieu à la tour de Bonta. Il faut les capturer tous les deux si possible.",r:[105000,null,null,null,null,null]};
Q.s[925] = {n:"Pas d\'issue pour les traîtres.",d:"Vous devez faire le tour des miliciens pour les poster à la Tour de Bonta.",r:[null,null,null,null,null,null]};
Q.s[930] = {n:"Bwork, quelle odeur !",d:"Soit Epuop Tik n\'en sait pas plus, soit il refuse de vous en dire davantage. Quoiqu\'il en soit, les bworks mages devraient être moins réticents à vous informer sur l\'un des leurs.",r:[null,null,null,null,null,null]};
Q.s[504] = {n:"Danathor, qu\'est-ce que tu nous mijotes encore ?",d:"Danathor semble avoir une nouvelle offre à vous faire. Probablement quelque chose de louche.",r:[null,null,null,null,null,null]};
Q.s[932] = {n:"La poupée enchantée.",d:"Vous devez trouver quatre Sadidas, suffisamment expérimentés pour invoquer des Gonflables, pour un rituel dans les eaux enchantées des lacs Koalaks.",r:[146000,null,null,null,null,null]};
Q.s[931] = {n:"Génialissime.",d:"Si vous levez la malédiction pesant sur Jibworknouille, il vous divulguera sûrement ce qu\'il sait en signe de reconnaissance. Il a suggéré de se renseigner dans une bibliothèque.",r:[null,null,null,null,null,null]};
Q.s[794] = {n:"A la recherche du greffier attristé.",d:"Aigurraf, Greffier de l\'Ordre de l\'Œil Attentif, écume les tavernes depuis la disparition de sa souris. Il faut le ramener auprès d\'Ebru Of El.",r:[null,null,null,null,null,null]};
Q.s[767] = {n:"Sortie de prison.",d:"Vous devez sauver un guerrier qui a été capturé par Bonta : il se trouve dans la prison de la milice bontarienne, au sous-sol.",r:[40000,null,null,null,null,null]};
Q.s[951] = {n:"Ennemi intime.",d:"Trouver et éliminer votre cible.",r:[null,null,null,null,null,null]};
Q.s[1051] = {n:"Gagner le combat.",d:"Continuez d\'attaquer votre cible pour gagner le combat. Passez votre tour grâce au bouton {ui,banner,btn_skipTurn::fin de tour} lorsque vous voulez regagner vos {ui,banner,lbl_pa,2::PA} et vos {ui,banner,lbl_pm,2::PM}.",r:[5,null,[[10784,1]],null,null,null]};
Q.s[1061] = {n:"Terminer le combat.",d:"Gagnez votre combat contre le monstre. Attention, les tours de jeu ont désormais une durée limitée. La {ui,banner,tx_artwork,3::jauge de temps restant} indique combien de temps il vous reste avant que votre tour ne se termine.",r:[null,null,null,null,null,null]};
