Q.s[1143] = {n:"Le glouglou qui fait glagla.",d:"Jean-Pierre Kofkof est intervenu après la dispute entre Valy Domidat et une étrangère. Il a peut-être remarqué quelque chose d\'inhabituel.",r:[340000,5000,[[11196,1]],null,null,null]};
Q.s[1142] = {n:"Problème de tuyauterie.",d:"Valy Domidat, la bricoleuse en chef, a disparu en allant réparer la tuyauterie de l\'atelier des paysans. Francky, son employé, vous a demandé de la retrouver.",r:[null,null,null,null,null,null]};
Q.s[1145] = {n:"Quatre fantastiques retour en ville.",d:"Vous avez trouvé les rescapés, victimes d\'un étrange maléfice. Vous devez les escorter en ville, un par un.",r:[603000,10000,[[11196,1]],null,null,null]};
Q.s[1144] = {n:"Fantastique ballade en forêt.",d:"Plusieurs Frigostiens employés par le Chef Rhonté ont disparu dans la forêt des pins perdus. Vous devez découvrir ce qui leur est arrivé.",r:[null,null,null,null,null,null]};
Q.s[1146] = {n:"Mauvais chasseur.",d:"Le chasseur Gérard a disparu. Clyde Parker, le chef de la milice, vous a chargé de le retrouver.",r:[669000,15000,[[11196,2]],null,null,null]};
Q.s[1169] = {n:"Il rêvait d\'un long voyage sur un bateau.",d:"Lafairé Danlsak a accepté de vous révéler l\'emplacement de son butin si vous réussissez à libérer son âme.",r:[null,null,[[11196,2]],null,null,null]};
Q.s[1168] = {n:"Il se laisse aller sur les flots.",d:"Germain Danlsak souhaite savoir où son défunt père a caché son butin.",r:[null,null,null,null,null,null]};
Q.s[1156] = {n:"Un dopeul inoffensif.",d:"Cette peluche Féca doit bien appartenir à quelqu\'un, mais qui ?",r:[170000,null,[[11196,1]],null,null,null]};
Q.s[1200] = {n:"Centrale à vapeur.",d:"Le naturaliste Pleni l\'Ancien est porté disparu dans les larmes d\'Ouronigride. A la demande de son neveu, Pleni le Jeune, Hyppolite Tairmy vous a engagé pour le retrouver.",r:[null,null,null,null,null,null]};
