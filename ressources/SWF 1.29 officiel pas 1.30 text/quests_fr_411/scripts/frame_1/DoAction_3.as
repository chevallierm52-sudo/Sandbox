Q.s[1126] = {n:"Le peuple migrateur.",d:"Le Capitaine Ardier vous a proposé une magnifique croisière sur son authentique navire pour aller visiter la lointaine île de Frigost.",r:[34000,null,null,null,null,null]};
Q.s[1124] = {n:"La maire m\'aide.",d:"Le mousse Haka vous a indiqué où trouver la mairesse, qui pourra vous renseigner sur la bourgade de Frigost et ses habitants.",r:[17000,null,null,null,null,null]};
Q.s[1125] = {n:"Site de rencontre.",d:"Afin de vous familiariser avec la bourgade, la maire Cantile vous a demandé de rencontrer plusieurs personnalités de Frigost.",r:[170000,null,null,null,null,null]};
Q.s[1139] = {n:"Affronter La Bête.",d:"Vous devez réussir à prélever un échantillon de sang sur le cobaye d\'Albert Paisse.",r:[340000,null,[[11198,1]],null,null,null]};
Q.s[1138] = {n:"Susceptibilité à fleur de peau.",d:"Albert Paisse a besoin d\'eau de mer isotonique. Seul le Capitaine Gneux sait comment s\'en procurer.",r:[null,null,null,null,null,null]};
Q.s[1137] = {n:"Rube Eole.",d:"Vous devez apporter à Albert Paisse des échantillons de sang de boufmouth malade.",r:[null,null,null,null,null,null]};
