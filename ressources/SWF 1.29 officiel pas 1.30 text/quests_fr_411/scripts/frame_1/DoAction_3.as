Q.s[7] = {n:"De la boubouffe",d:"Se renseigner sur la nourriture d\'un Chacha moyen auprès de ceux que vous rencontrez. Et ramenez un peu de nourriture à ce Chacha.",r:[1220,null,null,null,null,null]};
Q.s[9] = {n:"Chacha héros ?",d:"Trouver ce qui fera de ce frêle Chacha un héros auprès de sa compagne.",r:[3060,null,null,null,null,null]};
Q.s[6] = {n:"Du lailait pour un chacha",d:"Apporter du lailait pour le chacha malheureux",r:[1220,null,null,null,null,null]};
Q.s[8] = {n:"Promenade chacrée",d:"Promener le Chacha dans la ville",r:[1500,null,null,null,null,null]};
Q.s[13] = {n:"Anneau cédé",d:"Shani vous a donné un anneau possédant des pouvoirs latants. Pour les réveiller il va falloir aller tuer un abraknyde.",r:[11000,1200,[[6793,1]],null,null,null]};
Q.s[12] = {n:"Un peu de piquant",d:"Shani a oublié de prévoir assez d\'épines de champ champ pour l\'épreuve de demain. Allez en récuperer.",r:[2600,250,null,null,null,null]};
Q.s[11] = {n:"Recyclage d\'eau puante",d:"Rapporter de la bave de bouftou à Shani Sings",r:[1700,200,null,null,null,null]};
Q.s[10] = {n:"Une amulette velue ?",d:"Rapporter des pattes d\'arakne à la bijoutière, elles sont nécessaires à la fabrication d\'une amulette.",r:[1700,null,[[6773,1]],null,null,null]};
Q.s[24] = {n:"Pickpocket",d:"Trouvez un moyen de vous procurer le rapport d\'espion et apportez-le à Ztiv Oztin.",r:[1200,null,[[6784,1]],null,null,null]};
Q.s[22] = {n:"L\'espion qui valait 3 kamas",d:"Trouvez Ztiv Oztin et proposez lui vos services...",r:[1200,null,null,null,null,null]};
Q.s[20] = {n:"Discrétion assurée",d:"Trouvez Ogivol Scalarcin, vous devriez trouver l\'entrée de son repère grâce à une trappe dérobée dans le sol du dépôt de bois.",r:[600,null,null,null,null,null]};
Q.s[121] = {n:"Trouver et escorter le hors-la-loi",d:"Il est probable que Padgref Demoël se trouve dans le Nord Ouest des plaines de Cania, du côté du bois de Litneg. \nIl est condamné à l\'emprisonnement à Astrub pour détérioration de Bouftou domestique et tapage nocturne. \n",r:[null,84500,null,null,null,null]};
Q.s[26] = {n:"Recherche Jambes rapides",d:"Le Boulanger a besoin de livrer 4 personnes dans l\'urgence. Aller déposer les gâteaux chez chacun le plus vite possible.",r:[1000,null,null,null,null,null]};
Q.s[29] = {n:"A la recherche du nouveau livreur",d:"Trouver une personne à la fois forte et agile pour prendre la place de nouveau livreur.",r:[2000,250,null,null,null,null]};
Q.s[28] = {n:"Un livreur dragueur",d:"Vérifier si le livreur : Louc Drif, est réellement malade.",r:[2000,500,null,null,null,null]};
Q.s[30] = {n:"Une derniere livraison",d:"Aller livrer le gâteau à grand-mère",r:[5000,null,null,null,null,null]};
Q.s[103] = {n:"La maison de Nycheuz",d:"Pleur Nycheuz a oublié où se situe sa maison, terrorisée, elle n\'ose plus s\'aventurer seule en ville...",r:[5750,250,null,null,null,null]};
Q.s[33] = {n:"Le bouquet de lin",d:"Il faut récuperer des fleurs de Lin pour la mère de Pleur Nycheuz. Seul les alchimistes peuvent cueillir ces fleurs...",r:[2000,200,null,null,null,null]};
Q.s[31] = {n:"Les bandits manchots",d:"Le campement des bandits manchots se situe au nord de la forêt d\'Astrub, la peluche se trouve certainement sur l\'un des bandits du camp...",r:[2000,null,null,null,null,null]};
Q.s[37] = {n:"En garde Homme Ours ",d:"D\'après Abrazelon il faut attaquer l\'homme Ours à plusieurs pour être sûr qu\'il utilise son manuscrit en combat. Il faut ensuite lui rapporter pour qu\'il l\'authentifie.",r:[9000,2500,null,null,null,null]};
Q.s[35] = {n:"Compte rendu Osamodas",d:"Abrazelon Sixgriffe a parlé de l\'homme Ours, capable de controler des créatures trés puissantes. Avant de se mettre à sa poursuite, il faudrait avertir Menge Paca de vos découvertes...",r:[3000,null,null,null,null,null]};
Q.s[34] = {n:"La bête poilue",d:"Le berger Menge Paca a des ennuis avec une bête poilue, il cherche donc quelqu\'un capable d\'en savoir plus sur cette créature...",r:[750,null,null,null,null,null]};
Q.s[36] = {n:"Sur la piste de l\'Ours",d:"Il faut suivre les traces de pas de l\'ours et trouver sa tanière...",r:[3000,null,null,null,null,null]};
Q.s[53] = {n:"Doublure puante",d:"Alit vous conseille de rajouter une doublure à votre cape. Mais pour cela il vous faut lui ramener de la laine de bouftou.",r:[3500,null,[[6801,1]],null,null,null]};
Q.s[54] = {n:"Tout ça pour un cache oreille !",d:"Ramener les matériaux nécessaires à la confection d\'un cache oreille. Certains vont être durs à avoir, il faudra peut-être demander de l\'aide.",r:[11000,500,[[6802,1]],null,null,null]};
Q.s[52] = {n:"Besoin de laine",d:"Le tailleur Alit a besoin de laine de boufton blanc et noir. Si vous lui apportez il vous fera probablement quelque chose de sur-mesure",r:[2500,null,[[6800,1]],null,null,null]};
Q.s[49] = {n:"Besoin de renforts",d:"Allez chercher de l\'aide auprès des Féca et Eniripsa",r:[1200,null,null,null,null,null]};
Q.s[51] = {n:"Besoin d\'une pelle",d:"Retournez faire votre rapport à Joe pour obtenir votre récompense.",r:[1200,null,[[6786,1]],null,null,null]};
Q.s[45] = {n:"Besoin de main-d\'oeuvre",d:"Trouvez Howard le Simaisrien et remettez-lui la lettre de Joe Pierlivet.",r:[600,null,null,null,null,null]};
Q.s[55] = {n:"Le sang du wabbit GM",d:" ",r:[null,null,null,null,null,null]};
Q.s[57] = {n:"Analyse de sang",d:" ",r:[null,null,null,null,null,null]};
Q.s[58] = {n:"Wogew Wabbit",d:" ",r:[null,null,null,null,null,null]};
Q.s[76] = {n:"La nécessité de savoir s\'en servir",d:"Apprenez le maniement de votre nouvelle arme en attaquant quelques insectes.",r:[900,null,null,null,null,null]};
Q.s[67] = {n:"Comment forger une épée\' pour les nuls",d:"Vous avez besoin d\'un forgeron pour créer une épée.",r:[null,null,null,null,null,null]};
Q.s[68] = {n:"L\'utilité d\'une bonne poignée d\'épée",d:"Trouvez une poignée afin de faire forger votre épée.",r:[1200,null,null,null,null,null]};
Q.s[69] = {n:"L\'importance des finitions",d:"Apportez l\'épée fraîchement forgée à votre maître.",r:[900,null,[[6780,1]],null,null,null]};
Q.s[63] = {n:"... doute !",d:"Rapporter l\'épée à votre maître de guilde. Il vous y apposera la marque de votre classe.",r:[1200,null,null,null,null,null]};
Q.s[61] = {n:"Un métal douteux",d:"Apporter le sac de kamas douteux à une personne qui pourra en tirer quelque chose d\'intéressant.",r:[600,null,null,null,null,null]};
Q.s[62] = {n:"Affinement douteux",d:"Transformer votre métal douteux.",r:[1200,null,null,null,null,null]};
Q.s[72] = {n:"Voleur de coeur",d:"Les petits cailloux proviennent des alentours des mines au nord-est du village. Trouvez-y le coffre de Louc.",r:[4000,null,null,null,null,null]};
Q.s[150] = {n:"La récompense",d:"Allez chercher votre récompense chez Louc Drif.",r:[5000,null,[[1519,1]],null,null,null]};
Q.s[71] = {n:"A la recherche des petits cailloux",d:"Examiner les petits cailloux pour les comparer à ceux trouvés chez Louc. Pour cela rendez-vous sur les différents lieux suspects.",r:[1500,250,null,null,null,null]};
Q.s[70] = {n:"Echange metaria contre rendez-vous",d:"Louc doit résoudre son problème de coffre et se préparer en même temps pour son premier rendez-vous. Allez lui chercher deux roses, une pour chaque fille.",r:[1500,500,null,null,null,null]};
Q.s[73] = {n:"Cours Forest !",d:"Vous aimez les enfants ? Celui-ci vous allez le détester...",r:[600,50,null,null,null,null]};
Q.s[75] = {n:"Arc-Crâ-Daba-Gras",d:"Ha comme c\'est beau de faire fabriquer son premier arc.",r:[1200,null,[[6783,1]],null,null,null]};
Q.s[78] = {n:"Crâtastrophe",d:"Vous allez maintenant apprendre à tirer à l\'arc.",r:[1200,null,null,null,null,null]};
Q.s[119] = {n:"Trouver la hors-la-loi",d:"Certains disent avoir vu Frakacia Leukocytine du côté du village des Bandits Manchots. \nElle est recherchée pour ponctions illégales d\'Hémoglobine. \nCondamnée à l\'emprisonnement à Astrub. \n",r:[null,2000,null,null,null,null]};
Q.s[116] = {n:"Trouver le hors-la-loi",d:"Certains disent avoir vu Nervoes Brakdoun du côté de la forêt des Abraknydes \nRecherché pour vol de bijouterie \nCondamné à l\'emprisonnement à Astrub \n",r:[null,12005,null,null,null,null]};
Q.s[113] = {n:"Trouver le hors-la-loi",d:"Certains disent l\'avoir vu du côté des Landes de Sidimote. Il est recherché pour insoumission à l\'ordre cosmique. \nBrumen Tinctorias est condamné à l\'emprisonnement à Astrub. \n",r:[null,33600,null,null,null,null]};
Q.s[111] = {n:"Trouver le hors-la-loi",d:"Fouduglen parcourt la ville d\'Astrub à la recherche des glands succulents à se mettre sous la dent.",r:[null,245,null,null,null,null]};
Q.s[109] = {n:"Trouver le hors-la-loi",d:"Ogivol a été aperçu du côté de Brâkmar. Il est recherché pour avoir dérobé une foultitude de choses, et notamment des documents secrets. \nIl est condamné à l\'emprisonnement à Astrub. \n",r:[null,32000,null,null,null,null]};
Q.s[87] = {n:"Escorte de Mélange",d:"Tek Abir, le tavernier du village, est obligé de couper sa bière avec de l\'eau car on lui vole la sienne. Trouvez le livreur au sud-Ouest en longeant la route puis escortez-le.",r:[2000,500,null,null,null,null]};
Q.s[88] = {n:"Une fin pour l\'oppression ?",d:"Mettre un terme au vol de bière",r:[4000,3000,null,null,null,null]};
Q.s[90] = {n:"Kit de vision",d:"Récupérer différentes ressources pour aider Montrakwartz à voir l\'avenir",r:[600,null,null,null,null,null]};
Q.s[92] = {n:"L\'avenir ça fait pas rire !",d:"Montrakwartz vous en apprend plus sur votre avenir proche. ",r:[1200,null,null,null,null,null]};
Q.s[91] = {n:"Le futur c\'est l\'aventure !",d:"Montrakwartz a besoin d\'une peau de larve bleu pour terminer sa machine.",r:[1200,null,null,null,null,null]};
Q.s[94] = {n:"Livraison",d:"Apportez le remède que vous avez obtenu à Clint Pot. Pour soigner les Tofus ou les Enutrofs, je n\'ai pas bien compris. N\'oubliez pas de faire un rapport à votre maître de guilde.",r:[1800,null,[[6785,1]],null,null,null]};
Q.s[93] = {n:"Suborhube...",d:"Aidez votre maître de guilde à trouver un remède pour soigner ses Tofus.",r:[1200,null,[[6849,1]],null,null,null]};
Q.s[106] = {n:"Première salle",d:"Trouver comment se servir des trois Dofus",r:[null,null,null,null,null,null]};
Q.s[107] = {n:"Deuxième Salle",d:"Trouver la clef",r:[null,null,null,null,null,null]};
Q.s[131] = {n:"Tac Tic !",d:"...",r:[2500,20,null,null,null,null]};
Q.s[145] = {n:"... de ciseaux",d:"Avec les ciseaux tout neufs que vous avez récuperer, c\'est Phite qui va etre contente !",r:[1750,null,null,null,null,null]};
Q.s[133] = {n:"Une belle paire...",d:"Phite Pouque cherche des ciseaux forgés, elle conseille d\'aller voir le forgeron de l\'hotel des ventes pour lui en acheter...",r:[2000,null,null,null,null,null]};
Q.s[134] = {n:"Des cheveux... toujours des cheveux...",d:"Phite cherche à récupérer la totalité des types de cheveux des habitants d\'Astrub, pour en faire des postiches.",r:[3000,150,null,null,null,null]};
Q.s[135] = {n:"Un début de piste",d:"Les Enutrofs partis à la recherche des ranifftous se sont  probablement égarés loin dans les profondeurs des galeries. Les lieux sont infestés de milirats d\'égoutants...",r:[4000,null,null,null,null,null]};
Q.s[146] = {n:"Un tien vaut mieux que 2 pods de rat",d:"Débarrassez-vous de ce Rat d\'égoutant... il a l\'air malade, ça ne devrait pas être trop compliqué... enfin, à plusieurs quoi.",r:[8000,null,null,null,null,null]};
Q.s[139] = {n:"Le début de la fortune",d:"Collecter 10 pattes d\'Araknées pour le compte de Ant Emicheun. Ou pour le votre... qui sait ? En tout cas, ça semble rentable.",r:[1000,400,null,null,null,null]};
Q.s[140] = {n:"Plumes malades",d:"Avec vingt plumes, on doit pouvoir faire un plumeau. Ceci dit, vu les plumes...",r:[1000,50,null,null,null,null]};
Q.s[148] = {n:"Récompense méritée",d:"Reparler à grand mère et lui montrer la tête de sousouris.",r:[40,30,null,null,null,null]};
Q.s[147] = {n:"La cave infestée",d:"Aller dans la cave de grand-mère et exterminer la menace.",r:[10,null,null,null,null,null]};
Q.s[679] = {n:"Battre le milicien.",d:"Vous devez battre Tarche le milicien, dans la salle à côté.",r:[50,null,null,null,null,null]};
Q.s[681] = {n:"Donner des pains.",d:"Vous devez apporter 20 pains au blé complet à Amayiro.",r:[250,null,null,null,null,null]};
Q.s[682] = {n:"Les dents de Bouftou.",d:"Vous devez arracher des dents de Bouftous, exactement le nombre constituant un dentier humain, et les amener à Ned, au sud-ouest de la ville.",r:[500,null,null,null,null,null]};
Q.s[683] = {n:"Une tatanne pour le frérot.",d:"Vous devez battre le milicien Torche et ramener une preuve à Amayiro.",r:[1000,null,null,null,null,null]};
Q.s[685] = {n:"Retrouver le Corbac.",d:"Vous devez retrouver le Corbac qui a volé le collier de la fille du maire, le battre et récupérer le collier. Le Corbac serait vers la tour.",r:[2000,null,null,null,null,null]};
Q.s[688] = {n:"Chasse au sanglier.",d:"Vous devez trouver le sanglier agressif au sud de Bonta et le battre.",r:[3500,null,null,null,null,null]};
Q.s[691] = {n:"La réparation du katana.",d:"Vous devez demander à Kosuke le forgeron de réparer la lame d\'Amayiro en échange du chèque.",r:[4600,null,null,null,null,null]};
Q.s[690] = {n:"Tabasser le mauvais payeur.",d:"Le tavernier Tabasse doit une forte somme à Amayiro : vous devez le convaincre par tous les moyens de la payer.",r:[null,null,null,null,null,null]};
Q.s[692] = {n:"Communiquer avec l\'espion.",d:"Vous devez trouver Bishom Pot dans Brâkmar et lui soutirer les informations qu\'Amayiro a demandées.",r:[5200,null,null,null,null,null]};
Q.s[694] = {n:"Colmater la brèche.",d:"Shere Hacanon, à l\'entrée de Bonta, a besoin de quatre pierres de Craqueleur des plaines pour colmater la brèche des murailles.",r:[6400,null,null,null,null,null]};
Q.s[696] = {n:"Collection de casques.",d:"Vous devez amener 15 casques de Chafers d\'Elite à Amayiro.",r:[7600,null,null,null,null,null]};
Q.s[698] = {n:"De la bouillie pour le Tabi.",d:"Apporter de la bouillie de fleurs de blops à Amayiro. Pour obtenir cette bouillie, il faut concasser quatre fleurs de blops de couleurs différentes dans un Concasseur Munster.",r:[8800,null,null,null,null,null]};
Q.s[700] = {n:"De l\'agilité pour Amayiro.",d:"Amayiro vous a demandé vingt anneaux d\'agilité.",r:[10000,null,null,null,null,null]};
Q.s[702] = {n:"Amener les capes.",d:"Amayiro vous a demandé d\'apporter 10 capes bontariennes au capitaine Koda, à côté. Elles se confectionnent avec une teinture magique bleue, une plume de corbac et une laine de boufton blanc.",r:[11400,null,null,null,null,null]};
Q.s[705] = {n:"21 heures.",d:"Danathor vous a demandé de le retrouver à 21 heures avec les ingrédients indiqués sur sa liste.",r:[13500,null,null,null,null,null]};
Q.s[708] = {n:"De la viande pour le cuisinier.",d:"Le cuisinier de la milice de Bonta, Rei Nisuc, a besoin de 10 cuisses de Tofu.",r:[13500,null,null,null,null,null]};
Q.s[707] = {n:"Assassinat refusé.",d:"Retournez voir Amayiro.",r:[null,null,null,null,null,null]};
Q.s[712] = {n:"Amener le venin.",d:"Le capitaine Essacarf, dans la prison de Bonta, a besoin de 30 pods de venin de scorbute.",r:[15600,null,null,null,null,null]};
Q.s[714] = {n:"Combat... pour rire ?",d:"Vous devez trouver Dike Tarak dans le quartier, le défier et le battre.",r:[null,null,null,null,null,null]};
Q.s[713] = {n:"Combat... pour rire.",d:"Vous devez trouver Dike Tarak dans le quartier nord, le défier, et perdre.",r:[null,null,null,null,null,null]};
Q.s[716] = {n:"Trouver une faille.",d:"Amayiro vous a demandé d\'explorer le Cimetière des Torturés, à l\'Est de Brâkmar, et de voir s\'il y a une faille dans les défenses de la cité. Vous aurez sûrement besoin de matériel particulier.",r:[19000,null,null,null,null,null]};
Q.s[717] = {n:"Travail au choix.",d:"Vous devez apporter à Amayiro : soit 20 planches en frêne, soit 10 racines d\'Abraknyde.",r:[21000,null,null,null,null,null]};
Q.s[721] = {n:"Raid chez Brâkmar.",d:"Amayiro vous a demandé de vaincre des guerriers brâkmariens et de récupérer dix badges sur eux.",r:[28000,null,null,null,null,null]};
Q.s[723] = {n:"Une leçon à donner.",d:"Un certain William Lengland perturbe les habitants de Bonta : il faut aller le calmer, par la force.",r:[34000,null,null,null,null,null]};
Q.s[724] = {n:"Dans les geôles de Brâkmar.",d:"Amayiro vous a demandé de sauver Houé Dapyus, dans la prison de Brâkmar, et de le ramener à la milice bontarienne.",r:[37000,null,null,null,null,null]};
Q.s[154] = {n:"Pandrista à gogo !",d:"Trouvez un marchand ambulant : vous pourrez lui régler la taxe sur la Pandrista. N\'hésitez pas à insister lourdement.",r:[1000,null,null,null,null,null]};
Q.s[153] = {n:"Y\'a du soleil à Pandala !",d:"A votre arrivée dans Pandala, vous êtes invité à vous mettre en règle avec l\'administration : régler la taxe sur la Pandrista s\'impose.",r:[1000,null,null,null,null,null]};
Q.s[155] = {n:"Ma première Shaman Party",d:"Allez demander de l\'aide au Shaman de toute urgence !",r:[4700,null,null,null,null,null]};
Q.s[0] = {n:"null",d:"",r:[null,null,null,null,null,null]};
Q.s[170] = {n:"Un nouveau message du sage",d:"Un messager vous apporte un message, parlez-lui !",r:[5000,null,null,null,null,null]};
Q.s[168] = {n:"Petit entrainement au bouclier",d:"Pour vous remercier de la livraison, le forgeur de bouclier vous a fait cadeau d\'un petit bouclier d\'entraînement, Parlez au maitre du Dojo pour un petit entraînement.",r:[1000,null,null,null,null,null]};
Q.s[162] = {n:"L\'accent sur le voyage",d:"Le sage Lenald vous demande d\'aller au village de l\'Aerdala...ou de Terrdala, impossible d\'être sûr à cause de son accent. Une fois sur place, parlez au maître Pandawushu.",r:[750,null,null,null,null,null]};
Q.s[161] = {n:"Chez le forgeur de Boucliers",d:"A Terrdala, personne n\'est disponible pour aller porter les ressources à la forge de boucliers. Forger des boucliers est pourtant indispensable aux guerriers Pandawas... Heureusement que vous êtes là !",r:[750,null,[[7097,1]],null,null,null]};
Q.s[165] = {n:"Qui a peur du méchant chacha",d:"Poochan recherche son futur mari, les seuls indices qu\'elle a sont qu\'il doit toujours se trouver à Pandala, et qu\'il a peur des chachas. Le plus simple est encore de se transformer en chacha et de sauter dans les bras de tout le monde non ?",r:[1000,null,null,null,null,null]};
Q.s[166] = {n:"Arrangement à l\'amiable",d:"La coutume ici veut que le père décide qui son fils ou sa fille épousera. Vous devez donc convaincre le père de vous céder son fils. Il faudra faire tout ce qu\'il faut pour ça.",r:[1000,null,null,null,null,null]};
Q.s[167] = {n:"Conquête des Dento",d:"Pour libérer Lanma de ses obligations, il va falloir rompre la promesse de mariage qu\'il a avec une fille du Dojo Dento.",r:[1000,null,null,null,null,null]};
Q.s[205] = {n:"Récompense ?",d:"Poochan vous attend.",r:[7000,null,null,null,null,null]};
Q.s[174] = {n:"Balade dans l\'Espace et le Temps d\'Amakna ",d:"Cette Balade dans l\'Espace et le Temps d\'Amakna (B.E.T.A.) permettra de sauver le monde ! \n",r:[null,null,null,null,null,null]};
Q.s[173] = {n:"Un Kouartz et ça repart",d:"Amine propose à Henual d\'utiliser le dernier recours :... du Kouartz !",r:[null,null,null,null,null,null]};
Q.s[172] = {n:"Amine, de rien!",d:"Il faut transmettre une lettre à Amine au temple Xelor de la part du surveillant Henual.",r:[null,null,null,null,null,null]};
Q.s[178] = {n:"Boire et déboires",d:"Un marchand ambulant vous vendra certainement une de ces boissons fermentées qui ont fait la réputation de l\'île. Il vous suffit d\'en trouver un !",r:[null,null,null,null,null,null]};
Q.s[185] = {n:"Passage de grade Rokwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Rokwa.",r:[30000,null,null,null,null,null]};
Q.s[184] = {n:"Passage de grade Gokwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Gokwa.",r:[30000,null,null,null,null,null]};
Q.s[183] = {n:"Passage de grade Yonkwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Yonkwa.",r:[20000,null,null,null,null,null]};
Q.s[180] = {n:"Passage de grade Ikwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Ikwa.",r:[5000,null,null,null,null,null]};
Q.s[187] = {n:"Début entrainement",d:"Pour commencer l\'entraînement, il faut obtenir un certificat shamanique ainsi qu\'une tenue Pandawushuka.",r:[null,null,[[7313,1]],null,null,null]};
Q.s[182] = {n:"Passage de grade Sankwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Sankwa.",r:[15000,null,null,null,null,null]};
Q.s[181] = {n:"Passage de grade Nikwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Nikwa.",r:[10000,null,null,null,null,null]};
Q.s[191] = {n:"Yondanwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Yondanwa.",r:[60000,null,null,null,null,null]};
Q.s[190] = {n:"Sandanwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Sandanwa.",r:[50000,null,null,null,null,null]};
Q.s[186] = {n:"Shodanwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Shodanwa.",r:[30000,null,null,null,null,null]};
Q.s[189] = {n:"Nidanwa",d:"Il faut se présenter au maître un samedi pour passer l\'évaluation du grade Nidanwa.",r:[40000,null,null,null,null,null]};
Q.s[175] = {n:"Legende Lenalde",d:"Enfin ! Vous touchez au but ! Mais vous n\'êtes pas au bout de vos surprises ! Le Lénald de l\'île des Wabbits va vous révéler un grand secret longtemps gardé...",r:[7500,null,null,null,null,null]};
Q.s[188] = {n:"Dans le temple de votre dieu",d:"Suivant les conseils du sage Lenald, vous préparez votre prochaine expédition. Pour cela il vous faut vous rendre dans le temple de votre divinité en Amakna.",r:[7500,null,null,null,null,null]};
Q.s[176] = {n:"Dark Vlad, un gars qui en a !",d:"Purifiez votre âme et lavez-vous les oreilles : le sage Lénald vous révèle la vérité sur le Dofus de Pandala.",r:[40000,null,null,null,null,null]};
Q.s[193] = {n:"Le réceptacle aux Dofus",d:"Le Grandapan a accepté le cadeau des Enutrofs avec joie. Fervent admirateur des Dofus, il vous accueille à bras ouverts. Pour satisfaire votre curiosité à propos des Dofus, il vous invite à aller voir le réceptacle aux Dofus.",r:[1500,null,null,null,null,null]};
Q.s[192] = {n:"Bons baisers d\'Astrub",d:"Le shaman est débordé, il n\'a pas de temps à vous consacrer. Entre les Pandikazes, la maladie des Enutrofs d\'Astrub et le reste...Il vous conseille de parler à Pyrite, Enutrof en quarantaine, si vous désirez l\'aider.",r:[1500,null,null,null,null,null]};
Q.s[194] = {n:"Un tiens vaut mieux que deux tu boiras",d:"La voie de l\'eau consiste à résister à... l\'absorption et à l\'immersion (partielle et totale) d\'eau par tous les moyens. Ne jamais en boire, se laver uniquement en cas de nécessité. Trouvez le maître de la voie de l\'Eau : il en sait plus qu\'il n\'y paraît.",r:[10000,null,null,null,null,null]};
Q.s[207] = {n:"Le Grandapan",d:"Apporter le faux Dofus au Grandapan.",r:[2200,null,null,null,null,null]};
Q.s[195] = {n:"Ecuyer, Palefrenier, même combat.",d:"Des Brâkmariens ont détruit des greniers bontariens. Il faut  trouver un moyen de ravitailler les montures de la milice en allant trouver une solution auprès de Merlan, à l\'atelier des alchimistes.",r:[50000,null,null,null,null,null]};
Q.s[196] = {n:"Dans la peau d\'un espion.",d:"Suite à l\'incendie d\'entrepôts de nourriture par les Brâkmariens, Ebru Of El veut savoir ce que les ennemis manigancent.",r:[50000,null,null,null,null,null]};
Q.s[197] = {n:"Levez-vous et marchez.",d:"Elviana Tirips veut interroger les renégats bontariens mais avant de pouvoir le faire il faut les ressusciter.",r:[50000,null,null,null,null,null]};
Q.s[782] = {n:"Agriculture à haut risque.",d:"Kaffra a eu vent des plans de Bonta pour accroître sa production céréalière. Il a besoin de 20 Graines de scorbute pour que cette production serve les desseins de Brâkmar.",r:[50000,null,null,null,null,null]};
Q.s[200] = {n:"Brâkmariens bras cassés.",d:"Les agents brâkmariens étant des incapables, Kaffra vous a demandé de vous rendre à Astrub et de convaincre le marchand bontarien Raymond Santho de ravitailler Brâkmar.",r:[null,null,null,null,null,null]};
Q.s[783] = {n:"Intoxication alimentaire.",d:"Suite à votre rapport, Ledrob vous a confié 20 Graines de scorbute modifiées à déposer dans l\'atelier des alchimistes de Bonta. Il faut les déposer de nuit lorsque Merlan l\'Enchaîneur est endormi.",r:[50000,null,null,null,null,null]};
Q.s[198] = {n:"Inquiétudes brâkmariennes.",d:"Ledrob se demande ce qui se trame à Bonta en ce moment. Il vous envoie sur place pour prendre contact avec l\'espion Finche Aticus.",r:[null,null,null,null,null,null]};
Q.s[787] = {n:"J\'ai dit : Lève-toi et marche !",d:"La malédiction d\'Erazal vous a appris comment forcer une âme à se réincarner contre sa volonté. Pour cela, il faut créer une potion particulière et suivre un rituel précis.",r:[50000,null,null,null,null,null]};
Q.s[199] = {n:"Lève-toi et marche.",d:"Divad ne parvient pas à ressusciter Terra Tibya pour l\'interroger. Il faut donc improviser un sort de résurrection qui en soit capable et c\'est la mission qui vous a été confiée.",r:[null,null,null,null,null,null]};
Q.s[201] = {n:"Trouver le hors-la-loi",d:"Rok a été aperçu au Nord de Pandala. \nIl est condamné à l\'emprisonnement à Astrub. \n",r:[null,6250,null,null,null,null]};
Q.s[202] = {n:"Trouver le hors-la-loi",d:"Musha a été aperçu au sud de Pandala. \nIl est condamné à l\'emprisonnement à Astrub. \n",r:[null,64000,null,null,null,null]};
Q.s[203] = {n:"Trouver le hors-la-loi",d:"Marzwel a été aperçu du côté d\'Aerdala \nIl est condamné à l\'emprisonnement à Astrub. \n",r:[null,25000,null,null,null,null]};
Q.s[206] = {n:"Trouver la hors-la-loi",d:"Aermyne a été aperçue du côté de Terrdala. \nElle est condamnée à l\'emprisonnement à Astrub. \n",r:[null,16000,null,null,null,null]};
Q.s[785] = {n:"Interro surprise.",d:"Elviana Tirips veut savoir quelles informations les renégats bontariens ont données aux Brâkmariens et c\'est vous qui êtes en charge de l\'interrogatoire.",r:[200000,null,null,null,null,null]};
Q.s[786] = {n:"La chasse aux renégats est ouverte.",d:"Des renégats bontariens se sont réfugiés à Brâkmar. Vous devez les retrouver et les éliminer puis ramener leur dépouille à Bonta.",r:[200000,null,null,null,null,null]};
Q.s[209] = {n:"Le secret de Terra Tibya.",d:"Terra Tibya est enfin ressuscitée. Reste à la persuader de vous révéler son secret.",r:[200000,null,null,null,null,null]};
Q.s[208] = {n:"Le pont vers Terra Tibya.",d:"Ledrob Terceséc veut mettre la main sur les statuettes de Sumens. Il vous a chargé de capturer leur gardien.",r:[200000,null,null,null,null,null]};
Q.s[214] = {n:"Parler à Badufron, Chef Mercenaire d\'Astrub",d:"Badufron connaît les lois concernant les trafiquants de Dofawa.",r:[1000,45,[[7929,1]],null,null,null]};
