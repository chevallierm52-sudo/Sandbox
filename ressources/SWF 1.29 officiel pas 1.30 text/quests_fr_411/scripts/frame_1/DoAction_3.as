Q.s[1123] = {n:"Savez-vous scalper les boufmouths ?",d:"Truffo vous a demandé de calmer les ardeurs du Royalmouth, rendu agressif par la chaleur tropicale de la serre et le manque de nourriture.",r:[165500,null,null,null,null,null]};
Q.s[1165] = {n:"Mon royaume pour un poisskaille.",d:"Waldos FieldChester Potcobble souhaite cuisiner un poisskaille royal lors d\'un dîner aux chandelles avec Aurore Boréale. Il vous a chargé de le lui fournir.",r:[null,null,null,null,null,null]};
