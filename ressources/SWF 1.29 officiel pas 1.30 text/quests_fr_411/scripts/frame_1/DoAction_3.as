Q.s[1150] = {n:"Faux témoignage.",d:"Damar a besoin de l\'aide de Valy Domidat, la bricoleuse de Frigost.",r:[446000,15000,[[11196,1]],null,null,null]};
Q.s[1149] = {n:"La faune et la fore.",d:"Damar, le chef des pêcheurs du lac gelé, a besoin de matériaux pour réparer le matériel de pêche.",r:[446000,15000,[[11196,1]],null,null,null]};
Q.s[1151] = {n:"Eclaireurs mansots.",d:"Les mansots vont attaquer les pêcheurs. Vous devez aider Mel à les repousser.",r:[223000,5000,[[11196,1]],null,null,null]};
Q.s[1154] = {n:"Distribution de pichon.",d:"Damar veut profiter de la démoralisation des mansots pour rouvrir les lignes de ravitaillement en pichons.",r:[null,null,null,null,null,null]};
Q.s[1155] = {n:"640, année exotique.",d:"Pour réhabiliter l\'ancien village de Frigost, Aurore Boréale a opté pour un mélange de bois de tremble et de planches en bois de kaliptus, que vous devez lui fournir.",r:[223000,15000,[[11196,1]],null,null,null]};
Q.s[1162] = {n:"Fondations.",d:"Aurore Boréale projette d\'ouvrir un hôtel entièrement taillé dans la glace. Afin d\'y parvenir, elle a besoin de nombreux outils.",r:[1115000,150000,[[11196,4]],null,null,null]};
Q.s[1167] = {n:"Rube Eole.",d:"Craignant la propagation du rube, Mac Givré a besoin de plusieurs vaccins.",r:[2230000,15000,[[11196,5]],null,null,null]};
Q.s[1166] = {n:"Hiver un jour, hiver toutjours.",d:"Mac Givré a besoin de main-d\'oeuvre qualifiée. Vous devez convaincre la Maire de Frigost de le laisser prospecter dans la bourgade.",r:[null,null,null,null,null,null]};
