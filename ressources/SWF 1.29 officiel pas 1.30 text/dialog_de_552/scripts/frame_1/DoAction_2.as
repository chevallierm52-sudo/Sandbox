D.q[1043] = "Hmmm. Diese Halskette ist in sehr schlechtem Zustand. Die Reparatur wird mindestens 1000 Kamas kosten.";
D.q[5361] = "";
D.q[2155] = "Da nimm! Ich geb dir alles!";
