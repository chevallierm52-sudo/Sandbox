D.q[479] = "Der Zutwitt zu diesem Teil dew Insel ist dem Wa vowbehalten. Vewschwinde von hiew!";
D.q[893] = "83";
D.q[7061] = "Die nächsten Steine...";
D.q[7317] = "";
D.q[3961] = "Das Attentat per Tofu ist leider fehlgeschlagen... Ich denke, wir sollten diese Dinge besser auf traditionelle Halsabschneiderart regeln, indem wir unsere guten, alten Pwinzen mit einem vergifteten Blobkuchen ins Jenseits befördern!";
