D.q[904] = "94";
D.q[906] = "96";
D.q[6817] = "Ich achte nicht auf Fremde, meine Eltern haben mir verboten, mit Fremden zu reden. Ihr seid mir übrigens fremd, also sag ich nichts.";
D.q[7956] = "";
D.q[1634] = "Tatsächlich gibt es bösartige Wesen in Amakna, die ohne Skrupel andere Identitäten annehmen, um ehrliche Bürger wie dich auszurauben. Also trau niemals denjenigen, die es auf deinen Reichtum abgesehen haben. \n \nHier ist die nächste Frage: Wenn du als großer und erfahrener Krieger einen jungen Lehrling triffst, der dich um Hilfe bittet - was antwortest du ihm dann?";
