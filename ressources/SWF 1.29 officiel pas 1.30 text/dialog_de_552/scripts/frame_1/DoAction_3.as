D.q[4981] = "";
D.q[6613] = "";
D.q[4976] = "";
D.q[4026] = "Ein Wabbitverwandlungstrank? Nanu, ihr seid heute bereits der Zweite, der mich darum fragt... Der Erste hat bereits einige Nachforschungen getan, doch hat die Rezeptur keine Wirkung gezeigt. Wir müssen also von vorn beginnen. Dazu müsst Ihr meine Kollegen in Amakna besuchen.";
D.q[7926] = "";
D.q[6003] = "";
