D.q[6271] = "Was machst du da?";
D.q[138] = "*Griesgrahm lässt den Würfel in den bronzenen Maßkrug fallen und bewegt dann sehr schnell alle Maßkrüge auf dem Tisch. Der Würfel scheint von einem Krug in den nächsten überzuwechseln, ohne dass ihr euch erklären könnt, wie Griesgrahm das bewerkstelligt.*\nNa, in welchem Krug befindet sich nun der Würfel?";
D.q[7930] = "";
D.q[4143] = "Guten Tag, ich bin Polka Mehrer, eine der bekanntesten Gehilfinnen von Otomaï. Ich kümmere mich darum, dass auf den Koppeln hier alles zum Rechten steht. Hier fangen wir nämlich die Kreaturen dieser Insel ein, um ihre Lebens- und Verhaltensweise zu untersuchen. Unglücklicherweise habe ich keine Aufzuchtgeräte mehr frei und kann also meine Untersuchungen nicht fortführen.";
D.q[4576] = "Gibt\'s was Neues?";
D.q[5323] = "Ruh dich aus und komm dann wieder.";
D.q[7931] = "";
D.q[7428] = "";
D.q[632] = "Wenn Ihr Rezepturen sucht, solltet Ihr einmal in der Bibliothek vorbeischauen. Ein Alchemist hat dort eine 12-bändige Enzyklopädie mit seltenen Rezepturen zusammengestellt.";
D.q[636] = "Wenn Ihr Rezepturen braucht, so rate ich Euch, der Bibliothek einen Besuch abzustatten. Dort steht sogar eine 12-bändige Enzyklopädie mit seltenen Rezepturen.";
D.q[7934] = "";
D.q[4590] = "";
D.q[4586] = "";
D.q[6814] = "Miau... wrumm, wrumm.";
D.q[6004] = "";
D.q[6619] = "";
D.q[291] = "Guten Tag, Ihr habt es hier mit einer echten Legende zu tun! Ich bin Kwaker Vans! Dieser Hochstapler Kelog Korflex hat mir meinen rechtmäßigen Platz an der Spitze des Brotmarktes von Amakna streitig gemacht. Doch bald steigt meine große Gegen-Offensive: das currylose Currybrot!";
D.q[2715] = "Falsch, falsch, absolut falsch! Ich bezweifle, dass du hierher gekommen bist, um ein Pandikaze zu werden...";
D.q[7932] = "";
D.q[7935] = "";
