D.q[6031] = "";
D.q[2598] = "Deine Reise war beschwerlich, Schüler, doch du bist schon auf dem richtigen Weg: er führt mitten in den Schattenwald hinein... Doch bevor du dorthin gehst, solltest du unbedingt noch mit unserem Dubbelzüchter reden. Trainiere ein wenig mit einem seiner Biester. Es gibt nichts Besseres, um seine Kampftechnik zu verbessern! Und dort wo du hingehst, hast du die bitter nötig. Denn man sagt, dieses Waldstück sei von den Göttern vergessen worden..";
D.q[4921] = "Danke, aber ich habe bereits alles, was ich brauche.";
D.q[7914] = "";
D.q[6045] = "";
D.q[6040] = "";
D.q[4873] = "";
D.q[304] = "Im kritischen Augenblick, wo die Welt auseinander bricht...";
D.q[3142] = "Ah, da seid Ihr ja wieder! Und, wie ich sehe, habt Ihr die vier Broschen! Das ist mir Beweis genug für das Vertrauen, dass Euch die vier Schwestern offenbar geschenkt haben. Also will ich Euch das meinige aussprechen. Ich sehe ja, dass Ihr nicht einer dieser verlotterten Abenteurer seid, die nur danach trachten, mich hereinzulegen. Nein, Ihr besitzt Stil und Klasse! \nNiemand wird es wagen, mich, den großen Frivolak hinters Licht zu führen! Niemand!!!";
D.q[3800] = "Harharhar! War die letzte Abreibung noch nicht genug für dich?";
D.q[7915] = "";
D.q[4455] = "Aaaaargh!";
D.q[2590] = "Deine Reise war beschwerlich, Schüler, doch du bist schon auf dem richtigen Weg: er führt mitten in den Schattenwald hinein... Doch bevor du dorthin gehst, solltest du unbedingt noch mit unserem Dubbelzüchter reden. Trainiere ein wenig mit einem seiner Biester. Es gibt nichts Besseres, um seine Kampftechnik zu verbessern! Und dort wo du hingehst, hast du die bitter nötig. Denn man sagt, dieses Waldstück sei von den Göttern vergessen worden..";
