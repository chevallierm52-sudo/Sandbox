D.q[5251] = "";
D.q[7936] = "";
D.q[3222] = "Hast du Angst, kleines Schweinchen? Ach komm, hör auf zu greinen, das ist alles halb so schlimm! Jetzt bin ich ja da! Ich werde dich schon hier hinausbegleiten und dir einen neuen Ausgangspunkt zuteilen, denn du scheinst deinen bereits vergessen zu haben. Mal sehen, was ich da noch so in petto habe... Das Sanctuarium des Praeputium? Hmmm... zu eng für dich... Der Fülltrog des Bülldog? ... zu gefährlich... Ich werde dich zum Zaap des Schlosses von Ankama schicken, das wird genau das Richtige für dich sein.";
D.q[1042] = "*klickklack* *klack, klick* *klickerdiklacker* - *klackerklick, klick, klick, klack* *klacker*";
D.q[1356] = "*Schere*\nTja, du hast eben kein Glück. Du hast verloren...";
D.q[1115] = "*eisiger Blick und Schweigen*";
D.q[1848] = "*Die Maunzmiez knabbert ohne rechte Überzeugung am angebotenen Futter herum und nimmt anschließend ihr lang gezogenes Jammern wieder auf.*\nMiauuuuu!";
D.q[1355] = "*Papier*\nTja, du hast eben kein Glück. Du hast verloren...";
D.q[7937] = "";
D.q[4804] = "Hallo, ich habe gehört, dass du Ermittlungen über den Verrat des Milizionärs Sulsch Tim Sliglu Terpeh anstellst. Es ist offensichtlich, dass dieser Verräter schuldig ist;\r\n            deshalb werde ich dich reich belohnen, wenn du im Prozess diese Version unterstützt.";
D.q[345] = "Hallo! Ich habe vor Kurzem eine Schriftrolle auf dem Speicher meiner Großmutter gefunden... Ich weiß zwar nicht, wozu die nutze ist, doch würde ich sie gegen 120 Moskitobrauen für meine Sammlung eintauschen. Mit denen kann ich wenigstens etwas anfangen!";
D.q[1426] = "Hallo #1, kannst du mir ein wenig zur Hand gehen für das Essen heut Abend? \nIch bräuchte noch etwas Vogelfleisch, etwa 10 Tofuschlegel sollten genug sein. Versuche einen Jäger zu finden, der dir ein paar davon verkauft.";
D.q[2920] = "";
D.q[5285] = "Der Prozess ist zu Ende, ihr habt in meinem Gerichtssaal nichts mehr verloren.";
D.q[330] = "Oh wie toll! Damit werde ich nie wieder einen kalten Hintern haben! Danke sehr! Welch ein tolles Geschenk! Dafür dürft Ihr nun auch in die Tiefen dieses Loches eintauchen.";
D.q[2294] = "*Der Fresssack schlingt in einem Happen den Maßkrug mitsamt Inhalt in sich hinein.* Glurp...Hips!";
D.q[7938] = "";
D.q[245] = "Nun gut, da du dir in den Kopf gesetzt hast, sterben zu wollen, will ich dir dabei nicht im Weg stehen. Doch will ich dir noch eine letzte Aufgabe stellen, bevor du hindurch darfst. Bring mir die Kralle eines Raubritters von Kleppripp, ihr Geruch vertreibt die anderen Monster und beschützt mich. Wenn du mir eine bringen kannst, so weiß ich, dass du dich auch gegen die Monster des Labyrinths behaupten wirst.";
D.q[5635] = "*Denk* Ich denke so stark nach, daß die Leute um mich herum meine Gedanken hören können.";
D.q[2297] = "*singt halblaut vor sich hin* \n\" ° ~ ~ Schni...Schna...Schnappi...-...Schnappi...Schnappi...Schnapp... gleich sind alle langen Haare bis auf Letzte ab...\" ~ ~° \"";
D.q[1461] = "Wie lange schon? \nNun, das Datum deiner Inhaftierung steht in den Gefängnispapieren, die du bei deiner Ankunft hier erhalten hast. Wisse, dass du hier für einer Stunde in Haft sein wirst, also ist die Rechnung leicht!";
D.q[7939] = "";
D.q[2296] = "*singt halblaut vor sich hin* \n\" ° ~ ~ WuWulf, du hast Tofus gestohlen...gib sie wieder her! ~ ~° \"";
D.q[6621] = "";
