D.q[4916] = "Mein Hammer? Ihr habt meinen Hammer gefunden? *der Geist leuchtet einen Moment auf*\nNein, ich will nicht dorthin zurück solange ich nicht meine Puppe zurück habe!";
D.q[1023] = "Gut gemacht! Du fängst wirklich an, Brâkmar wie deine Westentasche zu kennen, was?";
D.q[5676] = "Gute Arbeit! Hoffentlich schreckt das Milizsoldaten davon ab, die Lager zu wechseln. Du warst mutig und entschlossen, deshalb wirst du in die Ränge der Renegatenjäger eingegliedert. Herzlichen Glückwunsch!";
D.q[5441] = "";
