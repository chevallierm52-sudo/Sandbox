D.q[5482] = "Ich heiße Lina und bin Militionärin von Astrub. Es heißt, ein verdächtiger Witz-Goblin soll sich in der Gegend herumtreiben, drum drehe ich eine kleine Runde zur Sicherheit.";
D.q[5363] = "";
D.q[7916] = "";
D.q[5086] = "";
D.q[7917] = "";
D.q[4927] = "Das ist nicht mein Plüschtier, meins war sehr viel weniger ansehnlich. Naja, ich mache einen guten Tausch.\nIch folge euch bis zu meinem Hammer, aber wenn die Dinge brenzlich für euch werden, dann komme ich hierher zurück.";
D.q[5183] = "";
D.q[7918] = "";
D.q[3776] = "Willst du zur Statue zurückkehren?";
D.q[4931] = "";
D.q[4933] = "";
D.q[1594] = "Bas billst du, Menschbing? Bie bannst du es bagen, mich mitten bährend bieses Bieles bu Bören?";
D.q[5003] = "";
D.q[2596] = "Deine Reise war beschwerlich, Schüler, doch du bist schon auf dem richtigen Weg: er führt mitten in den Schattenwald hinein... Doch bevor du dorthin gehst, solltest du unbedingt noch mit unserem Dubbelzüchter reden. Trainiere ein wenig mit einem seiner Biester. Es gibt nichts Besseres, um seine Kampftechnik zu verbessern! Und dort wo du hingehst, hast du die bitter nötig. Denn man sagt, dieses Waldstück sei von den Göttern vergessen worden..";
D.q[5467] = "Hahaha! Du auch find Witz luschdisch? Ich mag Witz sähr... \nAber Witz nisch ganz kapiert...  \nDu kannst erkläre miah?";
D.q[5349] = "";
D.q[239] = "Hahaha! Ich wusste es! Ihr habt Euch verlaufen! Ausgang? Keine Ahnung, den such\' ich auch schon seit Jahren. Grrrr. Schon wieder dieses geringschätzige Lächeln. Hab es genau gesehen! Im Gegensatz zu Euch bin ich hier zu Hause! Genau! Hier im ... Ähm... unterm Felsenblock 17a! Jawohl! Auch wenn ich nicht genau weiß, wo ich hier bin.";
D.q[7919] = "";
D.q[7920] = "";
D.q[2486] = "\"Bring mir Bernstein!\", hat Manganaise gemeint. Das ist leichter gesagt, als getan. Wo in aller Welt soll ich Bernstein finden? Auf Bäumen, jaja, ist schon klar, bloß auf welchen? Hilf mir, mein Freund, dafür will ich dir dann auch eine kleine Schriftrolle der Vitalität geben!";
D.q[2589] = "Deine Reise war beschwerlich, Schüler, doch du bist schon auf dem richtigen Weg: er führt mitten in den Schattenwald hinein... Doch bevor du dorthin gehst, solltest du unbedingt noch mit unserem Dubbelzüchter reden. Trainiere ein wenig mit einem seiner Biester. Es gibt nichts Besseres, um seine Kampftechnik zu verbessern! Und dort wo du hingehst, hast du die bitter nötig. Denn man sagt, dieses Waldstück sei von den Göttern vergessen worden...";
