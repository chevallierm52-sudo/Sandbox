I.u[11411] = {n:"Abito da Eva",t:24,d:"Portato alla festa della Mutanda del Capitano Chafer, questo abito farà girare la testa ai tuoi pretendenti e provocherà numerosi torcicollo. Il tuo kinesiterapeuta te ne sarà molto grato.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11412] = {n:"Copia del dossier della famiglia Santho",t:24,d:"Questi documenti sono una copia dei diritti di successione, titoli di proprietà e altri documenti amministrativi della famiglia Santho. Indicano, fra l\'altro, l\'acquisto e l\'eredità di centinaia di ettari di terreno agricolo a Sud di Bonta. Gli acquisti sono stati fatti fra il 551 e il 555, ovvero poco dopo la glaciazione di Frigost. Sono stati possibili grazie all\'immensa fortuna di Edmond Santho, accumulata vendendo enormi quantità di cereali di origine Frigostiana.\nAl momento attuale solo un campo non appartiene a Raymond Santho: quello di Robin Marmoni.",ep:0,g:33,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11413] = {n:"Chiave della cella di Heike Holo",t:24,d:"La chiave della cella di Heike Holo.",ep:0,g:790,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11414] = {n:"Heike Holo",t:32,d:"Heike Holo vuole scappare, devi scortarlo fino alla battello per l\'isola di Wabbit.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11415] = {n:"Documenti sul furto",t:24,d:"Questi documenti parlano dei furti effettuati su carichi di cereali provenienti da Frigost. Vengono menzionati i battelli della famiglia Montay.",ep:0,g:26,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11416] = {n:"Stivalocchio",t:11,d:"Questo paio di stivaletti sono stati scolpiti in un tronco d\'albero. O forse è il contrario.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:171,p:8800};
I.u[11417] = {n:"Anellocchio",t:9,d:"Questo anello è stato confezionato con segatura di legno e qualcosa di molto appiccicoso. E\' meglio non volerne sapere di più.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:171,p:9825};
I.u[11418] = {n:"Mantello di Baglionus",t:17,d:"Claudius Baglionus adorava da morire questo mantello. Ecco spiegato perchè lo indossava ad ognuno dei suoi funerali.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:172,p:9858};
I.u[11419] = {n:"Stivali di Baglionus",t:11,d:"Un paio di stivali che Claudius Baglionus non dimentica mai di infilare quando va a fare la sua piccola commissione... nel capanno in fondo al giardino.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:172,p:8950};
I.u[11420] = {n:"Cappello di Baglionus",t:16,d:"Questo cappello un po\' vecchiotto rasenta il ridicolo. Grazie ad esso Claudius Baglionus si è guadagnato il titolo di \"nonna con i baffi\". Una cosa che ha sempre avuto la tendenza a metterlo di cattivo umore...",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:172,p:8980};
I.u[11421] = {n:"Cerbottana di Baglionus",t:4,d:"Claudius Baglionus non avrebbe mai dovuto utilizzare questa cerbottana dopo aver mangiato. Da quel momento è stato obbligato ad usarla come semplice bastone, ma come diceva sempre, \"era meglio prima...\"",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:12,e:[7,3,1,1,35,55,false,false],c:"CI>70&CV>50&CA>25",s:172,p:8050};
