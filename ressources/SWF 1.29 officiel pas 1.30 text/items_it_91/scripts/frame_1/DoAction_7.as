I.u[3203] = {n:"Anello Tribale",t:9,d:"L\'origine di questo anello è alquanto sospetta, si pensa che sia appartenuto ad una tribù di Sadida Kannibul vegetariani mangiatori di felci della peggior specie. Si tratta sicuramente di una storiella inventata per spaventare i giovani Sadida.",ep:11,g:49,l:51,wd:true,fm:true,w:5,p:7000};
I.u[3204] = {n:"Cintura Bontariana",t:10,d:"È la cintura più in voga nelle strade di Bonta. La fibbia è ornata con l\'insegna di una celebre confraternita di Ciabattini.",ep:3,g:37,l:53,wd:true,fm:true,w:10,c:"Ps=1",p:7400};
I.u[3205] = {n:"Cintura Brakmariana",t:10,d:"Si tratta della cintura più alla moda nelle fogne di Brakmar. È perfetta se vuoi dare l\'impressione di essere un vero duro. Ma per diventarlo veramente, dovrai affidarti ad altro.",ep:13,g:38,l:53,wd:true,fm:true,w:10,c:"Ps=2",p:7500};
I.u[3206] = {n:"La Xerbo",t:10,d:"È stata creata specialmente per ricompensare i guerrieri più abili. Si porta senza biancheria e solo in inverno.",ep:13,g:39,l:67,wd:true,fm:true,w:7,p:13000};
I.u[3207] = {n:"Stivali di Soddisfazione",t:11,d:"Questi stivali sono così comodi e leggeri che non si può non esserne soddisfatti. Gli avversari, invece, potrebbero non essere dello stesso parere se gli fai vedere le suole da troppo vicino.",ep:1,g:38,l:17,wd:true,fm:true,w:10,p:950};
I.u[3208] = {n:"Mutande del Bwork Arciere",t:56,d:"Il Bwork Arciere ha la cattiva abitudine di usare le mutande per tenere le frecce. Forse è proprio per questo che le frecce del Bwork Arciere sono considerate velenose.",ep:1,g:649,l:23,wd:true,fm:true,w:1,p:1};
I.u[3209] = {n:"Scalpo di Bwork Mago",t:15,d:"Sin da piccoli gli Anutrof cercano di impadronirsi di uno scalpo di Bwork Mago per nascondere la loro calvizie nascente. Con una tale porcheria sulla testa, sono ancora più ridicoli del solito, ma l\'odore Bwork permette di coprire facilmente il loro alito che sa sempre di alcool.",ep:4,g:653,l:23,wd:true,fm:true,w:1,p:1};
