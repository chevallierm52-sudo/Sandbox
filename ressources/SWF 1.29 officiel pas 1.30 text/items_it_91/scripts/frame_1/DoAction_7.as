I.u[2803] = {n:"Cintura del Kwabe",t:10,d:"Questa strana cintura è totalmente fabbricata con resti di chele e carapaci di granchio. Puzza moltissimo e non basterà neanche una strapotente magia per risolvere questo problema. Devi arrenderti...",ep:1,g:49,l:8,wd:true,fm:true,w:2,p:400};
I.u[2804] = {n:"Cintura Buulante",t:10,d:"Il famoso Buulupo ha donato i suoi presiosi organi per fabbricare questa incredibile cintura dall\'aria strapotente nonostante il suo strano aspetto capace di rendere felice il più perverso dei Chafer.",ep:2,g:50,l:81,wd:true,fm:true,w:10,p:16800};
I.u[2805] = {n:"Testicoli Magici del Buulupo",t:15,d:"Nessuno sa esattamente né come né quando sia successo, ma un giorno questi testicoli sono stati dotati di poteri magici alquanto oscuri.",ep:1,g:650,l:80,wd:true,fm:true,w:20,p:1000};
I.u[2806] = {n:"Testicoli Magici del Muulupo",t:15,d:"Per quanto possa sembrare strano questi testicoli sono dotati di poteri magici. Non si sa troppo a cosa potessero servire al Muulupo, ma forse è meglio continuare a ignorarlo..",ep:2,g:651,l:198,wd:true,fm:true,w:10,p:2000};
I.u[2807] = {n:"Cintura Muulante",t:10,d:"È un\'idea di Bowis il Ciabattino in persona. La regalò a Bruce Bulgur molto tempo fa, quando questi riuscì a sradicare a mani nude la Quercia Molle.",ep:2,g:51,l:129,wd:true,fm:true,w:20,p:50000};
I.u[2808] = {n:"Cintura Dragomaiala",t:10,d:"Questa cintura farà di te una persona irresistibile.\nBowis raccomanda comunque di non avvicinarsi al Drago Maiale indossandola, potrebbe risvegliare in lui certe pulsioni...",ep:2,g:52,l:77,wd:true,fm:true,w:20,s:58,p:16000};
I.u[2809] = {n:"Cintura Caliente",t:10,d:"Dietro questo nome grottesco si nasconde una bella creazione di Bowis il Ciabattino. Quest\'ultimo, durante una passeggiata nel Dongione degli Scheletri ha avuto la brillante idea di recuperare i resti dei suoi nemici.",ep:3,g:53,l:49,wd:true,fm:true,w:10,p:6500};
I.u[2810] = {n:"Cintura Pungente",t:10,d:"Grazie ai suoi poteri magici questa magnifica cintura di colore rosso ti permetterà di concentrarti meglio e di imparare più rapidamente. Il sogno di tutti i somari di Amakna.",ep:1,g:54,l:26,wd:true,fm:true,w:6,p:2000};
I.u[2811] = {n:"Cintura Uginakale",t:10,d:"Ecco una cintura che piacerà agli amanti delle sensazioni forti. In effetti essa è stata concepita per avvicinarti senza rischi agli Uginak. La sua efficacia però non è stata ancora provata.",ep:14,g:55,l:65,wd:true,fm:true,w:10,p:11000};
