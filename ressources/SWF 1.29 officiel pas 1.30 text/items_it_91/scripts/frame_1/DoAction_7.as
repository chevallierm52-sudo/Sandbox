I.u[2998] = {n:"Lana del Minotoror",t:57,d:"Questa lana eccezionale ha vissuto grandi momenti, come il terribile incontro con Vald. I peli che la compongono sono così duri, che proteggono anche dai colpi più violenti.",ep:2,g:654,l:125,wd:true,fm:true,w:30,p:12500};
I.u[2999] = {n:"Cuoio di Minotoror",t:56,d:"Questo cuoio è tanto resistente quanto le fortificazioni di Brakmar. Le sue proprietà intrinseche abbastanza sconosciute gli permettono di essere facilmente lavorato per realizzare gli oggetti più prestigiosi.",ep:2,g:655,l:125,wd:true,fm:true,w:30,p:12500};
I.u[3000] = {n:"Elmo rotto del Bwork",t:15,d:"Nella tribù Bwork sono i Bwork Maghi che si occupano della forgia. È un lavoro di grande impegno, infatti il piccolo Bwork usa l\'elmo fin dalla nascita per proteggersi dalle diverse cadute e dai colpi di martello.",ep:4,g:646,l:43,wd:true,fm:true,w:10,p:1};
I.u[3001] = {n:"Spallina di Bwork",t:15,d:"La Spallina è un elemento importante dell\'educazione Bwork, anche se questo termine non è appropriato. Forse sarebbe meglio parlare di allenamento...",ep:4,g:647,l:43,wd:true,fm:true,w:10,p:1};
I.u[3002] = {n:"Stivali bucati di Bwork",t:15,d:"Questi stivali sono inutilizzabili così. Devi portarli ad aggiustare da un Ciabattino esperto prima di pensare a come utilizzarli. Ma nel frattempo, puoi usare il loro odore per tenere lontane le proposte delle persone troppo intraprendenti.",ep:4,g:648,l:43,wd:true,fm:true,w:10,p:1};
