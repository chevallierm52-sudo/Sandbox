I.u[3647] = {n:"La Taver-Budella",t:5,d:"Questa daga a forma di falce serviva per sviscerare i viaggiatori persi. Prende il suo nome da tutte le bevute che il proprietario si faceva alla taverna, alla faccia dei poverini che aveva appena saccheggiato.",ep:13,g:31,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:17800};
I.u[3648] = {n:"Daghetta del Capitano Chafer",t:5,d:"Se il Capitano Chafer è scomparso, la sua daga invece è proprio nelle tue mani. Se il manico è passato tra le mani del Capitano Chafer, immagina un po\' dove può passare la lama...",ep:14,g:32,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>50",p:18000};
I.u[3649] = {n:"Daga Trice",t:5,d:"È stato il celebre artigiano Daghero ad aver l\'idea di creare una daga simile. Piuttosto incline ai giochi d\'azzardo e alle attività poco raccomandabili, questa daga fu la sua ultima creazione degna d\'interesse. C\'è di peggio come fine carriera.",ep:9,g:33,l:95,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:23000};
I.u[3650] = {n:"Daga Regazione",t:5,d:"Queste potenti daghe sono il frutto di una cooperazione tra gli artigiani capaci di mettersi d\'accordo sull\'avvenire della loro professione. Erano solo due. Morirono tutti e due litigando sul nome da dare a queste daghe.",ep:3,g:34,l:120,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>100",p:37000};
I.u[3651] = {n:"Daga Ingorgo",t:5,d:"Un piccolo e ridicolo artigiano di nome Slaillehin ha avuto la brillante idea di fabbricare queste superbe daghe. Da un giorno all\'altro tutti si sono messi in coda davanti alla sua forgia... ed è così che ha trovato il nome adatto a queste armi.",ep:9,g:35,l:90,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CV>30&CA>100&CS>70",p:22000};
I.u[3652] = {n:"Bastone di Mary Eg",t:4,d:"Mary Eg sapeva farci con gli uomini, il suo bastone sapeva respingere le avance dei più grandi cavalieri Yop. Solo tempo dopo si scoprì che Mary Eg non era altro che un ragazzo vestito da ragazza.",ep:12,g:30,l:112,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,40,false,false],c:"CI>250&CA>100&CV>100",p:32000};
