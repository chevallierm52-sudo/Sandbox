I.u[10955] = {n:"Anello del Corvo Nero",t:9,d:"Cosa c\'è di più normale per un volatile che portare un anello?",ep:0,g:188,l:33,wd:false,fm:true,w:10,s:155,p:3150};
I.u[10956] = {n:"Stivali del Corvo Nero",t:11,d:"Questo paio di stivali, come tutta la panoplia del Corvo Nero, è passata di zampa, ehm, di piede in piede per molte generazioni. Questo spiega il forte odore di Clakos.",ep:0,g:158,l:32,wd:false,fm:true,w:10,s:155,p:2850};
I.u[10957] = {n:"Mantello del Corvo Nero",t:17,d:"Filo, ago, qualche piuma prelevata dalle spoglie di Cuervoc in decomposizione, ed eccoti in possesso del più chic dei mantelli!",ep:0,g:174,l:35,wd:false,fm:true,w:10,s:155,p:3400};
I.u[10958] = {n:"Elmo del Corvo Nero",t:16,d:"E\' inutile che ti nascondi! Ti abbiamo smascherato, sei tu il Corvo Nero!",ep:0,g:259,l:32,wd:false,fm:true,w:10,s:155,p:2900};
I.u[10959] = {n:"Spada penetrante del Corvo Nero",t:6,d:"Ci hai lasciato delle piume, ma finalmente eccola nelle tue mani... La spada del Corvo Nero!",ep:0,g:98,l:39,wd:false,fm:true,w:10,an:14,e:[13,5,1,1,40,50,false,false],c:"CA>60&CV>60",s:155,p:4400};
I.u[10960] = {n:"Regalo Anello del Corvo Nero",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te. Attenzione, questo regalo può essere aperto solo su DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10961] = {n:"Regalo Spada penetrante del Corvo Nero",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te. Attenzione, questo regalo può essere aperto solo su DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10962] = {n:"Bastone di Rapina",t:4,d:"Niente come questo bastone per pulire le fogne, o anche il naso dei tuoi avversari caduti a terra ed incapaci di tapparsi le narici. Quest\'arma è ancora impregnata della magia di Rapina, magari riuscirai ad incarnarti in lui utilizzandola.",ep:0,g:92,l:30,wd:false,fm:false,w:10,an:12,e:[6,3,1,1,50,50,false,false],c:"CV>30",s:156,p:2650};
I.u[10963] = {n:"Stivali di Rapina",t:11,d:"La suola di questi stivali è spugnosa, permette di assorbire il sudore e spanderlo per terra ad ogni passo. Beh, potrai facilmente tornare sui tuoi passi così.",ep:0,g:156,l:32,wd:false,fm:true,w:10,s:156,p:2900};
I.u[10964] = {n:"Cintura di Rapina",t:10,d:"Questa cintura permetteva a Rapina di nascondervi dentro il suo bottino. Si può notare sulla parte interna una piccola valvola che permette di gonfiarla e farla diventare una boa... Indispensabile per le uscite nelle fogne.",ep:0,g:172,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10965] = {n:"Amuleto di Rapina",t:1,d:"Questo amuleto è stato appositamente concepito per non incastrarsi nel peli del collo di Rapina. Tu puoi quindi portarlo senza pericolo sotto le ascelle, o magari riuscire a tenerlo in mano.",ep:0,g:160,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10966] = {n:"Trasformazione in larva",t:31,d:"Le malelingue dicono che questa trasformazione rivela la tua vera natura... Hanno davvero torto?",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=21",p:0};
I.u[10967] = {n:"Cervello di larva",t:69,d:"Bisogna proprio essere disperati per mangiare una cosa del genere... No, non farlo!",ep:0,g:113,l:1,wd:false,fm:true,w:0,c:"Sc=21",u:true,ut:true,p:1};
I.u[10968] = {n:"Trasformazione in wabbit",t:31,d:"Stranamente non hai voglia di cawote.",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=22",p:0};
I.u[10969] = {n:"Pozione Winfwescante",t:12,d:"La dolcezza di una cawota, la freschezza di un dragacchino maratoneta... Niente di meglio per rimetterti in sesto. Alla salute!",ep:0,g:141,l:20,wd:false,fm:true,w:1,c:"Sc=22",u:true,ut:true,p:1};
I.u[10970] = {n:"Sudore di dragacchino",t:15,d:"Ma come hai fatto ad ottenerlo? E perchè? Sei veramente strano...",ep:0,g:773,l:1,wd:false,fm:true,w:1,p:1};
I.u[10971] = {n:"Zaino furbacchione",t:81,d:"Con questo zaino potrai farne di tutti i colori sempre col sorriso sulle labbra, furbacchione!",ep:0,g:25,l:20,wd:false,fm:true,w:10,c:"Sc=23",p:1};
I.u[10972] = {n:"Corvo inseguitore",t:31,d:"Nonostante sia molto affettuoso, supponi che al primo segno di pericolo questo volatile se la darà a gambe...",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,c:"Sc=24",p:0};
I.u[10973] = {n:"Pozione di destinazione sconosciuta",t:12,d:"Il tuo istinto ti dice di non bere il contenuto di questa fiala. Beh, in effetti è il tuo naso a dirlo, questa pozione impesta come le ascelle di un Bwork centenario.",ep:0,g:189,l:20,wd:false,fm:true,w:1,c:"Sc=25",u:true,p:10};
I.u[10974] = {n:"Fata d\'Artificio festiva",t:74,d:"E\' qui la festaaaaaaaaaaa!!",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"Sc=26",ut:true,p:1};
I.u[10975] = {n:"Spada di Phong Huss",t:6,d:"Odora di vecchio Fungiman, ma la sua lama non ne risente. Quest\'arma è ancora impregnata della sua magia, magari riuscirai ad incarnarti in Phong Huss, se la equipaggi.",ep:0,g:97,l:33,wd:false,fm:false,w:10,an:14,e:[12,6,1,1,40,60,false,false],c:"CS>50",s:157,p:3100};
I.u[10976] = {n:"Anello di Phong Huss",t:9,d:"I funghi portano generalmente i colletti, ma Phong Huss preferiva gli anelli. Magari gli piaceva vantarsi di avere le dita.",ep:0,g:185,l:33,wd:false,fm:true,w:10,s:157,p:3150};
I.u[10977] = {n:"Cintura di Phong Huss",t:10,d:"Phong Huss cercava di portare questa cintura come tracolla per poterci agganciare la sciabola. A parte pizzicargli il petto ogni volta, questa cintura non ha mai avuto altra utilità.",ep:0,g:170,l:30,wd:false,fm:true,w:10,s:157,p:2650};
