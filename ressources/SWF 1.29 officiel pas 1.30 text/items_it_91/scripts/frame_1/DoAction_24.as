I.u[10825] = {n:"Gulifiato",t:30,d:"Era davvero necessario fare tutta questa fatica per arrivare solo a questo risultato?",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10826] = {n:"Avviso di espulsione",t:24,d:"Dato che ti sei comportato male con colui che ti ospitava, quest\'ultimo ha deciso di chiuderti l\'accesso alla sua Cripta per le prossime 24 ore.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:0};
I.u[10827] = {n:"Pozione di Cura Larvesca",t:12,d:"Un liquido arancione con le bollicine, nessuno lo berrebbe.",ep:0,g:192,l:1,wd:true,fm:true,w:1,c:"Sc=7",u:true,ut:true,p:0};
I.u[10828] = {n:"Casco da Pappaball",t:16,d:"Si dice che il ridicolo non uccida. É vero, ma con quel casco hai veramente un\'aria ridicola.",ep:0,g:253,l:29,wd:false,fm:true,w:10,c:"Sc=10",p:2400};
I.u[10829] = {n:"Kamapesca",t:20,d:"Grazie a questo bastone le negoziazioni pecuniarie gireranno a tuo vantaggio.",ep:0,g:91,l:40,wd:false,fm:true,w:10,an:12,e:[7,3,1,1,40,50,false,false],c:"Sc=13",p:4200};
I.u[10830] = {n:"Bananantello",t:17,d:"Ikko, celebre artista di Amakna, fu il primo che osò indossare questo mantello. Tutto il mondo gli ripeteva pertanto:\n“Quando è troppo, è troppo Ikko”",ep:0,g:172,l:28,wd:false,fm:true,w:10,c:"Sc=14",p:2305};
I.u[10831] = {n:"Bananagrume",t:46,d:"Flambè o a pezzi, coperta di cioccolata fondente o al naturale, questo frutto è un dessert succulento.",ep:0,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[10832] = {n:"Croccaroccia",t:94,d:"Questa pietra levigata racchiude un Croccabul, ma non lo è. Sembra essere utilizzabile solo in prossimità di altri Croccaroc o Croccabul...",ep:0,g:18,l:1,wd:false,fm:true,w:20,c:"Sc=15&(PB=2|PB=96|PB=480)",u:true,p:0};
I.u[10833] = {n:"Panmao",t:33,d:"Questo pane è strabiliante, quando lo si morde miagola.",ep:0,g:4,l:1,wd:false,fm:true,w:2,c:"Sc=16",u:true,ut:true,p:0};
I.u[10834] = {n:"Berretto Woof",t:16,d:"Ti bastano poche cose per assomigliare ad un Uginak. Attenzione alle pulci.",ep:0,g:256,l:11,wd:false,fm:true,w:10,c:"Sc=17",p:530};
I.u[10835] = {n:"Segno della recluta",t:50,d:"Calpestato, maciullato, schiacciato, lavato, asciugato, stirato, ti abbiamo fatto di tutto. Non sei più vestito di blu: sei blu dai lividi...",ep:0,g:707,l:1,wd:false,fm:true,w:1,p:0};
I.u[10836] = {n:"Pappaballeto",t:1,d:"Indossi fieramente questo amuleto, simbolo della tua partecipazione a questa grande manifestazione sportiva. É ciò che occorre per restare fieri dopo essere passati sotto alla mischia del B.C Trool.",ep:0,g:158,l:64,wd:false,fm:true,w:1,c:"Sc=18",p:11765};
I.u[10838] = {n:"Arancione",t:30,d:"Hai di nuovo bevuto qualcosa senza sapere cosa fosse.",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10839] = {n:"Mostro Pane",t:33,d:"A volte ci si può rompere i denti con del pane troppo duro. Mangia questo e riceverai un colpo da farti cadere tutti i denti.",ep:0,g:12,l:1,wd:false,fm:true,w:100,c:"Sc=8",u:true,p:0};
I.u[10840] = {n:"Mostro Pane mangiabile",t:33,d:"Questo è più tenero, buon appetito.",ep:0,g:12,l:1,wd:true,fm:true,w:1,c:"Sc=8",u:true,ut:true,p:0};
I.u[10841] = {n:"Marrone",t:30,d:"Nessuno ti ha avvisato degli effetti collaterali?",ep:0,g:1,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10842] = {n:"Trasformazione in Maomao",t:31,d:"Ecco finalmente arriva quel che serviva ! Se sputi palle di pelo non venire a piangere.",ep:0,g:21,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=16",p:0};
I.u[10843] = {n:"Nota su Krtek",t:24,d:"Hai annotato a che ora Krtek ha preso una bastonata. In questo modo puoi sapere quando tornare a dargliene.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10844] = {n:"Mmmmm",t:31,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:0,g:19,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[10845] = {n:"null",t:12,d:"",ep:0,g:716,l:1,wd:false,fm:false,w:0,u:true,ut:true,p:1};
I.u[10846] = {n:"Ferontello",t:17,d:"Presi da una strana frenesia, i tofu che incroci vogliono strofinarsi contro la tua gamba. Ma è solo questo mantello che li attira?",ep:0,g:173,l:61,wd:false,fm:true,w:10,c:"Sc=19",p:9700};
I.u[10847] = {n:"Stivali di Ladrurbo",t:11,d:"Ladrurbo infilava questi stivali una volta l\'anno, ma se li levava tutti i giorni. Possiamo quindi dedurre che questi stivali siano magici.",ep:0,g:151,l:53,wd:true,fm:true,w:10,s:152,p:7400};
I.u[10848] = {n:"Stivali di Cudine",t:11,d:"Questi stivali possono essere usati come incudine. Il loro vecchio proprietario ti consiglia vivamente di non indossarli per ballare.",ep:0,g:152,l:52,wd:false,fm:true,w:10,s:153,p:7175};
I.u[10849] = {n:"Cintura di Ladrurbo",t:10,d:"Questa cintura è stata fabbricata intorno ad un\'armatura metallica calamitata che attira i borselli degli imprudenti che oseranno strofinarsi contro di te.",ep:0,g:169,l:51,wd:true,fm:true,w:10,s:152,p:6825};
I.u[10850] = {n:"Cintura di Cudine",t:10,d:"Cudine aveva tre debolezze: le arakne, il solletico, e le arakne solleticanti.",ep:0,g:167,l:52,wd:false,fm:true,w:10,s:153,p:7100};
I.u[10851] = {n:"Cintura di Kloug",t:10,d:"Questa cintura è ancora coperta di farina. Magari perchè serviva come tavolo a Kloug il Panettiere Oscuro. A meno che non fosse la farina che lui utilizzava per incipriarsi il posteriore.",ep:0,g:168,l:51,wd:false,fm:true,w:10,s:154,p:6928};
I.u[10852] = {n:"Amuleto di Ladrurbo",t:1,d:"Ladrurbo ha rubato quest\'amuleto a Gonztipay, un goblin che ha perso tutto il suo humor, anche il peggiore.",ep:0,g:156,l:53,wd:true,fm:true,w:10,s:152,p:7405};
I.u[10853] = {n:"Amuleto di Kloug",t:1,d:"Questo amuleto ti permetterà di impastare la pelle del tuo collo senza utilizzare le tue mani.",ep:0,g:155,l:53,wd:false,fm:true,w:10,s:154,p:7400};
I.u[10854] = {n:"Anello di Cudine",t:9,d:"Battin Cudine il Forgiatore ha scambiato questo anello con una spada che apparteneva a Dama Antio.",ep:0,g:183,l:54,wd:false,fm:true,w:10,s:153,p:7650};
I.u[10855] = {n:"Anello di Kloug",t:9,d:"Quest\'anello è stato immerso in una moltitudine di lieviti differenti. Si racconta che sia capace di trasformare in muffa coloro che lo indossano. Alcuni avventurieri non hanno percepito alcuna differenza dopo averlo indossato.",ep:0,g:184,l:51,wd:false,fm:true,w:10,s:154,p:6975};
I.u[10856] = {n:"Ascia di Ladrurbo",t:19,d:"Ladrurbo era un bandito molto cattivo divorato dai rimorsi, si sentiva obbligato a restituire quel che aveva rubato. Quest\'arma magica è ancora impregnata dell\'anima del Bandito Ladrurbo. Magari potrai riuscire ad incarnarti in lui utilizzando quest\'arma.",ep:0,g:58,l:47,wd:true,fm:false,w:10,an:17,e:[5,4,1,1,40,50,false,false],s:152,p:5900};
I.u[10857] = {n:"Martello di Cudine",t:7,d:"Questo martello ha permesso di forgiare delle Mutande in Kriptonite per il Capitano Chafer. Quest\'arma magica è ancora impregnata dell\'anima del Forgiatore Oscuro Cudine. Magari potrai riuscire ad incarnarti in lui utilizzando quest\'arma.",ep:0,g:724,l:51,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,40,50,false,false],s:153,p:7000};
I.u[10858] = {n:"Bacchetta di Kloug",t:3,d:"Kloug amava mostarsi generoso con coloro che osavano rivolgergli la parola, regalando loro del pane. Usava questa bacchetta per dare giudizi e punire gli innocenti. Quest\'arma è ancora impregnata della magia di Kloug il Panettiere Oscuro. Magari potrai riuscire ad incarnarti in lui utilizzando quest\'arma.",ep:0,g:73,l:53,wd:false,fm:false,w:10,an:11,e:[5,4,3,5,50,50,false,false],s:154,p:5000};
I.u[10860] = {n:"Pozione di cambiamento di nome",t:12,d:"Questa pozione permette di cambiare nome. Nessuno si ricorderà che ti chiamavi Xx-Roxxor-naruto-killer-feca-xX. Una nuova vita senza prese in giro ti si apre davanti. Potrai finalmente diventare qualcuno.",ep:0,g:718,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10861] = {n:"Pozione di cambiamento di colore",t:12,d:"Del rosa per i capelli, del malva per i calzini, e del fucsia per la pelle. La natura non ti ha rovinato, ma ora potrai finalmente rimediare. E\' l\'occasione che hai sognato per poter vedere la vita nei toni degli escrementi di oca.",ep:0,g:717,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10862] = {n:"Pozione di cambiamento di sesso",t:12,d:"Questa pozione, da bere direttamente alla bottiglia, ti permetterà di diventare un lui se sei una lei, o di diventare una lei se sei un lui. Da bere senza moderazione.",ep:0,g:719,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10863] = {n:"Sgarbarakne",t:18,d:"Questa Arakne è proprio maleducata, salta dappertutto, grida, morde chiunque, ma le vuoi bene lo stesso, e senza sapere perchè. La natura l\'ha inoltre dotata di un appetito feroce, questo famiglio divoratore di anime adora attaccare e in seguito divorare i moskito e le larve.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10864] = {n:"Fuuung Fuuung",t:18,d:"Questo Fung Fung fuori dal comune è stato cresciuto da una muta di Buulupi. Questo però non spiega come mai abbia i peli sotto le ascelle. Questo famiglio divoratore di anime adora i frutti di mare e non mangia altro che le creature della spiaggia.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10865] = {n:"Tofulmine",t:18,d:"Questo Tofu è stato fulminato 11 volte durante la crescita. Riceverai scariche elettriche se lo accarezzerai e ti fulminerà se non lo accarezzerai. Per una volta puoi scegliere. Questo divoratore di anime non sopporta i ratti e se ne nutre ogni volta che gliene capita l\'occasione.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10866] = {n:"Prespina",t:18,d:"Questo famiglio ama i cuori di carciofo con sangue di Rasbul, l\'insalata belga con peli di Bituf e le canzoni di Claudius Baglionus.\nSembra anche che gli piaccia la tua compagnia. Questo divoratore di anime mangia solo creature della Giungla Oscura.",ep:0,g:61,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10867] = {n:"Fantasma di Sgarbarakne",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:57,l:1,wd:true,fm:true,w:1,p:1};
