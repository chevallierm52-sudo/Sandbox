I.u[10899] = {n:"Bastone di Manitù Zoth",t:4,d:"Manitù Zoth era un manutentore, aggirava i problemi invece di risolverli. Ma che importa, era temuto all\'interno della comunità degli Zoth e gridava più forte di tutti gli altri, e la cosa fu sufficiente per farlo diventare capo degli Zoth. Questo bastone è ancora impregnato della sua anima. Magari potrai riuscire ad incarnarti in lui utilizzando quest\'arma.",ep:0,g:91,l:50,wd:false,fm:false,w:10,an:12,e:[5,3,1,1,40,50,false,false],p:6000};
I.u[10900] = {n:"Scaglia di krokiglia",t:24,d:"Hai in mano tutto quel che resta di quelle gigantesche krokiglie avvistate sulla penisola delle Draguova. Non se ne può nemmeno fare un buon portacenere.",ep:0,g:767,l:1,wd:false,fm:true,w:0,p:0};
I.u[10901] = {n:"Gigantesco Canino",t:24,d:"Grasmera e Grozilla si sono affrontati in un combattimento epico. Tutto quel che rimane è questo canino di taglia smisurata. Chi crederà che eri li ?",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:0};
I.u[10902] = {n:"Mutande del Manitù Zoth",t:24,d:"Adesso potrai dire senza mentire che il Manitù Zoth è tutto nudo sotto il suo pareo.",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10903] = {n:"Chiave dell\'Antro di Manitù Zoth",t:24,d:"Questa chiave permette di andare a combattere il Manitù Zoth.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[10904] = {n:"Grozillamu",t:1,d:"Questo amuleto testimonia la tua incontestabile capacità di rompere le uova senza fare frittate.",ep:0,g:157,l:51,wd:false,fm:true,w:10,p:7050};
I.u[10906] = {n:"Scudo Dragonico",t:82,d:"Fabbricato a partire da una Scaglia di Grozilla, questo pesante Scudo ha un\'incredibile prestanza. Solo rari e pericolosi guerrieri possono sfoggiare uno stendardo così eminente.",ep:0,g:51,l:1,wd:false,fm:false,w:10,p:0};
I.u[10907] = {n:"",t:23,d:"",ep:0,g:17,l:1,wd:false,fm:true,w:10,p:0};
I.u[10908] = {n:"Regalo Beta-Tester Dongioni DOFUS 2.0",t:89,d:"Questo regalo ti è stato offerto perchè hai passato più tempo nei dongioni del beta-test DOFUS 2.0 che i comuni mortali.",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10909] = {n:"Ferormone di Tofu",t:48,d:"Questa polvere di ferormone essiccato potrà attirare un tofu a chilometri di distanza. Sempre se i tuoi ferormoni non li asfissiano.",ep:0,g:241,l:1,wd:false,fm:true,w:1,p:1};
I.u[10910] = {n:"Regalo Scatola da collezione DOFUS 2.0",t:89,d:"Questo costume farà di te una luce, a patto che tu taccia. In caso contrario, potrà sempre impressionare gli abitanti di Astrub.",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10911] = {n:"Pozione di richiamo di M. Scouty",t:12,d:"Due volte più cremosa e due volte più untuosa di una pozione di richiamo classica, la “Pozione di richiamo di M. Scouty” ti permetterà di teletrasportarti allo zaap di Astrub non importa dove tu sia. Il doppio effetto di questa pozione ti assicura un uso prolungato, che dura a lungo, veramente a lungo.\nLa “Pozione di richiamo di M. Scouty” è un marchio depositato delle imprese Keurk & Spouky.",ep:0,g:26,l:1,wd:false,fm:false,w:0,c:"Sc=666",u:true,p:0};
I.u[10912] = {n:"Regalo di Nawal ridicolo",t:89,d:"I regali di Nawal non hanno tutti la stessa dimensione. Gli avventurieri che non sono stati molto coraggiosi guadagneranno dei regali ridicoli e il diritto di lamentarsi o di essere presi in giro.",ep:0,g:2,l:6,wd:false,fm:true,w:10,u:true,p:1};
I.u[10913] = {n:"Regalo di Nawal soddisfacente",t:89,d:"Chi ha fatto questo regalo è molto pretenzioso ed è convinto che il suo contenuto sarebbe stato soddisfacente.",ep:0,g:2,l:7,wd:false,fm:true,w:20,u:true,p:1};
I.u[10914] = {n:"Regalo di Nawal potenzialmente superpotente",t:89,d:"Questo regalo potrebbe essere potenzialmente interessante, se ci fidiamo di quello che è scritto sul fiocco in tessuto, ma non fidarti mai di quello che è scritto sui fiocchi in tessuto.",ep:0,g:2,l:8,wd:false,fm:true,w:30,u:true,p:1};
I.u[10915] = {n:"Obiettivo della missione di Felice Nawal",t:24,d:"Felice Nawal ti ha indicato l\'identità di uno dei ladri del deposito di Babbo Nawal.\nSe da qui a due ore non riesci a batterlo, puoi, se vuoi, tornare da Felice Nawal per ottenere un nuovo obiettivo di missione.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10916] = {n:"Felicitazioni di Felice Nawal",t:24,d:"La tua vittoria è stata molto apprezzata da Felice Nawal.Torna da lui fra 24 ore, avrà ancora bisogno dei tuoi servizi se le casse non saranno state tutte recuperate fino a quel momento.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10917] = {n:"Piccola cassa di regali",t:24,d:"Questa piccola cassa proviene dal deposito di Babbo Nawal. Restituirla al suo proprietario farà di te un eroe.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10918] = {n:"Cassa di regali",t:24,d:"Questa piccola cassa proviene dal deposito di Babbo Nawal. Restituirla al suo proprietario farà di te un eroe.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10919] = {n:"Grande cassa di regali",t:24,d:"Questa piccola cassa proviene dal deposito di Babbo Nawal. Restituirla al suo proprietario farà di te un eroe.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10920] = {n:"Biscotti di Nawal",t:24,d:"Ecco dei deliziosi biscotti cucinati con amore. Peccato che tu non possa provarli.",ep:0,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[10921] = {n:"Regalo sigillato del Minotobul",t:24,d:"Nessuno sa cosa contiene questo regalo, il Minotobul ha portato questo segreto nella sua tomba. Lo sai che è tutta colpa tua? Non hai niente di cui vantarti.",ep:0,g:715,l:1,wd:false,fm:true,w:0,p:1};
