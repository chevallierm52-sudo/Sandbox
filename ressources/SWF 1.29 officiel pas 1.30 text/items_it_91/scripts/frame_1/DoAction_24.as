I.u[10685] = {n:"Casco del Roks Or",t:16,d:"Equipaggiata con questo casco in oro, la tua testa sarà rapidamente messa in vendita e varrà il suo peso in oro.",ep:0,g:254,l:52,wd:false,fm:true,w:10,s:151,p:7325};
I.u[10686] = {n:"Mantello del Roks Or",t:17,d:"Questo mantello in tessuto, ricoperto di una fine lamina d\'oro, è magico. Attira gli sguardi e reinvia la luce direttamente nelle pupille dei subdoli che tenteranno di pugnalarti alle spalle. Indispensabile se hai degli amici Etram.",ep:0,g:171,l:54,wd:false,fm:true,w:10,s:151,p:7750};
I.u[10687] = {n:"Anello del Roks Or",t:9,d:"Quest\'anello è così pesante che aumenta considerevolmente l\'inerzia del tuo pugno quando semini colpi ai tuoi avversari. Quando avrai cominciato a punire i cattivi, sarà quasi impossibile fermarti.",ep:0,g:182,l:51,wd:false,fm:true,w:10,s:151,p:6862};
I.u[10688] = {n:"Cintura del Roks Or",t:10,d:"Questa cintura è perfetta per nascondere i tuoi lingotti d\'oro intorno alla tua vita, passeranno inosservati.",ep:0,g:166,l:53,wd:false,fm:true,w:10,s:151,p:7525};
