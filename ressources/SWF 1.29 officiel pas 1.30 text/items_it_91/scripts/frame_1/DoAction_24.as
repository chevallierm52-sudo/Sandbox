I.u[10544] = {n:"Gellufo",t:18,d:"Questa creatura venuta da lontano è stata ammaestrata dal suo precedente maestro per mangiare solo i mostri provenienti dalla famiglia dei Blop. È forse la ragione che spiega il suo aspetto sorprendente o il suo alito di Blop.",ep:0,g:55,l:1,wd:true,fm:true,w:10,p:1};
I.u[10552] = {n:"Yugoppello",t:16,d:"Questo copricapo sorprendente proteggerà in modo efficace le tue orecchie dal freddo e dalle cattive battute dei tuoi amici.",ep:0,g:245,l:41,wd:true,fm:true,w:10,s:134,p:4525};
I.u[10553] = {n:"Cappello di Tolot",t:16,d:"Solo un giocatore di Pappaball può avere l\'idea strampalata di travestirsi da Tofu per impressionare i nemici. A meno che non si tratti di fendere l\'aria come nessun altro grazie alla forma affusolata di questo Cappello. Comunque sia, non passerai inosservato.",ep:0,g:252,l:41,wd:false,fm:true,w:10,s:142,p:4550};
I.u[10554] = {n:"Cappello di Beneji",t:16,d:"Gli Occhiali integrati in questo Casco ti permetteranno di vedere rosso e di sentirti più Pappaton che mai.",ep:0,g:253,l:41,wd:false,fm:true,w:10,s:143,p:4550};
I.u[10555] = {n:"Scudo del Real Pappid",t:82,d:"Questo Scudo imponente conserva le tracce di numerose partite. Dall\'apparenza robusta, tuttavia non è di alcuna utilità in un vero combattimento, se non per impressionare i nemici o diventare amico dei Pappatutto.",ep:0,g:54,l:1,wd:false,fm:true,w:10,c:"PP>0",s:142,p:1};
I.u[10556] = {n:"Scudo del Pappaton United",t:82,d:"Questo Scudo imponente illustra perfettamente l\'impeto e l\'insolenza della giovinezza: tutta apparenza e niente fegato. Bisogna dirlo, non ti proteggerà da nulla in un vero combattimento, tranne nel caso in cui l\'avversario ti attacchi a colpi di pallone.",ep:0,g:53,l:1,wd:false,fm:true,w:10,c:"PP>0",s:143,p:1};
I.u[10557] = {n:"Guanto del Real Pappid",t:9,d:"Questo Guanto, segnato dal passare del tempo, facilita la presa di palloni o di qualsiasi altra bestiola tonda ricoperta di lana. Quello che ci fai dopo riguarda solo te.",ep:0,g:176,l:43,wd:true,fm:true,w:10,s:142,p:4500};
I.u[10558] = {n:"Guanto del Pappaton United",t:9,d:"Questo Guanto permetterà al giovane Baubau pazzo che sei di giocherellare a pallone come un giocatore di Pappaball adulto.",ep:0,g:177,l:43,wd:true,fm:true,w:10,s:143,p:4500};
I.u[10559] = {n:"Cintura di Tolot",t:10,d:"Inizialmente concepita per assorbire gli shock durante le violente partite di Pappaball, questa Cintura potrà servirti anche come salvagente se per caso vorrai farti un bagno. Che idea strana.",ep:0,g:159,l:41,wd:false,fm:true,w:10,s:142,p:4600};
I.u[10560] = {n:"Cintura di Munù",t:10,d:"Questa Cintura mostra a che punto il pappaball non sia uno sport per ragazzine, ecco la ragione delle protezioni giudiziosamente posizionate sotto la cintura per evitare qualsiasi colpo basso un po\' troppo basso. L\'ideale per garantire l\'allenamento dei piccoli Etram.",ep:0,g:160,l:41,wd:false,fm:true,w:10,s:143,p:4600};
I.u[10561] = {n:"Stivali del Real Pappid",t:11,d:"Questi Stivali hanno vissuto, e si sente. Con essi potrai spacciarti per un grande giocatore di Pappaball e dare un bel calcio nei posteriori a qualche Pappatutto davanti ai tuoi fan.",ep:0,g:144,l:42,wd:false,fm:true,w:10,s:142,p:4825};
I.u[10562] = {n:"Stivali del Pappaton United",t:11,d:"Questi Stivali alla moda faranno furore tra tutti i giovani avventurieri affascinati dal Pappaball. Facilitano le cadute per poter fare finta più facilmente d\'essere stato spinto da un avversario. L\'ideale per imparare i rudimenti dello sport.",ep:0,g:145,l:42,wd:false,fm:true,w:10,s:143,p:4825};
I.u[10563] = {n:"Orbe Ricostituente",t:50,d:"Questo oggetto permette di ripartire i propri Punti Caratteristica. I Maestri dei Templi di Classe sanno come utilizzarlo.",ep:0,g:460,l:1,wd:true,fm:true,w:100,p:1000};
I.u[10564] = {n:"Pacchetto Orbe Ricostituente",t:89,d:"Questo pacchetto contiene un Orbe incartato in modo prezioso.",ep:0,g:42,l:1,wd:true,fm:true,w:0,u:true,p:1};
