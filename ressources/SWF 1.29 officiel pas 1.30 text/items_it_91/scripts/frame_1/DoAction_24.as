I.u[10657] = {n:"Cercatore di Ogrin",t:18,d:"Questo strano Famiglio è nato da un incrocio tra i migliori cercatori di tartufi di tutta Amakna. L\'enorme muso gli permette di scovare gli Ogrin, perfino quando sono nascosti sott\'acqua. Otomai ha impiegato moltissimi anni per ottenere questa specie e si dice che la utilizzi per rimediare ad uno dei suoi grandi errori, ritrovare ciò che ha perso o lasciato fuggire. Nessuno lo sa... La ricerca degli Ogrin implica un procedimento fisiologico così complesso e costoso in termini energetici che questa creatura è obbligata a consumare le anime dei mostri per crescere. È stata allevata sulle spiagge dell\'Isola di Otomai e divora solo le anime delle creature che vivono lì.",ep:0,g:56,l:1,wd:true,fm:true,w:10,p:1};
I.u[10658] = {n:"Fantasma di Cercatore di Ogrin",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:56,l:1,wd:true,fm:true,w:1,p:1};
I.u[10659] = {n:"Uovo del Cercatore di Ogrin",t:72,d:"Questo strano Uovo contiene una piccola creatura magica. Tienila al caldo, finirà di sicuro per schiudersi.",ep:0,g:206,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10660] = {n:"Regalo Uovo di Cercatore di Ogrin",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10661] = {n:"Certificato di Deposito al Cianil: Cercatore di Ogrin",t:77,d:"Questo Certificato descrive le caratteristiche del Cercatore di Ogrin che hai lasciato al Cianil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10662] = {n:"Runa Pa Prospe",t:78,d:"Questa potente runa permette di avere più possibilità di trovare oggetti rari.",ep:0,g:36,l:20,wd:true,fm:true,w:1,p:10};
I.u[10663] = {n:"Brioche di Carne di Pappatutto",t:33,d:"Bisogna avere lo stomaco forte per inghiottire questa Brioche. La Carne di Pappatutto utilizzata, non sempre di giornata, ha un sapore vicino a quello delle ostriche al cioccolato. Una delizia per i Bwork.",ep:0,g:71,l:20,wd:true,fm:true,w:1,c:"Sc=1",u:true,ut:true,p:1};
I.u[10664] = {n:"Alberaghianda",t:94,d:"Molto delicata come tutte le ghiande, basta strofinarla leggermente perchè espella l\'Alberagno imprigionato al suo interno.",ep:0,g:15,l:1,wd:true,fm:true,w:0,c:"Sc=2&(PB=4|PB=22|PB=33|PB=169|PB=170|PB=486|PB=168)",u:true,p:0};
I.u[10665] = {n:"Scrigno di Giorbak",t:94,d:"Giorbak ha perso tutta la sua fortuna, quindi cosa potrà mai contenere questo strano Scrigno? Aprilo per scoprirlo.",ep:0,g:16,l:1,wd:true,fm:true,w:1,u:true,p:0};
I.u[10667] = {n:"Impronta di Giorbak",t:24,d:"Sei riuscito ad annotare quando si manifesterà lo Spirito di Giorbak. E\' inutile precipitarsi.",ep:0,g:251,l:1,wd:true,fm:true,w:0,p:0};
I.u[10668] = {n:"Buona Fortuna di Giorbak",t:28,d:"Per un po\' di tempo beneficerai della Fortuna di Giorbak.",ep:0,g:16,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10669] = {n:"Pozione di Buzzurrospo",t:12,d:"Così impari a bere qualsiasi cosa!",ep:0,g:18,l:1,wd:true,fm:true,w:1,c:"Sc=4",u:true,p:0};
I.u[10670] = {n:"Pergamena di Persimol",t:94,d:"Semplice da seguire come una ricetta di cucina Wabbit, le indicazioni di questa pergamena rivelano un segreto che ammalia.",ep:0,g:17,l:1,wd:true,fm:true,w:1,c:"Sc=5",u:true,p:0};
I.u[10673] = {n:"Pozione di MmmMmmMmmmh",t:12,d:"MmmMmmMmmmh.",ep:0,g:191,l:1,wd:true,fm:false,w:1,c:"Sc=7",u:true,ut:true,p:1};
I.u[10674] = {n:"Mmmmm",t:28,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:0,g:18,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10675] = {n:"Regalo di Dofus",t:89,d:"Buon Nawal! Non ti riveleremo mai il contenuto di questo regalo, ma sappi che ti darà la possibilità di divertirti e far festa. Nei giorni di festa, ci vuole proprio un regalo così.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10676] = {n:"Doppio effetto Kill Coos",t:28,d:"La tua Prospezione e la tua Saggezza sono aumentate per numerosi combattimenti.",ep:0,g:19,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10677] = {n:"Shigekax Kill Coos",t:42,d:"Ritrova il sapore e tutto il fascino dei dolciumi di un tempo con questa caramella preparata in modo tradizionale\n(Questa caramella aumenta la Prospezione e la Saggezza di 100 punti per 20 combattimenti).",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"PO!10676",u:true,p:1};
I.u[10678] = {n:"Viaggiare senza mai perdere il nord",t:25,d:"Arpagnagrobis ha scritto quest\'opera per tutti gli avventurieri che non sanno usare bussole e zaap.",ep:0,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10679] = {n:"null",t:12,d:"",ep:0,g:716,l:1,wd:false,fm:true,w:0,c:"Qf=485",u:true,p:1};
I.u[10680] = {n:"Souvenir sanguinante del Gultarminator",t:24,d:"Hai estratto questo cuore dall\'Essenza Malefica di Gultard. Potrai metterlo sulla tua scrivania come souvenir.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10681] = {n:"Trasformazione in Buzzurrospo",t:31,d:"Ben fatto!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[10682] = {n:"Il Segreto di Persimol",t:29,d:"Fortuna e felicità vanno a braccetto.",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:0};
