I.u[10618] = {n:"Runa Pa Da Per",t:78,d:"Questa potente runa aumenta i danni percentuali causati agli avversari.",ep:0,g:16,l:30,wd:true,fm:true,w:1,p:10};
I.u[10619] = {n:"Runa Ra Da Per",t:78,d:"Questa runa leggendaria aumenta i danni percentuali causati agli avversari.",ep:0,g:16,l:30,wd:true,fm:true,w:1,p:10};
I.u[10621] = {n:"Ordini dei Sacro",t:24,d:"Questo documento strappato elenca gli ordini dei Sacro. Semplici, consistono nella caccia e nell\'esecuzione di un bersaglio. Ma soprattutto, qualsiasi sia l\'esito dello scontro, non tornare indietro prima di dieci minuti.",ep:0,g:176,l:1,wd:true,fm:true,w:0,p:0};
I.u[10622] = {n:"Spada di Griut",t:6,d:"Questa Spada permetteva a Griut il Bwork di tagliare in due le noccioline degli avversari, cosa che di solito bastava a farli fuggire da qualsiasi combattimento. Quest\'Arma Magica è ancora impregnata della personalità di Griut. Equipaggiandola forse riuscirai ad incarnarla.",ep:0,g:94,l:41,wd:true,fm:false,w:10,an:0,e:[5,5,1,1,50,50,false,false],s:144,p:4600};
I.u[10623] = {n:"Amuleto di Griut",t:1,d:"Griut il Bwork non era molto intelligente. Anzi, era proprio stupidissimo. Per fortuna i metodi di insegnamento ancestrali funzionavano sui Bwork come sui bambini. Qualche bastonata ben meritata ha finito per avere la meglio sulla sua stupidità e, nel corso degli anni, Griut è diventato solo un pochino stupido.",ep:0,g:153,l:42,wd:true,fm:true,w:10,s:144,p:4900};
I.u[10624] = {n:"Cintura di Griut",t:10,d:"Coloro che hanno avuto a che fare con Griut il Bwork potranno ripetertelo: \"Non mirare alla testa, è vuota\". Il consiglio è valido per tutti coloro che devono affrontare gli Yop, i Goblin e le suocere.",ep:0,g:163,l:40,wd:true,fm:true,w:10,s:144,p:4300};
I.u[10625] = {n:"Stivali di Griut",t:11,d:"Gli Stivali di Griut sprigionano un odore talmente ripugnante da poter asfissiare gli avversari con un semplice calcio in testa. Da molto tempo la Convenzione di Sufokia ha vietato questi Stivali durante i combattimenti. Nessuno rimetterà in discussione questa decisione che ha evitato numerose morti atroci.",ep:0,g:150,l:44,wd:true,fm:true,w:10,s:144,p:5250};
I.u[10626] = {n:"Spada di Koccid",t:6,d:"La vita di uno Chafer Fante non è facile, contrariamente a quello che si potrebbe credere. Ma visto che nessuno è mai riuscito ad immaginare come vive uno Chafer Fante, se ne infischiano tutti e si pensa che abbia una vita facile. È a causa di ragionamenti stupidi come questo che lo Chafer Fante è diventato uno Chafer Fante. Quest\'Arma Magica è ancora impregnata della personalità di Koccid. Equipaggiandola forse riuscirai ad incarnarla.",ep:0,g:95,l:41,wd:true,fm:false,w:10,an:0,e:[5,5,1,1,50,50,false,false],s:145,p:4600};
I.u[10627] = {n:"Anello di Koccid",t:9,d:"Koccid lo Chafer Fante aveva molti svaghi piuttosto malsani, come mangiare delle patatine all\'aceto con una crema spalmabile o, ancora peggio, mangiare Peli di Maomao. Sono in molti ad aver tentato di portarlo sulla buona strada e ad essersi persi sulla via del ritorno.",ep:0,g:179,l:41,wd:true,fm:true,w:10,s:145,p:4650};
I.u[10628] = {n:"Stivali di Koccid",t:11,d:"Non c\'è niente di più rumoroso delle Ossa che sbattono sul parquet di Olmo. Grazie a questi Stivali, Koccid lo Chafer Fante poteva ballare l\'Ankarmagnola tutta la notte senza temere di svegliare i vicini, i morti o i vicini morti.",ep:0,g:149,l:42,wd:true,fm:true,w:10,s:145,p:4800};
I.u[10629] = {n:"Cintura di Koccid",t:10,d:"Koccid lo Chafer Fante aveva due sogni nella vita: scalare la Montagna dei Croccaroc e diventare Menestrello. La vita fu molto crudele con lui poiché dovette accontentarsi di suonare prima dei concerti di Claudius Baglionus. A volte il destino si accanisce contro di noi. Questa volta si è accanito contro quello di Koccid.",ep:0,g:164,l:42,wd:true,fm:true,w:10,s:145,p:4900};
I.u[10630] = {n:"Bastone di Gobluovo",t:4,d:"Questo Bastone assomiglia stranamente ad una Lancia, Gobluovo il Goblin ha fatto montare una Lama aguzza all\'Estremità di questo Bastone per poter trafiggere le Uova di Tofu a distanza. È inutile cercare una spiegazione razionale a tutto ciò: i Goblin, semplicemente, hanno sempre praticato giochi molto strani. Quest\'Arma Magica è ancora impregnata della personalità di Gobluovo. Equipaggiandola, forse riuscirai ad incarnarla.",ep:0,g:90,l:43,wd:true,fm:false,w:10,an:0,e:[10,5,1,1,50,50,false,false],s:146,p:5040};
I.u[10631] = {n:"Amuleto di Gobluovo",t:1,d:"Ecco un motto molto popolare tra i Goblin: \"A volte sei tu ad urtare l\'orso, a volte è l\'orso che ti urta\". Guardando attentamente i Goblin, il motto potrebbe venir riassunto così: \"A volte è l\'orso che ti urta\".",ep:0,g:152,l:42,wd:true,fm:true,w:10,s:146,p:4837};
I.u[10632] = {n:"Cintura di Gobluovo",t:10,d:"A Gobluovo il Goblin piaceva inghiottire le uova in stato avanzato di putrefazione. Se il suo apparato digestivo sopportava senza problemi questa spiacevole abitudine, le persone che si trovavano in prossimità del suo alito putrido cadevano come Mosquito. Questa Cintura permetteva a tutti i vicini di aggrapparsi prima di cadere penosamente al suolo.",ep:0,g:165,l:42,wd:true,fm:true,w:10,s:146,p:4800};
I.u[10633] = {n:"Anello di Gobluovo",t:9,d:"Gobluovo il Goblin era appassionato di giardinaggio, soprattutto quando si trattava di dare colpi di rastrello sugli imprudenti che si avvicinavano alle sue terre. Ha trovato questo Anello rastrellando il dito di un imprudente che aveva camminato su uno dei suoi piedi di Insalace.",ep:0,g:180,l:44,wd:true,fm:true,w:10,s:146,p:5250};
I.u[10634] = {n:"Arco di An Lekter",t:2,d:"Il Kannibul An Lekter utilizzava quest\'Arma per cacciare le prede e per far divertire i suoi piccoli ficcando qualche freccia nei loro sederini quando era di buon umore. Quest\'Arma Magica è ancora impregnata dell\'Anima del Kannibul An Lekter. Equipaggiandola, forse riuscirai ad incarnarla.",ep:0,g:68,l:41,wd:true,fm:false,w:10,an:0,tw:true,e:[10,5,1,5,30,50,false,false],s:147,p:2000};
I.u[10635] = {n:"Amuleto di An Lekter",t:1,d:"Quando le due palline attaccate a questo Amuleto si colpiscono, producono un leggero rumore di schiocco che ti permette di prevedere l\'arrivo di un Kannibul. Quando senti questo rumore, di solito è troppo tardi per fuggire, ma hai ancora tempo per scegliere con che salsa vuoi essere divorato.",ep:0,g:151,l:41,wd:true,fm:true,w:10,s:147,p:4525};
I.u[10636] = {n:"Anello di An Lekter",t:9,d:"Questo Anello diffonde alcune spezie per aromatizzare facilmente il brodo quando viene mescolato con le mani. Queste spezie sono così buone che, subito dopo aver equipaggiato l\'Anello, rischi di morderti le dita.",ep:0,g:178,l:42,wd:true,fm:true,w:10,s:147,p:4837};
I.u[10637] = {n:"Stivali di An Lekter",t:11,d:"Il Kannibul An Lekter ha utilizzato questi Stivali per molti anni prima di scambiarli con un turista dell\'Isola di Moon. La fame giustifica i mezzi.",ep:0,g:148,l:43,wd:true,fm:true,w:10,s:147,p:5050};
I.u[10638] = {n:"Spada di Altap Eto",t:6,d:"Il Pandit Altap Eto utilizzava questa Spada colpendo gli avversari con la parte piatta della Lama, per addormentarli senza tagliuzzarli. Di solito un solo colpo al posto giusto bastava per mandarli direttamente al tappeto. Quest\'Arma Magica è ancora impregnata dell\'Anima del Pandit Altap Eto. Equipaggiandola forse riuscirai ad incarnarla.",ep:0,g:93,l:41,wd:true,fm:false,w:10,an:0,e:[3,5,1,1,30,50,false,false],s:148,p:4600};
I.u[10639] = {n:"Amuleto di Altap Eto",t:1,d:"Altap aveva un fratello che si chiamava Verm\'Esolitario. Gli piaceva viaggiare da solo ed esplorare i tunnel oscuri dall\'odore strano.",ep:0,g:154,l:41,wd:true,fm:true,w:10,s:148,p:4525};
I.u[10640] = {n:"Cintura di Altap Eto",t:10,d:"Questa Cintura dovrebbe essere rovesciabile, ma nessuno ha mai osato utilizzare l\'altro lato temendo di scoprire che in realtà non è rovesciabile.",ep:0,g:161,l:40,wd:true,fm:true,w:10,s:148,p:4475};
I.u[10641] = {n:"Stivali di Altap Eto",t:11,d:"Altap Eto ha confezionato questi Stivali da solo, utilizzando Pezzi di Legno e un po\' di Tessuto. Non assomigliano per niente a degli Stivali, ma fa lo stesso, sono comunque magici.",ep:0,g:147,l:41,wd:true,fm:true,w:10,s:148,p:4550};
I.u[10642] = {n:"Piccone di Grisup",t:21,d:"Grisup il Minatore Oscuro ha utilizzato questo Piccone per scavare la celebre Miniera senza Fondo del Kruup, in cui il Gaddy ha vissuto per molti anni. Quest\'Arma è ancora impregnata dell\'Anima di Grisup. Equipaggiandola forse riuscirai ad incarnarla.",ep:0,g:2,l:41,wd:true,fm:false,w:10,an:0,e:[5,5,1,1,50,50,false,false],s:149,p:4600};
I.u[10643] = {n:"Anello di Grisup",t:9,d:"Questo Anello cambia colore quando è immerso nel Brodo di Scozze bollente. Di sicuro ciò spiega perché Grisup il Minatore Oscuro teneva così tanto a questo Anello.",ep:0,g:181,l:43,wd:true,fm:true,w:10,s:149,p:5107};
I.u[10644] = {n:"Stivali di Grisup",t:11,d:"La Suola magica di questi Stivali permette di rompere i blocchi di carbone inviando le vibrazioni necessarie per la loro frammentazione. Le istruzioni indicano che sono in grado di vibrare da sole appena si sente un suono di Pappatuttonik a prossimità.",ep:0,g:146,l:41,wd:true,fm:true,w:10,s:149,p:4575};
I.u[10645] = {n:"Cintura di Grisup",t:10,d:"Questa cintura, rinforzata grazie a numerosi metalli, era abbastanza solida da sostenere il peso delle enormi Borse di Grisup il Minatore Oscuro. Dovrebbe andar bene con delle borse più leggere.",ep:0,g:162,l:43,wd:true,fm:true,w:10,s:149,p:5050};
I.u[10646] = {n:"null",t:1,d:"",ep:0,g:76,l:30,wd:false,fm:true,w:1,p:1};
