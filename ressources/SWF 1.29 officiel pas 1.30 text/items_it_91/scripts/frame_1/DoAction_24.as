I.u[10606] = {n:"Gemma Spirituale di Ratto Bianco",t:85,d:"Guadagnata come ricompensa per le tue vittorie in duello, questa gemma contiene l\'anima di un mostro. Da conservare lontana dalla luce in un luogo asciutto. Agitare prima dell\'uso. ",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
