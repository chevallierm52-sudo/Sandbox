I.u[10597] = {n:"Fantasma di Gellufo",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:55,l:1,wd:true,fm:true,w:1,p:1};
I.u[10598] = {n:"Regalo Gellufo",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[10599] = {n:"Certificato di Deposito al Cianil: Gellufo",t:77,d:"Questo Certificato descrive le caratteristiche del Gellufo che hai lasciato al Cianil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
