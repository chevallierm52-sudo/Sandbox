I.u[10784] = {n:"Amuleto del debuttante",t:1,d:"Nessuno sa cosa aumenti questo amuleto, ma tutti sanno quel che diminuisce: la tua credibilità.",ep:0,g:163,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10785] = {n:"Anello del debuttante",t:9,d:"Questo anello proteggerà le tue dita dalle caccole dei tuoi avversari.",ep:0,g:190,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10786] = {n:"Pelle perfetta di Koalak Immaturo",t:24,d:"Il piccolo Koalak Immaturo a cui hai strappato questa pelle non era molto d\'accordo, ma che importa, eri più forte e crudele di lui.",ep:20,g:811,l:1,wd:true,fm:true,w:1,p:10};
I.u[10787] = {n:"Ala perfetta di Dragacchino Rosso Selvaggio",t:24,d:"Questa ala sa di zolfo. Qualsiasi bravo allevatore ti dirà che è la parte più tenera per un barbecul. Ricordati di condirla però, perché l\'ala è la parte più scialba.",ep:2,g:812,l:29,wd:true,fm:true,w:1,p:1};
I.u[10788] = {n:"Ala perfetta di Dragacchino",t:24,d:"Il Dragacchino domestico è molto più buono di quello selvaggio. Non ha il retrogusto di zolfo e la carne è gustosa al punto giusto. È il piatto preferito di tutti i bambini!",ep:2,g:813,l:29,wd:true,fm:true,w:1,p:1};
I.u[10789] = {n:"Peli di Koalak Forestiero irritanti",t:24,d:"Questi peli sono ricoperti di linfa di Kalipto, e per questo hanno un aspetto brillante e splendente. Sfortunatamente, non possono essere utilizzati nell\'alta moda a causa del loro odore di Dragacchino morto.",ep:20,g:814,l:1,wd:true,fm:true,w:1,p:100};
I.u[10790] = {n:"Osso magico di Mamy Koalak",t:24,d:"La Mamy Koalak ha ossa particolarmente resistenti che non cedono sotto il suo peso. Non si può certo dire la stessa cosa di Claudius Baglionus, il celebre menestrello, che perse l\'uso delle braccia facendosi schiacciare dalle cosce enormi della Mamy Koalak. Che brutta cosa la curiosità!",ep:20,g:815,l:1,wd:true,fm:true,w:1,p:10};
I.u[10791] = {n:"Peli di Barba del Warko Marrone urticanti",t:24,d:"Questi peli sono tanto urticanti da trasformare i baci del Warko Marrone in armi di distruzione di massa.",ep:20,g:816,l:1,wd:true,fm:true,w:1,p:10};
I.u[10792] = {n:"Pozione di cura del debuttante",t:12,d:"Questa fiala serviva anche per l\'analisi delle urine. Ora contiene una pozione capace di restituire i punti vita perduti.",ep:0,g:2,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10793] = {n:"Pane del debuttante",t:33,d:"E\' secco, fa male ai denti, odora di Mutande di Bwork ma ti permette di restituirti punti vita. Smetti di fare lo schizzinoso.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10794] = {n:"Stivali del debuttante",t:11,d:"Caldi all\'interno e freddi all\'esterno, questi stivali vi permetteranno di prendere a calci i glutei degli uomini di neve senza far loro sciogliere il sedere.",ep:0,g:2,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10795] = {n:"Pesc\' Ampanellio del debuttante",t:49,d:"Se colpisci violentemente questo pesce, lo sentirai risuonare. Potrai mangiarlo e poi farti colpire per trasformarti in uno strumento musicale.",ep:0,g:92,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10796] = {n:"Albondigas del debuttante",t:69,d:"Questa polpetta di carne tritata piccante concentra tutto ciò che c\'è di più indigesto nella contrada di Amakna, ma è troppo buono ed il tuo piccolo corpo ne vuole ancora.",ep:0,g:113,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10797] = {n:"Coltellino Ioso del debuttante",t:6,d:"Una volta tolta dal suo fodero questa spada può tagliare il prosciutto, gli Anutrof, le persone senza una gamba, i ballerini e gli Anutrof privi di una gamba avvolti in una fetta di prosciutto che danzano in una notte di luna piena. In compenso per uccidere i mostri è piuttosto inutile.",ep:0,g:96,l:1,wd:false,fm:true,w:1,an:14,e:[5,4,1,1,40,50,false,false],s:150,p:1};
I.u[10798] = {n:"Scudo del debuttante",t:82,d:"Questo Scudo non ti proteggerà dalla tua stupidità.",ep:0,g:55,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10799] = {n:"Cintura del debuttante",t:10,d:"Non riesci a nascondere la tua Spada? Nessun problema, puoi incastrarla fra le maniglie dell\'amore e la tua Cintura.",ep:0,g:10,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10800] = {n:"Mantello del debuttante",t:17,d:"Questo mantello permette di volare, basta chiudere gli occhi, stringere i pugni, aprire la bocca e saltare da una scogliera aprendo le braccia e gridando \"Volooooo !!!\" Alcuni istanti più tardi, ti sveglierai con due gambe rotte.",ep:0,g:3,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10801] = {n:"Cappello del debuttante",t:16,d:"Questa Cappello nasconde mirabilmente la tua calvizie. Purtroppo, non esistono cappelli abbastanza grandi per nascondere la tua falsa modestia.",ep:0,g:264,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10802] = {n:"Dragona Dorata",t:18,d:"Più dorata della Dragona Nera, meno rosa della Dragona Rosa, e più rara della Dragona Scheletrica, questo famiglio attirerà tutti gli sguardi su di te, anche se sei brutto come un Pìu. Questo famiglio divoratore di anime non mangia che i Dabol presenti nei templi di classe.",ep:0,g:57,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:151,p:1};
I.u[10803] = {n:"null",t:32,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10804] = {n:"Regalo Dragona Dorata",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10805] = {n:"Trasformazione in Fantasma Dragona Dorata",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10806] = {n:"Certificato di Deposito al Cianil: Dragona Dorata",t:77,d:"Questo Certificato descrive le caratteristiche della Dragona Dorata che hai lasciato al Cianil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10807] = {n:"Fantasma di Dragona Dorata",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10808] = {n:"Ormone di Dragona Dorata",t:48,d:"Questo ormone di crescita disidratato può essere utilizzato nella preparazione di una potente pozione per migliorare un famiglio.",ep:0,g:240,l:1,wd:true,fm:true,w:1,p:10};
I.u[10809] = {n:"Pozione di Miglioramento di Dragona Dorata",t:116,d:"Utilizzando questa potente pozione, aumenterai le capacità del tuo famiglio in maniera definitiva. Attenzione, una sola dose sarà sufficiente per il tuo famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PO=10802",u:true,p:10};
I.u[10810] = {n:"Ormone di Cercatore di Ogrin",t:48,d:"Questo ormone di crescita disidratato può essere utilizzato nella preparazione di una potente pozione per migliorare un famiglio.",ep:0,g:234,l:1,wd:false,fm:true,w:1,p:10};
I.u[10811] = {n:"Pozione di Miglioramento di Cercatore di Ogrin",t:116,d:"Utilizzando questa potente pozione, aumenterai le capacità del tuo famiglio in maniera definitiva. Attenzione, una sola dose sarà sufficiente per il tuo famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:0,g:54,l:1,wd:true,fm:true,w:1,c:"PO=10657",u:true,p:10};
I.u[10812] = {n:"Messaggio anonimo",t:24,d:"\"Se cerchi del lavoro facile e ben pagato, vieni a nord della città, a est della statua del dio Etram. Vieni solo.\"",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10813] = {n:"Lista di nomi",t:24,d:"Hai trovato questa lista di nomi nella casa di Pandala Dolce. Sembra che si tratti di Pandawa.",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10814] = {n:"Cassa per Pandebitato",t:24,d:"Devi consegnare questa Cassa a Pandebitato, nel villaggio di Aksadala. Il suo contenuto resta un mistero.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10815] = {n:"Liquido strano",t:24,d:"Ke Kasin ti ha chiesto di chiedere l\'aiuto del Mago Ax per analizzare questo liquido.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[10816] = {n:"Petalo Appassito di Rosa Demoniaca",t:24,d:"Questo Petalo sciupato ha perso la sua bellezza, la sua consistenza ora ricorda la pelle dei giovani Anutrof.",ep:0,g:817,l:1,wd:false,fm:true,w:0,p:1};
I.u[10817] = {n:"Anti-dipendente",t:24,d:"Questo prototipo di antidoto dovrebbe poter curare la dipendenza da Succo di Cencio.",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[10818] = {n:"Ascia dell\'Iniziato",t:19,d:"Questa arma dall\'aspetto rudimentale ti darà l\'impressione di essere in grado di combattere.",ep:0,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[10819] = {n:"null",t:93,d:"",ep:0,g:30,l:1,wd:false,fm:true,w:10,ut:true,p:1};
