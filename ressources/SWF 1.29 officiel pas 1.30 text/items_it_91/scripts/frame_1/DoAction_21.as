I.u[9575] = {n:"Cintura del Black Wab",t:10,d:"Questa cintura può essere portata dai due lati, in base a cosa vuoi mostrare o nascondere...",ep:0,g:153,l:46,wd:true,fm:true,w:10,s:127,p:5600};
I.u[9576] = {n:"Stivaletti del Black Wab",t:11,d:"Questi stivaletti in pelle di sedere di Black Wabbit ti permetteranno di prenderti una bella rivincita su queste terribili creature, avendo l\'impressione di dar loro un calcio nel didietro ogni volta che darai un colpo a qualcosa. A volte la vita è fatta di piaceri semplici.",ep:0,g:131,l:47,wd:true,fm:true,w:10,s:127,p:5850};
I.u[9577] = {n:"Maledizione di Assan Trapick",t:30,d:"Devi essere proprio arrabbiato.",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
