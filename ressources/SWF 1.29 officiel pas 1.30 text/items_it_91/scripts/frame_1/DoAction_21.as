I.u[9523] = {n:"Super Ricompensa di Missione Mercenario",t:14,d:"Questa super pergamena certifica che meriti una Super Ricompensa onorifica per il tuo impegno nel corso delle missioni presso i Mercenari.",ep:0,g:6,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[9524] = {n:"Regalo Scudo Tigrato",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9525] = {n:"Regalo di San Balotino",t:89,d:"Questo regalo contiene un kit di sopravvivenza per le operazioni d\'amore rischiose.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9526] = {n:"Promemoria di minacce",t:24,d:"Hai scritto su questo pezzo di carta per ricordarti che non bisogna minacciare un astrubiano quando i mercenari addetti alla sicurezza nel villaggio sono nelle vicinanze.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9527] = {n:"Polvere di unghie incarnite",t:24,d:"Questa vecchia polvere di unghie incarnite appartenne ai piedi di un Anutrof, e ne porta ancora l\'odore. Tutto fa credere che sei stato proprio fregato...",ep:1,g:37,l:1,wd:false,fm:true,w:0,p:1};
I.u[9528] = {n:"Amuleto di Lear",t:24,d:"Questo potente amuleto un tempo apparteneva a Lear, un capo del culto oggi scomparso. Era in contatto con delle creature extra-dimensionali e si dice che potesse clonare le anime incarnate. Era anche dotato di una facoltà d\'auto-resurrezione, un potere molto comodo quando non c\'è un prete nelle vicinanze.",ep:9,g:48,l:1,wd:false,fm:true,w:0,p:1};
I.u[9529] = {n:"Pozione di resurrezione forzata",t:24,d:"A volte capita che un\'anima non possa o non voglia reincarnarsi, quindi si usa questa pozione per renderle il suo corpo d\'origine contro la sua volontà.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9530] = {n:"Bastone da Pescis Stregato",t:24,d:"Con un po\' di fortuna, questo Bastone da Pescis ti permetterà di ottenere una Lingua Guilla da un Pescis.",ep:0,g:739,l:1,wd:false,fm:true,w:0,p:1};
I.u[9531] = {n:"Lingua Guilla",t:24,d:"Questo strano organo è talvolta usato nel metodo della lingua guilla.\nQuesto subdolo metodo consiste nel fare ingoiare una lingua guilla alla vittima, che non può più evitare di parlare gesticolando in tutti i sensi, come se ballasse la Smourf o, peggio ancora, la Pektonik. In tal modo la vittima si stanca molto velocemente, ed è questa la cosa più interessante. Infatti la vittima stanca scambia la prima persona che passa per il miglior amico, cosa che la rende molto più incline a divulgare informazioni.",ep:1,g:740,l:1,wd:false,fm:true,w:0,p:1};
I.u[9532] = {n:"Statuetta di Sumens",t:24,d:"È una delle Statuette offerte da Maiman a Sumens che rappresenta i beni e i mali dell\'umanità. Deve il suo aspetto ad un Incantesimo di Sumens che voleva tenerla al sicuro dalla bramosia della gente.\nRimangono due dubbi: questa Statuetta rappresenta i beni o i mali? E soprattutto, perché averle dato un aspetto così ridicolo?",ep:14,g:738,l:1,wd:false,fm:true,w:0,p:1};
I.u[9533] = {n:"Pietra di Anima Ammansita",t:24,d:"Stregata dal Maestro dell\'Ordine dell\'Occhio Putrido in persona, questa Pietra di Anima ha la facoltà d\'ammansire le Anime in modo che si lascino catturare di buon grado.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9534] = {n:"Pietra di Anima di Terra Tibya",t:24,d:"Questa Pietra di Anima contiene l\'anima dell\'Anutrof Terra Tibya. Dovrai prendertene ben cura se non vuoi che la tua anima ci finisca dentro.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9535] = {n:"Pozione di Transgenesi",t:24,d:"Se utilizzata correttamente, questa pozione permette di accelerare la crescita dei cereali modificando i loro geni. Ciò potrebbe causare degli effetti collaterali al momento del loro consumo, ma ssst, i consumatori non devono sapere niente!\nÈ necessaria la partecipazione di due Contadini e di due Alchimisti.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9536] = {n:"Pergamena di Transgenesi",t:24,d:"Questa pergamena permette d\'attivare gli effetti della Pozione di Transgenesi quando quest\'ultima è stata versata su dei cereali d\'avena.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9537] = {n:"La benedizione d\'Orazzal",t:24,d:"Questo libro, oltre a raccontare storie strampalate di morti che camminano e di fantasmi, descrive il rituale per obbligare un\'anima a reintegrare il suo corpo.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9538] = {n:"null",t:24,d:"",ep:0,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[9539] = {n:"Badge del Capo dei Rinnegati",t:24,d:"Hai preso questo badge ad un Rinnegato Bontariano che non lo meritava.",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9540] = {n:"Mantello del Padrino",t:17,d:"Questo mantello proteggerà il tuo collo dal nevischio e il tuo posteriore dai colpi bassi.",ep:0,g:163,l:48,wd:true,fm:true,w:10,s:126,p:6200};
I.u[9541] = {n:"Borsalino del Padrino",t:16,d:"Questo cappello piuttosto originale permette di affermare con orgoglio il tuo ruolo di padrino. Sbaglieresti a fare senza.",ep:0,g:234,l:43,wd:true,fm:true,w:10,s:126,p:5100};
I.u[9542] = {n:"Scarpe laccate del Padrino",t:11,d:"Queste scarpe sfavillano, anche quando sono totalmente consumate. Molto efficaci per abbagliare gli avversari quando le riceveranno sulla loro testa.",ep:0,g:130,l:40,wd:true,fm:true,w:10,s:126,p:4450};
I.u[9543] = {n:"Grande Anellaccio del Padrino",t:9,d:"Questo pesante anello permette di dare un po\' più inerzia ai tuoi schiaffi e una nota un po\' più piccante alle tue carezze.",ep:0,g:166,l:40,wd:true,fm:true,w:10,s:126,p:0};
I.u[9544] = {n:"Tormentatore di Tenebre",t:114,d:"Questa terribile arma magica è stata confezionata per Issering, il famoso eroe e Tuttofare. Canalizza la magia di colui che l\'utilizza per farla uscire sotto forma di potenti scariche. Ma non è tutto: quest\'arma magica modifica l\'aspetto di colui che l\'utilizza e gli permette d\'utilizzare nuovi sortilegi. Il suo proprietario diventa così un\'altra persona e il suo Tormentatore diventa il suo unico amico, fino a che decide di non usarlo più.",ep:0,g:1,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
