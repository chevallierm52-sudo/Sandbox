I.u[9170] = {n:"Blopintura Indaco",t:10,d:"Dietro a questo stupido nome si nasconde, in realtà, una cintura originale di cui non si conoscono bene né le qualità né i difetti. Si sa solo che è considerata di utilità pubblica grazie all\'eccezionale protezione che dà alle maniglie dell\'amore.",ep:5,g:139,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9171] = {n:"Blopintura Griotta Reale",t:10,d:"Anche se sprovvista di fibbia, questa cintura può comunque fare molto male se la usi per frustare un didietro un po\' delicato. Le punte in ferro arrugginito sono da ordinare separatamente.",ep:5,g:140,l:80,wd:true,fm:true,w:10,s:102,p:16000};
I.u[9172] = {n:"Blopintura Reginetta Reale",t:10,d:"Anche se sprovvista di fibbia, questa cintura può comunque fare molto male se la usi per frustare un didietro un po\' delicato. Le punte in ferro arrugginito sono da ordinare separatamente.",ep:5,g:141,l:80,wd:true,fm:true,w:10,s:103,p:16000};
I.u[9173] = {n:"Blopintura Cocco Reale",t:10,d:"Anche se sprovvista di fibbia, questa cintura può comunque fare molto male se la usi per frustare un didietro un po\' delicato. Le punte in ferro arrugginito sono da ordinare separatamente.",ep:5,g:142,l:80,wd:true,fm:true,w:10,s:104,p:16000};
I.u[9174] = {n:"Blopintura Indaco Reale",t:10,d:"Anche se sprovvista di fibbia, questa cintura può comunque fare molto male se la usi per frustare un didietro un po\' delicato. Le punte in ferro arrugginito sono da ordinare separatamente.",ep:5,g:143,l:80,wd:true,fm:true,w:10,s:105,p:16000};
I.u[9175] = {n:"Blopintura Multicolore Reale",t:10,d:"Stringendo sufficientemente forte questa cintura, si può riuscire a bloccare completamente l\'apparato digestivo del suo proprietario. Non resta che trovare l\'utilità di questa stupidissima azione.",ep:5,g:144,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9176] = {n:"Lama Assacro",t:5,d:"Quando il Bworker cominciò a sviscerare lentamente Claudius Baglionus, quest\'ultimo si mise a cantare: \"Questa tua lametta finaaaaa...\". Da allora il Bworker è diventato sordo.",ep:22,g:70,l:182,wd:true,fm:true,w:10,an:13,e:[7,4,1,1,30,40,false,false],c:"CS>200&CI>150&CC>150&CA>150",s:108,p:58000};
I.u[9177] = {n:"Bracciale Sventrato",t:9,d:"Le tre punte di questo braccialetto rappresentano le tre debolezze del Bworker: la sua sete di vendetta, la sua sete di vittoria e la sua sete e basta.",ep:22,g:158,l:179,wd:true,fm:true,w:10,s:108,p:54000};
I.u[9178] = {n:"Anello Bliterato",t:9,d:"Questo anello è ricoperto di muco del Bworker. Le piccole punte, infatti, gli permettono di pulirsi il naso più efficacemente.",ep:22,g:159,l:179,wd:true,fm:true,w:10,s:109,p:54000};
I.u[9179] = {n:"Amuleto Raschiatura",t:1,d:"Un giorno, il Capitano Chafer incontrò il Bworker e gli disse: \"La tua faccia e il tuo sedere... che differenza c\'è?\". Da quel giorno, nessuno ha rivisto il Capitano Chafer. Persino le sue famose mutande aderenti di cuoio sembrano essere scomparse.",ep:22,g:137,l:184,wd:true,fm:true,w:10,s:108,p:52458};
I.u[9180] = {n:"Mantello Cucito",t:17,d:"Si dice che il Bworker si sia cucito questo mantello con la pelle delle chiappe di Rushu. Questa storia potrebbe anche essere credibile... se solo il Bworker sapesse cucire.",ep:22,g:151,l:185,wd:true,fm:true,w:10,s:108,p:58000};
I.u[9181] = {n:"Elmo Assacro",t:16,d:"Questo magnifico elmo racchiude molti segreti. Per molti anni, durante i quali è stato l\'unico compagno del Bworker, quest\'ultimo gli ha raccontato tutte le sue storie di battaglie e protezioni consumate. Dopo l\'ennesima storia il povero elmo non ce l\'ha più fatta... ed è morto.",ep:22,g:212,l:189,wd:true,fm:true,w:10,s:109,p:59000};
I.u[9182] = {n:"Stivali Battuta",t:11,d:"Molto tempo fa, Danus Kuaid ha voluto fare il furbo e battere il Bworker in un concorso di battute: \"Se hai gli stivali ricoperti da orecchini è semplicemente perché non hai capito che gli stivali non si portano alle orecchie\". Il Bworker gli ha risposto con un colpo di ascia in testa.",ep:22,g:126,l:184,wd:true,fm:true,w:10,s:109,p:58000};
I.u[9183] = {n:"Cintura To",t:10,d:"I due chiodi della cintura si infilavano direttamente nelle maniglie dell\'amore del Bworker. Quando si dimenava ballando la danza del ventre per distrarre i suoi nemici, si potevano intravedere le cuciture della sua biancheria in pelle di Kilibriss. L\'erotismo esasperato del Bworker ha fatto vacillare più di un nemico. La sua lama non ha fatto altro che finirli.",ep:22,g:145,l:181,wd:true,fm:true,w:10,s:109,p:58000};
I.u[9184] = {n:"Elmo di Galgarion",t:16,d:"Malgrado le apparenze, questo elmo non ti permetterà di sentire meglio... ma di vedere meglio! Però stai attento alle bufere inaspettate, il vento potrebbe portarti via...",ep:1,g:213,l:33,wd:true,fm:true,w:10,p:3000};
I.u[9185] = {n:"Copricapo di Gultard",t:16,d:"Questo copricapo non ti renderà più feroce e neanche più potente... E se credi veramente che gli avventurieri più ingenui ti scambieranno per Gultard ti sbagli di grosso! Solo una cosa è sicura: ti si vedrà arrivare da lontano.",ep:1,g:214,l:30,wd:true,fm:true,w:10,p:2600};
I.u[9186] = {n:"Cintura di Flash Gorgon",t:10,d:"Si conoscono solo poche cose su Flash Gorgon, tra cui la sua passione per i vasi in porcellana. La leggenda racconta che questo eroe corre talmente veloce che neanche un Tofu riuscirebbe a raggiungerlo. \nSfortunatamente un giorno, a furia di andare sempre di corsa, agganciò male la cintura... che gli si incastrò nei piedi. La sua collezione di porcellane se ne ricorda ancora...",ep:1,g:146,l:48,wd:true,fm:true,w:30,p:6075};
I.u[9187] = {n:"Copricapo del Maestro Nero Jack",t:16,d:"L\'Aniripsa Maestro Nero Jack ha sempre coltivato una passione per il cucito. Ciò che d\'altronde l\'ha portato a essere un grande esperto in punti di sutura. Amico dei Sarti, si dice che abbia concepito questo copricapo bicolore ispirandosi a una crudele Sarta che sterminò la tribù degli Uginak del Matas... Carino, no?",ep:1,g:215,l:33,wd:true,fm:true,w:10,p:3075};
I.u[9188] = {n:"Sombrero di Pepitox",t:16,d:"Questo Sombrero è ciò che resta di un oscuro Eroe Xelor improvvisamente scomparso. L\'ultima volta che è stato visto aveva appena cantato una serenata alla sua bella. Si dice che i fratelli della giovane ragazza abbiano a che fare con questa scomparsa. Si dice anche che sia stato portato in una dimensione parallela... Il mistero resta completo...",ep:1,g:216,l:40,wd:true,fm:true,w:10,p:5000};
I.u[9189] = {n:"Corna di XVII",t:16,d:"A furia di voler incornare gli altri avventurieri, sarai tu a finire per assomigliare a uno scolapasta! Le Corna di XVII, il demone della diciassettesima ora, hanno infatti la straordinaria capacità di farti dimenticare praticamente tutto... tranne forse l\'ora del pranzo!",ep:1,g:217,l:20,wd:true,fm:true,w:4,p:1300};
I.u[9190] = {n:"Copricapo di Ocra Bruciato",t:16,d:"Ecco un copricapo che si adatta perfettamente agli Ocra che non hanno paura di esser presi per degli imbecilli. Indossandolo, in effetti, non avrai l\'aria molto intelligente. D\'altronde sono quasi sempre gli Yop che lo portano, oppure gli avventurieri che si ritrovano già con qualche neurone in meno...",ep:1,g:218,l:35,wd:true,fm:true,w:5,p:10000};
I.u[9191] = {n:"Spada di Pym",t:6,d:"Pare che questa spada sia stata strappata dall\'insegna di un onesto Forgiatore... Speriamo che ti insegni a colpire più forte di prima! Sennò non ti resterà che aprire la tua botteguccia.",ep:1,g:84,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[9192] = {n:"Ciambellantura",t:10,d:"Quando indosserai questa cintura ti renderai conto che le tue anche non sono mai state così allettanti!",ep:1,g:147,l:45,wd:true,fm:true,w:2,s:110,p:5600};
I.u[9193] = {n:"Pizzamuleto",t:1,d:"Se hai sempre sognato di dare delle pizze ai tuoi amici, regalagli questo amuleto!",ep:1,g:138,l:43,wd:true,fm:true,w:2,s:110,p:5000};
I.u[9194] = {n:"Caskake",t:16,d:"Prima erano le pulci a divorarti la testa. Con questo cappello sulla testa, invece saranno i Pìu a beccartela. A volte è proprio meglio restare calvi.",ep:1,g:219,l:44,wd:true,fm:true,w:2,s:110,p:5200};
I.u[9195] = {n:"Mantelcake",t:17,d:"Dopo essere stato arrotolato intorno a frutta candita e coperto di gelatina reale, questo mantello si può degustare come supposta.",ep:1,g:152,l:45,wd:true,fm:true,w:2,s:110,p:5500};
I.u[9196] = {n:"Mantello Valazza",t:17,d:"Questo mantello fabbricato con chicchi enormi diffonde un odore persistente di ascelle di Bituf aereo. Si dice che serva a eccitare chi ti sta accanto, e a basso costo!",ep:1,g:153,l:45,wd:true,fm:true,w:2,s:111,p:5500};
I.u[9197] = {n:"Cappello Valazza",t:16,d:"Questo cappello ti farà passare la sete. Lo zucchero è da ordinare separatamente.",ep:1,g:220,l:44,wd:true,fm:true,w:2,s:111,p:5200};
I.u[9198] = {n:"Anello Valazza",t:9,d:"Quando l\'acqua o la birra non hanno più gusto, buttateci dentro questo anello.",ep:1,g:160,l:45,wd:true,fm:true,w:2,s:111,p:5600};
I.u[9199] = {n:"Stivali Valazza",t:11,d:"Ecco cosa succede quando si cerca di rompere tazze a colpi di stivale.",ep:1,g:127,l:43,wd:true,fm:true,w:2,s:111,p:5000};
I.u[9200] = {n:"Pergamena di Incantesimo Invocazione di Chafer Paz",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di imparare l\'incantesimo Invocazione di Chafer Paz.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[9201] = {n:"Pewgamena della Cawota",t:75,d:"Questa pewgamena descwive un metodo semplice in 101 lezioni, che ti pewmettewà di impawawe da autodidatta le basi della famosa, ma non tanto segweta, tecnica del We Wabbit.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[9202] = {n:"L\'altro Anelloprofitto del Maestro Jarbo",t:9,d:"Anche da morto Mastro Jarbo continua a forgiare degli oggetti completamente sfasati con l\'equilibrio cosmico del Mondo. Quando creò il suo secondo anello, pensò con tristezza che se l\'avesse avuto un po\' prima, avrebbe potuto attraversare le strade senza rischi. Un giorno un demone glielo rubò e lo nascose nel mondo dei vivi per gli avventurieri in cerca di potenza.",ep:1,g:9,l:1,wd:false,fm:true,w:1,p:0};
I.u[9203] = {n:"Corruttite",t:24,d:"È il materiale di cui ha bisogno Oto Mustam per la sua Lama. La Corruttite si disgrega molto rapidamente e necessita di un Ricettacolo particolare per essere trasportata e conservata senza correre rischi.",ep:1,g:706,l:1,wd:false,fm:true,w:0,p:1};
I.u[9204] = {n:"Corruttite trattata",t:24,d:"Questo Pezzo di Corruttite è stato trattato e non si disgrega più.",ep:16,g:706,l:1,wd:false,fm:true,w:0,p:1};
I.u[9206] = {n:"Ferro Maledetto",t:24,d:"Un po\' di Ferro Maledetto che serve a Oto per la Lama. Sembrerebbe del ferro normale, se solo non sprigionasse un\'Aura che farebbe scappare anche un Kanigrù.",ep:16,g:241,l:1,wd:false,fm:true,w:0,p:1};
I.u[9207] = {n:"Pezzo di Cinghia",t:24,d:"Questa Cinghia di Cuoio sembra essere stata strappata da uno Zaino.",ep:16,g:753,l:1,wd:false,fm:true,w:0,p:1};
I.u[9208] = {n:"Informazioni di Oli Venders",t:24,d:"Hai annotato le informazioni di Oli Venders su questo Foglio. Per accedere al Carpino Oscuro, devi essere in possesso dell\'Anima di un Alberagno Oscuro e di un Oni. Quattro Brakmariani del tuo rango o del rango superiore devono accompagnarti. Almeno due di essi devono essere Taglialegna in grado di tagliare un Carpino.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9209] = {n:"Ricetta dell\'Impugnatura di Spada",t:24,d:"Questa Ricetta indica gli elementi da utilizzare con il Legno di Carpino Oscuro per fabbricare un\'Impugnatura di Spada. Se non hai più Legno di Carpino Oscuro, puoi sempre andare a prenderne di nuovo nel Boschetto dietro l\'Atelier degli Alchimisti di Uba Tessé.\n- 1 Legno di Carpino Oscuro.\n- 3 Cuoi Neri.\n- 2 Sangue del Vampiro.\n- 1 Ebonite.",ep:9,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9210] = {n:"Messaggio di Gwenolaz Barnamuz",t:24,d:"Un Pezzo di Carta destinato al giudice Satirev Onivin sul quale Gwenolaz Barnamuz ha scritto di non essere in vendita.",ep:1,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9211] = {n:"Messaggio di Enileda",t:24,d:"Un Foglio indirizzato al giudice Satirev Onivin sul quale Enileda usa termini a dir poco coloriti per esprimere il suo rifiuto.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9212] = {n:"Messaggio di Nepra Lido",t:24,d:"Una Lettera di rifiuto da consegnare al giudice Satirev Onivin da parte di Nepra Lido sulla quale c\'è scritto: \"Non abbiamo gli stessi valori...\"",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9213] = {n:"Messaggio di Maskara",t:24,d:"Un Foglio di brutta per il giudice Satirev Onivin sul quale Maskara ha scritto di fretta che non diventerà la sua Bambola.",ep:1,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9214] = {n:"Messaggio di Chronokwartz",t:24,d:"Un Messaggio redatto direttamente da Chronokwartz per il giudice Satirev Onivin in cui dice che non si spoglierà per lui ancora per molto molto tempo e che sarà lui ad abbandonarsi a lei molto prima...",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9215] = {n:"Martello di Luce",t:24,d:"Questo Martello è posseduto da un potente Spirito di Luce.",ep:16,g:750,l:1,wd:false,fm:true,w:0,p:1};
I.u[9216] = {n:"Martello dei Chus",t:24,d:"È il Martello di Luce, ma senza lo Spirito di Luce. Consente di forgiare una Lama Demoniaca senza correre rischi.",ep:16,g:751,l:1,wd:false,fm:true,w:0,p:1};
I.u[9218] = {n:"Martello dei Chus Purificato",t:24,d:"È il Martello di Luce, ma senza lo Spirito di Luce. Consente di forgiare una Lama Demoniaca senza correre rischi. Domen lo ha privato di qualche suo potere distruttore.",ep:16,g:751,l:1,wd:false,fm:true,w:0,p:1};
I.u[9219] = {n:"null",t:9,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[9220] = {n:"Spada incompleta",t:24,d:"Questa Spada dall\'aspetto impressionante non è ancora terminata, ma emana già una potente Aura Malefica. Non pensare minimamente di rubarla, non è finita e d\'altronde scatenerebbe la collera di Oto, spettacolo a cui NON vuoi assolutamente assistere.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9221] = {n:"Lama incompleta impregnata (livello 1)",t:24,d:"Questa Lama dall\'aspetto impressionante ti è stata prestata da Oto per impregnarla di potere grazie alle buone cure di Lagren. Non pensare minimamente di rubarla, non è finita e d\'altronde scatenerebbe la collera di Oto, spettacolo a cui NON vuoi assolutamente assistere.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9222] = {n:"Lama incompleta impregnata (livello 2)",t:24,d:"Questa Lama dall\'aspetto impressionante ti è stata prestata da Oto per impregnarla di potere grazie alle buone cure di Lagren. Non pensare minimamente di rubarla, non è finita e d\'altronde scatenerebbe la collera di Oto, spettacolo a cui NON vuoi assolutamente assistere.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9223] = {n:"Lama Incompleta Impregnata (livello 3)",t:24,d:"Questa Lama dall\'aspetto impressionante ti è stata prestata da Oto per impregnarla di potere grazie alle buone cure di Lagren. Non pensare minimamente di rubarla, non è finita e d\'altronde scatenerebbe la collera di Oto, spettacolo a cui NON vuoi assolutamente assistere.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9224] = {n:"Lama Incompleta Impregnata (livello 3)",t:24,d:"Questa Lama dall\'aspetto impressionante ti è stata prestata da Oto per impregnarla di potere grazie alle buone cure di Lagren. Non pensare minimamente di rubarla, non è finita e d\'altronde scatenerebbe la collera di Oto, spettacolo a cui NON vuoi assolutamente assistere.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9225] = {n:"Lama Incompleta Impregnata (livello 5)",t:24,d:"Questa Lama dall\'aspetto impressionante ti è stata prestata da Oto per impregnarla di potere grazie alle buone cure di Lagren. Non pensare minimamente di rubarla, non è finita e d\'altronde scatenerebbe la collera di Oto, spettacolo a cui NON vuoi assolutamente assistere.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9226] = {n:"Essenza di Incubo",t:24,d:"Questa Essenza servirà a impregnare la Spada di Oto di potenza.",ep:16,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[9227] = {n:"Lista matrimoniale di Onivin",t:24,d:"Questa Lista ti è stata data da Satirev Onivin per intercedere in suo favore presso le seguenti donne di Astrub: Nepra Lido, Enileda, Gwenolaz Barnomuz, Maskara, Chronokwartz.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9228] = {n:"Testimonianza di Lamiss",t:24,d:"Su questo Foglio è annotata la Testimonianza di Lamiss.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9229] = {n:"Testimonianza dubbiosa di Lamiss",t:24,d:"Su questo Foglio è annotata la Testimonianza un po\' dubbiosa di Lamiss.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9231] = {n:"Acqua Putrida",t:24,d:"Sembra che questo Secchio sia servito come vaso da notte ad un Capo Coccodrail, ma non è così. L\'Acqua Putrida che contiene è ancora più ripugnante dell\'Acqua delle Paludi senza Fondo. Insomma, il contenuto di questo Secchio resta equivoco...",ep:6,g:46,l:1,wd:false,fm:true,w:0,p:1};
I.u[9232] = {n:"Acqua Putrida Purificata",t:24,d:"Anche se sai benissimo che quest\'Acqua Putrida è stata purificata, non vedi la differenza con la precedente... Guardandola da vicino, ti dici che puzza come prima. È normale visto che ti sei avvicinato col naso!",ep:16,g:46,l:1,wd:false,fm:true,w:0,p:1};
I.u[9233] = {n:"Mantello Vivoggetto",t:113,d:"Questo oggetto polimorfo stabilisce una relazione di predatore o simbionte con i mantelli inanimati. (Devi nutrirlo dandogli da mangiare altri mantelli. Puoi dargli un nuovo pasto ogni dodici ore).",ep:1,g:149,l:1,wd:true,fm:false,w:1,p:1};
I.u[9234] = {n:"Cappello Vivoggetto",t:113,d:"Questo oggetto polimorfo stabilisce una relazione di predatore o simbionte con i cappelli inanimati. (Devi nutrirlo dandogli da mangiare altri cappelli. Puoi dargli un nuovo pasto ogni dodici ore).",ep:1,g:211,l:1,wd:true,fm:false,w:1,p:1};
I.u[9235] = {n:"Versione di Bast sospetta",t:24,d:"Questa Lettera indica che per te la versione di Bast Konliskerz è sospetta.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9236] = {n:"Versione di Bast credibile",t:24,d:"Questa Lettera indica che per te la versione di Bast Konliskerz è credibile.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9237] = {n:"Testimone Lamiss credibile",t:24,d:"Secondo questa Lettera, per te il testimone Lamiss è credibile, a meno che che tu non stia ascoltando la sua pseudo-musica.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9238] = {n:"Testimonianza di Lamiss sospetta",t:24,d:"Secondo questa Lettera, per te il testimone Lamiss è credibile, a meno che che tu non lo dica solo perché non ti piace il suo modo di parlare... o di cantare.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9239] = {n:"Gnerah credibile",t:24,d:"Questa Lettera indica che tu pensi che non sia stato Gnerah. Tanto vale dire che il pesce profuma.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9240] = {n:"Gnerah complice",t:24,d:"Questa Lettera indica che tu pensi che Gnerah abbia messo il Documento Segreto nello Zaino di Bast Konliskerz, oppure deve trattarsi di una vendetta contro l\'abominevole odore che lo accompagna.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9241] = {n:"Parere su Bast sfavorevole",t:24,d:"Questa Lettera indica che secondo te Bast Konliskerz è colpevole di tradimento.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9242] = {n:"Parere su Bast favorevole",t:24,d:"Questa Lettera indica che secondo te Bast Konliskerz è innocente.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9243] = {n:"Bast colpevole",t:24,d:"Questa Lettera indica che hai testimoniato contro Bast Konliskerz. Danathor è soddisfatto di questa tua scelta.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9244] = {n:"Bast innocente",t:24,d:"Questa Lettera indica che hai testimoniato a favore di Bast Konliskerz. Amayiro è soddisfatto di questa tua scelta.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9245] = {n:"Non luogo",t:24,d:"Questa Lettera indica che non sei stato convincente al processo di Bast Konliskerz e che quest\'ultimo ha beneficiato di un non luogo a procedere. È inutile che aspetti la riconoscenza di Danathor o di Amayiro.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9247] = {n:"Chiave del Dongione Fungus",t:84,d:"Questa chiave ti permetterà di entrare nel terribile dongione Fungus.",ep:13,g:247,l:1,wd:true,fm:true,w:1,p:1};
I.u[9248] = {n:"Chiave del Dongione dei Blop",t:84,d:"Questa chiave ti permette di entrare nel dongione dei Blop.",ep:5,g:248,l:1,wd:true,fm:true,w:1,p:1};
I.u[9249] = {n:"Pezzo di chiave Griotta",t:84,d:"Se ritrovi gli altri pezzi di questa chiave potrai avere l\'occasione di affrontare un Blop multicolore.",ep:5,g:250,l:1,wd:true,fm:true,w:1,p:1};
I.u[9250] = {n:"Pezzo di chiave Reginetta",t:84,d:"Se ritrovi gli altri pezzi di questa chiave potrai avere l\'occasione di affrontare un Blop multicolore.",ep:5,g:251,l:1,wd:true,fm:true,w:1,p:1};
I.u[9251] = {n:"Pezzo di chiave Cocco",t:84,d:"Se ritrovi gli altri pezzi di questa chiave potrai avere l\'occasione di affrontare un Blop multicolore.",ep:5,g:252,l:1,wd:true,fm:true,w:1,p:1};
I.u[9252] = {n:"Pezzo di chiave Indaco",t:84,d:"Se ritrovi gli altri pezzi di questa chiave potrai avere l\'occasione di affrontare un Blop multicolore.",ep:5,g:249,l:1,wd:true,fm:true,w:1,p:1};
I.u[9253] = {n:"Pozione di Rabbia Folle",t:24,d:"Domen ha dimenticato di togliere l\'etichetta da questa Pozione. Il suo nome non annuncia nulla di buono...",ep:16,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9254] = {n:"Chiave dell\'Antro del Blop Multicolore",t:84,d:"Questa chiave ti permetterà di affrontare un Blop Multicolore. Dovresti essere contento...",ep:5,g:253,l:1,wd:true,fm:true,w:1,p:1};
I.u[9255] = {n:"Amuleto Vivoggetto",t:113,d:"Questo oggetto polimorfo stabilisce una relazione di predatore o simbionte con gli amuleti inanimati. (Devi nutrirlo dandogli da mangiare altri amuleti. Puoi dargli un nuovo pasto ogni dodici ore).",ep:1,g:139,l:1,wd:true,fm:false,w:1,p:1};
I.u[9256] = {n:"Anello Vivoggetto",t:113,d:"Questo oggetto polimorfo stabilisce una relazione di predatore o simbionte con gli anelli inanimati. (Devi nutrirlo dandogli da mangiare altri anelli. Puoi dargli un nuovo pasto ogni dodici ore.)",ep:1,g:161,l:1,wd:true,fm:false,w:1,p:1};
I.u[9257] = {n:"Soporifero",t:24,d:"Questa Pozione ha una proprietà interessante: aggiunta ad un qualsiasi alimento, chiunque ne mangi sprofonda subito in un sonno profondo. Ogni somiglianza con una pozione che conosci già è puramente casuale.",ep:16,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[9258] = {n:"Minacce del Guardiano",t:24,d:"In questa Lettera il Guardiano della Prigione di Astrub spiega a Darmmelf che i Guardiani hanno le Zanne e che potrebbero affondargliele nella gola se non si sbriga a portare la zuppa.",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9259] = {n:"Lettera di Darmmelf",t:24,d:"In questa Lettera Darmmelf spiega al Taverniere di Astrub che è malato e che ha mandato te per sostituirlo.",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9260] = {n:"Zuppa della Sera",t:24,d:"Questa Zuppa è destinata alle Guardie della Prigione di Astrub. È arrivato il momento di aggiungere un ingrediente più interessante...",ep:1,g:728,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[9261] = {n:"Zuppa Soporifera",t:24,d:"Hai aggiunto del Soporifero alla Zuppa. Le Guardie si faranno un bel sonnellino.",ep:1,g:728,l:1,wd:false,fm:true,w:0,p:1};
I.u[9262] = {n:"Chiave della Prigione di Astrub",t:24,d:"Questa Chiave apre la Cella della Prigione di Astrub.",ep:1,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9263] = {n:"Corteccia di Funknyde",t:96,d:"Il Funknyde è un Alberagno colpito da funghi senza scrupoli che gli si infilano fin dentro la corteccia. Ogni tanto, grattandosi il sedere, l\'Alberagno si strappa un pezzo di micosi purulenta che darà vita a un magnifico fungo che a sua volta parassiterà un altro Alberagno.",ep:23,g:109,l:113,wd:true,fm:true,w:1,p:10};
I.u[9264] = {n:"",t:32,d:"",ep:1,g:28,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9265] = {n:"Terhmiti",t:24,d:"Queste Terhmiti si possono trovare sulle teste dei Croccaroc che non sanno cosa sia l\'igiene.",ep:5,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9266] = {n:"Grasso di Gelatina Reale",t:24,d:"Questo Grasso è stato preso su una Gelatina Reale. È un ingrediente essenziale nella composizione di una Pozione di Paralisi.",ep:7,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9267] = {n:"Tromba della Trompanita",t:15,d:"Con questa sorprendente tromba, ancora carica dell\'alito putrido del suo vecchio proprietario, potrai uccidere tutto il pubblico suonando solo qualche nota.",ep:23,g:764,l:125,wd:true,fm:true,w:1,p:10};
I.u[9268] = {n:"Martello di Luce senza Spirito",t:24,d:"Questo Martello di Luce sembra aver perso lo Spirito, fonte del suo potere. Ora non ispira più tanta fiducia.",ep:3,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9269] = {n:"Lingua del Fungodonte",t:15,d:"Per leccare le spore dei suo compagni, il Fungodonte dispone di una lingua agile e incredibilmente elastica. È veramente l\'unica cosa che gli si possa invidiare.",ep:23,g:765,l:134,wd:true,fm:true,w:1,p:1};
I.u[9270] = {n:"Bambola di Sostituzione",t:24,d:"Una Bambola fabbricata dalle abili mani di Maskara per sostituire quella persa dallo Spirito di Luce.",ep:1,g:680,l:1,wd:false,fm:true,w:0,p:1};
I.u[9271] = {n:"Promessa di Maskara",t:24,d:"Questo Anello rappresenta la promessa di Maskara che ha accettato di giocare alla Bambola con te (ma soprattutto di essere la tua Bambola) quando ne avrà il tempo. È uno dei beni più preziosi al mondo.",ep:1,g:730,l:1,wd:false,fm:true,w:0,p:1};
I.u[9272] = {n:"Cassa di Bonta",t:24,d:"Hai osato rubare questa Cassa nella tua Torre degli Ordini per consegnarla ai Ladrurbi, senza nemmeno sapere cosa contenga. Agire in questo modo significa tradire la fiducia che il Maestro del tuo Ordine ha in te.",ep:1,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9273] = {n:"Rapporto di Bolzano Vecchiamacchia",t:24,d:"Su questo documento c\'è il tuo rapporto sulla discussione con Bolzano Vecchiamacchia.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9274] = {n:"Rapporto di Eowina Fiala",t:24,d:"Su questo documento c\'è il tuo rapporto sulla discussione con Eowina Fiala.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9275] = {n:"Rapporto di Lara Soft",t:24,d:"Su questo documento c\'è il tuo rapporto sulla discussione con Lara Soft.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9276] = {n:"Rapporto di Casper Van Brushing",t:24,d:"Su questo documento c\'è il tuo rapporto sulla discussione con Casper Van Brushing.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9277] = {n:"Occhio di Fungiman",t:109,d:"Il Fungiman ha la brutta abitudine di volersi grattare le palpebre con il suo bastone a punta. Talvolta ci rimette un occhio. Quando invece si gratta il collo, ci rimette la testa.",ep:23,g:587,l:152,wd:true,fm:true,w:1,p:1};
I.u[9278] = {n:"Lamina di Fungbis",t:15,d:"Il Fungbis ha due piedi, due braccia e due teste. Per questo è una creatura due volte più stupida delle altre.",ep:23,g:766,l:144,wd:true,fm:true,w:1,p:1};
I.u[9279] = {n:"Bava di Fung Ignon",t:15,d:"Viscida ma appetitosa, questa bava serve talvolta per oliare le armi, o i corpi degli avventurieri che amano combattere nudi nelle arene.",ep:23,g:45,l:149,wd:true,fm:true,w:1,p:1};
I.u[9280] = {n:"Spina di Ugah",t:15,d:"Ugah possiede solo quattro spine sulla testa, ma sono grosse!",ep:23,g:40,l:900,wd:true,fm:true,w:1,p:1};
I.u[9281] = {n:"Frammento di Ugacapo",t:15,d:"Ugah possiede un magnifico copricapo, e quello che hai tra le mani è uno dei suoi frammenti.",ep:23,g:41,l:900,wd:true,fm:true,w:1,p:1};
I.u[9282] = {n:"Libro: l\'assalto di \'Uk \'Not \'Allag",t:24,d:"Questo libro narra la salita al potere di \'Uk \'Not \'Allag e la sua cattura da parte dell\'attuale re Allister. C\'è scritto che suo fratello Fallanster è l\'unica persona a custodire le chiavi delle manette..",ep:2,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9285] = {n:"Pergamena di illusione: Draguovo",t:24,d:"Questa pergamena ti permetterà di prendere momentaneamente le sembianze di un Draguovo. La parola \"momentaneamente\" è da prendere alla lettera.",ep:11,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9286] = {n:"Informazioni su Satirev Onivin",t:24,d:"Hai ottenuto un\'informazione importante su Satirev Onivin e, per non dimenticarla, l\'hai annotata (insieme all\'appunto di non avvicinargli il naso alla bocca) su questo pezzo di carta.",ep:16,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9287] = {n:"Informazioni su Larry Poller",t:24,d:"Hai ottenuto un\'informazione importante su Larry Poller e, per non dimenticarla, l\'hai annotata (insieme a delle osservazione sul suo aspetto fisico) su questo pezzo di carta.",ep:16,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9288] = {n:"Informazioni su Grace Malcin",t:24,d:"Hai ottenuto un\'informazione importante su Grace Malcin e, per non dimenticarla, l\'hai annotata (insieme a una lista delle cose da fare sabato sera) su questo pezzo di carta.",ep:16,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9289] = {n:"Messaggio 2 di Nepra Lido",t:24,d:"Un messaggio scritto dalle piccole mani dolci e sottili di Nepra Lido in cui dice di essere pronta a incontrare il giudice Satirev Onivin \'per curiosità\'.",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9290] = {n:"Messaggio 2 di Enileda",t:24,d:"Un messaggio scritto dalle abili mani di Enileda che accetta d\'incontrare il giudice Satirev Onivin per dirgli di persona quello che pensa di lui..",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9291] = {n:"Messaggio 2 di Gwenolaz Barnamuz",t:24,d:"Un messaggio scritto di fretta da Gwenolaz Barnamuz in cui descrive la maniera con cui conta di domare il giudice Satirev Onivin, ovvero con la sua frusta (e con la sua tuta di cuoio di Pappaton nero). I gusti non si discutono.",ep:1,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9292] = {n:"Messaggio 2 di Maskara",t:24,d:"Un altro messaggio di Maskara che accetta di incontrare il giudice Satirev Onivin in un luogo tranquillo e rassicurante.",ep:1,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9293] = {n:"Messaggio 2 di Chronokwartz",t:24,d:"Una carta pulita, una scrittura elegante... e un bel rastrello! Cosa c\'è di meglio per convincere il giudice Satirev Onivin a insistere, ancora e ancora?",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9294] = {n:"Un buono commissione Autobus Nano 638",t:24,d:"Un buono commissione consegnato da Enileda a Larry Poller che può venire a prendere il suo Autobus Nano Bus Nain 638 quando vuole.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9295] = {n:"Lettera di minaccia",t:24,d:"Una lettera che indica a Grace Malcin che il suo tabi non è al sicuro.",ep:16,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9296] = {n:"Documento di Fallanster",t:24,d:"Questo documento segnala che Fallanster è attualmente in visita a Sufokia, per risolvere certi problemi diplomatici.",ep:2,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9297] = {n:"Simbolo: Draguovo",t:24,d:"Hai trovato questo simbolo di Draguovo nel Villaggio delle Draguova.",ep:11,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9298] = {n:"Simbolo: Demone",t:24,d:"Hai trovato questo simbolo di un demone nel Villaggio delle Draguova.",ep:11,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9299] = {n:"Simbolo: Tofu",t:24,d:"Hai trovato questo simbolo di Tofu nel villaggio delle Draguova. Non ti rimane che sperare che Uk\'Not\'Allag sia di buonumore, in ogni caso... che epigrafe vuoi sulla tua tomba?",ep:11,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9300] = {n:"Lettera del Sergente Gracia",t:24,d:"Si tratta di una lettera scritta dal Sergente Gracia per Amayiro. Puoi consegnarla a lui o a Danathor. Puoi anche bruciarla, ma non sarebbe educato.",ep:2,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9301] = {n:"Pezzo di Blopisiero Avvelenato",t:24,d:"Ecco un pezzo di blopisiero avvelenato che era destinato ad Amayiro. Sarebbe saggio non provare a mangiarlo, soprattutto se il suo gusto è uguale al suo aspetto.",ep:1,g:47,l:1,wd:false,fm:true,w:0,p:1};
I.u[9303] = {n:"Pietra di Anima di Olledrob",t:24,d:"Questa Pietra di Anima ti è stata data da Olledrob Oterges: sembra che possa catturare delle anime di creature per farne delle guardie.",ep:14,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9304] = {n:"Pozione di verità",t:24,d:"Questa pozione di verità è stata creata da Merlisello l\'Incatenatore in persona. Hai comunque qualche dubbio sul suo aspetto sospetto (della pozione, non di Merlisello).",ep:16,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9305] = {n:"Incisivo Magico di Wabbit",t:24,d:"[wait] Quando si sostituisce un dente con questo incisivo magico, si comincia a pawlawe come un wabbit, un\'espewienza quantomeno sconcewtante.",ep:8,g:769,l:1,wd:false,fm:true,w:0,p:1};
I.u[9306] = {n:"Pelo di Dragacchino selvaggio",t:24,d:"Chiunque si faccia fare il solletico alle narici con questo pelo di dragacchino perderà il suo quoziente intellettivo in maniera spettacolare. Per fortuna l\'effetto è temporaneo ma il viso ne conserva dei postumi irreversibili.",ep:2,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[9307] = {n:"Teschio di Kwoän",t:24,d:"Se incantato correttamente, questo teschio si lancia in discussioni metafisiche che solo Daryl può capire... e solo quando è in forma.",ep:3,g:770,l:1,wd:false,fm:true,w:0,p:1};
I.u[9308] = {n:"Piuma Irritante di Tofu",t:24,d:"La piuma irritante del Tofu è un oggetto molto raro. Se accarezzi la nuca di una persona con questa piuma, essa crederà di essere un Tofu e agirà come tale. Anche se questo effetto è temporaneo, un uso eccessivo potrebbe causare assuefazione.",ep:1,g:96,l:1,wd:false,fm:true,w:0,p:1};
I.u[9312] = {n:"Anima di Kanigrù",t:24,d:"Quest\'anima è stata recuperata con la Pietra di Anima fornita da Olledrob Oterges.",ep:13,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9313] = {n:"Anima di Uginak",t:24,d:"Quest\'anima è stata recuperata con la Pietra di Anima fornita da Olledrob Oterges.",ep:14,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9316] = {n:"Contratto del Sacri Zo",t:24,d:"Su questo foglio c\'è scritto che il Sàcri Zo accetta di essere un discepolo di Uk\'Not\'Allag a condizione di scegliersi la paga. Ma lo meriterà?",ep:14,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9317] = {n:"Contratto di Kapi Tagno",t:24,d:"Su questo foglio c\'è scritto che Kapi Tagno accetta di essere un discepolo di Uk\'Not\'Allag, a condizione però di essere subito nominato luogotenente. Non sa che è molto più probabile che Uk\'Not\'Allag lo nomini schiavo.",ep:14,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9318] = {n:"Risultato d\'interrogatorio",t:24,d:"Questo messaggio scritto da Amayiro ti dice di passare tra un quarto d\'ora per conoscere il risultato dell\'interrogatorio di Carub Lard.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9319] = {n:"Zampa di Bituf",t:24,d:"Grande. Molto grande. Il Bituf è probabilmente l\'unica bestia della regione a usare dei trampoli \"naturali\".",ep:14,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9320] = {n:"Contratto di Grassimor",t:24,d:"Come ringraziamento per le zampe di Bituf, Grassimor accetta di mettersi al servizio di Uk\'Not\'Allag. Che stolto, non immagina minimamente che tutte le zampe del mondo non valgono una tale sorte.",ep:14,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9321] = {n:"La cattura di Jiva",t:24,d:"Questo libro narra di come Jiva fu catturata da Djaul. La protettrice non apprezzerebbe affatto che la notizia si diffonda, ed è certamente per questo che il libro è redatto in una lingua sconosciuta.",ep:9,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9322] = {n:"Libro incantato della cattura di Jiva",t:24,d:"[wait] Questo libro narra di come Jiva fu catturata da Djaul. La protettrice non apprezzerebbe affatto che la notizia si diffonda, ed è certamente per questo che il libro è redatto in una lingua sconosciuta. Un maestro xelor ha incantato il libro perché sveli la fine della storia, ma tu sei ancora incapace di decifrarne la scrittura.",ep:9,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9323] = {n:"Stomaco di Pappatutto sporco",t:24,d:"Questo stomaco di Pappatutto è stato depositato come offerta sull\'altare della torre di Gisgul. Sembra che ti permetta di entrare in una certa sala...",ep:14,g:733,l:1,wd:false,fm:true,w:0,p:1};
I.u[9324] = {n:"Scudo di Dardondakal incompiuto",t:24,d:"Questo scudo, forgiato da una scaglia del drago bianco Dardondakal, non è finito ma sprigiona comunque un\'aura di potenza. Uno dei suoi vecchi proprietari ha avuto la cattiva idea di dipingerlo di blu, facendogli perdere parte della sua magnificenza. Ma la cosa più spiacevole è che non è ancora possibile equipaggiarsene.",ep:3,g:807,l:1,wd:false,fm:true,w:0,p:1};
I.u[9325] = {n:"Ronan il Barbaro",t:32,d:"Devi condurre Ronan da Oto Mustam.",ep:1,g:18,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9327] = {n:"Statuetta Magica d\'apertura",t:24,d:"Il Croccaroc Leggendario aveva scambiato questa statuetta per un croccabul nano. Tu invece l\'hai scambiata per un bwork nano. Invece è una chiave. Ancora una volta, è solo questione di punti di vista.",ep:5,g:735,l:1,wd:false,fm:true,w:0,p:1};
I.u[9328] = {n:"Appunti sui bwork",t:24,d:"Questo appunto contiene un sacco di informazioni sul lavaggio di cervello effettuato sui Bwork.",ep:14,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9329] = {n:"Appunti sui blop",t:24,d:"Questo appunto contiene un sacco di informazioni sui lavaggi del cervello effettuati sui Blop. Hmm... ma da quando i Blop hanno un cervello?",ep:14,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9330] = {n:"Appunti sui goblin",t:24,d:"Questo appunto contiene un sacco di informazioni sul lavaggio di cervello effettuato sui Goblin.",ep:14,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9331] = {n:"Orbe d\'ombra",t:24,d:"La sola presenza di questo oggetto, anche se chiuso nella scatola, ti ghiaccia il sangue. Hai l\'impressione che una forza oscura ti succhi l\'energia dall\'interno.",ep:5,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9333] = {n:"Orecchino strano",t:24,d:"Non hai mai visto un oggetto simile prima di oggi. Si dice sia appartenuto ad una persona potente... molto potente. E tu hai preferito metterlo in una scatola per evitare di perderlo e di farti, di conseguenza, linciare da Oto...",ep:5,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9335] = {n:"Bersaglio: Pandala",t:24,d:"La tua missione è di catturare i territori di Focodala, Erdala, Aksadala e Terradala prima di tornare dal capo della milizia.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9336] = {n:"Bersagli: Pandala e Villaggio dei Dabol",t:24,d:"La tua missione è di catturare il Villaggio dei Dabol prima di tornare dal capo della milizia. I Territori di Focodala, Erdala, Aksadala e Terradala devono restare sotto controllo.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9337] = {n:"Bersagli: Pandala e Villaggio dei Brigandini",t:24,d:"La tua missione è di catturare il Villaggio dei Brigandini prima di tornare dal capo della milizia. I territori di Focodala, Erdala, Aksadala e Terradala devono restare sotto controllo.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9338] = {n:"Bersagli: Pandala e Villaggio degli Zoth",t:24,d:"La tua missione è di catturare il Villaggio degli Zoth prima di tornare dal capo della milizia. I territori di Focodala, Erdala, Aksadala e Terradala devono restare sotto controllo.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9339] = {n:"Regalo Mantello Valazza",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9341] = {n:"Panoplia Completa di Linglés",t:24,d:"Hai riposto la panoplia completa di William Linglés in questa scatola per non sporcarla, o non sporcarti. Quando si conoscono i bonus della panoplia completa, ci si rende conto che è troppo uno sballo! Peccato per William, non la sa usare e comunque non potrà più farlo. Peccato anche per te, è un oggetto di ricerca che non puoi indossare. Che ingiustizia!",ep:1,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9342] = {n:"Falso appunto di Jiaye Djaul",t:24,d:"Devi portare questo appunto a Jiaye Djaul, alla taverna di Djaul... dopo esserti occupato dei briganti della banca.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
