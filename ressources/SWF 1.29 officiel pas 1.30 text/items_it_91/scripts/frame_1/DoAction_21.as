I.u[9364] = {n:"null",t:16,d:"",ep:0,g:211,l:1,wd:false,fm:false,w:1,p:1};
I.u[9365] = {n:"Pergamena di sonno",t:24,d:"Questa pergamena è abbastanza potente da addormentare chiunque... o quasi, non Oto Mustam comunque.",ep:16,g:768,l:1,wd:false,fm:true,w:0,p:1};
I.u[9366] = {n:"Tutù Rosa",t:10,d:"Questo tutù rosa andrà benissimo per lo spettacolo di fine anno di tua figlia. Fabbricato con cotone ancestrale e spugna di Mob, morbido e comodo con una gonnellina a frufru, questo tutù potrebbe essere il primo di una futura star della danza.",ep:22,g:148,l:49,wd:true,fm:true,w:5,p:300};
I.u[9367] = {n:"Anello di Divad",t:24,d:"È l\'anello che hai rubato a Divad Dleifrepok. Sembrava aumentasse i suoi poteri da illusionista, ma a te non servirà a niente.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9368] = {n:"Ciondolo di Olledrob",t:24,d:"È il ciondolo che hai rubato a Olledrob Oterges. Non sai assolutamente a cosa serva.",ep:16,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[9369] = {n:"Falso anello di David",t:24,d:"È una copia dell\'anello di Divad.",ep:16,g:763,l:1,wd:false,fm:true,w:0,p:1};
I.u[9370] = {n:"Falso ciondolo di Olledrob",t:24,d:"È una copia del ciondolo di Ledrob.",ep:16,g:770,l:1,wd:false,fm:true,w:0,p:1};
I.u[9371] = {n:"Pietra di Kirbul l\'Eroso",t:24,d:"Hai trovato questa pietra addosso a Kirbul l\'Eroso. Si dice che queste pietre siano utili per certi rituali...",ep:5,g:38,l:1,wd:false,fm:true,w:0,p:1};
I.u[9376] = {n:"Chiave strana",t:24,d:"Finch Aticus ti ha dato questa chiave, ma non sai a cosa serve.",ep:16,g:731,l:1,wd:false,fm:true,w:0,p:1};
I.u[9377] = {n:"Badge di Finch",t:24,d:"Finch Aticus ti ha dato il suo badge per ringraziarti di averlo liberato.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9378] = {n:"Ordine di missione per Tolevaj",t:24,d:"Quest\'ordine di missione indica che Tolevaj finirà il rituale sulla cima di una montagna a nord-ovest del Villaggio dei Brigandini. Ma non riesci a riconoscere la firma del documento.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9379] = {n:"Balotino di cioccolato",t:42,d:"Questo pacchettino è da regalare a colei o colui che ami.\nSe non ami nessuno, puoi mangiartelo.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9380] = {n:"Fata d\'artificio invocatrice di cuori",t:74,d:"Questa Fata d\'artificio originale ti permetterà di portare un po\' d\'amore in questo mondo di bruti, e un po\' di rutti in questo mondo d\'amore.",ep:1,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[9381] = {n:"Fiore di Glutoblop",t:35,d:"Il Glutoblop è talmente affamato che sarebbe capace di mangiare i propri fiori. Fortunatamente trova sempre un avventuriero imprudente a portata di... denti!",ep:5,g:7,l:50,wd:true,fm:true,w:1,p:1};
I.u[9382] = {n:"Fiore di Blopinolo",t:35,d:"Questo fiore è appena stato strappato dalla testa di un Blopinolo. Dato l\'aspetto ridicolo che gli dava, non se ne lamenterà.",ep:5,g:8,l:40,wd:true,fm:true,w:1,p:1};
I.u[9383] = {n:"Radice di Tronkoblop",t:98,d:"Il Tronkoblop possiede lunghe radici, che attingono dal suolo tutto ciò che gli avventurieri ci buttano.",ep:5,g:1,l:40,wd:true,fm:true,w:1,p:1};
I.u[9384] = {n:"Fiore di Blop Griotta Reale",t:35,d:"Se questo fiore non fosse stato reale, l\'avresti sicuramente buttato.",ep:5,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[9385] = {n:"Fiore di Blop Cocco Reale",t:35,d:"Se questo fiore non fosse stato reale, l\'avresti sicuramente buttato.",ep:5,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[9386] = {n:"Fiore di Blop Indaco Reale",t:35,d:"Se questo fiore non fosse stato reale, l\'avresti sicuramente buttato.",ep:5,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[9387] = {n:"Fiore di Blop Reginetta Reale",t:35,d:"Se questo fiore non fosse stato reale, l\'avresti sicuramente buttato.",ep:5,g:10,l:100,wd:true,fm:true,w:1,p:1};
I.u[9388] = {n:"Foglia di Blop Reale",t:36,d:"Una volta seccata, arrotolata e fumata, questa foglia può provocare, tra i soggetti più deboli, forti allucinazioni e una voglia incredibile di darsi sollievo. Un\'eccessiva consumazione può causare una morte improvvisa.",ep:5,g:13,l:100,wd:true,fm:true,w:1,p:1};
I.u[9389] = {n:"Foglia di Blop Multicolore Reale",t:36,d:"Questa foglia si nutre della materia grigia del Blop Multicolore Reale. Fortunatamente non è troppo golosa.",ep:5,g:14,l:150,wd:true,fm:true,w:1,p:1};
I.u[9390] = {n:"null",t:113,d:"",ep:0,g:211,l:1,wd:false,fm:true,w:0,p:1};
I.u[9391] = {n:"Fiore di Blop Multicolore Reale",t:35,d:"Questo fiore era nascosto all\'interno della scatola cranica del Blop Multicolore Reale. Gli serviva a riempire i vuoti di memoria.",ep:5,g:13,l:150,wd:true,fm:true,w:1,p:1};
I.u[9394] = {n:"Cappelblopignon",t:16,d:"Questo copricapo ti darà un elegante stile fungino, ma anche un odore di sottobosco che i tuoi amici eviterebbero volentieri.",ep:22,g:222,l:152,wd:true,fm:true,w:15,p:45782};
I.u[9395] = {n:"Bloporona Reale",t:16,d:"Questo copricapo è stato indossato da Kuri in persona per molti anni, fino a quando non decise di smettere di portare copricapi fuori moda.",ep:22,g:223,l:161,wd:true,fm:true,w:10,p:47750};
I.u[9396] = {n:"Il sigillo degli Zewuan",t:9,d:"In antico linguaggio Volpo, è chiamato \"Zeuan Ling\". Si dice che sia stato creato all\'interno di un vulcano situato sotto Pandala Fuoco, da Zauwon, il Wabbit oscuro.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PX=3|PX=5",p:1};
I.u[9399] = {n:"Chiave strana",t:24,d:"Sbab ti ha dato questa chiave, ma non sai a cosa serve.",ep:16,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9400] = {n:"Mappa del villaggio di Gisgul",t:24,d:"Questa mappa è consumata e non riesci a capire la parte riguardante il rituale. Ma studiandola con attenzione hai finalmente trovato il posto dove esso si terrà: a nord del villaggio in rovina di Gisgul, vicino alle montagne.",ep:16,g:6,l:1,wd:false,fm:true,w:0,p:1};
I.u[9401] = {n:"Pelle di Bworker",t:59,d:"Questa pelle ha attraversato un sacco di guerre uscendone indenne, e il tempo l\'ha appena appena scalfita. Questo non ti ha impedito però di farle la pelle.",ep:14,g:9,l:400,wd:true,fm:true,w:10,p:1};
I.u[9402] = {n:"Pantofolabrone",t:11,d:"Le piccole ali attaccate a queste pantofole permettono di aerare i piedi puzzolenti. Attenzione: è sconsigliato utilizzare queste pantofole per giocare a Pappaball, il Pappattuto potrebbe non essere contento di farsi punzecchiare il sedere.",ep:1,g:128,l:34,wd:true,fm:true,w:5,s:112,p:3200};
I.u[9403] = {n:"Mazza O\'dard",t:7,d:"Le piccole ali attaccate a questa mazza la rendono più leggera e facile da maneggiare. A volte, si metterà a volare da sola e ti colpirà durante il sonno, così... per farsi due risate.",ep:1,g:68,l:27,wd:true,fm:true,w:12,an:15,e:[10,4,1,1,45,50,false,false],c:"CI>17&CC>5",s:112,p:2100};
I.u[9404] = {n:"Mantello Kefabzz",t:17,d:"La freccia incastrata in questo mantello ti impedirà di sederti senza farti male al sedere... c\'è di buono che nessuno oserà sculacciarti.",ep:1,g:155,l:33,wd:true,fm:true,w:5,s:112,p:3000};
I.u[9405] = {n:"Caskapina",t:16,d:"Indossando questo cappello rischi di prenderti colpi di scacciamoskito sulle antenne!",ep:1,g:224,l:37,wd:true,fm:true,w:9,s:112,p:3825};
I.u[9406] = {n:"Porkorecie",t:16,d:"Queste orecchie di Porkass ancora fresche ti aiuteranno a sedurre le Porkass che incrocerai. E non ridere! Vedrai che le userai quanto ti sentirai troppo solo nella campagna di Amakna.",ep:1,g:225,l:36,wd:true,fm:true,w:2,s:113,p:3600};
I.u[9407] = {n:"Mantello Tappo",t:17,d:"Qualcuno chiama questo mantello il Tira-tappello, e odia ferocemente quelli che lo chiamano diversamente. Ma non importa, puoi dargli il nome che vuoi, tanto non ti serverà mai per aprire una bottiglia.",ep:1,g:156,l:37,wd:true,fm:true,w:3,s:113,p:3800};
I.u[9408] = {n:"Maianello",t:9,d:"Con questo anello al dito sembrerai proprio una Porkass, ai tuoi amici non dispiacerà affatto!",ep:1,g:162,l:40,wd:true,fm:true,w:3,s:113,p:500};
I.u[9409] = {n:"Cintura Salume",t:10,d:"La tua piccola coda a cavatappi farà morire d\'invidia più di una persona intorno a te.",ep:1,g:149,l:39,wd:true,fm:true,w:1,s:113,p:4225};
I.u[9410] = {n:"Cappello del Bosco dell\'Est",t:16,d:"Meno alla moda del Clint, ma molto più raffinato, questo cappello ti permetterà di mostrarti in tutta la tua frivolezza.",ep:1,g:226,l:40,wd:true,fm:true,w:25,s:114,p:1000};
I.u[9411] = {n:"Mantello del Bosco dell\'Est",t:17,d:"Questo mantello ti proteggerà la schiena dai colpi di sole. Stai attento, perché non riesce a coprire il sedere a tutti gli avventurieri.",ep:1,g:157,l:36,wd:true,fm:true,w:10,s:114,p:6500};
I.u[9412] = {n:"Cintura del Bosco dell\'Est",t:10,d:"La fionda agganciata a questa cintura è veramente ben agganciata. È talmente ben agganciata che non riuscirai mai a sganciarla... Insomma, serve solo a impressionare i piccoli banditi di strada che incroci sul tuo cammino.",ep:1,g:150,l:32,wd:true,fm:true,w:10,s:114,p:3000};
I.u[9413] = {n:"Stivali del Bosco dell\'Est",t:11,d:"Gli speroni di questi stivali permettono di lacerare il cuoio del tuo dragacchino, per poterlo spezzare meglio quando ti sarai deciso a mangiarlo.",ep:1,g:129,l:30,wd:true,fm:true,w:10,s:114,p:2700};
I.u[9414] = {n:"Cappellimone",t:16,d:"Questo enorme limone svuotato ospiterà senza problemi la tua testa e il piccolo seme che c\'è dentro.",ep:1,g:227,l:30,wd:true,fm:true,w:9,s:115,p:2600};
I.u[9415] = {n:"Mantello Agrume",t:17,d:"Questo mantello è stato fabbricato con numerose scorze di agrumi di diverse qualità. È bello e rinfrescante, ma non brilla nell\'oscurità.",ep:1,g:158,l:30,wd:true,fm:true,w:8,s:115,p:2525};
I.u[9416] = {n:"Anello Scorza",t:9,d:"Se la tua acqua non ha più gusto, mettici dentro il tuo dito con questo anello. Agitalo fino a quando non si stacca e otterrai un delizioso cocktail all\'arancia rossa e limone, anche se avrai perso un dito... Non si può mica avere tutto!",ep:1,g:163,l:20,wd:true,fm:true,w:4,s:115,p:1300};
I.u[9417] = {n:"Cannucciatone",t:4,d:"Se hai sempre sognato di succhiare il sangue degli avversari continuando a picchiarli con forza, questo bastone fa al caso tuo.",ep:1,g:81,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",s:115,p:2900};
I.u[9418] = {n:"Copricapo Cristallino",t:16,d:"Il prossimo che cercherà di pettinarti rischierà di rompere il pettine.",ep:1,g:228,l:22,wd:false,fm:true,w:12,s:125,p:1525};
I.u[9451] = {n:"Mantello Cristallino",t:17,d:"Questo impressionante pezzo di cristallo può servire da mantello rigido. Forse non ti farà diventare più forte, ma puoi stare sicuro che il mostro che cercherà di divorarti avrà una brutta sorpresa.",ep:1,g:159,l:21,wd:false,fm:true,w:10,s:125,p:1400};
I.u[9452] = {n:"Anello Cristallino",t:9,d:"Con quest\'anello, il tuo dito splenderà come non mai.",ep:1,g:164,l:30,wd:false,fm:true,w:4,s:125,p:2600};
I.u[9453] = {n:"Cintura Cristallina",t:10,d:"Con questa cintura intorno alla vita, nessuno oserà più pizzicarti le anche per paura di tagliarsi le dita.",ep:1,g:151,l:48,wd:false,fm:true,w:30,s:125,p:6075};
I.u[9454] = {n:"Pompamuleto",t:1,d:"Questo amuleto può servire da bavaglino per i più giovani e i più vecchi.",ep:1,g:140,l:27,wd:false,fm:true,w:5,s:124,p:2200};
I.u[9455] = {n:"Pompanello",t:9,d:"Questo anello può essere indossato all\'alluce per nascondere il cattivo odore dei piedi.",ep:1,g:165,l:30,wd:false,fm:true,w:4,s:124,p:2600};
I.u[9456] = {n:"Pompantello",t:17,d:"Se stimi che il tuo didietro non abbia mai goduto dell\'attenzione che merita, non è mai troppo tardi per indossare questo mantello che lo coprirà... attirando così tutti gli sguardi.",ep:1,g:160,l:33,wd:false,fm:true,w:5,s:124,p:3075};
I.u[9457] = {n:"Pompocapo",t:16,d:"Questo copricapo emana un odore di rosa demoniaca abbastanza forte da fare fuggire tutte le pulci che vivono sulla tua testa, nonché tutti i parassiti che si spacciano come tuoi amici.",ep:1,g:229,l:33,wd:false,fm:true,w:5,s:124,p:3000};
I.u[9459] = {n:"Lista di giocattoli di Babbo Nawal",t:24,d:"Babbo Nawal si prende sempre cura della lista dei giocattoli portati dai bambini che divora.\nTu non hai ancora scritto la tua, eccone una.",ep:1,g:41,l:1,wd:false,fm:true,w:0,p:0};
I.u[9460] = {n:"Mela di Pik",t:24,d:"Ecco un Pokipik che non crescerà mai, non ti vergogni?",ep:1,g:123,l:1,wd:false,fm:true,w:0,p:0};
I.u[9461] = {n:"Il Kim",t:16,d:"Si dice che il Kimbo porti questa parrucca in omaggio a un bel fusto abbronzato incontrato un giorno sulla sua isola e del quale amava particolarmente il bel sorriso. La nasconde comunque sotto il suo cocco perchè la trova ridicola.",ep:22,g:230,l:196,wd:true,fm:true,w:10,p:60000};
I.u[9463] = {n:"Amunnite",t:1,d:"Questo gioiello emana una tale potenza da uccidere un Moskito a 30 passi di distanza, se il suo odore non lo obbligasse a fermarsi a un chilometro di distanza.",ep:23,g:141,l:189,wd:true,fm:true,w:10,s:107,p:58000};
I.u[9464] = {n:"Kralamansion",t:1,d:"Questo spaventoso amuleto è rimasto nascosto per molto tempo in un maniero sperduto. Tempo fa era vivo e voleva conquistare il mondo, ora conquisterà solo il tuo collo. Poverino.",ep:22,g:142,l:194,wd:true,fm:true,w:30,s:97,p:58411};
I.u[9465] = {n:"null",t:76,d:"",ep:0,g:20,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9468] = {n:"Pala Ladra",t:8,d:"Questa pala è pericolosa, ruberà la tua vitalità, la tua gioventù, l\'acqua del tuo corpo e anche i tuoi preziosi gatrooll.",ep:22,g:51,l:191,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,35,50,false,false],c:"CC>450",p:58401};
I.u[9469] = {n:"Spada Micotica",t:6,d:"Questa spada, costruita a partire da frammenti di micosi, parassiterà a meraviglia l\'intestino dei tuoi nemici.",ep:23,g:85,l:184,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,50,50,false,false],c:"CC>300&CA>300",p:58456};
I.u[9471] = {n:"Cappello di San Balotino",t:16,d:"Balotine e Balotini, voi che cercate l\'anima gemella, questo copricapo sobrio ma elegante sarà il vostro segno di riconoscimento. Infatti, questo oggetto può essere indossato solo dagli avventurieri che non sono ancora sposati. \nPotrai così distinguere più facilmente colei o colui il cui cuore è ancora libero.",ep:1,g:231,l:1,wd:false,fm:true,w:1,c:"PR=0",p:1};
I.u[9472] = {n:"Shigekax Passion",t:42,d:"Famosa per le sue virtù afrodisiache, questa caramella morbida e dolce è il regalo ideale per la paersona amata.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9473] = {n:"null",t:94,d:"",ep:0,g:14,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9474] = {n:"Sublime Pietra di Anima azzardata",t:83,d:"Questa pietra offre una piccola possibilità di catturare delle anime di una potenza semplicemente incredibile.",ep:0,g:17,l:1,wd:false,fm:true,w:1,tw:true,p:23000};
I.u[9475] = {n:"Sublime Pietra di Anima",t:83,d:"Questa pietra offre una ragionevole possibilità di catturare delle anime di una potenza semplicemente incredibile.",ep:0,g:16,l:1,wd:false,fm:true,w:1,tw:true,p:50000};
I.u[9476] = {n:"Sublime Pietra di Anima felice",t:83,d:"Questa pietra offre una buona possibilità di catturare delle anime di una potenza semplicemente incredibile.",ep:0,g:18,l:1,wd:false,fm:true,w:1,tw:true,p:75000};
I.u[9477] = {n:"null",t:14,d:"",ep:0,g:6,l:10,wd:false,fm:true,w:1,c:"Ps=1|Ps=2|Ps=3",u:true,p:1};
I.u[9478] = {n:"null",t:14,d:"",ep:0,g:1,l:10,wd:false,fm:true,w:1,c:"PX=4|PX=5",u:true,p:1};
I.u[9479] = {n:"Poshocapo",t:16,d:"Il chiodo piantato in questo copricapo permette di sgonfiare la testa di coloro che l\'hanno un po\' troppo montata.",ep:1,g:232,l:45,wd:true,fm:true,w:23,s:123,p:1000};
I.u[9480] = {n:"Poshontello",t:17,d:"Con questo bel bersaglio ricamato sul tuo mantello, i tuoi nemici non avranno più nessuna scusa per mancarti.",ep:1,g:161,l:33,wd:true,fm:true,w:10,s:123,p:3000};
I.u[9481] = {n:"Poshoscudo",t:82,d:"Il chiodo piantato in questo scudo può servirti come arma per il corpo a corpo se vuoi sgonfiare il tuo avversario.",ep:1,g:36,l:1,wd:true,fm:true,w:1,s:123,p:1};
I.u[9482] = {n:"Cicaloscudo",t:82,d:"Se hai paura di spaventare i tuoi amici con la tua testa da mostro, puoi sempre decidere di nasconderla dietro questo Scudo per avere l\'aria un po\' più simpatica.",ep:1,g:37,l:1,wd:true,fm:true,w:1,s:122,p:1};
I.u[9483] = {n:"Scudo Boh-Bihn",t:82,d:"Questo scudo era utilizzato dai giovani Yop per incollare le immagini che gli insegnanti davano come ricompensa. Ogni tanto, si divertivano a farle girare rapidamente per sbalordire i compagni di classe.",ep:1,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[9484] = {n:"Scudo Tigrato",t:82,d:"Questo scudo non protegge completamente chi lo porta, ma difende con efficacia contro i fantasmi.",ep:1,g:39,l:1,wd:true,fm:true,w:1,p:1};
I.u[9485] = {n:"Cicalontello",t:17,d:"Le tre piccole sfere che decorano questo mantello permettono di dare dei bei colpi sei sai fare la ruota.",ep:1,g:162,l:30,wd:true,fm:true,w:10,s:122,p:2500};
I.u[9486] = {n:"Cicalocapo",t:16,d:"Con o senza questo copricapo, assomiglierai sempre a un buffone, però almeno così avrai una buona scusa.",ep:1,g:233,l:33,wd:true,fm:true,w:10,s:122,p:3075};
I.u[9487] = {n:"Certificato di cambiamento di schieramento",t:24,d:"Questo certificato ti è stato recapitato da Morrie Gane. Contiene molte informazioni su di te e attesta il tuo cambiamento di schieramento.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9488] = {n:"Registro di Bonta",t:24,d:"Questo registro appartiene a Morrie Gane e contiene numerosi documenti tra cui come diventare bontariano. C\'è una pagina che dovrai compilare tu.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9489] = {n:"Registro di Brakmar",t:24,d:"Questo registro appartiene a Morrie Gane e contiene molti documenti tra cui come diventare Brakmariano. C\'è una pagina che dovrai compilare tu.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9490] = {n:"Certificato degli Ordini numero 5",t:24,d:"Questo certificato attesta la tua appartenenza a un ordine. Per cambiare ordine devi aspettare sette giorni dalla data dell\'emissione del presente certificato. Hai la possibilità di ripensarci, ma cerca di non approfittarne.",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9491] = {n:"Maledizione del Balotino",t:30,d:"Ormai vedi la vita tutta rose e fiori, e sei felice.",ep:1,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
