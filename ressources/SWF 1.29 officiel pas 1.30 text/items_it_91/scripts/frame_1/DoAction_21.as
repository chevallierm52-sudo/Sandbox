I.u[9549] = {n:"Mutande con bretelle del Padrino",t:10,d:"Lo slogan del Sarto all\'origine di questa meraviglia era: \"Anche nell\'impeto dell\'azione, questa mutanda resterà saldamente attaccata al tuo posteriore, grazie alle sue bretelle di lino di qualità superiore\". Prima di essere Sarto, era un cattivo poeta.",ep:0,g:152,l:48,wd:true,fm:true,w:10,s:126,p:6175};
I.u[9550] = {n:"Posizione del campo",t:24,d:"Merlisello ti ha indicato dove il miliziano utilizzerà l\'incantesimo di Transgenesi. Devi sbrigarti per arrivare prima che sia troppo tardi.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9551] = {n:"Seme di Scorbuto modificato",t:24,d:"Questi semi di scorbuto sono stati modificati, ma tu non vedi la differenza con dei semi di scorbuto classici. Il vero problema è che invece vedi benissimo la differenza tra questi semi e dei semi di papavero. Solo uno scemo potrebbe sbagliarsi.",ep:0,g:405,l:1,wd:false,fm:true,w:0,p:1};
