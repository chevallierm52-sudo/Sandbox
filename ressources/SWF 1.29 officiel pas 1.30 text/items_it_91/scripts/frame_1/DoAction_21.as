I.u[9161] = {n:"Stivoblopli Indaco",t:11,d:"Smettila di lamentarti di questo nome impronunciabile, questo particolare ti salverà la vita quando un brigante ti aggredirà chiedendoti: \"Dammi i tuoi Stilopali, no... i tuoi Stiblopali, no... i tuoi Stivpali, no... \". Tranquillo, avrai tutto il tempo di correre via.",ep:5,g:120,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9162] = {n:"Stivoblopli Griotta Reali",t:11,d:"Di\' per diciotto volte la parola \"Stivoblopli\" più veloce che puoi. Ecco, sembri proprio uno Yop!",ep:5,g:121,l:80,wd:true,fm:true,w:10,s:102,p:16000};
I.u[9163] = {n:"Stivoblopli Reginetta Reali",t:11,d:"Di\' per diciotto volte la parola \"Stivoblopli\" più veloce che puoi. Ecco, sembri proprio uno Yop!",ep:5,g:122,l:80,wd:true,fm:true,w:10,s:103,p:16000};
I.u[9164] = {n:"Stivoblopli Cocco Reali",t:11,d:"Di\' per diciotto volte la parola \"Stivoblopli\" più veloce che puoi. Ecco, sembri proprio uno Yop!",ep:5,g:123,l:80,wd:true,fm:true,w:10,s:104,p:16000};
I.u[9165] = {n:"Stivoblopli Indaco Reali",t:11,d:"Di\' per diciotto volte la parola \"Stivoblopli\" più veloce che puoi. Ecco, sembri proprio uno Yop!",ep:5,g:124,l:80,wd:true,fm:true,w:10,s:105,p:16000};
I.u[9166] = {n:"Stivoblopli Multicolori Reali",t:11,d:"Con o senza l\'imbottitura, questi stivali rimangono strani. È inutile cercare di imbottirli con qualcos\'altro che non siano i tuoi piedi.",ep:5,g:125,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9167] = {n:"Blopintura Griotta",t:10,d:"Dietro a questo stupido nome si nasconde, in realtà, una cintura originale di cui non si conoscono bene né le qualità né i difetti. Si sa solo che è considerata di utilità pubblica grazie all\'eccezionale protezione che dà alle maniglie dell\'amore.",ep:5,g:136,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9168] = {n:"Blopintura Reginetta",t:10,d:"Dietro a questo stupido nome si nasconde, in realtà, una cintura originale di cui non si conoscono bene né le qualità né i difetti. Si sa solo che è considerata di utilità pubblica grazie all\'eccezionale protezione che dà alle maniglie dell\'amore.",ep:5,g:137,l:50,wd:true,fm:true,w:10,s:99,p:1000};
