I.u[9557] = {n:"Chiave del forziere",t:24,d:"Questa chiave sembra aprire il forziere che, secondo Terra Tibya, conterrebbe le statuette di Sumens.",ep:1,g:3,l:1,wd:false,fm:true,w:0,p:1};
I.u[9558] = {n:"Pozione di Mescolamento",t:14,d:"Questa pozione ti permette di rivelare tutti i personaggi invisibili presenti attorno a te.",ep:0,g:73,l:1,wd:false,fm:true,w:1,c:"Pg>23,3",u:true,p:1};
I.u[9559] = {n:"Bigliettino Bontariano",t:24,d:"Su questo Bigliettino c\'è scritto: Cretino di un Brakmariano, oltre a essere stupido e brutto, sei anche lento e puzzi. Persino una Mamy Bwork non ti vorrebbe come animale da compagnia. Ti consiglio allora di tornare nella tua misera Città o, se sei abbastanza pazzo, di venire a recuperare la Statuetta alla Torre di Bonta.\nFirmato: un furbo Bontariano.",ep:3,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9562] = {n:"null",t:24,d:"",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9563] = {n:"Peli di Brakmarziano",t:24,d:"Questo Ciuffo di Peli è stato strappato ad una creatura sconosciuta che porta le Insegne di Brakmar ed è dunque la prova inconfutabile che TU li hai visti!",ep:0,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[9564] = {n:"Badge di uno Psicopatico",t:24,d:"Hai recuperato questo Badge sul corpo ancora caldo di uno Psicopatico Brakamariano. Non ti vergogni a derubare i morti?",ep:0,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9565] = {n:"Badge di un Assassino",t:24,d:"Hai recuperato questo Badge sul corpo ancora caldo di un Assassino Bontariano. Non ti vergogni a derubare i morti?",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9566] = {n:"Scudo Anti-impatto",t:82,d:"Lo Scudo Anti-impatto fu costruito per la prima volta nelle taverne di Pandala. Si dice che questo scudo, ispirato dalla Dea Pandawa in persona, proteggerà dagli effetti della Cometa di Cristallo. Realtà o operazione di marketing dei Forgiatori di scudi pandawaiani? Nessuno lo sa.",ep:0,g:34,l:1,wd:false,fm:true,w:1,p:5000};
I.u[9567] = {n:"Copricapo del Black Wab",t:16,d:"Con questo copricapo potrai metamorfizzarti facilmente in vendicatore mascherato e forse perfino in mendicatore vascherato. Vedi tu.",ep:0,g:235,l:49,wd:true,fm:true,w:10,s:127,p:6325};
I.u[9569] = {n:"Mantello del Black Wab",t:17,d:"La piccola nappa attaccata all\'estremità di questo mantello permette di raccogliere efficacemente la polvere di casa tua, di solito è abbastanza piccola per poter passare sotto i mobili. Non dimenticare di toglierla quando vai a lavorare nei campi.",ep:0,g:164,l:46,wd:true,fm:true,w:10,s:127,p:5600};
