I.u[9594] = {n:"Palladineve del Padrino",t:18,d:"Questo palladineve ha un aspetto del tutto normale... Eppure sembra che la sua lana in alcuni punti diventi nera... Lasciagli un po\' di tempo e potresti avere una sorpresa!",ep:0,g:46,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9595] = {n:"Fantasma di Palladineve del Padrino",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[9596] = {n:"Regalo Palladineve del Padrino",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9597] = {n:"Trasformazione Fantasma Palladineve del Padrino",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9598] = {n:"Certificato di Deposito al Cianil: Palladineve del Padrino",t:77,d:"Questo Certificato descrive le caratteristiche del Palladineve del Padrino che hai lasciato al Cianil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
