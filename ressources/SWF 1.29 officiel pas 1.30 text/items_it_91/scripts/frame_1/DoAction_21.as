I.u[9616] = {n:"Fantasma di Cinghialetto",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:40,l:1,wd:true,fm:true,w:1,p:1};
I.u[9617] = {n:"Maomao Angora",t:18,d:"Questa palla di peli è più protetta contro il freddo di un Maomao classico ed è più dolce, ma sembra che il suo carattere sia ancora più insopportabile. Questa creatura mangia solo carne e pesce.",ep:0,g:50,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9618] = {n:"Regalo Grande Anellaccio del Padrino",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9619] = {n:"Tiwabbit Keafam",t:18,d:"Questa creatura è un po\' stupida, il solo modo per farla camminare è di attaccarle sul dorso un bastone che tiene una Cawota. Per fortuna questo famiglio è stato educato correttamente e non proverà a lanciare delle bombe spaventose. Questo divoratore di anime si nutre dei resti degli altri Wabbit.",ep:0,g:51,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9620] = {n:"Miniminotot",t:18,d:"Questa creatura è un Minimino cresciuto dal Minotot in persona. Purtroppo gli ha trasmesso il suo carattere e una parte dei suoi odori corporali a forza di coccolarlo sotto le sue ascelle. Questo divoratore di anime mangia i resti delle creature dell\'isola del Minotoror.",ep:0,g:49,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9621] = {n:"Regalo venuto d\'altrove",t:89,d:"Di sicuro due minuti fa questo zaino non era qui. Ma cosa diavolo può contenere? (DOPPIO-CLIC PER USARLO)",ep:0,g:32,l:1,wd:false,fm:false,w:1,u:true,p:0};
I.u[9622] = {n:"Germoglio di Tempofuggendula",t:36,d:"L\'esistenza di questa pianta è misteriosa ed improbabile quanto il suo nome. Allo stesso tempo qui e qui, ma non ora, per fortuna che non è altrove, se no non ci si capirebbe più niente. Portala al tempio Xelor di Amakna (coordinate 3,1), solo degli illuminati come loro possono provare a capirci qualcosa.",ep:0,g:638,l:1,wd:false,fm:false,w:1,p:0};
I.u[9623] = {n:"Coccodrail",t:18,d:"Non farti ingannare, i denti aguzzi di questa creatura un giorno o l\'altro finiranno per conficcarsi nel tuo posteriore. Questo famiglio mangia solo carne e pesce.",ep:0,g:47,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9624] = {n:"Dragona Nera",t:18,d:"Prendi una Dragona Rosa, tingila di nero, cospargila di polvere d\'oro, immergila nell\'olio, immergila nell\'acqua e avrai una Dragona Nera. Questo divoratore di anime si nutre solo di resti di draguova.",ep:0,g:48,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
