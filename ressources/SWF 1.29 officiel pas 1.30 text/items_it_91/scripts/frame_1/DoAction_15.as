I.u[6690] = {n:"Paio di Forbici consumate",t:80,d:"Un paio di forbici consumate, non c\'è niente di più classico.",ep:1,g:33,l:1,wd:true,fm:true,w:2,ut:true,p:1};
I.u[6706] = {n:"Benda della Mummia Nova",t:15,d:"Questa benda è tanto vecchia quanto il suo proprietario. Col tempo si è impregnata dei poteri della Mummia Nova, ma anche del suo odore di carne in putrefazione.",ep:1,g:712,l:150,wd:true,fm:true,w:1,p:1000};
I.u[6707] = {n:"Mantello della Mummia Nova",t:17,d:"Questo mantello maleodorante è fatto con le bende maleodoranti della Mummia Nova. Come eccitare tutti gli abitanti dei cimiteri dei dintorni.",ep:14,g:63,l:75,wd:false,fm:true,w:10,p:14600};
I.u[6708] = {n:"Certificato Dabol",t:24,d:"Questo certificato attesta la data della tua ultima vittoria contro un dabol",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6712] = {n:"Mantello Uccino",t:17,d:"Questo magnifico mantello profuma di fiori di bosco. Non servirà certo a fare impazzire d\'amore un\'Ocrina, ma sarà sufficiente per coprire gli odori di un Sadida che non si cura.",ep:1,g:82,l:71,wd:true,fm:true,w:10,p:13100};
I.u[6713] = {n:"Lorsothisa",t:5,d:"Impregnate del sangue del terribile Lordsoth, queste daghe gli hanno permesso di distruggere il re degli Chafer durante una gara di lancio delle daghe alla Fiera del Trool. Da quel giorno il re dei Chafer non ha mai più osato mostrare neanche un pezzo delle sue Mutande di cuoio, ed è partito in esilio con l\'illustre Capitano Chafer nei dintorni del cimitero di Pandala.",ep:1,g:34,l:100,wd:false,fm:true,w:10,an:13,e:[10,3,1,1,30,30,false,false],c:"PN~Lordsoth",p:1};
I.u[6716] = {n:"Nomoon",t:18,d:"Questa scimmietta ladruncola sembra essersi affezionata a te adesso. Anche se docile, è molto esigente sul cibo e accetta solo i vegetali che crescono sulla sua isola.",ep:3,g:11,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6717] = {n:"Baubau Nero",t:18,d:"Con questo piccolo cagnolino scoprirai la gioia delle passeggiate per la pipì. Ricordati che è un animale selvaggio quindi, se non vuoi perdere una mano, evita di dargli da mangiare.\n(QUESTO FAMIGLIO NON AMA NESSUNA RISORSA)",ep:1,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6718] = {n:"Maomao Bianco",t:18,d:"Questa piccola palla di pelo carina e maliziosa fa perdere la testa alle donne di tutte le classi. Il Maomao è un animale temibilissimo!\n(QUESTO LEGGENDARIO FAMIGLIO NON HA BISOGNO DI MANGIARE)",ep:1,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6719] = {n:"Copricapo dell\'Uomo Orso",t:16,d:"Questo strano copricapo è appartenuto al tristemente famoso Uomo Orso. Cucito con i resti della testa di un orso in decomposizione, questo copricapo non ti farà passare inosservato e, grazie all\'originale odore, lascerà una traccia del tuo passaggio.",ep:1,g:64,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6720] = {n:"Mantello dell\'Uomo Orso",t:17,d:"Questo grazioso mantello è stato indossato per anni dall\'Uomo Orso. Non farà certo di te un orso, ma potrai rivaleggiare con i migliori.",ep:8,g:58,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6721] = {n:"Stivali dell\'Uomo Orso",t:11,d:"Questi stivali sono imbottiti di pelliccia d\'orso. Così anche coloro che hanno il sangue freddo potranno tenere i piedi al caldo.",ep:2,g:51,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6722] = {n:"Fede dell\'Uomo Orso",t:9,d:"L\'Uomo Orso non ha mai tolto questa fede, neanche dopo che la sua amata è stata divorata davanti ai suoi occhi da uno degli orsi che aveva appena invocato per stupirla... accidenti se l\'ha stupita!",ep:1,g:66,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6723] = {n:"Amuleto dell\'Uomo Orso",t:1,d:"L\'Uomo Orso portava questo amuleto quando affrontò i Brigandini del rifugio di Bimdhul. La leggenda racconta che gli ha salvato la vita, ma se lo guardi da vicino ti accorgi... che non può essere altro che una leggenda!",ep:1,g:74,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6724] = {n:"Cintura dell\'Uomo Orso",t:10,d:"Questa piccola cintura ricoperta da peli d\'orso è l\'ideale per nascondere le maniglie dell\'amore. Non toglierla mai, se non vuoi deludere la tua anima gemella.",ep:1,g:66,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6725] = {n:"Bastone dell\'Uomo Orso",t:4,d:"L\'Uomo Orso usava questo bastone per addomesticare le invocazioni d\'orso, e talvolta per colpire le dita dei suoi figli, quando non facevano i compiti per la scuola. Ecco un uomo che aveva capito tutto sull\'educazione dei figli!",ep:14,g:46,l:20,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CA>50&CV>50",s:12,p:1300};
I.u[6731] = {n:"Amukwak di Ghiaccio",t:1,d:"Con questo amuleto al collo, potresti far credere agli altri di avere un alito fresco... ma lascia perdere, è fatica sprecata.",ep:1,g:71,l:42,wd:true,fm:true,w:3,s:13,p:4900};
I.u[6732] = {n:"Kwakanello di Ghiaccio",t:9,d:"Questo anellino è da sempre desiderato da tutte le Anutrofine che lo usano per ornare i loro alluci. Una trovata geniale per nascondere le verruche!",ep:1,g:63,l:42,wd:true,fm:true,w:2,s:13,p:4900};
I.u[6735] = {n:"Radice di Furbazza",t:98,d:"Questa minuscola radice incarna perfettamente la furbizia. Nessuno sa perché... ma tutti lo sanno.",ep:12,g:96,l:22,wd:true,fm:true,w:5,p:200};
I.u[6736] = {n:"Gemma di Furbazza",t:108,d:"Questo piccolo germoglio di Furbazza contiene una linfa sciropposa e appiccicosa. Se hai la sfortuna di camminare su una vecchia Furbazza nascosta nell\'erba alta, rischi di restarci appiccicato fino a quando non ti avrà divorato tutti gli stivali. In compenso, se riesci a prelevare una gemma di Furbazza intatta, potrai far tacere il più loquace dei Feca, offrendogliela come gomma da masticare.",ep:12,g:97,l:22,wd:true,fm:true,w:5,p:1};
I.u[6737] = {n:"Corteccia di Furbazza",t:96,d:"La Furbazza non ha veramente dei rami, come tutti gli alberi che si rispettino, e ha una corteccia fine fine ma molto resistente e piena di asperità. È ideale per creare manici per gli attrezzi antiscivolo, o per fare bastoni che strappano la pelle del sedere dei bambini troppo burrascosi. Comunque sia, nell\'uno o nell\'altro caso, la soddisfazione è incredibile, almeno per chi tiene il manico.",ep:12,g:98,l:22,wd:true,fm:true,w:5,p:200};
I.u[6738] = {n:"Cranio di Capo Coccodrail",t:47,d:"Questo enorme cranio mostra la scarsa igiene dentaria del Capo Coccodrail. Un particolare divertente: sembra essere ancora animato da una certa magia, l\'anima del Capo Coccodrail lo abita ancora. Gli succede a volte anche di versare lacrime di Coccodrail se sei cattivo con lui.",ep:4,g:637,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6739] = {n:"Pelle di Coccodrail",t:59,d:"Riuscire ad avere un pezzo completo di pelle di Coccodrail è quasi un miracolo, spesso i bracconieri non ne recuperano che poche scaglie. Ideale per fare uno zaino, questa vecchia pelle potrà anche soddisfare i Sarti di biancheria da combattimento.",ep:4,g:601,l:36,wd:true,fm:true,w:10,p:1000};
I.u[6740] = {n:"Pelle di Capo Coccodrail",t:59,d:"Questa pelle formata da una moltitudine di scaglie è superiore a qualsiasi altra pelle di Coccodrail. In effetti, la parte esterna della pelle di Capo Coccodrail è più resistente e ricoperta da scaglie appuntite molto taglienti, mentre la parte interna è particolarmente morbida. Si dice che certi vecchi Sarti confondano le due parti quando cuciono la biancheria. La storia però non ci dice se questa distrazione gli porti più o meno clienti...",ep:4,g:600,l:69,wd:true,fm:true,w:10,p:1000};
I.u[6741] = {n:"null",t:16,d:"",ep:0,g:75,l:200,wd:false,fm:true,w:0,p:1};
I.u[6742] = {n:"Furbamuleto",t:1,d:"Questo amuleto è fatto di un miscuglio di foglie di Furbazza e di detriti dell\'isola di Moon. Assomiglia più ad una collana di fiori che a un vero amuleto, ma ti permetterà di sedurre senza troppi sforzi la fauna locale dell\'isola di Moon, che è composta quasi esclusivamente di abominevoli creature. Così nessuna Furbazza potrà più resisterti e ti salteranno tutte al collo per farti dei succhiotti. I più sfortunati in amore si accontenteranno anche di questo.",ep:12,g:69,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6743] = {n:"Furbafede",t:9,d:"Prendi delle foglie di Furbazza, mettile una sull\'altra, lasciale macerare nell\'alcool alterato, bucale, bevi quel che resta dell\'alcool, incolla le foglie intorno a un pezzo di scorza, fissaci dei pezzi di foglia di Kokoko con una materia viscosa, e voilà, hai ottenuto una magnifica Furbafede. Puzza molto, e per questo ti sarà molto utile per giustificare il cattivo odore delle tue dita se hai l\'abitudine di metterle un po\' dappertutto. Soprattutto laddove non si dovrebbe.",ep:12,g:60,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6744] = {n:"Furbastivali",t:11,d:"Dopo che avrai provato questi stivali non potrai più farne a meno. Non perché siano eccezionali ma perché sono estremamente appiccicosi. Una caratteristica simile a quella delle femmine di Furbazza.",ep:12,g:47,l:34,wd:true,fm:true,w:5,s:16,p:3200};
I.u[6745] = {n:"Cintura Furbicante",t:10,d:"Notevole creazione artigianale fatta con resti di Furbazza e di detriti raccolti lungo la spiaggia di Moon, nel bel mezzo della spuma nauseante, questa cintura, se indossata completamente da sola, ti darà un\'aria sorprendente. Ecco come sconcertare i tuoi avversari o sorprendere il tuo amato... approfitta di questo istante!",ep:12,g:62,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6746] = {n:"Amukwak di Terra",t:1,d:"Tempo fa Oto Mustam, capo dei guerrieri di Brakmar, portava questo piccolo amuleto per farsi bello in occasione delle orgie organizzate nella città. Tutto un programma!",ep:5,g:72,l:42,wd:true,fm:true,w:3,s:14,p:4900};
I.u[6747] = {n:"Amukwak di Vento",t:1,d:"Quando il vento soffia tra le sue piume, il Kwak del Vento si sente libero come l\'aria, e plana come una vecchia foglia morta trasportata da una bufera. Malgrado ciò che se ne dice, è veramente impressionante!",ep:5,g:70,l:42,wd:true,fm:true,w:3,s:15,p:4900};
I.u[6748] = {n:"Kwakanello di Terra",t:9,d:"Se portato con giudizio, questo anello ti permetterà di abbellire le tue grosse dita. Sfortunatamente per qualcuno, ha effetto solo sulle dita.",ep:5,g:64,l:42,wd:true,fm:true,w:2,s:14,p:4900};
I.u[6749] = {n:"Kwakanello di Vento",t:9,d:"Questo anello è così leggero che potrebbe volare via al primo colpo di vento. Ma non sperare, tu non volerai via con lui. Nel migliore dei casi si riderà di te...",ep:5,g:62,l:42,wd:true,fm:true,w:2,s:15,p:4900};
I.u[6750] = {n:"Kwaklama di Ghiaccio",t:6,d:"Questa lama fredda e tagliente risveglierà gli istinti più primitivi di colui che la utilizza.",ep:1,g:51,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CC>50&CV>50",s:13,p:4600};
I.u[6751] = {n:"Kwaklama di Terra",t:6,d:"\"Questa lama affilata ma non mascherata, è perfetta per gli avventurieri già esperti in cerca di nuove sensazioni\": ecco cosa si può leggere sul manuale di questa spada. I manuali non sono proprio più come una volta...",ep:5,g:53,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>50&CV>50",s:14,p:4600};
I.u[6752] = {n:"Kwaklama di Vento",t:6,d:"Ideale per tagliare le nuvole, questa lama potrà anche servirti per farti aria se la agiti come un ventaglio. Una tecnica eccellente per sterminare i moskito o sfigurare gli amici.",ep:5,g:50,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CA>50&CV>50",s:15,p:4600};
I.u[6753] = {n:"Kwakstivali di Ghiaccio",t:11,d:"Ideali come pattini da ghiaccio sui laghi ghiacciati, questi stivali sono anche molto utili per tenere i piedi al fresco, o per tenerci la merenda nelle giornate molto calde. Ti sconsigliamo comunque di farli asciugare vicino al forno, rischieresti di non vederli mai più.",ep:2,g:36,l:40,wd:true,fm:true,w:5,s:13,p:4400};
I.u[6754] = {n:"Kwakstivali di Terra",t:11,d:"\"Non c\'è niente di meglio dei Kwakstivali di Terra per camminare sulla terra\", così diceva la nota Contadina Rola Ingals poco prima di diventare cieca, a causa di una zolla di terra gigante dritta negli occhi.",ep:5,g:49,l:40,wd:true,fm:true,w:5,s:14,p:4400};
I.u[6755] = {n:"Kwakstivali di Vento",t:11,d:"Rudimentali ma efficaci, questi stivali leggerissimi sono a volte usati dopo esser stati modificati con una manica d\'aria che indica la direzione e la forza del vento. È consigliabile non porsi dietro la manica, per non morire asfissiati.",ep:5,g:48,l:40,wd:true,fm:true,w:5,s:15,p:4400};
I.u[6756] = {n:"Kwantello di Terra",t:17,d:"Ideale per camuffarsi in zolla di terra gigante, questo mantello ti permetterà di attaccare di sorpresa le contadine e di rubargli tutte le loro ricchezze. È soprattutto adatto ai collezionisti di selce.",ep:8,g:64,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6757] = {n:"Kwantello di Vento",t:17,d:"Leggera e raffinata, questa creazione può servire da tenda per i più sprovveduti. Tempo fa era già uno dei desideri della Mummia Nova che la bramava per fare bella figura durante le sue uscite mondane. Un esempio da imitare... per qualcuno.",ep:8,g:62,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6758] = {n:"Kwakantura di Terra",t:10,d:"Il Kwak di Terra non è molto socievole, ed è soprattutto molto ambito per le sue piume. Portando questa cintura intorno alle anche, ti esporrai alle numerose trappole dei Cacciatori di Kwak di Terra che ti scambieranno per un vecchio Kwak malandato. A pensarci bene... l\'aspetto non inganna sempre.",ep:12,g:65,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6759] = {n:"Kwakantura di Vento",t:10,d:"\"L\'unico modo per acciuffare un vecchio Kwak del Vento maschio arrabbiato, è di travestirsi da femmina di Kwak del Vento arrabbiata. Così il maschio cercherà di capire l\'origine della collera della femmina e cercherà di soddisfarla il più possibile. Bisogna allora approfittare della beatitudine del maschio dopo la sua prestazione per prenderlo e spennarlo\". Ecco cosa si può leggere nella sezione 12 del tomo tre sulla caccia ai Kwak del Vento. Vi è inoltre indicato che questa cintura è un elemento essenziale del travestimento in Kwak del Vento. Il resto lo sai già.",ep:12,g:63,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6760] = {n:"Kwakapo di Terra",t:16,d:"Questo Kwakapo di Terra è talmente pesante che ti permetterà di tenere sempre i piedi per terra, ma a volte ti farà anche cadere per terra. Non si può avere tutto.",ep:13,g:71,l:41,wd:true,fm:true,w:25,s:14,p:4600};
I.u[6761] = {n:"Kwakapo di Vento",t:16,d:"Per lasciare i capelli al vento, anche se si indossa un copricapo, non c\'è niente di meglio del grazioso Kwakapo del Vento. Questo oggetto ti permetterà senza alcun dubbio di lasciarti andare alla tua fantasia in materia di capigliature. È abbastanza per riuscire a sconcertare il più impassibile dei Chafer.",ep:13,g:69,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6762] = {n:"Furba-Ston",t:4,d:"\"Per dare una bastonata, non c\'è niente di meglio che un Furba-Ston!\", ecco lo slogan che si poteva leggere sul depliant pubblicitario dell\'Agenzia Turista che proponeva ai propri clienti di ricostruire questo bastone con risorse nascoste un po\' ovunque sull\'isola di Moon. Un po\' come una caccia al tesoro, ma senza tesoro.",ep:12,g:44,l:32,wd:true,fm:true,w:5,e:[15,4,1,1,20,70,false,false],s:16,p:2900};
I.u[6763] = {n:"Furbantello",t:17,d:"Si dice che le Furbazze morte siano molto comode dopo essersi decomposte al sole. Infatti con il tempo diventano molto più morbide e tenere. Molti avventurieri vorrebbero poter dire la stessa cosa della loro amata.",ep:12,g:61,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6764] = {n:"Furbacapo",t:16,d:"Con questo copricapo sulla testa, non hai veramente l\'aria molto intelligente... ma comunque molto più che se non lo avessi, quindi tanto vale lasciarlo.",ep:12,g:68,l:31,wd:true,fm:true,w:5,s:16,p:2800};
I.u[6765] = {n:"Lalatte",t:79,d:"Attenzione: sulla confezione c\'è scritto di non dare questo latte a un giovane Maomao, rischierebbe di macchiarti un po\' i muri di casa...",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:4};
I.u[6766] = {n:"Spiga di Farle",t:1,d:"Questo amuleto dall\'apparenza rudimentale è stato fabbricato a partire da tre spighe di Grano magico, ricoperte di polvere di pietre preziose e falciate nelle pianure di Snossios durante la terza mietitura d\'Istrabraq. Questo amuleto conferisce un coraggio fuori dal comune a chi lo porta, che gli permette di falciare pianure e valli senza mai stancarsi.",ep:1,g:68,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6767] = {n:"Bracciale Magico di Farle",t:9,d:"Mentre Farle seminava l\'orzo, Shika fasciava questo braccialetto di pietre preziose con una tela di Canapa per evitare di attirare l\'attenzone dei Cuervoc.",ep:13,g:61,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6768] = {n:"Soki",t:32,d:"Porti a passeggio questo Maomao sfortunato per distrarlo un po\'.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[6769] = {n:"Bastone di Farle",t:4,d:"Questo splendido bastone è munito di bellissimi denti all\'estremità, il che ne fa un eccellente forca. Farle se ne serviva per creare immense balle di fieno, più alte e più grandi degli Olmi che crescevano nella foresta Litneg. Si dice che fu Bruce Bulgur in persona a tagliare il legno necessario alla fabbricazione di questo bastone, in cambio di enormi razioni quotidiane di fiocchi d\'avena, che si sbafava prima di andare a radere al suolo intere foreste.",ep:14,g:43,l:80,wd:true,fm:true,w:10,an:12,tw:true,e:[10,5,1,1,45,45,false,true],c:"CS>100&CV>100",s:17,p:16500};
I.u[6770] = {n:"Scuiscuit",t:15,d:"Questo Scuiscuit è stato cacciato dalla casa di Nonna a colpi di scopa.",ep:1,g:282,l:1,wd:true,fm:true,w:10,p:1};
I.u[6771] = {n:"Anello Té",t:9,d:"Questo anello non ha ancora superato le prove. Si tratta di un pezzo unico fatto da un apprendista Orefice per un test importante. È fabbricato a partire da un anello di ferro classico immerso in una soluzione di Té magico.",ep:1,g:1,l:4,wd:false,fm:true,w:1,p:50};
I.u[6773] = {n:"Amuleto Tude",t:1,d:"Questo amuleto è costruito secondo il metodo di creazione Tude, da cui prende il nome. È un metodo molto facile, e per questo è uno dei primi che si insegna agli apprendisti Orefici. Non produce sicuramente oggetti potenti, ma non bisogna neanche chiedere troppo...",ep:1,g:19,l:1,wd:false,fm:true,w:1,p:25};
I.u[6774] = {n:"Zoccoli di Farle",t:11,d:"Questi zoccoli sono stati intagliati in un legno raro, rinforzati di pezzi di cuoio pregiatissimo e imbottiti con dei cereali magici. Allo stesso tempo leggeri, eleganti e comodi, questi zoccoli sono anche molto resistenti all\'usura del tempo. Gli avventurieri un po\' troppo misogini vorrebbero poter dire la stessa cosa delle loro compagne.",ep:9,g:46,l:80,wd:true,fm:true,w:10,s:17,p:16600};
I.u[6775] = {n:"Mantello di Farle",t:17,d:"Questo mantello di tessuto e pelle permetteva a Farle Ingals di seminare enormi campi per un\'intera stagione senza mai doversi fermare. Effettivamente, una volta ripiegato e utilizzato come bisaccia, la sua capacità sembra praticamente illimitata. Nessuno conosce realmente il Sarto che ha creato questa meraviglia, ma la leggenda racconta che si sia ritirato dalla professione quando i suoi clienti hanno cominciato a scambiare i suoi mantelli per degli stracci. Che triste conclusione di una vita di lavoro!",ep:13,g:70,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6776] = {n:"Farlintura",t:10,d:"Questa cintura serviva da grembiule a Farle Ingals quando doveva sgozzare le sue greggi di Pappatutto. Un compito ingrato e crudele, al quale lui si apprestava con diligenza e ostentato piacere.",ep:4,g:61,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6778] = {n:"Farlacapo",t:16,d:"Questo cappello di paglia è stato confezionato con moltissime spighe magiche intrecciate insieme, in seguito l\'interno è stato imbottito con diverse stoffe e peli cuciti a mano da Shika Ingals, la moglie di Farle. Più chic del Plukos e con più classe del Kak A\'Rella, questo cappello ti proteggerà dal sole come ha protetto Farle per centinaia di mietiture, e il tutto dandoti un\'aria veramente gagliarda e \"cool\"... abbastanza per incoronarti re o regina dei campi.",ep:13,g:67,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6779] = {n:"Rapporto della Spia Etram",t:24,d:"Rapporto della spia Ztiv Oztin, recuperato con una certa difficoltà dalle mani di Joe Pierlivet.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6780] = {n:"Spada dell\'Iniziato",t:6,d:"Quest\'arma dall\'apparenza rudimentale, ti darà l\'impressione di saper combattere.",ep:1,g:96,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6781] = {n:"Bacchetta dell\'Iniziato",t:3,d:"Quest\'arma dall\'apparenza rudimentale ti darà l\'impressione di saper combattere.",ep:1,g:8,l:1,wd:true,fm:true,w:10,an:11,e:[5,4,2,3,50,50,false,true],p:1};
I.u[6782] = {n:"Bastone dell\'Iniziato",t:4,d:"Quest\'arma dall\'apparenza rudimentale, ti darà l\'impressione di saper combattere.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6783] = {n:"Arco dell\'Iniziato",t:2,d:"Quest\'arma dall\'apparenza rudimentale, ti darà l\'impressione di saper combattere.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,6,50,50,false,true],p:1};
I.u[6784] = {n:"Daghe dell\'Iniziato",t:5,d:"Quest\'arma dall\'apparenza rudimentale, ti darà l\'impressione di saper combattere.",ep:1,g:10,l:1,wd:true,fm:true,w:10,an:13,e:[5,3,1,1,30,50,false,false],p:1};
I.u[6785] = {n:"Martello dell\'iniziato",t:7,d:"Quest\'arma dall\'apparenza rudimentale, ti darà l\'impressione di saper combattere.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:15,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6786] = {n:"Pala dell\'Iniziato",t:8,d:"Quest\'arma dall\'apparenza rudimentale, ti darà l\'impressione di saper combattere.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6787] = {n:"Scheda riempita valida",t:80,d:"Questa piccola scheda è di un potenziale candidato a diventare fattorino del Panettiere.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW>1499&CA>49",p:0};
I.u[6788] = {n:"Dolci",t:24,d:"Questi dolci sono appena usciti dal forno. Devi consegnarli mentre sono ancora caldi. Pensi veramente di avere tutto questo tempo da perdere a guardarli così?",ep:1,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[6789] = {n:"Amuleto dei Fung",t:1,d:"Questo piccolo amuleto fiorisce in primavera, ma secca in estate, appassisce in autunno e marcisce in inverno. Una buona occasione per cambiare look ad ogni stagione!",ep:1,g:73,l:10,wd:false,fm:true,w:5,s:18,p:500};
I.u[6790] = {n:"Scheda da riempire",t:80,d:"Questa scheda assomiglia a una semplice foglia, ma al contatto con la pelle di una persona mostra subito se la persona corrisponde ai criteri forniti nell\'intestazione.",ep:1,g:6,l:1,wd:false,fm:true,w:0,ut:true,p:0};
I.u[6791] = {n:"Anello Campestre",t:9,d:"Con questo piccolo anello al dito potresti quasi cercare di passare inosservato attraverso i campi.",ep:1,g:65,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6792] = {n:"La Piantatrice dei Campi",t:4,d:"Questo bastone a forma di fiore è stato fabbricato con i resti di fiori campestri morti durante un orribile e crudele combattimento. Tutta la rabbia e l\'odio di queste povere piante sono contenuti in questo ridicolo bastone. Quest\'arma è usata dagli Etram più scaltri, i quali tentano di persuadere gli ignoranti dicendo di volergli offrire un mazzo di fiori. Una volta alla portata giusta, l\'imprudente si ritrova tramortito da colpi in testa ben meritati.",ep:1,g:45,l:10,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,45,50,false,false],c:"CV>20",s:18,p:500};
I.u[6793] = {n:"Anello Té",t:9,d:"Questo anello ha superato le prove, un piccolo segno al suo interno lo prova. Si tratta di un pezzo unico fatto da un apprendista Orefice per un test importante. È fabbricato a partire da un anello di ferro classico immerso in una soluzione di Té magico.",ep:1,g:1,l:4,wd:true,fm:true,w:1,p:50};
I.u[6794] = {n:"Stivali Campestri",t:11,d:"Per schiacciare i miserabili fiori che crescono sul tuo campo non c\'è niente di meglio che usare stivali fabbricati con resti di fiori campestri. Inoltre, con questi stivali i tuoi piedi avranno un piacevole odore floreale. Peccato che non esistano anche delle calze campestri.",ep:1,g:50,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6795] = {n:"Mantellina dei Campi",t:17,d:"Se vuoi essere la più bella al ballo di questa sera, ecco il mantello che fa per te.",ep:1,g:65,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6796] = {n:"Cintura Fiorita",t:10,d:"Con questa cintura ornata di piccoli fiori intorno alla vita, potrai farti passare senza eccessiva difficoltà per una stella danzante in mezzo ad un combattimento perso in partenza. Potresti addirittura lasciare a bocca aperta un esercito di Chafer e capovolgere la situazione a tuo favore.",ep:1,g:64,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6797] = {n:"Copricapo Campestre",t:16,d:"Se hai sempre sognato di essere un fioraio e di avere un alito profumato all\'acqua di rose, è il momento di indossare questo strano copricapo.",ep:1,g:70,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6798] = {n:"Fiore di Dzibi",t:24,d:"Il suo profumo è leggero, sottile, inebriante... Ma solo i Sadida e i Aniripsa conoscono il segreto di questi fiori.",ep:1,g:117,l:1,wd:false,fm:true,w:0,p:1};
I.u[6799] = {n:"Lama del Capo Bwork",t:6,d:"Tagliente come la lama di un Bwork, questa lama del Capo Bwork ha il vantaggio di essere più pesante. Sarà anche meno maneggevole, ma basta lasciarla cadere sull\'avversario per tagliarlo in due, come una volgare fetta di Tronknyde. Se il tuo nemico non morirà per il dolore, morirà sicuramente di vergogna... e tu dalle risate.",ep:1,g:48,l:100,wd:true,fm:true,w:100,an:14,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>200&CA>200&CV>200",s:19,p:25000};
I.u[6800] = {n:"Mantello Banale",t:17,d:"Questo mantello è in lana di Pappatutto. Ti servirà solo ad avere l\'aria un po\' chic... ma neanche tanto...",ep:1,g:15,l:1,wd:true,fm:true,w:1,p:1};
I.u[6801] = {n:"Mantello Invernale",t:17,d:"Quest\'imbottitura bella calda e profumata è stata cucita su un banale mantello. \nPuoi indossarlo o metterlo per terra davanti al camino,  l\'importante è che finalmente serva a qualcosa.",ep:1,g:18,l:1,wd:true,fm:true,w:2,p:1};
I.u[6802] = {n:"Paraorecchie",t:16,d:"Questo paraorecchie morbidissimo terrà sempre al caldo le tue orecchiucce.",ep:1,g:73,l:1,wd:true,fm:true,w:10,p:1};
I.u[6803] = {n:"Estratto di Fiore di Dzibi",t:24,d:"Evita di berne... e basta!",ep:1,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[6804] = {n:"Amuleto del Capo Bwork",t:1,d:"Di sembianze rudimentali, questo amuleto a forma di selce lavorata è dotato di una magia molto potente capace di trasformare un Bwork in principessa, o il contrario, nessuno lo sa.",ep:1,g:66,l:100,wd:true,fm:true,w:1,s:19,p:25600};
I.u[6805] = {n:"Bracciale del Capo Bwork",t:9,d:"Con questo piccolo gioiello potrai fare credere ai tuoi amici che hai sposato un grande Capo Bwork e che ti ha regalato questo braccialetto come regalo di matrimonio. Proprio quello che ti ci voleva per renderti interessante durante le serate alla taverna in cui non hai niente da dire.",ep:1,g:58,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6806] = {n:"Frammento di Legno",t:24,d:"Questo frammento di legno proviene da una recente costruzione, verosimilmente rossa.",ep:1,g:246,l:1,wd:false,fm:true,w:0,p:1};
I.u[6807] = {n:"Stivali del Capo Bwork",t:11,d:"Da lontano, questi stivali assomigliano ai classici stivali del Bwork... ma anche da vicino. Tuttavia, questi sono stivali di Capo Bwork: più resistenti, più potenti, e più puzzolenti. E fidati, fanno la differenza in un combattimento che sembra già perso.",ep:1,g:44,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6808] = {n:"Pezzo di tessuto strappato",t:24,d:"Questo pezzo di tessuto bianco è molto morbido ma anche molto macchiato...",ep:1,g:247,l:1,wd:false,fm:true,w:0,p:1};
I.u[6809] = {n:"Descrizione dell\'Assassino",t:24,d:"Questa descrizione descrive una ragazzina con i capelli biondi e vestita di scuro.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6810] = {n:"Rapporto di Attività del Quartiere",t:24,d:"Questo rapporto indica che il giorno del  furto della casa non ci sono stati incidenti da segnalare nel quartiere.\nA parte l\'avvistamento di un Ladrurbo la notte dell\'incidente.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6811] = {n:"Mantello del Capo Bwork",t:17,d:"Questo mantello lacerato e pieno di buchi ti farà passare per un grande guerriero Bwork. È l\'ideale per terrorizzare i vecchi del villaggio, ma non tanto per sedurre l\'anima gemella. La soluzione sarebbe di indossarlo completamente nudi... il che ti permetterebbe anche di continuare a terrorizzare i vecchi del villaggio.",ep:1,g:60,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6812] = {n:"Mutande del Capo Bwork",t:10,d:"Queste Mutande di cuoio viola bastano a se stesse, puoi accontentarti di indossarle senza niente altro addosso e avrai comunque un portamento fiero. Ma devi stare attento che siano della taglia giusta e che non ti cadano sulle ginocchia mentre giochi a saltare la corda.",ep:1,g:59,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6813] = {n:"Elmo del Capo Bwork",t:16,d:"Se vuoi veramente avere una testa da stupido, questo elmo fa proprio al caso tuo. Con un po\' di fortuna, non si vedrà neanche la differenza quando lo toglierai.",ep:1,g:65,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6814] = {n:"Insieme di pezzi di legno",t:24,d:"Questo insieme di pezzi di legno forma un lettino morbido, ideale per un Pìu.",ep:1,g:248,l:1,wd:false,fm:true,w:0,p:1};
I.u[6815] = {n:"Siringa di Nibé Lulla",t:24,d:"Nibé Lulla ti ha dato questa siringa per prelevare un campione di sangue di Adlu Minite, il Minatore Oscuro.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6816] = {n:"Campione di sangue",t:24,d:"Sei finalmente riuscito a prelevare un campione di sangue di Adlu Minite. Molto appetitoso.",ep:1,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[6817] = {n:"Amuleto del Capo Coccodrail",t:1,d:"Questo sorprendente amuleto è stato fabbricato partendo da uno Scudo Rettile dal quale sono state staccate le numerose pietre preziose. È un gioiello molto pesante ma veramente resistente. Il tuo collo sarà perfettamente protetto dai vampiri, ma anche dai succhiotti delle paesane un po\' troppo intraprendenti.",ep:4,g:67,l:70,wd:true,fm:true,w:100,s:20,p:12700};
I.u[6818] = {n:"Rosa Demoniaca Tagliata",t:35,d:"Adesso questo fiore, un tempo demoniaco, è un innocuo regalo. Detto ciò, se la persona che lo riceverà non sa cosa farsene, potrai sempre riprenderlo per fare della marmellata.",ep:1,g:118,l:1,wd:false,fm:true,w:1,p:1};
I.u[6819] = {n:"Bracciale del Capo Coccodrail",t:9,d:"Questo braccialetto assomiglia stranamente a un guanto, ma è proprio un braccialetto. A volte le apparenze ingannano.",ep:4,g:59,l:70,wd:true,fm:true,w:20,s:20,p:12800};
I.u[6820] = {n:"Erba Curativa",t:24,d:"Questa erba è l\'ingrediente principale dei vecchi rimedi degli Alchimisti. Oggigiorno non si usa più ed è stata sostituita dal trifoglio. Bisogna dire che quest\'ultimo evita il prurito facciale... un particolare da non sottovalutare.",ep:1,g:103,l:1,wd:true,fm:true,w:0,p:1};
I.u[6821] = {n:"Lama del Capo Coccodrail",t:6,d:"Fabbricata a partire dai resti trovati addosso a un Capo Coccodrail, quest\'arma si rivelerà molto efficace se sei abbastanza bello, abile, intelligente e forte per maneggiarla. Con un po\' di fortuna, finirai per trovare qualcuno che accetterà di scambiartela con una spada di Legnuccio.",ep:4,g:49,l:70,wd:true,fm:true,w:100,an:14,e:[12,6,1,1,40,40,false,false],c:"CA>150&CC>150&CV>100",s:20,p:12800};
I.u[6822] = {n:"Puntura del Risveglio",t:24,d:"Questa puntura contiene una medicina così potente da risvegliare un morto. D\'altronde sembra che l\'illustre morto vivente Hyrkul ne prendesse regolarmente. Non si può chiedere prova migliore della sua efficacia.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6823] = {n:"Pozione a base di piante",t:24,d:"Questa pozione ha un odore talmente nauseante che riuscirebbe a svegliare un Sadida durante il pisolino... sempre che il Sadida sia giovane e sul punto di svegliarsi.",ep:1,g:500,l:1,wd:true,fm:true,w:0,p:1};
I.u[6824] = {n:"Pietra di Cura Fuggitiva",t:24,d:"Questa pietra di cura perde il suo potere molto in fretta, bisogna avvolgerla in un metallo che ne assorbe certe radiazioni, in modo da circoscrivere l\'effetto della pietra e preservarne così la sua efficacia. Spesso si preferiscono degli amuleti standard a questa pietra, infatti sono altrettanto efficaci e costano meno.",ep:1,g:104,l:1,wd:false,fm:true,w:0,p:1};
I.u[6825] = {n:"Pantofole Dentate del Capo Coccodrail",t:11,d:"Queste magnifiche pantofole in pelle e scaglie di Capo Coccodrail sono munite, sulle estremità, di denti affilati. Stai attento quando fai piedino alla tua amata, potresti strapparle le calze in lana di Tabi.",ep:4,g:45,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6826] = {n:"Pietra di Cura Incastonata",t:24,d:"Questo amuleto è una pietra di cura fuggitiva graziosamente incastonata in un pezzo di metallo raro. Tenerla in mano procura una sensazione di benessere, la fatica scompare e il cervello si libera. E in più brilla di notte!",ep:1,g:105,l:1,wd:false,fm:true,w:0,p:1};
I.u[6827] = {n:"Lettera di Joe Pierlivet",t:24,d:"Joe ti ha affidato una lettera per il suo buon amico Howard Simanul, uno Yop... eh... come dire... uno Yop insomma!",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6828] = {n:"Elsa",t:24,d:"Questa elsa non ti farà diventare un asso della spada ma potrà aiutarti.",ep:1,g:97,l:1,wd:false,fm:true,w:0,p:1};
I.u[6829] = {n:"Spada appena forgiata",t:24,d:"Questa spada è appena stata forgiata.",ep:1,g:98,l:1,wd:false,fm:true,w:0,p:1};
I.u[6830] = {n:"Piccolo Zaino dello scolaro del Capo Coccodrail",t:81,d:"Anche ad Amakna il rientro a scuola è un bruttissimo giorno per gli scolari. Soprattutto per i giovani Yop per i quali questo giorno è una tortura senza precedenti. Tiragli su il morale con questo magnifico zaino dello scolaro in pelle e scaglie di Capo Coccodrail, imbottito da un ammasso di peli.",ep:14,g:58,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6831] = {n:"Cintura del Capo Coccodrail",t:10,d:"Questa cintura ricoperta di minuscole pietre preziose è troppo rigida per essere usata come frusta, tuttavia può essere utilizzata in maniera più convenzionale: ad esempio, per impedire ai tuoi pantaloni di caderti sulle ginocchia.",ep:4,g:60,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6832] = {n:"Fattorino della Birra",t:32,d:"Il Fattorino della Birra è importante come un portavalori. Anche se molto più scorbutico.",ep:1,g:15,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6833] = {n:"Borsa di Kama dubbiosa",t:24,d:"Questi kama sembrano essere molto antichi. Devi fonderli rapidamente prima che decidano di ritornare da dove sono venuti.",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6834] = {n:"Copricapo del Capo Coccodrail",t:16,d:"Se hai sempre sognato di assomigliare a un Coccodrail senza però volerti trasformare in Coccodrail, questo copricapo fa al caso tuo. Non cercare di far credere ai tuoi amici che sei riuscito ad uccidere un Coccodrail con le tue mani... a parte te, nessuno ci crederà.",ep:4,g:66,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6835] = {n:"Metallo Trasmutato",t:24,d:"La borsa di kama dubbiosa è stata abilmente trasmutata da Nibé Lulla. Una spada è ormai pronta per essere creata con questo metallo...",ep:1,g:241,l:1,wd:true,fm:true,w:0,p:1};
I.u[6836] = {n:"Spada rozza",t:24,d:"Questa è una spada forgiata dalle mani di Duedita, ma sembra ancora troppo fragile per te. Nibé Lulla l\'Alchimista dovrebbe poterti aiutare.",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6837] = {n:"Spada saltellante",t:24,d:"Una spada fatta apposta per te, leggera e efficace. Ma ci manca un tocco finale, quel non so che di Ecaflip...",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6838] = {n:"Spada di Fuoco rozza",t:24,d:"L\'acqua di luna sembra avere fatto effetto. Questa spada è a prova di tutto, ma ci manca quel non so che di Ecaflip.",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6839] = {n:"Spada di Yingnitié",t:6,d:"Questa Arma marchiata da Meow Meow potrebbe fare di te un Ecaflip leggendario, forse...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=0",p:1};
I.u[6840] = {n:"Spada di Yanguru",t:6,d:"Quest\'arma marchiata da Meow Meow potrebbe fare di te un Ecaflip leggendario, forse...",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=1",p:1};
I.u[6841] = {n:"Stoffa dell\'Orso",t:55,d:"Questa strana stoffa odora di Orso. Proprio quello che ci vuole per fare impazzire le donne!",ep:1,g:121,l:22,wd:true,fm:true,w:1,p:500};
I.u[6842] = {n:"Dente di Orso",t:47,d:"Questo strano dente apparteneva a un vecchio Orso. O meglio ad un\'invocazione di Orso che, bisogna ammettere, è tutta un\'altra cosa. Hai tra le mani un dente invocato... molto interessante.",ep:1,g:432,l:22,wd:true,fm:true,w:1,p:500};
I.u[6843] = {n:"Osso di Orso",t:47,d:"Quest\'osso appuntito si è rotto durante un terribile combattimento contro uno degli Orsi invocati dall\'Uomo Orso. Era troppo tardi per ingessare la zampa di questo povero Orso agonizzante e gemente di dolore a causa dei tuoi ripetuti attacchi. Hai preferito finirlo lentamente con la bava di Pappatutto, tagliarlo a pezzi e strappargli l\'osso mentre era ancora cosciente. Nessuna pietà per le invocazioni!",ep:1,g:48,l:22,wd:true,fm:true,w:1,p:500};
I.u[6844] = {n:"Peli di Orso",t:54,d:"A volte, all\'Uomo Orso viene l\'idea di depilare un\'invocazione di Orso per divertirsi o passare il tempo. Poi con i peli fa della biancheria di altissima qualità, molto apprezzata dai Cacciatori solitari attirati dalle sensazioni e dagli odori forti.",ep:1,g:195,l:22,wd:true,fm:true,w:1,p:500};
I.u[6845] = {n:"Pelle di Orso",t:59,d:"Questa pelle rugosa e senza peli è il frutto di un lungo lavoro di depilazione intensiva con olio bollente e ferro incandescente. Non ti stupire se puzza un po\' di bruciato.",ep:1,g:35,l:22,wd:true,fm:true,w:1,p:500};
I.u[6846] = {n:"Fiala cristallo di pallido Anthir",t:24,d:"Si direbbe una banale fiala, ma in realtà possiede un potere che solo gli Xelor sanno utilizzare.",ep:1,g:99,l:1,wd:false,fm:true,w:0,p:1};
I.u[6847] = {n:"Sacco di Semi di Epyss",t:24,d:"Semi abbastanza rari che non servono a molto. Chi ha detto \"come gli Xelor!\"?",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6848] = {n:"Legno Infiorato",t:24,d:"Legno di manifattura media.",ep:1,g:100,l:1,wd:false,fm:true,w:0,p:1};
I.u[6849] = {n:"Scatola di Suborhube",t:24,d:"Gli Anutrof sono i soli a sapere come si usa. Forse perché è meglio non saperne troppo sui loro segreti... E che segreti!",ep:1,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[6850] = {n:"Pizzaya",t:24,d:"Una delle specialità culinarie di Astrub, la pizzaya ha il vantaggio di poter essere consumata quando e dove si vuole... eccetto forse nel quartiere dei Macellai dove l\'odore è insopportabile...",ep:1,g:107,l:1,wd:false,fm:true,w:0,p:1};
I.u[6852] = {n:"Peluche della fiera",t:24,d:"Il peluche che Piañu Kolon ha vinto alla Fiera del trool...",ep:1,g:151,l:1,wd:true,fm:true,w:0,p:1};
I.u[6853] = {n:"Legno di Arash",t:24,d:"Questo legno ha la peculiarità di crescere dritto dritto, come un bastone. È pratico da stoccare...",ep:1,g:100,l:1,wd:true,fm:true,w:0,p:1};
I.u[6854] = {n:"Pelle di Larva Blu",t:24,d:"Pezzo di pelle viscida strappata a una povera larva senza difese.",ep:1,g:101,l:1,wd:false,fm:true,w:0,p:1};
I.u[6855] = {n:"Piccolo Arco d\'Enileda",t:24,d:"Frutto del lavoro della celebre Intagliatrice di archi Enileda, questo piccolo arco non è veramente da prendere come modello.",ep:1,g:244,l:1,wd:true,fm:true,w:0,p:1};
I.u[6856] = {n:"Forbici per Rosa Demoniaca",t:20,d:"La forma di queste forbici è stata specialmente studiata per tagliare il gambo di qualsiasi rosa demoniaca senza rovinarne i petali. E il tutto mentre ti sta mordendo il polpaccio, naturalmente!",ep:1,g:22,l:1,wd:true,fm:true,w:2,an:13,e:[5,3,1,1,20,20,false,false],p:1};
I.u[6857] = {n:"Birra di Astrub",t:37,d:"Una birra classica che favorisce lo sviluppo dei tuoi addominali, meglio conosciuti con il nome di Abdo Kro.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:4};
I.u[6858] = {n:"Scheda riempita ma non valida",t:80,d:"Questa scheda è, purtroppo, di un candidato non idoneo a diventare fattorino del Panettiere. La piccola macchia rossa in basso indica che gli mancano Forza e Agilità per questo mestiere.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW<1500|CA<50",p:0};
I.u[6859] = {n:"Paio di Forbici",t:24,d:"Un paio di forbici che, secondo certi parrucchieri, tenderebbero più a tagliare che a pettinare... o almeno così dicono.",ep:1,g:150,l:1,wd:true,fm:true,w:0,p:1};
I.u[6862] = {n:"Manoscritto dell\'Orso",t:24,d:"Questa strana pergamena spiega come l\'Uomo Orso abbia imparato a invocare gli Orsi. Incredibile!",ep:1,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[6863] = {n:"Elmo dei Mercenari di Astrub",t:16,d:"Elmo dei Mercenari di Astrub",ep:1,g:72,l:1,wd:false,fm:true,w:10,p:1};
I.u[6864] = {n:"Fiore di Rosa Oscura",t:24,d:"Un fiore di rosa talmente oscura che a confronto la sua ombra sembra risplendere.",ep:2,g:106,l:23,wd:true,fm:true,w:0,p:1};
I.u[6865] = {n:"Nota",t:24,d:"\"Vai ai margini della foresta per la consegna\".",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6866] = {n:"Pezzo di mantello",t:24,d:"Un pezzo di mantello blu appartenente a coloro che ti hanno attaccato. Ma gli hai dato una bella lezione!",ep:1,g:249,l:1,wd:false,fm:true,w:0,p:1};
I.u[6867] = {n:"Nota di raccolta",t:24,d:"Per non dimenticartelo hai annotato su questo pezzo di carta l\'ora alla quale devi raccogliere il Vhent.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6868] = {n:"Tavola di Castagno",t:95,d:"Questa tavola consente ai Tuttofare di costruire degli oggetti di legno, come una bara per esempio...",ep:1,g:1,l:10,wd:true,fm:true,w:10,p:20};
I.u[6869] = {n:"Piañu Kolon",t:32,d:"Piañu Kolon non sa più dov\'è casa sua, devi accompagnarla...",ep:1,g:14,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6870] = {n:"Padgref Demoël",t:32,d:"Padgref Demoël è in tuo potere. Devi portarlo in prigione senza rischi.",ep:13,g:8,l:1,wd:false,fm:true,w:0,m:true,p:1};
