I.u[6438] = {n:"Bacchetta Molle",t:3,d:"Questa bacchetta è fatta di elementi piuttosto molli, ed è quindi una bacchetta difficile da maneggiare. Ma nel cuore della battaglia sprigiona tutto il suo potere.",ep:5,g:33,l:85,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,70,false,true],c:"CI>85",p:8500};
I.u[6439] = {n:"Bacchetta Irreale",t:3,d:"Dei miscugli magici di elementi soprannaturali hanno permesso la creazione di questa bacchetta ai confini della realtà. Tanto terrificante quanto divertente, questa bacchetta è l\'emblema dell\'instabilità.",ep:4,g:32,l:90,wd:true,fm:true,w:12,an:11,e:[10,4,2,3,20,20,false,false],c:"CI>90&CW>30",p:9000};
I.u[6440] = {n:"Bacchetta Pelosa",t:3,d:"Questa bacchetta non è che un volgare ammasso di peli. Il cuore stesso della bacchetta assorbe l\'essenza magica dei vari ciuffi e le unisce. Per quanto possa sembrare aberrante... funziona!",ep:14,g:31,l:95,wd:true,fm:true,w:12,an:11,e:[5,3,2,5,40,40,false,true],c:"CW>40&CI>40",p:9500};
I.u[6441] = {n:"Peli di Moon",t:54,d:"Questi peli sono incredibilmente morbidi e caldi al tatto. Sembra quasi che siano ancora vivi.",ep:12,g:656,l:200,wd:true,fm:true,w:2,p:10000};
I.u[6442] = {n:"Bastone d\'Aga Dou",t:4,d:"Sempre in cerca di un modo per sorprendere i nemici, il Sadida Aga Dou ha pensato bene di attaccare una bambolina all\'estremità del suo bastone. Le giovani Yoppine si lanciano in avanti per acchiappare la bambolina e muoiono impalate.",ep:14,g:31,l:81,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>80&CV>50",p:17000};
I.u[6443] = {n:"Amuleto della Rinascita",t:1,d:"È stato il celebre e scherzoso artigiano Yamato, ingiustamente sbeffeggiato per il suo ridicolo arco, che per primo ebbe l\'audacia di incantare un amuleto con così tanti effetti... pratica che da secoli era ritenuta impossibile.",ep:9,g:57,l:126,wd:true,fm:true,w:20,p:40000};
I.u[6444] = {n:"Amuleto Turchese",t:1,d:"Ha lo stesso colore del famoso Dofus Turchese, ma pur non avendo niente a che vedere con lui, è comunque un oggetto molto potente. Come vedi le apparenze non ingannano sempre.",ep:9,g:58,l:63,wd:true,fm:true,w:10,p:10300};
I.u[6445] = {n:"Arc Rampante",t:2,d:"La forma di quest\'arco è stata veramente studiata, la sua curvatura è proprio perfetta. Si dice che per farlo l\'Intagliatore abbia preso come modello il sedere di una femmina Pappatutto.",ep:14,g:13,l:80,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>70&CC>50",p:16500};
I.u[6446] = {n:"Arco Ciduca",t:2,d:"Ciduca era un Intagliatore di archi famoso per i suoi problemi di pronuncia. Infatti era incapace di pronunciare il suono \"ar\" senza aggiungere una \"k\" dopo. Ma era comunque un grande arktista!",ep:12,g:14,l:87,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,30,false,true],c:"CW>50&CA>80",p:19000};
I.u[6447] = {n:"Pozione d\'oblio \"Invocazione di Chafer Paz\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo: \"Invocazione di Chafer Paz\"",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6448] = {n:"Pozione d\'oblio \"Invocazione di Arakne\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo: \"Invocazione di Arakne\".",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6449] = {n:"Cuervontello",t:17,d:"Utile per travestirsi da ombra, o da Messer Cuervoc se si vuole fare colpo sulle ragazze all\'uscita della Panetteria sul calar della notte.",ep:1,g:54,l:45,wd:true,fm:true,w:26,s:8,p:1000};
I.u[6450] = {n:"Cintura dell\'Amante di Ha",t:10,d:"La celebre Ciabattina Ha aveva un amante conosciuto per non essere affidabile. Ma l\'amore è cieco e lei gli offrì comunque questa magnifica cintura come prova della loro unione segreta.",ep:14,g:57,l:121,wd:true,fm:true,w:20,p:37255};
I.u[6451] = {n:"Arco Angelo",t:2,d:"A proposito di quest\'arco... ma com\'è possibile che abbia un nome così stupido? Come se il tuo fosse più intelligente, poi...",ep:14,g:31,l:82,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>80&CS>50",p:17000};
I.u[6452] = {n:"Arco Itetto",t:2,d:"Questo arco dalle sembianze complesse è un vero oggetto d\'arte. L\'Intagliatore di archi che l\'ha creato è famoso anche per aver esposto i suoi modelli più controversi nella celebre grotta di Loopin, vietata da secoli al pubblico minorenne.",ep:9,g:30,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>200&CS>100&CI>30",p:37000};
I.u[6453] = {n:"Arco del Pescatore",t:2,d:"Nato da un\'eccellente constatazione, (e cioè che l\'arco è molto utile per pescare i pesci volanti), quest\'arco è munito di una canna da pesca integrata che permette di pescare anche altri tipi di pesce...",ep:14,g:32,l:70,wd:true,fm:true,w:1,an:10,tw:true,e:[10,4,2,8,30,50,false,true],c:"CS>70&CA>70",p:13000};
I.u[6454] = {n:"Alberastone Oscuro",t:4,d:"Questo ramo di Alberagno Oscuro non è altro che una delle sua braccia. Eccellente per allenarsi a braccio di ferro, è soprattutto un\'eccellente arma per terrorizzare i nemici d\'infanzia o torturare i Tronknydi.",ep:13,g:23,l:87,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,50,false,false],c:"CV>150&CW>50",p:20000};
I.u[6455] = {n:"null",t:22,d:"",ep:0,g:1,l:100,wd:false,fm:true,w:1,e:[-1,-1,1,-1,-1,-1,false,false],p:1};
I.u[6457] = {n:"Kriptonite",t:40,d:"Una lega notevole la cui origine sembra lontanissima. In mancanza di impiego può sempre essere usata per decorare il camino o picchiare sulla testa di uno Yop, anche solo per assicurarsi che sia vuota...",ep:1,g:706,l:80,wd:true,fm:true,w:80,p:0};
I.u[6458] = {n:"Kobalite",t:40,d:"La Kobalite è una delle più sorprendenti leghe oggigiorno scoperte. Quando i vecchi Minatori la scoprirono pensarono di aver trovato la lega per eccellenza, fino a quando si accorsero che si trasformava in polvere a contatto della Bava di Pappatutto.",ep:1,g:704,l:100,wd:true,fm:true,w:100,p:0};
I.u[6459] = {n:"Amuleto del Minatore Oscuro",t:1,d:"L\'unica possibilità di sopravvivere in una miniera infestata di Minatori Oscuri, è di vederci chiaro. Se non riuscirai a impossessarti della loro candela, indossa questo amuleto che ti porterà fortuna.",ep:14,g:61,l:39,wd:true,fm:true,w:1,c:"CC>30",p:4200};
I.u[6460] = {n:"La Foglia d\'Inverno",t:1,d:"Questa magnifica Spilla è un omaggio alla celebre resistenza dei Minatori della miniera d\'Argento di Grimoth, i quali passarono un intero inverno a combattere un Roccioso  cattivissimo, per morire alla fine uccisi da un vecchio Tofu perso.",ep:1,g:65,l:98,wd:true,fm:true,w:10,p:25000};
I.u[6461] = {n:"La Foglia di Primavera",t:1,d:"Questo Amuleto specialmente concepito per i vecchi Anutrof, ha permesso tempo fa a Setag di ripulire la miniera di Grimoth da tutti i Minatori rivali. Un metodo discutibile ma terribilmente efficace.",ep:7,g:62,l:123,wd:true,fm:true,w:10,p:40000};
I.u[6462] = {n:"La Foglia d\'Estate",t:1,d:"Questa piccola spilla ha proprio del fascino, destinata in principio agli sfortunati decisi a partecipare ai giochi della fiera, si è subito notato come fosse anche ben adatta alle avventure epiche.",ep:13,g:63,l:45,wd:true,fm:true,w:4,p:5400};
I.u[6463] = {n:"Anello Giostraio",t:9,d:"Questo anello è stato creato da un celebre giostraio, di cui nessuno si ricorda il nome. È morto durante il concorso di tiro con l\'arco, mettendosi come bersaglio sulla testa un seme di Girasole Selvatico al posto della tradizionale Zucca.",ep:1,g:50,l:44,wd:true,fm:true,w:5,p:5300};
I.u[6464] = {n:"Anello dell\'Invocatore Soddisfatto",t:9,d:"Questo anello è una versione migliorata del famoso Anello di Soddisfazione. Ideale per lasciare combattere le piccole invocazioni al tuo posto, oppure solo per fare il furbo invocando un intero esercito di Tofu.",ep:1,g:51,l:40,wd:true,fm:true,w:5,p:4000};
I.u[6465] = {n:"Anello di Loopin",t:9,d:"Tempo fa Loopin chiese al mostro che abita la sua grotta in che modo poteva creare un tale anello, in cambio di alcuni servizi che l\'hanno cambiato per sempre. La gente ti racconterà di quanto lo scambio gli sia stato sfavorevole.",ep:5,g:52,l:80,wd:true,fm:true,w:10,p:16000};
I.u[6466] = {n:"Amuleto di Shika",t:1,d:"Questo amuleto ha permesso a Shika Ingals di sopravvivere più volte alle ribellioni delle greggi di Pappatutto ben decisi a rovinarle la vita.",ep:14,g:60,l:29,wd:true,fm:true,w:10,p:2300};
I.u[6467] = {n:"Anello Nimo",t:9,d:"Nessuno conosce le proprietà di questo anello, che ha preferito mantenersi anonimo dopo un combattimento umiliante perso contro un\'Arakne invocata. Tuttavia bisogna ammettere che l\'Arakne era appena stata compulsata da uno Yop.",ep:1,g:53,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6468] = {n:"Anello del Giovane Vald",t:9,d:"Quando tutti gli altri Yop della sua età ricevettero in regalo, per la loro comunione, una cavalcatura Tabi, o una Gultard in legno, Vald ricevette quest\'anello.",ep:1,g:54,l:59,wd:true,fm:true,w:10,p:9275};
I.u[6469] = {n:"Fede di Farle",t:9,d:"Questa fede è stata consumata dallo strofinio delle spighe di orzo durante centinaia di raccolti. Testimonia l\'unione tra Farle e Shika, che si sposarono in mezzo a un campo d\'orzo in primavera.",ep:9,g:55,l:87,wd:true,fm:true,w:5,p:20000};
I.u[6470] = {n:"Stivali dell\'Allevatore di Pappatutto",t:11,d:"Questi magnifici stivali sono perfetti per prendere a calci nel sedere i Pappatutto quando bisogna convincerli a cambiare pascolo e ad attraversare il villaggio. Sono ideali anche per costringere i piccoli Yop a fare i compiti di scuola.",ep:13,g:40,l:68,wd:true,fm:true,w:10,p:12000};
I.u[6471] = {n:"Scarpe Verniciate di Porkass",t:11,d:"Queste piccole scarpe sono state rinforzate, rimesse a nuovo, e soprattutto profumate. Sono usate soprattutto per attirare i Fun Fung, grazie al substrato lasciato dal Porkass che per loro è veramente appetitoso.",ep:13,g:41,l:30,wd:true,fm:true,w:10,p:2700};
I.u[6472] = {n:"Dragocapo Dorato",t:16,d:"Questo guscio di Draguovo Dorato imbottito ti rende quasi insensibile ai colpi di folgore magica del Bwork Mago. In compenso però non ti proteggerà per niente contro i veri colpi di fulmine...",ep:11,g:55,l:57,wd:true,fm:true,w:10,p:8500};
I.u[6473] = {n:"Dragocapo Zaffiro",t:16,d:"Questo guscio di Draguovo Zaffiro ti starà a pennello, se saprai indossarlo. Saper indossare un copricapo del genere non è alla portata di tutti, infatti gli Yop tendono a portarlo al contrario.",ep:11,g:57,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6474] = {n:"Dragocapo Nero",t:16,d:"Questo Guscio di Draguovo Nero è l\'ideale per non farsi vedere di notte o per proteggersi dalle frane in montagna o, ancora, quando si sfida un Croccaroc nel lancio delle pietre.",ep:11,g:56,l:93,wd:true,fm:true,w:20,p:22300};
I.u[6475] = {n:"Elmo rotto dello Chafer",t:15,d:"Non puoi utilizzare questo elmo nello stato in cui è, ti farebbe troppo male alla testa. Un buon Sarto dovrebbe poterlo riparare, mettere una buona imbottitura all\'interno e, tra una cosa e l\'altra, spillarti un bel po\' di kama.",ep:3,g:709,l:40,wd:true,fm:true,w:20,p:1000};
I.u[6476] = {n:"Candela Magica del Minatore Oscuro",t:15,d:"Questa candela brilla anche quando è spenta, e non emana calore. Se si ascolta bene, si riesce solo a percepire un piccolo crepitio, un po\' come il rumore di certi cereali in una tazza di latte.",ep:1,g:701,l:40,wd:true,fm:true,w:10,p:10000};
I.u[6477] = {n:"Cappello del Minatore Oscuro",t:16,d:"Questa sontuoso cappello ti permette di vederci più chiaro anche se la giornata è già abbastanza chiara. È anche molto utile per abbagliare le bestie che vivono nelle miniere malfamate, o semplicemente per far credere agli Yop di essere una luce.",ep:16,g:90,l:103,wd:true,fm:true,w:20,p:27000};
I.u[6478] = {n:"Mykakka Dilaniato",t:15,d:"Questo Mykakka magico è veramente in cattivo stato, non deve aver sopportato la violenza dei tuoi attacchi e il suo pelo è diventato scuro. Forse potrebbe cominciare una nuova vita se tu fossi capace di curarlo.",ep:14,g:702,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6479] = {n:"Orso Spezzettato",t:15,d:"Questa piccola testa di Orso è veramente in cattivo stato. Con un po\' di filo, di tessuto e d\'inventiva si dovrebbe riuscire a fare qualcosa per questo orrore e trasformarlo in un bel copricapo.",ep:1,g:703,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6480] = {n:"Vimini Oscuro",t:15,d:"Questo pezzo di vimini è oscuro come il più oscuro dei fantasmi, magico come il più magico dei fantasmi, resistente come il più resistente dei fantasma. Ma ricordati che i fantasmi non esistono.",ep:14,g:123,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6481] = {n:"Dora Bora",t:16,d:"Questo splendido cappello è stato concepito sull\'isola di Dora Bora che si trova un po\' a sud dell\'isola di Moon. Adattissimo per il combattimento, è anche molto apprezzato come cestino da frutta, in particolare per metterci le noci di Kokoko Traumatizzate.",ep:12,g:61,l:120,wd:true,fm:true,w:20,p:40000};
I.u[6482] = {n:"Korko Kusto",t:16,d:"Versione rilavorata del Juik Kramp, questo cappello è fatto con le migliori risorse dell\'isola di Moon, il che gli dà veramente un\'aria nostrana. A parte questo, la cosa interessante è che potrai veramente sbizzarrirti a dare testate.",ep:12,g:59,l:73,wd:true,fm:true,w:10,c:"PG=10",p:14000};
I.u[6483] = {n:"Elmo del Bwork di Bronzo",t:16,d:"Questo sorprendente elmo trasforma chi lo porta in Bwork di Bronzo, o almeno così dice la leggenda. Da provare subito con soggetti un po\'... robusti, potresti rivenderli a un buon prezzo.",ep:20,g:91,l:144,wd:true,fm:true,w:10,p:46625};
I.u[6484] = {n:"Arco dell\'Etram Arciere",t:2,d:"Quando le daghe non bastano più e gli dei ti snobbano, devi scegliere il tuo stile di combattimento. Alcuni Etram l\'hanno capito, altri sperano ancora in un aiuto da parte degli dei.",ep:9,g:40,l:90,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>90&CA>90&CW>50",p:16000};
I.u[6485] = {n:"Arco dello Chafer Arciere",t:2,d:"Lo Chafer Arciere non è mai stato abbastanza astuto e abile a causa delle sue ossa tremolanti, per maneggiare questo arco. A parte il problema delle ossa tremolanti, tu sei probabilmente nelle stesse condizioni di questo ridicolo Chafer.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CC>100&CS>100",p:36600};
I.u[6486] = {n:"Corteccia della Quercia Molle",t:96,d:"Questa corteccia è più resistente di qualsiasi altra corteccia, ed è incredibilmente potente. Però niente ci assicura che non si tratti di una falsa corteccia di Alberagno ridipinta. Forse è il momento che anche tu imbrogli un amico.",ep:9,g:666,l:200,wd:true,fm:true,w:10,p:10};
I.u[6487] = {n:"Gemma della Quercia Molle",t:108,d:"Se provi a succhiare la linfa calda e sciropposa di questa gemma enorme, ti verranno sicuramente in mente i tuoi biberon d\'infanzia. Ma subito dopo, ti trasformerai in una foglia morta.",ep:9,g:665,l:200,wd:true,fm:true,w:10,p:10};
I.u[6488] = {n:"Radice della Quercia Molle",t:98,d:"Qualcuno tentò di fare della birra con questa radice.\nÈ però fortemente sconsigliato, la Quercia Molle non regge per niente l\'alcool e le radici rischierebbero di diventare instabili a contatto anche con una sola goccia d\'alcool. Un po\' come un Sadida.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[6489] = {n:"Legno di Quercia Molle",t:38,d:"Questo legno ha conosciuto l\'ascia di Bruce Bulgur da molto vicino. Ha però conosciuto molte altre cose misteriose e intriganti che il libro del Bwork Mago non rivela. Hai il diritto di immaginare il peggio...",ep:1,g:668,l:200,wd:true,fm:true,w:10,p:10};
I.u[6490] = {n:"Ambra della Quercia Molle",t:50,d:"Quest\'ambra contiene una miserabile bestiola intrappolata nella resina. Questo gioiello di Quercia Molle è un oggetto da collezione, come i calzini a pois rossi e gialli del Chuko.",ep:9,g:669,l:200,wd:true,fm:true,w:10,p:10};
I.u[6491] = {n:"Il Tronknydum",t:2,d:"Questo arco è un incrocio mal riuscito tra un Tronknyde e un Alberagno. Per un Taglialegna non esiste fallimento peggiore, ma per un Intagliatore di Archi è un vero successo. I tuoi genitori avrebbero voluto dire la stessa cosa di te.",ep:9,g:41,l:57,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],p:8500};
I.u[6492] = {n:"Bastone del Wobot",t:4,d:"La distanza tra le due punte di questo bastone corrisponde a quella che c\'è tra gli occhi di un Volpo... Ma fin dove arriverano questi owwibili Wabbit?",ep:2,g:37,l:60,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>60&CV>60",s:11,p:9400};
I.u[6493] = {n:"Infradito Wabbits",t:11,d:"Entra nella \"Cawota attitude\" con questi infradito dell\'ultima collezione. Sono raccomandati da tutti gli esperti in ciabatte e danze rituali, nonché dagli esperti in Tango rapido del Capitano Chafer.",ep:8,g:39,l:60,wd:true,fm:true,w:10,s:11,p:9300};
I.u[6494] = {n:"Bacchetta di Elya Wood",t:3,d:"Usata dai più famosi Aniripsa di Amakna, questa bacchetta costituisce l\'arma ideale per inviare un incantesimo sui propri avversari o cercare di rendere più intelligenti i propri amici. E così, potrai trasformare uno Yop in zucca.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,50,50,false,true],c:"CI>300&CW>100",s:39,p:36800};
I.u[6495] = {n:"Bacchetta della Quercia Molle",t:3,d:"Fabbricata a partire dai resti della Quercia Molle rediviva, questa bacchetta è semplicemente strapotente. Basta agitarla a destra e a sinistra con un buon ritmo, per dare inizio a una pioggia di rospi... o sembrare un perfetto idiota.",ep:22,g:42,l:172,wd:true,fm:true,w:10,an:11,tw:true,e:[7,3,3,4,45,70,false,true],c:"CI>400&CC>250&CW>150",p:45000};
I.u[6496] = {n:"Bacchetta in Radice di Alberagno Oscuro",t:3,d:"Questa bacchetta tende qualche volta a tornare in vita e ritorcersi contro il proprio padrone. In questo caso, la miglior soluzione è di darla al tuo nemico, o a uno Yop che l\'apprezzerà credendo che gli stai facendo un regalo.",ep:9,g:40,l:67,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>70&CW>70",p:12000};
I.u[6497] = {n:"Bulgurda delle Scuse",t:3,d:"La moglie di Bruce Bulgur, un\'Aniripsa, non la smetteva di rubargli la sua famosa ascia. Per mettere fine a questa storia, Bruce le tagliò un\'ala e un braccio e, per scusarsi, le regalò questa bacchetta. Era un uomo che ci sapeva fare con le donne!",ep:9,g:43,l:63,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,50,false,true],c:"CI>63&CW>30",p:10325};
I.u[6498] = {n:"Mutande Kanguwu del Wabbit GM",t:10,d:"Di dimensioni più che rispettabili, queste magnifiche Mutande conservano ancora le tracce nonché qualche pelo un po\' strano del suo vecchio proprietario. Sul sedere o sulla testa, queste mutande faranno di te un personaggio rispettato in tutta Amakna.",ep:8,g:58,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6499] = {n:"Amuleto \"Denti di Wabbit\"",t:1,d:"I denti di questo amuleto hanno sgranocchiato più cawote di quanti alberi abbia sradicato Bruce Bulgur... Non ti stupire se sai di cawota e se i Tiwabbit cercano di darti dei bacini sul collo.",ep:8,g:59,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6500] = {n:"Orecchie di Wabbit",t:16,d:"Queste orecchie non ti faranno sentire meglio, ma aiuteranno i tuoi amici a ritrovarti meglio in mezzo alla folla, mentre i tuoi nemici moriranno dal ridere. Due orecchie che, con il tempo, si riveleranno indispensabili.",ep:8,g:52,l:60,wd:true,fm:true,w:10,s:11,p:9500};
I.u[6501] = {n:"Zaino-Cawota",t:81,d:"Con questo Zaino sulle spalle, puoi partire all\'avventura senza preoccuparti dei problemi alimentari. Infatti, anche se la Cawota è vuota come la testa di uno Yop, le foglie ricrescono spontaneamente... puoi sempre farti delle buone tisane.",ep:8,g:57,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6503] = {n:"Martello Poltiyetta",t:7,d:"La Poltiyetta è il risultato dell\'incrocio tra un Kwak di Fiamma aggressivo e un Tofu malato. Sin dalla notte dei tempi, la caccia alla Poltiyetta è considerata come un rituale, cacciare questa orribile creatura è veramente un piacere.",ep:13,g:35,l:57,wd:true,fm:true,w:20,an:15,e:[6,5,1,1,40,50,false,false],c:"CI>60&CS>20",p:8000};
I.u[6504] = {n:"Martello Fantal",t:7,d:"Solo il diminutivo del suo creatore è conosciuto, un certo Fantal, ma si sa che aveva cattivo gusto. Infatti gli piaceva cospargersi di Gelatina Reale per poi ricoprirsi di piume di Tofu Reale. E sì, in più aveva gusti nobili!",ep:9,g:36,l:81,wd:true,fm:true,w:20,an:15,e:[10,5,1,1,50,50,false,false],c:"CS>80&CV>70",p:17000};
I.u[6505] = {n:"Martello Taurino",t:7,d:"Questo martello è l\'ideale per combattere contro le bestie con le corna. In compenso per piantare chiodi o cavoli, è proprio inutile.",ep:9,g:37,l:100,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CC>100&CW>40&CS>50",p:26000};
I.u[6506] = {n:"Anello del Minatore Gorgorificato",t:9,d:"Tra gli Anutrof si dice che un Minatore viene gorgorificato quando, a furia di lavorare in miniera, non sopporta più la luce del giorno. Non provare mai ad avvicinargli una candela, ti trasformerebbe in bronzo.",ep:1,g:40,l:84,wd:true,fm:true,w:10,c:"PG=3",p:18500};
I.u[6507] = {n:"Martello della Terps",t:7,d:"La Terps era una creatura villana pericolosa ed odiata tanto quanto la sua grande rivale, la vecchia Liche. Forgiò questo martello per schiacciarle gli alluci, ma alla fine le ruppe i piedi. Nacque così una grande storia d\'amore.",ep:9,g:38,l:90,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,35,80,false,false],c:"CS>60&CI>60",p:19000};
I.u[6508] = {n:"Martello Zanna",t:7,d:"Un martello eccezionale, destinato a curare il tuo piccolo Prespic adorato, o i suoi nemici se sei un discepolo del Chafer Paz.",ep:9,g:39,l:50,wd:true,fm:true,w:20,an:15,e:[6,4,1,1,40,40,false,false],p:6000};
I.u[6509] = {n:"Martello R\'Cicollo",t:7,d:"Questo sontuoso martello ha fatto girare la testa a più di un Osamodas. Infatti è talmente potente che tutti si girano quando passa il suo proprietario. Questo martello è da tempo all\'origine di una strana patologia.",ep:9,g:40,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>100&CI>150",p:36000};
I.u[6510] = {n:"Martello Kahr",t:7,d:"Kahr era veramente scarso quando si trattava di combattere con il martello. Fortunatamente ricevette in eredità questa meraviglia che lo fece diventare una persona rispettata e invidiata. Il successo non viene mai per caso...",ep:12,g:41,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>150&CI>150",p:36000};
I.u[6511] = {n:"Martello Ruga",t:7,d:"È il martello ideale per i momenti caldi, e ti darà un successo enorme se lo saprai utilizzare correttamente. Comunque non è per tutti...",ep:9,g:42,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,40,40,false,false],c:"CI>150&CS>100",p:36000};
I.u[6512] = {n:"Martello Nitrico",t:7,d:"È l\'arma degli Xelor un po\' ribelli e che sono in cerca di adrenalina. Gli permette soprattutto di compensare i complessi dovuti alle loro ridicole dimensioni.",ep:14,g:43,l:82,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,40,50,false,false],c:"CI>50&CC>50",p:17000};
I.u[6513] = {n:"Martello Macina",t:7,d:"Questo martello deve la sua potenza a un sottile incantesimo, che non si vede a prima vista, e nemmeno alla seconda. Per questo lo si dice ogni volta, in modo da aumentare il suo valore per gli acquirenti un po\' ingenui.",ep:1,g:44,l:55,wd:true,fm:true,w:20,an:15,e:[6,4,1,1,50,50,false,false],p:9000};
I.u[6516] = {n:"Daghe R\'Hoh",t:5,d:"Nessun Etram può resistere alla voglia di aggredire un amico con queste sublimi daghe. Il loro obiettivo è di riportare la sicurezza ad Amakna, uccidendo uno a uno tutti gli Etram che restano.",ep:9,g:41,l:121,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>100&CV>100",p:38000};
I.u[6517] = {n:"Daghe Vibranti",t:5,d:"Queste daghe farebbero innamorare qualsiasi Etramina in cerca di nuove esperienze. Effettivamente, i loro strani poteri permettono di compiere azioni crudeli tanto contro i nemici quanto contro gli amici. Il Capitano Chafer le avrebbe adorate.",ep:7,g:42,l:80,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>80",p:8000};
I.u[6518] = {n:"Amrothilina",t:3,d:"Concepita da un famoso Intagliatore, questa bacchetta ha vinto 13 volte il concorso della Bacchetta N\'hi, riuscendo a sostituire così i vecchi modelli Bulgur, oggi ritirati dal mercato perché troppo pericolosi per i giovani Aniripsa.",ep:9,g:44,l:120,wd:true,fm:true,w:10,an:11,e:[6,4,2,4,50,50,false,true],c:"CI>300&CV>100",p:36000};
I.u[6519] = {n:"Bacchetta di Kuartz",t:3,d:"È un famosissimo Intagliatore, conosciuto anche per la somiglianza del suo nome con una delle leghe più preziose di Amakna. Fu il primo ad avere l\'idea di integrare il metallo nelle creazioni. Talvolta la pazzia porta al successo.",ep:14,g:41,l:80,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>120&CW>40",p:17000};
I.u[6520] = {n:"L\'Emicrania",t:3,d:"L\'Intagliatore di questa bacchetta ha chiesto più di una volta di cambiare nome, ma i responsabili del registro di Amakna erano sempre troppo abituati a passare il tempo alla taverna facendosi venire dei terribili mal di testa. Questa bacchetta gli è dedicata.",ep:13,g:45,l:85,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150&CV>100",p:19000};
I.u[6521] = {n:"Kelinoramo",t:4,d:"Si dice che con questo bastone si possa fare arrossire una femmina di Alberagno, o solleticare le parti intime della Quercia Molle per cercare di sedurla. A ogni modo, ti sconsigliamo di usarlo... La Quercia Molle è veramente molto possessiva...",ep:9,g:38,l:129,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,40,false,false],c:"CS>250&CV>200",p:43000};
I.u[6522] = {n:"La Radice Sinati",t:4,d:"La leggenda racconta che questa radice è erbivora: tende a infilarsi rapidamente sotto le foglie morte per mangiare i giovani alberi. Molto impressionante, ma non ti servirà a niente se stai combattendo dei Dente di Leone.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CI>200&CS>200&CV>150",p:37000};
I.u[6523] = {n:"La Radice Agoga",t:4,d:"Creazione elegante e raffinata, questa radice intagliata farà di te un vero invocatore. Niente di cui vantarsi nelle serate, ma per far cadere ai tuoi piedi le Sadidine di Amakna, non c\'è di meglio!",ep:9,g:40,l:120,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>200&CV>150",p:36000};
I.u[6524] = {n:"Radice Scorbutica",t:4,d:"Un Sadida perdutamente innamorato di una Sadidina Selvaggia ha cercato di attirarla sotto ad un carpine con questa radice... l\'ha aspettata per un centinaio di anni. Insomma lei gli ha fatto un pacco coi fiocchi o, come dicono ora i Sadida, un pacco con le radici!",ep:14,g:41,l:54,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"PG=10",p:9000};
I.u[6525] = {n:"Bastone del Feca",t:4,d:"Gli abitanti di Amakna ne avevano abbastanza di sentire i discepoli Feca lamentarsi tutto il giorno delle loro armature. Così decisero di concepire questo bastone sperando di cambiare il loro argomento di conversazione alla taverna.",ep:14,g:42,l:94,wd:true,fm:true,w:10,an:12,tw:true,e:[7,5,1,1,40,80,false,false],c:"PG=1",p:25600};
I.u[6526] = {n:"Pala Hebù",t:8,d:"Il Forgiatore di questa pala ha voluto conservare l\'anonimato per essere modesto, ma ha lasciato un indizio nel nome di questa pala. Certi artigiani sono veramente irrecuperabili...",ep:1,g:4,l:94,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>70&CW>50",p:23000};
I.u[6527] = {n:"Pala Musicale",t:8,d:"\"Pala pala pala uh come spalo, pala pala pala come uh ti amo\" canticchiava Noh Yele, l\'illustre Forgiatore di spade. Era così stonato che sua moglie si pentì per tutta la vita di avergli costruito questa pala.",ep:1,g:38,l:52,wd:true,fm:true,w:10,an:16,e:[10,5,1,1,20,20,false,false],c:"CC>80&CI>50",p:7100};
I.u[6528] = {n:"Pala Grinaggio",t:8,d:"Questa pala ha attraversato i continenti, ha visto il tramonto sul Monte Crakelur, l\'alba all\'orizzonte del Mare di Asse. E pensare che tu non sei mai andato oltre l\'isola di Moon... pietoso.",ep:12,g:4,l:88,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CI>80&CC>150&CW>40",p:20000};
I.u[6535] = {n:"Pala Hikola",t:8,d:"Questa strana pala multiuso serviva a uccidere le pulci dei giovani Yop, a togliergli la forfora e a fargli entrare in testa le basi dell\'aritmetica.",ep:9,g:36,l:121,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>300&CS>50&CV>100&CW>50",p:37000};
I.u[6536] = {n:"Pala del Minatore Oscuro",t:8,d:"Il Minatore Oscuro usa questa pala, grande come la mano di un Croccaroc, essenzialmente per schiacciare più Aniripsa in un solo colpo. Ti consigliamo di fare lo stesso, per non morire come un idiota.",ep:9,g:34,l:120,wd:true,fm:true,w:10,an:16,e:[10,5,1,1,60,60,false,false],c:"CC>250&CV>100&CS>75",p:34000};
I.u[6537] = {n:"Pala Kulo",t:8,d:"Questa pala è veramente antipatica. Nessuno sa veramente perché, ma le Pala Kulo sono sempre insopportabili. Insomma, meglio soli che male accompagnati...",ep:12,g:37,l:88,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>100&CA>70",p:20000};
I.u[6538] = {n:"Pala Noramik",t:8,d:"Questa pala permette agli Anutrof di vedere più lontano. È fatta in modo che possano affondarla nel terreno e salirci su per scrutare l\'orizzonte e gasarsi un po\'. Ideale per ritrovare il proprio ospizio quando ci si è persi tra due felci.",ep:12,g:39,l:84,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>70",p:18200};
I.u[6539] = {n:"Barza Pala",t:8,d:"Questa pala è veramente diversa dalle altre. Se vuoi utilizzarla per combattere rischi di farti prendere veramente in giro. In effetti, le barzellette su questa Pala sono molto popolari nelle Taverne.",ep:9,g:35,l:71,wd:true,fm:true,w:10,an:16,tw:true,e:[10,4,1,1,25,60,false,false],c:"CS>30&CC>150",p:13000};
I.u[6540] = {n:"La Pala Elabest",t:8,d:"Si racconta che colui che forgiò questa pala assomigliasse ad una vera e propria bestia. Insomma, una specie di incrocio tra un Sadida e un Buulupo. Si racconta anche che la sua pala si fosse innamorata di lui. Che storia delle pale!",ep:14,g:33,l:87,wd:true,fm:true,w:10,an:16,tw:true,e:[15,5,1,1,30,100,false,false],c:"CC>150&CV>80",p:20000};
