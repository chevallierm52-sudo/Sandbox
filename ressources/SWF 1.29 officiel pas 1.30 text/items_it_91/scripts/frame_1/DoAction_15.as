I.u[6601] = {n:"Polvere di Artificio",t:48,d:"Quando i tuoi invitati cominciano ad annoiarsi, la soluzione migliore è quella di usare la celebre Fata d\'Artificio, da costruire da sé con questa polvere e con i diversi ingredienti. Questa Fata renderà la tua serata veramente esplosiva.",ep:16,g:670,l:1,wd:true,fm:true,w:1,p:100};
I.u[6602] = {n:"Sangue di Ratto d\'Hyoactiv",t:24,d:"Le norme di sicurezza Bontariane prevedono di tenersi ad una distanza di 100 metri da ogni sostanza Hyoactiva pena la moltiplicazione per tre del proprio tempo di gioco.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[6603] = {n:"Peluche del Pappatutto",t:61,d:"Questo peluche è la copia esatta di un Pappatutto, chi l\'ha creato gli ha persino dato l\'odore di un Pappatutto. Non ti stupire quindi se puzzi un po\' quando ti svegli la mattina.",ep:13,g:671,l:1,wd:true,fm:true,w:10,p:1};
I.u[6604] = {n:"Quaquà",t:18,d:"Più stupido del Tofu, del Pappatutto e addirittura dello Yop, il Quaquà eccelle in cretineria.",ep:1,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[6605] = {n:"Peluche del Pappatutto Reale",t:61,d:"Questo peluche sembra proprio vero, dalle cuciture all\'imbottitura, niente è stato lasciato al caso. Un eccellente regalo per i bambini viziati o i piccoli figli di papà.",ep:13,g:672,l:1,wd:true,fm:true,w:10,p:1};
I.u[6606] = {n:"Peluche del Dabol Sadida",t:61,d:"Nell\'imbottitura di questo peluche c\'è una grossa sveglia, molto utile per i Sadida che fanno fatica a svegliarsi la mattina. In compenso, è meglio non portarselo dietro quando si è innamorati, il tempo non conta più in quei momenti!",ep:13,g:673,l:1,wd:true,fm:true,w:10,p:1};
I.u[6607] = {n:"Peluche del Dabol Ecaflip",t:61,d:"Questo piccolo peluche diverte gli Ecaflip di ogni età.",ep:13,g:674,l:1,wd:true,fm:true,w:10,p:1};
I.u[6608] = {n:"Peluche del Dabol Yop",t:61,d:"Questo peluche assomiglia proprio a un vero Yop, infatti il suo cranio non è neanche imbottito.",ep:13,g:675,l:1,wd:true,fm:true,w:10,p:1};
I.u[6610] = {n:"Peluche del Dabol Etram",t:61,d:"Questo peluche è stato rubato a un giovane Etram che, a sua volta, l\'aveva rubato a uno dei suoi compagni.",ep:13,g:677,l:1,wd:true,fm:true,w:10,p:1};
I.u[6611] = {n:"Peluche del Dabol Aniripsa",t:61,d:"Questo peluche potrebbe quasi volare da solo se le sue ali non fossero così consumate. Effettivamente non è proprio un oggetto di prima mano, ma che importa, è sempre un bel regalo.",ep:13,g:678,l:1,wd:true,fm:true,w:10,p:1};
I.u[6612] = {n:"Peluche del Dabol Anutrof",t:61,d:"Attenzione: questo peluche è veramente molto pesante. Infatti è imbottito con pietre di Bauxite e Pepite d\'Oro.",ep:13,g:679,l:1,wd:true,fm:true,w:10,p:1};
I.u[6613] = {n:"Peluche del Dabol Feca",t:61,d:"Questo peluche è quasi indistruttibile. Sarà perfetto per i giovani Feca un po\' turbolenti e noncuranti.",ep:13,g:680,l:1,wd:true,fm:true,w:10,p:1};
I.u[6614] = {n:"Peluche del Dabol Osamodas",t:61,d:"Si dice che questo peluche possa invocare altri piccoli peluche se curato con attenzione. Una vecchia leggenda per impedire ai giovani Osamodas di mangiarlo.",ep:13,g:681,l:1,wd:true,fm:true,w:10,p:1};
I.u[6615] = {n:"Peluche del Dabol Ocra",t:61,d:"Questo peluche dall\'aspetto fiero, è fatto per essere lanciato sui vostri compagni di gioco da molto lontano, una specie di boomerang, ma che non torna indietro...",ep:13,g:682,l:1,wd:true,fm:true,w:10,p:1};
I.u[6616] = {n:"Peluche del Dabol Xelor",t:61,d:"Questo peluche fa uno strano rumore. Sembra che all\'interno dell\'imbottitura della sua testa ci sia un orologio. Ideale per conciliare il sonno dei bambini Xelor.",ep:13,g:683,l:1,wd:true,fm:true,w:10,p:1};
I.u[6617] = {n:"Peluche del Cinghiale",t:61,d:"Questo peluche assomiglia tantissimo a un peluche di Cinghiale. Impressionante. Noterai che i suoi peli sono veri peli di Cinghiale. Un marchio di qualità, non c\'è dubbio.",ep:13,g:684,l:1,wd:true,fm:true,w:10,p:1};
I.u[6618] = {n:"Peluche del Tofu",t:61,d:"Chi non ha mai sognato di stringere tra le braccia una copia di Tofu? Forse tu. In questo caso, non sai veramente fare acquisti oppure i tuoi amici non sanno farti i regali.",ep:13,g:685,l:1,wd:true,fm:true,w:10,p:1};
I.u[6619] = {n:"Peluche del Fung",t:61,d:"Questo Fung non ha spine che fanno male né veleno paralizzante. È comunque abbastanza pericoloso da fare paura a tutti gli Yop un po\' ingenui.",ep:13,g:686,l:1,wd:false,fm:true,w:10,p:1};
I.u[6620] = {n:"Peluche del Prespic",t:61,d:"Questo Prespic di peluche non lancerà lancette e non diventerà invisibile. Ma compie perfettamente il suo lavoro di peluche e tutti i tuoi amici te lo invidieranno.",ep:13,g:687,l:1,wd:true,fm:true,w:10,p:1};
I.u[6621] = {n:"Peluche del Wabbit",t:61,d:"Il Wabbit di peluche resta un classico, forse perché non passa mai di moda. Mica come te.",ep:13,g:688,l:1,wd:true,fm:true,w:10,p:1};
I.u[6622] = {n:"Sonaglino del Dark Vlad",t:15,d:"Questo sonaglino è appartenuto al Dark Vlad in persona, il che gli dà un valore inestimabile, anche se si tratta di un sonaglino classicissimo.",ep:13,g:696,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6624] = {n:"Peluche del Drago Maiale",t:61,d:"Questo peluche è veramente unico nel suo genere. Ma attenzione: è destinato a un pubblico adulto!",ep:13,g:689,l:1,wd:true,fm:true,w:10,p:1};
I.u[6625] = {n:"Kendama di Messer Cuervoc",t:15,d:"Questo magnifico giocattolo è appartenuto a Messer Cuervoc in persona. Essendo troppo stupido per capirne il funzionamento, lo usava per darlo in testa ai suoi piccoli Cuervoc. A ognuno il suo svago...",ep:13,g:710,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6626] = {n:"Corda per Saltare del Capitano Chafer",t:15,d:"Per allenare le articolazioni, il Capitano Chafer usava questa famosa corda per saltare. Da quando è scomparso, quest\'oggetto passa di mano in mano.",ep:13,g:695,l:1,wd:true,fm:true,w:1,p:50};
I.u[6627] = {n:"Piccola Fata di Artificio Multicolore",t:74,d:"Questa Fata d\'artificio abbaglierà e stupirà i tuoi amici più esperti. È molto utile per festeggiare la partenza dalla tua gilda.",ep:1,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:350};
