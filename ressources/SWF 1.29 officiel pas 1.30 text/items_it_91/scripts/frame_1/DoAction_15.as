I.u[6642] = {n:"Potente Spada d\'Urandal",t:6,d:"Questa spada è un regalo onorifico che si dà solo ai mercenari esperti. Taglia molto bene.",ep:1,g:25,l:50,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[6643] = {n:"Gelato Booden",t:42,d:"Questo delizioso gelato è fabbricato artigianalmente dalla piccola fattoria Booden che cerca di imporre l\'uso dei Boo in tutti i dessert.",ep:13,g:143,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:150};
I.u[6644] = {n:"Cono Weale",t:42,d:"Questo gelato si ispira al famoso cappello del We per la sua parte superiore, il che crea un effetto molto riuscito.",ep:13,g:144,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:120};
I.u[6646] = {n:"Gelato Bontariano",t:42,d:"Questo gelato, pregiato abbinamento di due gusti alla frutta, mostra \"tutta la maestria degli angeli\"... o almeno, così dice la scatola.",ep:13,g:145,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:90};
I.u[6647] = {n:"Magma Brakmariano",t:42,d:"Questo gelato, che fonde il croccante con il morbido, mostra \"ancora una volta la superiorità di Brakmar\"... insomma, se si crede a quello che c\'è scritto sulla scatola.",ep:13,g:146,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:90};
I.u[6648] = {n:"Pallone rosso",t:15,d:"Questo pallone è un souvenir della Fiera del trool",ep:13,g:690,l:1,wd:true,fm:true,w:1,p:15};
I.u[6649] = {n:"Pallone blu",t:15,d:"Questo pallone è un souvenir della Fiera del trool",ep:13,g:691,l:1,wd:true,fm:true,w:1,p:15};
I.u[6650] = {n:"Pallone verde",t:15,d:"Questo pallone è un souvenir della Fiera del trool",ep:13,g:692,l:1,wd:true,fm:true,w:1,p:15};
I.u[6651] = {n:"Pallone giallo",t:15,d:"Questo pallone è un souvenir della Fiera del trool",ep:13,g:693,l:1,wd:true,fm:true,w:1,p:15};
I.u[6652] = {n:"Palla di neve fiera del Trool",t:15,d:"Questa bella palla di neve starà benissimo sulla mensola di un camino.",ep:13,g:694,l:1,wd:true,fm:true,w:1,p:15};
I.u[6653] = {n:"Biglietto della fiera del Trool",t:24,d:"Questo biglietto ti permette di entrare alla fiera.",ep:13,g:94,l:1,wd:true,fm:true,w:0,p:1};
I.u[6654] = {n:"Stivali del Guardiano delle Fogne",t:11,d:"Il colmo dell\'ironia: il Guardiano delle Fogne si è fatto divorare dalla Guardiana delle Fogne. È stato digerito per quasi cent\'anni prima di morire. Fortunatamente i suoi stivali erano più resistenti di lui e sono ancora in perfetto stato.",ep:16,g:28,l:83,wd:true,fm:true,w:10,p:17800};
I.u[6655] = {n:"Zaino Sorpresa del Fortunato",t:89,d:"Le persone che l\'hanno depositato nella tua banca sono veramente generose, e hanno voluto testimoniarti la loro amicizia. (DOPPIO CLIC PER APRIRE LO ZAINO)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6656] = {n:"Zaino Sorpresa del Fortunato",t:89,d:"Le persone che l\'hanno depositato nella tua banca sono veramente generose, e hanno voluto testimoniarti la loro amicizia. (DOPPIO CLIC PER APRIRE LO ZAINO)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6657] = {n:"",t:89,d:"ne pas traduire ce texte.",ep:1,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[6658] = {n:"Peluche del Buulupo",t:61,d:"Questo magnifico peluche, di vero pelo di Buulupo, ti terrà caldo durante la notte diffondendo in tutta la stanza un gradevole odore di sudore di Buulupo morto.",ep:13,g:699,l:1,wd:true,fm:true,w:10,p:1};
I.u[6659] = {n:"Falce Quaquà",t:15,d:"Non fidarti, questo Quaquà è un falso, dallo a Erone Pap vicino alla bancarella delle papere per ricevere una ricompensa.",ep:1,g:700,l:1,wd:true,fm:true,w:1,p:1};
I.u[6660] = {n:"Cappello dello Sposo",t:16,d:"Nessuna potrà dirti di no con un cappello così!\nA te la gloria e le conquiste!",ep:2,g:53,l:1,wd:true,fm:true,w:5,c:"PS=0",p:1000};
I.u[6661] = {n:"Canna da Quaquà",t:20,d:"Questa canna consente di pescare un Quaquà alla bancarella della fiera del Trool.",ep:13,g:8,l:1,wd:true,fm:true,w:10,an:18,e:[0,10,1,1,50,2,false,false],p:1};
I.u[6662] = {n:"Cappello della Sposa",t:16,d:"Fai fondere il tuo amato come una gelatina menta al sole con questo meraviglioso copricapo di seta di larva del sud. Lavabile in acqua dolce.",ep:2,g:54,l:1,wd:true,fm:true,w:5,c:"PS=1",p:1000};
I.u[6663] = {n:"Mazzo di Rose demoniache",t:6,d:"Con questo stupendo mazzo di rose demoniache mostrerai a chi ami che sei pronto/a ad affrontare 1000 pericoli per i suoi begli occhietti. E tutto ciò senza neanche un graffio e per una modica cifra.",ep:2,g:47,l:1,wd:false,fm:true,w:3,an:14,e:[1,4,1,1,50,50,false,true],p:70};
I.u[6664] = {n:"Pergamena di Incantesimo Speciale Felinizione",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permette di imparare l\'incantesimo Felinizione... Riservato solo agli Ecaflip.",ep:2,g:5,l:1,wd:true,fm:true,w:1,c:"PG=6",u:true,p:10000};
I.u[6666] = {n:"Lecca-Lecca Tofu",t:42,d:"Questo delizioso Lecca-Lecca è aromatizzato agli estratti di Tofu. Una leccornia per il tuo palato... ma una catastrofe per il tuo alito.",ep:13,g:147,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:30};
I.u[6667] = {n:"Lecca-lecca Trooll",t:42,d:"Un lecca-lecca che ha veramente un buon gusto e che, soprattutto, non finisce mai. Da mangiare preferibilmente tra amici.",ep:13,g:148,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6668] = {n:"Hot Dog di Tofu",t:42,d:"Questa salsiccia bella grassa ti permetterà di recuperare le forze... per poter digerire le altre salsicce che hai appena mangiato.",ep:13,g:150,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6669] = {n:"Hamburger di Trooll",t:42,d:"Questo impressionante hamburger potrebbe far risuscitare un esercito di Chafer affamati. Da consumare con moderazione, l\'abuso di Trooll è pericoloso per la salute.",ep:13,g:149,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:600};
I.u[6670] = {n:"Patatine di Girasole Selvatico",t:42,d:"Queste patatine sono tagliate nello stelo del Girasole Selvatico, poi sono cotte nell\'olio di Girasole Selvatico, giusto per farle sentire un po\' a loro agio mentre friggono.",ep:13,g:151,l:1,wd:false,fm:true,w:1,u:true,p:300};
I.u[6671] = {n:"Fagiolini",t:58,d:"...",ep:1,g:471,l:1,wd:true,fm:true,w:1,p:1};
I.u[6672] = {n:"Farina di Xavier il Panettiere",t:52,d:"Questa farina è di una leggerezza e di una finezza straordinarie ed è talmente dolce che è utilizzata per tenere il sedere dei giovani Yop all\'asciutto. È poi riutilizzata per dare ancora più gusto al pane.",ep:1,g:250,l:100,wd:true,fm:true,w:1,p:0};
I.u[6673] = {n:"Piuma di Tofu Nero",t:24,d:"Una piuma nera di Tofu Nero...",ep:1,g:96,l:1,wd:false,fm:true,w:0,p:1};
