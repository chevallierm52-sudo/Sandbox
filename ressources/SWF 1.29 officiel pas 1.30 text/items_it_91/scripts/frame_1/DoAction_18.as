I.u[8050] = {n:"Pelle di Koalak Immaturo",t:59,d:"Il piccolo Koalak Immaturo a cui hai strappato questa pelle non era molto d\'accordo, ma che importa, eri più forte e crudele di lui.",ep:20,g:3,l:1,wd:true,fm:true,w:1,p:10};
I.u[8051] = {n:"null",t:59,d:"",ep:0,g:4,l:1,wd:true,fm:true,w:1,p:10};
I.u[8052] = {n:"Pelle di Maestro Koalak",t:59,d:"Questa pelle vecchia e consumata ricopriva le chiappe del Maestro Koalak. Ha ancora qualche bella macchia rossa, segni evidenti di una vita agitata e un po\' folle.",ep:20,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[8053] = {n:"Pelle di Cavaliere Koalak",t:59,d:"Questa pelle strappata è stata usata contro quella della cavalcatura del Cavaliere Koalak. Evidentemente è un simbolo di qualità.",ep:20,g:6,l:1,wd:true,fm:true,w:1,p:10};
I.u[8054] = {n:"Pelle di Drakoalak",t:59,d:"Questa pelle dovrebbe ricordarti l\'odore delle stalle del castello di Amakna. Molto pratica per spaventare gli spiriti sensibili e ucciderli prima che decidano di accompagnarti in un dongione.",ep:20,g:7,l:1,wd:true,fm:true,w:1,p:10};
I.u[8055] = {n:"Osso di Mamy Koalak",t:47,d:"La Mamy Koalak ha ossa particolarmente resistenti che non cedono sotto il suo peso. Non si può certo dire la stessa cosa di Claudius Baglionus, il celebre menestrello, che perse l\'uso delle braccia facendosi schiacciare dalle cosce enormi della Mamy Koalak. Che brutta cosa la curiosità!",ep:20,g:638,l:1,wd:true,fm:true,w:1,p:10};
I.u[8056] = {n:"Femore di Koalak Selvaggio",t:47,d:"Una volta intagliato a forma di daga, quest\'osso può essere usato come una daga... o come uno schiacciabrufoli.",ep:20,g:639,l:1,wd:true,fm:true,w:1,p:10};
I.u[8057] = {n:"Tibia del Koalak Becchino",t:47,d:"Quest\'osso può essere usato come pala per dissotterrare i cadaveri e saccheggiarli, ovviamente se ti piace passare le vacanze vicino ai cimiteri. In via accessoria, serve da tibia al Koalak Becchino.",ep:20,g:640,l:1,wd:true,fm:true,w:1,p:10};
I.u[8058] = {n:"Cubito della Mummia Koalak",t:47,d:"Quest\'osso ha conservato tutto il suo splendore grazie alle numerose bende della Mummia Koalak che proteggono dagli attacchi magici più potenti.",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8059] = {n:"Peli di Koalak Griotta",t:54,d:"Questi peli sono ricoperti di polline di Blop, il che gli conferisce un gusto delizioso ma un odore orribile.",ep:20,g:660,l:1,wd:true,fm:true,w:1,p:10};
I.u[8060] = {n:"Peli di Koalak Cocco",t:54,d:"Questi peli sono ricoperti di polline di Blop, il che gli conferisce un gusto delizioso ma un odore orribile.",ep:20,g:662,l:1,wd:true,fm:true,w:1,p:10};
I.u[8061] = {n:"Peli di Koalak Reginetta",t:54,d:"Questi peli sono ricoperti di polline di Blop, il che gli conferisce un gusto delizioso ma un odore orribile.",ep:20,g:661,l:1,wd:true,fm:true,w:1,p:10};
I.u[8062] = {n:"Peli di Koalak Indaco",t:54,d:"Questi peli sono ricoperti di polline di Blop, il che gli conferisce un gusto delizioso ma un odore orribile.",ep:20,g:659,l:1,wd:true,fm:true,w:1,p:10};
I.u[8063] = {n:"Coda di Koalak Sanguigno",t:65,d:"Questa ridicola codina avrebbe potuto essere la tua, tanto sei insignificante. Eppure non la è, considerati fortunato.",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8064] = {n:"Boomerang del Koalak Sanguigno",t:15,d:"Questo pezzo di legno dalla strana forma ha viaggiato per molto tempo nell\'atmosfera e tra i ranghi nemici prima di spezzarsi. Si dice che ritorni sempre verso chi lo lancia, ma raramente tra le sue mani...",ep:20,g:721,l:1,wd:true,fm:true,w:1,p:10};
I.u[8065] = {n:"Peli di Barba del Warko Marrone",t:54,d:"Questi peli sono tanto urticanti da trasformare i baci del Warko Marrone in armi di distruzione di massa.",ep:20,g:657,l:1,wd:true,fm:true,w:1,p:10};
I.u[8066] = {n:"Peli di Barba del Warko Viola",t:54,d:"Questi peli di barba sono urticanti, tanto da fare di questa barba un\'arma ben più efficace del tuo alito di Bwork. Semplicemente spaventevole!",ep:20,g:658,l:1,wd:true,fm:true,w:1,p:10};
I.u[8067] = {n:"Stivali del Campione",t:11,d:"Alcuni avventurieri dicono che questi stivali permettono di camminare sulle trappole senza attivarle. Ma attento... potrebbe essere una trappola.",ep:1,g:72,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8068] = {n:"Mantello del Campione",t:17,d:"Questo splendido mantello dispone di spalline integrate che ti danno la prestanza fisica necessaria per assomigliare ad un campione.",ep:1,g:96,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8069] = {n:"Copricapo del Campione",t:16,d:"Questo imponente copricapo ti farà montare la testa, sempre che tu non te la sia già montata da solo.",ep:1,g:127,l:1,wd:false,fm:true,w:100,s:45,p:10};
I.u[8070] = {n:"Cintura del Campione",t:10,d:"Con questa cintura sui fianchi riuscirai a nascondere facilmente la parte di te che non ti soddisfa.",ep:1,g:88,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8071] = {n:"Mini Campione",t:18,d:"Questa piccola creatura segue solo i campioni, quindi un giorno o l\'altro potrebbe seguire anche te, per poi rendersi conto che sei un impostore. Da quel giorno sarai tu a seguirla come un piccolo famiglio.",ep:1,g:32,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:45,p:1};
I.u[8072] = {n:"Dofus Kalipto",t:23,d:"Nessuno conosce il drago che ha creato questo Dofus. Si sa solo che probabilmente aveva ingoiato una quantità incredibile di foglie di Kalipto, prima di deporlo e morire per una crisi di aerofagia.",ep:1,g:10,l:6,wd:false,fm:true,w:1,p:500000};
I.u[8073] = {n:"Chiave del Rifugio di Skunk",t:84,d:"Questa chiave ti è stata data da Rigrulak in cambio di una panoplia del Culosse. Con essa potrai entrare nel Rifugio di Skunk.",ep:13,g:11,l:1,wd:true,fm:true,w:1,p:100};
I.u[8075] = {n:"Boomerang del Dok Alako",t:15,d:"Questo pezzo di legno dalla strana forma ha viaggiato per molto tempo nell\'atmosfera e tra i ranghi nemici prima di spezzarsi. Si dice che ritorni sempre verso chi lo lancia, ma raramente tra le sue mani...",ep:20,g:722,l:1,wd:true,fm:true,w:1,p:10};
I.u[8076] = {n:"Boomerang del Maestro Koalak",t:15,d:"Questo pezzo di legno dalla strana forma ha viaggiato per molto tempo nell\'atmosfera e tra i ranghi nemici prima di spezzarsi. Si dice che ritorni sempre verso chi lo lancia, ma raramente tra le sue mani...",ep:20,g:723,l:1,wd:true,fm:true,w:1,p:10};
I.u[8077] = {n:"Boomerang del Warko Marrone",t:15,d:"Questo pezzo di legno dalla strana forma ha viaggiato per molto tempo nell\'atmosfera e tra i ranghi nemici prima di spezzarsi. Si dice che ritorni sempre verso chi lo lancia, ma raramente tra le sue mani...",ep:20,g:724,l:1,wd:true,fm:true,w:1,p:10};
I.u[8078] = {n:"Tavola di Legno di Kalipto",t:95,d:"Questa tavola consente ai Tuttofare di costruire degli oggetti di legno, come una bara per esempio...",ep:20,g:22,l:70,wd:true,fm:true,w:10,p:10};
I.u[8079] = {n:"Trasformazione Fantasma Piccolo Maomao Bianco",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8080] = {n:"Trasformazione Fantasma Piccolo Baubau Nero",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8081] = {n:"Sacco di Legno di Carpine",t:100,d:"Questo enorme sacco contiene una quantità impressionante di Legno di Carpine.",ep:1,g:55,l:1,wd:true,fm:true,w:250,u:true,p:100};
I.u[8082] = {n:"Stoffa del Fochalak",t:55,d:"Questa stoffa puzza a morte, mentre tu sai di morto. La differenza è notevole, no?",ep:20,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8083] = {n:"Osso di Pekuelak",t:47,d:"Quest\'osso è spugnoso e può galleggiare se il Pekualak cade in acqua cercando di tirare su una grossa preda.",ep:20,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[8084] = {n:"Pelle di Piralak",t:59,d:"Questa pelle ricoperta di sfregi è diventata più resistente della roccia, conservando comunque una notevole elasticità. È la pelle ideale per le fruste e i sandali di cattivo gusto.",ep:20,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[8085] = {n:"Peli di Koalak Forestiero",t:54,d:"Questi peli sono ricoperti di linfa di Kalipto, e per questo hanno un aspetto brillante e splendente. Sfortunatamente, non possono essere utilizzati nell\'alta moda a causa del loro odore di Dragacchino morto.",ep:20,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[8086] = {n:"Copricapo strappato di Drakoalak",t:15,d:"Questo strano copricapo nascondeva la calvizie precoce del Drakoalak. Con un po\' di impegno, forse riuscirà anche a nascondere la tua.",ep:20,g:725,l:1,wd:true,fm:true,w:1,p:100};
I.u[8087] = {n:"Incantesimo Padronanza dell\'Ascia",t:73,d:"(Doppio clic per imparare questo incantesimo)\nQuesta pergamena ti permetterà di fare più danni con un\'ascia.",ep:20,g:8,l:20,wd:false,fm:true,w:1,u:true,p:10000};
I.u[8088] = {n:"Bacchetta Gyver",t:3,d:"Questa bacchetta fatta di detriti racchiude in sé un\'energia sorprendente. Si racconta che sia capace di spostarsi da sola per scegliere il bersaglio e difendere il padrone anche quando quest\'ultimo sta agonizzando. A proposito di questa bacchetta il Chuko ha detto: \"Credo che la tua bacchetta sia aperta\". Povero Chuko.",ep:20,g:56,l:128,wd:true,fm:true,w:10,an:11,e:[5,5,2,5,40,50,false,true],c:"CI>250",p:41257};
I.u[8089] = {n:"Bacchetta Ioz",t:3,d:"Ioz era un pappagallo che ripeteva sempre tutto, si racconta che questa bacchetta sia stata intagliata col suo becco.",ep:20,g:57,l:138,wd:true,fm:true,w:20,an:11,tw:true,e:[5,4,3,4,40,50,false,true],c:"CI>150&CA>100&CC>100&CS>100",p:44125};
I.u[8090] = {n:"Bastone dei Caraibi",t:4,d:"Questo bastone ha già morso parecchia gente, o è stato morso da parecchia gente... non si capisce bene.",ep:20,g:64,l:114,wd:true,fm:true,w:10,an:12,tw:true,e:[5,5,1,1,35,50,false,true],c:"CI>200&CA>150",p:33520};
I.u[8091] = {n:"La Canna Birra",t:4,d:"Questo bastone viene dal sud e, in qualsiasi modo, ci torna.",ep:20,g:65,l:134,wd:true,fm:true,w:20,an:12,tw:true,e:[20,4,1,1,150,150,false,true],c:"CS>150&CA>150&CI>150",p:43550};
I.u[8092] = {n:"Le Daghe del Buwin",t:5,d:"Il buwin non è fine, il buwin non è furbo, il buwin qua, il buwin là... ma quando ha le sue daghe in mano nessuno prova a provocarlo.",ep:20,g:56,l:135,wd:true,fm:true,w:20,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CS>250&CA>100",p:43510};
I.u[8093] = {n:"Daghe Ristocratiche",t:5,d:"Portare queste daghe non ti renderà un eroe, ma se le sistemi nella tua biancheria intima, finirai per assomigliare ad un\'eroina.",ep:0,g:64,l:58,wd:true,fm:true,w:1,e:[-1,-1,1,1,-1,-1,false,false],p:4253};
I.u[8094] = {n:"La Spada Ridente",t:6,d:"Questa spada è la materializzazione del famoso proverbio Yop: \"Quando il nemico muore, la spada ride\".",ep:20,g:66,l:169,wd:true,fm:true,w:30,an:14,e:[10,5,1,1,50,50,false,true],c:"CS>450&CV>450",p:49010};
I.u[8095] = {n:"La Sciabola Ayassalam",t:6,d:"Questa spada fu forgiata con la sola preoccupazione dell\'estetica perché doveva servire ad ornare un camino di grande valore, ma la sua efficacia durante i combattimenti la fa usare regolarmente. La gente non ha proprio nessun rispetto per l\'arte.",ep:20,g:67,l:143,wd:true,fm:true,w:20,an:14,e:[15,4,1,1,80,50,false,true],c:"CI>300&CS>130&(PG=6|PG=8|PG=11)",p:44587};
I.u[8096] = {n:"Martello Kostner",t:7,d:"Il suo precedente proprietario danzava con in buulupi. È morto divorato.",ep:20,g:56,l:140,wd:true,fm:true,w:20,an:15,e:[5,5,1,1,30,45,false,true],c:"CI>250&CC>250",p:44541};
I.u[8097] = {n:"Martello Xiko",t:7,d:"Questo martello ti fa vedere la vita rose e fiori prima di ridurti la testa in poltiglia.",ep:20,g:57,l:129,wd:true,fm:true,w:30,an:15,e:[5,4,1,1,40,15,false,true],c:"CS>250&CI>150",p:42658};
I.u[8098] = {n:"Lama Usika",t:19,d:"Questa ascia dalla forma eccezionale dispone di una lama vibrante che permette di uccidere i nemici a ritmo di musica.",ep:0,g:38,l:1,wd:false,fm:true,w:1,an:17,e:[10,4,1,1,50,50,false,true],p:1};
I.u[8099] = {n:"La Ascia M\'bola",t:19,d:"Quest\'arma è stata immersa in una fontana di folgore pura, poi cosparsa di polvere di stelle... ma sembra che siano solo cavolate.",ep:20,g:39,l:116,wd:true,fm:true,w:10,an:17,tw:true,e:[7,5,1,1,35,50,false,false],c:"CA>120&CV>150",p:34562};
I.u[8100] = {n:"L\'Ascia Fischio",t:19,d:"Quest\'ascia è cosparsa di piccoli buchi un po\' dappertutto. In questo modo i suoi colpi sono sempre accompagnati da eleganti fischi che servono a coprire le grida di dolore dei nemici. È pericolosissima!",ep:20,g:40,l:112,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,40,50,false,false],c:"CS>150&CW>150",p:30300};
I.u[8101] = {n:"La Fenditrice",t:19,d:"Quest\'ascia fu forgiata da Bruce Bulgur mentre stava seduto in panetteria per far piacere al suo amico Xavier il Panettiere. Il problema è che inizialmente voleva fare una paletta per dolci.",ep:20,g:41,l:128,wd:true,fm:true,w:1,an:17,e:[5,4,1,1,20,30,false,false],c:"CI>230&CA>60&CV>250",p:444};
I.u[8102] = {n:"Pietra del Croccaroc Leggendario",t:51,d:"Si dice che questa pietra sia il cuore del Croccaroc Leggendario. Però a pensarci bene il Croccaroc non ha mai pesi sul cuore, e quindi questa pietra è di una leggerezza incredibile. È adatta per fabbricare oggetti per personaggi che danno la precedenza alla mobilità, all\'agilità e alla protezione. Veramente geniale.",ep:5,g:457,l:120,wd:true,fm:true,w:50,p:100};
I.u[8103] = {n:"Arco Ragno",t:2,d:"Quest\'arco è in realtà la capigliatura fossilizzata di un Sadida profondamente addormentato, sulla quale delle Arakni hanno tessuto la loro ragnatela.",ep:20,g:53,l:121,wd:true,fm:true,w:20,an:10,tw:true,e:[5,5,2,6,30,50,false,true],c:"CS>100&CA>100&CI>100&CC>100&CV>200",p:34857};
I.u[8104] = {n:"Arco Terion",t:2,d:"Quest\'arco, di un colore discutibile, è perfetto per mettersi in mostra allo Zaap di Bonta e in caso contrario per farti passare per un gallo... attirerà tutte le pollastrelle! A volte sbalorditivo e a volte revulsivo, ti aiuterà a sconfiggere tutti i tuoi nemici senza nemmeno scoccare una freccia.",ep:20,g:54,l:129,wd:true,fm:true,w:20,an:10,tw:true,e:[7,4,2,6,35,40,false,true],c:"CI>300&CV>300&CA>100",p:42510};
I.u[8105] = {n:"",t:74,d:"",ep:1,g:30,l:1,wd:false,fm:true,w:1,c:"(PX=3)|(PX=4)",ut:true,p:1};
I.u[8106] = {n:"Pozione d\'oblio di mestiere: Tuttofare",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Tuttofare.",ep:7,g:2,l:1,wd:false,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[8107] = {n:"Libro Onorifico dei Bardi",t:25,d:"Questo libro è stato solennemente consegnato a Nolius come premio per aver vinto il concorso di Bardaggine dell\'anno 636. Gloria al suo merito e al suo talento! Anche Hujikan, Du-Lor e Madahin sono presenti in questa raccolta. Lunga vita a loro e alla loro memoria.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8108] = {n:"Amuleto del Tofu",t:1,d:"Leggero come una piuma di Tofu, questo amuleto si porta al collo o... intorno alla fronte, per gli avventurieri più originali.",ep:3,g:95,l:22,wd:true,fm:true,w:5,s:50,p:1525};
I.u[8109] = {n:"Anello del Tofu",t:9,d:"Questo anello veramente insignificante e ridicolo può rivelarsi indispensabile. Infatti i tuoi nemici avranno talmente tanta pietà di te che ti daranno il colpo di grazia piuttosto che lasciarti soffrire atrocemente. Bisogna sempre trovare il lato buone delle cose...",ep:3,g:100,l:21,wd:true,fm:true,w:5,s:50,p:1350};
I.u[8110] = {n:"Bacchetta del Tofu",t:3,d:"Al contrario di ciò che si può pensare, questa bacchetta non è usata dai Tofu (che sono creature troppo stupide per saper maneggiare una tale arma), bensì contro i Tofu. Infatti, le piume di Tofu di cui è composta permettono ai Cacciatori di simulare la parata nuziale di queste creature. Ma fin dove sono disposti ad arrivare questi terribili Cacciatori per soddisfare i loro istinti assassini?",ep:3,g:58,l:25,wd:true,fm:true,w:10,an:11,e:[5,6,2,2,50,50,false,false],s:50,p:100};
I.u[8111] = {n:"Pantofole del Tofu",t:11,d:"Morbide e leggere, queste pantofole sono calde in inverno e fresche d\'estate. Sfortunatamente, non resistono ai lavaggi in lavatrice.",ep:3,g:73,l:23,wd:true,fm:true,w:10,s:50,p:1575};
I.u[8112] = {n:"Mantello del Tofu",t:17,d:"Questo strano mantello sembra essere stato tagliato in due. Ma perché sarebbe stato tagliato in due? Nessuno lo sa, anche se tutti hanno una un\'opinione sulla questione.",ep:3,g:97,l:26,wd:true,fm:true,w:10,s:50,p:2000};
I.u[8113] = {n:"Cintura del Tofu",t:10,d:"Questa cintura è ideale per strozzare i Tofu, ma permette anche ai Cacciatori di frustare gli avventurieri che si inoltrano nei boschi durante i periodi di caccia. È consigliabile non scherzare troppo con i Cacciatori, non si sa mai come potrebbero reagire.",ep:3,g:89,l:22,wd:true,fm:true,w:5,s:50,p:1553};
I.u[8114] = {n:"Kaskofu",t:16,d:"Questo casco da cantiere è diventato un oggetto di moda imperdibile per tutte le avventuriere civettuole. Ma dove si andrà a finire?",ep:3,g:128,l:23,wd:true,fm:true,w:5,s:50,p:1575};
I.u[8116] = {n:"Scaracapo Dorato",t:16,d:"Questo copricapo è perfetto per coprire la tua acne o il tuo viso d\'angelo.",ep:6,g:129,l:58,wd:true,fm:true,w:10,s:51,p:8900};
I.u[8117] = {n:"Scarantello Dorato",t:17,d:"Più dorato di uno Scarantello classico e meno nero di uno Scarantello Nero, questo mantello è perfetto per nascondere le tue escrescenze. Tempo fa lo Scaragobba Dorato lo usava per nascondere la gobba, mentre oggi è usato per nascondere i brutti sederi. Come immaginerai, questo mantello è veramente diffuso.",ep:6,g:98,l:58,wd:true,fm:true,w:10,s:51,p:8980};
I.u[8118] = {n:"Bacchetta dello Scaragobba Dorato",t:3,d:"Questa bacchetta magica è perfetta per togliere la polvere dai vecchi mobili... o dalle vecchie persone.",ep:6,g:59,l:59,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,60,false,false],s:51,p:9300};
I.u[8119] = {n:"Scarantura Dorata",t:10,d:"Se ti piace passeggiare nudo sulle spiagge dell\'isola di Moon, ti innamorerai subito di questa cintura...",ep:6,g:90,l:51,wd:true,fm:true,w:10,s:51,p:6825};
I.u[8120] = {n:"Amuleto dello Scaragobba Dorato",t:1,d:"Indossato su un corpo peloso, questo amuleto piacerà sicuramente per il grazioso abbinamento con i ciuffi di pelo.",ep:6,g:96,l:45,wd:true,fm:true,w:5,s:51,p:5375};
I.u[8121] = {n:"Anello dello Scaragobba Dorato",t:9,d:"Lo Scaragobba è una strana creatura. Gibboso e brutto dalla nascita, è lo zimbello degli altri Scarafoglie. Forse è per questo che ti piace tanto...",ep:6,g:101,l:43,wd:true,fm:true,w:5,s:51,p:5000};
I.u[8122] = {n:"Scarastivali Dorati",t:11,d:"Questi stivali uncinati permettono di scalare facilmente le scogliere più scoscese, o di lavorare i campi senza aratro.",ep:6,g:74,l:54,wd:true,fm:true,w:10,s:51,p:7725};
I.u[8123] = {n:"Amuleto Contadino",t:1,d:"Questo amuleto è aromatizzato all\'olio di Girasole Selvatico e alle erbe fini. Può quindi essere utilizzato come esca per i pericolosi ruminanti che vorresti predare, come i Pappatutto... o le suocere, per esempio.",ep:1,g:97,l:20,wd:true,fm:true,w:5,s:47,p:1255};
I.u[8124] = {n:"Cinturmuda del Contadino",t:10,d:"Questa cintura è veramente eccezionale perché vi è attaccato un bermuda di lino. È la cintura ideale per coloro che amano liberarsi rapidamente dei loro indumenti e passare all\'azione sul campo. Attenzione: questa cintura è vietata nelle piscine municipali.",ep:1,g:91,l:20,wd:true,fm:true,w:10,s:47,p:1300};
I.u[8125] = {n:"Cappello del Contadino",t:16,d:"Per proteggerti dal sole mentre lavori i campi non c\'è niente di meglio di un Plukos. Per proteggerti dal sole mentre lavori i campi, ma non hai il becco di un kama, non c\'è niente di meglio del famoso cappello del Contadino.",ep:1,g:130,l:19,wd:true,fm:true,w:10,s:47,p:1200};
I.u[8126] = {n:"Guanto Tarmato del Contadino",t:9,d:"Questi guanti tarmati sono veri e propri gioielli. Si racconta che siano ricoperti da una polvere di diamanti che gli conferisce una resistenza straordinaria. In più dispongono di un lato abrasivo, ideale per sfregare il didietro dei Pappatutto, o quello di tua moglie!",ep:1,g:102,l:12,wd:true,fm:true,w:5,s:47,p:600};
I.u[8127] = {n:"Falce consumata del Contadino",t:22,d:"Questa falce è robusta ma rovinata, e dopo aver falciato molto ora non falcia quasi per niente. Però, è molto efficace per strappare la carne tenera e superficiale. Molto utile per combattere contro le varici dei tuoi avversari.",ep:1,g:2,l:17,wd:true,fm:true,w:1,an:17,e:[5,3,1,1,50,50,false,false],s:47,p:950};
I.u[8128] = {n:"Stivali Contadini",t:11,d:"Questi stivali sono imbottiti con la paglia, il che permette di assorbire il sudore e coltivare funghi tossici in modo economico. Grazie alle loro suole morbide, gli Stivali Contadini sono raccomandati dagli arbitri di Pappaball.",ep:1,g:75,l:18,wd:true,fm:true,w:5,s:47,p:1100};
I.u[8129] = {n:"Abuulupulupeto",t:1,d:"Dietro questo stupido nome, si nasconde in realtà un amuleto molto potente, fabbricato con zanne, denti e ossa di Buulupo. Questo spiega anche il cattivo odore che emana. Se non potrai abbinarlo ai vestiti, potrai almeno abbinarlo al tuo alito.",ep:1,g:98,l:57,wd:true,fm:true,w:10,s:32,p:8550};
I.u[8130] = {n:"Ascia del Buulupo",t:19,d:"Questa terribile ascia ha decapitato più di un avventuriero imprudente, eppure taglia abbastanza male. A volte infatti ci vogliono una decina di tentativi prima di tagliare un collo un po\' resistente.",ep:1,g:42,l:55,wd:true,fm:true,w:10,an:17,tw:true,e:[5,6,1,1,50,50,false,false],s:32,p:8125};
I.u[8131] = {n:"Zaino del Contadino",t:81,d:"Questo zaino va molto di moda tra i giovani scolari ed è l\'ideale per portare farine animali e vegetali. Una volta aperto, strappato lungo le cuciture e ben stirato, potrà servire come gonna... sempre che tu non abbia paura di mettere in mostra le tue cosce pelose.",ep:1,g:3,l:19,wd:true,fm:true,w:1,s:47,p:1153};
I.u[8132] = {n:"Scarantura Nera",t:10,d:"Questa cintura non ha assolutamente niente di originale. Sembra comunque essere abbinata alla tua capigliatura.",ep:6,g:93,l:43,wd:true,fm:true,w:10,s:49,p:4955};
I.u[8133] = {n:"Scaracapo Nero",t:16,d:"Questo copricapo è ideale per coloro che vogliono avere idee oscure.",ep:6,g:132,l:53,wd:true,fm:true,w:10,s:49,p:7350};
I.u[8134] = {n:"Scarantello Nero",t:17,d:"Se ti piace spaventare le Arakne ma non hai i soldi per comprarti un Cuervontello Mastralis, questo mantello fa per te.",ep:6,g:100,l:53,wd:true,fm:true,w:10,s:49,p:7575};
I.u[8135] = {n:"Chiave del Dongione dei Bwork",t:84,d:"Questa sorprendente chiave ti permetterà di entrare nel dongione dei Bwork, ma non di uscirne vivo.",ep:1,g:234,l:1,wd:true,fm:true,w:1,p:100};
I.u[8136] = {n:"Scaranello Nero",t:9,d:"Questo magnifico anello può essere portato all\'alluce. È ideale per nascondere le verruche o le unghie incarnite.",ep:6,g:104,l:48,wd:true,fm:true,w:10,s:49,p:6200};
I.u[8137] = {n:"Viscere dello Scaragobba Dorato",t:15,d:"Queste viscere sono in parte responsabili dei problemi di digestione dello Scaragobba Dorato, puoi quindi farle friggere senza rimorsi.",ep:6,g:726,l:70,wd:true,fm:true,w:5,p:100};
I.u[8138] = {n:"Carapace di Scarafoglie Nero",t:107,d:"Se lo si gira al contrario, questo carapace diventa un eccellente portacenere.",ep:6,g:727,l:40,wd:true,fm:true,w:5,p:100};
I.u[8139] = {n:"Chiave del Dongione degli Scarafoglie",t:84,d:"Questa magnifica chiave dorata ti permetterà di entrare nel dongione degli Scarafoglie. Ne vedrai delle belle!",ep:1,g:233,l:1,wd:true,fm:true,w:1,p:100};
I.u[8140] = {n:"Antenne dello Scarafoglie Nero",t:15,d:"Lo Scarafoglie nero non ha mai capito a cosa servissero le sue antenne. La natura a volte è proprio fatta male.",ep:6,g:728,l:40,wd:true,fm:true,w:1,p:100};
I.u[8141] = {n:"Ali di Scarafoglie Nero",t:104,d:"Contrariamente a ciò che si potrebbe immaginare, le ali di Scarafoglie Nero non sono nere, ma bianche. Ancora un mistero della natura che alimenta gli infervorati dibattiti della taverna.",ep:6,g:729,l:40,wd:true,fm:true,w:1,p:100};
I.u[8142] = {n:"Chiave Segreta del Tofullaio Reale",t:84,d:"Questa chiave ti dà accesso al Tofullaio Reale. Ti aspettano botte da orbi!",ep:3,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[8143] = {n:"Chiave dei Campi",t:84,d:"Queta chiave non ti permetterà di evadere dal Dongione dei Campi, ma piuttosto di chiudertici dentro.",ep:1,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8144] = {n:"Mocio del Muulupo",t:15,d:"Questa fialetta contiene tutta la potenza virile del Muulupo. Attenzione: il suo contenuto non è commestibile.",ep:2,g:730,l:1,wd:true,fm:true,w:1,p:1};
I.u[8145] = {n:"Birra Bwork",t:37,d:"La Birra Bwork fa ubriacare un Feca a 12 passi di distanza. Non si sa bene se sia fatta dai Bwork, con i Bwork, o tutt\'e due.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8146] = {n:"Stivali del Croccaroc Leggendario",t:11,d:"Se ti piace ballare e pestare i piedi al tuo partner, questi stivali fanno proprio al caso tuo.",ep:5,g:77,l:86,wd:true,fm:true,w:10,s:52,p:19150};
I.u[8147] = {n:"Elmo del Croccaroc Leggendario",t:16,d:"Versione migliorata dell\'elmo del Croccaroc che protegge ancora meglio dalla caduta di pietre, ma non dalla caduta di capelli.",ep:5,g:133,l:80,wd:true,fm:true,w:10,s:52,p:16530};
I.u[8148] = {n:"Martello del Croccaroc Leggendario",t:7,d:"Questo enorme martello non è altro che una spada del Croccaroc munita di una pietra del Croccaroc Leggendario. Questa sorprendente creazione sorprenderà veramente i tuoi nemici, sì... subito prima di schiacciarli.",ep:5,g:58,l:81,wd:true,fm:true,w:10,an:15,e:[7,5,1,1,40,50,false,false],c:"CA>100&CI>50",s:52,p:16850};
I.u[8149] = {n:"Croccanello Leggendario",t:9,d:"Questa roccia adornata con pietre preziose è l\'ideale per mettere un marchio definitivo sulle tempie o la fronte dei tuoi avversari.",ep:18,g:105,l:80,wd:true,fm:true,w:10,s:52,p:16775};
I.u[8150] = {n:"Amuleto del Croccaroc Leggendario",t:1,d:"Questo amuleto, di modeste fattezze, racchiude molti segreti tra cui il segreto che precisa quali segreti racchiude.",ep:5,g:99,l:84,wd:true,fm:true,w:10,s:52,p:18350};
I.u[8151] = {n:"Palladineve",t:18,d:"Questo piccolo mostro ti seguirà dappertutto nutrendosi dei resti dei suoi simili. A volte terrificante, spesso divertente, allieterà la tua vita, prima di prendertela definitivamente.",ep:3,g:35,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8152] = {n:"Cintura del Croccaroc Leggendario",t:10,d:"Il Croccaroc Leggendario porta questa cintura attorno alle dita dei piedi. Tu la porti attorno alla vita, o forse alle caviglie...",ep:5,g:94,l:80,wd:true,fm:true,w:10,s:52,p:16506};
I.u[8153] = {n:"Arbre Magic",t:18,d:"Questo giovane Alberagno non poteva più sopportare la sua famiglia e, proprio come te, decise di ribellarsi. Oggi verrà con te per contare quanti dei suoi parenti stretti puoi sterminare.",ep:3,g:34,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8154] = {n:"El Scarador",t:18,d:"Questo piccolo grazioso coleottero venuto dal sud è molto pericoloso. Umiliato dai suoi amici quando era giovane, ha deciso di vendicarsi e ti aiuterà a prendere a calci tutti gli Scarafoglie che incontrerai.",ep:3,g:36,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8155] = {n:"Tifux",t:18,d:"Questa splendida creatura è un lontano parente dei famosi Volpi dell\'isola dei Wabbit. Più temerario ma anche più indisciplinato, saprà aiutarti durante i tuoi combattimenti, e ti aiuterà anche un po\' subdolamente a combattere i membri della sua stessa famiglia.",ep:3,g:37,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8156] = {n:"Chiave del Dongione dei Canidei",t:84,d:"Questa chiave ti permetterà di entrare nel terribile dongione dei Canidei, e allo stesso tempo ti farà sbudellare dalle risate.",ep:1,g:235,l:1,wd:true,fm:true,w:1,p:1};
I.u[8157] = {n:"Petalo Magico del Girasole Affamato",t:35,d:"Come tutti gli oggetti magici, questo petalo è impressionante ed emana un\'aura di potenza proporzionale alla credulità degli avventurieri che lo osservano.",ep:1,g:2,l:20,wd:true,fm:true,w:1,p:100};
I.u[8158] = {n:"Piuma Grassosa del Tofu Panzeton",t:53,d:"Il Tofu Panzeton si cosparge regolarmente di grasso per evitare che gli si stacchino le piume. Una tecnica vecchia come il mondo, che permette anche a qualche Anutrof di conservare i capelli... persino dopo la pubertà.",ep:3,g:1,l:50,wd:true,fm:true,w:1,p:10};
I.u[8159] = {n:"Carapace dello Scaragobba Dorato",t:107,d:"Se lo porti sulla testa, questo carapace ti difenderà dalle intemperie e dalle cadute di guano.",ep:6,g:731,l:70,wd:true,fm:true,w:5,p:100};
I.u[8160] = {n:"Antenne dello Scaragobba Dorato",t:15,d:"Se vuoi assomigliare a Korgamon il Capon dei Karpaton, è molto semplice, ficcati queste antenne nel naso e canta per la campagna sculettando un po\'.",ep:6,g:732,l:70,wd:true,fm:true,w:1,p:100};
I.u[8161] = {n:"Ali dello Scaragobba Dorato",t:104,d:"Se hai sempre sognato di volare come un Pìu adiposo, attacca queste ali alla cintura e lanciati dalla torre degli ordini di Brakmar. Con un po\' di fortuna assomiglierai a un Cuervoc schiacciato! Offrirai così una bella risata ai Brakmariani e un eccellente pasto agli altri Cuervoc.",ep:6,g:733,l:70,wd:true,fm:true,w:1,p:100};
I.u[8162] = {n:"Testa di Cucuwbita",t:16,d:"Sembri ancora più stupido del solito con questa Cucuwbita magica sulla testa, ma ricordati della maledizione di Hallouin che trasforma certe creature in strane bestie difformi...\nSi dice che solo questo copricapo riesca a proteggere da una tale maledizione.",ep:1,g:134,l:1,wd:true,fm:true,w:1,p:1};
I.u[8163] = {n:"Kabuto",t:16,d:"Portato un tempo dalle forze dell\'ordine delle più grandi città, questo elmo è oggi utilizzato per spaventare i rivoltosi che cercano di saperne troppo su chi gestisce il Mondo.",ep:20,g:135,l:101,wd:true,fm:true,w:10,p:26000};
I.u[8164] = {n:"Regalo Palladineve",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8165] = {n:"Regalo Arbre Magic",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8166] = {n:"Regalo El Scarador",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8167] = {n:"Regalo Tifux",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8168] = {n:"Regalo di Halluin",t:89,d:"Hallouin era veramente il più grande coltivatore di Cucuwbite di tutto il continente. Sfortunatamente, era anche l\'apprendista di un Bwork Mago che amava un po\' troppo l\'arcano. Per vincere il concorso della più grossa Cucuwbita coltivata con letame di Porkass, Hallouin imbrogliò facendo appello al Bwork Mago che tentò una stregoneria inedita sulle Cucuwbite. Coloro che assaggiarono queste Cucuwbite magiche si trasformarono in strane e difformi creature per molti giorni, e ogni anno nello stesso periodo. Sembra che questa maledizione si trasmetta a volte agli avventurieri che si avvicinano troppo alle creature maledette. Per scongiurare la sorte, gli abitanti di Amakna e dei dintorni si mettono una Cucuwbita sulla testa per molti giorni, sperando che possa salvarli. La cosa più sorprendente è che sembra funzionare.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[8169] = {n:"Trasformazione Pappatutto di Hallouin",t:27,d:"Sei stato trasformato in Pappatutto di Hallouin. Devi combattere e vincere con un avventuriero per sbarazzarti di questa terribile maledizione.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8170] = {n:"Trasformazione Tofu di Hallouin",t:27,d:"Sei stato trasformato in Tofu di Hallouin. Devi combattere e vincere con un avventuriero per sbarazzarti di questa terribile maledizione.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8171] = {n:"Fantasma di Arbre Magic",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:34,l:1,wd:true,fm:true,w:1,p:1};
