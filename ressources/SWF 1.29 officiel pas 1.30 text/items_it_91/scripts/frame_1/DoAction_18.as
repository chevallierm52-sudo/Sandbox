I.u[7805] = {n:"I Dragacchini: come allevarli",t:25,d:"Questo imponente libro ti spiegherà come catturare, allevare e cavalcare dei Dragacchini. È stato scritto da Oshar Marif in persona. Una garanzia di qualità.",ep:16,g:19,l:1,wd:false,fm:true,w:1,u:true,p:500};
I.u[7806] = {n:"Certificato di Cavalcatura",t:97,d:"Questo certificato ti permette di andare a riprendere la tua cavalcatura in una stalla.\nAttenzione, questo certificato è valido solo per 20 giorni, trascorso questo termine la tua cavalcatura sarà rilasciata allo stato brado e il tuo certificato non sarà più valido, quindi la perderai. Ricordati di lasciare la tua cavalcatura in una stalla se devi assentarti per molto tempo.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
