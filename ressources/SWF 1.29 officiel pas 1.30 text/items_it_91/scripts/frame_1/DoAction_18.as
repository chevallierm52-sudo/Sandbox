I.u[7879] = {n:"L\'avvento di Hyrkul",t:25,d:"Gli Annali Colossali, Immorali e non Banali di Domen fanno venire la pelle d\'oca. Da leggere rispettando le dosi prescritte. Effetto secondario: sudori freddi e incontinenza notturna.",ep:16,g:19,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[7880] = {n:"Amuleto del Pappacool",t:1,d:"Tempo addietro questo amuleto era indossato da tutti gli avventurieri che preferivano fare l\'amore piuttosto che la guerra. Ognuno ha i suoi gusti...",ep:20,g:93,l:20,wd:true,fm:true,w:5,s:43,p:1300};
I.u[7881] = {n:"Anello del Pappacool",t:9,d:"Questo anello ti permetterà di fare ancora più male ai tuoi bambini, quando gli darai delle sculacciate ben meritate.",ep:20,g:98,l:38,wd:true,fm:true,w:5,s:43,p:4000};
I.u[7882] = {n:"Martello del Pappacool",t:7,d:"Questo martello è ideale per imprimere le tue idee pacifiste sulla fronte degli avversari.",ep:20,g:54,l:41,wd:true,fm:true,w:10,an:15,e:[5,5,1,1,40,40,false,false],s:43,p:4520};
I.u[7883] = {n:"Stivali del Pappacool",t:11,d:"Questi stivali, imbottiti con lana di Pappacool, non possono non piacere. Sono leggeri, caldi durante la stagione fredda e freschi durante la stagione calda. Sapranno soddisfare anche gli avventurieri più difficili.",ep:20,g:66,l:38,wd:true,fm:true,w:15,s:43,p:3925};
I.u[7884] = {n:"Mantello del Pappacool",t:17,d:"Se ti piace prendere la vita col sorriso, questo mantello è fatto per te! Infatti è così spesso e comodo che può essere usato come letto d\'emergenza quando sei troppo stanco. Il suo odore di Kalipto affumicato gli permette di respingere gli insetti, le creature indesiderate e anche le suocere.",ep:20,g:93,l:55,wd:true,fm:true,w:15,s:43,p:8030};
I.u[7885] = {n:"Cintura del Pappacool",t:10,d:"Portata attorno alle anche questa cintura ti permetterà di farti passare per un avventuriero pacifista e, ancora meglio, di sorprendere i tuoi nemici infilandogli la spada nella schiena.",ep:20,g:84,l:37,wd:true,fm:true,w:10,s:43,p:3800};
I.u[7886] = {n:"Copricapo del Pappacool",t:16,d:"Con questo copricapo sulla testa, non avrai certo l\'aria più astuta di prima, questo è sicuro! In compenso avrai l\'aria più \"cool\", e alla fine non c\'è altro che conti.",ep:20,g:119,l:47,wd:true,fm:true,w:15,s:43,p:6000};
I.u[7887] = {n:"Copricapo del Culosse",t:16,d:"Questo copricapo è appartenuto al celebre Culosse, famoso per i piedi di argilla e il suo buon umore leggendario.",ep:20,g:122,l:82,wd:true,fm:true,w:10,s:44,p:18375};
I.u[7888] = {n:"Zaino del Culosse",t:81,d:"Questo zaino permette al Culosse di conservare al fresco le sue foglie di Kalipto o di soffocare i Koalak un po\' troppo intraprendenti.",ep:20,g:2,l:69,wd:false,fm:true,w:10,s:44,p:12278};
I.u[7889] = {n:"Stivali del Culosse",t:11,d:"Basta sentire l\'odore di questi stivali per sapere che sono appartenuti al Culosse. Sono così comodi che ti faranno quasi dimenticare la tua miserabile vita.",ep:20,g:69,l:73,wd:true,fm:true,w:10,s:44,p:13775};
I.u[7890] = {n:"Bastone del Culosse",t:4,d:"Questo bastone in realtà è l\'osso vuoto di un antenato del Culosse. Bucato alle due estremità, può servire come pipa da Kalipto, ma anche da bastone per pastore. Niente ferma il progresso!",ep:20,g:62,l:75,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,20,50,false,false],s:44,p:14675};
I.u[7891] = {n:"Mini We",t:18,d:"Questo piccolo Wabbit è in realtà il figlio nascosto del tristemente famoso We Wabbit. Forse un giorno salirà anche lui sul trono.",ep:3,g:28,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7892] = {n:"Willy il Rompi",t:18,d:"Willy il Rompi è veramente una creatura cattiva, forse perché ha avuto un\'infanzia particolarmente difficile. Ti seguirà ovunque e farà fuggire i tuoi amici.",ep:3,g:29,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7893] = {n:"Fantasma di Mini Wa",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:18,l:1,wd:true,fm:true,w:1,p:1};
I.u[7894] = {n:"Fantasma di Willy il Rompi",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:17,l:1,wd:true,fm:true,w:1,p:1};
I.u[7895] = {n:"Certificato di Deposito al Cianil: Mini We",t:77,d:"Questo Certificato descrive le caratteristiche del Mini We che hai lasciato al Cianil.",ep:3,g:34,l:1,wd:false,fm:true,w:1,p:100};
I.u[7896] = {n:"Certificato di Deposito al Cianil: Willy il Rompi",t:77,d:"Questo Certificato descrive le caratteristiche del Willy il Rompi che hai lasciato al Cianil.",ep:3,g:29,l:1,wd:false,fm:true,w:1,p:100};
I.u[7897] = {n:"Regalo Mini We",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.\n(ATTENZIONE, questo regalo contiene oggetti molto pesanti, rischi di sovraccaricarti al momento dell\'apertura. Sbarazzati dei tuoi oggetti pesanti o fatti aiutare da un amico).",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7898] = {n:"Regalo Willy il Rompi",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.\n(ATTENZIONE, questo regalo contiene oggetti molto pesanti, rischi di sovraccaricarti al momento dell\'apertura. Sbarazzati dei tuoi oggetti pesanti o fatti aiutare da un amico).",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7899] = {n:"Il Mini Wa: Come allevarlo",t:25,d:"Questo libro scritto da Oshimo Li \'Kross Baffine spiega come allevare un Mini Wa.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7900] = {n:"Willy il Rompi: Come allevarlo",t:25,d:"Questo libro scritto da Oshimo Li \'Kross Baffine spiega come allevare un Willy il Rompi.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7902] = {n:"Cintura di una Donna d\'Oro",t:10,d:"Una vecchia leggenda del famoso libro \"Tutta la verità sulle donne\", racconta che questa cintura è appartenuta a una donna d\'oro, più interessata alla ricchezza che al potere. Nella versione non censurata del libro, si dice anche che questa donna fosse un\'appassionata di scherzi un po\' maliziosi. Alla fine non era poi così diversa dalle altre donne...",ep:2,g:86,l:71,wd:true,fm:true,w:5,p:13300};
I.u[7903] = {n:"Foglia di Kalipto",t:36,d:"Se la inserisci con delicatezza nelle narici, la foglia di Kalipto ti libererà il naso. Alcune leggende tribali raccontano che questa tecnica funziona anche con altri orifizi.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7904] = {n:"Fiore di Kalipto",t:35,d:"Una volta bruciato, questo fiore sprigiona uno spesso fumo dalle virtù allucinogene. Se masticato, invece, tende a rendere impotenti. Consumato in infusione può provocare grossi effetti lassativi. La miglior soluzione resta quella di non toccarlo neanche.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7905] = {n:"Lana di Pappacool",t:57,d:"Questa lana assomiglia tantissimo alla lana di Pappatutto eppure è diversissima. Infatti questa non puzza per niente.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7906] = {n:"Corno di Pappacool",t:47,d:"Una vecchia leggenda narra che la polvere estratta da questi corni ha virtù afrodisiache, inoltre precisa che ha degli effetti secondari sorprendenti. Una ragione in più per provarla.",ep:20,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[7907] = {n:"Cuoio del Pappacool",t:56,d:"Questo cuoio multicolore permette di fabbricare della biancheria in cuoio multicolore, il che renderà gelosi i più vissuti Chafer.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7908] = {n:"Chiave del Dongione del Culosse",t:84,d:"Questa chiave d\'osso ti permetterà di accedere al dongione del Culosse senza esservi stato invitato.",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[7911] = {n:"Koalak Sanguigno",t:18,d:"Questo piccolo Koalak ha l\'aria inoffensiva, ma in realtà non lo è per niente. Martirizzato fin dalla sua più tenera infanzia con un mucchio di colpi di boomerang sui denti e sul sedere, fomenta da allora un\'avversione totale per i boomerang e li divora senza neanche masticarli.",ep:3,g:30,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:46,p:1};
I.u[7913] = {n:"Il Divisore (MJ)",t:9,d:"Questo oggetto misterioso e dimenticato da tutti apparteneva a un grande mago... pare conferisse la capacità di parlare con certi animali...",ep:1,g:22,l:1,wd:false,fm:true,w:1,p:1};
I.u[7917] = {n:"Regalo di Compensazione",t:89,d:"Per scusarsi dei recenti problemi che hai incontrato, l\'équipe Ankama ti offre questo pacco regalo che comprende:\n- 5 Caramelle di Compensazione del Saggio\n- 5 Caramelle di Compensazione del Fortunato\n- 10 Caramelle di Compensazione Energetica\n- 10 Polveri di Aniripsa",ep:1,g:32,l:1,wd:true,fm:true,w:1,c:"PO!7801&PO!7800",u:true,p:1};
I.u[7918] = {n:"Chiave del Dongione dei Tofu",t:84,d:"Questa chiave fabbricata con una piuma di Tofu, ha la capacità di fare il solletico all\'interno di alcune serrature...\nTi permetterà inoltre di accedere al Tufollaio di Farle Ingals.",ep:1,g:6,l:1,wd:true,fm:true,w:1,p:100};
I.u[7919] = {n:"Gettone del Maestro di Gioco",t:15,d:"Dovresti poter scambiare questo splendido gettone con i preziosi regali della Fiera del Trool.",ep:1,g:737,l:1,wd:true,fm:true,w:1,p:100};
I.u[7920] = {n:"Bacchetta del Torneo (MJ)",t:3,d:"Questa modesta bacchetta permette ai Game Masters di teletrasportare degli avventurieri in una zona riservata ai tornei.",ep:1,g:8,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],u:true,p:100};
I.u[7921] = {n:"Corona del Tofu Reale",t:16,d:"Questa corona è abbastanza difficile da acchiappare perché scivola tra le dita. Non c\'è dubbio, è proprio la Corona del Tofu Reale. Inoltre non sembra proprio andare bene con la tua testolina, per non parlare di quella di uno Yop!",ep:13,g:154,l:128,wd:true,fm:true,w:10,p:42625};
I.u[7922] = {n:"Peluche del Dabol Sàcrido",t:61,d:"Questo peluche è fatto per i giovani Sàcridi, è perfetto per assorbire il loro sangue e lo si può pulire facilmente a qualsiasi temperatura.",ep:0,g:1,l:1,wd:true,fm:true,w:10,p:1};
I.u[7923] = {n:"Peluche del Dabol Pandawa",t:61,d:"Questo peluche sa di alcool e di pelo di Pandawa bagnato, proprio come mamma!",ep:1,g:2,l:1,wd:true,fm:true,w:10,p:1};
I.u[7924] = {n:"Chiave del Labirinto del Minotoror",t:84,d:"Questa magnifica chiave ti permetterà di entrare nel Labirinto del Minotoror, ma non di uscirne...",ep:13,g:7,l:1,wd:true,fm:true,w:1,p:100};
I.u[7925] = {n:"Legno di Kalipto",t:38,d:"Questo legno profumato permette di costruire delle case che sanno di buono, anche se i proprietari puzzano. Sfortunatamente questo legno non è abbastanza morbido per fabbricare biancheria intima.",ep:20,g:1,l:50,wd:true,fm:true,w:2,p:0};
I.u[7926] = {n:"Chiave del Dongione di Messer Cuervoc",t:84,d:"Questa chiave ti permetterà di incontrare Messer Cuervoc in persona, che ti inviterà sicuramente a mangiare un pezzetto di formaggio con lui.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[7927] = {n:"Chiave del Dongione dei Croccaroc",t:84,d:"Questa chiave indistruttibile ma molto logora ha aperto numerose porte. Dicono sia stata fabbricata con le parti intime di un Croccaroc. Semplicemente terribile!",ep:1,g:9,l:1,wd:true,fm:true,w:1,p:100};
I.u[7928] = {n:"",t:84,d:"",ep:1,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[7929] = {n:"Manuale del Mercenario di Astrub",t:25,d:"Il Manuale del Mercenario di Astrub, scritto dal famoso Bassofronte, capo mercenario di Astrub, è il libro di tutti coloro che rispettano la legge... o la infrangono.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7930] = {n:"Come farsi degli Amici e conservarli",t:25,d:"Consigli e astuzie per farsi dei buoni e leali amici, scritto da Acidrik Stracciapanza.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7931] = {n:"Il Tempo dei Draghi - Frammenti Ritrovati III",t:25,d:"Tomo III dei Frammenti della Storia del Mondo, ritrovati dall\'erudito Acidrik Stracciapanza, e da lui riscritti.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:50};
I.u[7932] = {n:"Pergamena Miss Astrub",t:25,d:"La prosperosa Miss Astrub di quest\'anno ci svela come ha sedotto la giuria.",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[7933] = {n:"null",t:25,d:"",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:69};
I.u[7934] = {n:"Come Viaggiare senza perdere di vista il Nord",t:25,d:"Arpagnagrobis ha scritto quest\'opera per tutti quegli avventurieri che non sanno usare né la bussola né gli zaap.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7935] = {n:"Spilla Zaffiro",t:24,d:"Questo gioiello è rimasto attaccato per mesi ad una spessa capigliatura. Un\'incisione spiega che, se riunito ad altre spille, può diventare una chiave.",ep:20,g:109,l:1,wd:true,fm:true,w:0,p:100};
