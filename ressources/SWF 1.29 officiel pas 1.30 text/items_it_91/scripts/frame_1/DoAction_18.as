I.u[8016] = {n:"Fantasma di Koalak Sanguigno",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:43,l:1,wd:true,fm:true,w:1,p:1};
