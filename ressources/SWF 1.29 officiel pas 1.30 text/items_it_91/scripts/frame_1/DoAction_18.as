I.u[7997] = {n:"null",t:6,d:"",ep:0,g:65,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],p:1};
I.u[7998] = {n:"null",t:16,d:"",ep:0,g:126,l:1,wd:false,fm:true,w:1,p:1};
I.u[7999] = {n:"Mantellananas",t:17,d:"Alcuni avventurieri raccontano che questo mantello è rugoso come la pelle di un Coccodrail, mentre altri dicono che è ancora più rugoso della pelle del sedere di una femmina di Bwork. Comunque sia, fai attenzione a metterlo nel verso giusto... se non vuoi avere anche te il sedere rugoso.",ep:1,g:94,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8000] = {n:"Bworky",t:18,d:"Questa piccola creatura non è altro che un Bwork rimasto intrappolato vivo in un boccale per molti decenni. Per questo ha la forma di un boccale e resterà nano tutta la vita. Il suo buon umore e il suo leggendario senso dell\'umorismo ne fanno il compagno ideale per affrontare dongioni impossibili o serate mondane indiavolate. Stai attento, è goloso di aperitivi, e mangia solo noci e noccioline, anche se ogni tanto manda giù anche una ghianda.",ep:3,g:31,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8001] = {n:"Benda del Guerriero Koalak",t:15,d:"Questa benda, di solito arrotolata sulle braccia del Guerriero Koalak, gli permette di soffiarsi il naso senza usare fazzoletti. Quando diventa un po\' vecchia e usata può essere attaccata al soffitto per eliminare i Moskito di passaggio nelle case.",ep:20,g:719,l:70,wd:true,fm:true,w:5,p:100};
I.u[8002] = {n:"Stoffa di Dok Alako",t:55,d:"Questa stoffa sembra essere impregnata di una magia ancestrale difficilmente prevedibile e controllabile. Ancora un punto in comune con la tua amata.",ep:20,g:720,l:40,wd:true,fm:true,w:5,p:1};
I.u[8003] = {n:"Amuleto del Koalak",t:1,d:"Questo amuleto non assomiglia a nessun altro amuleto, semplicemente perché nessun altro amuleto gli assomiglia.",ep:20,g:94,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8004] = {n:"Anello del Koalak",t:9,d:"Questo magnifico anello è indossato dai Koalak più temerari, quelli che sono stati così coraggiosi da rubarlo agli avventurieri di Astrub all\'uscita della banca.",ep:20,g:99,l:53,wd:true,fm:true,w:10,s:46,p:7375};
I.u[8005] = {n:"Arco del Koalak",t:2,d:"Questo sorprendente arco permette di rubare la vita dei tuoi avversari, e a volte persino di rubare i tuoi avversari alla vita, il che non significa niente in sé, ma sembra comunque molto impressionante.",ep:20,g:52,l:61,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,4,50,50,false,true],s:46,p:9775};
I.u[8006] = {n:"Stivali del Koalak",t:11,d:"Questi stivali sono in realtà dei piedi di Koalak selvaggiamente strappati al loro proprietario, svuotati e poi imbottiti con i peli del Koalak. Tanto terrificanti quanto affascinanti questi stivali faranno di te il terrore di Astrub.",ep:20,g:71,l:60,wd:true,fm:true,w:10,s:46,p:9600};
I.u[8007] = {n:"Mantello del Koalak",t:17,d:"Questo mantello ti proteggerà da quasi tutti gli attacchi, ma non dal ridicolo.",ep:20,g:95,l:61,wd:true,fm:true,w:10,s:46,p:9675};
I.u[8008] = {n:"Cintura del Koalak",t:10,d:"Questa cintura di foglie di Kalipto diffonde un delizioso profumo, capace di mascherarne altri. Inoltre è perfetta per nascondere la tua ciccia.",ep:20,g:87,l:60,wd:true,fm:true,w:10,s:46,p:9508};
I.u[8009] = {n:"Copricapo del Koalak",t:16,d:"Questo copricapo è ornato di enormi orecchie di Koalak che permettono di amplificare i suoni emessi dalle creature che ti circondano. Attenzione: può distruggerti i timpani se i tuoi amici sono adepti dei venti di panico.",ep:20,g:125,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8010] = {n:"Smontatore",t:93,d:"Permette di recuperare un equipaggiamento posizionato dentro un recinto.",ep:1,g:96,l:1,wd:false,fm:true,w:10,ut:true,p:1};
I.u[8011] = {n:"I Profeti, i Culti, la Fede",t:25,d:"Qualche buona storia religiosa che farà felici gli avventurieri credenti.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8012] = {n:"Polvere di resurrezione",t:48,d:"Questa polvere permette di riportare in vita un famiglio fantasma, a condizione di saper nutrire un fantasma di famiglio.",ep:20,g:51,l:1,wd:true,fm:true,w:1,p:100};
