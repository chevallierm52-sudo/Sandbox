I.u[8175] = {n:"Certificato di Deposito al Cianil: Arbre Magic",t:77,d:"Questo Certificato descrive le caratteristiche dell\'Arbre Magic che hai lasciato al Cianil.",ep:3,g:36,l:1,wd:false,fm:true,w:1,p:100};
I.u[8176] = {n:"Certificato di Deposito al Cianil: Palladineve",t:77,d:"Questo Certificato descrive le caratteristiche del Palladineve che hai lasciato al Cianil.",ep:3,g:37,l:1,wd:false,fm:true,w:1,p:100};
I.u[8178] = {n:"Certificato di Deposito al Cianil: El Scarador",t:77,d:"Questo Certificato descrive le caratteristiche dell\'El Scarador che hai lasciato al Cianil.",ep:3,g:38,l:1,wd:false,fm:true,w:1,p:100};
I.u[8179] = {n:"Certificato di Deposito al Cianil: Tifux",t:77,d:"Questo Certificato descrive le caratteristiche del Tifux che hai lasciato al Cianil.",ep:3,g:39,l:1,wd:false,fm:true,w:1,p:100};
I.u[8180] = {n:"Certificato di Deposito al Cianil: Bworky",t:77,d:"Questo Certificato descrive le caratteristiche del Bworky che hai lasciato al Cianil.",ep:3,g:40,l:1,wd:false,fm:true,w:1,p:100};
I.u[8181] = {n:"Croccantello Leggendario",t:17,d:"Questo spesso mantello in pietra grezza ti farà diventare uno spesso grezzo in pietra.",ep:5,g:101,l:84,wd:true,fm:true,w:10,s:52,p:18200};
