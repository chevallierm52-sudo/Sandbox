I.u[7552] = {n:"Mantellacchino",t:17,d:"A volte, quando un guerriero e una Dragacchina si uniscono, possono accadere strani fatti.\nQuesto mantello ne è la prova vivente: è fatto di ali di Dragacchino cucite su un mantello. La Dragacchina che si è sacrificata per questo mantello ha voluto offrirlo al celebre menestrello Lonne Jenon il giorno della loro unione. Claudius Baglionus ci ha persino composto una canzone.",ep:2,g:90,l:50,wd:true,fm:true,w:5,s:42,p:25000};
I.u[7553] = {n:"Cappellacchino",t:16,d:"Se hai sempre voluto assomigliare a un Dragacchino, questo è il momento giusto! Tuttavia, se tieni alla tua salute, evita di passeggiare nelle vie di Amakna sotto Natale.",ep:2,g:118,l:50,wd:true,fm:true,w:10,s:42,p:15000};
I.u[7554] = {n:"Stivalacchino",t:11,d:"Le tue amiche ti invidieranno questi stivali, perché sicuramente ti permetteranno di partecipare a una delle serate dell\'ambasciatore e sgranocchiare i suoi fantastici cioccolatini.",ep:2,g:65,l:50,wd:true,fm:true,w:3,s:42,p:5000};
I.u[7555] = {n:"Anocchino",t:9,d:"Grazie a questo anello, gli amici diranno di te: \"Ha veramente tutto di un tacchino\".",ep:2,g:97,l:50,wd:true,fm:true,w:1,s:42,p:1000};
I.u[7556] = {n:"Regalo Dragacchino",t:89,d:"Questo pacchetto regalo contiene una parte di un famoso travestimento. I Dragacchini ti invidieranno da morire!",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7557] = {n:"Chiave del Dongione Alberagno",t:84,d:"Questa chiave in corteccia di Alberagno potrebbe mettere radice se la depositi in un luogo caldo e umido, come le mutande di un Bwork, ad esempio...",ep:1,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[7558] = {n:"Peli deulk di Bworky",t:24,d:"Questi peli non resteranno nel tuo zaino per molto tempo... O almeno... te lo auguriamo!",ep:14,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[7559] = {n:"Goldontura",t:10,d:"Si dice che quando il suo primo proprietario infilava questa cintura, girava ogni volta su se stesso. Ecco la conferma che bisogna avere qualche rotella fuori posto per indossare una roba del genere.",ep:22,g:85,l:164,wd:true,fm:true,w:0,p:48200};
I.u[7560] = {n:"Runa Ré Per Acqua",t:78,d:"Questa runa aumenta la resistenza percentuale ai danni elementari di tipo Acqua.",ep:1,g:31,l:10,wd:true,fm:true,w:1,p:10};
