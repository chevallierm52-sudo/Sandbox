I.u[7495] = {n:"Tagliacuoio del Calzimago",t:5,d:"Questo Tagliacuoio magico permette di tagliare il cuoio meglio e grattare le pelli. È l\'attrezzo indispensabile per migliorare i vecchi stivali e le cinture.",ep:2,g:53,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=62",p:1000};
