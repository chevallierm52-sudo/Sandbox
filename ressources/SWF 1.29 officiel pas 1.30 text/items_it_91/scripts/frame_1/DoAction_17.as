I.u[7581] = {n:"Sakananas",t:81,d:"Questo zaino assomiglia moltissimo ad un ananas magico, forse perché si tratta di un ananas magico trasformato in zaino per ragioni che restano ancora sconosciute. \nAl contrario dello Zaino-Cawota, il Saknanas non è vuoto, anzi non ci sta più niente, è inoltre sempre pesante, un po\' come il tuo amico Yop che si è perso da mesi nella taverna di Astrub.\nQuesto zaino, al contrario di ciò che si potrebbe pensare, non fa parte della panoplia ananas. Ti hanno mentito ancora una volta.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[7590] = {n:"Abbeveratoio in Frassino",t:93,d:"Questo abbeveratoio permetterà alla tua futura cavalcatura di dissetarsi o darsi una rinfrescata durante la stagione calda. Se versi un po\' di pozione magica nell\'acqua dell\'abbeveratoio, la tua cavalcatura crescerà meglio.",ep:1,g:1,l:1,wd:true,fm:true,w:10,ut:true,p:1};
