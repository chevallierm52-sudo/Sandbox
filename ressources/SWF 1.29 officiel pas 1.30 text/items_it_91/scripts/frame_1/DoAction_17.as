I.u[7420] = {n:"Certificato di Deposito al Cianil: Nomoon",t:77,d:"Questo Certificato descrive le caratteristiche del Nomoon che hai lasciato al Cianil.",ep:3,g:35,l:1,wd:false,fm:true,w:1,p:100};
I.u[7421] = {n:"Pozione d\'oblio di mestiere: Forgiatore di Scudi",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Forgiatore di Scudi.",ep:18,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7422] = {n:"Maskananas",t:16,d:"Questa maschera a forma di frutto esotico è un vero pezzo da collezione. Non serve a niente, se non a renderti veramente originale ed appetitoso. Va già bene, no?",ep:1,g:117,l:1,wd:true,fm:true,w:1,s:74,p:10};
I.u[7423] = {n:"Uovo di Larva Dorata",t:12,d:"Per quanto possa sembrare strano le uova delle Larve Dorate non sono deposte dalle Larve Dorate, ma da larve comuni di colore verde, arancione o blu. La natura è proprio piena di misteri!",ep:1,g:715,l:10,wd:true,fm:true,w:1,u:true,p:1};
I.u[7425] = {n:"Piccola Larva Dorata",t:32,d:"Questa larva è appena uscita dall\'uovo. Il suo primo sguardo si è posato su di te, e ora è convinta che tu sia sua mamma.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
