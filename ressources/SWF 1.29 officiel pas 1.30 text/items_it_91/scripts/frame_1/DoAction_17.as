I.u[7392] = {n:"Pozione d\'oblio: \"Follia sanguinaria\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo dei Sàcrido: \"Follia sanguinaria\".",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7393] = {n:"Stoffa di Fantasma Pandora",t:55,d:"Questa stoffa è ancora impregnata del sudore di Pandora, il che gli conferisce un valore non trascurabile.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7394] = {n:"Pozione d\'oblio: \"Felinizione\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo speciale degli Ecaflip: \"Felinizione\"",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7395] = {n:"Pozione d\'oblio: \"Cattura Anime\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo speciale: \"Cattura Anime\".",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7396] = {n:"Prosperità",t:29,d:"Questa benedizione aumenterà la tua resistenza all\'Acqua nei prossimi combattimenti.",ep:18,g:10,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7397] = {n:"Perspicacia",t:29,d:"Questa benedizione aumenterà la tua resistenza al Fuoco nei prossimi combattimenti.",ep:18,g:9,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7398] = {n:"Elasticità",t:29,d:"Questa benedizione aumenterà la tua resistenza all\'Aria nei prossimi combattimenti.",ep:18,g:8,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7399] = {n:"Durezza",t:29,d:"Questa benedizione aumenterà la tua resistenza alla Terra nei prossimi combattimenti.",ep:18,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7400] = {n:"Pergamena Legata",t:87,d:"Questa pergamena permette di localizzare il bersaglio per cacciarlo.",ep:1,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:1};
I.u[7401] = {n:"Pergamena vergine",t:87,d:"Questa pergamena permette di \"marchiare\" un bersaglio per poterlo cacciare in seguito.",ep:16,g:1,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,ut:true,p:100};
I.u[7402] = {n:"Lotto di dieci pergamene vergini",t:87,d:"Questo lotto permette di \"segnare\" <b>un solo bersaglio</b> per poi poterlo attaccare più volte.",ep:16,g:3,l:10,wd:false,fm:true,w:10,c:"Ps!0&PP>0",u:true,ut:true,p:500};
I.u[7403] = {n:"Osso di Fantasma Leopardo",t:47,d:"Questo piccolo osso appuntito era usato dai Brigandini per ornarsi le narici. Un modo elegante per dare valore ad un brutto naso appuntito.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7404] = {n:"Osso di Fantasma Maho Focopaz",t:47,d:"Quest\'osso è ancora impregnato di una magia che si potrebbe definire artigianale. Non ti stupire allora se dovesse riprendere vita e cominciare a cercare i resti del suo proprietario.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7405] = {n:"Osso di Fantasma Pandikaze",t:47,d:"Quest\'osso è tutto quello che resta del fantasma che hai appena annientato. Sei stato sfortunato, non sembra proprio un osso magico.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7406] = {n:"Osso di Fantasma Pandora",t:47,d:"Quest\'osso non viene dalla scatola di Pandora, eppure tutto farebbe pensare al contrario.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7407] = {n:"Osso di Fantasma Pandulo",t:47,d:"Se intagliato perfettamente, quest\'osso può servire senza problemi come lancetta per un orologio gigante. È un oggetto a dir poco indispensabile.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7408] = {n:"Osso di Fantasma Soryo Focopaz",t:47,d:"La prima volta che il Soryo Focopaz si è rotto un osso, ha cercato di vendicarsi sul primo arrivato. Nello stesso momento, Claudius Baglionus, il menestrello, passeggiava cantando e incrociò il Soryo. Il seguito della storia è sconosciuto, quello che si sa è solo che dopo la voce di Claudius Baglionus era diventata ancora più acuta.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7410] = {n:"Osso di Fantasma Tanukui San",t:47,d:"A forza di sopportare l\'enorme peso dei suoi testicoli, le ossa del Tanukui San sono diventate incredibilmente resistenti.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7411] = {n:"Osso di Fantasma Yokai Focopaz",t:47,d:"Quest\'osso avrebbe potuto essere usato come mazza per spaccare i crani degli avventurieri imprudenti, o come martello per conficcare gli Anutrof nella terra come asparagi. Ma da un po\' di tempo è nelle tue mani, e sembra che il suo destino sia ben diverso...",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7412] = {n:"Lotto di cento pergamene vergini",t:87,d:"Questo lotto permette di \"segnare\" <b>un solo bersaglio</b> per poi poterlo attaccare più volte.",ep:16,g:3,l:10,wd:false,fm:true,w:100,c:"Ps!0&PP>0",u:true,ut:true,p:3500};
I.u[7413] = {n:"Pergamena \"Indicare\"",t:25,d:"(Doppio clic per imparare questa emote)\nQuesta pergamena ti permette di imparare l\'attitudine \"Indicare\", per mostrare una direzione o denunciare davanti a tutti gli imbroglioni.",ep:18,g:9,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7414] = {n:"Piccolo Maomao Bianco",t:18,d:"Questa piccola palla di pelo graffia, morde, pizzica... anche la mano che la sta nutrendo. È una creatura terrificante ma comunque irresistibile, attraente e affascinante. Ogni riferimento al sesso femminile è puramente casuale... Attenzione: questa creatura oltre al suo carattere irascibile è molto esigente sul piano alimentare, perché consuma solo selvaggina fresca.",ep:3,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7415] = {n:"Piccolo Baubau Nero",t:18,d:"Questa strana creaturina si nutre solo di pesce appena pescato. Ma non ti preoccupare, la sua piacevole compagnia compensa di gran lunga il suo alito di pesce disidratato.",ep:3,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7417] = {n:"Certificato di Deposito al Cianil: Peki Peki",t:77,d:"Questo Certificato descrive le caratteristiche del Peki Peki che hai lasciato al Cianil.",ep:3,g:26,l:1,wd:false,fm:true,w:1,p:100};
I.u[7418] = {n:"Certificato di Deposito al Cianil: Piccolo Maomao Bianco",t:77,d:"Questo Certificato descrive le caratteristiche del Piccolo Maomao Bianco che hai lasciato al Cianil.",ep:3,g:27,l:1,wd:false,fm:true,w:1,p:100};
