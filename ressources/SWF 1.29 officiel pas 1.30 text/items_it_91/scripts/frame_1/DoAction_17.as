I.u[7680] = {n:"Ugacapo",t:16,d:"Questo copricapo non è altro che una parte della testa di Ugah, eccellentissima divinità venerata dai Porcos. Imbottito di tessuto, piume e lana, questo copricapo può essere indossato da chiunque, a condizione di sopportarne l\'odore di pelo.",ep:23,g:120,l:178,wd:true,fm:true,w:200,s:118,p:57850};
