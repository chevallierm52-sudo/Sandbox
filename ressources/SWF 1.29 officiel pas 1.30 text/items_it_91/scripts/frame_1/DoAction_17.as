I.u[7650] = {n:"Martello del Tuttofare",t:7,d:"Questo martello consente al Tuttofare di realizzare una miriade di oggetti differenti.",ep:7,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:100};
I.u[7651] = {n:"Corno di Bruma",t:94,d:"Questo corno di bruma permette di chiamare la tua cavalcatura alla riscossa quando ne hai bisogno.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7652] = {n:"Pozione di Ricordo",t:12,d:"Questa pozione consente di rubare una parte dell\'essenza di un essere per conservarne un ricordo immortale. Molto utilizzata anche per segnare il tuo territorio e i tuoi beni, questa pozione è usata regolarmente anche nella fabbricazione di rune di firma.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
