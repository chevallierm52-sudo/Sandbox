I.u[7439] = {n:"Ricompensa per la Missione\nMercenario",t:14,d:"Questa pergamena attesta che meriti una ricompensa onorifica per l\'impegno da te dimostrato durante le varie missioni presso i Mercenari.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"Ps=3&Pa>79",u:true,ut:true,p:1};
