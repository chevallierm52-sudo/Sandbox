I.u[7673] = {n:"Abbeveratoio in Legno Ancestrale",t:93,d:"Questo abbeveratoio permetterà alla tua futura cavalcatura di dissetarsi o darsi una rinfrescata durante la stagione calda. Se versi un po\' di pozione magica nell\'acqua dell\'abbeveratoio, la tua cavalcatura crescerà meglio.",ep:3,g:88,l:1,wd:true,fm:true,w:10,ut:true,p:1};
