I.u[7497] = {n:"Pozione di liberazione di massa",t:14,d:"Questa pozione permette di liberare le anime dei tuoi nemici per rimandarle direttamente nel loro cimitero, senza permettere loro di essere resuscitate.",ep:0,g:59,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
I.u[7498] = {n:"Piccola pozione di cura di massa",t:14,d:"Questa pozione permette di curare tutti gli alleati presenti sulla mappa.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"Pg>23,2",u:true,p:10};
I.u[7499] = {n:"Pozione di Villaggio dei Kwak di Ghiaccio",t:12,d:"Questa pozione ti permette di essere teletrasportato nel villaggio dei Kwak di Ghiaccio, se quest\'ultimo ti appartiene.",ep:0,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7500] = {n:"Pozione di Villaggio dei Kwak di Fiamma",t:12,d:"Questa pozione ti permette di essere teletrasportato nel villaggio dei Kwak di Fiamma, se quest\'ultimo ti appartiene.",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7501] = {n:"Pozione di Villaggio dei Kwak di Vento",t:12,d:"Questa pozione ti permette di essere teletrasportato nel villaggio dei Kwak di Vento, se quest\'ultimo ti appartiene.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7502] = {n:"Pozione di Riunione",t:12,d:"Questa pozione permette di creare un punto di riunione, per permettere agli avventurieri allineati di raggiungerti per organizzare un attacco o una difesa di villaggio, per esempio. Questa pozione magica permette inoltre di salvare la posizione delle persone che ti stanno raggiungendo, per permettere loro di ripartire rapidamente dal loro punto di partenza iniziale.",ep:0,g:21,l:1,wd:false,fm:true,w:1,p:1};
I.u[7503] = {n:"",t:88,d:"",ep:1,g:45,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7504] = {n:"",t:88,d:"",ep:1,g:46,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7505] = {n:"Pozione d\'oblio di mestiere: Vestimago",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Vestimago.",ep:9,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
