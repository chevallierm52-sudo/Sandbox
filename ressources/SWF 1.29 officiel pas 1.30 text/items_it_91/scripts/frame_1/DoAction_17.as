I.u[7683] = {n:"Mangiatoia in Legno Ancestrale",t:93,d:"Questa mangiatoia dovrebbe consentire alla tua cavalcatura di non morire di fame, o di vomitare i dolcetti che le hai dato. Servirà a ridare un po\' di energia alla tua cavalcatura, quando darà segni di debolezza.",ep:2,g:92,l:1,wd:true,fm:true,w:10,ut:true,p:1};
