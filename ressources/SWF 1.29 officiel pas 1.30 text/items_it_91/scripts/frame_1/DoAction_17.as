I.u[7367] = {n:"Angeli & Demoni",t:25,d:"Acclamato da una miriade di lettori, Acidrik Stracciapanza torna alla ribalta con qualche altra considerazione metafisica.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7368] = {n:"Bacchetta Tela",t:3,d:"L\'Intagliatore di questa bacchetta voleva distruggere le stelle cadenti che gli impedivano di dormire. La leggenda racconta che una sera, uscendo dalla taverna completamente ubriaco, abbia provato la bacchetta prendendo la luna per una stella cadente. La bacchetta era veramente potente e ha rotto la luna in due... una di queste parti è caduta nel Mare di Asse, provocando la nascita dell\'isola di Moon. Un\'ennesima storia da raccontare davanti a un bicchiere di birra alla taverna.",ep:19,g:55,l:126,wd:true,fm:true,w:15,an:11,e:[5,4,2,4,50,50,false,true],c:"CS>100&CV>150&CI>300",p:39355};
I.u[7369] = {n:"Ambra di Bambuto",t:50,d:"Quest\'ambra è di solito attaccata alla cima del Bambuto, gli serve come gioiello, ma anche per dargli più inerzia quando il Bambuto decide di abbattersi su di te per farti ancora più male. Che creatura ingegnosa.",ep:18,g:2,l:40,wd:true,fm:true,w:2,p:100};
I.u[7370] = {n:"Ambra di Bambuto Sacro",t:50,d:"Quest\'ambra è la sola ricchezza del Bambuto Sacro, e forse è proprio per questo che è così acido e cattivo con tutti i turisti che arrivano sull\'isola di Pandala.",ep:18,g:1,l:120,wd:true,fm:true,w:2,p:100};
