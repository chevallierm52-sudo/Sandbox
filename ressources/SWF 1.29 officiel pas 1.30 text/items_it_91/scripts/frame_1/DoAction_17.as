I.u[7703] = {n:"Cattivo Piccolo Cuervoc",t:18,d:"Questo volatile oscuro è conosciuto soprattutto per la sua propensione ai cimiteri e agli avventurieri dalla pelle bianca. Adora rompere a colpi di becco le ossa che si trovano nelle tombe.",ep:3,g:18,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:8,p:1};
I.u[7704] = {n:"Scoiattolo Furfante",t:18,d:"Questo scoiattolo passa il tempo a rompere noccioline, il che potrebbe anche essere pratico quando non si tratta delle tue! Questo famiglio mangia solo semi.",ep:3,g:16,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7705] = {n:"Leopardo",t:18,d:"Questo Leopardo è un lontano parente dei celebri Volpi dell\'isola dei Wabbits. Più temerario ma anche più indisciplinato, saprà aiutarti durante i tuoi combattimenti, ma se lo trascuri non esiterà a fartela pagare. Mangia la carne.",ep:3,g:27,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7706] = {n:"Bilby",t:18,d:"Bilby, o Bilbiblabalù come si chiama in realtà, è una piccola gelatina in cerca di avventura. È particolarmente affezionata a Vald e possiede notevoli poteri (proporzionati alla sua grandezza, insomma). Questo famiglio mangia solo fiori.",ep:3,g:43,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7707] = {n:"Cinghialetto",t:18,d:"Questo piccolo maiale selvaggio ha un muso di dimensioni smisurate, adatto alla ricerca delle grosse ghiande, e sembra averti trovato abbastanza facilmente... così... per caso. Si nutre di Porkass, maiali e cinghiali.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7708] = {n:"Pìut Blu",t:18,d:"Questo piccolo Pìut non è come gli altri Pìu, basta guardarne il colore per accorgersene. Ma comunque condivide con gli altri Pìu il gusto sfrenato per becchettare i sederi. Sembra che a qualcuno piaccia... Questo famiglio mangia solo semi.",ep:1,g:19,l:1,wd:true,fm:true,w:10,p:1};
