I.u[7379] = {n:"Stoffa di Fantasma Pandikaze",t:55,d:"Questo ammasso di peli è quasi intatto malgrado le batoste che hai dovuto infliggere al povero Fantasma Pandikaze per strapparglielo.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7380] = {n:"Stoffa di Fantasma Maho Focopaz",t:55,d:"Questa stoffa magica di colore rosso è impregnata di una magia strapotente. Non si può dire la stessa cosa di te.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7381] = {n:"Stoffa di Fantasma Soryo Focopaz",t:55,d:"Questa stoffa di modeste dimensioni è perfetta per tappare i buchi delle vecchie porte, quando l\'inverno arriva.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7382] = {n:"Stoffa di Fantasma Leopardo",t:55,d:"Questa stoffa non è dolce come la musica del Leopardo, eppure a qualcosa deve pur servire. Ma a cosa? Questo è il problema...",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7383] = {n:"Stoffa di Fantasma Yokai Focopaz",t:55,d:"Questa stoffa è fatta con le parti più sensibili del Fantasma Yokai Focopaz, che sono anche le più maleodoranti. Molti avventurieri pensano che si tratti dei suoi baffi, ma si sbagliano...",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7384] = {n:"Stoffa di Fantasma Pandulo",t:55,d:"Contrariamente a quello che si pensa, questa stoffa non si può mangiare. Le ultime persone che hanno cercato di cucinarla si sono trasformate in Tanukui San. Una fortuna per alcune di loro.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7385] = {n:"Stoffa di Fantasma Tanukui San",t:55,d:"Questa stoffa proviene direttamente dalle ascelle del Fantasma Tanukui San, famose per la loro morbidezza ma anche per il loro odore che assomiglia, nel migliore dei casi, a quello che sprigiona la carne di Cuervoc in decomposizione.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7386] = {n:"Testicoli di Tanukui San",t:15,d:"Questi enormi testicoli sono ricoperti di una peluria molto morbida che protegge benissimo dagli attacchi magici, ma anche dai colpi di trampolo che il Tanukui San si dà ogni tanto senza fare attenzione, o quando entra in trance durante l\'invocazione di una femmina di Tanuki Chan. Comunque sia, hai tra le mani un oggetto importante.",ep:1,g:2,l:120,wd:true,fm:true,w:200,p:10};
I.u[7387] = {n:"Il Clan dei Mercenari",t:25,d:"Tutto, tutto ma proprio tutto sui Mercenari! Un\'opera scritta dal fondatore e Grande Maestro del Clan.",ep:1,g:19,l:1,wd:true,fm:true,w:1,u:true,p:1};
