I.u[7508] = {n:"Runa di Firma",t:50,d:"Questa runa permette agli artigiani più dotati di firmare le loro creazioni.\n(da utilizzare con gli altri ingredienti durante la fabbricazione dell\'oggetto)",ep:18,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[7509] = {n:"Prima parte della chiave del labirinto del Drago Maiale",t:84,d:"Se questo muso non ti dice niente, allora non cercare di farne qualcosa, o potresti ricevere un colpo mortale, soprattutto se sei un po\' stordito.",ep:13,g:1,l:1,wd:true,fm:true,w:1,p:100};
I.u[7510] = {n:"Seconda parte della chiave del labirinto del Drago Maiale",t:84,d:"Questo oggetto forse è una parte della chiave che apre il forziere del tesoro che hai sempre sognato. A meno che non sia la chiave della tua tomba.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[7511] = {n:"Chiave del Labirinto del Drago Maiale",t:84,d:"Se speri di incontrare delle belle maiale con questa chiave, sbagli di grosso. Ti permetterà solo di aprire il labirinto del Drago Maiale. Attenzione: si autodistruggerà dopo l\'uso.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:100};
I.u[7512] = {n:"",t:24,d:"",ep:1,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[7513] = {n:"Sandali Titud",t:11,d:"Titud era un modesto Anutrof Ciabattino, più piccolo di uno Xelor. Si racconta che abbia fabbricato questi sandali per poter finalmente baciare la sua amata, un\'Aniripsa senza gambe, ma che non funzionò lo stesso e che dovette rassegnarsi a non baciarla mai in piedi.",ep:20,g:67,l:122,wd:true,fm:true,w:10,p:37800};
I.u[7514] = {n:"Stivali Harry",t:11,d:"Harry era un vecchio saggio che passava le giornate a pescare sulle banchine di Sufokia. I suoi grandi baffi lo facevano assomigliare a Danus Kuaid, il famoso attore di una compagnia teatrale che recitava regolarmente alla taverna di Amakna come preludio di incredibili orgie a base di birra e Frittelle.",ep:20,g:70,l:123,wd:true,fm:true,w:10,p:37850};
I.u[7515] = {n:"Mantello Spaziale",t:17,d:"Questo mantello non viene dalla tua galassia, eppure sembra abbinarsi perfettamente al colore delle tue calze a rete in lana di Pappatutto.",ep:20,g:92,l:148,wd:true,fm:true,w:10,p:47925};
I.u[7516] = {n:"Copricapo del Bimd\'Ulo",t:16,d:"È stato un vecchio Anutrof di nome Dhy-Ah-Mhanhd, inacidito e tormentato da una sfortuna secolare, a scoprire questo terribile copricapo in fondo a un\'alcova nella grotta di Bimd\'Ulo. Tempo dopo, l\'Anutrof partì lontano da Amakna per scoprire nuovi orizzonti. La leggenda racconta che ritorna a casa una volta ogni secolo per sfottere i vecchi amici, ma soprattutto per nostalgia.",ep:20,g:121,l:110,wd:true,fm:true,w:10,p:31675};
I.u[7517] = {n:"Birra del Ripata",t:37,d:"Questa birra è così acida che la pinta in cui si versa dura meno di un Moskito.",ep:7,g:4,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7518] = {n:"Fotasma",t:18,d:"Questa sorprendente creatura viene dall\'aldilà e non vuole ritornarci a meno che, per un tragico destino, tu non debba andarci con lei...",ep:3,g:13,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7519] = {n:"Dragona Rosa",t:18,d:"Questo piccolo drago ha la pelle rosa come le chiappe di una femmina di Bwork. Potrebbe essere una buona fonte di pensieri senza spese né rischi, o semplicemente una fonte di buoni ricordi. Fortunatamente la Dragona non serve solo a questo ma è una creatura molto saggia e potente. Attenzione: la sua voracità è uguale solo alla perversità di uno Chafer durante la luna piena, e si nutre solo di altri famigli.",ep:3,g:14,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7520] = {n:"Crum",t:18,d:"È un vecchio soldatino di piombo in pensione che ha ripreso vita. Ti seguirà dappertutto e farà di tutto per difenderti dai pericoli, sempre che tu gli dia da mangiare regolarmente. Non sperare però che si faccia picchiare al tuo posto... non sostituirà gli avventurieri principianti di Astrub...",ep:3,g:15,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7521] = {n:"Regalo Fotasma",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7522] = {n:"Minimino",t:18,d:"Questo neonato di Minotoror può essere avvicinato e accarezzato a condizione che sia addomesticato e pulito. Tuttavia bisogna essere prudenti, la natura riprende a volte i suoi diritti e l\'istinto distruttore di questa creatura potrebbe rifarsi vivo in qualsiasi momento. Per evitare cattive sorprese allevalo come i tuoi figli... a colpi di bastone!",ep:3,g:21,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7523] = {n:"Maomicina Rossa",t:18,d:"Questa adorabile creatura rossa è capace di fare girare la testa a tutti i felini, anche a quelli più indifferenti!\n(QUESTO LEGGENDARIO FAMIGLIO NON HA BISOGNO DI MANGIARE)",ep:1,g:40,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7524] = {n:"Maomao Tigrato",t:18,d:"Questa sorprendente creatura deriva dall\'incrocio tra un Maomao bianco e un Maomao nero. Mangia solo pesci.",ep:3,g:41,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7525] = {n:"Regalo Dragona Rosa",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7526] = {n:"Regalo Crum",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, un manuale per allevarlo, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.\n(ATTENZIONE, questo regalo contiene oggetti molto pesanti, rischi di sovraccaricarti al momento dell\'apertura. Sbarazzati dei tuoi oggetti pesanti o fatti aiutare da un amico).",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
