I.u[7098] = {n:"Martello del Forgiatore di Scudi",t:7,d:"Attrezzo indispensabile per la creazione di scudi.",ep:18,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:500};
I.u[7101] = {n:"null",t:25,d:"",ep:0,g:8,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7102] = {n:"Spada del Cavaliere di Ghiaccio",t:6,d:"Il Cavaliere di Ghiaccio era conosciuto come uno dei più grandi Forgiatori di spade di tutta Amakna. Solo l\'orribile e impietosa Liche rifiutava di riconoscere questo immenso talento. Il Cavaliere, offeso da questa indifferenza, le diede un ultimatum: aspettando il pubblico riconoscimento del suo talento di Forgiatore di spade, avrebbe smesso di esercitare questa professione. Ma non conosceva bene la terribile Liche che non cedette assolutamente. Il Forgiatore dovette rinunciare alla sua richiesta e centinaia di anni dopo ricominciò a lavorare. Nel frattempo, però, aveva completamente dimenticato come si forgiavano le spade, e questa spada un po\' ridicola fu la sua ultima creazione.",ep:1,g:51,l:12,wd:true,fm:true,w:10,an:14,e:[5,6,1,1,40,60,false,false],p:575};
I.u[7103] = {n:"La Xyativa",t:3,d:"Questa bacchetta serviva a decapitare tutti gli zoticoni di Amakna. Tanto vale dire che serviva quasi ogni giorno. È interessante constatare quanto assomigli a un bastone, o addirittura a una canna... Forse serviva per risolvere certi problemi intestinali del suo proprietario, che alla fine l\'ha chiamata così. Nessuno saprà mai cosa c\'è dietro questa sordida storia.",ep:19,g:53,l:145,wd:true,fm:true,w:15,an:11,tw:true,e:[7,4,3,5,30,50,false,true],c:"CI>450&CV>200",p:10000};
I.u[7104] = {n:"Infradito Dimenticati",t:11,d:"Questi infradito servivano per praticare diverse arti marziali. Di aspetto poco innovativo né artistico, sono stati presto dimenticati... un po\' come te... ma meno velocemente comunque...",ep:18,g:58,l:67,wd:true,fm:true,w:5,p:11700};
I.u[7105] = {n:"Amuleto di Pandala",t:24,d:"Questo amuleto dal semplice aspetto racchiude un mistero che solo un Pandawa sul punto di morire potrebbe capire...",ep:18,g:48,l:0,wd:true,fm:true,w:0,p:1};
I.u[7106] = {n:"Larvamuleto",t:1,d:"Con questa testa di larva appesa attorno al collo, assomiglierai a Ulrik Holgan, il famoso domatore di larve dei tempi moderni.",ep:5,g:88,l:26,wd:true,fm:true,w:5,s:33,p:1950};
I.u[7107] = {n:"Larvastivali",t:11,d:"Chi non ha mai sognato di affondare il piede direttamente nelle budella di una larva? Sicuramente tu no, allora lasciati andare e approfittane.",ep:1,g:53,l:33,wd:true,fm:true,w:10,s:33,p:3150};
I.u[7108] = {n:"Larvazaino",t:81,d:"Questo zaino originale ma senza tanti fronzoli era di moda molto tempo fa. Ecco un tipico esempio del cattivo gusto dei tuoi antenati.",ep:5,g:60,l:27,wd:true,fm:true,w:10,s:33,p:2150};
I.u[7109] = {n:"Larvacapo",t:16,d:"Finalmente hai l\'opportunità di assomigliare a una vera larva. Potrai finalmente ostentare il tuo stile di vita larvesco.",ep:5,g:103,l:34,wd:true,fm:true,w:10,s:33,p:3225};
I.u[7110] = {n:"Bacchetta Larvesca",t:3,d:"Questa terrificante bacchetta è un intestino di larva, seccato, stregato, e reidratato. Ormai ha un aspetto assurdo... insomma un po\' come te, con la differenza che tu non sei nemmeno stregato.",ep:5,g:19,l:40,wd:true,fm:true,w:5,an:11,e:[5,3,2,4,40,50,false,true],s:33,p:4000};
I.u[7112] = {n:"Dofus Maculato",t:23,d:"Solo l\'incrocio tra un drago nero e un drago bianco poteva permettere la creazione di un tale uovo. A meno che non si tratti di un inganno...",ep:1,g:8,l:6,wd:true,fm:true,w:1,p:50000};
I.u[7113] = {n:"Dofawa",t:23,d:"Questo Dofus assamiglia stranamente ad un uovo di Dragacchino selvaggio... Per una volta, forse, l\'apparenza non inganna.",ep:1,g:9,l:6,wd:false,fm:true,w:1,p:10};
I.u[7114] = {n:"Dofus Ebano",t:23,d:"Nero come le tenebre, duro come la roccia, questo Dofus Ebano è stato creato da Grugalorasalar il Drago Nero per tenergli compagnia. Aveva semplicemente dimenticato che un uovo, per quanto magico potesse essere, non sa parlare.",ep:1,g:7,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7115] = {n:"Dofus Avorio",t:23,d:"Se la bianchezza del Dofus Avorio non ha eguali è perché il Drago Bianco Dardondakal lo sbianca a grandi alitate ogni mattina (un vecchio segreto tramandatogli da nonna Drago)",ep:1,g:11,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7116] = {n:"Anello Mertà",t:9,d:"Questo anello porta con se uno strano sortilegio. Infatti, una volta indossato, potrai parlare solo all\'Orefice che l\'ha fabbricato.",ep:18,g:91,l:59,wd:true,fm:true,w:5,p:9155};
I.u[7117] = {n:"Fede Etnica",t:9,d:"Un gruppo di Menestrelli cosmopoliti, ma particolarmente imbranati, aveva deciso di usare questa fede per ritrovarsi in mezzo alla gente che avrebbe assistito ai loro concerti. Alla fine non gli servì a nulla perché non ebbero alcun successo. Secondo certe malelingue... o orecchie fini, non meritavano altro.",ep:18,g:92,l:53,wd:true,fm:true,w:5,p:7150};
I.u[7118] = {n:"Anello Ak\'Tuale",t:9,d:"Questo Anello a forma di grande falena non farà risaltare le tue mani, ma è meglio così... non ti preoccupare.",ep:18,g:94,l:90,wd:true,fm:true,w:5,p:20775};
I.u[7119] = {n:"Anello Ha",t:9,d:"L\'Orefice che ha creato quest\'opera non ha nessun legame di parentela con il celebre Forgiatore di spade. Secondo il suo creatore questo anello dovrebbe ricordare l\'atmosfera della boscaglia, senza però sentire la tartaglia. Ancora oggi nessuno ha capito di cosa stesse parlando.",ep:18,g:85,l:58,wd:true,fm:true,w:5,p:8750};
I.u[7120] = {n:"Anello Hoé",t:9,d:"Quest\'anello apparteneva a un vecchio che, secondo certe voci, avrebbe salvato tutte le creature dell\'Isola di Moon da un terribile diluvio. Secondo un\'altra versione dei fatti invece avrebbe barattato la sua barca per una scimma, senza pensare alle creature dell\'Isola.",ep:18,g:86,l:44,wd:true,fm:true,w:2,p:5350};
I.u[7121] = {n:"Anello Nozocomial",t:9,d:"Questo anello vivente ha un terribile sortilegio, è infatti capace di fare ammalare gli avventurieri più resistenti. Si racconta che in realtà dovesse guarire la persona che lo portava all\'indice, ma divenne pericoloso e aggressivo a forza di trovarsi contro la sua volontà in posti poco raccomandabili.",ep:18,g:87,l:50,wd:true,fm:true,w:5,p:6655};
I.u[7122] = {n:"Anello Vizio",t:9,d:"L\'anello dei principianti per eccellenza, ma che simboleggia anche un bel po\' di usi e costumi indicibili. Sembra comunque che sia proprio fatto per te. Bene bene...",ep:16,g:88,l:18,wd:true,fm:true,w:2,p:1100};
I.u[7123] = {n:"Anello Bsceno",t:9,d:"Riservato agli avventurieri esperti, questo anello rischia di scioccare i vostri compagni... se si tratta di giovani creature innocenti.",ep:18,g:95,l:70,wd:true,fm:true,w:2,p:12900};
I.u[7124] = {n:"Dofus al Latte",t:42,d:"Questo uovo di Dofus possiede un potere senza eguali, quello di farti impazzire di felicità.",ep:1,g:27,l:1,wd:false,fm:true,w:1,p:1};
I.u[7125] = {n:"Dofus al Cioccolato Bianco",t:42,d:"Questo uovo di Dofus possiede un potere senza eguali, quello di farti impazzire di felicità.",ep:1,g:28,l:1,wd:false,fm:true,w:1,p:1};
I.u[7126] = {n:"null",t:42,d:"",ep:0,g:29,l:1,wd:false,fm:true,w:1,p:1};
I.u[7127] = {n:"Guscio di Dofus",t:42,d:"...",ep:1,g:30,l:1,wd:false,fm:true,w:1,p:1};
I.u[7128] = {n:"Anello Karina",t:9,d:"Al contrario di quello che pensano alcune persone, questo anello non ha nessun rapporto con la solforosa Karina, che si è più volte messa in mostra in maniera un po\' esotica nei bar dei pirati di Sufokia. In realtà, è stato un musicista allevatore di Tofu ad aver chiamato così questo anello che, una volta indossato attorno al pollice, è in grado di emettere un suono simile a quello che emette un Tofu al quale gli si sta tirando il collo.",ep:18,g:89,l:54,wd:true,fm:true,w:5,p:7700};
I.u[7129] = {n:"Panda al cioccolato",t:42,d:"Non farti ingannare, non è solo il cioccolato che dona gusto al cibo, la forma porta allo stesso modo una buona quantità di sapore. Gusta un Cencio al cioccolato e magari capirai meglio.",ep:0,g:31,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[7130] = {n:"Ricetta del Dofus di Cioccolato",t:24,d:"La ricetta del Dofus di cioccolato, un \"must\" che stupirà i tuoi amici.",ep:1,g:250,l:1,wd:false,fm:true,w:0,p:100};
I.u[7131] = {n:"Anello Oppio",t:9,d:"Questo gioiello ha fatto sognare numerosi avventurieri prima di te. In effetti, gli si attribuiscono numerose virtù, come quella di trasformare gli animi più aggressivi in dolci agnellini. Le istruzioni indicano chiaramente che non si deve bruciare, ma senza spiegare perché.",ep:16,g:90,l:57,wd:true,fm:true,w:5,p:8475};
I.u[7132] = {n:"Anello Rigami",t:9,d:"Questo anello deve il nome alle ultime parole del suo creatore. \"Oh, Rigami amico mio!\", disse in un impeto di dolore molto divertente. È importante constatare come la fabbricazione di questo anello di Bambù preceda l\'apparizione stessa del Bambù. Un enigma in più che sarà difficilmente risolto prima di molti decenni.",ep:16,g:96,l:49,wd:true,fm:true,w:5,p:6300};
I.u[7133] = {n:"Mixomawosis",t:30,d:"Tutti i Wabbit ti avvertiranno, se non vuoi vedere la vita in rosso evita come la peste la Mixomawosis.",ep:1,g:9,l:1,wd:false,fm:true,w:0,p:1};
I.u[7134] = {n:"Rabbia",t:30,d:"Si racconta che la rabbia trasformi completamente gli esseri affetti. Le persone bellicose diventano docili, e le persone calme diventano aggressive. Però quelle che sbavavano già da prima continueranno a sbavare.",ep:1,g:10,l:1,wd:false,fm:true,w:0,p:1};
I.u[7135] = {n:"Maloria",t:30,d:"Malattia trasmessa dai moskito che abitano in regioni dal clima tropicale, la Maloria è anche chiamata Bavoria da certi indigeni, perché sembra che si trasmetta anche attraverso gli sputi dei moskito.",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[7136] = {n:"Medaglia Kido",t:1,d:"Questa medaglia apparteneva a un famoso Pandawa, maestro di una vecchia scuola di arti marziali che insegnava ai discepoli come difendersi usando la forza degli avversari. La sua scuola finì per scomparire perché gli avversari non erano più abbastanza forti.",ep:19,g:89,l:125,wd:true,fm:true,w:10,p:40425};
I.u[7137] = {n:"Mantello Caffeino",t:17,d:"Questo mantello è stato cucito con un solo e unico scopo, creare un mantello capace di mantenere sveglio chi lo porta per più giorni di fila. Infatti è talmente rigido che ti terrà in piedi in ogni circostanza. Attenzione però, non potrai più allacciarti le scarpe...",ep:16,g:15,l:44,wd:true,fm:true,w:15,p:5300};
I.u[7138] = {n:"Ortiz",t:17,d:"Questo mantello, portato dai più grandi guerrieri del Mondo, è famoso soprattutto per la sua morbidezza leggendaria, che gli consente di essere indossato senza biancheria durante la stagione calda. Una forma raffinata d\'esibizionismo che ha fatto più di un adepto.",ep:19,g:91,l:125,wd:true,fm:true,w:15,p:40175};
I.u[7139] = {n:"Cintura Sula",t:10,d:"Sula la Ciabattina amava perdere tempo a gironzolare nei campi, in cerca di un improbabile amore. Invece di trovare l\'essere tanto bramato, trovò la morte cadendo in una grande fossa piena di immondizia, vicino alla zona Maiala. Il suo corpo fu ritrovato solo 7 decenni dopo, quando si svuotò la fossa. Suo fratello avrebbe gridato: \"Lo sapevo che era da qualche parte!\", proprio un istante prima di cadere dentro anche lui.",ep:19,g:82,l:125,wd:true,fm:true,w:15,p:39975};
I.u[7140] = {n:"Xenantura",t:10,d:"Al contrario di quello che si pensa, Xena non era una guerriera, ma una ciabattina. Grazie alle sue forme generose e all\'infinita passione per i lavori domestici, avrebbe sicuramente fatto una brillante carriera nelle taverne di Amakna. Purtroppo il fato ha deciso diversamente.",ep:19,g:83,l:125,wd:true,fm:true,w:15,p:40125};
I.u[7141] = {n:"Hulun",t:16,d:"Questo strano cappello ti proteggerà dai raggi del sole, anche di notte. Attenzione: ogni tre decenni torna in vita e si rivolta contro il padrone cercando di soffocarlo nel sonno.",ep:19,g:111,l:122,wd:true,fm:true,w:10,p:37925};
I.u[7142] = {n:"Piruk",t:16,d:"Questo cappello era usato da certi Xelor per nascondere il loro principio di calvizie. Certi Anutrof invece lo usavano per nascondere la moglie. Insomma un unico metodo per sopperire a due grossi problemi dei nostri giorni. Pratico, no?",ep:19,g:112,l:145,wd:true,fm:true,w:15,p:46980};
I.u[7143] = {n:"Solomonk",t:16,d:"Il Solomonk era il cappello di un vecchio capo di una Tribù di Pandawa, esperto in pozioni lassative. I Pandawa in questione erano spesso obbligati a testare su se stessi gli effetti delle pozioni e usavano questo tipo di cappello che, in caso di bisogno, poteva diventare un eccellente vasino.",ep:19,g:123,l:120,wd:true,fm:true,w:50,p:36880};
I.u[7144] = {n:"Impallichiappa",t:16,d:"Questa cuffietta da sposa è passata di moda da molto tempo, forse a causa del merletto che data di un\'altra epoca. Eppure riciclata come mutandina e messa su una testa molto folta, potrebbe mandare in trance anche lo Chafer più consumato.",ep:19,g:116,l:108,wd:true,fm:true,w:15,p:29775};
I.u[7145] = {n:"Copricapo del Gaddy",t:16,d:"Strana creatura uscita da un mondo immaginario, il Gaddy si distingueva prima di tutto per la straordinaria astuzia, la totale avversione nei confronti del mondo vegetale e la capacità di digiunare per più e più giorni in tempo di guerra. Ma una creatura dalla psicologia così complessa era anche impossibile da domare, per questo la si lasciò vivere in pace nelle miniere senza fondo del Kruup, dove conobbe una vecchia Liche divoratrice di Pappaton.",ep:19,g:115,l:106,wd:true,fm:true,w:15,p:26375};
I.u[7146] = {n:"La Bertuz",t:16,d:"Questo cappello strapotente assomiglia più a una parrucca, ma che importa, è strapotente. Effettivamente il suo proprietario adorava travestirsi e farsi passare per altre persone in modo da imbrogliare meglio gli ingenui. Ma i suoi lugubri giochi finirono per essere scoperti, un po\' come la sua testa quando gli si tolse il cappello. Il suo talento d\'artista gli salvò la vita perché, poco prima della sua esecuzione, ebbe l\'idea di proporsi come scultore di una statua gigante rappresentante le parti intime del muulupo. Fu comunque bruciato vivo dopo aver terminato la statua.",ep:18,g:114,l:81,wd:true,fm:true,w:10,p:16925};
I.u[7147] = {n:"null",t:42,d:"",ep:0,g:32,l:1,wd:true,fm:true,w:1,p:1};
I.u[7148] = {n:"Quadretto di Cioccolato Bianco",t:42,d:"...",ep:1,g:33,l:1,wd:false,fm:true,w:1,p:1};
I.u[7149] = {n:"Quadretto di Cioccolato Nero",t:42,d:"Estratto da cacao puro, questo quadretto di cioccolato ha un sapore irresistibile. Non abusarne se non vuoi avere problemi di digestione.",ep:1,g:34,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:200};
I.u[7150] = {n:"La Stampella",t:16,d:"Questo cappello, dal nome sorprendente, apparteneva a un povero Ecaflip che aveva perso l\'uso della parola in seguito a un terribile trauma. Nonostante il suo grande animo artistico, fu costretto a seguire un corso da Birraio. Annegò in un fusto di birra e lacrime al suo quattordicesimo compleanno. Fortunatamente, la birra non andò persa, infatti il prete che doveva celebrare il funerale andò in coma etilico per diversi anni prima di risvegliarsi e riprendere la cerimonia laddove l\'aveva interrotta.",ep:19,g:109,l:111,wd:true,fm:true,w:20,p:31725};
I.u[7151] = {n:"Koloss",t:16,d:"Lo slogan pubblicitario di questo elmo diceva: \"Questo imponente elmo in argilla ti trasformerà in un vero colosso dalla testa d\'argilla\". Uno studio accurato ti farà accorgere che questo casco non è per niente d\'argilla, ma di piombo. Come se non avessi già abbastanza piombo nella testa!",ep:19,g:108,l:120,wd:true,fm:true,w:15,p:36925};
I.u[7152] = {n:"Kanistero",t:16,d:"Questo cappello a forma di tinozza serviva ai pompieri di Amakna durante gli incendi dei campi di cereali. Oggigiorno serve prima di tutto ai Birrai e alle cameriere che devono pulire il vomito dei loro clienti.",ep:19,g:110,l:120,wd:true,fm:true,w:20,p:36675};
I.u[7153] = {n:"Martello Heco",t:7,d:"Questo enorme martello fa un rumore incredibile ogni volta che si abbatte sul cranio di uno Yop, perché tende ad amplificare la risonanza. Sorprendente... e terribilmente efficace.",ep:19,g:51,l:126,wd:true,fm:true,w:15,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>200",p:40200};
I.u[7154] = {n:"Martello Pollicino",t:7,d:"Questo martello leggero era destinato ai piccoli esseri: gli Xelor utilizzavano il manico e le Arakni ricevevano il blocco... sulla testa. Da allora il suo uso è cambiato e adesso è diventato un giocattolo per i giovani Yop Tuttofare.",ep:18,g:46,l:107,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>350&CV>200&CW>100",p:29475};
I.u[7155] = {n:"Martello Kat-Yvello",t:7,d:"Per molti anni il celebre Capitano Kradoc ha usato questo terribile martello per uccidere tutti coloro che si mettevano sulla sua strada, compresi donne e bambini. Il suo leggendario cattivo carattere e il risaputo amore per l\'alcool l\'hanno comunque portato a essere molto rispettato dai diversi eserciti, tanto alleati quanto nemici.",ep:18,g:48,l:113,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,40,60,false,false],c:"CI>150&CW>100&PG=5",p:32650};
I.u[7156] = {n:"Martello Ronto",t:7,d:"Questo martello arrugginito è perfetto per distruggere gli aceri, o i Moskito.",ep:18,g:50,l:107,wd:true,fm:true,w:20,an:15,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>150&CV>150&(PG=2|PG=5)",p:334251};
I.u[7157] = {n:"Martello Ksen",t:7,d:"Tempo fa questo martello era usato per far suonare la campana della chiesa di Amakna. Oggi serve per suonare, sì, sbriciolando le ossa degli imprudenti per esempio.",ep:19,g:49,l:124,wd:true,fm:true,w:15,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CI>250",p:29400};
I.u[7158] = {n:"Martello Lahr",t:7,d:"Concepito da un famoso Alchimista durante un soggiorno nella prigione di Brakmar, questo martello doveva servire per distruggere il materiale di alchimia dei suoi concorrenti.",ep:19,g:47,l:143,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CA>250&PG=5",p:46550};
I.u[7159] = {n:"Martello Pineta",t:7,d:"Questo martello da Minatore è utilizzabile come pala o piccone a seconda delle tue necessità. Il suo utilizzo nel giardinaggio è comunque sconsigliato perché ha la cattiva abitudine di distruggere in modo definitivo le aiuole.",ep:19,g:52,l:135,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>300",p:41200};
I.u[7160] = {n:"Arco Hanna",t:2,d:"Quest\'arco è stato incantato molto tempo fa con una magia molto oscura. Tanto oscura da preoccupare tanto i nemici quanto lo stesso proprietario.",ep:19,g:44,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CI>400&PG=9",p:36900};
I.u[7161] = {n:"Arc Assino",t:2,d:"Quest\'arco era utilizzato soprattutto per cacciare i Cinghiali delle Pianure. È infatti così potente che con una sola freccia può uccidere numerosi cinghialetti, a condizione che siano correttamente allineati.",ep:18,g:45,l:107,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CI>250&CA>150",p:29325};
I.u[7162] = {n:"Arco Rossi",t:2,d:"Quest\'arco apparteneva a un menestrello indipendente, famoso soprattutto per la capacità di distruggere le orecchie dei nemici con i suoi canti di guerra. Fu mandato in esilio a Pandala per molti anni, a causa dei canti che assordavano anche i Cuervoc di Brakmar. Dopo aver fatto impazzire numerose generazioni di Pandawa, fu consegnato vivo al grande Sorlok che lo digerì lentamente per oltre 752 anni. Che fine artistica!",ep:19,g:46,l:130,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,3,6,30,50,false,true],c:"CA>200&CC>70&PG=9",p:30000};
I.u[7163] = {n:"Arco Dissuasivo",t:2,d:"Quest\'arco era utilizzato prima di tutto come arma di dissuasione. Il proprietario raccontava a chi voleva ascoltarlo, che le sue frecce erano avvelenate, spaventando così la popolazione locale e facendo indietreggiare tutti i vigliacchi che si trovavano sulla sua strada.",ep:19,g:47,l:124,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"PG=9&CA>250",p:39050};
I.u[7164] = {n:"Arco Angelico",t:2,d:"Quest\'arco leggero e fragile seduce tutti gli avventurieri che apprezzano più l\'apparenza dell\'efficacia.",ep:19,g:48,l:143,wd:true,fm:true,w:15,an:10,e:[5,5,2,6,30,50,false,true],c:"CA>120&CI>120&CC>120&CV>300",p:46025};
I.u[7165] = {n:"Bacchetta Nah",t:3,d:"Questa bacchetta esplosiva è stata immersa nella lava di un vulcano in eruzione prima di essere intagliata e incantata. Non c\'è bisogno di descrivere la sua potenza, malgrado il ridicolo aspetto...",ep:18,g:54,l:105,wd:true,fm:true,w:15,an:11,e:[5,4,3,6,50,50,false,true],c:"CI>300",p:28625};
I.u[7167] = {n:"Bacchetta Cetera",t:3,d:"L\'artigiano che ha creato questa bacchetta aveva molti apprendisti che faceva lavorare tutta la giornata. Doveva insegnar loro le basi del mestiere, ma era un cattivissimo tutore... cominciava sempre le spiegazioni, ma non le finiva mai.",ep:18,g:50,l:43,wd:true,fm:true,w:5,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>60",p:5000};
I.u[7168] = {n:"Bacchetta Etilica",t:3,d:"Una volta intagliata, questa bacchetta è stata immersa nella birra per molti anni. Sta già marcendo ma conserva comunque ancora qualche proprietà magica, tanto quanto basta per divertire o sterminare i tuoi alleati.",ep:18,g:51,l:63,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150",p:4800};
I.u[7169] = {n:"Bacchetta Fiammella",t:3,d:"Ideale per accendere il fuoco, o ravvivare un po\' i matrimoni noiosi, questa bacchetta forse ti permetterà, una volta nella vita, di fare faville. Un\'occasione da non perdere.",ep:18,g:52,l:81,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>200",p:17000};
I.u[7170] = {n:"Bacchetta Mat-Cretien",t:3,d:"Mat il pasticcere fu così pazzo da sposarsi con la Taglialegna Cretien e soffocarla l\'indomani con i suoi dolci troppo grassi. Da allora si parla di \"roba da Mat\", per descrivere le cose più strambe.",ep:18,g:46,l:112,wd:true,fm:true,w:15,an:11,tw:true,e:[5,2,3,4,30,50,false,true],c:"CI>350&CV>200",p:32330};
I.u[7171] = {n:"Bacchetta Stordita",t:3,d:"L\'Intagliatore di questa bacchetta aveva la brutta abitudine di dimenticarsi i figli a scuola. Sua moglie, una madre indegna come tante altre, si divertiva quando succedeva. Cosciente di essere troppo stordito, intagliò questa bacchetta che, tutti i santi giorni, gli ricordava di andare a prendere i bambini. In seguito ha cercato di fare una bacchetta simile per ricordare a sua moglie di fare le pulizie, ma la bacchetta non fu mai abbastanza potente da riuscirci.",ep:19,g:47,l:127,wd:true,fm:true,w:15,an:11,tw:true,e:[10,4,4,6,40,60,false,true],c:"CI>300&CV>300",p:43125};
I.u[7172] = {n:"Bacchetta Rhon",t:3,d:"Ancora oggi questa bacchetta magica è usata per svuotare le fosse biologiche, svuotare i fossati e pulirsi il naso. Gli Intagliatori più esperti ti spiegheranno che tutta la sua magia viene proprio dall\'immondizia che tocca, soprattutto da quella presente nel tuo naso.",ep:18,g:49,l:105,wd:true,fm:true,w:20,an:11,tw:true,e:[10,4,2,4,30,60,false,true],c:"CI>200&CW>50",p:28375};
I.u[7173] = {n:"Bacchetta Strozzante",t:3,d:"Questa terribile bacchetta è capace di arrotolarsi attorno al collo degli avversari per strangolarli lentamente ma senza via di scampo. Un modo originale e chic per uccidere gli avversari che stimi un pochino.",ep:18,g:48,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,4,50,50,false,true],c:"CI>50",p:2100};
I.u[7174] = {n:"Mantello Pandawushu",t:17,d:"Questo mantello è indispensabile per l\'allenamento del Pandawushu...",ep:1,g:89,l:10,wd:true,fm:true,w:5,p:10};
I.u[7175] = {n:"Certificato sciamanico",t:24,d:"Certificato medico indispensabile per la pratica del Pandawushuka.",ep:18,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[7176] = {n:"Radice Cithy",t:4,d:"È stato un certo Intagliatore di bastoni di nome Frank a creare questa piccola meraviglia, capace di oscurare il cielo e di fare colare il sangue dei nemici senza sangue. Si dice che gli ci siano volute più di mille ore per intagliarla. Persino i tuoi nemici non potranno fare gli indifferenti.",ep:19,g:53,l:143,wd:true,fm:true,w:15,an:12,e:[10,4,1,1,45,70,false,false],c:"CS>150&CV>400&CI>50&CA>50",p:46600};
I.u[7177] = {n:"Fascia Pandawushu",t:16,d:"Con la fascia Pandawushu legata intorno alla testa, potrai sicuramente spaventare i piccoli Volpi, che ti scambieranno per un Maestro di arti marziali. Non dimenticare di lanciare anche qualche grido di guerra per essere più credibile.",ep:1,g:102,l:1,wd:false,fm:true,w:5,p:10};
I.u[7178] = {n:"Radice Ofrut",t:4,d:"Da molte generazioni i Sadida usano delle radici magiche come bastoni, eppure qualcuno si rifiuta ancora di utilizzare questa qui perché sembra più un frutto che una radice. Frutto o radice, che importa, fa malissimo laddove s\'infila, e questo è l\'essenziale.",ep:18,g:58,l:86,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,50,50,false,false],c:"CI>150",p:19100};
I.u[7179] = {n:"Strade e Sentieri: Foresta Maledetta",t:25,d:"Questo libro riunisce i migliori itinerari turistici da percorrere nel labirinto della foresta maledetta... Da avere assolutamente! Almeno da quello che dice la copertina.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7180] = {n:"",t:27,d:"",ep:1,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7181] = {n:"Radice Semilla",t:4,d:"Semilla era una giovane Sadidina appassionatissima di giardinaggio e anche di canto. Infatti per lei era fantastico poter raccogliere i pomodori anche sul palcoscenico, alla fine di uno dei suoi concerti...",ep:18,g:54,l:106,wd:true,fm:true,w:15,an:12,tw:true,e:[10,4,1,1,50,50,false,false],c:"CV>250&CW>60",p:28575};
I.u[7182] = {n:"Radice Hekuanone",t:4,d:"Hekuanon era proprio sfortunata, suo marito era un grosso fannullone, incapace di assumersi le proprie responsabilità di capofamiglia. Doveva sempre imporgli delle condizioni: \"Avrai la Gelatina Fragola quando avrai falciato i cereali\" o ancora \"Potrai fumare dei Fun Fung quando avrai tosato i Pappatutto\", per fare gli esempi più frequenti. Ma questa storia non ha assolutamente nessun rapporto con la potentissima radice in questione, a meno che anche lei, a forza di stare con la sua padrona, non vi imponga delle condizioni...",ep:18,g:60,l:103,wd:true,fm:true,w:15,an:12,tw:true,e:[15,4,1,1,25,50,false,false],c:"CV>200",p:27280};
I.u[7183] = {n:"Radice Inusyt",t:4,d:"Questa radice ha una forma pura, che alcuni artigiani considerano perfetta. Forse è proprio per questo che certi avventurieri vi si affezionano più che alla loro amata.",ep:18,g:55,l:88,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>70",p:20000};
I.u[7184] = {n:"Radice Taclisma",t:4,d:"Questa terribile radice è soprattutto conosciuta per la sua capacità di causare catastrofi climatiche nel luogo stesso in cui è usata. Evita quindi di usarla per picchiare il sedere dei tuoi avversari, non si sa mai quello che può capitare...",ep:18,g:56,l:86,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>100",p:18945};
I.u[7185] = {n:"Radice Danient",t:4,d:"Dovrebbe essere abbastanza semplice usare questa radice in combattimento. Talvolta però riprende vita e decide di fare di testa sua. È proprio in questi momenti che si può sentire il suo proprietario gridare: \"Accidenti, non è una Radice Danient!\"",ep:18,g:57,l:103,wd:true,fm:true,w:20,an:12,e:[5,5,1,1,50,50,false,false],c:"CV>200&CW>150",p:27425};
I.u[7186] = {n:"Passaggio di grado",t:24,d:"Su questo foglio c\'è scritta l\'ultima data del tuo passaggio di grado Pandawashuka.",ep:18,g:58,l:0,wd:true,fm:true,w:0,p:1};
I.u[7187] = {n:"Jakchir Arc",t:2,d:"Quest\'arco è famoso per rubare i soldi del popolo a distanza e senza farsi beccare. La cosa più sorprendente è che, nonostante il passare degli anni, è sempre più popolare. Fortunatamente per la gente, comincia a consumarsi un po\'.",ep:19,g:50,l:124,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,4,6,30,2,false,true],c:"CA>100&CC>100&PG=9",p:40000};
I.u[7188] = {n:"Daghe Rumi",t:5,d:"Queste daghe sono perfette per tagliare i frutti, o per tagliare l\'erba sotto i piedi dei tuoi avversari. Che modo originale di sorprenderli!",ep:18,g:48,l:113,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,35,50,false,false],c:"CA>100&CI>100",p:32575};
I.u[7189] = {n:"Rod Gers",t:4,d:"Questo strano bastone è una versione migliorata del celebre God Rod. Effettivamente, questo bastone è stato immaginato e fabbricato dopo i numerosi test del God Rod effettuati dalle Profetesse dell\'Amore. Questo modello è persino utilizzato da Kuri in persona, il che ne fa proprio un pezzo unico.",ep:19,g:59,l:176,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,100,false,false],c:"CI>450",p:57000};
I.u[7190] = {n:"Daghe Meydhyn China",t:5,d:"Queste sublimi daghe sono state fabbricate su misura da un\'Etramina in cerca di sensazioni forti. Infatti, delusa di non riuscire a trovare delle daghe che le convenissero, lanciò una sfida a tutti i Forgiatori di daghe di Amakna: colui che sarebbe riuscito a forgiare delle daghe capaci di uccidere in un colpo solo qualsiasi Tofu, avrebbe passato 3 notti in sua compagnia. Purtroppo la sfida non ebbe l\'effetto sperato, poiché nessuno vi partecipò e la ragazza dovette aspettare un centinaio d\'anni prima che un Forgiatore di daghe Anutrof in pensione si interessasse alla ricompensa che, nel frattempo, era parecchio cambiata...",ep:18,g:45,l:100,wd:true,fm:true,w:10,an:13,tw:true,e:[15,3,1,1,35,50,false,false],c:"CS>150&CA>150",p:21800};
I.u[7191] = {n:"Incastonatore di Ramug",t:5,d:"Ramug era un vecchio Etram diventato maestro nella fabbricazione dei gioielli. Usava questo incastonatore sia per le sue creazioni, sia per uccidere i propri clienti quando si annoiava troppo in negozio. Era conosciuto per il cattivissimo carattere che lo spingeva talvolta a distruggere le sue più belle creazioni. Oggi, coloro che utilizzano queste daghe continuano a rendergli omaggio, perché le usano quasi esclusivamente per tagliare i \"gioielli di famiglia\".",ep:19,g:49,l:127,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,30,false,false],c:"CA>200&CS>200",p:40825};
I.u[7192] = {n:"Artiglio di Musol Ungo",t:6,d:"Musol Ungo non è mai riuscito a usare correttamente questo artiglio. A forza di giocare a carte e agli altri giochi d\'azzardo bevendo birra, i suoi muscoli si sono atrofizzati. Su certe persone, questo tipo di piacere potrebbe atrofizzare anche altri organi.",ep:18,g:59,l:111,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>300&CA>120",p:31625};
I.u[7193] = {n:"Spada del Dark Vlad",t:6,d:"Solo il Dark Vlad in persona è capace di tirar fuori tutta la magia di questa spada, per renderla realmente sfavillante. Portandola, potrai mostrare con fierezza che non hai fatto la stessa fine di tutti gli altri ridicoli avventurieri che sono morti sotto i colpi della sua lama.",ep:19,g:61,l:126,wd:true,fm:true,w:20,an:14,e:[12,5,1,1,50,100,false,false],c:"CV>250&CI>300&PG=8",p:40625};
I.u[7194] = {n:"Arco Anum",t:2,d:"Quest\'arco è la prova che se la tecnologia e la magia collaborano insieme possono arrivare a ottimi risultati. Eppure, quest\'arco è stato rapidamente dimenticato, e per ragioni sconosciute. L\'artigiano che l\'ha costruito è stato addirittura costretto a chiudere bottega, scontentando parecchi dei suoi vecchi clienti.",ep:18,g:49,l:96,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"CI>200&CA>60&PG=9",p:23500};
I.u[7195] = {n:"Karnak",t:6,d:"Questa spada leggendaria è stata forgiata all\'alba da un esercito di Anutrof ubriachi, in fondo alle miniere di Grimoth. Emana un\'aura di potenza sorprendente, ma anche un forte odore di birra alterata.",ep:19,g:60,l:158,wd:true,fm:true,w:15,an:14,tw:true,e:[10,5,1,1,50,80,false,false],c:"CV>300&CA>300&PG=8",p:51100};
I.u[7196] = {n:"null",t:82,d:"",ep:0,g:34,l:1,wd:true,fm:true,w:1,p:1};
I.u[7197] = {n:"Martello Ciociok",t:7,d:"Questo martello serviva in origine per rompere le tavolette di cioccolato e farne della polvere. Di conseguenza nel corso degli anni si è impregnato di un odore e di un gusto deliziosi. Una ragione di più per farlo assaggiare ai tuoi nemici.",ep:19,g:53,l:150,wd:true,fm:true,w:100,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CI>150&CV>200&(PG=5|PG=2)",p:473751};
I.u[7198] = {n:"Rasoio della Sera",t:6,d:"Tutti i vecchi Anutrof te lo diranno: \"Una bella barba è una barba curata\". La sua lama è tagliente al punto giusto, e sarà ideale anche per le donne un po\' troppo pelose.",ep:18,g:62,l:106,wd:true,fm:true,w:15,an:14,e:[10,4,1,1,50,50,false,false],c:"CS>200&CA>100",p:28925};
I.u[7199] = {n:"Gladio Deno",t:6,d:"Questo gladio apparteneva a Metzger il Macellaio, che lo usava per recuperare rapidamente le viscere dei suoi nemici per farne carne da salsiccia da rivendere a prezzo economico sul mercato di Bonta.",ep:19,g:63,l:135,wd:true,fm:true,w:15,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>200&CA>120&CV>300",p:44225};
I.u[7200] = {n:"Sciabola del Shodanwa",t:6,d:"Questa magnifica sciabola è usata dai discepoli Pandawushuka che sono riusciti a raggiungere il grado Shodanwa senza essere morti.",ep:18,g:55,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>60",p:4300};
I.u[7201] = {n:"Sciabola del Nidanwa",t:6,d:"Questa magnifica sciabola è usata dai discepoli Pandawushuka che sono riusciti a raggiungere il grado Nidanwa senza essere morti.",ep:18,g:56,l:66,wd:true,fm:true,w:15,an:14,e:[10,5,1,1,50,50,false,false],c:"CA>80",p:11300};
I.u[7202] = {n:"Sciabola del Sandanwa",t:6,d:"Questa magnifica sciabola è usata dai discepoli Pandawushuka che sono riusciti a raggiungere il grado Sandanwa senza essere morti.",ep:18,g:57,l:83,wd:true,fm:true,w:10,an:14,e:[10,5,1,1,50,50,false,false],c:"CS>120",p:17800};
I.u[7203] = {n:"Sciabola del Yondanwa",t:6,d:"Questa magnifica sciabola è usata dai discepoli Pandawushuka che sono riusciti a raggiungere il grado Yondanwa senza essere morti.",ep:18,g:58,l:93,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,50,50,false,false],c:"CA>100",p:22175};
I.u[7204] = {n:"Bastone del Shodanwa",t:4,d:"Questo bastone è in generale usato dai discepoli Pandawushuka che hanno raggiunto il grado Shodanwa senza perdere l\'uso delle braccia.",ep:18,g:49,l:46,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,false],c:"CV>30&CW>10",p:5775};
I.u[7205] = {n:"Bastone del Nidanwa",t:4,d:"Questo bastone è in generale usato dai discepoli Pandawushuka che hanno raggiunto il grado Nidanwa senza perdere l\'uso delle braccia.",ep:18,g:50,l:62,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>100",p:10125};
I.u[7206] = {n:"Bastone del Sandanwa",t:4,d:"Questo bastone è in generale usato dai discepoli Pandawushuka che hanno raggiunto il grado Sandanwa senza perdere l\'uso delle braccia.",ep:18,g:51,l:80,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,30,50,false,false],c:"CA>100&CV>70",p:16700};
I.u[7207] = {n:"Bastone del Yondanwa",t:4,d:"Questo bastone è in generale usato dai discepoli Pandawushuka che hanno raggiunto il grado Yondanwa senza perdere l\'uso delle braccia.",ep:18,g:52,l:93,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>250",p:22500};
I.u[7208] = {n:"Ascia del Shodanwa",t:19,d:"Quest\'ascia è usata dai discepoli Pandawushuka che hanno raggiunto il grado Shodanwa. È molto pratica per radere al suolo le foreste di Bambù e tutto ciò che vi si nasconde.",ep:18,g:37,l:36,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:3550};
I.u[7209] = {n:"Ascia del Nidanwa",t:19,d:"Quest\'ascia è usata dai discepoli Pandawushuka che hanno raggiunto il grado Nidanwa. È molto pratica per radere al suolo le foreste di Bambù e tutto ciò che vi si nasconde.",ep:18,g:36,l:59,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],c:"CS>100&CV>50",p:9000};
I.u[7210] = {n:"Ascia del Sandanwa",t:19,d:"Quest\'ascia è usata dai discepoli Pandawushuka che hanno raggiunto il grado Sandanwa. È molto pratica per radere al suolo le foreste di Bambù e tutto ciò che vi si nasconde.",ep:18,g:35,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:17800};
I.u[7211] = {n:"Ascia del Yondanwa",t:19,d:"Quest\'ascia è usata dai discepoli Pandawushuka che hanno raggiunto il grado Yondanwa. È molto pratica per radere al suolo le foreste di Bambù e tutto ciò che vi si nasconde.",ep:18,g:34,l:98,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,50,50,false,false],c:"CI>150&CS>75&CV>85",p:24500};
I.u[7212] = {n:"La Tagliatrice di Bambù",t:19,d:"Leggera ed elegante, quest\'ascia ti permetterà di avanzare più facilmente nelle foreste di Bambù di Pandala, e di difenderti contro i Panditi più subdoli, sempre pronti ad attaccare i Taglialegna solitari per rubare i loro averi...",ep:18,g:33,l:26,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:2000};
I.u[7213] = {n:"Pala Rhon",t:8,d:"Questa pala dovrebbe tagliare l\'aria a una velocità incredibile. Coloro che sanno usarla correttamente ci tagliano soprattutto le teste dei loro nemici.",ep:19,g:41,l:142,wd:true,fm:true,w:15,an:16,tw:true,e:[10,5,1,1,40,70,false,false],c:"CC>400&CV>250",p:46050};
I.u[7214] = {n:"Sandali Mata",t:11,d:"Questi sandali appartenevano ai Mata, una tribù di Uginak oggi scomparsa. Questi ultimi erano molto vicini ai Pandawa, per questo con il passare delle generazioni il loro pelo cambiò colore diventando bianco a macchie nere. Alla fine furono tutti trasformati in mantelli da una crudelissima Sarta.",ep:18,g:59,l:30,wd:true,fm:true,w:10,p:2650};
I.u[7215] = {n:"Sandali Teladà",t:11,d:"Questi sandali erano usati da certe femmine Pandit per sedurre gli avventurieri persi ed attirarli in orribili trappole.",ep:19,g:60,l:121,wd:true,fm:true,w:20,p:37400};
I.u[7216] = {n:"Sandali Kolika",t:11,d:"Questi sandali erano dati ai Pandawa malati che avevano bisogno di correre molto veloce quando avevano contratto il virus della Pandrista o dopo una notte da sbornia alla taverna.",ep:18,g:61,l:58,wd:true,fm:true,w:10,p:8975};
I.u[7217] = {n:"Sandali M\'bicco",t:11,d:"I Pandawa sono sempre stati attirati dalle bevande alcoliche, imparando con il tempo a conservarle meglio e ad aromatizzarle. Per quanto riguarda questi sandali, sono fatti apposta per i Pandawa alcolizzati. Infatti sono zavorrati al livello della suola per permetterti di tenere il più possibile i piedi per terra.",ep:19,g:62,l:159,wd:true,fm:true,w:50,p:50800};
I.u[7218] = {n:"Sandali Din",t:11,d:"Din era un giovane Pandawa. Non era veramente un genio, ma era un grande collezionista di lampade!",ep:18,g:63,l:76,wd:true,fm:true,w:15,p:14900};
I.u[7219] = {n:"Sandali Luya",t:11,d:"Questi sandali erano affidati ai Pandit alla fine del rituale religioso. Oggi sono soprattutto usati durante i campionati di tip-tap.",ep:18,g:64,l:56,wd:true,fm:true,w:15,p:8200};
I.u[7220] = {n:"Biglietto della Lotteria",t:15,d:"Hai tra le mani un magnifico biglietto della lotteria, conservalo con cura, potresti essere il vincitore del grande sorteggio!",ep:1,g:717,l:2,wd:true,fm:true,w:1,p:1};
I.u[7221] = {n:"Collana di Tanukui San",t:1,d:"Questa collana è indossata dal Tanukui San fin dall\'infanzia, il che gli conferisce un valore ancora più grande, sapendo di cosa era già capace il Tanukui quando era un bambino.",ep:19,g:92,l:152,wd:true,fm:true,w:10,p:49030};
I.u[7222] = {n:"Artefatto Pandawushu Acqua",t:50,d:"Questo Artefatto magico è usato dai discepoli Pandawushu per incantare il loro equipaggiamento.",ep:1,g:104,l:1,wd:true,fm:true,w:1,p:1};
