I.u[7250] = {n:"Amuleto Aksadala",t:1,d:"Solo gli abitanti del villaggio di Aksadala avevano l\'autorizzazione ad indossare questo amuleto, che rappresenta uno degli elementi più importanti del loro costume tradizionale. Guardandolo da vicino, ci si chiede proprio il perché.",ep:18,g:79,l:41,wd:true,fm:true,w:2,s:34,p:5050};
I.u[7251] = {n:"Amuleto Terradala",t:1,d:"Solo gli abitanti del villaggio di Terradala avevano l\'autorizzazione ad indossare questo amuleto, che rappresenta uno degli elementi più importanti del loro costume tradizionale. Guardandolo da vicino, ci si chiede proprio il perché.",ep:18,g:80,l:80,wd:true,fm:true,w:10,s:36,p:16550};
