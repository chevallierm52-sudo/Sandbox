I.u[7279] = {n:"Pelle di Kitsù Nae",t:59,d:"Questa pelle di Kitsù Nae è di una qualità eccezionale, se tagliata a cordicelle potrebbe diventare una frusta eccellente. È il regalo ideale da offrire ai genitori di bambini un po\' troppo sfacciati.",ep:18,g:46,l:19,wd:true,fm:true,w:2,p:10};
I.u[7280] = {n:"Pelle di Kitsù Nufoc",t:59,d:"Questa pelle di Kitsù Nufoc è di una qualità eccezionale, se tagliata a cordicelle potrebbe diventare una frusta eccellente. È il regalo ideale da offrire ai genitori di bambini un po\' troppo sfacciati.",ep:18,g:44,l:111,wd:true,fm:true,w:2,p:10};
I.u[7281] = {n:"Pelle di Kitsù Nere",t:59,d:"Questa pelle di Kitsù Nere è di una qualità eccezionale, se tagliata a cordicelle potrebbe diventare una frusta eccellente. È il regalo ideale da offrire ai genitori di bambini un po\' troppo sfacciati.",ep:18,g:45,l:80,wd:true,fm:true,w:2,p:10};
I.u[7282] = {n:"Pelle di Kitsù Nakwa",t:59,d:"Questa pelle di Kitsù Nakwa è di una qualità eccezionale, se tagliata a cordicelle potrebbe diventare una frusta eccellente. È il regalo ideale da offrire ai genitori di bambini un po\' troppo sfacciati.",ep:1,g:43,l:60,wd:true,fm:true,w:2,p:10};
I.u[7283] = {n:"Pelle di Tanukui San",t:59,d:"Questa enorme pelle tesa di Tanukui San potrebbe diventare un eccellente borsello per i tuoi kama.",ep:1,g:2,l:85,wd:true,fm:true,w:2,p:100};
I.u[7284] = {n:"Peli di Tanukui San",t:54,d:"Questi peli di Tanukui San non sono profumatissimi, ma non importa, sono sempre dei peli di Tanukui San.",ep:1,g:3,l:85,wd:true,fm:true,w:2,p:100};
I.u[7285] = {n:"Zampa di Araknawa",t:103,d:"Questa piccola zampa continuerà a dimenarsi ancora per molto. Mettila nelle mutande dei tuoi nemici, gli farà perdere l\'equilibrio in pieno combattimento, e tu vincerai senza fatica.",ep:18,g:716,l:43,wd:true,fm:true,w:2,p:100};
I.u[7286] = {n:"Legno di Bambuto",t:38,d:"Il legno di Bambuto vale quasi tanto quanto quello del Culbuto, eppure è molto più facile da trovare... le leggi dell\'economia sono sempre più oscure.",ep:18,g:675,l:47,wd:true,fm:true,w:2,p:100};
I.u[7287] = {n:"Foglia di Bambuto",t:36,d:"Le foglie di Bambuto sono larghe e spesse, un po\' come le femmine Bwork, ma senza l\'aggressività.",ep:18,g:69,l:47,wd:true,fm:true,w:2,p:1};
I.u[7288] = {n:"Foglia di Bambuto Sacro",t:36,d:"Questa grossa foglia è così dura e pesante che potrebbe schiacciarti vivo se ti addormentassi sotto un Bambuto Sacro in autunno.",ep:18,g:68,l:120,wd:true,fm:true,w:2,p:100};
I.u[7289] = {n:"Legno di Bambuto Sacro",t:38,d:"Questo legno non deve finire nelle mani sbagliate, ma nessuno sa ancora perché.",ep:18,g:674,l:120,wd:true,fm:true,w:10,p:100};
I.u[7290] = {n:"Radice Magica di Bambuto",t:98,d:"Questa radice permette al Bambuto di tirar fuori tutta la sua magia dalla terra prima di combattere.",ep:18,g:100,l:20,wd:true,fm:true,w:2,p:10};
I.u[7291] = {n:"Radice Magica di Bambuto Sacro",t:98,d:"Questa radice permette al Bambuto Sacro di tirar fuori tutta la sua magia dalla terra prima di combattere.",ep:18,g:99,l:87,wd:true,fm:true,w:2,p:100};
I.u[7292] = {n:"Peli di Maho Focopaz",t:54,d:"Questi peli sono di un Maho Focopaz, una spaventosa creatura dal misero aspetto, che nasconde però terribili poteri magici.",ep:18,g:202,l:150,wd:true,fm:true,w:2,p:1};
I.u[7293] = {n:"Peli di Soryo Focopaz",t:54,d:"Questi peli sono di una creaturina rossa molto maliziosa, come tante altre d\'altronde...",ep:18,g:203,l:130,wd:true,fm:true,w:10,p:1};
I.u[7294] = {n:"Peli di Yokai Focopaz",t:54,d:"Questi peli spessi e puzzolenti sono stati strappati con forza e determinazione dal sedere di un\'orribile creatura rossa.",ep:18,g:204,l:110,wd:true,fm:true,w:10,p:10};
I.u[7295] = {n:"Peli di Pandora",t:54,d:"Questi peli misteriosi permettono in generale di tessere dei mantelli o dei cappelli magici dagli effetti inaspettati.",ep:18,g:2,l:200,wd:true,fm:true,w:10,p:200};
I.u[7297] = {n:"Peli di Pandulo",t:54,d:"Questi peli magici sono abbastanza potenti da ridare vita a un orologio rotto.",ep:18,g:206,l:150,wd:true,fm:true,w:1,p:1};
I.u[7298] = {n:"Pelle di Maho Focopaz",t:59,d:"Questa pelle liscia e fine offre un\'eccellente protezione contro gli attacchi magici che il Maho Focopaz incontra quando i suoi incantesimi gli si rivoltano contro.",ep:18,g:42,l:150,wd:true,fm:true,w:1,p:100};
I.u[7299] = {n:"Pelle di Soryo Focopaz",t:59,d:"Questa pelle era usata per cucire le mutande dei bambini con la pelle sensibile. Le mutande in pelle di Soyo Focopaz sono approvate dalla discendenza del Capitano Chafer.",ep:18,g:38,l:130,wd:true,fm:true,w:1,p:100};
I.u[7300] = {n:"Pelle di Yokai Focopaz",t:59,d:"Questa pelle spessa offre un\'eccellente protezione contro i colpi di Bambù.",ep:18,g:37,l:110,wd:true,fm:true,w:1,p:100};
I.u[7301] = {n:"Pelle di Leopardo",t:59,d:"Tempo fa questa pelle era usata dai Pandawa per fabbricare della biancheria leggera e minimalista.",ep:18,g:36,l:40,wd:true,fm:true,w:1,p:10};
I.u[7302] = {n:"Pelle di Pandora",t:59,d:"La pelle di Pandora ti sorprenderà molto se sei un Ciabattino.",ep:18,g:1,l:200,wd:true,fm:true,w:10,p:100};
I.u[7303] = {n:"Pelle di Pandulo",t:59,d:"Questa pelle rugosa cambia colore di ora in ora.",ep:18,g:39,l:100,wd:true,fm:true,w:1,p:10};
I.u[7304] = {n:"Stoffa di Maho Focopaz",t:55,d:"Questa stoffa magica di colore rosso è impregnata di una magia strapotente. Non si può dire la stessa cosa di te.",ep:18,g:11,l:150,wd:true,fm:true,w:1,p:100};
I.u[7305] = {n:"Stoffa di Soryo Focopaz",t:55,d:"Questa stoffa di modeste dimensioni è perfetta per tappare i buchi delle vecchie porte, quando l\'inverno arriva.",ep:18,g:10,l:130,wd:true,fm:true,w:1,p:10};
I.u[7306] = {n:"Stoffa di Yokai Focopaz",t:55,d:"Questa stoffa è fatta con le parti più sensibili del Fantasma Yokai Focopaz, che sono anche le più maleodoranti. Molti avventurieri pensano che si tratti dei suoi baffi, ma si sbagliano...",ep:18,g:9,l:110,wd:true,fm:true,w:1,p:10};
I.u[7307] = {n:"Stoffa di Pandora",t:55,d:"Questa stoffa è tanto rara quanto una bella sorpresa nella scatola di Pandora.",ep:18,g:125,l:200,wd:true,fm:true,w:10,p:10};
I.u[7308] = {n:"Stoffa di Pandulo",t:55,d:"Contrariamente a quello che si pensa, questa stoffa non si può mangiare. Le ultime persone che hanno cercato di cucinarla si sono trasformate in Tanukui San. Una fortuna per alcune di loro.",ep:18,g:12,l:100,wd:true,fm:true,w:1,p:10};
I.u[7309] = {n:"Chiave dei Pandikaze",t:84,d:"Questa chiave permette di entrare nel dongione dei Pandikaze. Attenzione: si autodistruggerà dopo l\'uso.",ep:13,g:229,l:1,wd:true,fm:true,w:1,p:100};
I.u[7310] = {n:"Chiave della caverna dei Bulbi",t:84,d:"Questa chiave ti permette di entrare nella caverna dei Bulbi.\nAttenzione: si autodistruggerà dopo l\'uso.",ep:1,g:230,l:1,wd:true,fm:true,w:1,p:100};
I.u[7311] = {n:"Chiave del Dongione dei Kitsun",t:84,d:"Questa chiave ti permette di entrare nel Dongione dei Kitsun. Attenzione: si autodistruggerà dopo l\'uso.",ep:1,g:231,l:1,wd:true,fm:true,w:1,p:100};
I.u[7312] = {n:"Chiave del Dongione dei Focopaz",t:84,d:"Questa chiave ti permette di entrare nel Dongione dei Focopaz. Attenzione: si autodistruggerà dopo l\'uso.",ep:2,g:232,l:1,wd:true,fm:true,w:1,p:100};
I.u[7313] = {n:"L\'arte Pandawushu",t:25,d:"Si tratta di un libro che tutti i praticanti di Pandawushu dovrebbero conoscere a menadito...",ep:18,g:19,l:1,wd:true,fm:true,w:2,u:true,p:1};
