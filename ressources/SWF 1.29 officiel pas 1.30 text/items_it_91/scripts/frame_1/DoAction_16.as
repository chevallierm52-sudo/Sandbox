I.u[7238] = {n:"Cintura Aksadala",t:10,d:"Le Pandawa del villaggio di Aksadala hanno sempre voluto avere la vita piccola. Stringendo al massimo questa cintura, dovresti arrivare allo stesso risultato.",ep:18,g:76,l:41,wd:true,fm:true,w:2,s:34,p:4600};
