I.u[6948] = {n:"Scarantura Verde",t:10,d:"Tempo fa la Scarantura serviva per indicare il tuo livello nel combattimento a mani nude. La Scarantura verde significava che eri un debuttante, la rossa che leccavi il sangue dei tuoi nemici dopo averli uccisi, la bianca che eri una vera macchina di morte per gli avversari, e la blu significava che non avevi abbastanza kama per comprarti una delle altre tre cinture.",ep:3,g:67,l:46,wd:true,fm:true,w:2,s:27,p:5600};
I.u[6949] = {n:"Scarantura Bianca",t:10,d:"Tempo fa la Scarantura serviva per indicare il tuo livello nel combattimento a mani nude. La Scarantura verde significava che eri un debuttante, la rossa che leccavi il sangue dei tuoi nemici dopo averli uccisi, la bianca che eri una vera macchina di morte per gli avversari, e la blu significava che non avevi abbastanza kama per comprarti una delle altre tre cinture.",ep:3,g:69,l:46,wd:true,fm:true,w:2,s:29,p:5600};
I.u[6950] = {n:"Scarantura Rossa",t:10,d:"Tempo fa la Scarantura serviva per indicare il tuo livello nel combattimento a mani nude. La Scarantura verde significava che eri un debuttante, la rossa che leccavi il sangue dei tuoi nemici dopo averli uccisi, la bianca che eri una vera macchina di morte per gli avversari, e la blu significava che non avevi abbastanza kama per comprarti una delle altre tre cinture.",ep:3,g:68,l:46,wd:true,fm:true,w:2,s:28,p:5600};
I.u[6951] = {n:"Scarantura Blu",t:10,d:"Tempo fa la Scarantura serviva per indicare il tuo livello nel combattimento a mani nude. La Scarantura verde significava che eri un debuttante, la rossa che leccavi il sangue dei tuoi nemici dopo averli uccisi, la bianca che eri una vera macchina di morte per gli avversari, e la blu significava che non avevi abbastanza kama per comprarti una delle altre tre cinture.",ep:3,g:70,l:46,wd:true,fm:true,w:2,s:30,p:5600};
I.u[6952] = {n:"Copricapo del Buulupo",t:16,d:"Con questa copricapo di Buulupo sulla testa, assomiglierai a Dodo Gudunyo, l\'illustre menestrello la cui testa fu ritrovata incastrata nella bocca di un Buulupo che stava agonizzando per le canzoni che il menestrello aveva tentato di cantare.",ep:1,g:131,l:61,wd:true,fm:true,w:4,s:32,p:10000};
I.u[6953] = {n:"Stivaletti del Buulupo",t:11,d:"Questi stivaletti ricoperti di peli di Buulupo sono molto pratici per pulire i parquet polverosi, o semplicemente per pulire la testa degli avversari mentre stramazzano a terra agonizzanti.",ep:1,g:76,l:61,wd:true,fm:true,w:2,s:32,p:9700};
I.u[6954] = {n:"Mantello del Buulupo",t:17,d:"Questa pelle di Buulupo è una protezione eccellente contro il freddo, ma anche contro gli avventurieri dall\'olfatto un po\' troppo sviluppato.",ep:1,g:99,l:64,wd:true,fm:true,w:5,s:32,p:11000};
I.u[6955] = {n:"Perizoma del Buulupo",t:10,d:"Usato come frusta, questo perizoma è molto più efficace di quanto sembri. Puoi usarlo per motivare i tuoi compagni d\'avventura quando l\'amore per il rischio comincia a indebolirsi.",ep:1,g:92,l:49,wd:true,fm:true,w:2,s:32,p:6500};
I.u[6956] = {n:"Anello del Buulupo",t:9,d:"Attenzione, questo anello renderà il tuo dito particolarmente puzzolente... Un odore che ne coprirà sicuramente un altro. Effettivamente, per il tuo dito e per i tuoi amici, potrebbe essere una fortuna!",ep:1,g:103,l:51,wd:true,fm:true,w:2,s:32,p:7000};
I.u[6957] = {n:"Lama del Croccaroc",t:6,d:"Tempo fa questa spada serviva a tagliare i blocchi di granito per costruire le mura delle città prestigiose come Bonta o Brakmar. Oggi, quest\'arma è prima di tutto ricercata per la sua capacità di schiacciare qualsiasi tipo di creatura vivente, consenziente o no.",ep:5,g:54,l:37,wd:true,fm:true,w:10,an:14,tw:true,e:[5,6,1,1,50,50,false,true],s:26,p:3800};
I.u[6958] = {n:"Genialissimo Copricapo di Tort\' Hu",t:16,d:"Appena appena fuori moda, questo copricapo ti darà uno stile unico e ti permetterà soprattutto di guardare sotto le gonne delle Ocraine senza farti vedere. È l\'ideale per le serate d\'estate un po\' alcoliche.",ep:5,g:82,l:22,wd:true,fm:true,w:12,p:1525};
I.u[6961] = {n:"Anello del Bandito",t:9,d:"Questo anello è molto popolare tra i banditi, ma anche tra i dentisti che lo usano per rompere i denti degli imprudenti. Insomma, un modo come un altro per prevenire le carie.",ep:1,g:77,l:17,wd:true,fm:true,w:2,s:25,p:1000};
I.u[6962] = {n:"Regalo di Dofus",t:89,d:"Buon Nawal! Non ti riveleremo mai il contenuto di questo regalo, ma sappi che ti darà la possibilità di divertirti e far festa. Nei giorni di festa, ci vuole proprio un regalo così.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6963] = {n:"Palle del Minotobul",t:12,d:"Queste enormi palle sono veramente deliziose. E sono sempre in paio.",ep:1,g:143,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6964] = {n:"Pozione di città: Brakmar",t:12,d:"Questa pozione a base di riso permette a tutte le persone di schieramento Brakmariano di raggiungere istantaneamente la città di Brakmar.",ep:1,g:145,l:1,wd:true,fm:true,w:1,c:"Ps=2|Ps=0|Ps=3",u:true,p:1};
I.u[6965] = {n:"Pozione di città: Bonta",t:12,d:"Questa pozione a base di riso permette a tutte le persone di schieramento Bontariano di raggiungere istantaneamente la città di Bonta.",ep:1,g:144,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=0|Ps=3",u:true,p:1};
I.u[6966] = {n:"Pergamena di Incantesimo Speciale Iella",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permette d\'imparare l\'incantesimo Iella... Riservato solo agli Etram. ",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"PG=4",u:true,p:10000};
I.u[6967] = {n:"Pergamena di Intronizzazione del Mercenario Apprendista",t:14,d:"Questa pergamena è la chiave che permette ad un Mercenario di essere promosso Apprendista.",ep:1,g:5,l:1,wd:false,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6968] = {n:"Pergamena di Intronizzazione presso i Mercenari",t:14,d:"Questa pergamena è la chiave che permette ad un Mercenario di essere definitivamente promosso Mercenario.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6969] = {n:"Pergamena di Intronizzazione del Grande Mercenario",t:14,d:"Questa pergamena è la chiave che permette ad un Mercenario di essere promosso Grande Mercenario.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6970] = {n:"Pergamena di Intronizzazione del Maestro Mercenario",t:14,d:"Questa pergamena è la chiave che permette ad un Mercenario di essere promosso Maestro del Clan dei Mercenari.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6971] = {n:"Clint del Discepolo Mercenario",t:16,d:"Questo Cappello è una valida copia del celebre Clint ed è adatto soprattutto per i Discepoli Mercenari che vorranno farsi passare per il Maestro.",ep:1,g:38,l:1,wd:false,fm:true,w:20,c:"Ps=3",p:1};
I.u[6975] = {n:"Clint del Mercenario Neofita",t:16,d:"Questo Cappello superpotente è l\'insegna dei Mercenari. Ha il potere di proteggere dalla pioggia e dal sole... ed è già qualcosa.",ep:1,g:38,l:1,wd:false,fm:true,w:20,p:1};
I.u[6978] = {n:"Peki",t:18,d:"Vista da lontano questa creatura sembra un Baubau. La sua testa mostra chiaramente numerosi traumi che l\'hanno spinta a diventare vegetariana. Si nutre solo di verdura e piante che crescono sull\'isola di Pandala.",ep:3,g:12,l:60,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6979] = {n:"",t:17,d:"",ep:1,g:59,l:50,wd:false,fm:true,w:10,p:5000};
I.u[6980] = {n:"Dofus Vulbis",t:23,d:"Questo Dofus è stato posto da un drago che ha deciso di restare anonimo. Gli avventurieri più curiosi si domandano ancora perché.",ep:11,g:4,l:6,wd:false,fm:true,w:1,p:500000};
I.u[6981] = {n:"Daghe Cyata",t:5,d:"La lama di queste daghe è di ghiaccio e può rinfrescare l\'alito dei tuoi nemici. Per farlo, aprigli la bocca, infilaci la tua grossa daga ghiacciata e il gioco è fatto.",ep:19,g:44,l:150,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>150",p:15};
I.u[6982] = {n:"Daga Onia",t:5,d:"Queste daghe sono state immerse nel sangue di numerose creature demoniache agonizzanti, il che gli conferisce una grande esperienza nel campo della tortura.",ep:18,g:50,l:46,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5775};
I.u[6983] = {n:"Daghe Ressive",t:5,d:"Anche se affilate una sola volta ogni decennio, queste daghe restano pericolosissime e mortali. Animate da una magia molto oscura, riescono a spostarsi da sole di notte per andare a infilarsi, nel migliore dei casi, nel sedere dei più imprudenti... Ecco un\'altra storia che si racconta ai giovani Yop per fargli paura.",ep:19,g:47,l:143,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>250&CA>100",p:15};
I.u[6984] = {n:"Daghe dell\'Apprendista Ammazza-Pappatutto",t:5,d:"Queste daghe appartenevano a un povero Sadida la cui incredibile ascesa rimarrà nella storia di Amakna. Egli aveva dedicato la sua esistenza alla caccia dei Pappaton, ricevendo così lo scherno di tutti gli abitanti del villaggio. Certa gente veniva persino da lontano per guardarlo cacciare quelle ridicole creature e prenderlo in giro. La sua vendetta fu terribile, perché nel frattempo era diventato talmente ricco da poter mettere una taglia su tutte le brutte teste che si erano prese gioco di lui.",ep:18,g:46,l:113,wd:true,fm:true,w:15,an:13,tw:true,e:[5,3,1,1,25,50,false,false],c:"CS>300&CA>100",p:32750};
I.u[6986] = {n:"Scudo del Monte Kepuz spezzato",t:82,d:"Questo valoroso scudo ha vissuto troppe battaglie e non serve più a nulla in queste condizioni. Forse Scudawa, al villaggio Pandala, potrà cambiartelo.",ep:18,g:1,l:1,wd:false,fm:true,w:20,c:"BI=non équipable",p:5400};
I.u[6987] = {n:"Piccola Pietra di Anima Temeraria",t:83,d:"Questa pietra offre una piccola possibilità di catturare delle anime di piccole dimensioni...",ep:5,g:1,l:1,wd:false,fm:true,w:1,tw:true,p:1250};
I.u[6988] = {n:"Sulik",t:16,d:"Un tempo indossato da uno Xelor selvaggio la cui sorella era stata rapita da schiavisti senza scrupoli, questo sontuoso cappello farà di te un selvaggio veramente originale.",ep:19,g:92,l:172,wd:true,fm:true,w:10,p:56100};
I.u[6989] = {n:"Krokop",t:16,d:"Questo cappello è stato fabbricato molto tempo fa da un apprendista Sarto che voleva proteggersi dalle grida di rabbia di Mirko il Sarto. Quest\'ultimo aveva la cattiva abitudine di decimare a calci in testa gli apprendisti che non lavoravano abbastanza velocemente. Un modo come un altro per spingerli a essere più rapidi.",ep:19,g:86,l:120,wd:true,fm:true,w:20,p:37025};
I.u[6990] = {n:"Falenas",t:16,d:"Questo copricapo è un omaggio ai lontani cugini dei Moskito, le Falenas. Più grosse ma più docili dei Moskito, le Falenas avevano la brutta abitudine di volersi riprodurre con qualsiasi cosa e con chiunque, ma soprattutto con qualsiasi cosa... vizio che le ha condotte all\'estinzione. Questa terribile storia aveva colpito l\'opinione pubblica, tanto che ancora oggi si usa l\'insulto di Falenas per i giovani avventurieri che hanno scelto molto male il loro coniuge.",ep:19,g:87,l:113,wd:true,fm:true,w:10,p:32925};
I.u[6991] = {n:"Goyave",t:16,d:"Questo strano copricapo assomiglia a un grosso frutto disidratato e in decomposizione, un po\' come te dopo una serata passata alla taverna.",ep:18,g:88,l:46,wd:true,fm:true,w:10,p:5800};
I.u[6992] = {n:"Kannipìu",t:16,d:"Versione abbellita della celebre maschera Kannibul, il Kannipìu ti farà sembrare agli occhi dei tuoi amici un vero e proprio Cacciatore di Pìu.",ep:12,g:89,l:55,wd:true,fm:true,w:5,p:8000};
I.u[6993] = {n:"Mantello Tonì",t:17,d:"Littol Tonì era un celebre menestrello che adorava cantare fino a perdere la voce. Fu bruciato vivo vicino alla banca di Bonta dopo aver scandalizzato la città con la canzone: \"Friggerà, friggerà, friggerà, tu falla friggere perchè...\".",ep:18,g:79,l:46,wd:true,fm:true,w:10,p:5600};
I.u[6994] = {n:"Mantello Berretto",t:17,d:"Questa creazione ibrida tra un berretto e un mantello è strabiliante. Se fosse stata di cuoio il Capitano Chafer l\'avrebbe adorata.",ep:1,g:80,l:58,wd:true,fm:true,w:10,p:8875};
I.u[6995] = {n:"Mantello Kaput",t:17,d:"Questo mantello molto potente ha rivoltato più di un avventuriero imprudente che ha cercato di indossarlo, una caratteristica condivisa con la Mummia Nova.",ep:18,g:81,l:105,wd:true,fm:true,w:10,p:28300};
I.u[6996] = {n:"Anello Stradamus",t:9,d:"Stradamus era un vecchio Anutrof completamente ciucco che leggeva l\'avvenire nelle pinte di birra. La leggenda racconta che sia sepolto in verticale in uno dei muri della taverna di Brakmar, in modo che \"nessun imbecille versasse la birra sulla sua tomba\". Il genere di leggenda raccontata durante le bevute organizzate dai Maestri Seriani.",ep:18,g:78,l:48,wd:true,fm:true,w:5,p:6075};
I.u[6997] = {n:"Anello Fiuturo",t:9,d:"Colei che ha creato questo anello pensava che la fine del mondo fosse vicina, infatti trascorreva le sue giornate a incidere sulle tavole di legno che non c\'era più futuro per gli abitanti di Amakna. Gli avvenimenti che seguirono la presero in contropiede.",ep:18,g:79,l:70,wd:true,fm:true,w:5,p:12730};
I.u[6998] = {n:"Fede di Elya Wood",t:9,d:"Questa piccola fede si adatta benissimo alle piccole dita degli Aniripsa. È però assolutamente inutilizzabile per le grosse dita salsicciose degli Yop... nonché per la loro incapacità di capire dove si infili una fede.",ep:18,g:84,l:120,wd:true,fm:true,w:15,s:39,p:36000};
I.u[6999] = {n:"Medaglia Lahilama",t:1,d:"Lahilama era un grande capo spirituale che officiava nel profondo delle montagne. Si annoiava talmente che passava le giornata a cucire cappelli gialli per i discepoli. La follia non conosce limiti.",ep:18,g:83,l:31,wd:true,fm:true,w:3,p:2800};
I.u[7000] = {n:"Bambamuleto",t:1,d:"Questo ridicolo pezzetto di bambù è dotato di poteri magici molto particolari. Tempo addietro era portato dai giovani Pandawa, ma solo dopo la pubertà. Forse dovresti aspettare ancora qualche anno prima di mettertelo intorno al collo...",ep:18,g:78,l:40,wd:true,fm:true,w:5,p:4400};
I.u[7001] = {n:"Talismano del Falciatore d\'Avena",t:1,d:"\"Una terra promessaaaaa... Un mondo diversooooo...\". Ecco cosa cantava a squarciagola tornando dalle vacanze passate sull\'isola di Moon, Errios, il celebre menestrello Contadino, famoso per battere l\'Avena cantando.",ep:18,g:84,l:55,wd:true,fm:true,w:10,p:8000};
I.u[7002] = {n:"La Resinetta",t:1,d:"Questo amuleto fatto di resina di Bambù diffonderà un buon profumo tutto intorno a te. È molto utile per nascondere le tue prove di Venti di Panico.",ep:18,g:85,l:94,wd:true,fm:true,w:5,p:22800};
I.u[7003] = {n:"Talismano di Elya Wood",t:1,d:"Questo Talismano è stato fabbricato con della polvere di stelle e di pietre preziose, prese nell\'ambra di un Alberagno Ancestrale. Essendo questo miscuglio alquanto esplosivo, ti sconsigliamo di provare a fabbricarne uno da te, lascialo fare a un Orefice che ti sta antipatico.",ep:18,g:86,l:135,wd:true,fm:true,w:10,s:39,p:45600};
I.u[7004] = {n:"Media Pietra di Anima Temeraria",t:83,d:"Questa pietra offre una piccola possibilità di catturare delle anime relativamente importanti...",ep:5,g:8,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7005] = {n:"Grande Pietra di Anima Temeraria",t:83,d:"Questa pietra offre una buona possibilità di catturare anime particolarmente feroci...",ep:5,g:9,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7006] = {n:"Enorme Pietra di Anima temeraria",t:83,d:"Questa pietra offre una buona possibilità di catturare anime particolarmente colossali...",ep:16,g:10,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7007] = {n:"Piccola Pietra di Anima",t:83,d:"Questa pietra offre una piccola possibilità di catturare delle anime di piccole dimensioni...",ep:5,g:2,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7008] = {n:"Media Pietra di Anima",t:83,d:"Questa pietra offre una piccola possibilità di catturare delle anime relativamente elevate...",ep:5,g:12,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7009] = {n:"Grande Pietra di Anima",t:83,d:"Questa pietra offre una buona possibilità di catturare anime particolarmente feroci...",ep:16,g:13,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7010] = {n:"Pietra di Anima Piena",t:85,d:"Questa Pietra di Anima contiene le anime di un gruppo di mostri che chiedono solo di tornare in vita per vendicarsi di te. Tuttavia è utilizzabile solo nelle arene previste a questo scopo, situate nelle grandi città.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7011] = {n:"Mantello del Desiderio O\'Bul",t:17,d:"Questo mantello quasi vivente di peli di barba rossa è unico nel suo genere. Animato da una magia straordinaria, tende a fare numerosi scherzi al padrone, nascondendosi sempre quando più c\'è bisogno di lui. Fortunatamente compensa questi dispetti con una potenza senza eguali in combattimento, che secondo certi Wabbit fa di lui \"una vewa e pwopwia macchina da guewwa!\".",ep:13,g:83,l:67,wd:false,fm:true,w:10,s:38,p:11875};
I.u[7012] = {n:"L\' Aschell O\'Bul",t:1,d:"Questo amuleto è in realtà una ghiottoneria. Potrebbe addirittura essere mangiato, se per 36 generazioni non fosse stato arrotolato sotto le ascelle di un\'orda di femmine Bwork in calore.",ep:7,g:87,l:77,wd:true,fm:true,w:10,s:38,p:15425};
I.u[7013] = {n:"Legno di Bambù",t:38,d:"Al contrario della canna, il bambù si piega e si rompe. Fortunatamente sono piuttosto i denti degli avventurieri incoscienti che si rompono sotto i colpi del bambù. Talvolta persino la natura si mette al servizio dei dentisti senza scrupoli.",ep:18,g:673,l:50,wd:true,fm:true,w:5,p:0};
I.u[7014] = {n:"Legno di Bambù Sacro",t:38,d:"Anche se non si direbbe, questo legno è sacro. Solo i migliori Pandawa possono tagliare questo legno, ma capita talvolta che i turisti Taglialegna in visita sull\'isola di Pandala ripartano con un souvenir del loro viaggio. Si parla allora di \"benedetti turisti!\".",ep:18,g:671,l:100,wd:true,fm:true,w:5,p:0};
I.u[7015] = {n:"Germogli di Bambù",t:38,d:"Questi germogli di Bambù non sono buoni da mangiare perché non hanno proprio nessun sapore. Si consiglia, quindi, di falciarli con una falce arrugginita o di lasciarli macerare qualche anno nel succo di Glutovora prima di servirli ai tuoi amici. L\'ennesimo trucco preso in prestito da ristoratori poco scrupolosi e pronti a tutto per farti ingoiare qualsiasi schifezza.",ep:1,g:676,l:50,wd:true,fm:true,w:2,p:5};
I.u[7016] = {n:"Legno di Bambù Oscuro",t:38,d:"Un giorno Galthuz, un giovane Pandawa, chiese a suo padre: \"Qual è la differenza tra il Bambù e il Bambù Oscuro, papà?\". Si prese una meritatissima sculacciata per aver fatto una domanda tanto stupida. Tutti sanno che la differenza tra il Bambù e il Bambù Oscuro risiede nella dimensione dei loro semi.",ep:18,g:672,l:60,wd:true,fm:true,w:5,p:0};
I.u[7017] = {n:"Legno di Bambù Dorato",t:38,d:"Un giorno Galthuz, un giovane Pandawa, chiese a suo padre: \"Qual è la differenza tra il Bambù e il Bambù Dorato, papà?\". Si prese una meritatissima sculacciata per aver fatto una domanda tanto stupida. Tutti sanno che la differenza tra il Bambù e il Bambù Dorato risiede nella dimensione della loro radice.",ep:18,g:669,l:45,wd:true,fm:true,w:5,p:20};
I.u[7018] = {n:"Riso",t:34,d:"Anche se molto appiccicoso, il riso ha sempre avuto un grandissimo successo tra i giovani Pandawa affamati.",ep:18,g:10,l:20,wd:true,fm:true,w:2,p:0};
I.u[7020] = {n:"Fiore di Loto",t:38,d:"Si dice che sia il più vecchio fiore mai conosciuto, simboleggia la fecondità, ma anche il distacco, perché a volte emerge dalle acque senza bagnarsi.\nAlcuni capi Pandawa si servono di questo simbolo per fare capire ai fedeli che devono vivere in questo mondo senza affezionarsi troppo.",ep:1,g:141,l:30,wd:true,fm:true,w:1,p:2};
I.u[7022] = {n:"Bastone del Sangrokù",t:4,d:"Questo bastone apparteneva al nonno di Sangrokù, Sangrokan, famoso per la sua presunzione. La leggenda racconta che questo bastone magico fosse capace di allungarsi per raggiungere qualsiasi nemico o, semplicemente, per compensare certi complessi di inferiorità.",ep:18,g:47,l:120,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,50,60,false,false],c:"CA>250&CV>300",p:36620};
I.u[7023] = {n:"Pietra di Acquamarina",t:51,d:"Si trova in generale nei dintorni dell\'isola Pandala. I Pandawa raccontano che questa pietra è dotata di poteri particolari. Tutti ne parlano, ma nessuno li ha ancora scoperti. Un po\' come gli Yop intelligenti...",ep:1,g:75,l:60,wd:true,fm:true,w:5,p:600};
I.u[7024] = {n:"Pietra di Topazio",t:51,d:"Questa strana pietra serviva tempo fa per nutrire i giovani Croccabul di alcuni allevatori di Pandala. Ora queste pietre sono diventate rarissime, ed è vietato darle da mangiare ai Croccabul.",ep:5,g:76,l:70,wd:true,fm:true,w:5,p:700};
I.u[7025] = {n:"Pietra d\'Agata",t:51,d:"Questa pietra prende il nome da un fiume di Pandala in cui si trovava in abbondanza. Ma i tempi sono cambiati e lo sfruttamento intensivo di questi giacimenti l\'ha resa quasi introvabile.",ep:5,g:128,l:80,wd:true,fm:true,w:5,p:1};
I.u[7026] = {n:"Acquamarina",t:50,d:"Questa pietra preziosa trasparente e a volte leggermente azzurrognola, è così brillante che, portata al collo, permette di nascondere le rughe più marcate. D\'altronde i Pandawa gridano sempre ai turisti: \"Fai felice la tua amata con l\'Acquamarina, e accetta più facilmente le insidie del tempo che la colpiscono\". Un buon metodo di prendere due piccioni con una... pietra!",ep:1,g:101,l:60,wd:true,fm:true,w:5,p:600};
I.u[7027] = {n:"Topazio",t:50,d:"Molto apprezzata dagli Orefici per ragioni non ancora chiare, questa pietra preziosa è sicuramente utilissima per attirare l\'attenzione dei Cuervoc in mezzo alle Pianure di Cania.",ep:5,g:102,l:70,wd:true,fm:true,w:5,p:700};
I.u[7028] = {n:"Agata",t:50,d:"Questa pietra prende il nome da una potente femmina Pandawa, conosciuta con il nome di Agata Zhamp e nota soprattutto nei luoghi poco raccomandabili, come il bar dei Pirati di Sufokia per esempio, dove ha passato i suoi ultimi anni ballando incatenata a un grosso albero piantato in mezzo al bar.",ep:5,g:103,l:80,wd:true,fm:true,w:5,p:800};
I.u[7029] = {n:"Cintura di Sangrokù",t:10,d:"Quando Sangrokù abusava troppo dei fagioli magici, stringeva al massimo questa cintura per contenere il più possibile i venti di panico che l\'hanno reso tristemente celebre in tutta la provincia di Amakna.",ep:13,g:80,l:86,wd:false,fm:true,w:10,c:"CS>100",p:18400};
I.u[7030] = {n:"Pelle di Kanigrù",t:59,d:"Dopo essere stata depilata, la pelle di Kanigrù diventa molto morbida, un po\' come le femmine Sadida.",ep:13,g:47,l:70,wd:true,fm:true,w:5,p:1};
I.u[7031] = {n:"Ciondolo di Gudolo",t:1,d:"Il povero Gudolo ha perso la testa a causa di un terribile combattimento con Many. Fortunatamente, il suo amuleto non si è rovinato durante lo scontro. Ha conservato i poteri ipnotizzanti, e anche quelli lassativi. Da usare con moderazione.",ep:18,g:90,l:46,wd:false,fm:true,w:2,p:5600};
I.u[7032] = {n:"Silicato",t:39,d:"Questo minerale proviene sicuramente dalle profonde miniere oscure dell\'Isola di Pandala nelle quali Gardan Framin si è innamorato perso di uno spettro di femmina di Pandawa. L\'amore non conosce veramente ostacoli.",ep:16,g:111,l:70,wd:true,fm:true,w:5,p:0};
I.u[7033] = {n:"Dolomite",t:39,d:"\"Sempre dura, e resistente\", queste erano le parole di Irko il Minatore Oscuro a proposito della Dolomite.",ep:16,g:110,l:80,wd:true,fm:true,w:5,p:0};
I.u[7034] = {n:"Elmo del Maestro Nabur",t:16,d:"Tramandato di generazione in generazione, questo elmo difforme è stato persino portato da Crail in persona. Molti avventurieri gli attribuiscono poteri che non possiede, come d\'altronde per altre divinità o eroi dei tempi moderni.",ep:16,g:93,l:97,wd:false,fm:true,w:10,p:23000};
I.u[7035] = {n:"Pyruta",t:40,d:"Questa lega era usata per forgiare delle lame che non arrugginivano mai al contatto con il sangue o con la bava dei nemici.",ep:16,g:708,l:100,wd:true,fm:true,w:100,p:0};
I.u[7036] = {n:"Rutile",t:40,d:"Questa lega brillante è molto apprezzata dagli Orefici in rovina che non possono permettersi di lavorare con pietre preziose e allora lavorano con leghe super economiche che non hanno concorrenza. Buono a sapersi, soprattutto se vuoi sposarti solo per interesse.",ep:16,g:707,l:100,wd:true,fm:true,w:100,p:0};
I.u[7037] = {n:"Canna di Mamie Bonbon",t:4,d:"Questa canna appartiene a Mamy Bonbon in persona, una delle tre terribili profetesse dell\'amore. Affilata da una parte e lucidata dall\'altra, questa canna è soprattutto famosa per la sua polivalenza e la sua capacità di potersi infilare ovunque. Nessuno poteva esservi indifferente.",ep:18,g:48,l:98,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,50,50,false,false],c:"CS>100&CV>300",p:24500};
I.u[7038] = {n:"Corona del Re Gelax",t:16,d:"Questa corona è appartenuta all\'illustre Re Gelax, conosciuto per il suo romanticismo sfrenato e per il suo potere di seduzione che ha segnato più di una femmina di Gelatina della regione di Amakna... Si dice infatti che sia il padre di quasi tutte le Gelatine della regione, il che prova la sua resistenza e la sua fertilità leggendaria.",ep:7,g:94,l:79,wd:true,fm:true,w:15,p:15000};
I.u[7039] = {n:"Cintura Nera di Frank Lee Bruce",t:10,d:"Celebre guerriero della domenica, Frank si è dato alle arti marziali dopo il clamoroso fallimento all\'esame di tagliatore di pietre.",ep:13,g:81,l:47,wd:true,fm:true,w:5,p:5900};
I.u[7040] = {n:"Arco di Kuri",t:2,d:"Quest\'arco è appartenuto a Kuri in persona, celebre profetessa dell\'amore, e braccio sinistro di Mamy Bonbon. Non dare mai le spalle ad una profetessa dell\'amore, una sola freccia di quest\'arco potrebbe bastare a spezzarti il cuore, e persino il c...",ep:18,g:43,l:56,wd:true,fm:true,w:10,an:10,tw:true,e:[15,5,2,6,20,40,false,true],p:8300};
I.u[7041] = {n:"Pandrista",t:30,d:"Chiamata anche Sciolta del Pandawa, la Pandrista è una specialità di Pandala molto conosciuta dai viaggiatori. I sintomi: una voglia incontenibile di andare in bagno seguita dall\'incapacità di tirar fuori uno stronzetto degno di questo nome.",ep:18,g:8,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7042] = {n:"Copricapo Pandawa",t:14,d:"Al contrario del Pandawa di Amakna, il Pandawa di Pandala non ti farà montare la testa, ma solo una voglia pressante di andare a depositare un concime naturale sulla pianta più vicina... O, in caso non ne trovassi, su un maomao: è lo stesso efficace, ma molto più divertente!",ep:18,g:31,l:1,wd:false,fm:true,w:1,c:"PG!12",u:true,p:1000};
I.u[7043] = {n:"Dofus dei Ghiacci",t:23,d:"La leggenda racconta che questo splendido Dofus è uscito dalla narice ghiacciata di Aguabrial il drago dell\'acqua. La leggenda non dice che il drago era raffreddato quel giorno... anche se non è tanto difficile capirlo.",ep:1,g:5,l:1,wd:false,fm:true,w:1,p:1};
I.u[7044] = {n:"Falso Dofus",t:24,d:"Questo Dofus non assomiglia agli altri, eppure...",ep:18,g:256,l:1,wd:false,fm:true,w:0,p:1};
I.u[7045] = {n:"Una fiala di Pandaburg",t:79,d:"La Pandaburg è una bevanda gustosa che ha molto successo. Sembra però che renda ciechi, muti e sordi... anche se lentamente. Ma va bene così, i Pandawa tanto non hanno fretta.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[7046] = {n:"Una fiala di Pandapiler",t:79,d:"Secondo l\'erudito Hel Munster, questo autentico nettare renderebbe felice la dea Pandawa stessa, dandole euforia. Ogni Pandawa che si rispetti dovrebbe offrire una di queste fiale alla venerata dea.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[7047] = {n:"Una fiala di Pandapils",t:79,d:"Che strana tradizione che hanno i Pandawa di brindare con una piuma di Tofu sulla testa, cantando: \"Pandapils, Pandapils, lalalaLALLERO!\". E non è questa la parte peggiore...",ep:18,g:4,l:1,wd:true,fm:true,w:1,p:1};
