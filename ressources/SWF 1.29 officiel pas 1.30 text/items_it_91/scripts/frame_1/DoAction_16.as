I.u[7234] = {n:"Scudo Aksadala inghiottito",t:82,d:"Questo valoroso scudo ha vissuto troppe battaglie e non serve più a nulla in queste condizioni. Forse Scudawa, al villaggio Pandala, potrà cambiartelo.",ep:18,g:31,l:1,wd:false,fm:true,w:2,c:"BI=non équipable",p:5350};
