I.u[7246] = {n:"Fede Aksadala",t:9,d:"Questa fede proviene dal villaggio di Aksadala. Più portafortuna che reliquia magica, ti permetterà comunque di far credere ai tuoi amici che hai trovato l\'anima gemella.",ep:1,g:80,l:37,wd:true,fm:true,w:2,s:34,p:3800};
