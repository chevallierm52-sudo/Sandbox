I.u[7055] = {n:"Una fiala di Pandaneken",t:79,d:"\"Le zampe del Bwak sono corte, è vero, ma allungargliele non serve a niente\". Ecco una delle riflessioni tipiche provocate dall\'eccessiva consumazione di Pandaneken. Per questo i Pandawa preferiscono conservarla per le libagioni in onore del dio Pandawa.",ep:18,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[7056] = {n:"Krepito",t:16,d:"Questo cappello, unico nel suo genere, è appartenuto a uno Xelor, conosciuto per le idee esplosive e la capacità di controllare il tempo. È morto in modo poco comune, lanciando un Vento di Panico, dimenticando che il suo cappello lanciava scintille intorno a lui. La sua morte fu molto dolorosa ma talmente splendente che avrebbe potuto illuminare a giorno l\'intera città di Brakmar.",ep:19,g:95,l:149,wd:true,fm:true,w:10,p:45850};
I.u[7057] = {n:"Assistente dello Sciamano",t:32,d:"Porta l\'assistente presso la dea, te ne sarà riconoscente.",ep:18,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7058] = {n:"Octovius",t:16,d:"Questo copricapo è stato fabbricato con resti di Kralamori morti e seccati. Attenzione: rischia di riprendere vita se lo usi come cuffia da bagno.",ep:18,g:96,l:77,wd:true,fm:true,w:10,p:15475};
I.u[7059] = {n:"Seme di Panzucca",t:58,d:"Questo enorme seme è pieno di un olio indigesto, ma magico. Il suo guscio è considerato infrangibile, numerosi artigiani lo usano per incantare delle armi, mentre altri lo usano come boccino magico per giocare a bocce.",ep:18,g:67,l:100,wd:true,fm:true,w:10,p:10};
I.u[7060] = {n:"Pandapiler Speciale",t:24,d:"Il saggio Volpo ti ha affidato questo Pandapiler per portarlo al Maestro Pandawushu della via dell\'Acqua.",ep:18,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[7061] = {n:"Trasformazione Maomao",t:31,d:"L\'acqua della sorgente maledetta suk-sang-ky-ô del Maomao ti ha temporaneamente trasformato in Maomao, il minimo choc ti farà tornare normale.",ep:18,g:21,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7062] = {n:"Poochan",t:32,d:"Devi portare Poochan dove si trova suo marito.",ep:18,g:21,l:1,wd:false,fm:true,w:0,m:true,p:1};
