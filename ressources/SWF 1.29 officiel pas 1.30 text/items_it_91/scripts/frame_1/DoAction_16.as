I.u[6894] = {n:"Strapotente Maomao da Combattimento (MJ)",t:18,d:"Questo strapotente Maomao da combattimento è un meraviglioso esempio di strapotenza. Ma attenzione: è riservato ai Game Master che lo meritano.",ep:1,g:1,l:1,wd:false,fm:false,w:10,c:"PX=3|PX=5",p:1};
I.u[6895] = {n:"Piccolo Maomao da Combattimento (MJ)",t:18,d:"Questo famiglio, meno potente dello strapotente Maomao da Combattimento, ma comunque molto potente, resta un riferimento sicuro per tutti i Game Master degni di questo nome. Però bisogna ammettere che è molto sporco. Non dimenticare di strofinarlo con forza nell\'acqua bollente per fargli conservare tutto il suo splendore.",ep:1,g:9,l:1,wd:false,fm:true,w:10,p:1};
