I.u[7254] = {n:"Bastone Aksadala",t:4,d:"Questo bastone serviva a castigare i giovani Pandawa un po\' burrascosi. Tre colpi sulle dita, quindici sul sedere, sessanta sulla testa, due negli occhi... ed era fatta!",ep:18,g:61,l:43,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,false],c:"CC>50",s:34,p:5040};
I.u[7255] = {n:"Ascia Terradala",t:19,d:"Sin dall\'inizio quest\'ascia è stata concepita per tagliare gli esseri viventi. Attenzione: un solo errore da parte tua, e potresti trovarti ridotto a metà.",ep:18,g:32,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],s:36,p:17635};
I.u[7256] = {n:"Daghe Erdala",t:5,d:"Taglienti come artigli di muulupo, queste daghe faranno di te un eccellente apprendista assassino.",ep:18,g:51,l:62,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>50",s:35,p:10105};
I.u[7257] = {n:"Sciabola Focodala",t:6,d:"Questa sciabola è stata forgiata da Hotari Honza in persona. Pare che sia una delle sue ultime creazioni prima della sua conversione in cuoco. Un vero pezzo da collezione in ogni caso.",ep:18,g:64,l:76,wd:true,fm:true,w:1,an:14,e:[5,6,1,1,50,50,false,false],c:"CI>200&CA>60",s:37,p:14900};
I.u[7258] = {n:"Peli di Pandikaze",t:54,d:"Questi peli molto fini potrebbero provenire dal sedere di una Sadidina, ma non vi lasciate ingannare... non è così.",ep:16,g:556,l:40,wd:true,fm:true,w:1,p:10};
I.u[7259] = {n:"Stoffa di Pandikaze",t:55,d:"Questo ammasso di peli è quasi intatto malgrado le batoste che hai dovuto infliggere al povero Pandikaze per strapparglielo.",ep:18,g:124,l:40,wd:true,fm:true,w:1,p:10};
I.u[7260] = {n:"Pelle di Pandikaze",t:59,d:"Questa pelle è ancora coperta da una leggera peluria, tanto morbida quanto i peli delle ascelle di un\'Aniripsa, ma senza l\'odore del sudore.",ep:18,g:40,l:40,wd:true,fm:true,w:2,p:10};
I.u[7261] = {n:"Legno di Bambù Magico",t:38,d:"Questo pezzo di Bambù è impregnato di una magia sorprendente. Una leggenda tribale narra che tutte le notti, esso bussa alla porta di tutti coloro che sono considerati ferventi libertini. I Pandawa quindi fanno ben attenzione ad attaccarlo a una catena prima di andare a dormire, per evitare problemi di vicinato.",ep:18,g:670,l:220,wd:true,fm:true,w:5,p:20};
I.u[7262] = {n:"Radice di Bulbifiore",t:98,d:"Questa radice di Bulbifiore non è come le altre radici, puoi infatti masticarla a lungo senza perdere i denti. Attenzione: contrariamente agli altri dolciumi, ha un cattivissimo gusto.",ep:18,g:142,l:26,wd:true,fm:true,w:2,p:20};
I.u[7263] = {n:"Radice di Bulcespuglio",t:98,d:"Questa radice di Bulcespuglio non è come le altre radici, puoi infatti masticarla a lungo senza perdere i denti. Attenzione: contrariamente agli altri dolciumi, ha un cattivissimo gusto.",ep:18,g:143,l:42,wd:true,fm:true,w:2,p:20};
I.u[7264] = {n:"Radice di Bulbambù",t:98,d:"Questa radice di Bulbambù non è come le altre radici, puoi infatti masticarla a lungo senza perdere i denti. Attenzione: contrariamente agli altri dolciumi, ha un cattivissimo gusto.",ep:18,g:145,l:67,wd:true,fm:true,w:2,p:20};
I.u[7265] = {n:"Radice di Bulbig",t:98,d:"Questa radice di Bulbig non è come le altre radici, puoi infatti masticarla a lungo senza perdere i denti. Attenzione: contrariamente agli altri dolciumi, ha un cattivissimo gusto.",ep:18,g:144,l:150,wd:true,fm:true,w:2,p:20};
I.u[7266] = {n:"Fiore di Bulbifiore",t:35,d:"Questo fiore cresce solo in un posto, ovvero sulla testa del Bulbifiore, non cercare quindi di farlo crescere sulla tua, il substrato non è altrettanto ricco.",ep:18,g:119,l:26,wd:true,fm:true,w:1,p:10};
I.u[7267] = {n:"Foglia di Bulcespuglio",t:36,d:"Queste foglie crescono in un solo punto, sulla testa del Bulcespuglio. Non cercare quindi di farle crescere sulla tua, rischierebbero di appassire rapidamente.",ep:18,g:55,l:42,wd:true,fm:true,w:2,p:10};
I.u[7268] = {n:"Germogli di Bulbambù",t:36,d:"Questo germoglio vive solo in un posto, sulla testa del Bulbambù, non cercare di farlo crescere sulla tua testa, non ci troverebbe niente d\'interessante da mangiare.",ep:18,g:56,l:67,wd:true,fm:true,w:2,p:10};
I.u[7269] = {n:"Corteccia magica di Bulbig",t:96,d:"Questa corteccia magica è resistente quanto uno Scudo di Capitan Amakna, ma molto meno bella...",ep:18,g:105,l:150,wd:true,fm:true,w:2,p:10};
I.u[7270] = {n:"Corteccia magica di Bulbifiore",t:96,d:"Questa corteccia è così fine e fragile che potrebbe essere utilizzata per la fabbricazione di merletti o biancheria sexy.",ep:18,g:106,l:26,wd:true,fm:true,w:2,p:10};
I.u[7271] = {n:"Corteccia magica di Bulcespuglio",t:96,d:"Questa corteccia ruvida è perfetta per fabbricare suole antiscivolo.",ep:18,g:107,l:42,wd:true,fm:true,w:2,p:10};
I.u[7272] = {n:"Corteccia magica di Bulbambù",t:96,d:"Questa corteccia liscia è perfetta per la fabbricazione di parquet o piste da ballo.",ep:18,g:108,l:67,wd:true,fm:true,w:2,p:10};
I.u[7273] = {n:"Pelle di Colobra",t:59,d:"Questa pelle di Colobra ti scivolerà tra le dita come nessun\'altra pelle. Non cercare di farne delle scarpe, non riusciresti più a togliertele.",ep:18,g:41,l:67,wd:true,fm:true,w:2,p:10};
I.u[7274] = {n:"Dente magico di Colobra",t:47,d:"Questo dente non è come gli altri, puzza molto di più... come se si fosse impregnato del terribile alito del Colobra.",ep:18,g:16,l:67,wd:true,fm:true,w:2,p:100};
I.u[7275] = {n:"Peli di Kitsù Nae",t:54,d:"Questi peli di Kitsù Nae sono morbidi come la groppa di una femmina Trool. Che bei ricordi, vero?",ep:16,g:560,l:29,wd:true,fm:true,w:1,p:10};
I.u[7276] = {n:"Peli di Kitsù Nufoc",t:54,d:"Questi peli di Kitsù Nufoc sono morbidi come la groppa di una femmina Trool. Che bei ricordi, vero?",ep:18,g:557,l:111,wd:true,fm:true,w:1,p:10};
