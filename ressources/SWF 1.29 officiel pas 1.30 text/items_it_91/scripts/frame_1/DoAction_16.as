I.u[6885] = {n:"Gettone del Bworker",t:15,d:"Ideale per giocare a testa o croce o per uccidere i tuoi nemici con un lancio di moneta, questo gettone in oro massiccio farà di te un felice giocatore... ma anche fortunato?",ep:13,g:90,l:100,wd:true,fm:true,w:1,p:100};
