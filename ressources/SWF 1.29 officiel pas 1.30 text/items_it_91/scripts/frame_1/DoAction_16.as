I.u[6904] = {n:"Protezione usata del Bworker",t:15,d:"L\'amore a volte fa più danni e distruzioni di una guerra. E il Bworker ne sa qualcosa...",ep:1,g:714,l:200,wd:true,fm:true,w:1,p:1000};
I.u[6905] = {n:"Pack Sorpresa Bwork",t:89,d:"Per l\'apertura di questo pack è necessario che il possessore sia molto sereno. Il suo stato d\'animo influenzerà direttamente la qualità del contenuto.",ep:1,g:42,l:1,wd:true,fm:true,w:4,u:true,p:100};
I.u[6906] = {n:"Mercenario Neofita",t:14,d:"Questa pergamena è il Modulo di Iscrizione per entrare a far parte dei Mercenari. L\'avventuriero a cui è proposto sarà iscritto, come Neofita, nei registri del Clan.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6907] = {n:"Neutralizzatore",t:14,d:"Consente di dare uno schieramento neutro al personaggio scelto.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6908] = {n:"Sanguantura",t:10,d:"Pelosa ma elegante, questa cintura dovrebbe farti pensare ogni tanto alla tua dolce metà.",ep:1,g:75,l:18,wd:true,fm:true,w:2,s:21,p:1050};
I.u[6909] = {n:"Piedi del Cinghiale",t:11,d:"Questi stivali sono perfetti per camminare nel fango e rigare i parquet. Di norma sono proibiti su tutte le piste di danza.",ep:1,g:51,l:22,wd:true,fm:true,w:2,s:21,p:1525};
I.u[6910] = {n:"Anello del Cinghiale",t:9,d:"Questo anello era posto sulle zampe dei cinghiali in calore, per farli riconoscere facilmente dall\'allevatore. Oggi lo indossi tu, vedi un po\' te...",ep:1,g:73,l:19,wd:true,fm:true,w:2,s:21,p:1200};
I.u[6911] = {n:"Araknoton",t:9,d:"Questo ridicolo piccolo anello ti permetterà di sconfiggere più facilmente la tua fobia delle Arakni.",ep:1,g:76,l:5,wd:true,fm:true,w:1,s:22,p:275};
I.u[6912] = {n:"Araknontura",t:10,d:"Confezionata a partire da resti di Arakni in decomposizione, questa cintura ti piacerà sicuramente. Ogni tanto riprenderà vita e si farà due risate mordendoti i fianchi. Che bestiaccia!",ep:1,g:73,l:6,wd:true,fm:true,w:1,s:22,p:305};
I.u[6913] = {n:"L\'Araknecapo",t:16,d:"Con questo copricapo, assomigli a un\'Arakne selvaggia. Al massimo riuscirai a spaventare i Moskito più ingenui.",ep:1,g:83,l:6,wd:true,fm:true,w:2,s:22,p:305};
I.u[6914] = {n:"La Tagliatrice di Arakni",t:19,d:"Un fatto curioso: l\'Arakne ha solo quattro zampe pelose, il che vuol dire che con quattro colpi di ascia puoi trasformarla facilmente in un\'Arakne Mozza.",ep:1,g:31,l:8,wd:true,fm:true,w:5,an:17,e:[5,4,1,1,50,50,false,false],s:22,p:600};
I.u[6915] = {n:"Mos Kitanello",t:9,d:"Questo anello così leggero ti permetterà di realizzare ogni sorta di acrobazia con le dita. È molto pratico per umiliare un avversario dieci volte più piccolo di te, schiacciandogli la testa con il pollice.",ep:1,g:71,l:21,wd:true,fm:true,w:2,s:23,p:1400};
I.u[6916] = {n:"Zaino del Piccolo Moskito",t:81,d:"Tempo addietro questo Zaino di pelle e ali di Moskito faceva furore tra gli scolari. Oggi invece è completamente fuori modo e nel cuore dei bambini è stato sostituito dal Piccolo Zaino di scuola del Capo Coccodrail. Una fesseria visto che quest\'ultimo è molto più caro e più brutto. Un\'oscura storia di moda.",ep:1,g:59,l:16,wd:true,fm:true,w:2,s:23,p:900};
I.u[6917] = {n:"Moskitellino",t:16,d:"Questo copricapo deve il suo sorprendente nome all\'eccentricità del primo Anutrof che l\'ha scoperto saccheggiando un Moskito malato. Molto utile per gli avventurieri principianti, permette soprattutto di fare impazzire per te le Arakni affamate.",ep:1,g:80,l:15,wd:true,fm:true,w:2,s:23,p:900};
I.u[6918] = {n:"Amuleto del Moskito",t:1,d:"Meno efficace e meno apprezzato del celebre Araknamu, questo piccolo amuleto acquista tuttavia un fascino tutto particolare quando è indossato da solo su un corpo molto peloso.",ep:1,g:75,l:15,wd:true,fm:true,w:2,s:23,p:800};
I.u[6919] = {n:"Anello del Fun Fung",t:9,d:"I Fun Fung non sono mai stati famosi per la loro simpatia. Ti avvelenano la vita appena possono, mordono forte e hanno un pessimo carattere. È stupefacente quanto queste piccole creature possano a volte ricordarti un parente.",ep:1,g:74,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6920] = {n:"Fede del Fun Fung",t:9,d:"Quando un Fun Fung si sposa, offre questa fede alla sua amata che, non avendo né braccia né mani, la mette in una spina. Se gliela prendi e la indossi romperai il legame di questa unione, e nel migliore dei casi il Fun Fung... ti scambierà per la sua amata!",ep:1,g:75,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6921] = {n:"Fungocapo",t:16,d:"Spesso usato come infusione, a volte fumato, questo copricapo di Fun Fung ha tutte le qualità per piacere.",ep:1,g:84,l:9,wd:true,fm:true,w:3,s:24,p:425};
I.u[6922] = {n:"Mantello del Fun Fung",t:17,d:"L\'unica cosa più impressionante di un Fun Fung arrabbiato, è un Fun Fung arrabbiato con un mantello. Bisogna dire che questo mantello dà una certa aria di superpotenza, pur essendo parecchio brutto.",ep:1,g:76,l:9,wd:true,fm:true,w:2,s:24,p:450};
I.u[6923] = {n:"Amuleto del Bandito",t:1,d:"Questo amuleto apparteneva al grande bandito \"Thisme\", famoso per la sua spietata crudeltà e la sua morte idiota. La sua vita è degna di un racconto di Aniripsa;\r\n            morì annegato e schiacciato da una pressa a olio proprio quando aveva appena finito di scontare una pena di un centinaio di anni. E tutto questo per aver rubato una noce di acagiù...",ep:1,g:76,l:16,wd:true,fm:true,w:2,s:25,p:900};
I.u[6924] = {n:"Daghe del Bandito",t:5,d:"Queste daghe affilate sono popolari tra i banditi ma non tra i giovani avventurieri, e per la stessa ragione: possiedono infatti un incantesimo che permette di rubare dei kama agli avversari. Una sorta di tassa molto originale.",ep:1,g:9,l:12,wd:true,fm:true,w:1,an:13,e:[5,3,1,1,30,50,false,false],s:25,p:600};
I.u[6925] = {n:"Cintura del Bandito",t:10,d:"Questa cintura ti andrà a meraviglia il giorno in cui deciderai di unirti ai banditi di strada. Nel frattempo, però, non farà altro che renderti più ridicolo.",ep:1,g:72,l:15,wd:true,fm:true,w:2,s:25,p:850};
I.u[6926] = {n:"Copricapo del Prespic",t:16,d:"Con questo copricapo del Prespic sulla testa assomiglierai quasi a Devy Cloket, la famosa cacciatrice pronta a tutto per nascondere la sua imminente calvizie. Se avevi l\'intenzione di fare la stessa cosa, lascia perdere, dovrai accontentarti di un copricapo rosso che emanerà un odore terribile appena si metterà a piovere.",ep:1,g:81,l:36,wd:true,fm:true,w:2,s:31,p:3600};
I.u[6927] = {n:"Mantello del Prespic",t:17,d:"Questo piccolo mantello rosso può anche servire come tappeto o zerbino. Un modo economico per cambiare arredamento ogni giorno.",ep:1,g:75,l:37,wd:true,fm:true,w:3,s:31,p:3800};
I.u[6928] = {n:"Anello del Prespic",t:9,d:"Sobrio ma allo stesso tempo originale, questo anello sedurrà gli avventurieri avidi di accessori di lusso ma completamente al verde, al punto di saccheggiare piccole ridicole creature selvatiche per ornarsi di gioielli. La meschinità non conosce limiti!",ep:1,g:72,l:38,wd:true,fm:true,w:1,s:31,p:4000};
I.u[6929] = {n:"Cintura del Prespic",t:10,d:"Nonostante sia l\'ideale per tenere i fianchi al calduccio, questa cintura ha l\'inconveniente di irritare e pizzicare le pelli delicate. Solo per i veri duri.",ep:1,g:71,l:33,wd:true,fm:true,w:2,s:31,p:3000};
I.u[6930] = {n:"Elmo del Croccaroc",t:16,d:"Questo elmo, ricavato direttamente dalla pietra, vale tanto oro quanto pesa. Ti proteggerà dagli attacchi di un Croccaroc permettendoti sempre di tirargli delle testate degne di un Desirobul. I tuoi avversari perderanno letteralmente la testa!",ep:5,g:85,l:44,wd:true,fm:true,w:200,s:26,p:5300};
I.u[6931] = {n:"Croccantello",t:17,d:"Questo mantello di pietra è un po\' troppo rigido, ma resta la migliore protezione contro il lancio di pietre o, ancora meglio, contro i pericolosissimi sputi dei Croccaroc.",ep:5,g:77,l:46,wd:true,fm:true,w:1,s:26,p:5800};
I.u[6933] = {n:"Stivali del Croccaroc",t:11,d:"Gli stivali del Croccaroc sono incredibilmente pesanti, ma molto efficaci. Ti permetteranno finalmente di avere una buona scusa per trascinare i piedi quando dovrai difendere il tuo percettore in un combattimento praticamente perso in partenza.",ep:5,g:52,l:47,wd:true,fm:true,w:10,s:26,p:4700};
I.u[6934] = {n:"Croccamuleto",t:1,d:"Questo amuleto è pesante come un Blop bulimico, il che dovrebbe scoraggiare gli avventurieri un po\' troppo fragili. Però bisogna riconoscere che indossarlo, una volta abituati al suo peso, rende molto fieri.",ep:5,g:77,l:46,wd:true,fm:true,w:10,s:26,p:4600};
I.u[6935] = {n:"Cintura del Croccaroc",t:10,d:"Se porti questa cintura sui fianchi, diventerai un avventuriero rispettato. Se invece la porti sulla testa come fascia, diventerai lo zimbello di Astrub.",ep:5,g:74,l:45,wd:true,fm:true,w:10,s:26,p:5400};
I.u[6936] = {n:"Scaracapo Verde",t:16,d:"Con questo originale copricapo, potrai finalmente far credere ai tuoi amici di essere un Cacciatore di Scarafoglie.",ep:3,g:78,l:44,wd:true,fm:true,w:2,s:27,p:5200};
I.u[6937] = {n:"Scaracapo Rosso",t:16,d:"Con questo originale copricapo, potrai finalmente far credere ai tuoi amici di essere un Cacciatore di Scarafoglie.",ep:3,g:77,l:44,wd:true,fm:true,w:2,s:28,p:5200};
