I.u[6940] = {n:"Scarantello Verde",t:17,d:"Chi non ha mai sognato di indossare un mantello in guscio di Scarafoglie? Una volta indossato, ti sembrerà di essere davvero uno Scarafoglie e forse comincerai anche a muoverti scivolando e slittando. \nCome sbalordire un\'orda di Trooll...",ep:3,g:74,l:45,wd:true,fm:true,w:2,s:27,p:5500};
