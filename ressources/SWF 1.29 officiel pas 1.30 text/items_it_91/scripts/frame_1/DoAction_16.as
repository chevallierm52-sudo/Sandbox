I.u[6944] = {n:"Scaranello Verde",t:9,d:"Portando questo anello intorno al dito penserai con commozione a tutti quei poveri Scarafoglie che hai ucciso. E forse ti chiederai se questa carneficina valesse veramente la pena.",ep:3,g:69,l:43,wd:true,fm:true,w:2,s:27,p:5000};
