I.u[7226] = {n:"Cappello Aksadala",t:16,d:"Con questo cappello sulla testa assomiglierai da lontano a un Pandawushuka del villaggio di Aksadala. Da vicino invece non assomiglierai a niente.",ep:18,g:146,l:43,wd:true,fm:true,w:2,s:34,p:5100};
