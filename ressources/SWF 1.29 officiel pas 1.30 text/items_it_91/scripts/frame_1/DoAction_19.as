I.u[8248] = {n:"Cappello del Pìu Rosa",t:16,d:"Con questo cappello sulla testa, sarai molto ridicolo, ma anche terribilmente irresistibile. In fondo, la vita è una questione di punti di vista...",ep:1,g:142,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8249] = {n:"Piuma di Beone",t:53,d:"Questa piuma impregnata d\'alcool forte è molto infiammabile. Molto pratica per cucinare un Beone arrosto.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[8250] = {n:"Pelo di Volpel",t:54,d:"Il Volpel adora travestirsi in Cuervoc, nessuno sa veramente perché, anche se le persone più maligne hanno un loro parere sulla questione...",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[8251] = {n:"Pelo di Peki",t:54,d:"Chi poteva credere che il Peki avrebbe accettato di darti un ciuffo dei suoi peli? Nessuno, a parte Joch Banet, celebre idiota di Amakna, famoso per la sua adorazione morbosa nei confronti dei Peki imbalsamati.",ep:18,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[8252] = {n:"Piuma di Cuervoc Addomesticato",t:53,d:"Questa piuma bella grassa appartiene a un Cuervoc Addomesticato, che ha passato la maggior parte della sua esistenza rinchiuso e ingozzato fino a riempire completamente lo spazio della sua gabbia.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[8253] = {n:"Amuleto di Spugna",t:1,d:"Questo amuleto è spesso confuso con un giocattolo delle scatoline a sorpresa, ma invece si vince al tirassegno.",ep:1,g:106,l:11,wd:true,fm:true,w:2,s:63,p:525};
I.u[8254] = {n:"Anello di Spugna",t:9,d:"Offerto come fede, questo anello permette di dare due messaggi all\'essere amato: \"Ti amo\" e \"Vai a lavare i piatti\". Ideale per non perdere tempo a ripetere tutte le sere la stessa cosa.",ep:1,g:112,l:10,wd:true,fm:true,w:2,s:63,p:500};
I.u[8255] = {n:"Pala Molle",t:8,d:"Quest\'arma, terribilmente potente contro le zolle di terra, ha lasciato il segno su più di un avventuriero principiante. Bagnata, diventa molle e può essere arrotolata, ma bisogna essere in due per riuscirci.",ep:1,g:44,l:10,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,true],s:63,p:500};
I.u[8256] = {n:"Stivali di Spugna",t:11,d:"Con questi stivali un Aniripsa può camminare sull\'acqua, il che non gli serve a niente, perché sa volare, ma riesce comunque a stupire la gente. Gli altri potranno usare questi stivali per grattarsi i piedi camminando, o semplicemente per pulire.",ep:1,g:84,l:11,wd:true,fm:true,w:5,s:63,p:525};
I.u[8257] = {n:"Cintura di Spugna",t:10,d:"Questa cintura permetteva a Vald di farsi il bagno senza pericolo dato che nessuno Yop ha mai imparato a nuotare.",ep:1,g:102,l:10,wd:true,fm:true,w:5,s:63,p:500};
I.u[8258] = {n:"Mantello di Spugna",t:17,d:"Questo mantello è ideale per camuffarsi nell\'ambiente naturale... quando non c\'è nessuno che ti vede.",ep:1,g:109,l:10,wd:true,fm:true,w:1,s:63,p:505};
I.u[8259] = {n:"Copricapo di Spugna",t:16,d:"Sul manuale di questo copricapo c\'è scritto: \"Regala il copricapo a tuo marito, legaglielo in testa e trascinalo in cucina per i piedi. Ed ecco che il pavimento splende!\". Siamo di fronte alla concezione moderna della pulizia e della ripartizione dei compiti domestici nelle coppie disinibite e che si divertono.",ep:1,g:143,l:11,wd:true,fm:true,w:10,s:63,p:525};
I.u[8260] = {n:"Fascia Kalipto",t:16,d:"Con questa fascia, gli Yop saranno più affascinanti che mai!",ep:20,g:124,l:133,wd:true,fm:true,w:10,p:43500};
I.u[8262] = {n:"La Muletto",t:1,d:"La Muletto racchiude una strana sostanza trovata nelle viscere del muulupo. Alcuni pensano che si tratti dell\'essenza stessa del mostro, altri che si tratti solo di un Kirbul che aveva divorato poco prima.",ep:20,g:107,l:143,wd:true,fm:true,w:1,s:55,p:44850};
I.u[8263] = {n:"Anello del Muulupo",t:9,d:"Attenzione, questo anello renderà il tuo dito particolarmente puzzolente... Un odore che ne coprirà sicuramente un altro. Effettivamente, per il tuo dito e per i tuoi amici, potrebbe essere una fortuna!",ep:20,g:113,l:126,wd:true,fm:true,w:10,s:55,p:40190};
I.u[8264] = {n:"Stivali del Muulupo",t:11,d:"Questi stivali sono ancora animati da una parte del vorace appetito del muulupo. Se i tuoi piedi sanno di Clakos, potrebbero morderterli.",ep:18,g:85,l:131,wd:true,fm:true,w:20,s:55,p:42840};
I.u[8265] = {n:"Mantello del Muulupo",t:17,d:"Il muulupo ha la coda così bella e così lunga che striscia per terra. Alcuni avventurieri gelosi gliel\'hanno staccata e la indossano, sperando che li faccia diventare più virili.",ep:20,g:110,l:139,wd:true,fm:true,w:10,s:55,p:44500};
I.u[8266] = {n:"Cintura del Muulupo",t:10,d:"Questa cintura colorata è dotata di un bellissimo ciuffo violaceo sul davanti, puoi portarla al contrario se vuoi travestirti da Wabbit.",ep:20,g:103,l:125,wd:true,fm:true,w:1,s:55,p:1};
I.u[8267] = {n:"Copricapo del Muulupo",t:16,d:"Smembrando il Muulupo, i Cacciatori si sono accorti che quest\'animale possiede un solo corno che gli attraversa il cranio da una parte all\'altra. Gli Yop non hanno fatto una piega a questa notizia, anzi lo indossano con evidente entusiasmo.",ep:4,g:144,l:141,wd:true,fm:true,w:10,s:55,p:44600};
I.u[8268] = {n:"Collana del Minotoror",t:1,d:"Questa collana permetteva al Minotoror di non avere né pulci, né zecche, né pidocchi. Ne hai sicuramente bisogno.",ep:18,g:112,l:111,wd:true,fm:true,w:1,s:54,p:31260};
I.u[8269] = {n:"Anello del Minotoror",t:9,d:"Contrariamente a quello che dicono molti avventurieri, questo anello non è mai stato portato dal Minotoror, che sarebbe stato incapace di infilarsi un anello del genere negli zoccoli.",ep:21,g:117,l:105,wd:true,fm:true,w:1,s:54,p:28010};
I.u[8270] = {n:"Bracciale del Minotot",t:9,d:"Questo braccialetto consente di proteggere tutto il braccio di un Aniripsa, ma ne triplica il peso.",ep:21,g:116,l:151,wd:true,fm:true,w:10,s:57,p:45425};
I.u[8271] = {n:"Anello del Drago Maiale",t:9,d:"Questo anello di cuoio e avorio ti permetterà di stimolare più facilmente il partner.",ep:18,g:115,l:108,wd:true,fm:true,w:1,s:58,p:29600};
I.u[8272] = {n:"Collana del Minotot",t:1,d:"Questa collana permetteva ai Minotot di proteggere la cervicale e di evitare di morire a causa di uno stupido colpo di Wabbit.",ep:21,g:111,l:158,wd:true,fm:true,w:20,s:57,p:47800};
I.u[8273] = {n:"Collana del Drago Maiale",t:1,d:"Questa collana ha un piccolo anellino che permetteva al proprietario del Drago Maiale di attaccarvi una corda per portarlo a fare una passeggiatina notturna.",ep:21,g:110,l:100,wd:true,fm:true,w:1,s:58,p:25470};
I.u[8274] = {n:"Ascia del Minotoror",t:19,d:"Quest\'ascia ha permesso di tranciare la testa di uno dei più pericolosi Minotoror che la provincia di Amakna abbia mai conosciuto. La cosa più incredibile in questa storia è che sembra lasciarti indifferente.",ep:21,g:44,l:109,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,40,50,false,true],s:54,p:30110};
I.u[8275] = {n:"Scettro del Minotot",t:4,d:"Questo scettro ornato all\'estremità da una testa di Serpentino in pietre preziose, permette di affrontare i giovani avventurieri per farli fuggire e sculacciargli le chiappe tutte rosa.",ep:21,g:67,l:151,wd:true,fm:true,w:50,an:12,tw:true,e:[5,4,1,1,40,50,false,false],s:57,p:46200};
I.u[8276] = {n:"Stivali del Minotoror",t:11,d:"Evidentemente questi terribili stivali di pelo e cuoio di Minotoror sono troppo pesanti per farti vincere la leggendaria corsa della baia di Amakna.\nTuttavia, dovrebbero permetterti di schiacciare abbastanza facilmente i piedi degli altri concorrenti sul traguardo.",ep:21,g:89,l:113,wd:true,fm:true,w:40,s:54,p:32290};
I.u[8277] = {n:"Sandali del Minotot",t:11,d:"Questi sandali incredibili ti permetteranno di entrare nelle acque più pericolose, senza rischiare di farti male ai piedi. Attenzione però, sembra che righino le vasche da bagno.",ep:21,g:88,l:163,wd:true,fm:true,w:20,s:57,p:48400};
I.u[8278] = {n:"Pantofole del Drago Maiale",t:11,d:"Un buon paio di pantofole e ti sentirai subito più forte, più potente, più prestante, anche se sono solo delle pantofole.",ep:20,g:87,l:93,wd:true,fm:true,w:5,s:58,p:22800};
I.u[8279] = {n:"Mantello del Minotoror",t:17,d:"Prendi un Minotoror, legalo bene, prendi una pialla gigante, e pelagli la schiena (in un colpo solo). Ecco fatto, hai tra le mani un mantello del Minotoror.",ep:21,g:117,l:109,wd:true,fm:true,w:10,s:54,p:30500};
I.u[8280] = {n:"Mantello del Minotot",t:17,d:"Se devi uscire di sera o se vuoi sedurre qualcuno al ballo in maschera del Capitano Chafer, ecco il mantello che fa per te!",ep:21,g:116,l:156,wd:true,fm:true,w:40,s:57,p:48850};
I.u[8281] = {n:"Mantello del Drago Maiale",t:17,d:"Questo mantello non ti trasformerà in un Maialino da Latte, ma forse ti permetterà di travestirti almeno per una sera, giusto il tempo di rimorchiare una bella Maialina.",ep:20,g:118,l:103,wd:true,fm:true,w:10,s:58,p:27500};
I.u[8282] = {n:"Cintura del Minotoror",t:10,d:"Questa cintura è così morbida che può servire per frustare il sedere dei bambini più burrascosi. Con un po\' di fortuna i suoi ferri strapperanno loro qualche lembo di pelle, e i terribili mostriciattoli capiranno finalmente la lezione.",ep:21,g:106,l:111,wd:true,fm:true,w:1,s:54,p:1};
I.u[8283] = {n:"Cintura del Minotot",t:10,d:"Questa rigida cintura permetteva al Minotot di contenere la sua enorme panza, in modo da non perdere l\'equilibrio ad ogni colpo di vento.",ep:21,g:105,l:149,wd:true,fm:true,w:30,s:57,p:49950};
I.u[8284] = {n:"Copricapo del Minotot",t:16,d:"Questo copricapo è tramandato di generazione in generazione nella famiglia del Minotot, il che spiega in buona parte il suo odore di forfora in decomposizione.",ep:21,g:151,l:157,wd:true,fm:true,w:20,s:57,p:47652};
I.u[8285] = {n:"Copricapo del Drago Maiale",t:16,d:"Con questo enorme copricapo sembrerai un Grizbul dal pelo duro, ma senza pelo... Come lasciare senza parole le tue ammiratrici.",ep:20,g:150,l:98,wd:true,fm:true,w:10,s:58,p:24500};
I.u[8286] = {n:"Mantello del Draguovo",t:17,d:"Secondo la leggenda questo mantello coperto di scaglie ti proteggerà dai fulmini, dai pomodori e, soprattutto, dalle donne fatali.",ep:11,g:115,l:127,wd:true,fm:true,w:10,s:56,p:41000};
I.u[8287] = {n:"Elmo Draguovo",t:16,d:"Questo elmo terrificante e di dimensioni spropositate farà passare un moscerino come te per un pietoso guerriero venuto dall\'aldilà. Inchiodato ad un muro potrebbe essere un eccellente attaccapanni.",ep:11,g:149,l:128,wd:true,fm:true,w:10,s:56,p:41500};
I.u[8288] = {n:"Cintura del Draguovo",t:10,d:"Gli spiriti più perversi di Amakna raccontano che questa cintura poteva servire da protesi. Nessuno ha mai capito perché e fortunatamente non ce n\'è motivo, infatti non è altro che una banale cintura di Draguovo.",ep:20,g:104,l:124,wd:true,fm:true,w:1,s:56,p:1};
I.u[8289] = {n:"Anello del Draguovo",t:9,d:"Questo anello direttamente intagliato in una scaglia gigante di Draguovo proteggerà una piccola parte di una delle tue falangi. Sicuramente la più importante.",ep:20,g:114,l:128,wd:true,fm:true,w:10,s:56,p:41468};
I.u[8290] = {n:"Amuleto del Draguovo",t:1,d:"Realizzato a partire da scaglie di Draguovo, questo amuleto protegge efficacemente il tuo pomo d\'Adamo o le tue tonsille... e può seriamente fare la differenza su un campo di battaglia.",ep:11,g:108,l:124,wd:true,fm:true,w:1,s:56,p:38930};
I.u[8291] = {n:"Stivali del Draguovo",t:11,d:"Questi stivali sono perfetti per uccidere un Pappatutto durante una partita di Pappaball, o per fare soffrire un po\' di più i vostri nemici durante una bella strigliata.",ep:20,g:86,l:129,wd:true,fm:true,w:20,s:56,p:41500};
I.u[8292] = {n:"Spada del Draguovo",t:6,d:"Affilata come il rasoio della sera, questa lama ti permetterà di raderti al mattino, ma unicamente sotto le ascelle.",ep:11,g:68,l:127,wd:true,fm:true,w:30,an:14,e:[8,5,1,1,40,50,false,true],c:"CS>200&CA>200",p:41025};
I.u[8293] = {n:"Ascia del Draguovo",t:19,d:"Quest\'ascia taglia il burro tanto facilmente quanto i crani, a meno che non sia il contrario...",ep:20,g:43,l:126,wd:true,fm:true,w:20,an:17,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>180&CW>80",p:40854};
I.u[8294] = {n:"Martello del Draguovo",t:7,d:"Più pesante di un cranio vuoto di Kroker, ma meno solido di un femore di Kirbul delle caverne, questo martello resta tuttavia un\'arma pericolosissima.",ep:20,g:59,l:123,wd:true,fm:true,w:30,an:15,e:[10,5,1,1,45,50,false,true],c:"CI>200&CC>100",p:38542};
I.u[8295] = {n:"Arco del Draguovo",t:2,d:"Quest\'arco è così potente che permette di inviare delle uova marce di Draguovo oltre le mura di Brakmar. Che spreco!",ep:20,g:55,l:122,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,8,40,50,false,true],c:"CS>300&CV>250",p:38015};
I.u[8296] = {n:"Bacchetta del Draguovo",t:3,d:"Questa bacchetta sembra più effecace quando la si utilizza come manganello o come scacciamoskito.",ep:21,g:60,l:124,wd:true,fm:true,w:10,an:11,e:[5,3,2,5,30,30,false,true],c:"CI>100&CA>200",p:37884};
I.u[8297] = {n:"Bastone del Draguovo",t:4,d:"Questo bastone è munito all\'estremità di una grossa punta di cui nessuno conosce l\'origine. In compenso, gli avventurieri ne conoscono bene la destinazione...",ep:20,g:66,l:124,wd:true,fm:true,w:30,an:12,tw:true,e:[5,5,1,1,30,50,false,true],c:"CS>300&CA>150&CV>300",p:39800};
I.u[8298] = {n:"Spiga di Shika",t:1,d:"Shika aiutava Farle durante la mietitura, raccogliendo le spighe magiche tagliate dalla falce. Col tempo prese l\'abitudine di attaccarsele al collo dove, anche se prive di radice e gambo, queste spighe magiche continuavano a maturare ogni anno nello stesso periodo.",ep:18,g:113,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8299] = {n:"Bracciale Magico di Shika",t:9,d:"Questo braccialetto copriva le braccia di Shika proteggendola dai colpi di sole, e soprattutto dalle beccate dei Cuervoc attirati dalla sua bellezza raggiante. È ancora impregnato del suo soave sudore.",ep:21,g:118,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8300] = {n:"Bastone di Shika",t:4,d:"Questo bastone intagliato su misura permetteva a Shika di creare le balle di fieno più alte di tutta Amakna. La leggenda racconta che erano così grandi che i marinai le usavano come punto di riferimento per sapere se si stavano o no avvicinando alle coste di Amakna.",ep:20,g:69,l:80,wd:true,fm:true,w:10,an:12,e:[10,5,1,1,45,45,false,false],s:53,p:16500};
I.u[8301] = {n:"Zoccoli di Shika",t:11,d:"Questi zoccoli sono stati concepiti per evitare a Shika di calpestare la semenza mentre seminava le pianure di Snossios. Shika ci fece aggiungere dei tacchi alti, per poter correre liberamente di mattina nella stoppia, senza riempirsi gli zoccoli di rugiada o farsi male alle fragili caviglie.",ep:21,g:91,l:80,wd:true,fm:true,w:10,s:53,p:16600};
I.u[8302] = {n:"Mantello di Shika",t:17,d:"Su questo mantello, fabbricato con cereali magici intrecciati insieme, sono stati cuciti dei fiori. Quest\'oggetto è animato da una potentissima magia che Shika usava come protezione contro i fulmini, durante i temporali.",ep:20,g:120,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8303] = {n:"Shikantura",t:10,d:"Questa cintura di cuoio proteggeva le cosce di Shika quando attraversava i campi di grano correndo per acchiappare i Pappatutto che si erano allontanati dal gruppo. Ricoperta di polline di cereali magici, si dice che brillasse al chiaro di luna, permettendo così a Farle di non tranciare le gambe di sua moglie mentre falciava interi campi di cereali a notte fonda.",ep:21,g:107,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8304] = {n:"Shikacapo",t:16,d:"Questo copricapo, ricoperto di molti fiori, dava un portamento arzillo a Shika quando partiva all\'alba per andare a lavorare sulle colline Koln.",ep:20,g:156,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8305] = {n:"Reliquia del Mominotor",t:24,d:"Questa strana reliquia è indispensabile per poter incontrare il Minotoror.",ep:21,g:119,l:1,wd:false,fm:true,w:0,p:1};
I.u[8306] = {n:"Reliquia di Dominobol",t:24,d:"Questa strana reliquia è indispensabile per poter incontrare il Minotoror.",ep:21,g:120,l:1,wd:false,fm:true,w:0,p:1};
I.u[8307] = {n:"Chiave della Sala del Minotot",t:84,d:"Questa chiave costruita con diverse risorse, ti permetterà di incontrare l\'incredibile Minotot. Un incontro che ti segnerà a vita, soprattutto dopo che il Minotot ti avrà dato qualche calcio sul sedere con i suoi zoccoli.",ep:13,g:15,l:1,wd:true,fm:true,w:1,p:10};
I.u[8308] = {n:"Carapace di Scaratos",t:107,d:"Questo piccolo carapace brillante è praticissimo per creare bei gioielli a basso costo. Potrai in seguito rivenderli carissimi quando riuscirai a convicere un Astrubiano che si tratta di una potente reliquia che permette di volare e diventare invisibili.",ep:21,g:735,l:1,wd:true,fm:true,w:1,p:10};
I.u[8309] = {n:"Piuma del Serpipiume",t:53,d:"Questa piuma è ricoperta di polvere di pietra magica, il che spiega come una piuma di Serpipiume pesi più di tre piume di Tofu. Questione di logica.",ep:21,g:4,l:1,wd:true,fm:true,w:10,p:1};
I.u[8310] = {n:"Gelatina di Scongelamento",t:110,d:"Questo vasetto di gelatina contiene una sostanza dall\'odore sgradevole e dal gusto spaventoso, eppure il tuo sogno segreto è quello di cospargerti con questa sostanza. Un altro tuo problema psicologico che deve sicuramente nasconderne molti altri...",ep:21,g:736,l:1,wd:true,fm:true,w:1,p:1};
I.u[8311] = {n:"Pelo di Gammino",t:54,d:"Questo pelo sembra essere ricoperto di gommina a base di muschio di Bituf a pelo raso, e di grasso di Kirbul delle caverne. Fa quasi venire voglia di mangiarlo.",ep:21,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[8312] = {n:"Pelle del Minoskitos",t:59,d:"Questa pelle consumata dalla sabbia e dal sale di mare è fine come un vecchio calzino consumato dalla sabbia e dal sale di mare. Da qui a dire che il Minoskitos somiglia a un vecchio calzino, c\'è solo un passo, che tu non farai.",ep:21,g:604,l:1,wd:true,fm:true,w:1,p:1};
I.u[8313] = {n:"Femore del Minotoror",t:47,d:"Quest\'osso è abbastanza solido per servire da trave, o per rompere dieci mattoni in una volta. È molto pratico per distruggere la casa al vicino, ma completamente inutile per le persone sane di mente.",ep:2,g:644,l:1,wd:true,fm:true,w:1,p:1};
I.u[8314] = {n:"Pelle di Kramaleonte",t:59,d:"Questa pelle bruciata protegge efficacemente le pelli sensibili dai raggi del sole. Da portare molto vicino al corpo.",ep:21,g:603,l:1,wd:true,fm:true,w:1,p:1};
I.u[8315] = {n:"Pelle di Mandrina",t:59,d:"Questa pelle macchiata ha la reputazione di essere ricoperta da un veleno capace di trasformare chiunque in Karabul secco. Inquietante, ma molto invitante.",ep:21,g:602,l:1,wd:true,fm:true,w:1,p:1};
I.u[8316] = {n:"Il Tifux: Come allevarlo",t:25,d:"Questo libro scritto da Oshimo Li \'Kross Baffine spiega come allevare un Tifux.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8317] = {n:"El Scarador: Come allevarlo",t:25,d:"Questo libro scritto da Oshimo Li \'Kross Baffine spiega come allevare un El Scarador.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8318] = {n:"Arbre Magic: Come allevarlo",t:25,d:"Questo libro scritto da Oshimo Li \'Kross Baffine spiega come allevare un Arbre Magic.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8319] = {n:"Palladineve: Come allevarlo",t:25,d:"Questo libro scritto d Oshimo Li \'Kross Baffine spiega come allevare un Palladineve.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8320] = {n:"Chiave dell\'Antro del Drago Maiale",t:84,d:"Dopo essere entrato ed esserti perso nel labirinto del Drago Maiale, ti sei accorto di aver dimenticato di prendere la chiave dell\'antro del Drago Maiale. Fortunatamente, i tuoi amici Porcos ne avevano una copia.",ep:15,g:16,l:1,wd:true,fm:true,w:1,p:100};
I.u[8321] = {n:"Pelo di Dominobul",t:54,d:"È inutile insistere, questi peli non sono commestibili.",ep:21,g:664,l:100,wd:true,fm:true,w:1,p:10};
I.u[8322] = {n:"Pelo di Mominotor",t:54,d:"Sotto le bende, il Mominotor nasconde una peluria molto morbida che farebbe invidia alla più civettuola delle principesse.",ep:21,g:663,l:100,wd:true,fm:true,w:1,p:10};
I.u[8323] = {n:"Cuoio di Dominobol",t:56,d:"Questo cuoio rovinato e rugoso ti ricorderà le guance della tua amata.",ep:21,g:657,l:100,wd:true,fm:true,w:1,p:10};
I.u[8324] = {n:"Cuoio di Mominotor",t:56,d:"Il Mominotor ha sempre avuto la pelle molto fragile ed è per questo che deve ricoprirsi con numerose bende. Le malelingue dicono che lo faccia invece per nascondere altre cose alquanto sorprendenti...",ep:21,g:656,l:100,wd:true,fm:true,w:1,p:10};
I.u[8325] = {n:"Copricapo del Mominotor",t:16,d:"Se vuoi proteggere il tuo viso dalle angosce del tempo, ti consigliamo questo copricapo. Attenzione, è completamente inefficace per proteggerti dalle perdite di memoria.",ep:0,g:157,l:110,wd:false,fm:true,w:10,s:59,p:100};
I.u[8326] = {n:"Benda del Mominotor",t:15,d:"Arrotolata intorno alle corna ma soprattutto alle parti intime del Mominotor, questa benda si è impregnata per un sacco di anni di tutta la magia del Mominotor. Tanto maleodorante quanto terrificante, questa benda fa parte delle collezioni di tutti gli archelogi più famosi.",ep:21,g:734,l:100,wd:true,fm:true,w:1,p:10};
I.u[8327] = {n:"Corno di Dominobol",t:47,d:"A prima vista questo corno impressionante non serve a niente, e anche guardandolo da più vicino sembra veramente inutile. Un po\' come un esercito di zecche ad esempio.",ep:21,g:643,l:100,wd:true,fm:true,w:1,p:10};
I.u[8328] = {n:"Corno di Mominotor",t:47,d:"Questo corno arrotolato in bende magiche deve valere moltissimo, essere molto prezioso, puzzare e essere maledetto. Un po\' come una mummia, insomma...",ep:21,g:642,l:100,wd:true,fm:true,w:1,p:10};
I.u[8329] = {n:"null",t:84,d:"",ep:1,g:0,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8330] = {n:"Copricapo del Draguovo Volante",t:16,d:"Questo piccolo copricapo permette al Draguovo Volante di lanciarsi sui nemici senza rischiare di farsi dei bernoccoli sulla testa. Usato da molto tempo nei grandi cantieri di Amakna, questo copricapo ha ritrovato popolarità dopo l\'invasione di Astrub da parte delle truppe dei muulupi della montagna di Kruup. Non c\'è nessuna logica in questa storia, ma che importa?",ep:13,g:152,l:72,wd:true,fm:true,w:10,p:16000};
I.u[8331] = {n:"Copricapo della Dragosa",t:16,d:"Equipaggiato con questo copricapo, potrai facilmente travestirti e sedurre il primo Astrubiano un po\' troppo credulone che vorrai imbrogliare, proponendogli una folle notte d\'amore sotto un grande olmo per soli 100 kama...",ep:18,g:153,l:95,wd:true,fm:true,w:10,p:23000};
I.u[8333] = {n:"Mantello di Babbo Nawal",t:17,d:"Questo misterioso mantello appare nelle stagioni fredde e permette agli impostori di farsi passare per  un vecchio generoso.",ep:1,g:119,l:19,wd:true,fm:true,w:10,p:1205};
I.u[8334] = {n:"Cappello di Babbo Nawal",t:16,d:"Questo cappello ti aiuterà a nascondere le cicatrici che hai sulla testa. Finalmente smetterai di fare paura ai bambini.",ep:1,g:155,l:22,wd:true,fm:true,w:10,p:1478};
I.u[8335] = {n:"Piccolissimo Regalo di Nawal",t:89,d:"Il team Ankama ti augura buone feste. Questo regalo ti renderà felice come non lo sei mai stato.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8336] = {n:"Piccolo Regalo di Nawal",t:89,d:"Il team Ankama ti augura buone feste. Questo regalo ti renderà felice come non lo sei mai stato.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8337] = {n:"Regalo di Nawal",t:89,d:"Il team Ankama ti augura buone feste. Questo regalo ti renderà felice come non lo sei mai stato.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8338] = {n:"Spada di Nawal",t:6,d:"Questa strana spada non ti renderà invincibile, ma potrai forse usarla per uccidere tutte le palle di neve.",ep:1,g:69,l:1,wd:false,fm:true,w:1,an:14,e:[1,1,1,1,2,2,false,true],p:1};
I.u[8339] = {n:"Grande Regalo di Nawal",t:89,d:"Il team Ankama ti augura buone feste. Questo regalo ti renderà felice come non lo sei mai stato.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8340] = {n:"Incredibile Regalo di Nawal",t:89,d:"Il team Ankama ti augura buone feste. Questo regalo ti renderà felice come non lo sei mai stato.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8341] = {n:"Stivalananas",t:11,d:"Questi stivali sanno di succo di ananas macerato in un substrato di calze bucate. Il vantaggio è che i tuoi amici non ti chiederanno mai di toglierli quando andrai a trovarli.",ep:1,g:90,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8342] = {n:"Chiave del Santuario delle Draguova",t:84,d:"Questa chiave fatta di gusci di Draguova ti permetterà di accedere al terribile Santuario delle Draguova, conosciuto da tutti per i suoi abitanti poco loquaci.",ep:10,g:18,l:1,wd:true,fm:true,w:1,p:100};
I.u[8343] = {n:"Chiave del Dongione delle Draguova",t:84,d:"Pensavi di aver superato tutte le pene dell\'inferno entrando nel Santuario delle Draguova? Ti sei sbagliato. Questa chiave ti porterà probabilmente ad una morte certa.",ep:10,g:17,l:1,wd:true,fm:true,w:1,p:100};
I.u[8344] = {n:"Corno di Dragosso Nero",t:47,d:"Meno appuntite di una lancetta di Xelor, ma più robuste, queste corna permettono al Dragosso di prendere gli avversari a cornate sul sedere.",ep:11,g:648,l:50,wd:true,fm:true,w:1,p:10};
I.u[8345] = {n:"Corno di Dragosso Zaffiro",t:47,d:"Meno appuntite di una lancetta di Xelor, ma più robuste, queste corna permettono al Dragosso di prendere gli avversari a cornate sul sedere.",ep:11,g:647,l:50,wd:true,fm:true,w:1,p:10};
I.u[8346] = {n:"Corno di Dragosso Bianco",t:47,d:"Meno appuntite di una lancetta di Xelor, ma più robuste, queste corna permettono al Dragosso di prendere gli avversari a cornate sul sedere.",ep:11,g:646,l:50,wd:true,fm:true,w:1,p:10};
I.u[8347] = {n:"Corno di Dragosso Dorato",t:47,d:"Meno appuntite di una lancetta di Xelor, ma più robuste, queste corna permettono al Dragosso di prendere gli avversari a cornate sul sedere.",ep:11,g:645,l:50,wd:true,fm:true,w:1,p:10};
I.u[8348] = {n:"Guscio di Dragosso Nero",t:111,d:"Questo guscio può eventualmente servire a proteggere i tuoi beni più preziosi.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Guscio di Dragosso Zaffiro",t:111,d:"Questo guscio può eventualmente servire a proteggere i tuoi beni più preziosi.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
I.u[8350] = {n:"Guscio di Dragosso Bianco",t:111,d:"Questo guscio può eventualmente servire a proteggere i tuoi beni più preziosi.",ep:11,g:740,l:50,wd:true,fm:true,w:1,p:10};
I.u[8351] = {n:"Guscio di Dragosso Dorato",t:111,d:"Questo guscio può eventualmente servire a proteggere i tuoi beni più preziosi.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Scaglia di Dragosso Nero",t:59,d:"Questa scaglia di Dragosso potrebbe servire per fabbricare degli stivaletti o della biancheria intima da combattimento.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Scaglia di Dragosso Zaffiro",t:59,d:"Questa scaglia di Dragosso potrebbe servire per fabbricare degli stivaletti o della biancheria intima da combattimento.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"Scaglia di Dragosso Bianco",t:59,d:"Questa scaglia di Dragosso potrebbe servire per fabbricare degli stivaletti o della biancheria intima da combattimento.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Scaglia di Dragosso Dorato",t:59,d:"Questa scaglia di Dragosso potrebbe servire per fabbricare degli stivaletti o della biancheria intima da combattimento.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Pelle di Dragosa",t:59,d:"Liscia e profumata con il sangue di giovani guerrieri, questa pelle fa perdere la testa a tutte le Dragose. Usata per fabbricare stivali e cinture, ha il grande pregio di essere lavabile in lavatrice a qualsiasi temperatura.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Corno di Dragosa",t:47,d:"La Dragosa dispone di due piccoli corni dietro il cranio, che le permettono di ricevere più facilmente le onde amorose emesse dalle altre Draguova durante la stagione degli amori che, ricordiamolo, non finisce mai per questa specie...",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Protezione della Dragosa",t:111,d:"Questo paio di gusci di Draguovo permette alla Dragosa di proteggersi dai suoi colpi di fulmine. Questa protezione è utilizzabile anche dai maschi, se portata sotto la cintura.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Ala di Draguovo Volante",t:104,d:"Anche se consumata, strappata e bruciata, quest\'ala permette al Draguovo Volante di muoversi liberamente nel vuoto come un giovane Moskito sbarazzino.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Pelle di Draguovo Volante",t:59,d:"Questa pelle oscura è ricoperta da una moltitudine di piccole scaglie che dovrebbero migliorare l\'aerodinamica del Draguovo Volante, ma, in realtà servono solo a impressionare i curiosi.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Corno di Draguovo Volante",t:47,d:"Questo corno serve da mirino al Draguovo Volante per non sbagliare bersaglio quando vola in stato di ebrezza.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Pelle di Draguovo Guerriero",t:59,d:"La pelle di Draguovo Guerriero è famosa per resistere ai colpi inflitti dalla sua stessa lama, ma è soprattutto famosa per il fatto di essere commestibile... dopo essere stata bollita per molti anni.",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Corno di Draguovo Guerriero",t:47,d:"Il Draguovo Guerriero dispone di tre corni differenti, due dietro la testa e uno sul muso.  \nDi solito, dopo un combattimento, uno dei tre si ritrova piantato nel sedere della vittima, mentre gli altri due sono infilzati profondamente nelle narici di un imprudente di passaggio. Talvolta, però, il Draguovo Guerriero scambia il sedere con le narici delle sue vittime, il che provoca loro molto... ma molto più dolore.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Cinghia in cuoio di Draguovo Guerriero",t:15,d:"Questa cinghia in cuoio permette al Draguovo Guerriero di agganciare le sue spalline o di sostituire le tue bretelle.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Corno spezzato di Crocabulia",t:47,d:"Crocabulia si è rotta il corno durante un terribile combattimento nel quale cercava di proteggere l\'uovo che diede vita, quindici anni dopo, a Crocobarro.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Mantello del Capponcino Rosso",t:17,d:"Questo mantello appartiene a un celebre Cappone, un vecchio volatile dalle lunghe piume che adorava mettersi in mostra allo Zaap di Bonta, davanti al suo seguito di uccelli creduloni e pollastre immature.",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Pelle di Crocabulia",t:59,d:"Questa pelle rossa ti permetterà, forse, di confezionare un mantello del Cappuccetto Rosso, se lo scherno dei tuoi alleati non ti spaventa, ovviamente.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Dente di Crocabulia",t:47,d:"Questo enorme dente è stato strappato in extremis prima che Crocabulia chiudesse la bocca per sempre.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Frammento di Guscio di Terrapieno il Guerriero",t:111,d:"Questo frammento di guscio, appartenente a Terrapieno il Guerriero, dovrebbe aiutarti a fabbricare una chiave per il Santuario delle Draguova.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Frammento di Guscio di Ignexcalibur il Guerriero",t:111,d:"Questo frammento di guscio, appartenente a Ignexcalibur il Guerriero, dovrebbe aiutarti a fabbricare una chiave per il Santuario delle Draguova.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Frammento di Guscio di Aerosol il Guerriero",t:111,d:"Questo frammento di guscio, appartenente ad Aerosol il Guerriero, dovrebbe aiutarti a fabbricare una chiave per il Santuario delle Draguova.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Frammento di Guscio di Aquaboy il Guerriero",t:111,d:"Questo frammento di guscio, appartenente a Aquaboy il Guerriero, dovrebbe aiutarti a fabbricare una chiave per il Santuario delle Draguova.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Pietra di Ignercocopops l\'Affamato",t:51,d:"Questa pietra, se combinata assieme alle tre mancanti, dovrebbe liberare un\'onda magica abbastanza potente per attivare e aprire una porta magica.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Pietra di Aquaplanning il Guidatore",t:51,d:"Questa pietra, se combinata assieme alle tre mancanti, dovrebbe liberare un\'onda magica abbastanza potente per attivare e aprire una porta magica.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Pietra di Terrabruciata il Tattico",t:51,d:"Questa pietra, se combinata assieme alle tre mancanti, dovrebbe liberare un\'onda magica abbastanza potente per attivare e aprire una porta magica.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Pietra di Aerosmith il Rocker",t:51,d:"Questa pietra, se combinata assieme alle tre mancanti, dovrebbe liberare un\'onda magica abbastanza potente per attivare e aprire una porta magica.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Runa del Tuttofare",t:88,d:"Questa pietra magica permette ai Tuttofare di dare la loro posizione ai clienti.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Frammento Magico",t:88,d:"Questo Frammento Magico contiene una parte della magia di un vecchio oggetto. Con un po\' di fortuna dovresti riuscire a recuperare qualche runa magica.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Runa Vie",t:78,d:"Questa piccola runa rende più resistenti.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Stoffa di Peki",t:55,d:"Questa stoffa ricopriva le chiappe pelose del Peki prima che decidessi di accarezzargliele contropelo.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Coda Magica di Peki",t:65,d:"Questa coda è così magica che freme ancora, anche dopo essere stata tagliata, seccata ed imbalsamata. Con un po\' d\'impegno potrai trovarle un\'utilità diversa da quella ornamentale.",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Pelle di Moon",t:59,d:"Privato della sua dolce pelle, il povero piccolo Moon si è sentito denudato e ha preferito fuggire vigliaccamente nella giungla urlando di dolore. Una scena divertentissima che racconterai ai tuoi figli la sera prima di metterli a letto.",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Stoffa Magica di Moon",t:55,d:"Questa stoffa assomiglia a una stoffa magica, ma non riesci ad accettarlo. Eppure dovrai pure riconoscere un giorno o l\'altro che sei troppo stupido per sapere cosa è o cosa non è magico. Non seguire il tuo istinto da rompiscatole Astrubiano, fidati di queste descrizioni.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Pelle di Shin Larva",t:59,d:"La pelle di Shin Larva è ancora più viscida di quello che potresti immaginare. Ti ricorda l\'ultima principessa che hai salvato.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Dente di Shin Larva",t:47,d:"Nessuno crederebbe mai che una Shin Larva abbia la bocca piena di denti. Forse perché la Shin Larva ha solo un dente.",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Piuma Vibrante del Tofu Reale",t:53,d:"Più reale di una piuma di Tofu Reale, più vibrante della piuma di un Kirbul Vibrante delle miniere di Kruup, questa piuma farà il solletico a chi vorrai e dove vorrai. La sua manutenzione, spiegata nel manuale, è abbastanza semplice.",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Pelle di Bworketta",t:59,d:"La Bworketta ha scambiato un pezzo della sua pelle con un po\' della tua clemenza. Ma ha dimenticato di dirti che ha avvisato suo fratello maggiore, il Bworker, che ti sta cercando per strapparti la tua!",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Pelo di Bworketta",t:54,d:"La Bworketta ha la pelle liscia, tranne sotto le ascelle. Deve pure guarnire i dolci ogni tanto!",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Pelle di Maiale di Farle",t:59,d:"Farle era il più grande allevatore di maiali e forse anche di maialine, da quello che dicono gli allevatori che ardevano per Shika. Quello che la gente non sa invece è che lui ha creato i Maiali di Farle, e che gli ha dato questo nome perché li aveva creati a sua immagine e somiglianza.",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"Pelle di Don Dorgan",t:59,d:"Il Don Dorgan è stato ancora una volta molto generoso con te, malgrado il suo terribile carattere. Ti ha regalato la sua pelle prima di andare via grugnendo come un grosso Porkass. Che faccia tosta!",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"Pelle di Don Dussan",t:59,d:"Il Don Dussan che probabilmente hai pelato con una grattugia per ottenere della pelle così fine, se ne ricorderà per tutta la vita e sicuramente ti serberà rancore per molto tempo. Non contare più su di lui per conoscere la strada giusta la prossima volta che ti perderai nel suo labirinto.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Pelo di Drago Maiale",t:54,d:"Stai cercando come un matto ma non riesci a capire in quale parte del corpo del Drago Maiale fosse attaccato questo pelo? Cerca meglio! L\'anatomia del Drago Maiale può nascondere molte sorprese...",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Mega Pietra del Croccaroc Leggendario",t:51,d:"Questa enorme pietra assomiglia alla pietra del Croccaroc Leggendario, ma non è così... è molto di più!",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Mocio del Buulupo",t:15,d:"Questa fialetta contiene tutta la potenza virile del Buulupo. Attenzione: il suo contenuto non è commestibile.",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Pelo del We Wabbit",t:54,d:"Il We Wabbit è in genere molto avaro e restio a condividere i suoi peli. Eccezionalmente però, per ricompensare il tuo coraggio (o comprare la tua clemenza), ha deciso di donarti una piccola parte del suo corpo. Commovente...",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Stoffa del We Wabbit",t:55,d:"Nessuno sa, né sembra voler sapere, da dove il We Wabbit abbia tirato fuori questa stoffa. Inquietante e sconcertante allo stesso tempo, l\'origine di questa stoffa resta uno dei più grandi misteri di Amakna.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Pelo di Maestro Pandora",t:54,d:"Ancora una volta il Maestro Pandora ha voluto fare il furbo, e si è preso una bella lezione che non dimenticherà tanto presto. Avrebbe fatto meglio a restare in fondo alla sua scatola.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Stoffa di Maestro Pandora",t:55,d:"Proteggendo tanto la sua testa, quanto il suo sedere, questa stoffa ha salvato la vita del Maestro Pandora più di una volta. Ma non questa!",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Pelle di Maestro Pandora",t:59,d:"Consumata dagli attacchi magici e seccata dal vento dell\'Isola di Pandala, questa pelle ha perso tutto il suo pregio. Nonostante tutto sembri esserci molto affezionato, come se volessi conservare un prezioso ricordo di quel coraggioso Maestro Pandora, che però ha persino rischiato di ucciderti più volte e senza rimorso. È proprio in questo genere di situazione che si riconosce un vero mostro.",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Pietra del Culosse",t:51,d:"Anche se il Culosse è generoso, non ti ha dato la sua pietra di allegria del cuore, il che è comprensibile visto quello che ne faresti tu.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
I.u[8403] = {n:"Treccia del Culosse",t:15,d:"Questa enorme treccia è stata confezionata dal Culosse in persona molte centinaia di anni fa. Col tempo è diventata rigida quasi come un blocco di pietra. È comunque ancora piena di un liquido viscido e nauseabondo che attira i Moskito. La cosa più sorprendente in tutto ciò è che questa treccia donava tantissimo al Culosse, e tu hai avuto la malsana idea di rubargliela.",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Pelle di Skunk",t:59,d:"Questo pezzo di pelle sembra provenire dai talloni di Skunk, ecco perché hanno un bellissimo colore giallastro. Invece di farti dei vestiti alla moda, con questa bella pelle potrai farti dei vestiti di altre epoche e avere un aspetto \"rétro\" che farà furore tra i giovani.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Pelo di Skunk",t:54,d:"Chi, a parte te, avrebbe creduto che Skunk non si depilasse tutto il corpo fin dalla sua più tenera età?",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Lana di Minotot",t:57,d:"Questa lana ha la caratteristica di essere molto fine, e permette al Minotot di non avere nodi sul corpo. Nessuno sa a cosa serva, forse per farti dei trapianti di peli e ostentare una folta peluria bruna sul petto. Persino i sogni di bambino si possono realizzare un giorno o l\'altro!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Cuoio del Minotot",t:56,d:"Poco più raro del cuoio di Pappatutto, questo cuoio è ideale per le creazioni che hanno bisogno di cuciture semplici, come le maschere di cuoio per esempio.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Zoccolo del Minotot",t:47,d:"Questo zoccolo ha schiacciato un sacco di avventurieri, ma anche moltissime bestie che si erano perse nel labirinto del Minotoror. A difesa del Minotot bisogna riconoscere che non è sempre facile distinguerli al primo colpo d\'occhio.",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
I.u[8409] = {n:"Corno del Minotot",t:47,d:"Questo corno assomiglia da lontano a un corno di Pappatutto gigante e estremamente magico. Ma da vicino assomiglia sorprendentemente ad un corno di Minotot.",ep:21,g:655,l:400,wd:true,fm:true,w:1,p:10};
I.u[8410] = {n:"Femore del Minotot",t:47,d:"Quest\'osso imponente ha sopportato per molti secoli il grande peso del Minotot. Un\'impresa che meritava di essere ricordata.",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8411] = {n:"Amuleto del Mominotor",t:1,d:"Questo amuleto maledetto ricoperto di bende forse ti permetterà di sopravvivere alla maledizione del labirinto del Minotoror. Ma niente è meno certo, forse si tratta solo di un ninnolo destinato a stupire i turisti.",ep:0,g:114,l:111,wd:false,fm:true,w:5,s:59,p:31300};
I.u[8412] = {n:"Anello del Mominotor",t:9,d:"Questo anello, confezionato a partire da bende di Mominotor arrotolate su se stesse, puzza parecchio ed è molto brutto, ma sarà un ottimo cerotto quando ti schiaccerai le dita in una delle porte del labirinto del Minotoror.",ep:0,g:119,l:111,wd:false,fm:true,w:10,s:59,p:31525};
I.u[8413] = {n:"Martello del Mominotor",t:7,d:"Il blocco di pietra all\'estremità di questo martello è arrotolato in bende del Mominotor, per assorbire i fluidi che fuoriusciranno dalle creature che schiaccerai o semplicemente per far loro meno male e non ucciderle troppo velocemente.",ep:0,g:60,l:112,wd:false,fm:true,w:10,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>100&CI>200&CW>150",s:59,p:100};
I.u[8414] = {n:"Daghe del Draguovo",t:5,d:"Queste daghe sono ideali per tagliare la parte alta di un uovo di Draguovo cotto alla coque. Sono molto leggere e permettono di correre veloce quando gli altri Draguovi della comunità se ne accorgono.",ep:20,g:58,l:128,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CS>150&CI>150&CA>100",p:39854};
I.u[8415] = {n:"Stivali del Mominotor",t:11,d:"Imbottiti e decorati con bende di Mominotor, questi stivali sono molto confortevoli e anche molto caldi. Forse ti ricordano qualcuno.",ep:0,g:92,l:110,wd:false,fm:true,w:10,s:59,p:31255};
I.u[8416] = {n:"Mantello del Mominotor",t:17,d:"Confezionato a partire da bende del Mominotor intrecciate tra di loro, questo mantello ti darà uno stile che viene direttamente dall\'oltretomba. I tuoi nemici rischiano di crepare d\'invidia.",ep:0,g:122,l:111,wd:false,fm:true,w:10,s:59,p:31780};
I.u[8417] = {n:"Paletta per Dolci",t:8,d:"Questa piccola pala è stata offerta a un giovane Anutrof, ci era talmente affezionato che la utilizzò fino alla morte.",ep:20,g:43,l:131,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CC>250&CA>100",p:42514};
I.u[8418] = {n:"Cintura del Mominotor",t:10,d:"Questa grossa benda di Mominotor possiede un valore aggiunto straordinario, la cui origine resta tuttavia sconosciuta. Ma fa lo stesso, la si potrà vendere cara e la sua maledizione accelererà la putrefazione dei fianchi degli amici a cui offrirai questa cintura, il che, bisogna confessarlo, è semplicemente inestimabile.",ep:0,g:108,l:112,wd:false,fm:true,w:10,s:59,p:32255};
I.u[8419] = {n:"Pala Moh",t:8,d:"Con questa pala, il capitano Machab ha sventrato Grobill Dick, il grande Kralamore Bianco.",ep:20,g:42,l:115,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>200",p:33653};
I.u[8420] = {n:"Pala del Draguovo",t:8,d:"Alle Draguova piace scavare gallerie, ma non usano pale. Gli Anutrof hanno cercato di risolvere per molto tempo questo enigma, e alla fine si sono detti che era più importante saperla usare per picchiare piuttosto che conoscerne la provenienza.",ep:20,g:45,l:127,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,40,40,false,true],c:"CC>200&CS>100",p:42154};
I.u[8421] = {n:"Certificato di Deposito al Cianil: Cattivo Piccolo Cuervoc",t:77,d:"Questo Certificato descrive le caratteristiche del Cattivo Piccolo Cuervoc che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8422] = {n:"",t:18,d:"...",ep:1,g:39,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[8423] = {n:"",t:89,d:"",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8424] = {n:"Regalo di compensazione dell\'Allevatore",t:89,d:"Questo regalo è destinato agli allevatori, contiene tutto il necessario per riempire un recinto di eccellenti macchine d\'allevamento. (Attenzione, questo regalo contiene oggetti molto pesanti, rischi di sovraccaricarti al momento dell\'apertura).",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8425] = {n:"Borsa di 10000 Kama",t:100,d:"Questa borsa è molto pesante, contiene sicuramente una grande fortuna. Un mercante sarebbe entusiasta di scambiarla contro il suo valore in kama.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:100000};
I.u[8426] = {n:"",t:74,d:"",ep:1,g:30,l:1,wd:false,fm:true,w:1,c:"(PX=3)|(PX=4)",ut:true,p:1};
I.u[8428] = {n:"Pozione d\'invisibilità Nebulosa",t:12,d:"Questa pozione permette di evaporarsi per tornare all\'ultimo punto di salvataggio senza lasciare tracce.",ep:0,g:26,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,ut:true,p:1};
I.u[8430] = {n:"Pallone Giallo Magico",t:94,d:"Al contrario delle contraffazioni che si trovano alla Fiera del trool, questo pallone sa almeno prendere il volo con grazia e facilità. È fabbricato a mano, come ai vecchi tempi, con vere piume di Tofu, secondo la tradizionale ricetta del grande mago Vahy Nez.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8431] = {n:"Pozione fumogena Ciclonica",t:12,d:"Questa pozione fumogena crea un vorticoso schermo di fumo che camuffa le tue azioni con stile.",ep:0,g:29,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,p:1};
I.u[8432] = {n:"",t:31,d:"",ep:1,g:1,l:1,wd:false,fm:false,w:0,m:true,c:"PX=3|PX=4",p:1};
I.u[8435] = {n:"Pallone Rosso Magico",t:94,d:"Al contrario delle contraffazioni che si trovano alla Fiera del trool, questo pallone sa almeno prendere il volo con grazia e facilità. È fabbricato a mano, come ai vecchi tempi, con vera palpebra di Gelatina Fragola, secondo la tradizionale ricetta del grande mago Vahy Nez.",ep:1,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8436] = {n:"Chiave del Dongione della Quercia Molle",t:84,d:"Questa chiave ti permetterà di accedere alle parti più intime della Quercia Molle, senza pertanto capire dove stai andando. Eccitante ma allo stesso tempo sconvolgente, questo viaggio verso l\'infinito e l\'aldilà non ti lascerà indifferente.",ep:1,g:236,l:1,wd:true,fm:true,w:1,p:100};
I.u[8437] = {n:"Chiave del Dongione Insabbiato",t:84,d:"Questa chiave fatta di detriti marini e di conchiglie ti permetterà di accedere alla spiaggia costituita dalla sabbia fine più fine di tutto il Mar di Asse.",ep:1,g:237,l:1,wd:true,fm:true,w:1,p:100};
I.u[8438] = {n:"Chiave del Dongione dei Ratti di Brakmar",t:84,d:"Questa chiave ti permetterà di accedere al dongione dei Ratti delle fogne di Brakmar. È inutile travestirsi, passerai inosservato anche se non sei Brakmariano.",ep:1,g:238,l:1,wd:true,fm:true,w:1,p:100};
I.u[8439] = {n:"Chiave del Dongione dei Ratti di Bonta",t:84,d:"Questa chiave ti permetterà di accedere al dongione dei Ratti delle fogne di Bonta. È inutile travestirsi, passerai inosservato anche se non sei Bontariano.",ep:1,g:239,l:1,wd:true,fm:true,w:1,p:100};
I.u[8441] = {n:"Billaureola",t:16,d:"Bill voleva un\'aureola. Si mise a gridare così forte e fece talmente tanti capricci che la ottenne... Veramente un piccolo diavolo!",ep:22,g:159,l:100,wd:true,fm:true,w:1,p:25540};
I.u[8442] = {n:"Maschera del Ratto Nero",t:16,d:"Questa maschera è servita a Bruce Bulgur per infiltrarsi in un rifugio di ratti d\'Isgustosi e tagliare un olmo dalle radici. Alla fine comunque ha massacrato tutti i ratti del rifugio, perché con quei grossi zoccoli in legno non poteva passare inosservato.",ep:2,g:158,l:102,wd:true,fm:true,w:1,s:68,p:17222};
I.u[8443] = {n:"Mantello del Ratto Nero",t:17,d:"Questo mantello può essere fabbricato con peli di ogni tipo, a condizione che siano sporchissimi. Questi poi vengono intrecciati tra di loro e fissati con varie secrezioni. L\'odore non è in opzione.",ep:13,g:123,l:105,wd:true,fm:true,w:5,s:68,p:18356};
I.u[8444] = {n:"Daghe del Ratto Nero",t:5,d:"Consumate ma ancora molto taglienti, le lame di queste daghe permettono di mozzare le membra degli avversari con una facilità sconcertante, e portando via una quantità impressionante di lembi di carne. Peccato che non siano anche arrugginite, roventi e avvelenate...",ep:8,g:59,l:108,wd:true,fm:true,w:5,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CW>100&CV>300",s:68,p:19358};
I.u[8445] = {n:"Collana del Ratto Nero",t:1,d:"Il ratto che possedeva questa collana pensava di diventare il capo del suo clan. Si è fatto mangiare da un Volpo arrabbiato.",ep:18,g:115,l:103,wd:true,fm:true,w:5,s:68,p:17650};
I.u[8446] = {n:"Stivali del Ratto Nero",t:11,d:"Fai attenzione calzando questi stivali, potrebbero contenere ancora i piedi del precedente proprietario.",ep:13,g:93,l:101,wd:true,fm:true,w:10,s:68,p:18700};
I.u[8447] = {n:"Cintura del  Ratto Nero",t:10,d:"Al contrario del suo cugino bianco bontariano, il Ratto Nero ama agire discretamente, e indossa una semplicissima cintura di stoffa. Gli piace però portarsi moltissime armi dietro, che fanno un rumore infernale scontrandosi ad ogni passo.",ep:13,g:109,l:101,wd:true,fm:true,w:5,s:68,p:18934};
I.u[8448] = {n:"Anello del Ratto Nero",t:9,d:"Gira questo anello verso destra se stringi la mano di un nemico, e verso sinistra se stringi quella di un amico. Comunque sia, ti sconsigliamo vivamente di applaudire con questo anello.",ep:20,g:120,l:98,wd:true,fm:true,w:5,s:68,p:16980};
I.u[8449] = {n:"Trasformazione del Dongione Alberagno",t:27,d:"Un Alberagno ti ha morso e ti ha trasmesso una strana maledizione.",ep:9,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8450] = {n:"Spada del Ratto Bianco",t:6,d:"Quest\'arma è il simbolo del Ratto Bianco. È famosa per la sua capacità di tagliare nemici e alleati con la stessa facilità.",ep:16,g:71,l:109,wd:true,fm:true,w:10,an:14,tw:true,e:[5,5,1,1,40,50,false,false],c:"CA>150&CS>100",s:67,p:17542};
I.u[8451] = {n:"Copricapo del Ratto Bianco",t:16,d:"Con questo copricapo, il Ratto Bianco assomiglia ad un vero Ratto Bianco di Bonta. Senza di esso, assomiglia invece ad un Ratto Bianco di Bonta senza copricapo.",ep:13,g:160,l:105,wd:true,fm:true,w:10,s:67,p:18451};
I.u[8452] = {n:"Mantello del Ratto Bianco",t:17,d:"Questo mantello è il simbolo distintivo del ratto bianco delle fogne di Bonta, gli è consegnato dopo un esame lungo e difficile, e lo indossa con fierezza fino alla morte, ovvero non per molto tempo.",ep:14,g:124,l:102,wd:true,fm:true,w:5,s:67,p:17025};
I.u[8453] = {n:"Collana del Ratto Bianco",t:1,d:"Se indossi questo oggetto come una collana, ti proteggerà dalle emanazioni tossiche proveniente dalle fogne. In compenso, se lo indossi come una cintura, proteggerà i tuoi alleati dalle TUE emanazioni tossiche.",ep:18,g:116,l:103,wd:true,fm:true,w:5,s:67,p:18900};
I.u[8454] = {n:"Guanto del Ratto Bianco",t:9,d:"Questo guanto apparteneva a Mary Té, cuoca del palazzo di Bonta. Se ne serviva per accoppare i Pappatutto che rifiutavano di farsi sgozzare, le piante selvatiche che non volevano andare nell\'insalatiera, e i clienti che non volevano mangiare.",ep:18,g:121,l:101,wd:true,fm:true,w:5,s:67,p:17150};
I.u[8455] = {n:"Cintura del Ratto Bianco",t:10,d:"Al contrario di quello che pensa il suo cugino nero brakmariano, il ratto bianco ama agire discretamente. I raccordi metallici di questa cintura sono pieni di catrame e non fanno nessunissimo rumore... a parte quando cade, e accade spesso, visto che questa cintura pesa molte tonnellate.",ep:16,g:110,l:102,wd:true,fm:true,w:150,s:67,p:18850};
I.u[8456] = {n:"Stivali del Ratto Bianco",t:11,d:"Con questi stivali il tuo equilibrio sarà perfetto, non ti sposterai di un centimetro neanche in mezzo a una bufera.",ep:3,g:94,l:99,wd:true,fm:true,w:10,s:67,p:17650};
I.u[8457] = {n:"Copricapo Cerimoniale del Signore dei Ratti",t:16,d:"Questo copricapo non ha niente a che fare con un Dora... ma proprio niente! È quindi inutile spargere false voci sulla mancanza di ispirazione degli ideatori o sulla loro poltroneria. Però è molto carino, no?",ep:13,g:173,l:133,wd:true,fm:true,w:10,s:64,p:43300};
I.u[8458] = {n:"Mantello Cerimoniale del Signore dei Ratti",t:17,d:"Questo mantello colorato fa di te un bersaglio privilegiato. Solo gli avventurieri forti e agili hanno potuto indossarlo per molto tempo.",ep:14,g:125,l:130,wd:true,fm:true,w:10,s:64,p:42030};
I.u[8459] = {n:"Collana Cerimoniale del Signore dei Ratti",t:1,d:"Per evitare di farsela rubare, questa collana è infilata al collo dell\'erede del Signore dei ratti direttamente alla nascita. Così, con l\'età adulta, l\'unico modo di toglierla è tagliargli la testa. Fatto sta che i furti restano frequenti.",ep:18,g:117,l:134,wd:true,fm:true,w:5,s:64,p:45842};
I.u[8460] = {n:"Anello Cerimoniale del Signore dei Ratti",t:9,d:"Questo anello è stato concepito all\'epoca in cui il signore dei ratti si era mutilato e gli restava solo un dito. Gli sfortunati signori che gli succedettero avevano ancora tutte le loro dita.",ep:20,g:122,l:131,wd:true,fm:true,w:5,s:64,p:42542};
I.u[8461] = {n:"Cintura Cerimoniale del Signore dei Ratti",t:10,d:"I disegni di questa cintura danno l\'impressione che tu stia prendendo fuoco. L\'illusione è così reale che la maggior parte di chi la indossa comincia a correre urlando dappertutto. Il che corrisponde esattamente al rituale della cerimonia.",ep:16,g:111,l:133,wd:true,fm:true,w:10,s:64,p:43358};
I.u[8462] = {n:"Stivali Cerimoniali del Signore dei Ratti",t:11,d:"Il primissimo Signore dei ratti è morto camminando sbadatamente su una pozzanghera di lava fusa. Questi stivali sono dedicati a lui ma attenzione, non sono ignifughi.",ep:13,g:95,l:134,wd:true,fm:true,w:10,s:64,p:43541};
I.u[8463] = {n:"Alberacasko Ancestrale",t:16,d:"Questo copricapo fu creato da Jiccì Auér per chi, come lui, ha la testa piatta. Può essere ostentato quindi senza problemi di equilibrio.\nL\'ha fatto fabbricare dopo aver battuto l\'Alberagno Ancestrale schiacciandone le nocciole tra le chiappe, ma di questo particolare si vanta meno...",ep:9,g:174,l:114,wd:true,fm:true,w:10,s:65,p:33150};
I.u[8464] = {n:"Alberantello Ancestrale",t:17,d:"In estate all\'Alberagno Ancestrale piace dorarsi al sole, ma il suo legno abituato alle foreste oscure non sopporta la luce. Questo mantello è fatto con la buccia della sua corteccia.",ep:18,g:126,l:114,wd:true,fm:true,w:5,s:65,p:33524};
I.u[8465] = {n:"Collana Ancestrale",t:1,d:"Questa collana metterà in risalto la tua barba. Se non hai la barba, puoi prendertela solo con te stesso.",ep:20,g:118,l:110,wd:true,fm:true,w:10,s:65,p:31542};
I.u[8466] = {n:"Anello Ancestrale",t:9,d:"Durante le serate in cui hai alzato il gomito, forse vedrai il Moskito intrappolato in questo anello farti l\'occhiolino. Ma non parlarne con i tuoi amici... stava facendo finta.",ep:9,g:123,l:113,wd:true,fm:true,w:5,s:65,p:33241};
I.u[8467] = {n:"Parastinchi Ancestrali",t:11,d:"Con questi parastinchi di legno massiccio, le tue gambe non temeranno più niente, ma non potrai indossare gli stivali. Vuol dire che potrai usare i parastinchi per proteggerti durante le competizioni di Pappaball, ma non potrai più fare delle entrate con gli stivali con la punta di ferro.",ep:20,g:96,l:110,wd:false,fm:true,w:10,s:65,p:31524};
I.u[8468] = {n:"Alberantura Ancestrale",t:10,d:"Questa cintura dovrebbe darti la virilità ancestrale. Ma che sia vero o no, l\'effetto è scaduto.",ep:9,g:112,l:111,wd:true,fm:true,w:10,s:65,p:32101};
I.u[8469] = {n:"Talismano della Quercia Molle",t:1,d:"Questo pezzo di legno prelevato dal cuore della Quercia Molle racchiude un enorme potere, come quello di fare arrabbiare tantissimo la Quercia Molle.",ep:20,g:119,l:138,wd:true,fm:true,w:10,s:66,p:44521};
I.u[8470] = {n:"Anello della Quercia Molle",t:9,d:"Questo anello è un escremento della Quercia Molle, anche se è in legno l\'odore resta inconfondibile!",ep:9,g:124,l:139,wd:true,fm:true,w:5,s:66,p:43014};
I.u[8471] = {n:"Infradito della domenica della Quercia Molle",t:11,d:"La domenica, la Quercia Molle fa la pennichella, e quando si sveglia vuole assolutamente che un Tronknyde le porti gli infradito senza doverli chiedere. Eppure la Quercia Molle non ha piedi...",ep:20,g:97,l:136,wd:true,fm:true,w:5,s:66,p:43521};
I.u[8472] = {n:"Mantello Consumato della Quercia Molle",t:17,d:"Più di 200 anni fa una stoffa di un tessuto insignificante si è incastrata tra i rami della Quercia Molle. L\'albero vi crebbe attorno e attraverso, impregnandolo così della sua magia. Purtroppo ora è indissociabile dal grande tronco, il che la rende poco pratica e molto infiammabile, ma la sua potenza resta innegabile.",ep:18,g:127,l:142,wd:true,fm:true,w:10,s:66,p:44578};
I.u[8473] = {n:"Perizoma autunnale della Quercia Molle",t:10,d:"In autunno, la Quercia Molle si mette il perizoma per proteggere le sue preziose ghiande, mentre in estate le porta all\'aria aperta.",ep:9,g:113,l:141,wd:true,fm:true,w:10,s:66,p:44514};
I.u[8474] = {n:"Copricapo della Quercia Molle",t:16,d:"Puoi metterti questo copricapo nel senso che più ti piace, darà comunque sempre l\'impressione di essere storto.",ep:9,g:166,l:145,wd:true,fm:true,w:10,s:66,p:45241};
I.u[8475] = {n:"",t:84,d:"",ep:1,g:240,l:1,wd:true,fm:true,w:1,p:100};
I.u[8476] = {n:"Prima Chiave del Dongione di Sfinter",t:24,d:"Questa chiave non ti basterà per entrare nel dongione di Sfinter, hai bisogno anche dell\'altra chiave!",ep:1,g:502,l:1,wd:false,fm:true,w:0,p:100};
I.u[8477] = {n:"Seconda Chiave del Dongione di Sfinter",t:24,d:"Non ti basterà questa chiave per entrare nel dongione di Sfinter, ti serve anche l\'altra!",ep:1,g:503,l:1,wd:false,fm:true,w:0,p:100};
I.u[8478] = {n:"Pozione di lecca-stivali",t:12,d:"Questa pozione davvero illegale fa paura ai migliori. Una semplice sorsata e la persona ha una sola ossessione, leccare gli stivali più vicini. Alcuni dicono che esistono delle varianti che mirano altri posti. Il malcapitato bevitore avrà quindi un cattivo alito.",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:10};
I.u[8480] = {n:"Pozione di leccapiedi",t:24,d:"Questa pozione altamente illegale è temuta persino dai migliori. In effetti, un solo piccolo sorso e chi la beve è ossessionato da un solo pensiero: leccare gli stivali più vicini. Certe voci dicono che esiste una versione alternativa che mira a leccare altro. Il solo indizio relativo a questo posto misterioso è il cattivo alito dei malcapitati.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:10};
I.u[8481] = {n:"Pelo di Ratto d\'Isgustoso",t:54,d:"Questo pelo è sporco e puzzolente, ed è stato nelle fogne più disgustose di tutta la regione... Eppure brilla ancora.",ep:2,g:670,l:42,wd:true,fm:true,w:1,p:10};
I.u[8482] = {n:"Pelle di Ratto d\'Isgustoso",t:59,d:"Questa pelle è ricoperta di piccole cicatrici che testimoniano l\'infanzia difficile di questo Ratto d\'Isgustoso. Potresti avere almeno un po\' di pietà, no?",ep:2,g:621,l:42,wd:true,fm:true,w:1,p:10};
I.u[8483] = {n:"Pelle di Sciamano d\'Isgustoso",t:59,d:"Una volta lavata, questa pelle potrà essere un buon tappeto o uno zerbino.",ep:2,g:622,l:40,wd:true,fm:true,w:1,p:10};
I.u[8484] = {n:"Pelo di Sciamano d\'Isgustoso",t:54,d:"Usato da tempo per i baffi finti, questo tipo di pelo va benissimo anche per le ascelle finte.",ep:2,g:671,l:40,wd:true,fm:true,w:1,p:10};
I.u[8485] = {n:"Stoffa del Ratto Nero",t:55,d:"Arrotolata attorno ad una lamina di legno tenero, questa stoffa serve da spugna o da gratta-chiappe. Ce n\'è per tutti i gusti!",ep:2,g:725,l:100,wd:true,fm:true,w:1,p:10};
I.u[8486] = {n:"Stoffa del Ratto Bianco",t:55,d:"Questa stoffa è grassa come un pelo di Wabbit immerso nel grasso di Blop. Protegge con efficacia dal freddo, soprattutto se le dai fuoco.",ep:2,g:726,l:100,wd:true,fm:true,w:1,p:10};
I.u[8487] = {n:"Stoffa di Sfinter Cell",t:55,d:"Questa Stoffa sembra ricoperta di uno strano prodotto chimico dagli effetti secondari sconosciuti. È meglio non tenere troppo questa stoffa tra le mani, potrebbe crescerci un grosso pelo.",ep:2,g:727,l:200,wd:true,fm:true,w:10,p:100};
I.u[8488] = {n:"Cubito del Ratto Nero",t:47,d:"Quest\'osso di ratto può essere svuotato, bucato e intagliato per farne uno strumento musicale, o una cerbottana... nel caso tu non abbia l\'orecchio musicale.",ep:2,g:658,l:100,wd:true,fm:true,w:10,p:10};
I.u[8489] = {n:"Dente di Ratto Bianco",t:47,d:"Questo dente è in realtà un orribile zanna che permetteva al Ratto Bianco di trasmettere una moltitudine di malattie mordendo le sue vittime. Un modo come un altro di ucciderle anche senza riuscire a finirle sul momento. Quando si vuole essere rispettati, il fine giustifica sempre i mezzi.",ep:2,g:659,l:100,wd:true,fm:true,w:10,p:10};
I.u[8490] = {n:"Femore di Sfinter Cell",t:47,d:"Sfinter non è mai stato il tipo da scherzare con le ossa, le spezzava in due, poi in tre, poi in quattro, e a volte anche in cinque, quando doveva risvegliare la folla assopita da un combattimento noioso.",ep:2,g:657,l:200,wd:true,fm:true,w:10,p:10};
I.u[8491] = {n:"Pelle del Ratto Nero",t:59,d:"Il Ratto Nero era noto per il suo alito cattivo, ma anche per la pelle rugosa del suo didietro. Particolare molto pratico per non scivolare sulla tazza del bagno. Sfortunatamente, il Ratto Nero non si preoccupava mai di andare al bagno, visto che abitava nelle fogne.",ep:2,g:623,l:100,wd:true,fm:true,w:1,p:10};
I.u[8492] = {n:"Pelle di Ratto Bianco",t:59,d:"Al Ratto Bianco piaceva tantissimo fare il nostalgico in fondo alle fogne, aspettando una persona gentile che lo rincuorasse. Approfittava poi dell\'ingenuità e della credulità di queste vittime per tagliarle a pezzi e arrostirle dopo averle riempite di noci di acagiù. Povere noci di acagiù!",ep:2,g:624,l:100,wd:true,fm:true,w:1,p:10};
I.u[8493] = {n:"Pelle di Sfinter Cell",t:59,d:"Chi avrebbe creduto che un giorno avresti tenuto tra le mani la pelle del celebre Sfinter?\nSicuramente non Sfinter. La sua enorme fiducia in se stesso gli è costata cara.",ep:2,g:625,l:200,wd:true,fm:true,w:10,p:100};
I.u[8494] = {n:"Corteccia di Alberagno Ancestrale",t:96,d:"Questa corteccia si è staccata dall\'Alberagno Ancestrale, senza che tu abbia dovuto strapparla con i denti.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[8495] = {n:"Gemma di Alberagno Ancestrale",t:108,d:"Tempo fa questa gemma seccata fu completamente svuotata dalla sua linfa da una creatura affamata. Se la immergi nell\'acqua, potrai vederla riprendere la sua forma iniziale, poi se aspetti ancora un po\'... potrai vederla marcire.",ep:9,g:755,l:200,wd:true,fm:true,w:1,p:10};
I.u[8496] = {n:"Radice di Alberagno Ancestrale",t:98,d:"Anche dopo essere stata strappata, questa radice vuole frustarti sul sedere o spezzarti le caviglie. Maledetta!",ep:9,g:668,l:200,wd:true,fm:true,w:1,p:10};
I.u[8497] = {n:"La ricetta della Filtunga",t:24,d:"Questo libro racchiude i segreti della Filtunga, il piatto mitico inventato da Mus Buff.",ep:16,g:95,l:1,wd:true,fm:true,w:0,u:true,p:10};
I.u[8498] = {n:"Carne di Kanigrù",t:63,d:"Questa carne è tenera come un cervello di Boo.",ep:13,g:375,l:80,wd:true,fm:true,w:1,p:1};
I.u[8499] = {n:"Carne di Koalak",t:63,d:"Di solito la carne di Koalak è abbastanza dura. Per intenerirla basta colpirla con un tronco di Kalipto. Proprio come si fa con i bambini indisciplinati.",ep:20,g:376,l:60,wd:true,fm:true,w:1,p:1};
I.u[8500] = {n:"Carne di Coccodrail",t:63,d:"Questa carne insipida può essere conservata nel fango per molti anni, prima di marcire e cominciare a prendere un po\' di gusto.",ep:4,g:377,l:70,wd:true,fm:true,w:1,p:1};
I.u[8501] = {n:"Carne di Kanigrù Conservata",t:64,d:"Adesso questa carne di Kanigrù può essere conservata diversi giorni prima di essere cucinata.",ep:13,g:387,l:80,wd:true,fm:true,w:1,p:10};
I.u[8502] = {n:"Carne di Koalak Conservata",t:64,d:"Adesso questa carne di Koalak può essere conservata diversi giorni prima di essere cucinata.",ep:20,g:388,l:120,wd:true,fm:true,w:1,p:10};
I.u[8503] = {n:"Carne di Coccodrail Conservata",t:64,d:"Adesso questa carne di Coccodrail può essere conservata per diversi giorni prima di essere cucinata.",ep:4,g:389,l:70,wd:true,fm:true,w:1,p:10};
I.u[8504] = {n:"Costata di Kanigrù",t:69,d:"Da mangiare calda e fredda, questa costata sazierà gli appetiti più voraci.",ep:13,g:132,l:80,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8505] = {n:"Rete di Koalak",t:69,d:"Questo pezzo di carne riempirà anche gli stomaci senza fondo.",ep:20,g:133,l:120,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8506] = {n:"Costata di Coccodrail",t:69,d:"Questo grande pezzo di carne è sicuramente difficile da digerire. Ma la golosità vince sempre contro la ragione.",ep:4,g:134,l:70,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8507] = {n:"Piatto di Filtunga",t:69,d:"La Filtunga è un piatto unico. Gli ingredienti che lo compongono gli danno un sapore... unico. Da servire tiepido.",ep:1,g:136,l:100,wd:true,fm:true,w:1,c:"Cv<100",u:true,ut:true,p:1};
I.u[8508] = {n:"Piatto di Filtunga",t:24,d:"Questo piatto è per Paindep, la stregona.",ep:1,g:120,l:1,wd:true,fm:true,w:0,p:1};
I.u[8509] = {n:"La ricetta della Birra Bwork",t:25,d:"Il grande mago Bworknroll svela la ricetta sacra della birra Bwork in tutti i suoi particolari di fabbricazione. Consiglia persino il modo migliore per degustarla. Una chicca per gli amatori, un incubo per coloro che hanno già bevuto questa birra senza conoscerne i segreti...",ep:1,g:130,l:10,wd:false,fm:true,w:5,u:true,p:500};
I.u[8511] = {n:"Balestra della Superpotenza Tenebrosa della Morte che uccide",t:102,d:"...",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:10,tw:true,e:[20,7,4,12,50,30,true,true],p:1};
I.u[8512] = {n:"",t:85,d:"",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8513] = {n:"Scalpello di Bworknroll",t:5,d:"Per raccogliere \"pezzi\" di creature non c\'è niente di meglio che lo Scalpello di Bworknroll che preserva la vitalità delle membra strappate. Bisogna utilizzarlo in combattimento per prendere i pezzi desiderati.",ep:1,g:60,l:40,wd:true,fm:true,w:10,an:13,e:[10,4,1,1,30,50,false,false],c:"Qa=166",p:100};
I.u[8514] = {n:"Cervello di Vampiro",t:15,d:"Il cervello del vampiro è sempre ricco di globuli freschi perché aspira a sé tutti i globuli rossi disponibili. Per questo i vampiri sono pallidi. Negli Yop, sono piuttosto i piedi a attirare il sangue... ecco perché sono più bravi a saltare che a riflettere.",ep:3,g:492,l:20,wd:true,fm:true,w:2,u:true,p:10};
I.u[8515] = {n:"Osso di Trooll",t:47,d:"Quando si constatano la robustezza e il peso di un osso di Trooll, si capisce meglio perché le loro sberle facciano così male durante una partita di gioco Trooll.",ep:4,g:640,l:5,wd:true,fm:true,w:50,p:50};
I.u[8516] = {n:"Cuore di Bworkselana",t:15,d:"Questa Bworkina senza cuore, che ha gettato il figlio Krazybwork in un fosso, è stata maledetta da Bworknroll dopo averne rifiutato l\'amore. Rinchiusa in una cantina, vive nutrendosi del suo cuore ogni giorno. Ma di notte il cuore ricresce e batte di nuovo all\'impazzata.",ep:4,g:518,l:33,wd:true,fm:true,w:33,p:33};
I.u[8517] = {n:"Cocozza",t:15,d:"Questa bella Cocozza fresca serve ai Bwork soli che partono in saccheggio lontano dalle loro compagne.",ep:3,g:756,l:1,wd:true,fm:true,w:3,p:21};
I.u[8518] = {n:"Cocozze fritte",t:69,d:"Nelle profondità del Mar di Asse, le Cocozze raccolgono le alghe per passarsele sotto le ascelle.\nQuando questa sostanza si trasforma in patate fritte, vanno sulla spiaggia per farle dorare al sole prima di ingoiarle.",ep:3,g:135,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:30};
I.u[8519] = {n:"Gatrooll",t:69,d:"Questo dolce rituale riempito di kaka di Trooll è una vecchia ricetta Bwork. Solo un Bwork che ha battuto un Trooll a mani nude ha il diritto di mangiarne. Se è sopravvissuto a un combattimento del genere, potrebbe mandar giù qualsiasi cosa.",ep:1,g:136,l:5,wd:true,fm:true,w:20,u:true,p:200};
I.u[8520] = {n:"Gratrooll",t:60,d:"Questo grasso spesso e nutriente consente di cuocere la maggior parte degli alimenti in vecchi pentoloni senza che si appiccichino. Alcuni adepti Osamodas lo usano anche per far scivolare i Tofu in luoghi che la morale Yop disapprova.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[8521] = {n:"Il Mantello Rosso",t:17,d:"Il mantello rosso è l\'artefatto preferito dai megalomani. Quando lo posano sulle loro fragili spalle, gli sembra quasi di essere Superman o un mago superpotente, ma poi incrociano un Minotoror e...",ep:1,g:128,l:9,wd:false,fm:true,w:1,p:200};
I.u[8522] = {n:"Lanciatore di Effetti Magici",t:74,d:"Questo oggetto sorprendente è un concentrato di magia nera abbastanza instabile. Nessuno sa cosa racchiuda, ma ti consigliamo di non aspettare troppo prima di usarlo.",ep:1,g:31,l:1,wd:false,fm:true,w:0,ut:true,p:1};
I.u[8523] = {n:"La reliquia dei Robilo",t:24,d:"Questo oggetto familiare originato da un flusso magico estremamente potente, trasmesso da generazione in generazione tra i membri della famiglia Robilo, non ha perso nulla del suo grande potere. Esistono pochi oggetti che emanano una tale forza, potrebbe essere stato a contatto con un Dofus...",ep:1,g:714,l:200,wd:true,fm:true,w:0,p:1};
I.u[8524] = {n:"Fantasma di Walk",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:45,l:1,wd:true,fm:true,w:1,p:1};
I.u[8525] = {n:"Uovo di Pìu",t:69,d:"Le uova di Pìu sono veramente una prelibatezza per i più golosi. Tuttavia, si schiudono molto in fretta quando sono vicine a una fonte di calore. Ecco perché bisogna evitare di tenersele in tasca o in bocca, dato che dopo qualche minuto un mini pìu potrebbe uscire dal guscio. E avere un pìu affamato incastrato tra i denti o che s\'infila tra i vestiti può solleticarti il palato o altre parti del corpo ben più intime.",ep:4,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[8526] = {n:"Certificato di Deposito al Cianil: Koalak Sanguigno",t:77,d:"Questo Certificato descrive le caratteristiche del Koalak Sanguigno che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8527] = {n:"Gobtrottar",t:11,d:"Questi stivali in pelle di goblin sono stati creati da Planbworksek per attaccare il nemico (preferibilmente alla schiena) con grande velocità. Calzando questi stivali, ha salvato più di un compagno Bwork in difficoltà.",ep:4,g:98,l:14,wd:true,fm:true,w:20,p:400};
I.u[8528] = {n:"La ricetta delle crêpes",t:25,d:"Grazie a Pol Bokuz saprai finalmente fare la pasta delle crêpes per dare da mangiare ai tuoi bambini e metterli a letto. Il segreto di questa ricetta nutriente e soporifera: la birra di Astrub naturalmente!",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[8529] = {n:"Il Martello dello Zaap",t:24,d:"Per riparare uno Zaap sregolato, non c\'è niente di meglio di un buon colpo di martello!",ep:1,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[8530] = {n:"Ruskapo",t:16,d:"Questo copricapo tiene caldo alle orecchie e assorbe gli effluvi d\'alcool del tuo alito. Cosa vuoi di più?",ep:22,g:167,l:151,wd:true,fm:true,w:10,p:46280};
I.u[8531] = {n:"Cuniyocapo",t:16,d:"Chi avrebbe il coraggio di indossare un copricapo del genere? Nessuno... eccetto te!",ep:1,g:168,l:33,wd:true,fm:true,w:6,p:3000};
I.u[8532] = {n:"Mantello del Cuniyo Deluso",t:17,d:"Con questo mantello sulle spalle potrai finalmente mostrare alle persone a cui dai la schiena che sei veramente deluso a causa della loro stupidità.",ep:1,g:129,l:14,wd:true,fm:true,w:1,p:775};
I.u[8533] = {n:"Il Flud",t:16,d:"Il Flud non è veramente un cappello, ma piuttosto un parassita che si sviluppa sulla testa dei personaggi troppo loquaci, rumorosi o semplicemente maleducati. L\'aspetto ripugnante fa fuggire tutti, il che spinge chi lo porta a gridare ancora più forte per farsi sentire, ma senza successo... poiché non ha niente da dire.",ep:1,g:169,l:1,wd:true,fm:true,w:1,s:69,p:100};
I.u[8534] = {n:"Il Mantello Slok",t:17,d:"Questo mantello foderato assorbe tutti i rumori ambientali, costringendo chi lo porta a urlare in continuazione.",ep:1,g:130,l:1,wd:true,fm:true,w:10,s:69,p:100};
I.u[8535] = {n:"I Ficcanaso",t:11,d:"Questi Geta sono così leggeri che spingono i proprietari a correre e a saltare in tutti i sensi quando un combattimento inizia. Gli avventurieri esperti odiano i Geta, perché permettono a chiunque di prendere parte a un combattimento senza essere stato invitato.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8536] = {n:"La Spametta",t:10,d:"Questa cintura si porta talmente stretta che obbliga quasi il suo proprietario a balbettare, tremolare, e fare di tutto quando la indossa.",ep:1,g:114,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8537] = {n:"Il Piusano",t:9,d:"Questo anellino molto vistoso non serve a niente, giusto a far vedere agli altri che esisti anche tu.",ep:1,g:125,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8538] = {n:"Il s\'Mesmo",t:1,d:"Dopo numerose notti di duro lavoro per realizzare questo amuleto, il più grande Orefice di Astrub, noto per essere stato allevato dai Bwork, esclamò davanti a una folla stupita: \"È 1 amu trp bll!\". Neanche l\'illustre storico Champo Gnon riuscì mai a decifrare le strane parole dell\'Orefice.",ep:1,g:120,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8539] = {n:"Ascia dell\'Apprendista Taglialegna",t:19,d:"Anche se non sai maneggiare le asce molto bene, con questa non rischierai di tagliarti, viste le condizioni di usura della lama. Ma comunque, colpendo abbastanza forte, riuscirai forse a tagliare qualche albero.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:0};
I.u[8540] = {n:"Falce dell\'Apprendista Contadino",t:22,d:"È una falce di mediocre qualità, ma te l\'hanno regalata... non lamentarti. Inoltre falcia il grano come si deve, ed è più che sufficiente.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[8541] = {n:"Canna dell\'Apprendista Pescatore",t:20,d:"In effetti questa canna da pesca ha conosciuto tempi migliori, la lenza non è più tanto solida e l\'amo è un po\' arrugginito. È perfetta per pescare ghiozzi.",ep:1,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,1,100,100,false,false],p:1};
I.u[8542] = {n:"Guanti dell\'Apprendista Alchimista",t:20,d:"Sono guanti di qualità indiscutibile, quasi senza buchi, l\'odore di sudore del vecchio proprietario si sente appena, le dita sono un poco troppo corte, e non tengono su... Una qualità indiscutibile, infatti sono una porcheria!",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:1};
I.u[8543] = {n:"Birra di Incarnam",t:79,d:"Questa birra creata dagli dei è un miscuglio di acqua, bolle e luppolo. Rinvigorisce i giovani spiriti appena arrivati a Incarnam. Per i più esperti, invece, non è altro che acqua gassata buona solo per allenarsi per i concorsi di rutti.",ep:1,g:4,l:1,wd:true,fm:true,w:1,c:"PL<16",u:true,ut:true,p:1};
I.u[8544] = {n:"Certificato di Deposito al Cianil: Walk",t:77,d:"Questo Certificato descrive le caratteristiche del Walk che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8545] = {n:"Chiave del Dongione di Incarnam",t:84,d:"Questa chiave ti permette di entrare nel dongione di Incarnam, abitato dal terribile Milimilupo.",ep:1,g:19,l:1,wd:true,fm:true,w:1,p:10};
I.u[8546] = {n:"Pelle di Milimilupo",t:59,d:"Piccoli boccoli fanno di questa pelle un bel tappeto da letto. Sicuramente ad Incarnam qualcuno sarà disposto a barattarla... ma chi?",ep:1,g:3,l:1,wd:true,fm:true,w:10,p:1};
I.u[8547] = {n:"Trisfimizinik inik sciittilik",t:31,d:"Lik niccilinik milidittik nicinik grivimintik illik silitik.",ep:1,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8548] = {n:"Twasfowmazione in Wabbit",t:31,d:"Le Cawote maledette fanno male alla salute.",ep:8,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
