I.u[8688] = {n:"Trasformazione Fantasma Ross",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Contrassegno di vittoria",t:24,d:"Hai battuto il discepolo abbastanza facilmente. Ti ha dato questa pergamena come attestato.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Formula di Pozione di Trasformazione",t:24,d:"Questa raccolta contiene le teorie di diversi Alchimisti sulla possibilità di trasformarsi in Wabbit. Si vede che non hanno niente di meglio da fare...",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Fëanor",t:18,d:"Grazie a questo famiglio qualsiasi persona di sesso opposto ti farà gli occhi dolci. Un consiglio: evita di esultare. Ti accorgerai presto che in realtà l\'ammiratore/trice è ipnotizzato/a da Fëanor. Non sperare neanche di approfittarne: ormai il/la tuo/a spasimante mangia Pescis crudo strusciandosi contro le tue gambe... Hai passato tempi migliori, vero? Questo famiglio mangia solo pesce.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Spezia Candita",t:42,d:"Questa spezia candita è avvolta in una caramella rossa fusa strapotente. Questo miscuglio esplosivo tra la confetteria e la drogheria ha permesso al dragacchino Bruyer Blond di vincere la più celebre gara di Dragokart. Puoi usarla come supposta se vuoi avere il pepe al fondoschiena o come pastiglia se vuoi un alito ben carico.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"La Spada Nis",t:6,d:"Come diceva Brice: \"Non sono le dimensioni che contano, ma come si usa\".",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
