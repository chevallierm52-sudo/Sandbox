I.u[8557] = {n:"Piuma del Batofu",t:53,d:"Questa piuma direttamente strappata dalle ascelle del Batofu, emana un odore di Ascell ancestrale marinato.",ep:3,g:120,l:20,wd:true,fm:true,w:1,p:10};
I.u[8558] = {n:"Cappello del Cuniyo",t:16,d:"Se devi discutere con un Wabbit, forse hai proprio bisogno di questo copricapo. Se devi sedurre qualcuno, metti questo copricapo sulla testa dei tuoi rivali.",ep:1,g:170,l:6,wd:true,fm:true,w:10,p:12000};
I.u[8559] = {n:"La MmmMmmMmmm",t:16,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:2,g:171,l:42,wd:true,fm:true,w:1,p:420};
I.u[8560] = {n:"",t:18,d:"",ep:1,g:40,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[8561] = {n:"Bebé Pandawa",t:18,d:"Questo adorabile bebé Pandawa ti seguirà dappertutto per scoprire il mondo con i suoi grandi occhi rotondi. Questo famiglio addomesticato mangia riso, ma gli piacciono anche le noccioline.",ep:3,g:42,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8563] = {n:"Titi Goblet",t:32,d:"Titi deve incontrare il suo futuro professore di magia.",ep:1,g:18,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[8564] = {n:"Certificato di Deposito al Cianil: Bebé Pandawa",t:77,d:"Questo Certificato descrive le caratteristiche del Bebé Pandawa che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8565] = {n:"Fantasma di Bebé Pandawa",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[8566] = {n:"Trasformazione Fantasma Walk",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8567] = {n:"Trasformazione Fantasma Bebé Pandawa",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8568] = {n:"Regalo Bebé Pandawa",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8569] = {n:"Doro Black",t:16,d:"Questo copricapo apparteneva ad una piccola Xelorina che si divertiva un sacco a sregolare il tempo. La leggenda racconta che in questo modo riuscì a rubare molti giorni agli abitanti di Amakna. È riuscita a sedare la collera della popolazione solo distribuendo dei dolcetti.",ep:22,g:172,l:129,wd:true,fm:true,w:10,p:42512};
I.u[8570] = {n:"Pelo di Ratto Bontariano",t:54,d:"Questo pelo apparteneva ai ratti delle fogne di Bonta, i soli che avevano i ciuffi di peli coordinati ai colori delle mura della loro città.",ep:2,g:672,l:40,wd:true,fm:true,w:1,p:10};
I.u[8571] = {n:"Pelo di Ratto Brakmariano",t:54,d:"Questo pelo apparteneva ai ratti delle fogne di Brakmar, i soli che avevano i ciuffi di peli coordinati ai colori delle mura della loro città.",ep:2,g:673,l:40,wd:true,fm:true,w:1,p:10};
I.u[8572] = {n:"Pozione d\'oblio: \'Addomesticamento di Cavalcatura\'",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo  \"Addomesticamento di cavalcatura\".",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8573] = {n:"Pozione d\'oblio: \'Boomerang perfido\'",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo  \'Boomerang perfido\'.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8574] = {n:"Dofus Aceto",t:23,d:"Con o senza pancetta, questo Dofus resta sempre buonissimo.",ep:0,g:13,l:1,wd:false,fm:true,w:1,p:1};
I.u[8575] = {n:"Il Ramboton",t:4,d:"Un famoso guerriero Feca che viveva nella giungla di Pandala diceva spesso: \"Per vincere la guerra, bisogna diventare guerra!\".",ep:1,g:71,l:200,wd:false,fm:true,w:20,an:12,tw:true,e:[7,3,1,2,42,42,false,true],c:"PN~xxramboplxx",p:100000};
I.u[8576] = {n:"Pergamena di Raccomandazione d\'Yse Vewybad",t:24,d:"Questa pergamena ti è stata consegnata da Yse Vewybad per i servizi resi.",ep:2,g:26,l:20,wd:false,fm:true,w:0,p:1};
I.u[8588] = {n:"Insegna Ladrurbo",t:24,d:"Questa insegna, data da un Ladrurbo, sarà forse la chiave per entrare nel suo nascondiglio.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[8590] = {n:"Contratto tra Vil Smis e Yse Vewybad",t:24,d:"Questo contratto è la prova della disonestà di Yse Vewybad. Non ti resta che portarlo a chi di dovere.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[8593] = {n:"Pozione di Trasformazione in We Wabbit",t:27,d:"Questa pozione ti è stata data da Uba Tessé. Ti trasformerà in Wabbit e dovrebbe permetterti di farti passare per il pretendente alla mano di Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8594] = {n:"Pozione di Twasfowmazione in We Wabbit",t:27,d:"Questa pozione ti è stata data da Uba Tessé. Ti trasformerà in Wabbit e dovrebbe permetterti di farti passare per il pretendente alla mano di Allisteria.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8595] = {n:"Uovo di Tofu Obeso",t:24,d:"Questo uovo racchiude un Tofu obeso, forse il futuro vincitore del principe di We.",ep:1,g:122,l:1,wd:true,fm:false,w:0,p:1};
I.u[8596] = {n:"Artiglio Purpureo",t:6,d:"Questa spada affilata ha assunto questa tinta purpurea così elegante dopo aver sventrato migliaia di Bwork, mentre prima era solo viola scuro.",ep:22,g:72,l:145,wd:true,fm:true,w:15,an:14,tw:true,e:[8,6,1,1,45,100,false,false],c:"CS>350&CV>400",p:52000};
I.u[8597] = {n:"Pozione di Ingrassamento",t:24,d:"Questa pozione permetterà a Vil Smis di ingrassare il Tofu obeso che gli hai portato.",ep:3,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[8598] = {n:"Daghe Rattugia",t:5,d:"Queste daghe sono perforate sulla lama in modo da emettere un piccolo fischio quando le si muove rapidamente. I buchi sono efficaci anche per tirar via le viscere dai nemici.",ep:22,g:61,l:67,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CA>100",p:10654};
I.u[8599] = {n:"Artiglietti",t:5,d:"Queste daghe sono state forgiate per un\'Ecaflipetta maniaca della manicure. Pensava che le spade pesanti si abbinassero male con i suoi graziosi artigli smaltati.",ep:22,g:62,l:69,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,30,false,true],c:"CA>100&CS>100",p:11254};
I.u[8600] = {n:"La pigrizia di salire le scale",t:30,d:"Ti sei stancato molto a forza di gridare, e per questo non pensi di fare altrettanti gradini almeno per altri 6 minuti...",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8603] = {n:"Divisa del valletto del principe Wabbit",t:24,d:"Con questa divisa, il valletto del principe Wabbit sarà all\'ultima moda.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8604] = {n:"Spada Botanica",t:6,d:"Questa spada brillante è l\'ideale per raccogliere i fiori, anche quelli che si difendono. Può anche essere usata per raccogliere gli alberi.",ep:22,g:73,l:100,wd:true,fm:true,w:10,an:14,e:[15,8,1,1,40,50,false,false],c:"CS>250&CI<1",p:25654};
I.u[8605] = {n:"Spada Zervativa",t:6,d:"Questa lama è lubrificata per scivolare più facilmente nella sua guaina. In compenso è impossibile da pulire e deve essere gettata dopo l\'uso, soprattutto quando è ricoperta di sangue. Non dimenticare che serve soprattutto a proteggerti.",ep:22,g:74,l:73,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,40,50,false,true],c:"CS>80&CI>80&CA>80",p:14000};
I.u[8606] = {n:"Vestito da Sposa",t:24,d:"Il vestito da sposa è accuratamente piegato in questo pacco. Non ti rimane che portarlo all\'intendente San Lavals.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8607] = {n:"Il Bastone Chiodato",t:4,d:"Si tratta di un grosso bastone con dei chiodi piantati dentro. Non cercare altro, è semplicissimo, eppure è estremamente efficace per staccare i denti dei tuoi avversari.",ep:22,g:72,l:107,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,50,false,true],c:"CA>150&CI>150",p:29856};
I.u[8608] = {n:"La Bastonatrice",t:4,d:"Si dice che un discepolo di nome Fraye abbia usato questo bastone per difendere la moglie e il figlio contro un gregge di Pappatutto impazzito. La cosa triste è che abbia confuso la sua famiglia con il resto delle terribili creature.",ep:22,g:73,l:85,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,35,40,false,true],c:"CW>150&CV>200",p:20000};
I.u[8609] = {n:"Geish\'Arco",t:2,d:"Quest\'arco è leggero, fine, elegante e sa di fiori di ciliegio. Ma può anche essere un arco pericolosissimo se non lo si usa solo per pavoneggiarsi.",ep:22,g:56,l:81,wd:true,fm:true,w:15,an:10,tw:true,e:[5,4,3,7,30,50,false,true],c:"CA>200",p:16900};
I.u[8610] = {n:"Il Kikularc",t:2,d:"Se sollevi bene quest\'arco e pronunci con impeto le parole \"Pampulu Pimpulu Parimpampum!\", avrai veramente l\'aria ridicola.",ep:22,g:57,l:79,wd:true,fm:true,w:10,an:10,tw:true,e:[7,5,4,7,30,50,false,true],c:"CI>150&CC>150",p:15320};
I.u[8611] = {n:"Bacchetta Caffé",t:3,d:"Questa bacchetta appartiene al celebre Grinegò, che fa un buonissimo caffé ma che non venderà la sua scala.",ep:22,g:61,l:72,wd:true,fm:true,w:15,an:11,e:[5,3,2,4,15,50,false,true],c:"CI>100&CC>100",p:16500};
I.u[8612] = {n:"La Bidjiz",t:3,d:"Con la Bidjiz riuscirai a sopravvivere soprattutto perché i tuoi avversari si metteranno a ballare contemplando le numerosissime sfaccettature della sfera che orna questa bacchetta.",ep:22,g:62,l:79,wd:true,fm:true,w:10,an:11,tw:true,e:[10,4,2,5,40,50,false,true],c:"CA>150",p:18000};
I.u[8613] = {n:"Pala Politik",t:8,d:"Creata come un\'opera d\'arte di forgimagia, questa pala scava malissimo la terra ma egregiamente la testa dei tuoi avversari.",ep:22,g:46,l:70,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,30,50,false,false],c:"CC>100",p:13540};
I.u[8614] = {n:"Pala Raschietto",t:8,d:"Magnifica invenzione, questa pala due-in-uno permette di scavare una tomba e poi di fare da croce. Sempre che si perda un solo compagno alla volta, altrimenti dovrai scavare le altre tombe con le mani!",ep:22,g:47,l:66,wd:true,fm:true,w:1,an:16,tw:true,e:[5,4,1,1,20,30,false,false],c:"CI>100&CC>50",p:1};
I.u[8615] = {n:"Martello Tomato",t:7,d:"Questo martello riduce così facilmente le teste in poltiglia, che ha preso un elegante colorito rosso pomodoro.",ep:22,g:61,l:83,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100&CV>100",p:17560};
I.u[8616] = {n:"Martello Minoker",t:7,d:"Questo martello è stato creato all\'epoca del Re Steve, che ha terrorizzato milioni di persone.",ep:22,g:62,l:178,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,40,50,false,true],c:"CI>350&CW>180",p:10000};
I.u[8617] = {n:"Ascia Ebbah",t:19,d:"Per dire ti amo.",ep:22,g:45,l:62,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,20,30,false,false],c:"CV>150",p:10200};
I.u[8618] = {n:"Ascia Euluh",t:19,d:"Questa strana ascia è concepita in modo da decapitare i Bwork più facilmente. La disinvoltura con la quale decapita anche gli abitanti di Astrub indica chiaramente che esiste un legame tra questi due popoli. Ma ancora nessuno ha trovato quale.",ep:22,g:46,l:80,wd:true,fm:true,w:10,an:17,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>120&CA>60",p:16700};
I.u[8619] = {n:"Elmo Kemmidici",t:16,d:"Grazie a questo elmo guerriero, gli Yop hanno veramente un\'andatura fiera. Il solo problema è che nasconde una parte del campo visivo e impedisce di ascoltare correttamente le parole dei loro avversari. L\'elmo Kemmidici è veramente fatto per la gente a cui piace picchiare senza riflettere.",ep:22,g:175,l:40,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8620] = {n:"null",t:28,d:"",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8621] = {n:"Cawota Maledetta",t:94,d:"Questa cawota appetitosa sembwa essewe owdinawia ma puzza di maleficio a chilometwi di distanza. Weistewai alla tentazione di addentawla?",ep:8,g:6,l:21,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[8624] = {n:"Pallone Blu Magico",t:94,d:"Al contrario delle contraffazioni che si trovano alla fiera del Trool, questo pallone sa almeno prendere il volo con grazia e facilità. È fabbricato con una larva blu, svuotata mentre ancora si muoveva, poi gonfiata da un Trooll, secondo la tradizionale ricetta del grande mago Vahy Nez.",ep:1,g:7,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8625] = {n:"Pallone Verde Magico",t:94,d:"Questo pallone verde è lo strano risultato che si produce dopo che una larva verde mangia un Champignon Luidegit. Da notare che dopo un pasto del genere, quasi sempre gli occhi della larva escono dalle orbite e rotolano per terra. Sono spesso i bwork dei dintorni che li raccolgono, ghiotti di questi stuzzichini per i loro aperitivi. Questo pallone a ispirato le famose ricette del grande mago Vahy Nez.",ep:1,g:8,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8626] = {n:"Niccilinik milidittik",t:94,d:"kistik niccilinik ippititisik hik ink ispittik ciminik mik inik riltik ik imprinitik dik inik grindik milidizinik. Risistirik illik tintizinik dik mirdirlik?",ep:6,g:9,l:21,wd:false,fm:true,w:1,u:true,ut:true,p:100};
I.u[8627] = {n:"Flauto di Sarr Ys",t:3,d:"Collega e amico del celebre Guy-guy (parente stretto della Quercia Molle), Sarr Ys è un trovatore le cui incantevoli note sono scolpite nelle memoria di Amakna. Sfortunatamente questo brillante artista è tragicamente morto in un incidente di Quaquà, durante un festino estivo.",ep:1,g:63,l:1,wd:false,fm:true,w:10,an:11,e:[10,6,2,3,100,30,false,true],p:1};
I.u[8628] = {n:"Cappello Oping",t:16,d:"Questo copricapo infonde sicurezza e temerarietà a colui che lo porta. Grazie a lui sarai sempre in prima linea, convinto di poter realizzare qualsiasi impresa. Ricordati comunque di levarlo ogni tanto, altrimenti ti trascinerà in situazioni inestricabili!",ep:22,g:185,l:40,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8629] = {n:"Cappello Niente",t:16,d:"A causa di questo cappello, gli avversari diventano spesso muti come una tomba. Non si sa proprio a cosa voglia assomigliare questo copricapo, ma non fa niente... Gli Etram non sono molto permalosi.",ep:22,g:179,l:40,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8630] = {n:"Cappello Ayomatto",t:16,d:"Questo copricapo assomiglia molto al Sulik e al Piruk. Ma siccome è molto comodo e gli Xelor non se lo tolgono mai, neanche per dormire, è comunemente chiamato Cappello Ayomatto. Emana un gradevole odore di té che concilia il sonno, ma provoca un russare fastidiosissimo come il canto dei rospi durante la stagione dell\'amore.",ep:22,g:177,l:40,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8631] = {n:"Copricapo Kefar",t:16,d:"Grazie al Copricapo Kefar, gli Aniripsa sanno sempre come agire nei casi di emergenza. Effettivamente, la lista dei gesti di primo soccorso è scritta in piccolo nel risvolto. Questo copricapo gli conferisce un\'aria dottorale, da giovani diplomati, ma nessuno al mondo metterebbe mai un cappello così ridicolo a una cerimonia scolastica.",ep:22,g:184,l:40,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8632] = {n:"Cappello N\'cione",t:16,d:"Si potrebbe credere che questo cappello sia di un bel colore arancione. Proprio per niente! In più questo accessorio di moda sembra più una maschera che un cappello. Allora perché i creatori l\'hanno chiamato Cappello N\'cione? Sicuramente per far parlare i pettegoli!",ep:22,g:178,l:40,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8633] = {n:"Cappello Sparanza",t:16,d:"Gli spunzoni affilati che escono da questo cappello non permettono solo di ferire l\'avversario ma anche di avere più possibilità di prendersi un fulmine sulla testa durante i temporali. I Sàcrido sono effettivamente una classe che ama tanto fare soffrire gli altri quanto se stessi. Un buon odore di carne alla griglia: niente di meglio per cominciare la giornata.",ep:22,g:180,l:40,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8634] = {n:"Cappuccio Apino",t:16,d:"Grazie a questo copricapo avrai veramente l\'aspetto di una bestia cornuta, che la gente si girerà sicuramente ad osservare. Questo ampio cappuccio serve inoltre per conservare al fresco certi alimenti come il fieno dei Pappatutto o il pane dei Tofu.",ep:22,g:181,l:40,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8635] = {n:"Cappello Politico",t:16,d:"Questo cappello ha la capacità di far promettere a chi lo porta cose impossibili e che dimenticherà subito. Forse perché esercita una pressione sulla zona della memoria o su quella del linguaggio? Nessuno lo sa con precisione. La cosa importante è ricordarsi di prendere sul serio solo le cose meno stravaganti.",ep:22,g:176,l:40,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8636] = {n:"Copricapo di Roby Cappuccio",t:16,d:"Roby Cappuccio era un celebre Ocra che viveva nei boschi, e che aveva un copricapo verde per mimetizzarsi con il paesaggio. Si credeva un giustiziere e passava tutto il suo tempo a rubare i soldi dei ricchi per una buona causa: la sua.",ep:22,g:186,l:40,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8637] = {n:"Cappello Guida",t:16,d:"Indossando questo copricapo, il Feca aumenta la propria fortuna e quella degli alleati. Se il tuo gruppo è guidato da un Feca che porta un Cappello Guida, puoi essere sicuro di raggiungere la tua meta senza un graffio. L\'odore è così nauseante che ne fa l\'oggetto ideale per proteggersi dalla vedova e dall\'orfano.",ep:22,g:182,l:40,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8638] = {n:"Cappello Fornello",t:16,d:"Questo copricapo serve tanto da protezione contro le intemperie quanto da accessorio da cucina per preparare dei piatti alla giusta temperatura. Agitare il cappello permette l\'afflusso d\'aria necessaria alla buona cottura. Tutti sanno che in cucina bisogna avere pazienza, ecco perché gli Anutrof hanno dei polsi così muscolosi.",ep:22,g:183,l:40,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8639] = {n:"Mantello Olonello",t:17,d:"Un mantello che sventola al vento è indispensabile se vuoi avere un aria da guerriero, soprattutto quando giri la schiena all\'avversario. Alcuni pensano che sia rinforzata da una placca di metallo che contrasta qualsiasi colpo.",ep:22,g:131,l:80,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8640] = {n:"Mantello Dollars",t:17,d:"Fatto di un tessuto dolce e resistente, questo mantello dà agli Ecaflip l\'impressione di essere sempre i migliori, qualunque cosa accada. Quando vincono adorano avvolgersi in questo vestito prima di richiedere la ricompensa: \"E adesso, devi pagare!\"",ep:22,g:133,l:80,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8641] = {n:"Mantello Quilone",t:17,d:"Questo mantello è così leggero e così fine che volerebbe al minimo soffio di vento... qualsiasi vento. Non è molto pratico, soprattutto quando si ha bisogno di essere discreti dopo un pasto fatto di birra e fagioli.",ep:22,g:140,l:80,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8642] = {n:"Passamantello",t:17,d:"Il colore scuro di questo mantello gli permette di abbinarsi a qualsiasi altro abito. Grazie alla sua ampiezza può anche proteggere la testa e il naso.",ep:22,g:141,l:80,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8643] = {n:"Mantello Sulhit",t:17,d:"Il Mantello Sulhit si posa delicatamente sulle spalle per proteggere chi lo porta dalle tendiniti e dagli irrigidimenti articolari. Questo vestito dalle virtù curative è bramato da tutti i Pandawa che passano molto tempo a sollevare tanto gli avversari quanto gli alleati. Vorrebbero tanto avere un mantello del genere...",ep:22,g:134,l:80,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8644] = {n:"Mantello Anguillo",t:17,d:"Questo oggetto serve a nascondere il grasso in eccesso dei Sadida. A causa del loro vizio di dormire al posto di fare esercizio fisico, i personaggi di questa classe sviluppano una tendenza all\'obesità. Se le Sadidine hanno delle riserve anti-carestia poste in luoghi che ammaliano gli sguardi maschili, i Sadida tentano piuttosto di nascondere le loro scorte con questo mantello.",ep:22,g:139,l:80,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8645] = {n:"Mantello Vitale",t:17,d:"Questo abito ha un ruolo importantissimo nella prestanza dei Sàcridi. Lo usano come benda per le ferite, come straccio per asciugare il sangue, come tappeto da letto per non avere freddo ai piedi. È incredibile quanto i personaggi di questa classe odino i suoli gelati!",ep:22,g:138,l:80,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8646] = {n:"Mantel Lina",t:17,d:"Questo morbido mantello è talvolta usato dalle Osamodine maliziose come copricapo a bordi ampi. I maschi Osamodas lo usano solo come mantellina. Grazie al disegno ornamentale di questo abito, i personaggi di questa classe si sono guadagnati la reputazione di persone oneste. Non li si vede mai ridere sotto il mantello, infatti la risata vi è cucita sopra!",ep:22,g:137,l:80,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8647] = {n:"Mantello Capwera",t:17,d:"I Pandawa usano questo mantello come protezione contro le intemperie e come accessorio per la danza. Lo posano a terra, al centro di un cerchio di gente ubriaca, e poi cominciano la loro coreografia improvvisata senza che il piede tocchi il terreno al di fuori dalla zona delimitata dal mantello.",ep:22,g:142,l:80,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8648] = {n:"Mantello Hapulco",t:17,d:"Il Mantello Hapulco deve questo nome originale a uno strano Ocra che possedeva un senso dell\'orientamento molto particolare... era capace di perdersi a casa propria. Eppure non era grande! Aveva un problema di deformazione nel cervello a causa del quale per lui tutti i luoghi assomigliavano a una vasta spiaggia, circondata da palme e accarezzata dalla calda luce del sole serale.",ep:22,g:132,l:80,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8649] = {n:"Mantello Atlante",t:17,d:"I colori caldi e confortevoli di questo mantello possono immergere chi lo porta in un viaggio immaginario, in contrade assolate, piene di canyon scavati dall\'erosione, e di scorci rupestri tra rocce e scogliere. Estremamente utile per dimenticare il freddo e il grigiore delle giornate uggiose.",ep:22,g:136,l:80,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8650] = {n:"Mantello Mappa",t:17,d:"Gli Anutrof hanno preso l\'abitudine di disegnarsi una mappa sul mantello, perché vivono in un tale bordello che gli è spesso difficile ritrovare la strada per il bagno. Cosa parecchio fastidiosa quando si è colpiti da voglie tanto urgenti quanto incontrollabili.",ep:22,g:135,l:80,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8651] = {n:"Cintura Inaria",t:10,d:"Questa magnifica cintura aggiunge prestigio alla tenuta degli Yop. Alcuni dicono che la croce centrale possa trasformarsi in un\'arma removibile, quando non si ha la spada a portata di mano. È sicuramente una leggenda, perché solo gli Etram sono abbastanza furbi per questo genere di cose.",ep:22,g:116,l:130,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8652] = {n:"Cintura Zardo",t:10,d:"Quando un Ecaflip non sa più cosa fare, sguaina il suo mazzo di carte dalla cintura e comincia un solitario. In combattimento usa le carte come proiettili. Tira più veloce della sua ombra e, dopo la vittoria, si concede sempre una piccola partita!",ep:22,g:117,l:130,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8653] = {n:"Cintura Calende Greche",t:10,d:"L\'origine del nome di questa Cintura proviene dal rumore particolare che produce. L\'urto delle ossa che la ornano impedisce agli Etram, anche se invisibili, di passare inosservati. Per questo dicono sempre: \"Sorprendere qualcuno con la Cintura Calende Greche? Puoi attaccarti!\".",ep:22,g:118,l:130,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8654] = {n:"Cintura Ticchettac",t:10,d:"Il rumore incessante del meccanismo della Cintura Ticchettac impedisce agli Xelor di dormire quando i combattimenti vanno per le lunghe. È vivamente consigliato togliere questa cintura prima di andare a dormire.",ep:22,g:119,l:130,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8655] = {n:"Cintura Tirs",t:10,d:"Questa cintura permette di trasportare materiale medico, come ad esempio tutte le pozioni che servono a curare il mal di gola o altre affezioni orali. È veramente molto efficace, perché un Aniripsa con la voce rauca non può lanciare correttamente i propri sortilegi... e sarebbe utile come una pelliccia di orso in piena estate.",ep:22,g:120,l:130,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8656] = {n:"Cintura Lazione",t:10,d:"Le ragioni che hanno spinto gli inventori di questo accessorio di moda a mettere una testa di bambola lì in mezzo restano misteriose. Sono state proposte numerose teorie ma tutte troppo pompose!",ep:22,g:121,l:130,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8657] = {n:"Cintura Blad",t:10,d:"Guerrieri di un\'anziana tribù famosa per il suo gusto per il sangue, i Blad sarebbero i primi adoratori della dea Sacrido. Dietro l\'apparenza inoffensiva, questa cintura è in realtà uno strumento di tortura molto sofisticato.",ep:22,g:122,l:130,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8658] = {n:"Cintura Bolzebù",t:10,d:"Gli Osamodas hanno la reputazione di essere personaggi impulsivi. Questa cintura dalle molteplici fibbie li aiuta a frenare questa spontaneità: \"Prima di arrabbiarti, e di farti salire il sangue al cervello, tocca tutte le punte della tua cintura Bolzebù!\"",ep:22,g:123,l:130,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8659] = {n:"Cintura Gravity",t:10,d:"Questa cintura aiuta i Pandawa a stare più o meno dritti quando sono ubriachi, cioè quasi sempre. In questi momenti, gli sembra di essere inghiottiti dal suolo ma la gravità non ha naturalmente nessun rapporto con questa sensazione di pesantezza. La gravità è troppo occupata a stordire gli scienziati a colpi di mele in testa.",ep:22,g:124,l:130,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8660] = {n:"Cintura Bersaglio",t:10,d:"Questo cinturone permette sia di stringere i vestiti che cadono (e non scioccare così certi spiriti sensibili), sia di offrire un bersaglio ai giovani Ocra in fase di apprendistato. Infatti gli si insegna a non colpire mai sotto la cintura, ma sempre in mezzo.",ep:22,g:125,l:130,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8661] = {n:"Borsa Agio",t:10,d:"I Feca sono dei personaggi previdenti, e conservano delle provviste in una borsetta. Si tratta soprattutto di pane in pietra di Croccabul. Ecco perché questo cibo dura così a lungo. La Cintura Dezegureza serve per agganciare senza rischio questa borsetta alla vita di chi la possiede, perché la sua caduta accidentale fa ancora troppi feriti...",ep:22,g:126,l:130,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8662] = {n:"Cintura Gessante",t:10,d:"La cintura Gessante è un accessorio di modo molto utile presso gli Anutrof maschi. Grazie alla mappa che vi è cucita possono nascondere certi incidenti di percorso quando non trovano la strada per andare in bagno.",ep:22,g:127,l:130,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8663] = {n:"Stivali Show",t:11,d:"Con gli Stivali Show ai piedi, gli Yop sono sempre i primi ad arrivare sul campo di battaglia e a vivacizzare l\'atmosfera. C\'è da dire che questa classe di personaggi adora divertire gli spettatori con le sue imprese guerresche. Ma non sono mai presi sul serio a causa della loro intelligenza inversamente proporzionale alla loro forza.",ep:22,g:100,l:100,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8664] = {n:"Scarpette pelose",t:11,d:"Si dice che i Sadida non si sentano mai soli perché possono invocare un sacco di bambole. Anche tu non soffrirai più di solitudine con queste scarpette! Non potrai solo prenderti il piede per parlargli ma in più, grazie a queste pantofole pelose, nessuno potrà metterti a nudo. Una volta indossate, ti sentirai veramente bene... anche se ti vergognerai un po\' ad uscire.",ep:22,g:105,l:100,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8665] = {n:"Stivali Hox",t:11,d:"Impregnati di un prodotto tonificante a diffusione lenta, questi stivali permettono di migliorare il profilo delle gambe e di lottare contro il naturale pallore cadaverico degli Etram. Questa crema ha degli effetti spettacolari sulle femmine Etram, ma sembra assolutamente inutile sui maschi. Sarà mica un problema di ormoni?",ep:22,g:102,l:100,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8666] = {n:"Stivali Aerografici",t:11,d:"Creati da un artista Xelor, questi stivali avrebbero dovuto permettergli di dipingere più rapidamente. E così fu! In compenso, tendono però a deformare la visione, e più precisamente il senso della distanza. Con questi stivali, tutto sembra più rotondo. I quadri di questo Xelor sono particolarmente apprezzati dai Sadida perché contribuiscono a mettere in risalto le generose curve delle donne un po\' rotondette.",ep:22,g:103,l:100,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8667] = {n:"Stivali Eucociti",t:11,d:"Grazie a questi stivaletti sarai sempre protetto dalle tossine provenienti dal suolo. Non si fa mai abbastanza attenzione ai microbi e alle altre bestiole che girano. Secondo alcuni osservatori, queste calzature somigliano più a delle pantofole che a degli stivali. Eppure gli Aniripsa le chiamano proprio così. Sarà mica perché sono degli esseri piccolini che vedono le cose sotto un altro punto di vista?",ep:22,g:104,l:100,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8668] = {n:"Stivali Botanici",t:11,d:"L\'amore per le piante spinge i Sadida ad equipaggiarsi di queste calzature a segnalazione floreale. Grazie all\'avanzato sistema infatti, esse ti permetteranno di individuare le piante rare ed evitare di calpestarle. Però non ti impediranno di camminare su vari tipi di escrementi... guarda dove metti i piedi!",ep:22,g:101,l:100,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8669] = {n:"Infrachiodo",t:11,d:"Contrariamente alle altri classi, ai Sàcrido piace vivere con le spine nei piedi piuttosto di toglierle. Il dolore gli ricorda che sono vivi e gli dà la rabbia necessaria per massacrare i loro nemici. Inoltre, le tracce lasciate dal sangue aiutano i Sàcrido a non perdersi mai. Sono sempre capaci di tornare a casa seguendo i propri passi, il che sarebbe stato impossibile con delle scarpe di cattiva qualità.",ep:22,g:106,l:100,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8670] = {n:"Stivali Smania",t:11,d:"Queste calzature permettono agli Osamodas di percorrere lunghe distanze attraverso i continenti, anche nei più sperduti. A parte questo, non si sa bene a cosa servano. Alcuni pensano sia possibile farne nidi per Tofu o eleganti vasi per mettere in risalto i fiori campagnoli. Ma niente di tutto questo è molto convincente, insomma, gli Stivali Smania non sono altro che scarpe!",ep:22,g:107,l:100,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8671] = {n:"Reliquia del Corallaro Magistrale",t:24,d:"Questa impressionante reliquia ti farà forse dimenticare tutti i tuoi problemi.",ep:22,g:152,l:1,wd:true,fm:true,w:0,p:1};
I.u[8672] = {n:"Reliquia di Gurlo il Terribile",t:24,d:"Questa impressionante reliquia ti farà forse dimenticare tutti i tuoi problemi.",ep:22,g:153,l:31,wd:true,fm:true,w:0,p:1};
I.u[8673] = {n:"Reliquia del Rasbul Maggiore",t:24,d:"Questa impressionante reliquia ti farà forse dimenticare tutti i tuoi problemi.",ep:22,g:154,l:61,wd:true,fm:true,w:0,p:1};
I.u[8674] = {n:"Reliquia del Tynril",t:24,d:"Questa impressionante reliquia ti farà forse dimenticare tutti i tuoi problemi.",ep:22,g:155,l:101,wd:true,fm:true,w:0,p:1};
I.u[8675] = {n:"Reliquia del Kimbo",t:24,d:"Questa impressionante reliquia ti farà forse dimenticare tutti i tuoi problemi.",ep:22,g:156,l:141,wd:true,fm:true,w:0,p:1};
I.u[8676] = {n:"Spada che Scorreggia",t:6,d:"Vlad si era innamorato di questa magnifica spada e per comprarla ha partecipato alle più terribili corse di Dragokart. Sfortunatamente, non aveva capito che questa spada aveva una terribile maledizione...",ep:1,g:75,l:95,wd:true,fm:true,w:1,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8677] = {n:"Ross",t:18,d:"Questo magnifico Cuniyo è il famiglio preferito dal celebre Maestro Nero Jack. Non fidarti del suo aspetto, può essere molto pericoloso in combattimento. Questo famiglio mangia solo Cawote e piante.",ep:3,g:44,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8678] = {n:"Cappello di Satanasso",t:16,d:"Satanasso era un pattinatore artistico a cui piaceva scaldare i suoi pattini di Holibul on Ice in piste di periferia. Un giorno, cadendo sull\'osso sacro, ebbe la visione che cambiò la sua vita: il suo destino era alla guida di un Dragokart, ed era il migliore! A volte un piccolo choc serve a farci imboccare la strada giusta!",ep:1,g:187,l:36,wd:true,fm:true,w:20,p:3550};
I.u[8679] = {n:"Fantasma di Ross",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:46,l:1,wd:true,fm:true,w:1,p:1};
I.u[8680] = {n:"Squama appiccicosa",t:59,d:"Questa squama appiccicosa e scivolosa permetteva al suo proprietario di non farsi acchiappare facilmente dagli avventurieri che pescavano con i denti.\nSfortunatamente per lui, non l\'ha per niente protetto da un buon colpo di spada arrugginita.",ep:1,g:626,l:10,wd:true,fm:true,w:1,p:1};
I.u[8681] = {n:"Pelle di Raul Mops",t:59,d:"La vera debolezza di Raul Mops è che adora cospargersi di acqua, vino e anche aceto. Ma soprattutto adora rotolarsi nei barattoli di vetro intorno a una cipolla. Un\'ennesima creatura dalle misteriose abitudini.",ep:1,g:627,l:40,wd:true,fm:true,w:1,p:1};
I.u[8682] = {n:"Pelle di Mob la Spugna",t:59,d:"Questa pelle può essere usata dai due lati, il primo è morbido e permette di lavare le superfici morbide, l\'altro è invece molto più rugoso e permette per esempio di lustrare le proprie parti anatomiche che erano rimaste inaccessibili fino a oggi.",ep:1,g:628,l:10,wd:true,fm:true,w:1,p:1};
I.u[8683] = {n:"Regalo Walk",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8684] = {n:"Certificato di Deposito al Cianil: Ross",t:77,d:"Questo Certificato descrive le caratteristiche del Ross che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8685] = {n:"Certificato di Deposito al Cianil: Bilby",t:77,d:"Questo Certificato descrive le caratteristiche del Bilby che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
