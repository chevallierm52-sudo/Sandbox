I.u[8699] = {n:"Copricapo del Tynril",t:16,d:"Con questo copricapo sulla testa, avrai sempre una testa da matti, anche se non sei arrabbiato. C\'è da dire che le scorze della capigliatura del Tynril si arricciano quando fa umido, caratteristica che fa di questo animale l\'indicatore meteorologico più sicuro al mondo. In compenso, ha paura del fuoco. Fai quindi molta attenzione alle fiamme se non vuoi trasformarti in una torcia umana.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Guscio Smeraldo",t:16,d:"Sembra che questo copricapo sia stato fabbricato a partire da un Dofus Smeraldo spezzato. Il Dofus non è ancora completamente vuoto, potrai approfittarne per farti uno shampoo all\'uovo.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Spada Beccata",t:6,d:"Questa sontuosa spada apparteneva ad un famoso ladro, famoso per essersi fatto catturare dopo ogni crimine che commetteva.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
