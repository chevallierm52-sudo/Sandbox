I.u[901] = {n:"Cuoio del Maiale da Latte",t:56,d:"Questo cuoio bello liscio assume quasi una tinta arancione con il tempo, ma puzza anche sempre di più... un po\' come il gorgonzola.",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Piccoli Stivali di Klim",t:11,d:"L\'Agilità che questi stivali conferiscono, permetteva a Klim il Ciabattino di montare facilmente in sella a qualsiasi Pappatutto. È morto per aver confuso un Pappatutto con una Gelatina, dopo una serata un po\' troppo alcolica alla taverna.",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Stivali di Klim",t:11,d:"L\'Agilità che questi stivali conferiscono, permetteva a Klim il Ciabattino di montare facilmente in sella a qualsiasi Pappatutto. È morto per aver confuso un Pappatutto con una Gelatina, dopo una serata un po\' troppo alcolica alla taverna.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Grandi Stivali di Klim",t:11,d:"L\'Agilità che questi stivali conferiscono, permetteva a Klim il Ciabattino di montare facilmente in sella a qualsiasi Pappatutto. È morto per aver confuso un Pappatutto con una Gelatina, dopo una serata un po\' troppo alcolica alla taverna.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Strapotenti Stivali di Klim",t:11,d:"La leggenda racconta che questi stivali furono barattati con altri stivali, difettosi ma strapotenti, fabbricati da un Ciabattino maldestro e insonne.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Piccoli Stivali di Inseguimento",t:11,d:"Questi stivali permettevano a Hogmeiser di maltrattare gli unici esseri viventi che non sopportava, ovvero i bambini. Fortunatamente per loro, il peso di questi stivali gli impediva di prenderli a calci nel sedere.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Stivali di Inseguimento",t:11,d:"Questi stivali permettevano a Hogmeiser di maltrattare gli unici esseri viventi che non sopportava, ovvero i bambini. Fortunatamente per loro, il peso di questi stivali gli impediva di prenderli a calci nel sedere.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Grandi Stivali di Inseguimento",t:11,d:"Questi stivali permettevano a Hogmeiser di maltrattare gli unici esseri viventi che non sopportava, ovvero i bambini. Fortunatamente per loro, il peso di questi stivali gli impediva di prenderli a calci nel sedere.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Potenti Stivali di Inseguimento",t:11,d:"Questi stivali permettevano a Hogmeiser di maltrattare gli unici esseri viventi che non sopportava, ovvero i bambini. Fortunatamente per loro, il peso di questi stivali gli impediva di prenderli a calci nel sedere.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Stivali di Hogmeiser",t:11,d:"Per lunghi anni questi stivali sono appartenuti a Hogmeiser, che poi li perse per una stupida scommessa con Musol Ungo. Morale: non scommettere mai con un Ecaflip.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Stivali Consumati di Hogmeseir",t:11,d:"Questi stivali consumati sono appartenuti a Hogmeseir per molti anni. Sono talmente consumati che indossarli diventa soprattutto un impaccio. Un bravo Ciabattino dovrebbe poterli riparare con un po\' di fortuna.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Stivali Dorati di Hogmeiser",t:11,d:"Questi magnifici stivali di Hogmeiser sono ricoperti di un fine strato di pietre preziose che li proteggono da alcuni attacchi magici. Proprio con questi stivali, tempo addietro, Bruce Bulgur ha schiacciato la testa del Re degli Alberagni per ravvivare la cerimonia di apertura della fiera del Trool.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[913] = {n:"null",t:16,d:"",ep:0,g:258,l:1,wd:false,fm:true,w:1,p:10000};
I.u[914] = {n:"null",t:16,d:"",ep:0,g:257,l:1,wd:false,fm:true,w:1,p:10000};
