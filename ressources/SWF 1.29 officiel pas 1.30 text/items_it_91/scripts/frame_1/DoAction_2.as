I.u[391] = {n:"Noce di Acagiù",t:58,d:"Se raccolta ancora verde, da questa Noce di Acagiù si può ricavare dell\'olio. Se già seccata invece può essere usata come giocattolo per i bambini Yop un po\' sempliciotti.",ep:4,g:63,l:32,wd:true,fm:true,w:1,p:10};
I.u[392] = {n:"Noce di Pecan",t:58,d:"Dalla Noce di Pecan si può ricavare dell\'olio, ma è meglio consumarla quando si è già seccata a causa degli effetti lassativi di tale olio.",ep:4,g:64,l:32,wd:true,fm:true,w:1,p:10};
I.u[393] = {n:"Ghianda",t:58,d:"I cinghiali adorano le ghiande e tutti, o quasi, se ne chiedono il perché.",ep:1,g:65,l:14,wd:true,fm:true,w:1,p:10};
I.u[394] = {n:"Nocciola",t:58,d:"Questa nocciolina è deliziosa se mangiata con una barra di cioccolato. Peccato che ad Amakna il cioccolato non esista.",ep:1,g:66,l:14,wd:true,fm:true,w:1,p:1};
I.u[395] = {n:"Trifoglio a 5 foglie",t:36,d:"Questo trifoglio costituisce un elemento essenziale della dieta dei Tabi. Gli allevatori fanno comunque molta attenzione perché il Trifoglio a 5 foglie provoca gonfiori.",ep:1,g:67,l:20,wd:true,fm:true,w:1,p:0};
I.u[396] = {n:"Olio di Palma",t:60,d:"Dal gusto e dal profumo leggeri, quest\'olio va bene per tutto, dalla frittura al condimento.",ep:3,g:68,l:32,wd:true,fm:true,w:1,p:100};
I.u[397] = {n:"Olio di Gomto",t:60,d:"Quest\'olio molto raro è una vera manna. È talmente lubrificante da impedire ai meccanismi e agli ingranaggi di consumarsi. È composto da un\'accurata miscela di olii diversi.",ep:4,g:69,l:32,wd:true,fm:true,w:1,p:100};
I.u[398] = {n:"Frutto di Palma",t:46,d:"Se si spreme questo strano frutto si ottiene un olio raffinato. Peccato che sia molto difficile spremerlo a causa del suo guscio duro come le suole degli stivali di Bowis.",ep:3,g:81,l:32,wd:true,fm:true,w:1,p:10};
I.u[399] = {n:"Olio di Sesamo",t:60,d:"Quest\'olio estratto da chicchi di sesamo si distingue per il suo gusto ricco e delicato di noccioline grigliate. Peccato che l\'odore si avvicini più a quello di un Pappatutto che a quello della menta selvatica.",ep:1,g:71,l:1,wd:true,fm:true,w:1,p:100};
I.u[400] = {n:"Orzo",t:34,d:"L\'orzo è un cereale usato per la fabbricazione di birra ma anche per il bestiame e a volte per il bestiame che beve birra.",ep:1,g:82,l:10,wd:true,fm:true,w:2,p:0};
I.u[401] = {n:"Luppolo",t:34,d:"Il fiore della pianta femmina di Luppolo racchiude i principi attivi utilizzati dal birraio, tra i quali soprattutto le resine amare e gli olii essenziali. \"Questo mi ricorda le mie lezioni di Biologia, anche se non ho mai seguito delle lezioni di Biologia\", diceva Gabriel Nay leggendo questa descrizione che, diciamocelo, è un po\' romanzata.",ep:1,g:80,l:30,wd:true,fm:true,w:2,p:0};
I.u[402] = {n:"null",t:48,d:"",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[403] = {n:"null",t:48,d:"",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[404] = {n:"null",t:48,d:"",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:10};
I.u[405] = {n:"Malto",t:34,d:"È il nome dato all\'orzo germogliato. È un ingrediente di prima scelta per la birra di qualità. Ma attenzione: il malto è vizioso e ha l\'abitudine di assorbire la birra durante la sua germinazione, un po\' come il Tot dopo una dura giornata di caccia ai Tofu.",ep:1,g:83,l:60,wd:true,fm:true,w:2,p:0};
I.u[406] = {n:"Stomaco di Wo Wabbit",t:15,d:"Questo stomaco ha la capacità di dilatarsi molto facilmente, il che semplifica di gran lunga le difficili digestioni di Wo Wabbit che ha la cattiva abitudine di abusare di liquori di Cawote fermentate.",ep:8,g:146,l:39,wd:true,fm:true,w:1,p:10};
I.u[407] = {n:"Aculeo del Prespic",t:47,d:"Come stuzzicadente o come punta per una freccia, non c\'è niente di meglio che l\'Aculeo del Prespic.",ep:1,g:134,l:18,wd:true,fm:true,w:1,p:50};
I.u[408] = {n:"Dentiera dello Chafer scelto",t:47,d:"Il Chafer scelto ha i denti marciti dall\'alcool, e per questo deve utilizzare una dentiera. Questa dentiera costa un fortuna perché i denti sono d\'oro e l\'alito fetido del Chafer scelto ha conferito loro poteri inimmaginabili.",ep:9,g:129,l:43,wd:true,fm:true,w:1,p:50};
I.u[409] = {n:"Peli di Barba del Bwork Mago",t:54,d:"Questi peli rossi puzzano molto quando piove, ma non si sa perché. Tuttavia, i Bwork Maghi sembrano prendere una parte dei loro poteri magici proprio da essi, il che potrebbe essere interessante per certi Alchimisti.",ep:4,g:131,l:23,wd:true,fm:true,w:1,p:20};
I.u[410] = {n:"Libro del Bwork Mago",t:25,d:"Questo libro è un vero pezzo da collezione, da esso il Bwork Mago prende tutta la sua ispirazione e il suo vigore.\nOgni pagina di questo libro racchiude numerosi segreti sull\'anatomia di certe creature di Amakna.",ep:4,g:130,l:1,wd:true,fm:true,w:1,p:100};
I.u[411] = {n:"Becco del Kwak di Ghiaccio",t:47,d:"Questo becco straordinariamente solido permette al Kwak di Ghiaccio di fare dei buchi nel ghiaccio, solo per il gusto di fare dei buchi nel ghiaccio... I Kwak di Ghiaccio sono veramente un po\' strani...",ep:1,g:133,l:24,wd:true,fm:true,w:1,p:20};
I.u[412] = {n:"Becco del Kwak di Fiamma",t:47,d:"Questo becco straordinariamente solido permette al Kwak di Fiamma di spegnere la brace nel becco, solo per il gusto di spegnere la brace nel becco... I Kwak di Fiamma sono veramente un po\' strani...",ep:5,g:132,l:24,wd:true,fm:true,w:1,p:20};
I.u[413] = {n:"Becco del Kwak di Vento",t:47,d:"Questo becco straordinariamente solido permette al Kwak del Vento di parlare da solo col vento, solo per il gusto di parlare da solo col vento... I Kwak di Vento sono veramente un po\' strani...",ep:5,g:110,l:24,wd:true,fm:true,w:1,p:20};
I.u[414] = {n:"Piuma del Kwak di Ghiaccio",t:53,d:"Questa piuma ha la peculiarità di resistere al gelo. È per questo che non s\'incontrano mai Kwak di Ghiaccio ghiacciati.",ep:1,g:112,l:24,wd:true,fm:true,w:1,p:20};
I.u[415] = {n:"Piuma del Kwak di Fiamma",t:53,d:"Questa piuma ha la peculiarità di resistere alle fiamme. È per questo che non s\'incontrano mai Kwak di Fiamma infiammati.",ep:5,g:111,l:24,wd:true,fm:true,w:1,p:20};
I.u[416] = {n:"Piuma del Kwak di Vento",t:53,d:"Questa piuma ha la peculiarità di resistere alle bufere di vento. È per questo che il Kwak di vento può resistere a tutti i tipi di bufera senza demoralizzarsi né indebolirsi.",ep:5,g:113,l:24,wd:true,fm:true,w:1,p:20};
I.u[417] = {n:"Fango del Boo",t:15,d:"Il Boo è molto aggressivo, è fatto con pezzi di fango appiccicati uno all\'altro. Il solo modo per sconfiggerlo è seccarlo, ma è talmente umido che probabilmente ti seccherai tu.",ep:2,g:116,l:17,wd:true,fm:true,w:1,p:1};
I.u[418] = {n:"Peli di Barba del Nonno Wabbit",t:54,d:"Il Nonno Wabbit ha una barba finta che puzza molto, un po\' come Babbo Nawal, ma ancora peggio... A furia di sbavare senza sosta davanti alle Nonne Wabbit, i peli della sua barba si sono impregnati di questa bava dai poteri sconosciuti.",ep:8,g:114,l:39,wd:true,fm:true,w:1,p:100};
I.u[419] = {n:"Orecchio del Nonno Wabbit",t:106,d:"Le orecchie del Nonno Wabbit sono appuntite e rigide, ma sono ricoperte di una pelliccia spessa e zebrata. È senza dubbio una delle pellicce più ricercate, anche perché l\'unica priva di odore...",ep:8,g:115,l:39,wd:true,fm:true,w:1,p:1};
I.u[420] = {n:"Filo di Lino",t:15,d:"Il Filo di Lino è molto resistente, permette di fare cuciture molto solide o di legare gli amici per mostrare chi è veramente il capo della gilda.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[421] = {n:"Fiore di Lino",t:35,d:"Il Fiore di Lino può essere blu o bianco, a seconda del periodo dell\'anno nel quale è stato seminato. In decotto o in infusione dà una sensazione di benessere poco comune.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:0};
I.u[422] = {n:"Seme di Lino",t:58,d:"Questo semino contiene un sacco di buone cose. I Cacciatori di Kwak sanno che questi ultimi ne vanno ghiotti e così li attirano in trappola con semi luccicanti.",ep:1,g:119,l:1,wd:true,fm:true,w:2,p:1};
I.u[423] = {n:"Lino",t:34,d:"Il gambo di Lino non ha niente di speciale, se non che ha la capacità di raddrizzarsi per 7 volte dopo essere stato piegato dalle tempeste. È sicuramente per questo che la sua fibra è così tenera.",ep:1,g:122,l:40,wd:true,fm:true,w:2,p:0};
I.u[424] = {n:"Fibra di Lino",t:55,d:"È la fibra ideale per fabbricare le più belle stoffe, è rara e cara ma talmente più bella delle altre fibre classiche che nessun tessitore potrebbe farne a meno.",ep:13,g:120,l:46,wd:true,fm:true,w:1,p:1};
I.u[425] = {n:"Canapa",t:34,d:"Il Gambo di Canapa può essere utilizzato per i suoi effetti allucinogeni, ma anche per le sue fibre che i tessitori usano per tutt\'altra ragione.",ep:1,g:121,l:70,wd:true,fm:true,w:2,p:0};
I.u[426] = {n:"Fibra di Canapa",t:55,d:"Questa fibra non è molto bella, ma è particolarmente resistente. In più, nei momenti di riflessione sulla propria vita, è sempre possibile fumarla.",ep:13,g:123,l:46,wd:true,fm:true,w:1,p:1};
I.u[427] = {n:"Seme di Canapa",t:58,d:"Il Seme di Canapa è utilizzato soprattutto per calmare le greggi di Tabi in calore, basta dargliene qualcuno e diventano subito meno eccitati.",ep:1,g:157,l:10,wd:true,fm:true,w:1,p:10};
I.u[428] = {n:"Fiore di Canapa",t:35,d:"Questo fiore permette di fare pozioni dagli effetti aleatori, che possono variare dalla paralisi totale all\'invulnerabilità ai gas di Wabbit.",ep:1,g:156,l:10,wd:true,fm:true,w:1,p:0};
I.u[429] = {n:"Punta della Freccia del Bwork Arciere",t:15,d:"Questa punta di freccia arrugginita è fatta di un metallo raro, che si trova solo su questo tipo di punta di freccia.",ep:4,g:125,l:24,wd:true,fm:true,w:1,p:1};
I.u[430] = {n:"Osso InvisibiIe dello Chafer Invisibile",t:47,d:"Quest\'osso è reso invisibile dalle proprietà magiche che gli sono state conferite. Deve sicuramente essere ideale per fare pozioni magiche...",ep:1,g:126,l:23,wd:true,fm:true,w:1,p:20};
I.u[431] = {n:"Pietra del Croccaroc",t:51,d:"Questa pietra è quasi vivente, e prende vita dalle pietre preziose che racchiude. È praticamente indistruttibile, eccetto che per un Croccaroc. Non c\'è niente di meglio per farsi un bel grosso martello di pietra.",ep:2,g:127,l:31,wd:true,fm:true,w:5,p:1};
I.u[432] = {n:"Costine di Rib",t:47,d:"Le costine di Rib sono fantastiche alla griglia, non c\'è molta carne intorno ma è talmente fine che si mangia senza fine.",ep:3,g:158,l:33,wd:true,fm:true,w:1,p:100};
I.u[433] = {n:"Femore dello Chafer Arciere",t:47,d:"Ecco un osso un po\' strano, è particolarmente friabile e emana un odore di curry avariato quando brucia. Potrebbe quasi andare bene per certi cuochi poco scrupolosi.",ep:1,g:101,l:34,wd:true,fm:true,w:1,p:100};
I.u[434] = {n:"Corteccia di Alberagno",t:96,d:"Questo pezzo di corteccia è rugoso, crepato, coperto di piccole asperità ma ha stranamente un buon profumo, un po\' come la pelle dei piedi di un Anutrof.",ep:1,g:103,l:32,wd:true,fm:true,w:1,p:1};
I.u[435] = {n:"Radice di Alberagno",t:98,d:"Questo pezzo di radice ha conosciuto diversi substrati a forza di accompagnare l\'Alberagno nei sottoboschi. Ma ciò non spiega la magia di questo pezzo di radice.",ep:1,g:102,l:32,wd:true,fm:true,w:1,p:1};
I.u[436] = {n:"Bastone in Radice di Alberagno",t:4,d:"Questo bastone ricavato da una grossa radice di Alberagno è molto efficace nel corpo a corpo, ma stai attento a non lasciarlo a contatto con l\'acqua, potrebbe prendere radici e rivoltarsi contro di te.",ep:1,g:1,l:30,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,20,50,false,false],c:"CI>30&CC>5",p:2650};
I.u[437] = {n:"Gemma di Alberagno",t:108,d:"Durante la pubertà, gli Alberagni si coprono di brutte gemme piene di linfa succosa ricca di vitamina. Più tardi queste gemme diventeranno Alberagni che daranno vita ad altre gemme.",ep:1,g:104,l:32,wd:true,fm:true,w:1,p:1};
I.u[438] = {n:"Coda del Buulupo",t:65,d:"La Coda del Buulupo assomiglia tantissimo a un enorme ceppo peloso, eppure non lo è... fidati!",ep:1,g:105,l:70,wd:true,fm:true,w:1,p:50};
I.u[439] = {n:"Canino del Buulupo",t:47,d:"Questo canino molto tagliente è ricercatissimo come portafortuna. Ma in realtà è solo fonte di cattivi odori.",ep:1,g:106,l:70,wd:true,fm:true,w:1,p:1};
I.u[440] = {n:"Artiglio del Buulupo",t:15,d:"Questo artiglio ben sporco è un\'arma temibilissima.",ep:1,g:107,l:70,wd:true,fm:true,w:1,p:1};
I.u[441] = {n:"Rame",t:39,d:"Il Rame è un metallo molto utile per fabbricare armi a buon mercato. Può essere considerato un surrogato dell\'oro se non si tiene conto di tutte le qualità dell\'oro...",ep:1,g:108,l:10,wd:true,fm:true,w:5,p:0};
I.u[442] = {n:"Bronzo",t:39,d:"Questo metallo è spesso usato per la fabbricazione di articoli decorativi. È il metallo ideale per abbellire le tue armi spendendo poco",ep:1,g:109,l:20,wd:true,fm:true,w:5,p:0};
I.u[443] = {n:"Kobalto",t:39,d:"Il nome \"Kobalto\" significa \"rame del diavolo\" nell\'anziana lingua Sadida. Si tratta di un metallo adatto alla forgiatura di armi leggere, eleganti, e soprattutto mortali!",ep:1,g:77,l:30,wd:true,fm:true,w:5,p:0};
I.u[444] = {n:"Stagno",t:39,d:"Lo Stagno è un metallo molle e pesante, un po\' come il Wo Wabbit... ma in peggio.",ep:1,g:78,l:50,wd:true,fm:true,w:5,p:0};
I.u[445] = {n:"Manganesio",t:39,d:"Al contrario di ciò che tutti pensano, questo materiale non serve a fare grondaie, ma piuttosto armi terrificanti, come la pericolosissima \"Lama Manganesiana\" che ha fatto fuori più di un Tofu durante le feste di Bulgur.",ep:1,g:397,l:40,wd:true,fm:true,w:5,p:0};
I.u[446] = {n:"Bauxite",t:39,d:"Questo metallo è molto apprezzato per il suo colore argentato e per la sua capacità di taglio, se correttamente affilato.",ep:1,g:76,l:70,wd:true,fm:true,w:5,p:0};
I.u[447] = {n:"Carbone",t:39,d:"Il Carbone non ha nessuna proprietà magica particolare, al contrario di ciò che si potrebbe pensare. Tende però ad attirare i fulmini, imprigionarli e liberarli al momento sbagliato.",ep:5,g:75,l:1,wd:true,fm:true,w:5,p:0};
I.u[448] = {n:"Selce",t:51,d:"Questo sasso è particolarmente tagliente, ha sgozzato più di una talpa imprudente.",ep:1,g:74,l:22,wd:true,fm:true,w:5,p:1};
I.u[449] = {n:"Legno d\'Ebano",t:38,d:"Questo legno prende il nome da un malinteso. Molto tempo fa, Bano era il nome della famiglia di Taglialegna che sapeva dove trovare questi alberi, e si parlava dappertutto del \"Legno de\' Bano\". Ecco cosa succede quando non si conosce l\'ortografia!",ep:7,g:73,l:70,wd:true,fm:true,w:5,p:0};
I.u[450] = {n:"Pietra di Granito",t:51,d:"Questo minerale è praticamente indistruttibile ma anche molto pesante, il che ne limita l\'uso nella forgiatura delle armi. Lavorandolo a lungo, si possono a volte ricavare delle pietre preziose.",ep:1,g:1,l:30,wd:true,fm:true,w:20,p:1};
I.u[454] = {n:"Ascia del Taglialegna",t:19,d:"Questa ascia è indispensabile al Taglialegna se vuole esercitare correttamente la propria professione. In altri casi può anche usarla per sbarazzarsi di qualche mostro.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:150};
I.u[455] = {n:"Martello dell\'Aurora",t:7,d:"Questo ridicolo martellino serviva al Contadino Zokrim, che lo usava per piantare i pali del recinto durante l\'aurora. Nessuno sa perché Zokrim piantasse i pali a quell\'ora, ma dicono che avesse le sue buone ragioni.",ep:1,g:2,l:26,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CS>10&CI>16",p:2000};
I.u[456] = {n:"Ammazzaquerce",t:19,d:"Questa ascia permette di tagliare facilmente anche gli alberi più grossi. È particolarmente apprezzata per il suo peso che permette di tagliare un Bwork in tre con un solo colpo, sempre che la si riesca a sollevare...",ep:7,g:2,l:33,wd:true,fm:true,w:50,an:17,e:[5,4,1,1,40,40,false,false],c:"CS>66&CA>10",p:3150};
I.u[458] = {n:"Amuleto dello Chafer",t:1,d:"Lo Chafer è sensibile e distinto, porta sempre con sé un amuleto fatto con i crani dei suoi parenti caduti in combattimento. Ma a pensarci bene... lo Chafer non ha mai avuto parenti!",ep:1,g:3,l:19,wd:true,fm:true,w:4,p:1200};
I.u[459] = {n:"Tavola di Frassino",t:95,d:"Questa tavola consente ai Tuttofare di costruire degli oggetti di legno, come una bara per esempio...",ep:1,g:93,l:1,wd:true,fm:true,w:10,p:10};
I.u[460] = {n:"Legno di Quercia",t:38,d:"La particolare robustezza di questo legno di eccellente qualità permette di fare quasi tutto: randelli, case, barche, ma il miglior modo per utilizzarlo restano ancora i fusti di birra (Hic!)",ep:1,g:92,l:30,wd:true,fm:true,w:5,p:0};
I.u[461] = {n:"Legno di Tasso",t:38,d:"Questo legno particolarmente morbido e che non si spezza mai è ideale per la fabbricazione degli archi. È però molto difficile da trovare: i Contadini di Amakna tagliano tutti i giovani alberi perché, così dicono, fanno ammalare i loro Pappatutto.",ep:1,g:94,l:50,wd:true,fm:true,w:5,p:0};
I.u[462] = {n:"Arco in Radice di Alberagno",t:2,d:"Siccome il legno di Alberagno resta vivo anche dopo essere stato tagliato, questo arco è molto difficile da utilizzare. Tuttavia, non c\'è di meglio per ridicolizzare un Alberagno che ucciderlo con un arco fatto con le radici dei suo fratelli.",ep:1,g:1,l:28,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,30,50,false,true],c:"CS>10&CA>28",p:2250};
I.u[463] = {n:"Ambra",t:50,d:"Questa magnifica pietra preziosa è fatta di resina di albero fossilizzato. Talvolta al suo interno si può trovare un Moskito intrappolato secoli addietro, che le dà un po\' più di valore.",ep:1,g:96,l:32,wd:true,fm:true,w:4,p:20};
I.u[464] = {n:"Ambra di Alberagno",t:50,d:"Questa magnifica pietra preziosa è fatta di resina di Alberagno fossilizzato. Al suo interno si può talvolta trovare un\'Arakne intrappolata secoli fa nella linfa del proprio padrone. Proprio la morte che si merita un mostro del genere!",ep:1,g:97,l:32,wd:true,fm:true,w:5,p:40};
I.u[465] = {n:"Cristallo",t:50,d:"Il Cristallo è una pietra traslucida e molto fragile. Eh sì, neanche le pietre preziose sono perfette.",ep:1,g:98,l:50,wd:true,fm:true,w:20,p:5000};
I.u[466] = {n:"Zaffiro",t:50,d:"Questa pietra preziosa tutta blu è adatta per la fabbricazione di armi magiche, forse perché i creatori del gioco in mancanza di ispirazione usano sempre il blu per rappresentare il Mana.",ep:1,g:99,l:50,wd:true,fm:true,w:20,p:5000};
I.u[467] = {n:"Rubino",t:50,d:"Questa pietra preziosa è di colore rossastro come le piume del Kwak di Fiamma e fredda al tatto come le piume del Kwak di Ghiaccio.",ep:1,g:100,l:50,wd:true,fm:true,w:20,p:5000};
I.u[468] = {n:"Pane di Amakna",t:33,d:"Questo pane bello caldo dalla mollica molle e la crosta dorata permette di recuperare i punti vita persi in combattimento. È il pane più popolare e il meno caro.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[469] = {n:"Bacchetta in radice di Alberagno",t:3,d:"Questa bacchetta usa le proprietà magiche della Radice di Alberagno ancora viva. Fai attenzione: a volte questa bacchetta si ritorce contro il proprio padrone.",ep:1,g:3,l:33,wd:true,fm:true,w:20,an:11,e:[5,4,2,2,50,40,false,true],c:"CI>33&CW>10",p:3100};
I.u[470] = {n:"Legno d\'Olmo",t:38,d:"Il Legno di Olmo è uno dei legni più ricercati. Questo legno, molto comune un tempo, è oggi rarissimo perché colpito dalla Grafiosi, un terribile incantesimo lanciato da un potentissimo Bwork Mago delle Caverne della peggior specie.",ep:3,g:140,l:90,wd:true,fm:true,w:5,p:0};
I.u[471] = {n:"Legno d\'Acero",t:38,d:"Le foglie di Acero servono alle persone poco ispirate per creare bandiere originali, lo sciroppo di Acero serve a dare gusto alle crêpes... Purtroppo non si sa ancora a cosa serva il suo legno.",ep:1,g:153,l:40,wd:true,fm:true,w:5,p:0};
I.u[472] = {n:"Legno di Carpine",t:38,d:"Il Legno di Carpine deve il suo nome ai Sadida che si accoppiano sempre sotto il suo albero. Le ragioni di questo fatto sono rivelate nel libro del Bwork Mago.",ep:1,g:138,l:80,wd:true,fm:true,w:5,p:0};
I.u[473] = {n:"Legno di Castagno",t:38,d:"L\'odore del Legno di Castagno allontana le mosche, tranne quelle che adorano le castagne e quelle che hanno perso l\'olfatto. Questo spiega perché, effettivamente, l\'odore del legno di Castagno non allontana proprio nessuna mosca.",ep:1,g:86,l:10,wd:true,fm:true,w:5,p:0};
I.u[474] = {n:"Legno di Ciliegio Selvatico",t:38,d:"Questo legno è molto ricercato dagli ebanisti per la sua struttura compatta e il colore scuro rossastro che prende col tempo.",ep:1,g:139,l:60,wd:true,fm:true,w:5,p:0};
I.u[476] = {n:"Legno di Noce",t:38,d:"Il Legno di Noce è molto usato per fare mobili. Per oscure ragioni, alcuni carpentieri si rifiutano di utilizzarlo per le loro barche.",ep:1,g:95,l:20,wd:true,fm:true,w:5,p:0};
I.u[477] = {n:"Sangue di Drago Maiale",t:15,d:"Questa fiala è piena di un sangue che conferiva al Drago Maiale poteri diabolici. Da consumare con moderazione, o da fare cuocere se ti piace il sanguinaccio nero di Drago Maiale.",ep:2,g:544,l:70,wd:true,fm:true,w:10,p:100};
I.u[478] = {n:"Roncola di Carpine",t:19,d:"Questa ascia deve il suo nome a Woodee la Taglialegna che sapeva usare il suo fascino per distrarre gli altri Taglialegna e tenere segreta, così, la posizione dei Carpini rari che voleva proteggere.",ep:7,g:3,l:47,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,40,40,false,false],c:"CW>20&CI>20&CC>20",p:5900};
I.u[479] = {n:"Avorio",t:47,d:"L\'avorio è ricercatissimo dai collezionisti per il suo leggendario candore, e dai Forgiatori per la sua capacità di rendere le armi mortali. In più, di questi tempi, l\'avorio va veramente di moda ad Amakna.",ep:1,g:88,l:40,wd:true,fm:true,w:10,p:100};
I.u[480] = {n:"Minerale Strano",t:39,d:"Questo Minerale è stato estratto da una misteriosa cava sconosciuta. Al contrario di tutti gli oggetti strani di Amakna, questo non è magico per niente.",ep:1,g:90,l:24,wd:true,fm:true,w:5,p:100};
I.u[481] = {n:"Cranio del Drago Maiale",t:47,d:"Malgrado le sue piccole dimensioni, questro cranio è un vero pezzo da collezione. La sua grande somiglianza con un cranio Yop ha inoltre permesso a numerosi studenti in medicina di spiegare l\'origine delle debolezze intellettuali di certi Yop.",ep:2,g:91,l:70,wd:true,fm:true,w:50,p:100};
I.u[482] = {n:"Pala \'Nca",t:8,d:"Dopo una serata un po\' troppo alcolica finita in rissa, un Anutrof si è accorto che questa pala, all\'origine concepita per i lavori di costruzione, era un\'arma eccellente.",ep:1,g:8,l:27,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>7&CC>20",p:2200};
I.u[483] = {n:"Grande Pala \'Nca",t:8,d:"Dopo una serata un po\' troppo alcolica finita in rissa, un Anutrof si è accorto che questa pala, all\'origine concepita per i lavori di costruzione, era un\'arma eccellente.",ep:1,g:8,l:29,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>9&CC>20",p:2500};
I.u[484] = {n:"Potente Pala \'Nca",t:8,d:"Dopo una serata un po\' troppo alcolica finita in rissa, un Anutrof si è accorto che questa pala, all\'origine concepita per i lavori di costruzione, era un\'arma eccellente.",ep:1,g:8,l:31,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>11&CC>20",p:2800};
I.u[485] = {n:"Mutande di Cuoio dello Chafer Lanciere",t:56,d:"In inverno lo Chafer Lanciere non esce mai senza le sue Mutande di cuoio che gli permettono di tenere al caldo le articolazioni... nonché di distrarre il nemico.",ep:1,g:152,l:44,wd:true,fm:true,w:10,p:100};
I.u[486] = {n:"Cuoio di Cinghiale",t:56,d:"Questo cuoio è particolarmente resistente, ma puzza di cinghiale maschio in calore, ecco perché i Contadini lo usano per attirare in trappola le femmine di cinghiale che sono troppo stupide per capire uno stratagemma del genere.",ep:1,g:16,l:14,wd:true,fm:true,w:10,p:1};
I.u[487] = {n:"Cuoio del Drago Maiale",t:56,d:"A furia di credersi un Drago, il Drago Maiale si è bruciato i peli della cotenna, questa è la ragione dell\'odore abbrustolito di questo cuoio.",ep:2,g:142,l:70,wd:true,fm:true,w:10,p:6000};
I.u[489] = {n:"Lente",t:20,d:"La lente permette di esaminare con attenzione gli elementi dello sfondo per trovare dei tesori.",ep:1,g:3,l:1,wd:true,fm:true,w:10,an:3,e:[1,6,1,1,100,10,false,false],p:10};
I.u[490] = {n:"Fiala",t:20,d:"Questa fiala, di vitale importanza per ogni Alchimista che si rispetti, permette di realizzare le migliori pozioni.",ep:1,g:2,l:1,wd:true,fm:true,w:3,an:4,e:[1,6,1,1,200,2,false,false],p:10};
I.u[491] = {n:"Incastonatore",t:5,d:"Questo oggetto permette all\'Orefice di lavorare i suoi gioielli.",ep:1,g:16,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[492] = {n:"L\'Impastatore",t:20,d:"È un attrezzo indispensabile se vuoi esercitare il mestiere di Panettiere-pasticcere.",ep:1,g:1,l:1,wd:true,fm:true,w:8,an:4,tw:true,e:[50,6,1,1,500,10,false,false],p:10};
I.u[493] = {n:"Martello del Forgiatore di Martelli",t:7,d:"Attrezzo indispensabile per la creazione di Martelli.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[494] = {n:"Martello del Forgiatore di Spade",t:7,d:"Attrezzo indispensabile per la creazione di Spade.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[495] = {n:"Martello del Forgiatore di Daghe",t:7,d:"Attrezzo indispensabile per la creazione di Daghe.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[496] = {n:"Martello del Forgiatore di Pale",t:7,d:"Attrezzo indispensabile per la creazione di Pale.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[497] = {n:"Piccone del Minatore",t:21,d:"Attrezzo indispensabile per la raccolta dei minerali.",ep:1,g:1,l:1,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[498] = {n:"Intagliatrice di Bastoni",t:5,d:"Attrezzo indispensabile per la creazione di Bastoni.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[499] = {n:"Intagliatrice di Bacchette",t:5,d:"Attrezzo indispensabile per la creazione di Bacchette.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[500] = {n:"Intagliatrice di Archi",t:5,d:"Attrezzo indispensabile per la creazione di Archi.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[501] = {n:"Linfa di Alberagno Lavorata",t:15,d:"Questa linfa sciropposa è stata lavorata da un Alchimista rinomato, che voleva ridare vita alle Radici di Alberagno. Questo tipo di linfa deve essere maneggiata solo da mani esperte.",ep:2,g:162,l:30,wd:true,fm:true,w:2,p:50};
I.u[502] = {n:"Tranciatrice di Tasso",t:19,d:"Questa ascia è una delle poche a poter tagliare gli alberi incantati. Per estensione si può dunque pensare che sia capace di tagliare qualsiasi oggetto incantato, vivente o no.",ep:1,g:4,l:17,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,50,false,false],c:"CS>10&CI>35",p:950};
I.u[515] = {n:"Bolgurda delle Radure",t:19,d:"Questa ascia è appartenuta a Bruce Bulgur, il famoso Taglialegna, che era sposato con Kassiopea Bano, figlia di un altro grande Taglialegna. Quest\'arma gli permise di difendersi numerose volte quando usciva di notte per andare a tagliare intere foreste.",ep:7,g:5,l:62,wd:true,fm:true,w:60,an:17,tw:true,e:[15,6,1,1,50,40,false,false],c:"CI>124&CC>30&CV>10",p:10100};
I.u[519] = {n:"Polvere di Perlinpanpan",t:48,d:"Come indica il suo nome, questa polvere è fatta di Pane e Semi di Lino, il che non spiega però la magia di questa polvere.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[520] = {n:"Pane ai Semi di Papavero",t:33,d:"La fabbricazione di questo pane è delicata, perché i Panettieri che ne respirano i fumi durante la cottura sono vittime di sintomi strani e cominciano a ballare intorno alla panetteria.",ep:1,g:10,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[521] = {n:"Pane ai Semi di Sesamo",t:33,d:"I Kwak più audaci non esitano a travestirsi da Panettieri per rubare i Semi di Sesamo, ma questa strategia non funziona mai... tranne che con i Panettieri Yop.",ep:1,g:11,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[522] = {n:"Pane ai Semi di Lino",t:33,d:"Questo pane è ricco di proteine ma senza gusto. Eh sì, nella vita bisogna sempre scegliere...",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[524] = {n:"Pane alle Nocciole",t:33,d:"Questo pane dal gusto fine non ha né coloranti né conservanti, insomma tutto il contrario della Gelatina Reale.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[526] = {n:"Pane ai Cereali",t:33,d:"Questo pane fatto con moltissimi cereali, è talmente ricco di proteine da poter far rivivere uno Chafer.",ep:1,g:6,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[527] = {n:"Pane alle Noci",t:33,d:"Questo pane è cotto con legno di Noce e le noci sono tostate prima di essere inserite nella mollica.",ep:4,g:8,l:40,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[528] = {n:"Pane di Grano Integrale",t:33,d:"Questo pane è ricco di grano integrale. È quindi un pane di qualità per persone esigenti.",ep:1,g:7,l:20,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[529] = {n:"Farina di Orzo",t:52,d:"Questa farina si ottiene al mulino, macinando chicchi di orzo. Permette di dare una leggerezza alla mollica senza eguali, a meno che non si usi una qualche magia segreta per cuocere il pane.",ep:1,g:256,l:1,wd:true,fm:true,w:2,p:0};
I.u[530] = {n:"Farina di Segale",t:52,d:"Questa farina conserva tutte le qualità della segale. Secondo la leggenda, la segale che germoglia all\'aurora, non matura mai. Seguendo questo principio, alcuni Contadini concepiscono i loro bambini all\'aurora sperando che non invecchino mai.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[531] = {n:"Farina di Avena",t:52,d:"Questa farina non lievita alla cottura e questo consente di produrre pane veramente denso, particolarmente utile quando bisogna distribuirlo ai mostri.",ep:1,g:250,l:1,wd:true,fm:true,w:2,p:0};
I.u[532] = {n:"Segale",t:34,d:"Questo cereale scuro ha il potere di crescere anche in condizioni difficili, è uno dei pochi cereali a sopravvivere durante i periodi di grande siccità.",ep:1,g:82,l:50,wd:true,fm:true,w:2,p:0};
I.u[533] = {n:"Avena",t:34,d:"Questo cereale è usato per nutrire i giovani Tabi che non hanno ancora i denti abbastanza solidi per ruminare. I Contadini fanno comunque attenzione perché a volte l\'avena causa degli attacchi di aerofagia al bestiame sensibile.",ep:1,g:154,l:20,wd:true,fm:true,w:2,p:0};
I.u[534] = {n:"Farina di Malto",t:52,d:"Questa farina bianca è ottenuta macinando chicchi di orzo germinato, il che dà un gusto un po\' acido al pane o, nel migliore dei casi, un gusto di birra alterata, utile allo svezzamento progressivo degli amatori di birra. Una volta cotta, questa farina permette infatti di sopportare meglio... le cotte.",ep:1,g:255,l:1,wd:true,fm:true,w:2,p:0};
I.u[535] = {n:"Farina di Luppolo",t:52,d:"Questa farina permette di dare un delizioso gusto di birra al pane, senza dover utilizzare la birra. A volte bisogna riconoscere che la natura ha pensato proprio a tutto!",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[536] = {n:"Pane ai Fiocchi di Avena",t:33,d:"Questo pane dalla mollica particolarmente leggera è ideale per le persone che non sono state baciate da Madre Natura, e che hanno uno stomaco piccolissimo.",ep:1,g:5,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[537] = {n:"Patata",t:68,d:"In genere, se cadi su questo oggetto vuol dire che ti trovi in mezzo a un campo, o in fondo a una cella.",ep:1,g:135,l:1,wd:true,fm:true,w:20,p:10};
I.u[538] = {n:"Patata Sbucciata",t:68,d:"Questa Patata è senza buccia, vuol dire che è commestibile.",ep:1,g:136,l:1,wd:true,fm:true,w:20,p:10};
I.u[539] = {n:"Pane di Segale",t:33,d:"Questo pane è fatto con la Farina di Segale che dà alla mollica un colore scuro particolare, ma soprattutto le dà un leggero gusto zuccherato.",ep:1,g:9,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[543] = {n:"Pietra di Diamante",t:51,d:"Se correttamente levigata, da questa pietra si può ricavare un magnifico Diamante.",ep:1,g:144,l:30,wd:true,fm:true,w:20,p:15};
I.u[544] = {n:"Pietra di Smeraldo",t:51,d:"Se correttamente levigata, da questa pietra si può ricavare un magnifico Smeraldo.",ep:1,g:145,l:30,wd:true,fm:true,w:20,p:15};
I.u[545] = {n:"Pietra di Cristallo",t:51,d:"Se correttamente levigata, da questa pietra si può ricavare un magnifico Cristallo.",ep:1,g:141,l:30,wd:true,fm:true,w:20,p:15};
I.u[546] = {n:"Pietra di Zaffiro",t:51,d:"Se correttamente levigata, da questa pietra si può ricavare un magnifico Zaffiro.",ep:1,g:151,l:30,wd:true,fm:true,w:20,p:15};
I.u[547] = {n:"Pietra di Rubino",t:51,d:"Se correttamente levigata, da questa pietra si può ricavare un magnifico Rubino.",ep:1,g:150,l:30,wd:true,fm:true,w:20,p:15};
I.u[548] = {n:"Pozione di richiamo",t:12,d:"Questa pozione permette di tornare all\'ultimo punto di backup.",ep:1,g:17,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[577] = {n:"Falce del Contadino",t:22,d:"Questa falce non è molto affilata ed è soprattutto un po\' arrugginita. È quindi un\'arma poco pericolosa, però rimane un attrezzo ideale per falciare.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[578] = {n:"Pietra per Arrotare",t:51,d:"Non ti getto la pietra, Pietro!",ep:2,g:127,l:1,wd:true,fm:true,w:20,p:1};
I.u[579] = {n:"Tagliacuoio",t:5,d:"Attrezzo indispensabile per la creazione di scarpe e cinture.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[580] = {n:"Pozione Ghetto Raid",t:12,d:"Questa pozione consente di recuperare qualche punto energia.",ep:1,g:18,l:10,wd:true,fm:true,w:1,u:true,p:20};
I.u[582] = {n:"Farina Bianca",t:52,d:"Per ottenere questa farina ci vogliono numerosi cereali, ma è apprezzata moltissimo per la sua qualità. Tuttavia, a prima vista, nulla la distingue da una normale farina.",ep:1,g:7,l:1,wd:true,fm:true,w:2,p:0};
I.u[583] = {n:"Farina Bacio",t:52,d:"Questa farina semi-bianca prende il nome dalla sua inventrice, una graziosa Contadina che adorava dare i baci con le guance piene di farina. Che birichina!",ep:1,g:7,l:20,wd:true,fm:true,w:2,p:0};
I.u[586] = {n:"Farina Contadina",t:52,d:"Shika Ingals ha avuto l\'idea di creare questa farina, divenuta poi popolare, lottando contro la moglie di Bruce Bulgur a colpi di sacchi di farina. I combattimenti tra donne a volte sono molto più che una semplice distrazione per il popolo.",ep:1,g:258,l:30,wd:true,fm:true,w:2,p:0};
I.u[587] = {n:"Farina Completa",t:52,d:"Questa farina è ottenuta da numerosi cereali, è quindi una farina particolarmente completa, molto utile per il pane integrale.",ep:1,g:259,l:40,wd:true,fm:true,w:2,p:0};
I.u[592] = {n:"Corda d\'Ivan Noe",t:2,d:"Questo arco è appartenuto a Ivan Noe, un Ocra temerario che ha ucciso più di un Tofu smarrito. Questo arco ha la capacità di lanciare colpi sorprendenti, che lasciano gli avversari senza fiato e agonizzanti.",ep:7,g:1,l:36,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,15,50,false,true],c:"CS>30&CA>36",p:3600};
I.u[593] = {n:"Orchidea Freyesca",t:35,d:"Questo fiore è di una rarità e di una bellezza inimmaginabili, ma è quasi introvabile. Infatti i Rospi hanno l\'abitudine di portarlo nei loro accampamenti per sfamare la prole.",ep:1,g:192,l:40,wd:true,fm:true,w:1,p:0};
I.u[594] = {n:"Edelweiss",t:35,d:"Questo fiore è di una rarità e di una bellezza inimmaginabili, ma è quasi introvabile, e a ragione... la sua magia è così potente che sarebbe capace di far rivivere i morti.",ep:1,g:191,l:50,wd:true,fm:true,w:1,p:0};
I.u[595] = {n:"null",t:20,d:"",ep:1,g:19,l:1,wd:false,fm:true,w:1,e:[1,4,1,1,100,100,false,false],p:10};
I.u[596] = {n:"Canna da Pesca Corta",t:20,d:"Questa piccola canna da pesca è l\'ideale per divertirsi a pescare i piccoli pesci nelle pozzanghere.",ep:1,g:8,l:1,wd:true,fm:true,w:1,an:18,e:[1,4,1,1,100,100,false,false],p:200};
I.u[597] = {n:"Rete semplice di cattura",t:99,d:"Questa rete molto resistente permette di catturare anche la cavalcatura più selvaggia, a condizione di essere riusciti a ipnotizzarla o a distrarla poco prima.",ep:20,g:1,l:1,wd:true,fm:true,w:1,an:0,p:10};
I.u[598] = {n:"Gambretto",t:41,d:"I Gambretti sono apprezzati per il colore roseo e il sapore raffinato. Sono però odiati per il cattivo carattere e le antenne con il gel.",ep:1,g:292,l:1,wd:true,fm:true,w:1,p:10};
I.u[600] = {n:"Kralamore",t:41,d:"Il Kralamore è molto romantico, i suoi occhi da piccolo Tofu gli danno un\'aria un po\' ingenua, ma non ti distrarre troppo, il Kralamore è molto aggressivo con gli stranieri.",ep:2,g:309,l:20,wd:true,fm:true,w:1,p:10};
I.u[602] = {n:"Squalo Falce-Martello",t:41,d:"Questo squalo rosso è uno squalo militante, d\'istinto gregario, secondo il quale l\'individualismo non deve esistere all\'interno del gruppo, anche se alla fine il loro capo, lo squalo Stakanovy, è considerato come un idolo.",ep:2,g:322,l:80,wd:true,fm:true,w:2,p:1};
I.u[603] = {n:"Pesce-Micino",t:41,d:"Questo pesce ha i baffi e fa le fusa sott\'acqua, per questo fa molta paura ai Pesci Volanti.",ep:1,g:277,l:1,wd:true,fm:true,w:1,p:50};
I.u[607] = {n:"Trota Fangosa",t:41,d:"La Trota Fangosa è una lontana parente del Salmone Aggressivo dell\'isola di Moon. Questa trota è buona sia cruda che cotta, chi l\'avrebbe detto?",ep:1,g:395,l:1,wd:true,fm:true,w:1,p:50};
I.u[610] = {n:"Amuleto di Granchio",t:1,d:"Questo amuleto biancastro è fabbricato con granchi, è quindi molto fragile, ma anche molto originale.",ep:1,g:30,l:24,wd:true,fm:true,w:2,p:1800};
I.u[616] = {n:"Amuleto del Marinaio",t:1,d:"Questo amuleto, incastonato con scaglie di pesce, dovrebbe portare fortuna al suo proprietario durante i giorni di tempesta in mare.",ep:1,g:29,l:22,wd:true,fm:true,w:2,p:2000};
I.u[617] = {n:"Amuleto del Pirata",t:1,d:"Questo terrificante amuleto ha impressionato più di un marinaio, averlo al collo significa diventare un personaggio temuto e rispettato.",ep:1,g:20,l:41,wd:true,fm:true,w:2,p:4500};
I.u[619] = {n:"Bastone dell\'Allevatore di Pappatutto",t:4,d:"Questo bastone permetteva a Farle Ingals, allevatore di Pappatutto, di invocare più facilmente i Tofu guardiani di gregge. Col tempo questo bastone si è anche rivelato un\'eccellente arma da combattimento.",ep:7,g:6,l:85,wd:true,fm:true,w:20,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>60&CW>20&CA>40",p:10000};
I.u[620] = {n:"Tranciakralamori",t:6,d:"Questa spada ha permesso al celebre Mobby Dikens di tagliare a fette i tentacoli del famoso Kralamore Gigante dell\'isola di Moon conosciuto per la sua grande capacità di soffocare i marinai ubriachi e ubriacare i marinai soffocati.",ep:1,g:8,l:61,wd:true,fm:true,w:50,an:14,e:[10,7,1,1,50,50,false,false],c:"CV>60&CW>60",p:9900};
I.u[629] = {n:"Cappello Appuntito",t:16,d:"Questo magnifico cappello permetterà alla tua eroina di essere la più bella per il ballo in maschera.",ep:5,g:1,l:21,wd:true,fm:true,w:5,p:1400};
I.u[638] = {n:"Amuleto del Pescatore di Salmoon",t:1,d:"Pescare un Salmoon è una vera impresa, ma con questo amuleto al collo nulla è impossibile.",ep:12,g:24,l:35,wd:true,fm:true,w:5,p:2500};
I.u[639] = {n:"Amuleto degli Abissi",t:1,d:"Questo amuleto è stato ritrovato nel relitto incagliato del celebre Pescatore di Kralamori, Moby Dikens, famoso anche per le sue battutacce al bar dei pirati.",ep:14,g:22,l:47,wd:true,fm:true,w:5,p:6000};
I.u[640] = {n:"Arco dei Fiumi",t:2,d:"Quest\'arco permetteva ai Pescatori di ripulire le rive da tutti gli insetti del luogo senza doversi alzare, ma stando comodamente seduti alla finestra del bar dei pirati.",ep:14,g:38,l:46,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,10,30,45,false,true],c:"CA>46",p:5600};
I.u[641] = {n:"Cotone Ancestrale",t:15,d:"Questo cotone è morbido come il pelo di una giovane Ecaflippina, bianco come una nuvola di primavera, ma fragile come una piuma di Tofu.",ep:1,g:657,l:6,wd:true,fm:true,w:1,p:500};
I.u[642] = {n:"Bozzolo di Baco da Seta",t:15,d:"Srotolando questo enorme bozzolo biancastro, puoi ottenere un magnifico filo di seta.\nSi dice che l\'avventuriero Harry Hane l\'abbia usato per uscire dal labirinto del Dark Vlad.",ep:1,g:489,l:6,wd:true,fm:true,w:1,p:100};
I.u[643] = {n:"Filo di Seta",t:15,d:"Questo filo è di una finezza e di una morbidezza senza eguali. È di sicuro il materiale preferito dallo Chafer quando si tratta di indossare biancheria da combattimento.",ep:1,g:486,l:5,wd:true,fm:true,w:1,p:100};
I.u[646] = {n:"Peli di Black Tiwabbit",t:54,d:"Questo pelo completamente nero ha il vantaggio di essere sempre pulito, il che potrebbe interessare gli eroi a cui piace l\'igiene e la civetteria. Ma attenzione: questo pelo tende a scolorirsi a contatto con sudore abbondante o corrosivo.",ep:8,g:195,l:11,wd:true,fm:true,w:1,p:50};
I.u[648] = {n:"Peli di Wabbit",t:54,d:"Questi peli non sono apprezzatissimi dai Sarti esperti, che preferiscono i peli di altri Wabbit, ma hanno comunque il merito di far scappare i moskito grazie all\'odore di Citronella Selvatica.",ep:8,g:196,l:18,wd:true,fm:true,w:1,p:1};
I.u[649] = {n:"Peli di Wo Wabbit",t:54,d:"Questo pelo è così grasso che si usa per fabbricare stoffe impermeabili.",ep:8,g:197,l:39,wd:true,fm:true,w:1,p:40};
I.u[650] = {n:"Peli di Nonno Wabbit",t:54,d:"Questo pelo puzzolente è difficilmente utilizzabile dai Sarti a causa della sua tendenza ad arricciarsi al contatto con il succo di Cawota.",ep:8,g:198,l:39,wd:true,fm:true,w:1,p:50};
I.u[651] = {n:"Stoffa del Buulupo",t:55,d:"Questa stoffa fatta di Peli di Buulupo è moto rara ma molto resistente. Può, infatti, tener testa ad ogni tipo di aggressione fisica e a volte anche magica.",ep:1,g:199,l:70,wd:true,fm:true,w:1,p:100};
I.u[652] = {n:"Stoffa del Cinghiale",t:55,d:"Questa stoffa fatta di Peli di Cinghiale è ruvida e puzzolente, ma protegge in modo efficace dagli attacchi fisici.",ep:1,g:220,l:13,wd:true,fm:true,w:1,p:50};
I.u[653] = {n:"Stoffa del Prespic",t:55,d:"Sotto gli aghi, il Prespic ha una pelliccia rossa molto morbida che però emana uno sgradevole odore quando piove. Fortunatamente per te, ad Amakna non piove mai, ma evita di usare questa stoffa per farti un costume da bagno.",ep:1,g:661,l:17,wd:true,fm:true,w:1,p:100};
I.u[654] = {n:"Stoffa del Wabbit",t:55,d:"Questa stoffa di Peli di Barba del Nonno Wabbit è molto folta, ma è anche irritante, un po\' come un bruco urticante.",ep:8,g:15,l:18,wd:true,fm:true,w:1,p:100};
I.u[657] = {n:"Bastone dell\'Allevatore di Tofu",t:4,d:"Questo bastone permetteva a Shika Ingals, allevatrice di Tofu, d\'invocare più facilmente i Tofu guardiani di gregge. Col tempo questo bastone si è anche rivelato un\'eccellente arma da combattimento.",ep:7,g:6,l:56,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>40&CW>10&CS>30",p:5600};
I.u[658] = {n:"Bastone dell\'Allevatore di Tabi",t:4,d:"Questo bastone permetteva a Graminia Ingals, allevatrice di Tabi, d\'invocare più facilmente i Tofu guardiani di gregge. Col tempo questo bastone si è anche rivelato un\'eccellente arma da combattimento.",ep:7,g:6,l:34,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>20&CW>5",p:3400};
I.u[666] = {n:"Purè Picfail",t:15,d:"Originariamente sinonimo di errore culinario, questo piatto viene servito ogni volta che si presenta un errore, non importa che origine abbia.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:0};
I.u[670] = {n:"null",t:22,d:"",ep:0,g:1,l:36,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,35,45,false,false],c:"CS>10",p:3600};
I.u[671] = {n:"null",t:22,d:"",ep:0,g:1,l:40,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,45,45,false,false],c:"CS>20&CV>20",p:4400};
I.u[672] = {n:"null",t:22,d:"",ep:0,g:1,l:18,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,45,45,false,false],c:"CS>5",p:1100};
I.u[673] = {n:"Mangiatrice di Castagno",t:19,d:"Questa ascia non ha niente di particolare, ma la leggerezza naturale del Legno di Castagno le permette di avere un manico leggero come una piuma di Tofu Malefico.",ep:1,g:6,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>8&CA>3",p:400};
I.u[674] = {n:"Fenditrice di Ciliegio Selvatico",t:19,d:"\"A questa ascia non manca niente\" diceva il famoso slogan di Bruce Bulgur, il noto Taglialegna. Effettivamente, il manico in Legno di Ciliegio permette di ammortizzare i colpi contro gli alberi... o contro i Bwork dalla testa troppo dura.",ep:1,g:7,l:32,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>40",p:2900};
I.u[675] = {n:"Tranciatrice di Noce",t:19,d:"Questa ascia ha un aspetto rudimentale, ma è molto efficace. Con questo attrezzo Bruce Bulgur vinse il concorso di abbattimento di Bwork nani. Il che la dice lunga sull\'efficacia di questa arma, no?",ep:1,g:8,l:21,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>30",p:1350};
I.u[676] = {n:"Mangiatrice di Acero",t:19,d:"Questa ascia ha la peculiarità di non arrugginire mai. Evita così le cattive sorprese ai Taglialegna golosi che amano leccare lo sciroppo di acero che rimane sulla lama dopo una pesante giornata di abbattimento di aceri.",ep:1,g:10,l:25,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CA>30",p:1850};
I.u[677] = {n:"Mantello del Pirata",t:17,d:"Questo mantello è appartenuto al un vecchio pirata di nome Zokrim. Doveva essere piuttosto sfortunato...",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:1};
I.u[678] = {n:"Pergamena di Avorio",t:13,d:"(Doppio clic per acquisire Punti Esperienza)\nQuesta pergamena permette di acquisire Punti Esperienza senza rischi.",ep:1,g:3,l:25,wd:true,fm:true,w:1,u:true,p:1};
I.u[679] = {n:"Pergamena Bianca",t:13,d:"(Doppio clic per acquisire Punti Esperienza)\nQuesta pergamena ti permette di acquisire Punti Esperienza senza rischi.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[680] = {n:"Pergamena Dorata",t:13,d:"(Doppio clic per acquisire Punti Esperienza)\nQuesta pergamena permette di acquisire Punti Esperienza senza rischi.",ep:1,g:3,l:50,wd:true,fm:true,w:1,u:true,p:1};
I.u[682] = {n:"null",t:22,d:"",ep:0,g:1,l:1,wd:true,fm:true,w:1,an:17,e:[1,1,1,1,1,1,false,false],p:1};
I.u[683] = {n:"Piccola Pergamena di Forza",t:76,d:"(Doppio clic per acquisire Forza)\nQuesta pergamena permette di acquisire Forza in modo definitivo e senza rischi.\nMa attenzione: non puoi utilizzarla se la tua Forza è superiore a 25.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<25",u:true,p:1000};
I.u[684] = {n:"Pergamena di Incantesimo",t:76,d:"(Doppio clic per acquisire Punti Incantesimo)\nQuesta pergamena permette di acquisire Punti Incantesimo in modo definitivo e senza rischi.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:15000};
I.u[686] = {n:"Piccola Pergamena di Intelligenza",t:76,d:"(Doppio clic per acquisire Intelligenza)\nQuesta pergamena permette di acquisire Intelligenza in modo definitivo e senza rischi.\nMa attenzione: non puoi utilizzarla se la tua Intelligenza è superiore a 25.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<25",u:true,p:1000};
I.u[690] = {n:"Farina di Lino",t:52,d:"Questa farina è molto strana perché non deriva da un cereale, per questo non assomiglia a nessun altra farina.",ep:1,g:254,l:1,wd:true,fm:true,w:2,p:0};
I.u[691] = {n:"null",t:48,d:"",ep:0,g:79,l:1,wd:true,fm:true,w:1,p:50};
I.u[692] = {n:"Pane Consistente",t:33,d:"Questo pane è fatto con la Farina di Lino, il che spiega perché sia così grasso e perché la mollica sia scura. Ricchissimo in olii essenziali, ma con un cattivissimo gusto.",ep:1,g:12,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[694] = {n:"Dofus Porpora",t:23,d:"Il Dofus porpora fu creato dal Drago di Fuoco Ignemikhal. Il meno che si possa dire di quest\'uovo è che puzza di zolfo, e non solo...",ep:1,g:1,l:6,wd:true,fm:true,w:5,p:500000};
I.u[695] = {n:"Pergamena del Taglialegna",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Taglialegna",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[696] = {n:"Il Copricapo del Plukos",t:16,d:"Nonostante sia apparentemente passato di moda, il Copricapo del Plukos rimane molto efficace durante i combattimenti per un semplice cappello di paglia.",ep:1,g:2,l:20,wd:true,fm:true,w:4,p:1300};
I.u[697] = {n:"Mykakka",t:16,d:"Mykaka è un cane molto affettuoso... Il problema è che quando trova un nuovo amico... non si stacca più... e adesso ha più di 30 milioni di amici...",ep:2,g:3,l:6,wd:true,fm:true,w:6,p:30000};
I.u[698] = {n:"Cappello Hogwarts",t:16,d:"Il Cappello Hogwarts viene da una grande scuola di magia. È una creatura vivente che ha incontrato i più grandi maghi di tutti i tempi, per esempio: Mrs Minierva MaGranit, Mr Silenzios e il celebre Jerry Ponter.",ep:1,g:4,l:33,wd:true,fm:true,w:6,p:3000};
I.u[699] = {n:"Il Troma",t:16,d:"Il Troma è orrendo come un Rasbul in pelo di Bituf. (Chi non sa cos\'è un Rasbul in pelo di Bituf, può consultare i grandi libri dei Dubbi da Gallina).",ep:1,g:5,l:22,wd:true,fm:true,w:10,p:1525};
I.u[700] = {n:"Pandawa",t:16,d:"Ah il Pandawa, com\'è presuntuoso. Come il suo amico Mykakka, passa il tutto il tempo sulla testa del suo padrone. Non si muove per niente, quando è veramente affamato riesce persino a rubare il cibo a chi lo porta.",ep:2,g:6,l:6,wd:true,fm:true,w:10,c:"PG!10",p:12000};
I.u[701] = {n:"L\'Oiram",t:16,d:"L\'Oiram ha numerosi adepti in tutto il mondo che amano il suo aspetto un po\' classico... Questo cappello è stato a lungo portato da un idraulico che passava il tempo a saltare e correre...",ep:1,g:7,l:22,wd:true,fm:true,w:12,c:"PG!10",p:1525};
I.u[702] = {n:"Kritter",t:16,d:"Questo teschio di demone ricostruito con differenti ossa dà grazia ed eleganza a chi lo indossa... I tuoi amici ti invidieranno...",ep:1,g:8,l:30,wd:true,fm:true,w:9,c:"PG!10",p:2600};
I.u[703] = {n:"Dora",t:16,d:"Questo cappello a forma di cesto da frutta di vimini rovesciato è, in effetti, un cesto da frutta rovesciato magico. Impressionerai così tutti quelli che ti stanno attorno, soprattutto se si tratta di principianti Bwork Maghi.",ep:2,g:9,l:36,wd:true,fm:true,w:20,p:3550};
I.u[704] = {n:"Dantgul",t:16,d:"Questo cappello, fatto con le Mutande di cuoio dello Chafer Lanciere intrecciate insieme, ti renderà sicuramente irresistibile per le Bwork Maghe, famose per la loro grande femminilità accentuata dalla loro barba rossa.",ep:2,g:10,l:36,wd:true,fm:true,w:10,p:3550};
I.u[705] = {n:"Maschera Traumatizzante",t:16,d:"Se desideri essere traumatizzato, hai assolutamente bisogno di questa magnifica noce di cocco bucata. Ricordiamo all\'utilizzatore che l\'interno è equipaggiato di una cannuccia e di bevande rinfrescanti.",ep:12,g:11,l:47,wd:true,fm:true,w:10,p:6000};
I.u[706] = {n:"Crystal O\'Bul",t:16,d:"Hugne \"il senza memoria\" possedeva una magnifica sfera di cristallo che gli aveva regalato suo nonno. Con l\'intento di conservarla per tutta la vita, la nascose sotto il suo cappello che non tolse mai più... Hugne è poi morto di fatica cercando di ritrovarla.",ep:4,g:12,l:24,wd:true,fm:true,w:12,s:38,p:1775};
I.u[707] = {n:"Minotokorno",t:16,d:"Questo cappello in Corna di Minotoror è molto efficace per impressionare i nemici facendosi scambiare per un Minotoror. Questo stratagemma funziona solo su gli avversari sempliciotti. Uno Yop o un Tofu dovrebbero andare bene.",ep:2,g:13,l:33,wd:true,fm:true,w:10,s:54,p:3000};
I.u[708] = {n:"Hud",t:16,d:"Questo cappello in pelle di larva verde magica conferisce un\'andatura baldanzosa a chi lo porta, ma anche un po\' stupida. Non si può avere tutto dalla vita, basta prendere come esempio chi porta questo cappello.",ep:1,g:14,l:30,wd:true,fm:true,w:8,p:2525};
I.u[709] = {n:"Lorko Kasko",t:16,d:"Questo cappello in corteccia incantata apparteneva a Lorko, un noto Taglialegna che non ha esitato a sfidare il celebre Taglialegna Bruce Bulgur, in un famoso duello di sradicamento di Olmi a mani nude nella radura di Leroy Merlin.",ep:9,g:15,l:37,wd:true,fm:true,w:9,c:"PG!10",p:3825};
I.u[710] = {n:"Korko Klako",t:16,d:"Ol Korko Klako os ono cappollo molto bollo. Molto ostotico, molto grozioso, os portoto dol piò bollo doi Sadida.",ep:1,g:16,l:17,wd:true,fm:true,w:9,c:"PG=10",p:1000};
I.u[711] = {n:"Juik Kramp",t:16,d:"Questa magnifica maschera di cuoio apparteneva a Juik Kramp, cugino di Zeorg. A tutti e due piacevano molto i vestiti di cuoio attillati. Un po\' come al Capitano Chafer, ma senza la perversione.",ep:8,g:17,l:26,wd:true,fm:true,w:15,c:"PG=10",p:2025};
I.u[712] = {n:"Gulliver",t:16,d:"L\'originalità di questo cappello fabbricato con orecchie cucite insieme ti renderà semplicemente unico. Si racconta che tempo fa abbia permesso a Rakmar Bilgut di sedurre la regina dei Pappatutto, per poi sgozzarla più facilmente.",ep:13,g:18,l:33,wd:true,fm:true,w:10,p:3075};
I.u[713] = {n:"Pergamena di Forgiatore di Spade",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Forgiatore di Spade",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[714] = {n:"Pergamena del Forgiatore di Daghe",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Forgiatore di Daghe.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[715] = {n:"Pergamena dell\'Intagliatore di Archi",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Intagliatore di Archi.",ep:4,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[716] = {n:"Pergamena dell\'Intagliatore di Bastoni",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Intagliatore di Bastoni.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[717] = {n:"Pergamena dell\'Intagliatore di Bacchette",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Intagliatore di Bacchette.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[718] = {n:"Pergamena di Incantesimo Fiammella",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di imparare l\'incantesimo elementare Fiammella.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[719] = {n:"Pergamena di Incantesimo Liberazione",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di imparare l\'incantesimo elementare Liberazione.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[720] = {n:"Pergamena di Incantesimo Folgorazione",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di imparare l\'incantesimo elementare Folgorazione.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[721] = {n:"Pergamena di Incantesimo Invocazione di Arakne",t:75,d:"(Doppio clic per imparare questo incantesimo)\nQuesta pergamena ti permetterà di imparare l\'incantesimo Invocazione di Arakne.",ep:16,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[724] = {n:"Incantesimo Padronanza del Bastone",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con un bastone.",ep:1,g:2,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[725] = {n:"Incantesimo Padronanza della Spada",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con una spada.",ep:3,g:1,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[726] = {n:"Incantesimo Padronanza dell\'Arco",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con un arco.",ep:4,g:3,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[727] = {n:"Incantesimo Padronanza del Martello",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con un martello.",ep:1,g:4,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[728] = {n:"Incantesimo Padronanza della Bacchetta",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con una bacchetta.",ep:1,g:5,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[729] = {n:"Incantesimo Padronanza delle Daghe",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con una daga.",ep:2,g:6,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[730] = {n:"Incantesimo Padronanza della Pala",t:73,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permetterà di fare più danni con una pala.",ep:7,g:7,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[731] = {n:"Pergamena di Incantesimo Speciale Brokle",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permette di imparare l\'incantesimo Brokle... Riservato solo agli Yop.",ep:2,g:4,l:1,wd:true,fm:true,w:1,c:"PG=8",u:true,p:10000};
I.u[732] = {n:"Fede di Silimelle",t:9,d:"Questa splendida fede è stata rubata alla birraia Silimelle, durante una serata da sbronza alla taverna. Ecco cosa succede quando si paga da bere agli sconosciuti...",ep:1,g:30,l:26,wd:true,fm:true,w:1,p:2000};
I.u[733] = {n:"Stivali di Ragalde",t:11,d:"Ragalde era sicuramente uno dei più temerari Guerrieri Yop. Questi stivali magici gli hanno permesso di uccidere un buon numero di persone odiate.",ep:1,g:7,l:49,wd:true,fm:true,w:1,p:5000};
I.u[734] = {n:"Cintura di Sicurezza",t:10,d:"Questa cintura permetteva alle guardie del Castello di Amakna di sedare le sommosse o altri incidenti simili durante le feste popolari.",ep:1,g:7,l:17,wd:true,fm:true,w:10,p:1000};
I.u[737] = {n:"Dofus Smeraldo",t:23,d:"Più verde di un Tofu malato, il Dofus Smeraldo fu creato da Aerafal, il Drago dell\'aria. Per creare una roba così verde, doveva veramente avere il mal d\'aria. Un colmo, no?",ep:1,g:2,l:6,wd:true,fm:true,w:5,p:500000};
I.u[739] = {n:"Dofus Turchese",t:23,d:"Il Dofus Turchese fu creato da Aguabrial, il Drago dell\'acqua. A pensarci, è proprio incredibile quello che un drago può fare con questo elemento...",ep:1,g:3,l:6,wd:true,fm:true,w:5,p:500000};
I.u[742] = {n:"Bastone Cornuto",t:4,d:"\"Questo bastone deve averne fatte di guerre per essere così forte\": queste sono state le ultime parole di Claudius Baglionus, il celebre Menestrello Forgiatore di Asce, prima di morire schiacciato da un Uovo di Tofu Gigante.",ep:1,g:1,l:29,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,200,false,false],c:"CC>20&CI>30",p:2350};
I.u[743] = {n:"Brioche Dorata",t:33,d:"La ricetta di questa Brioche è stata elaborata da Xavier il Panettiere in persona, il quale voleva creare una brioche deliziosa ma leggera. Possiamo veramente dire che ce l\'ha fatta.",ep:1,g:8,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[744] = {n:"Mantello di Bowis",t:17,d:"Questo mantello è come il suo proprietario, unico nel suo genere e troppo spesso sottovalutato.\nÈ fatto di un insieme di pelli di larva verde, che gli danno un bell\'aspetto rugoso.",ep:1,g:1,l:20,wd:true,fm:true,w:10,p:1275};
I.u[745] = {n:"Lingotto d\'Oro",t:40,d:"Questo lingotto si ottiene facendo fondere l\'oro grezzo.",ep:1,g:241,l:10,wd:true,fm:true,w:1,p:0};
I.u[746] = {n:"Ebonite",t:40,d:"Questa lega molto rara permette di fabbricare diversi oggetti rari e spesso mortali. Infatti, una volta arrugginita, l\'Ebonite diventa velenosa.",ep:1,g:658,l:20,wd:true,fm:true,w:20,p:0};
I.u[747] = {n:"Alluminite",t:40,d:"Questa lega è di una leggerezza impressionante, è quindi il metallo ideale per le piccole daghe o le spade corte.",ep:1,g:660,l:10,wd:true,fm:true,w:10,p:0};
I.u[748] = {n:"Magnesite",t:40,d:"Questa originale lega è quasi magica e brilla e vibra di notte. Potrebbe essere sufficiente per spaventare un Bwork un po\' troppo crudele.",ep:1,g:659,l:30,wd:true,fm:true,w:30,p:0};
I.u[749] = {n:"Bakelelite",t:40,d:"Questa lega non è delle più solide, ma se correttamente affilata diventa più tagliente della Lama di uno Chafer.",ep:1,g:487,l:40,wd:true,fm:true,w:40,p:0};
I.u[750] = {n:"Kuartz",t:40,d:"Questa lega molto strana può racchiudere un\'energia straordinaria, il che la rende molto instabile in certe condizioni. I migliori Forgiatori vanno matti per questa lega perché gli permette di forgiare armi dai poteri quasi leggendari.",ep:1,g:664,l:60,wd:true,fm:true,w:60,p:0};
I.u[752] = {n:"Sangue del Vampiro",t:15,d:"Questo sangue è magico, ed è quindi un ingrediente indispensabile per il sanguinaccio nero magico. Gli effetti secondari sono però ancora sconosciuti.",ep:2,g:89,l:15,wd:true,fm:true,w:1,p:100};
I.u[754] = {n:"Mantello del Vampiro",t:17,d:"Questo mantello rosso sangue è stato immerso nel sangue per molti anni. Questo tipo di accessorio è richiestissimo per le feste di Hallouin.",ep:7,g:17,l:29,wd:true,fm:true,w:13,p:2500};
I.u[756] = {n:"Mutande di Cuoio attillato del Vampiro",t:56,d:"Per proteggersi dai colpi critici nelle parti critiche, a volte il Vampiro usa Mutande di Cuoio per andare a caccia. Queste Mutande gli permettono di proteggere le parti critiche dai colpi di sole.",ep:3,g:622,l:15,wd:true,fm:true,w:1,p:100};
I.u[757] = {n:"Gelatina Celeste",t:110,d:"Questa gelatina è particolarmente collosa, un po\' come una Bloccatrice arrabbiata. Stranamente, incolla particolarmente bene le piume di Tofu. Ma ci si chiede ancora a cosa possa servire...",ep:5,g:42,l:3,wd:true,fm:true,w:1,p:1};
I.u[758] = {n:"Mantello del Giustiziere",t:17,d:"Questo mantello può essere indossato solo dai più grandi giustizieri di Amakna, ovvero quasi da nessuno.",ep:1,g:2,l:30,wd:true,fm:true,w:10,c:"Ps=1&Pa>20",p:2550};
I.u[759] = {n:"Mantello del Poolay Vibrardente",t:17,d:"Questo magnifico mantello è stato confezionato con le piume dell\'ultimo Poolay di Amakna. Si tratta di una vera rarità che i collezionisti sognano di avere.",ep:8,g:3,l:33,wd:true,fm:true,w:4,p:5000};
I.u[760] = {n:"Pane al curry senza curry",t:33,d:"Si tratta di un prototipo di Kwaker Vans cui il gusto e l\'efficacia sono sempre una sorpresa, ma sfortunatamente l\'odore non cambia mai.",ep:2,g:12,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[761] = {n:"Peli di Topo",t:54,d:"Questi peli di topo sono molto fini e morbidi, e per questo sono molto usati nella fabbricazione di mantelli. ll mantello in pelo di topo fa furore nell\'alta società di Amakna. Si dice che sia una questione di stile...",ep:1,g:549,l:1,wd:true,fm:true,w:1,p:1};
I.u[764] = {n:"Amuleto del Piccolo Gufo",t:1,d:"Questo piccolo amuleto sarà la gioia degli avventurieri principianti.",ep:1,g:1,l:1,wd:true,fm:true,w:2,p:50};
I.u[765] = {n:"Falce di FarIe Ingals",t:22,d:"Questa Falce, appartenuta a Farle Ingals in persona, è sufficientemente affilata per falciare tutti i tipi di cereali e tutti i tipi di mostri che si nascondono nei campi di cereali.",ep:3,g:1,l:13,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,50,false,false],c:"CC>10",p:650};
I.u[766] = {n:"Kollo Kiodo",t:1,d:"Questo amuleto consente ai giovani avventurieri di causare più danni.",ep:1,g:34,l:1,wd:true,fm:true,w:1,p:20};
I.u[767] = {n:"Ganti Reale",t:9,d:"Nonostante il nome pomposo, questo anello rende solo un po\' più forti... e un po\' più stupidi.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[768] = {n:"Camanello",t:9,d:"Questo anello influisce sul tuo destino. Ti rende più resistente, ma meno fortunato. Aumenta la tua longevità diminuendo però la tua felicità.",ep:1,g:33,l:1,wd:true,fm:true,w:1,p:100};
I.u[769] = {n:"Einekenux",t:11,d:"Sono stivali che portano Fortuna. Il problema è che ti tolgono resistenza in combattimento.",ep:1,g:5,l:2,wd:true,fm:true,w:1,p:200};
I.u[770] = {n:"Fecaflip",t:11,d:"Questi magnifici stivali convertono un po\' della tua Forza in Intelligenza.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[771] = {n:"Mangiatrice di Frassino",t:19,d:"Questa ascia non ha niente di eccezionale, ma è comunque apprezzata dai Taglialegna principianti per la sua semplicità d\'uso.",ep:1,g:9,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>10&CC>10",p:400};
I.u[772] = {n:"Mantello Espada",t:17,d:"Si dice che questo mantello leggendario faccia diventare quasi invincibili se lo si abbina alla spada leggendaria degli schermidori, al Dard Tagnan e al leggendario cappello dei Se\' Ramò di Bergers Rahk.",ep:7,g:4,l:22,wd:true,fm:true,w:10,p:1500};
I.u[773] = {n:"Mantello Tortellino",t:17,d:"Questo mantello viene dal paese delle Pastitaliane, un posto dove si parla con le mani, ed è per questo che il mantello lascia una grande libertà di movimento. Inoltre è veramente molto leggero.",ep:1,g:5,l:14,wd:true,fm:true,w:1,p:775};
I.u[774] = {n:"Mantello Uleto",t:17,d:"Proveniente dal Monte Taigü o dal Mondo Aigü (dipende da come lo si pronuncia), questo mantello ha avvelenato il suo vecchio proprietario. Stranamente però aumenta la resistenza di chi lo indossa.",ep:1,g:7,l:14,wd:true,fm:true,w:3,p:775};
I.u[775] = {n:"Mantello Abilità",t:17,d:"Cucito magicamente e con infinita cura, il Mantello Abilità permette al suo proprietario di individuare i punti deboli degli avversari per dargli il colpo di grazia.",ep:5,g:9,l:17,wd:true,fm:true,w:10,p:1000};
I.u[776] = {n:"Mantello Sulcorpe",t:17,d:"Questo mantello appartenne a una certa Mulba che lo usava per trasportare gli oggetti ingombranti durante la sua ricerca delle Sette Polle di Cristallo scese dalle stelle. Tale mantello aumenta considerevolmente la Forza.",ep:5,g:8,l:14,wd:true,fm:true,w:3,p:775};
I.u[777] = {n:"Mantello del Gal Lett",t:17,d:"Il Gallo a cui appartenevano le piume con le quali è stato fabbricato questo mantello si è battuto per ore prima di cedere e farsi spiumare. \"Me ne vado a lett! Ha detto alla fine il suo proprietario privo di forze\".",ep:5,g:10,l:44,wd:true,fm:true,w:10,p:5275};
I.u[778] = {n:"Mantello di Mori Arty",t:17,d:"Questo mantello da vero cattivo è una prova della tua appartenenza alla banda del diabolicamente geniale Mori Arty, la cui intelligenza è eguagliata solo dalla sua sfortuna. Può essere indossato solo dai più cattivi.",ep:2,g:11,l:6,wd:true,fm:true,w:1,c:"Ps=2&Pa>30",p:20000};
I.u[779] = {n:"Mantello Maj\'Hic",t:17,d:"Questo mantello qualunque non è affatto qualunque: infatti rende invisibile chi lo porta agli occhi di chi non lo guarda. Che storia!",ep:8,g:12,l:34,wd:true,fm:true,w:15,p:3300};
I.u[781] = {n:"Mantello Capy Tulassion",t:17,d:"Questo magnifico mantello era del Grande Strategherra. Un celebre stratega avido di conquiste che però abbandonò tutte le sue ambizioni all\'improvviso... proprio dopo aver indossato questo mantello. Che strano!",ep:8,g:7,l:21,wd:true,fm:true,w:10,p:1400};
I.u[782] = {n:"Agrida",t:19,d:"Questa ascia è abbastanza particolare ed è destinata soprattutto all\'apprendimento del mestiere di Taglialegna. Se usata correttamente può tagliare in due un giovane Alberagno troppo ingenuo, il che è abbastanza raro.",ep:1,g:11,l:27,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CW>15",p:2200};
I.u[783] = {n:"Amuleto del Taglialegna",t:1,d:"Questo amuleto, fabbricato solo con legno pregiato, è molto apprezzato dai Taglialegna che gli attribuiscono spesso poteri che in realtà non ha.",ep:1,g:9,l:22,wd:true,fm:true,w:2,p:1500};
I.u[784] = {n:"Stivali del Gatto Zuccone",t:11,d:"Il Gatto Zuccone è il soprannome dato a un famoso Ecaflip. Nessun Ecaflip era più testardo di lui, e solo la fortuna lo salvava dalla sua stupidaggine durante i combattimenti. Per questo esclamava spesso: \"Chi è zuccone come le zucche?\".",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[785] = {n:"Anello Fortificante",t:9,d:"Questo anello, trasmesso da Nonno Anutrof in Padre Anutrof, dà una formidabile Forza a chi lo porta. Questa non è che un\'insipida copia dell\'originale, ma saprà comunque soddisfare i collezionisti, Anutrof e non.",ep:1,g:29,l:11,wd:true,fm:true,w:1,p:525};
I.u[786] = {n:"Ciondolo del Gufo Fragile",t:1,d:"Nato da un errore di manipolazione di un Orefice, questo amuleto aumenta l\'Intelligenza di chi lo porta. Però, fa venire un gran mal di testa che indebolisce le condizioni fisiche del proprietario.",ep:1,g:1,l:2,wd:true,fm:true,w:1,p:200};
I.u[787] = {n:"Anello Rexik",t:9,d:"Questo strano piccolo anello ha la capacità di aumentare l\'Agilità di chi lo porta, anche se stranamente colpito da una mancanza di Fortuna.",ep:1,g:31,l:1,wd:true,fm:true,w:1,p:100};
I.u[789] = {n:"Cintura del Kobeer",t:10,d:"Questa cintura va di moda tra i giovani di Amakna. È la creazione di un Sarto Sadida. In occasione della presentazione al pubblico della sua creazione, esclamò: \"La vita è corta, giocate duro!\".",ep:2,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[790] = {n:"Mantello di Buona Speranza",t:17,d:"Gli effetti magici di questo mantello sono spesso sopravvalutati causando la morte di molti avventurieri. Uno tra tutti, il tristemente famoso Menestrello Claudius Baglionus.",ep:8,g:5,l:30,wd:true,fm:true,w:8,p:2525};
I.u[791] = {n:"Alberagnis Vivitus",t:4,d:"Si tratta di un Bastone in radice di Alberagno vivente. Ma attenzione, ha la fastidiosa abitudine di rivoltarsi contro chi lo possiede. Può essere efficace quando decide di attaccare lo stesso bersaglio del suo proprietario.",ep:2,g:1,l:34,wd:true,fm:true,w:10,an:12,e:[5,2,1,1,50,30,false,false],c:"CC>30&CI>34&CW>15",p:3400};
I.u[792] = {n:"Linfa di Alberagno",t:15,d:"Questa linfa sciropposa non serve a niente, a meno che tu non sia disposto ad aspettare che si trasformi in ambra. Si dice però che un\'Anutrofina molto astuta e seducente abbia trovato il modo di accelerare questo processo.",ep:1,g:162,l:45,wd:true,fm:true,w:2,p:50};
I.u[793] = {n:"Pozione di Vecchiaia",t:12,d:"Questa pozione accelera certi processi chimici, come la formazione di sedimenti. È un po\' come un lievito strapotente, ma senza cattivo gusto.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[795] = {n:"Pergamena di Forza",t:76,d:"(Doppio clic per acquisire Forza)\nQuesta pergamena permette di acquisire Forza in modo definitivo e senza rischi.\nMa attenzione: non puoi utilizzarla se la tua Forza è superiore a 50.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<50",u:true,p:2500};
