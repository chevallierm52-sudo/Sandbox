I.u[938] = {n:"Mappa del tesoro dei Forgiatori Oscuri",t:24,d:"Questa mappa indica la posizione del forziere dei Forgiatori Oscuri:\n-- a faire --",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Mappa del tesoro dei Bwork",t:24,d:"Questa mappa indica la posizione del forziere dei Bwork: \"L\'accesso al forziere si trova in un vicolo cieco, a Sud-Est della foresta oscura. Sarà comunque sicuramente protetto da un gruppo di Bwork\".",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Scorreggiatore",t:16,d:"Lo Scorreggiatore protegge dai danni fisici.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Fascia Komintot",t:16,d:"La fascia Komintot aumenta la Saggezza di chi la porta.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Lisciatore",t:16,d:"Il Lisciatore previene i danni magici.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Piccolo Fascia di Vitalità",t:16,d:"Questa fascia aumenta la Vitalità di chi la porta.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Fascia di Vitalità",t:16,d:"Questa fascia aumenta la Vitalità di chi la porta.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
