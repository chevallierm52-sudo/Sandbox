I.u[948] = {n:"Alberantello",t:17,d:"Questo magnifico mantello è un eccellente miscuglio di essenza di Alberagno e buon Pappatutto delle famiglie.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Grande Fascia di Vitalità",t:16,d:"Questa fascia aumenta la Vitalità di chi la porta.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Aghi e filo",t:20,d:"Questo set di aghi e filo ti permetterà di esercitare il mestiere di Sarto.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Mantello del Buulupo Pazzo",t:17,d:"Questo mantello è fatto di peli e altri elementi organici di Buulupo... Si può proprio dire che sa... di potenza.",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Mantello del Tofu Pazzo",t:17,d:"Questo mantello, cucito a mano con piume di Tofu, permette agli avventurieri che lo portano di correre più veloce e scappare più facilmente dalle zone di contrasto.",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"La Samulaya",t:17,d:"La Samulaya è un mantello leggendario, ricamato dai più grandi Sarti appositamente per i guerrieri che preferiscono i combattimenti corpo a corpo.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Mantello Capello",t:17,d:"Il Mantello Capello è un tipo di mantello molto richiesto dai parrucchieri che adorano rotolarcisi dentro. Aumenta la resistenza dei capelli di chi lo porta.",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Mantello Capriccio",t:17,d:"Questo mantello aumenta la Portata di chi lo indossa, permettendogli di raggiungere bersagli molto lontani, o di impressionare gli avventurieri un po\' ingenui.",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"La Pappatrice",t:17,d:"La Pappatrice aumenta i danni e la Vitalità di chi la porta. Tuttavia emana un odore fortissimo, e può capitare che un Pappatutto ti prenda per uno di loro.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofusantello",t:17,d:"Questo mantello è di sicuro uno dei più potenti al mondo. Aumenta tutte le caratteristiche di chi lo porta.",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Mappa del tesoro 5",t:24,d:"-- a faire --",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Pozione Wabbit",t:24,d:"Questa pozione è un rimedio contro la myxomawosis. Un solo sorso ti permetterà di visitare l\'isola dei Wabbit senza rischiare la vita.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Chiave Wabbit",t:24,d:"Una delle tre chiavi che permettono di entrare nel castello dei Wabbit.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Chiave Wabbit",t:24,d:"Una delle tre chiavi che permettono di entrare nel castello dei Wabbit.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
