I.u[818] = {n:"Chiave di Pietra di Ded Aleicar",t:12,d:"Questa chiave di pietra ti aprirà la porta della grotta di Ded Aleicar. Ovviamente, prima devi trovarla...",ep:4,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[819] = {n:"Spada Sacra",t:6,d:"Una spada santa distribuita ai giovani guerrieri durante il loro addestramento.",ep:1,g:1,l:15,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>30&CV>3",p:800};
