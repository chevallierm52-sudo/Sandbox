I.u[834] = {n:"Grande Bacchetta di Saggezza",t:3,d:"Questa bacchetta aumenta la Saggezza di chi la usa.",ep:1,g:4,l:25,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>25&CW>9",p:1900};
I.u[835] = {n:"Potente Bacchetta di Saggezza",t:3,d:"Questa bacchetta aumenta la Saggezza di chi la usa.",ep:1,g:4,l:27,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>27&CW>11",p:2200};
I.u[836] = {n:"Alberanello",t:9,d:"Questo anello forgiato nella corteccia di Alberagno possiede dei grandi poteri che implicano grandi responsabilità. Nonostante il suo grande valore però, si dice che sia maledetto.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:100};
I.u[837] = {n:"Stivali di Kluh",t:11,d:"Questi stivali aumentano la Forza di chi li porta, ma rischiano di renderlo un po\' stupido dopo un po\' di tempo, tanto da trasformarlo in Yop se usati in modo regolare e prolungato.",ep:1,g:3,l:8,wd:true,fm:true,w:1,p:400};
I.u[838] = {n:"Sangue di Oni",t:15,d:"Questa fiala di sangue di Oni è molto ricercata dagli Alchimisti esperti che vogliono conferire a certe armi poteri spaventosi.",ep:4,g:662,l:75,wd:true,fm:true,w:1,p:100};
I.u[840] = {n:"Peli del Minotoror",t:54,d:"Questi peli puzzano molto ma sono di una resistenza senza eguali. Se indosserai una stoffa in pelo di Minotoror sarai temuto dagli avversari, e apprezzato dalle mosche.",ep:2,g:201,l:125,wd:true,fm:true,w:1,p:100};
I.u[841] = {n:"Anello di Soddisfazione",t:9,d:"Questo anello permetterà al tuo personaggio di aumentare i suoi PA, in cambio della sua Forza e della sua Intelligenza.",ep:1,g:12,l:8,wd:true,fm:true,w:1,p:10};
I.u[842] = {n:"Guscio di Draguovo Dorato",t:111,d:"Questo guscio è quasi indistruttibile ma levigandolo per generazioni e generazioni, i migliori Orefici riescono a usarne le facoltà magiche per costruire amuleti dai poteri eccezionali.",ep:11,g:202,l:64,wd:true,fm:true,w:5,p:1};
I.u[843] = {n:"Guscio di Draguovo Nero",t:111,d:"Questo guscio è quasi indistruttibile ma levigandolo per generazioni e generazioni, i migliori Orefici riescono a usarne le facoltà magiche per costruire amuleti dai poteri eccezionali.",ep:11,g:203,l:64,wd:true,fm:true,w:5,p:150};
I.u[844] = {n:"Uovo di Draguovo Zaffiro",t:105,d:"Una volta covato da una femmina di Draguovo Zaffiro, questo strano uovo darà alla luce un simpatico Dragovetto. Nell\'attesa evita di tenerlo al caldo con il tuo corpo, non si sa mai cosa potrebbe succedere...",ep:11,g:204,l:74,wd:true,fm:true,w:20,p:100};
I.u[845] = {n:"Uovo di Draguovo Dorato",t:105,d:"Una volta covato da una femmina di Draguovo Dorato, questo strano uovo darà alla luce un simpatico Dragovetto. Nell\'attesa evita di tenerlo al caldo con il tuo corpo, non si sa mai cosa potrebbe succedere...",ep:11,g:205,l:74,wd:true,fm:true,w:20,p:100};
I.u[846] = {n:"Uovo di Draguovo Nero",t:105,d:"Una volta covato da una femmina di Draguovo Nero, questo strano uovo darà alla luce un simpatico Dragovetto. Nell\'attesa evita di tenerlo al caldo con il tuo corpo, non si sa mai cosa potrebbe succedere...",ep:11,g:206,l:74,wd:true,fm:true,w:20,p:100};
I.u[847] = {n:"Uovo di Draguovo Bianco",t:105,d:"Una volta covato da una femmina di Draguovo Bianco, questo strano uovo darà alla luce un simpatico Dragovetto. Nell\'attesa evita di tenerlo al caldo con il tuo corpo, non si sa cosa potrebbe succedere...",ep:10,g:38,l:74,wd:true,fm:true,w:1,p:100};
I.u[848] = {n:"Vecchio Osso di Draguovo",t:47,d:"Questo vecchio osso è magico. Se lo usi correttamente ti aiuterà a fabbricare oggetti molto potenti.",ep:11,g:15,l:70,wd:true,fm:true,w:20,p:100};
I.u[849] = {n:"Anello Forzesco",t:9,d:"Questo anello dà Forza a chi lo porta.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[850] = {n:"Anello Agilesco",t:9,d:"Stranamente, i collezionisti di Amakna fanno a pugni per quest\'anello... eppure non vale niente.",ep:1,g:1,l:1,wd:true,fm:true,w:1,p:50};
I.u[851] = {n:"Anello Vitalesco",t:9,d:"Questo anello aumenta la Vita di chi lo porta.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[852] = {n:"Piccolo Anello Magico",t:9,d:"Questo anello aumenta l\'Intelligenza di chi lo porta.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[853] = {n:"Piccolo Anello del Fortunato",t:9,d:"Questo anello aumenta la Fortuna di chi lo porta.",ep:1,g:42,l:1,wd:true,fm:true,w:1,p:50};
I.u[854] = {n:"Amuleto del Piccolo Orso",t:1,d:"Questo amuleto aumenta la Forza di chi lo porta.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[855] = {n:"null",t:1,d:"",ep:0,g:6,l:1,wd:true,fm:true,w:1,p:50};
I.u[856] = {n:"Ranocchietta",t:1,d:"Questo amuleto aumenta l\'Agilità di chi lo porta.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[859] = {n:"Cintura di Agilità",t:10,d:"Questa modesta cintura aumenta l\'Agilità di chi la porta.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:50};
I.u[860] = {n:"Cintura di Fortuna",t:10,d:"Questa modesta cintura aumenta la Fortuna di chi la porta.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[861] = {n:"Piccoli Stivali di Forza",t:11,d:"Questi stivali aumentano la Forza di chi li porta a scapito dell\'Agilità. In poche parole ti rendono diverso da un Tofu ma non meno idiota.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[862] = {n:"Sandali di Intelligenza",t:11,d:"Questi sandali aumentano l\'Intelligenza di chi li porta, conferendogli allo stesso tempo uno stile veramente alla moda grazie alle suole in Legno di Noce che offrono un\'aderenza senza pari.",ep:1,g:4,l:8,wd:true,fm:true,w:1,p:400};
I.u[863] = {n:"Stivali Agileschi",t:11,d:"Questi stivali aumentano l\'Agilità di chi li porta, e fanno in modo che assomigli sempre più facilmente a un Tofu quando gli viene voglia di fare lo stupido.",ep:1,g:5,l:8,wd:true,fm:true,w:1,p:400};
I.u[864] = {n:"Stivali di Fortuna",t:11,d:"Questi stivali aumentano la Fortuna di chi li porta per permettergli di trovare degli oggetti molto potenti, come ad esempio la bava di Pappatutto.",ep:1,g:1,l:8,wd:true,fm:true,w:1,p:100};
I.u[867] = {n:"Dragolyr",t:1,d:"Questo splendido amuleto, fabbricato con resti di Draguovo, è abbastanza impressionante per far scappare in ritirata la maggior parte dei nemici.",ep:11,g:9,l:32,wd:true,fm:true,w:2,p:4700};
I.u[878] = {n:"Pergamena del Panettiere",t:13,d:"(Doppio click per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Panettiere.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[879] = {n:"Pergamena del Ciabattino",t:13,d:"(Doppio clic per utilizzarla)\nQuesta pergamena ti permette di acquisire Punti Esperienza nel mestiere di Ciabattino.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[880] = {n:"Lana di Pappatutto Reale",t:57,d:"Questa lana è reale, morbida e leggera, ma irrita un po\' le pelli sensibili. Inoltre è molto consumata e fragile, data l\'età del Pappatutto Reale.",ep:1,g:207,l:35,wd:true,fm:true,w:1,p:4000};
I.u[881] = {n:"Lana di Pappaton Bianco",t:57,d:"Si tratta di una lana morbidissima perché ricavata dal Pelo di un Pappaton. Attenzione però ad indossarla: questa lana è ancora impregnata di un odore che potrebbe spingere la madre del Pappaton a leccarti.",ep:1,g:208,l:2,wd:true,fm:true,w:1,p:1};
I.u[882] = {n:"Lana del Capo Guerra Pappatutto",t:57,d:"Questa lana puzza moltissimo, ma è appartenuta a un Capo di Guerra Pappatutto, il che le conferisce un grande valore sentimentale tra i guerrieri.",ep:1,g:209,l:19,wd:true,fm:true,w:1,p:1};
I.u[883] = {n:"Cuoio di Pappaton Bianco",t:56,d:"Questo cuoio molto liscio è particolarmente adatto alla confezione di biancheria in cuoio, le Mutande di Cuoio dello Chafer ne sono un perfetto esempio.",ep:1,g:534,l:2,wd:true,fm:true,w:1,p:1};
I.u[884] = {n:"Cuoio di Pappaton Nero",t:56,d:"Questo cuoio luccicante è molto apprezzato dai Ciabattini e dai Sarti per la confezione di stivaletti o cappelli.",ep:1,g:16,l:2,wd:true,fm:true,w:1,p:1};
I.u[885] = {n:"Lana di Pappaton Nero",t:57,d:"Questa lana grezza non è molto utilizzata dai Sarti, ma è invece molto apprezzata dagli Anutrof, che la usano come parrucchino.",ep:1,g:210,l:2,wd:true,fm:true,w:1,p:1};
I.u[886] = {n:"Cuoio di Pappatutto Reale",t:56,d:"Questo cuoio reale è di una morbidezza straordinaria, e le sue crepe sono la testimonianza della sua lunga vita di Pappatutto Reale. Non esiste cuoio migliore in tutta la provincia di Amakna.",ep:1,g:535,l:35,wd:true,fm:true,w:1,p:4000};
I.u[887] = {n:"Cuoio del Capo di Guerra Pappatutto",t:56,d:"\"Questo cuoio deve aver fatto tutte le guerre, anche le più dure\" cantava il famoso Menestrello Claudius Baglionus poco prima di morire asfissiato dall\'odore del Capo di Guerra Pappatutto.",ep:1,g:534,l:19,wd:true,fm:true,w:1,p:1};
I.u[888] = {n:"Grandi Stivali di Concentrazione",t:11,d:"Questi stivali sono così comodi che aumentano la concentrazione dell\'eroe che li calza.",ep:1,g:6,l:26,wd:true,fm:true,w:15,p:1950};
I.u[889] = {n:"Potenti Stivali di Concentrazione",t:11,d:"Questi stivali sono così comodi che aumentano la concentrazione dell\'eroe che li calza.",ep:1,g:6,l:27,wd:true,fm:true,w:15,p:2200};
I.u[890] = {n:"Stivali del Pappatutto",t:11,d:"L\'odore di questi stivali, fatti in cuoio di Pappatutto, permette agli allevatori di avvicinarsi più facilmente ai Pappatutto per ucciderli.",ep:1,g:3,l:1,wd:true,fm:true,w:3,p:150};
I.u[891] = {n:"Stivali del Grande Pappatutto",t:11,d:"L\'odore di questi stivali, fatti in cuoio di Pappatutto, permette agli allevatori di avvicinarsi più facilmente ai Pappatutto per ucciderli.",ep:1,g:3,l:2,wd:true,fm:true,w:4,p:200};
I.u[892] = {n:"Stivali del Potente Pappatutto",t:11,d:"L\'odore di questi stivali, fatti in cuoio di Pappatutto, permette agli allevatori di avvicinarsi più facilmente ai Pappatutto per ucciderli.",ep:1,g:3,l:4,wd:true,fm:true,w:5,p:250};
I.u[893] = {n:"Piccole Daghe Silvestri",t:5,d:"Queste daghe erano particolarmente adatte a tagliare radici o giovani alberi, ma ora qualcuno le ha trasformate in armi quasi mortali.",ep:1,g:6,l:20,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>20&CI>5",p:1300};
