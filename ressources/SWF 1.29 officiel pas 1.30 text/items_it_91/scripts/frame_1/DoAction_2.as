I.u[916] = {n:"Amuleto di Silicato",t:1,d:"Silicato ha fabbricato questo amuleto in un mattino d\'inverno, per il famoso avventuriero Rimb Vardi, che cacciava un vecchio Bwork Mago responsabile di numerose catastrofi naturali causate dalla sua magia troppo approssimativa.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"La Foglia d\'Autunno",t:1,d:"Questa spilla è stata fabbricata durante un mattino d\'autunno nel mezzo di una foresta di Faggi e Olmi non lontana dall\'isola di Olac-Lacustre. I Taglialegna la venerano come una reliquia.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Ambra Ancestrale",t:50,d:"Quest\'ambra proviene da un Alberagno Ancestrale, per questo ha un valore inestimabile e, se lavorata da mani esperte, può conferire delle proprietà magiche ad alcuni oggetti.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Daghe Ancestrali",t:5,d:"Queste potenti daghe, forgiate all\'antica con dell\'ambra Ancestrale, servirono durante la colonizzazione dell\'isola di Moon, prima che diventasse un luogo selvaggio.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Legno Ancestrale",t:38,d:"Questo legno viene da un Olmo dell\'isola di Olac-lacustre, folgorato un mattino d\'autunno da un Bwork Mago che non sapeva usare i suoi primi incantesimi.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Martello del Forgiatore di Asce",t:7,d:"Attrezzo indispensabile per la creazione di asce.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Fenditrice di Alberagno",t:19,d:"Questa ascia da guerra è stata forgiata da Kademlia Bulgur per combattere gli Alberagni più terrificanti. Secondo la leggenda quest\'arma ha ucciso più Alberagni in una notte sola di quanti alberi esistono ad Amakna.",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Potenti Stivali di Klim",t:11,d:"L\'Agilità che questi stivali conferiscono, permetteva a Klim il Ciabattino di montare facilmente in sella a qualsiasi Pappatutto. È morto per aver confuso un Pappatutto con una Gelatina, dopo una serata un po\' troppo alcolica alla taverna.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Legno Incantato",t:38,d:"Questo legno è stato incantato da un Mago Alberagno per dare vita a un piccolo Alberagno una volta immerso nell\'acqua. Inutile dire che è un legno estremamente magico.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Fenditrice di Alberagno Ancestrale",t:19,d:"Questa ascia da guerra è stata forgiata da Kademlia Bulgur per combattere l\'Alberagno Ancestrale. Solo i migliori guerrieri sono capaci di utilizzarla.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Lama di Ogralimde",t:6,d:"Ogralimde era un guerriero che doveva la sua forza al suo maestro Adyol, un potente Bwork Mago dotato di un\'intelligenza sorprendente. In questo caso, però, l\'allievo non ha mai superato il maestro, nonostante quello che racconta la leggenda.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristallite",t:50,d:"Questa pietra magica dal nome particolare non è da mettere nelle mani sbagliate, vista l\'enorme potenza che può conferire alle armi e ai gioielli.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Mappa del tesoro dei Minatori Oscuri",t:24,d:"Questa mappa indica la posizione del forziere dei Minatori Oscuri:\n\"Il forziere si trova su un\'isola, il suo accesso è dietro una fonderia\".",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Mappa del tesoro dei Panettieri Oscuri",t:24,d:"Questa mappa indica la posizione del forziere dei Panettieri Oscuri:\n\"Il forziere si trova su un\'isola a sud di Amakna, devi passare dietro le rocce tra due piccoli stagni\".",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Piccolo Mantello di Rossore",t:17,d:"Questo mantello aumenta la Vita di chi lo porta.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
