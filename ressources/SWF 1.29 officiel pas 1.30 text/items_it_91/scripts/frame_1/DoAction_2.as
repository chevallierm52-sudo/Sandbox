I.u[897] = {n:"Piccole Daghe Affilate",t:5,d:"Queste daghe dall\'apparenza modesta sono invece pericolosissime. Si possono inoltre occultare facilmente, e per questo sono armi richiestissime dagli assassini.",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
