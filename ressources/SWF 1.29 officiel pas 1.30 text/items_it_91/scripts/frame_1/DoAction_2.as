I.u[822] = {n:"Spada del Cavaliere",t:6,d:"La spada del Cavaliere è solida ed efficace. Se usata correttamente può provocare danni enormi ai tuoi nemici.",ep:7,g:9,l:23,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>46",p:1600};
I.u[823] = {n:"Spada del Grande Cavaliere",t:6,d:"La spada del Grande Cavaliere è solida ed efficace. Se usata correttamente può provocare danni enormi ai tuoi nemici.",ep:7,g:9,l:24,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>48",p:1800};
I.u[824] = {n:"Spada del Potente Cavaliere",t:6,d:"La spada del Potente Cavaliere è solida ed efficace. Se usata correttamente può provocare danni enormi ai tuoi nemici.",ep:7,g:9,l:26,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>52",p:2000};
I.u[825] = {n:"Lama del Bwork",t:6,d:"Questa spada dall\'aspetto rudimentale è molto apprezzata dai Bwork più stupidi che non sanno usare un arco o un bastone. Alcuni confondono persino la lama con il manico, per l\'immensa gioia dei nemici.",ep:1,g:13,l:23,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>46&CA>8",p:1600};
I.u[826] = {n:"Lama del Grande Bwork",t:6,d:"Questa spada dall\'aspetto rudimentale è molto apprezzata dai Bwork più stupidi che non sanno usare un arco o un bastone. Alcuni confondono persino la lama con il manico, per l\'immensa gioia dei nemici.",ep:1,g:13,l:24,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>48&CA>14",p:1800};
I.u[827] = {n:"Lama del Potente Bwork",t:6,d:"Questa spada dall\'aspetto rudimentale è molto apprezzata dai Bwork più stupidi che non sanno usare un arco o un bastone. Alcuni confondono persino la lama con il manico, per l\'immensa gioia dei nemici.",ep:1,g:13,l:26,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>52&CA>16",p:2000};
I.u[828] = {n:"Arco Fischiante",t:2,d:"Questo arco tira le frecce così rapidamente, che le si sentono partire da molto lontano. Ricordati di mettergli un silenziatore, se hai bisogno di essere discreto.",ep:1,g:15,l:11,wd:true,fm:true,w:10,an:10,tw:true,e:[5,3,2,6,30,40,false,true],c:"CA>11&CS>5",p:550};
I.u[829] = {n:"Arco Hata",t:2,d:"A causa della sua debole portata, questo arco non è molto efficace, ma permette comunque di indebolire il nemico quanto basta prima di dargli il colpo di grazia con un\'altra arma o magia.",ep:1,g:1,l:8,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,30,50,false,true],c:"CA>8",p:400};
I.u[830] = {n:"Bacchetta di Intelligenza",t:3,d:"Questa bacchetta aumenta l\'Intelligenza di chi la usa.",ep:7,g:1,l:24,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>24",p:1700};
