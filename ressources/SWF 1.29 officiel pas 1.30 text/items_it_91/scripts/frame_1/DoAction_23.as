I.u[10168] = {n:"Chispivali",t:11,d:"Ponch lucidava i suoi stivali tutte le mattine prima di partire in missione sul suo dragacchino per salvare la vedova e l\'orfano, ma soprattutto la vedova... Un dannato seduttore quel Ponch.",ep:0,g:141,l:42,wd:true,fm:true,w:10,s:138,p:4850};
I.u[10169] = {n:"Chispcudo",t:82,d:"Ponch portava fieramente questo scudo sul suo dragacchino quando vegliava sulla sicurezza delle stradine di Bonta.",ep:0,g:41,l:1,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10170] = {n:"Chispocasco",t:16,d:"Questo casco permette di proteggersi molto efficacemente dalle cadute dal dragacchino o di passare per un idiota senza esserlo.",ep:0,g:246,l:40,wd:true,fm:true,w:10,s:138,p:4400};
I.u[10171] = {n:"Chispuanto",t:9,d:"Questi guanti in cuoio sono perfetti per dare delle sculacciate.",ep:0,g:173,l:44,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10172] = {n:"Amulettuga",t:1,d:"Questo amuleto può nutrire una lumaca per due giorni, oppure per tre se viene accompagnato da un purè fatto con la tua testa.",ep:0,g:148,l:42,wd:true,fm:true,w:10,s:137,p:4900};
I.u[10173] = {n:"Lumastivali",t:11,d:"La suola di questi Stivali è ricoperta da una bava adesiva e l\'interno è riempito da una bava scivolosa. O forse è il contrario...",ep:0,g:142,l:39,wd:true,fm:true,w:10,s:137,p:4105};
I.u[10174] = {n:"Lumantello",t:17,d:"Una Bava vischiosa esce dei pori di questo Mantello. Prendi un po\' di slancio, sdraiati sulla schiena e lasciati scivolare.",ep:0,g:169,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10175] = {n:"Lumaschera",t:16,d:"Questa Maschera vischiosa e bavosa alimenterà con il gel il tuo cuoio capelluto in modo continuo. I due Occhi appesi alla Maschera possono essere connessi al tuo cranio se accetti di inserire le terminazioni nervose nelle Orecchie.",ep:0,g:247,l:42,wd:true,fm:true,w:10,s:137,p:4800};
