I.u[10131] = {n:"Regalo Vampyretta",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10132] = {n:"Regalo Pipì-strello",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10133] = {n:"Bacchetta del bandito stregone",t:3,d:"Questa bacchetta apparteneva ad un ex-bandito stregone che la utilizzava per ridurre in cenere i nemici che voleva bruciare. É impregnata da una magia così potente che rischierai di trasformarti in bandito stregone se te ne equipaggi...",ep:0,g:72,l:30,wd:true,fm:false,w:10,an:11,tw:true,e:[2,5,2,4,40,40,false,true],p:3000};
I.u[10134] = {n:"Certificato di Deposito al Cianil: Vampyretta",t:77,d:"Questo Certificato descrive le caratteristiche della Vampyretta che hai lasciato al Cianil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
