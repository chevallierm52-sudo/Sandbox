I.u[10118] = {n:"Canin Blando appena domato",t:32,d:"Questo Canin Blando è stato ammaestrato secondo il Metodo d\'Allevamento Canino messo a punto dal celebre addestratore di Maomao Riyu Tchevlakuk.",ep:0,g:23,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10119] = {n:"Gulifiato",t:30,d:"Ti senti diverso...",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,c:"POX10055&POX10054&POX10056&POX10061&POX10058&POX10102",p:0};
