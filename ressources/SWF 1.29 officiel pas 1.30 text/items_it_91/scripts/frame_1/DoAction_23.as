I.u[10102] = {n:"Maschera del Vampyro",t:16,d:"Questa maschera ti proteggerà dai raggi di sole in mancanza d\'altro.",ep:0,g:244,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4725};
I.u[10103] = {n:"Lettera per Fidji Merlin",t:24,d:"Ebru Of El ti ha affidato questa lettera da dare a Fidji Merlin. Sembra che sia necessario seguire le istruzioni della Tuttofare di Brakmar.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[10104] = {n:"Mangiatoia modificata",t:24,d:"Questa mangiatoia è stata modificata per nascondere delle melanzane ed è meglio non attraversare Brakmar su una cavalcatura che si sia saziata col contenuto di questa mangiatoia. Infatti, le flatulenze generate dal consumo eccessivo di melanzane potrebbero provocare un incidente esplosivo.",ep:0,g:759,l:1,wd:false,fm:true,w:0,p:1};
I.u[10105] = {n:"Zampa coperta di peli",t:24,d:"Questa Zampa di Arakne coperta di peli di Arakne e di Maomao è un\'arma terribile se bisogna affrontare Olledorb Oterges.",ep:0,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[10106] = {n:"Vampyretta",t:18,d:"Questa terribile creatura sarà al settimo cielo a succhiare il sangue dei tuoi amici o quello delle tue caviglie se sono un po\' troppo grosse. Ma neanche questo basterà a divertirla, adora soprattutto che tu affronti con lei degli scheletri per nutrirsi dei loro resti. Ti avevamo ben detto che è una creatura terribile.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10107] = {n:"Pipì-strello",t:18,d:"Questo famiglio ha avuto un\'infanzia difficile, ha ereditato un nome davvero stupido. Forse è ciò che spiega perché sia diventato un po\' pazzo e perché abbia una sola ossessione nella vita, uccidere tutti i Cenci che incontra per nutrirsi dei loro resti.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10108] = {n:"Fantasma di Vampyretta",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
