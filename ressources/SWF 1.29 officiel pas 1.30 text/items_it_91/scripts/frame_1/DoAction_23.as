I.u[10121] = {n:"Sassolino",t:51,d:"Questo sassolino serve ad attivare la magia delle Pietre per raggiungere lo Spirito dell\'Acqua. Il suo utilizzo è semplicissimo: basta appoggiarlo su una Pietra e la magia si compie da sola. Semplice ed efficace. Anche uno Yop può riuscirci, se nel frattempo non trova nessun nemico su cui gettare il sassolino.",ep:0,g:267,l:1,wd:false,fm:true,w:1,p:1};
I.u[10122] = {n:"Lista di Norb",t:24,d:"Norb ti ha fatto una lista dei risorse da portare a Nara. Ci vogliono:\n-2 * Bakelelite\n-10 * Manganese\n-20 * Bauxite\n-15 * Dolomite\n-20 * Legno d\'Oliviola.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
