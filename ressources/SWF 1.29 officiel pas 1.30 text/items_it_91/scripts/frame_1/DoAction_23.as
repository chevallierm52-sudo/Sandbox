I.u[10207] = {n:"Mazzo di chiavi",t:24,d:"E\' dotato di lunghe stanghette molto agili. Tuttavia, si stancano facilmente e la loro magia si ricarica solo dopo una settimana. Con questo oggetto potrai forzare tutte le serrature dei dongioni.",ep:0,g:774,l:1,wd:false,fm:true,w:0,p:0};
I.u[10208] = {n:"Elisir Pandawa",t:12,d:"Un buon sorso e sarai teletrasportato al tempio della tua classe. Effetti secondari conosciuti: coliche, apparizione di suocera, caduta dei capelli, alito di sciacallo, scarpe slacciate, semafori rossi successivi.",ep:0,g:153,l:1,wd:true,fm:true,w:1,c:"PG=12",u:true,p:0};
