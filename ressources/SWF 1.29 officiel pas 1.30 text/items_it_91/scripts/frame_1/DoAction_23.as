I.u[10089] = {n:"Cassa di merce",t:24,d:"Xefires ti ha chiesto di consegnare questa cassa di merce al consigliere Boyowa, dal Grandapan, in segno di fiducia. Tu ignori il suo contenuto esatto, ma si tratta di sicuro d\'oggetti di valore.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10090] = {n:"Lista delle forniture di Nara",t:24,d:"Nara ti ha fatto una lista di ciò di cui ha bisogno per il suo nuovo atelier da Forgiatore: 20 Legno di Quercia, 1 Scherzo di Zolfo, 30 Ferro, 1 Kuartz, 5 Bakelelite e 10 Pelli di Cinghiale delle Pianure.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10091] = {n:"Appunti sulla Maledizione d\'Orazzal",t:24,d:"La maledizione d\'Orazzal indica come resuscitare un\'anima contro la sua volontà. Ci vuole 1 Sangue di Fenice, 5 Polveri di Perlinpanpan e 1 Amuleto di Lear, ottenuto dai cadaveri di Alberagni e di Alberagni oscuri.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10092] = {n:"Ordine d\'annullamento",t:24,d:"Questa lettera, datata appena qualche ora fa, indica che l\'assalto su Bonta è stata annullato in ragione del migliore equipaggiamento che i loro miliziani hanno ricevuto, e della cattura del traditore Xefires.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
