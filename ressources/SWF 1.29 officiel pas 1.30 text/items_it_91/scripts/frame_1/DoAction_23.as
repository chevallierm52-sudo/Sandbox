I.u[10180] = {n:"L\'Esteban",t:1,d:"Questo Medaglione dovrebbe essere utilizzabile come una Chiave per accedere ad una misteriosa città dimenticata.",ep:0,g:149,l:42,wd:true,fm:true,w:10,s:136,p:4800};
I.u[10181] = {n:"Anello Solare",t:9,d:"Questo Anello è stato ritrovato in una misteriosa città di cui nessuno immaginava davvero l\'esistenza fino al momento in cui si è cominciato ad immaginarne l\'esistenza.",ep:0,g:174,l:41,wd:true,fm:true,w:10,s:136,p:4600};
I.u[10182] = {n:"Scudo Solare",t:82,d:"Questo Scudo assorbe i raggi solari e li dirige direttamente sul viso degli avversari. Non potendoli abbagliare con la tua intelligenza, li accecherai temporaneamente con questo Scudo.",ep:0,g:42,l:1,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10183] = {n:"Maschera Solare",t:16,d:"Questa Maschera catturerà i raggi solari e li concentrerà sul tuo viso per conservare la tua abbronzatura tutto l\'anno, anche se abiti a Nord di Amakna.",ep:0,g:248,l:42,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10184] = {n:"Maschera di Noké",t:16,d:"A Noké piaceva molto portare questa Maschera e nascondersi nei boschi per far paura ai camminatori sperduti. È morto di paura molto tempo fa riflettendosi in una pozzanghera.",ep:0,g:249,l:42,wd:true,fm:true,w:10,s:135,p:4700};
I.u[10185] = {n:"Mantello di Noké",t:17,d:"Noké sognava di essere un grande lupo cattivo. Perfino con questo Mantello sulle spalle, assomigliava solo ad un cattivello.",ep:0,g:170,l:41,wd:true,fm:true,w:10,s:135,p:4600};
I.u[10186] = {n:"Collana di Noké",t:1,d:"Questo Amuleto in Denti di Cinghiale spaventerà i Cinghiali, quindi anche tua suocera.",ep:0,g:150,l:41,wd:true,fm:true,w:10,s:135,p:4525};
I.u[10187] = {n:"Daghe di Noké",t:5,d:"Un tempo queste Daghe servirono a squartare un cinghiale bellicoso che sognava di essere un cervo.",ep:0,g:76,l:41,wd:true,fm:true,w:10,an:13,tw:true,e:[12,3,1,1,30,45,false,false],c:"CS>50&CW>50&CV>80",s:135,p:4000};
I.u[10188] = {n:"Copricapo della Derrata",t:16,d:"Questo copricapo ti trasformerà in un eccellente Wobot da protocollo grazie al suo dispositivo unico che permette di tradurre al volo le conversazioni dei cavoli. È anche un eccellente casco insonorizzante.",ep:0,g:250,l:43,wd:true,fm:true,w:10,s:133,p:5075};
I.u[10189] = {n:"Oxanello",t:9,d:"Questo Anello apparteneva ad uno zoccolaio conosciuto col nome di \"Il Fesso\" ereditato dopo un lungo viaggio a trotto. I suoi vicini l\'avevano soprannominato \"Il Fesso Trottatore\".",ep:0,g:175,l:37,wd:true,fm:true,w:10,s:133,p:3875};
I.u[10190] = {n:"Stivaletti della Derrata",t:11,d:"Se decidi di piantare dei cavoli, di moda qui da noi, ricordati di equipaggiare questi stivaletti concepiti per non schiacciare i cavoli. Non provare ad utilizzarli per ballare con il tuo partner, non permettono di evitare di schiacciare i piedi.",ep:0,g:143,l:38,wd:true,fm:true,w:10,s:133,p:3925};
I.u[10191] = {n:"L\'Oxocintura",t:10,d:"Questa cintura permette di contenere i tuoi gonfiori di stomaco dopo un\'indigestione di zuppa di cavoli.",ep:0,g:158,l:37,wd:true,fm:true,w:10,s:133,p:373};
I.u[10192] = {n:"Regalo Mantello Sics Uan Nain",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
