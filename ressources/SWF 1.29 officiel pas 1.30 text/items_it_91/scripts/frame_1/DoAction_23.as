I.u[10125] = {n:"Arco del Bandito arciere",t:2,d:"Questo arco apparteneva ad un ex-bandito arciere che lo utilizzava per finire le sue vittime a distanza, per non sporcarsi. É impregnato da una magia così potente che rischierai di trasformarti in bandito arciere se te ne equipaggi...",ep:0,g:67,l:30,wd:true,fm:false,w:10,an:10,tw:true,e:[2,6,3,5,40,40,false,true],p:3000};
I.u[10126] = {n:"Spada del bandito lama-fine",t:6,d:"Questa spada apparteneva ad un ex-bandito lama-fine che non sopportava di dover rincorrere gli avversari. Cominciava tagliando loro le gambe e in seguito poneva loro delle domande. É impregnata di una magia così potente che rischierai di trasformarti in bandito spadaccino se te ne equipaggi...",ep:0,g:92,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,40,40,false,false],p:3000};
I.u[10127] = {n:"Bastone del bandito battagliero",t:4,d:"Questo bastone apparteneva ad un ex-bandito battagliero. Sempre ubriaco, era incapace di ripulire le tasche delle sue vittime senza crollare. Questo bastone gli permetteva di restare in piedi il tempo di finire il suo dovere. É impregnato da una magia così potente che rischierai di trasformarti in bandito battagliero se te ne equipaggi...",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:12,e:[5,6,1,1,40,40,false,false],p:3000};
