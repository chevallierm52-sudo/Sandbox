I.u[10155] = {n:"Yugoleto",t:1,d:"Questo amuleto dovrebbe proteggerti dalle decapitazioni aleatorie o dalle obliterazioni epilatorie.",ep:0,g:147,l:43,wd:true,fm:true,w:10,s:134,p:5030};
I.u[10156] = {n:"Yugontofole",t:11,d:"Queste pantofole sono più comode delle pantofole normali, ma non saprai mai esattamente perché. Forse le migliaia di acari massaggiatori che vivono all\'interno sono li apposta per qualcosa.",ep:0,g:140,l:41,wd:true,fm:true,w:10,s:134,p:4575};
I.u[10157] = {n:"Yugura",t:10,d:"Questa cintura è stata fabbricata a partire da resti di fili di lino. Dovrebbe poter servire a chiudere i sacchi dell\'immondizia.",ep:0,g:157,l:43,wd:true,fm:true,w:10,s:134,p:5025};
