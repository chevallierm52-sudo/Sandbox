I.u[10043] = {n:"Il desiderio di essere bella",t:30,d:"Una lozione di bellezza molto potente ti ha dato questo aspetto... Eccoti pronta a far svenire tutti i mici! Miow!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10044] = {n:"Lozione di bellezza di Mylaise",t:12,d:"Ogni giorno Mylaise applica questa lozione sul suo corpo per restare giovane e bella... Provaci e vedrai! Però ogni minimo sforzo nel combattimento ti darà un aspetto scarno e i tratti saranno tirati...",ep:0,g:40,l:1,wd:false,fm:true,w:1,u:true,p:1};
