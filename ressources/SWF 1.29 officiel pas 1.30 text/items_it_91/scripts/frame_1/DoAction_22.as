I.u[9808] = {n:"Regalo Shushu di Rushu",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio e delle polveri d\'Aniripsa per curarlo.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9809] = {n:"Trasformazione Fantasma Shushu di Rushu",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9810] = {n:"Certificato di Deposito al Cianil: Shushu di Rushu",t:77,d:"Questo Certificato descrive le caratteristiche del Shushu di Rushu che hai lasciato al Cianil.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[9811] = {n:"Modulo di neutralità",t:24,d:"Questo certificato ti è stato dato da Morrie Gane per la milizia del castello di Amakna. É necessario per tornare neutro.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9812] = {n:"Modulo di diserzione",t:24,d:"Questo certificato che conferma la tua diserzione ti è stato recapitato da Morrie Gane. É un documento necessario per tornare neutro.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
