I.u[9916] = {n:"Pergamena di Incantesimo Speciale Lazo Spirituale",t:75,d:"(Doppio clic per imparare l\'incantesimo)\nQuesta pergamena ti permette d\'imparare l\'incantesimo Lazo Spirituale. Riservato solo agli Osamodas.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"PG=2",u:true,p:10000};
I.u[9917] = {n:"Pergamena premio",t:24,d:"Questa pergamena indica il bersaglio.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9919] = {n:"Anello del Gufo",t:9,d:"Per avere l\'aspetto di un gufo.",ep:0,g:7,l:1,wd:false,fm:false,w:0,p:0};
I.u[9920] = {n:"Pergamena premio compiuto",t:24,d:"Questa pergamena prova che il bersaglio è stato eliminato con successo.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9921] = {n:"Bracciale di Teutonik",t:9,d:"Questo braccialetto dovrebbe brillare, ma solo di notte e nelle taverne.",ep:0,g:168,l:45,wd:true,fm:true,w:10,s:132,p:5525};
I.u[9922] = {n:"Cintura del Teutonik",t:10,d:"Questa cintura è dotata di un meccanismo magnetico incredibilmente potente che le permette di restare chiusa senza usare la fibbia della cintura. Attenzione, si sconsiglia di utilizzarla quando s\'indossano già delle mutande di piombo.",ep:0,g:154,l:38,wd:true,fm:true,w:10,s:132,p:4050};
I.u[9923] = {n:"Scarpe di Teutonik",t:11,d:"Se sei molto muscoloso e vuoi ballare come un robot, queste scarpe sono fatte per te. Attenzione, i lacci sono un optional.",ep:0,g:135,l:40,wd:true,fm:true,w:10,s:132,p:4300};
I.u[9924] = {n:"Corna folgoranti",t:16,d:"La leggenda racconta che questa corna servivono da parafulmine, concentrano i fulmini per molte ore e poi scaricano la loro furia sugli imprudenti che si avvicinano troppo. Un\'altra leggenda racconta che ti servono solo a farti passare per un idiota.",ep:0,g:239,l:42,wd:true,fm:true,w:10,s:139,p:4825};
I.u[9925] = {n:"Pugno folgorante",t:9,d:"Questo anello è più simile ad un guanto che ad una fede, la che importa, nessuno ti stringerà più la mano come prima.",ep:0,g:169,l:44,wd:true,fm:true,w:10,s:139,p:4400};
I.u[9926] = {n:"Ascia doppia folgorante",t:19,d:"Quest\'ascia, composta da due lame, permette di tagliare due teste simultaneamente decapitando quindi un ottavo di un\'idra a sedici teste in un colpo solo.",ep:0,g:57,l:39,wd:true,fm:true,w:10,an:17,e:[3,5,1,1,20,50,false,false],c:"CC>60&CV>50&CW>30",s:139,p:3900};
I.u[9927] = {n:"Stivali folgoranti",t:11,d:"Olcar portava questi stivali quando, dall\'alto del monte Jifu vide degli strani oggetti volanti non identificati solcare il cielo.",ep:0,g:136,l:42,wd:true,fm:true,w:10,s:139,p:4805};
I.u[9928] = {n:"Stivali Sics Uan Nain",t:11,d:"Ci vorranno almeno 12 ore per annodare i lacci di questi stivali e 16 ore per snodarli. Se decidi di toglierli una volta al giorno, sarai in ritardo ogni giorno, a meno di portarti avanti fin da oggi per i prossimi giorni.",ep:0,g:137,l:42,wd:true,fm:true,w:10,s:131,p:4750};
I.u[9929] = {n:"Cintura Sics Uan Nain",t:10,d:"Per alcuni guerrieri il tallone d\'Achille si trova al livello dell\'ombelico. Con questa cintura attorno ai fianchi i tuoi amici ti troveranno pesante il doppio, ma tu sarai più protetto.",ep:0,g:155,l:41,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9930] = {n:"Maschera Sics Uan Nain",t:16,d:"Con questa maschera sulla testa da lontano sembrerai una gigantesca larva mutante, ma da vicino sembrerai un terribile guerriero. Evita i combattimenti a distanza.",ep:0,g:240,l:38,wd:true,fm:true,w:10,s:131,p:4000};
I.u[9931] = {n:"Copricapo di Teutonik",t:16,d:"Capelli lunghi sul collo, cresta da Pìut, questo copricapo ti starà come un guanto, soprattutto se lo infili altrove piuttosto che alle mani.",ep:0,g:241,l:39,wd:true,fm:true,w:10,s:132,p:4255};
I.u[9932] = {n:"Ciuffo di peli del Taverniere Bagrutta",t:24,d:"Questo ciuffo di peli appiccicoso è stato strappato dalle ascelle del Taverniere Bagrutta. L\'odore che si sprigiona ti dà voglia di correre e di saltare urlando Groink! Un altro disturbo psichiatrico latente.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[9933] = {n:"Mantello Sics Uan Nain",t:17,d:"I peli di Bituf cuciti sulla parte alta di questo mantello proteggeranno in modo efficace la tua testa quando il pubblico deciderà di lanciarti qualche sedia per esprimere la mediocrità delle tue prestazioni.",ep:0,g:167,l:42,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9934] = {n:"Chiave del recinto",t:24,d:"I goblin sono dotati di strumenti rudimentali, quindi riciclano tutto ciò che riescono e quest\'osso non fa eccezione alla regola. Chi avrebbe creduto che un semplice osso avrebbe permesso d\'aprire il loro recinto? Di sicuro non tu.",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9935] = {n:"Corda da scalata",t:15,d:"Questa corda molto solida, in voga tra gli alpinisti in erba, può servire sia a salire che a scendere. Tuttavia, un\'antica tradizione amakneiana consiste nel fare un nodo scorrevole all\'estremità e nel passare questo nodo attorno al collo del capo del villaggio per fargli capire che le sue decisioni non fanno l\'unanimità.",ep:0,g:170,l:1,wd:false,fm:true,w:5,p:1};
I.u[9936] = {n:"Caskostar",t:16,d:"Questo casco è l\'ideale se vuoi sembrare cattivo nonostante il tuo viso da cherubino e i brufoli dell\'acne.",ep:0,g:242,l:37,wd:true,fm:true,w:10,s:117,p:3825};
I.u[9937] = {n:"Il Chappello",t:16,d:"Questo cappello è consegnato con una barba finta che non cresce, cosa che ti permetterà di risparmiarti qualche seduta dal barbiere.",ep:0,g:243,l:37,wd:true,fm:true,w:10,s:116,p:3700};
I.u[9938] = {n:"Shabola",t:6,d:"La lama di questa sciabola è stata immersa per 18 mesi in un concentrato di purè di lucciole. É davvero riprovevole, ma almeno brilla al buio.",ep:0,g:91,l:38,wd:true,fm:true,w:10,an:14,tw:true,e:[5,4,1,1,50,50,false,false],c:"CV>30&CS>20&CW>20",s:117,p:3800};
I.u[9939] = {n:"La Chapanna",t:4,d:"Questa canna flessibile è appartenuta ad un illustre vagabondo dai modi raffinati.",ep:0,g:88,l:37,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"CC>25",s:116,p:3700};
I.u[9940] = {n:"Madreperla bruta",t:51,d:"Lucidata correttamente, questa pietra rivelerà tutto il suo potenziale.",ep:0,g:10,l:20,wd:true,fm:true,w:1,p:10};
I.u[9941] = {n:"Madreperla",t:50,d:"Composta da cristalli d\'aragonite e di conchiolin, la madreperla era sconosciuta fino alla scoperta dell\'isola di Otomai e dei crustoralli. È un elemento molto apprezzato in alchimia e in gioielleria, benché le ricette in cui viene utilizzata siano tenute gelosamente segrete.",ep:0,g:4,l:50,wd:true,fm:true,w:10,p:5000};
I.u[9942] = {n:"Anello della morte",t:9,d:"La fabbricazione di quest\'anello, conosciuto anche con il nome di \"Anello nero\" sembra non essere terminata. Ma che importa, la sua potenza basta per distruggere una luna.",ep:0,g:170,l:36,wd:true,fm:true,w:10,s:117,p:3600};
I.u[9943] = {n:"I Chapangrattati",t:11,d:"Queste magnifiche scarpe sono ricoperte con una vernice a base di... Nessuno lo sa davvero, ma finchè brillano se ne fregheranno tutti.",ep:0,g:138,l:43,wd:true,fm:true,w:10,s:116,p:4975};
I.u[9944] = {n:"La Chapavatta",t:1,d:"Insieme amuleto e cravatta, quest\'oggetto da pompa magna permetterà ai tuoi cari di tenerti al guinzaglio facilmente. E la cosa non ti dispiace.",ep:0,g:145,l:43,wd:true,fm:true,w:10,s:116,p:5000};
I.u[9945] = {n:"Zaino di Bouba il Profeta",t:81,d:"Bouba ha sempre detto di essere un profeta, portatore di un messaggio che lui stesso ha finito per dimenticare. Riconvertitosi per molti anni come Cacciatore di premi, ha terminato la sua triste carriera digerito nel ventre di una creatura delle sabbie.",ep:0,g:33,l:38,wd:true,fm:true,w:10,s:117,p:4050};
I.u[9946] = {n:"Cristallo di Kain Dharyn",t:24,d:"Kain Dharyn era un Cacciatore di tesori famoso in tutta Amakna. Tra le sue scoperte ci sono dei cristalli preziosi dalle proprietà sorprendenti, fra cui la facoltà d\'adocchiare all\'inverso senza le mani. Kain nascose la posizione del giacimento e ancora oggi numerosi Anutrof lo cercano.",ep:0,g:744,l:1,wd:false,fm:true,w:0,p:1};
I.u[9947] = {n:"Cristallo di Kain Dharyn incantato",t:24,d:"Questo Cristallo di Kain Dharyn è stato incantato in modo da decuplicare l\'avidità di coloro che l\'osservano.",ep:0,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9948] = {n:"Tibia del capo dei ladri",t:24,d:"Con una tibia in meno, per il capo dei ladri non sarà facile camminare. Peggio per lui, gli servirà di lezione.",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9949] = {n:"Pasta alla Ta Trak",t:110,d:"Questa pasta fu inventata dal celebre Ta Trak, geologo specialista dell\'ecosistema e delle mietiture, colpito precocemente d\'artrosi alla schiena. Questa pasta aveva come particolarità d\'irrigidire e indurire qualsiasi sostanza organica con cui entrasse in contatto, il che permetteva a Ta Trak di tenersi dritto. Fu solo dopo la morte di quest\'ultimo che fu trovato tutt\'altro impiego per questa pasta, molto in voga soprattutto tra gli Anutrof. Il suo solo inconveniente è l\'odore, il che spiega l\'alito di certe Anutrofine.",ep:0,g:42,l:1,wd:false,fm:true,w:1,p:1};
I.u[9950] = {n:"Pietra d\'imbrattatura blu impura",t:51,d:"Lucidata correttamente, questa pietra rivelerà tutto il suo potenziale.",ep:0,g:151,l:1,wd:false,fm:true,w:5,p:1};
I.u[9951] = {n:"Pietra d\'imbrattatura gialla impura",t:51,d:"Lucidata correttamente, questa pietra rivelerà tutto il suo potenziale.",ep:0,g:145,l:1,wd:false,fm:true,w:5,p:1};
I.u[9952] = {n:"Pietra d\'imbrattatura verde impura",t:51,d:"Lucidata correttamente, questa pietra rivelerà tutto il suo potenziale.",ep:0,g:76,l:1,wd:false,fm:true,w:5,p:1};
I.u[9953] = {n:"Pietra d\'imbrattatura blu",t:50,d:"Questa pietra è in grado d\'imbrattare un\'anima senza troppa volontà, il che può avverarsi efficace per trasformare dei tofu in tofu malefici. Combinata ad altre pietre d\'imbrattatura, potrebbe permettere un controllo totale sulle anime imbrattate.",ep:0,g:460,l:50,wd:false,fm:true,w:10,p:100};
I.u[9954] = {n:"Pietra d\'imbrattatura gialla",t:50,d:"Questa pietra è in grado d\'imbrattare un\'anima senza troppa volontà, il che può avverarsi efficace per trasformare dei tofu in tofu malefici. Combinata ad altre pietre d\'imbrattatura, potrebbe permettere un controllo totale sulle anime imbrattate.",ep:0,g:463,l:50,wd:false,fm:true,w:10,p:100};
I.u[9955] = {n:"Pietra d\'imbrattatura verde",t:50,d:"Questa pietra è in grado d\'imbrattare un\'anima senza troppa volontà, il che può avverarsi efficace per trasformare dei tofu in tofu malefici. Combinata ad altre pietre d\'imbrattatura, potrebbe permettere un controllo totale sulle anime imbrattate.",ep:0,g:461,l:50,wd:false,fm:true,w:10,p:100};
I.u[9956] = {n:"Pietra delle Anime Imbrattate",t:24,d:"Questa pietra proviene dai Pozzi delle Anime Imbrattate. Grazie ad essa, è possibile controllare le anime delle creature intrappolate al suo interno.",ep:0,g:462,l:1,wd:false,fm:true,w:0,p:1};
I.u[9957] = {n:"null",t:114,d:"",ep:0,g:6,l:40,wd:false,fm:false,w:15,an:14,tw:true,e:[3,5,1,1,45,90,false,true],p:1};
I.u[9958] = {n:"Cassa di equipaggiamento Bontariano",t:24,d:"Questa cassa racchiude il kit del perfetto piccolo miliziano. Se il contenuto di questa cassa ha la stessa qualità del suo contenitore, non ci si dovrà stupire se la milizia di Bonta sarà battuta in meno di un giorno.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9959] = {n:"Rapporto di perizia",t:24,d:"Come immaginavi, questo rapporto della perizia conferma la cattiva qualità dell\'equipaggiamento dei miliziani Bontariani. Questa notizia dovrebbe mandare Oto Mustam in visibilio.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9960] = {n:"Chiavi del magazzino",t:24,d:"Questo boccale contiene i resti di ciò che un tempo si trovava nel ventre d\'Ybur Effel. La buona notizia è che contiene anche le Chiavi del magazzino. Ti resta solo metterci dentro le mani per recuperarle e, soprattutto, dopo non dimenticare di leccarti le dita.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9961] = {n:"Martello Martel",t:7,d:"Questo Martello di pessima qualità è stato concepito per ingannare i Forgiatori facendo credere loro che avevano in mano un martello d\'eccellente qualità. È vivamente sconsigliato usarlo, anche per non farci niente.",ep:0,g:2,l:1,wd:true,fm:false,w:5,an:15,e:[5,4,1,1,60,20,false,false],p:10};
I.u[9962] = {n:"Cassa di minerale",t:24,d:"Hai rubato questa cassa di minerale in modo che Ollatem Ossa non possa usarlo per fabbricare i nuovi equipaggiamenti destinati ai miliziani di Bonta.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9963] = {n:"Martello del Forgiatore",t:24,d:"Hai rubato questo Martello a Ollatem Ossa e l\'hai sostituito con un Martello di Martel. Ollatem Ossa è talmente incompetente che non dovrebbe vedere la differenza.",ep:0,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9964] = {n:"Regalo Dragacchino Kramaleonte",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno.  Non perdere un solo istante, aprilo subito!",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9965] = {n:"Metodo d\'Allevamento Canino",t:24,d:"Questo metodo, redatto dal celebre addestratore di Maomao Riyu Tchevlakuk, spiega come domare un Canin Blando per renderlo il miglior amico dell\'uomo, ma non della donna.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9966] = {n:"Bottino del convoglio",t:24,d:"Hai ottenuto un bottino attaccando un convoglio Bontariano. Calpestinor il Mascalzone, nell\'edificio della milizia di Brakmar, saprà ricompensarti per i tuoi sforzi. Con un po\' di fortuna, accetterà perfino di lasciarti andare tutt\'intero.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9967] = {n:"Come preparare della Glutoberg",t:24,d:"Laura Soho, cameriera alla Taverna di Amakna, ti ha scritto su questo Pezzo di Carta come preparare una buona Bottiglia di Glutoberg grazie ad un Alchimista.\n- 5 Fiale di Pandaburg.\n- 1 Gluto Rhum.\n- 10 Foglie di Insalace.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9968] = {n:"Bottiglia di Glutoberg",t:79,d:"Questa miscela di alcool potentissimi ustiona la lingua, raschia il palato, brucia l\'esofago e fa esplodere lo stomaco prima di far bollire il cervello. Tanto vale dire che è una bevanda per i Pandawa, quelli veri!\nSotto alla bottiglia, molto in piccolo, c\'è scritto: l\'abuso di alcool è dannoso per la salute, da consumare con moderazione tranne in caso di libagione per la dea. ",ep:0,g:177,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[9969] = {n:"Insalace di Mare Avvelenata",t:15,d:"Come dice il detto: un odore può nasconderne un altro. In effetti il profumo che si sprigiona da questa Insalace di Mare cela un potente Veleno che, se ingurgitato, fa rigurgitare. Molto efficace per animare un matrimonio un po\' fiacco o per fare uno scherzo al proprio Capo di Gilda preferito.",ep:0,g:80,l:1,wd:false,fm:true,w:1,p:1};
I.u[9970] = {n:"Ricetta dell\'Insalace di Mare",t:24,d:"Gropinson Crulué ha scritto la Ricetta dell\'Insalace di Mare sulla sabbia della spiaggia e tu l\'hai ricopiata su questo pezzo di carta.\n- Un Pescivendolo (metterlo nel piatto è opzionale).\n- 2 Branzini Rikano.\n- 3 Bastoncini di Granchio ***.\n- 2 Limoni.\n- 4 Foglie di Insalace.\n- 1 Blopisiero avvelenato (questo è il tuo tocco personale).",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9971] = {n:"Chiavi di Mulic Ber",t:24,d:"Queste Chiavi appartengono a Mulic Ber. Danno accesso alla sua Fucina speciale che permette, tra l\'altro, di fabbricare oggetti poco comuni per persone molto comuni come te.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9972] = {n:"Martello del Forgiatore di Grattaschiena",t:7,d:"Questo Martello destinato alla Fucina è stato concepito per un impiego ben preciso, cosa che rende difficile utilizzarlo per qualcos\'altro. Solo una persona disperata o emarginata lo utilizzerebbe per fabbricare delle armi.",ep:0,g:2,l:1,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,50,false,false],c:"PJ>20,49",p:150};
I.u[9973] = {n:"Estremità del Grattaschiena",t:15,d:"L\'Estremità di questo Grattaschiena ha numerose articolazioni per facilitare il suo utilizzo. I numerosi aculei illustrano perfettamente il vecchio detto Amakneiano \"Chi si sfrega si punge\".",ep:0,g:716,l:1,wd:false,fm:true,w:1,p:1};
I.u[9974] = {n:"Intagliatrice di Manichi",t:5,d:"Se utilizzi questa Intagliatrice durante i combattimenti, sarai agile come un manico. Se, invece, la utilizzi per scolpire delle maniche, i Sarti finiranno sul lastrico, cosa che farà arrabbiare i Contadini.",ep:0,g:17,l:1,wd:true,fm:true,w:5,e:[5,4,1,1,50,50,false,false],c:"PJ>19,49",p:150};
I.u[9975] = {n:"Manico del Grattaschiena",t:15,d:"Da solo questo Manico non ti servirà a nulla. È possibile aggiungere un\'estremità, ma neanche questa sarà utile. Puoi ragionevolmente concludere che solo uno spirito perverso saprebbe cosa farci.",ep:0,g:52,l:1,wd:false,fm:true,w:5,p:1};
I.u[9976] = {n:"Grattaschiena Incompleto",t:15,d:"Questo Grattaschiena è quasi perfetto. Quasi, ma non completamente. Solo un Forgiatore di grande talento potrebbe finirlo, ma sfortunatamente non ne conosci nessuno.",ep:0,g:52,l:1,wd:false,fm:true,w:10,p:1};
I.u[9977] = {n:"Grattaschiena Spentox",t:24,d:"Questo Grattaschiena ricoperto di Pungiglioni è articolato in modo da sposare la forma del corpo e raggiungere punti fino ad ora inaccessibili. Non cominciare a sognare, la bellezza non corrisponde a nessun punto preciso.",ep:0,g:745,l:1,wd:false,fm:true,w:0,p:1};
I.u[9978] = {n:"Esercito di Zecche di Cinghiale delle Pianure",t:24,d:"Più grosse delle Zecche di Pappatutto, le Zecche di Cinghiale delle Pianure possono assorbire fino a cento volte il loro peso in sangue. Da far morire di invidia i Vampiri e perfino Dark Vlad in persona.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9979] = {n:"Filtro di Longevità",t:12,d:"L\'Alchimista Nileza creò questa Pozione con la speranza che potesse concedergli l\'immortalità. Sfortunatamente morì prima di poterla utilizzare, scambiandola con il Sangue di Likrone avvelenato che si trovava lì accanto.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[9980] = {n:"Piatto di Gambretti",t:49,d:"Questo Piatto illustra perfettamente l\'espressione favorita del cavaliere Kacador \'Il grasso è la vita\'.",ep:0,g:82,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9981] = {n:"Farina Aspirata",t:52,d:"Questa farina fu utilizzata da Xavier il Panettiere per ideare il pane utilizzato in tutti i funerali del celebre Menestrello Claudius Baglionus.",ep:0,g:7,l:1,wd:false,fm:true,w:1,p:1};
I.u[9982] = {n:"Insalata Rivestita",t:69,d:"Il nome di questa Insalata è un omaggio al giorno in cui è stata creata. In effetti è stata servita per la prima volta durante la cerimonia di vestizione del Cavaliere Kacador. Come tutto il cibo destinato al Cavaliere, questa Insalata è sconsigliata ai vegetariani.",ep:0,g:129,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9983] = {n:"Pane Inphetto",t:33,d:"Servito durante i funerali del celebre Menestrello Claudius Baglionus, il gusto e l\'odore di questo Pane sono così disgustosi da resuscitare un morto o da uccidere un vivo. Il che potrebbe spiegare le numerose rinascite del Menestrello Claudius Baglionus.",ep:0,g:13,l:1,wd:false,fm:true,w:2,u:true,ut:true,p:1};
I.u[9984] = {n:"Lista degli Ingredienti di un tempo",t:24,d:"Ecco la Lista data da Oto Mustam:\n-1 * Pane Inphetto.\n-1 * Insalata Rivestita.\n-1 * Piatto di Gambretti.\n-1 * Filtro di Longevità.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9985] = {n:"Ricetta del Pane Inphetto",t:24,d:"-2 * Farina Aspirata.  \n-5 * Acqua.\n-2 * Lievito del Panettiere.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9986] = {n:"Ricetta della Farina Aspirata",t:24,d:"-1 * Farina di Xavier il Panettiere.\n-1 * Polvere d\'Aniripsa.\n-4 * Cipolla.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9987] = {n:"Ricetta dall\'Insalata Rivestita",t:24,d:"-5 * Insalata di Muso ***.\n-20 * Polline di Blop.\n-10 * Gemma di Alberagno.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9988] = {n:"Ricetta del Piatto di Gambretto",t:24,d:"-10 * Frittella di Gambretto ***.\n-5 * Limone.\n-10 * Foglia di Insalace.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9989] = {n:"Ricetta del Filtro di Longevità",t:24,d:"-2 * Sangue di Likrone.\n-10 * Pozione di Vecchiaia.\n-2 * Pozione di Ricordo.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9990] = {n:"Spilla di Gerl",t:24,d:"Questa spilla ti è stata data da Gerl per aver difeso coraggiosamente il suo convoglio di mercanzia. È anche il segno della sua promessa di ringraziarti personalmente al suo ritorno a Bonta.",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9993] = {n:"Sabina",t:32,d:"Devi portare Sabina all\'edificio della milizia di Brakmar.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9995] = {n:"Pergamena Legata di mercenario",t:87,d:"Questa pergamena permette di localizzare il bersaglio per cacciarlo.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps=3",u:true,p:1};
I.u[9996] = {n:"Lotto di cento pergamene di mercenariato",t:87,d:"Questo lotto permette di \"marchiare\" <b>un solo bersaglio</b> per permettere poi ad un mercenario di cacciarlo più volte.",ep:0,g:3,l:10,wd:false,fm:true,w:100,ut:true,p:3500};
I.u[9997] = {n:"Chiave del covo dei banditi",t:24,d:"Questa chiave permette di aprire la porta del covo dei banditi. Grazie a Errabondol sai che un meccanismo chiude automaticamente la porta appena entra qualcuno. Ecco perché ogni persona autorizzata dai banditi possiede un esemplare della chiave.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9999] = {n:"Copia della chiave del covo dei banditi",t:84,d:"Questa copia della chiave del covo dei banditi Ecaflip sembra essere sul punto di rompersi. Ci si può scommettere che accadrà quando vorrai usarla. L\'indicazione \"Da adoperare con attenzione\" non appare sull\'imballaggio: ne dedurrai che si tratta di una contraffazione e hai ragione!",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10000] = {n:"Ciuffo di peli di Errabondol",t:24,d:"Tenendo in mano questo ciuffo di peli, hai l\'impressione che brulichi d\'attività. Se si guarda da più vicino, la tua impressione è confermata. Non è un ciuffo di peli ma un ciuffo di pulci e di zecche giganti. Insomma, hai nelle tue mani un vero ecosistema.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[10001] = {n:"Lotto di dieci pergamene di mercenariato",t:87,d:"Questo lotto permette di \"marchiare\" <b>un solo bersaglio</b> per permettere poi ad un mercenario di cacciarlo più volte.",ep:0,g:3,l:10,wd:false,fm:true,w:10,ut:true,p:500};
I.u[10002] = {n:"Pergamena vergine di mercenariato",t:87,d:"Questa pergamena permette di \"marchiare\" un bersaglio per permettere poi ad un mercenario di cacciarlo.",ep:0,g:1,l:10,wd:false,fm:false,w:1,ut:true,p:100};
I.u[10003] = {n:"Gelatina Sbhica",t:110,d:"Solo Leroy Merlin conosce la ricetta di questa gelatina artificiale. Quando si combina a dell\'erba umida, la gelatina si indurisce e prende la forma di qualsiasi oggetto che sia stato messo al suo interno in precedenza, il che rende l\'uso della Gelatina Sbhica molto popolare per confezionare le cozze.",ep:0,g:47,l:1,wd:false,fm:true,w:0,p:1};
I.u[10004] = {n:"L\'arte d\'utilizzare la Gelatina Sbhica",t:24,d:"Questo documento redatto da Leroy Merlin spiega i mille e un usi della Gelatina Sbhica. La parte che ti interessa è quella che spiega come creare delle chiavi a basso costo:\n-1 * Gelatina Sbhica.\n-1 * Erba Folle\n-1 * Bakelelite.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10005] = {n:"Documenti confidenziali",t:24,d:"Una lista di documenti confidenziali bontariani. Ci si può chiedere come dei tali documenti si siano ritrovati in un covo di banditi.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10006] = {n:"Rapporto sospetto",t:24,d:"Questo rapporto ha gettato dei grossi sospetti su di te. Mette in dubbio la tua lealtà verso Bonta e ti implica in numerosi loschi affari. Solo un esperto potrà dirti se si tratta di un documento autentico.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10007] = {n:"Fiala di veleno brakmariano",t:24,d:"Questa fiala di veleno brakmariano preparata in modo tradizionale contiene l\'indicazione \'Da conservare al caldo e da consumare molto lentamente una volta aperta\', seguita dall\'indicazione \'Non ingoiare, tranne se sei la vittima o bontariano\'. È chiaro che i Brakmariani non scherzano con il veleno.",ep:0,g:39,l:1,wd:false,fm:true,w:0,p:1};
I.u[10008] = {n:"Registro dei clienti",t:24,d:"Questo registro contiene la lista di tutti i clienti dell\'atelier degli Alchimisti di Brakmar di queste ultime due settimane. Il problema è che è scritto tutto in brakmariano e tu non ci capisci niente.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10009] = {n:"Xefires",t:32,d:"Devi portare il traditore Xefires da Amayiro. Deve rendergli conto di molte cose.",ep:0,g:24,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10010] = {n:"Chiave della Sala da Gioco",t:24,d:"Questa Chiave dà accesso alla Sala da Gioco della Taverna del Maokemao.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[10011] = {n:"Cuore di Pola",t:24,d:"Questo è il Cuore ancora palpitante di Pola. Che una Discepola del dio Etram non abbia opposto alcuna resistenza quando le hai tolto la vita ti turba ancora, ma, riflettendoci, ti dici che il risultato sarebbe stato lo stesso ed è a cuor leggero che porti questo Cuore al tuo adorato Capo.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10012] = {n:"Cuore di Pola",t:24,d:"Questo è il Cuore ancora palpitante di Pola. Che una Discepola del dio Etram non abbia opposto alcuna resistenza quando le hai tolto la vita ti turba ancora, ma, riflettendoci, ti dici che il risultato sarebbe stato lo stesso ed è a cuor leggero che porti questo Cuore al tuo adorato Capo.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10013] = {n:"Cuore di Pola",t:24,d:"Questo è il Cuore ancora palpitante di Pola. Che una Discepola del dio Etram non abbia opposto alcuna resistenza quando le hai tolto la vita ti turba ancora, ma, riflettendoci, ti dici che il risultato sarebbe stato lo stesso ed è a cuor leggero che porti questo Cuore al tuo adorato Capo.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10014] = {n:"Assegno di Pola",t:24,d:"Questo Assegno destinato a Oto Mustam è stato preparato da Pola. Peccato che non si tratti di kama sonanti, se no avresti potuto servirti discretamente.",ep:0,g:54,l:1,wd:false,fm:true,w:0,p:1};
I.u[10015] = {n:"Lista della Spesa di Oto Mustam",t:24,d:"Hai fallito miseramente al test di malignità e Oto Mustam te la vuol far pagare obbligandoti a trovare i seguenti Oggetti:\n-1 * Sacco di Bronzo.\n-1 * Sacco di Malto.\n-1 * Sacco di Fiori di Canapa.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10016] = {n:"Ascia Cheuleana",t:24,d:"Sembra che quest\'ascia dall\'aspetto rudimentale appartenga ad un\'altra epoca. La sua qualità è così mediocre che ti sembra impossibile tagliarci un Tronknyde.",ep:0,g:746,l:1,wd:false,fm:true,w:0,p:1};
I.u[10017] = {n:"Katana di Nara",t:24,d:"Questa Katana è stata fabbricata da Nara in occasione del suo esame. La sua qualità è di gran lunga migliore dell\'Ascia Cheuleana fabbricata da Ollatem Ossa.",ep:0,g:53,l:1,wd:false,fm:true,w:0,p:1};
I.u[10018] = {n:"Schema della Molletta da Bucato",t:15,d:"Questo schema è così chiaro che forse anche un piccolo di Yop potrebbe capirlo. Forse perché uno Yop resta uno Yop. Tra le mani di un Tuttofare, questo schema potrebbe anche servire a fabbricare degli oggetti. Se in più un Tuttofare è uno Yop, potresti assistere ad un miracolo.\nTi serve questo schema, 10 Tavole di Legno di Kalipto e 10 Alluminiti.",ep:0,g:767,l:1,wd:false,fm:true,w:1,p:1};
I.u[10019] = {n:"Secchio delle Mollette da Bucato",t:15,d:"Questo secchio contiene abbastanza Mollette da Bucato per attaccare la biancheria di tutta la guarnigione di Amakna sui bastioni. Si possono usare anche per far asciugare le pelli e le cotenne dei mostri appena uccisi o dei tuoi suoceri.",ep:0,g:768,l:1,wd:false,fm:true,w:10,p:1};
I.u[10020] = {n:"Bambola Malmenata",t:24,d:"Fai fatica a credere che questa Bambola dall\'aspetto sgradevole e dall\'odore ripugnante un tempo sia stata un Bwork Mago. Poi ti dici che l\'aspetto d\'un Bwork Mago è ripugnante e che il suo odore è sgradevole, quindi la storia acquista un senso.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10021] = {n:"Bambola Rattoppata",t:24,d:"Ti chiedi se la Bambola stesse meglio prima o dopo essere stata rattoppata da Maskara. Una cosa è certa, solo un dio poteva rendere la Bambola più bella del suo modello originario. Allora si capirà meglio perché il Bwork Mago si era rinchiuso in una caverna e la ragione del suo brutto carattere.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10022] = {n:"Bambola Incantata",t:24,d:"Che incantesimo ricevere questa bambola incantata dalle mani dell\'incantatore che l\'ha incantata nei Laghi Incantati. Se fosse ancora in vita, il Menestrello Claudius Baglionus di sicuro te l\'avrebbe offerta cantando.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10023] = {n:"Registro delle ronde",t:24,d:"Contrariamente a ciò che indica il titolo, questo registro non parla delle Mama Bwork, ma del percorso imboccato dalle pattuglie Brakmariane. Per tendere un\'imboscata c\'è l\'imbarazzo della scelta.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10024] = {n:"Vecchio Libro Magico Bwork",t:24,d:"È il Vecchio Libro Magico di un Bwork delle caverne, il che significa che le illustrazioni che contiene sono difficilmente comprensibili per un Bwork Mago delle caverne moderne e ancora di più per un Bwork Mago standard. Non resta che sperare che Danathor trovi un modo d\'utilizzarlo. Se no sarebbe un peccato aver fatto tanta fatica, non credi?",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10025] = {n:"Febbre da Glutoberg",t:30,d:"Eri stato avvisato: l\'abuso di Glutoberg nuoce gravemente alla salute.",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10026] = {n:"Ricetta dell\'Insalace di Mare",t:24,d:"Gropinson Crulué ha scritto la Ricetta dell\'Insalace di Mare sulla sabbia della spiaggia e tu l\'hai ricopiata su questo pezzo di carta.\n- Un Pescivendolo (metterlo nel piatto è opzionale).\n- 2 * Branzino Rikano.\n- 3 * Bastoncino di Granchio ***.\n- 2 * Limone.\n- 4 * Foglia di Insalace.\n- 1 * Vertgely (questo è il tuo tocco personale).",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10028] = {n:"Ricetta del Tessuto di Rattoppo",t:24,d:"Questa Ricetta è stata messa a punto dal Sarto Sosh per rattoppare i Vestiti Magici. I Sarti esperti possono utilizzarla per creare un Tessuto che resista al tempo e alle intemperie. (Azione\' Cucire un Mantello\')\n-5 * Pelo di Barba di Bwork Mago.\n-5 * Pelo di Black Tiwabbit.\n-3 * Pelo di Barba del Nonno Wabbit.\n-3 * Pelo du Milibuulupo.\n-1 * Filo di Seta.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10029] = {n:"Ricetta della Tintura Arancio Sanguigno",t:24,d:"Questa Ricetta è stata messa a punto dal celebre Alchimista Uba Tessé. Nessuno l\'hai mai utilizzata perché Uba Tessé l\'aveva dimenticata dal suo amico Sosh che te l\'ha generosamente donata.\n-1 * Tintura Magica di Rossore.\n-1 * Tintura Magica Arancione.\n-10 * Sangue di Pappatutto.\n-5 * Sardina Brillante.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10030] = {n:"Tessuto di Rattoppo",t:55,d:"Questo Tessuto di sintesi, inventato dal Sarto Sosh, permette di rattoppare i Vestiti Magici senza alterare i loro poteri. Ora si capisce perché i Sarti esperti lo apprezzino così tanto.",ep:0,g:434,l:1,wd:false,fm:true,w:1,p:1};
I.u[10031] = {n:"Tintura Arancio Sanguigno",t:70,d:"Questa Tintura magica inventata da Uba Tessé è estremamente aggressiva, come se fosse animata da una volontà propria che la spinge a fare del male. Si pone allora il problema di sapere perché è così cattiva.",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
I.u[10032] = {n:"Bandana Rattoppata",t:24,d:"Questa Bandana è in condizioni ben migliori rispetto a quando è stata scoperta. Puzza un po\' di meno di Cawota e un po\' di più di pesce, segno che assomiglia sempre di più a quello che era un tempo. Garutar dovrebbe apprezzare il fatto di recuperarla in un così buono stato.",ep:0,g:749,l:1,wd:false,fm:true,w:0,p:1};
I.u[10033] = {n:"Ordine di Missione",t:24,d:"Questo Ordine di Missione firmato da Fraka Kyper indica ai Brakmariani che devono consegnare i Documenti a Sesi Ves, in servizio ai piedi della Torre degli Ordini di Brakmar.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10034] = {n:"Lista del Mago Ax",t:24,d:"Lista degli Oggetti da portare per il Rituale di Rivelazione:\n-5 * Pozioni di Pioggerellina.\n-10 * Acqua.\n-10 * Semi di Panzucca.\n-4 * Polveri di Perlinpanpan.\n-2 * Legni di Carpine.\n-4 * Pozioni di Corrente d\'Aria.\n-2 * Persone di Fiducia.\n-NIENTE Zolfo con sé.",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10035] = {n:"Risultato della Rivelazione",t:24,d:"Su questa pergamena il Mago Ax ha scritto il risultato del Rituale di Rivelazione. Per utilizzare il Corno Davola, basta togliere il tappo e berne il contenuto.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10036] = {n:"Fata lanciatrice di Artiglio Giocoso",t:74,d:"Quando viveva nella Torre Infermaschio, Mylaise aveva ordinato ad un famoso artigiano numerose fate d\'artificio per animare le sue feste. Ancora oggi, a volte, quando è di buon umore, ne distribuisce.",ep:0,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:1};
