I.u[10054] = {n:"Anello del Vampyro",t:9,d:"Quest\'anello è stato immerso per tre anni nello sterco di pipistrello. Ma è magico.",ep:0,g:171,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4703};
I.u[10055] = {n:"Amuleto del Vampyro",t:1,d:"Questo amuleto dovrebbe avvertire i Vampyri intenzionati a morderti sul collo che è semplicemente inutile provare a succhiarti il sangue perché anche tu sei un Vampyro.",ep:0,g:146,l:45,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:5500};
I.u[10056] = {n:"Cintura del Vampyro",t:10,d:"Sullo slogan pubblicitario di questa cintura puoi leggere \"E in più brilla di notte!\". D\'accordo, ma in più di cosa?",ep:0,g:156,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4805};
I.u[10057] = {n:"Runa di caccia",t:78,d:"Ricordati quello che diceva il famoso Mr. Forest: \"Allora, un cattivo Cacciatore ha un arco... vede una cosa che si muove e tira! E un buon Cacciatore, anche lui ha un arco, vede una cosa, tira, ma... è un buon Cacciatore...\". Potrai verificarlo con qualsiasi tua arma grazie a questa runa.",ep:0,g:60,l:10,wd:false,fm:true,w:1,p:10};
I.u[10058] = {n:"Mantello del Vampyro",t:17,d:"Bram aveva ragione, bisogna sempre diffidare dei personaggi dai denti lunghi, soprattutto quando portano il mantello da Vampyro.",ep:0,g:168,l:41,wd:true,fm:true,w:5,c:"PO!10119",s:130,p:4550};
