I.u[9785] = {n:"Shushu di Rushu",t:18,d:"Questo demone minore ti accompagnerà nel corso di tutte le tue peregrinazioni, dallo Zaap di Astrub al cimitero, forse persino dal cimitero allo Zaap di Astrub. Questa creatura è animata da un odio viscerale contro i Cenci. Sembra una triste storia di coppia... Beh, tu attacca i Cenci e lei si nutrirà dei loro resti.",ep:0,g:52,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9786] = {n:"Fantasma di Shushu di Rushu",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:49,l:1,wd:true,fm:true,w:1,p:1};
I.u[9787] = {n:"Frammento d\'intelligenza minore",t:115,d:"Questo frammento d\'anima proviene da un Shushu di Rushu. Se possiedi un\'arma Shushetta puoi usare questo frammento per renderla più potente. Se la tua arma Shushetta supera il suo potenziale massimo, le rune saranno ritirate tutte e messe nel tuo inventario. \n(Doppio clic per mettere questo frammento d\'anima su un\'arma Shushetta attrezzata)",ep:0,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
