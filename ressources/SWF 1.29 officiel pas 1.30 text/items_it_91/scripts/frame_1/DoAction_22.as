I.u[9653] = {n:"Kaskwetta",t:16,d:"Le ali cucite su questo Cappello proteggono le tue orecchie dalle ingiurie, ma solo da quelle che proferisci tu.",ep:0,g:237,l:42,wd:true,fm:true,w:10,s:140,p:4825};
I.u[9654] = {n:"Mantello Loha",t:17,d:"Questo mantello valorizzerà le curve del tuo posteriore o quelle della tua schiena gobba.",ep:0,g:165,l:48,wd:true,fm:true,w:10,s:129,p:6105};
I.u[9655] = {n:"Sandali Loha",t:11,d:"La suola di questi sandali è rinforzata per sopportare il peso dei Loha più corpulenti.",ep:0,g:132,l:49,wd:true,fm:true,w:10,s:129,p:6475};
I.u[9656] = {n:"Le Slumpette",t:11,d:"Le rotelle presenti su questi Stivali permettono di scendere le scale senza sforzi, pur aumentando notevolmente le possibilità di romperti le ossa. A te la scelta.",ep:0,g:133,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9657] = {n:"Pupùstone",t:4,d:"Chi ha osato affibbiare un nome così ridicolo a questo Bastone? Nessuno lo saprà mai, ma dovrai continuare a chiamarlo così e ad avere un aspetto ridicolo quando ti si chiederà il nome del tuo Bastone.",ep:0,g:82,l:42,wd:true,fm:true,w:10,an:12,e:[1,3,1,1,10,40,false,false],c:"CV>60&CW>30",s:140,p:4200};
I.u[9658] = {n:"Amuleto Loha",t:1,d:"Questo amuleto in realtà è solo un assortimento di fiori attaccati ad un filo. Dovrebbe diffondere un profumo magico capace di trasformare un Loha in Lohaiano.",ep:0,g:144,l:47,wd:true,fm:true,w:10,s:129,p:6000};
I.u[9659] = {n:"Collana Slump",t:1,d:"Erala ha portato questo Amuleto durante tutta la sua infanzia. Nessuno sa precisamente cosa rinchiuda.",ep:0,g:143,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9660] = {n:"Mantello di Slait",t:17,d:"Due code per una sola persona. Un sogno diventato realtà.",ep:0,g:166,l:47,wd:true,fm:true,w:10,s:128,p:5825};
