I.u[10052] = {n:"Pozione d\'oblio: \"Lazo Spirituale\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo degli Osamodas: \"Lazo Spirituale\".",ep:0,g:31,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
