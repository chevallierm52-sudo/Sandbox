I.u[10073] = {n:"Scudo Ispanico",t:82,d:"Il mitico Dal-Uk-Wet, unificatore dei regni d\'IspaÑia, aveva uno Scudo Magico. Il suo pronipote, Sir-Dal, ne fece fabbricare qualche riproduzione per ricompensare i migliori guerrieri d\'IspaÑia. Questo Scudo è una di queste rare copie.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[10074] = {n:"Lettera del capo dei ladri",t:24,d:"Ritrovata in occasione del combattimento contro i ladri da Milon:\n\"Milon Corichel l\'Orefice ha appena creato un gioiello di valore inestimabile. Impadroniscitene ad ogni costo\".\nPer fortuna Milon ha dato loro un falso e non per merito tuo.\nInvece, sul retro del messaggio si trova la posizione del loro covo. S\'impone una rivincita, ma è meglio andarci accompagnati.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10075] = {n:"Poltiglia disgustosa",t:24,d:"Questa poltiglia disgustosa è apparsa come per magia nella tua tasca.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[10076] = {n:"Scudo Ispanico Unico",t:82,d:"Il mitico Dal-Uk-Wet, unificatore del regno d\'IspaÑia, concentrava tutto il suo potere nello Scudo, a tutto danno dei suoi avversari. Molti anni dopo, Sir-Dal, il suo pronipote, ne fece fabbricare qualche riproduzione per ricompensare i migliori guerrieri d\'IspaÑia, ma questo è l\'originale, l\'unico, il più potente di tutti!",ep:0,g:40,l:1,wd:false,fm:true,w:30,c:"PP>9",p:63200};
I.u[10077] = {n:"Terra Cogita",t:32,d:"Devi scortare Terra Cogita in diversi luoghi prima di presentarlo a Mel Aghignavon.",ep:0,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10078] = {n:"Eni Hoob",t:32,d:"Devi scortare e proteggere Eni Hoob. Da quando ti accompagna, sembra che il destino s\'accanisca contro di te.",ep:0,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10079] = {n:"Pane Trepido",t:33,d:"Molto apprezzato dagli Yop, questo pane rende sia coraggiosi che temerari, il che ha già causato la morte prematura di numerosi avventurieri. Xavier il Panettiere smise di prepararne quando un\'intera compagnia di trovatori caricò un gruppo di Buulupi rabbiosi.",ep:0,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[10080] = {n:"Messaggio dei Rinnegati",t:24,d:"Questo messaggio dà appuntamento ai Rinnegati vicino al Dongione dei Scarafoglie. Dovresti andarci per saperne di più.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10081] = {n:"Messaggio del Capo dei Rinnegati",t:24,d:"In questo messaggio, il Capo dei Rinnegati chiede loro di raggiungerlo a sud del territorio dei banditi. Per te è l\'occasione per eliminare questo traditore.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10082] = {n:"Cocktail Moritov",t:24,d:"Cosa si ottiene spremendo un Petalo Mojito? Della Linfa Alcolica a base di numerosi cocktail con cui i Discepoli d\'Otomai si dilettano durante le loro feste estive. In effetti questo cocktail esplosivo saprà mettere il fuoco alle tue feste, sia in senso reale che in quello figurato.",ep:0,g:762,l:1,wd:false,fm:true,w:0,p:1};
I.u[10083] = {n:"Insalace di Mare",t:49,d:"Come dice il detto: un odore può nasconderne un altro. In effetti il profumo che si sprigiona da questa Insalace di Mare cela una grande puzza di piedi. Da non consumare in presenza di Porkass in fregola, a meno che tu non sia una maialina.",ep:0,g:80,l:1,wd:false,fm:true,w:3,u:true,ut:true,p:1};
I.u[10084] = {n:"Fischietto di chiamata",t:24,d:"Questo fischietto, concepito secondo il metodo d\'allevamento canino di Riyu Tchevlakuk, permette di chiamare i Canin Blandi domati. Tuttavia non permette di farsi passare per il Maestro di un Canin Blando che non ti appartiene. Funziona anche con i Canin Blandi selvaggi.",ep:0,g:755,l:1,wd:false,fm:true,w:0,p:1};
I.u[10085] = {n:"Ordine d\'esecuzione",t:87,d:"Gli ordini sono chiari e netti, non come le mutande del Minotot. Trova e abbatti il bersaglio designato.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:0};
I.u[10086] = {n:"Canino di bandito delle pianure",t:24,d:"La violenza del combattimento contro i banditi delle pianure era tale che uno di loro ha perso un canino.",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:1};
I.u[10087] = {n:"Appuntamento di Xarthan",t:24,d:"Questo foglio scritto da un brakmariano dà appuntamento a Xarthan nella Torre di Bonta dopo la sua prossima riunione. Ciò significa che l\'appuntamento è forse già in corso.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10088] = {n:"Fazzoletto consumato",t:24,d:"Hai raccolto questo fazzoletto durante il tuo combattimento contro Xefires. È un ricordino utile e gradevole, soprattutto se hai il naso tappato o se sei allergico ai peli di maomao.",ep:0,g:756,l:1,wd:false,fm:true,w:0,p:1};
