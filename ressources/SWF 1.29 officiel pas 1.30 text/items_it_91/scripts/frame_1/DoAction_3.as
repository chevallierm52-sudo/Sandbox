I.u[963] = {n:"Chiave Wabbit",t:24,d:"Una delle tre chiavi che permettono di entrare nel castello dei Wabbit.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Pietra di Dabol",t:50,d:"Questa pietra viene dal mondo dei Dabol. Ha un grande valore per alcuni abitanti di Amakna.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Manuale del Sarto",t:25,d:"(Doppio clic per il imparare il mestiere di Sarto)\nQuesto manuale del Sarto ti permette di imparare le basi del mestiere. Per coloro che hanno poca immaginazione, il manuale offre nelle prime pagine dei modelli da ritagliare.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Mantello Folgorante",t:17,d:"Questo magnifico mantello aumenta i punti azione di chi lo porta. Ne aumenta anche la Vitalità e la Saggezza.",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
I.u[968] = {n:"Cintura Folgorante",t:10,d:"Questa magnifica cintura aumenta i punti azione di chi la porta. Aumenta anche la Vitalità e la Saggezza.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Corona del We Wabbit",t:16,d:"Questa magnifica corona è appartenuta al tristemente celebre We Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Bastone del We Wabbit",t:4,d:"Questo bastone apparteneva al tristemente celebre We Wabbit.",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Mantello del We Wabbit",t:17,d:"Questo mantello apparteneva al tristemente celebre We Wabbit. È ancora impregnato del suo sudore, cosa che ti permetterà di ricordare quel magnifico combattimento ogni volta che lo indosserai.",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Dofus Cawota",t:23,d:"Il Dofus Cawota aumenta la Saggezza di chi lo porta.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Zampa di Araknella",t:24,d:"Una zampa molto fine, ma molto pelosa. I migliori Alchimisti riescono a creare potenti veleni con il succo estratto da questa zampa.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Testa del Contadino Depresso",t:24,d:"Quello che doveva accadere è accaduto, il Contadino Depresso ha perso la testa.",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Canino del Vampiro Prigioniero",t:24,d:"Questo dente molto appuntito è di un Vampiro. Possederlo o portarlo al collo ti permetterà di impressionare i tuoi amici facendo credere di essere un Cacciatore di Vampiri.",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Cucuwbita",t:16,d:"La cucuwbita ha la peculiarità di impedire la dispersione delle particelle magiche, il che ne fa un buonissimo isolante magico. È proprio per questo motivo che molti guerrieri usano questo legume come elmo.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Shigekax Limone",t:42,d:"Ritrova il sapore e il fascino delle golosità di un tempo... con questa caramella alla banana preparata in modo tradizionale.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Shigekax Fragola",t:42,d:"Ritrova il sapore e il fascino delle ghiottonerie di un tempo... con questa caramella alla fragola preparata in modo tradizionale.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Shigekax Menta",t:42,d:"Ritrova il sapore e il fascino delle golosità di un tempo... con questa caramella alla menta preparata in modo tradizionale.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Shigekax Ciliegia",t:42,d:"Ritrova il sapore e il fascino delle golosità di un tempo... con questa caramella alla banana preparata in modo tradizionale.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Vertgely",t:42,d:"Anche se ha disgustato più di un vegetariano, questo piatto a base di gelatina verde resta una delle specialità di Amakna.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Rougely",t:42,d:"Preparato a base di gelatina fragola, questo piatto ha disgustato più di un vegetariano, ma resta comunque una delle specialità di Amakna.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Blugely",t:42,d:"Anche se ha disgustato più di un vegetariano, questo piatto a base di gelatina celeste resta una delle specialità di Amakna.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multigely",t:42,d:"La multigely è vietata alla vendita, perché provoca la scomparsa di numerosi bambini.\nPare che provochi terribili incubi alla persona che la mangia.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[997] = {n:"Noce di Kokoko",t:46,d:"Rotonda come una palla di cannone, questa noce ha tre buchi che la rendono molto pratica da sollevare e lanciare lontano.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Calzone Carino del Capitano Pirata",t:15,d:"Il calzone del Capitano Pirata è la testimonianza che anche il ridicolo può uccidere ogni tanto. Ma sembra che almeno porti fortuna.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Tela poco invitante",t:55,d:"Anche se viscido e puzzolente, questo gran tessuto conserva una certa qualità. Peccato che sia bucato.",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Botte Vuota",t:15,d:"Questa grossa botte è vuota da moltissimo tempo, ma si può comunque indovinare ciò che ha contenuto fino adesso: rum, kama, pirati ubriachi... un po\' di tutto insomma, ma mai dell\'acqua.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Tavola in legno di Kokoko",t:95,d:"Futuro frammento di barca? Futuro pavimento di casa? In ogni modo, per il momento si tratta solo di una tavola come un\'altra.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"Tronco di Kokoko",t:38,d:"Il tronco di Kokoko è dritto e solido come tutti gli altri, ma un po\' più fine della media.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Trave di legno di Kokoko",t:38,d:"Una trave di legno solida da non mettere nell\'occhio.",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Corda indispensabile",t:15,d:"Tutti gli avventurieri sanno che bisogna sempre avere con sé una corda come questa... Eppure, nessuno ce l\'ha.",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Ricevuta per la zattera",t:24,d:"Una ricevuta firmata da Kib Roche, sulla quale è scritto che la tua zattera sarà pronta tra un po\'.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Cappello Pirata",t:24,d:"Forma imponente, simbolo di morte ricamato sul davanti, ornato di pelliccia, questo cappello da pirata è un classico per i capitani.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Uncino",t:24,d:"Si tratta di un accessorio indispensabile ai pirati sfortunati, questo gancio infatti sostituisce in tutto e per tutto una mano. Inoltre il colore gli dà anche un aspetto abbastanza chic.",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Mascella cadente",t:24,d:"Questa mascella che sembra una collana è sicuramente il risultato del momento di rabbia di un capitano nei confronti di un mozzo che aveva sghignazzato troppo dopo aver visto le mutande del capo.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Teschio di pirata",t:24,d:"Questo cranio rivestito da una benda mostra alla perfezione che un pirata, anche se morto, può ancora vergognarsi di essere calvo.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Carapace Verde",t:24,d:"Si tratta del carapace di una tartaruga pazza che pensava di essere un ninja.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1011] = {n:"Carapace Giallo",t:24,d:"Si tratta del carapace di una tartaruga pazza che sicuramente ha fatto uso eccessivo di sostanze pericolose.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Carapace Rosso",t:24,d:"Si tratta del carapace di una tartaruga pazza che mangiava dei pomodori e del formaggio su del pane caldo.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Carapace Blu",t:24,d:"Si tratta del carapace di una tartaruga pazza che voleva imitare Zowwo, la volpe maschewata.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Maschera Verde",t:24,d:"Maschera da Kannibul sorridente, del colore della Verdura, elemento di contorno della carne.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Maschera Gialla",t:24,d:"Maschera da Kannibul piangente, del colore della Folgore, elemento che spaventa spesso la carne fresca.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Maschera Rossa",t:24,d:"Maschera da Kannibul arrabbiato, del colore del Fuoco, elemento importante per cucinare la carne.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Maschera Blu",t:24,d:"Maschera da Kannibul sorpreso, del colore dell\'Acqua, elemento dissetante tra due bocconi di carne.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Kolla",t:15,d:"Questo vasetto di gelatina rosa dal buon profumo non deve assolutamente essere mangiato. Questa gelatina è così appiccicosa che rischieresti di non poter più parlare.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Elmo",t:16,d:"Indossare questo elmo vuol dire adottare un look unico... a metà strada tra il ridicolo e il comico.",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Elmo rotto",t:15,d:"Questo elmo ha salvato la tua vita, ma non è riuscito a salvare la sua.",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Ali di Legno",t:17,d:"Messaggio indirizzato a tutti coloro che sognano di volare come un Kwak: tornate a dormire! Queste ali non faranno altro che farvi diventare uno stupido pericolo pubblico.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Ali rotte",t:104,d:"Queste ali rotte continuano a ricordarti che avresti veramente dovuto rimetterti a letto.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Bottiglia di rum",t:15,d:"L\'etichetta dice \"rum invecchiato 10 anni\", ma è un\'informazione impossibile da verificare. Una nota precisa anche di non abusarne sulla strada per non avere il mal di mare...",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
I.u[1026] = {n:"Piccolo Coltello di Stek",t:5,d:"Questi coltelli strani e temibili sono stati ordinati dall\'illustre Stek Aifer. Nessuno ne conosceva l\'utilità fin quando non tentò di offrire da mangiare al suo dio.",ep:1,g:13,l:32,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>32&CS>10",p:3000};
I.u[1027] = {n:"Coltello di Stek",t:5,d:"Questi coltelli strani e temibili sono stati ordinati dall\'illustre Stek Aifer. Nessuno ne conosceva l\'utilità fin quando non tentò di offrire da mangiare al suo dio.",ep:1,g:13,l:35,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>35&CS>12",p:3400};
I.u[1028] = {n:"Grande Coltello di Stek",t:5,d:"Questi coltelli strani e temibili sono stati ordinati dall\'illustre pazzo Stek Aifer. Nessuno ne conosceva l\'utilità fin quando non tentò di offrire da mangiare al suo dio.",ep:1,g:13,l:38,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>38&CS>14",p:3800};
I.u[1029] = {n:"Coltello Largo di Stek",t:5,d:"Questi coltelli strani e temibili sono stati ordinati dall\'illustre Stek Aifer. Nessuno ne conosceva l\'utilità fin quando non tentò di offrire da mangiare al suo dio.",ep:1,g:13,l:41,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>41&CS>16",p:4000};
I.u[1030] = {n:"Code di Micetto",t:5,d:"Questo paio di daghe è in realtà un giocattolo magico creato per divertire i giovani Ecaflip. La sua produzione fu vietata dopo che un bimbo Etram prese parte ai giochi.",ep:14,g:20,l:25,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>40&CS>20&CV>20",p:1800};
I.u[1031] = {n:"Daghe Crudeli d\'Elory Entuwan",t:5,d:"Queste magnifiche daghe sono appartenute all\'Etramina più crudele che Ankama abbia mai conosciuto. O meglio, una delle più crudeli... solo un pochino più delle altre... come le altre insomma. Ma già è abbastanza... fidati!",ep:1,g:7,l:40,wd:true,fm:true,w:1,an:13,e:[12,3,1,1,30,50,false,false],c:"CA>40",p:4000};
I.u[1032] = {n:"Piccola Lama di Fon",t:5,d:"Tempo fa questa lama era usata dalla confraternita segreta di Fon. Questa gilda voleva far sprofondare Amakna nel caos. Fortunatamente affondò subito quando l\'isola su cui si trovava fu sommersa dai flutti.",ep:1,g:14,l:44,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>44&CC>5",p:5000};
I.u[1033] = {n:"Lama di Fon",t:5,d:"Tempo fa questa lama era usata dalla confraternita segreta di Fon. Questa gilda voleva far sprofondare Amakna nel caos. Fortunatamente affondò subito quando l\'isola su cui si trovava fu sommersa dai flutti.",ep:1,g:14,l:48,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>48&CC>8",p:5500};
I.u[1034] = {n:"Grande Lama di Fon",t:5,d:"Tempo fa questa lama era usata dalla confraternita segreta di Fon. Questa gilda voleva far sprofondare Amakna nel caos. Fortunatamente affondò subito quando l\'isola su cui si trovava fu sommersa dai flutti.",ep:1,g:14,l:52,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>52&CC>10",p:6000};
I.u[1035] = {n:"Potente Lama di Fon",t:5,d:"Tempo fa questa lama era usata dalla confraternita segreta di Fon. Questa gilda voleva far sprofondare Amakna nel caos. Fortunatamente affondò subito quando l\'isola su cui si trovava fu sommersa dai flutti.",ep:1,g:14,l:56,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>56&CC>12",p:6500};
I.u[1036] = {n:"Piccola Daga Ingannatrice",t:5,d:"Questa daga Etram possiede una forma particolarmente ingannatrice. Così ingannatrice che non sembra neanche una daga. Ma quando lo si capisce... è spesso troppo tardi!",ep:7,g:11,l:53,wd:true,fm:true,w:1,e:[14,3,1,1,30,50,false,false],c:"CA>53&CS>18",p:7000};
I.u[1037] = {n:"Daga Ingannatrice",t:5,d:"Questa daga Etram possiede una forma particolarmente ingannatrice. Così ingannatrice che non sembra neanche una daga. Ma quando lo si capisce... è spesso troppo tardi!",ep:7,g:11,l:58,wd:true,fm:true,w:10,e:[15,3,1,1,30,50,false,false],c:"CA>58&CS>20",p:7500};
I.u[1038] = {n:"Superba Daga Ingannatrice",t:5,d:"Questa daga Etram possiede una forma particolarmente ingannatrice. Così ingannatrice che non sembra neanche una daga. Ma quando lo si capisce... è spesso troppo tardi!",ep:7,g:11,l:63,wd:true,fm:true,w:10,an:13,e:[16,3,1,1,30,50,false,false],c:"CA>63&CS>22",p:8000};
I.u[1039] = {n:"Ipnotica Daga Ingannatrice",t:5,d:"Questa daga Etram possiede una forma particolarmente ingannatrice. Così ingannatrice che non sembra neanche una daga. Ma quando lo si capisce... è spesso troppo tardi!",ep:7,g:11,l:67,wd:true,fm:true,w:10,an:13,e:[17,3,1,1,30,50,false,false],c:"CA>67&CS>25",p:8500};
I.u[1040] = {n:"Lame Sanguinarie di Ortimus Contrari",t:5,d:"Ortimus Contrari è l\'idolo degli assassini. Onora sempre i suoi contratti in modo completamente anticonformista. Non essere troppo curioso al riguardo, potresti morire subito!",ep:9,g:19,l:80,wd:true,fm:true,w:15,an:13,e:[15,3,1,1,20,50,false,false],c:"CA>79&CS>40",p:10000};
I.u[1041] = {n:"Spada Rotta del Cavaliere Sfortunato",t:5,d:"Questa spada fu data a Suzé Schel, un giovane Yop, per la sua vestizione. Sfortunatamente, durante la sua prima missione da cavaliere, scivolò su una grossa pietra... niente meno che un Croccaroc!",ep:1,g:43,l:35,wd:true,fm:true,w:20,an:13,e:[5,5,1,1,30,50,false,false],c:"CS>20",p:3000};
I.u[1042] = {n:"Piccola Pala di Legno Addormentato",t:8,d:"Questa pala è fatta con un legno molto raro. Secondo la leggenda, tutte le ragazze che entrano in contatto con questa pala cadono in un sonno eterno. Attenzione: in caso di contatto ripetuto, l\'effetto si applica a chiunque.",ep:1,g:20,l:34,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>26",p:3200};
I.u[1043] = {n:"Pala di Legno Addormentato",t:8,d:"Questa pala è fatta con un legno molto raro. Secondo la leggenda, tutte le ragazze che entrano in contatto con questa pala cadono in un sonno eterno. Attenzione: in caso di contatto ripetuto, l\'effetto si applica a chiunque.",ep:1,g:20,l:37,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>27",p:3400};
I.u[1044] = {n:"Grande Pala di Legno Addormentato",t:8,d:"Questa pala è fatta con un legno molto raro. Secondo la leggenda, tutte le ragazze che entrano in contatto con questa pala cadono in un sonno eterno. Attenzione: in caso di contatto ripetuto, l\'effetto si applica a chiunque.",ep:1,g:20,l:40,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>28",p:3600};
I.u[1045] = {n:"Magnifica Pala di Legno Addormentato",t:8,d:"Questa pala è fatta con un legno molto raro. Secondo la leggenda, tutte le ragazze che entrano in contatto con questa pala cadono in un sonno eterno. Attenzione: in caso di contatto ripetuto, l\'effetto si applica a chiunque.",ep:1,g:20,l:43,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>30",p:3800};
I.u[1046] = {n:"Piccola Pala \'Nrifusa",t:8,d:"Cosa c\'è di meglio di una pala ecologica per sradicare le erbacce? Questa pala è LA risposta, potrai facilmente strappare dei dente di leone e farli mangiare ai tuoi nemici, cominciando dalla radice!",ep:1,g:18,l:38,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CS>10&CC>28",p:4000};
I.u[1047] = {n:"Pala",t:8,d:"Cosa c\'è di meglio di una pala ecologica per sradicare le erbacce? Questa pala è LA risposta, potrai facilmente strappare dei dente di leone e farli mangiare ai tuoi nemici, cominciando dalla radice!",ep:1,g:18,l:42,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CS>11&CC>31",p:4200};
