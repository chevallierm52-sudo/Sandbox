I.u[1399] = {n:"Mazza Kiodo",t:7,d:"Proprio come l\'amuleto che porta lo stesso nome, la Mazza Kiodo ha la capacità di trasformare la tua energia vitale in potenza. Da consumare con moderazione...",ep:1,g:12,l:15,wd:true,fm:true,w:15,an:15,e:[5,5,1,1,40,40,false,true],p:1500};
