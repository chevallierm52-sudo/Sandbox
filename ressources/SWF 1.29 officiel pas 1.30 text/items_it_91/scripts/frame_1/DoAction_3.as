I.u[1085] = {n:"Martello dei Falisti",t:7,d:"I Falisti sono demoni Xelor che hanno rinnegato i vecchi principi, hanno sviluppato la loro forza forgiando martelli sempre più potenti. Dopo aver portato il caos, vennero vinti e spediti sotto terra. Ma qualche arma rimase nel Mondo.",ep:9,g:19,l:79,wd:true,fm:true,w:70,an:15,tw:true,e:[15,7,1,1,50,25,false,false],c:"CS>79",p:10000};
