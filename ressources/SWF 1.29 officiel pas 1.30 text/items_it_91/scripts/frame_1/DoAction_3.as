I.u[1383] = {n:"Martello Re\'Thu",t:7,d:"Per fabbricare questo martello ci sono voluti anni e anni, nonché decine di Forgiatori. Il risultato è un\'arma splendida, ma che ha sfortunatamente ereditato dai suoi creatori una strana idea della velocità.",ep:1,g:5,l:55,wd:true,fm:true,w:20,an:15,tw:true,e:[8,4,1,1,50,50,false,false],p:8000};
