I.u[1403] = {n:"Martello Tau",t:7,d:"Questo martello è appartenuto a Tau, un giovane discepolo di Osamodas che passava il tempo raccontando barzellette stupide. Il suo martello, proprio come lui, non rende molto intelligenti, però riesce a calmare l\'ambiente...",ep:1,g:3,l:23,wd:true,fm:true,w:20,an:15,e:[4,4,1,1,30,30,false,true],c:"CA>20",p:1700};
I.u[1404] = {n:"Martello Toh\'Lo",t:7,d:"Ami gli animali? Anche Toh\'Lo. Aveva dedicato loro la sua vita. Questo martello racconta un po\' la sua storia: una grande comunione con le bestie...",ep:5,g:15,l:35,wd:true,fm:true,w:35,an:15,e:[6,4,1,1,30,30,false,true],c:"CI>80&CW>30",p:3400};
I.u[1405] = {n:"Pozione Acqua di Fata",t:12,d:"Questa pozione riproduce gli stessi poteri di guarigione del sangue Aniripsa, e finalmente non ci sarà più bisogno di dissanguarli.",ep:3,g:41,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1406] = {n:"Sangue di Likrone",t:12,d:"Questa pozione riproduce gli effetti del sangue di Likrone, tranne l\'immortalità. \"Bevila e guarirai da tutti i mali\" diceva il celebre slogan.",ep:3,g:40,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
