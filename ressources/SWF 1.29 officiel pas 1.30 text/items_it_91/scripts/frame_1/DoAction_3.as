I.u[1393] = {n:"Il Martonomo",t:7,d:"Questo martello è stato fabbricato da un famoso orologio: quello ingoiato dal Coccodrail che ha divorato la mano di Capitan Spiedino. Anche se si è riusciti a recuperare l\'orologio, della mano non si sa niente...",ep:5,g:21,l:54,wd:true,fm:true,w:20,an:15,e:[8,6,1,1,40,40,false,true],c:"CI>62&CW>22",p:9700};
