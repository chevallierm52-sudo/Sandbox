I.u[1324] = {n:"Erba Felina",t:36,d:"Questa pianta fa venire l\'acquolina in bocca a qualsiasi Ecaflip.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1325] = {n:"Guscio di Noce",t:46,d:"Questo guscio, solido di natura, resiste ad ogni tipo di aggressione e rappresenta bene l\'ideologia Feca.",ep:2,g:52,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1326] = {n:"Selce Insanguinata",t:51,d:"Questa pietra tanto resistente quanto tagliente sembra essere stata utilizzata contro qualcosa o qualcuno. Il suo aspetto grezzo e pericoloso dà perfettamente l\'idea di uno Yop.",ep:2,g:47,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1327] = {n:"Osso intagliato",t:47,d:"Se ben lavorato quest\'oggetto di morte diventa temibilissimo, proprio come un Etram.",ep:2,g:48,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1328] = {n:"Kama Enigmatico",t:15,d:"Questo kama è ornato di una testa di tofu con uno strano cappello.",ep:1,g:182,l:1,wd:true,fm:true,w:10,p:1};
I.u[1329] = {n:"Legno elastico",t:38,d:"Questo grande ramo di legno fa subito pensare agli Ocra per la sua elasticità e la sua forma curva.",ep:2,g:49,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1330] = {n:"Amuleto Itby",t:1,d:"Creazione originale dell\'Orefice John Le Nonn, oggi è uno dei gioielli più classici.",ep:1,g:31,l:10,wd:true,fm:true,w:5,p:500};
I.u[1331] = {n:"Medaglia Oly",t:1,d:"Oly era una discepola di Yop il cui unico talento era la cucina. Si dice che fu Yop in persona a darle questa medaglia, per compensare le sue debolezze in combattimento. Solo i cuori puri possono portarla.",ep:7,g:23,l:51,wd:true,fm:true,w:10,c:"Ps=1&Pa>10",p:7000};
I.u[1332] = {n:"Vecchio Trifoglio a 4 foglie",t:36,d:"I trifogli a quattro foglie sono più rari di quelli a cinque foglie. Quando ne trovi uno ti consigliamo di farlo seccare tra due pergamene di incantesimo.",ep:2,g:50,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1333] = {n:"Pozione di Scintilla",t:26,d:"Questa pozione scaldante, grazie alla debole magia di fuoco che racchiude, è in genere usata per incantare ogni tipo di oggetto.",ep:3,g:1,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1334] = {n:"Scherzo di Zolfo",t:48,d:"Questo piccolo sacchetto pieno di zolfo emana un odore insopportabile... proprio lo stesso degli Osamodas.",ep:2,g:51,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1335] = {n:"Pozione di Pioggerellina",t:26,d:"Questa pozione frizzantina, grazie alla debole magia d\'acqua che racchiude, è in genere usata per incantare ogni tipo di oggetto.",ep:3,g:2,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1336] = {n:"Ortiche",t:36,d:"Strofinando in maniera decisa questa pianta contro la tua pelle, soffrirai come un martire. Eppure lo stimolo provocato sembra essere benefico, o almeno secondo la filosofia dei Sàcrido.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1337] = {n:"Pozione di Corrente di Aria",t:26,d:"Questa pozione sospirante, grazie alla debole magia d\'aria che racchiude, è in genere usata per incantare ogni tipo di oggetto.",ep:3,g:3,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1338] = {n:"Pozione di Scossa",t:26,d:"Questa pozione vibrante, grazie alla debole magia di terra che racchiude, è in genere usata per incantare ogni tipo di oggetto.",ep:3,g:4,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1339] = {n:"Campanelle",t:35,d:"Questi fiori di mughetto sono veramente piccolissimi, fragili e graziosi. Si dice inoltre che hanno il potere di calmare lo spirito e di guarire certi mali. Sono stati sicuramente creati da una divinità desiderosa di vedere una pianta ad immagine degli Aniripsa.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1340] = {n:"Pozione di Frana",t:26,d:"Questa pozione tremante, grazie alla magia di terra che racchiude, è in genere usata per incantare correttamente ogni tipo di oggetto.",ep:9,g:4,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1341] = {n:"Pozione di Acquazzone",t:26,d:"Questa pozione sciabordante, grazie alla magia d\'acqua che racchiude, è in genere usata per incantare correttamente ogni tipo di oggetto.",ep:9,g:2,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1342] = {n:"Pozione di Raffica",t:26,d:"Questa pozione fischiante, grazie alla magia d\'aria che racchiude, è in genere usata per incantare correttamente ogni tipo di oggetto.",ep:9,g:3,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1343] = {n:"Pozione di Fiammata",t:26,d:"Questa pozione crepitante, grazie alla magia di fuoco che racchiude, è in genere usata per incantare correttamente ogni tipo di oggetto.",ep:9,g:1,l:25,wd:true,fm:true,w:1,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1344] = {n:"Verbena",t:36,d:"Questa pianta speciale permette di fare dormire chiunque più facilmente. Dev\'essere sicuramente l\'emblema dei Sadida.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1345] = {n:"Pozione d\'Incendio",t:26,d:"Questa pozione fulminante, grazie alla grande magia di fuoco che racchiude, è in genere usata per incantare potentemente ogni tipo di oggetto.",ep:4,g:1,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1346] = {n:"Pozione di Tsunami",t:26,d:"Questa pozione inondante, grazie alla potente magia d\'acqua che racchiude, è in genere usata per incantare potentemente ogni tipo di oggetto.",ep:4,g:2,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1347] = {n:"Pozione di Uragano",t:26,d:"Questa pozione urlante, grazie alla grande magia d\'aria che racchiude, è in genere usata per incantare potentemente ogni tipo di oggetto.",ep:4,g:3,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1348] = {n:"Pozione di Sisma",t:26,d:"Questa pozione distruttrice, grazie alla grande magia di terra che racchiude, è in genere usata per incantare potentemente ogni tipo di oggetto.",ep:4,g:4,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1350] = {n:"Arco Holico",t:2,d:"Questo arco è stato creato da un mago che adorava la sua bottiglia. Per mettere fine a questo problema sentimentale, ha inventato questo arco specializzato in acqua.",ep:3,g:4,l:15,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,3,6,30,50,false,true],p:250};
I.u[1351] = {n:"Arco dello Xueluom",t:2,d:"\"Con un arco, o è così... o è così\", dice il proverbio. I saggi eviteranno questo arco, pare che porti sfortuna...",ep:1,g:51,l:30,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,10,10,false,true],c:"CC>30",p:1600};
I.u[1352] = {n:"Arco di Boo",t:2,d:"Questo arco prende forza dalla terra e dall\'acqua. Sfortunati coloro che non padroneggiano né l\'uno né l\'altro elemento.",ep:2,g:6,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],p:5000};
I.u[1353] = {n:"Arco Invecchiato",t:2,d:"Tempo addietro quest\'arco era il simbolo della lotta del bene contro il male. Ancora oggi, sebbene invecchiato, si può sentire in lui la fiamma degli antichi giustizieri.",ep:12,g:10,l:41,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"Ps=1&Pa>10&CI>30&CW>30",p:200};
I.u[1354] = {n:"L\'Arco d\'Hick",t:2,d:"Hick era un Ocra maledetto: non riusciva mai a sbarazzarsi del suo singhiozzo. Un giorno gettò il suo arco nel fuoco per sostituirlo con una spada e il suo male scomparve magicamente...",ep:13,g:11,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,6,40,40,false,true],p:1000};
I.u[1355] = {n:"Arc Marc Esedsad",t:2,d:"Il creatore di quest\'arco, un certo Marc Esedsad, non ha mai saputo servirsene molto bene. Finiva con infliggere ferite gravissime sia ai suoi nemici che a se stesso.",ep:14,g:12,l:40,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,7,30,50,false,true],p:4000};
I.u[1356] = {n:"Semi-Bacchetta",t:3,d:"Rika Zaruil la Panettiera era conosciuta come l\'Aniripsa più piccola della contrada. Faceva il pane in mezzi forni di cartone e combatteva con mezze bacchette.",ep:1,g:13,l:11,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,30,50,false,true],p:1000};
I.u[1357] = {n:"Dacchetta",t:3,d:"Uno scultore un po\' burlone tentò di far credere che queste bacchette fossero daghe. Il suo stratagemma non ebbe nessun successo, ma le sue bacchette sì... eccome!",ep:7,g:17,l:35,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,40,40,false,true],c:"CI>25",p:3500};
I.u[1359] = {n:"Il Tizzone Furbo",t:3,d:"Le origini di questa Bacchetta restano misteriose.\nTuttavia ha sempre aiutato i suoi felici proprietari ad imboccare la strada meno trafficata di Amakna, il che può essere veramente utile durante i giorni di affluenza nel regno del Pappatutto Reale.",ep:9,g:12,l:59,wd:true,fm:true,w:10,an:11,e:[7,3,2,3,30,50,false,true],c:"CI>70&CS>30",p:5000};
I.u[1360] = {n:"L\'Hyldegard",t:3,d:"Questa bacchetta fu creata molti anni addietro nelle fiamme del Mont Dur. Quest\'arma ha bisogno di avere sempre dell\'acqua vicino a sé per poter controllare il suo fuoco interno...",ep:13,g:8,l:48,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],p:4800};
I.u[1361] = {n:"Bacchetta Sylviana",t:3,d:"La Bacchetta Sylviana ha lo strano potere di conferire una vista eccezionale a chi la usa, che dovrà poi essere abbastanza agile per fuggire il pericolo.",ep:1,g:15,l:43,wd:true,fm:true,w:10,an:11,e:[4,5,2,2,40,40,false,true],c:"CA>80",p:4000};
I.u[1362] = {n:"Paletto Vampiresco",t:3,d:"Il paletto vampiresco era la bacchetta di un vampiro, da molto tempo ritirata dalla vita sociale. Questo strano pezzo di legno ha comunque conservato qualche caratteristica del suo precedente proprietario...",ep:7,g:14,l:65,wd:true,fm:true,w:10,an:11,e:[5,6,2,3,50,20,false,true],c:"CA>30&CW<60",p:4000};
I.u[1363] = {n:"Bastone Tont \'Olone",t:4,d:"Oltre al nome insopportabile, questo bastone ha molti metodi per fare impazzire di rabbia il suo proprietario.",ep:1,g:5,l:40,wd:true,fm:true,w:10,an:12,e:[5,5,1,1,5,5,false,true],c:"CI<100",p:5000};
I.u[1364] = {n:"Bastone di Oblio",t:4,d:"Questo bastone fa dimenticare tutte le preoccupazioni e i cattivi pensieri al proprietario. Sfortunatamente, egli perde anche spesso la memoria e riesce a concentrarsi sempre meno... Riservato unicamente ai saggi...",ep:13,g:11,l:30,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,true],c:"CW>50",p:3000};
I.u[1365] = {n:"La Canna Ta",t:4,d:"Ta era veramente un guerriero fortissimo con il bastone. Era talmente forte che si raccontava che il suo bastone fosse magico e lanciasse delle fiamme.",ep:1,g:68,l:20,wd:true,fm:true,w:15,an:12,e:[8,5,1,1,50,40,false,true],p:2000};
I.u[1366] = {n:"Bastone del Pappandriano",t:4,d:"Questo bastone è usato per la transumanza dai Pappandriani. Ai Bwork piace degustare le greggi di Pappatutto tagliati a fettine fini come aperitivo (il pasto ovviamente è il pappandriano intero!).",ep:9,g:9,l:12,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,true],p:1200};
I.u[1367] = {n:"Bastone di Dina, detta \"la Mythe\"",t:4,d:"Questo bastone è appartenuto alla bellissima Dina \"Mythe\", che era conosciuta soprattutto per le sue forme burrose e il suo carattere esplosivo... Insomma, era proprio una bomba!",ep:13,g:6,l:40,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,30,50,false,true],c:"CI>50&CA>40",p:4000};
I.u[1368] = {n:"La Lancia dei \"110\"",t:4,d:"\"I 110\" è il soprannome dato ai 110 coraggiosi pompieri Amakniani che hanno spento il fuoco di un Draghetto in cerca di sensazioni forti. Questa lancia apparteneva a uno di loro. Per servirsi di tale lancia bisogna essere forti e coraggiosi.",ep:1,g:18,l:29,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,true],c:"CC>10",p:2500};
I.u[1369] = {n:"Le Lame da Tavola",t:5,d:"Questi coltelli dovevano inizialmente essere usati in un ristorante di lusso. Ma il loro look un po\'... strano, ha spinto il proprietario del locale a venderli a un lanciatore di coltelli ambulante.",ep:1,g:13,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>55&CC>5",p:3000};
I.u[1370] = {n:"L\'Ergot Mina",t:5,d:"L\'impugnatura di quest\'arma è unta e scivolosa, ma l\'Ergot Mina ha veramente un bel look.",ep:1,g:14,l:20,wd:true,fm:true,w:10,an:13,e:[8,3,1,1,50,50,false,true],p:2000};
I.u[1371] = {n:"Daghe Eulas",t:5,d:"Eulas era un Pappandriano del nord di Amakna che un giorno trovò, in mezzo agli escrementi dei suoi Pappatutto, un paio di daghe leggermente sporche.\nAttenzione: il manico è scivoloso, potresti fallire l\'attacco.",ep:1,g:10,l:40,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>40",p:4000};
I.u[1372] = {n:"Daghe Asolio",t:5,d:"Chi non conosce Asolio l\'eremita, il leggendario discepolo di Etram che ha passato tutta la sua vita a evitare ogni contatto con la gente? Quando morì queste daghe furono ritrovate accanto al suo corpo, solo i più agili potranno domarle.",ep:9,g:19,l:44,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5300};
I.u[1373] = {n:"Il Rasoio Infernale",t:5,d:"Krys Noraso era un vecchio discepolo Anutrof che portava la barba lunga, come tutti i discepoli Anutrof degni di questo nome. Quando sua moglie gli regalò un rasoio, lui preferì usarlo come arma per combattere.",ep:1,g:17,l:30,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1374] = {n:"Daghe Tylo",t:5,d:"Tylo era uno scriba amakneiano vissuto secoli addietro. Aveva l\'abitudine di incidere i suoi quaderni di pietra con le daghe. Di lui ci restano queste splendide daghe, resistentissime ai colpi.",ep:1,g:12,l:30,wd:true,fm:true,w:13,an:13,e:[10,3,1,1,30,50,false,false],c:"CS>50",p:3000};
I.u[1375] = {n:"Ascia Terofilo",t:19,d:"Terofilo era un discepolo Yop capace di sollevare dei pesi impressionanti. Ma purtroppo per lui, come per tutti gli Yop troppo muscolosi, l\'intelligenza non era proprio il suo forte...",ep:1,g:14,l:15,wd:true,fm:true,w:25,an:17,e:[10,5,1,1,50,50,false,true],c:"CS>70&CI<10",p:800};
I.u[1376] = {n:"Ascia di Grazia",t:19,d:"Questa ascia, a volte pesante da maneggiare, è perfetta per uccidere i Trooll: le rune magiche che contiene, infatti, le permettono di bruciare i nemici.",ep:7,g:15,l:35,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,50,false,true],c:"CS>50",p:3000};
I.u[1377] = {n:"Ascia Huré",t:19,d:"Huré era un giovane prete che, in nome della fede, non indietreggiava mai davanti alle armi. La sua arma prediletta era un\'ascia sulla quale aveva disegnato numerosi segni, il cui significato è perso per sempre...",ep:1,g:16,l:22,wd:true,fm:true,w:22,an:17,e:[10,5,1,1,50,50,false,true],c:"CW>30",p:2200};
I.u[1378] = {n:"Francisca Rikamartina",t:19,d:"Questa ascia da combattimento, riservata ai giovani guerrieri, ha la capacità di produrre un suono stridente molto fastidioso quando si scontra con un\'altra arma.",ep:1,g:17,l:28,wd:true,fm:true,w:22,an:17,e:[8,5,1,1,40,40,false,true],c:"CA>30",p:2300};
I.u[1379] = {n:"Lo Scrounnchhh",t:7,d:"Secondo la leggenda il nome di questo martello imiterebbe il rumore che fa quando fracassa un cranio nemico. \nPurtroppo nessun nemico può confermarlo.",ep:7,g:9,l:35,wd:true,fm:true,w:35,an:15,e:[8,5,1,1,30,40,false,true],c:"CS>50&CA>20",p:35000};
