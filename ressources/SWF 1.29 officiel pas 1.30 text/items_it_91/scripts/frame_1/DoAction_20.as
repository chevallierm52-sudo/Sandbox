I.u[8966] = {n:"Zampa di Ecaflip Perfetta",t:6,d:"Questa spada è l\'incarnazione stessa della fortuna del dio Ecaflip. Hai tra le mani la versione più pura della Zampa di Ecaflip, che testimonia la tua fortuna tanto incredibile quanto insolente (e che ti lascerà celibe per tutta la vita).",ep:1,g:81,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
