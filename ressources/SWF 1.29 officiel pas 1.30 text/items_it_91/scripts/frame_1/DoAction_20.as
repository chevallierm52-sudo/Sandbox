I.u[8913] = {n:"Pozione Bulbica",t:12,d:"Questa pozione è composta da estratti di bulbi macerati in una purea di Klug. Gli Alchimisti più audaci usano della farina di riso al posto della purea di Klug ormai introvabile al giorno d\'oggi. Per quanto ti possa sembrare strano... ti abituerai al suo gusto.",ep:22,g:23,l:110,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[8914] = {n:"Scheda descrittiva di un Tuttofare",t:24,d:"Questa scheda contiene tutte le informazioni necessarie per ritrovare il Tuttofare descritto.",ep:0,g:176,l:1,wd:false,fm:true,w:0,c:"PJ>65,50",p:1};
I.u[8915] = {n:"Scheda del Tuttofare da compilare",t:80,d:"Questa scheda è fatta per inserirci tutte le informazioni necessarie per identificare un Tuttofare.",ep:0,g:6,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[8916] = {n:"Ambra del Tynril",t:50,d:"Quest\'ambra non è come le altre. Se la agiti dall\'alto in basso, chiudendo gli occhi e ballando un tango rapido del Capitano Chafer, potrai forse sentirla vibrare e brillare, come se fosse abitata da un\'anima misteriosa. Avrai l\'aria di un pazzo, certo, ma di un pazzo che brilla e vibra.",ep:22,g:1,l:100,wd:true,fm:true,w:10,p:1};
I.u[8917] = {n:"Chiave della Grotta Esca",t:84,d:"Questa strana chiave ti permetterà di entrare nella Grotta Esca tutto intero.",ep:22,g:244,l:1,wd:true,fm:true,w:1,p:1};
I.u[8918] = {n:"Elmo migliorato",t:16,d:"Questo casco migliorato permette in teoria di cavalcare gli Scarafoglie più veloci senza perdere la parrucca. Semplicemente inestimabile.",ep:22,g:25,l:1,wd:true,fm:true,w:10,p:1};
I.u[8919] = {n:"Ali di legno migliorate",t:17,d:"Queste ali di legno migliorate sono state imbottite e rese più leggere con delle piume e del tessuto di qualità. La struttura resta in legno, sarà difficile non farti schiacciare.",ep:22,g:22,l:30,wd:true,fm:true,w:10,p:2633};
I.u[8922] = {n:"Borsa di Kama",t:24,d:"Questa borsa contiene una grossa somma di denaro. È sicuramente destinata a corrompere qualcuno.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8923] = {n:"Sacco di Patate",t:24,d:"Un sacco di Patate, bisogna veramente non sapere come passare il tempo per andare in giro con una roba simile...",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8924] = {n:"Arco di Apason",t:2,d:"È la storia di un uomo chiamato Apason, aveva un teatro. Era il Teatro di Apason.",ep:22,g:59,l:151,wd:true,fm:true,w:10,an:10,e:[10,3,2,7,30,50,false,true],c:"CA>200",p:46105};
I.u[8925] = {n:"Arco Olettico",t:2,d:"Quest\'arco è stato intagliato da una Sadida durante una fase di sonnambulismo creativo. Emana un\'intensa voglia di dormire che colpisce tanto chi lo porta quanto i suoi bersagli.",ep:22,g:60,l:185,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,3,8,30,50,false,true],c:"CA>300&CI>300",p:51125};
I.u[8926] = {n:"Daga Duh",t:5,d:"Queste daghe sono perfette per pulire gli ananas o macinare il caffé. Alcuni le usano addirittura per schiacciare le mele e le pere.",ep:22,g:65,l:175,wd:true,fm:true,w:10,an:13,tw:true,e:[7,3,1,1,30,30,false,false],c:"CA>250&CC>250&CS>150",p:49775};
I.u[8927] = {n:"Daghe Hood",t:5,d:"Hood era un Etram completamente pazzo, rubava ai poveri per dare ai ricchi.",ep:22,g:66,l:171,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>350&CA>200",p:49280};
I.u[8928] = {n:"Daghe Ruik",t:5,d:"Ruik è più bravo a bere che a combattere, e non migliora certo con il tempo. È comunque sconsigliato travestirsi da tappo quando ha con sé le sue daghe.",ep:22,g:67,l:158,wd:true,fm:true,w:10,an:13,e:[15,2,1,1,30,50,false,false],c:"CA>300",p:47275};
I.u[8929] = {n:"Kriss Tubal",t:5,d:"Da non confondere con il celebre bastone dal nome simile, queste lame provocano danni molto ma molto più violenti.",ep:22,g:68,l:149,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CI>250&CC>250",p:45875};
I.u[8930] = {n:"Fuchsia",t:6,d:"Molti prodi guerrieri hanno rifiutato quest\'arma a causa del suo colore, la maggior parte di loro in seguito è morta sotto questa lama.",ep:22,g:78,l:163,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,30,50,false,false],c:"CA>300&CI>300",p:48245};
I.u[8931] = {n:"Az\'tech",t:6,d:"Questa spada apparteneva a un vecchio Anutrof megalomane, è in oro massiccio... come il suo ego d\'altronde.",ep:22,g:79,l:186,wd:true,fm:true,w:10,an:14,tw:true,e:[7,5,1,1,45,50,false,false],c:"CA>200&CC>200&CS>200",p:51275};
I.u[8932] = {n:"Kubri Kura",t:6,d:"Sorridi! Fai cheese! Ecco, sei tagliato in due!",ep:22,g:80,l:179,wd:true,fm:true,w:10,an:14,e:[7,4,1,1,40,50,false,false],c:"CS>300&CA>150",p:50330};
I.u[8933] = {n:"Ascia Sudore Rancido",t:19,d:"Urag\'han era un vecchio Pandawa dalla pelle così morbida che lo si chiamava Pelle Liscia. Il suo odore però era così forte da meritarsi un altro tipo di soprannome, e l\'ha trasmesso alla sua fedele ascia.",ep:22,g:49,l:162,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,50,50,false,false],c:"CW>250&CS>300",p:47900};
I.u[8934] = {n:"Ascia Rabbia",t:19,d:"Arrabbiato per essersi fatto rubare un chicco di riso da uno scoiattolo furfante durante le sue vacanze sull\'isola di Pandala, Bruce Bulgur si è servito di quest\'ascia per abbattere ogni bambù sul quale il ladro andava a rifugiarsi. Le Pandawa del villaggio hanno dovuto tranquillizzarlo con la metà della riserva di alcool di bambù per evitare che radesse al suolo tutta la foresta. Mammia mia questo Bruce!",ep:22,g:50,l:158,wd:true,fm:true,w:10,an:17,e:[7,5,1,1,50,50,false,false],c:"CC>150&CA>150&CI>150",p:47542};
I.u[8935] = {n:"La Vanga di Trice",t:8,d:"Sin da piccola la Yoppina Trice si allenava a combattere i draghi. Usava le rocce del giardino di sua madre come avversari e una pala come spada. Faceva furore!",ep:22,g:48,l:176,wd:true,fm:true,w:10,an:16,e:[7,4,1,1,35,50,false,false],c:"CC>250&CI>250",p:49985};
I.u[8936] = {n:"Pala Gattin",t:8,d:"Questa pala è selvaggia e tenta di mordere il proprietario ad ogni utilizzo. Emette degli strani suoni quando è contenta e si calma solo al suono dei sonaglini.",ep:22,g:49,l:137,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>150&CA>200",p:43945};
I.u[8937] = {n:"Pala Egante",t:8,d:"Un Anutrof scaltro aveva deciso di diventare pirata dopo aver constatato che si recuperavano molte più risorse su un cadavere fresco che in una vecchia tomba marcia. Il suo simbolo era una pala rosso sangue, con la quale faceva tremare tutti gli equipaggi delle barche di ogni mare.",ep:22,g:50,l:156,wd:true,fm:true,w:10,an:16,e:[7,5,1,1,20,50,false,false],c:"CS>250&CI>250",p:49455};
