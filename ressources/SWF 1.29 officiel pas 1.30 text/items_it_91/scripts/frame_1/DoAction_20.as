I.u[8961] = {n:"Zampa di Ecaflip",t:6,d:"Alcuni superstiziosi credono che le zampe di coniglio portino fortuna e ricchezza. Grazie a questa spada leggendaria potrai risplendere ai loro occhi. D\'altronde la sua lama è affilatissima e la sua forma ti ricorda leggermente quella di una spada che hai già conosciuto.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
