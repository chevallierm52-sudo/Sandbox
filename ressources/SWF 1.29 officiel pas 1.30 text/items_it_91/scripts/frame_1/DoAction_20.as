I.u[9158] = {n:"Stivoblopli Griotta",t:11,d:"Smettila di lamentarti di questo nome impronunciabile, questo particolare ti salverà la vita quando un brigante ti aggredirà chiedendoti: \"Dammi i tuoi Stilopali, no... i tuoi Stiblopali, no... i tuoi Stivpali, no... \". Tranquillo, avrai tutto il tempo di correre via.",ep:5,g:117,l:50,wd:true,fm:true,w:10,s:98,p:1000};
