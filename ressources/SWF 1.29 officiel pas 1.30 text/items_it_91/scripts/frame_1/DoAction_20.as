I.u[8985] = {n:"EPEO per Dragona Rosa e Tifux",t:116,d:"Utilizzando questa potente pastiglia, aumenterai definitivamente le capacità della tua Dragona Rosa o del tuo Tifux. Attenzione, una sola dose sarà sufficiente per il tuo Famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"PO=7519|PO=8155",u:true,p:1};
I.u[8986] = {n:"EPEO per Palladineve e Fotasma",t:116,d:"Utilizzando questa potente pastiglia, aumenterai definitivamente le capacità del tuo Palladineve o del tuo Fotasma. Attenzione, una sola dose sarà sufficiente per il tuo Famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"PO=8151|PO=7518",u:true,p:1};
I.u[8987] = {n:"EPEO per El Scarador e Crum",t:116,d:"Utilizzando questa potente pastiglia, aumenterai definitivamente le capacità del tuo El Scarador o del tuo Crum. Attenzione, una sola dose sarà sufficiente per il tuo Famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:1,g:10,l:1,wd:true,fm:true,w:1,c:"PO=8154|PO=7520",u:true,p:1};
I.u[8988] = {n:"EPEO per Arbre Magic e Minimino",t:116,d:"Utilizzando questa potente pastiglia, aumenterai definitivamente le capacità del tuo Arbre Magic o del tuo Minimino. Attenzione, una sola dose sarà sufficiente per il tuo Famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:1,g:11,l:1,wd:true,fm:true,w:1,c:"PO=8153|PO=7522",u:true,p:1};
I.u[8989] = {n:"Elmo del Bituf Aereo",t:16,d:"Con questo casco sulla testa, puoi sperare di librarti nell\'aria... sempre che tu riesca a girare su te stesso alla velocità della luce. Per l\'atterraggio... sbrigatela da solo.",ep:22,g:209,l:154,wd:true,fm:true,w:10,p:44350};
I.u[8990] = {n:"Prisma di Conquista",t:112,d:"Quest\'oggetto magico di pietra brilla in tutta la zona sulla quale è posto. Ti permette di marchiare il territorio senza farti sprecare urina. Da utilizzare senza moderazione se hai l\'anima del conquistatore.\nAttenzione: puoi piazzare un prisma di conquista solo se metti ben in evidenza il tuo grado (modalità PvP attiva), e se ti trovi in una zona senza prismi. La zona nella quale vuoi piazzare un prisma di conquista deve inoltre essere limitrofa con una zona alleata da almeno cinque minuti.",ep:4,g:1,l:1,wd:true,fm:true,w:10,c:"PL>9&PP>2",u:true,p:1};
I.u[8991] = {n:"Anellamore",t:9,d:"Questo anello succhia il dito in continuazione. È viscoso e freddo, se sopporti tutto ciò potrai approfittare dei suoi enormi poteri.",ep:22,g:145,l:189,wd:true,fm:true,w:10,s:97,p:55000};
I.u[8992] = {n:"Falce maledetta dello Sgozzatore Guerriero",t:22,d:"Questa lama falcia i tuoi nemici come il grano, ma provoca anche l\'invidia dei tuoi alleati. Questo è il destino dei potenti.",ep:22,g:3,l:200,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,100,50,false,false],p:58000};
I.u[8993] = {n:"Spada Maledetta dello Sgozzatore Assassino",t:6,d:"Questa spada sprigiona un potere impressionante, i massacri che fa sono di quelli che restano nei libri di storia. Ma il suo uso resta comunque molto casuale... forse esiste qualcuno capace di correggere questo difetto.",ep:20,g:83,l:200,wd:true,fm:true,w:10,an:14,tw:true,e:[10,5,1,1,100,2,false,false],p:58000};
I.u[8994] = {n:"Stoffa Corallosa",t:55,d:"Questa stoffa umida è rimasta sotto l\'acqua per molti anni. Piccole particelle di corallo hanno cominciato a ricoprirla. Peccato che sia così rigida, avresti potuto usarla come fazzoletto.",ep:22,g:728,l:150,wd:true,fm:true,w:1,p:100};
I.u[8995] = {n:"Stoffa di Gurlo il Terribile",t:55,d:"Tempo fa usata come cerotto per curare le vesciche di Gurlo il Terribile, questa stoffa è ancora impregnata di un liquido dall\'odore sorprendente. La cosa più strana è che sembra farti venire l\'acquolina in bocca.",ep:22,g:729,l:150,wd:true,fm:true,w:1,p:100};
I.u[8996] = {n:"Pelle di Rasbul Maggiore",t:59,d:"Questa pelle è più morbida di quella del sedere di una femmina Kilibriss.",ep:22,g:48,l:250,wd:true,fm:true,w:1,p:100};
I.u[8997] = {n:"Pelle lacerata del Tynril",t:59,d:"Questa pelle ricopriva sicuramente un punto sensibile del Tynril. Poverino.",ep:22,g:629,l:400,wd:true,fm:true,w:1,p:100};
I.u[8998] = {n:"Pietra preziosa del Kimbo",t:50,d:"Per anni il Kimbo ha succhiato questa pietra preziosa per renderla più liscia e poterla infilare più facilmente nelle sue narici. A volte la natura è difficile da capire.",ep:22,g:109,l:900,wd:true,fm:true,w:1,p:100};
I.u[9000] = {n:"null",t:82,d:"",ep:0,g:10,l:1,wd:false,fm:true,w:10,c:"PP>5",p:1};
I.u[9001] = {n:"Scudo di Sidimote",t:82,d:"Questo scudo dovrebbe ricordare ai tuoi avversari che sei cresciuto nelle Lande di Sidimote. Sembra che questo basti a spaventarli.",ep:18,g:8,l:1,wd:true,fm:true,w:10,c:"PP>4",p:15650};
I.u[9002] = {n:"Ftalmo",t:82,d:"Questo scudo è ricoperto di diversi occhi, per permettere a chi lo porta di fissare più facilmente il suo avversario negli occhi.",ep:18,g:5,l:1,wd:true,fm:true,w:10,c:"PP>4",p:33000};
I.u[9003] = {n:"Scudo Taverna",t:82,d:"Il taverniere dell\'osteria Fubuk di Bonta doveva veramente annoiarsi quando ha avuto l\'idea di dotare i suoi buttafuori di questo scudo pubblicitario.",ep:18,g:6,l:1,wd:true,fm:true,w:10,c:"PP>3",p:16200};
I.u[9004] = {n:"Scudo Aksadala",t:82,d:"Questo scudo del villaggio di Aksadala dovrebbe riuscire a contrastare ogni tipo di colpo.",ep:14,g:31,l:1,wd:true,fm:true,w:2,c:"PP>2",s:34,p:5350};
I.u[9005] = {n:"Scudo Ventaglio",t:82,d:"Quando i tuoi alleati cominciano a essere stanchi o quando vuoi disperdere gli effetti di un Vento di Panico, questo scudo può salvarti la vita. Basta sventolarlo con vigore in tutti i sensi, un po\' come fai con la mano quando la mattina lasci andare i gas!",ep:18,g:11,l:1,wd:true,fm:true,w:10,c:"PP>8",p:54450};
I.u[9006] = {n:"Scudo del Sadida",t:82,d:"Questo scudo serviva come sgabello per i Sadida che dovevano riposarsi. Dopo aver chiuso lo sgabello, ti proteggerà efficacemente dagli attacchi dei nemici, ma non dalle loro risate.",ep:18,g:12,l:1,wd:true,fm:true,w:10,c:"PP>6",p:18700};
I.u[9007] = {n:"Scudo di Mutande",t:82,d:"Questa sorprendente creazione è ricoperta dalle Mutande di Cuoio del Chafer Lanciere, bollite, pulite e stirate per adattarsi al meglio alle forme dello scudo, che sono ben lontane da quelle dello Chafer, molto più formose e provocanti...",ep:18,g:13,l:1,wd:true,fm:true,w:10,c:"PP>5",p:26700};
I.u[9008] = {n:"Scudo di Asse",t:82,d:"Questo splendido scudo contiene un campione d\'acqua del Mar d\'Asse, il che oltre a portarti fortuna potrà servirti da borraccia. Pratico no?",ep:18,g:16,l:1,wd:true,fm:true,w:10,c:"PP>7",p:32450};
I.u[9009] = {n:"Scudo Alberagno",t:82,d:"Nascosto dietro a questo scudo sembrerai un Alberagno e gli avventurieri più ingenui scapperanno di corsa. Gli altri invece ti aggrediranno pensando di ottenere un po\' di ambra.",ep:18,g:19,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5950};
I.u[9010] = {n:"Scudo Pandawa",t:82,d:"Ideale per mimetizzarsi su Pandala, ma per farsi notare da qualsiasi altra parte, questo scudo ha soprattutto il vantaggio di essere ricoperto di peli di Pandawa, famosi per non avere assolutamente alcun potere. Fai prima a metterlo direttamente nelle tue mutande di cuoio senza pensarci più!",ep:18,g:22,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5600};
I.u[9011] = {n:"Quadrante di Fuoco",t:82,d:"Questo originale scudo ti proteggerà dall\'elemento Fuoco e in più darà l\'ora ai tuoi avversari. Li aiuta a cronometrare la sconfitta.",ep:18,g:24,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9012] = {n:"Quadrante di Aria",t:82,d:"Questo originale scudo ti proteggerà dall\'elemento Aria e in più darà l\'ora ai tuoi avversari. Li aiuta a cronometrare la sconfitta.",ep:18,g:26,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9013] = {n:"Quadrante di Terra",t:82,d:"Questo originale scudo ti proteggerà dall\'elemento Terra e in più darà l\'ora ai tuoi avversari. Li aiuta a cronometrare la sconfitta.",ep:18,g:27,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9014] = {n:"Quadrante di Acqua",t:82,d:"Questo originale scudo ti proteggerà dall\'elemento Acqua e in più darà l\'ora ai tuoi avversari. Li aiuta a cronometrare la sconfitta.",ep:18,g:25,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9015] = {n:"Scudo del Taglialegna",t:82,d:"Originariamente questo scudo serviva ai Taglialegna che volevano proteggersi dalla caduta degli alberi. Ma il suo uso è cambiato in fretta e adesso serve per proteggersi dalla caduta dei nemici che spesso hanno la cattiva abitudine di piombarti addosso senza preavviso.",ep:18,g:4,l:1,wd:true,fm:true,w:10,c:"PP>1",p:1200};
I.u[9016] = {n:"Scudo del Monte Kepuz",t:82,d:"Questo scudo, verdastro e maleodorante, offre comunque una protezione di prima scelta, soprattutto quando si tratta di affrontare le creature del monte Kepuz.",ep:18,g:1,l:1,wd:true,fm:true,w:20,c:"PP>2",p:5400};
I.u[9017] = {n:"Scudo dei Brigandini",t:82,d:"Se hai sempre sognato di essere un vero Brigandino, ecco lo scudo che fa per te! Tramandato di generazione in generazione, ti permetterà di scovare, senza il minimo sbaglio, tutti i giovani avventurieri di Astrub.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"PP>6",p:30700};
I.u[9018] = {n:"Il Kuart Icuore",t:82,d:"Un illustre avventuriero collezionista ha passato tutta la vita cercando questo tipo di scudo. Si racconta perfino che raccogliendo quattro di questi scudi, si potesse vivere una vita migliore.",ep:18,g:7,l:1,wd:true,fm:true,w:10,c:"PP>3",p:13000};
I.u[9019] = {n:"Scudo del Bawbawo",t:82,d:"Non tutti i Wabbit sono piccole creature inoffensive, anzi! I Wabbit sono delle creature infami, alcune di esse hanno persino delle abitudine barbariche e estraggono il succo dalle Cawote schiacciandole con questo enorme scudo.",ep:18,g:2,l:1,wd:true,fm:true,w:15,c:"PP>3",p:10500};
I.u[9020] = {n:"Derma Tho",t:82,d:"Ami così tanto questo scudo di pelle che manca poco perché diventiate siamesi. Ricordati di curargli come si deve le verruche e i foruncoli per evitare che si rovini.",ep:18,g:3,l:1,wd:true,fm:true,w:10,c:"PP>2",p:2200};
I.u[9021] = {n:"Scudo di Capitan Amakna",t:82,d:"Un giovane avventuriero si arruolò nella milizia di Bonta con l\'idea di difendere gli oppressi. Riformato a causa della sua debole costituzione, fu in seguito contattato da un Alchimista di Amakna che voleva usarlo come cavia per testare una nuova pozione magica. L\'effetto fu immediato, il giovane avventuriero diventò rapidamente un vero guerriero con una forza straordinaria, ma completamente idiota. Era stato trasformato in Yop! Si fece forgiare questo scudo considerato indistruttibile, e gli fu per sempre attribuito il nome di Capitan Amakna (in omaggio all\'illustre Capitano Chafer, scomparso in circostanze misteriose).",ep:18,g:14,l:1,wd:true,fm:true,w:30,c:"PP>9",p:63200};
I.u[9022] = {n:"Klum",t:82,d:"Tempo fa questo enorme scudo ha permesso al celebre avventuriero Klum di non morire schiacciato sotto il peso di un Croccaroc che voleva saltargli addosso. La storia non racconta se è sopravvissuto anche agli effetti secondari di questa appassionante relazione con il Croccaroc.",ep:18,g:15,l:1,wd:true,fm:true,w:10,c:"PP>4",p:22100};
I.u[9023] = {n:"Scudo Volante",t:82,d:"Per quanto possa sembrare strano, si dice che questo scudo di legno e peli consenta agli avventurieri più leggeri di volare per qualche istante. Il tutto per impressionare un\'ultima volta gli avversari prima di spiaccicarsi stupidamente per terra.",ep:18,g:17,l:1,wd:true,fm:true,w:1,c:"PP>0",p:1200};
I.u[9024] = {n:"Scudo del Chuko",t:82,d:"Il Chuko usava questo scudo per proteggersi dalle grosse palle di cannone che gli erano regolarmente sparate. Le storie più bizzarre raccontano persino che certe palle fossero vive!",ep:18,g:18,l:1,wd:true,fm:true,w:10,c:"PP>6",p:36850};
I.u[9025] = {n:"Scudo del Pappatutto",t:82,d:"Abbastanza inutile ma molto impressionante a causa dell\'odore che emana, questo scudo sarà il compagno di molti giovani avventurieri.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PP>0",p:400};
I.u[9026] = {n:"Scudo di Bowis",t:82,d:"Questo scudo è un chiaro omaggio al mantello del Bowis, che a sua volta era un omaggio a una celebre reliquia composta da tre frammenti di forma triangolare. Un\'ennesima noiosissima storia!",ep:18,g:21,l:1,wd:true,fm:true,w:10,c:"PP>3",p:10150};
I.u[9027] = {n:"Scudo del Croccaroc",t:82,d:"Questo scudo in pietra non è altro che una testa di Croccaroc schiacciata dal piede di un Minotoror. Un modo come un altro per mischiare teste montate e puzza sotto il naso.",ep:5,g:23,l:1,wd:true,fm:true,w:10,c:"PP>2",p:6300};
I.u[9028] = {n:"Scudo Terradala",t:82,d:"Questo scudo del villaggio di Terradala dovrebbe riuscire a contrastare ogni tipo di colpo.",ep:18,g:32,l:1,wd:true,fm:true,w:10,c:"PP>3",s:36,p:14100};
I.u[9029] = {n:"Scudo Focodala",t:82,d:"Questo scudo del villaggio di Focodala dovrebbe riuscire a contrastare ogni tipo di colpo.",ep:18,g:33,l:1,wd:true,fm:true,w:15,c:"PP>5",s:37,p:27100};
I.u[9030] = {n:"Scudo Erdala",t:82,d:"Questo scudo del villaggio di Erdala dovrebbe riuscire a contrastare ogni tipo di colpo.",ep:18,g:30,l:1,wd:true,fm:true,w:10,c:"PP>4",s:35,p:11600};
I.u[9031] = {n:"Anelloprofitto del Maestro Jarbo",t:9,d:"Ai suoi tempi, il Maestro Jarbo era molto forte e aveva ricchezze e donne a iosa. Ma non ne aveva alcun merito perchè il suo potere proveniva interamente dal suo bell\'anello. Un giorno, attraversò una strada e... PUF, sparito il Maestro Jarbo. Da quel momento il suo anello si trasmette di mano in mano tra persone poco scrupolose.",ep:0,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[9035] = {n:"Pozione di Recinto di Gilda",t:12,d:"Questa pozione permette di tornare nel tuo recinto di gilda.",ep:5,g:25,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[9036] = {n:"Pozione del Villaggio degli Zoth",t:12,d:"Questa pozione ti permette di essere teletrasportato nel villaggio dei Zoth, se quest\'ultimo ti appartiene.",ep:0,g:24,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9037] = {n:"Pozione di scoperta",t:14,d:"Questa pozione permette di scoprire i personaggi invisibili che ti circondano.",ep:0,g:0,l:1,wd:true,fm:true,w:1,p:10};
I.u[9038] = {n:"Piccola pozione d\'aggressione",t:14,d:"Questa pozione ti permette di arrabbiarti talmente tanto da attaccare automaticamente i nemici che si avvicinano troppo.",ep:0,g:32,l:1,wd:true,fm:true,w:1,c:"Pg=21",u:true,p:10};
I.u[9039] = {n:"Pozione di richiamo prismatico",t:12,d:"Questa pozione ti permette di essere teletrasportato verso il prisma alleato più vicino.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9040] = {n:"Pozione d\'aggressione Media",t:14,d:"Questa pozione ti permette di arrabbiarti talmente tanto da attaccare automaticamente i nemici che si avvicinano troppo.",ep:0,g:33,l:1,wd:true,fm:true,w:1,c:"Pg>21,1",u:true,p:10};
