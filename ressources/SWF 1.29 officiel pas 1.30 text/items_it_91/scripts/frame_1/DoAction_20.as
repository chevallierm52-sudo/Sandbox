I.u[8964] = {n:"Zampa di Ecaflip",t:6,d:"\"La Fortuna sorride agli audaci!\" cantano gli adepti del dio Ecaflip. Ora sei armato di tutto punto e pronto per fare furore nel gioco. Questa spada prestigiosa e di una rarità e di una purezza eccezionali.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
