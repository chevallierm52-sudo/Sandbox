I.u[9059] = {n:"",t:24,d:"",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[9060] = {n:"Pezzo di carta strappato",t:24,d:"È un pezzo di lettera che è stato strappato. Vi si può ancora leggere: \"...Come convenuto, farò in modo che l\'inchiesta su questo mercante non riesca. Versami la somma prevista al solito posto dove le donne offrono una compagnia affascinante\'. La lettera è firmata X.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9061] = {n:"Exoram",t:32,d:"Exoram deve essere scortato fuori dal campo goblin e fino al tempio Etram.",ep:1,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9062] = {n:"Documento su Xefires",t:24,d:"Questo documento contiene numerose informazioni su Xefires. Si sa per esempio che passa molto tempo alla taverna di Astrub.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9063] = {n:"Lista di Milon",t:24,d:"Questa impressionante lista ti è stata data da Milon l\'Orefice. Vi sono elencati gli oggetti necessari per costruire un gioiello sontuoso.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9064] = {n:"Bava di Pappatutto Reale",t:24,d:"È veramente diversa da una bava qualunque? Chissà, a vederla così non sembra proprio.",ep:1,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9065] = {n:"Lettera per Milon",t:24,d:"Questa lettera, scritta in fretta, spiega a Milon che il gioiello è in pericolo. D\'altronde... perché stai perdendo tempo a leggerla invece di precipitarti da lui?",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9066] = {n:"Lettera del capo dei ladri",t:24,d:"Lettera ritrovata addosso a uno dei ladri che hai combattuto da Milon:\n\"Milon Corichel l\'Orefice ha appena creato un gioiello di valore inestimabile. Impadroniscitene ad ogni costo\". Evidentemente i ladri hanno fallito e in più sul retro del messaggio si trova la strada per raggiungere il loro nascondiglio. Una veloce visita di cortesia bisogna fargliela, ma è meglio se ci vai accompagnato.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9067] = {n:"Lettera per Xefires",t:24,d:"Questa lettera di Oto Mustam spiega nei dettagli il piano per Xefires.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9068] = {n:"Gioiello di Milon",t:24,d:"Questo gioiello è il simbolo dei tuoi sforzi e di quelli di Milon l\'Orefice. Vale sicuramente una piccola fortuna... per coloro a cui interessa.",ep:16,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9069] = {n:"Nuova lettera per Xefires",t:24,d:"Oto vi descrive le sue condizioni per corrompere Xefires.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9070] = {n:"Spada strana",t:24,d:"Questa spada è veramente insolita. Sicuramente non ne hai mai vista una simile a Bonta.",ep:1,g:718,l:1,wd:false,fm:true,w:0,p:1};
I.u[9071] = {n:"Appunti del Taverniere Fubuk",t:24,d:"Il taverniere Fubuk ha ricevuto degli Ecaflip sospetti che hanno pronunciato il nome di Ludac.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9072] = {n:"Appunti del Taverniere Pinchot",t:24,d:"Il taverniere Pinchot ha sentito delle guardie parlare dei loro problemi con una banda di Ecaflip.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9073] = {n:"Insegna di Bandito Ecaflip",t:24,d:"Hai preso questa insegna ai banditi Ecaflip delle pianure di Cania.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9074] = {n:"Gioiello di Amayiro",t:24,d:"Questo gioiello serve ad attirare il capo dei banditi per catturarlo.",ep:1,g:111,l:1,wd:false,fm:true,w:0,p:1};
I.u[9075] = {n:"Lettera dello Xelor",t:24,d:"Questa lettera ti è stata data da Marge l\'Orefice:\n\'Porta il gioiello a Ekusoyk Ubnan alla Taverna della Pintalegno. Sarà più rapido per noi e più redditizio per te.\'",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9076] = {n:"Gioiello di Amayiro (falso)",t:24,d:"Questo gioiello assomiglia in modo impressionante a quello che Amayiro ti ha mandato a cercare. D\'altronde sarebbe meglio se ci assomigliasse veramente, sennò...",ep:1,g:110,l:1,wd:false,fm:true,w:0,p:1};
I.u[9077] = {n:"Cranio di Feca",t:47,d:"Il cranio Feca può essere un eccellente bloccalibri.",ep:1,g:34,l:1,wd:true,fm:false,w:1,p:1};
I.u[9078] = {n:"Cranio di Osamodas",t:47,d:"A forza di un Tofu qui e un Bwork mago là questo discepolo Osamodas ha perso la testa.",ep:1,g:33,l:1,wd:true,fm:false,w:2,p:1};
I.u[9079] = {n:"Cranio di Anutrof",t:47,d:"Questo trofeo era già vecchio prima di diventare un trofeo.",ep:1,g:32,l:1,wd:true,fm:false,w:2,p:1};
I.u[9080] = {n:"Cranio di Etram",t:47,d:"Questo trofeo era già morbido prima di diventare un trofeo.",ep:1,g:31,l:1,wd:true,fm:false,w:2,p:1};
I.u[9081] = {n:"Cranio di Xelor",t:47,d:"Questo cranio è spesso confuso con quello della celebre mummia di Tut Enkarthon. Non lasciatevi ingannare: queste fasce non sono di cartone, ma di carta masticata.",ep:1,g:30,l:1,wd:true,fm:false,w:2,p:1};
I.u[9082] = {n:"Cranio di Ecaflip",t:47,d:"Data l\'impossibilità di giocare ai dadi con questo cranio, si potrebbe giocare agli astragali.",ep:1,g:29,l:1,wd:true,fm:false,w:2,p:1};
I.u[9083] = {n:"Cranio di Aniripsa",t:47,d:"Non fare la malalingua: no! non è il cranio di un passerotto!",ep:1,g:28,l:1,wd:true,fm:false,w:2,p:1};
I.u[9084] = {n:"Cranio di Yop",t:47,d:"Questo trofeo vuoto rimbomba come quando era pieno.",ep:1,g:27,l:1,wd:true,fm:false,w:1,p:1};
I.u[9085] = {n:"Cranio di Ocra",t:47,d:"A vederlo si direbbe uscito da uno scavo archeologico, questo cranio di Ocra-magnon!",ep:1,g:26,l:1,wd:true,fm:false,w:2,p:1};
I.u[9086] = {n:"Cranio di Sadida",t:47,d:"Chi avrebbe creduto che sotto quell\'ammasso di capelli ci fosse pure un cranio?",ep:1,g:25,l:1,wd:true,fm:false,w:2,p:1};
I.u[9087] = {n:"Cranio di Sàcrido",t:47,d:"Questo Sàcrido fa meno lo sbruffone senza tutti i suoi punti vita.",ep:1,g:24,l:1,wd:true,fm:false,w:2,p:1};
I.u[9088] = {n:"Cranio di Pandawa",t:47,d:"Si sarebbe potuto facilmente pensare che dopo tutta quella birra il Pandawa avesse un\'aspetto peggiore.",ep:1,g:23,l:1,wd:true,fm:false,w:2,p:1};
I.u[9089] = {n:"Insegna della pattuglia di Bonta",t:24,d:"Hai recuperato questa insegna durante la (facilissima) scaramuccia contro Bonta.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9090] = {n:"Insegna della pattuglia di Brakmar",t:24,d:"Hai recuperato questa insegna con molti sforzi durante la scaramuccia contro Brakmar.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9094] = {n:"Veleno Bwork",t:24,d:"Assomiglia più che altro a della Gelatina di Menta piuttosto che a del Veleno. I Bwork di sicuro non sono molto abili in questo: la cosa più preoccupante è che sembra che non lo siano neanche le Spie di Brakmar.",ep:4,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9096] = {n:"Stratega",t:32,d:"Lo Stratega ha accettato di seguirti fino dal tuo capo.",ep:16,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9097] = {n:"Badge del Potente Miliziano",t:24,d:"Hai preso questo badge al miliziano particolarmente temibile che ha sconfitto numerosi guerrieri di Brakmar. Il suo equipaggiamento sembrava molto singolare.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9098] = {n:"Martello di Nara",t:24,d:"Questo martello mostrerà a Oto che hai battuto il Forgiatore mercenario di Bonta.",ep:16,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9099] = {n:"Richiesta d\'aiuto di Amayiro",t:24,d:"Questa lettera, firmata da Amayiro, è una richiesta ufficiale d\'aiuto.",ep:3,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9100] = {n:"Mutanda di Linglés",t:24,d:"Ora è certo: per un bel po\' Linglés non farà più parlare di lui.",ep:1,g:84,l:1,wd:false,fm:true,w:0,p:1};
I.u[9101] = {n:"Cassetta degli attrezzi di Nara",t:24,d:"Questa cassetta contiene gli attrezzi che Nara il Forgiatore ha dimenticato.",ep:3,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9103] = {n:"Piano d\'attacco",t:24,d:"Questa lettera, con la data di una settimana fa, spiega nei dettagli il piano d\'attacco contro Bonta. Tuttavia non bisogna fidarsi perché una nota a piè di pagina indica che questo piano non è ancora stato confermato ed è soggetto a modifiche nei prossimi giorni da parte dell\'ufficiale Kapi Tagno. Quindi devi scoprire a che punto è attualmente.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9104] = {n:"Insegna della pattuglia del Cimitero",t:24,d:"Hai preso quest\'insegna alla pattuglia brakmariana che hai attaccato al Cimitero dei Torturati.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9105] = {n:"Lettera di Danathor",t:24,d:"Qualcuno ha infilato questa lettera nel tuo zaino mentre Amayiro ti dava la missione:\n\"Ritrova i documenti, ma portali a me e non a Amayiro. Sarai ricompensato. Danathor.\"",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9106] = {n:"Documenti segreti di Bonta",t:24,d:"Questi Documenti contengono numerose informazioni sulla difesa e sul sistema di Bonta. Ma a chi li darai?",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9107] = {n:"Ordini per la Spia Bontariana",t:24,d:"Penetra nellaTorre di Brakmar a mezzanotte e prendi tutti i Documenti che trovi al primo piano. Poi torna a Bonta passando a Est della strada.\nNo, non devi farlo TU, si tratta degli Ordini per la Spia che devi salvare.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9108] = {n:"Documenti segreti Brakmariani",t:24,d:"Questi Documenti contengono numerose informazioni segrete sul Corno Davola.",ep:14,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9109] = {n:"Bandana Rotta",t:24,d:"Questa Bandana in cattivo stato è coperta di catarro, come se fosse stata utilizzata come fazzoletto da parecchie generazioni di Wabbit. È appartenuta indubbiamente a Garutar, lo testimonia l\'odore di aringa putrefatta sottilmente camuffato da un odore di Cawota. Per avere un così cattivo odore dopo tutti questi anni, deve essere di sicuro impregnata di una potente magia.",ep:8,g:748,l:1,wd:false,fm:true,w:0,p:1};
I.u[9110] = {n:"Corno Davola",t:24,d:"Hai già provato a soffiarci dentro, ma non accade nulla di speciale...",ep:16,g:720,l:1,wd:false,fm:true,w:0,p:1};
I.u[9112] = {n:"Ordini per la Spia Brakmariana",t:24,d:"Penetra nella Torre di Bonta a mezzanotte, sgozza tutti coloro che incontri sul tuo cammino e prendi tutti i Documenti che trovi al primo piano. Poi torna a Brakmar passando per la strada.\nNo, non devi farlo TU, si tratta degli Ordini per la Spia che devi ritrovare.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9113] = {n:"Documenti segreti Rubati",t:24,d:"Si tratta dei Documenti che la spia ferita ha recuperato nella Torre di Bonta.",ep:13,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9114] = {n:"Documenti segreti stropicciati",t:24,d:"Si tratta dei documenti che la spia ferita ha recuperato nella torre di Bonta. Si sono un po\' stropicciati durante il tuo combattimento contro le forze di Bonta.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9115] = {n:"Insalace Piena di Polline",t:24,d:"Questa Insalace è stata preparata nel Paiolo Primordiale che le ha conferito virtù particolari. Per conoscerle bisognerebbe poterla assaggiare, ma, sfortunatamente, è destinata a Garutar. A volte la vita è ingiusta.",ep:12,g:719,l:1,wd:false,fm:true,w:0,p:1};
I.u[9116] = {n:"Cassa di equipaggiamento",t:24,d:"Un\'Arma, un Elmo, uno Scudo: questa Cassa contiene un equipaggiamento rudimentale ma efficace per i guerrieri.",ep:16,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9117] = {n:"Ugartello",t:7,d:"Ugah ha la testa dura, più dura di chiunque altro, ecco perché un martello creato con il suo cranio è l\'ideale per fracassare quello degli altri.",ep:23,g:67,l:180,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,50,50,false,false],c:"CV>1200",s:118,p:50000};
I.u[9118] = {n:"Regalo Event Shika",t:89,d:"x",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[9119] = {n:"Regalo Shika",t:89,d:"x",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[9120] = {n:"Cappello Shika",t:16,d:"x",ep:0,g:210,l:30,wd:false,fm:true,w:10,p:3000};
I.u[9121] = {n:"Mantello Shika",t:17,d:"x",ep:0,g:148,l:30,wd:false,fm:true,w:10,p:3000};
I.u[9122] = {n:"Blopanello Griotta",t:9,d:"È impossibile togliere questo anello dopo averlo messo al dito. Più ci pensi e più ti ricorda qualcuno.",ep:5,g:149,l:50,wd:true,fm:true,w:10,s:98,p:4000};
I.u[9123] = {n:"Blopanello Reginetta",t:9,d:"È impossibile togliere questo anello dopo averlo messo al dito. Più ci pensi e più ti ricorda qualcuno.",ep:5,g:150,l:50,wd:true,fm:true,w:10,s:99,p:1000};
I.u[9124] = {n:"Blopanello Cocco",t:9,d:"È impossibile togliere questo anello dopo averlo messo al dito. Più ci pensi e più ti ricorda qualcuno.",ep:5,g:151,l:50,wd:true,fm:true,w:10,s:100,p:1000};
I.u[9125] = {n:"Blopanello Indaco",t:9,d:"È impossibile togliere questo anello dopo averlo messo al dito. Più ci pensi e più ti ricorda qualcuno.",ep:5,g:152,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9126] = {n:"Blopanello Griotta Reale",t:9,d:"Tempo fa Krula aveva provato a infilarsi questo anello sul suo grande alluce. Sperava di farsi leccare i piedi dai suoi nemici recuperando, così, qualche goccia di succo di Blop Reale.",ep:5,g:153,l:80,wd:true,fm:true,w:10,s:102,p:15000};
I.u[9127] = {n:"Blopanello Reginetta Reale",t:9,d:"Tempo fa Krula aveva provato a infilarsi questo anello sul suo grande alluce. Sperava di farsi leccare i piedi dai suoi nemici recuperando, così, qualche goccia di succo di Blop Reale.",ep:5,g:154,l:80,wd:true,fm:true,w:10,s:103,p:15000};
I.u[9128] = {n:"Blopanello Cocco Reale",t:9,d:"Tempo fa Krula aveva provato a infilarsi questo anello sul suo grande alluce. Sperava di farsi leccare i piedi dai suoi nemici recuperando, così, qualche goccia di succo di Blop Reale.",ep:5,g:155,l:80,wd:true,fm:true,w:10,s:104,p:15000};
I.u[9129] = {n:"Blopanello Indaco Reale",t:9,d:"Tempo fa Krula aveva provato a infilarsi questo anello sul suo grande alluce. Sperava di farsi leccare i piedi dai suoi nemici recuperando, così, qualche goccia di succo di Blop Reale.",ep:5,g:156,l:80,wd:true,fm:true,w:10,s:105,p:15000};
I.u[9130] = {n:"Ugamuleto",t:1,d:"Questa copia approssimativa del grande Ugah si porta intorno al collo, con uno sguardo nero e una barba correttamente curata.",ep:23,g:127,l:181,wd:true,fm:true,w:15,s:118,p:58000};
I.u[9131] = {n:"Anello Colerina",t:9,d:"Colerina, la giovane Ocraina, ha perso la testa nel bosco di Litneg. La poverina si è beccata un\'ascia lanciata da Bruce Bulgur che l\'aveva scambiata per una felce gigante. Menomale che alla fine è morta... non le avrebbe fatto piacere sapere che da lontano assomigliava ad una felce gigante.",ep:23,g:146,l:188,wd:true,fm:true,w:10,s:119,p:57950};
I.u[9132] = {n:"Anello Capelluto",t:9,d:"Con questo anello oltre ad avere un capello sulla lingua e un pelo nella mano, potrai vantarti di avere dei capelli intorno alle dita.",ep:23,g:147,l:180,wd:true,fm:true,w:10,s:121,p:57822};
I.u[9133] = {n:"Fede Boletata",t:9,d:"Se i tuoi nemici sono allergici ai funghi, lascia che ti sgranocchino le dita.",ep:23,g:148,l:186,wd:true,fm:true,w:10,s:107,p:56000};
I.u[9134] = {n:"Arco a Doga",t:2,d:"All\'origine costruita per essere utilizzata come doga per i letti, questa lamina è stata in seguito usata nella fabbricazione di un arco che ti permetterà di mettere a letto i nemici per l\'eternità.",ep:23,g:61,l:187,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>300&CI>300",p:58421};
I.u[9135] = {n:"Bacchettrombetta",t:3,d:"In origine, bastava soffiare molto forte dentro questa tromba fungina per fare arrivare il menestrello Claudius Baglionus. Egli si metteva allora a cantare e tutti i mostri morivano all\'istante. Ma siccome era una tecnica un po\' troppo facile per uccidere i mostri, gli dei hanno deciso di tapparla e di trasformarla in una volgare bacchetta.",ep:23,g:66,l:184,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,45,50,false,true],c:"CI>300&CA>300",p:54284};
I.u[9136] = {n:"Bastone Fungmanico",t:4,d:"Le tre punte di questo bastone permettono di raccogliere i residui di plasmogrin presenti nella brezza quadramentale. Mettici un po\' di saliva sopra, punta il bastone nel senso delle lancette di un orologio Xelor invertito, conta fino a sessanta (o fino a 6 se sei uno Yop). Resta concentrato, stringi le chiappe, ecco... ora hai una possibilità su due di prenderti un fulmine addosso o di trasformare i tuoi nemici in Kirbul dal pelo irsuto.",ep:23,g:80,l:191,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>200&CC>200&CI>100",p:55000};
I.u[9137] = {n:"Coltello da Champignon",t:5,d:"Questi coltelli erano usati per tagliare via le micosi che parassitavano sui piedi degli avventurieri. Il tutto tagliandogli le gambe al livello delle ginocchia.",ep:23,g:69,l:187,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,30,50,false,false],c:"CA>450",s:119,p:57000};
I.u[9138] = {n:"Ascia a lamine",t:19,d:"Le diverse lamine di questa ascia permettono di tagliare più velocemente il salame, tre fette con un solo colpo. Per uccidere i nemici, però, è un po\' meno utile, salvo se hai l\'abitudine di mangiarli a fette.",ep:23,g:51,l:176,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,50,50,false,false],c:"CC>450",s:120,p:54854};
I.u[9139] = {n:"Stivaletti dei sottoboschi",t:11,d:"Questi stivaletti sono perfetti per camminare nel sottobosco senza schiacciare le foglie morte. Ma attenzione: la loro origine vegetale li spinge inesorabilmente a schiacciare tutto ciò che assomiglia al letame.",ep:23,g:115,l:175,wd:true,fm:true,w:10,s:120,p:54852};
I.u[9140] = {n:"Pantofolignon",t:11,d:"Queste pantofole sono ricoperte di piccole prese d\'aria che, contrariamente a quello che si pensa, non permettono ai piedi di respirare meglio, ma piuttosto alle spore fungine che coprono i tuoi piedi di uscire più rapidamente per andare a parassitare altri avventurieri.",ep:23,g:116,l:181,wd:true,fm:true,w:15,s:121,p:57000};
I.u[9141] = {n:"Mantellarcio",t:17,d:"Se questo mantello non fosse stato coperto di marciume, sarebbe potuto servire da tovaglia. Non fa niente, potrai sempre usarlo come lenzuolo.",ep:23,g:154,l:181,wd:true,fm:true,w:10,s:119,p:58000};
I.u[9142] = {n:"Mantellignon",t:17,d:"Questo mantello era tempo addietro riservato ai migliori arrampicatori, gli avventurieri che scalavano la montagna dei Croccaroc nel minor tempo possibile. Oggi serve soprattutto a mettersi in mostra nelle serate mondane.",ep:23,g:150,l:190,wd:true,fm:true,w:10,s:107,p:60000};
I.u[9143] = {n:"Tanga Ammazza-Mosche",t:10,d:"Come indicato nel nome, questo tanga è particolarmente efficace per uccidere le mosche un po\' troppo interessate alla tua anatomia. È meglio evitare di strapparlo con i denti, anche se ti piace farlo.",ep:23,g:132,l:192,wd:true,fm:true,w:20,s:107,p:48000};
I.u[9144] = {n:"Cintura Micosina",t:10,d:"Il miglior modo per non avere fun fung tra le gambe è di attirarli da un\'altra parte! Siccome le tue scarpe sono già piene, potrai utilizzare questa cintura per conservare i fun fung migliori.",ep:23,g:133,l:177,wd:true,fm:true,w:10,s:121,p:58444};
I.u[9145] = {n:"Fetta dei Sottoboschi",t:10,d:"Prendi un Olmo, strappagli la corteccia, immergila in una pozzanghera, sotterrala nel fango per un po\' di mesi, ricoprila di spore di funghi, mettila sotto il tuo letto per una settimana cospargendola di grasso di Blop tutte le sere, e il gioco è fatto: hai una cintura di scorza che puzza tantissimo! Sei contento?",ep:23,g:134,l:179,wd:true,fm:true,w:10,s:120,p:68420};
I.u[9146] = {n:"Ugantura",t:10,d:"Sull\'etichetta di questa cintura, si può leggere: \"Spiacenti, ma questa cintura non ti permetterà di avere il leggendario movimento di anche di Ugah\". E allora?",ep:23,g:135,l:185,wd:true,fm:true,w:10,s:118,p:56000};
I.u[9147] = {n:"Cappellignon",t:16,d:"Prendi un Dora, ricoprilo di bava di Pappatutto e di sudore di Yop. Lascialo marcire per qualche settimana ed è fatta, hai creato una copia del Cappellignon. Attenzione: questo cappello provoca spesso allucinazioni.",ep:23,g:221,l:185,wd:true,fm:true,w:10,s:119,p:48521};
I.u[9148] = {n:"Blopanello Multicolore Reale",t:9,d:"Piuttosto che ridurre il suo consumo di succo di Blop adulterato, Shika Ingals preferì continuare a falciare mezza ubriaca. Ed è proprio errando tra i campi che cadde su questo anello. Una storia interessante, vero?",ep:5,g:157,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9149] = {n:"Amublop Griotta",t:1,d:"Quando Lorkos entrò nel Labirinto del Minotoror, non esitò ad indossare l\'Amublop. Nessuno ha mai saputo perché.",ep:5,g:128,l:50,wd:true,fm:true,w:10,s:98,p:1000};
