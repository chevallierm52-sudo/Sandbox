I.u[9153] = {n:"Amublop Griotta Reale",t:1,d:"La fabbricazione di questo amuleto costa molto di più quella di un Amublop classico. Ma bisogna vederla in modo positivo, può anche essere venduto più caro... soprattutto imbrogliando un abitante di Astrub!",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
