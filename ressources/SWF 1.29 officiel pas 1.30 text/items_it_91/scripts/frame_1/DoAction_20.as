I.u[8708] = {n:"Certificato di Deposito al Cianil: Atuin",t:77,d:"Questo Certificato descrive le caratteristiche dell\'Atuin che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Trasformazione Fantasma Fëanor",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Regalo Fëanor",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Pezzo di Goldemort",t:110,d:"Bravo! Sei riuscito a saccheggiare il cadavere di Goldemort e a prendere un cucchiaio della sua materia. Gli avvoltoi sono fieri di te!",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Geta Bernacolo",t:11,d:"In certe contrade, sembrerebbe che i Geta Bernacolo siano lanciati come se fossero insulti, per provocare dei duelli. Anche se una cosa del genere può fare sorridere, a pensarci bene non è più stupido che schiaffeggiare l\'avversario con un paio di guanti. Il vantaggio dei Geta Bernacolo è di aggiungere una impatto olfattivo al colpo fisico. I Pandawa infatti non sono mai stati famosi per l\'igiene dei piedi...",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Anello Bhli",t:9,d:"Portare questo anello è un marchio onorifico. Ciò significa che sei un degno fedele della dea Ocra, l\'unica che svela il segreto su come tendere l\'arco più velocemente per tirare con più efficacia.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Anello Bla",t:9,d:"La loquacità degli Ecaflip è leggendaria. Sono capaci di raccontarti qualsiasi fesseria pur di farti giocare. Questo anello è il simbolo di questa qualità.\nIn via accessoria, può servire da dado di ricambio o addirittura per grattarsi... un po\' ovunque.",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Anello Zoo",t:9,d:"Le Osamodine adorano l\'anello Zoo perché conferisce un tocco di grazia in più al loro passo felino. C\'è da dire che a forza di stare con i mostri, finiscono talvolta col trasformarsi in vere tigresse. Ma in realtà sono buone come una mamma lupa.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Anello Rissa",t:9,d:"Le malelingue dicono che l\'anello Rissa sia l\'accessorio più inutile al mondo. Le ali che ha sui lati sono fastidiosissime quando bisogna cercare un fazzoletto in tasca. Fortunatamente gli Yop non hanno né fazzoletti, né tasche e in più le ali permettono di tagliuzzare un po\' di più il nemico ogni volta che lo si sfiora. Sembrerebbe quasi un gioiello fatto apposta per i Sàcrido.",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Anello Nota",t:9,d:"I mini scudi dell\'anello Nota servono da promemoria ai Feca che vi incastrano degli appunti o delle piccole cose da fare. Questo gioiello è soprannominato lo scudo anti-oblio. In compenso non protegge né dalla balbuzie né dai lapsus.",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Anello Stalgico",t:9,d:"Grazie a questo oggetto gli Anutrof possono ricordare i bei tempi andati in qualsiasi momento. Basta togliere la pala che vi è conficcata e sentire il profumo soave che si sprigiona. Però prima bisogna ovviamente racchiudervi l\'odore che si vuole tenere come ricordo, e non è sempre cosa facile.",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Anello Z\'amore",t:9,d:"Quest\'oggetto è stato dato dalla dea Aniripsa ai suoi fedeli in segno di unione spirituale durante la cerimonia di iniziazione agli incantesimi di classe. In via accessoria gli Aniripsa possono servirsene anche come braccialetto di spugna per asciugare il sangue degli alleati.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Anello Beffa",t:9,d:"Questo gioiello tende a rendere i Pandawa un po\' beffardi, soprattutto dopo la terza birra. Possono addirittura arrivare agli insulti. Ma non è molto importante perché, come dice il celebre proverbio Pandawa: \"Ventre ubriaco non ha orecchie\".",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Anello Hell",t:9,d:"Questo gioiello a forma di teschio era un regalo che, durante la festa tradizionale, si dava a tutti i bambini Etram per ricompensarli dei loro raggiri e colpi bassi. Le altre classi tendono spesso a screditare questa pratica che rende i bimbi troppo agitati... e infernali.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Anello Autilus",t:9,d:"L\'anello Autilus è l\'unico gioiello che dà l\'ora e che è assolutamente impermeabile. Certi pensano che ingrandendo e modificando questo oggetto si possa costruire un mezzo capace di spostarsi sott\'acqua. Ma dov\'è che sentono tutta \'sta roba?",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Anello Pelo",t:9,d:"Al contrario di quello che si dice, i Sadida non hanno peli sulle mani. No! Ce li hanno intorno a questo stupendo anello, e servono a rinforzarne gli effetti positivi. Non devono assolutamente essere tagliati. Grazie all\'anello Pelo, sarete sempre perfetti!",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"Anello Spedale",t:9,d:"Se vedi un personaggio non Sàcrido mettere un anello Spedale, portalo subito in rianimazione. Questo gioiello ferisce moltissimo e la gente di solito perde il proprio sangue freddo davanti al bagno di sangue caldo che provoca.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Scarpe Ballerine",t:11,d:"Queste scarpe permettono a chi le porta di ballare fino a tarda notte, nonostante i calli che provocano! Si muovono da sole al ritmo della musica e fanno \"bip bip\" quando si avvicinano a un minerale prezioso. Ecco perché gli Anutrof sono spesso chiamati le \"beat-machine\".",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Stivali 4x4",t:11,d:"Quando i Feca sono imbarazzati e vogliono cambiare argomento, parlano sempre degli stivali 4x4 e raccontano come questi stivali siano adatti a qualsiasi tipo di terreno. Quando i loro alleati sono in difficoltà durante i combattimenti, la comodità di questi stivali gli permette di non fare mai un passo falso.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Stivali Gadget",t:11,d:"Le molteplici fibbie di queste scarpe possono servire da corda di emergenza quando quella dell\'arco si rompe. Le giovani Ocra le usano anche per fare dei passati di verdura in cucina. Si vede che non temono l\'odore di piedi.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Corallo consumato",t:51,d:"Questo corallo consumato è veramente bello. Certi ne fanno addirittura dei gioielli. Altri invece lo mangiano. Ma sono rari e lo fanno solo quando lo scambiano per dei bastoncini di granchio surimi.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Coccige del Corallaro",t:47,d:"Situato in un posto strategico, quest\'osso permette al Corallaro di sedersi comodamente. Ora che è morto, tu potresti usarlo per far valere la tua autorità sui suoi simili.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Corallo Magistrale",t:51,d:"L\'unica differenza tra il Corallo consumato e il Corallo Magistrale risiede nella dimensione e nell\'uso che se ne fa. Ma, ahimé, un ammasso di Coralli consumati non sostituirà mai un solo Corallo Magistrale.",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Corallo Kuraçao",t:51,d:"La colorazione eccellente di questo corallo deriva dall\'alimentazione sregolata del Crustorallo. Eccone un altro che ha dimenticato di mangiare la sua razione di frutta e verdura!",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Corallo Malibù",t:51,d:"La colorazione eccellente di questo corallo deriva dall\'alimentazione sregolata del Crustorallo. Eccone un altro che ha dimenticato di mangiare la sua razione di frutta e verdura!",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Corallo Passaoh",t:51,d:"La colorazione eccellente di questo corallo deriva dall\'alimentazione sregolata del Crustorallo. Eccone un altro che ha dimenticato di mangiare la sua razione di frutta e verdura!",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Corallo Morito",t:51,d:"La colorazione eccellente di questo corallo deriva dall\'alimentazione sregolata del Crustorallo. Eccone un altro che ha dimenticato di mangiare la sua razione di frutta e verdura!",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Cuore di pietra levigato",t:51,d:"L\'unica cosa che distingue un cuore di Croccaroc da un cuore di Croccaroc levigato è la delicatezza con la quale questo oggetto può schiacciarti le dita dei piedi quando meno te lo aspetti.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Palla levigata",t:51,d:"Di quale parte dell\'anatomia del Croccabul proviene questa palla? E perché se ne ritrovano spesso due?",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Sacrum magistrale",t:47,d:"Se il Corallaro ti offriva un osso del suo sedere, il Corallaro Magistrale ti permette di usufruire di un\'altra parte della sua anatomia, ma situata più o meno nella stessa zona.",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Omero dello Sparo",t:47,d:"Anche se lo si chiama Omero, niente ci dice che quest\'osso appartenga veramente al braccio di Sparo. Come tutto il suo scheletro, è stato ridotto in briciole dalle spade che hanno trapassato la botte.",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Gengiva del Flib",t:47,d:"Fossi in te, non raccoglierei questo oggetto uscito da una bocca dall\'igiene abbastanza dubbia. Ma fai come vuoi, sei tu l\'avventuriero!",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Becco del Kido",t:47,d:"Il becco del Kido è così fragile che i discepoli di Otomai se ne servivano per costruire frecce di allenamento dalla punta smussata che non provocassero troppi danni.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Pinza di Crustorallo",t:47,d:"Evita di stringere la pinza del Crustorallo! Rischi di perdere la mano per un semplicissimo gesto di educazione!",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Petalo Kuraçao",t:35,d:"Dal colore di questo petalo si capisce chiaramente la sua provenienza. L\'abuso di alcool da parte dei discepoli di Otomai si riscontra persino nelle loro creazioni.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Petalo Malibù",t:35,d:"Dal colore di questo petalo si capisce chiaramente la sua provenienza. L\'abuso di alcool da parte dei discepoli di Otomai si riscontra persino nelle loro creazioni.",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8747] = {n:"Petalo Passaoh",t:35,d:"Dal colore di questo petalo si capisce chiaramente la sua provenienza. L\'abuso di alcool da parte dei discepoli di Otomai si riscontra persino nelle loro creazioni.",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Petalo Morito",t:35,d:"Dal colore di questo petalo si capisce chiaramente la sua provenienza. L\'abuso di alcool da parte dei discepoli di Otomai si riscontra persino nelle loro creazioni.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Bulbo Kuraçao",t:36,d:"Il Palmifiore non nasce da un seme ma da un bulbo che si annaffia con l\'alcool. Perché? E boh!",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Bulbo Malibù",t:36,d:"Il Palmifiore non nasce da un seme ma da un bulbo che si annaffia con l\'alcool. Perché? E boh!",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Bulbo Passaoh",t:36,d:"Il Palmifiore non nasce da un seme ma da un bulbo che si annaffia con l\'alcool. Perché? E boh!",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Bulbo Morito",t:36,d:"Il Palmifiore non nasce da un seme ma da un bulbo che si annaffia con l\'alcool. Perché? E boh!",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Criniera fiorita",t:36,d:"Strano ibrido tra peli e petali di fiori, questa criniera è un doppio allergene. Se sei sensibile ai suoi due elementi, cerca di starne lontano... potresti espellere il cervello starnutendo.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Barba inesistente del Barbrussa",t:54,d:"Questo minuscolo ciuffo di peli ti ricorderà le vacanze grazie al suo odore di sabbia, di prodotti solari e di alcool. Peccato che puzzi tanto di polvere!",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Ciuffo rosso del Flib",t:54,d:"Non si è mai saputo se il colore di questo ciuffo fosse naturale o se causato da un incendio intempestivo.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Pelliccia del Kilibriss",t:54,d:"Grazie alla sua leggerezza la pelliccia di Kilibriss è molto ricercata per la fabbricazione dei materassi. Ecco perché, aspettando la creazione di una specie di materassi viventi da uccidere durante i safari, gli artigiani si dedicano con fervore alla caccia al Kilibriss.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Canottiera di Barbrussa",t:15,d:"Bisogno di un insetticida? Usa la Canottiera del Barbrussa! Ma rinuncia però a ogni ulteriore contatto con il genere umano.",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Pezzo di calzone di Gurlo",t:15,d:"Non è mai stato possibile ritrovare un calzone di Gurlo intatto. A forza di giocare con la polvere, riesce sempre a farla esplodere.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Forziere maledetto del Flib",t:15,d:"Questo forziere ha preso la forma del Flib, a meno che non sia il contrario... Comunque sia, rimane un forziere maledetto.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Foulard dello Sparo",t:15,d:"Accessorio di moda indispensabile in estate come in inverno, questo foulard ti darà un look originale, ma un po\' kitsch. Grazie al suo colore sgargiante, sarai sicuro di eccitare i maschi di pappatutto. Ma è veramente quello che vuoi?",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Polvere esplosiva di Gurlo",t:48,d:"Gurlo non uscirebbe mai di casa senza la sua arma, piuttosto se la farebbe incollare al braccio. Purtroppo non è mai capace di sparare abbastanza velocemente perché deve sempre aspettare che la polvere si secchi. Prova della sua cattiva qualità.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Frammento di cervello pulito",t:50,d:"Grazie a questo frammento di cervello, potrai finalmente imparare le buone maniere dei Croccaroc: stritolamento di mano come buongiorno.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Baffi del Mufafah",t:15,d:"Più folti di quelli dei pesci micino, i baffi del Mufafah possono servire per costruire i pennelli del pittore Marylork.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Sopracciglia del Rasbul maggiore",t:15,d:"Per dimostrare di essere il Boss, il Rasbul maggiore aggrotta sempre le sopracciglia, tanto che gli restano così anche dopo la morte.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Bastone del Kilibriss",t:15,d:"Grazie alla sua lunghezza questo bastone ti permetterà di arrivare in tutti i posti difficilmente raggiungibili, e di grattarti dappertutto...",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Piuma del sedere del Kido",t:53,d:"Questa risorsa è servita per creare uno dei più grandi enigmi di Otomai: cos\'è più pesante? Cento pods di piume di Kido o cento pods di Pyruta?",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Ala del Bituf delle Pianure",t:104,d:"Il Bituf non è mai stato famoso per le sue capacità di volo. Considerate le sue ali non poteva essere altrimenti...",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Orecchio strappato di Pumbaa",t:106,d:"Mettendo questo orecchio sopra il tuo, potrai sentire il cinghiale delle pianure al galoppo... e non il suono del mare.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Cocco del Bituf delle Pianure",t:111,d:"In questo Cocco di Bituf non c\'è latte, ma succo di cervello con qualche neurone che galleggia in superficie.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Corteccia di Tynril",t:96,d:"Questa corteccia è curiosamente storta, come se la si fosse ottenuta con una grattugia.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Corteccia di Floribond",t:96,d:"Questa corteccia è curiosamente storta, come se la si fosse ottenuta con una grattugia.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Corteccia di Brutbrut",t:96,d:"Questa corteccia è curiosamente storta, come se la si fosse ottenuta con una grattugia.",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Corteccia di Nerba",t:96,d:"Questa corteccia è curiosamente storta, come se la si fosse ottenuta con una grattugia.",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Corteccia di Fecorza",t:96,d:"Questa corteccia è curiosamente storta, come se la si fosse ottenuta con una grattugia.",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Corteccia di Gramigna",t:96,d:"Questa corteccia è curiosamente storta, come se la si fosse ottenuta con una grattugia.",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Cocco del Bituf Oscuro",t:111,d:"In questo Cocco di Bituf non c\'è latte, ma succo di cervello con qualche neurone che galleggia in superficie.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Pistilli di Tynril",t:36,d:"I fiori corrispondono agli organi sessuali delle piante. Se il pistillo fa parte del fiore... traine le conclusioni che vuoi.",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Stame di Floribond",t:36,d:"Lo stame è l\'organo maschio di riproduzione dei vegetali. E sì, nonostante le apparenze, Floribond è un maschietto...",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Carpello di Brutbrut",t:36,d:"I fiori corrispondono agli organi sessuali delle piante. Se il pistillo fa parte del fiore e il carpello e un elemento del pistillo, traine le conclusioni che vuoi.",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Sepalo di Nerba",t:36,d:"Questa parte del corpo di Nerba resta sempre verde. È dovuto all\'eccesso di clorofilla o ad altro?",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Calice di Fecorza",t:36,d:"Non è utilizzando il calice di Fecorza che riuscirai a bere qualcosa... Non ti sei accorto del buco?",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Brattea di Gramigna",t:36,d:"La Brattea di Gramigna corrisponde a una zona che la morale ci impedisce di nominare.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Tonsille del Bituf Oscuro",t:15,d:"Una volta senza tonsille, il Bituf oscuro è molto più docile e tranquillo. Normale! Di solito questa operazione ne provoca la morte.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Tallone d\'Achille dell\'Alberaklur Oscuro",t:15,d:"Non vincerai l\'Alberaklur Oscuro colpendolo con una freccia sul Tallone d\'Achille. Ma puoi sempre provarci se vuoi...",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Seme dell\'Alberaklur Oscuro",t:58,d:"Con molta pazienza, tempo, acqua e concime, forse riuscirai a far crescere un Alberaklur nel tuo giardino per usarlo come avversario d\'allenamento. Ma è più semplice andare direttamente a combatterli sull\'isola di Otomai.",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Treccia del Poolay",t:15,d:"Questa treccia ruvida e spessa può essere usata sia come riportino che come straccio, per questo dovrai lavarla più e più volte.",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Cloaca del Poolay",t:15,d:"No, non è disgustoso, è la natura!",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Sedere del Bituf aereo",t:15,d:"Questo didietro ti permetterà di creare degli oggetti per non avere più il sedere per aria.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Calze del Kimbo",t:15,d:"Malgrado le apparenze, Kimbo indossa proprio delle calze, ma non ai piedi. Preferisce arrotolarle e ficcarle in un luogo strategico.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Imbottitura di Mopet",t:15,d:"La Natura non è stata gentile con Mopet, per questo deve usare qualche trucchetto per apparire più formosa. A volte se ne serve anche per imbottire un po\' il suo materasso.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Stoffa di Mopet",t:55,d:"Questa stoffa ha una consistenza un po\' strana ma veste in un batter d\'occhio qualsiasi mostro un po\' pudico.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Cocco del Bituf Aereo",t:111,d:"In questo Cocco di Bituf non c\'è latte, ma succo di cervello con qualche neurone che galleggia in superficie.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Guscio di Kaskargo",t:111,d:"Rotondo e splendente allo stesso tempo, questo guscio è stato lucidato con la bava per molti secoli. Che c\'è da stupirsi?",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Parrucca del Kimbo",t:54,d:"Per mascherare il principio di calvizie, Kimbo mette questa parrucca ridicola. Per fortuna la noce di cocco la nasconde quasi totalmente.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Nodo dell\'Alberaklur chiaro",t:38,d:"È a causa di questo oggetto che molte persone soprannominano l\'Alberaklur: \"testa di nodo\".",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Ceppo dell\'Alberaklur Chiaro",t:38,d:"Un ceppo diverso dagli altri, e in più gira come una trottola!",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Coda piumata del Rasbul Maggiore",t:65,d:"Le piume di Rasbul sono incollate sulla sua coda, una a una, anno dopo anno. Più la coda è piena, più il Rasbul è vecchio.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Peli d\'ascella di Pumbaa",t:54,d:"Anche se se li rade spesso, i peli ricrescono sempre duri e con un odore rancido. Hai visto che non è sempre colpa del sudore!",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Stoffa Zoth",t:55,d:"Questa stoffa, fatta con una materia tanto resistente quanto morbida, si adatta perfettamente alla silhouette degli Zoth per nasconderne l\'essenza.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Stoffa di Cencio",t:55,d:"Questa stoffa ha più buchi di un groviera, ma è capace di assorbire un sacco di rifiuti per rigurgitarli poi al momento opportuno.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Tibia del Guerriero Zoth",t:47,d:"Come tutte le altre ossa del Guerriero Zoth, questa tibia ha subito molteplici fratture. Si è risaldata perfettamente ed è diventata più resistente. Visto? Se avesse potuto parlare, anche lei avrebbe detto: \"Quel che non uccide, rende più forti\".",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Rotula del Discepolo Zoth",t:47,d:"A forza di dare dei colpi col ginocchio, la rotula del Discepolo Zoth è diventata molto resistente e molto più grossa. Tra un po\' potrai addirittura usarla per giocare a bocce.",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Cerniera del Maestro Zoth",t:15,d:"La cerniera del Maestro Zoth è di enorme valore ed è stata appositamente concepita per non tirare la pelle. Gli avventurieri che sono stati già traumatizzati da questo tipo di esperienza sanno di cosa stiamo parlando.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Fazzoletto della Marmocchia Zoth",t:15,d:"La Marmocchia Zoth non usa questo fazzoletto per gli addii pieni di lacrime, ma per asciugarsi dal sangue dei suoi nemici.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Stemma del Sergente Zoth",t:15,d:"Offertogli dalla madre e cucito su una stoffa, questo stemma è un bel ricordo d\'infanzia prima di essere un\'insegna militare.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Succo di Cencio",t:15,d:"A meno che non tu non sia ubriaco, non puoi confondere questo succo con qualsiasi altro liquido potabile. L\'odore nauseabondo dissuaderebbe anche un cieco dal berne un sorso.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
I.u[8808] = {n:"Stoffa del Re Cencio",t:55,d:"Questa stoffa è più bucata di un gruviera, ma è comunque capace di assorbire un sacco di detriti. \"Dove questa stoffa passa, la sporcizia trapassa\".",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"Mutande al contrario del Re Cencio",t:15,d:"Da quando il Re Cencio Dagobert diede il via a questa moda, tutti i Re Cencio portano le mutande al contrario. L\'importante è che questa pratica non gli rivolti anche lo stomaco.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Torba secca di Fyench",t:15,d:"Questa torba, fatta di vegetali in decomposizione, ha un potere quantomeno strabiliante. Le Mamy Bwork la usano infatti per risolvere un problema mensile.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Falso mento del Myench",t:15,d:"Il Myench passa molto tempo nei bagni di fango sperando di dimagrire. Ma invece di perdere peso, non ha guadagnato altro che un doppio mento che si abbina al resto della sua figura.",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Inchiostro del Kralamore gigante",t:15,d:"Viscoso e ricoprente, l\'inchiostro di Kralamore può essere utilizzato per scrivere o dipingere i muri della camera di un depresso.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Ventosa del Kralamore gigante",t:15,d:"Date le sue dimensioni, l\'aderenza di questa ventosa dev\'essere eccellente. Inoltre, quando la si stacca il rumore è tonante.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Borsa di 5000 Kama",t:100,d:"Questa borsa è molto pesante, contiene sicuramente una grande fortuna.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Borsa di 1000 Kama",t:100,d:"Questa borsa è molto pesante, contiene sicuramente una grande fortuna. Un mercante sarebbe entusiasta di scambiarla contro il suo valore in kama.",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Regalo Spada che Scoreggia",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Regalo Cappello Satanasso",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"Mantello Sovrano del Re Cencio",t:17,d:"Fatto con una stoffa di Re Cencio, questo mantello ha dei micro buchi che permettono una migliore traspirazione in caso di sforzo intenso, come ad esempio una mischia bellicosa in una palude. Questo mantello lascia passare l\'umidità ma trattiene il calore, così resterai asciutto in qualsiasi situazione. Peccato che il persistente odore di marcio sia inalterabile.",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Mantello del Cencio",t:17,d:"Meno forte del mantello del Re Cencio questo mantello ha comunque la stessa caratteristica di traspirazione. Potrai far fronte ad ogni genere di situazione... se riesci a combattere in apnea, perché visto l\'odore che emana è veramente impossibile non svenire.",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Maschera del Sergente Zoth",t:16,d:"Grazie a questa maschera, affronterai tutti i pericoli senza alcuna paura! Normale, visto che blocca tutto il campo visivo...",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Copricapo del Discepolo Zoth",t:16,d:"Da lontano questo copricapo assomiglia ad un abat-jour con due buchi per gli occhi. Ed anche da vicino...",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Maschera dell\'Alberaklur Chiaro",t:16,d:"Questa maschera non permette né di prevenire né di guarire la sbornia, ma almeno ti dà la possibilità di dissimularla in modo elegante.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Maschera dell\'Alberaklur Oscuro",t:16,d:"Questa maschera non permette né di prevenire né di guarire la sbornia, ma almeno ti dà la possibilità di dissimularla in modo elegante. La sfumatura un po\' oscura indica solo che non sei di buon umore e che, se qualcuno cerca rogne, non ci metterai molto ad accontentarlo scagliando su tutti una raffica di legno verde.",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Kaskargo",t:16,d:"Con questo sulla testa, assomiglierai proprio a un Kaskargo. Ti proteggerà sicuramente dai colpi alla testa, ma c\'è bisogno di strisciare così? Mica ne hai bisogno per camminare!",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Mazza del Corallaro Magistrale",t:7,d:"Più grande, più forte, più potente, e anche più rumorosa quando si abbatte sui nemici, stranamente questa mazza è più ergonomica e più leggera da maneggiare. Il Corallo usato per fabbricarla, però, non era per niente magistrale.",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Martello della Marmocchia Zoth",t:7,d:"Malgrado le piccole dimensioni, la Marmocchia Zoth va in giro con un enorme martello! È un modo come un altro per fare un po\' di ginnastica e rinforzare la muscolatura. Nessun bisogno di attaccare pesi ai piedi o ai polsi, basta trascinare questo martello!",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Ascia del Guerriero Zoth",t:19,d:"Il Guerriero Zoth ha preso l\'abitudine di portare due asce, perché è incapace di colpire il fianco sinistro del nemico con la sua mano destra. Problema ortopedico o goffaggine congenita? Difficile a dirsi. Ma con le sue due asce mette a ferro e fuoco tutti i boschi, quando non deve stare a casa a tagliare la legna per il fuoco...",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Parrucca del Poolay",t:16,d:"Il Poolay è un volatile incapace, vivace quanto una gallina colpita da influenza aviaria e intelligente quanto un Tofu. Tanto vale dire che non sopravviverà molto. Sembra che certi adorino la sua curiosa capigliatura che ricorda lo straccio intrecciato di una massaia teutonica. La natura umana è proprio strana.",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Cappello di Barbrussa",t:16,d:"Questo cappello era abbastanza grande da nascondere la testa e la barba scandalosamente calve di Barbrussa, ma non è sicuramente capace di coprire il cranio di chi si è montato la testa.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8830] = {n:"null",t:16,d:"",ep:0,g:198,l:1,wd:false,fm:true,w:1,p:1};
I.u[8832] = {n:"Bava del Kaskargo",t:15,d:"La bava di Kaskargo non potrà mai raggiungere le piume del Bituf, ma potrà incollarti al suolo!",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Mazza del Corallaro",t:7,d:"Questo martello prende il suo grazioso colore dai pezzi di Corallo che lo compongono. Contrariamente a quello che si può pensare, non serviva a schiacciare gli Yop o i nemici, ma si tratta di un oggetto artigianale lasciato in eredità da un\'altra civiltà. Questa mazza serviva da battiporta per le persone che avevano problemi di udito e non sentivano i visitatori che bussavano.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Ramo dell\'Alberaklur Oscuro",t:3,d:"Questo ramo serviva a raschiare certe parti del corpo altrimenti inaccessibili. Ma non preoccuparti, il colore scuro è originale e non ha nessun rapporto con il materiale contenuto nelle cavità meno accessibili dell\'Alberaklur.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Ramo dell\'Alberaklur Chiaro",t:3,d:"Questo ramo serviva a raschiare certe parti del corpo altrimenti inaccessibili, il che forse spiega lo strano odore di questo ramo.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Stelo di Brutbrut",t:4,d:"Le Brutbrut usano il loro stelo per pulirsi le orecchie. Gli Intagliatori di bastoni preferiscono usarli come arma. Insomma, i gusti non si discutono.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Bastone del Maestro Zoth",t:4,d:"Il Maestro Zoth è capace di battere chiunque con questo bastone. Nessun avversario gli fa paura! Normale, visto che con il suo copricapo non vede assolutamente niente e non può essere terrorizzato da nessun nemico. Questa tecnica è molto pratica in combattimento ma tragicamente imbarazzante durante i pasti. Con un campo visivo così limitato il Maestro Zoth ha sempre avuto un sacco di problemi per mangiare senza sbrodolarsi come un bambino.",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Rizoma di Tynril",t:4,d:"Come l\'erba cattiva, il Tynril è capace di riprodursi all\'infinito grazie a un semplice pezzo di rizoma. Partendo da questa constatazione certi Intagliatori hanno creato un bastone a base di Tynril. Speravano così di poterlo riprodurre più facilmente e a basso costo per rivenderlo al miglior offerente. Ma fu un fallimento.",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Maschera Vudù Thierry",t:16,d:"Questa maschera Vudù serve essenzialmente per nascondere il viso dei Kannibul che amano usare la fionda ma che sbagliano spesso bersaglio. Ecco perché sono sempre verdi di rabbia.",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Maschera Vudù Jav",t:16,d:"I Kannibul Jav hanno spesso il magone quando guardano il cielo. Sarà dovuto a una vecchia storia d\'amore? Sarà a causa del colore blu, e delle nuvole? Insomma, scoprirlo è difficile, ma sarebbe meglio che si accontentassero di indossare la maschera smettendo di cantare la loro malinconia.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Maschera Vudù Sarbak",t:16,d:"Questi Kannibul riuscivano ad allenarsi solo colpendo dei bersagli gialli... Quando si accorsero del colore della loro maschera cominciarono a ridere a crepapelle, ma si vedeva che si sforzavano!",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Maschera Vudù Arciere",t:16,d:"I Kannibul Arcieri riescono a concentrarsi e a mirare bene solo quando sono arrabbiati, e il colore che odiano di più e il rosso. Per questo hanno dipinto la loro maschera di rosso... logico, no?",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Cappello di Coccodrail Dandy",t:16,d:"Con questo cappello sulla testa, il Coccodrail pensa di essere all\'ultima moda. In realtà dovrebbe essere proprio l\'ultima perché ciò sia possibile. Ma è meglio evitare di fare commenti ridicoli, il Coccodrail è molto permaloso...",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"Cappuccio Sovrano del Re Cencio",t:16,d:"Cappuccio reale, questo cappuccio possiede le stesse virtù del Mantello Sovrano del Re Cencio. Le sue microareazioni contribuiscono a una migliore traspirazione per avere sempre il sangue freddo. Ma purtroppo ha gli stessi difetti del mantello: il suo odore nauseante è così forte che si potrebbe quasi tagliare con un coltello.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Cappuccio del Cencio",t:16,d:"Meno efficace del Cappuccio Sovrano, questo copricapo consente tuttavia una buonissima traspirazione. Un po\' troppo, in realtà. Alla fine, se indossi o no questo cappuccio, non fa alcuna differenza.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Cappello della Marmocchia Zoth",t:16,d:"Il cappello della Marmocchia Zoth ha la caratteristica di farle vedere le cose doppie. Così quando vede una persona della tribù... saluta due volte.",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Elmo del Guerriero Zoth",t:16,d:"Questo elmo ha gli stessi vantaggi degli altri copricapi Zoth: protegge dai colpi di sole persino in piena canicola, ammortizza i colpi ricevuti in testa, e impedisce di rendersi conto del pericolo restringendo il capo visivo di chi lo porta. Insomma... è l\'elmo ideale per un guerriero.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Copricapo del Maestro Zoth",t:16,d:"Il copricapo del Maestro Zoth possiede l\'immenso vantaggio di ridurre ancora di più il campo visivo rispetto agli altri elmi. È grazie a questo oggetto che si può accedere alla tecnica di combattimento detta \"della faina\". A grandi linee basta colpire un po\' ovunque con tutta la forza possibile. Essendo così imprevedibile sarai sicuro di battere l\'avversario (o almeno di sorprenderlo abbastanza per dargli un bel po\' di calci dove se li merita!).",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Radice di Fecorza",t:4,d:"Questo bastone va molto di moda presso le donne tronco. Ma se vuoi cercare di sedurre un altro tipo di donna, sei libero di farlo (anche se sarà un po\' meno efficace).",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Radice di Floribond",t:4,d:"Se sei un maniaco del profumo, con questa radice, oltre ai tuoi nemici potrai combattere anche i cattivi odori! Infatti profumerà le tue vittorie con un gradevole aroma floreale.",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"Worn Treasure Map",t:24,d:"Event Shika",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"Crack Sparrow\'s Own Withered Hat",t:16,d:"Event Shika",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"Scudo Fi\'Squal",t:82,d:"Sicuramente questo scudo ti assicurerà una buona protezione, ma non illuderti, non durerà a lungo.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Cintura Rasbulare del Rasbul",t:10,d:"Quando al Rasbul girano le palle, mette la sua cintura Rasbulare per mandare a quel paese tutti i rompipalle.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Stivali Straccio",t:11,d:"Questi stivali emettono un immondo rumore di suzione a ogni passo. Purtroppo ti ricordano il canto d\'amore dei Trooll in calore... un ricordo di cui avresti volentieri fatto a meno.",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"Sigillo Sovrano del Re Cencio",t:9,d:"Questo sigillo designa chi lo possiede come sovrano incontestato della Torbiera senza fondo dell\'Isola di Otomai. È difficile immaginare un regno più bucolico.",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Fede di Corallo",t:9,d:"Questo anello è stato strappato dal dito ancora caldo di un giovane Corallaro appena massacrato. Sua madre l\'aspettava per mangiare, fino a quando non si accorse che il suo rampollo era stato trasformato in pietra tombale. Anche il corallo ha un cuore, e non per forza di pietra.",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Sandali Circolari del Kimbo",t:11,d:"Solo il Kimbo e i suoi piedi assolutamente strambi possono trovarsi bene in questi sandali. In compenso non è l\'unico a poter sfruttare la loro potenza. Attenzione però a non sbagliarti di senso infilandoli!",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Cintura Bitufale di Prosper Youpla",t:10,d:"Prosper Youpla era convinto di poter volare grazie a questa cintura ornata di ali di Bituf. Ignorando che pochissimi Bituf sanno volare, si lanciava dall\'alto dell\'albero Hakam e si spiaccicava sistematicamente per terra, tanto da essere soprannominato \"Boom\".",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothuleto",t:1,d:"Questo amuleto non è che un volgare pezzo di legno e di tessuto strappato, ma gli Zoth credono che abbia dei poteri incredibili. Poveri pazzi!",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Kask\'Ar Co",t:2,d:"La corda di quest\'arco è fatta di bava di Kaskargo che ha un\'elasticità senza precedenti. La sua consistenza appiccicaticcia e viscosa invece ricorda... non si sa bene cosa in realtà, ma sicuramente non è piacevole.",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Anello Skargo",t:9,d:"Intagliato in un carapace di Kaskargo, quest\'anello resiste a qualsiasi cosa e a chiunque.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Potente Mantello Folgorante",t:17,d:"Tessuto con stoffe di Zoth, questo mantello possiede un potere straordinario la cui origine resta ancora sconosciuta.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Mantello della Mopet",t:17,d:"Portando questo mantello, avrai una voglia incontrollabile di aceto!",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Poolascia",t:19,d:"Il becco di Poolay che orna quest\'arma non serve assolutamente a niente, anzi mette in difficoltà chi la usa.\nFortunatamente è un\'arma potente... almeno quello.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Stivaletti in legno di Alberaklur",t:11,d:"Questi stivali sono così pesanti che dovrebbero essere classificati tra le armi. Un calcio ben dato con questi stivali, infatti, potrebbe essere fatale.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Cintura Oscura di Alberaklur",t:10,d:"Questa cintura, intagliata in un Alberaklur oscuro, non è abbastanza flessibile per permettere di muoversi liberamente, ma almeno protegge bene.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Cintura Chiara di Alberaklur",t:10,d:"Intagliata in un Alberaklur chiaro, questa cintura non protegge molto ma almeno è abbastanza flessibile per muoversi liberamente.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Palmano",t:9,d:"Questo gioiello non è molto prezioso ma ha le dimensioni ideali per dosare il murgal in un buon belgruth alla glaviuz!",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Krustontura",t:10,d:"Finalmente una buona scusa per puzzare di mare!",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Cencios",t:1,d:"Questo gioiello cerca a volte di rubarti il cibo durante i tuoi pasti, vedi di non lasciargli troppa libertà.",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Velo d\'Inchiostro",t:17,d:"Questo strano mantello sembra fatto di inchiostro nero. Si comporta come una stoffa, non cola, in compenso però macchia. Il tuo sedere non è mai stato così sporco.",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Kralano",t:9,d:"Attenzione: una volta infilato, le sue potentissime ventose ti impediranno di toglierlo.",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kidortello",t:7,d:"Questo martello non è pratico, non è bello, non è ergonomico, non è potente, non è abbastanza pesante, non è resistente, non è equilibrato. Ma è colorato! Ci vuole proprio un po\' di colore in questo mondo di bestie!",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
I.u[8879] = {n:"Anello Levigato",t:9,d:"Sfortunatamente questo anello è levigato solamente all\'esterno. L\'interno infatti è fatto di schegge di roccia acuminate. Consigliato ai Sàcridi.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Amufafah",t:1,d:"Questa collana dà a colui che la indossa una voglia pazza di urlare, semplicemente perché i baffi del Mufafah che la ornano gli solleticano i capezzoli.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Anello Solo",t:9,d:"Solo era un simpatico mascalzone, e se lo diceva da sé. Morì impiccato nella piazza del villaggio dopo aver rubato le mutandine della moglie del capo. Solo non era molto furbo, ma era bravo poverino...",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Pozione di Focolare di Gilda",t:12,d:"Questa Pozione ti permetterà di ritornare in qualsiasi momento al tuo focolare di gilda.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Fantasma di Maomao Tigrato",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Trasformazione Fantasma Maomao Tigrato",t:27,d:"Sei stato trasformato in fantasma per poter entrare nel Santuario dei famigli.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8887] = {n:"Certificato di Deposito al Cianil: Maomao Tigrato",t:77,d:"Questo Certificato descrive le caratteristiche del Maomao Tigrato che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8888] = {n:"Certificato di Deposito al Cianil: Scoiattolo Furfante",t:77,d:"Questo Certificato descrive le caratteristiche dello Scoiattolo Furfante che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8889] = {n:"Certificato di Deposito al Cianil: Leopardo",t:77,d:"Questo Certificato descrive le caratteristiche del Leopardo che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8890] = {n:"Regalo Maomao Tigrato",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8891] = {n:"Regalo Scoiattolo Furfante",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8892] = {n:"Regalo Leopardo",t:89,d:"Appoggiando l\'orecchio su questo regalo o scuotendolo con forza, potrai sentire dei rumori strani che ti riveleranno la presenza di una creatura ancora viva al suo interno. Non perdere un solo istante, aprilo subito, troverai un fantastico famiglio, delle risorse per nutrirlo e delle polveri d\'Aniripsa per curarlo.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
