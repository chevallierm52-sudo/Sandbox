I.u[2319] = {n:"null",t:65,d:"",ep:0,g:461,l:40,wd:true,fm:true,w:1,p:1};
I.u[2320] = {n:"Collana Rotta di Uginak",t:15,d:"Come ogni Uginak che si rispetti, la sua Collana dà delle informazioni. C\'è scritto: \"Mi sono perso, il mio quartiere si trova sul sentiero delle Lande di Sidimote, per favore riportami dai miei padroni Brakmariani, ti ricompenseranno con degli schiaffi\".",ep:14,g:462,l:51,wd:true,fm:true,w:5,p:1};
I.u[2321] = {n:"Labbra di Uginak",t:15,d:"Hai come l\'impressione che le Labbra di Uginak possano produrre bava in eterno. Forse perché questo animale è famoso per la sua ghiottoneria senza fine.",ep:14,g:463,l:51,wd:true,fm:true,w:1,p:1};
I.u[2322] = {n:"Zanne di Ratto",t:47,d:"Non ti fare ingannare da questi piccoli denti, sono vere e proprie zanne affilate, vecchie e puzzolenti! A volte si usano per sostituire i denti d\'oro degli Anutrof un po\' troppo tirchi.  ",ep:1,g:464,l:50,wd:true,fm:true,w:1,p:1};
I.u[2323] = {n:"Colonna Vertebrale",t:47,d:"Questa è una Colonna Vertebrale di alta qualità, ma non è il caso comunque di rompersi la schiena.",ep:1,g:465,l:34,wd:true,fm:true,w:2,p:1};
I.u[2324] = {n:"Cocomero",t:46,d:"...",ep:1,g:466,l:1,wd:true,fm:true,w:2,p:1};
I.u[2325] = {n:"Banana",t:46,d:"Il famoso menestrello Ciro Lindorma compose tempo fa un\'ode in onore di questo frutto: \"La banana delle persone felici\".",ep:1,g:467,l:1,wd:true,fm:true,w:1,p:1};
I.u[2326] = {n:"Arancia",t:46,d:"...",ep:1,g:468,l:1,wd:true,fm:true,w:1,p:1};
I.u[2327] = {n:"Mela",t:46,d:"...",ep:1,g:469,l:1,wd:true,fm:true,w:1,p:1};
I.u[2328] = {n:"Piccola Perla Dorata",t:15,d:"Questa perla dorata è un regalo della piccola larva che porti con te. Ha dunque un grande valore sentimentale per te, e il suo colore e la sua dolcezza ne fanno il regalo ideale per una persona che abbia un minimo di femminilità.",ep:5,g:483,l:1,wd:true,fm:true,w:1,p:1};
I.u[2329] = {n:"Pera",t:46,d:"...",ep:1,g:470,l:1,wd:true,fm:true,w:1,p:1};
I.u[2330] = {n:"Capsula Esplosiva",t:15,d:"Questa capsula esplosiva contiene estratti di agrumi magici. Si consiglia di agitarla prima dell\'uso per non lasciare la polpa sul fondo.",ep:4,g:711,l:23,wd:true,fm:true,w:1,p:1};
I.u[2331] = {n:"Melanzana",t:46,d:"Relativamente nutritiva, è accompagnata spesso da ogni tipo di condimento. Questo legume ha una cattiva reputazione nonostante faccia bene alla salute, a parte a quella dei Bwork... ma nessuno sa perché.",ep:1,g:472,l:1,wd:true,fm:true,w:1,p:10};
I.u[2332] = {n:"Caramella di Consolazione",t:42,d:"Questa caramella ti ha permesso di non piangere.",ep:13,g:135,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2333] = {n:"Caramella Rossa strapotente",t:42,d:"Questa caramella aumenta la tua concentrazione durante il combattimento, ma sfortunatamente ha un gusto orribile. (DOPPIO CLIC PER USARLA, bonus di 20 punti Saggezza e 10 punti Prospezione per i prossimi 30 combattimenti).",ep:1,g:136,l:1,wd:true,fm:false,w:1,c:"PO!1723",u:true,p:1};
I.u[2334] = {n:"null",t:42,d:"",ep:0,g:137,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[2335] = {n:"null",t:42,d:"",ep:0,g:138,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2336] = {n:"Cranio dello Chafer",t:47,d:"Questo cranio non scricchiolerà mai più... anche se...",ep:1,g:480,l:16,wd:true,fm:true,w:1,p:1};
I.u[2337] = {n:"Libro Magico",t:25,d:"Questo libro sembra magico. Strano...",ep:1,g:7,l:1,wd:true,fm:true,w:1,p:50};
I.u[2338] = {n:"Vecchio Libro",t:25,d:"...",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[2339] = {n:"Lista di equipaggiamento standard",t:24,d:"Un guerriero di valore medio non deve portare stracci ma neanche lustrini. Deve preferire:\n-Un cammeo o simile\n-Una fascia e una cintura di Vitalità\n-Stivali di Kluh\n-Un mantello Brakmariano",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2340] = {n:"Mutande di miliziano",t:24,d:"Queste sono proprio mutande di miliziano. Devi essere un gran feticista per possedere una cosa del genere. Oppure qualcuno ti sta facendo uno scherzo...",ep:2,g:84,l:1,wd:true,fm:true,w:0,p:1};
I.u[2341] = {n:"Arco di Mech Riorraw",t:2,d:"Quest\'arco è stato concepito da Mech Riorraw, è calibrato apposta per attraversare il fiume di lava e raggiungere la sommità delle mura di Brakmar, né più, né meno.",ep:16,g:8,l:10,wd:true,fm:true,w:100,an:10,tw:true,e:[0,6,20,21,0,30,false,true],c:"Ps=1",p:0};
I.u[2342] = {n:"Anello di Fedeltà",t:24,d:"Questo anello ti è stato dato da Domen. Restituirlo significherebbe desiderare la distruzione di tutto, e quindi che stai dalla parte di Djaul...",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[2343] = {n:"Bracciale di Djaul",t:24,d:"Questo braccialetto ti è stato dato da Djaul in persona. Portarlo significa condividere le sue idee.",ep:2,g:85,l:1,wd:true,fm:true,w:0,p:1};
I.u[2344] = {n:"Lettera per Oto",t:24,d:"Questa lettera ti è stata affidata da Domen per Oto.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2345] = {n:"Occhio di Tartaruga",t:24,d:"Questa tartaruga non sarà più cattiva adesso.",ep:2,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2346] = {n:"Vestito Ladrurbesco",t:14,d:"No, non è il famosissimo costume di Dragovamp, il famoso pipistrello volante. È la veste di un abitante del cimitero, un Ladrurbo insomma.",ep:1,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[2347] = {n:"Resoconto di missione",t:24,d:"Questo resoconto narra dell\'assalto al bastione est di Brakmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2348] = {n:"Attitudine Ladrurbo",t:31,d:"Avrai l\'attitudine Ladrurbo fino a quando non entrerai in combattimento.",ep:1,g:17,l:1,wd:true,fm:false,w:0,m:true,u:true,p:1};
I.u[2349] = {n:"Lettera per Oto",t:24,d:"Questa lettera ti è stata affidata da Domen per Oto, ma tu hai dimenticato di consegnarla.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2350] = {n:"Ciuffo di capelli",t:24,d:"Sembra che questo ciuffo di capelli appartenesse a uno dei tuoi nemici.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2351] = {n:"Pane del Pinchot",t:33,d:"In questo pane c\'è da bere e da mangiare, e strizzandolo bene potrai anche riempire una pinta di birra.",ep:16,g:13,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[2352] = {n:"Lettera di Danathor",t:24,d:"\"Devo parlarti, vieni da me appena hai un momento libero. A presto mio giovane amico\".",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2353] = {n:"Lettera di Larry Poller",t:24,d:"\"Buongiorno, sono Larry Poller, ci siamo conosciuti durante la liberazione del Colonnello Lyeno. Ho un favore da chiederti. Vieni da me quando hai un momento libero. A presto.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2354] = {n:"Cervello di Tartaruga",t:24,d:"Se cucinato correttamente, questo cervello di tartaruga è un piatto veramente succulento.",ep:2,g:89,l:1,wd:true,fm:true,w:0,p:1};
I.u[2355] = {n:"Polvere di Oni",t:24,d:"Questa polvere celeste è un catalizzatore magico molto potente.",ep:2,g:88,l:1,wd:true,fm:true,w:0,p:1};
I.u[2356] = {n:"Miracolo",t:31,d:"Avrai un potere miracoloso fino a quando non entrerai in combattimento.",ep:13,g:19,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2357] = {n:"Legno d\'Oliviola",t:38,d:"Questo legno sembra resistere a tutte le temperature. Non pensare minimamente di accendere un fuoco per riscaldarti, moriresti di freddo prima che il legno prenda.",ep:14,g:481,l:50,wd:true,fm:true,w:5,p:0};
I.u[2358] = {n:"Legno di Bombù",t:38,d:"Questo è il legno più tenero di tutti. È malleabile e veramente piacevole da lavorare.",ep:13,g:482,l:50,wd:true,fm:true,w:5,p:0};
I.u[2359] = {n:"Spilla di Heticili Ufot",t:24,d:"Questa spilla ti è stata data da Heticili Ufot.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2360] = {n:"Atto di proprietà",t:24,d:"È l\'atto di proprietà della casa di Heticili Ufot.",ep:2,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[2361] = {n:"Arco di Mulic Ber",t:2,d:"Quest\'arco è un\'invenzione del geniale Mulic Ber. La sua portata massima è quantomeno incredibile, il problema è che è quasi uguale a quella minima.",ep:16,g:10,l:10,wd:true,fm:false,w:100,an:10,tw:true,e:[0,6,17,23,0,30,false,true],p:0};
I.u[2362] = {n:"Predizione di Paro Cabanne",t:24,d:"La predizione che Paro Cabanne ha fatto sulle prossime elezioni.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2364] = {n:"null",t:50,d:"",ep:0,g:485,l:1,wd:true,fm:true,w:1,p:1};
I.u[2365] = {n:"Foglia di rovo d\'Hestia",t:36,d:"Questa foglia di rovo, dall\'aspetto inoffensivo, è una pianta indispensabile per certe strane ricette.",ep:16,g:415,l:1,wd:true,fm:true,w:1,p:1};
I.u[2366] = {n:"Canna da Kralamore",t:20,d:"Questa canna, fatta di metallo e diamanti, è la sola canna capace di sostenere il peso del Kralamore. Inoltre è impregnata dell\'odore della Kralamoretta che dà una possibilità in più di pescarlo.",ep:1,g:8,l:1,wd:false,fm:true,w:10,an:18,e:[2,6,1,9,30,30,false,false],p:1};
I.u[2367] = {n:"Lamil Eunotte",t:10,d:"Lamil sapeva farsi degli amici e li invitava spesso a grandi feste in maschera. Aveva anche la reputazione di mettere i piatti piccoli nei grandi e di regalare sontuosi gioielli per ringraziare della partecipazione alla serata.",ep:8,g:21,l:37,wd:true,fm:true,w:20,c:"CW>49&Ps=1",p:3700};
I.u[2368] = {n:"Ramum l\'Eterno",t:10,d:"Ramum era un vecchio amico di Nova. I due si sono persi di vista quando Ramum decise di fare un pisolino eterno.",ep:2,g:22,l:37,wd:true,fm:true,w:50,c:"CW>49&Ps=2",p:1000};
I.u[2369] = {n:"Potente Cintura Folgorante",t:10,d:"Questa magnifica cintura è stata confezionata in seguito a una pazza scommessa. La sfida era quella di migliorare una delle più belle cinture concepite ad Amakna: la Cintura Folgorante. La scommessa fu vinta da Pakape Prometeo.",ep:2,g:26,l:80,wd:true,fm:true,w:150,p:300000};
I.u[2370] = {n:"La Vegeta Tiva",t:10,d:"Equipaggiamento di una leggerezza incomparabile, la Vegeta Tiva conferisce un minimo di grazia in questo mondo di Bwork in calore.",ep:2,g:23,l:41,wd:true,fm:true,w:5,c:"CA>50",p:4575};
I.u[2371] = {n:"La Muthmu",t:10,d:"Questa cintura ti è consigliata da Jiva in persona, per le notti fredde e dure. In caso di macchie, si lava con la Rimerlana.",ep:13,g:24,l:27,wd:true,fm:true,w:30,p:2775};
I.u[2372] = {n:"Stivali di Lymphe A\'Tik",t:11,d:"Questi stivali danno l\'impressione di camminare costantemente nell\'erba fresca. Sono l\'ideale per tutti coloro cui l\'odore dei piedi assomiglia più a quello del Clakoss, piuttosto che a quello della Gelatina Menta.",ep:5,g:18,l:39,wd:true,fm:true,w:5,c:"CC>50",p:4100};
I.u[2373] = {n:"Moon Boot",t:11,d:"Il pelo di Moon, necessario per questo paio di stivali, è senza dubbio il pelo più caldo che ci sia per i piedi, anche se indossare questi stivali in ricordo di Moon ti scalderà di più il cuore.",ep:14,g:19,l:62,wd:true,fm:true,w:30,p:10000};
I.u[2374] = {n:"Stivali Tarsy",t:11,d:"Tarsy era un eremita a cui le visite non piacevano per niente. Infatti, accoglieva gli invitati mostrandogli la taglia dei suoi stivali da molto, molto vicino.",ep:4,g:20,l:38,wd:true,fm:true,w:40,p:4000};
I.u[2375] = {n:"Stivali Otori",t:11,d:"Grazie a questi stivali sarai in grado di sentire il vento tra le vele di una barca in mezzo al Mar di Asse, o di sentire i gemiti di uno Chafer Lanciere perso in fondo al labirinto.",ep:13,g:21,l:77,wd:true,fm:true,w:40,p:15500};
I.u[2376] = {n:"Ascia Hémal",t:19,d:"Questa ascia è l\'unica capace di resistere ai poteri del Kerlier ed è quindi l\'unica a poterlo tagliare.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,6,1,1,45,45,false,false],c:"PJ>2,79",p:1};
I.u[2377] = {n:"null",t:21,d:"",ep:0,g:1,l:1,wd:false,fm:true,w:10,e:[6,6,1,1,50,50,false,false],c:"PJ>24,79",p:1};
I.u[2378] = {n:"Sangue di Roccia",t:51,d:"Questa pietra color cremisi permette di fabbricare delle potentissime pozioni.",ep:16,g:459,l:1,wd:true,fm:true,w:0,p:1};
I.u[2379] = {n:"Legno di Kerlier",t:38,d:"Questo legno proviene dal rarissimo Kerlier. Le sue proprietà sono alquanto... strabilianti!",ep:14,g:140,l:40,wd:true,fm:true,w:5,p:20};
I.u[2380] = {n:"Mantello di Boo",t:17,d:"Questo mantello è molto strano, è fatto di pezzi di fango di Boo, ma sta comunque in piedi. Una volta indossato farà di te un bellimbusto.",ep:13,g:35,l:41,wd:true,fm:true,w:10,p:4500};
I.u[2381] = {n:"Mantello Galleggiante",t:17,d:"Questo mantello è stato ritagliato in una bandiera che era situata sulla più alta torre del castello di Amakna. È sicuramente per questo motivo che sa di biancheria stesa all\'aria aperta.",ep:5,g:36,l:61,wd:true,fm:true,w:10,c:"CI>90",p:9500};
I.u[2382] = {n:"Mantello Mempà",t:17,d:"Mempà era un Ecaflip che si beffava del vuoto, dicendo di poter sempre ricadere sulle proprie zampe. Ma un giorno, atterrò su un Trooll affamato. Fu seppellito il giorno stesso nel luogo in cui si trovarono i suoi resti... ovvero un po\' ovunque.",ep:14,g:37,l:36,wd:true,fm:true,w:10,p:6500};
I.u[2383] = {n:"Mantello Sanguigno",t:17,d:"A base di tessuto sanguigno, questo mantello è ruvido al tatto, come se la tintura si fosse coagulata.",ep:7,g:38,l:50,wd:true,fm:true,w:10,c:"CS>90",p:6000};
I.u[2384] = {n:"Stivali Animali",t:11,d:"Si può proprio dire che questi Stivali abbiano un lato quantomeno... hmmm... bestiale. Quindi non ti stupire se un Buulupo si innamora di loro, ma potrebbe essere la cosa peggiore che ti sia mai successa.",ep:14,g:22,l:94,wd:true,fm:true,w:40,p:23000};
I.u[2385] = {n:"La Bruterba",t:17,d:"Ideale per il giardino, la Bruterba può anche servire come zerbino per la porta d\'ingresso. All\'origine concepita per i Sadida, è fatta in modo da non rovinare i peli, neanche i più fragili. Alcuni dicono persino che ne rallenta la caduta.",ep:12,g:39,l:88,wd:true,fm:true,w:10,p:20000};
I.u[2386] = {n:"Lo Straccio",t:17,d:"Questo strano Mantello prende tutta la sua forza dal suo aspetto trasandato. Più sarà sporco... più ti sarà utile.",ep:13,g:40,l:53,wd:true,fm:true,w:10,p:7000};
I.u[2387] = {n:"La Pelosa",t:17,d:"Bisogna ammettere che questo mantello emana un odore sgradevolissimo. In poche parole si tratta semplicemente di un insieme di peli di mostri che creano questo magnifico pot-pourri.",ep:14,g:41,l:63,wd:true,fm:true,w:10,c:"CW>30&CV>50",p:10500};
I.u[2388] = {n:"L\'Amuleto del Puzzle dell\'Artiglio",t:1,d:"Tempo fa un Ecaflip chiamato Dodge ruppe in mille pezzi una mappa del tesoro incisa su una pietra. Mentre cercava di rimettere insieme i pezzi, decise di tenere il più grande per farne un amuleto. Nessuno sa che fine abbia fatto il tesoro.",ep:14,g:36,l:44,wd:true,fm:true,w:5,p:4000};
I.u[2389] = {n:"Amuleto del Badul",t:1,d:"Dodge adorava distruggere tutto quello che secondo lui valesse qualcosa. Diceva che era il suo modo di esistere. Ognuno ha il suo metodo, insomma...",ep:14,g:37,l:32,wd:true,fm:true,w:5,p:3200};
I.u[2390] = {n:"Amuleto della Palla",t:1,d:"Questo amuleto è quasi perfetto, accresce in modo considerevole la saggezza di colui che lo porta. È molto utile per farti sembrare più saggio davanti agli amici, o farti passare per un secchione.",ep:5,g:38,l:49,wd:true,fm:true,w:1,p:6400};
I.u[2391] = {n:"Amuleto della Papalla",t:1,d:"Un vecchio proverbio di Sufokia dice: \"Palla oggi, forse Papalla domani\". Come puoi constatare, più il proverbio è vecchio, più è ridicolo.",ep:5,g:39,l:98,wd:true,fm:true,w:1,p:24400};
I.u[2392] = {n:"Dragolyr Ritoccata",t:1,d:"Grazie al talento degli artigiani di Amakna, la Dragolyr Ritoccata sfiora la perfezione.",ep:11,g:25,l:42,wd:true,fm:true,w:1,p:5000};
I.u[2393] = {n:"Omelette Amuleto",t:1,d:"L\'Osamodas Onehaiuov Bek voleva assolutamente fare bella figura davanti ai membri della sua gilda, per questo decise di costruire un Amuleto rivoluzionario. Ci riuscì preparando la colazione ai suoi amici. Strano...",ep:1,g:40,l:17,wd:true,fm:true,w:10,p:1000};
I.u[2394] = {n:"La Gemmina",t:1,d:"Abbracciata dal sole, la gemmina riscalda i cuori e dà una sensazione di invulnerabilità verso il mondo. È anche talmente leggera che a volte ci si dimentica di toglierla prima di andare a letto..",ep:9,g:41,l:32,wd:true,fm:true,w:1,p:3000};
I.u[2395] = {n:"Il Foulard del Lard Fù",t:1,d:"Il Lard Fù era un piccolo demone spregevole che si fermava davanti alle persone senza muoversi. Era anche molto resistente alla magia e per questo era rispettato da tutti. Da allora il Lard Fù si nasconde da qualche parte e aspetta.",ep:8,g:42,l:42,wd:true,fm:true,w:15,p:5000};
I.u[2396] = {n:"La Lu Chola",t:1,d:"Sylvelina non era molto intelligente. Sua madre, Lu, le regalò questa lanterna dicendole \"Tieni, almeno sarai una luce!\". Neanche lei era molto brillante, ma questo non le impedì di illuminare la vita di sua figlia con un colpo di genio.",ep:7,g:43,l:15,wd:true,fm:true,w:5,p:1500};
I.u[2397] = {n:"Law Bibelò",t:1,d:"Law Bibelò era un vecchio che adorava creare cose dal nulla. Un giorno creò questo medaglione dalla forma curiosa. Dopo averlo messo al collo, sentì una strana sensazione... ma proprio strana.",ep:13,g:44,l:30,wd:true,fm:true,w:10,p:3000};
I.u[2398] = {n:"L\'Occhio di Kanigrù",t:1,d:"Offerto a Melyonen dal celebre Kanigrù Rook Y Balbua, per ringraziarla di avergli presentato la sua attuale moglie, Ar d\'riaaaaaaaaanhaaa, come la chiama lui.",ep:13,g:45,l:52,wd:true,fm:true,w:1,p:7000};
I.u[2399] = {n:"La Vitel Dolce",t:1,d:"Jozebo Vez era un pastore di Vitel, lontani cugini dei Pappatutto. Qualcuna delle bestie del suo gregge possedeva una pelliccia più morbida delle altre che si vendeva molto più cara. Per distinguerle dalle altre bestie gli metteva questa collana intorno al collo.",ep:13,g:46,l:15,wd:true,fm:true,w:1,p:1};
I.u[2400] = {n:"Stivali Animali Oscuri",t:11,d:"Si può proprio dire che questi Stivali abbiano un lato quantomeno... hmmm... oscuro. Quindi non ti stupire se un Vampiro si innamora di loro, ma potrebbe essere la cosa peggiore che ti sia mai successa.",ep:14,g:23,l:122,wd:true,fm:true,w:35,p:38000};
I.u[2401] = {n:"Carta di Kwelsh",t:15,d:"Questa carta è legata al maestro Kwelsh. È tutto ciò che sai e che ti è dato sapere.",ep:16,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[2402] = {n:"Spada di Serian-Kerm",t:6,d:"Questa spada è un regalo onorifico che si dà solo ai mercenari esperti. Taglia molto bene.",ep:1,g:25,l:30,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[2403] = {n:"Thovist",t:10,d:"Tempo fa usata per le libertà condizionali, la Thovist sembra possedere un potere supplementare rispetto alle altre cinture. Ma nessuno l\'ha ancora trovato. È meglio fare attenzione a quest\'oggetto.",ep:13,g:25,l:49,wd:true,fm:true,w:10,p:6100};
I.u[2404] = {n:"Cintura del Ratto",t:10,d:"Questa cintura bella attillata è appartenuta a un Ratto d\'Isgustoso. Gli calzava a pennello e gli nascondeva le maniglie dell\'amore.",ep:2,g:27,l:55,wd:true,fm:true,w:10,p:8100};
I.u[2409] = {n:"Kwakapo di Fiamma",t:16,d:"Il Kwakapo di Fiamma ti dà veramente un\'aria da spaccacuori. Questo accessorio è molto pratico per far fuori i tuo nemici mentre si stanno piegando in due dalle risate dopo averti visto conciato così.",ep:13,g:39,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2410] = {n:"Alberacasko",t:16,d:"L\'Alberacasko permette di evitare i postumi delle sbronze.",ep:1,g:40,l:45,wd:true,fm:true,w:50,s:3,p:5500};
I.u[2411] = {n:"Copricapo del Pappatutto",t:16,d:"Questo superbo copricapo aumenta Forza e Intelligenza di chi lo porta, sempre che riesca ad abituarsi all\'odore.",ep:1,g:41,l:10,wd:true,fm:true,w:15,s:1,p:2050};
I.u[2412] = {n:"Kwantello di Fiamma",t:17,d:"Molto poco irritante, ma comunque un pochino bisogna ammetterlo, questo mantello purtroppo non vi farà volare, e neanche planare. Non funzionerà neanche cucendoci sopra una grande \"M\", ma qualcuno ci crede ancora. Peccato.",ep:8,g:42,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2413] = {n:"Alberacappa",t:17,d:"Vestito di Foglie di Alberagno, potrai pavoneggiarti nel bel mezzo della foresta senza farti riconoscere. Ma stai attento agli Alberagni in germogliamento primaverile.",ep:1,g:43,l:45,wd:true,fm:true,w:17,s:3,p:5500};
I.u[2414] = {n:"Mantello Pappante",t:17,d:"Questo mantello ha tutte le qualità per essere apprezzato: resistenza, comodità, colore, rarità. Purtroppo però ha un odore schifosissimo. Non si può avere tutto, no?",ep:1,g:44,l:10,wd:true,fm:true,w:30,s:1,p:2780};
I.u[2415] = {n:"Kwaklama di Fiamma",t:6,d:"La Kwaklama di Fiamma è un\'arma veramente di stile. Anche se non fa paura al tuo avversario, potrà sempre affascinarlo, per poi sorprenderlo con un vecchio trucchetto...",ep:5,g:52,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CI>50&CV>50",s:2,p:4600};
I.u[2416] = {n:"Martello del Pappatutto",t:7,d:"Il Manuale spiega che questo sorprendente martello può liberare un\'energia colossale quando è usato correttamente. Ancora un manuale Osamodas tradotto in Sadida...",ep:1,g:23,l:10,wd:true,fm:true,w:25,an:15,e:[5,5,1,1,40,40,false,true],s:1,p:845};
I.u[2417] = {n:"Alberastone",t:4,d:"Questo bastone ha conservato tutta l\'aggressività dell\'Alberagno, ma non ha mantenuto l\'odore di legno marcio che spesso caratterizza i vecchi Alberagni.",ep:1,g:23,l:45,wd:true,fm:true,w:10,an:12,tw:true,e:[3,4,1,1,30,50,false,false],s:3,p:5500};
I.u[2418] = {n:"Kwakanello di Fiamma",t:9,d:"Se ti perdi mentre vai a consegnare un messaggio, il tuo padrone potrà ritrovarti grazie a questo anello.",ep:5,g:43,l:42,wd:true,fm:true,w:2,s:2,p:4900};
I.u[2419] = {n:"Anello di Buz il Prete",t:9,d:"Questo anello proviene da Buz il Prete, salvatore dei tempi moderni. La sua frase culto parlava di un luogo dove si fermava spesso a predicare, l\'Inn\"Finito e oltre\".",ep:1,g:44,l:10,wd:true,fm:true,w:10,s:1,p:775};
I.u[2420] = {n:"Aneramo",t:9,d:"Lavorare un Ramo di Alberagno non è cosa facile. Ma con un po\' di perseveranza, si può finire per ottenere un anello allo stesso tempo sobrio, elegante e raffinato. Proprio il contrario di un Sadida in una taverna.",ep:1,g:45,l:40,wd:true,fm:true,w:10,s:3,p:4500};
I.u[2421] = {n:"Kwakstivali di Fiamma",t:11,d:"Con questi stivali di Kwak di Fiamma, non ti rimane che camminare senza fare rumore per non farteli rubare da un Etram malintenzionato.",ep:5,g:25,l:40,wd:true,fm:true,w:5,s:2,p:4400};
I.u[2422] = {n:"Pappastivali",t:11,d:"Questi stivali sono di una comodità senza eguali. L\'interno sembra imbottito con lana di Pappatutto, ma tra le dita si percepisce anche lo scorrere di un liquido. Resta da sapere se si tratta di bava o sangue di Pappatutto. Vabbé, fa niente.",ep:1,g:26,l:10,wd:true,fm:true,w:15,s:1,p:1700};
I.u[2423] = {n:"Alberastivali",t:11,d:"Gli effetti di questo paio di Stivali possono essere perfettamente riprodotti andando in una taverna. Bevendo un po\', anzi tantissimo, l\'effetto sarà eccellente. L\'indomani avrai le gambe pesanti come i tuoi stivali!",ep:1,g:27,l:45,wd:true,fm:true,w:20,s:3,p:4500};
I.u[2424] = {n:"Amukwak di Fiamma",t:1,d:"Con tutte queste piume al collo assomigli a Eldo Rado, il grande avventuriero Sàcrido che cercava la città dorata.",ep:5,g:47,l:42,wd:true,fm:true,w:3,s:2,p:4900};
I.u[2425] = {n:"Amuleto del Pappatutto",t:1,d:"Un buon Corno di Pappatutto conferisce calma e saggezza. Allora anche un buon ciondolo di Pappatutto conferisce saggezza e calma. O il contrario? O altro? O niente?... Boh!",ep:1,g:48,l:3,wd:true,fm:true,w:10,s:1,p:550};
I.u[2426] = {n:"L\'Araknamu",t:1,d:"Questa piccola Arakne è la prova vivente che non si è obbligati ad imbalsamare un animale per farne un Amuleto. Ti farà il solletico al collo e forse ti tesserà una ragnatela davanti alla bocca, se sbadigli troppo spesso o se hai l\'alito cattivo.",ep:1,g:49,l:20,wd:true,fm:true,w:10,s:3,p:1300};
I.u[2427] = {n:"Kwakantura di Fiamma",t:10,d:"Per pavoneggiarsi come un Kwak di Fiamma durante la stagione degli amori, non c\'è niente di meglio di questa cintura, a condizione di non indossare nient\'altro.",ep:12,g:28,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2428] = {n:"Cintura del Pappatutto",t:10,d:"È una cintura rapida da indossare e leggera rispetto alla sua taglia. La lana sembra nuova... e a ragione. Secondo la leggenda si sono squartati un centinaio di Pappaton per darle questo aspetto liscio e setoso.",ep:1,g:29,l:20,wd:true,fm:true,w:10,s:1,p:1253};
I.u[2429] = {n:"Alberantura",t:10,d:"Questa cintura ti darà sicurezza e addominali di legno. Si raccomanda comunque un trattamento anti-Arakne ogni anno. Un po\' come per i capelli di un Sadida insomma... ma usando solo un terzo dell\'anti-parassitario.",ep:1,g:30,l:45,wd:true,fm:true,w:25,s:3,p:4500};
I.u[2430] = {n:"Pozzanghera di Gelatina Blu",t:24,d:"Sei stato veramente brutale con questa Gelatina Blu. Un giorno, chissà, pagherai per questo crimine.",ep:7,g:91,l:1,wd:true,fm:true,w:0,p:1};
I.u[2431] = {n:"Pozzanghera di Gelatina Limone",t:24,d:"Sei stato veramente brutale con questa Gelatina Limone. Un giorno, chissà, qualcuno schiaccerà così anche te.",ep:7,g:90,l:1,wd:true,fm:true,w:0,p:1};
I.u[2432] = {n:"Pozzanghera di Gelatina Fragola",t:24,d:"Sei stato veramente brutale con questa Gelatina Fragola. Un giorno, chissà, assomiglierai anche tu ad una grossa macchia informe.",ep:7,g:92,l:1,wd:true,fm:true,w:0,p:1};
I.u[2433] = {n:"Pozzanghera di Gelatina Menta",t:24,d:"Sei stato veramente brutale con questa Gelatina Menta. Un giorno, chissà, di te non resteranno che resti... come lei.",ep:7,g:93,l:1,wd:true,fm:true,w:0,p:1};
I.u[2435] = {n:"L\'Ani Kère",t:11,d:"Kère fu il solo Aniripsa a battere gli Ecaflip nella grande Maratona di Amakna. Grazie a questi stivali artigianali Kère riuscì ad attraversare il Mare di Asse e a distanziare tutti gli Ecaflip stupiti nel vedere un Ani correre in quel modo. La classe non è acqua.",ep:5,g:29,l:45,wd:true,fm:true,w:5,p:4800};
I.u[2436] = {n:"Gelatina Limone",t:110,d:"Questo barattolo di Gelatina Limone ha uno strano aspetto. Secondo Elrik Ola, questa gelatina proviene da casa sua, ovvero dall\'altra parte della galassia. Insomma, non proprio dietro l\'angolo.",ep:7,g:490,l:45,wd:true,fm:true,w:1,p:1};
I.u[2437] = {n:"Gelatina Limone Reale",t:110,d:"Secondo certe voci, la Gelatina Limone Reale è la migliore. Forse perché il limone nasconde il gusto della gelatina.",ep:7,g:491,l:200,wd:true,fm:true,w:1,p:100};
I.u[2438] = {n:"Pappacapo Reale",t:16,d:"Il Pappacapo Reale è un oggetto elegantissimo e intramontabile. Dà a chi lo porta Forza e Intelligenza.",ep:1,g:42,l:50,wd:true,fm:true,w:45,s:4,p:100};
I.u[2440] = {n:"Spada reale del Pappatutto",t:6,d:"Questa spada non sa bene in quale scarpa stare... e infligge danni di ogni elemento.",ep:1,g:30,l:70,wd:true,fm:true,w:65,an:14,e:[4,4,1,1,30,50,false,false],s:4,p:30000};
I.u[2441] = {n:"Anello Reale del Pappatutto",t:9,d:"Questo anello aumenta la Vita di chi lo porta, proprio come l\'odore della femmina del Pappatutto Reale aumenta il suo fascino.",ep:1,g:46,l:30,wd:true,fm:true,w:5,s:4,p:100};
I.u[2442] = {n:"Pappastivali Reali",t:11,d:"Brillano, sprigionano potenza... questi stivali sono veramente Reali!",ep:1,g:30,l:50,wd:true,fm:true,w:50,s:4,p:6600};
I.u[2443] = {n:"Amuleto Reale del Pappatutto",t:1,d:"Questo amuleto aumenta la Forza e l\'Intelligenza di chi lo porta.",ep:1,g:50,l:50,wd:true,fm:true,w:10,s:4,p:5000};
I.u[2444] = {n:"Cintura del Pappatutto Reale",t:10,d:"Questa magnifica cintura aumenta la Vitalità di chi la porta e gli permette di portare più facilmente i suoi oggetti. È così morbida che ci puoi anche legare la tua amata quando si rifiuta di restare in casa.",ep:1,g:31,l:52,wd:true,fm:true,w:10,s:4,p:7000};
I.u[2445] = {n:"Mantello Pappante Reale",t:17,d:"Questo mantello, indossato dal grande Pappatutto Reale, conferisce a chi lo porta uno stile favoloso e una forza fuori dal comune.",ep:1,g:46,l:50,wd:true,fm:true,w:60,s:4,p:50000};
I.u[2446] = {n:"Gelontello",t:17,d:"Senza fili né peli, questo Mantello resta un mistero per tutti i cervelli di Amakna... non più di una decina di persone più o meno...",ep:7,g:47,l:60,wd:true,fm:true,w:10,s:6,p:1000};
I.u[2447] = {n:"Gelocapo",t:16,d:"Con questo copricapo sulla testa, puoi essere certo che i tuoi amici sogneranno di leccarti. Questo è un cappello che, all\'epoca, avrebbe fatto la felicità del Capitano Chafer.",ep:5,g:43,l:60,wd:true,fm:true,w:23,s:6,p:9500};
I.u[2448] = {n:"Cervello di Pappatutto",t:15,d:"Non c\'è dubbio, questo Cervello è proprio di un Pappatutto. Questo è il piatto preferito da tutti i giovani Yop che vogliono diventare grandi e forti. Rende anche intelligenti, ma non bisogna dirlo ai bambini Yop, altrimenti non ne mangerebbero più!",ep:1,g:492,l:9,wd:true,fm:true,w:1,p:1};
I.u[2449] = {n:"Esercito di Zecche",t:15,d:"Secondo i Cacciatori, un Esercito di Zecche affamate potrebbe divorare tutta la lana di un Pappatutto in una sola notte. Secondo qualche trave di bar, potrebbe venire a capo anche della chioma di un Sadida.",ep:1,g:493,l:9,wd:true,fm:true,w:1,p:1};
I.u[2451] = {n:"Zoccolo di Pappatutto",t:47,d:"Tempo fa veniva usato come sottobicchiere, ma alcuni Alchimisti Aniripsa un po\' furbetti li hanno riciclati per farne delle tazze... per dare un po\' di gusto ai loro cereali preferiti.",ep:1,g:495,l:9,wd:true,fm:true,w:1,p:1};
I.u[2453] = {n:"Occhio di Pappatutto",t:109,d:"Tempo fa con quest\'occhio si cucinava una zuppa buonissima.\nCosì succulenta che la ricetta è stata bandita dai libri, perché i Cacciatori avevano cominciato a prendere solo gli occhi lasciando la carcassa fumante del povero Pappatutto.",ep:1,g:497,l:9,wd:true,fm:true,w:1,p:1};
I.u[2454] = {n:"Stomaco di Pappatutto",t:15,d:"Uno Stomaco di questo genere possiede grandi qualità elastiche. Però non stupitevi se all\'interno resta sempre una poltiglia di Trifogli, al contrario, gioite signorine, questa poltiglia è buonissima per la pelle!",ep:1,g:498,l:9,wd:true,fm:true,w:1,p:1};
I.u[2455] = {n:"Sangue di Pappatutto",t:15,d:"L\'odore del Sangue di Pappatutto attira i Pappatutto più grossi, è quindi indispensabile cospargersene per uscire a caccia. Attira tantissimo anche i moskito, ma non si sa ancora perché.",ep:1,g:499,l:9,wd:true,fm:true,w:1,p:1};
I.u[2460] = {n:"Occhio di Pappaton",t:109,d:"Questo Pappaton non sta certo tenendoti gli occhi addosso, ma si capisce che non ti apprezza particolarmente.",ep:1,g:500,l:2,wd:true,fm:true,w:1,p:1};
I.u[2462] = {n:"Cervello di Capo Guerriero Pappatutto",t:15,d:"Sembra evidente che il Capo Guerriero Pappatutto a cui hai preso il Cervello avrà qualche problema...",ep:1,g:501,l:19,wd:true,fm:true,w:1,p:1};
I.u[2463] = {n:"Dente di Capo di Guerra Pappatutto",t:47,d:"Bisogna ammettere che estrarre un Dente di Capo di Guerra non è da tutti. Da notare che questo dente vale molto di più se è rovinato. Non ti fare domande... è una questione di equilibrio economico.",ep:1,g:502,l:19,wd:true,fm:true,w:1,p:1};
I.u[2464] = {n:"Coda di Capo di Guerra Pappatutto",t:65,d:"Resta nascosto nel Bosco, osserva pazientemente, senza fare rumore, ed ecco!, forse potrai vedere un Capo di Guerra Pappatutto che scodinzola bello contento. Da notare che questo piccolo gesto inoffensivo è caratteristico del periodo dell\'accoppiamento.",ep:1,g:503,l:19,wd:true,fm:true,w:1,p:1};
I.u[2465] = {n:"Corno di Capo di Guerra Pappatutto",t:47,d:"Meno tenero del suo parente, il Capo di Guerra Pappatutto ha più facilità ad infilzare gli Etram e le altre razze temerarie. Si possono notare spesso pezzi di vestiti attaccati alle corna, un po\' come trofei.",ep:1,g:504,l:19,wd:true,fm:true,w:1,p:1};
I.u[2466] = {n:"Lingua di Capo di Guerra Pappatutto",t:15,d:"L\'espressione \"avere il marcio in bocca\" è proprio perfetta per il Capo di Guerra Pappatutto. Infatti, dà sempre l\'impressione di essersi mangiato un Trooll marcio.",ep:1,g:505,l:19,wd:true,fm:true,w:1,p:1};
I.u[2467] = {n:"Zoccolo di Capo di Guerra Pappatutto",t:47,d:"Secondo i Ciabattini, questo zoccolo è il più resistente e il più malleabile della Provincia. Rimane da sapere cosa intendano dire con \"malleabile\". Da come parlano si potrebbe dedurre che sono capaci di trasformare questi zoccoli in stivali.",ep:1,g:538,l:18,wd:true,fm:true,w:1,p:1};
I.u[2468] = {n:"Stomaco di Capo di Guerra Pappatutto",t:15,d:"All\'interno di questo stomaco c\'è una sorpresa. Piccole dita di Anutrof, nasi di Osamodas... Ci si potrebbe tranquillamente costruire un nuovo personaggio con tutti questi pezzi.",ep:1,g:506,l:19,wd:true,fm:true,w:1,p:1};
I.u[2469] = {n:"Gelanello",t:9,d:"Non mangiarti le unghie, leccati le dita!!!",ep:7,g:47,l:60,wd:true,fm:true,w:5,s:6,p:10000};
I.u[2470] = {n:"Gelostivali",t:11,d:"Questi stivali sono molto comodi d\'estate perché emanano un dolce odore di fragole di bosco che copre quello di sudore dei piedi pelosi di un vecchio Sadida.",ep:5,g:31,l:60,wd:true,fm:true,w:50,s:6,p:1000};
I.u[2471] = {n:"Gelontura",t:10,d:"Il problema di questa Gelontura è che, in caso di fame violenta, si è tentati di morderla.",ep:7,g:32,l:60,wd:true,fm:true,w:15,s:6,p:1000};
I.u[2472] = {n:"Gelamu",t:1,d:"Questo è un amuleto che manifesterà la tua enorme attrazione verso le orgie di Gelatina. Certo, si può trovare di meglio per mettersi in mostra e brillare in società, ma devi prenderti la responsabilità del tuo debole per la gelatina.",ep:5,g:51,l:60,wd:true,fm:true,w:4,s:6,p:1000};
I.u[2473] = {n:"Mantello dell\'Avventuriero",t:17,d:"Chic ma poco utile, questo mantello soddisferà comunque i giovani avventurieri.",ep:1,g:48,l:1,wd:true,fm:true,w:7,s:5,p:100};
I.u[2474] = {n:"Cappello dell\'Avventuriero",t:16,d:"A parte il fatto di far scappare le ragazze, questo cappello non è molto utile.",ep:1,g:44,l:1,wd:true,fm:true,w:12,s:5,p:100};
I.u[2475] = {n:"Anello dell\'Avventuriero",t:9,d:"Questo piccolo e grazioso anello per principianti, divertirà i bambini... o gli Ecaflip.",ep:1,g:48,l:1,wd:true,fm:true,w:5,s:5,p:10};
I.u[2476] = {n:"Stivali dell\'Avventuriero",t:11,d:"Stivali di semplice manifattura ma ideali per i giovani che intraprendono l\'avventura.",ep:1,g:32,l:1,wd:true,fm:true,w:15,s:5,p:10};
I.u[2477] = {n:"Cintura dell\'Avventuriero",t:10,d:"Una piccola cintura per i giovani avventurieri.",ep:1,g:33,l:1,wd:true,fm:true,w:6,s:5,p:10};
I.u[2478] = {n:"Amuleto dell\'Avventuriero",t:1,d:"Né chic, né efficace, però molto simpatico se ne si possiede la panoplia.",ep:1,g:52,l:1,wd:true,fm:true,w:2,s:5,p:10};
I.u[2479] = {n:"Cresta di Porkass",t:15,d:"Questa pettinatura è segno di maturità tra i Porkass. Ed è per questo che ogni tanto si può intravedere qualche giovane Aniripsa, in cerca di maturità, passeggiare in città con questa cresta. Anche se, conciati così, non osano assolutamente avventurarsi nelle Pianure Rocciose...",ep:13,g:507,l:18,wd:true,fm:true,w:1,p:1};
I.u[2480] = {n:"Mutande di cuoio di Porkass",t:56,d:"\"Un Porkass senza Mutande è un Porkass Morto\", diceva sempre Donna Rissa, Feca adepta del voyeurismo e del nonnismo... Il suo passatempo preferito era quello di obbligare gli \"amici\" a mettere sulla testa le mutande sporche del Porkass.",ep:13,g:508,l:18,wd:true,fm:true,w:1,p:1};
I.u[2481] = {n:"Muso di Porkass",t:15,d:"Questo Muso, rosa come il sedere di un neonato Osamodas, deve sicuramente essere utile per una ricetta gastronomica. O forse per una bella collana di Musi, ma bisogna veramente essere coraggiosi per indossarne una e subire tutti gli sguardi divertiti della gente.",ep:13,g:509,l:18,wd:true,fm:true,w:1,p:1};
I.u[2482] = {n:"Scarpa di Porkass",t:15,d:"Tempo fa una scarpa simile è stata trovata sui gradini di un grande palazzo reale. Delle voci dicono che questa scarpa sia scivolata via dal piede di una Porkassina che aveva fretta di rientrare a casa prima di mezzanotte.",ep:13,g:510,l:18,wd:true,fm:true,w:2,p:1};
I.u[2483] = {n:"Dentiera di Porkass",t:47,d:"Alcuni Porkass nascono senza denti. Altri invece, dopo aver sbattuto la faccia nel sonno, si svegliano sdentati, senza ricordarsi di niente...",ep:13,g:511,l:30,wd:true,fm:true,w:1,p:1};
I.u[2484] = {n:"Tridente Rotto",t:15,d:"Ecco un piccolo souvenir del tuo amico Porkass. Sperando che non ti porti rancore e non ti cerchi per tutta la provincia. Col porco carattere che si ritrova, ne sarebbe ben capace. Fai attenzione!",ep:13,g:512,l:18,wd:true,fm:true,w:2,p:1};
I.u[2485] = {n:"Vegecapo",t:16,d:"Il top del top della moda, ma solo a nord-est di Amakna.",ep:1,g:45,l:40,wd:true,fm:true,w:25,s:10,p:4500};
I.u[2486] = {n:"Orecchio di Porkass",t:106,d:"Questo orecchio è un buon mezzo per farsi rispettare, funge da trofeo e prova quanto tu sia temuto dai Porkass. Attenzione: non vantartene con i Porkass, loro non ti acclameranno sicuramente... anzi.",ep:13,g:513,l:18,wd:true,fm:true,w:1,p:1};
I.u[2487] = {n:"Carapace di Scorbuto",t:107,d:"Ideale per costruire armature pesanti, lo Scorbuto è sempre stato cacciato dalla Milizia di Brakmar perché il suo tasso di riproduzione era da guinness dei primati. Persino le Gelatine non si riproducevano tanto rapidamente.",ep:14,g:514,l:36,wd:true,fm:true,w:1,p:1};
I.u[2488] = {n:"Viscere di Scorbuto",t:15,d:"Di primo acchito, queste viscere non sono certo molto invitanti. E neanche di secondo acchito... perché le viscere di Scorbuto fanno sempre schifo, anche se cucinate con amore.",ep:14,g:445,l:36,wd:true,fm:true,w:1,p:1};
I.u[2489] = {n:"Vegentello",t:17,d:"Un mantello che ti renderà irresistibile per gli amatori delle belle piante.",ep:1,g:49,l:58,wd:true,fm:true,w:15,s:10,p:1000};
I.u[2490] = {n:"Zampa di Scorbuto",t:103,d:"È veramente raro poter trovare una Zampa di Scorbuto in così buono stato. Speriamo almeno che tu te ne serva bene e non solo come gancio per scassinare le porte. Anche se...",ep:14,g:515,l:36,wd:true,fm:true,w:1,p:1};
I.u[2491] = {n:"Occhio di Uginak",t:109,d:"Inquietante, ma palpitante, quest\'occhio di Uginak non riflette veramente ciò che ci si aspetta. Per esempio, invece di te stesso, riflette il tuo omologo Dabol. Chissà...",ep:14,g:516,l:51,wd:true,fm:true,w:1,p:1};
I.u[2492] = {n:"Catena di Uginak",t:15,d:"Questa maledetta Catena proviene quasi sicuramente da un Uginak. Prima di essere spezzata doveva essere stata usata per incatenare l\'Uginak ed evitare che scappasse.",ep:14,g:517,l:51,wd:true,fm:true,w:2,p:1};
I.u[2493] = {n:"Cuore di Uginak",t:15,d:"Questo cuore ti sarà fedele, tanto che non lo venderai né lo scambierai mai. Resterà con te sul fondo del tuo zaino. Quanto sei dolce!",ep:14,g:518,l:51,wd:true,fm:true,w:1,p:1};
I.u[2494] = {n:"Pomo di Spada",t:15,d:"C\'è sicuramente voluto un colpo strapotente per sconfiggere questa mitica spada. In effetti, la Spada di Uginak dà a chi la usa un\'immensa voglia di urlare di gioia! Wa-hooooo!",ep:14,g:519,l:51,wd:true,fm:true,w:2,p:1};
I.u[2495] = {n:"Occhio di Koleratto",t:109,d:"Questo Occhio brilla di notte, anche dopo essere stato strappato al suo proprietario.",ep:2,g:520,l:9,wd:true,fm:true,w:1,p:1};
I.u[2496] = {n:"Coda di Koleratto",t:65,d:"Se tagliata correttamente, la Coda di Koleratto ha il gusto del salame. Quello che è strano però, è che se tagli delle fette grosse il gusto di salame scompare completamente. Un ennesimo enigma culinario nel mondo.",ep:2,g:521,l:9,wd:true,fm:true,w:1,p:1};
I.u[2497] = {n:"Orecchio di Koleratto",t:106,d:"Se te lo metti vicino all\'orecchio potrai sentire il mare.",ep:2,g:522,l:9,wd:true,fm:true,w:1,p:1};
I.u[2498] = {n:"Vegemuleto",t:1,d:"Il Vegemuleto tende talvolta ad attirare i moskito che da lontano lo scambiano per una femmina. Sono parecchio delusi quando poco dopo cadono nelle mani di chi porta questo amuleto.",ep:1,g:53,l:40,wd:true,fm:true,w:20,s:10,p:1000};
I.u[2499] = {n:"Muso di Koleratto",t:15,d:"Il Koleratto possiede un fiuto fuori dal comune. Non arriva neanche alla caviglia dell\'Uginak, ma riesce a sentire il suo odore in un raggio di trecento metri. E questo è proprio un bel vantaggio per evitare i predatori.",ep:2,g:523,l:9,wd:true,fm:true,w:1,p:1};
I.u[2500] = {n:"Koleratto Morto",t:15,d:"Hai fatto bene a raccoglierlo, è intatto. Morto... ma intatto.",ep:2,g:524,l:9,wd:true,fm:true,w:10,p:1};
I.u[2501] = {n:"Coda di Canin Blando",t:65,d:"Il dio Osamodas non sopporta che si faccia del male agli animali selvatici: \"Sono così carini!\", urla sempre. Che simpatico... si vede che non ha mai subito un\'ablazione da un \"carino\"...",ep:1,g:525,l:19,wd:true,fm:true,w:1,p:1};
I.u[2502] = {n:"Zazampa di Canin Blando",t:103,d:"Le Zazampe di Canin Blando sono abbastanza ricercate dai gastronomi locali. Possiedono virtù magiche, come quelle di portare fortuna al proprietario. Buono, no?",ep:1,g:526,l:19,wd:true,fm:true,w:1,p:1};
I.u[2503] = {n:"Stoffa di Canin Blando",t:55,d:"Con questa Stoffa potrai essere astuto come un Canin Blando. Se sognavi di portare una Stoffa sulla testa e di muoverti come un felino, ebbene, detto tra noi... fai dei sogni un po\' strani!",ep:1,g:200,l:19,wd:true,fm:true,w:1,p:1};
I.u[2504] = {n:"Lingua del Canin Blando",t:15,d:"Questa lingua è probabilmente stata in molti luoghi prima di ritrovarsi nel tuo zaino.",ep:1,g:527,l:19,wd:true,fm:true,w:1,p:1};
I.u[2505] = {n:"Crocchetta",t:15,d:"Per attirare un Canin Blando e cercare di farlo diventare domestico, lanciagli una Crocchetta... ne va matto. Non te lo dirà mai, ma resterà tuo amico per tutta la vita.",ep:1,g:528,l:19,wd:true,fm:true,w:1,p:1};
I.u[2506] = {n:"Grelot",t:15,d:"Con un Grelot, sentirai il Serpentino a chilometri di distanza. E menomale, perché a due metri rischieresti di mancarlo a causa della folta vegetazione delle Pianure di Cania.",ep:13,g:529,l:10,wd:true,fm:true,w:1,p:1};
I.u[2507] = {n:"Lingua Forcuta",t:15,d:"Armato di questa lingua potrai frustare i tuoi amici. Un modo carino di far contenti i tuoi colleghi Osamodas e Sàcrido.",ep:13,g:530,l:10,wd:true,fm:true,w:1,p:1};
I.u[2508] = {n:"Veleno del Serpentino",t:15,d:"Pericolosissimo, questo Veleno può uccidere un intero esercito di Pappatutto arrabbiati. Per questo prima si usava per controllare le greggi, se ne metteva un po\' sul bastone, e il gioco era fatto.",ep:13,g:531,l:10,wd:true,fm:true,w:1,p:1};
I.u[2509] = {n:"Dente del Serpentino",t:47,d:"Non c\'è dubbio, questo dente apparteneva a un Serpentino. Sì può constatare osservandolo da vicino... difficile trovarne di più appuntiti.",ep:13,g:432,l:10,wd:true,fm:true,w:1,p:1};
I.u[2510] = {n:"Stomaco di Cinghiale delle Pianure",t:15,d:"Questo stomaco può contenere cose incredibili, una Yoppina sarebbe felice di tutte le spade che potrebbe metterci dentro.",ep:13,g:532,l:44,wd:true,fm:true,w:1,p:1};
I.u[2511] = {n:"Cuoio di Cinghiale delle Pianure",t:56,d:"I Ciabattini hanno esitato molto prima di decidersi a utilizzare le qualità di questo cuoio per fabbricare cinture e stivali. Il fatto che fosse inodore rappresentava un gran problema, perché i clienti pensavano fosse del falso cuoio.",ep:2,g:410,l:44,wd:true,fm:true,w:10,p:1};
I.u[2512] = {n:"Coda di Cinghiale delle Pianure",t:65,d:"Molti bracconieri Brakmariani collezionano questo trofeo peloso. Ancora oggi, le ragioni di questo massacro restano sconosciute.",ep:13,g:536,l:44,wd:true,fm:true,w:1,p:1};
I.u[2513] = {n:"Stoffa di Cinghiale delle Pianure",t:55,d:"Contrariamente al suo Cuoio, la Stoffa del Cinghiale delle Pianure ha un profumo efficacissimo contro il naso chiuso. Tanto per dire... quest\'odore potrebbe persino risvegliare un Sadida in ibernazione.",ep:13,g:537,l:44,wd:true,fm:true,w:1,p:1};
I.u[2514] = {n:"Zoccolo di Cinghiale delle Pianure",t:47,d:"Di solito gli Zoccoli del Cinghiale sono coperti di fango e terra, ma talvolta non bisogna stupirsi di trovare dei Biblop di tutti i colori. Eh sì, proprio come te, il Cinghiale delle Pianure non ama i Biblop.",ep:13,g:539,l:44,wd:true,fm:true,w:1,p:1};
I.u[2515] = {n:"Muso di Cinghiale delle Pianure",t:15,d:"A prima vista, questo Muso non è proprio fresco. Ebbene, devi ricrederti, da lontano questo è il muso più fresco e più tenero che esista...",ep:13,g:540,l:44,wd:true,fm:true,w:1,p:1};
I.u[2516] = {n:"Zanna di Cinghiale delle Pianure",t:47,d:"Questa zanna ti ricorderà che il Cinghiale delle Pianure è il più antipatico dei Cinghiali. Infatti è tanto consumata quanto un Dente di Wabbit rovinato dalle Cawote.",ep:13,g:541,l:44,wd:true,fm:true,w:1,p:1};
I.u[2517] = {n:"Megantello",t:17,d:"Questo mantello apparteneva ad un celebre eroe, conosciuto per avere combattuto contro il terribile dottor Wily che voleva invadere e dominare il Mondo dei Dodici con le sue invocazioni. Il dottor Wily morì prima che tutte le sue invocazioni ebbero il tempo di attaccare.",ep:1,g:50,l:45,wd:true,fm:true,w:2,s:76,p:5500};
I.u[2518] = {n:"Mantello Viutiful",t:17,d:"Silvia di Jodaw ha cucito questo sorprendente mantello con le sue stesse mani usando delle vecchie tende. Fortunatamente non si nota perché in realtà assomiglia a uno straccio bollito in sangue di Porkass.",ep:1,g:51,l:45,wd:true,fm:true,w:2,s:75,p:5500};
I.u[2519] = {n:"Megacapo",t:16,d:"Per sbrigarsela nelle situazioni più estreme e avere un posto importante nella società, questo copricapo dovrebbe essere il massimo.",ep:1,g:46,l:44,wd:true,fm:true,w:2,s:76,p:5200};
I.u[2520] = {n:"Elmo Viutiful",t:16,d:"Questo elmo è appartenuto al buon vecchio Jojo, celebre eroe dei vecchi tempi. Nonostante i diversi exploit, non si capisce ancora bene cosa attiri tutti i suoi fan.",ep:1,g:47,l:44,wd:true,fm:true,w:2,s:75,p:5200};
I.u[2521] = {n:"Megastivali",t:11,d:"Roll, la brava sorella del proprietario di questi stivali, era una specialista di tassidermia astrale. Qualche tempo fa, ancora nessuno era in grado di capire la differenza tra la tassidermia e la tassidermia astrale. Ma ai giorni nostri possiamo affermare con sicurezza che la tassidermia astrale permette di fabbricare creature imbalsamate astrali. Se questa risposta pare così evidente ora, forse è perché i tuoi antenati non erano tanto furbi all\'epoca.",ep:1,g:33,l:43,wd:true,fm:true,w:2,s:76,p:5000};
I.u[2522] = {n:"Stivali Viutiful",t:11,d:"Questi stivali permettevano al famoso Jojo di aumentare la potenza del suo celebre colpo del piede rotante, anche conosciuto con il nome di \"colpo rosso e caldo\". Ci si domanda ancora l\'origine di questo nome, visto che gli stivali erano bianchi.",ep:1,g:34,l:43,wd:true,fm:true,w:2,s:75,p:5000};
I.u[2523] = {n:"Megantura",t:10,d:"Questa cintura è stata appositamente concepita per proteggere i fianchi degli eroi. Non ti serverà a niente.",ep:1,g:34,l:45,wd:true,fm:true,w:2,s:76,p:5600};
I.u[2524] = {n:"Cintura Viutiful",t:10,d:"Si racconta che questa cintura sia stata fabbricata dal capitano Bluë in persona. Incredibile, eppure la gente ci crede lo stesso!",ep:1,g:35,l:46,wd:true,fm:true,w:2,s:75,p:5600};
I.u[2525] = {n:"Cuore di Messer Cuervoc",t:15,d:"Senza il suo cuore, il suo canto non sarà più come prima. Ma non glielo dire assolutamente, Messer Cuervoc è permalosissimo.",ep:13,g:328,l:160,wd:true,fm:true,w:1,p:1};
I.u[2526] = {n:"Falce di Messer Cuervoc",t:15,d:"Questa falce era originariamente destinata alla falciatura dello Yop, ma Messer Cuervoc si è accorto che, affilata com\'era, poteva falciare qualsiasi cosa e chiunque.",ep:1,g:557,l:160,wd:true,fm:true,w:10,p:1};
I.u[2527] = {n:"Clakos",t:15,d:"Il Messer è pieno di sorprese, in tasca aveva un Clakos, il celebre formaggio reale. Il fatto che sia già aperto è la prova di quanto Messer Cuervoc lo adori. Per quanto riguarda l\'odore, non ti si può consigliare altro che non tenerlo addosso.",ep:13,g:558,l:160,wd:true,fm:true,w:1,p:1};
I.u[2528] = {n:"Unghia di Kanigrù",t:47,d:"Bisogna essere potenti e rapidi per riuscire a strappare un\'unghia ad un Kanigrù. Potenti per estrarla e rapidi per non prendersi una zampata gigante.",ep:13,g:559,l:70,wd:true,fm:true,w:1,p:1};
I.u[2529] = {n:"Pozione di metallo liquido",t:26,d:"Questa pozione permette di ridare un po\' di realtà a una lama eterea.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2530] = {n:"Carastivali",t:11,d:"Sono un po\' pesanti, è vero... ma con questi affascinanti stivali sarai la regina della notte.",ep:12,g:35,l:60,wd:true,fm:true,w:50,s:9,p:1000};
I.u[2531] = {n:"Caracapo",t:16,d:"Come te, la tartaruga ha veramente una testa piccolissima. Bene, il Caracapo è fatto apposta per questo.",ep:12,g:48,l:60,wd:true,fm:true,w:24,s:9,p:10000};
I.u[2532] = {n:"Carantello",t:17,d:"Un mantello pratico e resistente, ma che certo non farà di te una celebrità... tanto non lo eri neanche prima, quindi non c\'è problema!",ep:12,g:52,l:60,wd:true,fm:true,w:15,s:9,p:10000};
I.u[2534] = {n:"Kwantello di Ghiaccio",t:17,d:"È ideale per rinfrescarsi sull\'isola di Moon durante la bella stagione, ed è perfetto per calmare i bollenti spiriti degli amici più intraprendenti. Questo mantello saprà soddisfare le aspettative dell\'avventuriero dei tempi moderni.",ep:8,g:53,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2535] = {n:"Kwakapo di Ghiaccio",t:16,d:"Questo Kwakapo di Ghiaccio ti permetterà di avere sempre idee fresche, anche quando sarai a corto di idee. Purtroppo non è abbastanza potente per uno Yop.",ep:13,g:49,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2537] = {n:"Kwakantura di Ghiaccio",t:10,d:"Ideale per rassodare le anche, questa cintura ti permetterà di tenere ben al fresco tutto ciò che hai sotto la cintura.",ep:12,g:36,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2538] = {n:"Pozione di metallo pesante liquido",t:26,d:"Questa pozione permette di ridare un po\' di realtà a una lama eterea.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2539] = {n:"Pozione di Trucioli di Legno",t:26,d:"Questa pozione permette di ridare un po\' di realtà a un\'opera intagliata eterea.",ep:1,g:16,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2540] = {n:"Pozione di Trucioli di Legno Solidi",t:26,d:"Questa pozione permette di ridare un po\' di realtà a un\'opera intagliata eterea.",ep:1,g:17,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2541] = {n:"Pozione di metallo prezioso liquido",t:26,d:"Questa pozione permette di ridare un po\' di realtà a una lama eterea.",ep:2,g:15,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2542] = {n:"Pozione di Focolare",t:12,d:"Questa Pozione ti permetterà di ritornare in qualsiasi momento al tuo focolare.",ep:1,g:142,l:1,wd:true,fm:true,w:2,u:true,p:100};
I.u[2543] = {n:"Pozione di Trucioli di Legno Rari",t:26,d:"Questa pozione permette di ridare un po\' di realtà a un\'opera intagliata eterea.",ep:9,g:18,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2544] = {n:"Cuervolama",t:6,d:"Terribilmente tagliente e incredibilmente chic, questa lama rischia di fare ingelosire parecchia gente intorno a te.",ep:1,g:32,l:45,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,20,50,false,false],s:8,p:4500};
I.u[2545] = {n:"Cuervostivali",t:11,d:"Questi stivali trasmettono un incredibile senso di leggerezza a chi li porta, ma anche un\'aria parecchio stupida.",ep:1,g:37,l:45,wd:true,fm:true,w:1,s:8,p:1000};
I.u[2546] = {n:"Cuervocapo",t:16,d:"Grazie a questo magnifico copricapo, avrai la stessa classe del tristemente famoso Messer Cuervoc.",ep:1,g:50,l:45,wd:true,fm:true,w:23,s:8,p:1000};
I.u[2547] = {n:"Cuervantello Mastralis",t:17,d:"Da molto tempo i migliori Sarti di Amakna si sono messi in società per usare le spoglie di Messer Cuervoc e farne un sontuoso mantello. Con un mantello del genere sulle spalle, il Messer sarai tu!",ep:13,g:56,l:127,wd:true,fm:true,w:30,p:41000};
I.u[2549] = {n:"Legno di Kanigrù",t:15,d:"Questo barattolo contiene del Kanigrù in pezzi, prima tagliato e poi messo in scatola. Molto pratico da trasportare, il Kanigrù in pezzi è veramente il miglior amico dell\'uomo.",ep:13,g:560,l:70,wd:true,fm:true,w:1,p:1};
I.u[2550] = {n:"Stoffa di Kanigrù",t:55,d:"Con questa Stoffa potrai farti un parrucchino bellissimo. Ti si vedrà persino da lontano... da molto lontano.",ep:13,g:561,l:70,wd:true,fm:true,w:1,p:1};
I.u[2551] = {n:"Orecchio di Kanigrù",t:106,d:"Ecco il piatto preferito dall\'Uginak: Orecchio di Kanigrù in salsa naturale. Secondo la tradizione però si cucina con molta menta selvatica e qualche Unghia per dargli un po\' di gusto in più.",ep:13,g:562,l:70,wd:true,fm:true,w:1,p:1};
I.u[2552] = {n:"Occhio di Kanigrù",t:109,d:"L\'occhio di Kanigrù è diventato un fenomeno di moda, ormai è consuetudine vedere gli avventurieri passeggiare con quest\'occhio intorno al collo.",ep:13,g:563,l:70,wd:true,fm:true,w:1,p:1};
I.u[2553] = {n:"Grossa Palla",t:15,d:"Questa è proprio una Palla. Pesante al punto giusto, non la smetterà di spaccarvi la testa quando ne avrà voglia. Niente di più noioso di un tipo palloso insomma.",ep:1,g:564,l:40,wd:true,fm:true,w:500,p:1};
I.u[2554] = {n:"Costine di Porkass",t:47,d:"Le Costine di Porkass hanno un sapore particolare.\nCerte persone le mangiano cotte con un po\' di spezie, altre le preferiscono crude. Il Porkass però preferisce le tue... A ognuno la propria ricetta!",ep:13,g:159,l:40,wd:true,fm:true,w:1,p:1};
I.u[2555] = {n:"Sella di Cuoio",t:56,d:"Ma quant\'è delicato il Porkass! Pensa che sotto il suo sedere nascondeva una sella con un\'imbottitura di eccellente qualità. Una volta rilavorata, questa sella potrebbe diventare un bellissimo paio di pantofole.",ep:13,g:565,l:40,wd:true,fm:true,w:5,p:1};
I.u[2556] = {n:"Polline di Blop",t:15,d:"Ecco l\'origine di tutte le allergie benigne di questo mondo. L\'unico problema è che tutte le allergie mortali derivano da un\'allergia benigna. Insomma, non andare in giro col Polline in tasca se non ne hai veramente bisogno.",ep:5,g:566,l:34,wd:true,fm:true,w:1,p:1};
I.u[2557] = {n:"Petalo di Blop",t:35,d:"Per quanto possa sembrare strano i Petali di Blop non sono commestibili, né cotti né crudi.",ep:5,g:567,l:34,wd:true,fm:true,w:1,p:1};
I.u[2558] = {n:"Blop Morto",t:15,d:"Hai fatto bene a raccoglierlo, è intatto. Morto... ma intatto.",ep:5,g:568,l:34,wd:true,fm:true,w:10,p:1};
I.u[2559] = {n:"Criniera di Trooll",t:15,d:"Una Criniera come questa non è tanto comune. Solo i più ricchi Anutrof possono permettersi di usarla come parrucchino.",ep:4,g:569,l:115,wd:true,fm:true,w:1,p:1};
I.u[2560] = {n:"Spallina di Trooll",t:15,d:"È meglio ammirare questa spallina così piuttosto che vederla ancora attaccata alla spalla di un Trooll. Ci mancherebbe solo che ti facesse una sfilata.",ep:4,g:570,l:115,wd:true,fm:true,w:5,p:1};
I.u[2561] = {n:"Bracciale di Forza del Trooll",t:15,d:"Come se il Trooll avesse bisogno di un braccialetto di forza... Quell\'incredibilie macchina sfasciaossa ne porta uno su ogni polso.",ep:4,g:571,l:115,wd:true,fm:true,w:5,p:1};
I.u[2562] = {n:"Mutande del Trooll",t:56,d:"A giudicare dalle sue Mutande, il Trooll si siede veramente ovunque. Grazie a queste Mutande si può anche determinare l\'età del proprietario. A naso... ovviamente.",ep:4,g:572,l:115,wd:true,fm:true,w:1,p:1};
I.u[2563] = {n:"Ceppo di Legno del Tronknyde",t:38,d:"Per il Tronknyde questo ceppo serve da piede, perché il piede serve da ceppo. Per questo il Tronknyde è, sfortunatamente, sempre in cerca di un fermapiedi.",ep:9,g:573,l:35,wd:true,fm:true,w:2,p:1};
I.u[2564] = {n:"Sopracciglia di Tronknyde",t:38,d:"Volevi conoscere la tecnica del Tronknyde per spaventare i visitatori imprudenti? Ebbene, ce l\'hai tra le mani: un bel grosso paio di spesse Sopracciglia.",ep:9,g:574,l:35,wd:true,fm:true,w:2,p:1};
I.u[2565] = {n:"Fetta di Tronknyde",t:15,d:"Dopo avergli tagliato una bella fetta, il Tronknyde starà sicuramente tenendo il broncio.",ep:9,g:575,l:35,wd:true,fm:true,w:2,p:1};
I.u[2566] = {n:"Fetta Magica di Tronknyde",t:15,d:"Questa Fetta di Tronknyde sembra diversa da tutte le altre. Nel momento in cui fu tagliata, una luce accecante scaturì dal Tronknyde, per poi scomparire immediatamente, lasciando per terra solo la Fetta.",ep:9,g:576,l:35,wd:true,fm:true,w:2,p:1};
I.u[2567] = {n:"Anticipazione",t:29,d:"Questa benedizione ti permetterà di essere più sveglio per i prossimi combattimenti.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2568] = {n:"Riflessi Subumani",t:30,d:"Questa maledizione ti manda in uno stato di semicoscienza e i tuoi riflessi diminuiscono per il prossimo combattimento.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2569] = {n:"Pergamena di Riflessi Sovrumani",t:14,d:"Questa pergamena ti renderà più vivace al prossimo combattimento.",ep:1,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2570] = {n:"Pergamena di Riflessi Sottumani",t:14,d:"Questa pergamena ti renderà un pochino più inerte al prossimo combattimento.",ep:1,g:29,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2571] = {n:"Zampa di Prespic",t:103,d:"Come fa un Prespic a essere così agile con delle zampette del genere? Te lo sei chiesto anche tu, vero? Ma per ora il mistero resta irrisolto.",ep:1,g:577,l:18,wd:true,fm:true,w:1,p:1};
I.u[2572] = {n:"Stomaco di Prespic",t:15,d:"\"A furia di mangiare sempre la stessa roba, finirai per assomigliare a quello che mangi\". Queste erano le sagge parole del cuoco Bontariano Jon-kierre Poff. Ecco perché il Prespic ha lo stomaco inverdito dall\'erba ingerita.",ep:1,g:578,l:18,wd:true,fm:true,w:1,p:1};
I.u[2573] = {n:"Coda di Prespic",t:65,d:"Il Prespic usa la coda molto raramente, e menomale! Infatti la sua potenza è sorprendente. Alcuni Taglialegna hanno persino visto dei Prespic di notte mentre spostavano dei tondelli di legno con la coda.",ep:1,g:579,l:18,wd:true,fm:true,w:1,p:1};
I.u[2574] = {n:"Criniera di Prespic",t:15,d:"Questa criniera è perfetta per le cosiddette serate \"vip\". Vacci con un amico Osamodas e ti prenderanno per una delle sue invocazioni.",ep:1,g:580,l:18,wd:true,fm:true,w:1,p:1};
I.u[2575] = {n:"Scalpo di Buulupo",t:15,d:"Quando sei arrivato, il Buulupo aveva sicuramente la tua stessa voglia, e cioè di prenderti, con più o meno tatto, lo scalpo. Sei stato il più rapido!",ep:1,g:581,l:70,wd:true,fm:true,w:1,p:1};
I.u[2576] = {n:"Scalpo di Milibuulupo",t:15,d:"Quando sei arrivato, il Milibuulupo aveva sicuramente la tua stessa voglia, e cioè di prenderti, con più o meno tatto, lo scalpo. Adesso fa meno il furbetto senza il suo cervelletto.",ep:1,g:582,l:22,wd:true,fm:true,w:1,p:1};
I.u[2577] = {n:"Scalpo di Muulupo",t:15,d:"Quando sei arrivato, il Muulupo aveva sicuramente la tua stessa voglia, e cioè di prenderti, con più o meno tatto, lo scalpo. Adesso è pronto per prendersi un raffreddore cerebrale.",ep:2,g:583,l:198,wd:true,fm:true,w:1,p:1};
I.u[2578] = {n:"Occhio di Buulupo",t:109,d:"Lo sguardo del Buulupo resta su di te anche dopo essere stato strappato. E se lo guardi bene ti sembrerà che ti stia seguendo con gli occhi... ops, con l\'occhio.",ep:1,g:584,l:70,wd:true,fm:true,w:1,p:1};
I.u[2579] = {n:"Occhio del Milibuulupo",t:109,d:"Lo sguardo del Milibuulupo resta su di te anche dopo essere stato strappato. E se lo guardi attentamente ti accorgerai che le palpebre sbattono ancora. Che vitalità questo Milibuulupo!",ep:1,g:585,l:22,wd:true,fm:true,w:1,p:1};
I.u[2580] = {n:"Occhio di Muulupo",t:109,d:"Lo sguardo del Muulupo resta su di te anche dopo essere stato strappato. E se lo guardi bene corruga la fronte quando lo indichi. Senza dubbio il Muulupo non non ha voglia di scherzare.",ep:2,g:586,l:198,wd:true,fm:true,w:1,p:1};
I.u[2581] = {n:"Denti di Muulupo",t:47,d:"Se cerchi la specie che ha i denti più grandi nella famiglia dei buulupi, l\'hai appena trovata. \"È per sbavarvi meglio cari bambini\".",ep:2,g:587,l:198,wd:true,fm:true,w:1,p:1};
I.u[2582] = {n:"Testicoli del Muulupo",t:15,d:"Se il prezzo dei Testicoli di Buulupo è scandaloso, capirai rapidamente che quelli che hai in mano valgono un bel paio di... lingotti.",ep:2,g:588,l:198,wd:true,fm:true,w:20,p:1};
I.u[2583] = {n:"Occhio di Granchio",t:109,d:"I marinai di acqua dolce sono abbastanza golosi di questo Occhio di Granchio, perché si può catturare sulla terra ferma.",ep:1,g:589,l:4,wd:true,fm:true,w:1,p:1};
I.u[2584] = {n:"Mano di Boo",t:15,d:"Questa Mano di Boo è ricoperta di fango. A meno che non ci sia niente sotto il fango... neanche la Mano di Boo.",ep:2,g:590,l:19,wd:true,fm:true,w:1,p:1};
I.u[2585] = {n:"Cuore di Fango del Boo",t:15,d:"Con il suo Cuore di Fango, il Boo è un essere difficile da catalogare nella catena alimentare. Ma pensandoci bene, sarebbe sicuramente l\'ultimo anello.",ep:2,g:591,l:19,wd:true,fm:true,w:1,p:1};
I.u[2586] = {n:"Ala di Dragacchino Rosso Selvaggio",t:104,d:"Questa ala sa di zolfo. Qualsiasi bravo allevatore ti dirà che è la parte più tenera per un barbecul. Ricordati di condirla però, perché l\'ala è la parte più scialba.",ep:2,g:592,l:29,wd:true,fm:true,w:1,p:1};
I.u[2587] = {n:"Accetta del Taglialegna",t:19,d:"Questa accetta è un attrezzo indispensabile per tutti i Taglialegna. Non si può certo dire certo che sia molto utile, vista l\'impossibilità di usarla per tagliare gli alberi, ma i Taglialegna si sentono più calmi e al sicuro quando la portano appesa alla cintura.",ep:1,g:6,l:3,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,30,30,false,false],c:"CV>2",p:20};
I.u[2588] = {n:"Ala di Dragacchino",t:104,d:"Il Dragacchino domestico è molto più buono di quello selvaggio. Non ha il retrogusto di zolfo e la carne è gustosa al punto giusto. È il piatto preferito di tutti i bambini!",ep:2,g:593,l:29,wd:true,fm:true,w:1,p:1};
I.u[2589] = {n:"Accetta Hevlalav",t:19,d:"Questa piccola ascia non può tagliare gli alberi, ma può servire per difendersi contro i piccoli mostri. Tuttavia, se incontri un Minotoror ti conviene correre!",ep:1,g:7,l:6,wd:true,fm:true,w:10,an:17,e:[10,4,1,1,40,40,false,false],p:60};
I.u[2590] = {n:"Ascia Vôr\'Om",t:19,d:"Questa serie di asce fu concepita da un bwork apprendista Forgiatore. Sono ben equilibrate e relativamente potenti. Senza saperlo questo bwork aveva appena creato l\'ascia di guerra dei giovani avventurieri.",ep:1,g:13,l:12,wd:true,fm:true,w:15,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>10",p:120};
I.u[2591] = {n:"Coda di Dragacchino Rosso Selvaggio",t:65,d:"L\'interesse di questa coda è semplice: appoggiala su una roccia e falla girare. Quando la coda si ferma, segui la direzione indicata dalla punta. Per millenni questo è stato il modo di spostarsi dei Sadida.",ep:2,g:594,l:27,wd:true,fm:true,w:1,p:1};
I.u[2592] = {n:"Tagliatrice di Bombù",t:19,d:"Leggera e maneggevole, quest\'ascia facilita i gesti ampi necessari per tagliare un Bombù senza alcun rischio.",ep:13,g:15,l:39,wd:true,fm:true,w:1,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>20&CW>20",p:390};
I.u[2593] = {n:"Potatrice di Oliviola",t:19,d:"Questa ascia, fatta di Oliviola, è l\'unica ascia capace di resistere ai raggi violetti dell\'Oliviola. Come combattere il male con il male, insomma...",ep:14,g:14,l:42,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>60",p:420};
I.u[2594] = {n:"Coda di Dragacchino",t:65,d:"Stranamente la Coda di Dragacchino non ha nessun potere magico. Come al Coccodrail, la coda ricresce rapidamente. Una leggenda racconta anche che un Dragacchino era cresciuto all\'estremità della coda. Sei avvisato!",ep:2,g:595,l:17,wd:true,fm:true,w:1,p:1};
I.u[2595] = {n:"Ascia di Pietra",t:19,d:"Questa ascia, anche se primitiva, è molto efficace. \nUn po\' come certi vecchi saggi.",ep:5,g:2,l:51,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>50&CV>60",p:510};
I.u[2596] = {n:"Latte di Dragacchino",t:15,d:"Gli allevatori sono contenti di poter mungere i loro Dragacchini. L\'unico problema è che questo latte è invendibile perché schifosissimo. Quindi non serve ad altro che ad allattare i piccoli Dragacchini.",ep:2,g:424,l:29,wd:true,fm:true,w:1,p:1};
I.u[2597] = {n:"Ascia di Breccia",t:19,d:"Questa lunga ascia si infila nei più piccoli interstizi degli alberi per meglio spaccarli in due. In combattimento è usata allo stesso modo, infatti l\'avversario ha sempre uno o due interstizi da usare.",ep:14,g:16,l:54,wd:true,fm:true,w:20,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>70",p:540};
I.u[2598] = {n:"Aculeo di Dragacchino Rosso Selvaggio",t:47,d:"Questo Aculeo non è altro che una protuberanza ossea. Il Dragacchino se ne serve talmente poco che ci si domandava come facesse a consumarlo così tanto. Da quando però i Biologi l\'hanno visto strofinarsi ai Trooll, si è capito tutto.",ep:2,g:596,l:29,wd:true,fm:true,w:1,p:1};
I.u[2599] = {n:"Aculeo di Dragacchino",t:47,d:"Situato sulla schiena dei Dragacchini, questo Aculeo ti servirà a grattarti tra le gambe, sempre che tu riesca a salire sul Dragacchino.",ep:2,g:597,l:29,wd:true,fm:true,w:1,p:1};
I.u[2600] = {n:"Tagliatrice di Parole",t:19,d:"Questa grossa ascia fa un rumore assordante quando si abbatte su qualcosa, il che provoca spesso un silenzio incredibile intorno a sé. È già qualcosa di buono, no?",ep:14,g:17,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>30&CV>30&CA>30",p:660};
I.u[2601] = {n:"Ascia Darsson",t:19,d:"Darsson era un valoroso Anutrof estremamente maldestro. Siccome si faceva sempre cadere la pala durante i combattimenti, ebbe l\'ingegnosa idea di attaccare un\'ascia di riserva alla cintura. Questo gli salvò la vita parecchie volte, fino a quando non fece cadere anche l\'ascia...",ep:14,g:18,l:57,wd:true,fm:true,w:15,an:17,e:[12,4,1,1,30,30,false,false],c:"CC>20&CA>20&CV>20",p:570};
I.u[2602] = {n:"Petalo di Trukikol",t:35,d:"Delle dimensioni di un Occhio di Granchio, il Petalo di Trukikol è composto da numerose bollicine appiccicose e spugnose al tatto. È spesso utilizzato per riparare i tetti dopo le forti tempeste di fine anno.",ep:12,g:598,l:12,wd:true,fm:true,w:1,p:1};
I.u[2603] = {n:"Tagliatrice di Parti",t:19,d:"Quest\'ascia è molto utile per staccare certe parti noiose dagli alberi, in particolare i piccoli bozzi del tronco. In questo modo potrai avere un albero perfettamente liscio e tondo.",ep:13,g:2,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CS>30",p:660};
I.u[2604] = {n:"Alabarda del Miliziano",t:19,d:"Questa Alabarda è utilizzata in particolare dai miliziani di Amakna. La sua lunghezza e la sua efficacia compensano tutti gli altri difetti.",ep:13,g:3,l:78,wd:true,fm:true,w:30,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>30&CS>30&CW>30&CC>5",p:780};
I.u[2605] = {n:"Pelle di Trukikol",t:59,d:"Non stupirti se ti dicono che la pelle del Trukikol si appiccica. Grazie a lei, si riesce ad incollare tutto sul soffitto. Bisogna dare anche il merito al Contadino che l\'ha brevettata: un certo Rulio de Scautch.",ep:12,g:599,l:12,wd:true,fm:true,w:1,p:1};
I.u[2606] = {n:"Accetta Saggia",t:19,d:"Su questa grossa accetta sono incise numerose iscrizioni che ricordano le nozioni Amakniane di base. Il suo inventore Claus Ansipedi voleva dare un accenno di cultura ai bruti duri e puri... causa persa, è morto infatti con il cranio spaccato in due.",ep:4,g:4,l:81,wd:true,fm:true,w:30,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CA>50&CI>50",p:810};
I.u[2607] = {n:"Trukikol Morto",t:15,d:"Hai fatto bene a raccoglierlo, è intatto. Morto, ma intatto.",ep:12,g:600,l:14,wd:true,fm:true,w:10,p:1};
I.u[2608] = {n:"Franciascia Basca",t:19,d:"Quest\'ascia fa spesso il giro del mondo cominciando dal basso. Infatti questo tipo di ascia è stato creato a sud di Amakna da una piccola gilda di Cacciatori di tesori famosi per la loro efficacia.",ep:18,g:1,l:84,wd:true,fm:true,w:18,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>100&CS>50",p:840};
I.u[2609] = {n:"Carapace Verde Vuoto",t:107,d:"Ma dove si è nascosto il proprietario? Deve essere uscito a comprarsi pane e pomodori.",ep:7,g:601,l:24,wd:true,fm:true,w:2,p:1};
I.u[2610] = {n:"Carapace Rosso Vuoto",t:107,d:"Ma dove si è nascosto il proprietario? Deve aver traslocato da poco.",ep:7,g:602,l:24,wd:true,fm:true,w:2,p:1};
I.u[2611] = {n:"Carapace Giallo Vuoto",t:107,d:"Ma dove si è nascosto il proprietario? Forse è dentro a fare un pisolino.",ep:7,g:603,l:24,wd:true,fm:true,w:2,p:1};
I.u[2612] = {n:"Roncola per Pesci",t:19,d:"Questa lunga ascia è usata dai marinai esperti per affrontare i pesci giganti che attaccano le barche. Figurati cosa può fare contro i mostri più piccoli...",ep:14,g:4,l:87,wd:true,fm:true,w:32,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>50&CA>50",p:870};
I.u[2613] = {n:"Carapace Blu Vuoto",t:107,d:"Ma dove si è nascosto il proprietario? Dev\'essere sotto la doccia...",ep:7,g:604,l:24,wd:true,fm:true,w:2,p:1};
I.u[2614] = {n:"Ascia di Donna Osa",t:19,d:"Donna Osa era un\'affascinantissima principessa innocente e fresca. Tutti furono sorpresi quando, durante un attacco Bwork nella sua città, uscì con quest\'ascia tra le mani e fracassò da sola la metà dell\'esercito nemico.",ep:18,g:5,l:90,wd:true,fm:true,w:28,an:17,tw:true,e:[10,4,1,1,40,40,false,false],c:"CV>150&CW>50&CS>250",p:900};
I.u[2615] = {n:"Ascia di Luk Abir",t:19,d:"Quest\'ascia è famosa per la sua capacità di far terminare definitivamente e molto rapidamente una disputa tra due Anutrof ubriachi.",ep:18,g:8,l:96,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>120",p:960};
I.u[2616] = {n:"Casa di Bardi",t:19,d:"Quest\'ascia prende il nome dal test che fu usato per provare la sua terribile efficacia: un\'ascia gigante e una sala piena di bardi.",ep:14,g:7,l:99,wd:true,fm:true,w:40,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>100&CS>100",p:990};
I.u[2617] = {n:"Fetta di Nochkokos",t:15,d:"Haaa... finalmente un oggetto che fa pensare alle vacanze. Questa Agenzia di Viaggi ti aspetta a porte aperte!",ep:12,g:605,l:14,wd:true,fm:true,w:1,p:1};
I.u[2618] = {n:"kokosnuccia",t:15,d:"Per sorseggiare qualcosa di fresco non c\'è niente di meglio di una cannuccia colorata. Ora devi solo riuscire a trovare un buco nella Nochkoko.",ep:12,g:433,l:14,wd:true,fm:true,w:1,p:1};
I.u[2619] = {n:"Kokolatte",t:15,d:"Ecco una buona idea: avere del Kokolatte in bottiglia, per poterne bere quando si vuole e dove si vuole.",ep:12,g:423,l:14,wd:true,fm:true,w:1,p:1};
I.u[2620] = {n:"Rum di Qualità",t:15,d:"Questo Rum deve appartenere ad una cantina molto pregiata. A meno che non sia rimasto chiuso in una tasca per molte generazioni.",ep:12,g:177,l:94,wd:true,fm:true,w:1,p:1};
I.u[2621] = {n:"Barba del Chuko",t:15,d:"Hai appena strappato la Barba dal mento del Chuko. Stranamente vi sono rimasti attaccati i Denti... Ecco cosa vuol dire essere morti da un pezzo... venirsene via a pezzi...",ep:12,g:606,l:94,wd:true,fm:true,w:1,p:1};
I.u[2622] = {n:"Fibbia del Chuko",t:15,d:"Dal buco di questa Fibbia sette generazioni di pirati ti guardano.",ep:12,g:607,l:94,wd:true,fm:true,w:2,p:1};
I.u[2623] = {n:"Bwak Scheletrico",t:15,d:"Gli allevatori hanno sempre creduto che i Bwak volassero via lontano alla fine della loro vita, ma questo Bwak deve essere un\'eccezione alla regola.",ep:12,g:608,l:94,wd:true,fm:true,w:1,p:1};
I.u[2624] = {n:"Foglia di Kokoko",t:36,d:"Alcuni Cacciatori arditi vogliono a tutti i costi impadronirsi di una Foglia di Kokoko, per poi non tornare mai più su quest\'isola maledetta. Ma perché?",ep:12,g:609,l:42,wd:true,fm:true,w:1,p:1};
I.u[2625] = {n:"Bambola Vudù Thierry",t:15,d:"Questa Bambola sprigiona forza, mai hai la strana sensazione che aspetti qualcuno.",ep:12,g:610,l:51,wd:true,fm:true,w:2,p:1};
I.u[2626] = {n:"Bambola Vudù Jav",t:15,d:"Questa Bambola sprigiona forza, mai hai la strana sensazione che aspetti qualcuno.",ep:12,g:611,l:51,wd:true,fm:true,w:2,p:1};
I.u[2627] = {n:"Bambola Vudù Sarbak",t:15,d:"Questa Bambola sprigiona forza, mai hai la strana sensazione che aspetti qualcuno.",ep:12,g:612,l:51,wd:true,fm:true,w:2,p:1};
I.u[2628] = {n:"Bambola Vudù Arciere",t:15,d:"Questa Bambola sprigiona forza, mai hai la strana sensazione che aspetti qualcuno.",ep:12,g:613,l:51,wd:true,fm:true,w:2,p:1};
I.u[2629] = {n:"Caracapo Minotoris",t:17,d:"Questo mantello d\'aspetto reale offre una protezione eccezionale. Si tratta del modello che ha reso famosa una celebre Sarta, poco prima di morire per il successo, schiacciata dai fan.",ep:13,g:55,l:121,wd:true,fm:true,w:10,p:38500};
I.u[2630] = {n:"Barattolo di Glutovora",t:15,d:"La Glutovora non è molto generosa, quindi devi ritenerti fortunato ad aver ottenuto questo barattolo ben riempito. Ora non ti resta che capirne l\'utilità.",ep:12,g:614,l:44,wd:true,fm:true,w:1,p:1};
I.u[2631] = {n:"Stomaco di Glutovora",t:15,d:"Ecco lo stomaco più resistente che tu possa trovare. Grazie alla sua elasticità, potrai persino nasconderti lì dentro, se lo desideri.",ep:12,g:615,l:44,wd:true,fm:true,w:1,p:1};
I.u[2632] = {n:"Gluto Rum",t:15,d:"Questa bottiglia è stata abbandonata all\'interno di una Glutovora. Che spreco! Però sembra che sia invecchiato bene e che l\'aroma sia migliore. Se i Contadini lo sapessero, riempirebbero interi magazzini di Glutovore.",ep:12,g:177,l:44,wd:true,fm:true,w:1,p:1};
I.u[2633] = {n:"Rum Furbo",t:15,d:"Ah, ecco l\'imbroglio. La Furbazza è talmente furba che ha riempito una bottiglia di Rum con del... eh sì, del Rum... ma con un odore che si sente a chilometri di distanza: il Trukikol seccato.",ep:12,g:177,l:24,wd:true,fm:true,w:1,p:1};
I.u[2634] = {n:"Lancia Rotta",t:15,d:"Senza la sua Lancia, la Furbazza farà meno la furbetta. Ma tu cosa ne farai?",ep:12,g:616,l:24,wd:true,fm:true,w:2,p:1};
I.u[2635] = {n:"Pan Ontà",t:33,d:"Questa ricetta è stata elaborata da un rivale di Xavier il Panettiere, e cioè Daniul Garniul il Panettiere. Il nome era così stupido che i suoi clienti non smettevano di prenderlo in giro, così lui si vendicava impastando con i piedi.",ep:1,g:13,l:80,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2636] = {n:"Pain Tad",t:33,d:"Questo pane racchiude deliziosi pezzettini di carne, che hanno il sapore e l\'aspetto del pollame, ma è meglio non fidarsi... Se ci si avvicina, si può sentire un leggero odore di Tofu.",ep:1,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2637] = {n:"L\'Artiglio",t:6,d:"Questa lama ricurva, fatta d\'osso, di cartilagine e di corno, è tagliente come un artiglio di Ecaflip. È solo un po\' più grossa e più pulita.",ep:13,g:33,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[2638] = {n:"L\'Artiglio Affilato",t:6,d:"Naturale al cento per cento, questa spada è come un sesto artiglio nelle mani di un Ecaflip. A proposito, fai attenzione a non grattarti con quest\'arma!",ep:14,g:34,l:68,wd:true,fm:true,w:12,an:14,e:[12,4,1,1,30,50,false,false],c:"CV>30&CA>30&CS>30",p:6800};
I.u[2639] = {n:"Falso Artiglio di Ceangal",t:6,d:"Una forgiatrice Ecaflip ebbe l\'idea di forgiare questa spada dopo il suo fallimento nel controllo della tecnica ancestrale che portava lo stesso nome. Diceva che almeno questo artiglio non l\'avrebbe fregata.",ep:14,g:35,l:95,wd:true,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[2640] = {n:"Bastone Carnivoro",t:4,d:"Così stranamente scolpito, questo Bastone non è sicuramente di queste parti. Ha l\'odore dei vecchi posti umidi e oscuri di Brakmar.",ep:1,g:24,l:30,wd:true,fm:true,w:56,an:12,e:[3,5,1,1,20,50,false,false],s:7,p:1000};
I.u[2641] = {n:"Toady",t:16,d:"Rosso, bianco ma soprattutto di classe, questo cappello ti farà fare una bellissima figura alle riuscitissime serate dell\'ambasciatore.",ep:1,g:51,l:30,wd:true,fm:true,w:10,s:7,p:2700};
I.u[2642] = {n:"Mascella di Rib",t:47,d:"Il Rib è già un po\' magrolino così, ma se poi è anche senza Mascella... diventa tanto offensivo quanto un esercito di zecche ibernate.",ep:3,g:617,l:33,wd:true,fm:true,w:1,p:1};
I.u[2643] = {n:"Zanna di Drago Maiale",t:47,d:"Questa zanna appartiene a uno dei più celebri predatori delle montagne di Amakna: il Drago Maiale. Alcuni Cacciatori sarebbero pronti a vendere la loro famiglia per ottenere quello che hai tra le mani. Forse è l\'occasione che cercavi per comprare una famiglia in sconto.",ep:2,g:618,l:70,wd:true,fm:true,w:1,p:1};
I.u[2644] = {n:"Coda di Drago Maiale",t:65,d:"Che prelibatezza questo gran pezzo di Coda di Drago Maiale! Falla saltare in padella con un po\' di semi di sesamo, condiscila con un po\' di Salsa Icciona, e i tuoi invitati non se ne andranno più. Non è geniale? No? Ah no...?",ep:2,g:619,l:70,wd:true,fm:true,w:1,p:1};
I.u[2645] = {n:"Muso di Drago Maiale",t:15,d:"Date le condizioni del muso, il Drago Maiale non deve aver visto il colpo arrivare. Poverino!",ep:2,g:620,l:70,wd:true,fm:true,w:1,p:1};
I.u[2646] = {n:"Mutande in Cuoio di Maiale da Latte",t:56,d:"Queste Mutande belle larghe renderanno felice il Maiale da Latte: le cuciture sono elastiche e rinforzate per renderle più efficaci durante i combattimenti ravvicinati. Come da tradizione, queste mutande non devono mai essere lavate, altrimenti perderebbero tutte le loro proprietà intrinseche ancora sconosciute ma temute.",ep:1,g:621,l:20,wd:true,fm:true,w:1,p:1};
I.u[2647] = {n:"Orecchio del Maiale da Latte",t:106,d:"Normalmente il Maiale da Latte non è cacciato per le sue Orecchie, ma piuttosto per l\'avorio. Ma se l\'avorio manca...",ep:1,g:623,l:20,wd:true,fm:true,w:1,p:1};
I.u[2648] = {n:"Artigli del Kwak",t:15,d:"Il Kwak non è per niente della stessa famiglia dello sciacallo, tuttavia sotto i suoi artigli ci sono strani sedimenti che è meglio non descrivere.",ep:1,g:624,l:30,wd:true,fm:true,w:1,p:1};
I.u[2649] = {n:"Verme di Terra",t:15,d:"Questo Verme è il piatto preferito dei Kwak selvaggi. La cosa più strana è che sia ancora vivo, anche dopo essere stato estratto dallo stomaco del Kwak.",ep:5,g:625,l:30,wd:true,fm:true,w:1,p:1};
I.u[2650] = {n:"Verme di Acqua",t:15,d:"Questo Verme è il piatto preferito dei Kwak selvaggi. La cosa più strana è che sia ancora vivo, anche dopo essere stato estratto dallo stomaco del Kwak.",ep:1,g:626,l:30,wd:true,fm:true,w:1,p:1};
I.u[2651] = {n:"Verme di Fuoco",t:15,d:"Questo Verme è il piatto preferito dei Kwak selvaggi. La cosa più strana è che sia ancora vivo, anche dopo essere stato estratto dallo stomaco del Kwak.",ep:5,g:627,l:30,wd:true,fm:true,w:1,p:1};
I.u[2652] = {n:"Verme di Aria",t:15,d:"Questo Verme è il piatto preferito dei Kwak selvaggi. La cosa più strana è che sia ancora vivo, anche dopo essere stato estratto dallo stomaco del Kwak.",ep:5,g:628,l:30,wd:true,fm:true,w:1,p:1};
I.u[2653] = {n:"Arakne Maggiore Morta",t:15,d:"Hai fatto bene a raccoglierla, è intatta. Morta... ma intatta.",ep:1,g:629,l:43,wd:true,fm:true,w:10,p:1};
I.u[2654] = {n:"Uovo di Arakne Maggiore",t:105,d:"Il problema che si può avere con le Arakni è che con il caldo si rischia di ritrovarsi in mezzo a più generazioni in pochi giorni. Quindi evita di passeggiare nella foresta degli Alberagni quando fa troppo caldo.",ep:1,g:630,l:43,wd:true,fm:true,w:1,p:1};
I.u[2655] = {n:"Cintura Cuervochiale",t:10,d:"Questa cintura è stata fabbricata con i resti del Messer Cuervoc accuratamente cuciti insieme. Una volta indossata questa cintura dovresti sentirti più rispettato. Il Chuko ha persino accettato di prestare la propria fibbia per l\'occasione.",ep:13,g:56,l:120,wd:true,fm:true,w:10,p:36938};
I.u[2656] = {n:"Filo Resistente",t:15,d:"Se i Ciabattini e i Sarti conoscessero l\'esistenza di questo Filo Resistente, organizzerebbero la Settimana del Filo Resistente, la Fiera del Filo Resistente nonché il giorno santo del Filo Resistente.",ep:1,g:631,l:43,wd:true,fm:true,w:1,p:1};
I.u[2659] = {n:"Petalo di Girasole Selvatico",t:35,d:"Questo Petalo gira. Sì, gira in funzione del sole. Prova a mettertelo di mattina nella tasca destra, lo ritroverai la sera nella tasca sinistra.",ep:1,g:632,l:12,wd:true,fm:true,w:1,p:1};
I.u[2661] = {n:"Foglia di Girasole Selvatico",t:36,d:"Questa parte del Girasole non è solo la foglia della pianta, ma anche la sua volta plantare. Non ti stupire quindi se puzza di piedi.",ep:1,g:633,l:12,wd:true,fm:true,w:1,p:1};
I.u[2662] = {n:"Bava di Rosa Demoniaca",t:15,d:"Una rosa arrabbiata ha la cattiva abitudine di sbavare su chiunque le si avvicini. Ma sembra che sia un segno d\'affetto. Una rosa demoniaca arrabbiata che mostra affetto? Ma non scherziamo!",ep:1,g:634,l:8,wd:true,fm:true,w:1,p:1};
I.u[2663] = {n:"Fertilizzante",t:15,d:"Ogni bella pianta ha bisogno di un Fertilizzante, quindi le Anutrofine già in declino possono farne a meno...",ep:1,g:635,l:8,wd:true,fm:true,w:1,p:1};
I.u[2664] = {n:"Osso di Coccodrail",t:47,d:"Quest\'osso verdastro e quantomeno strano proviene da una zampa di Coccodrail, il quale ha certamente versato molte lacrime di Coccodrail quando si è accorto di aver perso una zampa.",ep:4,g:636,l:36,wd:true,fm:true,w:2,p:100};
I.u[2665] = {n:"Erba Folle",t:36,d:"Questo è il tipo di erba che si mette nei recinti dei Pappatutto. L\'erba folle è chiamata così perché, ogni tanto, si alza e scappa dai recinti... il che non è tanto comune per un ciuffo d\'erba.",ep:1,g:637,l:9,wd:true,fm:true,w:1,p:1};
I.u[2666] = {n:"Zoccolo del Minotoror",t:47,d:"Il Minotoror ha sicuramente schiacciato un bel po\' di avventurieri con questo zoccolo, ma dovrebbe smetterla di fare il furbo ballando su una sola zampa... anche se così in realtà fa più paura di prima...",ep:2,g:800,l:125,wd:true,fm:true,w:1,p:1};
I.u[2667] = {n:"Coda di Minotoror",t:65,d:"Vedere una coda di Minotoror è una grande impresa, senza il Minotoror insieme... Poverino, la starà cercando dappertutto... sempre che si sia accorto di averla persa. Tutto è possibile.",ep:2,g:640,l:125,wd:true,fm:true,w:1,p:1};
I.u[2669] = {n:"Pipistrello",t:15,d:"A volte i Vampiri si trasformano in Pipistrelli per scappare meglio. Ma prima di scappare fanno sempre una strana risata del tipo: \"niap nioop niap niap\". Questa risata è capace di disorientare un esercito di... zecche.",ep:3,g:641,l:21,wd:true,fm:true,w:1,p:1};
I.u[2673] = {n:"Uovo marcio",t:105,d:"È veramente vergognoso. Come si può deporre un Uovo di Tofu in stato di decomposizione? Bisogna veramente avere uno spirito Malefico per fare una cosa simile!",ep:1,g:642,l:3,wd:true,fm:true,w:1,p:1};
I.u[2674] = {n:"Zucchetta",t:46,d:"La zucchetta è deliziosa in questa stagione. Né troppo piccola per essere scialba, né troppo matura da trasformarsi in Cucuwbita, succulenta e rimborsata dal secco Huh.",ep:4,g:643,l:15,wd:true,fm:true,w:1,p:1};
I.u[2675] = {n:"Piuma di Tofu Malefico",t:53,d:"Il Tofu Malefico non ha molte piume e si beccherà un grande raffreddore. Non stupirti se lo sentirai starnutire di notte.",ep:1,g:644,l:3,wd:true,fm:true,w:1,p:1};
I.u[2676] = {n:"Noeul Morto",t:15,d:"Hai fatto bene a raccoglierlo, è intatto. Morto... ma intatto.",ep:4,g:645,l:274,wd:true,fm:true,w:10,p:1};
I.u[2677] = {n:"Cintura Chukosa",t:10,d:"Questa cintura è stata fabbricata con gli elementi più potenti del Chuko, in particolare con il suo celebre calzone. Ecco come mettere in agitazione tutte le filibustiere del bar dei pirati.",ep:12,g:41,l:98,wd:true,fm:true,w:10,p:25000};
I.u[2678] = {n:"Cintura Kokoketta",t:10,d:"Questa cintura assomiglia quasi a un perizoma, ti sarà molto utile se vuoi camuffarti tra i Kokoko dell\'isola di Moon o semplicemente se vuoi fare la corte a un Kokoko.",ep:12,g:40,l:42,wd:true,fm:true,w:10,p:4800};
I.u[2681] = {n:"Cintura Tartaruga Gialla",t:10,d:"Questa piccola cintura è ideale per proteggere le parti sensibili... dai colpi critici.\nPrima di provarla, controlla comunque che il Ciabattino abbia tolto il proprietario dal suo carapace.",ep:7,g:43,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2683] = {n:"Cintura Tartaruga Blu",t:10,d:"Questa piccola cintura è ideale per proteggere le parti sensibili... dai colpi critici.\nPrima di provarla, controlla comunque che il Ciabattino abbia tolto il proprietario dal suo carapace.",ep:7,g:44,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2685] = {n:"Cintura Tartaruga Verde",t:10,d:"Questa piccola cintura è ideale per proteggere le parti sensibili... dai colpi critici.\nPrima di provarla, controlla comunque che il Ciabattino abbia tolto il proprietario dal suo carapace.",ep:7,g:42,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2687] = {n:"Cintura Tartaruga Rossa",t:10,d:"Questa piccola cintura è ideale per proteggere le parti sensibili... dai colpi critici.\nPrima di provarla, controlla comunque che il Ciabattino abbia tolto il proprietario dal suo carapace.",ep:7,g:45,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2688] = {n:"Cintura Kollante",t:10,d:"Il meno che si possa dire è che una volta infilata questa cintura sarà impossibile perderla. È l\'ideale per gli storditi e per chi è sempre vittima di furti.",ep:12,g:46,l:50,wd:true,fm:true,w:10,p:6600};
I.u[2689] = {n:"Cintura Espulsione",t:10,d:"Il Ciabattino che ha creato questa cintura con i resti di un Dragacchino deve avere veramente poca immaginazione per avergli dato un nome così stupido.",ep:2,g:47,l:29,wd:true,fm:true,w:10,p:2400};
I.u[2710] = {n:"Cintura Espulsione Selvaggia",t:10,d:"Questa cintura è una versione migliorata con rinforzi in ferro della classica Cintura Espulsione. È stata specialmente concepita per la caccia ai Dragacchini Selvaggi nelle contrade selvagge.",ep:2,g:48,l:32,wd:true,fm:true,w:10,p:3000};
