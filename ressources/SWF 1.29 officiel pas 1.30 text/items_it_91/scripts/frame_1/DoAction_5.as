I.u[2138] = {n:"Assegno della Taverna Oh\' Ver d\'Os",t:24,d:"Questo assegno serve a pagare la nuova tassa sulle taverne annunciata da Oto Mustam.",ep:2,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2139] = {n:"Lista di Danathor",t:24,d:"- 3 * Pezzo di Blop Reginetta\n- 1 * Tazza\n- 2 * Ciliegie",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2140] = {n:"Busta",t:24,d:"...",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2141] = {n:"Polmone delle Pianure",t:24,d:"Questa collana ornata da un enorme diamante verde è talmente vistosa che non ci si accorge neanche della persona che la indossa... il che è molto comodo in certe situazioni.",ep:1,g:66,l:1,wd:true,fm:true,w:0,p:1};
I.u[2143] = {n:"Chiave dei Mercenari",t:15,d:"Hai tra le mani una delle chiavi che potrà farti entrare dai Mercenari.",ep:1,g:404,l:1,wd:true,fm:true,w:0,p:1};
I.u[2144] = {n:"Champello Banale",t:24,d:"Questo Champello non è di buona manifattura, ma ha la qualità di proteggere dal sole.",ep:2,g:68,l:1,wd:false,fm:true,w:0,p:1};
I.u[2145] = {n:"Spilla di Sbab",t:24,d:"Questa spilla ti è stata data da Sbab in segno di rispetto per il tuo onore di demone.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2146] = {n:"Confessione di Oni Tnec",t:24,d:"La confessione di Oni Tnec dove descrive come ha atrocemente ucciso Rimaraf.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2147] = {n:"Veleno di Scorbuto",t:24,d:"Veleno di scorbuto con fattura a nome di Oni Tnec.",ep:2,g:39,l:1,wd:true,fm:true,w:0,p:1};
I.u[2148] = {n:"Resoconto interrogatorio",t:24,d:"Un rapporto che mostra tutti gli erroracci che Oni Tnec ha commesso nella sua inchiesta.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2149] = {n:"Badge di Oni Tnec",t:24,d:"Il badge di Oni Tnec ritrovato in casa di Rimaraf.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2150] = {n:"Seme di Scorbuto",t:58,d:"Questi semi sono stati fabbricati con della tossina di Scorbuto. Ingoiarne uno è mortale, non parliamo di due...",ep:14,g:405,l:36,wd:true,fm:true,w:1,p:1};
I.u[2151] = {n:"Blopisiero avvelenato",t:33,d:"Questo dolce è buonissimo, se non gli si aggiungono dei semi di scorbuto...",ep:3,g:406,l:30,wd:true,fm:true,w:5,p:1};
I.u[2152] = {n:"Colonnello Lyeno",t:32,d:"Porta il Colonnello Lyeno da Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2153] = {n:"Badge di Lyeno",t:24,d:"È il badge di Lyeno che hai raccolto vicino alla prigione in cui si trova.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2154] = {n:"Anello di Sendar",t:9,d:"Anello portato da Silesy.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2155] = {n:"Amuleto di Jiva",t:1,d:"Amuleto portato da Silesy",ep:1,g:19,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2156] = {n:"Spada di Giustizia",t:6,d:"Questa spada ti permette di diffondere la santa parola.",ep:1,g:16,l:1,wd:false,fm:true,w:1,an:14,e:[30,5,1,1,30,50,false,false],c:"PN~Silaisie",p:1};
I.u[2157] = {n:"Clint",t:16,d:"Il Clint è un cappello sobrio ma che dice la sua. L\'ultima versione è adatta sia alle avventuriere maliziose quanto agli avventurieri virili. È sicuramente un accessorio di qualità.",ep:1,g:38,l:50,wd:true,fm:true,w:10,c:"Ps=3",p:1};
I.u[2158] = {n:"Lettera di Oto Mustam per Sbab",t:24,d:"Questa lettera piena di ironia ha come unico scopo quello di denigrare Sbab.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2159] = {n:"Pergamena di Coraggio",t:14,d:"Questa pergamena ti permette di migliorare la Forza. Questo può essere utile per esempio quando un Kanigrù affamato ti salta addosso.",ep:1,g:2,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2160] = {n:"Pergamena di Scoraggiamento",t:14,d:"Questa pergamena ti permette di diminuire la Forza di un unico bersaglio. Questo può essere utile per esempio quando un Kanigrù arrabbiato salta su un tuo acerrimo nemico.",ep:1,g:4,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2161] = {n:"Pergamena di Scioltezza",t:14,d:"Questa pergamena ti permette di migliorare l\'Agilità. Questo può essere utile per esempio quando devi assolutamente schivare un Muulupo.",ep:1,g:6,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2162] = {n:"Pergamena di Rigidità",t:14,d:"Questa pergamena ti permette di diminuire l\'Agilità di un unico bersaglio. Questo può essere utile per esempio quando non devi fare fuggire il tuo avversario nel momento in cui si avvicina un Muulupo.",ep:16,g:5,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2163] = {n:"Armistizio",t:31,d:"Sei inattaccabile fino a quando non entrerai in combattimento.",ep:1,g:3,l:1,wd:true,fm:true,w:0,m:true,c:"Ps=0",p:1};
I.u[2164] = {n:"Campione di lava",t:24,d:"Questo campione è stato trovato a Est della miniera.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2165] = {n:"Campione di lava",t:24,d:"Questo campione è stato trovato a Ovest della miniera.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2166] = {n:"Campione di lava",t:24,d:"Questo campione è stato trovato vicino alla miniera.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2167] = {n:"Campione di lava",t:24,d:"Questo campione è stato trovato a Sud della miniera.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2168] = {n:"Inizio di Rapporto",t:24,d:"Questo rapporto comincia a descrivere gli inquietanti mutamenti della massa magmatica brakmariana.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2169] = {n:"Raaga",t:32,d:"Portare Raaga in una caverna magmatica.",ep:14,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2170] = {n:"Spada da Mercenario",t:6,d:"Questa lunga spada è pesante e poco maneggevole ma taglia a meraviglia, un po\' come una lunga spada pesante e poco maneggevole...",ep:1,g:25,l:1,wd:true,fm:true,w:1,an:14,tw:true,e:[30,5,1,1,25,50,false,false],p:1};
I.u[2171] = {n:"Rapporto di Raaga",t:24,d:"Questo rapporto descrive i cambiamenti caotici delle attività vulcaniche di Brakmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2172] = {n:"Lista dei campioni da trovare",t:24,d:"Raaga ti ha velocemente scritto le indicazioni da seguire per trovare dei buoni campioni di lava:\nCercare in un perimetro di 5 leghe.\nCercare dei piccoli aculei.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2173] = {n:"I segreti del linguaggio scoiattolo",t:25,d:"Questo dizionario ti permetterà di parlare con uno scoiattolo, o almeno di provarci...",ep:2,g:6,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[2174] = {n:"Lasciapassare Sala d\'Interrogatorio",t:24,d:"Questo pezzo di carta ti permette di entrare liberamente nelle piccole Sale d\'Interrogatorio della prigione.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2175] = {n:"Minaccia dell\'Intendente",t:24,d:"Una minaccia scritta da Danathor, per non dimenticare di proteggergli le spalle in futuro.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2176] = {n:"Indirizzo di Rimaraf",t:24,d:"Rimaraf abita in una casa di mattoni rossi al numero 13 del Vicolo del Tayo, nel quartiere della Macelleria.",ep:2,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[2177] = {n:"Spilla di Danathor",t:24,d:"Questa spilla ti è stata data da Danathor.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2178] = {n:"Modulo di Inchiesta n°36",t:80,d:"Questo modulo consente di identificare dei sospettati di atti criminali.\n(Clicca sulla pergamena, e poi su qualcuno per utilizzarlo)",ep:16,g:6,l:1,wd:true,fm:true,w:1,c:"PO!2181&PO!2177&Ps=1&Pa=27",ut:true,p:100};
I.u[2179] = {n:"Dente di Dragacchino",t:47,d:"Questo dente sembra molto tagliente. Potrebbe essere usato da chiunque come arma temibile. \nPer fortuna il dragacchino lo usa solo per masticare l\'insalata.",ep:2,g:419,l:20,wd:true,fm:true,w:2,p:1};
I.u[2180] = {n:"Resoconto interrogatorio",t:24,d:"L\'alibi di questa persona sembra inattaccabile...",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2181] = {n:"Resoconto interrogatorio",t:24,d:"Questa persona è sospetta, il suo alibi non sta in piedi...",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2182] = {n:"Biglietto di un investigatore",t:24,d:"Un investigatore della milizia ti sorveglia e ti sospetta dell\'assassino di Rimaraf.\nTi ha lasciato il suo biglietto quando ti ha interrogato...",ep:2,g:71,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2183] = {n:"Pozione d\'oblio di mestiere: Pescatore",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Pescatore",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2184] = {n:"Pozione d\'oblio di mestiere: Pescivendolo",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Pescivendolo",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2185] = {n:"Pozione d\'oblio di mestiere: Cacciatore",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Cacciatore",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2186] = {n:"Pozione d\'oblio di mestiere: Macellaio",t:44,d:"Questa pozione ti farà dimenticare il mestiere di Macellaio",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2187] = {n:"Pescis Decompetizione",t:41,d:"Questo pesce, che si può pescare solo nella pichina di Sufokia, è un incrocio di molte specie di pesci.",ep:7,g:400,l:1,wd:true,fm:true,w:20,p:1};
I.u[2188] = {n:"Canna da Pescis",t:20,d:"Solo questa canna permette di pescare i pescis della pichina di Sufokia.",ep:7,g:8,l:1,wd:true,fm:true,w:2,an:18,e:[1,5,1,5,10,10,false,true],p:50};
I.u[2189] = {n:"Certificato di buon voto",t:24,d:"Questo pezzettino di carta firmato da Satirev Refibrom certifica il tuo voto durante una sentenza... e che hai votato bene.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2190] = {n:"Modulo di Inchiesta n°33",t:80,d:"Questo Modulo di solito permette di far ammettere le colpe di un crimine ad un sospetto. Non ti rimane che riempirlo da te per creare un falso interrogatorio di \"Oni Tnec\".\n(Clicca qui e usalo su te stesso)",ep:16,g:6,l:1,wd:true,fm:false,w:1,c:"PO=2177&Ps=1&Pa=27",u:true,p:100};
I.u[2191] = {n:"Certificato di cattivo voto",t:24,d:"Questo pezzettino di carta firmato da Satirev Refibrom certifica il tuo voto durante una sentenza... e che hai votato male.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2192] = {n:"Documenti rubati",t:24,d:"Questi documenti top secret sono sigillati con un glifo di morte. Se li apri non potrai leggerli...",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2193] = {n:"Ciuffo di capelli di Puja",t:24,d:"Hai dato una bella lezione al figlio di Oto Mustam. Non lo apprezzerà sicuramente.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2194] = {n:"Promemoria",t:24,d:"Recupera 10 cortecce di Alberagno.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2195] = {n:"Dente",t:24,d:"Questo dente è probabilmente il tuo, vista la mazzata che ti ha dato Oto Mustam.\nSarebbe meglio, forse, aspettare che si calmi prima di parlargli di nuovo, a meno che tu non voglia farti massacrare un\'altra volta.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2196] = {n:"Conoscenza",t:29,d:"Questa benedizione aumenta la tua intelligenza durante i prossimi combattimenti.",ep:18,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2197] = {n:"La Forza Divorzio",t:14,d:"Questi anelli consentono di spezzare i sacri legami del matrimonio.",ep:1,g:13,l:1,wd:true,fm:true,w:0,ut:true,p:1};
I.u[2198] = {n:"Pergamena di Conoscenza",t:14,d:"Questa pergamena ti permette di migliorare l\'Intelligenza. Questo può essere utile per esempio quando devi conservare la calma davanti a due Bwork.",ep:1,g:7,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2199] = {n:"Pergamena di Stupidità",t:14,d:"Questa pergamena ti permette di diminuire l\'Intelligenza di un unico bersaglio. Questo può essere utile per esempio quando il tuo nemico è nel panico per l\'arrivo di due Bwork.",ep:1,g:8,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2200] = {n:"Minaccia di Satirev Refibrom",t:24,d:"Il grande giudice di Brakmar non vuole più vederti. Sembra che tu non occupi neanche un piccolissimo spazio nel suo cuore... ma la verità è che non ha cuore.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2201] = {n:"Serenità",t:29,d:"Questa maledizione ti impedirà di acquisire Saggezza nei prossimi combattimenti.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2202] = {n:"Senilità",t:30,d:"Questa maledizione diminuirà la tua Saggezza nel prossimo combattimento.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2203] = {n:"Pergamena di Moderazione",t:14,d:"Questa pergamena ti permette di migliorare la Saggezza. Questo può essere utile per esempio quando devi arrivare più velocemente alla caviglia di Dark Vlad.",ep:1,g:9,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2204] = {n:"Pergamena di Senilità",t:14,d:"Questa pergamena ti permette di diminuire la Saggezza di un unico bersaglio. Questo può essere utile per esempio quando il tuo nemico cerca di arrivare più velocemente di te alla caviglia di Dark Vlad.",ep:1,g:10,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2205] = {n:"Cambiamento di ordine",t:24,d:"Questo biglietto indica che hai già effettuato un combiamento di ordine.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2206] = {n:"Buona sorte",t:29,d:"Questa benedizione aumenterà la tua Fortuna nel prossimo combattimento.",ep:18,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2207] = {n:"Foglio di detenzione",t:24,d:"Su questo pezzo di carta sono indicati i crimini che hai commesso, nonché la data in cui sei stato incarcerato...",ep:2,g:73,l:1,wd:true,fm:true,w:0,p:1};
I.u[2208] = {n:"Iella",t:30,d:"Questa maledizione diminuirà la tua Fortuna nel prossimo combattimento.",ep:1,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2209] = {n:"Pergamena di Fortuna",t:14,d:"Questa pergamena ti permette di migliorare la Fortuna. Questo può essere utile per esempio per trovare più facilmente un Tofu in una balla di fieno.",ep:1,g:11,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2210] = {n:"Pergamena di Iella",t:14,d:"Questa pergamena ti permette di diminuire la Fortuna di un bersaglio unico. Questo può essere utile per esempio quando il tuo nemico tenta di fare fortuna...",ep:1,g:12,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2211] = {n:"Vestito Yopesco",t:14,d:"Grazie a questo vestito splenderai durante le serate mondane. L\'unico problema è che la gente non perderà neanche un\'occasione per dirti che sei furbo come uno Yop.",ep:1,g:14,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2212] = {n:"Vestito Xeloresco",t:14,d:"Con questo cappello e qualche altro accessorio incluso, la somiglianza è perfetta. Sei proprio uno Xelor, non c\'è ombra di dubbio.",ep:1,g:15,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2213] = {n:"Vestito Sadidesco",t:14,d:"Basta poco per assomigliare a un Sadida: uno scendiletto, lo sguardo addormentato e la testa incastrata tra le gambe. L\'effetto è garantito.",ep:1,g:16,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2214] = {n:"Attitudine Yop",t:31,d:"Avrai l\'attitudine Yop fino a quando non entrerai in combattimento",ep:1,g:4,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2215] = {n:"Attitudine Xelor",t:31,d:"Avrai l\'attitudine Xelor fino a quando non entrerai in combattimento",ep:1,g:5,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2216] = {n:"Attitudine Sadida",t:31,d:"Avrai l\'attitudine Sadida fino a quando non entrerai in combattimento",ep:1,g:6,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2217] = {n:"Vestito Fecaesco",t:14,d:"Questa parrucca era dentro un vecchio sgabuzzino, ecco il perché del suo aspetto un po\' antico. È comunque impressionante la tua somiglianza con un Feca quando la indossi (perche tu lo vuoi).",ep:1,g:17,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2218] = {n:"Attitudine Feca",t:31,d:"Avrai l\'attitudine Feca fino a quando non entrerai in combattimento.",ep:1,g:7,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2219] = {n:"Vestito Aniripsesco",t:14,d:"Queste ali di Aniripsa non ti faranno volare. Quindi evita di fare il furbo davanti ai tuoi amici, rischieresti di fare un atterraggio alquanto ridicolo!",ep:1,g:18,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2220] = {n:"Attitudine Aniripsa",t:31,d:"Avrai l\'attitudine Aniripsa fino a quando non entrerai in combattimento.",ep:1,g:8,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2221] = {n:"Vestito Anutrofesco",t:14,d:"Questa falsa barba ti fa assomigliare a un Anutrof, ma non solo... ti dà anche l\'alito di un Anutrof del sabato sera. Altro che febbre!",ep:1,g:19,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2222] = {n:"Attitudine Anutrof",t:31,d:"Avrai l\'attitudine Anutrof fino a quando non entrerai in combattimento.",ep:1,g:9,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2223] = {n:"Vestito Sàcridesco",t:14,d:"Un po\' di sangue di Tofu, delle vecchie cicatrici, uno sguardo da pirata psicopatico ed è fatta. Potrai partecipare alle riunioni dei Sàcridi infiltrandoti tra di loro e senza farti riconoscere.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2224] = {n:"Attitudine Sàcrido",t:31,d:"Avrai l\'attitudine Sàcrido fino a quando non entrerai in combattimento",ep:1,g:10,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2225] = {n:"Vestito Etramesco",t:14,d:"Un Kwane, un mantello sulla testa... l\'illusione è perfetta. Se indossi questo vestito avrai sicuramente l\'aria di un terribile e abietto personaggio uscito dal fondo di un cimitero: un Etram, insomma.",ep:1,g:21,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2226] = {n:"Attitudine Etram",t:31,d:"Avrai l\'attitudine Etram fino a quando non entrerai in combattimento.",ep:1,g:11,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2227] = {n:"Vestito Osamodesco",t:14,d:"Mettiti questa coda forcuta e queste corna che ti calzeranno a pennello, e preparati a partecipare alle famose feste \"vip\" che gli Osamodas fanno di nascosto.",ep:1,g:22,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2228] = {n:"Attitudine Osamodas",t:31,d:"Avrai l\'attitudine Osamodas fino a quando non entrerai in combattimento.",ep:1,g:12,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2229] = {n:"Vestito Ecaflipesco",t:14,d:"Ci troverai delle orecchie di pelo di Wabbit molto morbide, una coda tigrata e una scatola di pulci eccitate. Non c\'è dubbio, quando rifilerai queste bestiole ai tuoi vicini, nessuno potrà dubitare del tuo talento di trasformista.",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2230] = {n:"Attitudine Ecaflip",t:31,d:"Avrai l\'attitudine Ecaflip fino a quando non entrerai in combattimento.",ep:1,g:13,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2231] = {n:"Vestito Ocraesco",t:14,d:"L\'Ocra, come avete notato, va in giro sempre con la sua faretra. Non c\'è da stupirsi allora che, se indossi questo vestito, la gente ti scambi per uno di loro. Ma è solo un bluff, come ti piace fregarli ogni volta!",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2232] = {n:"Attitudine Ocra",t:31,d:"Avrai l\'attitudine Ocra fino a quando non entrerai in combattimento.",ep:1,g:14,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2233] = {n:"La Croccatrice",t:10,d:"Questa cintura fu creata da Xof il Volpo, il quale ebbe la buona idea di raccogliere tutti i denti possibili e immaginabili su un campo di battaglia Wabbit. Da quel giorno, tale gesto è diventato quasi un rituale.",ep:8,g:20,l:28,wd:true,fm:true,w:20,c:"CS<40&CI>80",p:2400};
I.u[2234] = {n:"Attitudine Bonta",t:31,d:"Avrai l\'attitudine Bonta fino a quando non entrerai in combattimento.",ep:1,g:15,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2235] = {n:"Attitudine Brakmar",t:31,d:"Avrai l\'attitudine Brakmar fino a quando non entrerai in combattimento.",ep:1,g:16,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2236] = {n:"Vestito Bontesco",t:14,d:"Indossando questo vestito sarai fermato da un buon numero di avventurieri che ti saluteranno e domanderanno il cammino da seguire.",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2237] = {n:"Vestito Brakmaresco",t:14,d:"Indossando questo vestito sarai temuto da tutti.",ep:1,g:26,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2239] = {n:"Polvere di Aniripsa",t:48,d:"Questa polvere è prodotta in piccole quantità con ali di Aniripsa. Sembra possedere virtù curative per i famigli.",ep:3,g:260,l:1,wd:true,fm:true,w:1,p:1000};
I.u[2240] = {n:"Piccola Fata di Artificio Rossa",t:74,d:"Ideale per le piccole feste di matrimonio, perfetta per la festa della Mutanda del Capitano Chafer.",ep:16,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:350};
I.u[2241] = {n:"Gelatina Menta Reale",t:110,d:"La Gelatina Menta Reale ha depredato più di un avventuriero un po\' troppo incosciente, ma eccola annientata. Attenzione: è sconsigliato consumarla come una volgare Gelatina Menta.",ep:7,g:408,l:100,wd:true,fm:true,w:1,p:100};
I.u[2242] = {n:"Gelatina Fragola Reale",t:110,d:"Il concentrato di Gelatina Fragola Reale può trasformare qualsiasi tabi pacifista in una macchina da guerra assetata di sangue. Attenzione quindi a proporla come aperitivo ai tuoi amici.",ep:7,g:409,l:150,wd:true,fm:true,w:1,p:100};
I.u[2245] = {n:"Pinza di Scorbuto",t:47,d:"Prima usata per grattare il fondoschiena, oggi è anche molto utile come gancio da muro per appendere i mantelli. Funziona benissimo anche se l\'agganci nel fondoschiena, ma è un pelino più doloroso.",ep:14,g:411,l:36,wd:true,fm:true,w:1,p:1};
I.u[2246] = {n:"Corona Spezzata del Tofu Reale",t:15,d:"Questa corona è stata spezzata da potenti attacchi magici, o dall\'ultima testata che il Tofu Reale ha tentato di darti.",ep:3,g:412,l:100,wd:true,fm:true,w:10,p:250};
I.u[2247] = {n:"Piuma di Tofu Reale",t:53,d:"Solo uno Yop potrebbe non rendersi conto che questa piuma proviene dalla groppa di un Tofu Reale. Eppure si vede, la piuma è più grossa.",ep:3,g:413,l:100,wd:true,fm:true,w:11,p:250};
I.u[2248] = {n:"Pelo di Uginak",t:54,d:"Questo Pelo tiene caldo, la prova è che la tua mano è umida da quando lo osservi. A meno che non sia la paura per la reazione del prossimo Uginak che ti vedrà con questo pelo. Diventerà pazzo di rabbia!\nWa-hoooo che storia!",ep:14,g:414,l:51,wd:true,fm:true,w:1,p:1};
I.u[2249] = {n:"Foglia di Tronknyde",t:36,d:"Questa Foglia dà sicuramente al Tronknyde la forza di battersi. Ma bisogna sapere come servirsene. Quello che viene subito in mente è di tritarla e unirla ai fagiolini. Una leccornia.",ep:2,g:415,l:35,wd:true,fm:true,w:1,p:1};
I.u[2250] = {n:"Legno di Tronknyde",t:38,d:"Questo pezzo di legno sembra vuoto. Il liquido verde che ne esce indica chiaramente che si trattava del naso di un Tronknyde.",ep:9,g:416,l:35,wd:true,fm:true,w:1,p:100};
I.u[2251] = {n:"Mega Pietra del Croccaroc",t:51,d:"Non ti getto la Megapietra, Pietro!",ep:5,g:417,l:45,wd:true,fm:true,w:15,p:150};
I.u[2252] = {n:"Dente d\'Oro del Croccaroc",t:47,d:"Hai appena sdentato senza scrupoli il Croccaroc che incrociava il tuo cammino. Peccato che possedesse solo un dente, qualcuno in più avrebbe sicuramente coperto le spese dello Zaap per un mese intero.",ep:5,g:418,l:31,wd:true,fm:true,w:5,p:1};
I.u[2253] = {n:"Fiore di Glutovora",t:35,d:"Questo Fiore facilita il transito intestinale. È vivamente raccomandato dopo un soggiorno presso il tuo cuoco preferito.",ep:12,g:420,l:42,wd:true,fm:true,w:1,p:100};
I.u[2254] = {n:"Foglia di Furbazza",t:36,d:"La foglia di Furbazza ha un gusto particolare, tra la nocciola e l\'insalace poco fresca. I tuoi piatti avranno così un piccolo sapore di furberia, se sei ancora disposto ad assaggiarla.",ep:2,g:421,l:22,wd:true,fm:true,w:1,p:1};
I.u[2255] = {n:"Rapporto della Spia",t:24,d:"Nessuna attività pericolosa al momento. L\'organizzazione dei Miliziani è turbata dall\'assassinio di uno di loro. Sembra che il colpevole sia un Bontariano.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2256] = {n:"Carcassa di Ratto di Fogna",t:24,d:"Questo ratto è morto stecchito. Menomale, uno in meno che gira nelle fogne.",ep:2,g:121,l:1,wd:true,fm:true,w:0,p:1};
I.u[2257] = {n:"Pezzo di mura di fogna",t:24,d:"Questo pezzo di muro di fogna è stato ritrovato nello stomaco di un aggeggio.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2259] = {n:"Dente di Karne",t:47,d:"Hai tra le mani il gioco più vecchio della contrada di Amakna. Le regole sono semplici: lancia un dente e cerca di riacchiapparlo con la stessa mano, mentre prendi un altro Dente di Karne appoggiato per terra.",ep:4,g:13,l:16,wd:true,fm:true,w:1,p:20};
I.u[2260] = {n:"Biglietto di un brakmariano",t:24,d:"Qualcuno ha infilato questo bigliettino da visita nel tuo equipaggiamento. Sembra essere un brakmariano. Questo biglietto dice che i Guerrieri sono interessati al tuo talento di assassino e ti propongono di unirti alla folle avventura brakmariana.",ep:2,g:72,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2261] = {n:"Spirito Annusatore",t:30,d:"Uno spirito annusatore ti ossessiona. Si nutre del tuo odore e della tua vitalità.",ep:1,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2262] = {n:"Descrizione dell\'Assassino",t:24,d:"Hai trovato un Bontariano che puzzava di sangue. Su questo foglio di carta ci sono scritte tutte le informazioni che sei riuscito a trovare su questo personaggio.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2263] = {n:"Bastone annusatore di Sangue",t:80,d:"Questo bastone è posseduto da uno spirito annusatore. Una volta liberato, questo spirito si fionderà in men che non si dica sulla persona più vicina che porti il suo odore preferito. Assillerà il malcapitato per un po\' di tempo prima di ritornare nel paese degli spiriti.",ep:16,g:25,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[2264] = {n:"Pelle di Goblin",t:59,d:"Un Goblin è spesso subdolo e dispettoso, ma se lo spezzetti farà certamente meno il furbo... maledetto Goblin!",ep:4,g:422,l:16,wd:true,fm:true,w:1,p:1};
I.u[2265] = {n:"Descrizione di un bontariano",t:24,d:"Hai liberato uno spirito annusatore che non si è fermato sulla persona scelta. Su questo foglio di carta hai scritto qualche informazione per ricordarti di questa persona.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2266] = {n:"Latte di Maiale da Latte",t:15,d:"Questo latte proviene da un Maiale da Latte. Non si sa mai, nel caso pensassi di averlo preso da un Tofu...",ep:1,g:423,l:18,wd:true,fm:true,w:1,p:1};
I.u[2267] = {n:"Dragolatte",t:15,d:"Questo Dragolatte è un cibo unico perché nessuno nella contrada ha mai visto un Drago Maiale lasciarsi mungere. Ci vogliono almeno sette persone per tenere la bestiola e un\'ottava che la munge molto, molto in fretta.",ep:2,g:424,l:70,wd:true,fm:true,w:2,p:1};
I.u[2268] = {n:"Scalpo di Bwork Arciere",t:15,d:"Ecco uno Scalpo che potrebbe lanciare una nuova moda per gli Anutrof: il parrucchino. Un po\' di anti-pulci e sarai pronto per il concorso mondiale dell\'Anutrof di classe.",ep:4,g:425,l:24,wd:true,fm:true,w:1,p:1};
I.u[2269] = {n:"Occhio di Larva Blu",t:24,d:"Hai appena recuperato quest\'occhio intatto. Se ben preparati, gli occhi strapazzati sono buonissimi per colazione. Quest\'occhio di larva, inoltre, proverà a Oto che hai veramente ucciso una larva blu.",ep:1,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2270] = {n:"Grappolo di Uova di Larva",t:24,d:"Questo grappolo di uova assomiglia a un grosso grappolo d\'uva. Ma è meglio evitare di mangiarlo.",ep:1,g:83,l:1,wd:true,fm:true,w:0,p:1};
I.u[2271] = {n:"Cuoio Viola di Bwork",t:56,d:"Ci sono ancora molti misteri attorno a questo manufatto Bwork. Certi avventurieri pensano che la tinta violacea provenga da un Goblin, ma non ci sono ipotesi sull\'origine del cuoio. Che strano...",ep:4,g:426,l:31,wd:true,fm:true,w:1,p:1};
I.u[2272] = {n:"Larva Dorata",t:32,d:"Questa larva è appena uscita dall\'uovo. Il suo primo sguardo si è posato su di te, e ora è convinta che tu sia sua mamma.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[2273] = {n:"Tessuto Porpora",t:55,d:"Leggero e morbido al tatto, ecco cosa si può dire del Tessuto Porpora. Sull\'etichetta al suo interno c\'è scritto \"made in taglia one\".",ep:2,g:427,l:23,wd:true,fm:true,w:1,p:1};
I.u[2274] = {n:"Candela del Minatore Oscuro",t:15,d:"Prendi un Anutrof: quando fa buio in miniera, non lo si vede più. La stessa cosa ora accade al Minatore Oscuro, perché tu gli hai preso la candela!",ep:1,g:428,l:24,wd:true,fm:true,w:10,p:10000};
I.u[2275] = {n:"Cuoio di Porkass",t:56,d:"Il Porkass ha rischiato di estinguersi. È stato necessario incrociare i Cinghiali e i Maiali da Latte per rivedere le Pianure di Cania ripopolarsi di Porkass. Da quel momento però, il Porkass ce l\'ha con tutti e tutto. Che carattere da porco.",ep:2,g:429,l:40,wd:true,fm:true,w:10,p:1};
I.u[2277] = {n:"Lenzuolo",t:55,d:"Per avere più credibilità, i fantasmi si avvolgono in un Lenzuolo che gli permette di terrorizzare tutti gli avventurieri persi.",ep:14,g:430,l:65,wd:true,fm:true,w:1,p:1000};
I.u[2278] = {n:"Tessuto Invisibile",t:55,d:"Questo tessuto servì a Harry Talper, il Cacciatore di talpe. Ci si arrotolava dentro per prendere le Talpe che infestavano il suo giardino. È stato poi il carismatico Capitano Chafer a appropriarsene in circostanze molto strane...",ep:1,g:431,l:23,wd:true,fm:true,w:1,p:1};
I.u[2279] = {n:"Dente Appuntito",t:47,d:"Non c\'è dubbio, questo dente apparteneva a un Vampiro. Sì può constatare osservandolo da vicino... difficile trovarne di più appuntiti.",ep:3,g:432,l:15,wd:true,fm:true,w:1,p:1};
I.u[2280] = {n:"Cannuccia Vampiresca",t:15,d:"Non sottovalutate mai un vampiro, soprattutto quando ha una cannuccia in mano, potrebbe succhiarvi il sangue fino all\'ultima goccia.",ep:3,g:433,l:22,wd:true,fm:true,w:1,p:1};
I.u[2281] = {n:"Tessuto Sanguigno",t:55,d:"Questo tessuto sembra vivo, i vampiri lo usano spesso per creare graziosi costumi da indossare durante i balli in maschera.",ep:3,g:434,l:15,wd:true,fm:true,w:1,p:1};
I.u[2282] = {n:"Ciuffo di capelli bianchi",t:15,d:"Ecco la prova che anche i mostri hanno tante preoccupazioni.",ep:1,g:435,l:24,wd:true,fm:true,w:1,p:1};
I.u[2283] = {n:"Occhio di Kwoan",t:109,d:"Questo Occhio di Kwoan ha degli effetti ipnotici sorprendenti, il che vuol dire che bisogna sempre tenere un occhio su di te quando lo maneggi.",ep:3,g:436,l:8,wd:true,fm:true,w:1,p:1};
I.u[2284] = {n:"Nota di Harry Stote",t:24,d:"L\'entrata della grotta leggendaria delle larve dorate si trova un po\' a ovest di Amakna. I poteri nascosti della larva dorata ti permetteranno di entrarvi. Attenzione: se la piccola larva subirà dei danni si getterà subito tra le braccia di suo padre.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2285] = {n:"Tessuto Oscuro",t:55,d:"La peculiarità di questo Tessuto non è più un soggetto di discussione. A parte questo, è molto irritante al tatto sicuramente perché un Uginak ci si è soffiato il naso per molti anni.",ep:3,g:437,l:50,wd:true,fm:true,w:1,p:1};
I.u[2286] = {n:"Bende",t:15,d:"Queste bende sono rivoluzionarie: triplo spessore, profumate alla viola, ultraresistenti. Si tratta veramente di un prodotto di qualità.",ep:2,g:438,l:51,wd:true,fm:true,w:1,p:1};
I.u[2287] = {n:"Cuoio Nero",t:56,d:"Questo cuoio è già trattato, la sua origine non è certa ma il colore proviene probabilmente da una tintura speciale.",ep:1,g:439,l:74,wd:true,fm:true,w:1,p:1};
I.u[2288] = {n:"Zampa di Wabbit",t:103,d:"Numerosi turisti vanno sull\'isola dei Wabbit solo per munirsi di una Zampa di Wabbit perché porta fortuna. Sfortunatamente non è vero... ma questa notizia penalizzerebbe molto il turismo.",ep:8,g:440,l:18,wd:true,fm:true,w:1,p:1};
I.u[2290] = {n:"Carapace di Scarafoglie Bianco",t:107,d:"Non ci vuole molto per avere una bella abat-jour a casa propria. Ma questo carapace deve pur avere un\'altra utilità, o almeno speriamo...",ep:3,g:441,l:32,wd:true,fm:true,w:1,p:1};
I.u[2291] = {n:"Carapace di Scarafoglie Blu",t:107,d:"Non ci vuole molto per avere una bella abat-jour a casa propria. Ma questo carapace deve pur avere un\'altra utilità, o almeno speriamo...",ep:3,g:442,l:32,wd:true,fm:true,w:1,p:1};
I.u[2292] = {n:"Carapace di Scarafoglie Rosso",t:107,d:"Non ci vuole molto per avere una bella abat-jour a casa propria. Ma questo carapace deve pur avere un\'altra utilità, o almeno speriamo...",ep:3,g:443,l:32,wd:true,fm:true,w:1,p:1};
I.u[2293] = {n:"Carapace di Scarafoglie Verde",t:107,d:"Non ci vuole molto per avere una bella abat-jour a casa propria. Ma questo carapace deve pur avere un\'altra utilità, o almeno speriamo...",ep:3,g:444,l:32,wd:true,fm:true,w:1,p:1};
I.u[2294] = {n:"Viscere di Scarafoglie",t:15,d:"A prima vista, queste viscere non sembrano essere così appetitose. Eppure, tritate con erbe fini seccate al sole, un po\' di menta selvatica, e cotte in salsa in un vecchio pentolone arrugginito, queste viscere faranno leccare le dita al più goloso degli Chafer.",ep:3,g:445,l:32,wd:true,fm:true,w:1,p:1};
I.u[2295] = {n:"Frammento di Spada Rettile",t:15,d:"Con questo Frammento di Spada appeso al camino, potrai vantarti di domare i Coccodrail, proprio come l\'eccentrico Mikul, meglio conosciuto con il nome di Coccodrail Dandy.",ep:4,g:446,l:69,wd:true,fm:true,w:10,p:1};
I.u[2296] = {n:"Scudo Rettile",t:15,d:"A cosa potrebbe servire questo magnifico scudo ornato di pietre preziose? Aspettando di scoprire la risposta, potresti già usarlo come vassoio da té.",ep:4,g:447,l:69,wd:true,fm:true,w:15,p:1};
I.u[2297] = {n:"Freccia di Balestra",t:15,d:"Questa freccia potrebbe servirti per fabbricare un\'arma corta ma tagliente. Ma potresti anche usarla come stuzzicadenti... a te la scelta.",ep:1,g:125,l:34,wd:true,fm:true,w:1,p:1};
I.u[2298] = {n:"null",t:65,d:"",ep:0,g:448,l:1,wd:true,fm:true,w:1,p:1};
I.u[2299] = {n:"Spallina del Dark Vlad",t:15,d:"Questa spallina ha visto più di una battaglia. Anche se apparentemente non sembra molto resistente, se ci tieni alla tua arma è meglio che non colpisci il Dark Vlad alla spalla.",ep:2,g:449,l:120,wd:true,fm:true,w:5,p:80};
I.u[2300] = {n:"Frammento di Osso",t:47,d:"Questo Frammento di Osso proviene dai resti di uno Chafer del neolitico o dal pasto di un Muulupo. Ma ci sono buone possibilità che non sia di nessuno dei due.",ep:9,g:450,l:43,wd:true,fm:true,w:1,p:1};
I.u[2301] = {n:"Baffi di Koleratto",t:15,d:"Questi baffi poco resistenti potranno servirti per fare il pagliaccio davanti agli amici, per esempio per mascherarti da Salve e Torh Bali, Grandi pittori Brakmariani.",ep:2,g:451,l:9,wd:true,fm:true,w:1,p:1};
I.u[2302] = {n:"Lingua di Granchio",t:15,d:"I cervelli di Amakna si chiedono ancora quale sia l\'utilità di questa lingua per i granchi. Se conoscessero la risposta ne sarebbero probabilmente contrariati.",ep:1,g:452,l:4,wd:true,fm:true,w:1,p:1};
I.u[2303] = {n:"Carapace Vuoto di Granchio",t:107,d:"Se ben pulito, questo Carapace di Granchio può contenere diversi oggetti, che purtroppo conserveranno per sempre un odore di Granchio parecchio inquietante.",ep:1,g:453,l:4,wd:true,fm:true,w:2,p:1};
I.u[2304] = {n:"Frammento di Pietra Levigata",t:51,d:"Questo Frammento proviene dalla chiappa sinistra di un Croccaroc delle Pianure. Non c\'è niente di meglio per distruggere un\'Arakne, a parte un Croccaroc intero ovviamente.",ep:5,g:454,l:45,wd:true,fm:true,w:5,p:1};
I.u[2305] = {n:"Frammento di Pietra Appuntita",t:51,d:"Questo Frammento proviene dalla scapola destra di un Croccaroc delle Pianure. A meno che non si tratti di una parte un po\' più bassa... A ogni modo, questa pietra non è da piazzare a caso.",ep:5,g:455,l:45,wd:true,fm:true,w:5,p:1};
I.u[2306] = {n:"Cuore di Croccaroc",t:51,d:"\"Cuore di pietra, non vedi l\'amore che provo per te? Se continui, ti lascerò per terra, non mi farò opprimere così!\"",ep:5,g:456,l:45,wd:true,fm:true,w:5,p:1};
I.u[2307] = {n:"Scudo dello Chafer Lanciere",t:24,d:"...",ep:2,g:75,l:1,wd:true,fm:true,w:0,p:1};
