I.u[2048] = {n:"Lista dei soldati in pausa",t:24,d:"Questa lista ti è stata data dal miliziano nella taverna. Sono scritti i seguenti nomi:\nHaco Norss, Tink Berval, Brank Thoof, Kad Maxy, Seta Bnamron.",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2049] = {n:"Confessione del Guerriero XaIe DuGros",t:24,d:"Xale DuGros confessa di non andare alla taverna, ma fa delle pause regolarmente.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2050] = {n:"Confessione del Guerriero Nager Nacmeil",t:24,d:"Il guerriero Nager Nacmeil confessa di non fare pause perché non sta tanto bene in questo momento.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2051] = {n:"Confessione di Bishom Pot",t:24,d:"Bishom Pot confessa tutto, il suo comportamento è imperdonabile.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2052] = {n:"Permesso firmato e datato",t:24,d:"Questo permesso indica che hai una giornata di congedo.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2053] = {n:"Badge del miliziano Allen Tokar",t:24,d:"Badge del miliziano Allen Tokar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2054] = {n:"Badge del miliziano Tek Aput",t:24,d:"Badge del miliziano Tek Aput.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2055] = {n:"Badge del miliziano Bill Ledebar",t:24,d:"Badge del miliziano Bill Ledebar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2056] = {n:"Occhio di Cuervoc",t:109,d:"Un occhio di cuervoc è sempre utile, ma attenzione che il malocchio non cada su di te.",ep:1,g:326,l:20,wd:true,fm:true,w:1,p:100};
I.u[2058] = {n:"Cuore di Brandon",t:15,d:"Questo cuore umano è sicuramente del famoso Lhi, che era un appassionato di cuervoc.",ep:1,g:328,l:20,wd:true,fm:true,w:5,p:500};
I.u[2059] = {n:"Cuervoc Morto",t:15,d:"Hai fatto bene a raccoglierlo, è intatto. Morto... ma intatto.",ep:1,g:329,l:20,wd:true,fm:true,w:10,p:100};
I.u[2060] = {n:"Zampa di Cuervoc",t:103,d:"Non vale la pena rompere una zampa a un cuervoc, anche perché al contrario della zampa di wabbit, la zampa di cuervoc potrebbe portarti sfortuna.",ep:1,g:330,l:20,wd:true,fm:true,w:1,p:10};
I.u[2061] = {n:"Mantello del Cuervoc",t:17,d:"Questo mantello non è certamente bello ma è molto efficace... bisogna però abituarsi al suo odore di Cuervoc in putrefazione.",ep:1,g:15,l:45,wd:true,fm:true,w:5,p:5600};
I.u[2062] = {n:"Camuffamento",t:31,d:"Sarai camuffato nello sfondo fino a quando non entrerai in combattimento.",ep:1,g:1,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2063] = {n:"Stivali Volatili",t:11,d:"Questi stivali, fatti con moltissime parti di cadavere di Cuervoc, danno a chi le porta una strana sensazione di leggerezza, proprio come quella provocata dai porcini grigliati.",ep:1,g:17,l:41,wd:true,fm:true,w:15,p:4500};
I.u[2064] = {n:"Pergamena di Camuffamento",t:14,d:"Questa pergamena ti permette di nasconderti nello sfondo fino a quando non entrerai in combattimento. Evita i movimenti bruschi e i rumori sospetti se non vuoi essere scoperto.",ep:16,g:1,l:10,wd:true,fm:true,w:1,c:"Pg=10&PM=B",u:true,p:250};
I.u[2065] = {n:"Elmo dello Chafer scelto",t:24,d:"Questo elmo di Chafer è danneggiato, ma resta sempre molto efficace per entrare nel gruppo di élite.",ep:2,g:59,l:1,wd:false,fm:true,w:0,p:1};
I.u[2066] = {n:"Bastone del Kanigrù",t:4,d:"Questo bastone è una copia approssimativa di quello del Kanigrù. Nasconde comunque qualche sorpresa... ma non solo buone sorprese...",ep:13,g:22,l:54,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,50,false,false],c:"CS>50&CA>40&CC>30",p:5400};
I.u[2067] = {n:"Pozione d\'oblio: \"Fiammella\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo elementare: \"Fiammella\"",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
