I.u[1871] = {n:"Collana",t:24,d:"Si tratta della collana persa dalla figlia del sindaco. Purtroppo ora, dopo essere stata nello stomaco di un Cuervoc, è ridotta malissimo.",ep:2,g:36,l:1,wd:true,fm:true,w:0,p:1};
I.u[1872] = {n:"Polvere di Cannone",t:24,d:"Un etichetta ricorda come utilizzare questa polvere di cannone. È facilissimo:\nPolvere + Fiamma = Esplosione",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[1873] = {n:"Blocco di pietra",t:24,d:"Un blocco di pietra di Croccaroc delle Pianure simile a quelli con cui sono stati costruiti i bastioni Bonta.",ep:2,g:38,l:1,wd:true,fm:true,w:0,p:1};
I.u[1874] = {n:"Tossina di Scorbuto",t:24,d:"Tossina di scorbuto da non dare in mano a chiunque.",ep:2,g:39,l:1,wd:true,fm:true,w:2,p:1};
I.u[1875] = {n:"Falce di Messer Cuervoc",t:24,d:"Perché falciare il grano, quando questa falce potrebbe falciare il granito?",ep:2,g:40,l:1,wd:true,fm:true,w:0,p:1};
I.u[1876] = {n:"Modulo di Ispezione",t:24,d:"Questo modulo d\'ispezione n° 243 permette di sapere se un uomo è Brakmariano o no...",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[1877] = {n:"Hud rotto",t:24,d:"Il vecchio proprietario di questo cappello è sicuramente stato malmenato. Capita spesso quando ci si ribella all\'autorità di Bonta...",ep:1,g:42,l:1,wd:true,fm:true,w:0,p:1};
I.u[1878] = {n:"Carta speciale",t:24,d:"Questa carta da gioco ha un aspetto particolare, è a dir poco perfetta. Sembra proprio che sia destinata a una collezione.",ep:2,g:43,l:1,wd:true,fm:true,w:0,p:1};
I.u[1879] = {n:"Cassa di armi bianche",t:24,d:"Una cassa di armi bianche, riempita con ogni sorta di oggetto contundente.",ep:2,g:44,l:1,wd:true,fm:true,w:500,p:1};
I.u[1880] = {n:"Scatola di Maognam",t:24,d:"Hmm... del maognam! Il tuo Kanigrù sarà contentissimo.",ep:2,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[1881] = {n:"Fango",t:24,d:"Ecco fatto.",ep:2,g:46,l:1,wd:true,fm:true,w:2,p:1};
I.u[1882] = {n:"Fiore di Blop schiacciato",t:24,d:"Hai tirato su una bella poltiglia.",ep:2,g:47,l:1,wd:true,fm:true,w:0,p:1};
I.u[1883] = {n:"Collana riparata",t:24,d:"È la collana persa dalla figlia del sindaco... quasi nuova.",ep:2,g:48,l:1,wd:true,fm:true,w:0,p:1};
I.u[1889] = {n:"Piuma di Cuervoc",t:53,d:"Usata  tempo addietro per la scrittura, questa piuma è adesso usata quasi esclusivamente nell\'alta moda. Effettivamente, i Cuervoc sono sempre meno generosi e non offrono più le loro penne a chiunque. I tempi cambiano purtroppo... come le buone maniere.",ep:1,g:327,l:20,wd:true,fm:true,w:1,p:1};
I.u[1890] = {n:"Pelo di Kanigrù",t:54,d:"Il pelo di Kanigrù riflette la luce del sole in maniera abbastanza strana, come se ne assorbisse una parte prima di rinviarla.",ep:13,g:359,l:70,wd:true,fm:true,w:1,p:1};
I.u[1891] = {n:"Pelle di Serpentino",t:59,d:"Non hai mai sognato di avere uno zainetto in pelle di Serpentino? No? Hai ragione perché la sua resistenza lascia a desiderare.",ep:2,g:361,l:10,wd:true,fm:true,w:1,p:1};
I.u[1892] = {n:"Piuma di Messer Cuervoc",t:53,d:"Preso dal panico, Messer Cuervoc aprì le sue larghe ali lasciando cadere questa piuma. Veramente niente di speciale, eppure...",ep:13,g:362,l:160,wd:true,fm:true,w:1,p:1};
I.u[1893] = {n:"Coda di Scorbuto",t:65,d:"Un formidabile trofeo, peccato che trasudi un liquido nauseabondo.",ep:14,g:363,l:36,wd:true,fm:true,w:1,p:1};
I.u[1894] = {n:"Pelo di Cinghiale delle Pianure",t:54,d:"Questo pelo è veramente ripugnante. Guardandolo da vicino, potrai vedere un intero microcosmo abitarci dentro. Che fortuna che hai!",ep:13,g:364,l:44,wd:true,fm:true,w:1,p:1};
I.u[1895] = {n:"Birra del Fubuk",t:37,d:"Questa birra molto alcolica ti permetterà di recuperare i tuoi punti vita.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:4};
I.u[1896] = {n:"Carne di Uccello",t:63,d:"Questa coscia di Tofu prova che i Cacciatori sanno andarci di precisione ogni tanto.",ep:1,g:348,l:1,wd:true,fm:true,w:2,p:1};
I.u[1897] = {n:"Carne di Uccello **",t:63,d:"Mini cosce di Kwak per il massimo del gusto.",ep:1,g:349,l:40,wd:true,fm:true,w:2,p:1};
I.u[1898] = {n:"Carne di Larva",t:63,d:"Questo ammasso giallo e nauseabondo rappresenta la vera natura della Larva. Ecco perché la loro pelle è così resistente...",ep:1,g:354,l:1,wd:true,fm:true,w:2,p:1};
I.u[1899] = {n:"Carne di Larva **",t:63,d:"Questo ammasso giallo e nauseabondo rappresenta la vera natura della Larva. Ecco perché la loro pelle è così resistente...",ep:1,g:354,l:9,wd:true,fm:true,w:2,p:1};
I.u[1900] = {n:"Carne di Larva ***",t:63,d:"Questo ammasso giallo e nauseabondo rappresenta la vera natura della Larva. Ecco perché la loro pelle è così resistente...",ep:1,g:354,l:10,wd:true,fm:true,w:2,p:1};
I.u[1901] = {n:"Coscia di Wabbit ****",t:63,d:"Questa coscia è semplicemente perfetta. Impossibile non divorarla con gli occhi... e con la bocca!",ep:2,g:368,l:80,wd:true,fm:true,w:2,p:1};
I.u[1902] = {n:"Coscia di Wabbit",t:63,d:"Questa coscia di Wabbit sembra essere speziata alla cawota. Ideale per il bollito.",ep:8,g:365,l:20,wd:true,fm:true,w:2,p:1};
I.u[1903] = {n:"Coscia di Wabbit **",t:63,d:"Una buona coscia bella soda che ha l\'aria veramente deliziosa.",ep:8,g:366,l:40,wd:true,fm:true,w:2,p:1};
I.u[1904] = {n:"Dragocapo Bianco",t:16,d:"Un guscio di Draguovo Bianco imbottito di cuoio e di lana, niente di meglio per proteggersi dagli attacchi classici e dai fulmini di un Bwork Mago ubriaco. In compenso, sembri appena uscito da un uovo con un cappello così.",ep:11,g:28,l:39,wd:true,fm:true,w:50,p:4200};
I.u[1905] = {n:"Coscia di Wabbit ***",t:63,d:"Questa coscia bella grossa dovrebbe riuscire a riempire la maggior parte degli stomaci.",ep:8,g:367,l:60,wd:true,fm:true,w:2,p:1};
I.u[1906] = {n:"null",t:16,d:"",ep:0,g:29,l:1,wd:false,fm:true,w:10,c:"Pg=11",p:10000};
I.u[1907] = {n:"Orecchie di Lapinup",t:16,d:"Queste orecchie esalteranno il tuo bellissimo sorriso, e ti aiuteranno a moltiplicare tutti i pettegolezzi e rumori che circolano su di te a tua insaputa.",ep:1,g:30,l:30,wd:true,fm:true,w:9,p:2600};
I.u[1908] = {n:"Elmo dello Chafer",t:16,d:"Persino Spartapin, il grande mietitore, non ebbe la fortuna di indossare un casco del genere, che deve la sua enorme resistenza alle pietre e ai metalli con i quali è costruito.",ep:13,g:31,l:50,wd:true,fm:true,w:18,p:6500};
I.u[1910] = {n:"Mantello Uginak",t:17,d:"Questo mantello proviene da un Uginak, porta ancora l\'odore del suo naso, caldo e umido, un po\' come le mammelle di una femmina Pappatutto in calore.",ep:14,g:33,l:50,wd:true,fm:true,w:10,p:6650};
I.u[1911] = {n:"Coscia di Pappaton",t:63,d:"L\'odore di questa piccola coscia scompare durante la cottura.",ep:1,g:334,l:10,wd:true,fm:true,w:2,p:1};
I.u[1912] = {n:"Coscia di Pappatutto **",t:63,d:"Questa coscia puzza di morte, anche se la ragione non sembra legarsi al decesso prematuro del suo proprietario.",ep:1,g:335,l:20,wd:true,fm:true,w:2,p:1};
I.u[1913] = {n:"Coscia di Pappatutto ***",t:63,d:"Questa coscia è di un capo di guerra Pappatutto. Dura come un croccaroc, potrebbe essere una potente clava, non fosse per l\'odore...",ep:1,g:336,l:40,wd:true,fm:true,w:2,p:1};
I.u[1914] = {n:"Coscia di Pappatutto ****",t:63,d:"Tenera, ma soda, né grassa né magra, questa coscia è come un buon vino che si arricchisce e affina con gli anni.",ep:1,g:337,l:50,wd:true,fm:true,w:2,p:1};
I.u[1915] = {n:"Carne di Insetto",t:63,d:"Il valore nutrizionale di questa carne viscida e asfissiante non è da sottovalutare.",ep:1,g:370,l:1,wd:true,fm:true,w:2,p:1};
I.u[1916] = {n:"Carne di Insetto **",t:63,d:"È una carne identica a quella dei moskito ma in quantità 10 volte superiore. Fortunatamente a qualcuno piace.",ep:3,g:370,l:50,wd:true,fm:true,w:4,p:1};
I.u[1917] = {n:"Lombata di Maiale",t:63,d:"Un pezzo di carne di prima scelta, ancora un po\' sanguinolento ma che promette grandi momenti.",ep:1,g:331,l:30,wd:true,fm:true,w:3,p:1};
I.u[1918] = {n:"Carré di Porco **",t:63,d:"Un po\' più grosso per un po\' più di piacere, questo trancio di Cinghiale delle Pianura renderà felice tutti i carnivori.",ep:13,g:331,l:50,wd:true,fm:true,w:3,p:1};
I.u[1919] = {n:"Lombata di Maiale ****",t:63,d:"Questo pezzo di Drago Maiale è così tenero e soffice che si potrebbe usare come cuscino reale. Ma è meglio mangiarlo.",ep:2,g:331,l:80,wd:true,fm:true,w:4,p:1};
I.u[1920] = {n:"Badge Bontariano",t:24,d:"Questo badge permette di identificare un miliziano quando muore sul campo di battaglia. Si dice che a Brakmar qualcuno ne faccia la collezione.",ep:2,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[1921] = {n:"Lombata di Maiale ***",t:63,d:"Sicuramente il maiale a cui apparteneva questo pezzo di carne bella soda faceva molto esercizio fisico.",ep:1,g:331,l:60,wd:true,fm:true,w:3,p:1};
I.u[1922] = {n:"Dragocarne",t:63,d:"È una carne di rara qualità. Dopo la cottura inoltre conserva il calore per molte ore, il che ne fa un cibo particolarmente pratico per i viaggi.",ep:2,g:371,l:40,wd:true,fm:true,w:2,p:1};
I.u[1923] = {n:"Dragocarne **",t:63,d:"Questa dragocarne, oltre alle sue qualità termiche, ha un gusto naturale di affumicato.",ep:2,g:371,l:60,wd:true,fm:true,w:2,p:1};
I.u[1924] = {n:"Dragocarne ***",t:63,d:"La Dragocarne di draguovo è un po\' dura da masticare, ma è molto più nutriente della Dragocarne tradizionale. Certi pensano persino che abbia delle virtù magiche.",ep:11,g:371,l:70,wd:true,fm:true,w:2,p:1};
I.u[1925] = {n:"Permesso di 24 ore",t:24,d:"Questo permesso della milizia indica che hai una giornata di congedo.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[1926] = {n:"Dragocarne ****",t:63,d:"Questa carne, che deriva dalle parti dragoniche del drago maiale (e nessuno ha voglia di dire dove sono), è una manna dal cielo... il che è abbastanza logico visto che il drago maiale vola.",ep:2,g:371,l:80,wd:true,fm:true,w:2,p:1};
I.u[1927] = {n:"Muso",t:63,d:"Questo muso di Milibuulupo, con le sue belle labbra sode, accompagnerà piacevolmente tutte le tue inscialate.",ep:1,g:372,l:30,wd:true,fm:true,w:1,p:1};
I.u[1928] = {n:"Zanna di Cinghiale Aggressivo",t:24,d:"C\'è sicuramente voluta una buona destrezza per estrarre questa zanna da un Cinghiale delle Pianure.",ep:2,g:51,l:1,wd:true,fm:true,w:0,p:1};
I.u[1929] = {n:"Muso **",t:63,d:"Questo muso dal gusto delicato ti renderà quieto. Da consumare senza moderazione.",ep:1,g:373,l:50,wd:true,fm:true,w:2,p:1};
I.u[1930] = {n:"Muso ***",t:63,d:"Questa carne è deliziosa, ma attenzione a non abusarne. Non per niente al Muulupo puzza l\'alito.",ep:2,g:374,l:70,wd:true,fm:true,w:2,p:1};
I.u[1931] = {n:"Katana scheggiata",t:24,d:"È l\'arma di Amayiro. È di una maneggiabilità stupefacente, ma sembra essere un po\' scheggiata.",ep:2,g:52,l:1,wd:true,fm:true,w:0,p:1};
I.u[1932] = {n:"Katana rinnovata",t:24,d:"Quest\'arma, prima scheggiata, è di nuovo pronta a tagliare qualsiasi cosa. Amayiro non sarà deluso.",ep:2,g:53,l:1,wd:true,fm:true,w:0,p:1};
I.u[1933] = {n:"Carne di Uccello ****",t:63,d:"Questo pezzetto di cuervoc è impregnato di una potente magia, probabilmente quella datagli da Messer Cuervoc in persona.",ep:13,g:350,l:30,wd:true,fm:true,w:2,p:1};
I.u[1934] = {n:"Coltello da Caccia",t:20,d:"Questo coltello è il tipico segno di riconoscimento dei Cacciatori. Secono loro la bellezza di un Cacciatore è legata alla taglia del coltello, alla sua lama e alla sua brillantezza.",ep:1,g:14,l:1,wd:true,fm:true,w:2,an:13,e:[10,3,1,1,25,30,false,false],c:"PJ>41,0",p:1};
I.u[1935] = {n:"Assegno di 100000 kama",t:24,d:"\"Chi paga i suoi debiti si arricchisce\", ma questo è proprio un debito grosso. È meglio evitare i debiti così, il tuo portafoglio ti ringrazierà.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[1936] = {n:"Ascia da Caccia",t:20,d:"Questa ascia è particolarmente adatta per tagliare in modo rapido e preciso qualsiasi parte di un animale ancora vivo.",ep:1,g:15,l:1,wd:true,fm:true,w:5,an:17,e:[10,4,1,1,30,40,false,false],c:"PJ>41,9",p:1000};
I.u[1937] = {n:"Rapporto di Spionaggio",t:24,d:"Questo rapporto di Bishom Pot deve contenere una buona quantità di fatti e gesta degli abitanti di Brakmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[1938] = {n:"Lama da Caccia",t:20,d:"Questa lama, dal nome contestato, è stata appositamente concepita per la caccia. È un po\' delicata da maneggiare, ma utilissima per i Cacciatori esperti.",ep:3,g:16,l:1,wd:true,fm:true,w:2,an:14,e:[5,4,1,1,40,40,false,false],c:"PJ>41,29",p:5000};
I.u[1939] = {n:"Lancia da Caccia",t:20,d:"Pratica contro i gruppi di mostri, questa lancia necessita di un certo talento per essere maneggiata.",ep:3,g:17,l:1,wd:true,fm:true,w:2,an:12,e:[7,5,1,1,30,50,false,false],c:"PJ>41,49",p:10000};
I.u[1940] = {n:"Martello da Caccia",t:20,d:"Questo martello non segue un concetto classico. È fatto in modo da stordire piuttosto che schiacciare. Molto pratico per cacciare, un po\' meno per sopravvivere.",ep:1,g:18,l:1,wd:true,fm:true,w:2,an:15,e:[5,6,1,1,50,50,false,false],c:"PJ>41,69",p:20000};
I.u[1941] = {n:"Pala Cacciatrice",t:20,d:"Questa pala è particolarmente indicata per uccidere i mostri senza rovinarli. Un accessorio solo per Cacciatori esperti.",ep:3,g:9,l:1,wd:true,fm:true,w:2,an:16,e:[7,4,1,1,30,50,false,false],c:"PJ>41,29",p:5000};
I.u[1942] = {n:"Arco da Caccia",t:20,d:"L\'arco da caccia è considerato l\'arma da caccia più sicura: massimi danni, nessun rischio, tracce minime.",ep:3,g:10,l:1,wd:true,fm:true,w:2,an:10,tw:true,e:[7,5,1,6,35,40,false,false],c:"PJ>41,29",p:5000};
I.u[1943] = {n:"Bacchetta da Caccia",t:20,d:"Questa bacchetta brucerà l\'animale colpito senza distruggerne la carne. Carne intatta e precotta... cosa si vuole di più!",ep:3,g:11,l:1,wd:true,fm:true,w:2,an:11,e:[5,3,2,4,30,50,false,false],c:"PJ>41,29",p:5000};
I.u[1944] = {n:"Sputa Palline",t:20,d:"Quest\'arma spara piccole sfere di rame. La sua efficacia è stupefacente ma il rumore che fa la confina al solo dominio della caccia.",ep:1,g:21,l:1,wd:false,fm:true,w:2,an:10,e:[5,3,1,10,40,40,false,false],c:"PJ>41,99",p:50000};
I.u[1945] = {n:"Coltello del Macellaio",t:20,d:"Questo enorme coltello permette di tagliare qualsiasi carne.",ep:1,g:12,l:1,wd:true,fm:true,w:2,an:14,e:[10,4,1,1,25,50,false,false],p:200};
