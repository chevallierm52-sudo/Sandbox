I.u[2042] = {n:"Osso di Mak Gahan",t:24,d:"Hai preso quest\'osso dopo avere disseminato pezzi del corpo dello chafer Mak Gahan per tutta la stanza.",ep:1,g:57,l:1,wd:true,fm:true,w:0,p:1};
