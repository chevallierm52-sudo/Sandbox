I.u[2070] = {n:"Shako",t:16,d:"Questo elmo in osso è stato per molto tempo nella tasca di un Kanigrù. Anche se consumato e rigato conserva delle buone qualità.",ep:9,g:58,l:34,wd:true,fm:true,w:15,p:3200};
I.u[2071] = {n:"Pozione d\'oblio: \"Liberazione\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo elementare: \"Liberazione\"",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2072] = {n:"Pozione d\'oblio: \"Folgorazione\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo elementare: \"Folgorazione\"",ep:5,g:36,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[2073] = {n:"Pozione d\'oblio: \"Brokle\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo speciale degli Yop: \"Brokle\"",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2074] = {n:"Bwak di Fuoco",t:18,d:"Questo grazioso Bwak diventerà col tempo un terribile Kwak. Fino a quel momento puoi tenerlo accanto a te senza paura.",ep:1,g:3,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:2,p:1};
I.u[2075] = {n:"Bwak di Acqua",t:18,d:"Questo grazioso Bwak diventerà col tempo un terribile Kwak. Fino a quel momento puoi tenerlo accanto a te senza paura.",ep:1,g:2,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:13,p:1};
I.u[2076] = {n:"Bwak di Aria",t:18,d:"Questo grazioso Bwak diventerà col tempo un terribile Kwak. Fino a quel momento puoi tenerlo accanto a te senza paura.",ep:1,g:4,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:15,p:1};
I.u[2077] = {n:"Bwak di Terra",t:18,d:"Questo grazioso Bwak diventerà col tempo un terribile Kwak. Fino a quel momento puoi tenerlo accanto a te senza paura.",ep:1,g:5,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:14,p:1};
I.u[2078] = {n:"Testamento di Ixa Mustam",t:24,d:"È il testamento del padre di Oto Mustam ed è scritto in Brakmariano antico. Peccato, la tua conoscenza di questa lingua si riduce alla parola: \"Guo\'rhalys!\".",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2079] = {n:"Vino di Glutovora",t:24,d:"Pare che ci vogliano vent\'anni prima di riuscire a distillare del succo di Glutovora senza creare un vino tossico.",ep:2,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[2080] = {n:"Succo di Glutovora",t:24,d:"Questo succo è tossico come il succo di scorbuto. Ma se ben distillato, dà al vino un gusto unico. Purtroppo le persone che sanno distillarlo sono rare, e quasi sempre si tratta di pirati...",ep:2,g:63,l:1,wd:true,fm:true,w:1,p:1};
I.u[2081] = {n:"Rapporto di Finch Aticus",t:24,d:"Il rapporto della spia Finch Aticus dà una lista esauriente delle armi e degli effettivi di Bonta.",ep:2,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[2082] = {n:"Cinghialetto",t:32,d:"Quando un giovane cinghialetto vede i genitori morire davanti ai suoi occhi, comincia a seguire l\'assassino perché quest\'ultimo si occupi di lui.",ep:13,g:1,l:1,wd:true,fm:true,w:0,m:true,p:10};
I.u[2083] = {n:"Lettera di Oto Mustam",t:24,d:"Una lettera del tuo maestro indirizzata a Vil Smis. E\' scritta in un dialetto sconosciuto per evitare che i curiosi come te ci diano un\'occhiata.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2084] = {n:"Risposta di Vil Smis",t:24,d:"Una risposta di Vil Smis per Oto Mustam, assolutamente incomprensibile per qualsiasi mortale.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2085] = {n:"Birra della Batosta",t:37,d:"Non soltanto non ha nessun gusto, ma in più si tratta di una birra carissima. Ancora un punto in comune con il gentil sesso.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2086] = {n:"Birra della Sulmenù",t:37,d:"Questa birra dall\'aroma di Blop Griotta è chiamata anche Manoca.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,p:3};
I.u[2087] = {n:"Birra della Bagrutta",t:37,d:"Questa birra ti rende più valoroso per qualche istante... ma attenzione al dopo... l\'istante è veramente breve!",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2088] = {n:"Birra della Pintalegno",t:37,d:"Una birra classica, ma la pinta in compenso è magnificamente intagliata. Per una volta, il contenitore ha più valore e importanza del contenuto. Una caratteristica condivisa con il cranio degli Yop e con la stampa locale.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2089] = {n:"Birra del Pinchot",t:37,d:"Questa birra è calda, e quindi particolarmente imbevibile d\'estate. In compenso, emana un gradevole odore di pane tostato, cosa che la rende la birra perfetta per le colazioni senza pane.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2090] = {n:"Birra del Ferrovecchio",t:37,d:"Questa birra ha un retrogusto di ferraglia moltro sgradevole, ma è molto rivitalizzante, un po\' come i baci della Mummia Nova.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:7};
I.u[2091] = {n:"Il Bwak: Come allevarlo",t:25,d:"Questo libro spiega come allevare un Bwak.",ep:3,g:4,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2092] = {n:"Il Maomao: Come allevarlo",t:25,d:"Questo libro spiega come allevare un Maomao.",ep:3,g:3,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2093] = {n:"Il Wabbit: Come allevarlo",t:25,d:"Questo libro spiega come allevare un Wabbit.",ep:3,g:5,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2094] = {n:"Mykakka Oscuro",t:16,d:"Il Mykakka Oscuro è un cappello fatto con il Mykakka Dilaniato ricucito a mano e senza anestesia.\nAdesso obbedisce solo al suo proprietario e adora mordere gli sconosciuti.",ep:14,g:33,l:50,wd:true,fm:true,w:5,p:6600};
I.u[2095] = {n:"L\'Orso",t:16,d:"L\'Orso è un cappello confezionato nella testa di un Orso morto. Ha comunque conservato un bellissimo pelo. Il Sarto che l\'ha cucito doveva essere veramente bravo per essere riuscito a conservare l\'ultima espressione di sconforto dell\'orso.",ep:14,g:34,l:35,wd:true,fm:true,w:5,p:10000};
I.u[2096] = {n:"Dora Oscuro di Brave",t:16,d:"È stato il fantasma Brave a capire per primo come usare correttamente il Vimini Oscuro per fini diversi da quelli gastronomici.",ep:14,g:35,l:37,wd:true,fm:true,w:5,p:3800};
I.u[2097] = {n:"Champello",t:16,d:"Il Champello apparteneva a uno dei più grandi Maestri Boleti di Amakna. Valoroso e brillante, Gnion il Boleto è stato l\'unico della sua razza a farsi rispettare dagli esseri umani.",ep:1,g:36,l:43,wd:true,fm:true,w:25,p:5000};
I.u[2098] = {n:"Certificato di Deposito al Cianil: Bwak di Terra",t:77,d:"Questo Certificato descrive le caratteristiche del Bwak di Terra che hai lasciato al Cianil.",ep:3,g:21,l:1,wd:false,fm:true,w:1,p:100};
I.u[2099] = {n:"Certificato di Deposito al Cianil: Bwak di Fuoco",t:77,d:"Questo Certificato descrive le caratteristiche del Bwak di Fuoco che hai lasciato al Cianil.",ep:3,g:23,l:1,wd:false,fm:true,w:1,p:100};
I.u[2100] = {n:"Certificato di Deposito al Cianil: Bwak di Acqua",t:77,d:"Questo Certificato descrive le caratteristiche del Bwak di Acqua che hai lasciato al Cianil.",ep:3,g:22,l:1,wd:false,fm:true,w:1,p:100};
I.u[2101] = {n:"Certificato di Deposito al Cianil: Bwak di Aria",t:77,d:"Questo Certificato descrive le caratteristiche del Bwak di Aria che hai lasciato al Cianil.",ep:3,g:20,l:1,wd:false,fm:true,w:1,p:100};
I.u[2102] = {n:"Certificato di Deposito al Cianil: Wabbit",t:77,d:"Questo Certificato descrive le caratteristiche del Wabbit che hai lasciato al Cianil.",ep:3,g:25,l:1,wd:false,fm:true,w:1,p:100};
I.u[2103] = {n:"Modulo di Welloy Cab",t:24,d:"Scritto a zampa da Welloy Cab, questo rapporto renderà felici tutti gli amanti di numeri e frasi senza senso.",ep:1,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2104] = {n:"Kak A\'Rella",t:16,d:"Il Kak A\'Rella è un elmo inquietante fabbricato con i resti di Uginak e diversi altri detriti. Indossato per molto tempo da Gurlo il Terribile, il Kak A\'Rella fu il simbolo della desolazione.",ep:14,g:37,l:48,wd:true,fm:true,w:30,p:6000};
I.u[2105] = {n:"Modulo di rapporto vergine",t:24,d:"Modulo di rapporto vergine.\nPronto per essere riempito da Welloy Cab",ep:1,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2106] = {n:"Lista di Esche per il Pescatore",t:24,d:"Devi andare a cercare delle esche il più rapidamente possibile.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2107] = {n:"Esche speciali",t:24,d:"Questa scatola di esche speciali assomiglia a una volgare scatola di Maognam.",ep:1,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[2108] = {n:"Badge di Tabach",t:24,d:"Badge di Tabach, Cancelliere dell\'Ordine del Cuore Valoroso",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2109] = {n:"Badge di Ybaul",t:24,d:"Badge di Ybaul, Cancelliera dell\'Ordine dello Spirito Redentore.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2110] = {n:"Badge di Aigurraf",t:24,d:"Badge di Aigurraf, Cancelliere dell\'Ordine dell\'Occhio Attento",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2111] = {n:"L\'anima del Pescatore",t:25,d:"Questo libro dà le basi per diventare un buon Pescatore.",ep:2,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2112] = {n:"L\'anima del Cacciatore",t:25,d:"Questo libro dà le basi per diventare un buon Cacciatore.",ep:3,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2114] = {n:"Alimento sconosciuto",t:15,d:"Quest\'alimento è sconosciuto.",ep:1,g:0,l:1,wd:true,fm:true,w:10,p:1};
I.u[2116] = {n:"Ricetta della Nocabregor",t:24,d:"Per creare della polvere di Nocabregor, servono 3 Polveri di Perlinpanpan e 1 Olio di Gomto.\nSolo un artificiere o un mago possono preparare questa ricetta con l\'aiuto di una Selce.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2117] = {n:"Dente di Canin Blando arrabbiato",t:24,d:"Questo dente è stato estratto con coraggio a un lupo arrabbiato.",ep:2,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2118] = {n:"Mantello Brakmariano",t:17,d:"Questo mantello permette di passare inosservati in un cimitero o di trasformarsi in una femmina di Chafer quando il bisogno di perversità si fa sentire.",ep:1,g:20,l:1,wd:true,fm:true,w:7,c:"Ps=2",p:800};
I.u[2119] = {n:"Mantello Bontariano",t:17,d:"Questo mantello ti mette le ali. Potrai persino planare sul fumo che sprigiona quando va a fuoco.",ep:5,g:34,l:1,wd:true,fm:true,w:3,c:"Ps=1",p:800};
I.u[2120] = {n:"Parola di Ixa Mustam",t:24,d:"\"Il mio testamento si trova al faro di Amakna, procurati una piccola Pala di Legnuccio per dissotterrarlo. E dai una sberla a mio figlio da parte mia!\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2121] = {n:"Parola di Tsog",t:24,d:"\"Ho nascosto un forziere sulla punta Est di Sufokia, in un tunnel sotto delle botti di vino. Ti consiglio di procurarti una piccola Pala di Legnuccio per dissotterrarlo.\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2122] = {n:"Lettera di invito alla cerimonia",t:24,d:"Questa lettera è sigillata, aprirla non sarebbe educato.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2123] = {n:"Ricetta dello Sonacixem",t:24,d:"Questa ricetta permette di fabbricare del Sonacixem, che pare sia un veleno magico potentissimo.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2124] = {n:"Modulo di Ispezione riempito",t:24,d:"Questo modulo d\'ispezione n°243 riempito da Leonzi Trool, a prima vista ci dice che non è Brakmariano ...",ep:2,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2127] = {n:"Lettera di Zeorg",t:24,d:"In questa lettera è scritto un sortilegio capace di annientare tutti gli Holbaid.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2128] = {n:"Veggenza",t:31,d:"Avrai il potere della veggenza fino a quando non entrerai in combattimento.",ep:6,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2129] = {n:"Ciuffo di capelli di Dike Tarak",t:24,d:"Questo ciuffo di capelli di Dike Tarak mostra quanto tu abbia malmenato questo povero ragazzo...",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2130] = {n:"Colonnello Lyeno",t:32,d:"Scorta il Colonnello Lyeno da un mago di Bonta per spezzare l\'incantesimo della Quercia Molle.",ep:9,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2131] = {n:"Decreto della tassa 51-11b",t:24,d:"Questa lettera annuncia senza riserve che tutti coloro che possiedono bevande alcoliche devono pagare una tassa ai militari, in ragione della pausa obbligatoria.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2132] = {n:"Hué Dapyus",t:32,d:"Scorta Hué Dapyus fuori dalla prigione di Brakmar e portalo a Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2133] = {n:"Assegno della Taverna Maokemao",t:24,d:"Questo assegno serve a pagare la nuova tassa sulle taverne annunciata da Oto Mustam.",ep:2,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2134] = {n:"Trof Hapyus",t:32,d:"Scortare Trof Hapyus fuori dalla prigione di Brakmar e portarlo a Oto Mustam.",ep:16,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2135] = {n:"Assegno della Taverna Bwork Ubriaco",t:24,d:"Questo assegno serve a pagare la nuova tassa sulle taverne annunciata da Oto Mustam.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2136] = {n:"Assegno della Taverna Da Djaul",t:24,d:"Questo assegno serve a pagare la nuova tassa sulle taverne annunciata da Oto Mustam.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
