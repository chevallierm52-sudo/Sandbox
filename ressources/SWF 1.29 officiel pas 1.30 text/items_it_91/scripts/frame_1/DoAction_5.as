I.u[2031] = {n:"Pane di Segale Resistente",t:33,d:"Questo pane è fatto con la Farina di Segale Resistente che gli dà un sapore schifoso ma con qualità nutrizionali eccellenti e uniche.",ep:1,g:9,l:10,wd:true,fm:true,w:1,c:"Cv<40",u:true,ut:true,p:1};
I.u[2032] = {n:"Orzo di Zucchero",t:34,d:"Quest\'orzo molto raro ha assorbito pioggia zuccherata durante la germinazione, il che gli ha conferito poteri magici inestimabili.",ep:1,g:477,l:10,wd:true,fm:true,w:2,p:0};
I.u[2033] = {n:"Farina di Orzo di Zucchero",t:52,d:"Questa farina è stata ottenuto con l\'orzo di zucchero, permette di fare un pane così leggero che potrebbe volarsene via al primo colpo di vento. Ma non è una ragione per mangiarne una quantità fuori ragione.",ep:1,g:256,l:1,wd:true,fm:true,w:1,p:0};
I.u[2034] = {n:"Zucchero d\'Orzo",t:42,d:"Estraendo lo zucchero dalla farina d\'orzo dolce si può fare una caramella unica dal gusto fantastico.",ep:1,g:128,l:1,wd:true,fm:true,w:1,c:"Cv<50",u:true,p:50000};
I.u[2035] = {n:"Canapa Euforica",t:34,d:"Pare che questo gambo di canapa abbia degli effetti inibitori molto potenti. Potrebbe rivelarsi molto interessante se utilizzato da uno specialista.",ep:1,g:478,l:70,wd:true,fm:true,w:1,p:0};
I.u[2036] = {n:"Avena Aurifera",t:34,d:"Quando si guarda questa avena si ha l\'impressione che pianga oro, segno della grande potenza che ha immagazzinato durante la sua crescita.",ep:1,g:551,l:20,wd:true,fm:true,w:2,p:0};
I.u[2037] = {n:"Farina di Avena Aurifera",t:52,d:"Questa farina è stata ottenuta con l\'avena aurifera, il che le conferisce un dolce colore dorato e un grande potere magico. Tuttavia non farà di te un mago pasticcere.",ep:1,g:250,l:1,wd:true,fm:true,w:1,p:0};
I.u[2038] = {n:"Pane ai Fiocchi di Avena aurifera",t:33,d:"Questo pane dalla mollica particolarmente leggera è semplicemente perfetto.",ep:1,g:5,l:10,wd:true,fm:true,w:2,c:"Cv<70",u:true,ut:true,p:1};
I.u[2039] = {n:"Contrassegno di test del Cacciatore",t:24,d:"Hai cercato di superare il test per diventare Cacciatore.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2040] = {n:"Forziere nascosto di Tsog",t:24,d:"Hai ritrovato il forziere di Tsog in una scatola che puzza esattamente come Tsog stesso... è un odore indescrivibile.",ep:2,g:56,l:1,wd:true,fm:true,w:0,p:1};
