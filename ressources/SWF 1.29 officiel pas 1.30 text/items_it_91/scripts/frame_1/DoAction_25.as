I.u[11174] = {n:"Chiave del Dongione dei Pappabuk",t:84,d:"Questa chiave permette di entrare nella serra dove si rintana il Realbuk.",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[11175] = {n:"Chiave del Dongione dei Pinguinotti",t:84,d:"Questa chiave, dall\'alto contenuto di amianto, fluttua bene sull\'acqua e sull\'aceto. Permette anche di entrare nel dongione dei Pinguinotti.",ep:0,g:255,l:1,wd:false,fm:true,w:1,p:1};
