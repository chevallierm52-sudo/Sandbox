I.u[11041] = {n:"Spada Handovai",t:6,d:"Pesante, poco maneggevole, smussata e sgraziata, ci si chiede come Gultard sia divenuto un combattente così temibile con una spada così mediocre. Maneggiarla non ti renderà migliore, solo ridicolo.",ep:0,g:99,l:40,wd:false,fm:true,w:10,an:14,e:[6,4,1,1,40,40,false,false],s:159,p:4000};
I.u[11042] = {n:"Cintura Padrinfiglio",t:10,d:"Regalo di un padre al figlio, questa cintura fu data a Gultard per il suo quinto compleanno. Di semplice fattura, è solida e terrà fermi i tuoi pantaloni sui tuoi fianchi. Può essere utile come corda per stendere o per saltare.",ep:0,g:175,l:40,wd:false,fm:true,w:10,s:159,p:4300};
I.u[11043] = {n:"Cappello Kalisse",t:16,d:"Questo cappello è così stretto che comprime la testa e provoca allucinazioni. Fortunatamente Gultard lo portava quando era giovane e in più ha un cranio piccolo... Ecco cosa tradisce le sue origini.",ep:0,g:265,l:41,wd:false,fm:true,w:10,s:159,p:4500};
I.u[11044] = {n:"Resti della famiglia di Gultard",t:24,d:"Qualche ossa, gioielli mortuari... ecco il tuo funesto bagaglio.",ep:0,g:818,l:1,wd:false,fm:true,w:0,p:0};
I.u[11045] = {n:"Mantello Stinenza",t:17,d:"Gultard portò questo mantello fino a quando non incontrò le tre sorelle, poi lo dimenticò in un vecchio baule.",ep:0,g:179,l:43,wd:false,fm:true,w:10,s:159,p:5050};
I.u[11046] = {n:"Collana maledetta di Istriona",t:24,d:"Questa collana ha un\'aura malefica così potente che stai facendo una gran fatica per sbarazzartene.",ep:0,g:819,l:1,wd:false,fm:true,w:0,p:0};
I.u[11047] = {n:"The Orc",t:32,d:"The Orc s\'è arreso, porta il prigioniero a Lethalin.",ep:0,g:29,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11048] = {n:"Indizi per Dark Vlad",t:24,d:"Un piano semplice e una pozione di intelligenza. Ecco, con questi oggetti persino Dark Vlad dovrebbe poter essere in grado di lasciare il suo labirinto.",ep:0,g:820,l:1,wd:false,fm:true,w:0,p:0};
I.u[11049] = {n:"Clementocapo",t:16,d:"Indossa questo copricapo, sbuccialo per molte ore e troverai sicuramente un piccolo seme.",ep:0,g:262,l:32,wd:false,fm:true,w:10,s:161,p:2900};
I.u[11050] = {n:"Clementello",t:17,d:"Questo mantello diffonde un profumo di agrumi tutto intorno a te, trasformandoti in una grossa trappola per Moskito.",ep:0,g:177,l:32,wd:false,fm:true,w:10,s:161,p:2850};
I.u[11051] = {n:"Clementamuleto",t:1,d:"Gettando questo amuleto nel tuo bicchiere la tua acqua insipida si trasformerà in una deliziosa bevanda agli agrumi.",ep:0,g:161,l:32,wd:false,fm:true,w:10,s:161,p:2925};
I.u[11052] = {n:"Clementivali",t:11,d:"La suola di questi stivali è confezionata con la buccia rugosa di frutti raccolti su un\'isola assolata di cui nessuno sospetta l\'esistenza.",ep:0,g:161,l:34,wd:false,fm:true,w:10,an:0,s:161,p:3205};
I.u[11053] = {n:"null",t:31,d:"",ep:0,g:0,l:1,wd:false,fm:false,w:0,p:0};
I.u[11054] = {n:"null",t:49,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,c:"Sc=994",ut:true,p:0};
I.u[11055] = {n:"Cappelligna",t:16,d:"Imbottito con peli di Maomao e ricoperto di corteccia, questo cappello è molto infiammabile. E\' sconsigliabile sedercisi sopra se hai mangiato fagioli per cena...",ep:0,g:263,l:41,wd:false,fm:true,w:10,an:0,s:162,p:4553};
I.u[11056] = {n:"Mantelpigna",t:17,d:"Quando fa caldo le scaglie di questo mantello si allargano per lasciar evaporare la tua traspirazione. Quando piove le scaglie si allargano per far entrare la pioggia e inzupparti tutto il fondoschiena.",ep:0,g:178,l:42,wd:false,fm:true,w:10,an:0,s:162,p:4875};
I.u[11057] = {n:"Cintura Pigna",t:10,d:"Questa cintura è composta da scaglie sistemate a spirale in modo da seguire la regola di Vibronacci.",ep:0,g:174,l:40,wd:false,fm:true,w:10,an:0,s:162,p:4305};
I.u[11058] = {n:"Anello Pigna",t:9,d:"Ma chi conti di sedurre con un anello del genere?",ep:0,g:189,l:43,wd:false,fm:true,w:10,an:0,s:162,p:5100};
