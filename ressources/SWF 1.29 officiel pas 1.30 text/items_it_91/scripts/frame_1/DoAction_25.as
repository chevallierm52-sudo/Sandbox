I.u[11312] = {n:"Coda di Fantasminmare",t:65,d:"",ep:0,g:0,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11313] = {n:"Olio di Fantimoniere",t:60,d:"Il Fantimoniere porta ogni giorno con se un po\' d\'olio per assicurarsi che la barra giri correttamente. Cerca disperatamente di berne un po\' ogni giorno per far girare meglio la sua testa... Ma non sembra funzionare.",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11314] = {n:"Guscio di Fantimoniere",t:111,d:"Questo guscio proteggeva il Fantimoniere alla guida della nave dagli spruzzi di schiuma e guano.\nOra gli serve per proteggere le sue pupille delicate dalle tempeste di sabbia nera della Culla di Alma.",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11315] = {n:"Pennone di Fantalbero Maestro",t:38,d:"Gli ignoranti potranno pensare che si tratta di un pezzo di davanzale, ma i Frigostiani ti diranno che è un pezzo di legno verticale, quindi è un pennone. Facile da capire, no?",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11316] = {n:"Dente di Fantalbero Maestro",t:47,d:"Anche i più grandi cercatori Frigostiani non hanno saputo spiegare l\'utilità dei denti per un fantasma, soprattutto se è legato ad un albero. Magari gli servono per mordere le corde...",ep:0,g:0,l:150,wd:false,fm:true,w:10,an:0,p:10};
I.u[11317] = {n:"Guscio di Fantarpione",t:111,d:"Il Fantarpione ha rubato il suo guscio a un mollusco impotente. Questo però non l\'ha reso più potente.",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11318] = {n:"Scaglia di Fantarpione",t:59,d:"Questa scaglia appartiene a quel che sembra essere un vecchio Frigostiano diventato pirata e trasformato in fantasma poichè sua mamma ha tentato molte volte di annegarlo. Ecco cosa accade con un\'alimentazione troppo salata.",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11319] = {n:"Stoffa della Vedetta Fantasma",t:55,d:"Girando questa stoffa puoi leggere un piano incredibile: \"Se vedi un nemico, rubagli il tesoro, nascondilo su un\'isola deserta e metti una croce su una mappa per ricordarti dove l\'hai sepolto. PS: non nascondere la mappa insieme al tesoro.\"",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11320] = {n:"Occhio di Vedetta Fantasma",t:109,d:"La Vedetta fantasma è scelta per la sua vista fuori dal comune. E\' capace di distinguere un tonno da una sirena in piena tempesta, di notte, con un polipo sugli occhi, del guano sulle palpebre e i canti di Claudius Baglionus di sottofondo.",ep:0,g:0,l:155,wd:false,fm:true,w:10,an:0,p:10};
I.u[11321] = {n:"Pelo di Ben il Ripata",t:54,d:"Conosciuto come \"La furia rossa\", \"Benny l\'imbroglione\", \"L\'Intarmatore\" e anche come \"Ben Venutiabordo\" (soprattutto quando è ubriaco), questo pirata ha navigato su tutti i mari in lungo e in largo ed ha finito per attraversarli tutti passando per i fondali... Le maree hanno deciso che dovrà finire i suoi giorni sulle spiagge di sabbia nera della Culla di Alma.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11322] = {n:"Scapola di Ben il Ripata",t:47,d:"Rotta due volte a cannonate, tre volte per essere scivolato sulla schiuma e quattro volte dopo varie cadute sul guano secco, quest\'osso ha fatto del medico di bordo un uomo ricco, fino a che non è finito in pasto agli squali a causa di oscure storie di alcool, soldi, donne, insubordinazione, provocazioni in duello, furti di tesori, sabotaggio e ammutinamento. Una successione di sciocchezze che hanno causa la sua perdita. Non rimpiangerlo con Ben il Ripata, mi raccomando.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11323] = {n:"Pietra di Atomistico",t:51,d:"Questa pietra levitava intorno ad un Atomistico fino a che non hai provato ad evitarla o a farla levitare. In poche parole, non sai cosa sia accaduto, ma ora ti ritrovi con un dolore atroce alla testa e coperto di bava fumante...",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11324] = {n:"Tefra di Atomistico",t:51,d:"Questo frammento di lava è stato sputato fuori a gran velocità da uno degli orifizi sconosciuti dell\'Atomistico che hai disperatamente cercato di uccidere a colpi di rastrello. Hai avuto la fortuna di non trovarti sulla sua traiettoria nel momento in cui è partito per piantarsi nel fondoschiena di un turista locale.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11325] = {n:"Residuo di Solfatara",t:51,d:"Come una creatura vaporosa può lasciare residui solidi? Questa domanda è stata posta 74 anni or sono durante l\'esame del celebre Concorso Frigostiano per la Promozione dei Giovani Geologi Graduati. Quell\'anno nessun partecipante fu ammesso, e la domanda rimane ancora oggi uno dei più terrificanti misteri dell\'isola di Frigost.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11326] = {n:"Ulna di Solfatara",t:47,d:"Quest\'osso vaporoso si deforma in funzione dell\'umore della Solfatara, famosa per i suoi disturbi a causa di tutti i fumi che le vanno nel cervello.",ep:0,g:0,l:165,wd:false,fm:true,w:10,an:0,p:10};
I.u[11327] = {n:"Cuore di Croccavapore",t:51,d:"Questo cuore di pietra si riempie di vapore quando un Croccavapore incontra una partner. Questa particolarità ti permette di determinare se hai appena ucciso un Croccavapore celibe, ti basta verificare se il suo cuore fluttua.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11328] = {n:"Uovo di Croccavapore",t:105,d:"Il Croccavapore è simile ad un Croccaroc di vapore che ha deciso di venire alle mani con qualsiasi cosa non somigli nè da vicino nè da lontano, nè da molto lontano, a del vapore. Fatto sorprendente, depone uova piene di vapore.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11329] = {n:"Pietra di Fumarola",t:51,d:"La Fumarola agita questa enorme pietra alla fine di quel che sembra essere la sua coda. Spera di intimidirti, fino al momento in cui trovi il suo punto debole. Sfortunatamente la tua testa di legno non è riuscito a memorizzare quale sia.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11330] = {n:"Artefatto di Fumarola",t:50,d:"Questo artefatto vaporoso puzza di uovo marcio misto a guanocamola. Il solo pensiero di questo mix ti fa venire fame.",ep:0,g:0,l:170,wd:false,fm:true,w:10,an:0,p:10};
I.u[11331] = {n:"Pietra di Mofetta",t:51,d:"La Mofetta prende il suo nome da una struttura geologica molto frequente nella zona delle Lacrime di Uronigride. Questa pietra somiglia ad uno dei suoi organi, magari uno dei suoi reni.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11332] = {n:"Tufo di Mofetta",t:51,d:"Dietro a questo strano nome si nasconde una roccia dalla struttura vacuolare. Puoi accontentarti di farla somigliare un un pezzo di Mofetta gigante che hai appena strappato selvaggiamente.",ep:0,g:0,l:175,wd:false,fm:true,w:10,an:0,p:10};
I.u[11333] = {n:"Scoria di Magmarmittone",t:51,d:"Evidentemente è uno scarto, anche per il Magmarmittone stesso. Da non mettere in tutte le tasche, soprattutto in quelle non ignifughe.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11334] = {n:"Vertebra di Magmarmittone",t:47,d:"Questa vertebra contiene del midollo osseo già cotto e pronto per essere mangiato. Hai sotto gli occhi e fra le mani le primizie della cucina istantanea.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11335] = {n:"Zampa di Maho Ghiacciopaz",t:103,d:"Dopo averla presa numerose volte in faccia, hai finalmente il diritto di tenerla nel tuo zaino come porta-fortuna.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11336] = {n:"Orecchio di Maho Ghiacciopaz",t:106,d:"Non si sa come i Ghiacciopaz siano giunti su Frigost, ma si sa che i loro lontani cugini vengono da Pandala. Questa informazione permette di comprendere meglio l\'origine dei residui gelati di Pandrista sui quali hai dormito la scorsa notte.",ep:0,g:0,l:185,wd:false,fm:true,w:10,an:0,p:10};
I.u[11337] = {n:"Cuoio di Soryo Ghiacciopaz",t:56,d:"Questo cuoio è così spesso da permettere al Soryo Ghiacciopaz di resistere alle più basse temperature e di fare  scivolate sul suo sedere senza farsi male. Questa cosa ti rende particolarmente geloso.",ep:0,g:0,l:190,wd:false,fm:true,w:10,an:0,p:10};
I.u[11338] = {n:"Lana di Soryo Ghiacciopaz",t:57,d:"Utilizzata a lungo come imbottitura per gli indumenti intimi dai Frigostiani complessati, questa lana ha come effetto collaterale quello di far crescere foruncoli a coloro che ci si strofinano contro. Ora hai un eccellente motivo per giustificare i tuoi brufoli.",ep:0,g:0,l:190,wd:false,fm:true,w:10,an:0,p:10};
I.u[11339] = {n:"Lana di Yokai Ghiacciopaz",t:57,d:"Difficile essere più stupidi della progenie degli Yokai Ghiacciopaz. Eppure qualche genitore ci riesce... Cerchi un legame con questa lana di Ghiacciopaz, ma non ne trovi, nemmeno se chiudi forte gli occhi e stringi i pugni...",ep:0,g:0,l:195,wd:false,fm:true,w:10,an:0,p:10};
I.u[11340] = {n:"Cranio di Yokai Ghiacciopaz",t:47,d:"La scatola cranica del Yokai Ghiacciopaz riesce a mala pena a contenere un fiocco di neve evaporato passato attraverso un colino. Ma siccome la stupidità fa paura, i Frigostiani sono terrorizzati da questa bestia quasi incapace di mettere una zampa davanti all\'altra.",ep:0,g:0,l:195,wd:false,fm:true,w:10,an:0,p:10};
