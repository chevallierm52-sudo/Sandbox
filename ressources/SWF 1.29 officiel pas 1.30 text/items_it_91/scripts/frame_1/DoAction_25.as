I.u[11297] = {n:"Lettera di Eelgatto Nelzacco",t:24,d:"Lemanee, se stai leggendo questa lettera è perchè sono morto. Probabilmente cerchi il mio tesoro, sappi però che non ti dirò mai dov\'è nascosto.\nCiao!",ep:0,g:55,l:1,wd:false,fm:true,w:0,an:0,p:1};
