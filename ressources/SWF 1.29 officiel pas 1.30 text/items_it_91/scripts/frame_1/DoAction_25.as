I.u[11156] = {n:"Yucca Lele",t:24,d:"Questo fiore è stato reso famoso dal cantante Gaet Anrin. Da quel momento in poi, tutti i cantanti hanno smesso di usarlo.",ep:0,g:841,l:1,wd:false,fm:true,w:0,p:1};
I.u[11157] = {n:"Tulip Osuzione",t:24,d:"Ridotto in polvere e bollito, questo fiore dal nome strano è un ingrediente raccomandato nei regimi per perdere peso rapidamente. L\'inconveniente è che perde peso rapidamente anche il mucchio dei tuoi kama.",ep:0,g:842,l:1,wd:false,fm:true,w:0,p:1};
I.u[11158] = {n:"Rosa Nelson",t:24,d:"Scoperta dal celebre botanico Yosef, questa rosa rilascia un dolce profumo di sterco di Freddocero aromatizzato al sudore. Ecco come ti vengono in mente i tuoi momenti più intimi.",ep:0,g:843,l:1,wd:false,fm:true,w:0,p:1};
I.u[11159] = {n:"Mima Osamodas",t:24,d:"L\'ombra di questo fiore ricorda quella degli Osamodas.",ep:0,g:844,l:1,wd:false,fm:true,w:0,p:1};
I.u[11160] = {n:"Rabarbapapà filato",t:24,d:"E\' il solo ricordo che ti rimane di tuo padre. Avresti preferito un maniero e molti kama, ma la vita è ingiusta, si sa.",ep:0,g:845,l:1,wd:false,fm:true,w:0,p:1};
I.u[11161] = {n:"Cri-santemo",t:24,d:"Un\'associazione che lotta contro le malattie frigostiane ha fatto di questo fiore il suo emblema. Il suo motto: uscite coperti.",ep:0,g:846,l:1,wd:false,fm:true,w:0,p:1};
I.u[11162] = {n:"Rosa Liecullen",t:24,d:"Un Signore del Tempo Xelor ha scoperto questo splendido fiore, ma fu costretto a separarsi da esso a malincuore.",ep:0,g:847,l:1,wd:false,fm:true,w:0,p:1};
I.u[11163] = {n:"Rosa Dalima",t:24,d:"Si dice che questa rosa sia benedetta dagli dei, una cosa che non si può dire di te.",ep:0,g:848,l:1,wd:false,fm:true,w:0,p:1};
I.u[11164] = {n:"Elleboro Dello",t:24,d:"Questo fiore viene usato dalla gente di facili costumi per riconoscersi fra di loro. Gli altri li riconoscono ugualmente.",ep:0,g:849,l:1,wd:false,fm:true,w:0,p:1};
I.u[11165] = {n:"Aconito pensatore",t:24,d:"Un tempo ci fu un avvelenamento di massa fra gli Yop a causa di questo fiore, poichè pensavano che masticarlo desse un\'aria intelligente. Avrebbe potuto essere vero, se gli Yop fossero stati in grado di pensare.",ep:0,g:850,l:1,wd:false,fm:true,w:0,p:1};
I.u[11166] = {n:"Giglio Ander",t:24,d:"Il nome di questo fiore è un omaggio a Ander, celebre capitano della flotta militare di Frigost, che morì rompendosi la testa contro le mura della casa del suo rivale Al Hiartus.",ep:0,g:851,l:1,wd:false,fm:true,w:0,p:1};
I.u[11167] = {n:"Giglio Tigrato",t:24,d:"Questo fiore ha la particolarità di essere molto utilizzato dai capitani pirati di un\'isola che non c\'è che cercano di far cadere in trappola i loro nemici.",ep:0,g:852,l:1,wd:false,fm:true,w:0,p:1};
