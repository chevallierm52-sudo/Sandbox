I.u[11367] = {n:"Siringa di vaccino contro la Ros Olia",t:24,d:"Questa siringa contiene una dose di vaccino contro la Ros Olia. Testato e certificato da Rosa Lina.",ep:0,g:31,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11368] = {n:"Mamanguinotta",t:32,d:"Questa Mamanguinotta ti seguirà perchè non ha scelta, ma scapperà alla prima occasione.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11369] = {n:"Seme di Panoramiz",t:24,d:"Questo seme ti è stato dato da Panoramiz per ripopolare la Foresta dei Pini perduti.",ep:0,g:831,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11370] = {n:"Frigovino",t:79,d:"Questa bevanda molto zuccherata ha la particolarità di essere fatta con chicchi d\'uva da vendemmia congelati. Questo spiega la sua rarità e il suo gusto raffinato unico.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,p:2};
I.u[11371] = {n:"Frigodka",t:79,d:"Chiamata anche la bevanda all\'erba di pappabuk, la Frigodka è famosa per il modo in cui facilita i rapporti umani e per il modo in cui si possono, con essa, affrontare discorsi difficili. Per quanto riguarda i Frigostiani la bevono solo perchè gli piace bere.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,p:2};
I.u[11372] = {n:"Cartantello",t:17,d:"Questo mantello è così lungo da permetterti di lasciare qualche spazio fra le righe dei bigliettini per copiare.",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:166,p:9175};
I.u[11373] = {n:"Cartappello",t:16,d:"Il Sarto che ha confezionato questo cappello ha dovuto utilizzare 12 potenti pergamene in carta. O 12 fogli di carta igienica.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:166,p:9400};
I.u[11374] = {n:"Cartamuleto",t:1,d:"Resta abbastanza spazio perchè uno dei tuoi amici scriva il tuo nome su questo amuleto di carta. Ecco come fanno gli allevatori a riconoscere i Pappatutto.",ep:0,g:0,l:62,wd:false,fm:true,w:10,an:0,s:166,p:10100};
I.u[11375] = {n:"Cartutande",t:1,d:"Questi indumenti intimi sono solidi e rigidi, non sono molto comodi, ma sono stati realizzati con carta masticata. Avere la saliva di uno sconosciuto sul sedere non sembra disturbare molti avventurieri...",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:166,p:9900};
I.u[11376] = {n:"Piumantello",t:17,d:"Quest\'enorme piuma accentua il tuo fisico da materasso...",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:167,p:8428};
I.u[11377] = {n:"Cappiumello",t:16,d:"Secondo alcune tribù la saggezza del capo si misura dal numero di piume sul suo cappello. Il tuo ne possiede solo una, piccola e usata, per giunta.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:167,p:9380};
I.u[11378] = {n:"Piumandali",t:11,d:"Più leggeri dei sandali classici, non hanno che un solo inconveniente: non sono adatti a coloro che soffrono il solletico.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:167,p:8230};
I.u[11379] = {n:"Piumamuleto",t:1,d:"Ti solletica il collo e ti farà venire i brividi ovunque.",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:167,p:9250};
I.u[11380] = {n:"Cacciatore ferito",t:32,d:"Questo cacciatore ferito ha bisogno delle cure di Albert Pes. Al minimo segno di combattimento tornerà a rifugiarsi dove l\'hai trovato.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11381] = {n:"Richiesta di tiro",t:24,d:"Richiesta stilata da Djauns per un tiro di Baubau delle nevi. Con la sua firma ti ricorda di spicciarti perchè il tempo è poco.",ep:0,g:55,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11382] = {n:"Pinzantello",t:17,d:"L\'ultima persona che ha provato a usare questo mantello per scendere da una nuvola si è spiaccicato sulla banca.",ep:0,g:0,l:56,wd:false,fm:true,w:10,an:0,s:168,p:8300};
I.u[11383] = {n:"Pinzappello",t:16,d:"Questo cappello non sopporta l\'umidità e ti costringerà ad andare perennemente in giro con un ombrello ridicolo.",ep:0,g:0,l:53,wd:false,fm:true,w:10,an:0,s:168,p:7503};
I.u[11384] = {n:"Pinzanello",t:9,d:"Metti questo anello intorno al collo dei bambini che devi sorvegliare, lega l\'anello ad un albero con una corda. Ecco fatto, ora sei tranquillo e i bambini non scapperanno.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:168,p:8895};
I.u[11385] = {n:"Pelliccia intatta di Ghiacciopaz",t:24,d:"Recuperare questa pelliccia senza massacrarla troppo rivela il modo in cui hai combattuto contro il suo precedente proprietario.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11386] = {n:"Pinzivali",t:11,d:"Sono perfetti per dare sculacciate con i piedi, senza sporcarti le mani. I bambini ti adoreranno!",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:168,p:9275};
I.u[11387] = {n:"Gaston",t:32,d:"Devi scortarlo fino da Larry Tutthe perchè diventi il suo nuovo assistente.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11388] = {n:"Cassa di materiale",t:24,d:"Questa cassa contiene tutto quello di cui Larry Tutthe ha bisogno.",ep:0,g:44,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11389] = {n:"Prelievo d\'acqua",t:24,d:"Quest\'acqua è stata prelevata nelle Lacrime di Uronigride su richiesta di Ogivol Victor.",ep:0,g:764,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11390] = {n:"Creatura d\'acqua",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11391] = {n:"Creatura d\'acqua modificata",t:24,d:"Gli effetti della crescita accelerata su questa creatura saltano agli occhi. Faresti meglio a sbrigarti, prima di non poterla più trasportare.",ep:0,g:760,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11392] = {n:"Resti di Ghiacciopaz",t:24,d:"Hai fieramente combattuto i Ghiacciopaz. Questi resti sono la prova della tua vittoria.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11393] = {n:"Mantelligioniero",t:17,d:"Questo mantello rigato è appartenuto a un prigioniero celebre per il suo dilemma.",ep:0,g:0,l:51,wd:false,fm:true,w:10,an:0,s:169,p:7003};
I.u[11394] = {n:"Cappelligioniero",t:16,d:"Questo cappello rigato è abbastanza grande per nascondere una palla. Non necessariamente quella che hai legata al piede.",ep:0,g:0,l:55,wd:false,fm:true,w:10,an:0,s:169,p:7900};
I.u[11395] = {n:"Amugioniero",t:1,d:"Questa piccola catena potrebbe essere presa per un amuleto, se non avesse il lucchetto.",ep:0,g:0,l:54,wd:false,fm:true,w:10,an:0,s:169,p:7825};
I.u[11396] = {n:"Cintugioniera",t:1,d:"La persona che ha dato un nome così stupido a questa cintura è ricercata, gli anni che ha già passato in galera non giustificano una tale mancanza di creatività.",ep:0,g:0,l:58,wd:false,fm:true,w:10,an:0,s:169,p:8750};
I.u[11397] = {n:"Mantistrello",t:17,d:"Questo mantello dal nome ridicolo ma intrigante apparteneva ad un giustiziere che diceva di voler ripulire le strade di Brakmar. Nessuno sa se si trattava di un giustiziere o di un netturbino.",ep:0,g:0,l:54,wd:false,fm:true,w:10,an:0,s:170,p:7703};
I.u[11398] = {n:"",t:16,d:"Questo cappello ti darà il portamento di un pipì-strello. Sai, rischi di restare celibe molto a lungo...",ep:0,g:0,l:57,wd:false,fm:true,w:10,an:0,s:170,p:8575};
I.u[11399] = {n:"Anistrello",t:9,d:"Sulla scatola puoi leggere: \"Solo per giustizieri che non hanno paura di nulla\". E tu che credevi di poterlo utilizzare...",ep:0,g:0,l:59,wd:false,fm:true,w:10,an:0,s:170,p:9187};
I.u[11400] = {n:"Stivastrelli",t:11,d:"Il Ciabattino che ha concepito questi stivali li ha muniti di ali di Pipì-strello per permettere al loro proprietario di volare. Questo è quel che ha detto il mercante ambulante che te li ha venduti, mentre gridava allo zaap di Astrub un discorso praticamente inascoltabile.",ep:0,g:0,l:57,wd:false,fm:true,w:10,an:0,s:170,p:8500};
I.u[11401] = {n:"Mantellocchio",t:17,d:"Questo mantello di legno si allunga se menti. Rischi di camminarci regolarmente sopra.",ep:0,g:0,l:60,wd:false,fm:true,w:10,an:0,s:171,p:9428};
I.u[11402] = {n:"Cappellocchio",t:16,d:"Questo cappello può essere usato come cono di segnalazione se hai un incidente con il Dragacchino.",ep:0,g:0,l:61,wd:false,fm:true,w:10,an:0,s:171,p:9875};
I.u[11403] = {n:"Mal di mare",t:24,d:"Non sei riuscito a trasformarti in pirata, decisamente non hai la stoffa del marinaio. Riprova fra 24 ore.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11404] = {n:"Trasformazione in Fantasma di Pirata",t:27,d:"Sei stato trasformato in fantasma per entrare nel relitto dello spirito ribelle.",ep:0,g:3,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11406] = {n:"Siero di Pinguinotto",t:24,d:"Solo la gente acculturata conosce l\'utilità di questo siero, ecco perchè tu non sai a cosa serve.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11407] = {n:"Guano di Gellicano cristallizzato",t:24,d:"Questo ghiacciolo dona un gusto particolare alle bevande nelle quali è immerso per rinfrescarle.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11408] = {n:"Siero della verità",t:24,d:"Giuri di dire tutta la verità, nient\'altro che la verità?",ep:0,g:2,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11409] = {n:"Borsa di kama",t:24,d:"Questa borsa contiene abbastanza kama da poterti permettere l\'acquisto di un abito decente. Vista la difficoltà della scelta, è inutile dire che si tratta di una vera fortuna. Sappi che non li potrai utilizzare per comprare altre cose.",ep:0,g:243,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11410] = {n:"Abito da Adamo",t:24,d:"Portato alla festa della Mutanda del Capitano Chafer, questo abito attirerà gli sguardi degli invidiosi, ma soprattutto delle invidiose vogliose di gustare il frutto nascosto.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,p:1};
