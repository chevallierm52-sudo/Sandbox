I.u[11077] = {n:"Martello di Lonne",t:7,d:"Quando si trattava di suonare gli avversari Lonne Jenon aveva più di una corda al suo violino... e lo usava come un martello. Una cosa è certa: volavano scintille!",ep:0,g:75,l:54,wd:false,fm:true,w:20,an:0,e:[6,5,1,1,42,50,false,false],c:"CA>20&CV>40",s:163,p:9700};
I.u[11078] = {n:"Mantello di Lonne",t:17,d:"Questo mantello in cuoio, eppure leggero, ti accompagnerà nelle tue fantastiche cavalcate sul tuo dragacchino...",ep:0,g:176,l:55,wd:false,fm:true,w:10,an:0,s:163,p:7900};
I.u[11079] = {n:"Cappello di Lonne",t:16,d:"Prima di essere stato indossato da Lonne Jenon questo cappello apparteneva a un certo Sergente Pepper. Un tipo piuttosto tranquillo che aveva una band composta da cuori solitari.",ep:0,g:261,l:55,wd:false,fm:true,w:10,an:0,s:163,p:8050};
I.u[11080] = {n:"Stivali di Lonne",t:11,d:"Questo paio di stivali ti garantirà una totale libertà di movimento. E\' per questo che Lonne li indossava per ballare con i Muulupi.",ep:0,g:160,l:55,wd:false,fm:false,w:10,an:0,s:163,p:7925};
I.u[11082] = {n:"Stivali da Pappaball",t:11,d:"Questi stivali sono stati concepiti specialmente per distruggere i parastinchi dei tuoi avversari, poi i loro stinchi, infine le dita dei tuoi piedi.",ep:0,g:157,l:28,wd:false,fm:true,w:10,an:0,c:"Sc=11",p:2300};
I.u[11083] = {n:"Anello da Pappaball",t:9,d:"Questo anello permette di bucare la Pappaball quando vuoi approfittare discretamente per fare una pausa di gioco.",ep:0,g:187,l:31,wd:false,fm:true,w:10,an:0,c:"Sc=12",p:2666};
I.u[11084] = {n:"Cappello di Gadjet",t:16,d:"Gadjet era uno dei Tuttofare più creativi del Mondo dei Dodici. Sfortunatamente era anche uno dei più storditi. Si racconta che confondeva spesso l\'incudine e la testa della moglie, ma che lei non si lamentava mai...",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6400};
I.u[11085] = {n:"Cintura di Gadjet",t:10,d:"Indossando questa cintura al contrario e chiudendola abbastanza stretta potrai magari riuscire ad attivare il modulo integrato di retromagia. Non ha mai funzionato, ma potrai attivarlo comunque. Altrimenti potrai rivendere questa cintura a qualcuno naif come te.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6358};
I.u[11086] = {n:"Mantello di Gadjet",t:17,d:"Gadjet fabbricò questo mantello nella speranza che gli permettesse di volare, per poter sfuggire alle punizioni quotidiane che gli venivano inflitte dalla moglie.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6350};
I.u[11087] = {n:"Anello di Gadjet",t:9,d:"Indossato da numerose generazioni di Tuttofare, questo anello protegge una delle tue falangi dalle martellate. Sfortunatamente non è mai venduto a lotti di cinque.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6453};
I.u[11088] = {n:"Cappello di Grillian",t:16,d:"Grillian era un grande mago, celebre per aver scoperto come tagliare la corda dopo aver dimenticato come si faceva.",ep:0,g:0,l:49,wd:false,fm:true,w:10,s:164,p:6325};
I.u[11089] = {n:"Mantello di Grillian",t:17,d:"Questo mantello è tenuto a proteggerti il posteriore dai morsi delle mostropiante.",ep:0,g:0,l:48,wd:false,fm:true,w:10,s:164,p:6250};
I.u[11090] = {n:"Avviso di ricerca",t:24,d:"Questo avviso di ricerca è per Lethalin Sigisbul.",ep:0,g:821,l:1,wd:false,fm:true,w:0,p:0};
I.u[11091] = {n:"Stivali di Grillian",t:11,d:"Grillian il mago scambiò un anello magico per questi stivali. Credo ci abbia perso nello scambio, non sono nemmeno imbottiti.",ep:0,g:0,l:46,wd:false,fm:true,w:10,an:0,s:164,p:5600};
I.u[11092] = {n:"Amuleto di Grillian",t:1,d:"Grillian indossava questo amuleto intorno al collo quando... quando... Che importa? Ormai lui è morto e questo amuleto ti appartiene.",ep:0,g:0,l:45,wd:false,fm:true,w:10,s:164,p:5450};
