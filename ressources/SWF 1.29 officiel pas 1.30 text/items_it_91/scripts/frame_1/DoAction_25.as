I.u[11306] = {n:"Spada Vivace",t:6,d:"Puoi leggere, inciso sul pomo della sua elsa: \"Ruba la vita ai poveri per donarla ai ricchi.\". E\' un peccato che tu sia povero.",ep:0,g:0,l:49,wd:false,fm:true,w:10,e:[5,5,1,1,45,50,false,false],p:4900};
I.u[11307] = {n:"Tesoro maledetto di Az il Teco",t:94,d:"Az il Teco voleva scambiare con l\'Anutrof conquistatore Sétroc questo tesoro in cambio della sua libertà. Una volta ottenuto il tesoro, Sétroc non mantenne la parola, e fece uccidere Az il Teco. Morendo questi scagliò una maledizione, che si abbatterà su tutti coloro che possiedono questo tesoro.",ep:0,g:0,l:1,wd:false,fm:true,w:1,an:0,u:true,p:1};
I.u[11308] = {n:"Maledizione di Az il Teco",t:30,d:"Hai rubato una parte del tesoro di Az il Teco. Ecco cosa succede alle persone avide.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
