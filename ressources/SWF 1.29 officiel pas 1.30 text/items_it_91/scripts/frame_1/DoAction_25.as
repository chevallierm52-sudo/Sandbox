I.u[11182] = {n:"Parrucca del Realbuk",t:24,d:"Una cosa è sicura: senza la sua parrucca l\'autorità del Realbuk viene gettata alle ortiche.",ep:0,g:826,l:1,wd:false,fm:true,w:0,p:1};
I.u[11183] = {n:"Pescetto Reale",t:24,d:"Il Pinguinotto Reale in persona ha usato questo pescetto contro di te. Non importa quale sia la sua origine, finirà in padella come un volgare pescetto.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
