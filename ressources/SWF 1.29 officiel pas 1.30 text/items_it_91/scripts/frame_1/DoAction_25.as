I.u[11010] = {n:"Pozione di Miglioramento di Maomao dei Ghiacci",t:116,d:"Utilizzando questa potente pozione, aumenterai le capacità del tuo famiglio in maniera definitiva. Attenzione, una sola dose sarà sufficiente per il tuo famiglio, ulteriori tentativi provocheranno risultati deludenti.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PO=10985",u:true,p:10};
I.u[11011] = {n:"Tifux Tigrato",t:18,d:"Più pazzo del Tifux comune, ma soprattutto con una chioma molto meno rossa, questo famiglio può essere immerso nell\'acqua senza che sia necessario tappargli il naso. Si nutre di creature che vivono sull\'Albero Hakam.",ep:0,g:63,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11012] = {n:"Baubau Tigrato",t:18,d:"Non è grazie al fatto di essere tigrato che questo famiglio non proverà ad annusarti il posteriore o a fare pipì sul tuo tappeto. Cosa speravi? Questo famiglio adora cacciare le creature che vivono nelle Lande di Sidimote.",ep:0,g:64,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11013] = {n:"Quaquà Nero",t:18,d:"Questo Quaquà Nero molto birichino è stato cacciato dalla sua famiglia perché era diverso dagli altri: era l\'unico che adorasse sentir cantare il menestrello Claudius Baglionus. Forse era solo un incompreso... Avendo vissuto un\'infanzia difficile, ha deciso di vendicarsi in modo arbitrario su tutte le creature della famiglia dei Cuervoc: li divora senza pietà.",ep:0,g:65,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11014] = {n:"Pipì-strello Slavato",t:18,d:"Questo famiglio ha dormito troppo a lungo sotto una pioggia acida. Di notte non brilla e non è magico, ma se lo usi per produrre dell\'aceto, sarà molto potente! Questo famiglio si nutre esclusivamente di creature della famiglia delle Gelatine.",ep:0,g:66,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11015] = {n:"Gupin",t:18,d:"Questa strana creatura ha attraversato gli oceani su un blocco di ghiaccio che si è incagliato in un porto sperduto. Sembra che ti prenda per un blocco di ghiaccio... Questo famiglio divoratore di anime mangia solo i mostri delle spiagge.",ep:0,g:67,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
