I.u[11102] = {n:"Bucaneve",t:35,d:"Indurito dal clima di Frigost, questo fiore è molto più resistente di quanto il suo aspetto delicato possa far supporre. La sua raccolta è comunque delicata per preservare tutte le proprietà alchemiche di una pianta così rara.",ep:0,g:635,l:100,wd:false,fm:true,w:1,p:0};
I.u[11103] = {n:"Sacco di Bucaneve",t:100,d:"Questo enorme sacco contiene una quantità impressionante di Bucaneve.",ep:0,g:57,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11104] = {n:"Quaquà migliorato",t:18,d:"Più stupido del Tofu, del Pappatutto e addirittura dello Yop, il Quaquà eccelle in cretineria.",ep:0,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[11105] = {n:"Fantasma di Quaquà migliorato",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[11106] = {n:"Pescetto Reale",t:41,d:"Spine taglienti come lame di Bwork, scaglie spesse come corteccia di Quercia Molle, e occhi neri come piume di Cuervoc. Questo pescetto può avere un aspetto temibile, ma nel piatto invece è semplicemente succulento.",ep:0,g:403,l:100,wd:false,fm:true,w:1,p:100};
I.u[11107] = {n:"Legno di Pioppo Tremulo",t:38,d:"Quest\'essenza di legno sembra tremare fra le tue dita. Dopo tutti i colpi di ascia che gli hai assestato è normale che abbia paura di te.",ep:0,g:677,l:100,wd:false,fm:true,w:5,p:100};
I.u[11109] = {n:"Frostiss",t:34,d:"Questo cereale è sorprendente, oltre a resistere al clima di Frigost da un gusto di cioccolato al lalatte nel quale viene immerso.",ep:0,g:552,l:100,wd:false,fm:true,w:1,p:100};
I.u[11110] = {n:"Ossidiana",t:39,d:"Tanto dura da rigare il vetro e tanto oscura da minare il tuo morale, questa roccia ha perso tutto il calore della lava dalla quale ha avuto origine. In ogni caso è perfetta per una pietra tombale, tanto non è mica la tua.",ep:0,g:90,l:100,wd:false,fm:true,w:5,p:0};
I.u[11111] = {n:"Sacco di Pescetti",t:100,d:"Questo enorme sacco contiene una quantità impressionante di Pescetti.",ep:0,g:59,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11112] = {n:"Sacco di Pioppo Tremulo",t:100,d:"Questo enorme sacco contiene una quantità impressionante di Pioppo Tremulo.",ep:0,g:58,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11113] = {n:"Sacco di Frostiss",t:100,d:"Questo enorme sacco contiene una quantità impressionante di Frostiss.",ep:0,g:60,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11114] = {n:"Sacco di Ossidiana",t:100,d:"Questo enorme sacco contiene una quantità impressionante di Ossidiana.",ep:0,g:34,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11115] = {n:"Pescis d\'Aperir",t:30,d:"Si sente arrivare la primavera. Si sente pure troppo, con quell\'Úridnac poco fresco attaccato alla schiena...",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[11116] = {n:"Úridnac",t:94,d:"Questo pesce ama talmente tanto le persone che vi si attacca facilmente.\nIl suo ritmo biologico è particolare: è attivo solo nel mese di Aperir, quando Siluate riscalda le acque dolci dove questo pesce vive.",ep:0,g:19,l:1,wd:false,fm:false,w:1,c:"SG=3&POX11115",u:true,ut:true,p:0};
I.u[11117] = {n:"Lana di Pappabuk",t:57,d:"I Pappabuk devono essere tosati una volta l\'anno, così come le ascelle di Bituf.",ep:0,g:211,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11118] = {n:"Clavicola di Pappabuk",t:47,d:"E\' inutile che continui a rosicchiare, non c\'è più la minima traccia di carne commestibile qua sopra.",ep:0,g:660,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11119] = {n:"Orecchio di Pappatonbuk",t:106,d:"I Frigostiani lo consumano generalmente con dell\'aceto, perchè non ha un buon sapore, e poi loro adorano l\'aceto.",ep:0,g:624,l:96,wd:false,fm:true,w:10,p:1};
I.u[11120] = {n:"Cuoio di Pappabuk",t:56,d:"Bollito 8 volte in acqua sembra che questo cuoio diventi commestibile. Questo è quel che raccontano i Frigostiani in vena di scherzi.",ep:0,g:534,l:96,wd:false,fm:true,w:10,p:1};
I.u[11121] = {n:"Occhio di Pappabuk di guerra",t:109,d:"Quest\'occhio ha visto più di un posteriore di femmina di Pappabuk, e ora non vedrà altro che il fondo della tua tasca. Che sfortuna.",ep:0,g:590,l:112,wd:false,fm:true,w:10,p:1};
I.u[11122] = {n:"Corno di Pappabuk di guerra",t:47,d:"I Pappabuk di guerra sono utilizzati, durante il loro sonno, come giocattolo dai Frigostiani più temerari che tentano di lanciare tre anelli metallici attorno a ciascun corno dell\'animale, senza svegliarlo. E\' sorprendente come nessuno sia ancora riuscito a finire vivo questo gioco.",ep:0,g:661,l:112,wd:false,fm:true,w:10,p:1};
I.u[11123] = {n:"Dente di saggezza di Pappabuk",t:24,d:"Hai strappato questo dente da un Pappabuk ancora vivo. Ma che cosa ti è passato per la testa?",ep:0,g:822,l:1,wd:false,fm:true,w:0,p:1};
I.u[11124] = {n:"Viscere congelate",t:24,d:"Queste viscere si sono congelate nel momento in cui le hai estratte dal corpo.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11125] = {n:"Piede del Pinguinotto",t:24,d:"Cosa sarà di questo Pinguinotto a cui hai portato via un piede, visto che la natura già non l\'ha dotato delle braccia?",ep:0,g:823,l:1,wd:false,fm:true,w:0,p:1};
I.u[11126] = {n:"Cranio etereo",t:24,d:"Come può un cranio essere etereo? Ci hai pensato su talmente tanto che ora ridi pensando alla risposta a questa domanda.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11127] = {n:"Lacrima ribelle",t:24,d:"Questa lacrima simboleggia l\'irriducibilità nei confronti dell\'oppressore.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11128] = {n:"Lacrima magmatica",t:24,d:"Invece di bagnare, questa lacrima brucia tutto il materiale combustibile col quale entra in contatto. Almeno non rischierai di far sciogliere il tuo trucco quando il tuo fidanzato ti lascerà per la sua dragacchina...",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11129] = {n:"Givranchy",t:24,d:"Questo estratto di muschio di Ghiacciopaz fa furore fra le femmine della specie. E\' un\'eccellente regalo da fare ai tuoi pretendenti, o ai tuoi rivali.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11130] = {n:"Muschio pietrificato",t:24,d:"Questo pezzo di muschio è stato pietrificato dal freddo. Una volta scongelato può essere utilizzato in una variante frigostiana della pizza al sanguinaccio.",ep:0,g:827,l:1,wd:false,fm:true,w:0,p:1};
I.u[11131] = {n:"Oggetto bizzarro",t:24,d:"Bisogna avere proprio la testa di legno per non capire a cosa serve questo oggetto...",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11132] = {n:"Cucchiaio",t:24,d:"Dato che non ha più il suo cucchiaio ora l\'orso deve mangiare con le dita, ed è tutta colpa tua.",ep:0,g:824,l:1,wd:false,fm:true,w:0,p:1};
I.u[11133] = {n:"Piuma Vibrante di Pinguinotto",t:94,d:"Seguendo l\'esempio del Tofu Reale, alcuni Pinguinotti hanno una piuma vibrante fortemente impregnata di magia. Per quanto riguarda l\'utilità, invece...",ep:0,g:20,l:50,wd:false,fm:false,w:1,c:"Qc=555&Qa!555",u:true,p:500};
I.u[11134] = {n:"Apewicubo",t:94,d:"Un oggetto è imprigionato dentro a questo cubetto gelato tagliato nel ghiaccio del Lago ghiacciato di Frigost. Per scoprire di cosa si tratta hai due scelte: o aspetti che si sciolga, o, come tutti gli impazienti, lo colpisci piano perchè si rompa.",ep:0,g:21,l:50,wd:false,fm:true,w:1,u:true,p:500};
I.u[11135] = {n:"Coda di Pappabuk leggendario",t:65,d:"Questa piccola coda pelosa leggendaria era ben nascosta sotto la spessa lana del Pappabuk leggendario. La cosa non ti ha impedito di trovarla e prendergliela.",ep:0,g:752,l:118,wd:false,fm:true,w:10,p:1};
I.u[11136] = {n:"Lana di Pappabuk leggendario",t:57,d:"E\' sporca, ma leggendaria. Ti ricorda qualcuno...",ep:0,g:212,l:118,wd:false,fm:true,w:10,p:1};
I.u[11137] = {n:"Pezzo di Ratto Stordito slavato",t:24,d:"E\' tutto quel che rimane dei ratti storditi della caverna del Nonno. Ci sei andato pesante, eh?",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11138] = {n:"Seme di Pisello",t:24,d:"No, non è un cervello di Pappabuk quello che tieni fra le mani, ma un piccolo Seme di Pisello. La differenza è abbastanza evidente: il seme è freddo al tatto.",ep:0,g:828,l:1,wd:false,fm:true,w:0,p:1};
I.u[11139] = {n:"Seme di Farro",t:24,d:"Ecco la versione arcaica dei semi di grano utilizzati una volta su Amakna. Chiunque penserebbe che il tempo si sia fermato su Frigost.",ep:0,g:829,l:1,wd:false,fm:true,w:0,p:1};
I.u[11140] = {n:"Seme di Granola",t:24,d:"Un avolta utilizzato nella farina per i biscotti, la coltivazione di questo cereale è stata vietata dopo una stupida scommessa. Il precedente sindaco di Frigost aveva scommesso con un Ecaflip che avrebbe mangiato solo un biscotto fatto con la farina di Granola. Perse la scommessa e la sua fortuna.",ep:0,g:830,l:1,wd:false,fm:true,w:0,p:1};
I.u[11141] = {n:"Seme di Pigna",t:24,d:"Questo seme proviene da una Pigna giunta a maturità.",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11142] = {n:"Seme di Lenticchia",t:24,d:"Applicando uno di questi semi su ciascuno dei tuoi occhi non vedrai meglio. In compenso avrai l\'aria ancora più stupida del solito agli occhi di chiunque ti veda.",ep:0,g:832,l:1,wd:false,fm:true,w:0,p:1};
I.u[11143] = {n:"Granelli di Sale",t:24,d:"Lo Sparo non ha molto sale in zucca, ed è per questo che è finito in un barile. Non dire che non ti avevamo avvisato.",ep:0,g:833,l:1,wd:false,fm:true,w:0,p:1};
I.u[11144] = {n:"Gran Ata",t:24,d:"Tira il picciolo, conta fino a due e lancia lontano. Se la Gran Ata tocca un F20 lascerà esplodere la sua collera. E\' così che i giovani miliziani si allenano nel lancio della Gran Ata.",ep:0,g:834,l:1,wd:false,fm:true,w:0,p:1};
I.u[11145] = {n:"Gran Oy",t:24,d:"Questo seme è utilizzato soprattutto dai giovani dei bassi fondi per aggredire la gente civilizzata. Ti chiedi come sia possibile? Meglio se non lo sai, dico davvero.",ep:0,g:835,l:1,wd:false,fm:true,w:0,p:1};
I.u[11146] = {n:"Granello di Basalto",t:24,d:"Questo granello è sopravvissuto ad un riscaldamento seguito da un raffreddamento estremo, a causa di questo ora è fragile e debole.",ep:0,g:836,l:1,wd:false,fm:true,w:0,p:1};
I.u[11147] = {n:"Grano Chia",t:24,d:"Questo grano possiede un alto contenuto di carbone e gracida nelle notti di luna piena. Bisogna essere un vero idiota, o uno Yop, per credere a una cosa simile.",ep:0,g:837,l:1,wd:false,fm:true,w:0,p:1};
I.u[11148] = {n:"Grano Demoniaco",t:24,d:"Una vecchia leggenda racconta che la farina ricavata da questo grano era usata per la fabbricazione del pane per i panini alla carne di demone, piatto preferito del Signore Demone Rushu. Ancora oggi i Frigostiani diffidano dall\'usarla.",ep:0,g:838,l:1,wd:false,fm:true,w:0,p:1};
I.u[11149] = {n:"Grano di Stella",t:24,d:"Se anche tu vuoi assomigliare a Piochetta la Truccata, questo seme è fatto per te. Grazie ad esso potrai dimenarti e sbraitare sotto agli applausi. Attenzione però, i suoi effetti sono molto effimeri.",ep:0,g:839,l:1,wd:false,fm:true,w:0,p:1};
I.u[11150] = {n:"null",t:24,d:"",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
