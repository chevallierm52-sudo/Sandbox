I.u[11190] = {n:"Regalo Amuleto dello YeCh\'Ti",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te. Attenzione, questo regalo può essere aperto solo su DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11191] = {n:"Stivali del Pulitore di Dongioni",t:11,d:"Le suole sono consumate, ma molto confortevoli. Hanno ripulito il suolo di molti dongioni pericolosi, così come la testa di alcuni mostri rognosi.",ep:0,g:162,l:73,wd:true,fm:true,w:10,an:0,p:13700};
I.u[11192] = {n:"Regalo Pulitore di Dongioni",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te. Attenzione, questo regalo può essere aperto solo su DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11193] = {n:"Tavola di Pioppo Tremulo",t:95,d:"Questa tavola consente ai Tuttofare di costruire degli oggetti di legno, come una bara per esempio...",ep:0,g:23,l:100,wd:false,fm:true,w:10,p:10};
I.u[11194] = {n:"Farina di Frostiss",t:52,d:"Questa farina ha la caratteristica di dissolversi nel lalatte e di donargli un gusto cioccolatoso. Gli abitanti di un\'isola scomparsa, adepti dei dessert a base di gelatina, preferivano scioglierla nell\'acqua.",ep:0,g:260,l:100,wd:false,fm:true,w:1,p:1};
I.u[11195] = {n:"La Ros Olia",t:30,d:"Devi farti curare prima che il tuo stato si aggravi.",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11196] = {n:"Kama di ghiaccio",t:24,d:"Non potendo creare nuova moneta di metallo, i Frigostiani hanno tagliato dei kama dal ghiaccio e li utilizzano per scambiarli con diversi oggetti del luogo.\nNon hanno valore fuori dall\'isola.",ep:0,g:825,l:1,wd:false,fm:true,w:0,p:1};
I.u[11197] = {n:"La Zinuzite",t:30,d:"La campagna di vaccinazione contro questa malattia è già costata al Borgo di Frigost la modica cifra di 2 miliardi di kama, e non ha avuto alcun risultato significativo. C\'è da credere che ai Frigostiani piaccia gettare il denaro dalla finestra...",ep:0,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11198] = {n:"Vaccino contro la Ros Olia",t:24,d:"Questo vaccino protegge efficacemente contro la Ros Olia, ma i suoi effetti spariscono in fretta. Bisogna quindi rinnovarlo tutte le settimane.",ep:0,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[11199] = {n:"Seme di Frostiss",t:58,d:"Questo seme, freddo al tatto, spande nell\'aria un forte profumo di cacao.",ep:0,g:0,l:100,wd:false,fm:true,w:1,p:1};
I.u[11200] = {n:"Ricevuta del Capo Tosto",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[11201] = {n:"Campioncino di sangue di Pappabuk",t:24,d:"Questo campioncino di sangue è stato prelevato da un Pappabuk malato di Ros Olia.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11202] = {n:"Acqua di mare isotonica",t:24,d:"Albert Pes ha bisogno di quest\'acqua per le sue ricerche sul vaccino contro la Ros Olia.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[11203] = {n:"Artemisia",t:24,d:"Quest\'erba cattiva è molto stimata dagli Alchimisti, dagli Aniripsa e dagli Alchimisti Aniripsa. Una pianta analoga a questa serve per il confezionamento di un potente liquore molto apprezzato dai marinai, dagli Anutrof, e dagli Anutrof marinai.",ep:0,g:103,l:1,wd:false,fm:true,w:0,p:1};
I.u[11204] = {n:"Campioncino di sangue de La Bestia",t:24,d:"Hai prelevato questo campioncino di sangue non senza fatica. Speriamo che la sua utilità valga gli sforzi che hai fatto per ottenerlo..",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11205] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dall\' 01.00 alle 04.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11206] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 04.00 alle 07.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11207] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 07.00 alle 10.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11208] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 10.00 alle 13.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11209] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 13.00 alle 16.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11210] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 16.00 alle 19.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11211] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 19.00 alle 22.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11212] = {n:"Orario dell\'appuntamento",t:24,d:"Hai un appuntamento con Capitan Ciuk alla taverna dalle 22.00 all\' 01.00.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11213] = {n:"Zecche di Pappabuk",t:24,d:"Più resistenti delle mutande in kriptonite del Capitano Chafer e più aggressive di un esercito di cacciatori astrubiani, queste zecche sono un vero flagello per chi le ospita.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[11214] = {n:"Sangue di Pappabuk parassitato",t:24,d:"Questo campioncino di sangue è stato prelevato da un Pappabuk parassitato dalle zecche.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11215] = {n:"Sangue di Pappabuk di guerra parassitato",t:24,d:"Questo campioncino di sangue è stato prelevato da un Pappabuk di guerra parassitato dalle zecche.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11216] = {n:"Sangue di Pappabuk leggendario parassitato",t:24,d:"Questo campioncino di sangue è stato prelevato da un Pappabuk leggendario parassitato dalle zecche.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11217] = {n:"Sangue di Pappatonbuk parassitato",t:24,d:"Questo campioncino di sangue è stato prelevato da un Pappatonbuk parassitato dalle zecche.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11218] = {n:"Busta per Otomai",t:24,d:"Wogew l\'Ewemita ti ha incaricato di portare questa busta a Otomai. Contiene diversi documenti utili sulle zecche che parassitano i pappabuk e anche i wabbit.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[11219] = {n:"Coda di Realbuk",t:65,d:"In estate questa coda permette al Realbuk di far fuggire i moskito. La restante parte dell\'anno non gli serve a nulla, e lui si dimentica di averla.",ep:0,g:755,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11221] = {n:"Lana di Realbuk",t:57,d:"Nessuno sa realmente quando i Pappabuk sono arrivati su Frigost. Quel che è certo è che sono là da molto tempo, dato che ci sono indumenti intimi fabbricati con questa lana che sono stati utilizzati da molte generazioni di Frigostiani",ep:0,g:213,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11222] = {n:"Becco di Tipinguinotto",t:47,d:"Quando non è fermamente attaccato alla testa del Tipinguinotto, questo becco è fermamente piantato nelle tue chiappe.",ep:0,g:662,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11223] = {n:"Piuma di Tipinguinotto",t:53,d:"I Tipinguinotti andavano sull\'isola di Frigost solo qualche giorno l\'anno, ma da quando è ghiacciata hanno deciso di restare. Ecco una buona occasione per rubare le loro piume durante l\'arco dell\'anno.",ep:0,g:646,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11224] = {n:"Ala di Pinguinobesotto",t:104,d:"I Frigostiani si sono spesso chiesti a cosa potessero servire  queste ali così ridicole che non permettono al Pinguinobesotto nemmeno di sperare di decollare.",ep:0,g:216,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11225] = {n:"Pelle di Pinguinobesotto",t:59,d:"E\' molto grassa, raramente lavata, e brilla. Non è il tuo parrucchino, ma la pelle del Pinguinobesotto.",ep:0,g:49,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11226] = {n:"Olio di Mamanguinotta",t:60,d:"Questo olio è estratto da una Mamanguinotta. Cerchi disperatamente di non ricordarti come l\'hai ottenuto...",ep:0,g:72,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11227] = {n:"Peluria di Mamanguinotta",t:54,d:"Su Frigost tutti adorano imbottire i propri indumenti intimi con questa peluria. Alcuni dicono che sia per ripararsi dal freddo. Solo gli Yop ci credono.",ep:0,g:675,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11228] = {n:"Lisca gigante di Shamanguinotto",t:47,d:"Su Frigost molte domande non hanno risposta e molte risposte non hanno domande, cosa che è molto più inquietante. Non saprai mai dove lo Shamanguinotto ha trovato questa lisca gigante.",ep:0,g:663,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11229] = {n:"Pelo di barba di Shamanguinotto",t:54,d:"La barba di Shamanguinotto odora di pesce e muschio di capra. Questo delizioso miscuglio è utilizzato dai Frigostiani coraggiosi come profumo repellente contro i Pappabuk e gli amici.",ep:0,g:674,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11230] = {n:"Coda di Fu Pinguinotto",t:65,d:"Non ti fidare della sua piccola misura, trova sempre la sua strada.",ep:0,g:753,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11231] = {n:"Orecchio di Fu Pinguinotto",t:106,d:"Generalmente nascoste da un pesce in decomposizione, le orecchie del Fu Pinguinotto non sentono altro che le chiamate delle partner disponibili nei periodi di riproduzione. Puoi quindi prendere in giro i Fu Pinguinotti senza pericolo... Almeno fino a che non assomigli ad una potenziale partner.",ep:0,g:625,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11232] = {n:"Piuma di Pinguinotto Reale",t:53,d:"Il Pinguinotto Reale è molto rispettato dai Frigostiani, che vedono in lui una bestiola con un titolo importante e una occasione per uccidere qualcosa di importante.",ep:0,g:647,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11233] = {n:"Uovo di Pinguinotto Reale",t:105,d:"Inutile fingere sorpresa, questo enorme uovo è ben uscito da qualche parte.",ep:0,g:643,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11234] = {n:"Richard Ritz",t:32,d:"Uno dei superstiti nella Foresta dei Pini Dorati, è da scortare da Capo Tosto.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11235] = {n:"Storm Siù",t:32,d:"Una dei superstiti nella Foresta dei Pini Dorati, è da scortare da Capo Tosto.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11236] = {n:"Storm Gionì",t:32,d:"Uno dei superstiti nella Foresta dei Pini Dorati, è da scortare da Capo Tosto.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11237] = {n:"Bengrime",t:32,d:"Uno dei superstiti nella Foresta dei Pini Dorati, è da scortare da Capo Tosto.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11238] = {n:"Coda di Scoiattobuk",t:65,d:"La Scoiattobuk si serve della sua coda per conservare l\'equilibrio quando si muove rotolando sulla sua ghianda. Questo animale sembra immunizzato contro il ridicolo.",ep:0,g:754,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11239] = {n:"Ghianda di Scoiattobuk",t:58,d:"Lo Scoiattobuk passa i primi anni della sua vita a cercare le migliori ghiande possibili. Passa la restante parte della sua vita a ricordarsi dove le ha nascoste.",ep:0,g:68,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11240] = {n:"Dente di Saberbuk",t:47,d:"Studi scientifici seri ed approfonditi hanno dimostrato che i denti di Saberbuk sono la prima causa di perforazione dei posteriori fra i Frigostiani.",ep:0,g:664,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11241] = {n:"Pelo di Saberbuk",t:54,d:"I peli del Saberbuk erano una volta usati per fabbricare le trapunte. Alcuni Frigostiani amavano avere una buona scusa per giustificare il loro odore di belva, al risveglio.",ep:0,g:676,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11242] = {n:"Zanna di Ghiaccinghiale",t:47,d:"Ha l\'odore di un paio di mutande, ma non delle tue.",ep:0,g:665,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11243] = {n:"Cuoio di Ghiaccinghiale",t:56,d:"Questo cuoio arrotonda gli angoli della silhouette del Freddocero per mettere in mostra le sue rotondità.",ep:0,g:16,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11244] = {n:"Messaggio di Gerard",t:24,d:"Ho seguito una Mamanguinotta e mi ha condotto nella sua caverna, dove si nascondono altre centinaia di Mamanguinotte. E\' un\'opportunità da non perdere. Entrerò e sparerò a tutto quel che si muove, farò abbastanza carne per i prossimi decenni.\nGerard.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[11245] = {n:"Gioielli di famiglia di Gerard",t:24,d:"Al contrario di quelli del Muulupo, questi gioielli di famiglia non hanno alcun valore ne utilità.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11246] = {n:"Occhio torvo di Freddocero",t:109,d:"Prima di raggiungere il santuario dei freddoceri morti in combattimento, l\'animale che ha tentato di ucciderti ti ha lanciato un ultimo sguardo da ghiacciare il sangue. Come se su Frigost non facesse già abbastanza freddo...",ep:0,g:591,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11247] = {n:"Orecchio bucato di Freddocero",t:106,d:"Le orecchie del Freddocero sono tutte bucate. E\' a causa della loro passione per gli orecchini o dei canti di Claudius Baglionus che potevano essere sentiti addirittura fino a Frigost?",ep:0,g:626,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11248] = {n:"Orecchio di Kanigloo",t:106,d:"Questo orecchio ti ricorda una delle più celebri canzoni fra i giovani Frigostiani: \"Kanigloo gloo gloo, Glutovora vora vora, tarata zum zum\". Non sarà un granchè, ma almeno è abbastanza corta da essere imparata a memoria da uno Yop.",ep:0,g:627,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11249] = {n:"Stoffa di Kanigloo",t:55,d:"Questa stoffa ti ricorda la seconda strofa diuna delle canzoni più popolari presso i giovani Frigostiani: \"Freddocero cero cero...\". Sfortunatamente hai dimenticato come continua...",ep:0,g:730,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11250] = {n:"Pelo di Maomao Selvaggio",t:54,d:"Quando erano ancora vivi, gli oppositori politici del Sindaco di Frigost spiegavano a chi li voleva ascoltare che la Sindaco utilizzava lingerie in pelo di Maomao Selvaggio.",ep:0,g:677,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11251] = {n:"Sterno di Maomao Selvaggio",t:47,d:"Tutti si chiedono cosa sia possibile fare con uno sterno di Maomao Selvaggio. Un Maomao Selvaggio impagliato magari.",ep:0,g:666,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11252] = {n:"Zampa di Ratto Stordito",t:103,d:"I giovani scolari di Frigost hanno un gioco che si chiama \"Maocaccia\" che consiste nel tagliare la zampa ad un Ratto Stordito ed utilizzarla per simulare tracce di passi nella neve. Le tracce attirano i Maomao dei Ghiacci, in cerca di prede, verso un\'imboscata. Una volta catturato il Maomao, lo appallottolano e lo trasformano in scaldamani. I bambini sono formidabili.",ep:0,g:36,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11253] = {n:"Stoffa di Ratto Stordito",t:55,d:"Prima della glaciazione di Frigost, i Ratti Storditi venivano cacciati per le loro stoffe di pelo che venivano in seguito esportate sul continente di Amakna e vendute col nome di \"Pelle di Kitsù esotico\".",ep:0,g:731,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11254] = {n:"Chela di Granchiaccio",t:47,d:"I Granchiacci sono cacciati dai pescatori di Frigost per due ragioni: il loro pessimo carattere e la loro tendenza a fare scherzi ai pescatori tagliando i fili da pesca. I pescatori si vendicano facendo a loro volta degli scherzi ai granchi tagliando le loro chele.",ep:0,g:668,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11255] = {n:"Occhio di Granchiaccio",t:109,d:"Quest\'occhio contiene un liquido trasparente, utilizzato nelle ricette di cucina ancestrale frigostiana, che permette di rimpiazzare l\'aceto. Questo accade solo se lasci fermentare l\'occhio abbastanza a lungo.",ep:0,g:592,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11256] = {n:"Becco di Gellicano",t:47,d:"Il Gellicano è una creatura piuttosto stupida e maleducata, si può trovare il suo guano ovunque al porto di Frigost e ha la tendenza a rubare il pesce ai pescatori. Se ben allenata è capace di rubare e nascondere nel suo becco gli effetti personali dei turisti distratti.",ep:0,g:667,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11257] = {n:"Piuma di Gellicano",t:53,d:"Queste piume sono molto utilizzate dagli scolari di Frigost per scrivere. Le mamme Gellicane spiegano quindi sempre ai loro figli che devono accelerare, quando passano davanti ad una scuola.",ep:0,g:648,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11258] = {n:"Ricevuta di Capo Tosto",t:24,d:"La data di ricevimento dei pini è scritta su questa ricevuta. Mostrala a Gormor il Mutilante per avere la tua paga.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[11259] = {n:"Tronchi di Pino",t:24,d:"Il Capo Tosto ha bisogno di questi tronchi per alimentare il riscaldamento delle tubature.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11260] = {n:"Grasso di Pinguinotto",t:24,d:"Questo grasso, spesso e appiccicoso, è un eccellente combustibile che brucia molto, molto a lungo. Questo spiega perchè i Pinguinotti non hanno mai freddo.",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[11261] = {n:"Lista delle forniture di Damar",t:24,d:"Questa lista elenca i pezzi mancanti che servono ai pescatori del lago ghiacciato per riparare i loro materiali.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[11262] = {n:"Fede di Damar",t:24,d:"Fede promessa da Damar a Nelly Clerichetta trenta anni fa.",ep:0,g:27,l:1,wd:false,fm:true,w:0,p:1};
I.u[11263] = {n:"Fata d\'Artificio Izterica",t:74,d:"Questa fata d\'artificio produce un gradevole effetto pirotecnico per qualche secondo, e ti brucia la retina per la restante parte della tua vita.",ep:0,g:0,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[11264] = {n:"Pelle dilaniata di Pinguinotto",t:24,d:"Questa pelle di Pinguinotto è in un pessimo stato. E\' impossibile usarla per fabbricare i nuovi indumenti intimi per la festa del Capitano Chafer.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11265] = {n:"Pinguinobesotto addomesticato",t:32,d:"Questo Pinguinobesotto è stato addestrato appositamente per ingurgitare enormi quantità di Pescetti lasciandoli intatti. C\'è un solo inconveniente: la sua digestione comincia dopo 30 minuti.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11266] = {n:"Cervello di Pinguinobesotto addomesticato",t:24,d:"Mentre tu combattevi, il tuo Pinguinobesotto è stato divorato. Questo è tutto quello che ti rimane di lui.",ep:0,g:89,l:1,wd:false,fm:true,w:0,p:1};
I.u[11267] = {n:"Buono sconto",t:24,d:"Questo buono sconto sarà valido per l\'affitto di una stanza nel futuro hotel di ghiaccio.",ep:0,g:72,l:1,wd:false,fm:true,w:0,p:1};
I.u[11268] = {n:"Vecchio peluche Feca",t:24,d:"Questo vecchio peluche dovrà pur appartenere a qualcuno... Si, ma a chi?\nDoppio-clic per utilizzarlo.",ep:0,g:680,l:1,wd:false,fm:true,w:0,c:"Qc=599",u:true,p:1};
I.u[11269] = {n:"Gomma da masticare",t:24,d:"Questa gomma da masticare non ti è di nessuna utilità, dato che il tuo alito è troppo pesante. Lo Xelor Mac Ghiacciver, invece, ne farà un uso insospettabile.",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=600",u:true,p:1};
I.u[11270] = {n:"Scrigno di famiglia",t:24,d:"Questo scrigno contiene numerosi gioielli di famiglia. Se non conosci un ricettatore puoi cercare di ottenere una ricompensa dal suo proprietario.\nDoppio-clic per utilizzarlo.",ep:0,g:44,l:1,wd:false,fm:true,w:0,c:"Qc=601",u:true,p:1};
I.u[11271] = {n:"Libro sigillato",t:24,d:"Questo libro sigillato è in pessimo stato. Forzarne l\'apertura potrebbe renderlo inutilizzabile. Farai meglio ad affidarlo ad un professionista, ma a chi?\nDoppio-clic per utilizzarlo.",ep:0,g:95,l:1,wd:false,fm:true,w:0,c:"Qc=602",u:true,p:1};
I.u[11272] = {n:"null",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=603",u:true,p:1};
I.u[11273] = {n:"null",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=604",u:true,p:1};
I.u[11274] = {n:"null",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=605",u:true,p:1};
I.u[11275] = {n:"null",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=606",u:true,p:1};
I.u[11276] = {n:"null",t:24,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,c:"Qc=607",u:true,p:1};
I.u[11277] = {n:"Tipinguinotto furfante",t:32,d:"Questo Tipinguinotto non ama essere adottato, e scapperà alla prima occasione. Nel frattempo puoi mostrarlo ai tuoi amici perchè lo maltrattino.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11278] = {n:"Scoiattobuk",t:30,d:"Hai sconfitto uno Scoiattobuk che ha sfortunatamente deciso di seguirti dappertutto. Potrai verificare tu stesso che la sua sfortuna non è solo una leggenda.",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11279] = {n:"Sega da ghiaccio",t:15,d:"Questa sega serve per tagliare i blocchi di ghiaccio. Taglia anche bene le membra gelate da amputare.",ep:0,g:0,l:100,wd:false,fm:false,w:5,an:0,p:1};
I.u[11280] = {n:"Placca d\'acciaio",t:40,d:"Questa placca di acciaio è molto popolare fra i Frigostiani che la usano per fabbricare macchine e tubi in acciaio.",ep:0,g:0,l:100,wd:false,fm:true,w:50,an:0,p:1};
I.u[11281] = {n:"Maschera di protezione",t:15,d:"Questa maschera è utilizzata dagli operai per proteggere il loro viso quando fanno lavori pericolosi. Protegge bene anche dagli schiaffi e dai piatti, se hai di nuovo dimenticato il compleanno della tua amata.",ep:0,g:0,l:100,wd:false,fm:true,w:5,an:0,p:1};
I.u[11282] = {n:"Guanti di protezione",t:15,d:"Questi guanti proteggono gli oggetti dalle tue mani sporche. Alcuni Etram li usano per proteggere la loro identità nascondendo le loro impronte digitali.",ep:0,g:0,l:100,wd:false,fm:true,w:2,an:0,p:1};
I.u[11283] = {n:"Ricetta della Sega da ghiaccio",t:24,d:"Un Forgiatore di Spade può creare una Sega da ghiaccio con:\n-2 * Cuoio di Freddocero\n-1 * Olio di Mamanguinotta\n-2 * Piuma di Gellicano\n-1 * Becco di Tipinguinotto\n-1 * Kriptonite\n-1 * Legno di Pioppo Tremulo\n-5 * Lana di Pappabuk\n-10 * Pietra per Arrotare",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11284] = {n:"Ricetta della Placca d\'acciaio",t:24,d:"Un Minatore può fondere questa Placca con:\n-5 * Carbone\n-25 * Ferro\n-10 * Stagno\n-10 * Manganese\n-5 * Kobalite\n-1 * Alluminite\n-1 * Scherzo di Zolfo\n-1 * Madreperla",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11285] = {n:"Ricetta della Maschera di protezione",t:24,d:"Un Sarto può fabbricare questo cappello con:\n-5 * Peluria di Mamanguinotta\n-5 * Lana di Pappabuk leggendario\n-2 * Orecchia di Kanigloo\n-2 * Cuoio di Freddocero\n-2 * Becco di Tipinguinotto\n-1 * Carbone\n-5 * Ferro\n-5 * Stagno",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11286] = {n:"Ricetta dei Guanti di protezione",t:24,d:"Un Orefice può fabbricare questo anello con:\n-4 * Piuma di Tipinguinotto\n-2 * Ala di Pinguinobesotto\n-10 * Pelo di Barba di Shamanguinotto\n-10 * Pelo di Saberbuk\n-2 * Coda di Scoiattobuk\n-4 * Cuoio di Pappatonbuk\n-2 * Chela di Granchiaccio\n-10 * Pelo di Maomao Selvaggio",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11287] = {n:"Zobie la Mousse",t:32,d:"Devi scortarlo da Mac Ghiacciver",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:0,m:true,p:1};
I.u[11288] = {n:"Schema dell\'Abbeveratoio frigostiano in Carpine",t:24,d:"Questo schema indica come un Tuttofare può fabbricare un prototipo di abbeveratoio assemblando:\n-1 * Abbeveratoio in Carpine\n-2 * Orecchio del Fu Pinguinotto\n-10 * Peluria di Mamanguinotta\n-2 * Stoffa di Kanigloo\n-10 * Cuoio di Freddocero\n-2 * Occhio di Granchiaccio\n-10 * Stoffa di Ratto Stordito\n-2 * Occhio torvo di Freddocero",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11289] = {n:"Schema della Mangiatoia frigostiana in Carpine",t:24,d:"Questo schema indica come un Tuttofare può fabbricare un prototipo di mangiatoia assemblando:\n-1 * Mangiatoia in Carpine\n-2 *Olio di Mamanguinotta\n-10 * Pelo di Barba di Shamanguinotto\n-2 * Ghianda di Scoiattobuk\n-10 * Orecchio bucate di Freddocero\n-2 * Becco di Gellicano\n-10 * Chela di Granchiaccio\n-10 * Pelo di Saberbuk",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11290] = {n:"Schema del Folgoratore frigostiano in Carpine",t:24,d:"Questo schema indica come un Tuttofare può fabbricare un prototipo di folgoratore assemblando:\n-1 * Folgoratore in Carpine\n-2 * Lisca giganti del Shamanguinotto\n-10 * Piuma di Tipinguinotto\n-2 * Zanna di Freddocero\n-10 * Orecchio di Kanigloo\n-2 * Sterno di Maomao Selvaggio\n-10 * Piuma di Gellicano\n-2 * Becco di Tipinguinotto",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
I.u[11291] = {n:"Schema dello Schiaffeggiatore frigostiano in Carpine",t:24,d:"Questo schema indica come un Tuttofare può fabbricare un prototipo di schiaffeggiatore assemblando:\n-1 * Schiaffeggiatore in Carpine\n-2 * Ala di Pinguinobesotto\n-10 * Coda di Fu Pinguinotto\n-2 * Dente di Saberbuk\n-10 * Coda di Scoiattobuk\n-2 * Zampa di Ratto Stordito\n-10 * Pelo di Maomao Selvaggio\n-10 * Pelle di Pinguinobesotto",ep:0,g:74,l:1,wd:false,fm:true,w:0,an:0,p:1};
