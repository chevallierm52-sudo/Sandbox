I.u[10978] = {n:"Stivali di Phong Huss",t:11,d:"I piedi dei fung non sono mai puliti, ma sempre coperti di micosi. Quelli di Phong Huss non erano da meno, e quindi lui li nascondeva con questi stivali. Non hanno un buon odore, ma sono particolarmente adatti alla coltivazione dei fung. Chi se ne preoccuperà, il tuo naso, o il tuo stomaco?",ep:0,g:153,l:32,wd:false,fm:true,w:10,s:157,p:2900};
I.u[10979] = {n:"Martello di Ectop",t:7,d:"Ectop provava un piacere maligno nel trascinarsi dietro quest\'arma. Tutti sapevano che fosse scansafatiche quanto un Pappatutto, ma voleva avvisare i suoi nemici del suo arrivo rumoroso. Quest\'arma è ancora impregnata della sua magia, magari riuscirai ad incarnarti in Ectop, se la equipaggi.",ep:0,g:74,l:30,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,50,50,false,false],c:"CA>50",s:158,p:2800};
I.u[10980] = {n:"Amuleto di Ectop",t:1,d:"L\'amuleto di questo fantasma non può essere altro che un oggetto magico estremamente potente, se si crede alle leggende sui fantasmi.",ep:0,g:159,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10981] = {n:"Anello di Ectop",t:9,d:"Si sa, i veri fantasmi non hanno dita. E allora come lo spieghi che possono portare gli anelli?",ep:0,g:186,l:32,wd:false,fm:true,w:10,s:158,p:2970};
I.u[10982] = {n:"Cintura di Ectop",t:10,d:"Il Capitano Kradoc incontrò Ectop una sera, mentre usciva ubriaco dalla taverna del Ripata. \"Ectoplasma su ruote!\" esclamò urlando. Povero Capitano Kradoc, l\'alcool gli giocò proprio un brutto scherzo, Ectop non ha mai avuto le ruote...",ep:0,g:171,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10984] = {n:"Amuleto dello YeCh\'Ti",t:1,d:"Con questo amuleto posato sul tuo torso imberbe potrai far credere ai tuoi nemici che sei peloso tanto quanto lo YeCh\'Ti, e questo li farà spaventare di sicuro.",ep:0,g:162,l:66,wd:false,fm:false,w:10,an:0,p:11500};
I.u[10985] = {n:"Maomao dei Ghiacci",t:18,d:"Questo Maomao ha conosciuto l\'inverno del grande nord, anche se non ha mai visto il grande nord... Nessuno sa come sia arrivato ad Amakna, i vecchi dicono che sia stato importato dall\'isola di Frigost per lottare contro la proliferazione dei Wabbit. Questo famiglio divoratore di anime non mangia che Wabbit.",ep:0,g:62,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10986] = {n:"Fantasma di Maomao dei Ghiacci",t:90,d:"Questo Fantasma non ha ancora abbandonato il mondo dei vivi, sta a te trovare un modo per resuscitarlo oppure abbandonarlo vigliaccamente una buona volta per tutte.",ep:0,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[10987] = {n:"Ghiacciantura",t:10,d:"Raffredda le anche, gli organi situati in prossimità e anche gli ardori di coloro che osano portarla. Da offrire ai cortigiani un po\' troppo ostinati.",ep:0,g:173,l:35,wd:false,fm:true,w:10,s:141,p:3500};
I.u[10988] = {n:"Ghiaccielmo",t:16,d:"Per tenere la testa fredda e le idee al fresco, questo elmo è l\'ideale. Per somigliare a qualcosa che non sia un normale ghiacciolo dovrai trovare altro.",ep:0,g:260,l:35,wd:false,fm:true,w:10,s:141,p:3450};
I.u[10989] = {n:"Ghiacciantello",t:17,d:"Claudius Baglionus portava un mantello simile durante il suo famoso concerto alla radura di Bruce Bulgur. Quelli che non divennero sordi quel giorno si ricordano ancora dell\'apoteosi del concerto, quando Baglionus smise di cantare dopo essere stato congelato dal proprio mantello.",ep:0,g:175,l:33,wd:false,fm:true,w:10,s:141,p:3150};
I.u[10990] = {n:"Ghiacciostivali",t:11,d:"Pesanti e rigidi, questi stivali non sembrano particolarmente interessanti. La loro suola di ghiaccio, però, ti permetterà di pattinare sul ghiaccio senza ghiaccio. Sempre se riesci a trovare una superficie ricoperta da lame di pattini da ghiaccio...",ep:0,g:159,l:33,wd:false,fm:true,w:10,s:141,p:3000};
I.u[10991] = {n:"Regalo Maomao dei Ghiacci",t:89,d:"Scuotendo vigorosamente questo regalo capisci che non è vuoto. Può darsi che, per una volta, gli dei non si siano presi gioco di te. Attenzione, questo regalo può essere aperto solo su DOFUS 2.0.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
