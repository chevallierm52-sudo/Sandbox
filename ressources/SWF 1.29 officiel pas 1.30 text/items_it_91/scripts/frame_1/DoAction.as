I.u[250] = {n:"Ares",t:8,d:"Metà ascia, metà pala, Ares fu una delle sette armi usate dal demone Kajlir per conquistare la Confraternita degli Anutrof collezionisti di Dofus Purpurei.",ep:9,g:9,l:72,wd:true,fm:true,w:50,an:16,e:[10,4,1,1,50,50,false,false],c:"CC>200",p:14000};
I.u[251] = {n:"Barba Grigia",t:8,d:"Barba Grigia era l\'arma preferita dal demone nano Effe Esse che terrorizzava numerosi villaggi attaccando di sorpresa senza gridare ne\' \"stazione\" ne\' \"treno\".",ep:1,g:11,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1250};
