I.u[264] = {n:"Piccolo Arco Fuorviante",t:2,d:"L\'arco fuorviante è un oggetto base, ma di grande utilità.",ep:1,g:3,l:14,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>14&CS>4",p:750};
I.u[265] = {n:"Arco Fuorviante",t:2,d:"L\'arco fuorviante è un oggetto base, ma di grande utilità.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>16&CS>6",p:900};
I.u[266] = {n:"Grande Arco Fuorviante",t:2,d:"L\'arco fuorviante è un oggetto base, ma di grande utilità.",ep:1,g:3,l:18,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>18&CS>8",p:1050};
I.u[267] = {n:"Potente Arco Fuorviante",t:2,d:"L\'arco fuorviante è un oggetto base, ma di grande utilità.",ep:1,g:3,l:19,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>19&CS>9",p:1200};
I.u[270] = {n:"Xaveur",t:2,d:"Lo Xaveur è un arco molto efficace. Apparteneva al grande Panettiere Xavier che, tra un\'infornata e l\'altra, partiva per distribuire il pane ai mostri che gli circondavano la panetteria.",ep:7,g:5,l:60,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,9,30,100,false,true],c:"CA>60&CV>15",p:9050};
I.u[271] = {n:"Il Martello dello Chafer",t:7,d:"Un\'arma bella, strana e affascinante che ti permetterà di combattere corpo a corpo come farebbe il migliore dei Chafer.",ep:1,g:9,l:21,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,40,30,false,false],c:"CS>10&CI>11",p:1350};
I.u[272] = {n:"Nomoon",t:2,d:"Questo arco è abbastanza potente da mandare una freccia sulla luna.",ep:7,g:9,l:28,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,12,30,50,false,true],c:"CA>28&CV>5",p:2350};
I.u[273] = {n:"La Corda di Yamato",t:2,d:"La Corda di Yamato ha fatto battere più di un cuore di mostro. È un\'arma molto fine capace di dirigere le sue frecce nei luoghi più nascosti.",ep:7,g:10,l:33,wd:true,fm:true,w:18,an:10,tw:true,e:[10,4,2,7,30,50,false,false],c:"CA>33&CS>10",p:3000};
I.u[274] = {n:"Pezzo di Puzzle dell\'Artiglio",t:51,d:"Un pezzo molto raro del tesoro del Dodge, uno dei più grandi Ecaflip di Amakna.",ep:1,g:267,l:12,wd:true,fm:true,w:1,p:100};
I.u[276] = {n:"Pezzo del Tesoro del Badul",t:15,d:"Un pezzo molto raro di un tesoro nascosto dal celebre Dodge, uno dei più grandi guerrieri Ecaflip di Amakna.",ep:1,g:268,l:12,wd:true,fm:true,w:1,p:100};
I.u[278] = {n:"Anello delle Rocce",t:9,d:"Questo anello, ornato di una pietra rara, deve il suo nome alle diverse pietre necessarie alla sua fabbricazione.",ep:1,g:4,l:15,wd:true,fm:true,w:4,p:800};
I.u[279] = {n:"La Lacrima del Pappatutto",t:1,d:"Secondo un illustre avventuriero, questo amuleto contiene una lacrima di Pappatutto dall\'odore e dalle proprietà paragonabili a quelle del decotto del cuoio di Pappatutto.",ep:1,g:7,l:2,wd:true,fm:true,w:5,p:200};
I.u[280] = {n:"Collana dell\'Arcobaleno",t:1,d:"Questa collana è molto ricercata dai collezionisti, potrai ricavarci un bel gruzzoletto.",ep:1,g:11,l:6,wd:true,fm:true,w:6,p:300};
I.u[281] = {n:"Mela",t:42,d:"Questa mela restituisce qualche punto vita perso.\nSe l\'appoggi sulla testa di un amico puoi usarla come bersaglio.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[282] = {n:"Fiala di Cura Superiore",t:12,d:"Questa fiala restituisce qualche Punto Vita perso.",ep:1,g:39,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[283] = {n:"Fiala di Cura",t:12,d:"Questa fiala restituisce qualche Punto Vita perso.",ep:1,g:3,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[284] = {n:"Sale",t:48,d:"Il sale è un minerale che ti permette di dare gusto alle pietanze.",ep:2,g:260,l:1,wd:true,fm:true,w:1,p:10};
I.u[285] = {n:"Farina di Grano",t:52,d:"La farina si ottiene macinando chicchi di grano, è molto utile per fare il pane, le crêpe, le gaufre e altri dolci deliziosi, ma è soprattutto utile per infarinare i tuoi nemici d\'infanzia.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[286] = {n:"Lievito da Panettiere",t:48,d:"È un ingrediente indispensabile per la fermentazione del pane.",ep:1,g:137,l:1,wd:true,fm:true,w:1,p:1};
I.u[287] = {n:"Seme di Sesamo",t:58,d:"Questo seme estremamente ricco di proteine permette di fare un pane delizioso. La coltivazione del sesamo è molto difficile ad Amakna, per questo i semi sono rari e molto cari.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[288] = {n:"Seme di Girasole Selvatico",t:58,d:"Questo seme ricco di proteine dà un sapore molto particolare al pane. Il solo modo di trovarne è uccidere un Girasole Selvatico o di comprarlo!",ep:1,g:6,l:12,wd:true,fm:true,w:1,p:10};
I.u[289] = {n:"Grano",t:34,d:"Fin dai tempi antichi il Grano è stato un ingrediente indispensabile nell\'alimentazione degli abitanti di Amakna e dei Tofu.",ep:1,g:9,l:1,wd:true,fm:true,w:2,p:0};
I.u[290] = {n:"Fungo",t:15,d:"Con o senza crema, i funghi sono sempre buonissimi. Il modo più semplice di procurarsene resta quello di uccidere un Fun Fung.",ep:1,g:1,l:5,wd:true,fm:true,w:1,p:10};
I.u[291] = {n:"Peli del Buulupo",t:54,d:"Questi peli non sono come gli altri peli. Hanno proprietà particolari che piacciono molto agli Alchimisti.",ep:1,g:8,l:70,wd:true,fm:true,w:1,p:1};
I.u[292] = {n:"Testicoli del Buulupo",t:15,d:"Questi enormi testicoli sono ricoperti di una strana peluria particolarmente calda e morbida. È quasi impossibile riuscire a recuperarli intatti dopo un combattimento contro un Buulupo, il che spiega il loro prezzo scandaloso.",ep:1,g:10,l:70,wd:true,fm:true,w:20,p:50};
I.u[293] = {n:"Piccola Pala del Croccaroc",t:8,d:"L\'unica cosa solida come un Croccaroc... è un Croccaroc. Ecco perché questa pala costruita per la caccia ai Croccaroc è fatta in Pietra di Croccaroc.",ep:1,g:7,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1200};
I.u[294] = {n:"Pala del Croccaroc",t:8,d:"L\'unica cosa solida come un Croccaroc... è un Croccaroc. Ecco perché questa pala costruita per la caccia ai Croccaroc è fatta in Pietra di Croccaroc.",ep:1,g:7,l:23,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>8&CC>15",p:1600};
I.u[295] = {n:"Grande Pala del Croccaroc",t:8,d:"L\'unica cosa solida come un Croccaroc... è un Croccaroc. Ecco perché questa pala costruita per la caccia ai Croccaroc è fatta in Pietra di Croccaroc.",ep:1,g:7,l:26,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>11&CC>15",p:2000};
I.u[296] = {n:"Potente Pala del Croccaroc",t:8,d:"L\'unica cosa solida come un Croccaroc... è un Croccaroc. Ecco perché questa pala costruita per la caccia ai Croccaroc è fatta in Pietra di Croccaroc.",ep:1,g:7,l:29,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>14&CC>15",p:2400};
I.u[297] = {n:"Stivali del Piccolo Pappatutto",t:11,d:"L\'odore di questi stivali, fatti in cuoio di Pappatutto, permette agli allevatori di avvicinarsi più facilmente ai Pappatutto per ucciderli.",ep:1,g:3,l:1,wd:true,fm:true,w:2,p:100};
I.u[298] = {n:"Sandali Tofeschi",t:11,d:"Questi sandali sono fatti con piume di Tofu bollito e la suola è di Becco di Tofu indistruttibile. Per ragioni ancora sconosciute, a volte rendono chi le porta un po\' deficiente... proprio come un Tofu.",ep:1,g:4,l:1,wd:true,fm:true,w:7,p:100};
I.u[299] = {n:"Stivali Marziali",t:11,d:"\"L\'attacco è la miglior difesa!\". Questi stivali antiaggressione ti permetteranno di sterminare un gruppo di aggressori senza alcuna difficoltà.",ep:1,g:8,l:24,wd:true,fm:true,w:30,p:1800};
I.u[300] = {n:"Seme di Papavero",t:58,d:"Questo seme conferisce delle virtù allucinogene al pane preferito dagli avventurieri che vogliono riposarsi dopo un combattimento difficile.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:1};
I.u[301] = {n:"Piume di Tofu",t:53,d:"Le piume di Tofu sono molto utili per fare imbottiture di diverso tipo. Ma soprattutto ricorda... un chilo di piume di Tofu pesa tanto quanto un chilo di piombo.",ep:1,g:14,l:4,wd:true,fm:true,w:1,p:10};
I.u[302] = {n:"Zucca",t:68,d:"Le zucche crescono nei campi, e sono poco più grosse dei testicoli di un Buulupo, ma almeno sono più buone.",ep:4,g:12,l:15,wd:true,fm:true,w:5,p:10};
I.u[303] = {n:"Legno di Frassino",t:38,d:"Il Legno di Frassino non è un legno di qualità ma è abbondante e cresce in fretta. Stai attento però a non tenerlo vicino al fuoco, si infiamma facilmente!",ep:1,g:17,l:1,wd:true,fm:true,w:5,p:0};
I.u[304] = {n:"Cuoio di Pappatutto",t:56,d:"Questo cuoio molto resistente è la principale risorsa dei conciatori che ne fanno stivali, cinture, e persino fruste. L\'unico inconveniente è che puzza del sudore di Pappatutto in calore... non è proprio il massimo per gli appuntamenti.",ep:1,g:16,l:9,wd:true,fm:true,w:2,p:1};
I.u[305] = {n:"Dente di Wabbit",t:47,d:"Consumati a furia di sgranocchiare cawote, i denti di Wabbit sono comunque molto utili nella fabbricazione di pozioni grazie alle loro proprietà rinvigorenti.",ep:8,g:13,l:20,wd:true,fm:true,w:1,p:1};
I.u[306] = {n:"Fiore di Dente di Leone Diabolico",t:35,d:"Se bollito e seccato correttamente, questo fiore perde le sue proprietà tossiche e può essere consumato come tisana, ma il Fiore di Dente di Leone Diabolico è usato soprattutto per divertire i giovani innamorati. Infatti, chi non ha mai soffiato su un Dente di Leone Diabolico per mandare sul collo dell\'essere amato questi magnifici semi, dolci come la carezza di una schiarita sulle foglie di un carpine ancora impregnato di rugiada? Forse gli Yop, che al posto di soffiare aspirano e muoiono soffocati dai semi tra atroci convulsioni.",ep:1,g:18,l:5,wd:true,fm:true,w:1,p:10};
I.u[307] = {n:"Ali di Moskito",t:104,d:"Queste ali molto fini hanno la peculiarità di favorire il pensiero delle persone che osano dire le cose. Il loro gusto è simile alle uova marce di Kwak, e per questo sono utilizzate soprattutto per le pozioni di saggezza.",ep:1,g:19,l:2,wd:true,fm:true,w:1,p:1};
I.u[308] = {n:"Guscio di Draguovo Bianco",t:111,d:"Questo guscio è quasi indistruttibile ma levigandolo per generazioni e generazioni, i migliori Orefici riescono a usarne le facoltà magiche per costruire amuleti dai poteri eccezionali.",ep:11,g:21,l:64,wd:true,fm:true,w:5,p:1};
I.u[309] = {n:"Petalo di Rosa Demoniaca",t:35,d:"Questi petali hanno virtù afrodisiache molto potenti, e sono quindi il regalo ideale per conquistare l\'essere amato. Evita di consumarli in infusione visto che in questo modo producono l\'effetto contrario.",ep:1,g:20,l:6,wd:true,fm:true,w:1,p:10};
I.u[310] = {n:"Osso dello Chafer",t:47,d:"Quest\'osso è quasi indistruttibile, ma al contatto con l\'acqua diventa molle e quindi più maneggevole per gli Alchimisti.",ep:1,g:15,l:34,wd:true,fm:true,w:5,p:1};
I.u[311] = {n:"Acqua",t:15,d:"L\'acqua è utile per diverse cose, e se bella torbida darà un gusto ancora più buono alla birra (attenzione: l\'acqua fango esplode).",ep:1,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[312] = {n:"Ferro",t:39,d:"Il ferro è molto utile ai Forgiatori e a coloro che lavorano i metalli... qualcuno lo utilizza anche per stirare.",ep:1,g:24,l:1,wd:true,fm:true,w:5,p:0};
I.u[313] = {n:"Oro",t:39,d:"L\'oro è un metallo raro e prezioso, le sue qualità intrinseche ne fanno un metallo di prima scelta per la costruzione di armi o di oggetti particolarmente potenti e esteticamente raffinati.",ep:1,g:22,l:80,wd:true,fm:true,w:5,p:0};
I.u[314] = {n:"null",t:57,d:"",ep:0,g:655,l:1,wd:true,fm:true,w:1,p:50};
I.u[315] = {n:"Diamante",t:50,d:"Tutti gli Orefici di Amakna vanno pazzi per questa pietra che richiede un\'eccellente destrezza per essere lavorata. Per averla bisogna spesso avventurarsi in miniere pericolose, ma per fortuna... un diamante è per sempre.",ep:1,g:25,l:50,wd:true,fm:true,w:10,p:5000};
I.u[316] = {n:"Smeraldo",t:50,d:"Con il suo verde intenso, questa magnifica pietra preziosa può facilmente trasformare un tonno in una principessa, senza l\'uso di nessuna magia segreta.",ep:1,g:23,l:50,wd:true,fm:true,w:10,p:5000};
I.u[317] = {n:"Bastone del Piccolo Tabi",t:4,d:"Originariamente questo bastone serviva agli allevatori di Amakna che volevano controllare più facilmente le loro greggi di Tabi. È così leggero che permette a chi lo usa di correre dietro ai Tabi disobbedienti senza stancarsi.",ep:7,g:6,l:30,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:2650};
I.u[318] = {n:"Bastone del Tabi",t:4,d:"Originariamente questo bastone serviva agli allevatori di Amakna che volevano controllare più facilmente le loro greggi di Tabi. È così leggero che permette a chi lo usa di correre dietro ai Tabi disobbedienti senza stancarsi.",ep:7,g:6,l:34,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:3200};
I.u[319] = {n:"Bastone del Grande Tabi",t:4,d:"All\'origine questo bastone serviva agli allevatori di Amakna che volevano controllare più facilmente le greggi di Tabi. È infatti così leggero da permettere a chi lo usa di correre dietro ai Tabi disobbedienti senza stancarsi.",ep:7,g:6,l:37,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>25",p:3750};
I.u[320] = {n:"Bastone del Potente Tabi",t:4,d:"Originariamente questo bastone serviva agli allevatori di Amakna che volevano controllare più facilmente le loro greggi di Tabi. È così leggero che permette a chi lo usa di correre dietro ai Tabi disobbedienti senza stancarsi.",ep:7,g:6,l:40,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>30",p:4300};
I.u[323] = {n:"Amuleto del Kam Assutra",t:1,d:"Questo amuleto conferisce capacità particolari a chi lo porta. Gli invade il corpo di un\'aura misteriosa che moltiplica le sue capacità fisiche.",ep:1,g:4,l:43,wd:true,fm:true,w:5,p:5000};
I.u[324] = {n:"Amuleto di Kroket",t:1,d:"Questo amuleto ha la capacità di diventare rosa nei giorni in cui il suo proprietario è di buon umore. Si dice anche che decuplichi le tue possibilità di trovare oggetti interessanti.",ep:1,g:7,l:6,wd:true,fm:true,w:5,p:300};
I.u[325] = {n:"Amuleto dell\'Etram",t:1,d:"Questo amuleto, fabbricato con piccoli crani da uno dei più grandi Orefici Etram, è un oggetto unico. Permette al suo proprietario di defilarsi più facilmente durante le situazioni pericolose.",ep:1,g:3,l:2,wd:true,fm:true,w:5,p:200};
I.u[326] = {n:"Amuleto Dimetarana",t:1,d:"Questo amuleto proviene dalle regioni nordiche e conferisce a chi lo porta la capacità di invocare più facilmente delle creature.",ep:1,g:2,l:33,wd:true,fm:true,w:4,p:3000};
I.u[327] = {n:"Lama del Cavaliere di Karne",t:6,d:"Questa lama inizialmente forgiata per i Cavalieri di Karne era troppo pesante per i deboli goblin. Resta comunque abbastanza leggera per un essere normale che può, così, colpire molto velocemente.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,50,20,false,false],c:"CS>32",p:900};
I.u[328] = {n:"Taj-Taj",t:6,d:"Questa doppia lama dalla forma stranissima serviva all\'origine a sfrondare gli alberi della foresta per poterci passare attraverso. I Taglialegna però si sono accorti in fretta che poteva essere usata come arma efficacissima per sterminare ogni forma di minaccia.",ep:1,g:4,l:18,wd:true,fm:true,w:28,an:14,e:[6,5,1,1,20,60,false,false],c:"CS>36",p:1050};
I.u[329] = {n:"Arco di Trionfo",t:2,d:"Come dice il nome, questo arco permette di vincere facilmente un combattimento. Un grande architetto Ocra privo di immaginazione ha persino usato il nome di questo arco per una delle sue opere.",ep:7,g:11,l:30,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,10,30,50,false,true],c:"CA>30&CC>5&CS>10",p:1950};
I.u[331] = {n:"Arco Baleno",t:2,d:"Questo è l\'arco più ricercato in tutta Amakna, si dice che nel punto in cui cadono le sue frecce si può trovare un tesoro. Stranamente, pare che sia efficace solo quando la pioggia e i raggi del sole si mischiano.",ep:7,g:16,l:22,wd:true,fm:true,w:19,an:10,tw:true,e:[10,5,2,11,30,50,false,true],c:"CA>22&CC>15",p:1500};
I.u[332] = {n:"Arco di Giovanna",t:2,d:"Giovanna era un po\' pazza, sentiva dei Tabi ruttare nella sua testa. Le è stato confiscato l\'arco per evitare che si ferisse e poi si è deciso di bruciarla viva per riscaldare l\'ambiente durante l\'inaugurazione della taverna.",ep:7,g:15,l:30,wd:true,fm:true,w:23,an:10,tw:true,e:[10,4,2,9,30,50,false,true],c:"CS>10&CA>30",p:2550};
I.u[333] = {n:"Bacchetta Delh-Pan",t:3,d:"Questa bacchetta all\'origine era destinata a essere mangiata, ma ora è un\'arma temutissima. Xavier il Panettiere, infatti, l\'ha dimenticata nel forno per 234 anni mentre stava distribuendo il pane ai mostri intorno alla sua panetteria.",ep:3,g:9,l:50,wd:true,fm:true,w:1,an:11,e:[5,3,3,5,50,50,false,true],c:"CW>40&CI>100",p:6650};
I.u[334] = {n:"Bacchetta di Liriel",t:3,d:"Questa bacchetta apparteneva all\'Aniripsa Liriel che morì tra atroci sofferenze per un\'overdose di fragole, e perse le ali in un rantolo di dolore terrificante. I collezionisti fanno di tutto per avere questa bacchetta considerata maledetta.",ep:7,g:5,l:20,wd:true,fm:true,w:13,an:11,e:[5,5,2,3,50,50,false,true],c:"CI>40",p:1300};
I.u[335] = {n:"Bastone del Bwork Mago",t:4,d:"Senza bastone, i Bwork Maghi sono inoffensivi come un Tofu senza becco. Questo la dice lunga sulla potenza del loro bastone.",ep:7,g:1,l:58,wd:true,fm:true,w:28,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>58&CA>20",p:8900};
I.u[336] = {n:"Bastone del Nonno Wabbit",t:4,d:"Questo bastone ha la capacità di fare crescere le Cawote... chissà a cosa può mai servire in combattimento.",ep:8,g:1,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",p:2900};
I.u[337] = {n:"Arco del Bwork Arciere",t:2,d:"È un arco molto semplice da usare, è stato concepito per adattarsi all\'intelligenza di un Bwork Arciere, il che vuol dire che potrebbe utilizzarlo anche un Tofu. In compenso per tenderlo ci vuole la forza di un Croccaroc.",ep:7,g:4,l:20,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>20&CA>20",p:1300};
I.u[338] = {n:"Lama del Piccolo Bwork",t:6,d:"Questa spada dall\'aspetto rudimentale è molto apprezzata dai Bwork più stupidi che non sanno usare un arco o un bastone. Alcuni confondono persino la lama con il manico, per l\'immensa gioia dei nemici.",ep:1,g:13,l:21,wd:true,fm:true,w:30,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>42",p:1400};
I.u[339] = {n:"Lama dello Chafer",t:6,d:"Questa lama apparteneva a Metzger il Macellaio, ed era stata forgiata per tagliare le ossa. Lo Chafer è però riuscito a rubargliela trasformandola in un\'arma temuta da tutti e che ha provocato più di un\'amputazione.",ep:1,g:5,l:27,wd:true,fm:true,w:20,an:14,e:[20,6,1,1,15,60,false,false],c:"CS>54&CC>10",p:2100};
I.u[340] = {n:"Ripulitrici",t:5,d:"Secondo la leggenda queste daghe permettono di rubare di tutto e e non importa cos\'altro, ma soprattutto non importa cosa a non importa chi, o qualcosa del genere... ma nessuno si ricorda più perfettamente della leggenda...",ep:1,g:9,l:12,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>12",p:600};
I.u[341] = {n:"Daghe Eurfol",t:5,d:"Queste daghe leggendarie sono dei veri pezzi da collezione per tutti gli Etram che si rispettino, sono talmente venerate che alcuni Etram si rifiutano di rubarle.",ep:7,g:10,l:46,wd:true,fm:true,w:10,an:13,e:[10,2,1,1,30,50,false,false],c:"CA>46",p:5600};
I.u[342] = {n:"Martello Becco",t:7,d:"Questo martello molto particolare è stato fabbricato con i becchi di Kwak, il che spiega perché becca così forte quando lo si prende in testa.",ep:5,g:12,l:18,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>12&CS>6",p:1100};
I.u[345] = {n:"Piccola Pala \'Nca",t:8,d:"Dopo una serata un po\' troppo alcolica finita in rissa, un Anutrof si è accorto che questa pala, all\'origine concepita per i lavori di costruzione, era un\'arma eccellente.",ep:1,g:8,l:25,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>5&CC>20",p:1900};
I.u[346] = {n:"Anello Rak",t:9,d:"Secondo certe leggende, questo anello protegge dalle intemperie chi lo porta. Ma questa capacità non è mai stata provata... infatti ad Amakna non piove mai.",ep:1,g:34,l:17,wd:true,fm:true,w:4,p:1000};
I.u[347] = {n:"Rizoma Dorata",t:8,d:"Questa pala da giardiniere è particolarmente efficace per tagliare le cattive erbe chiamate rizome. È inoltre un\'eccellente arma quando si tratta di tagliare altre cose...",ep:1,g:10,l:40,wd:true,fm:true,w:30,an:16,e:[10,4,1,1,50,50,false,false],c:"CS>10&CC>30",p:4400};
I.u[348] = {n:"Stivali di Celeri-Thà",t:11,d:"Questi stivali appartenevano a una cuoca che era sempre di corsa, e che andava a cercare il sedano e il té a tutta velocità attraverso la campagna di Amakna.",ep:2,g:5,l:53,wd:true,fm:true,w:20,p:6700};
I.u[350] = {n:"Argento",t:39,d:"L\'Argento è un metallo brillante molto apprezzato dagli Orefici. Non ha però nessun effetto contro i vampiri, anche se qualcuno afferma il contrario.",ep:1,g:28,l:60,wd:true,fm:true,w:5,p:0};
I.u[351] = {n:"Birra di Amakna",t:37,d:"Questa birra ti farà recuperare punti vita. E come dice un vecchio proverbio paterno: \"È meglio avere la birra nel corpo che il corpo nella birra\".",ep:2,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[352] = {n:"Piccola Spada Sacra",t:6,d:"Una spada santa distribuita ai giovani guerrieri durante il loro addestramento.",ep:1,g:1,l:13,wd:true,fm:true,w:30,e:[5,4,1,1,50,50,false,false],c:"CS>26&CV>5",p:700};
I.u[353] = {n:"Spada del Piccolo Cavaliere",t:6,d:"La spada del Piccolo Cavaliere è solida ed efficace. Se usata correttamente può provocare danni enormi ai tuoi nemici.",ep:7,g:9,l:21,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>42",p:1400};
I.u[354] = {n:"La Klebik",t:6,d:"Questo tipo di spada era stata forgiata per le guardie di un commerciante ricco e rinomato. Destinata soprattutto a far paura ai ladri, può servire anche per ucciderli o uccidere i clienti onesti, ma un po\' pesanti.",ep:1,g:11,l:25,wd:true,fm:true,w:20,e:[12,4,1,1,30,60,false,false],c:"CS>50&CW>5",p:1850};
I.u[355] = {n:"L\'Anello di Valore",t:9,d:"Questo anello aumenta la Forza e il coraggio di chi lo porta.",ep:1,g:7,l:12,wd:true,fm:true,w:4,p:600};
I.u[356] = {n:"Cintura di Resistenza",t:10,d:"Questa cintura aumenta la resistenza di chi la porta.",ep:1,g:3,l:27,wd:true,fm:true,w:16,p:2200};
I.u[357] = {n:"La Coda",t:6,d:"Spada simbolo della parte del corpo per la quale gli Ecaflip sono fierissimi. Questa spada riassume bene il modo di fare dei giocatori.",ep:1,g:18,l:13,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>26&CA>10",p:650};
I.u[358] = {n:"La Coda Infernale",t:6,d:"La Coda Infernale è veramente infernale... Tanto da rendere pazzi amici e nemici, e soprattutto trasformare i tuoi compagni in avversari in caso di errore. Purtroppo non può mai accadere il contrario.",ep:1,g:18,l:21,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>42&CA>10",p:1400};
I.u[359] = {n:"L\'Ecalizzatore",t:9,d:"Questo anello è stato offerto molto tempo fa a un gatto molto furbo di nome Isidor dal re Allister, che aveva riconosciuto l\'agilità ineguagliabile di questo Ecaflip.",ep:1,g:35,l:29,wd:true,fm:true,w:3,p:2400};
I.u[360] = {n:"Orecchie del Tiwabbit",t:106,d:"Queste piccole orecchie ricoperte di peli bruni puzzano di Buulupo morto, una volta bollite. Ma sono molto buone se servite ripiene di gelatina reale.",ep:8,g:30,l:11,wd:true,fm:true,w:1,p:10};
I.u[361] = {n:"Cawota",t:68,d:"È l\'unico cibo del Tiwabbit Keafam... ecco forse il perché della sua grande stupidità.",ep:2,g:31,l:20,wd:true,fm:true,w:1,p:2};
I.u[362] = {n:"Pelle di Larva Blu",t:59,d:"Questa pelle bella liscia è un buonissimo ingrediente per le pozioni magiche.",ep:1,g:32,l:2,wd:true,fm:true,w:1,p:2};
I.u[363] = {n:"Pelle di Larva Arancione",t:59,d:"Questa pelle bella liscia è un buonissimo ingrediente per le pozioni magiche.",ep:1,g:33,l:9,wd:true,fm:true,w:1,p:2};
I.u[364] = {n:"Pelle di Larva Verde",t:59,d:"Questa pelle bella liscia è un buonissimo ingrediente per le pozioni magiche.",ep:1,g:34,l:7,wd:true,fm:true,w:1,p:100};
I.u[365] = {n:"Zampa di Arakne",t:103,d:"Una zampa molto fine, ma molto pelosa. Apprezzata dagli Alchimisti per le proprietà eccitanti, è una piccola debolezza che li farà uscire fuori di testa.",ep:1,g:35,l:2,wd:true,fm:true,w:1,p:10};
I.u[366] = {n:"Becco del Tofu",t:47,d:"Questo ridicolo becco di tofu, nonostante l\'aspetto inoffensivo, è molto tagliente. Gli arcieri di Amakna lo usano da secoli come punta per le loro frecce.",ep:1,g:37,l:4,wd:true,fm:true,w:1,p:2};
I.u[367] = {n:"Uovo di Tofu",t:105,d:"Questo uovo ha la peculiarità di puzzare di uovo marcio anche quando non lo è, immaginate un po\' che puzza fa quando è veramente marcio. A parte questo ad Amakna nessuno sa se è nato prima l\'uovo di Tofu o il Tofu stesso.",ep:1,g:38,l:4,wd:true,fm:true,w:1,p:1};
I.u[368] = {n:"Gelatina alla Fragola",t:110,d:"Questa deliziosa gelatina alla fragola ha fatto ammalare più di un avventuriero un po\' troppo goloso. Come dice il famoso proverbio: \"Tutto è veleno, niente è veleno. Dipende dalla dose\". Per quanto riguarda la gelatina alla fragola, cerca di evitare l\'overdose!",ep:5,g:40,l:28,wd:true,fm:true,w:1,p:100};
I.u[369] = {n:"Gelatina alla Menta",t:110,d:"Questa deliziosa gelatina alla menta ha fatto ammalare più di un avventuriero un po\' troppo goloso. Provoca un effetto di sollievo a tutta la squadra se la mangi in caso di alito cattivo.",ep:5,g:41,l:10,wd:true,fm:true,w:1,p:100};
I.u[370] = {n:"Gelatina Celeste Reale",t:110,d:"Questa deliziosa gelatina è il prodotto della digestione e della fermentazione del miele di una Gelatina Reale. Anche se non è commestibile nella sua forma grezza, resta uno degli ingredienti principali per i dolci.",ep:7,g:407,l:50,wd:true,fm:true,w:1,p:100};
I.u[371] = {n:"Sopracciglia di Moskito",t:15,d:"Il Moskito ha sopracciglia lunghe e fini che mettono in risalto lo sguardo affascinante. La grande sensibilità del Moskito fa sì che le sue sopracciglia siano sempre impregnate di lacrime dalle proprietà sconosciute.",ep:1,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[372] = {n:"Fascia del Black Tiwabbit",t:15,d:"Questa fascia dà un\'apparenza di guerriero al Black Tiwabbit che la porta. Sembra che la tradizione di portare una fascia sia stata tramandata dal Wabbit Wambo.",ep:8,g:29,l:11,wd:true,fm:true,w:1,p:2};
I.u[373] = {n:"Gambo di Dente di Leone Diabolico",t:36,d:"Questo gambo molto morbido, si piega ma non si spezza. Questa qualità ne fa un componente di prima scelta per la fabbricazione di fruste e altri oggetti indispensabili all\'educazione dei bambini.",ep:1,g:45,l:6,wd:true,fm:true,w:1,p:10};
I.u[374] = {n:"Lingua di Dente di Leone Diabolico",t:36,d:"Il colore verde di questa lingua è dato dall\'eccessiva consumazione abusiva di gelatina menta di cui, neanche a dirlo, il Dente di Leone Diabolico è golosissimo.",ep:1,g:555,l:5,wd:true,fm:true,w:1,p:2};
I.u[375] = {n:"Dente del Tofu Malefico",t:47,d:"Il Tofu Malefico ha barattato il suo ridicolo piccolo becco di Tofu con ridicoli denti giganti. È difficile sapere quale delle due cose sia la più pericolosa, bisognerebbe provarle.",ep:1,g:47,l:3,wd:true,fm:true,w:1,p:1};
I.u[376] = {n:"Ala di Tofu Malefico",t:104,d:"Quest\'ala piccola e ridicola serve al Tofu Malefico solo per muovere l\'aria e fare perdere l\'equilibrio ai moskito.",ep:1,g:48,l:3,wd:true,fm:true,w:1,p:1};
I.u[377] = {n:"Spina del Fun Fung",t:15,d:"Questa spina velenosa protegge i Fun Fung dagli attacchi in corpo a corpo, però gli impedisce di fare le coccole all\'essere amato. Fortunatamente per lui, il Fun Fung usa un liquido chiamato Sporma che lancia a distanza per riprodursi.",ep:1,g:49,l:5,wd:true,fm:true,w:1,p:1};
I.u[378] = {n:"Sporma del Fun Fung",t:15,d:"Questo sporma è il \"piccolo seme\" che permette al Fun Fung di seminare la sua progenie veramente dappertutto. Attenzione: gli spormi del Fun Fung sono attirati dai piedi puzzolenti e dall\'odore degli stivali di Bowis.",ep:1,g:50,l:5,wd:true,fm:true,w:1,p:1};
I.u[379] = {n:"Chela del Granchio",t:47,d:"Questa chela dalle dimensioni smisurate è quasi vuota. Il Granchio la usa solo per impressionare e farsi passare per un boss. Tuttavia si dice che sia indistruttibile.",ep:1,g:51,l:4,wd:true,fm:true,w:1,p:1};
I.u[380] = {n:"Foglia di Menta Selvatica",t:36,d:"È l\'alimento base della Gelatina Verde, quindi se senti odore di menta, non è detto che vicino a te ci sia della menta.",ep:1,g:52,l:30,wd:true,fm:true,w:1,p:0};
I.u[381] = {n:"Fragola",t:46,d:"È l\'alimento base della Gelatina Fragola, quindi se senti odore di fragola, forse sei nella sua zona di caccia.",ep:7,g:53,l:28,wd:true,fm:true,w:1,p:1};
I.u[382] = {n:"Unghia di Cavaliere di Karne",t:47,d:"Quest\'unghia sporca e consumata è stata in diversi posti, soprattutto in quelli meno raccomandabili. E quindi è meglio per te se a tua volta non la metterai ovunque e soprattutto non in posti poco raccomandabili.",ep:3,g:54,l:16,wd:true,fm:true,w:1,p:1};
I.u[383] = {n:"Corno di Pappatutto",t:47,d:"Le Corna di Pappatutto sono brillanti e morbide come il cuoio. Per ragioni sconosciute gli Osamodas le apprezzano particolarmente.",ep:1,g:55,l:9,wd:true,fm:true,w:1,p:1};
I.u[384] = {n:"Lana di Pappatutto",t:57,d:"Questa spessa lana puzza di Bwork che non si lava, ma è molto calda e soprattutto non irrita le pelli sensibili. Una qualità particolarmente apprezzata dagli Aniripsa per la loro biancheria.",ep:1,g:56,l:9,wd:true,fm:true,w:1,p:1};
I.u[385] = {n:"Bava di Pappatutto",t:15,d:"Questa bava è puzzolente perché il Pappatutto passa tutto il tempo a leccarsi la lana;\r\n            per lo stesso motivo l\'alito non è dei migliori...",ep:1,g:57,l:9,wd:true,fm:true,w:1,p:1};
I.u[386] = {n:"Muso di Cinghiale",t:15,d:"Questo muso è un attrezzo di prima scelta per trovare le grosse ghiande sparse nel sottobosco. Al contrario del muso di Drago Maiale, questo è immangiabile a causa del suo odore ripugnante.",ep:1,g:58,l:14,wd:true,fm:true,w:1,p:1};
I.u[387] = {n:"Zanna di Cinghiale",t:47,d:"Questa zanna permette al Cinghiale di difendersi e anche di pulirsi il muso. Non dimenticare però di lavarla con l\'acqua prima di farne della polvere.",ep:1,g:59,l:14,wd:true,fm:true,w:1,p:1};
I.u[388] = {n:"Peli del Cinghiale",t:54,d:"Questi peli molto resistenti sono soprattutto usati per fabbricare pennelli e scope.\nAlcune persone sono allergiche al contatto con questi peli, quindi è meglio evitare di sfregarseli addosso con forza.",ep:1,g:60,l:14,wd:true,fm:true,w:1,p:1};
I.u[389] = {n:"Olio di Girasole Selvatico",t:60,d:"Quest\'olio è raccomandatissimo dai dietologi per il suo alto contenuto percentuale di acidi grassi essenziali. In più, il suo contenuto elevato di grassi poli-insaturi rispetto a quelli saturi lo rende ancora migliore.",ep:1,g:61,l:12,wd:true,fm:true,w:1,p:100};
I.u[390] = {n:"Olio di Noce",t:60,d:"Olio dal gusto molto fruttato, è usato in pasticceria per diversi dolci. Quest\'olio quasi senza grassi saturi si conserva molto poco, anche dentro una bottiglia che non è mai stata aperta.",ep:4,g:62,l:32,wd:true,fm:true,w:1,p:100};
