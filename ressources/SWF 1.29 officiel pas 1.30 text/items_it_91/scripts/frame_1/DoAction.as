I.u[157] = {n:"Il Goccetto",t:1,d:"Il Goccetto è stato creato con una pietra lunare tenuta a bagno in un barile di birra per ben 5.000 anni. Tutto ciò gli ha inevitabilmente conferito terribili poteri.",ep:2,g:7,l:17,wd:true,fm:true,w:5,p:1000};
I.u[158] = {n:"La Sorte Dorata",t:1,d:"La Sorte Dorata aumenta di molto la Vitalità e l\'Agilità dell\'eroe che la porta.",ep:1,g:9,l:12,wd:true,fm:true,w:5,p:600};
I.u[159] = {n:"La Spilla Celeste",t:1,d:"Si racconta che questa spilla sia stata creata dal famoso Forgiatore Bulgur, conosciuto soprattutto come Forgiatore delle armi degli dei.",ep:1,g:8,l:40,wd:true,fm:true,w:5,p:2900};
I.u[160] = {n:"Il Budino delle Stelle",t:1,d:"Questo budino è un miscuglio di uova celesti e polveri di stelle lattee. Da conservare al fresco.",ep:7,g:10,l:62,wd:true,fm:true,w:5,p:10000};
I.u[161] = {n:"La Celebrità",t:1,d:"A questo potente amuleto non manca niente per rendere celebre chi lo indossa.",ep:1,g:9,l:27,wd:true,fm:true,w:5,p:2200};
