I.u[233] = {n:"Kaiser",t:7,d:"Kaiser è il nome di un Drago Maiale che tempo fa distrusse il villaggio di Bunkaida. Dopo che la milizia riuscì a ucciderlo, i Forgiatori cominciarono a creare numerose armi a partire dai suoi resti. Questo martello è una di esse.",ep:2,g:10,l:82,wd:true,fm:true,w:20,an:15,e:[20,4,1,1,30,200,false,false],c:"CS>80&CI>80&CA>50",s:58,p:10000};
I.u[234] = {n:"Ragnarok",t:7,d:"Il Ragnarok è un martello molto potente, capace di scatenare tempeste o fulmini dai tuoi alleati quando li colpisci.",ep:7,g:55,l:66,wd:true,fm:true,w:60,an:15,e:[10,4,1,1,45,100,false,false],c:"CS>40&CI>40&CW>10",p:11400};
I.u[235] = {n:"Cerberus",t:7,d:"Questo martello era di proprietà del guardiano della Porta degli Inferi. Impediva ai vivi di entrare, ai morti di uscire e ai morti viventi di muoversi.",ep:1,g:7,l:16,wd:true,fm:true,w:35,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>15&CS>15",p:900};
I.u[236] = {n:"Barabas",t:7,d:"Barabas è temibile: permette a chi lo porta di spostarsi più facilmente, e soprattutto di essere più efficace nei combattimenti ravvicinati.",ep:1,g:11,l:23,wd:true,fm:true,w:40,an:15,e:[5,4,1,1,45,45,false,false],c:"CI>13&CS>10",p:1600};
