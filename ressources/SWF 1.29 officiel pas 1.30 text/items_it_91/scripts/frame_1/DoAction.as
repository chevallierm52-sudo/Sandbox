I.u[202] = {n:"Raziela",t:6,d:"Questa spada è stata benedetta dalle lacrime dell\'angelo Raziel. È una spada terribilmente distruttiva ed è abbastanza potente da permettere a chi la usa di affrontare il più terribile degli avversari.",ep:1,g:16,l:52,wd:true,fm:true,w:50,an:14,e:[15,5,1,1,40,50,false,false],c:"CS>104&CV>52&CA>20",p:7100};
I.u[203] = {n:"Cintura del Tot",t:10,d:"Se hai questo oggetto formidabile intorno alla vita, vuol dire che sei uno degli eroi più fortunati di questo universo. Questa cintura apparteneva all\'eroe barbuto più forte e seducente di tutti i tempi.",ep:1,g:10,l:33,wd:true,fm:true,w:15,p:3200};
I.u[204] = {n:"Kryst O\'Bul",t:4,d:"Questo bastone vivente è stato nei luoghi più oscuri dell\'universo di Amakna. Si risveglia ogni 300 anni per cambiare posto e proprietario, e preferisce passare nelle piccole e oscure gallerie puzzolenti.",ep:7,g:63,l:59,wd:true,fm:true,w:23,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>59&CA>5",s:38,p:9050};
