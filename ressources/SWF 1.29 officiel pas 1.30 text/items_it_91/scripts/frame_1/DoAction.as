I.u[200] = {n:"God Rod",t:4,d:"Il God Rod è un\'arma terribile. Potentissima, permette a chi la usa di mostrarsi all\'altezza dei migliori anche quando ha un piccolo calo di forza.",ep:3,g:7,l:67,wd:true,fm:true,w:23,an:12,e:[10,3,1,1,30,30,false,false],c:"CI>60&CV>10&CW>10",p:11650};
