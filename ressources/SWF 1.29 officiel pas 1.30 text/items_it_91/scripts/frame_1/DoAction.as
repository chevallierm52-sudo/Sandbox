I.u[219] = {n:"Blessdag",t:5,d:"Le Blessdag appartenevano al famoso Orco Mano Oscura che morì affrontando un paladino di Bimd\'Ule. Si racconta che queste malefiche daghe prendessero vita grazie al suo sangue.",ep:7,g:55,l:64,wd:true,fm:true,w:15,an:13,tw:true,e:[17,3,1,1,30,100,false,false],c:"CA>64&CV>10&CC>10",p:10900};
