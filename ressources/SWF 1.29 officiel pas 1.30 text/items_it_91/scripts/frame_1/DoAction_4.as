I.u[1853] = {n:"Squalo Mercato-Libero",t:41,d:"È parente dello squalo falce-martello, ma più feroce e molto meno organizzato. Prenderlo è il sogno di tutti i Pescatori, o meglio... prenderlo restando vivi.",ep:1,g:324,l:80,wd:true,fm:true,w:4,p:1};
