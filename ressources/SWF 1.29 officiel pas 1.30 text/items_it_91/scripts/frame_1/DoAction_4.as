I.u[1439] = {n:"Malo Piccone",t:21,d:"Questo piccone sembra attirare il malocchio.\nTuttavia, pare che gli manchi veramente poco per diventare un gran piccone.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,6,1,1,50,10,false,true],p:250};
