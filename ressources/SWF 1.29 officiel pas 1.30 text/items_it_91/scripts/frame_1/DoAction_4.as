I.u[1830] = {n:"Ghiozzo a fette ****",t:49,d:"Fette di ghiozzo Kiye ben cotte con un po\' di cipolla, una delizia! E non ti preoccupare per i cattivi odori, la carne del ghiozzo Kiye conferisce un odore di fiori alle esalazioni emanate dopo la sua digestione.",ep:1,g:101,l:1,wd:true,fm:true,w:1,c:"Cw<10",u:true,ut:true,p:10000};
I.u[1831] = {n:"Ala di Razza ****",t:49,d:"Cotta con sapienza nel burro nero di bwork, quest\'ala di razza di Farle sprigiona tutto il suo sapore. Questo è un pesce che ti metterà le ali!",ep:1,g:102,l:1,wd:true,fm:true,w:1,c:"Ci<70",u:true,ut:true,p:70000};
I.u[1832] = {n:"Trota flambé **",t:49,d:"La Ricetta esotica ancestrale dei Volpi permette a questo pesce di riaccendere la fiamma dentro di te. Ma bisogna saperla gestire, e purtroppo non è ancora il caso...",ep:1,g:108,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:30};
