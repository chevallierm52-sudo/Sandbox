I.u[1435] = {n:"La Pala del Largo",t:8,d:"Questa pala molto pesante è destinata agli avventurieri più gr... larghi!",ep:9,g:11,l:80,wd:true,fm:true,w:150,an:16,e:[10,6,1,1,50,50,false,true],c:"CS>100",p:40000};
I.u[1436] = {n:"Pala Ikan",t:8,d:"Ikan era il pesciolino di Churros il guerriero. È importante precisare che il nome di questa pala non ha nessun rapporto con questo pesce, ma piuttosto con il suo odore...",ep:7,g:8,l:50,wd:true,fm:true,w:50,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>30&CA>10",p:7800};
