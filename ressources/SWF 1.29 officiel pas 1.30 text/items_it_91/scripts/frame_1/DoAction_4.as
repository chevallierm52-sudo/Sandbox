I.u[1635] = {n:"Pergamena Vento di panico",t:25,d:"(Doppio clic per imparare questa emote)\nQuesta pergamena ti permette di imparare a \"sparare dei gas\", ma attento a non abusarne... potrebbe essere pericoloso per la tua salute e quella dei tuoi amici.",ep:4,g:9,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[1636] = {n:"Piccola Stella della Sera",t:6,d:"La creatrice di questa spada dall\'enorme fascino ha voluto ricreare tutta la sua bellezza con un pizzico del suo carattere pungente. Il risultato parla più di ogni parola.",ep:1,g:22,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>35&CV>35&CS>11",p:4000};
