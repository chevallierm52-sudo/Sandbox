I.u[1752] = {n:"Pesce Impanato Fritto **",t:49,d:"Questo saporito rettangolo è composto dai migliori e più leggeri pezzi di vecchi pesci cubici. Piace molto ai bambini, ma il valore nutrizionale è un po\' basso.",ep:2,g:71,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:60};
