I.u[1426] = {n:"Pala di Thart\'",t:8,d:"Thart\', il creatore di questa pala, era un discepolo Yop. Proprio un nome adatto a uno Yop, vero?",ep:3,g:8,l:24,wd:true,fm:true,w:24,an:16,e:[5,5,1,1,50,50,false,true],p:1800};
I.u[1427] = {n:"Pala Zébuth",t:8,d:"Questa pala è usata dai grandi sacerdoti Kannibul dell\'isola di Moon per invocare Zébuth, una delle loro divinità rappresentata spesso con aspetto bovino. Solo i personaggi vili possono usare quest\'arma.",ep:1,g:40,l:55,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,50,20,false,true],c:"Ps=2&CC>50",p:8000};
I.u[1428] = {n:"Immortale",t:36,d:"Questa strana piccola pianta cresce in ambienti aridi, e diffonde un odore di curry intorno a sé. È molto resistente e non subisce gli assalti del tempo... Se solo si potesse dire altrettanto di tutte le donne...",ep:2,g:54,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1429] = {n:"Piccola Pala Fruttifera",t:8,d:"Questa pala è usata dagli Anutrof per raccogliere i frutti dagli alberi, ma può diventare un\'arma da combattimento molto pericolosa. Come direbbe il suo creatore Frü Its: \"Its biutifruits my pala!\".",ep:1,g:19,l:30,wd:true,fm:true,w:15,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>10&CI>10",p:1500};
I.u[1430] = {n:"Pala Fruttifera",t:8,d:"Questa pala è usata dagli Anutrof per raccogliere i frutti dagli alberi, ma può diventare un\'arma da combattimento molto pericolosa. Come direbbe il suo creatore Frü Its: \"Its biutifruits my pala!\".",ep:1,g:19,l:45,wd:true,fm:true,w:23,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>15&CI>15",p:2300};
I.u[1431] = {n:"Grande Pala Fruttifera",t:8,d:"Questa pala è usata dagli Anutrof per raccogliere i frutti dagli alberi, ma può diventare un\'arma da combattimento molto pericolosa. Come direbbe il suo creatore Frü Its: \"Its biutifruits my pala!\".",ep:1,g:19,l:60,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>25&CI>25",p:3000};
I.u[1432] = {n:"Pala Iuola",t:8,d:"Gaston Iuola, giardiniere discepolo di Anutrof aveva l\'abitudine di esagerare con le piante. Quest\'arma ne è la prova. Questa potente pala ti giocherà brutti scherzi e metterà a dura prova la tua Intelligenza.",ep:1,g:17,l:21,wd:true,fm:true,w:21,an:16,e:[2,4,1,1,50,50,false,true],c:"CC>27&CW<100&CS>10",p:2100};
I.u[1433] = {n:"Pala di Autodifesa",t:8,d:"Questa pala è stata l\'arma di autodifesa di un piccolo gruppo di Anutrofine. Ma quando queste signorine si ritrovarono questo strumento del potere tra le loro mani, cambiarono completamente e cercarono di conquistare il mondo.",ep:7,g:4,l:60,wd:true,fm:true,w:30,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>60&CS>30&CA>10",p:6500};
