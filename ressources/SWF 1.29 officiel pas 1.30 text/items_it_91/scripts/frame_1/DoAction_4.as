I.u[1656] = {n:"Fecalizzatore del Mago",t:9,d:"Questo anello protegge chi lo porta dai piccoli attacchi magici, nonché dai piccoli mostri che usano la magia per fare i furbi e rendersi interessanti.",ep:1,g:40,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1657] = {n:"Fecalizzatore del Guerriero",t:9,d:"Questo anello protegge chi lo porta dai piccoli attacchi fisici, nonché dai piccoli mostri che approfittano della loro taglia per agire di sorpresa.",ep:1,g:41,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1658] = {n:"null",t:22,d:"",ep:0,g:1,l:31,wd:true,fm:true,w:15,e:[10,5,1,1,50,45,false,false],c:"CA>40&CV>20",p:2670};
I.u[1659] = {n:"null",t:22,d:"",ep:0,g:1,l:56,wd:false,fm:true,w:15,an:12,e:[10,5,1,1,45,50,false,false],c:"CC>80&CA>40&CI>20",p:8345};
I.u[1660] = {n:"Ambra di Alberagno Oscuro",t:50,d:"Questa magnifica ambra contiene una miserabile bestiola intrappolata nella linfa del proprio padrone. È una sorta di sarcofago che permette all\'Alberagno Oscuro di conservare i ricordi delle proprie invocazioni anche dopo la loro morte.",ep:9,g:638,l:78,wd:true,fm:true,w:2,p:6000};
I.u[1661] = {n:"Ambramuleto Moskito",t:1,d:"Portare al collo un Moskito intrappolato nell\'ambra mostra ai tuoi avversari che sei un temibile Cacciatore di... Moskito. Sarebbe ridicolo persino per un neonato!",ep:1,g:17,l:40,wd:true,fm:true,w:5,p:4400};
I.u[1662] = {n:"Ambramuleto Arakne",t:1,d:"Portare al collo un Arakne intrappolata nell\'ambra, durante un combattimento con una delle sue sorelle può rivelarsi un bel vantaggio.... Povera bestia... che ironia della sorte!",ep:1,g:18,l:34,wd:true,fm:true,w:5,p:3225};
I.u[1663] = {n:"Scaglia di Coccodrail",t:59,d:"Questa scaglia di Coccodrail è un piccolo trofeo per ogni Cacciatore principiante di Coccodrail che si rispetti. Non esitare a mostrarla agli ubriaconi della taverna, li impressionerai tanto che ti pagheranno da bere.",ep:4,g:233,l:36,wd:true,fm:true,w:5,p:50};
I.u[1664] = {n:"Dente di Coccodrail",t:47,d:"Quando un Coccodrail ha il dente marcio contro di te, l\'unica soluzione è quella di strapparglielo con determinazione, proprio come un dentista.",ep:4,g:234,l:36,wd:true,fm:true,w:1,p:50};
I.u[1665] = {n:"Stivali di Apprendimento",t:11,d:"Questi stivali molto strani erano fatti indossare ai giovani discepoli intellettualmente un po\' limitati, al fine di portarli al livello degli altri. Sono particolarmente adatti agli Yop.",ep:4,g:68,l:50,wd:true,fm:true,w:10,p:6675};
I.u[1666] = {n:"Stivali dell\'Apprendista Invocatore",t:11,d:"Questi stivali sono specialmente concepiti per coloro che amano lasciare alle loro invocazioni tutto il piacere dei combattimenti.",ep:12,g:14,l:51,wd:true,fm:true,w:10,p:7000};
I.u[1667] = {n:"Cintura Luthuthu",t:10,d:"Questa cintura ha il ridicolo nome del suo creatore: Luthutu era un Ciabattino meno conosciuto di Bowis ma ancora molto creativo alla sua veneranda età.",ep:8,g:13,l:50,wd:true,fm:true,w:10,p:6700};
I.u[1668] = {n:"Cintura del Dodu Tremante",t:10,d:"Il Dodu era un Sadida che si ostinava a fare tremare i suoi nemici. Ha ordinato questa cintura a Bowis, dicendogli di abbinarla al colore dei suoi peli. Il Dodu non è solo un essere tremante ma anche un grande seduttore.",ep:4,g:14,l:55,wd:true,fm:true,w:8,p:8000};
I.u[1669] = {n:"Cintura dei Venti",t:10,d:"Questa cintura è stata creata dalla più celebre delle Ocraine, che adorava occupare il tempo organizzando un sacco di feste ed eventi fuori dal comune. Il tutto per fare divertire un po\' il popolo tra una stirata e l\'altra delle Mutande di cuoio del Capitano Chafer.",ep:8,g:15,l:84,wd:true,fm:true,w:10,p:18300};
I.u[1670] = {n:"Piuma Appuntita del Kwak di Vento",t:53,d:"A volte un Kwak del vento ha una piuma appuntita diversa da tutte le altre. Si tratta quasi sempre di una piuma magica e che può essere usata per travestirsi da indiano.",ep:5,g:393,l:24,wd:true,fm:true,w:10,p:100};
I.u[1671] = {n:"Avena Magica",t:34,d:"Questo fuscello di Avena Magica è nata da un modesto Contadino stregato da un apprendista Bwork Mago che teneva il suo libro al contrario...",ep:1,g:550,l:20,wd:true,fm:true,w:10,p:0};
I.u[1672] = {n:"Peli di Darit",t:54,d:"Questi peli sono quello che resta di Darit, un giovane mago molto presuntuoso, che aveva dimenticato di verificare se il Prespic avesse lanciato un \"Contro\", prima di lanciare il suo incantesimo \"Folgore Svasante\".",ep:1,g:555,l:18,wd:true,fm:true,w:1,p:100};
I.u[1673] = {n:"Zampa di Arakne Magica",t:103,d:"Questa zampa di Arakne non è come tutte le altre, si muove da sola e sembra piena di vita, anche dopo essere stata strappata alla proprietaria. Una nuova vita sembra cominciare per questa zampa che sembra attirata dal cucito.",ep:1,g:392,l:2,wd:true,fm:true,w:10,p:100};
I.u[1674] = {n:"Champignon Luidegit",t:15,d:"Questo eroe è stato incantato dalla Quercia Molle, ma la magia un po\' imprecisa di quest\'ultima l\'ha trasformato in un fungo. I Fung, che sono un po\' stupidi, lo venerano e proteggono a costo della loro stessa vita.",ep:1,g:390,l:46,wd:true,fm:true,w:10,p:100};
I.u[1675] = {n:"Osso Sorpresa dello Chafer Fante",t:47,d:"Quest\'osso magico permette agli Chafer fanti di fare cose sorprendenti, come per esempio togliersi e mettersi le mutande sulla testa, senza le mani, in pieno combattimento e riuscendo anche a schivare i colpi. È sempre uno spettacolo vederglielo fare!",ep:3,g:15,l:35,wd:true,fm:true,w:1,p:100};
I.u[1676] = {n:"Vimini incantato",t:15,d:"Questo pezzo di Vimini incantato dovrebbe permetterti di costruire un magnifico cesto da frutta magico. Eleganza e potenza allo stesso tempo insomma, tutto il contrario di una cattiva Liche.",ep:2,g:123,l:69,wd:true,fm:true,w:10,p:100};
I.u[1677] = {n:"Pozione Dantgulesca",t:12,d:"Questa pozione magica è la sola capace di rendere magiche le Mutande di Cuoio del Capitano Chafer intrecciate tra di loro. E questo la dice lunga sulla potenza di tale pozione.",ep:2,g:139,l:50,wd:true,fm:true,w:10,p:1000};
I.u[1678] = {n:"Noce di Kokoko Traumatizzata",t:46,d:"Questa noce di Kokoko è stata traumatizzata durante la sua infanzia e ha passato questi ultimi anni a fomentare un odio incredibile, il che ne fa una noce di Kokoko molto potente.",ep:12,g:552,l:42,wd:true,fm:true,w:2,p:100};
I.u[1679] = {n:"Pietra di Crystalbul",t:50,d:"Con un po\' di pazienza e di lavoro, questa pietra preziosa può diventare rotonda e brillante come il pompon di un cappello magico. La sua forma gli permette inoltre di intrufolarsi praticamente ovunque.",ep:4,g:240,l:16,wd:true,fm:true,w:10,p:100};
I.u[1680] = {n:"Corno bruciato del Minotoror",t:47,d:"Questo Corno di Minotoror è stato bruciato da una magia molto potente che ne ha fatto un artefatto magico di prima scelta. Sfortunatamente, come molte altre cose, funziona solo in paio...",ep:2,g:245,l:125,wd:true,fm:true,w:10,p:100};
I.u[1681] = {n:"Pelle di Larva Verde Magica",t:59,d:"Non lasciarti ingannare dalla sua apparenza viscosa, se porti questo artefatto vicino alla testa potresti essere più fortunato di uno Chafer cornuto.",ep:1,g:391,l:7,wd:true,fm:true,w:10,p:100};
I.u[1682] = {n:"Corteccia di Leroy Merlin",t:96,d:"Questo pezzo di corteccia proviene da un albero della radura incantata di Leroy Merlin.\nSi è staccato quando Bruce Bulgur il Taglialegna ha rotto la sua Bulgurda tentando di abbattere un albero incantato.",ep:9,g:542,l:78,wd:true,fm:true,w:1,p:100};
I.u[1683] = {n:"Sacco di Patate Chiaro",t:15,d:"Questo sacco magico permette a un Sadida Ladrurbo di trasportare delle quantità incredibili di patate già pelate, per poi rivenderle ai prigionieri. Una volta morto, questo sacco è trasmesso da Ladrurbo a Ladrurbo come una specie di rituale.",ep:1,g:243,l:12,wd:true,fm:true,w:10,p:100};
I.u[1684] = {n:"Sacco di Patate Oscuro",t:15,d:"È più o meno la stessa cosa del Sacco di Patate Chiaro, a parte il fatto che questo è stato immerso nella linfa di Alberagno Oscuro, il che gli conferisce poteri supplementari.",ep:1,g:244,l:12,wd:true,fm:true,w:10,p:100};
I.u[1685] = {n:"Piuma dell\'ultimo Poolay",t:53,d:"Attenzione: hai tra le tue mani l\'ultima piuma strappata dal didietro dell\'ultimo Poolay di tutta Amakna. Questa piuma sarà un regalo bellissimo per i tuoi amici Sarti o per i fanatici del Poolay sempre più numerosi nel corso degli anni.",ep:3,g:247,l:32,wd:true,fm:true,w:1,p:100};
I.u[1686] = {n:"Tintura Magica di Rossore",t:70,d:"Questa piccola pozione magica dà un magnifico colore rosso ai peli sui quali si applica. \nIn più sembra che possieda qualche effetto magico.",ep:7,g:63,l:10,wd:true,fm:true,w:1,p:500};
I.u[1687] = {n:"Tintura Magica Verdastra",t:70,d:"Questa piccola pozione magica dà un magnifico colore verde ai peli sui quali si applica. \nIn più sembra che possieda qualche effetto magico.",ep:1,g:64,l:10,wd:true,fm:true,w:1,p:500};
I.u[1688] = {n:"Tintura Magica Celeste",t:70,d:"Questa piccola pozione magica dà un magnifico colore blu ai peli sui quali si applica. \nIn più sembra che possieda qualche effetto magico.",ep:5,g:65,l:10,wd:true,fm:true,w:1,p:500};
I.u[1689] = {n:"Tintura Magica Arancione",t:70,d:"Questa piccola pozione magica dà un magnifico colore arancione ai peli sui quali è applicata. In più, sembra che possieda qualche effetto magico.",ep:1,g:66,l:10,wd:true,fm:true,w:1,p:500};
I.u[1690] = {n:"Peli del Milibuulupo",t:54,d:"Questi peli assomigliano a quelli del Buulupo, solo un po\' più corti, meno solidi, ma più morbidi. Sfortunatamente, l\'odore resta quello.",ep:1,g:554,l:22,wd:true,fm:true,w:1,p:1};
I.u[1691] = {n:"Peli del Muulupo",t:54,d:"Sono rari gli avventurieri che hanno avuto la fortuna di toccare questi peli e di essere ancora in vita.\nMa non per questo sei diventato un eroe.",ep:2,g:553,l:198,wd:true,fm:true,w:10,p:200};
I.u[1692] = {n:"Tintura Magica Oscura",t:70,d:"Questa piccola pozione magica dà un magnifico colore nero ai peli sui quali si applica. \nIn più sembra che possieda qualche effetto magico.",ep:1,g:67,l:10,wd:true,fm:true,w:1,p:500};
I.u[1693] = {n:"Mantello di Jules Yanos",t:17,d:"Jules Yanos era un celebre Sarto, diventato ancora più celebre per avere barattato sua moglie con un ditale magico. Per fortuna esiste ancora qualcuno che ha il senso degli affari.",ep:8,g:8,l:54,wd:true,fm:true,w:1,p:7800};
I.u[1694] = {n:"Lana del Trooll Furioso",t:57,d:"Questo pezzo di lana proviene dal Trooll più pericoloso di Amakna. Proprio quello trasformato in copriletto da un Sarto senza scrupoli... lo stesso che ha scambiato la moglie per un ditale magico. Che mistero!",ep:4,g:27,l:115,wd:true,fm:true,w:10,p:1};
I.u[1695] = {n:"Mantello d\'Elya Wood",t:17,d:"Si racconta che il Capitano Chafer abbia tentato di rubare questo mantello per sostituire la sua famosa biancheria di cuoio. Ma non gli piaceva molto, perché per lui non era abbastanza perverso e perfido.",ep:8,g:9,l:80,wd:true,fm:true,w:10,s:39,p:16500};
I.u[1696] = {n:"Stoffa del Muulupo",t:55,d:"Tempo addietro i Sarti hanno trovato un metodo per determinare il valore di questa stoffa: più puzza più è potente. Questa stoffa puzza più di un pediluvio di Anutrof nel quale sono state lavate delle Mutande dello Chafer.",ep:2,g:14,l:198,wd:true,fm:true,w:20,p:300};
I.u[1697] = {n:"Piccolo Zaino di Lana di Pappaton",t:81,d:"Questo piccolo Zaino non ti farà diventare una celebrità, ma avrà almeno il merito di farti portare qualche oggetto personale.",ep:1,g:25,l:1,wd:true,fm:true,w:5,p:100};
I.u[1698] = {n:"Zaino del Piccolo Raccoglitore",t:81,d:"Questo zaino è stato appositamente studiato per contenere numerosi risorse raccoglibili.\nSolo i veri raccoglitori possono portarlo. (Livello 20 di raccoglitore necessario).",ep:1,g:26,l:5,wd:true,fm:true,w:5,c:"PJ>2,20|PJ>24,20|PJ>36,20|PJ>28,20|PJ>26,20|PJ>41,20",p:2000};
I.u[1699] = {n:"Zaino del Piccolo Avventuriero",t:81,d:"Questo Zaino è destinato a coloro che non si allontanano troppo da casa, e hanno bisogno di portare cose di nessun valore, come delle Tavole di Frassino per esempio.",ep:1,g:27,l:10,wd:true,fm:true,w:5,p:3000};
I.u[1700] = {n:"Cintura di Celerità",t:10,d:"Questa cintura aerodinamica fabbricata da Tengra Reufrus ha la capacità di renderti agile come l\'aria, e libero come un Tofu. O forse è il contrario...",ep:4,g:17,l:27,wd:true,fm:true,w:15,p:2000};
I.u[1701] = {n:"Cintura con Tasche",t:10,d:"Questa cintura possiede piccole tasche che ti permetteranno di mettere più oggetti nel tuo inventario.",ep:1,g:16,l:20,wd:true,fm:true,w:10,p:1300};
I.u[1702] = {n:"Zaino del Raccoglitore",t:81,d:"Questo zaino è stato appositamente studiato per contenere numerosi risorse raccoglibili.\nSolo i veri raccoglitori possono portarlo. (Livello 40 di raccoglitore necessario).",ep:8,g:28,l:15,wd:true,fm:true,w:10,c:"PJ>2,40|PJ>24,40|PJ>36,40|PJ>28,40|PJ>26,40|PJ>41,40",p:3000};
I.u[1703] = {n:"Zaino del Grande Raccoglitore",t:81,d:"Questo zaino è stato appositamente studiato per contenere numerosi risorse raccoglibili.\nSolo i veri raccoglitori possono portarlo. (Livello 60 di raccoglitore necessario).",ep:8,g:29,l:20,wd:true,fm:true,w:10,c:"PJ>2,60|PJ>24,60|PJ>36,60|PJ>28,60|PJ>26,60|PJ>41,60",p:2000};
I.u[1704] = {n:"Zaino dello Staca Novista",t:81,d:"Si racconta che un famoso Minatore fosse capace di lavorare senza sosta per mesi e allo stesso tempo in 4 Miniere differenti. Si tratta naturalmente di una leggenda inventata dalla Gilda della Falce-Martello per incitare i suoi Minatori a lavorare di più.",ep:8,g:30,l:20,wd:true,fm:true,w:10,c:"PJ>2,90|PJ>24,90|PJ>36,90|PJ>28,90|PJ>26,90|PJ>41,90",p:10000};
I.u[1705] = {n:"Zaino dell\'Avventuriero",t:81,d:"È lo zaino ideale per portare tutto il tuo pane e le pozioni quando parti per molti mesi, in un labirinto per esempio.",ep:8,g:31,l:40,wd:true,fm:true,w:4,p:4000};
I.u[1707] = {n:"Zaino del Grande Avventuriero",t:81,d:"È lo zaino ideale per conservare tutto il tuo pane e le tue pozioni quando parti per destinazioni esotiche, come l\'isola di Moon.",ep:13,g:32,l:60,wd:true,fm:true,w:5,p:6000};
I.u[1709] = {n:"Cocchino",t:47,d:"\"Chi è il cocchino di mammina?\". Queste sono state le ultime parole di una Anutrof che ha scambiato un Buulupo per il suo animale domestico.",ep:1,g:15,l:1,wd:true,fm:true,w:2,p:1};
I.u[1710] = {n:"Croissant di Luna",t:1,d:"Le origini di questo amuleto, che ha la forma di un quarto di luna, sono sconosciute da tutti... o quasi. Chissà chi conosce il segreto che questo gioiello porta in sé.",ep:1,g:19,l:1,wd:false,fm:true,w:10,p:1000};
I.u[1711] = {n:"Baubau",t:18,d:"Con questo piccolo cagnolino scoprirai la gioia delle passeggiate per la pipì. Ricordati che è un animale selvaggio quindi, se non vuoi perdere una mano, evita di dargli da mangiare.\n(QUESTO FAMIGLIO NON AMA NESSUNA RISORSA)",ep:1,g:6,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1712] = {n:"Pozione Pahoa Raid",t:12,d:"Questa pozione consente di recuperare qualche punto energia.",ep:1,g:140,l:20,wd:true,fm:true,w:1,u:true,p:50};
I.u[1713] = {n:"Pozione Raid Bul",t:12,d:"Questa pozione consente di recuperare qualche punto energia.",ep:1,g:141,l:40,wd:true,fm:true,w:1,u:true,p:100};
I.u[1715] = {n:"Il dono di Nawal",t:25,d:"Best seller di fine anno 634, questo libro deve essere assolutamente letto. Un classico!",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1716] = {n:"La famiglia DeCielo",t:25,d:"Seconda migliore vendita dell\'inverno 634, questo libro è un best-seller.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1717] = {n:"Primo Natale",t:25,d:"L\'outsider di inizio anno 635, questo libro merita veramente di essere letto.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1718] = {n:"Forza di Crocobarro",t:9,d:"Questo anello fu stregato dal soffio nero di Grugalorasalar, che gli conferì un potere immenso, oggi purtroppo quasi scomparso. Questa reliquia era destinata a Crocobarro, l\'unico che poteva indossarla senza subire il suo dominio.",ep:4,g:38,l:40,wd:true,fm:true,w:2,c:"CS>59",p:4000};
I.u[1719] = {n:"Spirito di Crocobarro",t:11,d:"Questi stivali appartenevano a Crocobarro. Le poche persone che riescono a calzarli si sentono all\'improvviso invase da pensieri machiavellici e ingegnosi. Secondo la leggenda questo maleficio è dovuto alle migliaia di crani che hanno schiacciato.",ep:4,g:12,l:42,wd:true,fm:true,w:10,c:"CI>49",p:5000};
I.u[1720] = {n:"Potenza di Crocobarro",t:10,d:"Grugalorasalar collezionava frammenti di osso appartenenti ai più forti nemici sconfitti. Il suo affetto per Crocobarro lo ha spinto a usarli per costruirgli una cintura strapotente.",ep:4,g:18,l:34,wd:true,fm:true,w:15,c:"CV>119",p:3000};
I.u[1721] = {n:"Pozione d\'oblio: \"Orologio\"",t:43,d:"Questa pozione fa dimenticare un livello dell\'incantesimo degli Xelor: \"Orologio\".",ep:2,g:37,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1722] = {n:"Trasformazione Alberagno",t:27,d:"La maledizione della Quercia Molle ti trasformerà in Alberagno.\nPer rompere il sortilegio devi battere un avventuriero perso nella foresta degli Alberagni.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1723] = {n:"Caramella Rossa strapotente",t:28,d:"Questa caramella ti potenzia temporaneamente.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1724] = {n:"Coraggio",t:29,d:"Questa benedizione aumenterà la tua Forza nei prossimi combattimenti.",ep:18,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1725] = {n:"Scoraggiato",t:30,d:"Questa maledizione diminuirà la tua Forza nel prossimo combattimento.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1726] = {n:"Ciuffo di capelli di Tarke",t:24,d:"Questo ciuffo di capelli prova la tua vittoria contro Tarke. Che impresa!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1727] = {n:"Lettera di Minaccia",t:24,d:"Una lettera di minaccia indirizzata a Donna Clude.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1728] = {n:"Maomao",t:18,d:"Questa piccola palla di pelo carina e maliziosa fa perdere la testa alle donne di tutte le classi. Il Maomao è un animale temibilissimo!",ep:1,g:1,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1729] = {n:"Anello Mar",t:9,d:"Questo anello apparteneva a Mar, il più grande fannullone di tutta la contrada di Amakna. Professava il culto dei donuts e delle costine di rib.",ep:7,g:28,l:25,wd:true,fm:true,w:25,c:"CI<100&CC<100",p:1900};
I.u[1730] = {n:"Misura di Sale",t:48,d:"Questa misura di sale è la dose ideale per condire molti piatti saporiti. È indispensabile per un pasto coi fiocchi.",ep:1,g:261,l:1,wd:true,fm:true,w:1,p:1};
I.u[1731] = {n:"Dose di succo gustoso",t:15,d:"Questo succo ti fornirà i sapori principali per avere un piatto saporito.",ep:1,g:262,l:1,wd:true,fm:true,w:1,p:4};
I.u[1732] = {n:"Tazza",t:15,d:"Non c\'è niente di più pratico di una tazza per gustare una buona zuppa, anche se berla con le mani non cambia niente al gusto... A meno che le tue dita non siano molto sporche.",ep:16,g:263,l:1,wd:true,fm:true,w:1,p:6};
I.u[1733] = {n:"Pasticcio",t:15,d:"\"Il pasticcio, è buono qui, è buono qui... Viva il pasticcio, viva il pasticcio!\" (Estratto dell\'inno del Macellaio - strofa 4).",ep:16,g:264,l:1,wd:true,fm:true,w:1,p:6};
I.u[1734] = {n:"Ciliegia",t:46,d:"Questo frutto assomiglia di brutto a un grosso paio di palle rimbalzanti.",ep:1,g:265,l:1,wd:true,fm:true,w:1,p:1};
I.u[1735] = {n:"Certificato di Deposito al Cianil: Maomao",t:77,d:"Questo Certificato descrive le caratteristiche del Maomao che hai lasciato al Cianil.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[1736] = {n:"Limone",t:46,d:"Il succo di Limone è l\'ideale per coprire gli odori della carne in putrefazione, e per servire resti di pesci avariati ai tuoi invitati.",ep:1,g:266,l:1,wd:true,fm:true,w:1,p:2};
I.u[1737] = {n:"Pane di Campagna",t:33,d:"In tasca o nello stomaco, questo pane si rivela molto pesante. Ma bisogna ammettere che il suo gusto ha quel non so che di rustico che ci si aspetta dal buon pane.",ep:1,g:68,l:40,wd:true,fm:true,w:3,u:true,ut:true,p:1};
I.u[1738] = {n:"Pane di Città",t:33,d:"Si può dire senza esitazione che questo pane dà voglia di farsi uno spuntino. Dà inoltre la sensazione di essere sazi in poco tempo.",ep:1,g:69,l:10,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[1739] = {n:"Bacchetta Focolento",t:3,d:"Questa bacchetta ha strane proprietà: brucia al tatto. Ma la cosa più enigmatica resta l\'odore di cenere, che fa pensare che il suo legno sia sopravvissuto a un incendio nella foresta.",ep:13,g:24,l:80,wd:true,fm:true,w:1,an:11,e:[5,4,2,3,40,50,false,true],c:"CI>60&CV>40",p:1};
I.u[1740] = {n:"Trasformazione Crocobarro",t:27,d:"La Crocobar racchiude l\'essenza di Crocobarro e può essere presa al suo proprietario solo togliendogli la vita.",ep:4,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1741] = {n:"Sangue di Fenice",t:14,d:"Questo sangue di Fenice permette di risuscitare un fantasma e di dargli qualche Punto Energia.",ep:18,g:3,l:10,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:1000};
I.u[1742] = {n:"Sangue di Fenice DOC",t:14,d:"Questo sangue di Fenice permette di risuscitare un fantasma e di dargli parecchi Punti Energia.",ep:18,g:3,l:50,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:2500};
I.u[1744] = {n:"Ciuffo di capelli di Torcha",t:24,d:"Questo ciuffo di capelli prova la tua vittoria contro Torcha. Che impresa!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1745] = {n:"Siringa del Veterinario",t:24,d:"Estremità appuntita, serbatoio, non c\'è dubbio, è una siringa... Sei avvisato.",ep:1,g:31,l:1,wd:true,fm:true,w:0,p:1};
I.u[1746] = {n:"Sangue di Wabbit GM",t:24,d:"Chi avrebbe mai immaginato di arrivare dai Wabbit con una siringa per prelevare il sangue della creatura più geneticamente modificata dell\'isola? Tu, evidentemente.",ep:8,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[1747] = {n:"Analisi dello Sangue di Wabbit GM",t:24,d:"Le analisi sono rigide, il sangue identificato appartiene a un antenato di Wabbit GM. I test sono stati tanto approfonditi che l\'Alchimista potrebbe dirti anche quale chiappa è stata punta... la destra in questo caso.",ep:5,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[1748] = {n:"Wabbit",t:18,d:"Questo piccolo Wabbit è domestico. Stai tranquillo, lui non ti morderà... però gli altri...",ep:8,g:7,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:11,p:1};
I.u[1749] = {n:"Gettone della Fiera del Trool",t:15,d:"Hai comprato questo gettone da Leonzi Trool che sogna un giorno di aprire un parco divertimenti aperto a tutti (Pianura di Cania).",ep:13,g:737,l:1,wd:true,fm:true,w:1,p:1};
I.u[1750] = {n:"Pesce Impanato",t:41,d:"Questo pesce cubico è conosciuto per avere la mentalità particolarmente quadrata. Ha pure il cervello quadrato ed è quindi molto facile da pescare.",ep:2,g:269,l:1,wd:true,fm:true,w:3,p:10};
