I.u[1455] = {n:"Ali di Scarafoglie Blu",t:104,d:"Queste ali di Scarafoglie possiedono dei principi magici e permettono di fabbricare delle pozioni elementari di Acqua.",ep:3,g:212,l:32,wd:true,fm:true,w:2,p:100};
I.u[1456] = {n:"Ali di Scarafoglie Bianco",t:104,d:"Queste ali di Scarafoglie possiedono dei principi magici e permettono di fabbricare delle pozioni elementari di Aria.",ep:3,g:213,l:32,wd:true,fm:true,w:2,p:100};
I.u[1457] = {n:"Ali di Scarafoglie Rosso",t:104,d:"Queste ali di Scarafoglie possiedono dei principi magici e permettono di fabbricare delle pozioni elementari di Fuoco.",ep:3,g:214,l:32,wd:true,fm:true,w:2,p:100};
I.u[1458] = {n:"Ai di Scarafoglie Verde",t:104,d:"Queste ali di Scarafoglie possiedono dei principi magici e permettono di fabbricare delle pozioni elementari di Terra.",ep:3,g:215,l:32,wd:true,fm:true,w:2,p:100};
I.u[1459] = {n:"Tubo Longiforme",t:71,d:"Questo tubo è stato appositamente studiato per essere stappato con una sola mano.",ep:1,g:55,l:1,wd:true,fm:true,w:1,p:5};
I.u[1460] = {n:"Grande fiala",t:71,d:"Questa fiala è studiata appositamente per essere stappata facilmente, anche senza l\'uso delle mani.",ep:3,g:56,l:1,wd:true,fm:true,w:1,p:10};
I.u[1461] = {n:"Veleno Pungente",t:15,d:"Questo veleno a base di zampe di Arakne ti farà perdere la testa in tutti i sensi, perché dopo un periodo di follia la scatola cranica esplode a causa della pressione sanguigna.",ep:1,g:189,l:20,wd:true,fm:true,w:1,p:100};
I.u[1462] = {n:"Liquido Vampiresco",t:15,d:"Questo liquido fatto con un incrocio di diversi tipi di sangue diverso ha la cattiva abitudine di saltare al collo.",ep:2,g:188,l:30,wd:true,fm:true,w:1,p:100};
I.u[1463] = {n:"Fiala da elemento",t:71,d:"Questa fiala è destinata naturalmente a contenere l\'essenza di un elemento.",ep:1,g:57,l:1,wd:true,fm:true,w:1,p:50};
I.u[1464] = {n:"Antenna dello Scarafoglie Blu",t:15,d:"Nessuno sa a cosa servano le antenne dello Scarafoglie. L\'unica certezza è che puzzano!",ep:3,g:216,l:32,wd:true,fm:true,w:1,p:100};
I.u[1465] = {n:"Antenna dello Scarafoglie Rosso",t:15,d:"Nessuno sa a cosa servano le antenne dello Scarafoglie. L\'unica certezza è che puzzano!",ep:3,g:217,l:32,wd:true,fm:true,w:1,p:1};
I.u[1466] = {n:"Antenna dello Scarafoglie Verde",t:15,d:"Nessuno sa a cosa servano le antenne dello Scarafoglie. L\'unica certezza è che puzzano!",ep:3,g:218,l:32,wd:true,fm:true,w:1,p:100};
I.u[1467] = {n:"Antenna dello Scarafoglie Bianco",t:15,d:"Nessuno sa a cosa servano le antenne dello Scarafoglie. L\'unica certezza è che puzzano!",ep:3,g:219,l:32,wd:true,fm:true,w:1,p:100};
I.u[1468] = {n:"Boccale",t:71,d:"Questo boccale può servire per tutto, dalla fabbricazione di pozioni all\'annegamento dei pesci.",ep:1,g:58,l:1,wd:true,fm:true,w:1,p:100};
I.u[1469] = {n:"Pergamena di Raccomandazione",t:24,d:"Con questa pergamena Uba Tessé ti raccomanda vivamente come Alchimista.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1470] = {n:"Pergamena di Raccomandazione",t:24,d:"Con questa pergamena Uba Tessé ti raccomanda vivamente come Alchimista. È stato aggiunto anche un piccolo appunto da Alam Bik.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1471] = {n:"Pergamena di Raccomandazione e fiore",t:24,d:"Con questa pergamena Uba Tessé ti raccomanda vivamente come Alchimista. È stato aggiunto anche un piccolo appunto da Alam Bik. Un fiore prova che hai imparato la prima lezione.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1472] = {n:"Pergamena di richiesta d\'esame",t:24,d:"Questa pergamena indica che hai passato con successo il tirocinio per diventare Alchimista e che ora sei pronto per l\'esame.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1473] = {n:"Mani Verdi",t:20,d:"Con questi guanti, potrai raccogliere ogni tipo di pianta o fiore facilmente e senza rischi.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:100};
I.u[1474] = {n:"Amuleto di Xelor",t:1,d:"Questo amuleto super potente è il frutto del lavoro sulla padronanza del tempo di un vecchio Xelor.",ep:1,g:28,l:52,wd:true,fm:true,w:10,p:7300};
I.u[1475] = {n:"La Zella Lame",t:6,d:"La Zella Lama è stata forgiata dal celebre Forgiatore Dave-LoL prima di morire, per la più Zella delle Yoppine del reame. Si dice che questa lama non abbia eguali se non la bellezza di chi la porta.",ep:4,g:15,l:60,wd:true,fm:true,w:30,an:14,e:[10,4,1,1,30,50,false,false],c:"CS>100&CV>50",p:3000};
I.u[1476] = {n:"Amuleto del Croccaroc",t:1,d:"Questo potente amuleto racchiude tutta la vita del Croccaroc, tutti gli oggetti che ha raccolto prima di perire sotto i colpi degli avventurieri attirati dalle sue ricchezze.",ep:2,g:25,l:47,wd:true,fm:true,w:5,p:5800};
I.u[1477] = {n:"Fortun a Muleto",t:1,d:"Muleto era una piccola Ecaflippina che non ha mai avuto fortuna nella vita, fino a quando sua nonna non le ha regalato questo amuleto.",ep:1,g:26,l:44,wd:true,fm:true,w:5,p:5000};
I.u[1478] = {n:"Armonia",t:1,d:"Questo ciondolo aiuta colui che lo porta a ritrovare l\'armonia con il mondo che lo circonda.",ep:1,g:122,l:47,wd:true,fm:true,w:1,p:6000};
I.u[1479] = {n:"Tut An\'Carton",t:7,d:"Questo martello leggendario ha già passato molte prove ad Amakna. Apparteneva al potente Tut An\'Carton che non ci pensava due volte ad usarlo per ridurre i suoi avversari in carta straccia e coriandoli.",ep:13,g:6,l:46,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>50&CV>30",p:5600};
I.u[1480] = {n:"Accordo",t:1,d:"Questo ciondolo aiuta colui che lo porta a ritrovare l\'armonia con il mondo che lo circonda.",ep:1,g:121,l:38,wd:true,fm:true,w:1,p:4000};
I.u[1481] = {n:"Intesa",t:1,d:"Questo ciondolo aiuta colui che lo porta a ritrovare l\'armonia con il mondo che lo circonda.",ep:1,g:11,l:26,wd:true,fm:true,w:1,p:2000};
I.u[1482] = {n:"Emblema Livido",t:1,d:"Questo amuleto è estremamente utile, ma fa diventare chi lo porta bianco come un Pappatutto.",ep:1,g:32,l:41,wd:true,fm:true,w:2,p:4500};
I.u[1483] = {n:"Kabala",t:1,d:"Misterioso simbolo di un misterioso organismo. D\'altronde non esiste neanche e tu non ne hai mai sentito parlare.",ep:11,g:13,l:29,wd:true,fm:true,w:2,p:2500};
I.u[1484] = {n:"Amuleto Itby Rivisto",t:1,d:"Eccellente lavoro dell\'apprendista Orefice Polme Kartnez. Questa copia supera l\'originale.",ep:1,g:31,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1485] = {n:"La Reginetta",t:1,d:"Questo amuleto è la versione migliorata della Sorte Dorata. Stranamente però non hanno niente in comune, a parte il loro aspetto alquanto ridicolo...",ep:1,g:27,l:22,wd:true,fm:true,w:5,c:"CC>10",p:1500};
I.u[1486] = {n:"Medaglia Holy",t:1,d:"Holy era una discepola di Yop che aveva giurato di sradicare il male dappertutto. Era sempre tranquilla e non si arrabbiava mai, eccetto quando la si comparava a una certa Oly.",ep:1,g:23,l:31,wd:true,fm:true,w:3,p:2800};
I.u[1487] = {n:"L\'Adelus",t:10,d:"Questa cintura, oltre a essere molto elegante, fa un massaggio veramente rilassante a chi la indossa. Il felice proprietario è così meno stressato è può riflettere meglio.",ep:1,g:12,l:48,wd:true,fm:true,w:30,p:6075};
I.u[1488] = {n:"Plimclik",t:1,d:"Dietro questo strano nome si nasconde un oggetto altrettanto strano, originato chissà come da altri amuleti. Non si sa nulla delle circostanze della sua scoperta.",ep:11,g:123,l:130,wd:true,fm:true,w:24,p:1000};
I.u[1489] = {n:"La Spilla Chà",t:1,d:"Chà era uno dei più grandi guerrieri di Amakna. La leggenda racconta che prendeva la sua saggezza dalla spilla che portava con sé.",ep:11,g:15,l:28,wd:true,fm:true,w:1,p:2300};
I.u[1490] = {n:"La Catena \'Noro Kebrill",t:1,d:"Il suo creatore, un certo Ken Aton, era celebre per i suoi strani vizi. Passava infatti le giornate a cacciare il Minotoror perché voleva farsi una moquette pettorale.",ep:1,g:12,l:13,wd:true,fm:true,w:2,p:650};
I.u[1491] = {n:"Catena della Liche",t:1,d:"La Liche era una creatura schifosa conosciuta per unirsi ai gruppi di valorosi guerrieri al fine di rubargli una parte del bottino. Un giorno, fu scoperta e dovette scappare.",ep:13,g:12,l:45,wd:true,fm:true,w:2,p:5400};
I.u[1492] = {n:"null",t:17,d:"",ep:0,g:23,l:30,wd:true,fm:true,w:11,p:800};
I.u[1493] = {n:"Ferita del Sàcrido",t:9,d:"Si dice che questo anello sia uscito da una delle numerose ferite di un Sàcrido.",ep:1,g:13,l:15,wd:true,fm:true,w:2,p:800};
I.u[1494] = {n:"L\'Anellatore",t:9,d:"La funzione principale di questo bell\'anello è quella di permettere agli Osamodas di riconoscere i propri tofu durante i combattimenti.",ep:1,g:14,l:15,wd:true,fm:true,w:4,p:800};
I.u[1495] = {n:"L\'Anello Dhyn",t:9,d:"Questo piccolo brutto anello è stato creato da Degun, un Orefice conosciuto per le sue sfuriate verso tutti e la sua crudele avversione per la Liche piuttosto che per la sua creatività nell\'Oreficeria.",ep:1,g:37,l:36,wd:true,fm:true,w:3,p:3575};
I.u[1496] = {n:"Fortuna dell\'Ecaflip",t:9,d:"Questo anello aumenta la fortuna di chi lo porta durante le partite a carte.",ep:1,g:32,l:20,wd:true,fm:true,w:4,p:1300};
I.u[1497] = {n:"Passato di Xelor",t:9,d:"Anelli generati durante i viaggi temporali di Xelor.",ep:1,g:16,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1498] = {n:"Ricordo di Anutrof",t:9,d:"Sono anelli creati con le lacrime di un Anutrof che ha perso la sua pala. Questo dà più o meno l\'idea della disperazione che può colpire una persona.",ep:1,g:15,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1499] = {n:"L\'Anutrofion",t:9,d:"Quest\'anello è solo per gli Anutrof. Il loro dio lo ha stregato in modo che lo usino unicamente i suoi discepoli. Aumenterà la Fortuna nella ricerca dei tesori ad ogni Anutrof che si rispetti.",ep:1,g:39,l:59,wd:true,fm:true,w:1,c:"PG=3",p:10000};
I.u[1500] = {n:"La Mokette",t:17,d:"Questo splendido mantello, cucito con elementi fibrosi di ogni specie, è un pezzo unico per il suo colore e i suoi riflessi.",ep:8,g:8,l:43,wd:true,fm:true,w:16,p:5000};
I.u[1501] = {n:"Fede",t:9,d:"Questa fede simbolizza l\'unione fra due anime follemente innamorate. Sono finiti i tempi in cui dovevate nascondervi, ora potete finalmente mostrarvi alla luce del giorno.",ep:2,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[1503] = {n:"Bacchetta di Fuoco Fatuo",t:3,d:"Per la fabbricazione di questa lugubre bacchetta si dice che bisogna metterla nel corpo di un cadavere fresco, e seppellirlo poco dopo... ma nessuno osa immaginare in che modo.",ep:3,g:14,l:20,wd:true,fm:true,w:15,an:11,e:[5,3,2,3,30,50,false,true],c:"CI>30",p:1000};
I.u[1504] = {n:"Daghe O\'Bert",t:5,d:"O\'Bert collo rosso era famoso nelle profonde campagne. Fu ucciso un giorno in cui cantava a squarciagola (da qui deriva il suo soprannome). La daga del delitto fu ritrovata, ma nessuno ne cercò il proprietario... O\'Bert cantava veramente malissimo.",ep:1,g:1,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1505] = {n:"Flauto",t:20,d:"Questo flauto molto raro in legno di Alberagno ti permetterà di divertire e commuovere i tuoi amici.",ep:1,g:6,l:1,wd:true,fm:true,w:1,an:4,e:[0,5,1,1,0,0,false,false],p:50000};
I.u[1506] = {n:"Simbolo dello strano",t:15,d:"Questa carta da gioco rappresenta... qualche cosa. In effetti, non si sa esattamente cosa, ma si crede sia veramente importante.",ep:1,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[1507] = {n:"Buono 1000 Kek",t:15,d:"Su questo pezzo di carta c\'è scritto un piccolo slogan: \"Bravo, possiedi un buono Kek, vuol dire che ti sei guadagnato stima e ammirazione. Vieni ad usarlo da noi, ti aspettiamo!\nSeguito dalle coordinate cartografiche -1,-2.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
