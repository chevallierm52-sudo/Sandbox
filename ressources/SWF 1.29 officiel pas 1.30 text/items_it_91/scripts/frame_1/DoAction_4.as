I.u[1844] = {n:"Trota",t:41,d:"La trota è un pesce abbastanza facile da pescare e i Pescatori veterani ne pescano addirittura tre alla volta. Spesso decidono al momento stesso se mangiarle crude o cotte. Forse questo è il motivo della loro ottima pronuncia.",ep:1,g:394,l:1,wd:true,fm:true,w:3,p:0};
I.u[1845] = {n:"Trota Pulita",t:62,d:"Adesso questa Trota può essere usata come ingrediente.",ep:1,g:396,l:1,wd:true,fm:true,w:2,p:1};
I.u[1846] = {n:"Trota Ancestrale",t:41,d:"Una delle più vecchie trote al mondo. Se è vero che il tempo rende più saggi, allora questa trota dovrebbe essere la più saggia di tutte... Ma il dubbio persiste.",ep:1,g:398,l:1,wd:true,fm:true,w:3,p:1};
I.u[1847] = {n:"Luccio",t:41,d:"Questo pesce d\'acqua dolce e di taglia media è l\'amico del barbecue del Pescatore.",ep:2,g:400,l:10,wd:true,fm:true,w:3,p:1};
