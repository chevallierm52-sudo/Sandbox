I.u[1652] = {n:"Zampa di Arakne Maggiore",t:103,d:"Una zampa molto fine, ma molto pelosa. Era usata tempo fa per la fabbricazione delle scope e delle parrucche dallo stile un po\' esotico.",ep:1,g:246,l:39,wd:true,fm:true,w:1,p:1};
I.u[1653] = {n:"Fede di Don Juan",t:24,d:"Questo anello mostra che sei alla ricerca del segreto di Don Juan. Ora hai imparato il coraggio.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1654] = {n:"Fede di Don Juan",t:24,d:"Questo anello mostra che sei alla ricerca del segreto di Don Juan. Ora hai imparato il coraggio, la comunicazione e devi avere pazienza.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
