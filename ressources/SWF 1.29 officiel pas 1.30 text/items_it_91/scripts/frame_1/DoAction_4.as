I.u[1860] = {n:"Canna Arpione",t:20,d:"Questa canna da pesca ultraresistente possiede un amo a forma di arpione, specialmente studiato per la pesca allo squalo.",ep:1,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1861] = {n:"La Grande Per(ti)ca",t:20,d:"Questa canna da pesca è stata appositamente studiata per prendere le perche scivolose.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1862] = {n:"Il Bastone di Amore",t:20,d:"Il Legno di questa Canna libera una Resina profumata che impregna la lenza e l\'amo. Questo soave profumo deve assomigliare a quello di una Kralamoretta perché attira tutti i Kralamori dei dintorni.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1863] = {n:"Canna di Chô",t:20,d:"Chô era il cuoco più famoso della tavola rotonda. La sua bravura era quella di procurarsi alimenti freschi proprio davanti al cliente. Questa canna gli permetteva di pescare pesci indispensabili per il suo celebre piatto di Carpa Chô.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1864] = {n:"Il Ferro da Calza",t:20,d:"La lenza di questa canna da pesca è esclusivamente composto di lana il cui gomitolo sostituisce l\'esca. Pochissimi pesci-micino riescono a resistergli.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1865] = {n:"Canna Cubica",t:20,d:"Questa canna è specialmente concepita per adattarsi alla morfologia tanto particolare dei... pesci impanati.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1866] = {n:"Canna da Pesca Standard",t:20,d:"Questa canna, di semplice manifattura, permetterà a un giovane Pescatore di pescare qualsiasi pesce... sempre che ne abbia la pazienza.",ep:2,g:8,l:1,wd:true,fm:true,w:3,an:18,e:[1,4,1,3,100,100,false,false],c:"PJ>36,9",p:1000};
I.u[1867] = {n:"Grande Canna da Pesca",t:20,d:"Questa canna da pesca è destinata ai Pescatori professionisti. Gli permetterà di lanciare l\'esca molto lontano, ma bisogna saperla usare correttamente per riuscire a pescare qualcosa.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,5,100,100,false,false],c:"PJ>36,39",p:2000};
I.u[1868] = {n:"Canna da Pesca Telescopica",t:20,d:"Questa canna da pesca può raggiungere lunghezze incredibili. Ma solo i maestri Pescatori la sanno usare correttamente.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,7,100,100,false,false],c:"PJ>36,69",p:4000};
I.u[1869] = {n:"Cavadenti",t:24,d:"Questo Cavadenti funziona soprattutto sui Pappatutto, ma puoi sempre utilizzarlo per toglierti una carie se ne hai il coraggio.",ep:2,g:34,l:1,wd:true,fm:true,w:0,p:1};
