I.u[1613] = {n:"Scaglia di Capo Coccodrail",t:59,d:"Questo frammento di carapace servirà sicuramente a creare dei bei stivali.",ep:4,g:547,l:69,wd:true,fm:true,w:5,p:100};
I.u[1614] = {n:"Denti di Capo Coccodrail",t:47,d:"Questi denti duramente staccati dalla bocca di un Coccodrail, devono pur avere una buona utilità...",ep:4,g:548,l:69,wd:true,fm:true,w:1,p:100};
I.u[1619] = {n:"L\'Alberamu",t:1,d:"L\'Alberamu è un amuleto molto elegante. Se hai intenzione di indossarlo, ti consigliamo di andare in giro nudo per mettere bene in risalto questo prezioso gioiello. Vedrai, le donne non resisteranno!",ep:9,g:16,l:46,wd:true,fm:true,w:2,p:5700};
I.u[1620] = {n:"Alberarco",t:2,d:"Questo arco sembra essere ancora vivo e può quasi tirare le frecce da solo, che bravo! Potrebbe essere l\'arco ideale per le persone che hanno due mani sinistre, ma resta comunque il problema di incoccare la freccia nel verso giusto.",ep:9,g:24,l:39,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,50,30,false,true],p:4200};
I.u[1621] = {n:"Stivali di Padronanza",t:11,d:"Gli stivali di Padronanza aumentano l\'Agilità e l\'Intelligenza di chi li lancia a scapito della Forza e della Fortuna. Al contrario di quello che si potrebbe credere, non ti permettono di controllare il tuo avversario.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1622] = {n:"Stivali di Potenza",t:11,d:"Gli stivali di Potenza aumentano la Forza e la Fortuna di chi li lancia a scapito dell\'Intelligenza e dell\'Agilità. Al contrario di ciò che si potrebbe pensare, non conferiscono una potenza enorme a chi li calza.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1623] = {n:"Stivali di Anticipazione",t:11,d:"Gli stivali di Anticipazione aumentano la Forza e l\'Agilità di chi li lancia a scapito dell\'Intelligenza e della Fortuna. Al contrario di quello che si potrebbe pensare, non permettono di anticipare le azioni degli avversari.",ep:4,g:15,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1624] = {n:"Stivali di Nexus",t:11,d:"Questi stivali sono appartenuti a Nexus, grande cavaliere ibernato per sempre.",ep:3,g:16,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1625] = {n:"La Leggenda del Croccaroc",t:25,d:"Questo libro ripercorre il percorso dell\'ultimo essere umano che ha avuto dei contatti con un Croccaroc.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1626] = {n:"Enciclopedia Alchemica Annesso A: Mestieri",t:25,d:"Questa enciclopedia contiene tutte le ricette d\'alchimia per l\'oblio dei mestieri.",ep:1,g:2,l:1,wd:true,fm:true,w:1,u:true,p:150};
