I.u[1511] = {n:"Nove Code",t:6,d:"La leggenda narra che Ecaflip, durante il combattimento dantesco che lo innalzò al rango di dio, utilizzò un\'arma costituita dalle sue code, una per ognuna delle sue vite.",ep:13,g:19,l:80,wd:true,fm:true,w:20,an:14,e:[9,9,1,1,20,20,false,false],c:"CS>99&CA>99&CV>99",p:20000};
