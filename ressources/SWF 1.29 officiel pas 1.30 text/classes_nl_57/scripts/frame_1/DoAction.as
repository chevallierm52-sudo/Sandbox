G = new Object();
G[1] = {sn:"Feca",ln:"Feca\'s Schild",ep:1,d:"De Fecas zijn loyale Beschermers. Ze worden ze bijzonder gewaardeerd bij de groepen avonturiers vanwege hun beschermende krachten, maar ook omdat ze als geen ander de staf hanteren. Al generaties lang zijn Fecas buitengewoon trots op hun beschermende rol. De Wijzen hebben hen de meest waardevolle voorwerpen toevertrouwd.",sd:"Als beschermers verlaagt hun uitrusting de schade die toegebracht wordt aan hun bondgenoten.",s:[3,17,6,4,2,1,9,18,20,14,19,5,16,8,12,11,10,7,15,13,1901],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[2] = {sn:"Osamodas",ln:"Osamodas\' Zweep",ep:1,d:"De Osamodas zijn geboren Bezweerders! Ze hebben de macht om wezens te bezweren en ze zijn opmerkelijke africhters. Het gerucht gaat dat ze hun kleding maken van de huid van hun vijanden, maar ga ze dus maar vragen of het zo is... Je zult \'t meemaken als je je leven beëindigd als  laars of als bontmuts.",sd:"Als bezweerders gebruiken ze bezweringen om van een afstand te vechten.",s:[23,34,21,26,22,35,28,37,30,27,24,33,25,38,36,32,29,39,40,31,1902],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[3] = {sn:"Enutrof",ln:"Enutrofs Vingers",ep:1,d:"De Enutrofs zijn verstokte Schatjagers! Ze hebben interesse in alle voedingsmiddelen, voorwerpen of wezens waar ze kama\'s mee kunnen verdienen. Het eerste wat een Enutrof doet als hij een andere avonturier ontmoet, is hem afwegend aankijken. Het is waar: in de ogen van een Enutrof is een avonturier een wezen bepakt met waren en beladen met voorwerpen... die weer te verkopen zijn!",sd:"Als schatjagers weten ze hoe ze spreuken ongedaan kunnen maken en kunnen ze de bewegingen van hun vijanden af te remmen.",s:[51,41,43,49,42,47,48,45,53,46,52,44,50,54,55,56,58,59,57,60,1903],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[150,3],[230,4],[330,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[60,3],[100,4],[150,5]]};
G[4] = {sn:"Sram",ln:"Sram\'s Schaduw",ep:1,d:"De Srams zijn Moordenaars die gek zijn op geldbuidels, bij voorkeur goed gevulde. Ze tillen de slipp op van een tuniek, voelen diep in een zak, zijn vingervlug, strijken gewilde juwelen op en zetten dodelijke valstrikken. Ziedaar het leven van een Sram discipel!",sd:"Als moordenaars kunnen ze zichzelf onzichtbaar maken en vallen zetten om hun vijanden te verrassen.",s:[65,72,61,66,68,63,74,64,79,78,71,62,69,77,73,67,70,75,76,80,1904],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[100,2],[200,3],[300,4],[400,5]],b15:[[0,2],[50,3],[150,4],[250,5]]};
G[5] = {sn:"Xelor",ln:"Xelor\'s Zandloper",ep:1,d:"De Xelors zijn Magiers die de tijd en alle mechaniek die het uur aangeven, beheersen: carillons, klokken en pendules dansen naar hun pijpen. De Xelors spelen dus met de tijd om een vijand af te remmen of om zich te teleporteren naar waar ze maar willen.",sd:"Als magiërs gebruiken ze hun spreuken om hun vijanden af te remmen en te voorkomen dat ze spelen.",s:[81,83,82,84,100,92,88,93,85,96,98,86,89,90,87,94,99,95,91,97,1905],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[6] = {sn:"Ecaflip",ln:"Ecaflip\'s Munt",ep:1,d:"De Ecaflips zijn speelse Krijgers die op plekken zijn waar veel te verdienen valt, en veel te verliezen... Een fatsoenlijke Ecaflip speelt onophoudelijk, voor alles en voor niets. Maar pas op, hij neemt het spel serieus en zal zelfs met dobbelen zijn leven op het spel zetten om een gevecht te winnen...",sd:"Als speelse krijgers baseren ze hun meeste aanvallen op kansen.",s:[102,103,105,109,113,111,104,119,101,107,116,106,117,108,115,118,110,112,114,120,1906],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[7] = {sn:"Eniripsa",ln:"Eniripsa\'s Handen",ep:1,d:"De Eniripsas zijn Verzorgers die met een simpel Woord kunnen genezen. Ze gebruiken ze vooral om hun bondgenoten te verzorgen, maar soms ook om hun vijanden te verwonden. Onder hen zijn zelfs woordenjagers, werkwoordmeters, of zwervers van vergeten talen.",sd:"Als verzorgers gebruiken ze hun spreuken om hun bondgenoten te genezen.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[8] = {sn:"Iop",ln:"Iop\'s Hart",ep:1,d:"De Iops zijn aanvallende ongenaakbare Krijgers! Een ding is zeker: de Iops weten hoe ze de wapen moeten hanteren. Trouwens, voor hen is minstens één keer per dag bloed vergieten een teken van goede gezondheid. Hun onstuimige temperament maakt Iops tot voorvechters van het extreme, en zijn in staat tot het beste... en het slechtste!",sd:"Als krijgers gebruiken ze hun gewelddadige spreuken om grote schade toe te brengen.",s:[142,143,141,144,145,146,147,148,154,150,151,155,152,153,149,156,157,158,160,159,1908],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[9] = {sn:"Cra",ln:"Cra\'s Bereik",ep:1,d:"De Cras zijn zowel trotse als nauwkeurige Boogschutters! Het zijn waardevolle bondgenoten in de strijd van het echte gevecht. Ze blijven op afstand, geven hun gevederde steken onder water bij de geringste opening. Ze zijn meester in het toebrengen van schade!",sd:"Als boogschutters zijn ze gespecialiseerd in lange-afstands aanvallen.",s:[169,164,161,163,165,172,167,168,162,170,171,166,173,174,176,175,178,177,179,180,1909],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[50,2],[150,3],[250,4],[350,5]]};
G[10] = {sn:"Sadida",ln:"Sadida\'s Schoen",ep:1,d:"De Sadidas zijn Bezweerders die zalfjes maken en vreselijk vergif! Ze richten Braamstruiken af om er huiveringwekkende wapens van te maken, vervaardigen oorlogs- en verzorgingspoppen. Daar schept een Sadida discipel, die deze naam waardig is, vreugde in.",sd:"Als bezweerders gebruiken ze handgemaakte poppen om met hun vijanden te vechten en hun spreuken ongedaan te maken.",s:[193,183,200,198,195,182,192,197,189,181,199,191,186,196,190,194,185,184,188,187,1910],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[250,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[11] = {sn:"Sacrier",ln:"Sacrier\'s Bloed",ep:1,d:"De Sacriers zijn Berserkers die hun krachten kunnen vertienvoudigen zodra ze geraakt worden! Ze zijn niet bang om slagen te incasseren, noch om verwondingen op te lopen. Ze zijn vaak te vinden in de voorste linie en daardoor erg gewaardeerd bij groepen avonturiers! De Sacrier is echt de ideale partner voor lange oorlogszuchtige avonden...",sd:"Als beschermers zijn ze extreem sterk en kunnen ze aanvallen op hun bondgenoten op zich nemen.",s:[431,432,434,444,449,436,437,439,433,443,440,442,441,445,438,446,447,448,435,450,1911],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,3],[100,4],[150,5]],b11:[[0,1,2]],b12:[[0,3]],b13:[[0,3],[100,4],[150,5]],b14:[[0,3],[100,4],[150,5]],b15:[[0,3],[100,4],[150,5]]};
G[12] = {sn:"Pandawa",ln:"Pandawa\'s Pint",ep:18,d:"Pandawa\'s zijn Sherpa Warriors die weten wat ze uit hun lichaam kunnen halen! En uit die van anderen... Inderdaad, Pandawa\' s aarzelen niet om hun vrienden op te tillen om ze te beschermen of hun vijanden om ze pijn te doen!",sd:"Als Sherpa krijgers worden ze gesterkt door hun drinken, het zorgt ervoor dat ze hun bondgenoten kunnen dragen.",s:[686,692,687,689,690,691,688,693,694,695,696,697,698,699,700,701,702,703,704,705,1912],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[200,3]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[50,2],[200,3]],b14:[[0,1],[50,2],[200,3]],b15:[[0,1],[50,2],[200,3]]};
