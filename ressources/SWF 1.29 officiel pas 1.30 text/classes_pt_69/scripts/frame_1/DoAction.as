G = new Object();
G[1] = {sn:"Feca",ln:"O escudo do Feca",ep:1,d:"Fecas são protetores fiéis. Eles são muito apreciados em grupos de aventureiros devido aos seus poderes defensivos, além da excelente perícia com bastões. Por muitas gerações, os Fecas se orgulharam por serem os maiores guardiões do mundo, sendo sempre escolhidos pelos sábios para confiar seus itens mais preciosos.",sd:"Como protetores, suas armaduras reduzem os danos recebidos por seus aliados.",s:[3,17,6,4,2,1,9,18,20,14,19,5,16,8,12,11,10,7,15,13,1901],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[2] = {sn:"Osamodas",ln:"O chicote do Osamodas",ep:1,d:"Osamodas são invocadores. Eles têm o poder de invocar criaturas e domá-las como ninguém. Alguns dizem que eles fazem suas roupas com a pele de seus inimigos. Você pode se perguntar se é verdade ou não. Apenas tome cuidado para não se tornar como uma bota ou um gorro!",sd:"Como invocadores, usam suas criaturas para lutar a distância.",s:[23,34,21,26,22,35,28,37,30,27,24,33,25,38,36,32,29,39,40,31,1902],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[3] = {sn:"Enutrof",ln:"Os dedos do Enutrof",ep:1,d:"Enutrofs são caçadores de tesouro inveterados! Eles estão sempre de olho em todo o tipo de mercadoria ou criatura que possa ser convertidas em Kamas. A primeira coisa que um Enutrof faz quando encontra outro aventureiro é avaliá-lo bem. Aos olhos de um Enutrof, um aventureiro é uma criatura cheia de mercadorias que pode ser vendida por um bom dinheiro!",sd:"Como caçadores de tesouros, sabem se livrar de encantos e prejudicar o movimento dos inimigos.",s:[51,41,43,49,42,47,48,45,53,46,52,44,50,54,55,56,58,59,57,60,1903],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[150,3],[230,4],[330,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[60,3],[100,4],[150,5]]};
G[4] = {sn:"Sram",ln:"A sombra do Sram",ep:1,d:"Srams são espiões que amam bolsos - especialmente quando estão cheios de moedas! É um instinto natural. Eles adoram sentir o fundo de um bolso com seus dedos ligeiros, especialmente quando encontram jóias e moedas. Isso é o que um Sram mais gosta de fazer na vida!",sd:"Como gatunos, eles podem ficar invisíveis e usar armadilhas para surpreender seus inimigos.",s:[65,72,61,66,68,63,74,64,79,78,71,62,69,77,73,67,70,75,76,80,1904],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[100,2],[200,3],[300,4],[400,5]],b15:[[0,2],[50,3],[150,4],[250,5]]};
G[5] = {sn:"Xelor",ln:"A ampulheta do Xelor",ep:1,d:"Xelors são magos que controlam o tempo e sabem como manipular tudo que seja relacionado a carrilhões, relógios e pêndulos. Xelors adoram brincar com o tempo. Gostam de desacelerar seus inimigos ou de se teletransportar para onde quiserem.",sd:"Como magos, usam suas magias para atrapalhar seus inimigos e evitar seus ataques.",s:[81,83,82,84,100,92,88,93,85,96,98,86,89,90,87,94,99,95,91,97,1905],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[6] = {sn:"Ecaflip",ln:"A moeda do Ecaflip",ep:1,d:"Ecaflips são guerreiros que podem ser encontrados nos locais mais surpreendentes apostando nos dados... Um bom Ecaflip sempre aposta no tudo ou nada. Mas tenha cuidado, eles podem chegar ao ponto de apostar a vida em um arremesso de dados para vencer uma luta.",sd:"São guerreiros apostadores, que deixam a sorte guiar seus ataques.",s:[102,103,105,109,113,111,104,119,101,107,116,106,117,108,115,118,110,112,114,120,1906],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[7] = {sn:"Eniripsa",ln:"As mãos do Eniripsa",ep:1,d:"Eniripsas são curandeiros. Eles podem curar com uma simples palavra, e usam outras diferentes para curar seus aliados. Porém, também podem usar algumas dessas palavras para machucar seus inimigos. Muitos se tornam caçadores de palavras mágicas, vagando pelo mundo por verbos obscuros ou procurando por linguagens esquecidas.",sd:"Como curandeiros, usam suas magias para restaurar os aliados.",s:[125,128,121,124,122,126,127,123,130,131,132,133,134,135,129,136,137,138,139,140,1907],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,2],[50,3],[150,4],[250,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[8] = {sn:"Iop",ln:"O coração do Iop",ep:1,d:"Iops são guerreiros natos! E não é para menos: os Iops sabem como tirar o melhor de cada arma. Eles precisam  derrotar pelo menos um oponente por dia, em sinal de sua boa saúde. Sua impetuosidade faz deles grandes cavaleiros!",sd:"Como guerreiros, suas habilidades ofensivas permitem causar danos pesados.",s:[142,143,141,144,145,146,147,148,154,150,151,155,152,153,149,156,157,158,160,159,1908],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[100,2],[200,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[20,2],[40,3],[60,4],[80,5]]};
G[9] = {sn:"Cra",ln:"O alcance do Cra",ep:1,d:"A precisão dos arqueiros Cras só é superada pelo seu orgulho! Eles são aliados preciosos no campo de batalha. De longe, disparam suas flechas em qualquer canto desprotegido. Eles sabem muito bem como causar dano!",sd:"São arqueiros especializados em ataques de longa distância.",s:[169,164,161,163,165,172,167,168,162,170,171,166,173,174,176,175,178,177,179,180,1909],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[150,3],[250,4],[350,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[20,2],[40,3],[60,4],[80,5]],b14:[[0,1],[50,2],[100,3],[150,4],[200,5]],b15:[[0,1],[50,2],[150,3],[250,4],[350,5]]};
G[10] = {sn:"Sadida",ln:"As botas do Sadida",ep:1,d:"Sadidas são invocadores que criam poções e venenos aterrorizantes! Transformam arbustos em armas incríveis e são capazes de criar bonecos que podem trazer dor e sofrimento aos oponentes - e essa é uma das coisas favoritas dos Sadidas.",sd:"Como feiticeiros, usam bonecos feitos manualmente para lutar e enfeitiçar seus inimigos.",s:[193,183,200,198,195,182,192,197,189,181,199,191,186,196,190,194,185,184,188,187,1910],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[250,3],[300,4],[400,5]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[100,2],[200,3],[300,4],[400,5]],b14:[[0,1],[20,2],[40,3],[60,4],[80,5]],b15:[[0,1],[100,2],[200,3],[300,4],[400,5]]};
G[11] = {sn:"Sacrier",ln:"O sangue do Sacrier",ep:1,d:"Sacriers são bárbaros que podem aumentar seus poderes em mais de dez vezes se forem feridos! Já que não temem a dor, ficam na linha de frente e são muito apreciados por todos os grupos de aventureiros. Os Sacriers são aliados perfeitos para longas batalhas.",sd:"Como protetores, suportam danos pesados e são extremamente resistentes.",s:[431,432,434,444,449,436,437,439,433,443,440,442,441,445,438,446,447,448,435,450,1911],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,3],[100,4],[150,5]],b11:[[0,1,2]],b12:[[0,3]],b13:[[0,3],[100,4],[150,5]],b14:[[0,3],[100,4],[150,5]],b15:[[0,3],[100,4],[150,5]]};
G[12] = {sn:"Pandawa",ln:"Pandawa",ep:18,d:"Pandawas são Guerreiros xerpas que sabem como extrair o melhor de seus corpos... E dos corpos dos outros! De fato, Pandawas não hesitam em proteger seus aliados evitando que sejam feridos!",sd:"Para os guerreiros Pandawas, os energéticos fazem com que se tornem capazes de carregar seus aliados.",s:[686,692,687,689,690,691,688,693,694,695,696,697,698,699,700,701,702,703,704,705,1912],cc:[[[100,1,5,1]],3,4,1,1,20,50,false,false,[],[1,3,18,42]],b10:[[0,1],[50,2],[200,3]],b11:[[0,1]],b12:[[0,3]],b13:[[0,1],[50,2],[200,3]],b14:[[0,1],[50,2],[200,3]],b15:[[0,1],[50,2],[200,3]]};
