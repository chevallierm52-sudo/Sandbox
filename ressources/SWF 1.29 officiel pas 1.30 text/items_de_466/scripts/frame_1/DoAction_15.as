I.u[6769] = {n:"Farles Stock",t:4,d:"Dieser hübsche Stock hat am oberen Ende drei Zinken, was ihn zu einer hervorragenden Mistgabel macht. Farle nutzt ihn gern, um damit gewaltige Heuhaufen zu bauen, höher noch als die größte Ulme, die einst im Wald von Litneg wuchs. Man sagt, es sei Bruce Boulgour persönlich gewesen, der das für den Bau dieses Stockes benötigte Holz gefällt habe. Im Austausch gegen eine Monsterration von Shikas Haferflocken, die er immer in sich hineinzustopften pflegte, bevor ganze Wälder seiner Axt zum Opfer fielen.",ep:14,g:43,l:80,wd:true,fm:true,w:10,an:12,tw:true,e:[10,5,1,1,45,45,false,true],c:"CS>100&CV>100",s:17,p:16500};
I.u[6770] = {n:"Sansouris",t:15,d:"Diese Sansouris wurde mit dem Besen im Haus der Großmutter aufgescheucht.",ep:1,g:282,l:1,wd:true,fm:true,w:10,p:1};
I.u[6771] = {n:"Thee-Ring",t:9,d:"Dieser Ring wurde noch nie in der Praxis getestet. Es handelt sich dabei um ein Unikat, welches von einem Juweliersgesellen als Probearbeit abgegeben wurde. Er wurde aus einem schlichten Eisenring gefertigt, welcher lange Zeit in eine magische Thee-Mischung getaucht wurde.",ep:1,g:1,l:4,wd:false,fm:true,w:1,p:50};
I.u[6773] = {n:"Halskette Tude",t:1,d:"Diese Halskette ist nach Tude-Art angefertigt worden. Das ist eine der ältesten und einfachsten Herstellungsarten der Juweliere, die heutzutage nur noch Lehrlinge zu Übungszwecken beigebracht wird. Natürlich ist eine solche Kette auch nicht sehr mächtig, das kann man ja auch nicht von ihr erwarten.",ep:1,g:19,l:1,wd:false,fm:true,w:1,p:25};
I.u[6774] = {n:"Farles Holzschuhe",t:11,d:"Diese Holzschuhe wurden aus seltenen Edelhölzern geschnitzt, durch Lederstücke von unvorstellbarem Wert verstärkt und mit magischen Getreidesorten ausgepolstert. Dadurch werden diese leichten, bequemen und sehr eleganten Holzschuhe dem Zahn der Zeit zu trotzen wissen. Viele ehemals liebestolle Abenteurer würden gern gleiches von ihrer Liebsten behaupten können.",ep:9,g:46,l:80,wd:true,fm:true,w:10,s:17,p:16600};
I.u[6775] = {n:"Farles Mantel",t:17,d:"Dieser lange, aus Stoff und Fell zusammengenähte Mantel erlaubte es Farle Ingalsse, die Saat ganzer Felder eine Jahreszeit hinweg zu verstreuen, ohne jemals aufhören oder wieder auffüllen zu müssen. Denn dieser praktische Mantel lässt sich zu einer Art Umhängetasche schier unglaublichen Inhaltes zusammenfalten. Niemand kennt den Erschaffer dieses Meisterwerkes, jedoch soll dieser einer Legende nach sein Handwerk aufgegeben haben, nachdem seine Kunden anfingen ihre Mäntel als Wischmobs zu gebrauchen. Welch trauriges Ende einer langen Karriere.",ep:13,g:70,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6776] = {n:"Farles Arbeitsschurz",t:10,d:"Dieser Lendenschurz diente Farle Ingalsse auch als Arbeitsschürze, wenn er mal wieder Tieren aus seiner Fresssackherde den Hals abschneiden mußte. Dies ist nämlich wirklich eine grausame und undankbare Aufgabe, die er immer sofort und mit kaum verholenem Unbehagen hinter sich bringt.",ep:4,g:61,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6778] = {n:"Farles Strohhut",t:16,d:"Dieser Strohhut wurde aus einer Vielzahl magischer Ähren angefertigt, die ineinander verflochten wurden. Anschließend wurde das Innere von Hand von Shika Ingalsse, Farles Frau, mit verschiedenen Fell- und Stoffstücken ausgepolstert. Nun ist er noch klassischer als das Grobianium und stylischer als eine Dracheischale. Er hat Farle viele hundert Ernten lang vor der Sonnenglut beschützt und seine fröhliche und einfach coole Art unterstrichen. Damit fühlt man sich fast wie der König oder die Königin der Felder.",ep:13,g:67,l:80,wd:true,fm:true,w:10,s:17,p:16500};
I.u[6779] = {n:"Bericht des Sram-Spiones",t:24,d:"Dies ist der Bericht des Spiones Ztiv Oztin, der nur unter großen Schwierigkeiten den Händen Joe Pierlivets entrissen werden konnte.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6780] = {n:"Schwert des Initiaten",t:6,d:"Mit diesem praktischen Schwert fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:96,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6781] = {n:"Stab des Initiaten",t:3,d:"Mit diesem praktischen Stab fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:8,l:1,wd:true,fm:true,w:10,an:11,e:[5,4,2,3,50,50,false,true],p:1};
I.u[6782] = {n:"Stock des Initiaten",t:4,d:"Mit diesem praktischen Stock fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6783] = {n:"Bogen des Initiaten",t:2,d:"Mit diesem praktischen Bogen fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,6,50,50,false,true],p:1};
I.u[6784] = {n:"Dolche des Initiaten",t:5,d:"Mit diesen praktischen Dolchen fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:10,l:1,wd:true,fm:true,w:10,an:13,e:[5,3,1,1,30,50,false,false],p:1};
I.u[6785] = {n:"Hammer des Initiaten",t:7,d:"Mit diesem praktischen Hammer fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:15,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6786] = {n:"Schaufel des Initiaten",t:8,d:"Mit dieser praktischen Schaufel fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,50,50,false,false],p:1};
I.u[6787] = {n:"Ausgefülltes, gültiges Formular",t:80,d:"Dieses kleine Formular enthält den Namen eines Kanditaten, der als Brotlieferant in Frage käme.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW>1499&CA>49",p:0};
I.u[6788] = {n:"Plätzchen",t:24,d:"Diese Plätzchen kommen geradewegs aus dem Ofen. Sie sollen ausgeliefert werden, solange sie noch heiß sind. Und ihr glaubt wirklich, dass ihr da noch Zeit habt, sie eingehend zu untersuchen?",ep:1,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[6789] = {n:"Wald-und-Wiesen-Amulett",t:1,d:"Dieses kleine Amulett blüht im Frühling, trocknet im Sommer, welkt im Herbst und verfault im Winter. Eine tolle Gelegenheit, seine Mode je nach Jahreszeit anzupassen.",ep:1,g:73,l:10,wd:false,fm:true,w:5,s:18,p:500};
I.u[6790] = {n:"Blanko-Formular",t:80,d:"Dieses kleine Formular sieht aus wie ein leeres Blatt Papier. Doch beim Kontakt mit der Haut einer Person zeigt es augenblicklich an, ob der Kanditat als Brotlieferant in Frage käme.",ep:1,g:6,l:1,wd:false,fm:true,w:0,ut:true,p:0};
I.u[6791] = {n:"Ring des Feldhüters",t:9,d:"Mit diesem kleinen Ring um den Finger schafft ihr es, beinahe völlig unbemerkt durch die Felder zu streifen.",ep:1,g:65,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6792] = {n:"Das Planktock der Wiesen",t:4,d:"Dieser Stock in Form einer Blume wurde aus den Blumenwiesen hergestellt, die im Verlaufe furchtbarer Schlachten von grausamen Abenteurern niedergemetzelt wurden. Darum ist nun der ganze Hass und die aufgestaute Wut der armen Pflanzen in diesem lächerlichen Stock gespeichert. Die Hinterhältigsten aller Srams nutzen diese Waffe gern, indem sie Uneingeweihten weismachen, sie würden ihnen einen Blumenstrauß schenken wollen. Einmal in Reichweite, schlagen sie zu und es hagelt dann wohlverdiente Ohrfeigen.",ep:1,g:45,l:10,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,45,50,false,false],c:"CV>20",s:18,p:500};
I.u[6793] = {n:"Thee-Ring",t:9,d:"Dieser Ring wurde noch nie in der Praxis getestet. Es handelt sich dabei um ein Unikat, welches von einem Juweliersgesellen als Probearbeit abgegeben wurde. Er wurde aus einem schlichten Eisenring gefertigt, welcher lange Zeit in eine magische Thee-Mischung getaucht wurde.",ep:1,g:1,l:4,wd:true,fm:true,w:1,p:50};
I.u[6794] = {n:"Wald-und-Wiesen-Stiefel",t:11,d:"Es geht doch nichts über ein paar Stiefel, die aus Teilen von Wiesenblumen gefertigt wurden, um all die ungezogenen wildwuchernden Wiesenblümchen auf euren Feldern damit zu zertreten. Zudem noch entströmt diesen Schuhen daher ständig der feine Geruch frischer Blumen. Schade, dass es von diesen Schuhen keine Version für Unterhosen gibt.",ep:1,g:50,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6795] = {n:"Purpurmantel",t:17,d:"Wenn ihr abends auf der Tanzfläche die Allerschönste im ganzen Land sein wollt, dann ist dieses Gewand genau das Richtige für euch!",ep:1,g:65,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6796] = {n:"Blumiger Gürtel",t:10,d:"Mit diesem farbig-leuchtenden Gürtel mit seinen kleinen Blütenblättern am Rand werdet ihr ohne Probleme als Star-Tänzerin durchgehen. Sehr praktisch bei von vorneherein verloren geglaubten Kämpfen. Es gibt nichts Besseres, um eine Armee von Chafern abzulenken, um die Lage wieder zu euren Gunsten zu ändern.",ep:1,g:64,l:10,wd:true,fm:true,w:5,s:18,p:500};
I.u[6797] = {n:"Blühütchen",t:16,d:"Habt ihr schon immer davon geträumt ein Blumenmädchen zu sein und nach Rosenwasser zu duften? Wenn ja, dann ist dieser seltsame Hut genau das Richtige für euch!",ep:1,g:70,l:10,wd:true,fm:true,w:10,s:18,p:500};
I.u[6798] = {n:"Dzibiblume",t:24,d:"Ihr Duft ist flüchtig, sehr subtil und absolut betörend... aber nur Sadidas kennen das Geheimnis dieser Blumen.",ep:1,g:117,l:1,wd:false,fm:true,w:0,p:1};
I.u[6799] = {n:"Bworkling des Chefs",t:6,d:"Diese Waffe ist nicht nur genauso scharf wie alle anderen Bworklingen, sondern auch noch sehr viel schwerer. Das macht sie zwar unhandlich, zugegeben, aber dafür genügt es in den meisten Fällen, sie einfach nur auf euren Gegner fallen zu lassen, um ihn wie einen gewöhnlichen Trunknyden in zwei Hälften zu spalten. Wenn euer Gegner nicht gleich vor Schmerzen umkommt, dann macht ihm die unerträgliche Schande bestimmt den Garaus... wie euch euer Lachanfall.",ep:1,g:48,l:100,wd:true,fm:true,w:100,an:14,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>200&CA>200&CV>200",s:19,p:25000};
I.u[6800] = {n:"Capa Banala",t:17,d:"Dieser Umhang wurde aus schwarzer Fresssackwolle gefertigt. Er ist zu nichts nutze, außer dazu, schick auszusehen... Und selbst das...",ep:1,g:15,l:1,wd:true,fm:true,w:1,p:1};
I.u[6801] = {n:"Wintermantel",t:17,d:"Speziell für diesen Mantel wurde ein warmes, weiches und wenig wohlriechendes Futter auf einen banalen Mantel oder auch auf eine Capa Banala genäht. Egal ob zum Wärmen eures Rückens oder als Tierfell vor dem Kamin, dieser Mantel wird euch noch richtig ans Herz wachsen mit der Zeit.",ep:1,g:18,l:1,wd:true,fm:true,w:2,p:1};
I.u[6802] = {n:"Ohrwärmer",t:16,d:"Diese Ohrwärmer werden eure abstehenden Segelohren schön warm halten.",ep:1,g:73,l:1,wd:true,fm:true,w:10,p:1};
I.u[6803] = {n:"Dzibiblumenextrakt",t:24,d:"Zu eurem Besten solltet ihr vermeiden, davon zu trinken... Ganz einfach!",ep:1,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[6804] = {n:"Amulett des Bwork-Chefs",t:1,d:"Trotz seines groben Aussehens schlummert in diesem Amulett aus sorgfältig behauenem Feuerstein eine mächtige Magie, die sogar in der Lage sein soll, einen Bwork in eine Prinzessin zu verwandeln, oder umgekehrt – so genau weiß das niemand mehr.",ep:1,g:66,l:100,wd:true,fm:true,w:1,s:19,p:25600};
I.u[6805] = {n:"Armschützer des Bwork-Chefs",t:9,d:"Mit diesem Armschützer könnt ihr eurem Umfeld vortäuschen, dass ihr einen der großen Bwork-Chefs geheiratet und diesen Armschützer als Hochzeitsgeschenk bekommen habt. Bei den abendlichen Gelagen in der örtlichen Taverne könnt ihr damit interessanter erscheinen, wenn ihr mal wieder nichts zu erzählen habt.",ep:1,g:58,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6806] = {n:"Holzsplitter",t:24,d:"Dieser Holzsplitter stammt von einem erst kürzlich erbauten und wahrscheinlich rot gestrichenen Gebäude.",ep:1,g:246,l:1,wd:false,fm:true,w:0,p:1};
I.u[6807] = {n:"Stiefel des Bwork-Chefs",t:11,d:"Von Weitem sehen diese Stiefel aus wie klassische Bwork-Stiefel. Von Nahem ebenfalls. Dennoch sind dies die Schuhe eines Bwork-Chefs. Darum sind sie noch haltbarer, noch mächtiger und vor allem noch übelriechender!",ep:1,g:44,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6808] = {n:"Abgerissener Stofffetzen",t:24,d:"Dieser weiße Stofffetzen ist sowohl weich, als auch voller Flecken.",ep:1,g:247,l:1,wd:false,fm:true,w:0,p:1};
I.u[6809] = {n:"Vage Personenbeschreibung",t:24,d:"Bei der betroffenen Person geht es um ein kleines, dunkel gekleidetes Mädchen mit blonden Haaren.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6810] = {n:"Bezirksbericht",t:24,d:"Dieser Bericht führt an, dass es am Tage des Hausdiebstahles keinerlei besondere Vorkommnisse gegeben habe. Die einzige Ausnahme sei die Sichtung eines Halsabschneiders gewesen, und zwar in der Nacht des Vorfalles.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6811] = {n:"Umhang des Bwork-Chefs",t:17,d:"Dieser zerrissene und verlotterte Umhang wird allen sofort zeigen, dass ihr ein großer Bwork-Krieger seid. Außerdem ist er ideal, um die Großväterchen und Großmütterchen des Dorfes in Angst und Schrecken zu versetzen. Eine Kampfgefährtin damit zu verführen, könnte sich hingegen als schwierig erweisen, es sei denn, ihr hättet unter dem Umhang nichts anderes an. Damit bleibt euch immernoch der Vorteil, weiterhin die Großväterchen und Großmütterchen des Dorfes in Angst und Schrecken zu versetzen.",ep:1,g:60,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6812] = {n:"Schlüpfer des Bwork-Chefs",t:10,d:"Es bedarf keiner Worte, um diesen violetten Lederschlüpfer zu beschreiben. Selbst wenn er das einzige Kleidungstück ist, was ihr am Leibe tragt, seht ihr immer noch wie ein Star aus. Vorausgesetzt er passt euch und fällt nicht wieder beim Seilspringen herunter.",ep:1,g:59,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6813] = {n:"Helm des Bwork-Chefs",t:16,d:"Wenn ihr wirklich wie ein grober Schwackkopf aussehen wollt, dann ist dieser Helm genau das richtige für euch! Mit etwas Glück bemerkt keiner den Unterschied mehr, wenn ihr den Helm irgendwann auszieht.",ep:1,g:65,l:100,wd:true,fm:true,w:50,s:19,p:25600};
I.u[6814] = {n:"Bündel Holzstücke",t:24,d:"Dieses Bündel Holzstücke formt ein kleines kuschliges Nest, ideal für Piepmätze.",ep:1,g:248,l:1,wd:false,fm:true,w:0,p:1};
I.u[6815] = {n:"Eli Bells Spritze",t:24,d:"Eli Bell hat euch diese Spritze gegeben, damit ihr damit Radlu Minite, dem Schattenbergmann, eine Blutprobe entnehmt.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6816] = {n:"Blutprobe",t:24,d:"Es ist euch endlich gelungen, Radlu Minite eine Blutprobe abzunehmen. Sehr appetitlich!",ep:1,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[6817] = {n:"Amulett des Chef-Crocodylls",t:1,d:"Dieses erstaunliche Amulett wurde in Wirklichkeit aus einem Reptilpanzer gefertigt, in welchen mehrere Edelsteine eingefasst wurden. Das macht es zu einem echten Schmuckstück, nicht gerade leicht zu tragen, aber dafür auch noch äußerst resistent. Euer Hals wird damit 100%ig gegen Vampirangriffe geschützt, sowie vor Knutschflecken etwas zu unternehmungsfreudigen Dorfbewohnerinnen.",ep:4,g:67,l:70,wd:true,fm:true,w:100,s:20,p:12700};
I.u[6818] = {n:"Abgeschnittene Dämonenrose",t:35,d:"Diese ehemalige Dämonenrose ist  DAS himmlische Geschenk für eure Liebste. Und solltet ihr dennoch nur ein müdes Lächeln von ihr ernten, so könnt ihr daraus immer noch eine leckere Marmelade kochen.",ep:1,g:118,l:1,wd:false,fm:true,w:1,p:1};
I.u[6819] = {n:"Armschützer des Chef-Crocodylls",t:9,d:"Dieser Armschützer ähnelt seltsamerweise einem Handschuh, und trotzdem handelt es sich um einen Armschützer. Manchmal trügt der Schein eben.",ep:4,g:59,l:70,wd:true,fm:true,w:20,s:20,p:12800};
I.u[6820] = {n:"Heilkraut",t:24,d:"Dieses grasähnliche Gewächs ist die Hauptzutat für einen alten Alchimistenheiltrank. Leider kennt heute niemand mehr das Rezept dazu. Daher zieht man es vor, stattdessen lieber Klee zu verwenden. Letzterer verursacht nämlich kein Jucken im ganzen Gesicht, was, wie ihr sicher zugeben werdet, doch ein großer Vorteil ist.",ep:1,g:103,l:1,wd:true,fm:true,w:0,p:1};
I.u[6821] = {n:"Klinge des Chef-Crocodylls",t:6,d:"Diese aus kleinen Stückchen eines Chef-Crocodylls gefertigte Klinge wird euch gute Dienste leisten, vorausgesetzt ihr seid schön, flink, intelligent und stark genug, um sie zu führen. Mit ein wenig Glück werdet ihr bestimmt jemanden finden, der sie euch gegen ein kleines hölzernes Schwert eintauschen wird. Nicht traurig sein!",ep:4,g:49,l:70,wd:true,fm:true,w:100,an:14,e:[12,6,1,1,40,40,false,false],c:"CA>150&CC>150&CV>100",s:20,p:12800};
I.u[6822] = {n:"Reanimierspritze",t:24,d:"Diese Spritze enthält ein Serum, welches so mächtig ist, dass es selbst Tote aufwecken könnte. Es heißt übrigens, dass sich der berüchtigte Untote Hyrkul regelmäßig eine Dosis des Mittels verabreicht. Womit die Wirksamkeit des Serums bewiesen wäre.",ep:1,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[6823] = {n:"Rein pflanzlicher Trank",t:24,d:"Dieser absolut übelriechende Trank könnte selbst einen Sadida aus seinem Schlummer erwecken... jedenfalls beinahe... Das heißt, wenn es sich um einen jungen Sadida handelt, der eh gleich aufgewacht wäre.",ep:1,g:500,l:1,wd:true,fm:true,w:0,p:1};
I.u[6824] = {n:"Flüchtiger Heilstein",t:24,d:"Dieser Heilstein verliert sehr schnell seine Kraft. Es ist daher notwendig, den Stein mit einem Schutzmantel aus strahlungsabsorbierendem Metall zu umgeben, um die Wirksamkeit weiterhin zu erhalten. Standardamulette sind heutzutage beinahe genauso wirksam, überall erhältlich und zudem noch sehr viel günstiger.",ep:1,g:104,l:1,wd:false,fm:true,w:0,p:1};
I.u[6825] = {n:"Klauenpantoffeln des Chef Crocodylls",t:11,d:"Diese wunderschönen Pantoffeln aus Haut und Schuppen des Chef Crocodylls besitzen an allen Extremitäten scharfe Krallen. Hütet euch daher, wenn ihr eurer Liebsten mal wieder auf den Fuß tretet, ihr könntet ihr dadurch nämlich leicht ihre kleinen Spitzenstrümpfe aus Tabi-Wolle zerreißen.",ep:4,g:45,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6826] = {n:"Eingefasster Heilstein",t:24,d:"Der flüchtige Heilstein wurde sorgfältig in ein Amulett aus seltenen Metallen eingefasst. Allein jenes in der Hand zu halten, bewirkt bereits ein Gefühl des Wohlbehagens, denn die Müdigkeit ist auf einmal wie weggeblasen und der Geist befreit. Außerdem sieht man euch im Dunkeln damit. Sehr praktisch!",ep:1,g:105,l:1,wd:false,fm:true,w:0,p:1};
I.u[6827] = {n:"Joe Pierlivets Brief",t:24,d:"Joe hat euch diesen Brief anvertraut, damit ihr ihn bei seinem guten Freund Howard, dem Sinusianer, abgebt. Dieser ist ein Iop und ähm... wie soll man sagen... er ist eben ein typischer Iop!",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6828] = {n:"Schwertheft",t:24,d:"Dieses Heft wird euch zwar nicht in einen Meister des Schwertkampfes verwandeln, aber es könnte euch vielleicht doch noch einmal nützlich werden.",ep:1,g:97,l:1,wd:false,fm:true,w:0,p:1};
I.u[6829] = {n:"Neugeschmiedetes Schwert",t:24,d:"Dieses Schwert wurde gerade frisch geschmiedet.",ep:1,g:98,l:1,wd:false,fm:true,w:0,p:1};
I.u[6830] = {n:"Kleiner Schulranzen des Chef-Crocodylls",t:81,d:"Auch in Amakna ist der Schulanfang oftmals eine harte Bewährungsprobe für die Kleinen. Besonders für junge Iops ist er ein Synonym für einen wahrlichen Leidensweg, der mit unüberwindbaren Zerreißproben gespickt ist. Ermutigt sie daher mit diesem wunderschönen Schulranzen aus der Haut und den Schuppen des Chef-Crocodylls, dessen inneres ganz mit Pelz gefüttert ist.",ep:14,g:58,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6831] = {n:"Gürtel des Chef-Crocodylls",t:10,d:"Dieser Gürtel ist zwar zu wenig biegsam, um als Peitsche zu dienen, doch dafür funkelt er hübsch, da er mit kleinen polierten Edelsteinchen überzogen ist. Er kann auch problemlos auf konventionnelle Art genutzt werden, beispielsweise um zu verhindern, dass euch die Gamaschen über die Knie rutschen.",ep:4,g:60,l:70,wd:true,fm:true,w:20,s:20,p:12700};
I.u[6832] = {n:"Bierlieferant",t:32,d:"Der Bierlieferant ist mindestens genauso wichtig wie der Sicherheitswachmann, der die Bank bewacht. Allerdings ist Ersterer noch sehr viel grantiger und hässlicher.",ep:1,g:15,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6833] = {n:"Seltsamer Kamabeutel",t:24,d:"Diese Kama scheinen aus einer anderen Zeit zu stammen. Man sollte sie schnell einschmelzen, bevor sie sich dazu entschließen, wieder in ihr Zeitalter zurückzukehren.",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6834] = {n:"Maske des Chef-Crocodylls",t:16,d:"Wenn ihr den Traum wahr werden lassen wollt, wie ein Crocodyll auszusehen, ohne gleichzeitig auch zu einem Crocodyll zu werden, dann könnt ihr dies endlich tun – dank dieser tollen Maske. Doch wenn ihr meint, vor euren Freunden prahlen zu können, es sei euch gelungen, dieses Crocodyll mit eigenen Händen zu erwürgen, um daraus die Maske zu fertigen, so vergesst es. Niemand, außer vielleicht ihr, selbst wird solche Märchen glauben.",ep:4,g:66,l:70,wd:true,fm:true,w:20,s:20,p:12600};
I.u[6835] = {n:"Umgeformter Metallbarren",t:24,d:"Der seltsame Kamabeutel wurde von Eli Bell geschickterweise zu einen Metallbarren umgeformt. Daraus lässt sich nun ein Schwert schmieden.",ep:1,g:241,l:1,wd:true,fm:true,w:0,p:1};
I.u[6836] = {n:"Rohform des Schwertes",t:24,d:"Dieses Schwert entstammt den starken Händen Zwehfingas. Dennoch ist es anscheinend noch nicht widerstandsfähig genug für euch. Doch der Alchimist Eli Bell könnte euch in dieser Sache eventuell weiterhelfen.",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6837] = {n:"Hüpfendes Schwert",t:24,d:"Dieses Schwert ist wie für euch gemacht. Es ist leicht und absolut tödlich. Allerdings fehlt noch das i-Tüpfelchen... irgendetwas Ecaflippisches!",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6838] = {n:"Rohform des Feuerschwertes",t:24,d:"Das Mondwasser scheint gut gewirkt zu haben. Das Schwert ist nun nahezu unzerstörbar, allerdings fehlt noch das i-Tüpfelchen... irgendetwas Ecaflippisches!",ep:1,g:98,l:1,wd:true,fm:true,w:0,p:1};
I.u[6839] = {n:"Schwert des Yinglings",t:6,d:"Diese Waffe mit dem Herstellungsstempel von Miau Miau höchstpersönlich wird euch zu einem legendären Ecaflip machen... vielleicht.",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=0",p:1};
I.u[6840] = {n:"Schwert des Yangurus",t:6,d:"Diese Waffe mit dem Herstellungsstempel von Miau Miau höchstpersönlich wird euch zu einem legendären Ecaflip machen... vielleicht.",ep:1,g:18,l:1,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"PG=6&PS=1",p:1};
I.u[6841] = {n:"Bärenpelz",t:55,d:"Dieser interessante Pelz riecht bärenstark. Damit könnt ihr sicherlich der Mehrheit der weiblichen Wesen völlig den Kopf verdrehen.",ep:1,g:121,l:22,wd:true,fm:true,w:1,p:500};
I.u[6842] = {n:"Bärenzahn",t:47,d:"Dieser alte Zahn gehörte einem alten Bären. Besser gesagt, einem alten, beschworenen Bären. Damit ist das, was ihr hier grade in der Hand haltet, ein alter, beschworener Zahn! Was ein subtiler, aber wichtiger Unterschied ist.",ep:1,g:432,l:22,wd:true,fm:true,w:1,p:500};
I.u[6843] = {n:"Bärenknochen",t:47,d:"Dieser spitze Knochen ist im Laufe des furchtbaren Kampfes zwischen dem Bärenmann und einem von ihm selbst beschworenen Bären zerbrochen. Aufgrund eurer wiederholten Angriffe kam niemand mehr dazu, die Tatze des armen, in einer Blutlache am Boden verendenden Bären zu schienen. Kurz darauf war dieser auch schon in Fresssackspeichel ertränkt, gehäutet und aufgeschnitten worden. Keine Gnade für beschworene Kreaturen.",ep:1,g:48,l:22,wd:true,fm:true,w:1,p:500};
I.u[6844] = {n:"Bärenhaare",t:54,d:"Manchmal beschließt der Bärenmann, einen seiner beschworenen Bären zu epilieren. Zum Zeitvertreib. Anschließend fertigt er aus diesen Haaren Unterwäsche gehobener Qualität für einsame Jäger auf der Suche nach dem gewissen Kick... und starkem Geruch.",ep:1,g:195,l:22,wd:true,fm:true,w:1,p:500};
I.u[6845] = {n:"Bärenfell",t:59,d:"Dieses raue und völlig haarlose Fell ist die Frucht einer langen Epilier-Behandlung mit heißem Wachs und glühenden Eisen. Wundert euch also nicht, wenn es an manchen Stellen angekokelt ist.",ep:1,g:35,l:22,wd:true,fm:true,w:1,p:500};
I.u[6846] = {n:"Kristallphiole aus Opal von Anthir",t:24,d:"Diese Phiole sieht auf dem ersten Blick wie jede andere hundsgewöhnliche Opal-Kristallphiole aus. Allerdings stecken in ihr mysteriöse Kräfte, die nur Xelors erwecken können.",ep:1,g:99,l:1,wd:false,fm:true,w:0,p:1};
I.u[6847] = {n:"Sack voller Epysskörner",t:24,d:"Dieses seltene Getreidekorn ist nur zu Wenigem gut. Wer hat da gerade gesagt, \"genau wie ein Xelor\"?!",ep:1,g:243,l:1,wd:false,fm:true,w:0,p:1};
I.u[6848] = {n:"Verziertes Holzstück",t:24,d:"Dieses Holzstück ist von durchschnittlicher Qualität.",ep:1,g:100,l:1,wd:false,fm:true,w:0,p:1};
I.u[6849] = {n:"Schachtel Antischnuzapfs",t:24,d:"Die einzigen Wesen, die das Geheimnis dieser Schachtel kennen, sind die Enutrofs. Vielleicht, weil niemand anderes daran Interesse hat, über all die Dinge Bescheid zu wissen, die sie so ausgraben... Aber: über welch Geheimnisse sie manchmal stolpern!!!",ep:1,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[6850] = {n:"Pizzahh",t:24,d:"Dies ist eine der kulinarischen Spezialitäten von Astrub. Die Pizzahh hat den Vorteil, dass sie jederzeit an jedem Ort der Welt gegessen werden kann, außer eventuell im Metzgerviertel, da der Gestank dort einfach unerträglich ist.",ep:1,g:107,l:1,wd:false,fm:true,w:0,p:1};
I.u[6852] = {n:"Jahrmarktsteddy",t:24,d:"Diesen Teddy hat Kate J. Zenhammer auf dem Jahrmarkt des Trools gewonnen.",ep:1,g:151,l:1,wd:true,fm:true,w:0,p:1};
I.u[6853] = {n:"Arashholz",t:24,d:"Diese Bäume haben die Eigenschaft, völlig gerade zu wachsen – gerade wie ein Stock. Dies ist sehr praktisch, um sie zu lagern...",ep:1,g:100,l:1,wd:true,fm:true,w:0,p:1};
I.u[6854] = {n:"Blaue Larvenhaut",t:24,d:"Diese gummiartige Haut wurde einer armen wehrlosen blauen Larve bei lebendigem Leib abgezogen.",ep:1,g:101,l:1,wd:false,fm:true,w:0,p:1};
I.u[6855] = {n:"Kleiner Bogen von Enileda",t:24,d:"Dieser Bogen entstammt den geschickten Händen der Bogenschnitzerin Enileda und ist eine Sonderanfertigung.",ep:1,g:244,l:1,wd:true,fm:true,w:0,p:1};
I.u[6856] = {n:"Schnippeldi Dämonenrosen",t:20,d:"Dank ihrer speziellen Form kann man mit dieser Schere problemlos die Stängel von Dämonenrosen jeglicher Größe durchtrennen, ohne dabei deren Blütenblätter zu beschädigen. Und das selbst dann, wenn sich die Rose gerade in eurer Wade festgebissen hat.",ep:1,g:22,l:1,wd:true,fm:true,w:2,an:13,e:[5,3,1,1,20,20,false,false],p:1};
I.u[6857] = {n:"Astrub-Bier",t:37,d:"Dieses klassische Bier fördert die Entwicklung eurer Bauchmuskeln. So werdet ihr endlich euren waschechten Brettbauch los, der euch so geplagt hat und könnt stolz euren waschechten Bierbauch präsentieren.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:4};
I.u[6858] = {n:"Ausgefülltes, ungültiges Formular",t:80,d:"Dieses kleine Formular enthält den Namen eines Kanditaten, der sich leider nicht zum Brotlieferanten eignet. Ein kleiner roter Fleck zeigt an, dass er entweder nicht genug Stärke, oder nicht genug Flinkheit besitzt, um diese Aufgabe zu erfüllen.",ep:1,g:6,l:1,wd:false,fm:true,w:0,c:"PW<1500|CA<50",p:0};
I.u[6859] = {n:"Schere",t:24,d:"Diese kleine Schere macht optisch nicht viel her. Aber wenn man sie richtig einsetzt, bemerkt man, wie scharf sie ist.",ep:1,g:150,l:1,wd:true,fm:true,w:0,p:1};
I.u[6862] = {n:"Handbuch des Bären",t:24,d:"Dieses schöne, gebundene Buch erläutert, wie der Bärenmann dazu kam, seinen ersten Bären zu beschwören. Wahnsinn!",ep:1,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[6863] = {n:"Helm der Söldner Astrubs",t:16,d:"Dies ist der Helm der Söldner von Astrub.",ep:1,g:72,l:1,wd:false,fm:true,w:10,p:1};
I.u[6864] = {n:"Blüte der Schattenrose",t:24,d:"Die Blüte der Schattenrose ist so dunkel, dass selbst ihr Schatten dagegen noch zu strahlen scheint.",ep:2,g:106,l:23,wd:true,fm:true,w:0,p:1};
I.u[6865] = {n:"Notiz",t:24,d:"\"Lieferung: Treffen am Waldrand\"",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6866] = {n:"Fetzen eines Umhangs",t:24,d:"Dies ist ein Fetzen des Umhangs, den einer eurer Angreifer getragen hat. Obwohl sie die Überraschung auf ihrer Seite hatten, ist es euch gelungen, ihnen eine tüchtige Abreibung zu verpassen.",ep:1,g:249,l:1,wd:false,fm:true,w:0,p:1};
I.u[6867] = {n:"Abholnotiz",t:24,d:"Damit ihr die Uhrzeit, zu der ihr den Vhan abholen sollt, nicht vergesst, habt ihr sie auf ein Stück Papier geschrieben.",ep:1,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[6868] = {n:"Brett aus Kastanienholz",t:95,d:"Dieses Brett aus Kastanienholz wird manchmal noch im Hausbau eingesetzt, doch die meiste Zeit nutzt man es zum Bau von Fliegenfallen.",ep:1,g:1,l:10,wd:true,fm:true,w:10,p:20};
I.u[6869] = {n:"Kate J. Zenhammer",t:32,d:"Das junge Mädchen hat vergessen, wo ihr Zuhause ist, darum ist es an euch, sie zurück zu geleiten...",ep:1,g:14,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6870] = {n:"Knöcherner Mark von Kainsdaf Ürmisch",t:32,d:"Der knöcherne Mark von Kainsdaf Ürmisch befindet sich nun in eurem sicheren Gewahrsam. Jetzt müsst ihr ihn nur noch zum Gefängnis eskortieren und dort abliefern.",ep:13,g:8,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6871] = {n:"Frakassurus Leukocytinas",t:32,d:"Frakassurus Leukocytinas befindet sich nun in eurem sicheren Gewahrsam. Jetzt müsst ihr ihn bloß noch zum Gefängnis eskortieren und dort abliefern.",ep:1,g:11,l:1,wd:false,fm:true,w:0,m:true,p:1};
