I.u[7250] = {n:"Akwadala-Amulett",t:1,d:"Einzig die Bewohner Akwadalas durften dieses Amulett tragen, welches eines der wichtigsten Teile ihrer traditionellen Tracht darstellt. Bei näherem Hinsehen fragt man sich allerdings warum.",ep:18,g:79,l:41,wd:true,fm:true,w:2,s:34,p:5050};
I.u[7251] = {n:"Terradala-Amulett",t:1,d:"Einzig die Bewohner Teradalas durften dieses Amulett tragen, welches eines der wichtigsten Teile ihrer traditionellen Tracht darstellt. Bei näherem Hinsehen fragt man sich allerdings warum.",ep:18,g:80,l:80,wd:true,fm:true,w:10,s:36,p:16550};
I.u[7252] = {n:"Feudala-Amulett",t:1,d:"Einzig die Bewohner Feudalas durften dieses Amulett tragen, welches eines der wichtigsten Teile ihrer traditionellen Tracht darstellt. Bei näherem Hinsehen fragt man sich allerdings warum.",ep:18,g:81,l:91,wd:true,fm:true,w:10,s:37,p:21225};
I.u[7253] = {n:"Aerdala-Amulett",t:1,d:"Einzig die Bewohner Aerdalas durften dieses Amulett tragen, welches eines der wichtigsten Teile ihrer traditionellen Tracht darstellt. Bei näherem Hinsehen fragt man sich allerdings warum.",ep:18,g:82,l:62,wd:true,fm:true,w:10,s:35,p:10000};
I.u[7254] = {n:"Akwadala-Stecken",t:4,d:"Dieser Stecken dient dazu, jungen und übermütigen Pandawas eine Abreibung zu verpassen. Drei Schläge auf die Finger, fünfzehn auf den Hintern, sechzig auf den Kopf, zwei in die Augen und schon ist die Lektion gelernt.",ep:18,g:61,l:43,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,false],c:"CC>50",s:34,p:5040};
I.u[7255] = {n:"Teradala-Axt",t:19,d:"Diese Axt war von Anfang an dazu gemacht, Lebewesen zu zerteilen. Daher solltet ihr vorsichtig mit ihr umgehen. Eine falsche Bewegung und euch fehlt eine Hälfte.",ep:18,g:32,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],s:36,p:17635};
I.u[7256] = {n:"Aerdala-Dolche",t:5,d:"Diese Dolche sind scharf wie die Krallen eines WuWulfs und machen aus euch einen ausgezeichneten Meuchelmördergesellen.",ep:18,g:51,l:62,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>50",s:35,p:10105};
I.u[7257] = {n:"Feudala-Säbel",t:6,d:"Dieser Säbel wurde von Alfredo Bioschreck höchstpersönlich geschmiedet. Man sagt, er sei eines seiner letzten Werke vor seinem Karrierewechsel in die Gastronomie gewesen. Auf jeden Fall handelt es sich um ein echtes Sammlerstück.",ep:18,g:64,l:76,wd:true,fm:true,w:1,an:14,e:[5,6,1,1,50,50,false,false],c:"CI>200&CA>60",s:37,p:14900};
I.u[7258] = {n:"Pandikaze-Haar",t:54,d:"Diese extrem feinen Haare könnten glatt vom Hinterteil eines Sadidettchens stammen. Doch leider Fehlanzeige.",ep:16,g:556,l:40,wd:true,fm:true,w:1,p:10};
I.u[7259] = {n:"Pandikaze-Pelz",t:55,d:"Dieses Pelzstück ist trotz der furchtbaren Schläge, die ihr im Kampf dem Pandikaze zugefügt habt, noch nahezu unversehrt geblieben.",ep:18,g:124,l:40,wd:true,fm:true,w:1,p:10};
I.u[7260] = {n:"Pandikaze-Haut",t:59,d:"Diese Haut ist von einem leichten Flaum bedeckt. Leicht wie die Härchen in der Achselhöhle einer Eniripsa, jedoch ohne deren schlechten Geruch.",ep:18,g:40,l:40,wd:true,fm:true,w:2,p:10};
I.u[7261] = {n:"Magisches Bambusholz",t:38,d:"Dieses außergewöhnliche Bambusstück ist von mächtiger Magie erfüllt, die es ihm sogar ermöglicht, sich fortzubewegen. Nach einer alten Legende eines der örtlichen Stämme soll das magische Bambusholz sogar an die Türen von Behausungen klopfen, wenn deren Bewohner gerade ausschweifenden Tätigkeiten nachgehen. Aus diesem Grunde befestigen es manche Pandawas mit einer Kette an der Wand, bevor sie zu Bett gehen.",ep:18,g:670,l:220,wd:true,fm:true,w:5,p:20};
I.u[7262] = {n:"Bulbiflora-Wurzel",t:98,d:"Diese Bulbiflora-Wurzel ist anders als alle anderen. Sie kann beispielsweise sehr lange gekaut werden, ohne die Zähne anzugreifen. Jedoch hat sie leider im Gegensatz zu richtigen Süßigkeiten überhaupt keinen Geschmack.",ep:18,g:142,l:26,wd:true,fm:true,w:2,p:20};
I.u[7263] = {n:"Bulbusch-Wurzel",t:98,d:"Diese Bulbusch-Wurzel ist anders als alle anderen. Sie kann beispielsweise sehr lange gekaut werden, ohne die Zähne anzugreifen. Jedoch hat sie leider im Gegensatz zu richtigen Süßigkeiten überhaupt keinen Geschmack.",ep:18,g:143,l:42,wd:true,fm:true,w:2,p:20};
I.u[7264] = {n:"Bulbambus-Wurzel",t:98,d:"Diese Bulbambus-Wurzel ist anders als alle anderen. Sie kann beispielsweise sehr lange gekaut werden, ohne die Zähne anzugreifen. Jedoch hat sie leider im Gegensatz zu richtigen Süßigkeiten überhaupt keinen Geschmack.",ep:18,g:145,l:67,wd:true,fm:true,w:2,p:20};
I.u[7265] = {n:"Bulbig-Wurzel",t:98,d:"Diese Bulbig-Wurzel ist anders als alle anderen. Sie kann beispielsweise sehr lange gekaut werden, ohne die Zähne anzugreifen. Jedoch hat sie leider im Gegensatz zu richtigen Süßigkeiten überhaupt keinen Geschmack.",ep:18,g:144,l:150,wd:true,fm:true,w:2,p:20};
I.u[7266] = {n:"Bulbiflora-Blüte",t:35,d:"Diese Blüte wächst nur an einem einzigen Ort – nämlich auf dem Kopf von Bulbiflorae. Versucht es also gar nicht erst, sie auf dem eurem anzupflanzen, dafür mangelt es an allen wesentlichen Inhaltsstoffen.",ep:18,g:119,l:26,wd:true,fm:true,w:1,p:10};
