I.u[6894] = {n:"Übermächtige Kampfmaunzmiez (SL)",t:18,d:"Diese übermächtige Kampfmaunzmiez ist ein Ausbund an Übermächtigkeit und damit sehr beeindruckend. Leider ist sie und ihre Übermächtigkeit den Spielleitern vorbehalten.",ep:1,g:1,l:1,wd:false,fm:false,w:10,c:"PX=3|PX=5",p:1};
I.u[6895] = {n:"Kleine Kampfmaunzmiez (SL)",t:18,d:"Ein wenig weniger übermächtig als die übermächtige Kampfmaunzmiez, aber immer noch sehr übermächtig. Diese kleine Kampfmaunzmiez ist der ideale der Vertraute für jeden wahren Spielleiter. Doch ist sie leider auch sehr schmutzanziehend. Drum vergesst nicht, sie von Zeit zu Zeit mit kochenden Wasser abzuwaschen, damit sie ihren herrlichen Farbton behält.",ep:1,g:9,l:1,wd:false,fm:true,w:10,p:1};
I.u[6896] = {n:"Maunzmientelligenz",t:18,d:"...",ep:1,g:1,l:1,wd:false,fm:true,w:10,p:1};
I.u[6897] = {n:"Feder eines blauen Piepmatzes",t:53,d:"Diese kleine Schwanzfeder wurde einem kleinen Piepmatz bei lebendigem Leib ausgerissen, ohne dass er etwas Unrechtes getan hätte. Die Welt ist schlecht...und ungerecht.",ep:1,g:114,l:1,wd:true,fm:true,w:1,p:10};
I.u[6898] = {n:"Feder eines violetten Piepmatzes",t:53,d:"Diese kleine Schwanzfeder wurde einem kleinen Piepmatz bei lebendigem Leib ausgerissen, ohne dass er etwas Unrechtes getan hätte. Die Welt ist schlecht...und ungerecht.",ep:1,g:115,l:1,wd:true,fm:true,w:1,p:10};
I.u[6899] = {n:"Feder eines grünen Piepmatzes",t:53,d:"Diese kleine Schwanzfeder wurde einem kleinen Piepmatz bei lebendigem Leib ausgerissen, ohne dass er etwas Unrechtes getan hätte. Die Welt ist schlecht...und ungerecht.",ep:1,g:116,l:1,wd:true,fm:true,w:1,p:10};
I.u[6900] = {n:"Feder eines roten Piepmatzes",t:53,d:"Diese kleine Schwanzfeder wurde einem kleinen Piepmatz bei lebendigem Leib ausgerissen, ohne dass er etwas Unrechtes getan hätte. Die Welt ist schlecht...und ungerecht.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:10};
I.u[6902] = {n:"Feder eines gelben Piepmatzes",t:53,d:"Diese kleine Schwanzfeder wurde einem kleinen Piepmatz bei lebendigem Leib ausgerissen, ohne dass er etwas Unrechtes getan hätte. Die Welt ist schlecht...und ungerecht.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[6903] = {n:"Feder eines rosa Piepmatzes",t:53,d:"Diese kleine Schwanzfeder wurde einem kleinen Piepmatz bei lebendigem Leib ausgerissen, ohne dass er etwas Unrechtes getan hätte. Die Welt ist schlecht...und ungerecht.",ep:1,g:119,l:1,wd:true,fm:true,w:1,p:10};
I.u[6904] = {n:"Gebrauchte Bworker-Schutzvorkehrung",t:15,d:"Liebe richtet manchmal mehr Schaden an, als jeder Krieg. Doch dies braucht man dem Bworker nicht mehr zu sagen, denn er weiß es selbst am Besten.",ep:1,g:714,l:200,wd:true,fm:true,w:1,p:1000};
I.u[6905] = {n:"Bwork-Überraschungspaket",t:89,d:"Das Öffnen dieses Paketes erfordert vom Träger sehr viel Ruhe und Sorgfalt, denn dies wirkt sich direkt auf die Qualität seines Inhalts aus.",ep:1,g:42,l:1,wd:true,fm:true,w:4,u:true,p:100};
I.u[6906] = {n:"Amtsschriftrolle zum Söldnerneophyten",t:14,d:"Diese Schriftrolle ist nichts anderes als das Formular zum Beitritt zu den Söldner. Die betroffene Person wird als Neophyt in das Clan-Register eingetragen.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6907] = {n:"Neutralizator",t:14,d:"Der Neutralizator ist in der Lage, einem Charakter wieder die neutrale Gesinnung zurückzugeben.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6908] = {n:"Keiler-Gürtel",t:10,d:"Mit diesem Lendenschurz auf den Lenden seid ihr gut gerüstet für all die furchtbaren Gefahren des Alltages. Zudem ist er so haarig und so elegant, dass ihr den ganzen Tag lang an eure Liebste denken werdet. Herrlich, nicht?",ep:1,g:75,l:18,wd:true,fm:true,w:2,s:21,p:1050};
I.u[6909] = {n:"Keilerpfotentreter",t:11,d:"Diese Schuhe sind einfach perfekt dazu geeignet, durch den Schlamm zu waten oder den Parkettboden zu zerkratzen. Allerdings ist es grundsätzlich untersagt, Tanzflächen damit zu betreten.",ep:1,g:51,l:22,wd:true,fm:true,w:2,s:21,p:1525};
I.u[6910] = {n:"Armband des Keilers",t:9,d:"Dieses Band wurde früher um die Beine von brünftigen Keilern gebunden, damit die Züchter sie leichter von anderen unterscheiden konnten. Heute tragt ihr nun dieses Band. Das lässt Spielraum für alle möglichen Interpretationen...",ep:1,g:73,l:19,wd:true,fm:true,w:2,s:21,p:1200};
I.u[6911] = {n:"Arachnoton",t:9,d:"Dieser lächerliche kleine Ring mag euch vielleicht dabei helfen, eure Arachneeophobie zu bekämpfen.",ep:1,g:76,l:5,wd:true,fm:true,w:1,s:22,p:275};
I.u[6912] = {n:"Arachnoschurz",t:10,d:"Dieser herrliche Lendenschurz wurde aus alten, halbverwesten Arachneenresten angefertigt. Das erklärt auch, warum er manchmal wieder zum Leben erwacht und euch mit perversem Vergnügen an alle Stellen beißt, die er erreichen kann. Was für schreckliche Biester!",ep:1,g:73,l:6,wd:true,fm:true,w:1,s:22,p:305};
I.u[6913] = {n:"Arachnamaska",t:16,d:"Mit dieser Maske vorm Gesicht ähnelt ihr von weitem einer wilden Arachnee. Doch damit erschreckt ihr bestenfalls alterschwache Moskitos.",ep:1,g:83,l:6,wd:true,fm:true,w:2,s:22,p:305};
I.u[6914] = {n:"Arachneewehweh",t:19,d:"Eine seltsame Tatsache, die nicht jedem bekannt sein wird, ist, dass Arachneen bloß vier haarige Klauen besitzen. Also braucht man nur vier Schläge statt acht, um eine Arachnee in ein Arachnotrunk zu verwandeln. Toll, was?",ep:1,g:31,l:8,wd:true,fm:true,w:5,an:17,e:[5,4,1,1,50,50,false,false],s:22,p:600};
I.u[6915] = {n:"Moski-Toring",t:9,d:"Dieser Ring ist so leicht, dass ihr damit zu einem regelrechten Fingerakrobaten avancieren könnt. Das ist sehr praktisch, wenn ihr um 10x kleinere Gegner erniedrigen wollt, indem ihr ihnen mit dem Daumen den Kopf zermalmt.",ep:1,g:71,l:21,wd:true,fm:true,w:2,s:23,p:1400};
I.u[6916] = {n:"Kleiner Moskitosack",t:81,d:"Diese aus Moskitohaut und -flügeln gefertigte Tasche war mal DAS Trendaccessoire auf Pausenhöfen. Doch heute wirkt sie nur noch spießig und wurde vom aktuellen Modeschlager verdrängt, dem kleinen Schulranzen des Chef-Crocodylls. Welch ein Unsinn, wenn man bedenkt, dass letzterer viel teuerer und vor allem auch noch viel häßlicher als dieser der kleine Moskitosack ist. Da verstehe einer die Mode...",ep:1,g:59,l:16,wd:true,fm:true,w:2,s:23,p:900};
I.u[6917] = {n:"Moskitomütz",t:16,d:"Der verblüffende Name dieser Kappe stammt von einem exzentrischen Enutrof, dem sie beim Entkleiden eines alten, kranken Moskitos in die Hände fiel. Sie ist sehr nützlich für angehende Abenteurer. Aber Vorsicht: sie erregt schon von weitem die Aufmerksamkeit aller ausgehungerten Moskitos der ganzen Umgebung.",ep:1,g:80,l:15,wd:true,fm:true,w:2,s:23,p:900};
I.u[6918] = {n:"Medaillon des Moskitos",t:1,d:"Dieses Medaillon ist zwar weniger hoch angesehen, als das berühmte Arach-Amuleth, doch hat es auch einen gewissen Charme, vor allem wenn es als einziges Kleidungsstück auf einem stark behaarten Körper getragen wird.",ep:1,g:75,l:15,wd:true,fm:true,w:2,s:23,p:800};
I.u[6919] = {n:"Pilzlingring",t:9,d:"Ein Pilzling ist nicht gerade als sehr großer Sympathieträger bekannt. Er vergiftet anderen das Leben, sobald er eine Möglichkeit dazu hat, er beißt um sich und hat einen ganz miesen Charakter. Es ist doch verwunderlich, wie sehr diese gemeinen kleinen Biester euch manchmal an eine Ehepartner erinnern können, nicht wahr?",ep:1,g:74,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6920] = {n:"Pilzlingtrauring",t:9,d:"Wenn ein Pilzling heiratet, schenkt er seiner Liebsten diese Art von Trauring. Da die Liebsten dummerweise keine Arme besitzen, wird der Trauring ganz vorsichtig auf einer ihrer Dornen abgelegt. Da ihr selbst nun diesen Trauring übergezogen habt, wurde der Bund des Lebens zwischen den beiden Kreaturen zerstört. Im besten Fall wird euch nun der betroffene Pilzling für seine Liebste halten.",ep:1,g:75,l:3,wd:true,fm:true,w:2,s:24,p:225};
I.u[6921] = {n:"Pilzkäppchen",t:16,d:"In der Vergangenheit wurde Tee daraus gebraut und es kann auch geraucht werden. Solch eine Pilzlingkopfbedeckung ist schon etwas Tolles!",ep:1,g:84,l:9,wd:true,fm:true,w:3,s:24,p:425};
I.u[6922] = {n:"Pilzmantel",t:17,d:"Das einzige, was noch beindruckender ist, als ein wütender Pilzling, ist ein wütender Pilzling mit einem Mantel. Den ein solcher Mantel strahlt eure innere vestimentarische Überlegenheit nach allen Seiten aus. Doch ob sich dieser giftgrüne Pilzmantel auch als Accessoire für die hohen Damen durchsetzen wird? Wer weiß...",ep:1,g:76,l:9,wd:true,fm:true,w:2,s:24,p:450};
I.u[6923] = {n:"Banditenamulett",t:1,d:"Dieses Amulett gehörte einst dem berüchtigten Banditen \"Thisme\", der für seine grenzenlose Grausamkeit und für seine stupide Todesart bekannt wurde. Nach einer Eniripsa-Erzählung ertrank er in einer großen Ölpresse und wurde darin zermalmt – und das, nachdem er gerade nach mehreren hunderten von Jahren wieder aus dem Gefängnis freigelassen wurde, wohin ihn eine gestohlene Nuss gebracht hatte.",ep:1,g:76,l:16,wd:true,fm:true,w:2,s:25,p:900};
I.u[6924] = {n:"Schurkendolche",t:5,d:"Diese scharfen Dolche sind bei Banditen sehr beliebt, ganz im Gegensatz zu jungen Abenteurern, die sie aus dem gleichen Grund fürchten. Diese Dolche sind nämlich in der Lage, bei Treffern den Gegnern Kamas zu rauben. Eine originelle Art und Weise, Steuern zu erheben, nicht wahr?",ep:1,g:9,l:12,wd:true,fm:true,w:1,an:13,e:[5,3,1,1,30,50,false,false],s:25,p:600};
I.u[6925] = {n:"Schurkenschurz",t:10,d:"Dieser scharfe Lendenschurz wird euch entzücken, wenn ihr den Weg eines wahren Wegelagerers einschlagt. Bis dahin macht ihr euch damit allerdings schlichtweg lächerlich.",ep:1,g:72,l:15,wd:true,fm:true,w:2,s:25,p:850};
I.u[6926] = {n:"Prespikapp",t:16,d:"Mit der Prespikapp auf dem Kopf seht ihr Debbie Crokett, der berühmtesten Jägerin der Gegenwart, zum Verwechseln ähnlich. Bloß dass ihre Kopfbedeckung dazu dient, ihren beginnenden Haarausfall zu vertuschen. Solltet ihr die gleiche Absicht haben, so wisst, dass diese kleine rötliche Kappe furchtbar stinken wird, sobald es anfängt zu regnen.",ep:1,g:81,l:36,wd:true,fm:true,w:2,s:31,p:3600};
I.u[6927] = {n:"Prespik-Umhang",t:17,d:"Dieser rötlich gefärbte, kleine Umhang kann im Zweifel auch als Bettvorleger oder als Türmatte dienen, falls ihr sparen müsst und trotzdem eure Innenausstattung umdekorieren möchtet.",ep:1,g:75,l:37,wd:true,fm:true,w:3,s:31,p:3800};
I.u[6928] = {n:"Prespik-Armband",t:9,d:"Dieses gleichzeitig nüchtern, aber auch originell wirkende Armband wird mit Sicherheit alle Abenteurer erfreuen, die scharf auf Luxus sind, ihn sich jedoch nicht leisten können. So können sie losziehen, um mal wieder arme, kleine, wilde Kreaturen abzuschlachten, damit sie daraus Schmuck herstellen können. Die Bosheit kennt wohl keine Grenzen!",ep:1,g:72,l:38,wd:true,fm:true,w:1,s:31,p:4000};
I.u[6929] = {n:"Prespik-Gürtel",t:10,d:"Dieser Gürtel hält nicht nur eure Hüften warm, sondern wird eure zarte Haut so lange sticheln, bis sie ganz rot und gereizt ist. Daher ist er nur etwas für Hartgesottene.",ep:1,g:71,l:33,wd:true,fm:true,w:2,s:31,p:3000};
I.u[6930] = {n:"Krachlerhelm",t:16,d:"Dieser Krachlerhelm, aus Fels herausgehauen, ist sein Gewicht in Gold wert! Er wird euch selbst vor den Angriffen eines Krachlklotzes zu bewahren wissen. Sprich: er ist euch durchaus kein Klotz am Bein, sondern mit ihm werdet ihr, statt bloß zu kleckern, richtig klotzen können, und das nicht nur gegen Räuber wie RotzamKlotz!",ep:5,g:85,l:44,wd:true,fm:true,w:200,s:26,p:5300};
I.u[6931] = {n:"Krachlcoatlus",t:17,d:"Dieser steinerne Umhang ist vielleicht anfangs ein wenig ungemütlich, aber dennoch ein wirklich guter Schutz gegen Steinwürfe, oder aber gegen die noch viel gefährlichere  Krachlerspucke.",ep:5,g:77,l:46,wd:true,fm:true,w:1,s:26,p:5800};
I.u[6933] = {n:"Stiefel des Krachlers",t:11,d:"Diese Stiefel sind unglaublich schwer, doch dafür auch sehr wirkungsvoll, um andere zu treten. Zudem liefern sie euch die perfekte Entschuldigung, wenn ihr mal wieder zu langsam wart, euch rechtzeitig einem von vornherein verlorenen Angriff auf einen Perceptoren eurer Gilde anzuschließen.",ep:5,g:52,l:47,wd:true,fm:true,w:10,s:26,p:4700};
I.u[6934] = {n:"Krachlerkette",t:1,d:"Diese Halskette ist so schwer wie ein fettsüchtiger Blob, was etwas zu leicht gebaute Abenteurer davon abhalten sollte, sie zu tragen. Allerdings muss man gestehen, dass sie sehr schick aussieht, wenn man erst einmal ihr Gewicht verkraftet.",ep:5,g:77,l:46,wd:true,fm:true,w:10,s:26,p:4600};
I.u[6935] = {n:"Krachlergurt",t:10,d:"Mit diesem Gürtel um die Hüften wird man euch sofort als erfahrenen Abenteurer respektieren. Wenn ihr ihn allerdings lieber als Stirnband tragen wollt, nur zu – es ist eure Sache, wenn ihr euch zum Gespött von ganz Astrub machen wollt.",ep:5,g:74,l:45,wd:true,fm:true,w:10,s:26,p:5400};
I.u[6936] = {n:"Grüner Scara-Helm",t:16,d:"Mit diesem originellen Helm auf dem Kopf werdet ihr all euren Freunden weismachen können, ihr währet ein großer Scarablatt-Jäger.",ep:3,g:78,l:44,wd:true,fm:true,w:2,s:27,p:5200};
I.u[6937] = {n:"Roter Scara-Helm",t:16,d:"Mit diesem originellen Helm auf dem Kopf werdet ihr all euren Freunden weismachen können, ihr seiet ein großer Scarablatt-Jäger.",ep:3,g:77,l:44,wd:true,fm:true,w:2,s:28,p:5200};
I.u[6938] = {n:"Weißer Scara-Helm",t:16,d:"Mit diesem originellen Helm auf dem Kopf werdet ihr all euren Freunden weismachen können, ihr währet ein großer Scarablatt-Jäger.",ep:3,g:79,l:44,wd:true,fm:true,w:2,s:29,p:5200};
I.u[6939] = {n:"Blauer Scara-Helm",t:16,d:"Mit diesem originellen Helm auf dem Kopf werdet ihr all euren Freunden weismachen können, ihr wäret ein großer Scarablatt-Jäger.",ep:3,g:76,l:44,wd:true,fm:true,w:2,s:30,p:5200};
I.u[6940] = {n:"Grüner Scara-Mantel",t:17,d:"Wer hat niemals davon geträumt, in die leere Schale eines Scarablattes zu schlüpfen? Wenn diese erst einmal angepasst ist, dann bekommt ihr beinahe das Gefühl, selbst ein echtes Scarablatt zu sein und werdet mit der Zeit womöglich auch noch anfangen, euch halb schwebend, halb (aus)rutschend fortzubewegen. Das kann die Horde von Trools, die euch gerade auffressen will, ganz schön aus dem Konzept bringen. Für eine kurze Zeit jedenfalls.",ep:3,g:74,l:45,wd:true,fm:true,w:2,s:27,p:5500};
I.u[6941] = {n:"Blauer Scara-Mantel",t:17,d:"Wer hat niemals davon geträumt, in die leere Schale eines Scarablattes zu schlüpfen? Wenn diese erst einmal angepasst ist, dann bekommt ihr beinahe das Gefühl, selbst ein echtes Scarablatt zu sein und werdet mit der Zeit womöglich auch noch anfangen, euch halb schwebend, halb (aus)rutschend fortzubewegen. Das kann die Horde von Trools, die euch gerade auffressen will, ganz schön aus dem Konzept bringen. Für eine kurze Zeit jedenfalls.",ep:3,g:73,l:45,wd:true,fm:true,w:2,s:30,p:5500};
I.u[6942] = {n:"Roter Scara-Mantel",t:17,d:"Wer hat niemals davon geträumt, in die leere Schale eines Scarablattes zu schlüpfen? Wenn diese erst einmal angepasst ist, dann bekommt ihr beinahe das Gefühl, selbst ein echtes Scarablatt zu sein und werdet mit der Zeit womöglich auch noch anfangen, euch halb schwebend, halb (aus)rutschend fortzubewegen. Das kann die Horde von Trools, die euch gerade auffressen will, ganz schön aus dem Konzept bringen. Für eine kurze Zeit jedenfalls.",ep:3,g:72,l:45,wd:true,fm:true,w:2,s:28,p:5500};
I.u[6943] = {n:"Weißer Scara-Mantel",t:17,d:"Wer hat niemals davon geträumt, in die leere Schale eines Scarablattes zu schlüpfen? Wenn diese erst einmal angepasst ist, dann bekommt ihr beinahe das Gefühl, selbst ein echtes Scarablatt zu sein und werdet mit der Zeit womöglich auch noch anfangen, euch halb schwebend, halb (aus)rutschend fortzubewegen. Das kann die Horde von Trools, die euch gerade auffressen will, ganz schön aus dem Konzept bringen. Für eine kurze Zeit jedenfalls.",ep:3,g:71,l:45,wd:true,fm:true,w:2,s:29,p:5500};
I.u[6944] = {n:"Grüner Scararara-Ring",t:9,d:"Mit diesem Ring am Finger habt ihr unweigerlich das Bild der vielen niedergemetzelten Scarablätter vor euch und werdet schwach. Da kann man sich wirklich fragen, ob es das Gemetzel wert war.",ep:3,g:69,l:43,wd:true,fm:true,w:2,s:27,p:5000};
I.u[6945] = {n:"Roter Scararara-Ring",t:9,d:"Mit diesem Ring am Finger habt ihr unweigerlich das Bild der vielen niedergemetzelten Scarablätter vor euch und werdet schwach. Da kann man sich wirklich fragen, ob es das Gemetzel wert war.",ep:3,g:68,l:43,wd:true,fm:true,w:2,s:28,p:5000};
I.u[6946] = {n:"Weißer Scararara-Ring",t:9,d:"Mit diesem Ring am Finger habt ihr unweigerlich das Bild der vielen niedergemetzelten Scarablätter vor euch und werdet schwach. Da kann man sich wirklich fragen, ob es das Gemetzel wert war.",ep:3,g:67,l:43,wd:true,fm:true,w:2,s:29,p:5000};
I.u[6947] = {n:"Blauer Scararara-Ring",t:9,d:"Mit diesem Ring am Finger habt ihr unweigerlich das Bild der vielen niedergemetzelten Scarablätter vor euch und werdet schwach. Da kann man sich wirklich fragen, ob es das Gemetzel wert war.",ep:3,g:70,l:43,wd:true,fm:true,w:2,s:30,p:5000};
I.u[6948] = {n:"Grüner Scara-Gurt",t:10,d:"Einst diente ein Scara-Gurt dazu, die Fähigkeiten seines Trägers im waffenlosen Kampf einzuschätzen. Demnach wurde ein grüner Scara-Gurt an Anfänger vergeben, ein roter Scara-Gurt war ein Zeichen dafür, dass man das vergossene Blut seiner Feinde stets vom Boden aufzulecken pflegte, ein Weißer, dass man von Gegnern im Kampf niemals getroffen wird, und ein Blauer, dass der Träger zu arm war, um sich einen der anderen Scara-Gurte zu leisten.",ep:3,g:67,l:46,wd:true,fm:true,w:2,s:27,p:5600};
I.u[6949] = {n:"Weißer Scara-Gurt",t:10,d:"Einst diente ein Scaragurt dazu, die Fähigkeiten seines Trägers im waffenlosen Kampf einzuschätzen. Demnach wurde ein grüner Scaragurt an Anfänger vergeben, ein roter Scaragurt war ein Zeichen dafür, dass man das vergossene Blut seiner Feinde stets vom Boden aufzulecken pflegte, ein Weißer, dass man von Gegnern im Kampf niemals getroffen wird, und ein Blauer, dass der Träger zu arm war, um sich einen der anderen Scaragurte zu leisten.",ep:3,g:69,l:46,wd:true,fm:true,w:2,s:29,p:5600};
I.u[6950] = {n:"Roter Scara-Gurt",t:10,d:"Einst diente ein Scaragurt dazu, die Fähigkeiten seines Trägers im waffenlosen Kampf einzuschätzen. Demnach wurde ein grüner Scaragurt an Anfänger vergeben, ein roter Scaragurt war ein Zeichen dafür, dass man das vergossene Blut seiner Feinde stets vom Boden aufzulecken pflegte, ein Weißer, dass man von Gegnern im Kampf niemals getroffen wird, und ein Blauer, dass der Träger zu arm war, um sich einen der anderen Scaragurte zu leisten.",ep:3,g:68,l:46,wd:true,fm:true,w:2,s:28,p:5600};
I.u[6951] = {n:"Blauer Scara-Gurt",t:10,d:"Einst diente ein Scaragurt dazu, die Fähigkeiten seines Trägers im waffenlosen Kampf einzustufen. Demnach wurde ein grüner Scaragurt an Anfänger vergeben, ein roter Scaragurt war ein Zeichen dafür, dass man das vergossene Blut seiner Feinde stets vom Boden aufzulecken pflegte, ein Weißer, dass man von Gegnern im Kampf niemals getroffen wird, und ein Blauer, dass der Träger zu arm war, um sich einen der anderen Scaragurte zu leisten.",ep:3,g:70,l:46,wd:true,fm:true,w:2,s:30,p:5600};
I.u[6952] = {n:"WuWulfut",t:16,d:"Mit dem WuWulfut auf dem Kopf habt ihr stets eine gute Entschuldigung für eventuellen Mundgeruch parat.",ep:1,g:131,l:61,wd:true,fm:true,w:4,s:32,p:10000};
I.u[6953] = {n:"WuWulf-Stiefelchen",t:11,d:"Diese Stiefelchen aus WuWulffell sind sehr praktisch, um staubige Parkettböden zu reinigen. Allerdings eignen sie sich auch hervorragend dafür, Gegnern damit den Kopf zu waschen, wenn sie mal wieder jämmerlich zu euren Füßen liegen und vor sich hin sterben.",ep:1,g:76,l:61,wd:true,fm:true,w:2,s:32,p:9700};
I.u[6954] = {n:"WuWulf-Umhang",t:17,d:"Das Fell eines WuWulfs isoliert hervorragende gegen Kälte, sowie gegen alle anderen Abenteurer, deren Nase noch nicht abgestorben ist.",ep:1,g:99,l:64,wd:true,fm:true,w:5,s:32,p:11000};
I.u[6955] = {n:"WuWulfische Gürtelschnur",t:10,d:"Wird diese Gürtelschnur als Peitsche eingesetzt, so zeigen sich schnell ihre extrem motivierenden Eigenschaften. Sie funktioniert genauso gut bei kampfunwilligen Weggefährten wie bei gefährlichen Crocodyllen und ist zu 100% natürlich abbaubar. Von führenden WuWulfs empfohlen!",ep:1,g:92,l:49,wd:true,fm:true,w:2,s:32,p:6500};
I.u[6956] = {n:"WuWulf-Ring",t:9,d:"Vorsicht! Dieser Ring verleiht eurem Finger einen besonders üblen Wolfsgeruch. Aber wie heißt es so schön: ein Geruch kann einen anderen verdecken. Darum ist es vielleicht für euren Finger und für euer Umfeld am Ende eine sehr gute Sache...",ep:1,g:103,l:51,wd:true,fm:true,w:2,s:32,p:7000};
I.u[6957] = {n:"Krachlerschwert",t:6,d:"Dieses Schwert diente einst dazu, gewaltige Granitblöcke für die Wände berühmter Städte wie Bonta oder Brâkmar zurechtzuschlagen. Heutzutage wird diese Waffe eher dazu benutzt, alle möglichen lebenden Kreaturen zu zermalmen – mit oder gegen ihren Willen.",ep:5,g:54,l:37,wd:true,fm:true,w:10,an:14,tw:true,e:[5,6,1,1,50,50,false,true],s:26,p:3800};
I.u[6958] = {n:"Genialer Schildkrötenlook",t:16,d:"Diese topmoderne Kopfbedeckung markiert einen wirklich einzigartigen Stil. Außerdem könnt ihr damit heimlich Blicke unter die Röcke der Iopinen werfen, ohne erwischt zu werden. Das ist einfach ideal bei den feucht-fröhlichen Parties eurer Freunde.",ep:5,g:82,l:22,wd:true,fm:true,w:12,p:1525};
I.u[6961] = {n:"Banditenring",t:9,d:"Dieser Ring ist sowohl bei Zahnärzten, als auch bei echten Banditen verbreitet. Denn beide verwenden ihn gern dazu, Unvorsichtigen die Zähne zu entfernen. Nur eine Methode von vielen zur Vorsorge gegen Karies.",ep:1,g:77,l:17,wd:true,fm:true,w:2,s:25,p:1000};
I.u[6962] = {n:"Geburtstagsgeschenk",t:89,d:"Alles Gute zum Geburtstag! Dieses Paket ist so gut verpackt, dass kein vorwitziger Blick möglich ist. Doch könnt ihr kräftig feiern und euch daran erfreuen. Viel Spaß dabei! Schließlich ist der Tag zum Feiern da!",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6963] = {n:"Kugeln des Minotoballs",t:12,d:"Diese enormen Kugeln sind einfach ein Leckerbissen. Weiterer Vorteil: ihr werdet den Eindruck haben, sie hielten ewig. Ist das nicht wunderbar?",ep:1,g:143,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[6964] = {n:"Stadttrank: Brâkmar",t:12,d:"Dieser aus Reis gebraute Trank bringt Abenteurer ohne Zeitverzögerung nach Brâkmar, vorausgesetzt sie haben die entsprechende Gesinnung.",ep:1,g:145,l:1,wd:true,fm:true,w:1,c:"Ps=2|Ps=0|Ps=3",u:true,p:1};
I.u[6965] = {n:"Stadttrank: Bonta",t:12,d:"Dieser aus Reis gebraute Trank bringt Abenteurer ohne Zeitverzögerung nach Bonta, vorausgesetzt sie haben die entsprechende Gesinnung.",ep:1,g:144,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=0|Ps=3",u:true,p:1};
I.u[6966] = {n:"Spezialzauberschriftrolle \"Pech\"",t:75,d:"(Doppelklick, um den Elementarzauber \"Pech\" zu lernen) \n... Nur für Srams.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"PG=4",u:true,p:10000};
I.u[6967] = {n:"Amtsschriftrolle des Söldnerinitiaten",t:14,d:"Diese Schriftrolle ist eure Eintrittskarte, um als Initiat bei den Söldnern aufgenommen zu werden.",ep:1,g:5,l:1,wd:false,fm:true,w:0,c:"Ps=3&Pa>59",ut:true,p:1};
I.u[6968] = {n:"Amtsschriftrolle des Söldners",t:14,d:"Diese Schriftrolle ist eure Eintrittskarte, um als vollwertiger Söldner aufgenommen zu werden.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6969] = {n:"Amtsschriftrolle des Erzsöldners",t:14,d:"Diese Schriftrolle ist Voraussetzung dafür, den Rang eines Erzsöldners zu erhalten.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6970] = {n:"Amtsschriftrolle des Söldnermeisters",t:14,d:"Diese Schriftrolle ist Voraussetzung dafür, den Rang des Söldnermeisters zu erhalten.",ep:1,g:5,l:1,wd:true,fm:true,w:0,c:"Ps=3&Pa>79",ut:true,p:1};
I.u[6971] = {n:"Clints Söldnerhut",t:16,d:"Dieser Hut ist eine gute Imitation des berühmten Clint-Easthuts. Er ist genau das Passende für alle Söldner, die sich als große Meister aufspielen wollen.",ep:1,g:38,l:1,wd:false,fm:true,w:20,c:"Ps=3",p:1};
I.u[6975] = {n:"Clints Söldnerneophytenhut",t:16,d:"Dieser übermächtige Hut ist das Erkennungszeichen der Söldner. Er sitzt wie angegossen und beschützt den Träger vor Sonne und Regen. Das ist schon gar nicht schlecht.",ep:1,g:38,l:1,wd:false,fm:true,w:20,p:1};
I.u[6978] = {n:"Péki",t:18,d:"Diese Kreatur ähnelt von Weitem einem SchnuffWuff. Ihr Kopf zeigt deutliche Spuren der schweren erlittenen Traumata, die dieses Wesen dazu gebracht haben, sich zum Vegetariertum zu bekennen. Es ernährt sich daher ausschließlich von Pflanzen und Gemüsen, die auf der Insel Pandala wachsen.",ep:3,g:12,l:60,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6980] = {n:"Dofus Vulbis",t:23,d:"Dieser Dofus wird euch beim anderen Geschlecht sehr erfolgreich machen. Wenn ihr nur bloß nicht alles glauben würdet, was man euch über diesen Dofus und seine Tugenden erzählt...",ep:11,g:4,l:6,wd:false,fm:true,w:1,p:500000};
I.u[6981] = {n:"Eisige Klingen",t:5,d:"Die Klinge dieser Dolche besteht aus Eis, was sehr praktisch ist, um den schlechten Atem eurer Gegner etwas aufzufrischen. Reißt ihnen einfach den Mund auf, stoßt eure Eisdolche hinein und fertig. Ein Kinderspiel!",ep:19,g:44,l:150,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>150",p:15};
I.u[6982] = {n:"Agondolchie",t:5,d:"Diese Dolche haben bereits das Blut einer Vielzahl dämonischer Kreaturen getrunken – von Kindern zum Beispiel –, was ihnen einen origenellen Touch verpasst.",ep:18,g:50,l:46,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5775};
I.u[6983] = {n:"Aggs Messoren",t:5,d:"Auch wenn sie nur einmal pro Jahrzehnt geschärft werden müssen, bleiben diese Dolche dennoch absolut tödlich. Zudem haust in ihnen dunkle Magie, die sie dazu antreibt, sich des Nachts davonzustehlen, um Unvorsichtige in den Allerwertesten zu pieksen. Das ist ganz klar wieder so eine Geschichte, die man jungen Iops erzählt, um ihnen Angst einzujagen.",ep:19,g:47,l:143,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>250&CA>100",p:15};
I.u[6984] = {n:"Dolche des angehenden Fresssäckchenjägers",t:5,d:"Diese Dolche gehörten einst einem armen Sadida, dessen blitzartiger Aufstieg in die Welt des Reichtums in ganz Amakna bekannt wurde. Dieser Sadida hatte beschlossen, Fresssäckchen jagen zu gehen, was alle Einwohner seines Heimatdorfes belustigte. Einige Schaulustige schauten sogar von den Hügeln aus zu, um ihn bei der Jagd zu verspotten. Seine Rache an ihnen war furchtbar... Inzwischen zu Geld gekommen, stellte er ein Kopfgeld auf sie aus, wodurch sie bis auf den letzten Spötter ausgelöscht wurden.",ep:18,g:46,l:113,wd:true,fm:true,w:15,an:13,tw:true,e:[5,3,1,1,25,50,false,false],c:"CS>300&CA>100",p:32750};
I.u[6986] = {n:"Stinkender Schild des O\'Stinkus Mons",t:82,d:"Dieser gute Schild hat einige Gefechte zuviel mitgemacht. In seinem Zustand ist er zu nichts mehr zu gebrauchen. Aber vielleicht könnte Bouwada aus Pandala ihn wieder herrichten?",ep:18,g:1,l:1,wd:false,fm:true,w:20,c:"BI=non équipable",p:5400};
I.u[6987] = {n:"Kleiner Seelenstein des Hasardeurs",t:83,d:"Diese Rune gibt einem eine geringe Chance, nicht allzu mächtige Seelen einzufangen... Das ist schon mal ein guter Anfang, aber ihr solltet nicht zuviel erwarten...",ep:5,g:1,l:1,wd:false,fm:true,w:1,tw:true,p:1250};
I.u[6988] = {n:"Sulik",t:16,d:"Dieser schicke Hut wurde ehemals von einem wilden Xelor getragen, dessen Schwester von skrupellosen Sklavenjägern entführt wurde. Mit ihm werdet ihr sicher sehr originell aussehen.",ep:19,g:92,l:172,wd:true,fm:true,w:10,p:56100};
I.u[6989] = {n:"Krokappo",t:16,d:"Dieser Hut wurde vor langer Zeit von angehenden Schneidern angefertigt, die sich dadurch vor den Jähzornanfällen ihres Meisters, Mirko, dem Meisterschneider, schützen wollten. Letzterer hatte nämlich die üble Angewohnheit, seine Lehrlinge mit Fußtritten auf den Kopf zu dezimieren, wenn sie ihm nicht schnell genug arbeiteten. Eine brutale aber wirkungsvolle Methode, um Untergebene zur Arbeit anzutreiben, oder?",ep:19,g:86,l:120,wd:true,fm:true,w:20,p:37025};
I.u[6990] = {n:"Nachtfalthut",t:16,d:"Diese seltsame Kopfbedeckung wurde den entfernten Cousins der Moskitos, nämlich den Nachtfaltern gewidmet. Sie waren zwar noch viel dicker als die Moskitos, doch auch um einiges freundlicher und weniger blutrünstig. Bloß neigten sie dazu, sich mit allem und jedem (und zwar vor allem mit allem) paaren zu wollen, was erheblich zum beschleunigten Aussterben ihrer Art beitrug.",ep:19,g:87,l:113,wd:true,fm:true,w:10,p:32925};
I.u[6991] = {n:"Guarghwe",t:16,d:"Diese seltsame Kopfbedeckung mit dem komischen Namen ähnelt einer ausgetrockneten dicken Frucht im fortgeschrittenen Stadium der Zersetzung. Genau wie ihr nach einer durchzechten Nacht in der Taverne.",ep:18,g:88,l:46,wd:true,fm:true,w:10,p:5800};
I.u[6992] = {n:"Kanniepmatz",t:16,d:"Diese verfeinerte Version der berühmten Kanniballischen Maske lässt euch vor euren Freunden wie einen wahren Piepmatzjäger aussehen.",ep:12,g:89,l:55,wd:true,fm:true,w:5,p:8000};
I.u[6993] = {n:"Mantel des Tänzers",t:17,d:"Der Sadida Adia war ein überall gefürchteter Minnesänger, da er einfach seine Klappe nicht halten konnte. Ständig musste er allen seine Liebe beweisen, dass es nicht mehr auszuhalten war. Schließlich wurde er neben der Bank von Bonta öffentlich verbrannt, als sein Aufruf \"Vielleicht ist das Licht eines flimmernden Sterns schon genug\", die Wut in den Herzen all derer entflammte, denen die Sterne völlig schnuppe waren.",ep:18,g:79,l:46,wd:true,fm:true,w:10,p:5600};
I.u[6994] = {n:"Überzieh-Umhang",t:17,d:"Diese interessante Mischung aus einem Umhang und einer Abdeckplane verblüfft die Uneingeweihten auf den ersten Blick durch ihr geniales Design. Selbst der Chafer-Offizier würde ihn liebend gern tragen, wenn er doch nur aus reinem Leder bestünde. Die aktuelle Version jedoch schützt den Träger besser vor jeder Art von Feuchtigkeit und gibt ihm ein schönes Gefühl von Sicherheit.",ep:1,g:80,l:58,wd:true,fm:true,w:10,p:8875};
I.u[6995] = {n:"Cape \"Houte\"",t:17,d:"Dieser übermächtige Umhang hat bereits mehr als einen unvorsichtigen Möchtegernträger umgehauen. Diese Eigenschaft teilt er neben vielen anderen auch mit der Mumie Nova.",ep:18,g:81,l:105,wd:true,fm:true,w:10,p:28300};
I.u[6996] = {n:"Ring O\'Stradamus",t:9,d:"Stradamus war ein alter, stets rattendichter Enutrof, der anderen die Zukunft aus Biergläsern las. Der Legende nach wurde er auf seinen eigenen Wunsch hin senkrecht in der Taverne von Brâkmar eingemauert, \"damit kein Idiot unabsichtlich ein Bier über meinem Grab ausschüttet.\" Diese Art von Legende wird gerne bei wüsten den Saufereien weitergegeben, die dort von den Serianen-Meistern regelmäßig organisiert werden.",ep:18,g:78,l:48,wd:true,fm:true,w:5,p:6075};
I.u[6997] = {n:"Fioutioure-Ring",t:9,d:"Die Erschafferin dieses Ringes dachte, das Ende der Welt sei nahe. Daher verbrachte sie ihre restlichen Tage damit mit Hilfe ihres Setzers in Holztäfelchen zu gravieren, dass die Einwohner Amaknas keine Zukunft mehr hätten. In der Folge stellte sich dann heraus, dass sie Unrecht hatte.",ep:18,g:79,l:70,wd:true,fm:true,w:5,p:12730};
I.u[6998] = {n:"Ehering von Elya Wood",t:9,d:"Dieser kleine Ehering ist perfekt geeignet für die zarten Fingerchen von Eniripsas. Er ist hingegen so gut wie unbenutzbar für Iops mit ihren dicken Wurstfingern und ihrer Unfähigkeit zu begreifen, wo man diesen Ehering eigentlich anbringen muss.",ep:18,g:84,l:120,wd:true,fm:true,w:15,s:39,p:36000};
I.u[6999] = {n:"Lahilama-Medaillon",t:1,d:"Lahilama war ein großer Guru am tiefsten Punkt des höchsten Gebirges. Dort langweilte er sich so sehr, dass er den ganzen Tag lang gelbe Mützen für seine Anhänger strickte.",ep:18,g:83,l:31,wd:true,fm:true,w:3,p:2800};
I.u[7000] = {n:"Bambulett",t:1,d:"Diese lächerlich anmutende kleine Halskette aus Bambusstückchen verfügt über seltsame magische Kräfte. Es wurde früher von jungen Pandawas getragen, sobald diese die Pubertät durchlaufen hatten. Daher wird es wohl noch ein paar Jährchen dauern, bis ihr es um den Hals tragen werdet...",ep:18,g:78,l:40,wd:true,fm:true,w:5,p:4400};
I.u[7001] = {n:"Talisman des KarpfEdiemtales",t:1,d:"\"Uuuunnnnddd ich warte auf ein Zeeeeeiiiiiicccchhhhhheeeennnnnnnn...\" pflegte Howie, der Fischer aus vollster Kehle zu singen, wenn er seine Angel an seinem Geheimtipp für Karpf Ediems auswarf, einen kleinen, versteckten Teich auf Moons Insel.",ep:18,g:84,l:55,wd:true,fm:true,w:10,p:8000};
I.u[7002] = {n:"Harzilein",t:1,d:"Dieses Amulett aus Bambusharz verbreitet einen sehr angenehmen Geruch um euch herum. Das ist sehr nützlich, zum Beispiel um misslungene Versuche beim Wirken von Panikwellen zu vertuschen.",ep:18,g:85,l:94,wd:true,fm:true,w:5,p:22800};
I.u[7003] = {n:"Talisman von Elya Wood",t:1,d:"Dieser Talisman besteht aus feinem Sternenstaub und Edelsteinen, die in Bernstein eines Ur-Astaknyden eingefasst wurden. Diese Mischung ist manchmal hochexplosiv. Darum ist es angeraten, sich niemals selbst an ihrer Herstellung zu versuchen, sondern diese Angelegenheit einem Juwelier eurer Unzufriedenheit zu überlassen.",ep:18,g:86,l:135,wd:true,fm:true,w:10,s:39,p:45600};
I.u[7004] = {n:"Mittelgroßer Seelenstein des Hasardeurs",t:83,d:"Diese Rune gibt einem eine geringe Chance, relativ erhabene Seelen einzufangen...",ep:5,g:8,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7005] = {n:"Großer Seelenstein des Hasardeurs",t:83,d:"Diese Rune gibt einem eine geringe Chance, auch noch überaus scheue Seelen einzufangen...",ep:5,g:9,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7006] = {n:"Enormer Seelenstein des Hasardeurs",t:83,d:"Diese Rune gibt einem eine geringe Chance, selbst die widerborstigsten Seelen einzufangen...",ep:16,g:10,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7007] = {n:"Kleiner Seelenstein",t:83,d:"Diese Rune gibt einem eine Chance, nicht allzu mächtige Seelen einzufangen...",ep:5,g:2,l:1,wd:false,fm:true,w:1,tw:true,p:2500};
I.u[7008] = {n:"Mittelgroßer Seelenstein",t:83,d:"Diese Rune gibt einem eine Chance, relativ erhabene Seelen einzufangen...",ep:5,g:12,l:1,wd:false,fm:true,w:1,tw:true,p:5000};
I.u[7009] = {n:"Großer Seelenstein",t:83,d:"Diese Rune gibt einem eine Chance, auch noch überaus scheue Seelen einzufangen...",ep:16,g:13,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7010] = {n:"Gefüllter Seelenstein",t:85,d:"Dieser Seelenstein enthält die Seelen eines oder mehrerer Monster, die nur darauf warten, wieder unter die Lebenden zurückzukehren, um sich an euch zu rächen. Allerdings lässt sich der Seelenstein nur in speziellen Arenen einsetzen, welch sich in den großen Städten befinden.",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7011] = {n:"O\'Bouls Traummantel",t:17,d:"Dieser beinahe lebende Umhang mit rotem Fellbesatz ist wirklich einzigartig. In ihm steckt die mächtige Magie des Chaos. Dies merkt man sofort daran, dass er es liebt, Schabernack mit seinem Träger zu treiben – dazu gehört auch, sich jedes Mal unsichtbar zu machen, wenn sein Träger auf Abenteuer losziehen möchte. Aber glücklicherweise gleicht sich diese kleine Verrücktheit dadurch aus, dass er laut gewisser Wabbits \"ein wewitablew Kwell dew Zewstöwung im Kwampf\" sei.",ep:13,g:83,l:67,wd:false,fm:true,w:10,s:38,p:11875};
I.u[7012] = {n:"Die Weichlichkeit O\'Bouls",t:1,d:"Dieses Amulett ist in Wirklichkeit eine Süßigkeit. Sie könnte auch gegessen werden, wenn eine Horde brünftiger, weiblicher Bworks sie nicht über 36 Generationen unter der Achselhöhle aufbewahrt hätte.",ep:7,g:87,l:77,wd:true,fm:true,w:10,s:38,p:15425};
I.u[7013] = {n:"Bambusholz",t:38,d:"Im Gegensatz zum Rohrstock biegt ein Stock aus Bambusholz die Zielscheibe seiner Schläge. Nur dumme Dinge, die nicht nachgeben wollen, zerbricht er. Glücklicherweise ist das selten der Fall, denn selbst Zähne unvorsichtiger Abenteurer geben unter harten Bambusholzschlägen nach. Manchmal hilft die Natur eben sogar skrupellosen Zahnärzten bei ihrer täglichen Arbeit.",ep:18,g:673,l:50,wd:true,fm:true,w:5,p:0};
I.u[7014] = {n:"Heiliges Bambusholz",t:38,d:"Entgegen seines Anscheins ist dieses Holzstück absolut heilig. Nur die besten aller Pandawas bekommen es normalerweise in ihre Hände. Doch sollen manchmal auch sogenannte Holztouristen aufkreuzen, die ihre Pandala-Rundreise mit einigen örtlichen Souvenirs abrunden. Verdammte Touristen! Oh nein. Heilige Touristen, eher.",ep:18,g:671,l:100,wd:true,fm:true,w:5,p:0};
I.u[7015] = {n:"Bambussprossen",t:38,d:"Diese Bambussprossen sind nicht zum Verzehr geeignet, da sie wirklich überhaupt keinen Geschmack haben. Daher wird angeraten eine rostige Sense zu verwenden, um sie zu gewinnen, oder aber die Sprossen einige Jahre lang im Saft eines Omnischlundes gähren zu lassen, bevor man seine Freunde einläd. Das ist sicherlich wieder ein Trick von skrupellosen Gastwirten, die ihren Gästen alles mögliche vorsetzen.",ep:1,g:676,l:50,wd:true,fm:true,w:2,p:5};
I.u[7016] = {n:"Schattenbambusholz",t:38,d:"Galthus, ein junger Pandawa, fragte eines Tages seinen Vater: \"Was ist eigentlich der Unterschied zwischen einem Bambus und einem Schattenbambus, Papa?\". Sofort bekam er eine Tracht Prügel von seinem Vater, weil er eine solch dumme Frage gestellt hatte. Schließlich weiß doch jedes kleine Kind, daß der Unterschied zwischen den beiden die Größe der Samenkörner ist.",ep:18,g:672,l:60,wd:true,fm:true,w:5,p:0};
I.u[7017] = {n:"Goldenes Bambusholz",t:38,d:"Galthus, ein junger Pandawa, fragte eines Tages seinen Vater: \"Was ist eigentlich der Unterschied zwischen einem Bambus und einem Goldenen Bambus, Papa?\". Sofort bekam er eine Tracht Prügel von seinem Vater, weil er eine solch dumme Frage gestellt hatte. Schließlich weiß doch jedes kleine Kind, daß der Unterschied zwischen den beiden die Größe der Wurzeln ist.",ep:18,g:669,l:45,wd:true,fm:true,w:5,p:20};
I.u[7018] = {n:"Reis",t:34,d:"Egal, ob klebrig oder sogar glibberig – dieser Reis erfreut sich großer Beliebtheit bei halbverhungerten, jungen Pandawas.",ep:18,g:10,l:20,wd:true,fm:true,w:2,p:0};
I.u[7020] = {n:"Lotusblüte",t:38,d:"Man sagt ihr nach, sie sei die älteste bekannte Blüte in ganz Amakna. Sie symbolisiert Fruchtbarkeit, aber auch Gleichgültigkeit, da sie manchmal aus dem Wasser emporsteigt, ohne nass zu sein. Gewisse Pandawa-Chefs nutzen sie als Zeichen, um ihren Getreuen zu demonstrieren, wie man in der Welt leben kann, ohne von ihr beeinflusst zu werden.",ep:1,g:141,l:30,wd:true,fm:true,w:1,p:2};
I.u[7022] = {n:"Stock von Sangroku",t:4,d:"Dieser Stock gehörte einst dem Großvater Sangrokus. Dieser, Sangrokran genannt, war für seinen dicken Kopf bekannt. Der Legende nach soll sich dieser magische Stock beliebig lang strecken können, um auch weit entfernte Gegner zu erreichen..., oder auch einfach nur um gewisse Minderwertigkeitskomplexe auszugleichen.",ep:18,g:47,l:120,wd:true,fm:true,w:10,an:12,e:[10,4,1,1,50,60,false,false],c:"CA>250&CV>300",p:36620};
I.u[7023] = {n:"Aquamarin",t:51,d:"Dieses Mineral findetet man normalerweise in der Umgebung von Pandala. Pandawas glauben, dieser Stein besäße spezielle Kräfte. Jeder glaubt dies, doch wurden sie noch niemals entdeckt. Genau wie beim Stamm der intelligenten Iops.",ep:1,g:75,l:60,wd:true,fm:true,w:5,p:600};
I.u[7024] = {n:"Topas",t:51,d:"Diese seltsamen Edelsteine sind schon seit langem das ideale Nahrungsmittel für gewisse Krachlklotz-Züchter in Pandala. Dadurch wurden sie mit der Zeit so selten, dass es verboten wurde, Krachlklötze damit zu füttern.",ep:5,g:76,l:70,wd:true,fm:true,w:5,p:700};
I.u[7025] = {n:"Achat",t:51,d:"Angeblich soll dieser Stein nach einem Fluss auf der Insel Pandawa benannt worden sein, wo man ihn angeblich in Massen gefunden haben soll. Doch halten das viele nur für ein Gerücht.",ep:5,g:128,l:80,wd:true,fm:true,w:5,p:1};
I.u[7026] = {n:"Geschliffener Aquamarin",t:50,d:"Dieser transparente, leicht bläuliche Edelstein leuchtet dermaßen hell, dass sich mit ihm selbst die tiefsten Falten im Gesicht verstecken lassen, wenn er als Halskette getragen wird. Gewisse Pandawa-Verkäufer gehen sogar so weit, ihn bei den Touristen anzupreisen... \"Macht mit diesem Stein eure Liebste zu einem glücklichen Menschen, ohne ein Vermögen für Botox auszugeben!\" Oder so ähnlich.",ep:1,g:101,l:60,wd:true,fm:true,w:5,p:600};
I.u[7027] = {n:"Geschliffener Topas",t:50,d:"Aus zweifelhaften Gründen wird dieser wertvolle Edelstein von Juwelieren sehr gepriesen. Allerdings gibt es kein besseres Mittel, um Rablinge in der Ebene von Cania von Nah und Fern anzulocken.",ep:5,g:102,l:70,wd:true,fm:true,w:5,p:700};
I.u[7028] = {n:"Geschliffener Achat",t:50,d:"Dieser Halbedelstein wurde einst von einer mächtigen weiblichen Pandawa getragen, welche unter dem Namen Achatha Crispy bekannt war. Sie war für ihre wilden Ausschweifungen in der Piratenbar von Sufokia berüchtigt, wo sie die letzten Jahre ihres Lebens als eine am großen Hauptmast der Taverne angekette Tänzerin verbrachte.",ep:5,g:103,l:80,wd:true,fm:true,w:5,p:800};
I.u[7029] = {n:"Sangrokus Gürtel",t:10,d:"Immer wenn Sangroku wieder einmal zu viel von seinen magischen Bohnen genascht hatte, pflegte er diesen Gürtel enger zu schnallen, um die Panikwellen in seinem Inneren besser einschließen zu können, für die er im ganzen ewigen Lande von Amakna berühmt war.",ep:13,g:80,l:86,wd:false,fm:true,w:10,c:"CS>100",p:18400};
I.u[7030] = {n:"Kanigrouhaut",t:59,d:"Wenn erst einmal alle Haare entfernt sind, ist die Haut eines Kanigrous überraschend sanft. Eine Gemeinsamkeit, die sie mit der Haut von Sadidettchen teilt.",ep:13,g:47,l:70,wd:true,fm:true,w:5,p:1};
I.u[7031] = {n:"Guduls Taschenuhr",t:1,d:"Der arme Gudul verlor völlig den Kopf bei einem harten Kampf gegen Many. Guduld währt eben doch nicht immer am Besten. Glücklicherweise wurde sein Uhr im Kampf nicht beschädigt. Sie behielt all ihre hypnotisierenden Fähigkeiten, genauso wie auch ihre abführende Wirkung. Nicht im Übermaß verwenden.",ep:18,g:90,l:46,wd:false,fm:true,w:2,p:5600};
I.u[7032] = {n:"Silikat",t:39,d:"Dieses Mineral stammt aus den tiefsten Minen der Insel Pandala, in denen Gardan Framine seinen Kopf an einen weiblichen Pandawa-Geist verlor. Liebe kennt eben keine Grenzen.",ep:16,g:111,l:70,wd:true,fm:true,w:5,p:0};
I.u[7033] = {n:"Dolomit",t:39,d:"\"Immer hart bleiben und nicht nachgeben\", dies waren die Worte mit denen Irko, ein Schattenbergmann, Dolomit beschrieb.",ep:16,g:110,l:80,wd:true,fm:true,w:5,p:0};
I.u[7034] = {n:"Helm von Meister Nabur",t:16,d:"Dieser alte, zerbeulte Helm wird bereits seit langem von Generation zu Generation weitergegeben. Er soll sogar eine Zeitlang von Crail höchstpersönlich getragen worden sein. Viele Abenteurer schreiben ihm daher wunders welche Kräfte zu, die er überhaupt nicht besitzt. Eine Eigenschaft, die gleichfalls bei vielen Gottheiten und Helden der Neuzeit verbreitet ist.",ep:16,g:93,l:97,wd:false,fm:true,w:10,p:23000};
I.u[7035] = {n:"Püryt",t:40,d:"Diese Legierung wird gern verwendet, um daraus Klingen zu schmieden, die weder beim Kontakt mit dem Blut, noch mit dem Speichel der Gegner rosten.",ep:16,g:708,l:100,wd:true,fm:true,w:100,p:0};
I.u[7036] = {n:"Rutil",t:40,d:"Diese glänzende Legierung wird besonders gern von Juwelieren in Geldnot verwendet, die es sich nicht leisten können, teure Edelsteine zu verarbeiten. Aus diesem Material können sie dann Eheringe und Schmuckstücke fertigen, bei deren Preisen kein anderer Juwelier mithalten kann. Das ist besonders praktisch, wenn jemand aus Geldgründen heiraten möchte.",ep:16,g:707,l:100,wd:true,fm:true,w:100,p:0};
I.u[7037] = {n:"Oma Pralinchens Spazierstock",t:4,d:"Dieser Spazierstock gehörte Oma Pralinchen höchstpersönlich, also einer der drei furchtbaren Liebespriesterinnen. Auf der einen Seite scharf, auf der anderen spitz, war dieser Spazierstock dafür berüchtigt, extrem vielseitig einsetzbar zu sein. Er soll sich wann auch immer, wohin auch immer, bei wem auch immer, und überhaupt überall hineinbohren können. Da bleibt kein Auge trocken.",ep:18,g:48,l:98,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,50,50,false,false],c:"CS>100&CV>300",p:24500};
I.u[7038] = {n:"Helm von König Gelax",t:16,d:"Dieser Krone gehörte einst dem berühmten König Gelax. Er stand im Ruf, mit seinem überschwenglichen Sinn für Romantik und seiner verführerischen Ausstrahlung das Leben mehr als eines weiblichen Gelees nachhaltig geprägt zu haben... Man munkelt sogar, er sei der Vater aller Gelees von Amakna... Falls das stimmt, wäre es eine klarer Beweis für die Ausdauer und Fruchtbarkeit, die in ihm steckt.",ep:7,g:94,l:79,wd:true,fm:true,w:15,p:15000};
I.u[7039] = {n:"Schwarzer Gürtel von Frank Lee Bruce",t:10,d:"Der berüchtigte Sonntagskämpfer Frank begann seine Kampfkunst-Karriere, nachdem er mit Pauken und Trompeten durch seine Diplomprüfungen als Steinmetz gefallen war.",ep:13,g:81,l:47,wd:true,fm:true,w:5,p:5900};
I.u[7040] = {n:"Kuris Bogen",t:2,d:"Dieser Bogen gehörte Kuri, der berühmten Liebespriesterin und linken Hand von Oma Pralinchen höchstpersönlich. Übrigens: kehrt niemals einer Liebespriesterin den Rücken zu! Ein einziger Pfeil ihres Bogens kann euch das Herz zerreißen, oder sogar euren Allerwertesten.",ep:18,g:43,l:56,wd:true,fm:true,w:10,an:10,tw:true,e:[15,5,2,6,20,40,false,true],p:8300};
I.u[7041] = {n:"Pandrista",t:30,d:"Manchmal auch Pandawagalopp genannt, ist die Pandrista eine Pandala-Eigenheit, die jeder Reisende kennen wird. Die Symptome sind ein starkes Bedürfnis, den nächsten Lokus aufzusuchen, ohne ein Geschäft machen zu können, dass dieses Namens wert wäre.",ep:18,g:8,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7042] = {n:"Pandawa-Kopfbedeckung",t:14,d:"Im Gegensatz zu allen Amaknaischen Pandawas, wird euch der Pandawa von Pandala keine Kater bescheren. Höchstens ein dringendes Bedürfnis, Naturdünger über die Pflanzen der Umgebung zu verstreuen... oder über Maunzmiezen, was natürlich sehr viel lustiger ist.",ep:18,g:31,l:1,wd:false,fm:true,w:1,c:"PG!12",u:true,p:1000};
I.u[7043] = {n:"Eisdofus",t:23,d:"Der Legende nach kommt dieser wunderschöne Dofus geradewegs aus dem frostigen Innersten Aguabrials, dem Wasserdrachen. Die Legende erwähnt allerdings nicht die Tatsache, dass er an diesem Tag erkältet war. Das ist dennoch leicht zu erraten.",ep:1,g:5,l:1,wd:false,fm:true,w:1,p:1};
I.u[7044] = {n:"Dofus-Fälschung",t:24,d:"Dieser Dofus ähnelt keinem anderen bekannten Dofus, aber dennoch hat er was...",ep:18,g:256,l:1,wd:false,fm:true,w:0,p:1};
I.u[7045] = {n:"Eine Phiole Pandaberg",t:79,d:"Das Pandaberg ist ein aromatisches Getränk, welches angeblich langsam blind, taub und stumm machen soll. Das trifft sich gut, Pandawas sind nämlich nur selten in Eile.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[7046] = {n:"Eine Phiole Pandabekks",t:79,d:"Wenn man dem Einsiedler Hel Münster Glauben schenken darf, soll dieser reine Nektar einst die Göttin Pandawa in Person entzückt haben. Daher sollte jeder respektable Pandawa dieses edle Gebräu zu Ehren seiner Göttin spenden!",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[7047] = {n:"Eine Phiole Pandapils",t:79,d:"Es gibt unter den Pandawas eine seltsame Sitte. Alle am Tisch setzen sich eine Tofufeder auf den Kopf und stoßen gemeinsam an, wobei sie mit lauter Stimme singen: \"Pandapils, Pandapils, tralalalaLAAAAAARRRRGGGH.\" Dies ist jedoch noch harmlos, es gibt noch viel schlimmere Trinkbräuche.",ep:18,g:4,l:1,wd:true,fm:true,w:1,p:1};
I.u[7055] = {n:"Eine Phiole Pandneken",t:79,d:"\"Die Pfoten eines Bwacks sind kurz, das ist wahr. Doch würde es nichts bringen, sie länger zu machen.\" Solche und ähnliche philosophische Überlegungen werden durch das Trinken von Pandneken begünstigt. Das ist auch der Grund, warum dieses Getränk gern als Trinkopfer zu Ehren der Göttin benutzt wird.",ep:18,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[7056] = {n:"Kaboom",t:16,d:"Dieser einzigartige Hut gehörte einst einem Xelor, der für seine hochexplosiven Ideen und seine Meisterung der Zeit bekannt war. Sein Tod wäre ein Fall für die Darwin Awards. Ihn überkam eine schwere Panikwelle, die die gesamte Umgebung in Mitleidenschaft zog, während sein Hut mal wieder kleine Funken warf. Seinen Tod tat er mit einem lauten Knall kund und er soll die gesamte Stadt Brâkmar einige Sekunden lang taghell erleuchtet haben.",ep:19,g:95,l:149,wd:true,fm:true,w:10,p:45850};
I.u[7057] = {n:"Der Gehilfe des Shamanen",t:32,d:"Bringt den Gehilfen des Shamanen zu seiner Göttin. Er wird es euch danken.",ep:18,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7058] = {n:"Oktoviehutus",t:16,d:"Dieser Hut wurde aus getrockneten Resten toter Krakamore angefertigt. Daher kann es passieren, dass wieder Leben in ihn zurückkehrt, solltet ihr ihn als Badekappe gebrauchen. Also Vorsicht!",ep:18,g:96,l:77,wd:true,fm:true,w:10,p:15475};
I.u[7059] = {n:"Pandürbissamen",t:58,d:"Diese riesigen Samen schwimmen in einem ungenießbaren und hochmagischem Öl. Der Schale sagt man nach, dass sie unzerstörbar sei. Viele Handwerksmeister verwenden sie, um daraus Waffen herzustellen. Manchmal auch Cochonnets zum Boules-Spielen.",ep:18,g:67,l:100,wd:true,fm:true,w:10,p:10};
I.u[7060] = {n:"Spezial-Pandapilsner",t:24,d:"Lenald, der Weise, hat euch diesen Pandapilsner mitgegeben, damit ihr ihn beim Pandawushu-Meister des Wassers abgebt.",ep:18,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[7061] = {n:"Maunzmiez-Verwandlung",t:31,d:"Das Wasser der verfluchten Quelle der ertrunkenen Maunzmiez hat euch zeitweise in eine Maunzmiez verwandelt. Die geringste Berührung wird euch allerdings wieder in eure ursprüngliche Form zurückverwandeln.",ep:18,g:21,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7062] = {n:"Poochan",t:32,d:"Bringt Poochan zu ihrem zukünftigen Ehemann.",ep:18,g:21,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7068] = {n:"Reismehl",t:52,d:"Dieses Mehl eignet sich perfekt für die Herstellung von Zement oder Ouginak-Streu.",ep:18,g:7,l:50,wd:true,fm:true,w:2,p:0};
I.u[7069] = {n:"Eingedellter Schild von Sidimot",t:82,d:"Dieser gute Schild hat einige Gefechte zuviel mitgemacht. In seinem Zustand ist er zu nichts mehr zu gebrauchen. Aber vielleicht könnte Bouwada aus Pandala ihn wieder herrichten?",ep:18,g:8,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:15650};
