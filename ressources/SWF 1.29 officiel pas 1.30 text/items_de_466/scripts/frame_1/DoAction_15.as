I.u[7203] = {n:"Yodanwa-Säbel",t:6,d:"Dieser außergewöhnliche Säbel wird gewöhnlich von Pandawushuka-Anhängern verwendet, die den Grad eines Yodanwa erreicht haben, ohne dafür zwischenzeitlich den Gebrauch ihrer Arme eingebüßt zu haben. Also nur sehr wenigen.",ep:18,g:58,l:93,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,50,50,false,false],c:"CA>100",p:22175};
I.u[7204] = {n:"Shodanwa-Stock",t:4,d:"Dieser außergewöhnliche Stock wird gewöhnlich von Pandawushuka-Anhängern verwendet, die den Grad eines Shodanwa erreicht haben, ohne dafür zwischenzeitlich den Gebrauch ihrer Arme eingebüßt zu haben. Also nur sehr wenigen.",ep:18,g:49,l:46,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,false],c:"CV>30&CW>10",p:5775};
