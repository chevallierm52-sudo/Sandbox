I.u[7245] = {n:"Aerdala-Getas",t:11,d:"Diese Holzgetas werden nur von den besten Schuhmachern von Aerdala hergestellt. Da sie sehr luftig sind, bekommen eure Warzen ab und zu eine frische Brise ab und können die schöne Landschaft genießen.",ep:18,g:57,l:57,wd:true,fm:true,w:10,s:35,p:8700};
I.u[7246] = {n:"Akwadala-Trauring",t:9,d:"Dieser Trauring stammt aus dem Dorf Akwadala. Obwohl er mehr einem Glücksbringer als einer magischen Reliquie ähnelt, reicht er dennoch aus, um euren Freunden weiszumachen, dass ihr eure Schwester im Geiste gefunden hättet.",ep:1,g:80,l:37,wd:true,fm:true,w:2,s:34,p:3800};
