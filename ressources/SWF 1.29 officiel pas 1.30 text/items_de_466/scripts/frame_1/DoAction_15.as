I.u[7226] = {n:"Akwadala-Mütze",t:16,d:"Mit dieser Mütze auf dem Kopf ähnelt ihr von Weitem einem Pandawushuka des Akwadala-Dorfes. Von Nahem verschwindet dieser Eindruck allerdings schnell wieder.",ep:18,g:146,l:43,wd:true,fm:true,w:2,s:34,p:5100};
