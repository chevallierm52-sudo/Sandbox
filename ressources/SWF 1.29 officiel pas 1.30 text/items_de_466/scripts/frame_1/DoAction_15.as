I.u[7234] = {n:"Zerfressener Akwadala-Schild",t:82,d:"Um Tiefschläge und Schicksalsschläge abzuwehren, ist dieser Schild aus dem Dorf Akwadala einfach ideal!",ep:18,g:31,l:1,wd:false,fm:true,w:2,c:"BI=non équipable",p:5350};
I.u[7235] = {n:"Begrabener Teradala-Schild",t:82,d:"Dieser Schild aus dem Dorf Teradala ist ideal, um Tief- und Schicksalsschläge abzuwehren.",ep:18,g:32,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:14100};
I.u[7236] = {n:"Verbrannter Feudala-Schild",t:82,d:"Dieser gute Schild hat einige Gefechte zuviel mitgemacht. In seinem Zustand ist er zu nichts mehr zu gebrauchen. Aber vielleicht könnte Bouwada aus Pandala ihn wieder herrichten?",ep:18,g:33,l:1,wd:false,fm:true,w:15,c:"BI=non équipable",p:27100};
I.u[7237] = {n:"Entflogener Aerdala-Schild",t:82,d:"Dieser gute Schild hat einige Gefechte zuviel mitgemacht. In seinem Zustand ist er zu nichts mehr zu gebrauchen. Aber vielleicht könnte Bouwada aus Pandala ihn wieder herrichten?",ep:18,g:30,l:1,wd:false,fm:true,w:10,c:"BI=non équipable",p:11600};
I.u[7238] = {n:"Akwadala-Gürtel",t:10,d:"Die Pandawas von Akwadala waren immer bestrebt, eine schmale Taille zu haben. Wenn ihr nun diesen Gürtel ins engste Loch schnallt, werdet ihr wissen, wie sie es dazu bringen.",ep:18,g:76,l:41,wd:true,fm:true,w:2,s:34,p:4600};
