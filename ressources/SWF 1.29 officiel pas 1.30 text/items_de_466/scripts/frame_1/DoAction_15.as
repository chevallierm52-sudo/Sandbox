I.u[7207] = {n:"Yodanwa-Stock",t:4,d:"Dieser außergewöhnliche Stock wird gewöhnlich von Pandawushuka-Anhängern verwendet, die den Grad eines Shodanwa erreicht haben, ohne dafür zwischenzeitlich den Gebrauch ihrer Arme eingebüßt zu haben. Also nur sehr wenigen.",ep:18,g:52,l:93,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>250",p:22500};
I.u[7208] = {n:"Shodanwa-Axt",t:19,d:"Diese Axt wird Pandawushuka-Schülern verliehen, wenn sie den Rang eines Shodanwa erreichen. Außerdem ist sie sehr praktisch, wenn es darum geht, Bambuswälder mitsamt aller Monster, die sich darin verstecken, niederzumähen.",ep:18,g:37,l:36,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:3550};
I.u[7209] = {n:"Nidanwa-Axt",t:19,d:"Diese Axt wird Pandawushuka-Schülern verliehen, wenn sie den Rang eines Nidanwa erreichen. Außerdem ist sie sehr praktisch, wenn es darum geht, Bambuswälder mitsamt aller Monster, die sich darin verstecken, niederzumähen.",ep:18,g:36,l:59,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],c:"CS>100&CV>50",p:9000};
I.u[7210] = {n:"Sandawa-Axt",t:19,d:"Diese Axt wird Pandawushuka-Schülern verliehen, wenn sie den Rang eines Sandawa erreichen. Außerdem ist sie sehr praktisch, wenn es darum geht, Bambuswälder mitsamt aller Monster, die sich darin verstecken, niederzumähen.",ep:18,g:35,l:83,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:17800};
I.u[7211] = {n:"Yodanwa-Axt",t:19,d:"Diese Axt wird Pandawushuka-Schülern verliehen, wenn sie den Rang eines Yodanwa erreichen. Außerdem ist sie sehr praktisch, wenn es darum geht, Bambuswälder mitsamt aller Monster, die sich darin verstecken, niederzumähen.",ep:18,g:34,l:98,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,50,50,false,false],c:"CI>150&CS>75&CV>85",p:24500};
I.u[7212] = {n:"Bambuschkayah",t:19,d:"Diese leichte und elegante Axt wird es ihrem Träger erlauben, problemlos durch die dichten Bambuswälder Pandalas zu reisen. Selbst ein Kampf gegen die heimtückischen Panditen, die dort im Wald auf vereinzelte Holzfäller lauern, um irgendwelche dunklen Geldgeschäfte abzuwickeln, wird mit dieser Axt zum Spaziergang.",ep:18,g:33,l:26,wd:true,fm:true,w:10,an:17,e:[5,6,1,1,50,50,false,false],p:2000};
I.u[7213] = {n:"Ahnz Triebschaufel",t:8,d:"Dieser Schaufel wird nachgesagt, dass sie die Luft mit großer Geschwindigkeit durchpflügt. Diejenigen, die in ihrem Gebrauch geübt sind, benutzen sie allerdings hauptsächlich dazu, die Schädel ihrer Gegner zu spalten.",ep:19,g:41,l:142,wd:true,fm:true,w:15,an:16,tw:true,e:[10,5,1,1,40,70,false,false],c:"CC>400&CV>250",p:46050};
I.u[7214] = {n:"Sandale \"Matina\"",t:11,d:"Diese Sandalen gehörten einst einem Mitglied des heute ausgestorbenen Ouginak-Stammes. Letztere waren mit den Pandawas verbündet, woraufhin sich im Laufe der Jahre langsam die Farbe ihres Felles zu verändern begann, bis es schließlich weiß mit schwarzen Flecken ward. Leider wurden eines Tages alle Stammesangehörigen, ob groß oder klein, von einer verrückten Schneiderin zu Pelzmänteln verarbeitet.",ep:18,g:59,l:30,wd:true,fm:true,w:10,p:2650};
I.u[7215] = {n:"Schuh Kubus",t:11,d:"Diese Schuhe wurden von weiblichen Panditen verwendet, die damit Abenteurer, die sich verlaufen hatten, anzulocken pflegten, um sie zu verführen und anschließend in grausamen Fallen elendig ums Leben kommen ließen.",ep:19,g:60,l:121,wd:true,fm:true,w:20,p:37400};
I.u[7216] = {n:"Sandale Kohols",t:11,d:"Diese Sandalen wurden den armen kranken Pandawas gegeben, die sich den Pandrista-Virus eingefangen oder eine durchzechte Nacht in der Taverne hinter sich hatten. In beiden Fällen ist es nämlich sehr hilfreich, schnell laufen zu können.",ep:18,g:61,l:58,wd:true,fm:true,w:10,p:8975};
I.u[7217] = {n:"Orts Treter",t:11,d:"Pandawas werden schon seit jeher von alkoholischen Getränken magisch angezogen. Im Laufe der Zeit haben sie die Kunst perfektionniert, diese noch besser zu aromatisieren und zu konservieren. Diese Treter hier wurden nun speziell für Pandawas mit extremem Alkoholkonsum hergestellt. Sie enthalten Bleigewichte in den Sohlen, damit die Bodenhaftung nach zu viel Alkoholgenuss besser klappt.",ep:19,g:62,l:159,wd:true,fm:true,w:50,p:50800};
I.u[7218] = {n:"Adins Sandale",t:11,d:"Adin war ein junger Pandawa. Seine Leidenschaft war das Sammeln alter Lampen, allerdings machte ihn dies noch lange nicht zu einem Genie.",ep:18,g:63,l:76,wd:true,fm:true,w:15,p:14900};
I.u[7219] = {n:"Sandale \"Luja\"",t:11,d:"Diese seltenen Sandalen wurden jungen Panditen für bestimmte religieuse Rituale verliehen. Heutzutage werden sie jedoch beinahe ausschließlich im Rahmen von Stepptanzwettkämpfen verwendet.",ep:18,g:64,l:56,wd:true,fm:true,w:15,p:8200};
I.u[7220] = {n:"Lotterieschein",t:15,d:"In euren Händen haltet ihr nun einen tollen Lotterieschein! Bewahrt ihn gut auf, vielleicht zieht ihr ja damit den Hauptgewinn bei der großen Tombola.",ep:1,g:717,l:2,wd:true,fm:true,w:1,p:1};
I.u[7221] = {n:"Collier des Tanukouï San",t:1,d:"Dieses Collier wurde seit frühester Kindheit von Tanukouï San getragen, was ihm einen erheblichen Mehrwert mitgibt, vor allem wenn man weiß, wozu Tanukouï San damals bereits in der Lage war.",ep:19,g:92,l:152,wd:true,fm:true,w:10,p:49030};
I.u[7222] = {n:"Pandawushu-Wasser-Artefakt",t:50,d:"Dieses magische Artefakt wird von Pandawushu-Anhängern benutzt, um damit ihre Ausrüstung zu verzaubern.",ep:1,g:104,l:1,wd:true,fm:true,w:1,p:1};
I.u[7223] = {n:"Pandawushu-Luft-Artefakt",t:50,d:"Dieses magische Artefakt wird von Pandawushu-Anhängern benutzt, um damit ihre Ausrüstung zu verzaubern.",ep:18,g:105,l:1,wd:true,fm:true,w:1,p:1};
