I.u[7097] = {n:"Übungsschild",t:82,d:"Dieser Schild wird jungen Schülern gegeben, die den korrekten Gebrauch eines solchen noch nicht erlernt haben.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[7098] = {n:"Hammer des Schildschmiedes",t:7,d:"Dieses Werkzeug wird bei der Herstellung von Schilden benötigt.",ep:18,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:500};
I.u[7102] = {n:"Schwert des Eisritters",t:6,d:"Der Eisritter gehört zu den ganz großen Schmieden in Amakna. Einzig der furchtbare und unerbittliche Licha weigerte sich, sein immenses Talent anzuerkennen. Beleidigt, dass eine solche Kreatur es wagt, vor seiner Kunst nicht ins Staunen zu geraten, stellte er diesem ein Ultimatum: solange letzterer nicht in aller Öffentlichkeit seine Kunst würdigen würde, würde er die Ausübung seiner Kunst stoppen. Doch unterschätzte er den Licha, der nicht klein beigab. Viele Jahrhunderte später entschloß sich der Schmied, seine Arbeiten fortzusetzen, doch hatte er inzwischen sein Handwerk völlig verlernt. Dieses seltsame Schwert war seine letzte nennenswerte Arbeit.",ep:1,g:51,l:12,wd:true,fm:true,w:10,an:14,e:[5,6,1,1,40,60,false,false],p:575};
I.u[7103] = {n:"Rutoxine",t:3,d:"Diese Rute dient dazu, alle Proleten Amaknas zu enthaupten. Anders gesagt, hat sie bereits viel mitgemacht. Interessanterweise sieht dieses Instrument wie ein Stecken aus, oder gar ein Stock... vielleicht deshalb, um eine gewisse Fantasie des alten Besitzers umzusetzen, der diesem Gegenstand seinen Namen verlieh? Niemand wird bei dieser schmutzigen Geschichte wohl jemals den wahren Grund erfahren.",ep:19,g:53,l:145,wd:true,fm:true,w:15,an:11,tw:true,e:[7,4,3,5,30,50,false,true],c:"CI>450&CV>200",p:10000};
I.u[7104] = {n:"Schuholong Backs Retrotreter",t:11,d:"Diese Schuhe dienen dem Training bestimmter Kampfkunst-Tricks. Des hohen Rückwärts-Dreh-Kicks und des tiefen Rückwärts-Fussfegers, unter anderem. Doch wirken sie so wenig neuzeitlich und sind vom Stil her so alt, dass sie in Vergessenheit geraten sind.",ep:18,g:58,l:67,wd:true,fm:true,w:5,p:11700};
I.u[7105] = {n:"Pandala-Amulett",t:24,d:"Diese gewöhnlich erscheinende Amulett enthält ein Geheimnis, welches allein ein Pandawa kurz vor seinem Tod begreifen kann.",ep:18,g:48,l:0,wd:true,fm:true,w:0,p:1};
I.u[7106] = {n:"Larvamulett",t:1,d:"Mit diesem Larvenkopf um den Hals werdet ihr bis auf ein Haar Ulk Hochgan ähneln, dem bekanntesten Larvendompteur der Gegenwart.",ep:5,g:88,l:26,wd:true,fm:true,w:5,s:33,p:1950};
I.u[7107] = {n:"Larvuschus",t:11,d:"Wer hat noch niemals davon geträumt, seine Füße in das Innere einer Larve zu tauchen? Ihr nicht? Dann seid mal nicht so zugeknöpft und versucht es doch einfach!",ep:1,g:53,l:33,wd:true,fm:true,w:10,s:33,p:3150};
I.u[7108] = {n:"Larvasack",t:81,d:"Dieser originelle Rucksack ohne Schnickschnack war vor langer Zeit einmal sehr im Trend. Das ist wieder einmal ein Beispiel für den wirklich schauderhaften Modegeschmack eurer Urahnen.",ep:5,g:60,l:27,wd:true,fm:true,w:10,s:33,p:2150};
I.u[7109] = {n:"Larvamütz",t:16,d:"Endlich bietet sich euch die Möglichkeit, wie eine echte Larve auszusehen! Endlich könnt ihr euch offen als langjähriger Anhänger des Larvendaseins outen und euer Leben im Larvenstadium beenden!",ep:5,g:103,l:34,wd:true,fm:true,w:10,s:33,p:3225};
I.u[7110] = {n:"Larvuta",t:3,d:"Dieser furchtverbreitende Stab ist in Wirklichkeit nichts anderes als der getrocknete, anschließend verzauberte und schließlich wieder mit Flüssigkeit gefüllte Darm einer Larve. Er sieht jetzt natürlich nicht mehr sehr appetitlich aus. Also gleicht er euch darin ein wenig, bloß mit dem Unterschied, dass ihr nicht verzaubert wurdet.",ep:5,g:19,l:40,wd:true,fm:true,w:5,an:11,e:[5,3,2,4,40,50,false,true],s:33,p:4000};
I.u[7112] = {n:"Scheckiger Dofus",t:23,d:"Nur die Vereinigung eines schwarzen Drachens und eines weißen Drachens könnte einen derartigen Dofus hervorgebracht haben. Oder aber es handelt sich hier um eine Fälschung...",ep:1,g:8,l:6,wd:true,fm:true,w:1,p:50000};
I.u[7113] = {n:"Dofawa",t:23,d:"Dieser Dofus erinnert einen seltsamerweise an das Ei eines wilden Dracotruters... Diesmal könnte es sogar gut sein, dass der Schein nicht trügt.",ep:1,g:9,l:6,wd:false,fm:true,w:1,p:10};
I.u[7114] = {n:"Ebenholz-Dofus",t:23,d:"Schwarz wie die Finsternis und hart wie Stein ist dieser Dofus. Grougalorasalar, der schwarze Drache, hat ihn einst erschaffen, um etwas Gesellschaft zu haben. Dabei hat er leider vergessen, dass Eier nicht sprechen können, ganz egal, wie magisch sie auch sein mögen.",ep:1,g:7,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7115] = {n:"Elfenbein-Dofus",t:23,d:"Dieses Ei ist von strahlender Reinheit. Das liegt daran, dass es jeden Morgen von Dardondakal, dem weißen Drachen, mit einem Odemhauch gebleicht wird (ein alter Trick, den dieser von seiner Großmutter erlernt hat.)",ep:1,g:11,l:6,wd:true,fm:true,w:10,p:50000};
I.u[7116] = {n:"Mertas Ring",t:9,d:"Dieser Ring besitzt einen sehr seltsamen Zauber. Wenn ihr ihn erst einmal angesteckt habt, könnt ihr nicht mehr mit dem Juwelier reden, der ihn angefertigt hat.",ep:18,g:91,l:59,wd:true,fm:true,w:5,p:9155};
I.u[7117] = {n:"Ring\'N\'Sing",t:9,d:"Eine Gruppe sehr weltoffener, aber leider auch unbegabter Minnesänger nutzte einst diese Ringe, um sich inmitten des Publikums leichter wiedererkennen zu können. Doch ihre Ringe nutzen ihnen wenig, da sie keinen Erfolg, und ergo auch kein Publikum hatten. Laut gewisser böser Zungen mit sehr guten Ohren war das verdient.",ep:18,g:92,l:53,wd:true,fm:true,w:5,p:7150};
I.u[7118] = {n:"Nachtfaltering",t:9,d:"Dieser Ring in Form eines dicken Nachtschwärmers wird eure Hände mit Sicherheit nicht gerade schmücken, doch wird es auch nicht zu eurem Schaden sein, ihn zu tragen...",ep:18,g:94,l:90,wd:true,fm:true,w:5,p:20775};
I.u[7119] = {n:"No Ha-Ring",t:9,d:"Der Juwelier, der dieses Schmuckstück hervorgebracht hat, soll trotz der Ähnlichkeit seines Names nicht mit dem berühmten Schwertschmied verwandt gewesen sein. Doch davon abgesehen, soll dieses Kleinod die Seele seines Trägers der unverdorbenen Buschatmosphäre öffnen, und so eventuelle Schicksalsstöße abfedern. Allerdings hat niemand je so richtig verstanden, was genau damit gemeint ist.",ep:18,g:85,l:58,wd:true,fm:true,w:5,p:8750};
I.u[7120] = {n:"No Ah-Ring",t:9,d:"Der Besitzer dieses Ringes – ein alter Mann – soll, wenn man gewissen Gerüchten Glauben schenken darf, einst alle Kreaturen von Moons Insel vor einer furchtbaren Sintflut bewahrt haben, indem er sie auf seine Floß brachte. Eine andere Version der gleichen Geschichte besagt allerdings, er habe sein Floß gegen ein kleines Äffchen eingetauscht, statt alle Kreaturen der Insel zu retten.",ep:18,g:86,l:44,wd:true,fm:true,w:2,p:5350};
I.u[7121] = {n:"Ozochiramial-Ring",t:9,d:"Dieser Ring enthält eine überaus mächtige Verzauberung, die selbst die stärksten aller Abenteurer krank machen kann. Man sagt, er sei ursprünglich dazu gefertigt worden, seinen Träger zu heilen, wenn dieser ihn am Ringfinger trüge. Allerdings sei er sei deswegen so gefährlich und aggressiv geworden, weil er gegen seinen Willen oftmals an wenig appetitlichen Orten getragen wurde...",ep:18,g:87,l:50,wd:true,fm:true,w:5,p:6655};
I.u[7122] = {n:"Initialiring",t:9,d:"Der Ring für Anfänger par excellence, aber gleichzeitig auch ein Symbol für unaussprechliche Lebensgewohnheiten. Er steht euch ganz gut.",ep:16,g:88,l:18,wd:true,fm:true,w:2,p:1100};
I.u[7123] = {n:"Obszönling",t:9,d:"Dieser Ring, der nur für aufgeklärte Abenteurer geeignet ist, birgt die Gefahr, eure Umgebung zu schocken, wenn diese aus jungen und unschuldigen Kreaturen besteht.",ep:18,g:95,l:70,wd:true,fm:true,w:2,p:12900};
I.u[7124] = {n:"Milchschoko-Dofus",t:42,d:"Dieses Dofus-Ei besitzt eine mächtige Kraft: nämlich euch das Wasser im Mund zusammenlaufen zu lassen.",ep:1,g:27,l:1,wd:false,fm:true,w:1,p:1};
I.u[7125] = {n:"Weißer Schoko-Dofus",t:42,d:"Dieses Dofus-Ei besitzt eine mächtige Kraft: nämlich euch das Wasser im Mund zusammenlaufen zu lassen.",ep:1,g:28,l:1,wd:false,fm:true,w:1,p:1};
I.u[7128] = {n:"OkaRinga",t:9,d:"Im Gegensatz zu dem, was einige wohl denken mögen, hat dieser Ring nicht das Geringste zu tun mit der heißen Karina, die mit ihrer spärlichen und exotischen Bekleidung schon oft die Piratenbar in Sufokia zum Kochen gebracht hat. In Wahrheit hat ein musikalischer Tofuzüchter dem Ring diesen Namen gegeben, weil er am Daumen getragen einen Ton produziert, der dem Umdrehen eines Tofu-Halses ähnelt.",ep:18,g:89,l:54,wd:true,fm:true,w:5,p:7700};
I.u[7129] = {n:"Schokopanda",t:42,d:"Nicht nur auf die Inhaltsstoffe der Schokolade kommt es an, nein, die Form ist ebenfalls sehr wichtig. Probiert doch einmal einen Schoko-Torf-Morph, dann wisst ihr wovon ich rede.",ep:0,g:31,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[7130] = {n:"Schokodofus-Rezept",t:24,d:"Dies ist das genaue Rezept für die Herstellung eines Schokoladen-Dofus. Es gibt nichts besseres, um eure Freunde zu verblüffen.",ep:1,g:250,l:1,wd:false,fm:true,w:0,p:100};
I.u[7131] = {n:"Opi Uhms Ring",t:9,d:"Dieses Schmuckstück hat bereits mehr als einen Abenteurer zum Träumen gebracht, bevor es in eure Hände fiel. Tatsächlich weist man ihm sehr viele Fähigkeiten zu. So verwandelt er auch den kämpferischsten Abenteuerer in einen sanftmütigen Träumer wie den gutmütigen Opi Uhm. Ein Hinweis warnt davor, den Ring ins Feuer zu werfen, liefert aber darüberhinaus keine weiteren Details.",ep:16,g:90,l:57,wd:true,fm:true,w:5,p:8475};
I.u[7132] = {n:"O\' Ring Ami",t:9,d:"Dieser Ring verdankt seinen Namen den letzten Worten seines Schöpfers: \"O\' Ring Ami! Du warst stets ein treuer Freund!\" stieß er aus, während er qualvoll verendete. Es ist bemerkenswert, dass dieser Ring aus Bambus besteht, und das zu einer Zeit, wo es noch gar keinen Bambus gab. Ein weiteres Rätsel mehr, welches bestimmt nicht vor mehreren Jahrzehnten gelöst wird.",ep:16,g:96,l:49,wd:true,fm:true,w:5,p:6300};
I.u[7133] = {n:"Mixomawose",t:30,d:"Jeder Wabbit wird euch dies bestätigen: wenn ihr das Leben nicht durch eine blutrote Brille sehen wollt, dann meidet die Mixomawose wie die Pest!",ep:1,g:9,l:1,wd:false,fm:true,w:0,p:1};
I.u[7134] = {n:"Tollwut",t:30,d:"Man sagt, die Tollwut würde die Betroffenen völlig verändern. Kriegerische Charaktere würden auf einmal sanftmütig, während sonst ganz ruhige auf einmal aggressiv würden. Hingegen werden Kreaturen, die vorher schon sabberten, durch die Tollwut nicht aufhören zu sabbern.",ep:1,g:10,l:1,wd:false,fm:true,w:0,p:1};
I.u[7135] = {n:"Maloria",t:30,d:"Hier handelt es sich um eine Krankheit, die durch Moskitos in den tropischen Gegenden Amaknas verursacht wird. Die Maloria wird von manchen Eingeborenen auch Molaria genannt, da sie auch durch die Spucke dieser Biesterchen übertragen werden kann.",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[7136] = {n:"Medaille Kido",t:1,d:"Diese Medaille gehörte einst einem berühmten Pandawa, Großmeister einer Kampfkunst-Schule, der seinen Schülern beibrachte sich zu verteidigen, indem sie sich die Kraft ihrer Gegner zunutze machten. Seine Schule verschwand allerdings schließlich, weil die Gegner nämlich irgendwann nicht mehr stark genug waren.",ep:19,g:89,l:125,wd:true,fm:true,w:10,p:40425};
I.u[7137] = {n:"Cape Huccino",t:17,d:"Dieser Umhang wurde nur zu einem einzigen Zweck angefertigt: nämlich den Träger viele Tage lang wach zu halten. Das funktioniert sogar auch, jedoch mit der Nebenwirkung, dass der Umhang so starr wird, dass er euch nicht nur unter Umständen, sondern gar unter allen Umständen aufrecht erhält. Ein echter Umstand sozusagen, bei dem selbst ein aufgegangener Schnürsenkel zu einem großen, umständlichen Problem werden kann.",ep:16,g:15,l:44,wd:true,fm:true,w:15,p:5300};
I.u[7138] = {n:"Ortiz",t:17,d:"Dieser Mantel eines der Größten von ganz Amakna ist für seine legendäre Leichtigkeit bekannt. Er kann sogar zu den warmen Jahreszeiten ganz ohne Unterkleidung getragen werden, ohne dass es auffällt. Damit kann der Träger seine exhibitionistischen Gelüste voll und ganz ausleben.",ep:19,g:91,l:125,wd:true,fm:true,w:15,p:40175};
I.u[7139] = {n:"Gürtel Lena",t:10,d:"Lena, die Schusterin, liebte es, über die Wiesen und Felder zu wandern, auf der Suche nach der Erfüllung ihres Traums. Oder besser gesagt: auf der Suche nach Liebe. Doch anstatt das geliebte Wesen zu finden, fiel sie in einen tiefen Bewässerungsgraben voller Unrat und ertrank. Ihren Körper fand man erst 7 Jahrzehnte später beim Ausleeren besagten Grabens. Dabei rief ihr Bruder: \"Ich dachte mir schon, dass sie hier irgendwo steckten mußte\", und fiel seinerseits hinein.",ep:19,g:82,l:125,wd:true,fm:true,w:15,p:39975};
I.u[7140] = {n:"Xenaschurz",t:10,d:"Der Schein mag etwas anderes andeuten, doch war Xena in Wirklichkeit niemals eine echte Kriegerin als vielmehr eine Schusterin. Ihre weiblichen Kurven und ihre grenzenlose Leidenschaft für häusliche Pflichten prädestinierten sie zwar zu einer brillianten Karriere in den großen Brauereien von Amakna, doch wollte es das Schicksal anders...",ep:19,g:83,l:125,wd:true,fm:true,w:15,p:40125};
I.u[7141] = {n:"Holond",t:16,d:"Dieser seltsame Hut wird euch wirksam vor den Strahlen der Sonne schützen, und das sogar nachts! Doch Vorsicht: aller paar Jahrzehnte erwacht er wieder zum Leben und versucht, seinen Träger im Schlaf zu ersticken.",ep:19,g:111,l:122,wd:true,fm:true,w:10,p:37925};
I.u[7142] = {n:"Piruk",t:16,d:"Dieser Hut wird gern von Xelors benutzt, um ihre beginnende Kahlköpfigkeit zu kaschieren. Manche Enutrofs nutzen ihn sogar dazu, ihre Frau zu verstecken. Beides sind wunderbare Methoden, um die schlimmsten Sorgen des Alltages unter den Hut zu kehren.",ep:19,g:112,l:145,wd:true,fm:true,w:15,p:46980};
I.u[7143] = {n:"Solomonk",t:16,d:"Der Solomonk ist der typische Hut eines alten Pandawa-Stammes, deren Spezialität die Anfertigung diverser Abführmittel ist. Die Pandawas waren oftmals gezwungen, die Auswirkung ihrer Tränke und Mittelchen an sich selbst auszuprobieren, wobei sie immer guten Gebrauch von diesen Hüten machten. Dadurch werden diese zwar nicht gerade eleganter, doch hätte man andernfalls wohl niemals herausgefunden, welch hervorragende Nachtöpfe sie abgeben.",ep:19,g:123,l:120,wd:true,fm:true,w:50,p:36880};
I.u[7144] = {n:"Fahlut",t:16,d:"Dieser Brauthut ist schon seit langem nicht mehr modern. Vielleicht liegt das an den Spitzen, die den Eindruck vermitteln, er würde aus einem anderen Jahrhundert stammen. Doch zu einem Schlüpfer umgenäht und auf einem behaarten Kopf getragen, könnte er selbst den pingeligsten aller Chafer in Trance versetzen.",ep:19,g:116,l:108,wd:true,fm:true,w:15,p:29775};
I.u[7145] = {n:"Gaddiehaube",t:16,d:"Der Gaddie ist eine seltsame Kreatur aus einer Phantasiewelt, der sich vor allem durch seine Schlauheit, seinen Hass auf alles Pflanzliche und seine Fähigkeit, zur Not auch viele Tage hinweg zu hungern, auszeichnet. Diese hochkomplizierte Kreatur war so unberechenbar und so schwer zu fangen, dass man sie in Ruhe in den endlosen Minen von Kruup leben ließ, wo sie einem alten, Fresssäckchen verschlingenden Licha begegnete.",ep:19,g:115,l:106,wd:true,fm:true,w:15,p:26375};
I.u[7146] = {n:"Berthusalem",t:16,d:"Diese übermächtige Haube sieht zwar eher wie eine Perrücke aus, ist jedoch tatsächlich  übermächtig. Ihr Träger kann sich nämlich in jemand anderen verkleiden, um naive Kreaturen zu foppen. Dies tat auch ihr Vorbesitzer sehr gerne. Doch eines Tages wurde er entlarvt und enthaubt. Dabei entpuppte sich seine Kahlköpfigkeit. Anschließend wurde er zum Tode verurteilt. Sein großes Talent als Steinmetz rettete ihn, da man ihn beauftragte, die Kronjuwelen des größten MuWulfs in Stein zu meißeln, doch war dies nur ein kurzer Aufschub der Strafe. Einmal das Kunstwerk vollbracht, wurde er lebend verbrannt.",ep:18,g:114,l:81,wd:true,fm:true,w:10,p:16925};
I.u[7148] = {n:"Tafel weißer Schokoloade",t:42,d:"...",ep:1,g:33,l:1,wd:false,fm:true,w:1,p:1};
I.u[7149] = {n:"Tafel dunkle Schokolade",t:42,d:"Diese Tafel Schokolade mit einem großen Prozentanteil an raffiniertem Kakao ist eine wahre Gaumenfreude. Doch sollte man sie immer nur in Maßen genießen, sonst gibt\'s Verdauungsbeschwerden.",ep:1,g:34,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:200};
I.u[7150] = {n:"Bekilli",t:16,d:"Dieser Hut mit dem lächerlichen Namen gehörte einst einem armen Ecaflip, der nach einem schweren Trauma den Gebrauch der Sprache verlernt hatte. Obwohl in ihm eine Künstlerseele steckte, ward er gezwungen, eine Ausbildung zum Braumeister zu machen. An seinem 14.Geburtstag ertrank er in einem Faß voll Bier und seinen Tränen. Glücklicherweise konnte das Bier noch gerettet werden, was dazu führte, dass sich Priester bei der Beerdigung ins Alkoholkoma soff. Als er wieder aufwachte, machte er dort weiter, wo er aufgehört hatte.",ep:19,g:109,l:111,wd:true,fm:true,w:20,p:31725};
I.u[7151] = {n:"Helmchen des Lords",t:16,d:"Dieser Helm war ausschließlich großen Anführern vorbehalten. Der optionale Federbusch lässt sich nach Belieben auch durch einen einbaubedürftigen Heiligenschein ersetzen. Außerdem gibt es dieses Modell auch in Schwarz und mit eingebautem Visier für maximale Verdunklung. Ein Muss für alle wahren Möchtegern-Lords!",ep:19,g:108,l:120,wd:true,fm:true,w:15,p:36925};
I.u[7152] = {n:"Kanistere",t:16,d:"Dieser Hut in Fassform wurde einst bei der Feuerwehr Amaknas eingesetzt, um kleinere Feuer auf den Getreidefeldern zu löschen. Heutzutage kommt er jedoch eher in den Brauereien zum Einsatz, wo ihn sich die Schankmädchen aufsetzen und als Fass ohne Boden, aber mit Beinen, die Gäste bedienen.",ep:19,g:110,l:120,wd:true,fm:true,w:20,p:36675};
I.u[7153] = {n:"Bohus Hammer des Tohuwers",t:7,d:"Dieser gewaltige Hammer macht einen enormen Krach, wenn er auf ein Ziel auftrifft. Vorsicht daher, wenn ihr den Schädel eines Iops ins Visier nehmt, denn dessen Vakuum prädestiniert ihn als tollen Resonanzkörper. Dabei könnten euch die Ohren wegfliegen.",ep:19,g:51,l:126,wd:true,fm:true,w:15,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>200",p:40200};
I.u[7154] = {n:"Däumlingsklopfer",t:7,d:"Dieser sehr leichte und einfache gebaute Hammer war ursprünglich für extrem kleine Wesen gedacht. Xelors führten ihn vom äußersten Ende des Stieles aus, um mit dem Hammerkopf Arachneen platt zu schlagen. Doch wurde er schnell zweckentfremdet, und die Iopkinder spielen nun damit: \"Wer ist Heimwerkerkönig\".",ep:18,g:46,l:107,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,40,50,false,false],c:"CI>350&CV>200&CW>100",p:29475};
I.u[7155] = {n:"Hammer des Donnerwetters",t:7,d:"Der berühmte Kapitän Hardrock benutzte viele Jahrzehnte lang diesen furchtbaren Hammer, um all diejenigen niederzustrecken, die sich ihm in den Weg stellten – Frauen und Kinder mit eingeschlossen. Sein legendärer schlechter Charakter und seine Vorliebe für Alkohol machten ihn dennoch zu einer bei Freund und Feind respektierten Persönlichkeit.",ep:18,g:48,l:113,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,40,60,false,false],c:"CI>150&CW>100&PG=5",p:32650};
I.u[7156] = {n:"Hammer der Burg",t:7,d:"Dieser angerostete alte Hammer ist so brüchig wie die Burg selbst, die er beschützte. Aber um verirrte Moskitos oder andere Wassertiere zu erschlagen, ist er immer noch perfekt geeignet.",ep:18,g:50,l:107,wd:true,fm:true,w:20,an:15,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>150&CV>150&(PG=2|PG=5)",p:334251};
I.u[7157] = {n:"Stürmischer Glockenklöppel",t:7,d:"Dieser Hammer wurde ehemals dazu verwendet, die Glocke der Kirche von Amakna zum Erklingen zu bringen. Heutzutage dient er allerdings eher dazu, Musik zu machen, indem er die Knochen aller sich zu nah heranwagenden Unvorsichtigen zermalmt.",ep:19,g:49,l:124,wd:true,fm:true,w:15,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CI>250",p:29400};
I.u[7158] = {n:"Gehs Fanghammer",t:7,d:"Dieser Hammer wurde vom berüchtigten Alchimisten Geh während seines Aufenthaltes im Gefängnis von Brâkmar gebaut. Er wollte damit ursprünglich die alchimistischen Gerätschaften seiner Konkurrenten zerschlagen, sobald er aus dem Gefängnis wieder herauskäme.",ep:19,g:47,l:143,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CA>250&PG=5",p:46550};
I.u[7159] = {n:"Mauls Wurfhammer",t:7,d:"Dieser Bergmannshammer kann je nach Bedarf auch wie eine Schaufel oder eine Spitzhacke benutzt werden. Daher ist er sehr praktisch und flexibel einsetzbar. Jedoch wurde sein Einsatz bei der Gartenarbeit verboten, da er die Tendenz hat, Rasenflächen meist permanent zu beschädigen.",ep:19,g:52,l:135,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>300",p:41200};
I.u[7160] = {n:"Arkaner Bogen",t:2,d:"Dieser Bogen wurde vor sehr langer Zeit durch dunkelste Magie verzaubert. Doch ist immer noch genug davon enthalten, um Gegner und Anwender gleichermaßen zu beunruhigen.",ep:19,g:44,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CI>400&PG=9",p:36900};
I.u[7161] = {n:"Frischpling",t:2,d:"Dieser Bogen wird vornehmlich dazu eingesetzt, die Keiler der Ebenen zu jagen. Tatsächlich ist er so zugkräftig, dass man mit einem einzigen Pfeil gleich mehrere Frischlinge erlegen kann, vorausgesetzt, sie stehen schön in Reih und Glied.",ep:18,g:45,l:107,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CI>250&CA>150",p:29325};
I.u[7162] = {n:"Place-Bogen",t:2,d:"Dieser Bogen gehörte einer bekannten Gruppe von Barden, die darauf spezialisiert waren, das Gehör ihrer Gegner mit Kriegsgesängen auszuschalten. Sie wurden allerdings für viele Jahre nach Pandala ins Exil verbannt, da ihre Gesänge selbst noch die Rablinge Brâkmars taub werden ließen. Nachdem sie viele Generationen von Pandawas verrückt werden ließen, wurden sie schließlich lebend dem großen Sorlok ausgeliefert, der sie 752 Jahre lang langsam verdaute.",ep:19,g:46,l:130,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,3,6,30,50,false,true],c:"CA>200&CC>70&PG=9",p:30000};
I.u[7163] = {n:"Weglaufbogen",t:2,d:"Dieser Bogen wurde von seinem Besitzer in erster Linie zur Abschreckung verwendet. Er erzählte einfach jedem, dass seine Pfeile vergiftet seien. Dadurch gelang es ihm immer, die örtliche Bevölkerung in Angst und Schrecken zu versetzen, so dass all die Feiglinge, die sich ihm sonst in den Weg stellten, statt dessen lieber das Weite suchten.",ep:19,g:47,l:124,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"PG=9&CA>250",p:39050};
I.u[7164] = {n:"Guter Bogen, kein schlechter Bogen",t:2,d:"Dieser leichte und zerbrechliche Bogen hat bereits viele Anhänger unter den Abenteurern gefunden – zumindest bei jenen, die mehr auf den Schein, als auf die Wirksamkeit achten.",ep:19,g:48,l:143,wd:true,fm:true,w:15,an:10,e:[5,5,2,6,30,50,false,true],c:"CA>120&CI>120&CC>120&CV>300",p:46025};
I.u[7165] = {n:"Killniemand-Stabo",t:3,d:"Im Gegensatz zu seinem Namen und trotz seines lächerlichen Aussehens hat dieser hochexplosive und sehr mächtige Stab schon so manch einem Abenteurer den Tod gebracht. Seine Macht erklärt sich dadurch, dass er vor dem Schnitzen und Verzaubern in den Lavastrom eines gerade ausbrechenden Vulkans getaucht wurde.",ep:18,g:54,l:105,wd:true,fm:true,w:15,an:11,e:[5,4,3,6,50,50,false,true],c:"CI>300",p:28625};
I.u[7167] = {n:"Endlosschleifstab",t:3,d:"Der Handwerker, der diesen Stab hervorgebracht hat, hatte eine gewaltige Menge an Lehrlingen, die er die ganze Zeit über ihre Stäbe polieren ließ. Eigentlich sollte er ihnen ja die Sitten und Gebräuche des Handwerks beibringen, doch da er eine Null in Didaktik war, begann er tausendfach seine Erklärungen und brachte sie nie zu Ende.",ep:18,g:50,l:43,wd:true,fm:true,w:5,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>60",p:5000};
I.u[7168] = {n:"Alkos Hohlstab",t:3,d:"Nachdem er fertig geschnitzt wurde, hat man diesen Stab für mehrere Jahre in Bier eingelegt. Obwohl er sich bereits im Anfangsstadium der Vermoderung befindet, hat er immer noch einige der gewonnenen magischen Eigenschaften beibehalten – jedenfalls genügend, um damit eure Verbündeten auszulöschen.",ep:18,g:51,l:63,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150",p:4800};
I.u[7169] = {n:"Freds Feuerstab",t:3,d:"Dieser Stab ist nicht nur ideal, um Feuer anzuzünden oder langweilige Hochzeiten in Schwung zu bringen, sondern er besitzt zudem auch noch die Funktion, einen Funken von Hoffnung in euer Leben zu bringen. Ein Gegenstand, den man sich nicht entgehen lassen sollte.",ep:18,g:52,l:81,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>200",p:17000};
I.u[7170] = {n:"Verfrut und Zugestäbt",t:3,d:"Verf, der Bäcker, war so verrückt, die Holzfällerin Zugeta zu heiraten. Doch gleich am nächsten Morgen verstarb sie, nachdem sie zu viele seiner fetten und kalorienreichen Kaffeeteilchen verzehrt hatte, während er von einem im Kamin explodierendem Holzscheit durchbohrt wurde. Seitdem hat sich die Redewendung \"Verfrut und Zugestäbt\" eingebürgert, die in den gleichnamigen Stab eingeritzt wurde.",ep:18,g:46,l:112,wd:true,fm:true,w:15,an:11,tw:true,e:[5,2,3,4,30,50,false,true],c:"CI>350&CV>200",p:32330};
I.u[7171] = {n:"Stab der Kopflosigkeit",t:3,d:"Der Erschaffer dieses Stabes pflegte ständig zu vergessen, seine Kinder von der Schule abzuholen. Seine Frau machte sich darüber auch noch lustig. Daher beschloss er schließlich, diesen Stab zu schnitzen und so zu verzaubern, dass dieser ihn täglich daran erinnert, die Kinder abzuholen. Anschließend schnitzte er noch ähnliche Stäbe, um seine Frau daran zu erinnern, das Haus zu putzen. Doch waren diese scheinbar nicht mächtig genug.",ep:19,g:47,l:127,wd:true,fm:true,w:15,an:11,tw:true,e:[10,4,4,6,40,60,false,true],c:"CI>300&CV>300",p:43125};
I.u[7172] = {n:"Stapopel",t:3,d:"Dieser magische Stab wird auch heutzutage noch dazu benutzt, Klärgruben zu entleeren und Kanalisationsgräben zu säubern. Außerdem ist er ein praktisches Hilfsmittel für alle Nasenpopler. Erfahrene Stabschnitzer werden euch bestätigen können, dass das Stapopel all seine Magie aus dem von ihm aufgegabelten Unrat bezieht, insbesondere dem in eurer Nase.",ep:18,g:49,l:105,wd:true,fm:true,w:20,an:11,tw:true,e:[10,4,2,4,30,60,false,true],c:"CI>200&CW>50",p:28375};
I.u[7173] = {n:"Würgrut",t:3,d:"Diese Furcht erregende Rute kann sich um den Hals eurer Gegner wickeln, um sie langsam, aber sicher zu Tode zu würgen. Ein origineller und vornehmer Weg, um eurem Gegenüber eure Missachtung kund zu tun!",ep:18,g:48,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,4,50,50,false,true],c:"CI>50",p:2100};
I.u[7174] = {n:"Pandawushu-Umhang",t:17,d:"Der Besitz dieses Umhangs ist eine der Voraussetzungen für die Teilnahme am Pandawushu-Training.",ep:1,g:89,l:10,wd:true,fm:true,w:5,p:10};
I.u[7175] = {n:"Ergebnis der Shamanischen Untersuchung",t:24,d:"Ein positives Ergebnis bei der Shamanischen Untersuchung ist unabdinglich für alle, die Pandawushuka praktizieren wollen.",ep:18,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[7176] = {n:"Wurzel Triss",t:4,d:"Ein gewisser Frank, seines Zeichens Stockschnitzer, soll dieses kleine Wunderwerk angefertigt haben, das in der Lage ist, den Himmel zu verdunkeln und das Blut eurer Gegner strömen zu lassen, selbst wenn diese gar keines besitzen. Man sagt, Frank habe mehr als tausend Stunden daran gesessen. Davon bleiben auch eure Gegner sicherlich nicht unberührt.",ep:19,g:53,l:143,wd:true,fm:true,w:15,an:12,e:[10,4,1,1,45,70,false,false],c:"CS>150&CV>400&CI>50&CA>50",p:46600};
I.u[7177] = {n:"Pandawushu-Stirnband",t:16,d:"Mit dem Pandawushu-Stirnband an der Stirn könnt ihr jederzeit all die jungen Lenalds erschrecken und euch als großen Meister der Kampfkünste ausgeben. Vergesst dennoch nicht, dies durch kurze schrille Kriegschreie zu verstärken, um ein wenig glaubhafter zu erscheinen.",ep:1,g:102,l:1,wd:false,fm:true,w:5,p:10};
I.u[7178] = {n:"YamYam-Wurzel",t:4,d:"Seit vielen Generationen nutzen Sadidas magische Wurzeln im Kampf. Seltsamerweise weigern sich die meisten, diese spezielle Wurzel zu gebrauchen... Angeblich sei sie nämlich besser zum Verdau als zum Verhau geeignet, so die kryptischen Worte der Sadidas. Ist ja auch ganz egal, solange diese Wurzel im Kampf überall dort weh tut, wo sie hingelangt. Das ist die Hauptsache.",ep:18,g:58,l:86,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,50,50,false,false],c:"CI>150",p:19100};
I.u[7179] = {n:"Straßen und Wege: der verwunschene Wald",t:25,d:"Diese Buch enthält Hinweise zu den interessanten Ausflugszielen im Herzen des Labyrinths des verwunschenen Waldes. Einfach eine Pflichtlektüre! \nJedenfalls, wenn man der Rückseite des Umschlags Glauben schenken darf.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7181] = {n:"Apothecawurzlika",t:4,d:"Diese immergrüne Wurzel ist nicht nur ein hervorragendes Medikament gegen diverse Fiebererkrankungen, sondern man kann mit ihr auch hervorragend auf Gegner eindreschen. Man erkennt sie sofort am charakteristischen Klang, wenn sie peitschend über die Gegner streicht. Dies entlockt ihr schön klingende Harmonien, die hervorragend zu schrillen Schmerzensschreien oder einem letzten Todesseufzer passen.",ep:18,g:54,l:106,wd:true,fm:true,w:15,an:12,tw:true,e:[10,4,1,1,50,50,false,false],c:"CV>250&CW>60",p:28575};
I.u[7182] = {n:"Ers Druckwurzel",t:4,d:"Es war einmal eine unglückliche Bäuerin namens Er. Ihr Mann war ein großer Faulpelz und Nichtsnutz, darum mußte sie ihm ständig Druck machen, um ihn zum Arbeiten zu bewegen. \"Erdbeergelee gibt es erst, wenn das Getreide gemäht ist!\" oder \"Pilze rauchen gehen darfst Du erst nach dem Melken der Fresssäcke!\". Dabei schwang sie diese Wurzel, welche im Laufe des langjährigen Gebrauchs die Eigenschaft, Druck auszuüben, von ihrer einstigen Besitzerin übernahm.",ep:18,g:60,l:103,wd:true,fm:true,w:15,an:12,tw:true,e:[15,4,1,1,25,50,false,false],c:"CV>200",p:27280};
I.u[7183] = {n:"Sinusoidalgewurzel",t:4,d:"Diese Wurzel soll angeblich die reinsten Formen besitzen. Manche Künstler gehen sogar soweit, sie als \"perfekt\" zu bezeichnen. Vielleicht ist dies ja der Grund, warum manche Abenteurer sie mit mehr Liebe behandeln, als ihre eigene Verlobte.",ep:18,g:55,l:88,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>70",p:20000};
I.u[7184] = {n:"Katastrowurzel",t:4,d:"Diese furchtbare Wurzel ist dafür bekannt, überall dort lokale Klimakatastrophen auszulösen, wo sie eingesetzt wird. Daher solltet ihr besser vermeiden, euren Gegnern den Hintern zu versohlen – man weiß ja nie, was ihr damit alles auslösen würdet.",ep:18,g:56,l:86,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,50,50,false,false],c:"CV>100",p:18945};
I.u[7185] = {n:"Schlagwurzel",t:4,d:"Diese Wurzel im Kampf zu verwenden ist sehr einfach. Denn sie ist lebendig und scheint oftmals großen Gefallen daran zu finden, auf Gegner einzudreschen. Doch manchmal schaltet sie auch auf stur und schlägt an Ort und Stelle Wurzeln. Dann hilft auch alles Schlagen auf die Wurzel nichts mehr – sie hat ja sowieso bereits einen Hau weg.",ep:18,g:57,l:103,wd:true,fm:true,w:20,an:12,e:[5,5,1,1,50,50,false,false],c:"CV>200&CW>150",p:27425};
I.u[7186] = {n:"Rangaufstiegsbestätigung",t:24,d:"Auf diesem Zettel steht das offizielle Datum, an dem ihr zuletzt einen Pandawashuka-Rang aufgestiegen seid.",ep:18,g:58,l:0,wd:true,fm:true,w:0,p:1};
I.u[7187] = {n:"Bogris EltzIhn",t:2,d:"Diesem Bogen wird nachgesagt, er könne unauffällig und aus großer Entfernung dem Volk Kamas entziehen. Doch am überraschendsten bleibt die Tatsache, dass er trotz allem jahrelang noch sehr populär blieb. Zum Glück für die Bevölkerung beginnt er jedoch, sich langsam abzunutzen.",ep:19,g:50,l:124,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,4,6,30,2,false,true],c:"CA>100&CC>100&PG=9",p:40000};
I.u[7188] = {n:"Zitrolch",t:5,d:"Dieser Dolch ist hervorragend dazu geeignet, Früchte zu ernten oder aber das Gras unter den Füßen eurer Gegner abzuschneiden. Ein originelles Mittel, sie zu überraschen!",ep:18,g:48,l:113,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,35,50,false,false],c:"CA>100&CI>100",p:32575};
I.u[7189] = {n:"Rod Gerse",t:4,d:"Dieser sonderliche Stecken ist eine verbesserte Version des berühmten Gott-Stockes. Tatsächlich wurde er nach vielen Tests mit dem Gott-Stock von den Liebespriesterinnen entwickelt und erbaut. Dieses Modell hier wurde sogar von Kuri höchstpersönlich benutzt, was es zu einem von Sammlern heiß begehrten Unikat macht.",ep:19,g:59,l:176,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,100,false,false],c:"CI>450",p:57000};
I.u[7190] = {n:"Maydhyn China-Dolche",t:5,d:"Diese auf Maß für einen weiblichen Sram angefertigten Dolche entstammten einem Wettbewerb für Waffenschmiede. Die Bedingungen: derjenige, dem es gelingen würde, einen Dolch zu fertigen, der in der Lage ist, jeden Tofu mit nur einem Schlag zu erledigen, würde 3 Nächte in ihren Armen liegen können. Doch unerwarteterweise blieb dieser Aufruf völlig unbeachtet. Erst viele Jahrezehnte später schmiedete ihr ein alter Enutrof im Ruhestand ihren Dolch, wobei sich die Belohnung im Laufe der Zeit doch sehr verändert haben soll...",ep:18,g:45,l:100,wd:true,fm:true,w:10,an:13,tw:true,e:[15,3,1,1,35,50,false,false],c:"CS>150&CA>150",p:21800};
I.u[7191] = {n:"Ramougres Einfassmesser",t:5,d:"Ramougre war ein alter Sram, der sich auf die Herstellung von Schmuckstücken verlegt hatte. Er nutzte sein Einfassmesser aber nicht nur für seine Kreationen, sondern auch, um seine eigenen Kunden zu meucheln, wenn er sich mal wieder langweilte. Er war berüchtigt für seinen schlechten Charakter, sowie für die kleine Eigenheit, manchmal mit seinem Einfassmesser seine schönsten Kreationen zu zerstören. Dennoch zollen ihm viele noch immer Tribut, indem sie sein Messer gebrauchen, um die Familienjuwelen ihrer Gegner abzuschneiden.",ep:19,g:49,l:127,wd:true,fm:true,w:15,an:13,tw:true,e:[10,3,1,1,30,30,false,false],c:"CA>200&CS>200",p:40825};
I.u[7192] = {n:"Griesgrahms Kralle",t:6,d:"Griesgrahm meisterte niemals völlig den Umgang mit dieser Kralle, denn im Laufe des Kartenspiels und der ewigen Besäufnisse verkümmerten seine Muskeln. Bei manch anderem wären inzwischen längst andere Organe verkümmert. Doch wen kümmert\'s?",ep:18,g:59,l:111,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>300&CA>120",p:31625};
I.u[7193] = {n:"Klinge des Dark Vlad",t:6,d:"Nur Dark Vlad höchstpersönlich kann die Magie dieser Klinge entfachen und sie in Flammen tauchen. Aber allein schon dadurch, dass ihr seine Waffe tragt, beweist ihr, dass ihr nicht wie die anderen Möchtegern-Abenteurer seiner Klinge zum Opfer gefallen seid.",ep:19,g:61,l:126,wd:true,fm:true,w:20,an:14,e:[12,5,1,1,50,100,false,false],c:"CV>250&CI>300&PG=8",p:40625};
I.u[7194] = {n:"Arkanum-Bogen",t:2,d:"Dieser Bogen ist der Beweis dafür, dass die Vereinigung von Magie und Technik doch hervorragende Ergenisse zeitigen kann. Dennoch ist dieser Bogen schnell in Vergessenheit geraten. Sein Erbauer war am Ende gezwungen, den Verkauf einzustellen, was viele seiner langjährigen Kunden doch sehr traurig gemacht hat.",ep:18,g:49,l:96,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,50,false,true],c:"CI>200&CA>60&PG=9",p:23500};
I.u[7195] = {n:"Karnak",t:6,d:"Dieses legendäre Schwert wurde sehr früh am Morgen am tiefsten Punkt der Grimoth-Mine von einer Gruppe sternhagelvoller Enutrofs geschmiedet. Es strahlt eine starke Aura der Macht aus, sowie einen penetranten Biergeruch.",ep:19,g:60,l:158,wd:true,fm:true,w:15,an:14,tw:true,e:[10,5,1,1,50,80,false,false],c:"CV>300&CA>300&PG=8",p:51100};
I.u[7197] = {n:"Xocoatlkrachl",t:7,d:"Dieser Hammer diente ursprünglich dazu, Schokoladentafeln zu zerkleinern und zu feinem Pulver zu zermahlen. Im Laufe der Jahre hat er daher den herrlichen Geruch und Geschmack feinster Schokolade angenommen. Ein Grund mehr, eure Gegner diesen Hammer so schnell wie möglich kosten zu lassen.",ep:19,g:53,l:150,wd:true,fm:true,w:100,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CI>150&CV>200&(PG=5|PG=2)",p:473751};
I.u[7198] = {n:"Rasierklinge des Abends",t:6,d:"Wie euch alle Enutrof-Opas bestätigen werden, ist nur ein gut gepflegter Bart ein schöner Bart. Die Rasierklinge des Abends ist daher stets so gut geschärft, dass sie sogar bei etwas stärker behaarten Damen gute Dienste leisten wird.",ep:18,g:62,l:106,wd:true,fm:true,w:15,an:14,e:[10,4,1,1,50,50,false,false],c:"CS>200&CA>100",p:28925};
I.u[7199] = {n:"Buhs Bastardspießschwert",t:6,d:"Dieses Bastardschwert gehörte Buh Tscher, dem Metzger, der es gerne dazu benutzte, die Innereien seiner Gegner herauszunehmen, um sie danach als Würstchen zu guten Preisen auf dem Markt von Bonta zu verkaufen.",ep:19,g:63,l:135,wd:true,fm:true,w:15,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>200&CA>120&CV>300",p:44225};
I.u[7200] = {n:"Shodanwa-Säbel",t:6,d:"Dieser außergewöhnliche Säbel wird gewöhnlich von Pandawushuka-Anhängern verwendet, die den Grad eines Shodanwa erreicht haben, ohne dafür zwischenzeitlich den Gebrauch ihrer Arme eingebüßt zu haben. Also nur sehr wenige.",ep:18,g:55,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>60",p:4300};
I.u[7201] = {n:"Nidanwa-Säbel",t:6,d:"Dieser außergewöhnliche Säbel wird gewöhnlich von Pandawushuka-Anhängern verwendet, die den Grad eines Yodanwa erreicht haben, ohne dafür zwischenzeitlich den Gebrauch ihrer Arme eingebüßt zu haben. Also nur sehr wenigen.",ep:18,g:56,l:66,wd:true,fm:true,w:15,an:14,e:[10,5,1,1,50,50,false,false],c:"CA>80",p:11300};
