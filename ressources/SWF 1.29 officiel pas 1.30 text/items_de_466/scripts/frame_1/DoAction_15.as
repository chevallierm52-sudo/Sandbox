I.u[6876] = {n:"Ogivol Scarlarcin",t:32,d:"Ogivol befindet sich nun in eurem sicheren Gewahrsam. Jetzt müsst ihr ihn bloß noch zum Gefängnis eskortieren und dort abliefern.",ep:16,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[6884] = {n:"Schlüssel zum Dungeon des Bworkers",t:84,d:"Dieser Schlüssel ist der Schlüssel zum Dungeon des Bworkers. Doch ist er nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:4,g:713,l:30,wd:true,fm:true,w:1,p:100};
I.u[6885] = {n:"Bworker-Jeton",t:15,d:"Dieser Jeton ist ideal für Kopf oder Zahl. Doch lässt er sich auch gut für Münzwürfe der Enutrofs einsetzen, da er aus purem Gold besteht.",ep:13,g:90,l:100,wd:true,fm:true,w:1,p:100};
I.u[6886] = {n:"Umhang der Söldner von Astrub",t:17,d:"Dies ist der Umhang der Söldner von Astrub.",ep:1,g:59,l:1,wd:false,fm:true,w:10,p:1};
I.u[6887] = {n:"Bwork-Überraschungspaket",t:89,d:"Das Öffnen dieses Paketes verlangt vom Träger sehr viel Ruhe und Sorgfalt, denn dies wirkt sich direkt auf die Qualität seines Inhalts aus.",ep:1,g:42,l:1,wd:false,fm:true,w:4,u:true,p:100};
