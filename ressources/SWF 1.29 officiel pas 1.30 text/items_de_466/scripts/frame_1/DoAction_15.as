I.u[7230] = {n:"Akwadala-Umhang",t:17,d:"Dieser Umhang stammt aus dem Dorf Akwadala. Er kann als Fußabtreter genutzt werden oder sogar als Wischlappen, wenn ihr gerade aus dem Wasser steigt.",ep:18,g:113,l:41,wd:true,fm:true,w:10,s:34,p:4550};
