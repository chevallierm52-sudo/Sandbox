I.u[7242] = {n:"Akwadala-Getas",t:11,d:"Diese Holzgetas werden nur von den besten Schuhmachern von Akwadala hergestellt. Da sie sehr luftig sind, bekommen eure Warzen ab und zu eine frische Brise ab und können die schöne Landschaft genießen.",ep:18,g:54,l:35,wd:true,fm:true,w:10,s:34,p:3350};
