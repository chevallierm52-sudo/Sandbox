I.u[6690] = {n:"Verbogene Schere",t:80,d:"Dies ist eine verbogene Schere, nichts weiter.",ep:1,g:33,l:1,wd:true,fm:true,w:2,ut:true,p:1};
I.u[6706] = {n:"Bandagen der Mumie Nova",t:15,d:"Diese Bandagen sind mindestens genauso alt wie ihr ursprünglicher Besitzer, welcher mindestens so alt ist wie die Bandagen. Im Laufe der Zeit haben sie nicht nur die magischen Kräfte der Mumie Nova aufgesogen, sondern auch ihren fauligen Geruch nach verwesendem Fleisch.",ep:1,g:712,l:150,wd:true,fm:true,w:1,p:1000};
I.u[6707] = {n:"Mumie Novas\' Umhang",t:17,d:"Dieser extrem schlecht riechende Umhang wurde zu 100% aus den halbverfaulten Bandagen der Mumie Nova gefertigt. Es gibt nichts besseres, um alle Lebewesen- und Nicht-Lebewesen auf den Friedhöfen der Umgebung außer Rand und Band zu bringen.",ep:14,g:63,l:75,wd:false,fm:true,w:10,p:14600};
I.u[6708] = {n:"Dubbel-Siegerurkunde",t:24,d:"Diese Siegerurkunde bestätigt euren kürzlichen Sieg über ein Dubbel.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[6712] = {n:"Cape Huzina",t:17,d:"Dieser wunderschön duftende Umhang lässt euch nicht nur wie ein Mauerblümchen erscheinen, sondern damit kauft man euch sogar ab, wie ein wahrer Mönch zu leben. Es gibt nichts besseres, um junge Crâs für euch zu gewinnen. Vor allem, wenn ihr in Wirklichkeit ein seit 100 Jahren nicht gewaschener Sadida seid.",ep:1,g:82,l:71,wd:true,fm:true,w:10,p:13100};
I.u[6713] = {n:"Lorsotheuse",t:5,d:"Mit diesen Dolchen, die bereits das Blut des furchtbaren LordSoth geschmeckt haben, wurde sogar der König der Chafer beim Dolchwurfwettbewerb während des Trool Jahrmarktes besiegt. Seitdem wagte er es nie wieder, seinen Lederschlüpfer zu zeigen. Er floh sogar zusammen mit dem Chafer-Offizier in die schützende Umgebung des Friedhofes von Pandala.",ep:1,g:34,l:100,wd:false,fm:true,w:10,an:13,e:[10,3,1,1,30,30,false,false],c:"PN~Lordsoth",p:1};
I.u[6716] = {n:"Nomoon",t:18,d:"Dieser diebische kleine Klammeraffe scheint euch in sein Herz geschlossen zu haben. Er ist sehr fügsam, jedoch in kulinarischer Hinsicht sehr anspruchsvoll. Er isst nämlich nur Dinge, die auf seiner Insel wachsen.",ep:3,g:11,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6717] = {n:"Schwarzer SchnuffWuff",t:18,d:"Mit diesem kleinen Hund macht selbst das tägliche Gassi-Gehen wieder Spaß. Doch außer seinen gewohnten wildwachsenden Wurzeln sollte man ihm nichts zu fressen geben, sonst riskiert man, seine Hand zu verlieren. (DIESER LEGENDÄRE VERTRAUTE BRAUCHT NICHTS ZU FRESSEN.)",ep:1,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6718] = {n:"Weiße Maunzmiez",t:18,d:"Damen jeder Klasse werden beim Anblick dieses verschmitzten und kuscheligen, kleinen Fellknäuels weich.  \nAus diesem Grunde sollte man dieses Tier keinesfalls unterschätzen. (DIESER LEGENDÄRE VERTRAUTE BRAUCHT NICHT GEFÜTTERT ZU WERDEN.)",ep:1,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[6719] = {n:"Maske des Bärenmannes",t:16,d:"Diese seltsame Maske gehörte dem berühmt-berüchtigten Bärenmann. Sie wurde aus den Überresten eines verwesenden Bären gefertigt. Dadurch werdet ihr niemals ignoriert werden, wo auch immer ihr gerade seid, da ihr an jedem Ort eure eigenen olfaktorischen Spuren hinterlasst.",ep:1,g:64,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6720] = {n:"Fellmantel des Bärenmannes",t:17,d:"Dieser warme Mantel wurde viele Jahre hinweg vom berüchtigten Bärenmann getragen. Das wird euch noch lange nicht zu einem Bären machen, wenn ihr den Mantel anzieht, aber euer Magen könnte dies möglicherweise glauben und seine Aktivität verdreifachen. Ihr seid hiermit gewarnt!",ep:8,g:58,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6721] = {n:"Stiefel des Bärenmannes",t:11,d:"Diese Stiefel sind mit Bärenpelz gefüttert. So können selbst die kaltblütigsten Killer noch warme Füße behalten.",ep:2,g:51,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6722] = {n:"Ehering des Bärenmannes",t:9,d:"Der Bärenmann hat diesen Ehering niemals aufgegeben, obwohl sein Eheweib vor seinen Augen von einem Bären zerfleischt wurde, den er selbst beschworen hatte, um seine Liebste damit zu beeindrucken. Sie war in der Tat sehr beeindruckt...",ep:1,g:66,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6723] = {n:"Amulett des Bärenmannes",t:1,d:"Der Bärenmann trug dieses Amulett um den Hals, als er die Brigandiner im Unterschlupf von Bimdhoul angriff. Der Legende nach hätte es ihm das Leben gerettet, doch wenn man die Sache genauer untersucht, stellt man fest, dass es sich dabei bloß um eine Legende handelt.",ep:1,g:74,l:20,wd:true,fm:true,w:2,s:12,p:1300};
I.u[6724] = {n:"Gürtel des Bärenmannes",t:10,d:"Dieser kleine Gürtel aus Bärenleder ist perfekt dafür geeignet, Knutschflecke an unauffälligen Stellen zu verdecken. Daher solltet ihr ihn auch niemals in Gegenwart eurer Herzensdame ablegen, um diese nicht zu enttäuschen.",ep:1,g:66,l:20,wd:true,fm:true,w:10,s:12,p:1300};
I.u[6725] = {n:"Stecken des Bärenmannes",t:4,d:"Der Bärenmann benutzte diesen Stecken gerne zum Zähmen von beschworenen Tieren und Monstern, und um seinen Kindern auf die Finger zu klopfen, wenn sie frech waren. Dieser Mann hatte die Wichtigkeit einer guten Kindererziehung verstanden!",ep:14,g:46,l:20,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CA>50&CV>50",s:12,p:1300};
I.u[6731] = {n:"Eisiges Amukwack",t:1,d:"Mit diesem Amukwack um den Hals könntet ihr versucht sein, eurer Umgebung weismachen zu wollen, dass ihr einen frischen Atem hättet. Versucht es gar nicht erst, das ist verlorene Liebesmüh.",ep:1,g:71,l:42,wd:true,fm:true,w:3,s:13,p:4900};
I.u[6732] = {n:"Eis-Kwackband",t:9,d:"Dieses schmale Band war einst heiß begehrt bei den Enutröffchen, die mit ihm ihre Zehen zu schmücken pflegten. Ausgezeichnet, um Warzen zu kaschieren.",ep:1,g:63,l:42,wd:true,fm:true,w:2,s:13,p:4900};
I.u[6735] = {n:"Heckenschützerwurzel",t:98,d:"Diese kleine Wurzel ist die Inkarnation der Heimtücke. Das weiß jeder, auch wenn keiner weiß, warum.",ep:12,g:96,l:22,wd:true,fm:true,w:5,p:200};
I.u[6736] = {n:"Heckenschützerknospe",t:108,d:"Diese kleine Knospe enthält ein zähflüssiges und vor allem äußerst klebriges Harz. Wenn ihr also einmal aus Unachtsamkeit auf einen zähen alten Heckenschützer tretet, der gut versteckt im Gras gelauert hat, so sagt euren Stiefeln Good-Bye. Andererseits ist dieses Harz ein hervorragendes Mittel, um streitlustigen Fecas das Maul zu stopfen, indem ihr es ihnen als Kaugummi anbietet.",ep:12,g:97,l:22,wd:true,fm:true,w:5,p:1};
I.u[6737] = {n:"Heckenschützerrinde",t:96,d:"Heckenschützer haben keine richtigen Äste wie die anderen Bäume. Dafür haben sie eine schmale, aber sehr widerstandsfähige Rinde mit vielen Unebenheiten. Diese wird gerne für rutschfeste Griffe oder für Prügelstöcke zur Bestrafung renitenter Halbwüchsiger, verwendet, da die Haut mit ihr gut aufgeschürft wird. In beiden Fällen gilt die Rinde als erfolgreich erprobt.",ep:12,g:98,l:22,wd:true,fm:true,w:5,p:200};
I.u[6738] = {n:"Schädel des Chef-Crocodylls",t:47,d:"Dieser enorme Schädel ist ein Beweis für die schlechte Hygiene seines früheren Besitzers. Lustigerweise scheint ihm immer noch eine gewisse Magie innezuwohnen. Von Zeit zu Zeit vergießt er nämlich große Crocodyll-Tränen, wenn ihr böse zu ihm wart.",ep:4,g:637,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6739] = {n:"Crocodyll-Haut",t:59,d:"An ein gut erhaltenes Stück Crocodyll-Haut zu kommen, grenzt beinahe an ein Wunder. Meist bekommen Wilderer bloß ein paar Schuppenstücke. Doch aus diesem Hautstück könnten Schneider gar eine Handtasche machen, oder ein Stück dieser berühmten Kampfunterwäsche.",ep:4,g:601,l:36,wd:true,fm:true,w:10,p:1000};
I.u[6740] = {n:"Haut des Chef-Crocodylls",t:59,d:"Diese Außenseite dieser Haut ist mit scharfkantigen und sehr harten Schuppen bedeckt, und zwar in viel besserer Qualität als bei einem gewöhnlichen Crocodyll. Ihre Innenseite hingegen ist außergewöhnlich weich und anschmiegsam. Bei der Herstellung von Unterkleidung pflegen manche alten Schneider mit Sehschwäche beide Seiten leider zu verwechseln... Ob ihnen das neue Kunden bringt, oder ihren Kundenstamm verringert ist nicht bekannt.",ep:4,g:600,l:69,wd:true,fm:true,w:10,p:1000};
I.u[6742] = {n:"Heckenschutzamulett",t:1,d:"Dieses Amulett enthält Heckenschützerblätter und Abfall von Moons Insel. Es ähnelt zwar eher einer Blumenkette als einem Amulett, aber mit ihm werdet ihr im Nu die örtliche Faune von Moons Insel verführen, auch wenn diese beinahe ausschließlich aus abscheulichen Kreaturen besteht. Kein Heckenschützer wird euch und der Versuchung, euch mit Knutzflecken zu übersähen, widerstehen können. Ein tolles Gegenmittel gegen Liebeskummer!",ep:12,g:69,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6743] = {n:"Heckenschutzring",t:9,d:"Nehmt Heckenschützerblätter, stapelt sie, lasst sie in flüchtigen Alkoholdämpfen einweichen, perforiert sie dann, trinkt den übrigen Alkohol aus, klebt die Blätter um ein Stück Rinde herum, fixiert dann mit einem Klebstoff Kokokoblattstücke darum, und fertig ist euer wunderschöner Heckenschutzring. Allerdings stinkt er abartig! Das kann aber sogar sehr nützlich sein, um den Geruch eurer zu unternehmungsfreudigen Finger zu verstecken, vor allem, wenn ihr sie mal wieder wohin gesteckt habt, wo sie nichts zu suchen haben.",ep:12,g:60,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6744] = {n:"Heckenschuhützer",t:11,d:"Wenn ihr diese Schuhe erst einmal anprobiert habt, so werdet ihr sie möglicherweise nie wieder ausziehen. Nicht unbedingt, weil sie so besonders sind, sondern vielmehr weil sie besonders klebrig sind.",ep:12,g:47,l:34,wd:true,fm:true,w:5,s:16,p:3200};
I.u[6745] = {n:"Heckenschutzschurz",t:10,d:"Dieses bemerkenswerte handwerkliche Kleinkunstwerk aus Überresten von Heckenschützern und sonstigem Unrat, der inmitten der übelriechenden Brandung von Moons Insel zusammengesammelt wurde, erzeugt eine einzigartige Wirkung an euch, vorausgesetzt ihr habt sonst nichts an. Dadurch lassen sich eure Gegner gut aus der Fassung bringen, oder gar eure Liebste. Vielleicht behaltet ihr ja nun ein für allemal die Oberhand und sie lässt sich unterkriegen, wer weiß?",ep:12,g:62,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6746] = {n:"Steinernes Amukwack",t:1,d:"Einst von Oto Mustam, dem Kriegshäuptling von Brâkmar, getragen, diente dieses kleine Amulett einzig und allein dazu, mit seiner Schönheit bei den organisierten brâkmarischen Orgien zu glänzen. Das volle Programm!",ep:5,g:72,l:42,wd:true,fm:true,w:3,s:14,p:4900};
I.u[6747] = {n:"Windiges Amukwack",t:1,d:"Wenn der Wind in seine Federn fährt, dann fühlt sich ein Luft-Kwacker frei und lässt sich von den Windströmungen hin- und herwiegen wie ein totes Blatt in einer Sturmbö. Entgegen dem, was die meisten dabei denken, ist das ziemlich beeindruckend.",ep:5,g:70,l:42,wd:true,fm:true,w:3,s:15,p:4900};
I.u[6748] = {n:"Stein-Kwackband",t:9,d:"Geschickt angelegt, vermag es dieses Armband, eure Wurstfinger zu verschönern. Zum Verdruss von so manch einem ist dies leider nur bei Fingern wirksam.",ep:5,g:64,l:42,wd:true,fm:true,w:2,s:14,p:4900};
I.u[6749] = {n:"Wind-Kwackband",t:9,d:"Dieses Band ist so leicht, dass man das Gefühl hat, es könne sich beim ersten Windstoß in die Luft erheben. Aber nicht träumen! Wenn das passieren sollte, dann werdet ihr mit Sicherheit nicht mitfliegen können. Bestenfalls werdet ihr dabei ausgelacht.",ep:5,g:62,l:42,wd:true,fm:true,w:2,s:15,p:4900};
I.u[6750] = {n:"Eis-Kwacklinge",t:6,d:"Dieses Schwert mit der kalten und scharfen Klinge weckt die innersten Instinkte im Träger.",ep:1,g:51,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CC>50&CV>50",s:13,p:4600};
I.u[6751] = {n:"Stein-Kwacklinge",t:6,d:"\"Ein außergewöhnliches Schwert für Abenteurer auf der Suche nach außergewöhnlichen Erfahrungen\" – liest man im Bedienungshandbuch. Handbücher von Schwertern sind auch nicht mehr das, was sie mal waren.",ep:5,g:53,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CS>50&CV>50",s:14,p:4600};
I.u[6752] = {n:"Luft-Kwacklinge",t:6,d:"Sie ist nicht nur ideal, um Wölkchen zu zerschneiden, sondern kann sogar dazu dienen, euch Luft zuzufächern, wenn ihr sie vor eurem Gesicht auf und ab bewegt. Das ist gleichzeitig auch eine hervorragende Technik, um Moskitos zu dezimieren, oder aber das Gesicht eurer Freunde zu entstellen.",ep:5,g:50,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CA>50&CV>50",s:15,p:4600};
I.u[6753] = {n:"Eisige Kwacklauen",t:11,d:"Einfach ideal zum Schlittschuhlaufen auf zugefrorenen Seen oder um an heißen Tagen euer Essen kühl aufzubewahren. In jedem Falle werden euch diese Schuhe helfen, stets einen kühlen Kopf und kühle Füße zu bewahren. Allerdings sollte man sie nach dem Trocknen vor dem Kamin nie liegen lassen, sonst gibt es sie eines morgens nicht mehr.",ep:2,g:36,l:40,wd:true,fm:true,w:5,s:13,p:4400};
I.u[6754] = {n:"Steinerne Kwacklauen",t:11,d:"\"Nichts geht über steinerne Kwacklauen, um über die Erde zu kwacklaufen\", sprach Rola Ingalsse, die berühmte Pflügerin, bevor ihr eine große Erdscholle beide Augen zerstörte und sie erblindete.",ep:5,g:49,l:40,wd:true,fm:true,w:5,s:14,p:4400};
I.u[6755] = {n:"Windige Kwacklauen",t:11,d:"Einfach, aber wirkungsvoll. Dennoch wurde das Design dieser wahnsinnig leichten Stiefel kürzlich noch einmal überarbeitet, um einen Wetterhahn anzubringen, der einem Richtung und Stärke des Windes weist. Achtet bloß darauf, immer auf der richtigen Seite des Windes zu stehen, sonst erleidet ihr in kürzester Zeit den Erstickungstod!",ep:5,g:48,l:40,wd:true,fm:true,w:5,s:15,p:4400};
I.u[6756] = {n:"Erd-Kwape",t:17,d:"Dieser Umhang ist einfach ideal, sich als Riesenerdscholle zu tarnen. Dadurch könnt ihr dann die pflügenden Bauern aus dem Hinterhalt angreifen und all ihre Reichtümer stehlen. Demnach ist er vor allem für Sammler schön geformter und -gefärbter Feuersteinsplitter geeignet.",ep:8,g:64,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6757] = {n:"Wind-Kwape",t:17,d:"Dieser raffinierte leichte Mantel kann den Ärmsten notfalls sogar als Vorhang dienen. Einst wurde er von der Mumie Nova gesucht, die ihn tragen wollte, um abends gut gekleidet ausgehen zu können. Tja, davon sollten sich einige mal eine Scheibe abschneiden!",ep:8,g:62,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6758] = {n:"Erd-Kwackürtel",t:10,d:"Dass der Erd-Kwack nicht gerade sehr gesellig ist und für seine Federn gejagt wird, ist wohl bekannt. Mit diesem Gürtel setzt ihr euch ebenfalls der Heimtücke der Erd-Kwack-Jäger aus, die euch womöglich mit einem alten, klapprigen Kwack verwechseln, der nicht mehr lange zu leben hat. Manchmal täuscht einen der Schein eben doch nicht.",ep:12,g:65,l:41,wd:true,fm:true,w:5,s:14,p:4600};
I.u[6759] = {n:"Wind-Kwackürtel",t:10,d:"\"Die einzig wirksame Art, einen alten streitlustigen Wind-Kwack zu fangen, besteht darin, sich in einen streitlustigen weiblichen Wind-Kwack zu verkleiden. Das Männchen wird versuchen zu begreifen, was das Weibchen so streitlustig macht und es mit allen verfügbaren Mitteln und Wegen befriedigen. Wenn es zufrieden mit seiner Leistung ist, kann man seine Glückseligkeit dazu ausnutzen, es zu rupfen.\" Soweit Abschnitt 12 des dritten Bandes des Handbuches des kleinen Kwack-Jägers. Ihr wißt nun, was ihr zu tun habt!",ep:12,g:63,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6760] = {n:"Stein-Kwackapp",t:16,d:"Dieser Helm ist dermaßen schwer, dass ihr damit ständig den Boden fest unter den Füßen spüren werdet. Andererseits könnten eure Ideen mitsamt eures Kopfes damit auch öfters auf den fruchtbaren Boden Amaknas fallen. Man kann schließlich nicht alles haben.",ep:13,g:71,l:41,wd:true,fm:true,w:25,s:14,p:4600};
I.u[6761] = {n:"Wind-Kwackapp",t:16,d:"Diese Maske ist nichts für Luftikusse, sondern für Abenteurer, die es gewöhnt sind, hart am Wind zu segeln. Doch auch für weibliche Abenteurer ist dieses Prachtstück wunderbar. Was, der Wind zerzaust euch mal wieder die Haare? Dann schnell die Wind-Kwackapp überziehen und schon wird euch der Wind kein Häarchen mehr krümmen.",ep:13,g:69,l:41,wd:true,fm:true,w:5,s:15,p:4600};
I.u[6762] = {n:"Heckenschützerstecken",t:4,d:"\"Wolln sich Gegner in Hecken verstecken, nehmt den Heckenschützerstecken!\" So lautet das Werbeplakat der Mannschaft von \"Abenteuer Reisen\", kurz AR-Team genannt, die ein All inclusive-Paket anbietet, bei dem man diesen Stecken aus verschiedenen, überall verstreuten Ressoucen der Insel zusammenbauen kann. Das ähnelt also ein wenig einer Schnitzeljagd, bloß dass dabei keine Schnitzel gejagt werden.",ep:12,g:44,l:32,wd:true,fm:true,w:5,e:[15,4,1,1,20,70,false,false],s:16,p:2900};
I.u[6763] = {n:"Heckenschutzummantelung",t:17,d:"Man sagt, tote Heckenschützer seien sehr bequem, wenn sie sich erst einmal in der Sonne zersetzt haben. Tatsächlich werden sie mit der Zeit immer elastischer und weicher. Viele Abenteurer würden gerne selbiges von ihrer Liebsten behaupten können.",ep:12,g:61,l:33,wd:true,fm:true,w:5,s:16,p:3000};
I.u[6764] = {n:"Heckenschutzmütze",t:16,d:"Mit dieser Mütze auf dem Kopf sehrt ihr grade nicht sehr schlau aus. Aber seid getröstet: das bessert sich auch nicht, wenn ihr sie abnehmt. Daher könnt ihr sie auch genauso gut weiter aufbehalten.",ep:12,g:68,l:31,wd:true,fm:true,w:5,s:16,p:2800};
I.u[6765] = {n:"MiMilch",t:79,d:"Vorsicht! Auf der Verpackung steht, dass man diese Milch keinen jungen Katzen geben soll, da es sein kann, dass sie dann einige Flecken in eurer Wohnung hinterlassen.",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:4};
I.u[6766] = {n:"Farles Ähre",t:1,d:"Dieses rudimentär anmutende Amulett wurde aus drei Weizenähren gefertigt, die während der dreizehnten Ernte Istrabraqs in den Ebenen von Snossios gemäht und dann mit Edelsteinstaub überzogen wurden. Es verleiht dem Träger außergewöhnliche Tapferkeit und erlaubt gleichzeitig das Mähen von Ebenen und Tälern, ohne jemals zu ermüden.",ep:1,g:68,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6767] = {n:"Farles magisches Armband",t:9,d:"Dieses mit Edelsteinen besetzte Armband wurde von Shika mit einem Tuch aus Hanf umwickelt, um zu verhindern, dass Farle beim Sähen der Gerstensaat damit die Aufmerksamkeit der Rablinge erweckt.",ep:13,g:61,l:80,wd:true,fm:true,w:5,s:17,p:16500};
I.u[6768] = {n:"Soki",t:32,d:"Nehmt diese unglückliche, arme, kleine Katze mit auf Abenteuer, um sie etwas abzulenken.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
