I.u[6601] = {n:"Feenwerkpulver",t:48,d:"Wenn die Gäste beginnen, sich zu langweilen, dann ist die beste Lösung ein herrliches Feenwerk. Und dazu braucht man außer diversen anderen Zutaten auch Feenwerkpulver.",ep:16,g:670,l:1,wd:true,fm:true,w:1,p:100};
I.u[6602] = {n:"Blut der hyoaktiven Ratte",t:24,d:"Die Bontarianische Sicherheitsverordnung sieht vor, dass man sich stets 100 Felder entfernt von allen hyoaktiven Substanzen oder Lebewesen entfernt halten soll, um die erforderliche Mindestspielzeit nicht zu verdreifachen.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[6603] = {n:"Fresssackteddy",t:61,d:"Dieser Teddy ist die exakte Nachbildung eines Fresssacks. Seine Erschaffer sind sogar so weit gegangen, der Wolle des Teddys den charakteristischen schlechten Geruch des Originals beizumischen. Wundert euch also nicht, wenn er an euch haften bleibt!",ep:13,g:671,l:1,wd:true,fm:true,w:10,p:1};
I.u[6604] = {n:"Quark-Quak",t:18,d:"Das Quark-Quak ist der ungeschlagene Meister der Dummheit. Schlimmer noch als der Tofu, der Fresssack oder gar der Iop...",ep:1,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[6605] = {n:"Königlicher Fresssackteddy",t:61,d:"Dieser Teddy ist einfach nur königlich! Vom Schnitt bis zum Ausstopfen wurde nichts dem Zufall überlassen. Daher ist er ein außergewöhnliches Geschenk, welches sogar dem Sohn eines Königs würdig ist.",ep:13,g:672,l:1,wd:true,fm:true,w:10,p:1};
I.u[6606] = {n:"Sadida-Dubbelteddy",t:61,d:"Dieser Teddy enthält in seinem Inneren einen großen Wecker, was sehr nützlich, um die langschläfrigen Sadidas aus ihrem Tiefschlaf zu reißen. Allerdings solltet ihr diesen Teddy nicht mitnehmen, wenn ihr vorhabt, den Hainbuchenhain aufzusuchen...",ep:13,g:673,l:1,wd:true,fm:true,w:10,p:1};
I.u[6607] = {n:"Ecaflip-Dubbelteddy",t:61,d:"Dieser kleine Teddy erfreut Ecaflips aller Altersklassen.",ep:13,g:674,l:1,wd:true,fm:true,w:10,p:1};
I.u[6608] = {n:"Iop-Dubbelteddy",t:61,d:"Dieser Teddy ähnelt stark einem lebenden Iop. Er schaut stupide drein und trägt ein Schwert. Sein Schädel enthält nicht einmal eine Füllung. Ein gutes Imitat eben.",ep:13,g:675,l:1,wd:true,fm:true,w:10,p:1};
I.u[6610] = {n:"Sram-Dubbelteddy",t:61,d:"Dieser Teddy wurde einer jungen Sram gestohlen, welche ihn wiederum einem ihrer Kameraden gestohlen hatte...",ep:13,g:677,l:1,wd:true,fm:true,w:10,p:1};
I.u[6611] = {n:"Eniripsa-Dubbelteddy",t:61,d:"Dieser Teddy könnte beinahe von allein fliegen, wenn seine Flügel nicht so abgenutzt wären. In der Tat scheint er nicht aus erster Hand zu stammen... Dennoch, ein tolles Geschenk!",ep:13,g:678,l:1,wd:true,fm:true,w:10,p:1};
I.u[6612] = {n:"Enutrof-Dubbelteddy",t:61,d:"Achtung, dieser Teddy ist wirklich schwer! Er wurde nämlich mit Bauxiterz und Goldnuggets gefüllt.",ep:13,g:679,l:1,wd:true,fm:true,w:10,p:1};
I.u[6613] = {n:"Feca-Dubbelteddy",t:61,d:"Dieser Teddy ist so gut wie unzerstörbar. Darum ist er besonders für die ungestümen und unachtsamen Fecakinder geeignet.",ep:13,g:680,l:1,wd:true,fm:true,w:10,p:1};
I.u[6614] = {n:"Osamodas-Dubbelteddy",t:61,d:"Es heißt, dieser Teddy könne andere Teddies beschwören, wenn man ihn sorgsam behandelt. Das ist sicher ein altes Märchen, um Osamodaskinder davon abzuhalten, ihn aufzuessen.",ep:13,g:681,l:1,wd:true,fm:true,w:10,p:1};
I.u[6615] = {n:"Crâ-Dubbelteddy",t:61,d:"Dieser stolz dreinblickende Teddy ist perfekt dafür, um auf eure Spielkameraden geschleudert zu werden. Ein wenig wie ein Boomerang, außer, dass er nicht zum Werfer zurückkommt.",ep:13,g:682,l:1,wd:true,fm:true,w:10,p:1};
I.u[6616] = {n:"Xelor-Dubbelteddy",t:61,d:"Dieser Teddy macht seltsame Geräusche. Er scheint im Inneren des Kopfes ein Uhrwerk zu enthalten. Es gibt nichts Besseres, um junge Xelors in den Schlaf zu wiegen.",ep:13,g:683,l:1,wd:true,fm:true,w:10,p:1};
I.u[6617] = {n:"Keiler-Teddy",t:61,d:"Dieser Teddy sieht einem Keiler-Teddy einfach zum Verwechseln ähnlich. Beeindruckend. Selbst die Haare sind orignial Keiler-Haare. Welch eine gute Qualität!",ep:13,g:684,l:1,wd:true,fm:true,w:10,p:1};
I.u[6618] = {n:"Tofu-Teddy",t:61,d:"Wer hat noch niemals davon geträumt, einen Tofu-Teddy in den Armen zu halten... Ihr vielleicht, das ist wahr. Doch in dem Fall kauft ihr womöglich immer das Falsche, oder aber ihr habt Freunde, die nicht wissen, was ihr mögt. Falls ihr überhaupt Freunde habt.",ep:13,g:685,l:1,wd:true,fm:true,w:10,p:1};
I.u[6619] = {n:"Pilzling-Teddy",t:61,d:"Dieser Pilzling-Teddy besitzt weder schmerzhafte Stacheln, noch lähmendes Gift. Dennoch gibt es nichts Besseres, um naive Iops einzuschüchtern.",ep:13,g:686,l:1,wd:false,fm:true,w:10,p:1};
I.u[6620] = {n:"Prespik-Teddy",t:61,d:"Dieser Prespik-Teddy wird keine Stacheln durch die Gegend schießen und sich auch nicht unsichtbar machen. Doch kommt er seinen Teddypflichten gewissenhaft nach und lässt eure Freunde schier platzen vor Neid.",ep:13,g:687,l:1,wd:true,fm:true,w:10,p:1};
I.u[6621] = {n:"Wabbit-Teddy",t:61,d:"Jeder will so einen Wabbit-Teddy haben. Vielleicht, weil er niemals aus der Mode gerät? Dasselbe lässt sich keineswegs von euch behaupten.",ep:13,g:688,l:1,wd:true,fm:true,w:10,p:1};
I.u[6622] = {n:"Rassel des Dark Vlad",t:15,d:"Diese Rassel gehörte dem berüchtigten Dark Vlad höchstpersönlich. Daher ist sie unbezahlbar, auch wenn sie einst bloß eine gewöhnliche Rassel war.",ep:13,g:696,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6624] = {n:"Schweinedrachen-Teddy",t:61,d:"Dieser Teddy ist absolut einzigartig. Doch spricht er eher eine etwas ältere Zielgruppe an.",ep:13,g:689,l:1,wd:true,fm:true,w:10,p:1};
I.u[6625] = {n:"Meister Rabs Kugelfangspiel",t:15,d:"Dieses schöne Spielzeug gehörte Meister Rab höchstpersönlich. Doch da er zu dämlich war, seine Funktionsweise zu verstehen, benutzte er es bloß, um mit der Kugel seine Rablinge zu verhauen. Jedem das Seine!",ep:13,g:710,l:1,wd:true,fm:true,w:1,p:2000};
I.u[6626] = {n:"Sprungseil des Chafer-Offiziers",t:15,d:"Der Chafer-Offizier pflegte dieses berühmte Sprungseil zu nutzen, um seine Gelenke zu trainieren. Doch seitdem er spurlos aus Amakna verschwand, geht dieses Seil von Hand zu Hand.",ep:13,g:695,l:1,wd:true,fm:true,w:1,p:50};
I.u[6627] = {n:"Kleines mehrfarbiges Feenwerk",t:74,d:"Dieses Feenwerk wird sogar noch die blasiertesten aller Freunde überraschen und beeindrucken. Es ist auch immer eine schöne Idee, es zur Gründungsfeier eurer langerwarteten eigenen Gilde zu zünden.",ep:1,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:350};
