I.u[6642] = {n:"Mächtige Klinge von Urandal",t:6,d:"Dieses Schwert verliehen zu bekommen, ist eine besondere Auszeichnung für die erfolgreichsten Söldner von Seriane-Kerm. Allerdings ist es trotzdem sehr scharf.",ep:1,g:25,l:50,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[6643] = {n:"Booden-Eis",t:42,d:"Dieses leckere Eis wird nach wie vor von Hand hergestellt, und zwar im kleinen Booden-Hof. Der Familienbetrieb versucht bereits seit langem, die Benutzung von Booschlamm in all seinen Eissorten den Kunden schmackhaft zu machen. Bisher noch mit nur mäßigem Erfolg.",ep:13,g:143,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:150};
I.u[6644] = {n:"Königliche Eiswaffel",t:42,d:"Für die Spitze dieser königlichen Eiswaffel ließ man sich vom berühmten Hut des WaWabbits inspirieren. Gut gelungen, nicht wahr?",ep:13,g:144,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:120};
I.u[6646] = {n:"Bonta-Eis",t:42,d:"Dieses Eis mit seiner gelungenen Mischung aus verschiedenen Eissorten beweist das \"überragende Know How der Engel\"... Jedenfalls, wenn man der Werbung glaubt.",ep:13,g:145,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:90};
I.u[6647] = {n:"Magma von Brâkmar",t:42,d:"Dieses Eis, das knackige Schokolade mit zartem Eisgeschmack kombiniert, beweist das \"überragende Know How von Brâkmar\"... Jedenfalls, wenn man der Werbung Glauben schenken darf.",ep:13,g:146,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:90};
I.u[6648] = {n:"Roter Ballon",t:15,d:"Dieser Ballon ist ein Andenken an den Jahrmarkt des Trools.",ep:13,g:690,l:1,wd:true,fm:true,w:1,p:15};
I.u[6649] = {n:"Blauer Ballon",t:15,d:"Dieser Ballon ist ein Andenken an den Jahrmarkt des Trools.",ep:13,g:691,l:1,wd:true,fm:true,w:1,p:15};
I.u[6650] = {n:"Grüner Ballon",t:15,d:"Dieser Ballon ist ein Andenken an den Jahrmarkt des Trools.",ep:13,g:692,l:1,wd:true,fm:true,w:1,p:15};
I.u[6651] = {n:"Gelber Ballon",t:15,d:"Dieser Ballon ist ein Andenken an den Jahrmarkt des Trools.",ep:13,g:693,l:1,wd:true,fm:true,w:1,p:15};
I.u[6652] = {n:"Schneekugel: Jahrmarkt des Trools",t:15,d:"Diese hübsche Schneekugel entfaltet ihre volle Wirkung erst so richtig auf einem Kaminsims.",ep:13,g:694,l:1,wd:true,fm:true,w:1,p:15};
I.u[6653] = {n:"Eintrittsschein zum Jahrmarkt des Trools",t:24,d:"Dieser Eintrittsschein ermöglicht es euch, den Jahrmarkt des Trools zu betreten.",ep:13,g:94,l:1,wd:true,fm:true,w:0,p:1};
I.u[6654] = {n:"Schuhe des GulliWächters",t:11,d:"Es ist Ironie pur: der GulliWächter wurde von der GulliWächterin verspeist! Sie hat ihn mehrere Jahrhunderte lang verdaut, bevor er schließlich endgültig verstarb. Jedoch waren seine Stiefel sehr viel widerstandsfähiger als er selbst. Der Beweis: hier sind sie, und zwar in hervorragendem Zustand.",ep:16,g:28,l:83,wd:true,fm:true,w:10,p:17800};
I.u[6655] = {n:"Überraschungspaket der Glücklichen",t:89,d:"Diejenigen, die dies in eurem Schliessfach abgelegt haben, waren wirklich sehr großzügig. Sie wollten wohl ihre Freundschaft unter Beweis stellen.  \n(Doppelklick, um das Paket zu öffnen.)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6656] = {n:"Überraschungspaket der Glücklichen",t:89,d:"Diejenigen, die dies in eurem Schliessfach abgelegt haben, waren wirklich sehr großzügig. Sie wollten wohl ihre Freundschaft unter Beweis stellen.  \n(Doppelklick, um das Paket zu öffnen.)",ep:1,g:32,l:1,wd:false,fm:true,w:200,u:true,p:500};
I.u[6657] = {n:"Sack zu ersetzen",t:89,d:"...",ep:1,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[6658] = {n:"WuWulf-Teddy",t:61,d:"Dieser wunderschöne Teddy aus echtem WuWulf-Fell wird euch nachts warmhalten und sogar noch das ganze Zimmer mit einem angenehmen Geruch nach altem WuWulf-Schweiß erfüllen.",ep:13,g:699,l:1,wd:true,fm:true,w:10,p:1};
I.u[6659] = {n:"Falscher Qwark-Qwak",t:15,d:"Täuscht euch da nicht, dieser Qwark-Qwak ist nicht echt! Gebt ihn dem neben dem Stand stehenden Dragoberk, um eure Belohnung abzuholen.",ep:1,g:700,l:1,wd:true,fm:true,w:1,p:1};
I.u[6660] = {n:"Zylinder des Bräutigams",t:16,d:"Wer wird zu euch noch \"Nein\" sagen, wenn ihr mit diesem eleganten Zylinder auf dem Kopf heranstolziert kommt? Ruhm und Eroberungen warten auf euch!",ep:2,g:53,l:1,wd:true,fm:true,w:5,c:"PS=0",p:1000};
I.u[6661] = {n:"QuackQuack-Angel",t:20,d:"Mit dieser Angel könnt ihr auf dem Jahrmarkt des Trools beim Wettfischen von QuackQuacks mitmachen.",ep:13,g:8,l:1,wd:true,fm:true,w:10,an:18,e:[0,10,1,1,50,2,false,false],p:1};
I.u[6662] = {n:"Brauthut",t:16,d:"Lasst ihn einfach dahinschmelzen, diesen wunderschönen Hut aus reinster südländischer Larvenseide, wie ein Minzgelee in der prallen Sonne. Achtung: nur mit warmen Wasser und von Hand waschen!",ep:2,g:54,l:1,wd:true,fm:true,w:5,c:"PS=1",p:1000};
I.u[6663] = {n:"Strauß Dämonenrosen",t:6,d:"Mit diesem wunderschönen Strauß Dämonenrosen könnt ihr eurer Liebsten eure Bereitschaft zur Überwindung von 1.001 Gefahren unter Beweis stellen. Und dies auch noch, ohne den geringsten Kratzer davonzutragen.",ep:2,g:47,l:1,wd:false,fm:true,w:3,an:14,e:[1,4,1,1,50,50,false,true],p:70};
I.u[6664] = {n:"Spezial-Zauberspruch \"Felienchen\"",t:75,d:"(Doppelklick, um den Zauber zu lernen.)  \nNur Ecaflips können den Spezialzauber \"Felienchen\" lernen.",ep:2,g:5,l:1,wd:true,fm:true,w:1,c:"PG=6",u:true,p:10000};
I.u[6666] = {n:"Tofu-Lutscher",t:42,d:"Dieser leckere Lutscher wurde mit Tofuextrakten aromatisiert. Damit ist es ein echter Genuß für euren Gaumen, doch eine Katastropfe für euren Mundgeruch.",ep:13,g:147,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:30};
I.u[6667] = {n:"Trool-Lutscher",t:42,d:"Dieser Lutscher schmeckt nicht nur gut, er hält auch noch sehr lange an. Daher möglichst nur im Beisein eurer besten Freunde genießen.",ep:13,g:148,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6668] = {n:"Tofu-Hotdog",t:42,d:"Dieses fettige Würstchen wird euch genug Energie geben, um all die anderen fettigen Würstchen zu verdauen, die ihr gerade hinuntergeschlungen habt.",ep:13,g:150,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:300};
I.u[6669] = {n:"Trool-Burger",t:42,d:"Dieser beeindruckende Burger könnte selbst eine ganz Armee hungriger Chafer sättigen. Nur in Maßen essen! In großen Massen können sich Trool-Burger schädlich auf die Gesundheit von Trool-Bürgern auswirken.",ep:13,g:149,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:600};
I.u[6670] = {n:"Pommes aus wilden Sonnenblumen",t:42,d:"Für diese Pommes wurden wilde Sonnenblumenstengel in Stücke geschnitten und anschließend in heißem, wilden Sonnenblumenöl frittiert. So fühlen sie sich beim Frittiert-Werden immer noch zu Hause und können kein Heimweh entwickeln.",ep:13,g:151,l:1,wd:false,fm:true,w:1,u:true,p:300};
I.u[6671] = {n:"Bohne",t:58,d:"...",ep:1,g:471,l:1,wd:true,fm:true,w:1,p:1};
I.u[6672] = {n:"Spezialmehl von Xaver, dem Bäcker",t:52,d:"Dieses Mehl ist dermaßen leicht und gut, dass es sogar als Windelersatz verwendet wird, um kleine Iops trocken und sauber zu halten. Gewissen Gerüchten zufolge soll es danach zum Brotbacken genutzt werden, damit die Brote noch mehr Geschmack entwickeln...",ep:1,g:250,l:100,wd:true,fm:true,w:1,p:0};
I.u[6673] = {n:"Schwarze Tofufeder",t:24,d:"Eine Feder des schwarzen Tofus...",ep:1,g:96,l:1,wd:false,fm:true,w:0,p:1};
