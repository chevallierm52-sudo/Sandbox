I.u[6438] = {n:"Wabbel",t:3,d:"Wabbel wurde aus hochschwabbeligem Material gefertigt. Drum lässt sich dieser Zauberstab (sofern man Stab dazu sagen kann) sehr schlecht handhaben. Nur beim Höhepunkt des Kampfes, wird der Stab steinhart. Schade!",ep:5,g:33,l:85,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,70,false,true],c:"CI>85",p:8500};
I.u[6439] = {n:"Fremdding",t:3,d:"Überirdische Elemente wurden bei der Erschaffung dieses die Grenzen der Wirklichkeit durchstreifenden Stabes miteingearbeitet. Sein Träger wird sicher mehr als einmal glauben, er sei in der 4-ten Dimension gelandet.",ep:4,g:32,l:90,wd:true,fm:true,w:12,an:11,e:[10,4,2,3,20,20,false,false],c:"CI>90&CW>30",p:9000};
I.u[6440] = {n:"Haarastabi",t:3,d:"Dieser Stab ist nicht bloß ein Haufen gewöhnlicher Fellbüschel! Ganz und gar nicht! Denn sein Mark hat die magische Essenz der verschiedenen Fellsorten absorbiert und miteinander verbunden, so dass die gemeinsame Energie viel größer wurde als die Summe der Einzelmagien. Klingt zwar völlig verrückt, aber es hat funktioniert!",ep:14,g:31,l:95,wd:true,fm:true,w:12,an:11,e:[5,3,2,5,40,40,false,true],c:"CW>40&CI>40",p:9500};
I.u[6441] = {n:"Moon-Haare",t:54,d:"Diese Haare sind unglaublich weich und warm, wenn man sie anfasst. Man könnte glatt glauben, sie seien noch lebendig.",ep:12,g:656,l:200,wd:true,fm:true,w:2,p:10000};
I.u[6442] = {n:"Aga Dous Stock",t:4,d:"Immer auf der Suche nach neuen Mitteln, um Gegner zu überraschen, befestigte der Sadida Aga Dou eines Tages ein kleines Püppchen am Ende seines Stockes. Seitdem stürzen sich die pubertierenden Iopinen darauf, um das Püppchen zu fangen, was zur Folge hat, dass sie sich daran aufspießen.",ep:14,g:31,l:81,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>80&CV>50",p:17000};
I.u[6443] = {n:"Medaillon des zweiten Frühlings",t:1,d:"Der berühmte und lebensfreudige Handwerksmeister Yamato, den man zu Unrecht für seinen lächerlichen Bogen verspottet hat, war der Erste, der es wagte, eine Unzahl an Kräften in ein Amulett einzuschließen und es dann magisch zu versiegeln. Das war etwas, was schon seit Ewigkeiten als unmöglich galt.",ep:9,g:57,l:126,wd:true,fm:true,w:20,p:40000};
I.u[6444] = {n:"Türkis-Amulett",t:1,d:"Obwohl es den selben Farbton hat wie der berühmte Türkis-Dofus, haben beide nichts weiter miteinander gemein. Doch das verhindert nicht, dass das Amulett sehr mächtig ist. Man sieht hier also, dass der Schein nicht immer trügt.",ep:9,g:58,l:63,wd:true,fm:true,w:10,p:10300};
I.u[6445] = {n:"Arche-Bogen",t:2,d:"Die Form dieses Bogens ist sehr genau ausgetüftelt worden, und seine Krümmung ist wirklich perfekt. Man sagt diesem Exemplar nach, dass der Bogenschnitzer sich des Hinterteils eines Fresssacks als Schnittmuster bedient hätte.",ep:14,g:13,l:80,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>70&CC>50",p:16500};
I.u[6446] = {n:"Chiducs Bogen",t:2,d:"Chiduc war ein Bogenschnitzer, der für seine lustigen Ticks bekannt war. Zum Beispiel war es ihm unmöglich, die Silbe \"Bo\" auszusprechen, ohne sofort danach herzhaft zu gähnen. Dennoch war er ein großer Bo*gähn*schnitzer.",ep:12,g:14,l:87,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,30,30,false,true],c:"CW>50&CA>80",p:19000};
I.u[6447] = {n:"Trank des Vergessens: \"Chaferwirr beschwören\"",t:43,d:"Dieser Trank lässt euch einen Grad des Beschwörungs-Zauberspruches \"Chaferwirr beschwören\" vergessen.",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6448] = {n:"Trank des Vergessens: \"Arachnee beschwören\"",t:43,d:"Dieser Trank lässt euch einen Grad des Beschwörungs-Zauberspruches \"Arachnee beschwören\" vergessen.",ep:5,g:36,l:50,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[6449] = {n:"Rabacapa",t:17,d:"Das ideale Stück, um des Nächtens als unscheinbarer Schatten zu erscheinen oder sich gar als Meister Rab zu verkleiden, um nach der Dämmerung die jungen Mädchen von der Bäckerei zu erschrecken.",ep:1,g:54,l:45,wd:true,fm:true,w:26,s:8,p:1000};
I.u[6450] = {n:"Gürtel des Armen Dates",t:10,d:"Die Schusterin Dual hatte einen Liebhaber, der dafür bekannt war, immer zur Seite wegzuspringen, wenn sie auf ihn zuging. Aber von der Liebe verblendet, schenkte sie ihm trotzdem diesen wunderschönen Gürtel als Zeichen ihres geheimen Bundes.",ep:14,g:57,l:121,wd:true,fm:true,w:20,p:37255};
I.u[6451] = {n:"Engel\'Erz-Bogen",t:2,d:"Natürlich ist es erlaubt, sich zu fragen, weshalb in aller Welt dieser Bogen einen solch bescheuerten Namen trägt. Doch könnte man sich diese Frage auch bei eurem Namen stellen.",ep:14,g:31,l:82,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>80&CS>50",p:17000};
I.u[6452] = {n:"Bogen des Architekten",t:2,d:"Dieser hochkompliziert aussehende Bogen ist ein wahres Kunstobjekt. Der Bogenschnitzer, der ihn erschuf, ist dadurch berühmt geworden, dass er seine kontroversesten Modelle in der berüchtigten Höhle von Dok Drum ausgestellt hat, die seit Ewigkeiten für das gewöhnliche Publikum gesperrt ist.",ep:9,g:30,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CA>200&CS>100&CI>30",p:37000};
I.u[6453] = {n:"Fischermanns Freund",t:2,d:"Wie man auf dem ersten Blick bereits sehen kann, enthält dieser Bogen zusätzlich auch noch eine integrierte Angel, mit der sich auch all die nicht fliegenden Fische aus dem Wasser holen lassen.",ep:14,g:32,l:70,wd:true,fm:true,w:1,an:10,tw:true,e:[10,4,2,8,30,50,false,true],c:"CS>70&CA>70",p:13000};
I.u[6454] = {n:"Schattenastecken",t:4,d:"Dieser Ast eines Schattenastaknyden war einmal sein rechter \"Arm\". Daher ist er hervorragend dazu geeignet, sich im Armdrücken zu üben. Zudem gibt er eine ausgezeichnete Waffe ab, um eure Kindheitsrivalen zu terrorisieren oder Trunknyden zu foltern.",ep:13,g:23,l:87,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,50,false,false],c:"CV>150&CW>50",p:20000};
I.u[6457] = {n:"Kriptonit",t:40,d:"Die Herkunft dieser seltsamen Legierung ist mysteriös und scheint in fernen Ländern zu liegen. Selbst wenn sie nicht direkt für die Herstellung von Gegenständen verwendbar sein sollte, kann man damit sehr gut den heimischen Kamin dekorieren oder auf Iop-Schädel hauen, um sich zum wiederholten Male davon zu überzeugen, dass diese auch tatsächlich leer und hohl sind.",ep:1,g:706,l:80,wd:true,fm:true,w:80,p:0};
I.u[6458] = {n:"Kobalit",t:40,d:"Von allen bisher entdeckten Legierungen ist Kobalit eine der überraschendsten. Die Bergleute, die sie entdeckten, dachten schon, es sei die perfekte Legierung für alles, bis sie herausfanden, dass sie beim Kontakt mit Fresssackspeichel zu Staub zerfällt.",ep:1,g:704,l:100,wd:true,fm:true,w:100,p:0};
I.u[6459] = {n:"Amulett des Schattenbergmanns",t:1,d:"Der einzige Weg, in einem von Schattenbergleuten heimgesuchten Bergwerk zu überleben, ist Licht. Falls es euch nicht gelingt, ihnen ihre Kerze zu stehlen, dann tragt dieses Amulett bei euch, es wird euch Glück bringen.",ep:14,g:61,l:39,wd:true,fm:true,w:1,c:"CC>30",p:4200};
I.u[6460] = {n:"Winterblatt",t:1,d:"Diese wunderschöne Brosche ist eine Würdigung des sagenhaften Widerstands der Bergleute der Silbermine von Grimoth, die den gesamten Winter lang gegen einen Krachler der schlimmsten Sorte durchgehalten hatten, um schließlich von einem verirrten Tofu niedergestreckt zu werden.",ep:1,g:65,l:98,wd:true,fm:true,w:10,p:25000};
I.u[6461] = {n:"Frühlingsblatt",t:1,d:"Dieses Amulett, welches speziell für alte Enutrofs entwickelt wurde, ermöglichte es Setag vor langer, langer Zeit, die Grimoth-Mine von allen Bergmann-Rivalen zu \"säubern\". Diese Methode ist mit Sicherheit sehr unprofessionell, aber dafür äußerst wirkungsvoll.",ep:7,g:62,l:123,wd:true,fm:true,w:10,p:40000};
I.u[6462] = {n:"Sommerblatt",t:1,d:"Diese kleine Brosche hat wirklich einen gewissen Charme. Ursprünglich trugen es nur Pechvögel, die dennoch unbedingt an den Spielen auf dem Jahrmarkt teilnehmen wollten. Doch dann hat man festgestellt, dass es auch für epische Verfolgungsjagden geeignet ist.",ep:13,g:63,l:45,wd:true,fm:true,w:4,p:5400};
I.u[6463] = {n:"Jahrmarktring",t:9,d:"Dieser Ring wurde von einem bekannten Schausteller angefertigt, an dessen Namen sich allerdings niemand mehr erinnern kann. Er starb bei einem Bogenschützenwettbewerb, bei dem er sich als Zielscheibe präsentierte, mit dem Kern einer wilden Sonnenblume auf dem Kopf anstelle des üblichen Kürbisses.",ep:1,g:50,l:44,wd:true,fm:true,w:5,p:5300};
I.u[6464] = {n:"Ring der Genugbeschwörtuung",t:9,d:"Dieser Ring ist eine verbesserte Version des berühmten Ringes der Genugtuung. Einfach ideal, um euren kleinen Viecher die Sorgen des Kampfes zu überlassen, oder auch einfach nur, um den Dicken zu machen, indem ihr ganze Armeen von Tofus beschwört.",ep:1,g:51,l:40,wd:true,fm:true,w:5,p:4000};
I.u[6465] = {n:"Dok Drums Ring",t:9,d:"Dok Drum fragte einst das Monster, welches seine Höhle heimsuchte, nach dem Rezept, wie man denn einen solchen Ring herstellt. Das Monster gab es ihm, im Austausch gegen einige Gefälligkeiten, die sein Leben für immer verändert haben. Zeugen sagen aus, dass er bei diesem Deal ein sehr schlechtes Geschäft gemacht haben soll...",ep:5,g:52,l:80,wd:true,fm:true,w:10,p:16000};
I.u[6466] = {n:"Shikas Amulett",t:1,d:"Dieses Amulett erlaubte es Shika Ingalsse bereits mehrmals, offene Rebellionen der Fresssackherde zu überleben.",ep:14,g:60,l:29,wd:true,fm:true,w:10,p:2300};
I.u[6467] = {n:"Ano Nims Ring",t:9,d:"Niemand kennt den Besitzer dieses Ringes, was auch beabsichtigt war, da dieser nach einem verlorenen Kampf gegen eine beschworene Arachnee nicht sonderlich erpicht darauf war, erkannt zu werden. Man muss zu seiner Verteidigung allerdings hinzufügen, dass diese Arachnee auch von einem Iop kontrolliert wurde.",ep:1,g:53,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6468] = {n:"Valds Jugendring",t:9,d:"Zu dem Zeitpunkt, zu dem die anderen Iops seines Alters zur Kommunion einen Tabi als Reittier oder ein hölzernes Goultard erhielten, schenkten seine Eltern Vald diesen Jugendring. Er mag ja weniger geeignet sein, um mit seinen Altersgenossen zu spielen, aber dafür ist er im echten Kampf sehr viel nützlicher.",ep:1,g:54,l:59,wd:true,fm:true,w:10,p:9275};
I.u[6469] = {n:"Farles Ehering",t:9,d:"Dieser Ehering wurde im Verlauf von Hunderten von Ernten durch die Reibung an sechszelliger Wintergerste abgenutzt. Dennoch bleibt er das Pfand für den Bund zwischen Farle und Shika, der eines schönen Frühlings inmitten eines Gerstenfeldes geschlossen wurde.",ep:9,g:55,l:87,wd:true,fm:true,w:5,p:20000};
I.u[6470] = {n:"Stiefel des Fresssackzüchters",t:11,d:"Diese wunderschönen Stiefel sind einfach ideal, um Fresssäcken in den Hintern zu treten, wenn man den Weidegrund wechseln muss oder das Dorf zu durchqueren hat. Doch funktionieren sie genauso gut bei allen vergleichbaren Aufgaben, wie z.B. Iop-Kinder dazu zu bringen, ihre Hau&Saufgaben zu machen oder zur Schule zu gehen.",ep:13,g:40,l:68,wd:true,fm:true,w:10,p:12000};
I.u[6471] = {n:"Haarige Treter des lausigen Schweinepriesters",t:11,d:"Diese kleinen Schuhe wurden ausgebessert, verstärkt und anschließend neu parfümiert. Dennoch lassen sie sich gut für die Jagd auf Pilzlinge verwenden, da diese vom starken Geruch der Hinterlassenschaften der Lausigen Schweinepriester über große Entfernungen hinweg angezogen werden.",ep:13,g:41,l:30,wd:true,fm:true,w:10,p:2700};
I.u[6472] = {n:"Goldene Dracheischale",t:16,d:"Diese gepolstere Schale eines goldenen Dracheis macht euch euch völlig unempfindlich gegen die Blitzstrahlen eines Bwork Magus. Gleiches gilt allerdings nicht für echte Blitzstrahlen bei Gewitter.",ep:11,g:55,l:57,wd:true,fm:true,w:10,p:8500};
I.u[6473] = {n:"Saphir-Dracheischale",t:16,d:"Diese Saphir-Dracheischale passt einfach hervorragend zu eurem Teint. Immer vorausgesetzt, ihr wißt sie zu handhaben. Ein solches Schmuckstück korrekt zu behandeln, ist nicht jedem Helden mitgegeben. Der Beweis: Iops haben sie häufig verkehrt herum auf.",ep:11,g:57,l:70,wd:true,fm:true,w:10,p:13000};
I.u[6474] = {n:"Schwarze Dracheischale",t:16,d:"Eine schwarze Dracheischale ist ideal, um Nachts unentdeckt zu bleiben oder sich vor Steinschlägen zu schützen, wie sie in Gebirgen vorkommen, oder wenn ihr mal wieder einen Krachler beim Steine werfen herausfordert.",ep:11,g:56,l:93,wd:true,fm:true,w:20,p:22300};
I.u[6475] = {n:"Geborstener Chafer-Helm",t:15,d:"Dieser Helm ist im jetzigen Zustand unbenutzbar. Er würde euch böse Kopfschmerzen bereiten. Doch ein guter Schneider sollte ihn reparieren können, innen dann noch ein wenig polstern, und euch das Geld aus der Tasche ziehen.",ep:3,g:709,l:40,wd:true,fm:true,w:20,p:1000};
I.u[6476] = {n:"Magische Leuchte des Schattenbergmannes",t:15,d:"Diese Leuchte erhellt die Umgebung, selbst wenn sie nicht angezündet ist und entwickelt weder Rauch noch Wärme. Einzig ein kleines Geräuch verbreitet sie, ähnlich dem, wenn Milch über trockene Haferflocken gegossen wird.",ep:1,g:701,l:40,wd:true,fm:true,w:10,p:10000};
I.u[6477] = {n:"Helm des Schattenbergmannes",t:16,d:"Dieser nützliche Helm wird euch erlauben, klarer zu sehen, selbst wenn es taghell ist. Zudem ist er auch noch gut dazu geeignet, in den Stollen heruntergekommener Gruben hausende Kreaturen zu blenden oder Iops weiszumachen, ihr wäret selbst eine Leuchte.",ep:16,g:90,l:103,wd:true,fm:true,w:20,p:27000};
I.u[6478] = {n:"Zerfetzter Makroute",t:15,d:"Dieser magische Makroute ist in sehr schlechtem Zustand. Er hat die Härte eurer Attacken sehr schlecht verkraftet und sein Haar ist dunkel geworden. Doch könnte sich ihm ein neues Leben eröffnen, würdet ihr ihn nur ein wenig besser pflegen.",ep:14,g:702,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6479] = {n:"Zerfetzter Teddy",t:15,d:"Dieser kleine Bärenkopf ist in sehr schlechtem Zustand. Doch mit etwas Schnur, ein paar Stofffetzen und viel Improvisationstalent lässt sich aus dieser Abscheulichkeit sicherlich noch eine tolle Kopfbedeckung zaubern.",ep:1,g:703,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6480] = {n:"Schattenweide",t:15,d:"Dieses verzauberte Weidenstück ist schattig, wie das schattigste aller Gespenster, magisch, wie das magischste aller Gespenster und widerstandsfähig, wie das widerstandsfähigste aller Gespenster. Nur zur Erinnerung: Gespenster gibt es nicht!",ep:14,g:123,l:70,wd:true,fm:true,w:10,p:1000};
I.u[6481] = {n:"Dora Bora",t:16,d:"Dieser wunderschöne Hut wurde auf der Dora Bora-Insel im Süden von Moons Insel angefertigt. Er ist nicht nur hervorragend zum Kämpfen geeignet, sondern kann auch als Früchteschale verwendet werden, beispielsweise um traumatisierte Kokosnüsse aufzubewahren.",ep:12,g:61,l:120,wd:true,fm:true,w:20,p:40000};
I.u[6482] = {n:"Korko Kousto",t:16,d:"Dieses verbesserte Modell von Jouiks Krempe wurde aus den allerfeinsten Rohstoffen von Moons Insel gefertigt. Das verleiht ihm auch seinen rustikalen Charme. Selbst wenn ihr damit noch nicht wie ein Kanniball ausseht, könnt ihr Gegnern mit dem Korko Kousto immer noch hervorragende Kopfstöße verpassen.",ep:12,g:59,l:73,wd:true,fm:true,w:10,c:"PG=10",p:14000};
I.u[6483] = {n:"Helm des Bronze-Bworks",t:16,d:"Laut einer Legende soll dieser wunderliche Helm seinen Träger in einen Bronze-Bwork verwandeln. Also, ran an die schweren Jungs! Helm aufsetzen, einschmelzen und schon seid ihr im Bronzegeschäft mit drin!",ep:20,g:91,l:144,wd:true,fm:true,w:10,p:46625};
I.u[6484] = {n:"Bogen des Sram-Bogenschützen",t:2,d:"Wenn Dolche nicht mehr ausreichend sind, wenn sich die Götter über einen lustig machen, dann wird es Zeit, seinen eigenen Kampfstil zu entwickeln. Einige Srams haben diese Lektion wohl gelernt, während andere immer noch darauf warten, dass ihr eigener Gott ihnen zu Hilfe kommt.",ep:9,g:40,l:90,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>90&CA>90&CW>50",p:16000};
I.u[6485] = {n:"Bogen des Chafer-Bogenschützen",t:2,d:"Der Chafer-Bogenschütze war noch nie sehr schlau oder geschickt. Darüber hinaus zittern seine Knochen ständig viel zu sehr, um anständig einen Bogen zu bedienen. Abgesehen von dem zittrigen Knochen, geht es ihm also wahrscheinlich genauso wie auch euch.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CA>150&CC>100&CS>100",p:36600};
I.u[6486] = {n:"Rinde von Weich-Eich",t:96,d:"Diese Rinde ist widerstandsfähiger als jede andere Baumrinde. Zudem strahlt sie eine unglaubliche Macht aus. Doch wer sagt euch, dass es sich hierbei nicht um eine Fälschung aus Astaknydenrinde handelt, so dass ihr vielleicht gerade dabei seid, eure Freunde damit zu betrügen?",ep:9,g:666,l:200,wd:true,fm:true,w:10,p:10};
I.u[6487] = {n:"Knospe von Weich-Eich",t:108,d:"Diese enorme Knospe ist randvoll gefüllt mit sirupartigem, warmen Harz. Das Zeug schmeckt genau wie die Trinkfläschchen, die ihr als Kind immer bekommen habt. Doch Vorsicht, manchmal verwandelt man sich danach in ein abgestorbenes Blatt.",ep:9,g:665,l:200,wd:true,fm:true,w:10,p:10};
I.u[6488] = {n:"Wurzeln von Weich-Eich",t:98,d:"Manche versuchen, aus dieser Wurzel Bier zu produzieren. Doch ist dies wenig ratsam, da Weich-Eich überhaupt kein Alkohol verträgt. Das lässt die Wurzeln zittrig werden und zusammenfallen, ein wenig wie bei den Sadidas.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[6489] = {n:"Holz von Weich-Eich",t:38,d:"Dieses Holz hat bereits die scharfe Axt von Bruce Boulgour gekostet. Mehr noch, es hat im Laufe seines langen Lebens mysteriöse Dinge gesehen, die selbst im Grimoire des Bwork Magus nicht erwähnt werden. Man kann sich also das Schlimmste dabei denken.",ep:1,g:668,l:200,wd:true,fm:true,w:10,p:10};
I.u[6490] = {n:"Bernstein von Weich-Eich",t:50,d:"Dieser Bernstein enthält ein Blatt, welches im Harz eingeschlossen wurde. Das macht ihn zu einem echten Sammlerstück. So, wie auch die gepunkteten, rotgelben Stümpfe von Le Tschuck eines sind.",ep:9,g:669,l:200,wd:true,fm:true,w:10,p:10};
I.u[6491] = {n:"Trunknydum",t:2,d:"Dieses hervorragende Kleinod hat ein findiger Bogenbauer aus der fehlgeschlagenen Kreuzung eines Astaknyden mit einem Trunknyden herausgearbeitet. Für einen Holzfäller ist dies natürlich ein Reinfall, doch für einen Bogenbauer ein großer Erfolg. Könnten nur eure Eltern das Gleiche mal von euch behaupten!",ep:9,g:41,l:57,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,7,30,50,false,true],p:8500};
I.u[6492] = {n:"Wobot-Stock",t:4,d:"Der Abstanz zwischen den beiden Spitzen dieses Stabes entspricht genau dem Abstand zwischen den Augen von Lenald... Wewden diese schwecklichen Wabbits denn niemals Wuhe geben?",ep:2,g:37,l:60,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,false],c:"CS>60&CV>60",s:11,p:9400};
I.u[6493] = {n:"Wabbit-Sandaletten",t:11,d:"Übernehmt die coole Kawott-Attitüde mit diesen klasse Sandalen aus der neuesten Kollektion. Die werden von allen führenden Experten empfohlen, sei es für Stepptanz, rituelle Tänze oder für den amakinischen Tango nach Chafer-Offizier-Art.",ep:8,g:39,l:60,wd:true,fm:true,w:10,s:11,p:9300};
I.u[6494] = {n:"Stab von Elya Wood",t:3,d:"Dieser von den berühmtesten Eniripsas von ganz Amakna benutzte Stab ist die ideale Waffe, um Zaubersprüche auf Gegner zu wirken, oder eigene Verbündete intelligenter werden zu lassen. Damit kann man beispielsweise sogar einem Iop die Intelligenz eines Küwbiss verleihen!",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,50,50,false,true],c:"CI>300&CW>100",s:39,p:36800};
I.u[6495] = {n:"Stab von Weich-Eich",t:3,d:"Dieser Stab ist nichts weiter als ein abgefallener Ast von Weich-Eich, der wiederbelebt wurde. Daher ist er auch so unglaublich mächtig. Ihr müsst ihn nur langsam nach rechts und dann schnell nach links schwingen, um Frösche vom Himmel regnen zu lassen. Es kann allerdings sein, dass ihr euch dabei zum Gespött der Zuschauer macht.",ep:22,g:42,l:172,wd:true,fm:true,w:10,an:11,tw:true,e:[7,3,3,4,45,70,false,true],c:"CI>400&CC>250&CW>150",p:45000};
I.u[6496] = {n:"Stab aus Schattenastaknydenwurzeln",t:3,d:"Dieser Stab hat die lästige Angewohnheit, sich mitunter gegen seinen Träger zu wenden. In diesem Fall gibt man ihn am besten an den Gegner weiter, oder an einen Iop. Der wird euch am Ende sogar noch dafür danken, in dem Glauben, dass ihr ihm ein Geschenk damit machen wolltet.",ep:9,g:40,l:67,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>70&CW>70",p:12000};
I.u[6497] = {n:"Lichte Balgourde",t:3,d:"Die Ehefrau von Bruce Boulgour, eine Eniripsa, pflegte ihm ständig seine berühmte Boulgourde der Lichtungen zu stehlen. Um diesen Unfug zu stoppen, schnitt er ihr einen Arm und einen Flügel ab. Später hat er ihr dann diese Lichte Balgourde geschenkt, um sich bei ihr zu entschuldigen. Definitiv ein Mann, der weiß, wie man mit Frauen umgeht.",ep:9,g:43,l:63,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,50,false,true],c:"CI>63&CW>30",p:10325};
I.u[6498] = {n:"Kanguwuschlüpfer des Wabbit GM",t:10,d:"Dieser Schlüpfer von mehr als respektabler Größe trägt noch die Spuren des alten Besitzers in sich, sowie einige seltsame Haare. Egal ob über den Hintern gezogen oder auf dem Kopf getragen, dieser Schlüpfer wird aus euch eine in ganz Amakna gefürchtete Persönlichkeit machen.",ep:8,g:58,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6499] = {n:"\"Die Zähne des Wabbits\"",t:1,d:"Die Zähne dieses Amuletts haben bereits mehr Cawotten geknabbert als Bruce Boulgour Bäume entwurzelt hat. Wundert euch also nicht, wenn ihr damit immer streng nach Cawotte riecht, und wenn die Tiwabbits versuchen, euren Hals zu küssen.",ep:8,g:59,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6500] = {n:"Wabbitohren",t:16,d:"Diese Ohren werden zwar nicht dazu beitragen, dass ihr besser hört, aber dafür erheblich dazu, dass euch eure Freunde besser in der Menge ausmachen können und eure Gegner sich bei eurem bloßen Anblick bereits totlachen, so dass ihr nichts mehr zu tun habt. Ihr werdet sehen, binnen kürzester Zeit werdet ihr diese schicken Ohren nicht mehr missen wollen.",ep:8,g:52,l:60,wd:true,fm:true,w:10,s:11,p:9500};
I.u[6501] = {n:"Kawott-Rucksack",t:81,d:"Mit diesem Rucksack auf den Schultern werdet ihr stets auf Abenteuer ausziehen können, ohne euch um so lästige Probleme wie die Nahrungsbeschaffung sorgen zu müssen. Denn auch wenn die Kawott selbst so leer ist wie der Schädel eines Iops, so wachsen die Blätter an der Oberfläche von alleine nach. Aus ihnen lässt sich ein guter Kräutertee kochen.",ep:8,g:57,l:60,wd:true,fm:true,w:10,s:11,p:9400};
I.u[6503] = {n:"Polpoulettes Hammer",t:7,d:"Eine Polpoulette ist eine Kreuzung aus einem aggressiven Flammen-Kwack und einem kränklichen Tofu. Schon seid Ewigkeiten wurde die Jagd auf Polpoulettes als wichtiges Ritual angesehen. Darüberhinaus ist es ein echtes Vergnügen, solch eine gruselige Kreatur zu jagen.",ep:13,g:35,l:57,wd:true,fm:true,w:20,an:15,e:[6,5,1,1,40,50,false,false],c:"CI>60&CS>20",p:8000};
I.u[6504] = {n:"Fantals Hammer",t:7,d:"Man kennt zwar nur die Koseform von demjenigen, der diesen Hammer erschaffen hat, allerdings weiß man mit Bestimmtheit, dass er einen sehr schlechten Modegeschmack hatte. Es ist beispielsweise bekannt, dass er sich gern mit königlichem Gelee einrieb, um sich dann in den Federn eines Königlichen Tofus zu wälzen. Ohne Zweifel, manche Menschen leben weit über ihre Verhältnisse.",ep:9,g:36,l:81,wd:true,fm:true,w:20,an:15,e:[10,5,1,1,50,50,false,false],c:"CS>80&CV>70",p:17000};
I.u[6505] = {n:"Stierhammerkämpfer",t:7,d:"Dieser Hammer ist perfekt dazu geeignet, gegen gehörnte Kreaturen zu kämpfen. Doch was das Einschlagen von Nägeln oder andere handwerkliche Tätigkeiten angeht... das steht auf einem anderen Tablett.",ep:9,g:37,l:100,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,50,50,false,false],c:"CC>100&CW>40&CS>50",p:26000};
I.u[6506] = {n:"Gogorifizierendes Bergmannsband",t:9,d:"Ein Bergmann der kein Tageslicht mehr erträgt, weil er zu lange in seinem Bergwerk gearbeitet hat, wird von den Enutrofs ein gogorifizierter Bergmann genannt. Versucht niemals, mit einer Kerze in die Nähe eines solchen Bergmannes zu gelangen, er könnte euch sonst nämlich leicht in Bronze verwandeln.",ep:1,g:40,l:84,wd:true,fm:true,w:10,c:"PG=3",p:18500};
I.u[6507] = {n:"Hammer des Terps",t:7,d:"Die Terps war eine bösartige kleine Kreatur, die mindestens genauso gefährlich und genauso unbeliebt war wie ihr Rivale, der Licha. Stets darum bestrebt, diesen zu übertreffen, erschuf sie eines Tages diesen Hammer, um ihm diesen um die Ohren zu schlagen. Stattdessen traf sie bei ihm einen Nerv... Und das war der Beginn einer großen Liebesgeschichte voller Leidenschaft.",ep:9,g:38,l:90,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,35,80,false,false],c:"CS>60&CI>60",p:19000};
I.u[6508] = {n:"Hammer von Meli",t:7,d:"Welch ein außergewöhnlicher Hammer! Der schreit förmlich danach, seinen heißgeliebten Prespic damit zu verarzten, oder auch seine Gegner, falls ihr Anhänger des Chaferwirrs seid.",ep:9,g:39,l:50,wd:true,fm:true,w:20,an:15,e:[6,4,1,1,40,40,false,false],p:6000};
I.u[6509] = {n:"Hammer-Star \"Rernacken\"",t:7,d:"Dieser prächtige Hammer hat bereits mehr als nur einem Osamodas den Kopf verdreht. Tatsächlich ist er dermaßen mächtig, dass sich jeder auf der Straße nach dessen Besitzer umschaut. Seitdem haben sich die Fälle seltsamer Leiden bei den Ärzten der Umgebung verzehnfacht.",ep:9,g:40,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,40,50,false,false],c:"CS>100&CI>150",p:36000};
I.u[6510] = {n:"Scheufäusteligkeit",t:7,d:"Der Oger Laller mit seinem verkrüppelten Körper war nicht nur häßlich wie die Nacht, er war zudem auch noch kämpferisch völlig unbegabt. Doch dies änderte sich schnell, als ihm eines Tages dieser alte Fäustel im wahrsten Sinne des Wortes vor die Füße fiel. Seitdem ist er eine respektierte und beneidete Persönlichkeit. Manchmal braucht es eben nicht viel zum Glück.",ep:12,g:41,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,50,50,false,false],c:"CC>150&CI>150",p:36000};
I.u[6511] = {n:"Der Verwüster",t:7,d:"Dieser Hammer ist perfekt an ein tropisches Klima angepasst. Doch will der Umgang mit ihm wohl erlernt sein, wenn ihr auf ein gutes Klima in eurer näheren Umgebung wert legt. Man sollte sich daher wohl überlegen, in welche Hände man ihn gibt.",ep:9,g:42,l:120,wd:true,fm:true,w:20,an:15,tw:true,e:[5,5,1,1,40,40,false,false],c:"CI>150&CS>100",p:36000};
I.u[6512] = {n:"Smerz\' Hammerkopf",t:7,d:"Dies ist DIE Traumwaffe für alle Xelor-Anhänger, die auf der Suche nach dem gewissen Kick sind. Ausserdem hilft sie den Xelors, über ihren alten Minderwertigkeitskomplex wegen ihrer einfach nur lächerlichen Größe hinwegzukommen.",ep:14,g:43,l:82,wd:true,fm:true,w:20,an:15,tw:true,e:[10,5,1,1,40,50,false,false],c:"CI>50&CC>50",p:17000};
I.u[6513] = {n:"Wurmlochhammer",t:7,d:"Dieser Hammer bezieht all seine Macht aus einer ganz subtilen Verzauberung. Diese ist auf den ersten Blick kaum zu entdecken, geschweige denn auf den zweiten. Daher wird diese Eigenschaft auch grundsätzlich beim Verkauf erwähnt, damit auch die etwas naiveren Kunden diesem Gegenstand ihr Interesse zuwenden.",ep:1,g:44,l:55,wd:true,fm:true,w:20,an:15,e:[6,4,1,1,50,50,false,false],p:9000};
I.u[6516] = {n:"Dolchschlago grobis",t:5,d:"Kein Sram kann es sich verkneifen, Freund wie Feind mit diesen wunderbaren Dolchen herauszufordern. Daher sollte man im Interesse der allgemeinen Sicherheit in Amakna alle verbleibenden Srams Stück für Stück mit diesem Dolch aus dem Verkehr ziehen.",ep:9,g:41,l:121,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>150&CS>100&CV>100",p:38000};
I.u[6517] = {n:"Hischantes Dolch",t:5,d:"Diese Dolche lassen jeden weiblichen Sram auf der Suche nach neuen Erfahrungen schwach werden. Tatsächlich sind dank der beträchtlichen und seltsamen Kräfte dieses Dolches auch die hinterhältigsten Untaten möglich, sei es gegen Freund oder gegen Feind. Der Chafer-Offizier hätte seine wahre Freude daran!",ep:7,g:42,l:80,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>80",p:8000};
I.u[6518] = {n:"Amothirilin",t:3,d:"Dieser Stab eines berühmten Stabschnitzers hat bereits 13 Mal den großen Wettkampf der Stäbe des N\'hi gewonnen. Dabei hat er jedes Mal auch alle anderen Boulgourden- und Balgourdenmodelle übertroffen, wobei erstere inzwischen vom Markt genommen wurden, da sie einfach zu gefährlich sind für kleine Eniripsas.",ep:9,g:44,l:120,wd:true,fm:true,w:10,an:11,e:[6,4,2,4,50,50,false,true],c:"CI>300&CV>100",p:36000};
I.u[6519] = {n:"Kwuarzstab",t:3,d:"Ein sehr berühmter Stabschnitzer, dessen Name seltsamerweise einer der wertvollsten Legierungen Amaknas ähnelt, hatte als allererstes den Einfall, Metalle und Legierungen in seine Kreationen einzubauen. An diesem Beispiel sieht man einmal mehr: Wahnsinn kann durchaus auch zum Erfolg führen.",ep:14,g:41,l:80,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>120&CW>40",p:17000};
I.u[6520] = {n:"Migräne",t:3,d:"Der Stabschnitzer dieses Stabes bestand unzählige Male darauf, dass jeder den wahren Namen seines Stabes verwenden solle. Doch den Verantwortlichen von Amakna brummte nach langen Nächten in der Taverne dermaßen der Schädel, dass sie den Namenstreit kurzerhand ad acta legten und den Stab zu ihren eigenen Ehren benannten.",ep:13,g:45,l:85,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>150&CV>100",p:19000};
I.u[6521] = {n:"Kelinoast",t:4,d:"Es wird gesagt, dass man mit diesem Stock weibliche Astaknyden zum Erröten bringen und sogar ungestraft den Intimbereich von Weich-Eich streicheln könne. Nun, wir würden euch letzteres dennoch nicht empfehlen, da diese Eiche wirklich sehr besitzergreifend ist.",ep:9,g:38,l:129,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,40,false,false],c:"CS>250&CV>200",p:43000};
I.u[6522] = {n:"Cinatis\' Wurzel",t:4,d:"Diese pflanzenfressende Wurzel buddelt sich einen Weg zwischen den vielen toten Blättern hindurch, um an junge Sprösslinge zu kommen. Eindrucksvoll... aber auch völlig unnütz, falls ihr nicht gerade gegen Löwenzahn kämpft.",ep:9,g:39,l:120,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CI>200&CS>200&CV>150",p:37000};
I.u[6523] = {n:"Biens\' Stock",t:4,d:"Diese elegante und hervorragend ausgearbeitete Wurzel wurde von Bien persönlich angefertigt. Mit ihrer Hilfe wird jeder zum Meisterbeschwörer. Auf Gesellschaftsabenden wird man damit zwar nur schlecht glänzen können, doch es gibt keinen besseren Aufhänger, um eine Horde begeisterter Sadidettchen um sich zu scharen.",ep:9,g:40,l:120,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,40,false,false],c:"CS>200&CV>150",p:36000};
I.u[6524] = {n:"Sauvages\' Wurzel",t:4,d:"Sauvage, der Sadida, war Hals über Kopf in ein Sadidettchen verliebt. Eines Abends fasste er sich ein Herz und versuchte, sie mit dieser Wurzel unter einen Lindenbaum zu locken, doch gab sie ihm bloß ihren Korb und sagte: \"Einmal mit Beeren füllen\". Dann ging sie weg und ward die nächsten hundert Jahre nicht mehr gesehen. Kein Wunder, dass sich die Redensart \"jemanden an der Wurzel herumführen\" nicht durchsetzen konnte und stattdessen fleißig Körbe vergeben wurden.",ep:14,g:41,l:54,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"PG=10",p:9000};
I.u[6525] = {n:"Stock des Fecas",t:4,d:"Die Einwohner Amaknas hatten eines Tages die Nase voll davon, die Anhänger Fecas ständig über ihre Rüstungen prahlen zu hören. Daher bauten sie diesen Stock, in der Hoffnung, zum Thema Nr. 1 der Tavernengespräche zu werden.",ep:14,g:42,l:94,wd:true,fm:true,w:10,an:12,tw:true,e:[7,5,1,1,40,80,false,false],c:"PG=1",p:25600};
I.u[6526] = {n:"Hebus\' Schaufel",t:8,d:"Der Schmied, der diese Schaufel angefertigt hat, wollte aus Pseudo-Bescheidenheit anonym bleiben. Trotzdem hatte er die Zeit dafür, sorgfältig und deutlich sichtbar seinen Namen in die Schaufel einzugravieren. Manche Handwerksmeister sind einfach unverbesserlich.",ep:1,g:4,l:94,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>70&CW>50",p:23000};
I.u[6527] = {n:"Schaufel der Musik",t:8,d:"\"Amboß Haudschi bumbaudschi, Amboß Haudschi bumbaudschi bummbumm\", pflegte der Schwertschmied Weiner Achten aus voller Kehle bei der Arbeit zu singen. Dabei sang er so falsch und so laut, dass ihm seine darunter leidende Frau mit dieser Schaufel ein ewiges Andenken verpasste.",ep:1,g:38,l:52,wd:true,fm:true,w:10,an:16,e:[10,5,1,1,20,20,false,false],c:"CC>80&CI>50",p:7100};
I.u[6528] = {n:"Wanderschaufel",t:8,d:"Diese Schaufel hat bereits zahlreiche Kontinente durchquert. Sie hat den Sonnenuntergang vom Gipfel des Mauna Crachloas aus genossen und den Sonnenaufgang am Assel-Meer betrachtet, wo Horizont und Wasser miteinander verschmelzen. Und dann kommt so einer wie ihr, der noch nie weiter als bis auf Moons Insel geschaftt hat und will ihr die Welt zeigen. Wie erbärmlich!",ep:12,g:4,l:88,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CI>80&CC>150&CW>40",p:20000};
I.u[6535] = {n:"Schupp-Schipp",t:8,d:"Diese seltsame aussehende und überaus vielseitige Schaufel wurde ursprünglich für drei Dinge verwendet: die dicken Flöhe von jungen Iops zu töten, ihre Schuppen zu entfernen,  und die Grundlagen der Arithmetik in ihre dicken Schädel zu kriegen.",ep:9,g:36,l:121,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>300&CS>50&CV>100&CW>50",p:37000};
I.u[6536] = {n:"Schaufel des Schattenbergmannes",t:8,d:"Bei den Schattenbergleute ist diese gewaltige Schaufel mit den Dimensionen einer Krachlerhand sehr beliebt, wenn es ihnen darum geht, gleich mehrere Eniripsas auf einmal zu zermalmen. Wir raten euch, das auch einfach mal auszuprobieren.",ep:9,g:34,l:120,wd:true,fm:true,w:10,an:16,e:[10,5,1,1,60,60,false,false],c:"CC>250&CV>100&CS>75",p:34000};
I.u[6537] = {n:"Schwiegrige Mutterschaufel",t:8,d:"Der Umgang mit dieser etwas höchst eigenwilligen Schaufel ist immer recht schwierig. Niemand weiß den genauen Grund hierfür, aber im Allgemeinen sind schwiegrige Mutterschaufeln auf lange Sicht kaum auszuhalten. Man sagt ihnen jedoch auch nach, sie hätten ihre guten Seiten, man müßte sie nur finden. Also, die Suche nicht aufgeben, hört ihr?",ep:12,g:37,l:88,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>100&CA>70",p:20000};
I.u[6538] = {n:"Aussichts-Plattschaufel",t:8,d:"Diese Schaufel ermöglicht es den Enutrofs, etwas weiter zu sehen. Sie ist schließlich so konzipiert, dass sie sich leicht in den Boden pflanzen lässt. So können die alten Herrschaften hinaufklettern, um den Horizont abzusuchen. Oder manchmal auch bloß, um sich interessant zu machen. Diese Schaufel ist einfach ideal für sie, um ihr Altersheim wiederzufinden, wenn sie sich wieder einmal unter all diesen hohen Farnwedeln verlaufen haben.",ep:12,g:39,l:84,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>200&CV>70",p:18200};
I.u[6539] = {n:"Die Schaufel von Bella Ghiena",t:8,d:"Diese Schaufel ist wirklich einzigartig. Solltet ihr sie ernsthaft benutzen wollen, so müßt ihr darauf gefasst sein, dass sich jeder darüber lustig machen und schlechte Witze reißen wird. Tatsache ist nämlich, dass gerade in der Taverne die Witze rund um die Schaufel von Bella Ghienna sehr beliebt sind.",ep:9,g:35,l:71,wd:true,fm:true,w:10,an:16,tw:true,e:[10,4,1,1,25,60,false,false],c:"CS>30&CC>150",p:13000};
I.u[6540] = {n:"Die Schaufel Untasbist",t:8,d:"Es wird erzählt, der Schöpfer dieser Schaufel sei ein echtes Monstrum gewesen. Er habe ausgesehen wie eine Kreuzung aus einem Sadida und einem WuWulf. Seine Schaufel habe sich auch promt in ihn verliebt. Welch ein verrücktes Hirngespinst! Sowas ist schließlich nur im Märchen möglich.",ep:14,g:33,l:87,wd:true,fm:true,w:10,an:16,tw:true,e:[15,5,1,1,30,100,false,false],c:"CC>150&CV>80",p:20000};
