I.u[3647] = {n:"Rachenstutzer",t:5,d:"Dieser sichelförmige Dolch diente dazu, Reisende zu zerfleischen, die sich verlaufen hatten. Seinen Namen bekam er dadurch, dass sich sein Besitzer nach dem Ausrauben seiner Opfer immer in der örtlichen Taverne zu betrinken pflegte.",ep:13,g:31,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:17800};
I.u[3648] = {n:"Dolch des Chafer-Offiziers",t:5,d:"Wenn auch der entsprechende Chafer-Offizier bereits seit Langem aus der Welt geschieden ist, so liegt dennoch sein Dolch in euren Händen. Das solltet ihr euch wirklich bewusst machen. Denn wenn das Heft des Dolches durch die Hände des Chafer-Offizieres gegangen ist, wie sieht es dann wohl mit der Klinge aus...?",ep:14,g:32,l:83,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>100&CS>50",p:18000};
I.u[3649] = {n:"Raffzahn",t:5,d:"Dieser Dolch ist das letzte Werk des berühmten Waffenschmiedes Dolchevito. Sonst eher versiert in Glücksspielen und anderen nicht zu empfehlenden Tätigkeiten, schuf er mit diesem Dolch ein echtes Meisterstück. Es gibt wirklich schlimmere Wege, seine Karriere zu beenden.",ep:9,g:33,l:95,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>80&CS>100",p:23000};
I.u[3650] = {n:"Kompromesser",t:5,d:"Diese mächtigen Doppelmesser sind das Ergebnis einer Kooperation zwischen den wenigen Handwerkern, die in der Lage waren, sich über die zukünftige Richtungswahl ihres Handwerkes einig zu werden. Es waren bloß zwei. Sie starben schließlich beide an den Folgen eines Streites bei der Namenswahl für ihr gemeinsames Werk.",ep:3,g:34,l:120,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CS>100",p:37000};
I.u[3651] = {n:"Agglutinadolch",t:5,d:"Ein kleiner Handwerker namens Sleyhin hatte eines Tages den brillianten Einfall, diesen wunderbaren Dolch zu schmieden. Von einem Tag auf den Nächsten standen alle Kunden vor seiner Schmiede Schlange, was ihn auch zum besonderen Namen seines Dolches inspirierte.",ep:9,g:35,l:90,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CV>30&CA>100&CS>70",p:22000};
I.u[3652] = {n:"Marie Aigues Stock",t:4,d:"Marie Aigue wusste, wie man mit Männern umgeht. Ihr Stock wusste es auch, da er selbst die hartnäckigsten Avancen der mächtigsten Iop-Ritter zurückwies. Daher sollte es noch sehr lange Zeit dauern, bis am Ende jemand herausfand, dass Marie Aigue nichts anderes als ein Junge war, der sich als Mädchen verkleidet hatte.",ep:12,g:30,l:112,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,40,40,false,false],c:"CI>250&CA>100&CV>100",p:32000};
