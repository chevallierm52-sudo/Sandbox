I.u[8913] = {n:"Knollentrank",t:12,d:"Die für diesen Trank verwendeten Knollen wurden in Äkebäke mariniert. Anstelle von Äkebäke, die bereits seit längerer Zeit vergriffen ist, mengen die etwas kühneren Alchimisten den Knollen einfaches Reismehl bei. Wie dem auch sei, ihr werdet euch an den Geschmack schon gewöhnen.",ep:22,g:23,l:110,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[8914] = {n:"Bastler-Beschreibung",t:24,d:"Diese Beschreibung enthält alle notwendigen Angaben, um den darauf beschriebenen Bastler zu finden.",ep:0,g:176,l:1,wd:false,fm:true,w:0,c:"PJ>65,50",p:1};
I.u[8915] = {n:"Blanko Bastler-Fahndungsblatt",t:80,d:"Auf diesem Blatt sind alle Angaben einzutragen, die helfen können, einen Bastler ausfindig zu machen.",ep:0,g:6,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[8916] = {n:"Tynril-Bernstein",t:50,d:"Dieser Bernstein ist tatsächlich einzigartig. Wenn ihr ihn kräftig schüttelt und dazu einen flotten Chafer-Tango tanzt, wird sich euch seine geheimnisvolle Seele offenbaren. Dass ihr dabei ein wenig lächerlich aussehen werdet, spielt weiter keine Rolle.",ep:22,g:1,l:100,wd:true,fm:true,w:10,p:1};
I.u[8917] = {n:"Schlüssel zur Aggrotte",t:84,d:"Dieser merkwürdige Schlüssel gestattet euch den sofortigen Zutritt zur Aggrotte.",ep:22,g:244,l:1,wd:true,fm:true,w:1,p:1};
I.u[8918] = {n:"Verbesserter Helm",t:16,d:"Der verbesserte Helm sollte es theoretisch ermöglichen, auch die schnellsten Scarablätter zu besteigen, ohne seine Perücke zu verlieren. Sollte sich die Theorie in der Praxis bestätigen, so wäre er schlicht und einfach unabdinglich.",ep:22,g:25,l:1,wd:true,fm:true,w:10,p:1};
I.u[8919] = {n:"Verbesserte hölzerne Flügel",t:17,d:"Für mehr Leichtigkeit wurden diese Flügel mit weichen Federn und hochwertigem Stoff versehen. Doch ist ihre Struktur immer noch aus Holz – also Vorsicht, wenn ihr euch nicht zum Gespött der fliegenden Holländer machen wollt!",ep:22,g:22,l:30,wd:true,fm:true,w:10,p:2633};
I.u[8922] = {n:"Geldbörse",t:24,d:"Diese Geldbörse enthält einen nicht unerheblichen Kama-Betrag. Vermutlich Bestechungsgeld.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8923] = {n:"Kartoffelsack",t:24,d:"Ein Kartoffelsack... Wirklich, wer sich mit diesem Sack sehen lässt, ist entweder Opfer einer geheimen Kartoffelsackverschwörung oder aber einer Geschmacksverirrung.",ep:2,g:243,l:1,wd:true,fm:true,w:0,p:1};
I.u[8924] = {n:"Rambo Zam-Bogen",t:2,d:"Rambo Zam hatte nur wenige erwähnenswerte Eigenschaften. Eine davon war, dass er diesen Bogen besaß.",ep:22,g:59,l:151,wd:true,fm:true,w:10,an:10,e:[10,3,2,7,30,50,false,true],c:"CA>200",p:46105};
I.u[8925] = {n:"Ellens Bogen",t:2,d:"Ellens Bogen sieht zugegebenermaßen etwas hippiemäßig aus, hat aber den Vorteil, seinen Besitzer in einen Zustand unbeschwerter Sorglosigkeit zu versetzen.",ep:22,g:60,l:185,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,3,8,30,50,false,true],c:"CA>300&CI>300",p:51125};
I.u[8926] = {n:"Okey-Do-Klinge",t:5,d:"Mit dieser Klinge ist wirklich alles okey-dokey. Sogar doppelt!",ep:22,g:65,l:175,wd:true,fm:true,w:10,an:13,tw:true,e:[7,3,1,1,30,30,false,false],c:"CA>250&CC>250&CS>150",p:49775};
I.u[8927] = {n:"Gaga-Dolche",t:5,d:"Gaga war ein vollkommen durchgeknallter Sram: er stahl von den Armen, um alles den Reichen zu geben.",ep:22,g:66,l:171,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CS>350&CA>200",p:49280};
I.u[8928] = {n:"Doingsch",t:5,d:"Ingsch war schon immer erfahrener im Wetttrinken als in Wettkämpfen, und das wurde mit der Zeit auch nicht unbedingt besser. Dennoch sollte man besser nicht wie ein Korken aussehen, wenn er seinen Dolch in der Hand hält...",ep:22,g:67,l:158,wd:true,fm:true,w:10,an:13,e:[15,2,1,1,30,50,false,false],c:"CA>300",p:47275};
I.u[8929] = {n:"Kris \"Tobal\"",t:5,d:"Diese Dolche sollten nicht mit dem berühmten Stecken ähnlichen Namens verwechselt werden. Sie verursachen nämlich ein viel blutigeres Gemetzel...",ep:22,g:68,l:149,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CI>250&CC>250",p:45875};
I.u[8930] = {n:"Fuchsiateufelswildchen",t:6,d:"Aus Gründen der Farbgebung hat es mehr als nur ein Krieger abgelehnt, dieses Schwert zu führen. Die meisten von ihnen waren ihm denn auch irgendwann unterlegen.",ep:22,g:78,l:163,wd:true,fm:true,w:10,an:14,e:[7,5,1,1,30,50,false,false],c:"CA>300&CI>300",p:48245};
I.u[8931] = {n:"Aztacke",t:6,d:"Die Aztacke gehörte einst einem größenwahnsinnigen Enutrof. Sie besteht aus Massivgold, genau wie das Ego ihres einstigen Besitzers, an welches das eure sowieso niemals heranreichen wird.",ep:22,g:79,l:186,wd:true,fm:true,w:10,an:14,tw:true,e:[7,5,1,1,45,50,false,false],c:"CA>200&CC>200&CS>200",p:51275};
I.u[8932] = {n:"Schwert des Teilens",t:6,d:"Lächeln bitte! Und schon seid ihr entzwei.",ep:22,g:80,l:179,wd:true,fm:true,w:10,an:14,e:[7,4,1,1,40,50,false,false],c:"CS>300&CA>150",p:50330};
I.u[8933] = {n:"Chiropteraxt",t:19,d:"Die Chiropteraxt ist dämmerungs- oder nachtaktiv. Sie legt bei der Nahrungssuche oft weite Strecken zurück, und tagsüber schläft sie kopfunter hängend.",ep:22,g:49,l:162,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,50,50,false,false],c:"CW>250&CS>300",p:47900};
I.u[8934] = {n:"Beil Ixt",t:19,d:"Voller Wut darüber, dass ihm während seines Urlaubes in Pandala von einem wuseligen Eichhörnchen ein Reiskorn vom Teller stibitzt wurde, stürzte Bruce Bulgour mit seinem Beil Ixt los, den Übeltäter zur Strecke zu bringen. Um den flinken Räuber zu erwischen, begann Bruce, große Teile des Bambuswaldes zu fällen, bis es den Pandawas schließlich gelang, den aufgebrachten Holzfäller durch Einflößen großer Mengen von hochprozentigem Bambusgeist zur Ruhe zu bringen. Guter, alter Bruce...",ep:22,g:50,l:158,wd:true,fm:true,w:10,an:17,e:[7,5,1,1,50,50,false,false],c:"CC>150&CA>150&CI>150",p:47542};
I.u[8935] = {n:"Schuppen-Schippe",t:8,d:"Wie jedermann weiß, sind Schuppen eine unangenehme Angelegenheit. Am besten, man schippt den Betroffenen beiseite, schüttelt ihn ein Mal richtig durch, und zieht hiernach seines Weges.",ep:22,g:48,l:176,wd:true,fm:true,w:10,an:16,e:[7,4,1,1,35,50,false,false],c:"CC>250&CI>250",p:49985};
I.u[8936] = {n:"Allesfürdiekatz",t:8,d:"Die Allesfürdiekatz ist nutzloseste aller Schaufeln überhaupt. Wenn sie zufrieden ist, gibt sie merkwürdige Laute von sich, das ist aber auch das Einzige.",ep:22,g:49,l:137,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>150&CA>200",p:43945};
I.u[8937] = {n:"Rokokokette Schaufel",t:8,d:"Die zierliche Rokokokette ist an Eleganz nicht zu übertreffen. In der Nähe von Edelmetallen schlägt sie ganz besonders fein und leicht aus.",ep:22,g:50,l:156,wd:true,fm:true,w:10,an:16,e:[7,5,1,1,20,50,false,false],c:"CS>250&CI>250",p:49455};
