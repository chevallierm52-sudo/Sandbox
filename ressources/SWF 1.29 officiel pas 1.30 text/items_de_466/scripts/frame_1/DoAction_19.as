I.u[9059] = {n:"",t:24,d:"",ep:1,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[9060] = {n:"Stück zerissenes Papier",t:24,d:"Ein Teil eines Briefes, das zerrissen wurde. Man kann noch Folgendes darauf lesen: \"... wie abgemacht, werde ich dafür sorgen, dass die Nachforschungen über den Händler ins Leere führen. Übergabe der vereinbarten Summe am üblichen Ort, wo man in charmanter Gesellschaft von Damen ist.\" Der Brief ist mit X unterzeichnet.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9061] = {n:"Exoram",t:32,d:"Exoram muss aus dem Goblin-Lager und bis zum Sram-Tempel beleitet werden.",ep:1,g:9,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9062] = {n:"Dokument über Xephirex",t:24,d:"Dieses Dokument enthält zahreiche interessante Informationen über ein Individuum namens Xephirex. Man erfährt voe allem, dass er viel Zeit in der Kneipe \"Zum betrunkenen Pandawa\" verbringt.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9063] = {n:"Milones Liste",t:24,d:"Diese beeindruckende Liste wurde euch von Milone dem Juwelier übergeben und beschreibt die benötigten Gegenstände, um ein prächtiges Juwel anzufertigen.",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9064] = {n:"Königlicher Fresssackspeichel",t:24,d:"Ob es sich wirklich von gewöhlichem Speichel unterscheidet? Jedenfalls sieht es nicht danach aus.",ep:1,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9065] = {n:"Brief an Milone",t:24,d:"Dieser hastig geschriebene Brief erklärt Milone, dass das Juwel in Gefahr ist. Was vergeudet ihr noch Zeit mit dem Lesen, anstatt rasch zu Milone zu eilen?",ep:16,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9066] = {n:"Brief des Anführers der Diebe",t:24,d:"Bei einem der Diebe gefunden, den ihr bei Milone besiegt habt:\nMilone Corichel hat vor kurzem ein Juwel von grossem Wert erschaffen. Entwendet das Juwel, koste es, was es wolle. Naja, die Diebe haben es nicht geschafft und auf der Rückseite befindet sich der Sitz ihres Schlupfwinkels aufgezeichnet. Ein Stippvisite ist angesagt, aber ihr geht besser mit Begleitung hin.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9067] = {n:"Brief an Xephirex",t:24,d:"Dieser Brief von Oto Mustam erläutert Xephirex alle Details des Planes.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9068] = {n:"Milones Juwel",t:24,d:"Dieses Juwel ist das Ergebnis eurer Mühe und der Mühe von Milone dem Juwelier. Er ist natürlich ein kleines Vermögen wert... für die, die es interessiert.",ep:16,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9069] = {n:"Neuer Brief an Xephirex",t:24,d:"Oto beschriebt hier seine Bedingungen zum Bestechen von Xephirex.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9070] = {n:"Seltsames Schwert",t:24,d:"Dieses Schwert ist wirklich ungewöhnlich. So eins habt ihr in Bonta noch nie gesehen.",ep:1,g:718,l:1,wd:false,fm:true,w:0,p:1};
I.u[9071] = {n:"Notizen des Wirts Feubuk",t:24,d:"Der Feubuk-Wirt hat verdächtige Ecaflips als Gäste gehabt, die den Namen Wolfek ausgesprochen haben.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9072] = {n:"Notizen des \"G\'smörtnbröd\"Wirts",t:24,d:"G\'smörtnbröd-Wirt hat gehört, wie Wachen von ihren Problemen mit einer Bande von Ecaflips gesprochen haben.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9073] = {n:"Abzeichen des Ecaflip-Banditen",t:24,d:"Dieses Abzeichen stammt von Ecaflip-Banditen der Ebene von Cania.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9074] = {n:"Amayiros Juwel",t:24,d:"Dieses Juwel dient dazu, den Chef der Banditen anzulocken, um ihn dann gefangen zu nehmen.",ep:1,g:111,l:1,wd:false,fm:true,w:0,p:1};
I.u[9075] = {n:"Brief des Xélor",t:24,d:"Dieser Brief wurde euch von einem Mittelsmann der Juwelierin Marge Gondersun überbracht: \nBringt das Juwel Nanbuky O\'Suke im  \"Hohlzkrug\". Das ist für uns schneller und für euch lukrativer.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9076] = {n:"Amayiros Juwel (Fälschung)",t:24,d:"Dieses Juwel sieht dem Juwel, das ihr für Amayiro holen solltet zum Verwechseln ähnlich. Es ist auch besser so, sonst...",ep:1,g:110,l:1,wd:false,fm:true,w:0,p:1};
I.u[9077] = {n:"Féca-Schädel",t:47,d:"Ein Féca-Schädel gibt eine excellente Buchstütze ab.",ep:1,g:34,l:1,wd:true,fm:false,w:1,p:1};
I.u[9078] = {n:"Osamodas-Schädel",t:47,d:"Ein Tofu hier, ein Bwork-Magus dort: diesem Osamodas-Anhänger hat das wohl den Kopf verdreht.",ep:1,g:33,l:1,wd:true,fm:false,w:2,p:1};
I.u[9079] = {n:"Enutrof-Schädel",t:47,d:"Diese Trophäe war bereits alt, bevor sie zur Trophäe wurde.",ep:1,g:32,l:1,wd:true,fm:false,w:2,p:1};
I.u[9080] = {n:"Sram-Schädel",t:47,d:"Heimtückisch wie ein Sram. Selbst als Schädel geben sie sich noch als etwas anderes aus, als sie sind, nämlich als Trophäe.",ep:1,g:31,l:1,wd:true,fm:false,w:2,p:1};
I.u[9081] = {n:"Xélor-Schädel",t:47,d:"Dieser Schädel wird oft mit dem der berüchtigten Mumie von Tuut Hänkamaan verwechselt. Doch gibt es einen wesentlichen Unterschied: die Bandagen sind nicht aus Karton, sondern aus Pappmaché",ep:1,g:30,l:1,wd:true,fm:false,w:2,p:1};
I.u[9082] = {n:"Ecaflip-Schädel",t:47,d:"Hiermit kann man tolle Dinge machen, wie zum Beispiel Knöchelchen werfen, oder gar Kopf oder Zahl spielen.",ep:1,g:29,l:1,wd:true,fm:false,w:2,p:1};
I.u[9083] = {n:"Eniripsa-Schädel",t:47,d:"Jetzt seid nicht so gehässig: nur weil es klein ist, handelt es sich noch lange nicht um ein Stubenfliegenhirn.",ep:1,g:28,l:1,wd:true,fm:false,w:2,p:1};
I.u[9084] = {n:"Iop-Schädel",t:47,d:"Diese Trophäe klingt ausgeleert genauso hohl wie vorher.",ep:1,g:27,l:1,wd:true,fm:false,w:1,p:1};
I.u[9085] = {n:"Crâ-Schädel",t:47,d:"Man könnte glatt meinen, er sei frisch ausgebuddelt worden, dieser Schädel eines Crâ Magnum.",ep:1,g:26,l:1,wd:true,fm:false,w:2,p:1};
I.u[9086] = {n:"Sadida-Schädel",t:47,d:"Wer hätte gedacht, dass sich unter all diesen Haare noch ein Schädel versteckt?",ep:1,g:25,l:1,wd:true,fm:false,w:2,p:1};
I.u[9087] = {n:"Sacrieur-Schädel",t:47,d:"Jetzt, wo ihm seine Milliarden an Lebenspunkten fehlen, wird dieser Sacrieur nicht mehr so angeben...",ep:1,g:24,l:1,wd:true,fm:false,w:2,p:1};
I.u[9088] = {n:"Pandawa-Schädel",t:47,d:"Wer hätte gedacht, dass dieser Pandawa-Schädel selbst so lange nach dem Tod seinen Kater behält...",ep:1,g:23,l:1,wd:true,fm:false,w:2,p:1};
I.u[9089] = {n:"Abzeichen der Bonta Patrouille",t:24,d:"Dieses Abzeichen habt ihr während des (sehr einfachen) Scharmützels gegen Bonta eingeheimst.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9090] = {n:"Abzeichen der Brâk-Patrouille",t:24,d:"Dieses Abzeichen habt ihr mit viel Aufwand während eines Scharmützels zwischen Bonta und Brâkmar sichergestellt.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9092] = {n:"",t:24,d:"",ep:16,g:86,l:1,wd:false,fm:true,w:0,p:1};
I.u[9094] = {n:"Bwork Gift",t:24,d:"Das Gift sieht eher aus wie Minzgelee;\r\n            naja die Bworks sind nicht gerade begabt dafür, aber was noch viel beunruhigender ist, die Spione aus Brâkmar auch nicht.",ep:4,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9096] = {n:"Taktiker",t:32,d:"Der Taktiker hat eingewilligt, euch bis zu eurem Chef zu begleiten.",ep:16,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9097] = {n:"Dienstmarke des mächtigen Milizionärs",t:24,d:"Diese Dienstmarke habt ihr dem furchterregenden Milizionär abgenommen, der mehrere Brâk-Krieger besiegt hat. Seine Ausrüstung schien ganz besonders eigentümlich.",ep:16,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9098] = {n:"Naras Hammer",t:24,d:"Dieser Hammer ist für Oto ein Hinweis darauf, dass ihr den Söldner-Schmied von Bonta besiegt habt.",ep:16,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9099] = {n:"Amyiros Hilfsgesuch",t:24,d:"Bei diesem von Amayiro unterschriebenen Brief handelt es sich um ein offizielles Hilfegesuch.",ep:3,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9100] = {n:"Lenglads Unterhose",t:24,d:"Eins ist sicher: Lenglad wird sich ganz sicher einige Zeit lang nicht mehr blicken lassen.",ep:1,g:84,l:1,wd:false,fm:true,w:0,p:1};
I.u[9101] = {n:"Naras Werkzeugkiste",t:24,d:"Diese Kiste enthält Werkzeug, das vom Schmied Nara vergessen wurde.",ep:3,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9103] = {n:"Angriffsplan",t:24,d:"Dieser Brief trägt das Datum letzter Woche. Darin stehen alle Details für die Planung des Angriffes auf Bonta. Allerdings besagt eine Fußnote, dass der Plan noch nicht bestätigt sei und der Offizier Käppi Tähn in den kommenden Tagen noch Änderungen vornehmen könnte. Daher müsst ihr nun herausfinden, was der letzte Stand der Dinge ist.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9104] = {n:"Abzeichen der Friedhofs-Patrouille",t:24,d:"Dieses Abzeichen habt ihr von einer Brâk-Patrouille, die ihr beim Friedhof der Verdammten überfallen habt.",ep:16,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9105] = {n:"Danathors Brief",t:24,d:"Während Amayiro euch die Mission anvertraut hat, hat jemand diesen Brief in eure Tasche gleiten lassen: \"Bringt die Dokumente in euren Besitz, aber bringt sie mir und nicht Amayiro. Eine Belohnung erwartet euch. Danathor\"",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9106] = {n:"Geheime Bonta-Dokumente",t:24,d:"Diese Dokumente enthalten zahlreiche Informationen zur Verteidigung und zum System von Bonta. Aber wem werdet ihr diese Informationen übergeben?",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9107] = {n:"Anweisungen für den Bonta-Spion",t:24,d:"Dringe um Mitternacht in den Turm von Brâkmar ein und bringe alle Dokumente die du im zweiten Stockwerk findest in deinen Besitz. Halte dich anschließend östlich der Straße nach Bonta, um zurückzukehren.\nNein, nicht IHR sollt das ausführen, das war die Anweisung für den Spion, den ihr retten sollt.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9108] = {n:"Geheime Brâk-Dokumente",t:24,d:"Diese Dokumente enthalten zahlreiche Informationen zum Horn des Ih-Fritts.",ep:14,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9109] = {n:"Löchriger Bandana",t:24,d:"Dieser Bandana in schlechtem Zustand ist mit Schleim überzogen, als ob er mehreren Generationen von Wabbits als Taschentuch gedient hätte. Ganz ohne Zweifel gehörte er Tökredilsch, man merkt es am Geruch von fauligem Hering, der zart von Kawottenaroma überdeckt wird. \nNach so vielen Jahren so schlecht zu riechen, bedeutet zweifellos, dass er von mächtigem Zauber durchwirkt ist.",ep:8,g:748,l:1,wd:false,fm:true,w:0,p:1};
I.u[9110] = {n:"Horn des Ih-Fritts",t:24,d:"Ihr habt schon vorher versucht reinzublasen, aber es passiert nichts Besonderes...",ep:16,g:720,l:1,wd:false,fm:true,w:0,p:1};
I.u[9112] = {n:"Anweisung für den Brâk-Spion",t:24,d:"Dringe um Mitternacht in den Turm von Bonta ein, bringe alle um, die sich dir in den Weg stellen und nimm alle Dokumente an dich, die du im ersten Stock findest. Kehre anschließend über die Straße nach Brâkmar zurück.\nNein, nicht IHR sollt das erledigen, das war nur der Auftrag für den Spion, den ihr wiederfinden solltet.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9113] = {n:"Geheime gestohlene Dokumente",t:24,d:"Die Dokumente, die der verletzte Spion im Turm von Bonta an sich genommen hat.",ep:13,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9114] = {n:"Zerknitterte geheime Dokumente",t:24,d:"Dokumente, die der verwundete Spion im Turm von Bonta entwendet hat. Sie wurden im Kampf gegen die Streitkräfte Bontas ein wenig beschädigt.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9115] = {n:"Mit Pollen gefüllter Schalat",t:24,d:"Dieser Schalat wurde im Hauptkessel zubereitet, was ihm ganz besondere Kräfte verleiht. Um herauszubekommen, welche, müsste man mal probieren, aber leider ist er für Tökredilsch bestimmt. So ist das Leben eben.",ep:12,g:719,l:1,wd:false,fm:true,w:0,p:1};
I.u[9116] = {n:"Kiste mit Ausrüstung",t:24,d:"Eine Waffe, ein Helm, ein Schild: diese Kiste enthält eine zwar rudimentäre aber wirkungsvolle Ausrüstung für Krieger.",ep:16,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9117] = {n:"Stinkelingshammer",t:7,d:"Der Stinkeling war ein alter Dickschädel. Selbiger wurde denn auch zu einen Hammer verarbeitet, welcher ideal ist, um allen anderen eins drüber zuziehen.",ep:23,g:67,l:180,wd:true,fm:true,w:15,an:15,e:[10,4,1,1,50,50,false,false],c:"CV>1200",s:118,p:50000};
I.u[9118] = {n:"Shika-Event-Geschenk",t:89,d:"(Event-Geschenk auf Shika)",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[9119] = {n:"Shika-Geschenk",t:89,d:"(Geschenk an Abonnenten auf Shika)",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[9120] = {n:"Shika-Hut",t:16,d:"(Geschenk an Abonnenten auf Shika)",ep:0,g:210,l:30,wd:false,fm:true,w:10,p:3000};
I.u[9121] = {n:"Shika-Umhang",t:17,d:"(Geschenk an Abonnenten auf Shika)",ep:0,g:148,l:30,wd:false,fm:true,w:10,p:3000};
I.u[9122] = {n:"Kirsch-Blob-Ring",t:9,d:"Wer diesen Ring einmal am Finger trägt, wird sich nicht davon trennen können... Zumal er ständig darüber grübeln wird, woran selbiger ihn wohl erinnert...",ep:5,g:149,l:50,wd:true,fm:true,w:10,s:98,p:4000};
