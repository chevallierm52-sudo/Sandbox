I.u[8890] = {n:"Getigerte Maunzmiez-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich genug Nahrung und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8891] = {n:"Wuseliges Eichhörnchen-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich genug Nahrung und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
