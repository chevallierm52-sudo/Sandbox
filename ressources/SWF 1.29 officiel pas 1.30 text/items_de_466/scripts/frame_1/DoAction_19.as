I.u[9165] = {n:"Königliche Indigoblobtten",t:11,d:"Wiederholt acht Mal schnell hintereinander das Wort \"Blobtten\"! Da steht ihr da wie ein Iop, nicht wahr?",ep:5,g:124,l:80,wd:true,fm:true,w:10,s:105,p:16000};
I.u[9166] = {n:"Königliche Multiblobtten",t:11,d:"Mit oder ohne Futter - dieses Schuhwerk sieht ziemlich überladen aus. Es ist also auch nicht weiter nötig, es mit etwas anderem als euren Füßen zu zieren.",ep:5,g:125,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9167] = {n:"Kirschblob-Gurt",t:10,d:"Dieser Gurt besitzt weder besondere Vorzüge, noch besondere Nachteile, ist jedoch gerade bei den beleibteren Abenteurern sehr beliebt, da er einen ausgezeichneten Schutz für die kleinen Hüftpölsterchen bietet.",ep:5,g:136,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9168] = {n:"Apfelblob-Gurt",t:10,d:"Dieser Gurt besitzt weder besondere Vorzüge, noch besondere Nachteile, ist jedoch gerade bei den beleibteren Abenteurern sehr beliebt, da er einen ausgezeichneten Schutz für die kleinen Hüftpölsterchen bietet.",ep:5,g:137,l:50,wd:true,fm:true,w:10,s:99,p:1000};
I.u[9169] = {n:"Kokosblob-Gurt",t:10,d:"Dieser Gurt besitzt weder besondere Vorzüge, noch besondere Nachteile, ist jedoch gerade bei den beleibteren Abenteurern sehr beliebt, da er einen ausgezeichneten Schutz für die kleinen Hüftpölsterchen bietet.",ep:5,g:138,l:50,wd:true,fm:true,w:10,s:100,p:1000};
I.u[9170] = {n:"Indigoblob-Gurt",t:10,d:"Dieser Gurt besitzt weder besondere Vorzüge, noch besondere Nachteile, ist jedoch gerade bei den beleibteren Abenteurern sehr beliebt, da er einen ausgezeichneten Schutz für die kleinen Hüftpölsterchen bietet.",ep:5,g:139,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9171] = {n:"Königlicher Kirschblob-Gurt",t:10,d:"Ohne den Blob-Schmuck kann dieser Gürtel ganz schön weh tun, insbesondere wenn er unverhofft und schwungvoll auf zarte, entblößte Haut trifft.  \nHinweis: Rostige Eisenspitzen sind gesondert zu bestellen.",ep:5,g:140,l:80,wd:true,fm:true,w:10,s:102,p:16000};
I.u[9172] = {n:"Königlicher Apfelblob-Gurt",t:10,d:"Ohne den Blob-Schmuck kann dieser Gürtel ganz schön weh tun, insbesondere wenn er unverhofft und schwungvoll auf zarte, entblößte Haut trifft.  \nHinweis: Rostige Eisenspitzen sind gesondert zu bestellen.",ep:5,g:141,l:80,wd:true,fm:true,w:10,s:103,p:16000};
I.u[9173] = {n:"Königlicher Kokosblob-Gurt",t:10,d:"Ohne den Blob-Schmuck kann dieser Gürtel ganz schön weh tun, insbesondere wenn er unverhofft und schwungvoll auf zarte, entblößte Haut trifft.  \nHinweis: Rostige Eisenspitzen sind gesondert zu bestellen.",ep:5,g:142,l:80,wd:true,fm:true,w:10,s:104,p:16000};
I.u[9174] = {n:"Königlicher Indigoblob-Gurt",t:10,d:"Ohne den Blob-Schmuck kann dieser Gürtel ganz schön weh tun, insbesondere wenn er unverhofft und schwungvoll auf zarte, entblößte Haut trifft.  \nHinweis: Rostige Eisenspitzen sind gesondert zu bestellen.",ep:5,g:143,l:80,wd:true,fm:true,w:10,s:105,p:16000};
I.u[9175] = {n:"Königlicher Multiblob-Gurt",t:10,d:"Wenn man diesen Gürtel nur fest genug zuzurrt, kann man seinen Verdauungsapparat so gut wie vollständig abschnüren. Fragt sich nur, welchen Sinn ein solch törichtes Vorhaben haben sollte...",ep:5,g:144,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9176] = {n:"Klaubtaubklinge",t:5,d:"Als sich der Bworker langsam daran machte, Oh\'Nein die Gedärme aus dem Leibe zu klauben, sang dieser immer noch lautstark \"Es kann nicht immer nur die Sonne scheinen...\" Woraufhin der Bworker ertaubte.",ep:22,g:70,l:182,wd:true,fm:true,w:10,an:13,e:[7,4,1,1,30,40,false,false],c:"CS>200&CI>150&CC>150&CA>150",s:108,p:58000};
I.u[9177] = {n:"Sündenpfahlring",t:9,d:"Die kleinen Pfähle dieses Schmuckstücks erinnern die Bworks ständig an ihre 3 Hauptsünden: Rachdurst, Siegesdurst und... Durst.",ep:22,g:158,l:179,wd:true,fm:true,w:10,s:108,p:54000};
I.u[9178] = {n:"Akkumulierring",t:9,d:"Dieses Schmuckstück legt Zeugnis ab von einer uralten Bworktradition der Körperpflege. Welcher genau, müsst ihr selbst herausfinden.",ep:22,g:159,l:179,wd:true,fm:true,w:10,s:109,p:54000};
I.u[9179] = {n:"Amulett des Bworkrippers",t:1,d:"Eines schönen Tages traf der Chafer-Offizier auf einen Bwork und prägte den legendären Ausspruch: \"Dein Hinterteil ist dir wie ins Gesicht geschrieben!\" Worauf der Bwork mit hoher Wahrscheinlichkeit zum Ripper wurde, denn der Chafer-Offizier ward nie wieder gesehen.",ep:22,g:137,l:184,wd:true,fm:true,w:10,s:108,p:52458};
I.u[9180] = {n:"Lügenmäntelchen",t:17,d:"Der Bworker behauptet steif und fest, er hätte sich dieses Mäntelchen aus der Haut Rushus gefertigt. Man könnte dies beinahe glauben, wenn nicht auf der Hand läge, dass der Bworker weder mit der Nadel noch mit dem Faden umzugehen weiß...",ep:22,g:151,l:185,wd:true,fm:true,w:10,s:108,p:58000};
I.u[9181] = {n:"Geheimnishüter",t:16,d:"Als alleiniger Begleiter des Bworkers hütete dieses Wunderwerk von Helm viele Jahre lang die ihm anvertrauten Geheimnisse. Eines Tages jedoch beging der Bworker den Fehler, ihm vom traurigen Ende seiner vorigen Helme zu berichten, woraufhin der Geheimnishüter in eine tiefe Ohnmacht sank, aus welcher er bis zum heutigen Tage noch nicht wieder erwacht ist.",ep:22,g:212,l:189,wd:true,fm:true,w:10,s:109,p:59000};
I.u[9182] = {n:"Beringte Stiefel",t:11,d:"Vor langer langer Zeit forderte Douglas Kwaid den Bworker mit den Worten heraus: \"Wenn deine Schuhe derart beringt sind, dann hast du wahrscheinlich nicht begriffen, dass man sie nicht an den Ohren trägt!\" Was ein großer Fehler war...",ep:22,g:126,l:184,wd:true,fm:true,w:10,s:109,p:58000};
I.u[9183] = {n:"Verzweckter Schurz",t:10,d:"Mit dem Zwecken tief in den Hüftpolsterchen steckend wiegt sich der Bworker derart in Trance, dass seine Feinde sogar die Nähte des aus Killibri-Haut gefertigten Bworker-Unterhöschen zu sehen kriegen. Daraufhin wird ihnen in der Regel reihenweise schwindelig, so dass es dem Bworker selbst in Trance ein Leichtes ist, sie zu erledigen. Einem richtigen Bworker gereicht eben fast jedes Mittel zum Zweck!",ep:22,g:145,l:181,wd:true,fm:true,w:10,s:109,p:58000};
I.u[9184] = {n:"Trophäelm",t:16,d:"Entgegen aller Vermutungen trägt dieser Helm nicht zur Verbesserung der Hörfahigkeit seines Trägers bei... Dafür lassen sich allerdings jede Menge Seile mit den Köpfen der Feinde an ihm befestigen.",ep:1,g:213,l:33,wd:true,fm:true,w:10,p:3000};
I.u[9185] = {n:"Goultards Helm",t:16,d:"Dieser Helm verleiht euch weder Stärke, noch Flinkheit, noch sonst irgendetwas. Außer einem lächerlichen Aussehen vielleicht. Und wenn ihr denkt, dass euch ein paar naive Abenteurer für Goultard höchstpersönlich halten werden, dann habt ihr euch geschnitten. Aber gut, wenigstens wird man euch bereits von Weitem kommen sehen, das ist ja schon mal nicht schlecht.",ep:1,g:214,l:30,wd:true,fm:true,w:10,p:2600};
I.u[9186] = {n:"Gürtel von Fläsch Gorgon",t:10,d:"Über Fläsch Gorgon ist ziemlich wenig bekannt, außer, dass er eine riesige Sammlung an Porzellanvasen besaß und schneller rennen konnte, als mancher Tofu. Da er ständig in Eile war, nimmt es nicht Wunder, dass er sich eine Tages mit seinem Fuß in seinem Gurt verhedderte. Seine Porzellanvasensammlung kann noch ein Lied davon singe...",ep:1,g:146,l:48,wd:true,fm:true,w:30,p:6075};
I.u[9187] = {n:"Hut von Meister Bläck Jack",t:16,d:"Meister Bläck Jack ist ein begeisterter Hobbyschneider, der die Kunst der unsichtbaren Nähte entwickelte, wie am Beispiel dieses Hutes ersichtlich. Reizend, nicht?",ep:1,g:215,l:33,wd:true,fm:true,w:10,p:3075};
I.u[9188] = {n:"Pepitox\' Sombrero",t:16,d:"Dieser Sombrero wartet immer noch auf seinen ursprünglichen Eigentümer... Dieser, ein düsterer Xélor, verschwand urplötzlich, als er seiner Liebsten auf der Leiter ein Ständchen hielt. Die Meinungen der Ursachenforscher, die sich dieses Falles angenommen haben, gehen auseinander: die einen denken, dass die beiden Brüder der besagten Liebsten an der Sache nicht ganz unschuldig waren, während die anderen schlicht und einfach davon ausgehen, dass er für eine Weile in einem Zeitloch verschwunden ist.",ep:1,g:216,l:40,wd:true,fm:true,w:10,p:5000};
I.u[9189] = {n:"Hörner von XVII",t:16,d:"Da habt ihr nun eure Gegner unbedingt auf die Hörner nehmen wollen, und jetzt lauft ihr dagegen herum mit einem Kopf wie ein Sieb... Nun, die Hörner von XVII gehören XVII, dem Dämonen der siebzehnten Stunde, der die außergewöhnliche Macht besitzt, anderen das Gedächtnis zu rauben, so dass sie sich an nichts anderes mehr erinnern als möglicherweise die Teestunde.",ep:1,g:217,l:20,wd:true,fm:true,w:4,p:1300};
I.u[9190] = {n:"Papperlakapp",t:16,d:"\"Lächerlich\", werden eure Betrachter sagen. Recht haben sie... Doch das kann euch egal sein. Ihr antwortet ihnen mit einem entschiedenen \"Papperlakapp\"!",ep:1,g:218,l:35,wd:true,fm:true,w:5,p:10000};
I.u[9191] = {n:"Pyms Schwert",t:6,d:"Dieses Schwert scheint dem Bestand eines Holzfällers zu entstammen... Hoffentlich erzielt ihr damit bessere Erfolge als bisher, denn andernfalls bleibt euch nur noch der Weg in die Ich-AG...",ep:1,g:84,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[9192] = {n:"Naschürtel",t:10,d:"Mit diesem Gürtel sind eure Hüften gleich doppelt so lecker gepanzert.",ep:1,g:147,l:45,wd:true,fm:true,w:2,s:110,p:5600};
I.u[9193] = {n:"Naschmulett",t:1,d:"Wenn ihr schon immer davon geträumt habt, eure Gegner mit Törtchen zu bewerfen, dann liegt ihr mit dem Naschmulett genau richtig!",ep:1,g:138,l:43,wd:true,fm:true,w:2,s:110,p:5000};
I.u[9194] = {n:"Naschelm",t:16,d:"Früher hattet ihr mit Flöhen auf dem Kopf zu kämpfen. Mit dem Naschelm werden es die Vögelein sein...",ep:1,g:219,l:44,wd:true,fm:true,w:2,s:110,p:5200};
I.u[9195] = {n:"Naschumhang",t:17,d:"Wenn ihr ihn in etwas Konfitürenlauge weichspült, werdet ihr mit diesem Umhang nicht nur eure Gegner, sondern auch jede Menge Fliegen im Rücken haben.",ep:1,g:152,l:45,wd:true,fm:true,w:2,s:110,p:5500};
I.u[9196] = {n:"Robusta-Cape",t:17,d:"Mit etwas Glück geht ihr mit diesem Cape als Küchendekoration durch und entgeht somit euren Feinden.",ep:1,g:153,l:45,wd:true,fm:true,w:2,s:111,p:5500};
I.u[9197] = {n:"Robusta-Hut",t:16,d:"Der Robusta-Hut ist nicht nur robust, sondern auch ein richtiger Muntermacher.",ep:1,g:220,l:44,wd:true,fm:true,w:2,s:111,p:5200};
I.u[9198] = {n:"Robusta-Ring",t:9,d:"Wenn euch euer Bier mal nicht mundet, könnt ihr ihm etwas mehr Aroma verleihen, indem ihr diesen Ring hineintaucht.",ep:1,g:160,l:45,wd:true,fm:true,w:2,s:111,p:5600};
I.u[9199] = {n:"Robusta-Treter",t:11,d:"Ja ja... Genau so etwas passiert, wenn man die Tassen mit den Schuhen tritt...",ep:1,g:127,l:43,wd:true,fm:true,w:2,s:111,p:5000};
I.u[9200] = {n:"Schriftrolle \"Chaferwirr beschwören\"",t:75,d:"(Doppelklick, um den Zauber zu erlernen) \nMit dieser Schriftrolle erlernt ihr den Zauber \"Chferwirr beschwören\".",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[9201] = {n:"Schwiftwolle \"Kawotte\"",t:75,d:"Diese Schwiftwolle beschweibt in 101 Kapiteln die Gwundlagen dew wundewbawen, abew nicht besondews geheimen Technik des Wa Wabitts, welche dawin besteht, eine wegenewatiwe Kawotte im Boden zu pflanzen.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[9202] = {n:"Meister Jarbos 2ter Überpowering",t:9,d:"Selbst nach dem Tod fährt Meister Jarbo damit fort, völlig übertriebene Artefakte zu schmieden, die sich nicht das geringste um den Erhalt des kosmischen Gleichgewichtes scheren. Bei diesem Ring stellte er fest, dass das Überqueren von Straßen keine Gefahr mehr darstellt. Hätte er ihn bloß früher besessen! Doch ein Dämon stahl ihn und versteckte ihn in der Welt der Lebenden für machtdürstende Abenteurer.",ep:1,g:9,l:1,wd:false,fm:true,w:1,p:0};
I.u[9203] = {n:"Korruptit",t:24,d:"Das Material, das Oto für seine Klinge braucht. Da es sich sehr schnell zersetzt, benötigt es zum gefahrlosen Transport und zur Aufbewahrung einen besonderen Behälter.",ep:1,g:706,l:1,wd:false,fm:true,w:0,p:1};
I.u[9204] = {n:"Behandeltes Korruptit",t:24,d:"Dieses Stück Korruptit wurde behandelt und zersetzt sich daher nicht mehr.",ep:16,g:706,l:1,wd:false,fm:true,w:0,p:1};
I.u[9206] = {n:"Verfluchtes Eisen",t:24,d:"Ein wenig Verfluchtes Eisen, das Oto für seine Klinge braucht. Es sieht aus wie gewöhnliches Eisen, bis auf seine Aura, die einen Kanigrou in die Flucht schlagen würde.",ep:16,g:241,l:1,wd:false,fm:true,w:0,p:1};
I.u[9207] = {n:"Riemenstück",t:24,d:"Dieses Stück Leder wurde anscheinend vom Riemen einer Tasche abgerissen.",ep:16,g:753,l:1,wd:false,fm:true,w:0,p:1};
I.u[9208] = {n:"Oli Venders Informationen",t:24,d:"Ihr habt Oli Venders Informationen auf diesem Blatt Papier notiert. Um an Schattenhainbuche heranzukommen, müsst ihr im Besitz einer Schattenastaknydenseele und der eines Onis sein. Ihr müsst in Begleitung von vier Brâks euren Ranges oder höher sein. Mindestens zwei von ihnen müssen Holzfäller sein, die Hainbuchholz fällen können.",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9209] = {n:"Rezeptur für den Schwertgriff",t:24,d:"Diese Rezeptur zeigt die Bestandteile auf, die ihr mit zusammen mit dem Schattenhainbuchholz benutzen müsst, um einen Schwertgriff schnitzen zu können. Wenn ihr kein Schattenhainbuchholz mehr habt, könnt ihr euch immer noch welches aus dem Wäldchen hinter der Alchemistenwerkstatt von Salg Zangaer besorgen. \n- 1 Schattenhainbuchholz \n- 3 Schwarzes Leder \n- 2 Vampirblut \n- 1 Ebonit",ep:9,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9210] = {n:"Gwenolaz Barnumuzes Nachricht",t:24,d:"Ein Stück Papier, das für den Richter Satirev Onivin bestimmt ist auf dem Gwenolaz Barnumuze geschrieben hat, sie sei nicht käuflich.",ep:1,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9211] = {n:"Eniledas Nachricht",t:24,d:"Ein Blatt Papier, das an den Richter Onivin Satirev gerichtet ist, in dem Enileda in blumigen Worten eine Absage erteilt.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9212] = {n:"Nepra Lidos Nachricht",t:24,d:"Ein ablehnendes Schreiben von Nepra Lido, der für den Richter Satirev Onivin bestimmt ist. Drauf steht: \"Wir haben nichts gemeinsam...\"",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9213] = {n:"Maskaras Nachricht",t:24,d:"Ein Schmierzettel für den Richter Satirev Onivin, auf dem Maskara gekritzelt hat, sie weigere sich, seine Puppe zu werden.",ep:1,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9214] = {n:"Kwuarzuahs Nachricht",t:24,d:"Eine Nachricht von Kwuarzuah an den Richter Satirev Onivin, die besagt, sie würde so leicht nicht vor ihm kuschen, eher würde er schlapp machen.",ep:1,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9215] = {n:"Lichthammer",t:24,d:"Dieser Hammer ist von einem mächtigen Lichtgeist besessen.",ep:16,g:750,l:1,wd:false,fm:true,w:0,p:1};
I.u[9216] = {n:"Phosphorus-Hammer",t:24,d:"Dies ist der Lichthammer, aber ohne Lichtgeist. Mit ihm könnt ihr gefahrlos eine dämonische Klinge schmieden.",ep:16,g:751,l:1,wd:false,fm:true,w:0,p:1};
I.u[9218] = {n:"Gereinigter Phosphorus-Hammer",t:24,d:"Dies ist der Lichthammer, aber ohne Lichtgeist. Mit ihm könnt ihr gefahrlos eine dämonische Klinge schmieden. Domen hat ihm einige seiner zerstörerischen Kräfte entzogen.",ep:16,g:751,l:1,wd:false,fm:true,w:0,p:1};
I.u[9219] = {n:"",t:9,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[9220] = {n:"Unvollständiges Schwert",t:24,d:"Dieses eindrucksvoll aussehende Schwert ist noch nicht vollendet aber strahlt schon eine unheilvolle Kraft aus. Denkt nicht einmal im Traum dran, es zu entwenden, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und das wollt ihr ganz bestimmt NICHT.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9221] = {n:"Durchdrungene unvollständige Klinge (Stufe 1)",t:24,d:"Oto hat euch diese eindrucksvoll aussehende Klinge ausgeliehen, damit es durch Lagrens Geschicklichkeit mit mehr Macht durchtränkt wird. Denkt nicht einmal im Traum dran, es zu stehlen, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und DAS wollt ihr ganz bestimmt NICHT.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
