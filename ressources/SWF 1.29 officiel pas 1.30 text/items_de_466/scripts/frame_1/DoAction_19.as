I.u[8747] = {n:"Braunblütenblatt",t:35,d:"Dem Braunblütenblatt ist seine Herkunft eindeutig anzusehen... Otomaïs Schüler sollten sich wirklich endlich hinter die Ohren schreiben, dass auf Kirschen und Limonade Durchfall folgt!",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8748] = {n:"Fahlblütenblatt",t:35,d:"Dem Fahlblütenblatt ist seine Herkunft eindeutig anzusehen... Otomaïs Schüler hätten eigentlich wissen sollen, dass Eisenmangel zu Blutarmut führt.",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8749] = {n:"Blaupalmiflorknolle",t:36,d:"Der Blaupalmiflor entspringt nicht einem Samen, sondern einer in Alkohol konservierten Knolle. Warum??? Darum!",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8750] = {n:"Grünpalmiflorknolle",t:36,d:"Der Grünpalmiflor entspringt nicht einem Samen, sondern einer in Alkohol konservierten Knolle. Warum??? Darum!",ep:22,g:6,l:40,wd:true,fm:true,w:1,p:1};
I.u[8751] = {n:"Braunpalmiflorknolle",t:36,d:"Der Braunpalmiflor entspringt nicht einem Samen, sondern einer in Alkohol konservierten Knolle. Warum??? Darum!",ep:22,g:4,l:40,wd:true,fm:true,w:1,p:1};
I.u[8752] = {n:"Fahlpalmiflorknolle",t:36,d:"Der Fahlpalmiflor entspringt nicht einem Samen, sondern einer in Alkohol konservierten Knolle. Warum??? Darum!",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
I.u[8753] = {n:"Mufafah-Mähne",t:36,d:"Diese unmögliche Kreuzung aus Haaren und Blütenblättern ist zwar dekorativ, jedoch gleich doppelt Allergie auslösend. Wer also nicht binnen 2 Sekunden sein Hirn verniesen will, sollte einen entsprechenden Abstand zu ihrem Träger wahren.",ep:22,g:2,l:80,wd:true,fm:true,w:1,p:1};
I.u[8754] = {n:"Nicht-Bart des Bartarossa",t:54,d:"Dieses lächerliche Haarbüschel riecht erstaunlich stark nach Sonne, Strand und Meer. Schade nur, dass sich dem ein Dunst von Rauch und Pulver beimischt.",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8755] = {n:"Verflippte Perücke",t:54,d:"Verflippt oder flippig? Das ist hier die Frage!",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8756] = {n:"Killibri-Daune",t:54,d:"Auf Grund ihrer Leichtigkeit ist die Killibri-Daune sehr begehrt für die Fertigung von Matratzen. Da lebende Matratzen als Zielscheibe für Safaris allerdings bisher noch eine große Marktlücke darstellen, haben es die Handwerker leider immer noch auf die Killibris abgesehen... Ein Phänomen, an dem man sehr gut beobachten kann, wie die Logik des Marktes funktioniert.",ep:22,g:12,l:80,wd:true,fm:true,w:1,p:1};
I.u[8757] = {n:"Bartarossa-Shirt",t:15,d:"Auf See bietet dieses Kleidungsstück 100-prozentigen Schutz gegen jede Art von Insekten. Allerdings solltet ihr euch damit nicht aufs Festland, geschweige denn unter Menschen, wagen!",ep:22,g:11,l:80,wd:true,fm:true,w:1,p:1};
I.u[8758] = {n:"Fetzen von Gurrlos Unterschlüpfer",t:15,d:"Bisher ist es noch niemandem gelungen, ein unversehrtes Exemplar eines von Gurrlos Unterschlüpfern aufzuspüren. Das mag wohl daran liegen, dass bei Gurrlo der Schuss oft in die Hose geht.",ep:22,g:12,l:200,wd:true,fm:true,w:1,p:1};
I.u[8759] = {n:"Flipps verflippte Kiste",t:15,d:"Diese Kiste hat sich der Anatomie von Flipp angepasst, oder umgekehrt. Wie dem auch sein, sie ist und bleibt verflippt.",ep:22,g:13,l:80,wd:true,fm:true,w:1,p:1};
I.u[8760] = {n:"Halstuch des Sparo",t:15,d:"Im Sommer wie im Winter ein absoluter Hingucker und genau die richtige Mischung aus Avantgarde und Kitsch! Doch Vorsicht! Auf männliche Fresssäcke übt dieses Tüchlein eine ganz besondere Signalwirkung aus.",ep:22,g:14,l:80,wd:true,fm:true,w:1,p:1};
I.u[8761] = {n:"Gurrlos Zündpulver",t:48,d:"Gurrlo beabsichtigte einst, sich seinen linken Arm zu amputieren, um diesen durch seine Kanone zu ersetzen. Was diese kleine Anekdote mit diesem Zündpulver hier zu tun hat, müsst ihr schon selbst herausfinden.",ep:22,g:1,l:200,wd:true,fm:true,w:1,p:1};
I.u[8762] = {n:"Hirnstück des geschliffenen Krachlklotzes",t:50,d:"Dieses Hirnstück wird euch dazu befähigen, endlich Krachlermanieren an den Tag zu legen. Ein kräftiger Händedruck genügt, und schon haltet ihr ausreichend Salz für eure Mittagssuppe in den Händen.",ep:16,g:3,l:80,wd:true,fm:true,w:1,p:1};
I.u[8763] = {n:"Mufafah-Schnurrbart",t:15,d:"Der Mufafah-Schnurrbart ist ein wenig dichter als der Katzenfischschnurrbart und eignet sich daher hervorragend zur Fertigung von Pinseln für Marylork.",ep:22,g:15,l:80,wd:true,fm:true,w:1,p:1};
I.u[8764] = {n:"Brauen des Groß-Shilfs",t:15,d:"Die anklagend verzogenen Augenbrauen weisen darauf hin, dass der Groß-Shilf selbst nach seinem Ableben noch darauf besteht, das Sagen zu haben.",ep:22,g:16,l:400,wd:true,fm:true,w:1,p:1};
I.u[8765] = {n:"Killibri-Stock",t:15,d:"Der Killibri-Stock ist ideal für alle, die gerne hoch hinaus wollen. Allerdings solltet ihr bedenken, dass der hohe Mut stets vor dem Fall kommt.",ep:22,g:17,l:100,wd:true,fm:true,w:1,p:1};
I.u[8766] = {n:"Kido-Feder",t:53,d:"Diese Feder löste vor etwa 159.286 Jahren eine heftige Debatte unter den Amaknischen Wissenschaftlern aus, die sich um die Frage rankte, was wohl schwerer sei: 100 Pods Kido-Federn oder 100 Pods Püryt.",ep:22,g:5,l:80,wd:true,fm:true,w:1,p:1};
I.u[8767] = {n:"Flügel des Bitoufs der Ebenen",t:104,d:"Der Bitouf war nicht besonders stolz auf seine Flugkünste. Zu Recht, wenn man sich so seine Flügel anschaut...",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8768] = {n:"Abgerissenes Pumbaa-Ohr",t:106,d:"Wenn ihr dieses Ohr ans Ohr haltet, so könnt ihr darin neben dem Meeresrauschen auch eine Herde von Keilern der Ebenen im vollem Galopp dahinpreschen hören.",ep:22,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8769] = {n:"Kokosschale des Bitoufs der Ebenen",t:111,d:"Diese Kokosschale enthält keine Kokosmilch, sondern lediglich etwas Gehirnflüssigkeit, versetzt mit ein paar Neuronen.",ep:16,g:1,l:80,wd:true,fm:true,w:1,p:1};
I.u[8770] = {n:"Tynril-Rinde",t:96,d:"Diese Rinde sieht irgendwie sehr gekrümmt aus. So als hätte man sie mit einem Rindenschäler entfernt...",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8771] = {n:"Floribond-Rinde",t:96,d:"Diese Rinde sieht irgendwie sehr gekrümmt aus. So als hätte man sie mit einem Rindenschäler entfernt...",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8772] = {n:"Rindefix-Rinde",t:96,d:"Diese Rinde sieht irgendwie sehr gekrümmt aus. So als hätte man sie mit einem Rindenschäler entfernt...",ep:22,g:5,l:120,wd:true,fm:true,w:1,p:1};
I.u[8773] = {n:"Nerbige Rinde",t:96,d:"Diese Rinde sieht irgendwie sehr gekrümmt aus. So als hätte man sie mit einem Rindenschäler entfernt...",ep:22,g:3,l:100,wd:true,fm:true,w:1,p:1};
I.u[8774] = {n:"Rindent-Rinde",t:96,d:"Diese Rinde sieht irgendwie sehr gekrümmt aus. So als hätte man sie mit einem Rindenschäler entfernt...",ep:22,g:6,l:100,wd:true,fm:true,w:1,p:1};
I.u[8775] = {n:"Rinde des Rindenhundes",t:96,d:"Diese Rinde sieht irgendwie sehr gekrümmt aus. So als hätte man sie mit einem Rindenschäler entfernt...",ep:22,g:4,l:100,wd:true,fm:true,w:1,p:1};
I.u[8776] = {n:"Kokosschale des Schatten-Bitoufs",t:111,d:"Diese Kokosschale enthält keine Kokosmilch, sondern lediglich etwas Gehirnsaft, versetzt mit ein paar Neuronen.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8777] = {n:"Tynril-Blütenstempel",t:36,d:"Erst dieser Stempel drückt der Blüte des Tynril ihren Stempel auf!",ep:22,g:7,l:500,wd:true,fm:true,w:1,p:1};
I.u[8778] = {n:"Floribonds Staubgefäße",t:36,d:"Da sieh mal einer an... Floribond ist männlichen Geschlechts! Wer hätte das gedacht?!",ep:22,g:8,l:100,wd:true,fm:true,w:1,p:1};
I.u[8779] = {n:"Rindefix-Fruchtblatt",t:36,d:"Es sieht wie ein Kelch aus, ist jedoch ein Fruchtblatt. Schein und Sein sind eben zwei verschiedene Dinge...",ep:22,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[8780] = {n:"Nerbiges Kelchblatt",t:36,d:"Dieser Körperteil des Nerbig ist immergrün. Für den düsteren Dschungel einfach nur erstaunlich!",ep:22,g:10,l:80,wd:true,fm:true,w:1,p:1};
I.u[8781] = {n:"Rindent-Kelch",t:36,d:"Aus diesem Kelch werdet ihr leider nicht trinken können, denn er ist in der Mitte durchbohrt.",ep:22,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[8782] = {n:"Rindenhundschurz",t:36,d:"Der Rindenhundschurz schürzt den Rindenhund. Wo genau, bleibt eurer Vorstellungskraft überlassen.",ep:22,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[8783] = {n:"Schabirama",t:15,d:"Einer Schabirama-Entfernung, also einer Entfernung der Schatten-Bitoufs-Rachenmandeln unterziehen sich diese Wesen nur ungern – verständlicherweise. Zwar sind sie danach weitestgehend angstfrei, allerdings dabei oftmals auch nicht mehr am Leben.",ep:22,g:18,l:100,wd:true,fm:true,w:1,p:1};
I.u[8784] = {n:"Achillesferse des dunklen Astakrachler",t:15,d:"Die Achillesferse des dunklen Astakrachler bleibt euch zwar nicht verborgen, doch werdet ihr es schwer haben, sie mit eurem Pfeil zu durchbohren.",ep:22,g:19,l:100,wd:true,fm:true,w:1,p:1};
I.u[8785] = {n:"Same des dunklen Astakrachlers",t:58,d:"Mit viel Zeit, Geduld, Ausdauer, Wasser und Erde könnt ihr euch aus diesem Samen einen dunklen Astakrachler zu Trainingszwecken heranziehen. Mit hoher Wahrscheinlichkeit bedeutet es aber wesentlich weniger Aufwand, sich auf Otomaïs Insel zu begeben. Dort könnt ihr sie nämlich sofort und in Massen aushebeln.",ep:22,g:1,l:100,wd:true,fm:true,w:1,p:1};
I.u[8786] = {n:"Heenchen-Schopf",t:15,d:"Dieser dichte Haarschopf kann euch aus der Patsche helfen, sobald ihr in die Jahre kommt und euch der Haarausfall befällt. Es ist allerdings angeraten, ihn vor dem Tragen durch die 90° C-Wäsche zu ziehen. Am Besten mit Grasotan.",ep:22,g:20,l:80,wd:true,fm:true,w:1,p:1};
I.u[8787] = {n:"Heenchen-Kloake",t:15,d:"Nein, das ist keineswegs eklig! Das ist der Wille der Natur!",ep:22,g:21,l:80,wd:true,fm:true,w:1,p:1};
I.u[8788] = {n:"Bürzelfeder des Luft-Bitouf",t:15,d:"Die Bürzelfeder ist das ideale Accessoire für alle, die ihren Allerwertesten nicht der Wertung der anderen aussetzen wollen.",ep:22,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8789] = {n:"Kimbo-Socken",t:15,d:"Es sieht zwar nicht so aus, aber es ist wirklich wahr! Auch der Kimbo trägt Socken! Nur nicht an den Füßen, sondern fein zusammengerollt an strategisch wichtigen Stellen.",ep:22,g:23,l:500,wd:true,fm:true,w:1,p:1};
I.u[8790] = {n:"Muhpett-Füllung",t:15,d:"Bei den Muhpetts tat Mutter Natur mit ihren Reizen geizen. Daher haben sich die Muhpetts-Mädels einen einfachen, aber wirkungsvollen Griff in die Trickkiste einfallen lassen. Ideal auch, wenn gerade mal kein Kopfkissen zur Hand ist.",ep:22,g:24,l:110,wd:true,fm:true,w:1,p:1};
I.u[8791] = {n:"Muhpett-Pelz",t:55,d:"Dieser Pelz fässt sich ganz eigenartig an, ist jedoch ideal, um eure Keksvorräte zu kaschieren.",ep:22,g:16,l:110,wd:true,fm:true,w:1,p:1};
I.u[8792] = {n:"Kokosschale des Luft-Bitoufs",t:111,d:"Diese Kokosschale enthält keine Kokosmilch, sondern lediglich etwas Gehirnflüssigkeit, versetzt mit ein paar Neuronen.",ep:22,g:3,l:110,wd:true,fm:true,w:1,p:1};
I.u[8793] = {n:"Schnelm-Schale",t:111,d:"Rund und glänzend, wie sie ist wurde diese Schale sicherlich viele Jahre lang hindurch mit Speichel blankpoliert und geplegt. Jedem das Seine!",ep:22,g:4,l:110,wd:true,fm:true,w:1,p:1};
I.u[8795] = {n:"Kimbo-Toupet",t:54,d:"Das Kimbo-Toupet kaschiert den beginnenden Haarausfall des Kimbo. Glücklicherweise fällt es unter seinem Blattwedel nicht sonderlich auf.",ep:22,g:13,l:500,wd:true,fm:true,w:1,p:1};
I.u[8796] = {n:"Knoten des hellen Astakrachlers",t:38,d:"Wer zuletzt lacht, lacht am Besten, sprach der helle Astakrachler, bevor er sich diesen Ast lachte.",ep:22,g:2,l:120,wd:true,fm:true,w:1,p:1};
I.u[8797] = {n:"Stumpf des hellen Astakrachler",t:38,d:"Dieser stumpfe Stumpf aus dem Sumpf wirkt wie eine geschnitzte Strumpfspitze für gewitzte Sumpfschlümpfe. Drum kann es passieren, dass die gewitzten Sumpfschlümpfe die stumpfen Sumpfstümpfe stibizen, um gut sitzende Sumpfschlumpfstrumpfspitzen daraus zu schnitzen.",ep:22,g:3,l:120,wd:true,fm:true,w:1,p:1};
I.u[8798] = {n:"Bürzelfedern des Groß-Shilf",t:65,d:"An der Anzahl seiner Bürzelfedern lässt sich das Alter des Groß-Shilfs ablesen. Also: je dichter der Bürzel, desto älter der Groß-Shilf.",ep:22,g:1,l:500,wd:true,fm:true,w:1,p:1};
I.u[8799] = {n:"Pumbaa-Achselhaar",t:54,d:"Auch wenn sich Pumbaa regelmäßig rasiert - seine Achselhaare sehen immer struppig aus und verströmen einen üblen Geruch. Der Gestank rührt also nicht vom Schweiß her, sondern von den Haaren. Gut zu wissen...",ep:22,g:14,l:100,wd:true,fm:true,w:1,p:1};
I.u[8800] = {n:"Zothiger Pelz",t:55,d:"Wetterfest und weich schmiegt sich der zothige Pelz um diejenigen Körperteile, die eines ganz besonderen Schutzes bedürfen.",ep:22,g:17,l:110,wd:true,fm:true,w:1,p:1};
I.u[8801] = {n:"Morph-Fell",t:55,d:"Dieses Fell enthält mehr Löcher als ein Schweizer Käse. Andererseits kann es auch mehr Abfälle aufnehmen, um diese bei einer günstigen Gelegenheit wieder auszuspucken.",ep:5,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8802] = {n:"Schienbein des Zoth-Kriegers",t:47,d:"Wie alle übrigen Knochen des Zoth-Kriegers hat auch dieses Schienbein mehrfache Brüche erlitten. Doch anstatt zu zersplittern, ist es hierdurch nur noch stabiler geworden. Und also sprach das Schienbein:\" Was mich nicht umbringt, macht mich nur härter.\"",ep:22,g:20,l:120,wd:true,fm:true,w:1,p:1};
I.u[8803] = {n:"Kniescheibe des Zoth-Schülers",t:47,d:"Kraft der vielen Knietritte, die der Zoth-Schüler verteilt, ist seine Kniescheibe stark ausgebildet. Es wird nicht mehr lange dauern, und ihr könnt eure Gegner damit beim Bowling aus dem Spiel katapultieren.",ep:22,g:21,l:120,wd:true,fm:true,w:1,p:1};
I.u[8804] = {n:"Reißverschluss des Zoth-Meisters",t:15,d:"Ein Meisterstück, dieser Reißverschluss. Der einzige, der kein Schenkelfleisch einklemmt! Vom Reißverschlusstrauma betroffene Abenteurer werden ihn zu schätzen wissen.",ep:22,g:25,l:120,wd:true,fm:true,w:1,p:1};
I.u[8805] = {n:"Tuch des Zoth-Mädels",t:15,d:"Dieses Tuch dient dem Zoth-Mädel keineswegs als Accessoire für tränenreiche Abschiede – vielmehr ist es hervorragend geeignet, das Blut ihrer Gegner aufzuwischen.",ep:22,g:27,l:120,wd:true,fm:true,w:1,p:1};
I.u[8806] = {n:"Wappen des Zoth-Sergeanten",t:15,d:"Sobald der Zoth-Sergeant dieses Wappen betrachtet, wird er von Kindheitserinnerungen übermannt... Von Mutter bestickt, diente es ihm dereinst als Schlummerkissenbezug.",ep:22,g:757,l:120,wd:true,fm:true,w:1,p:1};
I.u[8807] = {n:"Morph-Säfte",t:15,d:"Man muss schon völlig betrunken sein, um Morph-Säfte mit einer anderen trinkbaren Flüssigkeit zu verwechseln. Der widerliche Geruch würde sogar Blinde davon abhalten, einen Schluck davon zu probieren.",ep:5,g:758,l:80,wd:true,fm:true,w:1,p:1};
I.u[8808] = {n:"King Morphs Pelz",t:55,d:"Dieser Pelz hat mehr Löcher als ein Schweizer Käse, riecht aber trotzdem genauso.",ep:22,g:19,l:200,wd:true,fm:true,w:1,p:1};
I.u[8809] = {n:"King Morphs Liebestöter",t:15,d:"Auf Geheiß von King Morph wurden alle seine Untertanen angehalten, ihre Unterhosen verkehrt herum zu tragen. Kein Wunder, dass hiernach die Bevölkerungspyramide drastisch schrumpfte.",ep:22,g:759,l:200,wd:true,fm:true,w:1,p:1};
I.u[8810] = {n:"Auswurf des Torf Morphs",t:15,d:"In getrocknetem Zustand besitzt der Auswurf des Torf Morphs eine erstaunliche Absorptionsfähigkeit. Daher ist er ideal nach Blutbädern jeder Art, einschließlich derjenigen, mit denen sich allmonatlich die Bwork-Mütter abfinden müssen.",ep:22,g:760,l:80,wd:true,fm:true,w:1,p:1};
I.u[8811] = {n:"Doppelkinn des Schlammmorphs",t:15,d:"Von seinen Schlammbädern erhoffte sich der Schlammmorphs einen stetigen Gewichtsverlust. Stattdessen wuchs ihm leider dieses Doppelkinn. Tjaja, die Wellness-Industrie...",ep:22,g:761,l:80,wd:true,fm:true,w:1,p:1};
I.u[8812] = {n:"Tinte des Riesenkrakamors",t:15,d:"Diese hochviskose und abdeckende Flüssigkeit kann zum Schreiben eingesetzt werden oder auch als Wandbemalung für psychisch angeschlagene Personen.",ep:22,g:762,l:999,wd:true,fm:true,w:1,p:1};
I.u[8813] = {n:"Saugnapf des Riesenkrakamors",t:15,d:"Wenn man die Größe dieses Saugnapfes in Betracht zieht, muss seine Saugkraft wirklich enorm sein. Jedenfalls ist das Geräusch beim Abziehen wahrhaft ohrenbetäubend.",ep:22,g:763,l:999,wd:true,fm:true,w:1,p:1};
I.u[8814] = {n:"Geldbörse mit 5.000 Kamas",t:100,d:"Diese Geldbörse ist sehr schwer. Darin muss sich ja ein wahres Vermögen befinden!",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:50000};
I.u[8815] = {n:"Geldbörse mit 1.000 Kamas",t:100,d:"Diese Geldbörse ist sehr schwer. Darin muss sich ja ein wahres Vermögen befinden!",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:10000};
I.u[8816] = {n:"Bloah-Schwert-Geschenk",t:89,d:"Beim Schütteln dieses Geschenkpaketes könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8817] = {n:"Flieghut von Sichthofen-Geschenk",t:89,d:"Beim Schütteln dieses Geschenkpaketes könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8818] = {n:"King Morphs Mächtiger Umhang",t:17,d:"Dieser Umhang wurde aus echtem hochwertigem Material aus der King Morph-Factory gefertigt und bietet Mikroporen für die Austreibung von unter Stress auftretenden Körperausdünstungen, z.B. bei kriegerischen Auseinandersetzungen in Sumpfgebieten. Dabei gelangt die Feuchtigkeit nach außen, und die Wärme bleibt gespeichert, sodass ihr jederzeit eine angenehme Trockenheit verspürt. Schade nur, dass der Schimmelgeruch hartnäckig bestehen bleibt.",ep:22,g:143,l:152,wd:true,fm:true,w:10,s:78,p:46520};
I.u[8819] = {n:"Kleinmorph-Umhang",t:17,d:"Dieser Umhang ist weniger mächtig als der von King Morph, jedoch genauso atmungsaktiv wie selbiger, falls ihr unter Stress ins Schwitzen geraten solltet. Einmal ausprobiert, werdet ihr den typischen Geruch dieses Kleidungsstückes gewiss nicht mehr missen wollen.",ep:22,g:144,l:97,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8820] = {n:"Maske des Zoth-Sergeanten",t:16,d:"Mit dieser Maske ist der Zoth-Sergeant vor allen Feinden sicher, denn wer nichts sieht, der wird auch nicht gesehen.",ep:22,g:191,l:133,wd:true,fm:true,w:10,p:43340};
I.u[8821] = {n:"Hut des Zoth-Schülers",t:16,d:"Der Hut des Zoth-Schülers sieht von Weitem wie ein Lampenschirm mit zwei Augenschlitzen aus. Von Nahem auch.",ep:22,g:192,l:128,wd:true,fm:true,w:10,p:41688};
I.u[8822] = {n:"Maskenhelm des hellen Astakrachler",t:16,d:"Wer ein richtiger Holzkopf ist, kann dies hinter diesem Maskenhelm auf elegante Art und Weise verbergen.",ep:22,g:193,l:134,wd:true,fm:true,w:10,s:79,p:42200};
I.u[8823] = {n:"Maskenhelm des dunklen Astakrachler",t:16,d:"Wer ein richtiger Holzkopf ist, kann dies hinter diesem Maskenhelm auf elegante Art und Weise verbergen. Zudem verdeutlicht die dunkle Note des Materials, dass ihr schlechter Laune seid.",ep:22,g:194,l:95,wd:true,fm:true,w:10,s:80,p:23150};
I.u[8824] = {n:"Schnhelm",t:16,d:"Mit diesem Stück auf eurem Kopf wird euch jeder für einen Schnelm halten. Was noch lange kein Grund ist, aller Nase lang herumzusabbern, den immerhin gehört ihr noch zu den Zweibeinern! Doch einen Vorteil hat der Schnhelm: Er schützt euch vor harten Schlägen.",ep:22,g:195,l:123,wd:true,fm:true,w:10,s:96,p:43250};
I.u[8825] = {n:"Mächtige korallatorige Donnerkralle",t:7,d:"Diese Donnerkralle stammt nicht umsonst vom Mächtigen Korallator. Wuchtig, schwer und schlagkräftig straft sie eure Gegner, doch leicht und gefällig liegt sie euch in der Hand. Wirklich mächtige Magie!",ep:22,g:63,l:125,wd:true,fm:true,w:8,an:15,tw:true,e:[10,5,1,1,100,50,false,false],c:"CA>130&CC>130&CW>130",p:40150};
I.u[8826] = {n:"Hammer des Zoth-Mädels",t:7,d:"Selbst Winzigkeit ist kein Grund, sich vor Stärke zu drücken, sagte sich das Zoth-Mädel und fertigte sich ihren Riesenhammer, den sie sich wahlweise an Arm- oder Fußgelenke hängt, um später ihre Gegner aushebeln zu können.",ep:22,g:64,l:132,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,45,45,false,false],c:"CA>250&CW>150",s:93,p:43140};
I.u[8827] = {n:"Axt des Zoth-Kriegers",t:19,d:"Der Zoth-Krieger konnte sich mit einer einzigen Axt nicht abfinden – oder besser: zurechtfinden. Er bekam es einfach nicht in den Griff, mit seinem rechten Arm die linke Flanke seines Gegners zu treffen. Eine rein anatomische Frage oder einfach nur Unbeholfenheit? Die Meinungen hierüber sind geteilt. Fakt ist allerdings, dass er sich beim Holzschlagen wider Erwarten sehr geschickt anstellt.",ep:22,g:47,l:139,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,60,50,false,false],c:"CW>250&CV>500",s:95,p:44350};
I.u[8828] = {n:"Heenchen-Perücke",t:16,d:"Das Heenchen ist ein ungeschicktes Geflügel mit einer Intelligenz vergleichbar der eines Tofus und soviel Vitalität, wie eine dürre Henne mit Vogelgrippe. Kurz: es hat zum Überleben schlechte Karten. Dennoch scheinen einige es auf sein Flügelkleid abgesehen zu haben, welches aussieht, als habe eine teutonische Hausfrau einem Wischmop eine Rastafrisur gemacht. Seltsam sind die Leute von heute.",ep:0,g:196,l:1,wd:false,fm:true,w:1,p:1};
I.u[8829] = {n:"Bartarossa-Hut",t:16,d:"Dieser Hut bedeckte zwar den Kopf und das spärliche Barthaar des Bartarossa, ist jedoch für größere Köpfe gänzlich ungeeignet.",ep:22,g:197,l:79,wd:true,fm:true,w:1,p:16455};
I.u[8832] = {n:"Schnelmschleim",t:15,d:"Der Schleim eines Schnelm kann niemals das Federkleid des Bitoufs beflecken. Aber dafür euch mit Haut und Haaren am Boden festkleben...",ep:22,g:6,l:110,wd:true,fm:true,w:1,p:1};
I.u[8833] = {n:"Korallatorige Donnerkralle",t:7,d:"Die korallatorige Donnerkralle besteht aus Korallatorengestein. Entgegen des ersten Eindrucks des Betrachters wurde dieser Gegenstand ursprünglich NICHT als Iopschädelzermalmer konzipiert! Archäologische Studien belegen, dass er den Korallatoren im längst vergangenen Zeitalter der Schwerhörigkeit als Türöffner diente.",ep:22,g:65,l:85,wd:true,fm:true,w:10,an:15,tw:true,e:[10,4,1,1,50,50,false,false],c:"CC>100&CA>100&CV>150",p:18650};
I.u[8834] = {n:"Ast des dunklen Astakrachler",t:3,d:"Mit diesem Ast pflegte der dunkle Astakrachler die für ihn schwer zugänglichen Körperteile zu kraulen. Da der Ast nicht nachbehandelt wurde, könnt ihr aus seiner Farbe schließen, welches Körperteil dabei wohl am meisten strapaziert wurde.",ep:22,g:64,l:97,wd:true,fm:true,w:1,an:11,tw:true,e:[5,5,2,4,40,40,false,true],c:"CS>100&CI>100",s:80,p:25000};
I.u[8835] = {n:"Ast des hellen Astakrachler",t:3,d:"Mit diesem Ast pflegte der helle Astakrachler die für ihn schwer zugänglichen Körperteile zu kraulen. Da der Ast nicht nachbehandelt wurde, könnt ihr aus seinem Geruch schließen, welches Körperteil dabei wohl am meisten strapaziert wurde.",ep:22,g:65,l:132,wd:true,fm:true,w:5,an:11,tw:true,e:[4,5,2,5,10,50,false,true],c:"CA>200&CS>200",s:79,p:43225};
I.u[8836] = {n:"Rindefix-Stängel",t:4,d:"Die Rindefixe benutzen ihre Stängel, um sich die Ohren zu reinigen – die Stabschnitzer, um Stäbe zu fertigen. Wodurch einmal mehr bewiesen ist, dass sich über Geschmack nicht streiten lässt.",ep:22,g:75,l:119,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,45,45,false,false],c:"CA>200&CI>200",p:36025};
I.u[8837] = {n:"Stock des Zoth-Meisters",t:4,d:"Mit diesem Stock schlägt der Zoth-Meister alles und jeden - und zwar zu Brei. Niemand kann ihn mehr in Angst und Schrecken versetzen. Das ist auch nicht weiter verwunderlich, denn mit seinem Helm auf dem Kopf sieht er sowieso keinen. Wenngleich auch diese Technik im Kampfe unübertroffen sein mag, so hat sie doch ihre Nachteile. Beim Essen beispielsweise.",ep:22,g:76,l:158,wd:true,fm:true,w:10,an:12,e:[15,5,1,1,40,50,false,false],c:"CI>180&CS>100",s:94,p:47300};
I.u[8838] = {n:"Tynril-Rhizom",t:4,d:"Ein kleines Rhizom genügt, und der Tynril pflanzt sich bis ins Unendliche fort. Unkraut vergeht eben nicht... Inspiriert durch dieses Phänomen haben sich ein paar Schnitzer daran gemacht, die Natur nachzuahmen, um diesen Rhizom-Knüttel hier möglichst kamagünstig und in Massen unter selbige zu bringen. Ein einziger Flopp...",ep:22,g:77,l:186,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,40,50,false,false],c:"CI>250&CS>200",p:51248};
I.u[8839] = {n:"Thomas\' kanniballische Wuddu-Maske",t:16,d:"Trotz all ihrer Kampfeslust sind die kanniballischen Thomasse nicht in der Lage, ihr Ziel zu treffen. Um ihren Gegnern dennoch zu zeigen, dass sie ihnen nicht grün sind, haben sie sich diese Maske geschaffen.",ep:22,g:199,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8840] = {n:"Jaffs kaniballische Wuddu-Maske",t:16,d:"Die kanniballischen Jaffs tragen ausschließlich blaue Masken, weil sie regelmäßig vom Blues überfallen werden. Tja... Liebeskummer? Fernweh? Zahnschmerzen? Wer weiß... Allerdings wäre es begrüßenswert, wenn sie es beim Maskentragen beließen und ihre Klagegesänge einstellten.",ep:22,g:200,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8841] = {n:"Sarbaks kaniballische Wuddu-Maske",t:16,d:"Weil sie ständig ihr Ziel verfehlen, sind die kanniballischen Sarbaks regelmäßig gelb vor Neid. Damit sie das auch nicht vergessen, haben sie sich diese Maske geschaffen.",ep:22,g:201,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8842] = {n:"Archibalds kaniballische Wuddu-Maske",t:16,d:"Im ruhigen Zustand sind die kanniballischer Archibalds schlicht und einfach unfähig, sich auf ihr Ziel zu konzentrieren. Damit sie in Gefahrensituationen so richtig rot sehen können, haben sie sich diese Maske geschaffen.",ep:22,g:202,l:158,wd:true,fm:true,w:10,p:49000};
I.u[8843] = {n:"Hut des Crocodyll Dandy",t:16,d:"Bei diesem Stück stellt sich die Frage, ob Trendsetter oder einfach nur Modemuffel... Beim Crocodyll weiß man dies nicht so genau... Ihr tut allerdings besser daran, ihn nicht zu verspotten, denn er reagiert ausgesprochen empfindlich auf eure Häme.",ep:22,g:203,l:180,wd:true,fm:true,w:10,p:50475};
I.u[8844] = {n:"King Morphs Mächtige Haube",t:16,d:"Ebenso wie der gleichnamige Umhang wurde auch diese Haube aus echtem hochwertigen Material aus der King Morph-Factory gefertigt und bietet Mikroporen für die Austreibung von unter Stress auftretenden Hauptausdünstungen, damit ihr immer schön einen kühlen Kopf bewahrt.",ep:22,g:204,l:168,wd:true,fm:true,w:10,s:78,p:48800};
I.u[8845] = {n:"Morph-Haube",t:16,d:"Die Morph-Haube sorgt für eine ausgesprochen gute, wenn nicht gar optimale Feuchtigkeitsabfuhr. Tatsächlich ist es für selbige vollkommen egal, ob man die Haube trägt oder nicht.",ep:22,g:205,l:104,wd:true,fm:true,w:10,s:77,p:27650};
I.u[8846] = {n:"Hut des Zoth-Mädels",t:16,d:"Sobald das Zoth-Mädel ihren Hut aufsetzt, beginnt sie alles doppelt zu sehen. Kein Wunder, dass sie stottert, die Arme.",ep:22,g:206,l:128,wd:true,fm:true,w:10,s:93,p:41950};
I.u[8847] = {n:"Helm des Zoth-Kriegers",t:16,d:"Wie alle übrigen Ausstattungsstücke der Zoths bietet auch dieser Helm gleich mehrere Vorteile auf ein Mal: er dient als Sonnenschutz, schützt euer Haupt vor Schlägen, und bewahrt euch davor, der Gefahren um euch herum allzu sehr gewahr zu werden. Einfach unabdinglich für alle Krieger.",ep:22,g:207,l:134,wd:true,fm:true,w:100,s:95,p:44000};
I.u[8848] = {n:"Helm des Zoth-Meisters",t:16,d:"Dieser Helm ist ideal für die Ausübung der Blindekuh-Kampftechnik, da er das Blickfeld seines Trägers ganz ungemein begrenzt. Das Prinzip dieser Technik besteht darin, ganz einfach nur kräftig um sich zu schlagen. Irgendetwas erwischt man dabei immer.",ep:22,g:208,l:156,wd:true,fm:true,w:10,s:94,p:46900};
I.u[8849] = {n:"Rindent-Wurzel",t:4,d:"Dieses Stöckchen steht vor allem bei den Rindent-Damen hoch im Kurs, denn es beschert ihnen ein paar zusätzliche Löckchen. Kokett, kokett!",ep:22,g:78,l:138,wd:true,fm:true,w:10,an:12,e:[7,4,1,1,40,50,false,false],c:"CV>500",p:44200};
I.u[8850] = {n:"Floribond-Wurzel",t:4,d:"Wer abergläubisch ist und gerne 3 Mal auf Holz klopft, sollte sich mit der Floribond-Wurzel anfreunden. Ungläubige dürfen allerdings auch gerne gleich das Übel mit der Wurzel ausreißen. Sägt aber dabei nicht den Ast ab, auf dem ihr sitzt, denn andernfalls könntet ihr auf dem Holzweg landen!",ep:22,g:79,l:144,wd:true,fm:true,w:10,an:12,tw:true,e:[10,2,1,1,40,50,false,false],p:45125};
I.u[8851] = {n:"Abgenutzte Schatzkarte",t:24,d:"Event Shika",ep:7,g:6,l:1,wd:false,fm:true,w:0,c:"SI=1001",p:1};
I.u[8854] = {n:"Crack Sparrows abgetragener Hut",t:16,d:"Event Shika",ep:7,g:5,l:1,wd:false,fm:true,w:13,c:"SI=1001",p:1};
I.u[8855] = {n:"S\'Teuer-Schild",t:82,d:"Dem S\'Teuer-Schild wird nachgesagt, dass er der effektiven Vorsorge diene. Über Maßnahmen der Nachsorge im Versagensfalle ist leider nichts bekannt... Wie dem auch sei... Zu Risiken und Nebenwirkungen fragt besser euren Eniripsa. Und zu Studien über die Laufzeit der tatsächlichen Schutzwirkung wendet euch an den Xelor eures Vertrauens. Über die Anschaffungskosten wird euch gerne ein Enutrof beraten.",ep:16,g:35,l:10,wd:true,fm:true,w:25,c:"PK>790000",p:1};
I.u[8856] = {n:"Yastoinpatl",t:10,d:"Entgegen aller Vermutungen ist der Yastoinpatl nicht von aztekischer Herkunft, sondern entstammt dem Groß-Shilf. Sein Stoff lässt auf dessen heimliche Leidenschaft schließen.",ep:22,g:115,l:182,wd:true,fm:true,w:10,p:51020};
I.u[8858] = {n:"Schmoinkser",t:11,d:"Die Schmoinkser schmoinksen bei jedem Schritt. Wer sich das antun möchte, ist selbst dran schuld.",ep:22,g:112,l:100,wd:true,fm:true,w:10,s:77,p:25775};
I.u[8859] = {n:"King Morphs Siegelring",t:9,d:"Dieser Ring weist seinen Träger als unangefochtenen Herrscher des bodenlosen Moores von Otomaïs Insel aus. Es fällt wirklich schwer, sich eine romantischere Gegend vorzustellen.",ep:22,g:138,l:158,wd:true,fm:true,w:10,s:78,p:44581};
I.u[8860] = {n:"Koralliger Ehering",t:9,d:"Dieser Ring wurde auf brutale Weise vom Finger eines auf noch brutalere Weise massakrierten Korallatoren entfernt, während dieser daheim von seiner Mutter zum Abendessen erwartet wurde. Tja... Auch Korallatoren haben ein Herz, und dies ist nicht aus Stein!",ep:22,g:139,l:60,wd:true,fm:true,w:60,p:9500};
I.u[8861] = {n:"Kimbo-Treter",t:11,d:"Nur ein Kimbo wird sich in diesen Tretern so richtig wohl fühlen. Alle anderen werden wahrscheinlich eher abtreten.",ep:22,g:113,l:195,wd:true,fm:true,w:10,p:57325};
I.u[8862] = {n:"Ykaros\' Gurt",t:10,d:"Nachdem Ykaros auf Otomaïs Insel gestrandet ward, fertigte er sich diesen Gurt, welchen er mit zwei geretteten Bitouf-Flügeln versah, in der Annahme die Bitoufs könnten fliegen. So sprang er dann mehrmals vom Stammbaum, aber die Schwerkraft war jedes Mal stärker.",ep:22,g:128,l:148,wd:true,fm:true,w:20,p:78780};
I.u[8863] = {n:"Zothulett",t:1,d:"Dieses Amulett besteht eigentlich nur aus einem ganz gewöhnlichen Stück Holz mit ein paar zerrissenen Stofffetzen, aber dessen ungeachtet glauben die Zoths weiterhin ungebrochen an seine Macht. Arme Teufel...",ep:22,g:124,l:162,wd:true,fm:true,w:10,p:55420};
I.u[8864] = {n:"Schnelm-Bogen",t:2,d:"Die Sehne dieses Bogens besteht aus mehr oder minder getrocknetem Schnelm-Schleim und ist hochelastisch. Klebrig und zäh wie sie ist, erinnert sie entfernt an etwas Unangenehmes - nur woran?",ep:22,g:58,l:122,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,5,10,30,50,false,true],c:"CC>250",s:96,p:43125};
I.u[8865] = {n:"Schnelm-Ring",t:9,d:"Dieses aus einer Schnelm-Schale gefertigte Schmuckstück ist verwitterungsfest und verwindungssteif. Es könnte allerdings sein, dass es im dauerhaften Kontakt mit eurem Finger mit der Zeit ein paar zusätzliche Kammern bildet. Daher solltet ihr es zur Nacht unbedingt ablegen.",ep:22,g:140,l:120,wd:true,fm:true,w:10,s:96,p:28500};
I.u[8866] = {n:"Mächtiger schillernder Umhang",t:17,d:"Dieser aus zothigem Pelz gefertigte Umhang besitzt gar mächtige magische Eigenschaften, deren Ursprung noch im Unklaren liegt.",ep:22,g:145,l:110,wd:true,fm:true,w:10,p:45000};
I.u[8867] = {n:"Muhpett-Umhang",t:17,d:"Vorsicht! Wer diesen Umhang anlegt, bekommt Heißhunger auf Kekse.",ep:22,g:146,l:61,wd:true,fm:true,w:12,p:9675};
I.u[8868] = {n:"Schnabelaxt",t:19,d:"Der Heenchenschnabel am Keil dieser Axt dient lediglich der Verzierung und manchmal auch der Behinderung des sie führenden Kämpfers. Glücklicherweise gehört diese Waffe dennoch zu den effektivsten ihrer Art.",ep:22,g:48,l:137,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,120,50,false,false],p:15400};
I.u[8869] = {n:"Astakrachlerholz-Bottinen",t:11,d:"Auf Grund ihres beträchtlichen Gewichtes sollten diese Bottinen ursprünglich als Waffe eingestuft werden. Allerdings war ihr Schnitzer dagegen und übergab sie einem merkwürdigen, der menschlichen Sprache mächtigen Kater, der mit ihnen durch die außeramaknischen Lande zog. Den Rest der Geschichte könnt ihr euch wahrscheinlich denken.",ep:22,g:114,l:136,wd:true,fm:true,w:50,s:79,p:43850};
I.u[8870] = {n:"Gurt aus dunklem Astakrachlerholz",t:10,d:"Der Träger dieses Gurtes aus hartem, dunklem Astakrachlerholz hat zwar nicht allzu viel Bewegungsfreiheit, ist allerdings bestens geschützt.",ep:22,g:129,l:92,wd:true,fm:true,w:10,s:80,p:21975};
I.u[8871] = {n:"Gurt aus hellem Astakrachlerholz",t:10,d:"Der Träger dieses Gurtes aus weichem, hellem Astakrachlerholz ist zwar nicht besonders gut geschützt, genießt allerdings ausreichend Bewegungsfreiheit.",ep:22,g:130,l:128,wd:true,fm:true,w:10,s:79,p:41755};
I.u[8872] = {n:"Eindrindling",t:9,d:"Der Eindrindling ist nicht besonders attraktiv, lässt sich aber gegebenenfalls als Türöffner verwenden.",ep:16,g:141,l:46,wd:true,fm:true,w:9,p:3630};
I.u[8873] = {n:"Krusto-Riemen",t:10,d:"Endlich ein Grund, sich in die Fluten zu stürzen!",ep:22,g:131,l:39,wd:true,fm:true,w:1,p:4225};
I.u[8874] = {n:"Morphmamph",t:1,d:"Das Morphmamph hat die nervige Angewohnheit, von eurem Tellerchen mitzuessen. Lasst es also nicht allzu tief hängen!",ep:22,g:125,l:105,wd:true,fm:true,w:10,s:77,p:28452};
I.u[8876] = {n:"Tint O\'Mant",t:17,d:"Dieser Umhang scheint aus schwarzer Tinte zu bestehen. Allerdings tropft er nicht und verhält sich aus sonst genau wie ein Stofftuch. Nur, dass er ab und zu ein paar Flecken hinterlässt.",ep:22,g:147,l:191,wd:true,fm:true,w:15,p:52000};
I.u[8877] = {n:"Krakamoring",t:9,d:"Krallst du ihn dir, so krallt er dich! Wer ihn einmal aufsetzt, wird ihn nicht wieder los...",ep:22,g:142,l:199,wd:true,fm:true,w:10,s:97,p:49000};
I.u[8878] = {n:"Kido-Klopfer",t:7,d:"Er ist weder praxistauglich, noch besonders schön, noch ergonomisch. Auch ist er weder mächtig, noch wuchtig, noch wohlgeformt. Er ist zerbrechlich und glänzt zu stark. Aber... er zeigt Mut zur Farbe!",ep:22,g:66,l:79,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,50,50,false,false],p:16100};
I.u[8879] = {n:"Ring des geschliffenen Krachlklotzes",t:9,d:"Dieser Ring ist leider nur außen geschliffen... Daher ist es nicht besonders empfehlenswert, ihn am Finger zu drehen, es sei denn, ihr gehört zu den Sacrieurs.",ep:16,g:143,l:66,wd:true,fm:true,w:1,p:4755};
I.u[8880] = {n:"Mufafahmulett",t:1,d:"Aufregend schön ist es, dieses Amulett. Dazu noch sorgen die Mufafah-Barthaare für den richtigen Kitzel, wenn ihr dem Buben eures Herzens begegnet.",ep:22,g:126,l:84,wd:true,fm:true,w:10,p:18225};
I.u[8881] = {n:"Organa-Ring",t:9,d:"Starke Mode ist etwas für Selbstbewusste, dachte sich Leia, bevor sie sich diesen Ring ansteckte, ihre Haarpracht zu Schnecken zusammenband und in den galaktischen Bürgerkrieg startete.",ep:22,g:144,l:31,wd:true,fm:true,w:12,p:2625};
I.u[8883] = {n:"Gildenheimtrank",t:12,d:"Diese Trank ermöglicht es euch, euch direkt in das Haus eurer Gilde zu teleportieren.",ep:5,g:152,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[8885] = {n:"Getigerter Maunzmiez - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für alle Male fallen zu lassen.",ep:3,g:20,l:1,wd:true,fm:true,w:1,p:1};
I.u[8886] = {n:"Getigerte Maunzmiez - Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8887] = {n:"Tierheimzertifikat: Getigerte Maunzmiez",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über die Getigerte Maunzmiez, die ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8888] = {n:"Tierheimzertifikat: Wuseliges Eichhörnchen",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über das Wuselige Eichhörnchen, das ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
