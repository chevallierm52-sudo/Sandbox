I.u[8972] = {n:"Schlüssel zum Shilf-Engpass",t:84,d:"Dieser seltsame Schlüssel erlaubt es euch, mit heiler Haut durch den Shilf-Engpass zu gelangen.",ep:22,g:243,l:1,wd:true,fm:true,w:1,p:1};
