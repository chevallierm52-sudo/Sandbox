I.u[8956] = {n:"Ecaflips Tatze",t:6,d:"Dieses Schwert beweist, dass selbst, wenn man in höchster schwelgt, durchaus noch kleine Unglücke geschehen können.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8957] = {n:"Ecaflips Tatze",t:6,d:"Dieses Schwert beweist, dass selbst, wenn man in höchster schwelgt, durchaus noch kleine Unglücke geschehen können.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8958] = {n:"Ecaflips Tatze",t:6,d:"Der Gott Ecaflip hat euch seine Tatze gereicht, doch konntet ihr nur eine einzige Klaue nehmen... und die ist nicht einmal so scharf, wie es scheint. Vielleicht war es ja gar nicht der Gott Ecaflip?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8959] = {n:"Ecaflips Tatze",t:6,d:"Der Gott Ecaflip hat euch seine Tatze gereicht, doch konntet ihr nur eine einzige Klaue nehmen... und die ist nicht einmal so scharf, wie es scheint. Vielleicht war es ja gar nicht der Gott Ecaflip?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8960] = {n:"Ecaflips Tatze",t:6,d:"Der Gott Ecaflip hat euch seine Tatze gereicht, doch konntet ihr nur eine einzige Klaue nehmen... und die ist nicht einmal so scharf, wie es scheint. Vielleicht war es ja gar nicht der Gott Ecaflip?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8961] = {n:"Ecaflips Tatze",t:6,d:"Abergläubige behaupten, Hasenpfoten brächten Glück. Mit diesem legendären Schwert werdet ihr der neue Star aller Abergläubigen. Die Klinge ist scharf und erinnert ein wenig an ein anderes Schwert, das ihr kennt. Welches war das noch einmal?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8962] = {n:"Ecaflips Tatze",t:6,d:"Abergläubige behaupten, Hasenpfoten brächten Glück. Mit diesem legendären Schwert werdet ihr der neue Star aller Abergläubigen. Die Klinge ist scharf und erinnert ein wenig an ein anderes Schwert, das ihr kennt. Welches war das noch einmal?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8963] = {n:"Ecaflips Tatze",t:6,d:"Abergläubige behaupten, Hasenpfoten brächten Glück. Mit diesem legendären Schwert werdet ihr der neue Star aller Abergläubigen. Die Klinge ist scharf und erinnert ein wenig an ein anderes Schwert, das ihr kennt. Welches war das noch einmal?",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8964] = {n:"Ecaflips Tatze",t:6,d:"\"Das Glück lacht dem Mutigen zu!\" flüstern sich die Anhänger Ecaflips zu. Mit dieser Waffe werdet ihr stets mit guten Karten darstehen, denn sie ist scharf wie ein Pik As.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8965] = {n:"Ecaflips Tatze",t:6,d:"\"Das Glück lacht dem Mutigen zu!\" flüstern sich die Anhänger Ecaflips zu. Mit dieser Waffe werdet ihr stets mit guten Karten darstehen, denn sie ist scharf wie ein Pik As.",ep:1,g:82,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8966] = {n:"Perfekte Ecaflips Tatze",t:6,d:"Dieses Schwert ist der Inbegriff des Glücks des Gottes Ecaflip. In euren Händen haltet ihr nun das vollkommenste Exemplar von Ecaflips Tatze, was für euer unverschämtes Glück spricht.(und daher für euer ewiges Junggesellentum)",ep:1,g:81,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[8969] = {n:"Geschenk: Ecaflips Klaue",t:89,d:"Dieses Geschenkpaket strahl Macht und Erhabenheit aus. Vielleicht solltet ihr euch das mit dem Öffnen doch noch einmal überlegen...",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
