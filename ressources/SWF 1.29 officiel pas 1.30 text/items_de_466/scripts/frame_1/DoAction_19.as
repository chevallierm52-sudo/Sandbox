I.u[8985] = {n:"Ühp für Dragooner und Minifux",t:116,d:"Durch diese mächtige Pille könnt ihr die Fähigkeiten eures Vertrauten permanent erhöhen. Doch Vorsicht: gebt ihm nur eine einzige Dosis, sonst könnte das Mittel unerwünschte Auswirkungen ergeben.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"PO=7519|PO=8155",u:true,p:1};
I.u[8986] = {n:"Ühp für Fresskugel und Phantöffelchen",t:116,d:"Durch diese mächtige Pille könnt ihr die Fähigkeiten eures Vertrauten permanent erhöhen. Doch Vorsicht: gebt ihm nur eine einzige Dosis, sonst könnte das Mittel unerwünschte Auswirkungen ergeben.",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"PO=8151|PO=7518",u:true,p:1};
I.u[8987] = {n:"Ühp für El Scarador und Croum",t:116,d:"Durch diese mächtige Pille könnt ihr die Fähigkeiten eures Vertrauten permanent erhöhen. Doch Vorsicht: gebt ihm nur eine einzige Dosis, sonst könnte das Mittel unerwünschte Auswirkungen ergeben.",ep:1,g:10,l:1,wd:true,fm:true,w:1,c:"PO=8154|PO=7520",u:true,p:1};
I.u[8988] = {n:"Ühp für Astaknidasta und Minimino",t:116,d:"Durch diese mächtige Pille könnt ihr die Fähigkeiten eures Vertrauten permanent erhöhen. Doch Vorsicht: gebt ihm nur eine einzige Dosis, sonst könnte das Mittel unerwünschte Auswirkungen ergeben.",ep:1,g:11,l:1,wd:true,fm:true,w:1,c:"PO=8153|PO=7522",u:true,p:1};
I.u[8989] = {n:"Helm des Luft-Bitouf",t:16,d:"Mit diesem Helm auf dem Kopf werdet ihr ziemlich leicht abheben. Aber Vorsicht bei der Landung.",ep:22,g:209,l:154,wd:true,fm:true,w:10,p:44350};
I.u[8990] = {n:"Eroberer-Prisma",t:112,d:"Dieses magische Prisma aus Stein taucht die gesamte Umgebung in strahlendes Licht und gestattet es euch, euer Territorium zu markieren, ohne einen Tropfen Urin zu verschwenden. Uneingeschränkt empfehlenswert für alle, die sich zum Eroberer berufen fühlen.  \nHinweis: Ein Eroberer-Prisma kann nur aufstellen, wer sich in einem prismenfreien Gebiet befindet, den PvP-Modus aktiviert hat und seinen Grad anzeigt. Das Gebiet, in dem das Prisma aufgestellt werden soll, muss an ein Gebiet eurer Gesinnung angrenzen.",ep:4,g:1,l:1,wd:true,fm:true,w:10,c:"PL>9&PP>2",u:true,p:1};
I.u[8991] = {n:"Traum A-Ring",t:9,d:"Er saugt sich an eurem Finger fest und verursacht Schüttelfrost. Wer dies erträgt, kann sich nicht nur großen Leidens, sondern auch großer Macht erfreuen.",ep:22,g:145,l:189,wd:true,fm:true,w:10,s:97,p:55000};
I.u[8992] = {n:"Verfluchte Axt des Blutkriegers",t:22,d:"Diese Axt mäht alle eure Feinde nieder und wird daher den Neid eurer Mitgefährten erregen. Man kann eben nicht alles haben...",ep:22,g:3,l:200,wd:true,fm:true,w:10,an:17,tw:true,e:[10,5,1,1,100,50,false,false],p:58000};
I.u[8993] = {n:"Verfluchtes Schwert des Blutkriegers",t:6,d:"Die mit diesem Schwert angerichteten Metzeleien sind in die Annalen des amaknischen Kontinents eingegangen – wohl nicht zuletzt deswegen, weil diese Waffe mit einem unberechenbaren Fluch belegt ist. Es ist an euch, sie zu entfluchen.",ep:20,g:83,l:200,wd:true,fm:true,w:10,an:14,tw:true,e:[10,5,1,1,100,2,false,false],p:58000};
I.u[8994] = {n:"Korallatorengewirk",t:55,d:"Das Korallatorengewirk verbrachte viele Jahre lang unter Wasser. Dementsprechend ist es von hübschen kleinen Korallenpartikeln umlagert. Schade nur, dass es so steif ist, sonst gäbe es ein feines Taschentüchlein ab.",ep:22,g:728,l:150,wd:true,fm:true,w:1,p:100};
I.u[8995] = {n:"Fürchterliches Tuch von Gurrlo, dem Fürchterlichen",t:55,d:"Dieses handgewebte Tuch diente dem kleinen Gurrlo einst als Windel. Es ist nicht aus dem allerfeinsten Material, und daher nimmt es nicht Wunder, dass es als fürchterlich bekannt ist. Von seinem Geruch einmal ganz zu schweigen...",ep:22,g:729,l:150,wd:true,fm:true,w:1,p:100};
I.u[8996] = {n:"Haut des Groß-Shilfs",t:59,d:"Diese Haut ist noch sanfter als die des Hinterteils eines Killibri-Weibchens und gibt ein ausgezeichnetes Beinkleid für euch ab.",ep:22,g:48,l:250,wd:true,fm:true,w:1,p:100};
I.u[8997] = {n:"Verletzte Tynril-Haut",t:59,d:"Dieser Hautfetzen muss einst eine sehr empfindliche Stelle des Tynril bedeckt haben. Der Arme!",ep:22,g:629,l:400,wd:true,fm:true,w:1,p:100};
I.u[8998] = {n:"Kimbo-Klim-Bim",t:50,d:"Dieses Edel-Klim-Bim verbrachte Jahrzehnte lang im Schlund des Kimbo, wo es seinen besonderen Schliff erhielt. Die Wege der Natur sind unergründlich...",ep:22,g:109,l:900,wd:true,fm:true,w:1,p:100};
I.u[9001] = {n:"Schild von Sidimot",t:82,d:"Dieser Schild zeigt euren Gegnern deutlich, dass ihr in den Ebenen des Sidimot-Gebietes aufgewachsen seid. Es wird behauptet, dies würde bei den meisten Gegnern bereits ausreichen, um sie in die Flucht zu schlagen.",ep:18,g:8,l:1,wd:true,fm:true,w:10,c:"PP>4",p:15650};
I.u[9002] = {n:"O Ftalmo!",t:82,d:"Dieser Schild ist mit zahlreichen Augen übersät. Bestimmt, um euren Gegner noch besser mit den Augen fixieren zu können.",ep:18,g:5,l:1,wd:true,fm:true,w:10,c:"PP>4",p:33000};
I.u[9003] = {n:"Schild der Taverne",t:82,d:"Der Tavernenbesitzer der Feubuk-Brauerei in Bonta hatte sicherlich große Langeweile, als ihm mit einem Male die Idee kam, seine Rausschmeißer mit diesen Schilden mit Werbeaufschrift auszurüsten. Gesagt, getan!",ep:18,g:6,l:1,wd:true,fm:true,w:10,c:"PP>3",p:16200};
I.u[9004] = {n:"Akwadala-Schild",t:82,d:"Um Tiefschläge und Schicksalsschläge abzuwehren, ist dieser Schild aus dem Dorf Akwadala einfach perfekt geeignet.",ep:14,g:31,l:1,wd:true,fm:true,w:2,c:"PP>2",s:34,p:5350};
I.u[9005] = {n:"Schildfächer",t:82,d:"Wenn eure Verbündeten außer Atem geraten oder aber wenn ihr die Wirkung einer Panikwelle zerstreuen wollt, so kommt euch dieser Fächer gerade Recht. Ihr müßt ihn einfach kräftig in alle Richtungen auf und ab schütteln, genau so, als wolltet ihr wieder einmal einen etwas zu lauten Säugling beruhigen.",ep:18,g:11,l:1,wd:true,fm:true,w:10,c:"PP>8",p:54450};
I.u[9006] = {n:"Schild des Sadida",t:82,d:"Anfangs diente dieser Schild Sadidas als Hocker, wenn diese sich einmal ausruhen wollten. Doch mit eingeklappten Füßen kann er euch auch gut vor allen Arten von Angriffen beschützen, außer natürlich vor den Lachanfällen eurer Gegner.",ep:18,g:12,l:1,wd:true,fm:true,w:10,c:"PP>6",p:18700};
I.u[9007] = {n:"Schlüpferschild",t:82,d:"Diese wundersame Konzeption besteht aus einem Schlüpfer aus Chafer-Leder, welches gekocht, gesäubert und anschließend gestreckt wurde, um die Form dieses Schildes anzunehmen, die jedoch der wohlproportionierten und aufreizenden Form des ursprünglichen Chafers bei weitem unterlegen ist.",ep:18,g:13,l:1,wd:true,fm:true,w:10,c:"PP>5",p:26700};
I.u[9008] = {n:"Schild der Assel",t:82,d:"Dieser wunderhübsche Schild enthält Wasser aus dem Assel-Meer. Daher wird er euch nicht nur im Kampf beschützen, sondern auch noch als Feldflasche dienen, wenn euch eure Liebste nicht im Kampf begleiten kann.",ep:18,g:16,l:1,wd:true,fm:true,w:10,c:"PP>7",p:32450};
I.u[9009] = {n:"Schild des Astaknyden",t:82,d:"Wenn ihr euch hinter diesem Schild versteckt, so werden euch die naivsten unter den Abenteurern sicher für einen gefährlichen Astaknyden halten und schreiend davonrennen. Andere hingegen könnten euch allerdings angreifen, um an ein wenig Bernstein zu kommen.",ep:18,g:19,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5950};
I.u[9010] = {n:"Schild des Pandawa",t:82,d:"Dieser Schild ist ideal, um auf Pandala unbemerkt zu bleiben, und an jedem anderen Ort sofort aufzufallen. Darüberhinaus ist er noch mit Pandawa-Haaren überzogen, denen man nachsagt, sie würden keinerlei Allergien verursachen. Daher lässt er sich diskret und völlig ohne Nebenwirkung in eurer Unterhose aus Chafer-Leder unterbringen. Toll, was?",ep:18,g:22,l:1,wd:true,fm:true,w:10,c:"PP>2",p:5600};
I.u[9011] = {n:"Feurige Scheibe",t:82,d:"Dieser originelle Schild wird euch vor Feuerschaden behüten. Darüber hinaus gibt er euren Gegnern immer die genaue Uhrzeit an. Dies ist sehr praktisch, damit sie die Zeit bis zu ihrer Niederlage genau bestimmen können.",ep:18,g:24,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9012] = {n:"Luftige Scheibe",t:82,d:"Dieser originelle Schild wird euch vor Luftschaden behüten. Darüber hinaus gibt er euren Gegnern immer die genaue Uhrzeit an. Dies ist sehr praktisch, damit sie die Zeit bis zu ihrer Niederlage genau bestimmen können.",ep:18,g:26,l:1,wd:true,fm:true,w:10,c:"PP>1",p:2000};
I.u[9013] = {n:"Irdene Scheibe",t:82,d:"Dieser originelle Schild wird euch vor Erdschaden behüten. Darüber hinaus weist er euren Gegnern immer die richtige Uhrzeit. Dies ist sehr praktisch, damit sie die Zeit bis zu ihrer Niederlage genau bestimmen können.",ep:18,g:27,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9014] = {n:"Wäßrige Scheibe",t:82,d:"Dieser originelle Schild wird euch vor Wasserschaden behüten. Darüber hinaus gibt er euren Gegnern immer die genaue Uhrzeit an. Dies ist sehr praktisch, damit sie die Zeit bis zu ihrer Niederlage genau bestimmen können.",ep:18,g:25,l:1,wd:true,fm:true,w:10,c:"PP>0",p:2000};
I.u[9015] = {n:"Schild des Holzfällers",t:82,d:"Dieser Schild diente ursprünglich zum Schutz der Handwerker vor herabfallenden Bäumen und Ästen. Allerdings wurde er später dazu umfunktioniert, den Träger vor anfallenden Gegnern zu schützen, da diese manchmal die lästige Angewohnheit haben, in den ungünstigsten Momenten einzufallen.",ep:18,g:4,l:1,wd:true,fm:true,w:10,c:"PP>1",p:1200};
I.u[9016] = {n:"Schild des O\'Stinkus Mons",t:82,d:"Er mag zwar grünlich und übelriechend sein, doch wird euch dieser Schild gute Dienste dabei leisten, wenn es darum geht, die Kreaturen des O\'Stinkus Mons zu besiegen.",ep:18,g:1,l:1,wd:true,fm:true,w:20,c:"PP>2",p:5400};
I.u[9017] = {n:"Schild der Brigandiner",t:82,d:"Wenn auch ihr immer schon davon geträumt habt, ein echter Brigandiner zu sein, dann ist dieser Schild genau das Richtige für euch. Er wird nämlich seit langem von Generation zu Generation weitergegeben, und dank seiner könnt ihr alle jungen Abenteurer von Astrub auseinandernehmen, ohne auch nur einen Kratzer abzubekommen.",ep:18,g:9,l:1,wd:true,fm:true,w:10,c:"PP>6",p:30700};
I.u[9018] = {n:"Herz-Quartschen",t:82,d:"Ein berühmter Sammler verbrachte einst sein ganzes Leben damit, diese Art von Schild zu suchen. Es heißt nämlich, dass beim Vereinen aller vier Teile dieses Schildes das Leben besser werden würde.",ep:18,g:7,l:1,wd:true,fm:true,w:10,c:"PP>3",p:13000};
I.u[9019] = {n:"Schild des Bawbawen",t:82,d:"Nicht alle Wabbits sind klein und ungefährlich. In Wirklichkeit sind Wabbits nämlich bösartige Kreaturen, die in barbarischen Riten arme Cawotten mit diesen enormen Schilden zu Saft schlagen.",ep:18,g:2,l:1,wd:true,fm:true,w:15,c:"PP>3",p:10500};
I.u[9020] = {n:"Derma Tho",t:82,d:"Dieser aus Fellen und Häuten bestehende Schild wird euch wie eine zweite Haut begleiten, so sehr wird er euch gefallen. Das einzige, woran ihr dabei denken solltet, ist, seine Furunkel und Warzen von Zeit zu Zeit zu behandeln, damit er sich nicht abnutzt.",ep:18,g:3,l:1,wd:true,fm:true,w:10,c:"PP>2",p:2200};
I.u[9021] = {n:"Schild von Captain Amakna",t:82,d:"Es gab einmal einen jungen Abenteurer, der sich bei der Miliz von Bonta verdingen wollte, um die Unterdrückten zu verteidigen. Doch wurde er abgelehnt, weil er in zu schlechter körperlicher Verfassung war. Drum bot ihm ein Alchimist Amaknas an, einen neu entwickelten Zaubertrank an ihm auszuprobieren. Die Wirkung setzte augenblicklich ein und der Abenteurer entwickelte sich zu einem echten Helden von gewaltiger Stärke... und einem völligen Idioten. Er war nämlich in einen Iop verwandelt worden... Also ließ er sich diesen angeblich unzerstörbaren Schild schmieden und von aller Welt \"Captain Amakna\" nennen. (Angeblich als Ehrbekundung an den berüchtigten Chafer-Offizier, der zeitgleich unter mysteriösen Umständen verschwand.)",ep:18,g:14,l:1,wd:true,fm:true,w:30,c:"PP>9",p:63200};
I.u[9022] = {n:"Kloom",t:82,d:"Dieser gewaltige Schild ermöglichte es einst dem berühmten Abenteurer Kloom, nicht unter dem Gewicht eines Krachlers zermalmt zu werden, der sich in ihn verliebt hatte. Die Geschichte schweigt sich allerdings darüber aus, ob er die weiteren Nebenwirkungen seiner heißen Liebesbeziehung mit dem Krachler überlebte.",ep:18,g:15,l:1,wd:true,fm:true,w:10,c:"PP>4",p:22100};
I.u[9023] = {n:"Fliegenschild",t:82,d:"So seltsam, wie dies auch erscheinen mag, so kann man mit diesem Schild aus Holz und Fellen doch tatsächlich über eine kurze Distanz fliegen. Probiert es einfach mal aus, vorausgesetzt, ihr seid leicht genug! Es braucht nur etwas Schwung, um sich in die Lüfte zu erheben und majestätisch davonzugleiten. Eine wunderbare Einlage, um seine Gegner ein letztes Mal zu verblüffen, bevor man nach einem stupiden Absturz am Boden zerschmettert endet.",ep:18,g:17,l:1,wd:true,fm:true,w:1,c:"PP>0",p:1200};
I.u[9024] = {n:"Le Tschucks Schild",t:82,d:"Le Tschuck nutzte diesen Schild einst, um sein Schiff vor eintretenden GAUs zu schützen. Das war auch bitter nötig, bei den vielen DAUs, die ständig GAUs auszulösen pflegten. Naja, eine gute Mannschaft ist eben nur schwer zu finden.",ep:18,g:18,l:1,wd:true,fm:true,w:10,c:"PP>6",p:36850};
I.u[9025] = {n:"Schild des Fresssacks",t:82,d:"Dieser im Grunde ziemlich nutzlose Schild ist dennoch beeindruckend – auf Grund des Gestankes, den er permanent absondert. Daher ist er auch der treue Begleiter vornehmlich junger Abenteurer.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PP>0",p:400};
I.u[9026] = {n:"Bowissen-Schild",t:82,d:"Dieser Schild ist ganz klar mit dem Bowissen-Umhang und den Bowissen-Stiefeln verbunden, welche wiederum mit einem berühmten Artefakt in Form dreier dreieckiger Fragmente verknüpft sind. Eine ziemlich hanebüchene Geschichte.",ep:18,g:21,l:1,wd:true,fm:true,w:10,c:"PP>3",p:10150};
I.u[9027] = {n:"Schild des Krachlers",t:82,d:"Dieser Schild ganz aus Stein zeigt das Gesicht eines Krachlers, welcher gerade vom Fuss eines Minotorors zertreten wird. Eine Art wie jede andere, um einen Dickkopf mit üblem Fußgeruch zu kombinieren.",ep:5,g:23,l:1,wd:true,fm:true,w:10,c:"PP>2",p:6300};
I.u[9028] = {n:"Teradala-Schild",t:82,d:"Um Tiefschläge und Schicksalsschläge abzuwehren, ist dieser Schild aus dem Dorf Teradala einfach perfekt geeignet.",ep:18,g:32,l:1,wd:true,fm:true,w:10,c:"PP>3",s:36,p:14100};
I.u[9029] = {n:"Feudala-Schild",t:82,d:"Um Tiefschläge und Schicksalsschläge abzuwehren, ist dieser Schild aus dem Dorf Feudala einfach perfekt geeignet.",ep:18,g:33,l:1,wd:true,fm:true,w:15,c:"PP>5",s:37,p:27100};
I.u[9030] = {n:"Aerdala-Schild",t:82,d:"Um Tiefschläge und Schicksalsschläge abzuwehren, ist dieser Schild aus dem Dorf Aerdala einfach perfekt geeignet.",ep:18,g:30,l:1,wd:true,fm:true,w:10,c:"PP>4",s:35,p:11600};
I.u[9031] = {n:"Aufgeblasener Düsenring von Meister Knalldurch",t:9,d:"Meister Knalldurch gehörte einst zu den stattlichsten und begütertsten Männern in ganz Amakna. Doch war dies nicht sein eigener Verdienst, sondern der seines Ringes. Selbiger, sein Ruhm und sein Ego lösten sich in Luft auf, als er eines schönen Tages die Straße überquerte und auf einen Igel trat. Ein wenig skrupelhafter Bürger nahm sich der Überreste des Ringes an und flickte ihn zusammen. Nicht ohne Erfolg, wie man sieht.",ep:0,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[9035] = {n:"Gildenkoppeltrank",t:12,d:"Dieser Trank wird es euch ermöglichen, in Sekundenschnelle zur Koppel eurer Gilde zu reisen.",ep:5,g:25,l:1,wd:true,fm:true,w:2,c:"PZ=1",u:true,p:100};
I.u[9036] = {n:"Teleportationstrank: Zoth-Dorf",t:12,d:"Durch diesen Trank könnt ihr euch in das Zoth-Dorf teleportieren, falls dieses eurer Gesinnung angehört.",ep:0,g:24,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9037] = {n:"Enthüllungstrank",t:14,d:"Für den, der diesen Trank einnimmt, werden unsichtbare Charaktere in der Umgebung sichtbar.",ep:0,g:0,l:1,wd:true,fm:true,w:1,p:10};
I.u[9038] = {n:"Kleiner Aggrotrank",t:14,d:"Dieser Trank wird euch derart aggressiv machen, dass ihr automatisch alle Gegner angreift, die sich euch zu sehr nähern.",ep:0,g:32,l:1,wd:true,fm:true,w:1,c:"Pg=21",u:true,p:10};
I.u[9039] = {n:"Prisma-Rückruftrank",t:12,d:"Dank dieses Trankes könnt ihr euch zum nächstgelegenen verbündeten Prisma teleportieren.",ep:0,g:34,l:1,wd:true,fm:true,w:1,c:"Ps=1|Ps=2",u:true,p:10};
I.u[9040] = {n:"Mittlerer Aggrotrank",t:14,d:"Dieser Trank wird euch derart aggressiv machen, dass ihr automatisch alle Gegner angreift, die sich euch zu sehr nähern.",ep:0,g:33,l:1,wd:true,fm:true,w:1,c:"Pg>21,1",u:true,p:10};
