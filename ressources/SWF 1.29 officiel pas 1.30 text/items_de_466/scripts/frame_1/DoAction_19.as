I.u[9152] = {n:"Indigoblob-Amulett",t:1,d:"Als Lorkos angetragen wurde, ins Minotoror-Labyrinth einzudringen, zögerte er nicht eine Sekunde lang, sein Blob-Amulett anzulegen. Warum genau, ist nicht bekannt. Möglicherweise ein Schutzreflex?",ep:5,g:131,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9153] = {n:"Königliches Kirschblob-Amulett",t:1,d:"In der Anschaffung sind Königliche Blob-Amulette wesentlich teurer als gewöhnliche Blob-Amulette. Dies hat allerdings den Vorteil, dass man sie zu einem höheren Preis weiterverkaufen kann.",ep:5,g:132,l:80,wd:true,fm:true,w:10,s:102,p:15800};
