I.u[9126] = {n:"Königlicher Kirschblob-Ring",t:9,d:"Kroula hatte einstmals versucht, diesen Ring an seinem großen Zeh zu tragen, in der Hoffnung, dass seine Feinde ihm die Füße küssen würden, und sei es auch nur, um ein paar Tropfen des Königlichen Blobsaftes zu erhaschen.",ep:5,g:153,l:80,wd:true,fm:true,w:10,s:102,p:15000};
I.u[9127] = {n:"Königlicher Apfelblob-Ring",t:9,d:"Kroula hatte einstmals versucht, diesen Ring an seinem großen Zeh zu tragen, in der Hoffnung, dass seine Feinde ihm die Füße küssen würden, und sei es auch nur, um ein paar Tropfen des Königlichen Blobsaftes zu erhaschen.",ep:5,g:154,l:80,wd:true,fm:true,w:10,s:103,p:15000};
I.u[9128] = {n:"Königlicher Kokosblob-Ring",t:9,d:"Kroula hatte einstmals versucht, diesen Ring an seinem großen Zeh zu tragen, in der Hoffnung, dass seine Feinde ihm die Füße küssen würden, und sei es auch nur, um ein paar Tropfen des Königlichen Blobsaftes zu erhaschen.",ep:5,g:155,l:80,wd:true,fm:true,w:10,s:104,p:15000};
I.u[9129] = {n:"Königlicher Indigoblob-Ring",t:9,d:"Kroula hatte einstmals versucht, diesen Ring an seinem großen Zeh zu tragen, in der Hoffnung, dass seine Feinde ihm die Füße küssen würden, und sei es auch nur, um ein paar Tropfen des Königlichen Blobsaftes zu erhaschen.",ep:5,g:156,l:80,wd:true,fm:true,w:10,s:105,p:15000};
I.u[9130] = {n:"Stinkelingsamulett",t:1,d:"Dieses zu Ehren des Stinkelings entworfene Schmuckstück ist um den Hals zu tragen, und zwar in Verbindung mit einem finsteren Blick und einem ordentlich gepflegten Bart.",ep:23,g:127,l:181,wd:true,fm:true,w:15,s:118,p:58000};
I.u[9131] = {n:"Mariettes Enthauptring",t:9,d:"Im Schattenwald, im Schattenwald ward Mariett\' enthauptet bald. Bruce Bulgour, blind, verwechselt\'s Kind mit einem Farn!, und zielt geschwind. Die Axt, sie wiegt, doch nun sie fliegt, und bald das Kind am Boden liegt. O Kindlein zart, dein Tod, so hart, rührt alle... Ähm.... Aber wirklich alle!",ep:23,g:146,l:188,wd:true,fm:true,w:10,s:119,p:57950};
I.u[9132] = {n:"Behaaring",t:9,d:"Nicht genug, dass ihr bereits Haare auf den Zähnen habt – jetzt tragt ihr sie auch noch am Finger!",ep:23,g:147,l:180,wd:true,fm:true,w:10,s:121,p:57822};
I.u[9133] = {n:"Fungiering",t:9,d:"Wenn eure Feinde allergisch auf Pilze reagieren, fungitioniert euer Ring genau richtig. Lasst sie euch einfach aus der Hand fressen.",ep:23,g:148,l:186,wd:true,fm:true,w:10,s:107,p:56000};
I.u[9134] = {n:"Lamellenbogen",t:2,d:"Mit diesem Bogen verbreitet ihr ganz subtil die Botschaft, dass sich eure Gegner auf der absteigenden Lamelle ihrer Lebenskurve befinden.",ep:23,g:61,l:187,wd:true,fm:true,w:15,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>300&CI>300",p:58421};
I.u[9135] = {n:"Trompetenknüppel",t:3,d:"Früher genügte ein Ton aus dieser Pilztrompete, um den Sänger Oh\'Nein auf den Plan zu rufen, welcher mit seinen Künsten alle rotäugigen Monster auf der Stelle ins Jenseits versetzte. Diese Kampfmethode fand regen Anklang bei Einheimischen wie Abenteurern, so dass die Trompete schnell verschliss. Daraufhin beschlossen die Götter, sie zu verstopfen und sie somit auf immer verstummen zu lassen. Ihre Überreste wurden zu diesem Knüppel verarbeitet.",ep:23,g:66,l:184,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,45,50,false,true],c:"CI>300&CA>300",p:54284};
I.u[9136] = {n:"Schamorchel-Stab",t:4,d:"Die drei Spitzen dieses Stabes weisen eine hohe Konzentration an feinstofflichen Pi-Teilchen auf, welche sonst nur in Bereichen der Quadratbrise zirkulieren. Befeuchtet sie mit ein wenig Speichel, dreht den Stab im Uhrzeigersinn einer umgestülpten Xélor-Sanduhr und zählt bis sechzig. (Iops dürfen bei 6 aufhören.) Konzentriert euch, atmet tief ein, und stellt euch vor ihr seid ein Wochenendseminar. So. Genug! Jetzt habt ihr bereits gute Chancen, eure Gegner in behaarte Kirbullen zu verwandeln. Oder vom Blitz getroffen zu werden.",ep:23,g:80,l:191,wd:true,fm:true,w:10,an:12,tw:true,e:[5,4,1,1,50,50,false,false],c:"CS>200&CC>200&CI>100",p:55000};
I.u[9137] = {n:"Glissandolche",t:5,d:"Diese Dolche wurden früher eingesetzt, um die Mykosengeflechte an den Füßen und Beinen der Abenteurer wegzuschaben.",ep:23,g:69,l:187,wd:true,fm:true,w:10,an:13,tw:true,e:[8,3,1,1,30,50,false,false],c:"CA>450",s:119,p:57000};
I.u[9138] = {n:"Lamellenaxt",t:19,d:"Die vielen Lamellen dieser Axt sorgen dafür, dass ihr ganz schnell eure Wurst in Scheiben schneiden könnt. Und eure Gegner auch.",ep:23,g:51,l:176,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,50,50,false,false],c:"CC>450",s:120,p:54854};
I.u[9139] = {n:"Unterholzige Überstülpchen",t:11,d:"Diese Überstülpchen sind ideal für ausgedehnte Spaziergänge im Unterholz. Dank ihrer geringen Trittfläche verschonen sie Flora und Fauna. Und auch sonst verhalten sie sich sehr diskret.",ep:23,g:115,l:175,wd:true,fm:true,w:10,s:120,p:54852};
I.u[9140] = {n:"Pandemische Toffeln",t:11,d:"Die pandemischen Toffeln verfügen über kleine Luftlöcher, die entgegen aller vorgefassten Meinungen nicht der Atmungsaktivität dienen, sondern perfekte Nistlöcher für alle Art von Parasiten abgeben.",ep:23,g:116,l:181,wd:true,fm:true,w:15,s:121,p:57000};
I.u[9141] = {n:"Egermanteling",t:17,d:"Der Egermanteling ist die perfekte Tarnung für alle, die den Wald vor lauter Pilzen nicht sehen wollen.",ep:23,g:154,l:181,wd:true,fm:true,w:10,s:119,p:58000};
I.u[9142] = {n:"Tragestolz",t:17,d:"Früher war dieses Cape bei den kletternden Abenteurern in Mode, welche damit im Krachlergebirge Verstecke zu spielen pflegten. Heute wird es hauptsächlich von exzentrischen Langzeitsingles getragen.",ep:23,g:150,l:190,wd:true,fm:true,w:10,s:107,p:60000};
I.u[9143] = {n:"String \"Sektizid\"",t:10,d:"Dieser String ist absolut tödlich. Und zwar für alle Fliegen, die euer Hinterteil umschwirren. Leider handelt es sich bei dieser genialen Erfindung immernoch um ein Wegwerfprodukt, was ihr spätestens dann bemerken werdet, wenn ihr euch einmal hingesetzt habt.",ep:23,g:132,l:192,wd:true,fm:true,w:20,s:107,p:48000};
I.u[9144] = {n:"Mykosatorgürtel",t:10,d:"Wer noch immer nicht ausreichend unter Pilzbefall leidet, sollte alles daran setzen, in den Besitz dieses Gurtes und unter Befall einer Gürtelmykose zu gelangen.",ep:23,g:133,l:177,wd:true,fm:true,w:10,s:121,p:58444};
I.u[9145] = {n:"Unterholziger Ulmentgurt",t:10,d:"Man nehme einen Ulmenstumpf, befreie diesen von seiner Rinde, lasse selbige über Nacht in einer Pfütze wässern, presse sie hiernach in eine runde Schale, bestäube sie mit Pilzsporen, reibe sie zusätzlich mit Blobfett ein und bewahre sie schlussendlich eine Woche lang unterm Bett auf, während man sich selbst in der Badewanne einrichtet. Fertig ist der stinkende Unterholz-Gurt. Na, seid ihr jetzt endlich zufrieden?!",ep:23,g:134,l:179,wd:true,fm:true,w:10,s:120,p:68420};
I.u[9146] = {n:"Stinkelinggurt",t:10,d:"Auf dem Etikett dieses Gurts ist zu lesen: \"Es tut uns leid, aber selbst wenn Sie der stolze Träger dieses Gurtes sind, so werden Sie noch lange nicht über den legendären Hüftschwung des legendären Stinkelings verfügen.\" Ja und?",ep:23,g:135,l:185,wd:true,fm:true,w:10,s:118,p:56000};
I.u[9147] = {n:"Egerkäppling",t:16,d:"Das Egerkäppling passt hervorragend zum Egermanteling. Doch Vorsicht: eine halluzigene Wirkung ist nicht auszuschließen. Empfehlenswert für alle, die den Wald wirklich nicht sehen wollen.",ep:23,g:221,l:185,wd:true,fm:true,w:10,s:119,p:48521};
I.u[9148] = {n:"Königlicher Multiblobring",t:9,d:"Eine Weile lang zog es Shika Ingalsse vor, im trunkenen Zustand über die Felder zu ziehen, als auf ihren gepanschten Blobsaft zu verzichten. Und so stolperte sie denn eines schönen Mittags über diesen bunten Blobring. Ein Beweis mehr dafür, das Trunkenheit vor dem Fall kommt.",ep:5,g:157,l:90,wd:true,fm:true,w:10,s:106,p:20000};
I.u[9149] = {n:"Kirschblob-Amulett",t:1,d:"Als Lorkos angetragen wurde, ins Minotoror-Labyrinth einzudringen, zögerte er nicht eine Sekunde lang, sein Blob-Amulett anzulegen. Warum genau, ist nicht bekannt. Möglicherweise ein Schutzreflex?",ep:5,g:128,l:50,wd:true,fm:true,w:10,s:98,p:1000};
