I.u[9157] = {n:"Königliches Multiblob-Amulett",t:1,d:"Ohne Zusatzstoffe und Farbstoffe wäre dieses Amulett lediglich transparent. Aber keine Bange, ihr müsst es ja nicht verzehren.",ep:5,g:136,l:90,wd:true,fm:true,w:10,s:106,p:21000};
I.u[9158] = {n:"Kirsch-Bloptten",t:11,d:"Dass der Name dieses Schuhwerks unaussprechlich ist, sollte euch nicht weiter stören, zumal euch das unter gewissen Umständen durchaus von Nutzen sein kann. Zum Beispiel, wenn euch ein Brigandiner anschreit mit den Worten: \"Her mit deinen Ploppen! Äh... Boppen... Äh... Bolpt..\" Damit dürftet ihr genug Zeit gewinnden, um euch aus dem Staub zu machen.",ep:5,g:117,l:50,wd:true,fm:true,w:10,s:98,p:1000};
I.u[9159] = {n:"Apfelblobtten",t:11,d:"Dass der Name dieses Schuhwerks unaussprechlich ist, sollte euch nicht weiter stören, zumal euch das unter gewissen Umständen durchaus von Nutzen sein kann. Zum Beispiel, wenn euch ein Brigandiner anschreit mit den Worten: \"Her mit deinen Ploppen! Äh... Boppen... Äh... Bolpt..\" Damit dürftet ihr genug Zeit gewinnden, um euch aus dem Staub zu machen.",ep:5,g:118,l:50,wd:true,fm:true,w:10,s:99,p:1000};
I.u[9160] = {n:"Kokosblobtten",t:11,d:"Dass der Name dieses Schuhwerks unaussprechlich ist, sollte euch nicht weiter stören, zumal euch das unter gewissen Umständen durchaus von Nutzen sein kann. Zum Beispiel, wenn euch ein Brigandiner anschreit mit den Worten: \"Her mit deinen Ploppen! Äh... Boppen... Äh... Bolpt..\" Damit dürftet ihr genug Zeit gewinnen, um euch aus dem Staub zu machen.",ep:5,g:119,l:50,wd:true,fm:true,w:10,s:100,p:1000};
I.u[9161] = {n:"Indigoblobtten",t:11,d:"Dass der Name dieses Schuhwerks unaussprechlich ist, sollte euch nicht weiter stören, zumal euch das unter gewissen Umständen durchaus von Nutzen sein kann. Zum Beispiel, wenn euch ein Brigandiner anschreit mit den Worten: \"Her mit deinen Ploppen! Äh... Boppen... Äh... Bolpt..\" Damit dürftet ihr genug Zeit gewinnden, um euch aus dem Staub zu machen.",ep:5,g:120,l:50,wd:true,fm:true,w:10,s:101,p:1000};
I.u[9162] = {n:"Königliche Kirschblobtten",t:11,d:"Wiederholt acht Mal schnell hintereinander das Wort \"Blobtten\"! Da steht ihr da wie ein Iop, nicht wahr?",ep:5,g:121,l:80,wd:true,fm:true,w:10,s:102,p:16000};
