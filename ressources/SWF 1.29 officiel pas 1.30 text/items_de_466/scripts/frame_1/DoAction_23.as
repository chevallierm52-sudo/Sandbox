I.u[10675] = {n:"Geburtstagsgeschenk",t:89,d:"Alles Gute zum Geburtstag! Dieses Paket ist so gut verpackt, dass kein vorwitziger Blick möglich ist. Doch könnt ihr kräftig feiern und euch daran erfreuen. Viel Spaß dabei! Schließlich ist der Tag zum Feiern da!",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10676] = {n:"Kill Coos Doppelwirkung",t:28,d:"Euer Filzwert und eure Weisheit werden während mehrerer Kämpfe erhöht.",ep:0,g:19,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10677] = {n:"Kill Coos Shigekax",t:42,d:"Mit diesem nach altbewährter Methode hergestellten Bonbon werdet ihr den Geschmack und Charme von Süssigkeiten aus guten alten Zeiten wieder finden. \n(Dieses Bonbon erhöht 20 Kämpfe lang den Filzwert und die Weisheit um 100)",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"PO!10676",u:true,p:1};
I.u[10678] = {n:"Wie finde ich meinen Weg – Ein Ratgeber",t:25,d:"Arpagnagrobis schrieb einst dieses Werk für all die jungen Abenteurer, die noch unerfahren in der Benutzung von Kompass und Zaap sind.",ep:0,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
