I.u[11077] = {n:"Lonnes Hammer",t:7,d:"Wenn es darum geht, seinen Gegnern etwas auf die Ohren zu geben, ist Lonne Jenone ein wahrer Meister. Hammerhart prasseln die Schläge auf Gegner ein - das ist Musik in den Ohren dieses Meisterbarden!",ep:0,g:75,l:54,wd:false,fm:true,w:20,an:0,e:[6,5,1,1,42,50,false,false],c:"CA>20&CV>40",s:163,p:9700};
I.u[11078] = {n:"Lonnes Umhang",t:17,d:"Dieser Umhang aus Leder wird euch, wie damals Lonne auch, bei euren fantastischen Dracotruterausritten begleiten.",ep:0,g:176,l:55,wd:false,fm:true,w:10,an:0,s:163,p:7900};
I.u[11079] = {n:"Lonnes Hut",t:16,d:"Bevor Lonne Jenone in Besitz dieses Hutes kam, gehörte dieser einem gewissen Sergeant Peppa. Der Hut hat jedoch auch nach all der Zeit nicht seine Würze verloren.",ep:0,g:261,l:55,wd:false,fm:true,w:10,an:0,s:163,p:8050};
I.u[11080] = {n:"Lonnes Stiefel",t:11,d:"Diese elastischen Stiefel garantieren vollkommene Bewegungsfreiheit. Steht jedenfalls mal auf dem Etikett. Lonne Jenone musste aber bei seinem Tanz mit dem MuWulf erfahren, dass man sich nicht immer auf Etiketten verlassen sollte...",ep:0,g:160,l:55,wd:false,fm:false,w:10,an:0,s:163,p:7925};
I.u[11082] = {n:"Fressball Stiefel",t:11,d:"Diese Stiefel sind wie dafür geschaffen, die Schienbeinschoner eurer Gegner zu zerschlagen, anschließend das Schienbein der Gegner zu zertrümmern, bevor auch eure eigene Zehen dran glauben müssen...",ep:0,g:157,l:28,wd:false,fm:true,w:10,an:0,c:"Sc=11",p:2300};
I.u[11083] = {n:"Fressball Ring",t:9,d:"Wenn es wieder dringend an der Zeit ist, eine Spielpause zu arrangieren, dann kommt dieser Ring zum unauffälligen Zerstechen des Fressballes wie gerufen!",ep:0,g:187,l:31,wd:false,fm:true,w:10,an:0,c:"Sc=12",p:2666};
I.u[11084] = {n:"Gedschets Hut",t:16,d:"Gedschet war einer der schöpferischsten Bastler der Welt der Zwölf. Dummerweise auch einer der zerstreutesten. Es heißt, einst habe er sogar Hammer und Amboss verwechselt.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6400};
I.u[11085] = {n:"Gedschets Gürtel",t:10,d:"Indem ihr diesen Gürtel umgekehrt trägt und ihn stark genug schnürt, aktiviert ihr vielleicht das integrierte retromagische Modul. Es hat zwar nie funktioniert, aber ihr könnt es trotzdem aktivieren. Außerdem könnt ihr es an jemanden verkaufen, der so naiv ist, wie ihr es wart.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6358};
I.u[11086] = {n:"Gedschets Umhang",t:17,d:"Gedschet hat diesen Umhang in der Hoffnung genäht, damit fliegen zu können und so leichter den täglich verabreichten Strafen seiner Frau zu entkommen.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6350};
I.u[11087] = {n:"Gedschets Ring",t:9,d:"Von mehreren Generationen von Bastlern getragen, schützt dieser Ring ein Fingerglied vor euren Hammerschlägen. Leider wird er nie im 5-er Set verkauft.",ep:0,g:0,l:49,wd:false,fm:true,w:10,an:0,s:165,p:6453};
I.u[11088] = {n:"Grillians Hut",t:16,d:"Grillian war ein sehr großer Zauberer, berühmt dafür, das Fluchtpulver wieder erfunden zu haben, nachdem er die Herstellungsweise vergessen hatte.",ep:0,g:0,l:49,wd:false,fm:true,w:10,s:164,p:6325};
I.u[11089] = {n:"Grillians Umhang",t:17,d:"Dieser Umhang soll euren Hintern vor fleischfressenden Pflanzen schützen.",ep:0,g:0,l:48,wd:false,fm:true,w:10,s:164,p:6250};
I.u[11090] = {n:"Kopfgeldgesuch",t:24,d:"Diesem Kopfgeldgesuch nach wird Lethalina Sigisbull gesucht.",ep:0,g:821,l:1,wd:false,fm:true,w:0,p:0};
I.u[11091] = {n:"Grilllians Stiefel",t:11,d:"Grillian der Zauberer hat einen Zauberring gegen dieses Paar Stiefel eingetauscht. Es sieht so aus, als wäre das ein schlechter Tausch gewesen, denn sie sind nicht einmal gefüttert.",ep:0,g:0,l:46,wd:false,fm:true,w:10,an:0,s:164,p:5600};
I.u[11092] = {n:"Grillians Amulett",t:1,d:"Grillian trug einst dieses Amulett um seinen Hals, als er...als er... Ist ja auch egal, er ist tot und nun gehört das Amulett euch.",ep:0,g:0,l:45,wd:false,fm:true,w:10,s:164,p:5450};
