I.u[11070] = {n:"Hata Marie",t:32,d:"Sie war eine Gefangene der Bworks und bittet euch, sie aus dem Dorf heraus zu eskortieren.",ep:0,g:30,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[11071] = {n:"Abhandlung über den Ursprung Goultards",t:25,d:"Mit all den Flecken, Knicken und Löchern sind diese losen Pergamentseite kaum noch lesbar. Nach Abkratzen der dicken Dreckschicht könnt ihr mit Mühe und Not noch einige Wörter entziffern. Es geht offensichtlich um die Herkunft von Goultard.",ep:0,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[11072] = {n:"Geschenkpaket: Gedschets Hut",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
