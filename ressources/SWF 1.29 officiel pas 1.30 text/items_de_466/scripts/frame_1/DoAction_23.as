I.u[11008] = {n:"Tierheimzertifikat: Eismaunzmiez",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[11009] = {n:"Eismaunzmiez Hormon",t:48,d:"Mit diesem getrockneten Wachstumshormon kann man einen kraftvollen Trank zum Verbessern eines Vertrauten herstellen.",ep:0,g:262,l:1,wd:true,fm:true,w:1,p:10};
I.u[11010] = {n:"Eismaunzmiez-Kräftigungstrank",t:116,d:"Wenn ihr diesen mächtigen Trank einsetzt, dann erhöht ihr die Fähigkeiten eures Vertrauten definitiv. Achtung, es wird nur eine einzige Dosis pro Vertrauten angerechnet, mehrere Versuche führen zu enttäuschenden Ergebnissen.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PO=10985",u:true,p:10};
I.u[11011] = {n:"Gescheckter Minifux",t:18,d:"Dieser Vertraute ist noch heimtückischer als der rothaarige Minifux, doch hat er den Vorteil, dass sein Fell nass werden kann, ohne dass man sich deswegen gleich die Nase zuhalten muss. Der gescheckte Minifux ernährt sich von den Monstern des Stammbaumes.",ep:0,g:63,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11012] = {n:"Gescheckter Schnuffwuff",t:18,d:"Nur weil er gescheckt ist, bedeutet das noch lange nicht, dass er euch deswegen nicht anspringen oder sich auf eurem Teppich erleichtern würde. Habt ihr das etwa gedacht? Der Vertraute jagt gern die Kreaturen aus dem Sidimote-Gebiet.",ep:0,g:64,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11013] = {n:"Schwarzes Quark-Quak",t:18,d:"Das schwarze Quark-Quak wurde von seiner Familie verstoßen, weil es anders war, als die anderen. Es summte z.B. mit Liedern von Oh-Nein mit... Aber vielleicht war er bloß unverstanden? Nach seiner schweren Kindheit entschied er sich, alle Rablinge zu fressen. Vielleicht weil sie schwarz sind, wie er?",ep:0,g:65,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11014] = {n:"Ausgebleichte Fleddermaus",t:18,d:"Dieser Vertraute hat wohl zu lange unter saurem Regen geschlafen. Darum glänzt er nachts nicht mehr und ist auch nicht magisch, aber als Essigsäurelieferant für eine gute Salatsauce hervorragend geeignet. Der Vertraute   ist ganz schön verwöhnt und frisst ausschließlich Gelees.",ep:0,g:66,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[11015] = {n:"Gnupi",t:18,d:"Diese eigenartige Kreatur hat einst auf einer Eisscholle den Ozean überquert und ist an der Küste Frigosts gestrandet. Nun scheint sie euch für ihre Eisscholle zu halten... Dieser Seelenfresser ernährt sich von Strandkreaturen.",ep:0,g:67,l:1,wd:false,fm:true,w:10,c:"PZ=1",p:1};
I.u[11016] = {n:"Gescheckter Minifux - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
