I.u[10685] = {n:"Goldiger Helm",t:16,d:"Dieser Helm ist das beste Mittel, um die Höhe des auf euch ausgesetzten Kopfgeldes in schwindelerregende Höhen zu treiben!",ep:0,g:254,l:52,wd:false,fm:true,w:10,s:151,p:7325};
I.u[10686] = {n:"Goldigmantel",t:17,d:"Dieser Mantel wurde aus feinem Stoff gewoben und mit einer dünnen Goldschicht beschichtet und mit Magie imprägniert. Er zieht die Blicke der Anderen nun magisch an und blendet die zwielichtigen Gestalten, die euch hinterrücks erdolchen wollen. Das kann praktisch sein, falls Srams zu eurem Umfeld gehören...",ep:0,g:171,l:54,wd:false,fm:true,w:10,s:151,p:7750};
I.u[10687] = {n:"Golding",t:9,d:"Dieser Ring ist dermaßen schwer, dass er die Trägheit eures Armes erheblich erhöht, wenn ihr mal wieder Ohrfeigen austeilt. Der Nachteil: wenn ihr erst einmal angefangen habt, kann euch keiner mehr aufhalten, auch ihr selbst nicht mehr...",ep:0,g:182,l:51,wd:false,fm:true,w:10,s:151,p:6862};
I.u[10688] = {n:"Goldigürtel",t:10,d:"Dieser Gürtel ist das perfekte Versteck, für Goldbarren. Befestigt sie einfach daran, und sie sind so gut wie unsichtbar...",ep:0,g:166,l:53,wd:false,fm:true,w:10,s:151,p:7525};
