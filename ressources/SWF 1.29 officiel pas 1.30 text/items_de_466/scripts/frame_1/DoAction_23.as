I.u[10680] = {n:"Goultarminators blutige Erinnerung",t:24,d:"Ihr habt Goultards unheilvoller Essenz das Herz herausgerissen. Nun könnt ihr es euch als Souvenir auf euren Kamin stellen.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10681] = {n:"Muffelkröten-Verwandlung",t:31,d:"Geschieht dir recht!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[10682] = {n:"Parziweichs Geheimnis",t:29,d:"Chance und Glück gehen Hand in Hand.",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:0};
