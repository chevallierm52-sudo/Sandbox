I.u[10955] = {n:"Ring des Schwarzen Raben",t:9,d:"Beringtes Federvieh ist nichts Ungewöhnliches.",ep:0,g:188,l:33,wd:false,fm:true,w:10,s:155,p:3150};
I.u[10956] = {n:"Stiefel des Schwarzen Raben",t:11,d:"Dieses Paar Stiefel, wie der Rest des Schwarzer-Rabe-Sets, wurde im Laufe der Zeit von Fuß zu Fuß weitergereicht. Dies erklärt seinen starken Geruch nach Stinkus Casei...",ep:0,g:158,l:32,wd:false,fm:true,w:10,s:155,p:2850};
I.u[10957] = {n:"Umhang des Schwarzen Raben",t:17,d:"Nadel, Faden und ein paar Federn, die ihr von verwesenden Rablingen aufgelesen habt und schon seid ihr im Besitz eines schicken Capes!",ep:0,g:174,l:35,wd:false,fm:true,w:10,s:155,p:3400};
I.u[10958] = {n:"Helm des Schwarzen Raben",t:16,d:"Es bringt nichts, euch zu verstecken! Ihr wurdet entlarvt! Ihr seid es, der Rabenschwarze...äh, Rabe!",ep:0,g:259,l:32,wd:false,fm:true,w:10,s:155,p:2900};
I.u[10959] = {n:"Todesspitze des Schwarzen Raben",t:6,d:"Ihr habt zwar Federn gelassen, aber nun haltet ihr es in euren Händen! Das Schwert des Schwarzen Raben...",ep:0,g:98,l:39,wd:false,fm:true,w:10,an:14,e:[13,5,1,1,40,50,false,false],c:"CA>60&CV>60",s:155,p:4400};
I.u[10960] = {n:"Geschenk: Ring des Schwarzen Raben",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10961] = {n:"Geschenk: Todesspitze des Schwarzen Raben",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[10962] = {n:"Raubsaug Stecken",t:4,d:"Raubsaug pflegte mit dem Stecken erst die Gegner grün und blau zu schlagen, bevor er sie mit einem Finishing-Move aufspießte und ihnen das Leben raubte. Nach seinem Tod blieb ein Teil seiner Seele in diesem Stecken hängen. Bei Anlegen der Waffe macht sich das bemerkbar...",ep:0,g:92,l:30,wd:false,fm:false,w:10,an:12,e:[6,3,1,1,50,50,false,false],c:"CV>30",s:156,p:2650};
I.u[10963] = {n:"Raubsaug Stiefel",t:11,d:"Die Sohlen dieser Stiefel sind schwammförmig. Das ist ein Schutz gegen das Verirrung in der Kanalisation. Der Schlamm dort klebt dann nämlich an der Sohle und wird so bei jedem Schritt verbreitet. So weiß man immer, wo man schon gewesen ist...",ep:0,g:156,l:32,wd:false,fm:true,w:10,s:156,p:2900};
I.u[10964] = {n:"Raubsaug Gürtel",t:10,d:"Dieser kleine Gürtel ermöglichte es Raubsaug, seine Beute daran zu befestigen. An der Innenseite befindet sich außerdem auch noch ein kleines Ventil, durch welches der Gürtel in eine praktische Schwimmboje verwandelt werden kann, wenn einem das Wasser der Kanalisation zu Kopf steigt...",ep:0,g:172,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10965] = {n:"Raubsaug Amulett",t:1,d:"Dieses Amulett war eine Sonderanfertigung für Raubsaug. Doch auch ihr könnte es tragen, nämlich als stylische Brosche oder als Glücksbringer in eurer linken Hand.",ep:0,g:160,l:31,wd:false,fm:true,w:10,s:156,p:2800};
I.u[10966] = {n:"Larvenverwandlung",t:31,d:"Lästerzungen meinen, dieser Trank würde eure wahre Natur zum Vorschein bringen. Ob sie da unrecht haben?",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=21",p:0};
I.u[10967] = {n:"Larvenhirn",t:69,d:"Man muss schon wirklich verzweifelt sein, um das hier zu essen.... Nein! Tut es nicht!",ep:0,g:113,l:1,wd:false,fm:true,w:0,c:"Sc=21",u:true,ut:true,p:1};
I.u[10968] = {n:"Wabbitverwandlung",t:31,d:"Komisch, ihr habt keinen Appetit auf Kawotten.",ep:0,g:19,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=22",p:0};
I.u[10969] = {n:"Ewfischendew Twank",t:12,d:"Die Süsse der Kawotte kombiniert mit der Frische eines olympischen Dracotruters bringt euch gleich auf Trab! Prösterchen!",ep:0,g:141,l:20,wd:false,fm:true,w:1,c:"Sc=22",u:true,ut:true,p:1};
I.u[10970] = {n:"Dracotruterschweiss",t:15,d:"Aber wie habt ihr das denn aufgefangen? Und warum? Oder vielmehr: Wollen wir das wirklich wissen?",ep:0,g:773,l:1,wd:false,fm:true,w:1,p:1};
I.u[10971] = {n:"Frechsack",t:81,d:"Mit diesem Sack ausgerüstet könnt ihr grinsend über die Stränge schlagen!",ep:0,g:25,l:20,wd:false,fm:true,w:10,c:"Sc=23",p:1};
I.u[10972] = {n:"Mitmacher-Rabling",t:31,d:"Auch wenn er sehr anhänglich ist, habt ihr den Verdacht, dass dieses Viech beim ersten Anzeichen von Gefahr das Weite suchen wird.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,c:"Sc=24",p:0};
I.u[10973] = {n:"Trank des unbekannten Bestimmungsortes",t:12,d:"Euer Instinkt sagt euch, den Inhalt nicht zu trinken. Naja, eigentlich ist es eure Nase, denn dieses Gebräu riecht wie 100 Jahre alter Bwork Achselschweiss.",ep:0,g:189,l:20,wd:false,fm:true,w:1,c:"Sc=25",u:true,p:10};
I.u[10974] = {n:"Festliches Feenwerk",t:74,d:"Damit wird jedes Fest gleich festlicher!",ep:0,g:32,l:1,wd:false,fm:true,w:1,c:"Sc=26",ut:true,p:1};
I.u[10975] = {n:"Schwert von  Phung Huss",t:6,d:"Ein stetiger Hauch nach Schimmel und Sporen umgibt dieses Schwert mit dem Lamellenheft. Nach dem Tod von Phung Huss, blieb ein Teil seiner Seele in dieser Waffe hängen. Bei Anlegen des Schwertes macht sich das bemerkbar...",ep:0,g:97,l:33,wd:false,fm:false,w:10,an:14,e:[12,6,1,1,40,60,false,false],c:"CS>50",s:157,p:3100};
I.u[10976] = {n:"Phung Huss - Ring",t:9,d:"Üblicherweise assoziiert man ja mit Pilzen eher das Tragen aufwendiger Hüte. Doch Phung Huss machte da eine Ausnahme. Er zog aufwendige Ringe vor! Vielleicht, weil er seinem Umfeld beweisen wollte, dass er Finger besitzt?",ep:0,g:185,l:33,wd:false,fm:true,w:10,s:157,p:3150};
I.u[10977] = {n:"Phung Huss - Gürtel",t:10,d:"Phung Huss fand eine originelle Lösung für das Problem seines immer dicker werdenden Bauches. Ganz einfach: der Gürtel wächst mit! Dieser lebende Gürtel aus biologisch angebauter Züchtung geht eine symbiotische Vereinigung mit seinem Träger ein und genügt all seinen Ansprüchen.",ep:0,g:170,l:30,wd:false,fm:true,w:10,s:157,p:2650};
I.u[10978] = {n:"Phung Huss - Stiefel",t:11,d:"Die Füße von Pilzen sind selten wirklich sauber. Mycellreste kleben an ihnen. Phong Huss war da keine Ausnahme, jedoch nutze er seine Stiefel, um diesen Umstand zu verbergen. Das erklärt ihren schlechten Geruch und die außergewöhnliche Fruchtbarkeit, die sie verbreiten.",ep:0,g:153,l:32,wd:false,fm:true,w:10,s:157,p:2900};
I.u[10979] = {n:"Ma Äktoplas Hammer",t:7,d:"Ma Äktoplas empfand stets großes Vergnügen dabei, diese Waffe über den Boden zu schleifen. Sie war nämlich faul wie ein Fresssack und es reichte ihr, Gegner durch lautes Gepolter in die Flucht zu schlagen. Nach ihrem Tode blieb ein Teil ihrer Seele in diesem Hammer hängen. Bei Anlegen der Waffe macht sich das bemerkbar...",ep:0,g:74,l:30,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,50,50,false,false],c:"CA>50",s:158,p:2800};
I.u[10980] = {n:"Ma Äktoplas Amulett",t:1,d:"Das Amulett dieses Geistes muss ein extrem magischer Gegenstand sein, wenn man an Legenden, an Geister und an die Legenden über Geister glaubt.",ep:0,g:159,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10981] = {n:"Ma Äktoplas Ring",t:9,d:"Echte Geister sind durchscheinend und haben keine Finger. Aber wie erklärt man dann die Tatsache, dass dieser Ring Ma Äktoplas gehörte?",ep:0,g:186,l:32,wd:false,fm:true,w:10,s:158,p:2970};
I.u[10982] = {n:"Ma Äktoplas Gürtel",t:10,d:"Einst begegnete Kapitän Hardrock der Ma Äktoplas nach einer durchzechten Nacht in der Ripaten-Kneipe. \"Äh Ma Ä*hic*toplas Ma bitte!\", lallte er ihr zu, woraufhin er sich auf dem Boden der Tatsachen wiederfand mit einer wachsenden Beule auf dem Schädel. Das beweist, dass einige selbst Geistern auf den Geist gehen können...",ep:0,g:171,l:32,wd:false,fm:true,w:10,s:158,p:2900};
I.u[10984] = {n:"YeCh\'Ti-Amulett",t:1,d:"Wenn ihr dieses Amulett auf eurer glatten Brust platziert, dann könntet ihr eure Feinde fast glaubhaft machen, eine haarige Bestie wie der YeCh\'Ti zu sein. Furchterregend!",ep:0,g:162,l:66,wd:false,fm:false,w:10,an:0,p:11500};
I.u[10985] = {n:"Eismaunzmiez",t:18,d:"Diese Maunzmiez hat den Winter des hohen Nordens miterlebt, auch wenn sie selbst noch nie dort war. Dennoch bleibt die Frage, wie sie nach Amakna kam. Es wird spekuliert, dass sie vielleicht von der Insel Frigost aus eingeschleppt wurde, um der explosionsartigen Vermehrung der Wabbits Einhalt zu gebieten. Dieser Seelenfresser ernährt sich ausschließlich von Wabbits.",ep:0,g:62,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10986] = {n:"Eismaunzmiez Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal im Stich zu lassen.",ep:0,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[10987] = {n:"Frostiger Gürtel",t:10,d:"Dieser Gürtel kühlt die Lenden. Ideal zur äußerlichen Anwendung auf hitzköpfige Möchtegernliebhabern.",ep:0,g:173,l:35,wd:false,fm:true,w:10,s:141,p:3500};
I.u[10988] = {n:"Frostige Kappe",t:16,d:"Diese Kopfbedeckung ist hervorragend, wenn es gilt einen kühlen Kopf zu bewahren. So sagen zumindest die Träger derselben, wenn sie wieder einmal als Eiswürfel verspottet werden...",ep:0,g:260,l:35,wd:false,fm:true,w:10,s:141,p:3450};
I.u[10989] = {n:"Frostumhang",t:17,d:"Oh\'Nein trug einen ähnlichen Umhang bei seinem berühmt-berüchtigten Konzert auf der Bruce Bulgours Lichtung. Anwesende, die davon nicht taub wurden, erinnern sich noch gut an den einsetzenden Beifallssturm, als Oh\'Nein zu einem Eisklotz erstarrte und darum mit dem Singen aufhören musste!",ep:0,g:175,l:33,wd:false,fm:true,w:10,s:141,p:3150};
I.u[10990] = {n:"Froststiefelchen",t:11,d:"Diese schweren Stiefel sind eher ein Klotz am Bein, als eine nützliche Fußbekleidung. Doch einen Vorteil haben sie: man kann damit Schlittschuh laufen, auch wenn kein Eis da ist.",ep:0,g:159,l:33,wd:false,fm:true,w:10,s:141,p:3000};
I.u[10991] = {n:"Geschenk: Eismaunzmiez",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
