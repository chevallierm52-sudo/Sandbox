I.u[11041] = {n:"Tau-Genie Schwert",t:6,d:"Es ist zu schwer, schlecht ausbalanciert und unhandlich. Darum fragt ihr euch, wie Goultard je mit diesem Schwert zum gefürchteten Meister werden konnte! Eure Versuche, es ihm nachzumachen, sind technisch immer gescheitert. Einen gewissen Ruf bekommt ihr hingegen schon.",ep:0,g:99,l:40,wd:false,fm:true,w:10,an:14,e:[6,4,1,1,40,40,false,false],s:159,p:4000};
I.u[11042] = {n:"Vaters Sohneband",t:10,d:"Das hier ist das rührende Geschenk eines Vaters an seinen Sohn. Als Goultard 5 Jahre alt wurde, bekam er diesen Gürtel, der fortan seine Hose am richtigen Platz hielt. Daneben diente jeder allerdings auch noch als Spring- oder Kletterseil.",ep:0,g:175,l:40,wd:false,fm:true,w:10,s:159,p:4300};
I.u[11043] = {n:"Kapp O\'Kalyps",t:16,d:"Dieser Hut ist so eng, dass der Schädel komprimiert wird und der Träger Halluzinationen bekommt. Goultard hat jedoch einen sehr kleinen Schädel und trug den Hut in seiner Kindheit. Dies ist sozusagen ein Schwank aus seiner Jugend...",ep:0,g:265,l:41,wd:false,fm:true,w:10,s:159,p:4500};
I.u[11044] = {n:"Sterblichen Überreste der Goultard-Familie",t:24,d:"Einige Knochen, Grabbeilagen und das wars schon. Mehr blieb nicht übrig für euer unheilvolles Gepäck.",ep:0,g:818,l:1,wd:false,fm:true,w:0,p:0};
I.u[11045] = {n:"Cape Stinenz",t:17,d:"Goultard trug diese Kappe, bis er den drei Schwestern begegnete. Seitdem verstaubt sie in einem muffigen Kleiderschrank.",ep:0,g:179,l:43,wd:false,fm:true,w:10,s:159,p:5050};
I.u[11046] = {n:"Cabotines verfluchte Halskette",t:24,d:"Ihr könnt euch gerade noch so zusammenreißen, diese Halskette nicht weit wegzuwerfen, so mächtig ist die böse Aura, die sie verbreitet.",ep:0,g:819,l:1,wd:false,fm:true,w:0,p:0};
I.u[11047] = {n:"Da Rorc",t:32,d:"Da Rorc hat sich ergeben. Bringt nun den Gefangenen zu Lethalina.",ep:0,g:29,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11048] = {n:"Indizien für den Dark Vlad",t:24,d:"Mit einem einfach gehaltenen Plan und einigen Intelligenz-Tränken sollte sogar der Dark Vlad in der Lage sein, das Labyrinth zu verlassen!",ep:0,g:820,l:1,wd:false,fm:true,w:0,p:0};
I.u[11049] = {n:"Clementihütchen",t:16,d:"Tragt diesen Hut erst mal einige Zeit, schält ihn mehrere Stunden lang und ihr kommt den Kernen der Sache ein gutes Stück näher!",ep:0,g:262,l:32,wd:false,fm:true,w:10,s:161,p:2900};
I.u[11050] = {n:"Clementicape",t:17,d:"Dieser Umhang sondert ein strenges Zitrusaroma um euch herum aus. Dadurch werdet ihr zu einer perfekten Fliegenfalle!",ep:0,g:177,l:32,wd:false,fm:true,w:10,s:161,p:2850};
I.u[11051] = {n:"Clementinchenamulett",t:1,d:"Wenn man dieses Amulett in ein Glas Wasser taucht, erhält man ein toll prickelndes Getränk mit Zitronengeschmack.",ep:0,g:161,l:32,wd:false,fm:true,w:10,s:161,p:2925};
I.u[11052] = {n:"Clementinchenstiefel",t:11,d:"Die Sohlen dieser Stiefel wurde aus der rauhen Haut verschiedener Früchte gefertigt, die auf einer fernen Insel wachsen, die noch niemand je entdeckt hat.",ep:0,g:161,l:34,wd:false,fm:true,w:10,an:0,s:161,p:3205};
I.u[11053] = {n:"",t:31,d:"",ep:0,g:0,l:1,wd:false,fm:false,w:0,p:0};
I.u[11054] = {n:"",t:49,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,c:"Sc=994",ut:true,p:0};
I.u[11055] = {n:"Zapfentann Hut",t:16,d:"Mit seiner Füllung aus Maunzmiezhaaren und der Rinde an der Außenseite ist der Hut sehr leicht entflammbar. Vorsicht also, wenn ihr wieder Mal Feuer und Flamme für etwas oder jemanden seid.",ep:0,g:263,l:41,wd:false,fm:true,w:10,an:0,s:162,p:4553};
I.u[11056] = {n:"Zapfentann Mantel",t:17,d:"Wenn es sehr heiß ist, öffnen sich die Schuppen dieses Umhangs, um eure Transpiration zu verringern. Und wenn es regnet, öffnen sie sich ebenfalls, um problemloses Duschen zu ermöglichen. Das nennt man einen geregelten natürlichen Wasserhaushalt.",ep:0,g:178,l:42,wd:false,fm:true,w:10,an:0,s:162,p:4875};
I.u[11057] = {n:"Zapfentann Gürtel",t:10,d:"Die Schuppen dieses Gürtels folgen interessanterweise einer Anordnung gemäß der Fiberonacci-Reihe.",ep:0,g:174,l:40,wd:false,fm:true,w:10,an:0,s:162,p:4305};
I.u[11058] = {n:"Zapfentann Ring",t:9,d:"Wen wolltet ihr bloß mit einem derartigen Ring verführen? Eichhörnchen?",ep:0,g:189,l:43,wd:false,fm:true,w:10,an:0,s:162,p:5100};
