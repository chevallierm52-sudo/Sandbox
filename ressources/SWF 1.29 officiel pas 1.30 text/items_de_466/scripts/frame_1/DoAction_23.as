I.u[11100] = {n:"Geschenk: Abhandlung über den Ursprung Goultards",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11102] = {n:"Schneeweiß",t:35,d:"Trotz ihres zerbrechlichen Aussehens hat sich diese Pflanze gut an das Klima von Frigost angepasst. Auf Sorgfalt beim Pflücken ist jedoch zu achten, damit die alchimistische Wirkung der seltenen Pflanze erhalten bleibt!",ep:0,g:635,l:100,wd:false,fm:true,w:1,p:0};
I.u[11103] = {n:"Sack voller Schneeweiß",t:100,d:"Dieser gewaltige Sack enthält eine große Menge Schneeweiß.",ep:0,g:57,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11104] = {n:"Verbesserter Quark-Quak",t:18,d:"Das Quark-Quak ist der ungeschlagene Meister der Dummheit. Schlimmer noch als der Tofu, der Fresssack oder gar der Iop...",ep:0,g:8,l:1,wd:true,fm:false,w:10,c:"PZ=1",p:1};
I.u[11105] = {n:"Verbesserter Quark-Quak - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[11106] = {n:"Eisfisch",t:41,d:"Seine Gräten sind so scharf, wie die Klingen des Bworkers, die Schuppen so dick, wie die Rinde von Weich-Eich und die Augen schwärzer als das Gefieder von Meister Rab! Dieser Fisch sieht wirklich furchterregend aus, aber schmeckt dafür gekocht oder gedünstet umso besser.",ep:0,g:403,l:100,wd:false,fm:true,w:1,p:100};
I.u[11107] = {n:"Zitterpappel-Holz",t:38,d:"Dieses Holzstück scheint bei jeder Berührung zu zittern. Aber das ist ja auch kein Wunder bei all den Axthieben, die ihr zum Fällen des Baumes benötigt habt!",ep:0,g:677,l:100,wd:false,fm:true,w:5,p:100};
I.u[11109] = {n:"Frostizz",t:34,d:"Diese Getreidesorte ist wirklich einzigartig. Sie widersteht nicht nur dem extremen Klima von Frigost, sondern gibt eingetaucht in MiMilch dieser auch noch einen feinen Schokoladengeschmack.",ep:0,g:552,l:100,wd:false,fm:true,w:1,p:100};
I.u[11110] = {n:"Obsidian",t:39,d:"Dieses Gestein ist hart genug, um Glas zu ritzen und es ist so düster, dass ihr beim längeren Anblick in Depressionen verfallt. Sprich, es ist das ideale Material für einen Grabstein!",ep:0,g:90,l:100,wd:false,fm:true,w:5,p:0};
I.u[11111] = {n:"Sack voller Eisfische",t:100,d:"Dieser gewaltige Sack enthält eine große Menge Eisfische.",ep:0,g:59,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11112] = {n:"Sack voller Zitterpappeln",t:100,d:"Dieser gewaltige Sack enthält eine große Menge Zitterpappelholz.",ep:0,g:58,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11113] = {n:"Sack voller Frostizz",t:100,d:"Dieser gewaltige Sack enthält eine große Menge Frostizz.",ep:0,g:60,l:1,wd:false,fm:true,w:50,u:true,p:100};
I.u[11114] = {n:"Sack voller Obsidian",t:100,d:"Dieser gewaltige Sack enthält eine große Menge Obsidian.",ep:0,g:34,l:1,wd:false,fm:true,w:250,u:true,p:100};
I.u[11115] = {n:"Aperirel Uridnac-Fisch",t:30,d:"Der Frühling ist da, du kannst ihn riechen. Nun, es ist entweder der Frühling, oder der faulige Uridnac, der sich an deinen Rücken geheftet hat.",ep:0,g:1,l:1,wd:false,fm:false,w:0,m:true,p:0};
I.u[11116] = {n:"Uridnac",t:94,d:"Dieser kleine Fisch ist dem Menschen sehr zugetan und schließt sich ihnen gerne an. Allerdings hat er einen besonderen biologischen Rhytmus: Er ist nur aktiv, wenn die Sonnenstrahlen des Aperiels das frische Wasser erwärmen, in dem er lebt.",ep:0,g:19,l:1,wd:false,fm:false,w:1,c:"SG=3&POX11115",u:true,ut:true,p:0};
I.u[11117] = {n:"Fressmut-Wolle",t:57,d:"Fressmuts sollte man einmal jährlich scheren, genau wie die Achselhaare der Bitoufs.",ep:0,g:211,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11118] = {n:"Fressmut-Schlüsselbein",t:47,d:"Versucht erst gar nicht, diesen Knochen abzunagen. Es befindet sich nicht mehr das kleinste Stückchen Fleisch daran.",ep:0,g:660,l:105,wd:false,fm:true,w:1,an:0,p:10};
I.u[11119] = {n:"Ohr eines Fressmütchens",t:106,d:"Frigostianer verspeisen diese Ohren meist mit viel Vinaigrette. Die Ohren an sich schmecken nämlich nach wenig, während Vinaigrette viele leckere Geschmacksstoffe enthält!",ep:0,g:624,l:96,wd:false,fm:true,w:10,p:1};
I.u[11120] = {n:"Leder eines Fressmütchens",t:56,d:"Es heißt, dass das Leder so weich sei, dass es bereits nach 8-maligem Kochen essbar wäre. Jedenfalls lieben es die Frigostianern naiven Abenteurern vom Festland derartige Geschichten aufzutischen.",ep:0,g:534,l:96,wd:false,fm:true,w:10,p:1};
I.u[11121] = {n:"Auge eines Fressmut-Anführers",t:109,d:"Dieses Auge hat sich einst am Anblick prächtiger Fressmut-Weibchen erfreut. Nun erblickt es nur noch das Innere eurer Hosentasche. Das Ärmste!",ep:0,g:590,l:112,wd:false,fm:true,w:10,p:1};
I.u[11122] = {n:"Horn eines Fressmut-Anführers",t:47,d:"Schlafende Kriegsfressmuts wurden manchmal von den tollkühnsten jugendlichen Frigostianern als Spielzeug missbraucht. Sie versuchen 3 Metallringe verschiedener Größen über die Hörner zu werfen, ohne das Fressmut aufzuwecken. Überraschenderweise hat es noch niemand bisher geschafft, das Spiel lebend zu beenden.",ep:0,g:661,l:112,wd:false,fm:true,w:10,p:1};
I.u[11123] = {n:"Weisheitszahn eines Fressmuts",t:24,d:"Diesen Zahn habt ihr einem lebendigen Fressmut ausgerissen. Was mag bloß in den Köpfen von Abenteurern wie euch vorgehen?!?",ep:0,g:822,l:1,wd:false,fm:true,w:0,p:1};
I.u[11124] = {n:"Tiefgefrorene Eingeweide",t:24,d:"Eingeweide aus der ursprünglichen Körperhöhle entfernt, schon war sie tiefgefroren!",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11125] = {n:"Ping\'nes Füßchen",t:24,d:"Er war schon nicht allzu geschickt mit seinen Armen. Aber jetzt, mit nur noch einem Füßchen ist dieser Ping doppelt gestraft!",ep:0,g:823,l:1,wd:false,fm:true,w:0,p:1};
I.u[11126] = {n:"Ätherischer Schädel",t:24,d:"Wie kann ein Schädel ätherisch werden? Bei genauerer Überlegung kommt ihr zum Ergebnis, dass dies eigentlich völlig belanglos ist.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11127] = {n:"Träne der See",t:24,d:"Diese Träne mit extra hohem Salzgehalt ist ein Symbol für das Erreichen seiner langfristigen Ziele durch stetigen Widerstand!",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11128] = {n:"Magmatische Träne",t:24,d:"Diese Träne benetzt zwar nicht, verbrennt jedoch alles, womit sie in Berührung kommt. Das kann ein wenig unpraktisch sein, wenn ihr mal wieder schnell ein paar falsche Tränchen ausdrücken möchtet.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
