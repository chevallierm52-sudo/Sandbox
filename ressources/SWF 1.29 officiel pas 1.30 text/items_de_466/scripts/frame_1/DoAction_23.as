I.u[10784] = {n:"Anfänger-Amulett",t:1,d:"Niemand kann sagen, wie ihr zu diesem Amulett gekommen seid, aber eines wissen alle: es geht jede Glaubwürdigkeit den Bach hinunter.",ep:0,g:163,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10785] = {n:"Anfänger-Ring",t:9,d:"Dieser Ring wird eure Finger vor den Nasenpopeln eurer Gegner bewahren!",ep:0,g:190,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10786] = {n:"Haut eines unreifen Koalaks",t:24,d:"Der kleine unreife Koalak war nicht damit einverstanden, euch seine Haut zu überlassen. Doch störte euch das herzlich wenig, da ihr viel grausamer und auch viel stärker seid als er...",ep:20,g:811,l:1,wd:true,fm:true,w:1,p:10};
I.u[10787] = {n:"Flügel eines wilden, roten Dracotruters",t:24,d:"Dieser Flügel riecht nach Schwefel. Doch laut erfahrenen Züchtern ist dies das beste Stück für ein Barbecue. Einfach mit scharfen Gewürzen bestreuen und schon stört der Schwefelgeruch auch nicht mehr.",ep:2,g:812,l:29,wd:true,fm:true,w:1,p:1};
I.u[10788] = {n:"Dracotruterflügel",t:24,d:"Es ist definitiv wahr, dass das Fleisch gezähmter Dracotruter deutlich besser schmeckt, als das der Wilden. Es ist süßlicher und hat nicht diesen widerlichen Schwefelabgang.",ep:2,g:813,l:29,wd:true,fm:true,w:1,p:1};
I.u[10789] = {n:"Kratzende Haare eines Koalak-Försters",t:24,d:"Diese Haare sind mit Kalyptus-Harz übersäht, was ihnen einen wunderschönen Glanz verleiht. Leider sind sie in der Haute Couture wegen ihres schrecklichen Geruchs nach totem Dracotruter unbrauchbar.",ep:20,g:814,l:1,wd:true,fm:true,w:1,p:100};
I.u[10790] = {n:"Knochen einer Koalak-Mama",t:24,d:"Eine Koalak-Mama besitzt extrem stabile Knochen. Das ist auch nötig, damit sie ihrem eigenen Gewicht standhalten kann. Doch sollte man ihr besser nicht ins Gesicht sagen, dass sie einen schweren Knochenbau hat...",ep:20,g:815,l:1,wd:true,fm:true,w:1,p:10};
I.u[10791] = {n:"Barthaare eines braunen Warkos",t:24,d:"Diese Haare sind von Nesselkapselzellen übersäht, wodurch selbst der leichteste Kuss des braunen Warkos einem Angiff mit einer Massenvernichtungswaffe gleichkommt.",ep:20,g:816,l:1,wd:true,fm:true,w:1,p:10};
I.u[10792] = {n:"Anfänger-Heiltrank",t:12,d:"Dieser Behälter diente einst zur Abgabe von Urinproben. Aber nun hat er eine neue Bestimmung gefunden: die Aufnahme von laborgeprüften Flüssigkeiten zur Verbesserung des allgemeinen Gesundheitszustandes. Laien, die es nicht besser wissen, sagen auch manchmal \'Heiltrank\' dazu.",ep:0,g:2,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10793] = {n:"Anfänger-Brot",t:33,d:"Es ist trocken, tut an den Zähnen weh und riecht nach Bwork-Unterhosen aber man kann damit Lebenspunkte zurückgewinnen. Jetzt habt euch nicht so.",ep:0,g:6,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10794] = {n:"Anfänger-Stiefel",t:11,d:"Diese Stiefel sind innen stets warm und außen stets kalt. Deswegen sind sie ideal zum Verprügeln von Weißnachtsmännern.",ep:0,g:2,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10795] = {n:"Anfänger-Fisch",t:49,d:"Dieser Fisch hat auch einmal klein angefangen. Nun nimmt sein Anfang jedoch ein jähes Ende und euch bleibt ein guter Fang!",ep:0,g:92,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10796] = {n:"Anfänger-Frikadelle",t:69,d:"Dieser gewürzte Fleischklops vereint in sich alles, was in ganz Amakna unverdaulich ist, aber es schmeckt zu gut und euer Körper will mehr davon.",ep:0,g:113,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[10797] = {n:"Anfänger-Schwert",t:6,d:"Ein Anfänger-Schwert beweist, dass nicht immer aller Anfang schwer sein muss. Denn für ein Schwert ist diese Waffe schon ganz schön weit fortgeschritten...bloss mit dem Tranchieren von Monstern hat es noch ein wenig Schwierigkeiten.",ep:0,g:96,l:1,wd:false,fm:true,w:1,an:14,e:[5,4,1,1,40,50,false,false],s:150,p:1};
I.u[10798] = {n:"Anfänger-Schild",t:82,d:"Dieser Schild schützt vor eurer Torheit nicht.",ep:0,g:55,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10799] = {n:"Anfänger-Gürtel",t:10,d:"Passt euer Dolch nicht in die Unterhose? Kein Problem. Klemmt ihn einfach zwischen euren Speckröllchen und diesem Gürtel hier fest.",ep:0,g:10,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10800] = {n:"Anfänger-Umhang",t:17,d:"Mit diesem Umhang könnt ihr fliegen! Dazu braucht ihr nur eure Augen zu schließen, eure Fäuste zu ballen, den Mund zu öffnen und mit ausgebreiteten Armen von einem Felsen zu springen und zu schreien: \"Ich fliege!\" Wundert euch dann aber nicht, wenn ihr mit gebrochenen Beinen aufwacht.",ep:0,g:3,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10801] = {n:"Anfänger-Hut",t:16,d:"Dieser Hut versteckt prächtig euren beginnenden Haarausfall. Aber eure falsche Bescheidenheit könnt ihr euch wirklich an den Hut stecken!",ep:0,g:264,l:1,wd:false,fm:true,w:1,s:150,p:1};
I.u[10802] = {n:"Goldener Dragooner",t:18,d:"Er ist goldener als der Schwarze Dragooner, weniger rosa als der Rosa Dragooner und noch seltener als der Skelett-Dragooner! Bei diesem Vertrauten bleiben neidische Blicke nicht aus...  \nDieser Vertraute gehört zu den Seelenfressern und ernährt sich von den Seelen der Klassendubbel (aus den Klassentempeln).",ep:0,g:57,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:151,p:1};
I.u[10803] = {n:"",t:32,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10804] = {n:"Geschenk: Goldener Dragooner",t:89,d:"Beim Schütteln dieses Geschenkpaketes könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10805] = {n:"Goldene Dragooner Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10806] = {n:"Tierheimzertifikat: Goldener Dragooner",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10807] = {n:"Goldener Dragooner - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10808] = {n:"Goldenes Dragooner Hormon",t:48,d:"Mit diesem getrockneten Wachstumshormon kann man einen kraftvollen Trank zum Verbessern eines Vertrauten herstellen.",ep:0,g:240,l:1,wd:true,fm:true,w:1,p:10};
I.u[10809] = {n:"Goldener Dragooner - Kräftigungstrank",t:116,d:"Wenn ihr diesen mächtigen Trank einsetzt, dann erhöht ihr die Fähigkeiten eures Vertrauten definitiv. Achtung, es wird nur eine einzige Dosis pro Vertrauten angerechnet, mehrere Versuche führen zu enttäuschenden Ergebnissen.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PO=10802",u:true,p:10};
I.u[10810] = {n:"Hormon des Orgrinenjägers",t:48,d:"Mit diesem getrockneten Wachstumshormon kann man einen kraftvollen Trank zum Verbessern eines Vertrauten herstellen.",ep:0,g:234,l:1,wd:false,fm:true,w:1,p:10};
I.u[10811] = {n:"Ogrinenjäger-Kräftigungstrank",t:116,d:"Wenn ihr diesen mächtigen Trank einsetzt, dann erhöht ihr die Fähigkeiten eures Vertrauten definitiv. Achtung, es wird nur eine einzige Dosis pro Vertrauten angerechnet, mehrere Versuche führen zu enttäuschenden Ergebnissen.",ep:0,g:54,l:1,wd:true,fm:true,w:1,c:"PO=10657",u:true,p:10};
I.u[10812] = {n:"Anonymer Brief",t:24,d:"\"Suchst du gut bezahlte Arbeit und schnell verdientes Geld? Wenn ja, dann wirst du im Norden der Stadt fündig und zwar östlich der Sram-Statue. Komm allein!\"",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10813] = {n:"Namensliste",t:24,d:"Diese Namensliste habt ihr in Pandale Smoins Haus gefunden. Anscheinend handelt es sich bei allen aufgelisteten Namen um Pandawas.",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10814] = {n:"Kiste für Pandkreiden",t:24,d:"Diese Kiste sollt ihr zu Pandkreiden nach Akwadala bringen. Der Inhalt wurde euch nicht offenbart und ist streng geheim.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10815] = {n:"Seltsame Flüssigkeit",t:24,d:"Itze Dawa hat euch gebeten, diese Flüssigkeit zu Magus X zu bringen, damit er sie analysiert.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[10816] = {n:"Verwelktes Dämonenrosenblütenblatt",t:24,d:"Dieses Blütenblatt hat seinen Glanz eingebüßt und seine Oberfläche ähnelt nun der Haut eines jung gebliebenen Enutrofs.",ep:0,g:817,l:1,wd:false,fm:true,w:0,p:1};
I.u[10817] = {n:"Anti-Sucht-Mittel",t:24,d:"Dieser Prototyp eines neuen Anti-Sucht-Mittels sollte sogar in der Lage sein, schwere Fälle von Morph-Saft-Abhängigkeit zu kurieren.",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[10818] = {n:"Anfänger-Axt",t:19,d:"Mit dieser praktischen Axt fühlt ihr euch gleich wie ein kampferprobter Veteran.",ep:0,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
