I.u[10899] = {n:"Manitu Zoth Stock",t:4,d:"Manitu Zoth, der Manuskripteleser war ein As in der Disziplin Probleme zu verschieben anstatt sie zu lösen. Deswegen war er bei der Zoth-Gemeinschaft auch sehr gefürchtet. Nach Zoth-Art folgte er den beiden Leitsätzen: Chef hat immer Recht und der lauteteste Schreizoth gewinnt. Nach seinem Tode blieb ein Teil seiner Zothigen Seele in diesem Stock hängen. Bei Anlegen der Waffe macht sich das bemerkbar...",ep:0,g:91,l:50,wd:false,fm:false,w:10,an:12,e:[5,3,1,1,40,50,false,false],p:6000};
I.u[10900] = {n:"Schalensplitter",t:24,d:"In euren Händen haltet ihr den kümmerlichen Rest von einer dieser riesigen Eierschalten der Drachei-Halbinsel. Fast groß genug, um als Untersetzer zu dienen.",ep:0,g:767,l:1,wd:false,fm:true,w:0,p:0};
I.u[10901] = {n:"Riesenfangzahn",t:24,d:"Grasmera und Grozilla haben sich sicherlich in einem Zweikampf ohnegleichen gegenseitig niedergemacht, und dabei wird einem der beiden wohl dieser Fangzahn ausgeschlagen worden sein. Probiert besser erst gar nicht, anzudeuten ihr wärt dabei gewesen - das wird euch eh niemand abkaufen!",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:0};
I.u[10902] = {n:"Manitu Zoths Unterhose",t:24,d:"Jetzt ist es offiziell: Manitu Zoth ist unter seinem Lendenschurz nackig.",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10903] = {n:"Schlüssel zum Unterschlupf von Manitu Zoth",t:24,d:"Mit diesem Schlüssel könnt ihr Manitu Zoth entgegentreten.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[10904] = {n:"Grozillamulett",t:1,d:"Dieses Amulett bezeugt eure unwiderlegbare Fähigkeit Eier zu zerschlagen ohne Omeletts zu machen.",ep:0,g:157,l:51,wd:false,fm:true,w:10,p:7050};
I.u[10906] = {n:"Schuppenschild",t:82,d:"Dieser schwere Schild wurde aus einer Schuppe von Grozilla angefertigt und ist aussergewöhnlich stattlich. Nur einige wenige furchterregende Krieger tragen ihn stolz zur Schau.",ep:0,g:51,l:1,wd:false,fm:false,w:10,p:0};
I.u[10907] = {n:"",t:23,d:"",ep:0,g:17,l:1,wd:false,fm:true,w:10,p:0};
I.u[10908] = {n:"Beta-Test DOFUS 2.0 Dungeon Geschenk",t:89,d:"Ihr bekommt dieses Geschenk, weil ihr mehr Zeit in den Dungeons des DOFUS 2.0 Beta-Tests verbracht habt, als jeder gewöhnliche Sterbliche.",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10909] = {n:"Tofu-Pheromon",t:48,d:"Diese getrocknete Pheromonpulver könnte einen Tofu aus kilometerweiter Entfernung anziehen, wenn eure eigenen Pheromone ihn nicht ersticken würden.",ep:0,g:241,l:1,wd:false,fm:true,w:1,p:1};
I.u[10910] = {n:"DOFUS 2.0 Collector Geschenkpaket",t:89,d:"Dieses Set macht aus euch eine echte Leuchte, aber ihr dürft keinen Mucks von euch geben. Ansonsten könnt ihr damit immer noch die Einwohner Astrubs beeindrucken.",ep:0,g:42,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10911] = {n:"M. Sko-Tis Rückruftrank",t:12,d:"Er ist nicht nur doppelt so cremig wie ein herkömmlicher Rückruftrank, sondern \"M. Sko-Tis Rückruftrank\" ist auch der einzige Trank, der es euch ermöglicht, euch von jedem beliebigen Ort der Welt der Zwölf zum Zaap von Astrub zu teleportieren! Der Doppel-Effekt führt dazu, dass die Wirkung des Tranks lange..., sehr lange...., ja, wirklich sehr sehr lange anhält! \nKleingedrucktes: \"M. Sko-Tis Rückruftrank\" ist urheberrechtlich geschütztes Markenzeichen der Firma Körk & Spuky.\"",ep:0,g:26,l:1,wd:false,fm:false,w:0,c:"Sc=666",u:true,p:0};
I.u[10912] = {n:"Lächerliches Weißnachtsgeschenk",t:89,d:"Weißnachtsgeschenke haben nicht alle die gleiche Grösse. Nicht gerade mutige Abenteurer bekommen lächerliche Geschenke, sowie eine Runde Auslachen und eine Lizens zum Weinen.",ep:0,g:2,l:6,wd:false,fm:true,w:10,u:true,p:1};
I.u[10913] = {n:"Annehmbares Weißnachtsgeschenk",t:89,d:"Wer immer sich dieses Geschenk ausgedacht hat, bildet sich gross was ein, denn er ist davon überzeugt, dass sein Inhalt annehmbar sei. ",ep:0,g:2,l:7,wd:false,fm:true,w:20,u:true,p:1};
I.u[10914] = {n:"Eventuell übermächtiges Weißnachtsgeschenk",t:89,d:"Wenn man dem, was auf dem Stoffschleifchen steht Glauben schenken mag, dann hat dieses Geschenk das Zeug zum übermächtigen Inhalt. Allerdings werden es euch alle erfahrenen Abenteurer sagen: man sollte niemals glauben, was auf Stoffschleifen steht.",ep:0,g:2,l:8,wd:false,fm:true,w:30,u:true,p:1};
I.u[10915] = {n:"Missionsbefehl von Harry Kwismas",t:24,d:"Harry Kwismas hat euch die Identität eines der Einbrecher aus dem Lagerhaus des Weißnachtsmanns verraten. Wenn ihr diesen nicht innerhalb von 2 Stunden besiegt, könnt ihr, wenn ihr wollt, zu Harry Kwismas zurück gehen und eine neue Mission verlangen.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10916] = {n:"Glückwünsche von Harry Kwismas",t:24,d:"Harry Kwismas freut sich sehr über euren Erfolg. Kehrt in 24 Stunden wieder zu ihm zurück, denn wenn nicht alle Pakete bis dahin zurückgekommen sind, wird er eure Hilfe brauchen.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10917] = {n:"Kleines Geschenkpaket",t:24,d:"Dieses kleine Paket stammt aus dem Lagerhaus des Weißnachtsmanns. Bringt es zum rechtmässigen Besitzter zurück und ihr seid ein Held.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10918] = {n:"Geschenkpaket",t:24,d:"Dieses Paket stammt aus dem Lagerhaus des Weißnachtsmanns. Bringt es zum rechtmässigen Besitzter zurück und ihr seid ein Held.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10919] = {n:"Grosses Geschenkpaket",t:24,d:"Dieses grosse Paket stammt aus dem Lagerhaus des Weißnachtsmanns. Bringt es zum rechtmässigen Besitzter zurück und ihr seid ein Held.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10920] = {n:"Weißnachtsplätzchen",t:24,d:"Dies sind mit viel Liebe gebackene Plätzchen. Schade, dass ihr sie nicht probieren könnt.",ep:0,g:245,l:1,wd:false,fm:true,w:0,p:1};
I.u[10921] = {n:"Versiegeltes Geschenk des Minotoballs",t:24,d:"Niemand weiss, was in diesem Geschenk drin ist, denn der  Minotoball hat das Geheimnis mit ins Grab getragen. Ihr wisst, dass dies eure Schuld ist? Ihr hättet besser ein ruhige Kugel geschoben.",ep:0,g:715,l:1,wd:false,fm:true,w:0,p:1};
