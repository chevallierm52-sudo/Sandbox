I.u[10825] = {n:"Ghulifiziert",t:30,d:"War das nun wirklich den ganzen Aufwand wert?",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10826] = {n:"Ausschluss-Mitteilung",t:24,d:"Da ihr euch nicht an die Hausregeln eures Gastgebers gehalten habt, hat dieser beschlossen, euch für die nächsten 24 Stunden aus seiner Krypta auszuschließen.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:0};
I.u[10827] = {n:"Larvatiger Heiltrank",t:12,d:"Eine orangefarbene Flüssigkeit, in der Bläschen aufsteigen? Wer in aller Welt würde so etwas trinken?",ep:0,g:192,l:1,wd:true,fm:true,w:1,c:"Sc=7",u:true,ut:true,p:0};
I.u[10828] = {n:"Fressballkappe",t:16,d:"Es heisst ja immer Lächerlichkeit sei nicht tödlich. Dann ist es auch kein Wunder, dass ihr keinem Fresssäckchen etwas zu leide tun könnt, so lächerlich wie ihr mit dieser Kappe ausseht!",ep:0,g:253,l:29,wd:false,fm:true,w:10,c:"Sc=10",p:2400};
I.u[10829] = {n:"Kamangel",t:20,d:"Dank dieser Angel werdet ihr beim  immer die Oberhand haben.",ep:0,g:91,l:40,wd:false,fm:true,w:10,an:12,e:[7,3,1,1,40,50,false,false],c:"Sc=13",p:4200};
I.u[10830] = {n:"Banana Cape",t:17,d:"Ikko, ein bekannter Künstler aus Amakna war einer der Ersten, der es wagte, diesen Umhang in der Öffentlichkeit zu tragen.",ep:0,g:172,l:28,wd:false,fm:true,w:10,c:"Sc=14",p:2305};
I.u[10831] = {n:"Bananananas",t:46,d:"Egal, ob flambiert oder in Scheiben, natur oder mit Schokoladensauce übergossen. Das Bananananas ist einfach herrlich fruchtig!",ep:0,g:1,l:1,wd:true,fm:true,w:1,p:1};
I.u[10832] = {n:"Krachlostein",t:94,d:"Dieser geschliffene Stein beherbergt einen eher ungeschliffenen Krachlklotz. Der Stein scheint nur in der Nähe von Krachlern oder Krachlklötzen zu funktionieren...",ep:0,g:18,l:1,wd:false,fm:true,w:20,c:"Sc=15&(PB=2|PB=96|PB=480)",u:true,p:0};
I.u[10833] = {n:"Maunzebrot",t:33,d:"Dieses Brot ist wirklich absonderlich. Beisst man hinein, miaut es!",ep:0,g:4,l:1,wd:false,fm:true,w:2,c:"Sc=16",u:true,ut:true,p:0};
I.u[10834] = {n:"Hutinak",t:16,d:"Die Ähnlichkeit mit einem Ouginak ist einfach verblüffend, wenn ihr diesen Hut tragt. Passt auf Flöhe auf!",ep:0,g:256,l:11,wd:false,fm:true,w:10,c:"Sc=17",p:530};
I.u[10835] = {n:"Neulingsstein",t:50,d:"Ihr wurdet zerrieben, gequetscht, geklopft, gewaschen, gebügelt und getrocknet und seid nun bis auf eure blauen Flecken blütenweiss.",ep:0,g:707,l:1,wd:false,fm:true,w:1,p:0};
I.u[10836] = {n:"Fressbamu",t:1,d:"So, ihr tragt also voller Stolz das Fressbamu? Naja, da kann man nur sagen, dass es berechtigt ist. Bei eurer Teilnahme an diesem großen sportlichen Wettkampf habt ihr schließlich das Gedränge gegen den B.C.Trool mit nur minimalen Gliedmaßenverlusten überlebt!",ep:0,g:158,l:64,wd:false,fm:true,w:1,c:"Sc=18",p:11765};
I.u[10838] = {n:"Orange-Imagina",t:30,d:"Und wieder einmal habt ihr etwas getrunken, ohne zu wissen, was darin war... wie leichtsinnig!",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:0};
I.u[10839] = {n:"Monsterbrot",t:33,d:"Es heißt, manches Brot sei so hart, dass man sich im wahrsten Sinne die Zähne daran ausbeißen könne. Dieses Exemplar ist ein gutes Beispiel dafür!",ep:0,g:12,l:1,wd:false,fm:true,w:100,c:"Sc=8",u:true,p:0};
I.u[10840] = {n:"Essbares Monsterbrot",t:33,d:"Dieses Exemplar ist viel schmackhafter! Guten Appetit!",ep:0,g:12,l:1,wd:true,fm:true,w:1,c:"Sc=8",u:true,ut:true,p:0};
I.u[10841] = {n:"Bräune",t:30,d:"Hat euch etwa niemand über die Nebenwirkungen aufgeklärt?!",ep:0,g:1,l:1,wd:true,fm:true,w:0,m:true,p:0};
I.u[10842] = {n:"Maunzmiez-Verwandlung",t:31,d:"Eines Tages musste es ja so kommen! Beschwert euch nicht, wenn ihr den Geschmack von Tofufedern nie wieder los werdet!",ep:0,g:21,l:1,wd:false,fm:false,w:0,m:true,c:"Sc=16",p:0};
I.u[10843] = {n:"Notiz zum Thema: Krtek",t:24,d:"Auf diesen Notizzettel habt ihr vermerkt, um wieviel Uhr Krtek das letzte Mal vermöbelt wurde. So wisst ihr genau, um wieviel Uhr es wieder Zeit für seine nächste Tracht Prügel wird.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10844] = {n:"Mmmmm",t:31,d:"Mmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:0,g:19,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[10845] = {n:"",t:12,d:"",ep:0,g:716,l:1,wd:false,fm:false,w:0,u:true,ut:true,p:1};
I.u[10846] = {n:"Phero-Cape",t:17,d:"Von einer seltsamen Raserei ergriffen, reiben sich alle Tofus denen ihr begegnet an eurem Bein. Das wird doch nicht etwa an diesem Cape liegen, das sie anzieht?",ep:0,g:173,l:61,wd:false,fm:true,w:10,c:"Sc=19",p:9700};
I.u[10847] = {n:"Lerkstim-Stiefel",t:11,d:"Für Lerkstim wirkten diese Stiefel sehr stimulierend. Er brauchte sie nämlich nur einmal pro Jahr anzuziehen, um sie täglich ausziehen zu können. Eindeutig magisch!",ep:0,g:151,l:53,wd:true,fm:true,w:10,s:152,p:7400};
I.u[10848] = {n:"A.M.Boss Stiefel",t:11,d:"Diese koketten Stiefel sehen nicht nicht nur schick aus, sondern enthalten sogar einen eingravierten goldenen Amboss. So könnt ihr ohne viel Worte aller Welt beweisen, dass ihr am Hammer der Boss seid!",ep:0,g:152,l:52,wd:false,fm:true,w:10,s:153,p:7175};
I.u[10849] = {n:"Lerkstim-Gürtel",t:10,d:"Der Gürtel besteht aus einem seltsamen Metall. Dank magnetischer Eigenschaften zieht es die Geldbörsen all der Unvorsichtigen an, die sich dem Gürtel zu sehr genähert haben.",ep:0,g:169,l:51,wd:true,fm:true,w:10,s:152,p:6825};
I.u[10850] = {n:"A.M.Boss Gürtel",t:10,d:"A.M.Boss hatte nur drei Schwächen überhaupt.  \nErstens: Gekitzelt werden.  \nZweitens: Arachneen.  \nDrittens: Von Arachneen gekitzelt werden!",ep:0,g:167,l:52,wd:false,fm:true,w:10,s:153,p:7100};
I.u[10851] = {n:"Äkebäker-Gürtel",t:10,d:"Der Gürtel ist immer noch mit etwas Mehl bedeckt. Vielleicht daher, weil ihn Äkebäker, der Schattenbäcker als Schütze benutzte? Vielleicht ist das Weiße aber auch gar kein Mehl...",ep:0,g:168,l:51,wd:false,fm:true,w:10,s:154,p:6928};
I.u[10852] = {n:"Lerkstim-Amulett",t:1,d:"Lerkstim klaute einst dieses Amulett von Stopfert, einem kleinen Goblin ohne Sinn für Humor.",ep:0,g:156,l:53,wd:true,fm:true,w:10,s:152,p:7405};
I.u[10853] = {n:"Äkebäker-Amulett",t:1,d:"Danke dieses Amulettes habt ihr immer ein Ersatznudelholz zur Hand, sollte euer Hauptnudelholz beim Niederprügeln des hochalkoholisierten Ehepartners zu spätnächtlicher Stunde den Geist aufgeben.",ep:0,g:155,l:53,wd:false,fm:true,w:10,s:154,p:7400};
I.u[10854] = {n:"A.M.Boss Ring",t:9,d:"Ambrosius Merlinbimbus Boss, der Schattenschmied war einst verblendet genug, diesen tollen Ring gegen ein Schwert von Adam Antin einzutauschen. Bis heute unverständlich...",ep:0,g:183,l:54,wd:false,fm:true,w:10,s:153,p:7650};
I.u[10855] = {n:"Äkebäker-Ring",t:9,d:"Dieser Ring wurde mit einer Vielzahl von Hefekulturen imprägniert. Darum soll er die Macht haben, den Träger anschimmeln zu lassen. Doch einige unerschütterliche Abenteurer scheint dies nicht abzuschrecken...",ep:0,g:184,l:51,wd:false,fm:true,w:10,s:154,p:6975};
I.u[10856] = {n:"Lerkstim-Axt",t:19,d:"Lerkstim war ein viel zu gutmütiger Bandit. Nach einem erfolgreichen Überfall hatte er meist so schlechtes Gewissen, dass er die Beute gleich wieder zurückgab. Ein Teil der Seele des Banditen blieb in dieser Axt hängen. Bei Anlegen der Waffe macht sich das bemerkbar...",ep:0,g:58,l:47,wd:true,fm:false,w:10,an:17,e:[5,4,1,1,40,50,false,false],s:152,p:5900};
I.u[10857] = {n:"A.M.Boss Hammer",t:7,d:"Mit diesem Hammer hat A.M.Boss einst dem für seine Heimtücke gefürchteten Chafer-Offizier einen Reißverschluss aus reinstem Kryptonit geschmiedet Ein Teil der Seele des Schattenschmiedes blieb noch im Hammer hängen. Bei Anlegen der Waffe macht sich das bemerkbar...",ep:0,g:724,l:51,wd:false,fm:false,w:10,an:15,e:[5,4,1,1,40,50,false,false],s:153,p:7000};
I.u[10858] = {n:"Äkebäker-Stab",t:3,d:"Äkebäker, der Schattenbäcker liebte es, Horden von Abenteurern mit diesem Stab zu beglücken und kräftig auszuteilen. Nach seinem Tode blieb ein Teil der Seele des Schattenbäckers in diesem Stab hängen. Bei Anlegen der Waffe macht sich das bemerkbar...",ep:0,g:73,l:53,wd:false,fm:false,w:10,an:11,e:[5,4,3,5,50,50,false,false],s:154,p:5000};
I.u[10860] = {n:"Trank der Namensänderung",t:12,d:"Mit diesem Trank könnt ihr euren Namen ändern. Niemand wird sich mehr daran erinnern, dass ihr Xx-Roxxor-naruto-killer-féca-xX geheissen habt. Ein neues Leben ohne Hänseleien steht euch bevor, endlich werdet ihr Jemand sein.",ep:0,g:718,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10861] = {n:"Trank zur Farbveränderung",t:12,d:"Rosa Haare, lila Socken, malvenfarbene Haut;\r\n            die Natur hat euch vielleicht nicht gerade gesegnet, aber nun könnt ihr dem Abhilfe schaffen. Nun könnt ihr popelgrün durchs Leben gehen.",ep:0,g:717,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10862] = {n:"Trank zur Geschlechtsumwandlung",t:12,d:"Dieser Trank wird direkt aus der Flasche getrunken und erlaubt euch aus einem er eine sie zu machen und umgekehrt. Darf ungemässigt genossen werden.",ep:0,g:719,l:1,wd:false,fm:true,w:0,u:true,p:0};
I.u[10863] = {n:"Arachnaille",t:18,d:"Diese Arachnee ist wirklich schlecht erzogen. Sie springt andere an, sie schreit, sie beisst alle außer euch. Dennoch könnt ihr euch aus unerfindlichen Gründen nicht von ihr trennen. Dieser Seelenfresser hat eine Vorliebe für schwächere Kreaturen und liebt es, Moskitos und Larven zu vernichten.",ep:0,g:58,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10864] = {n:"Pfefferling",t:18,d:"Dieser Pilzling wurde von einem Rudel wilder WuWulfs aufgezogen. Dennoch erklärt das nicht seine starke Behaarung. Dieser Seelenfresser hat eine Schwäche für Meeresfrüchte und frisst nur Strandkreaturen.",ep:0,g:59,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10865] = {n:"Blitzofu",t:18,d:"Dieser Tofu wurde in seiner Kindheit nicht weniger als 11 Mal vom Blitz getroffen. Darum verteilt er Stromschläge, wenn er gestreichelt wird und schießt mit Blitzen um sich, wenn keiner ihn streicheln will. Dieser Seelenfresser hasst Ratten und frisst sie, sobald er die Gegelenheit dazu hat.",ep:0,g:60,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10866] = {n:"Prespieks",t:18,d:"Dieser Vertraute hat eine Schwäche für Artischockenherzen auf Shilfblutbett, Chicorée mit Bitouf-Haaren und Liedern von Oh\'Nein. Er scheint ebenfalls eine Schwäche für euch zu haben... Dieser Seelenfresser frisst Kreaturen aus dem düsteren Dschungel.",ep:0,g:61,l:1,wd:true,fm:true,w:1,c:"PZ=1",p:1};
I.u[10867] = {n:"Arachnaille-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:57,l:1,wd:true,fm:true,w:1,p:1};
