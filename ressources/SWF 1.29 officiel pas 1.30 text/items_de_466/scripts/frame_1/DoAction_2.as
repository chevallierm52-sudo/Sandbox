I.u[901] = {n:"Ferkelchen-Leder",t:56,d:"Dieses glatte Leder färbt sich im Laufe der Zeit gelb, bis es irgendwann ocker ist. Ebenso verschlechtert sich im Laufe der Zeit auch sein Geruch. Beides hat es mit ein paar  berühmten Käsesorten gemein...",ep:1,g:141,l:18,wd:true,fm:true,w:1,p:1};
I.u[902] = {n:"Kleine Stiefel von R.Klimm",t:11,d:"Die Flinkheit, die er mit diesen Stiefeln erlangte, ermöglichte es dem Schuhmacher R.Klimm, problemlos auf den Rücken eines jeden Fresssackes zu klettern. Leider verstarb er ziemlich früh, weil er nach einer durchzechten Nacht in der Taverne einen Fresssack mit einem Gelee verwechselte.",ep:1,g:9,l:13,wd:true,fm:true,w:10,p:700};
I.u[903] = {n:"Stiefel von R.Klimm",t:11,d:"Die Flinkheit, die er mit diesen Stiefeln erlangte, ermöglichte es dem Schuhmacher R.Klimm, problemlos auf den Rücken eines jeden Fresssackes zu klettern. Leider verstarb er ziemlich früh, weil er nach einer durchzechten Nacht in der Taverne einen Fresssack mit einem Gelee verwechselte.",ep:1,g:9,l:17,wd:true,fm:true,w:10,p:950};
I.u[904] = {n:"Große Stiefel von R.Klimm",t:11,d:"Die Flinkheit, die er mit diesen Stiefeln erlangte, ermöglichte es dem Schuhmacher R.Klimm, problemlos auf den Rücken eines jeden Fresssackes zu klettern. Leider verstarb er ziemlich früh, weil er nach einer durchzechten Nacht in der Taverne einen Fresssack mit einem Gelee verwechselte.",ep:1,g:9,l:18,wd:true,fm:true,w:10,p:1100};
I.u[905] = {n:"Übermächtige Stiefel von R.Klimm",t:11,d:"Der Legende nach wurden diese Stiefel gegen andere, ebenfalls übermächtige, aber defekte Stiefel ausgetauscht, die von einem ungeschickten Schuhmacher nach vielen Monaten der Schlaflosigkeit angefertigt worden waren.",ep:1,g:9,l:41,wd:true,fm:true,w:10,p:4500};
I.u[906] = {n:"Kleine Stiefel der Verfolgung",t:11,d:"Diese Stiefel erlaubt es Hogmeiser, die einzigen Wesen Amaknas zu verfolgen, die er nicht ausstehen konnte, nämlich Kinder. Zum Glück für diese waren die Stiefel allerdings so schwer, dass er ihnen damit noch nicht mal einen Tritt in den Allerwertesten verpassen konnte.",ep:20,g:10,l:31,wd:true,fm:true,w:9,p:2700};
I.u[907] = {n:"Stiefel der Verfolgung",t:11,d:"Diese Stiefel erlaubt es Hogmeiser, die einzigen Wesen Amaknas zu verfolgen, die er nicht ausstehen konnte, nämlich Kinder. Zum Glück für diese waren die Stiefel allerdings so schwer, dass er ihnen damit noch nicht mal einen Tritt in den Allerwertesten verpassen konnte.",ep:20,g:10,l:34,wd:true,fm:true,w:10,p:3200};
I.u[908] = {n:"Große Stiefel der Verfolgung",t:11,d:"Diese Stiefel erlaubt es Hogmeiser, die einzigen Wesen Amaknas zu verfolgen, die er nicht ausstehen konnte, nämlich Kinder. Zum Glück für diese waren die Stiefel allerdings so schwer, dass er ihnen damit noch nicht mal einen Tritt in den Allerwertesten verpassen konnte.",ep:20,g:10,l:37,wd:true,fm:true,w:11,p:3700};
I.u[909] = {n:"Mächtige Stiefel der Verfolgung",t:11,d:"Diese Stiefel erlaubt es Hogmeiser, die einzigen Wesen Amaknas zu verfolgen, die er nicht ausstehen konnte, nämlich Kinder. Zum Glück für diese waren die Stiefel allerdings so schwer, dass er ihnen damit noch nicht mal einen Tritt in den Allerwertesten verpassen konnte.",ep:20,g:10,l:39,wd:true,fm:true,w:12,p:4200};
I.u[910] = {n:"Hogmeiser-Stiefel",t:11,d:"Diese Stiefel gehörten jahrelang Hogmeiser, doch verlor er sie eines Tages aufgrund einer dummen Wette mit Griesgrahm. Und die Moral von der Geschicht: spiel niemals mit den Ecaflips nicht.",ep:2,g:11,l:76,wd:true,fm:true,w:20,p:15000};
I.u[911] = {n:"Abgenutzte Hogmeiser-Stiefel",t:11,d:"Diese Stiefel hat Hogmeiser jahrelang getragen, bis sie völlig abgenutzt waren. Nun sind sie nicht mehr verwendbar, da sie den Träger behindern. Doch ein sehr guter Schuhmacher sollte sie mit etwas Glück wieder flicken können.",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:10};
I.u[912] = {n:"Goldene Hogmeiser-Stiefel",t:11,d:"Diese wunderschönen Hogmeiser Stiefel sind voll vergoldet und von einer dünnen Schicht aus Edelsteinen bedeckt, die sie unempfindlich gegen bestimmte magischen Angriffe machen. Übrigens war es genau ein solches Stiefelpaar, welches Bruce Boulgour benutzte, als er anläßlich der Eröffnung des Jahrmarktes des Trools den Kopf des Königs der Astaknyden zermalmte.",ep:2,g:12,l:99,wd:true,fm:true,w:30,p:25000};
I.u[913] = {n:"Bäckerlehrlingmütze",t:16,d:"Diese Mütze zeigt jedem in eurer Umgebung, dass ihr ein waschechter Bäckerlehrling seid.",ep:0,g:258,l:1,wd:false,fm:true,w:1,p:10000};
I.u[914] = {n:"Bäckermütze",t:16,d:"Diese Mütze zeigt jedem in eurer Umgebung, dass ihr ein waschechter Bäcker seid.",ep:0,g:257,l:1,wd:false,fm:true,w:1,p:10000};
I.u[915] = {n:"Bäckermeistermütze",t:16,d:"Diese Mütze zeigt jedem in eurer Umgebung, dass ihr ein waschechter Bäckermeister seid. Ihr backt Brote schneller als alle anderen und knetet den Teig noch schneller als euer Schatten.",ep:0,g:74,l:1,wd:false,fm:true,w:1,c:"PJ>25,100",p:10000};
I.u[916] = {n:"Halskette von Silikat",t:1,d:"Silikat hat diese Halskette eines Wintermorgens für den berühmten Abenteurer Rimb Vardi gefertigt, als dieser einen alten Bwork Magus verfolgte, der mit seiner zweifelhaften Magie bereits mehrere Naturkatastrophen verursacht hatte.",ep:1,g:9,l:37,wd:true,fm:true,w:2,p:3700};
I.u[917] = {n:"Herbstblatt",t:1,d:"Diese Brosche wurde eines Morgens inmitten eines großen Laubwaldes aus Buchen und Ulmen in der Nähe der Insel von Olag-Lacustre erschaffen. In den Augen vieler Holzfäller ist sie eine echte Reliquie.",ep:7,g:64,l:89,wd:true,fm:true,w:2,p:20500};
I.u[918] = {n:"Ur-Bernstein",t:50,d:"Dieser Bernstein stammt von einem Ur-Astaknyden. Darum hat er auch solch einen unschätzbaren Wert. Zudem kann er bestimmten Gegenständen mächtige magische Fähigkeiten verleihen, wenn geschickte Handwerksmeister ihn richtig verarbeiten.",ep:9,g:108,l:100,wd:true,fm:true,w:2,p:200};
I.u[919] = {n:"Ancestraler Ur-Dolch",t:5,d:"Diese äußerst mächtigen Dolche, die nach altem Wissen mit Hilfe von uraltem Bernstein geschmiedet wurden, haben ihrem Träger bei der Kolonisierung der Moon-Insel gut gedient. Doch letzten Endes wurde die Insel dann wieder der Verwilderung überlassen. Urig, aber wahr.",ep:9,g:8,l:34,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>34&CI>10",p:3300};
I.u[920] = {n:"Urholz",t:38,d:"Dieses Holz stammt von einer Ulme auf der Insel von Olag-Lacustre. Sie wurde eines kalten Herbsttages vom Blitz getroffen, als ein angehenden Bwork Magus seine Zaubersprüche probte.",ep:2,g:140,l:100,wd:true,fm:true,w:1,p:0};
I.u[922] = {n:"Hammer des Axtschmiedes",t:7,d:"Dieses Werkzeug wird für die Herstellung von Äxten benötigt.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[923] = {n:"Astaknydenabknicker",t:19,d:"Diese Kriegsaxt wurde von Kademlia Boulgour geschmiedet, um die gefährlichsten aller Astaknyden niederstrecken zu können. Der Legende nach soll sie mit dieser legendären Waffe eines Nachts mehr Astaknyden niedergestreckt haben, als es in ganz Amakna Bäume gibt!",ep:7,g:12,l:74,wd:true,fm:true,w:190,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>148&CW>10&CV>30",p:14400};
I.u[924] = {n:"Mächtige Stiefel von R.Klimm",t:11,d:"Die Flinkheit, die er mit diesen Stiefeln erlangte, ermöglichte es dem Schuhmacher R.Klimm, problemlos auf den Rücken eines jeden Fresssackes zu klettern. Leider verstarb er ziemlich früh, weil er nach einer durchzechten Nacht in der Taverne einen Fresssack mit einem Gelee verwechselte.",ep:1,g:9,l:19,wd:true,fm:true,w:20,p:1200};
I.u[926] = {n:"Verzaubertes Holz",t:38,d:"Dieses Holz wurde von einem Astaknydus Magus verzaubert, der einen kleinen Astaknyden, der ins Wasser gefallen war, wiederbeleben wollte. Das misslang, doch hat das Holz die mächtige Magie vollständig gespeichert.",ep:1,g:140,l:45,wd:true,fm:true,w:30,p:0};
I.u[927] = {n:"Ur-Astaknydenspalter",t:19,d:"Diese Kriegsaxt wurde von Kademlia Boulgour geschmiedet, um die gefährlichsten aller Astaknyden, nämlich die Ur-Astaknyden, niederstrecken zu können. Nur die besten aller Krieger sind in der Lage, diese Waffe überhaupt zu führen.",ep:3,g:13,l:93,wd:true,fm:true,w:100,an:17,tw:true,e:[10,4,1,1,40,50,false,false],c:"CS>200&CI>100",p:22400};
I.u[928] = {n:"Ogralimdes Klinge",t:6,d:"Ogralimde war ein großer Krieger. Seine Ausbildung hatte er seinem Meister Adyol, einem mächtigen und erschreckend intelligenten Bwork Magus, zu verdanken. Jedoch hat im Gegensatz zu den üblichen Erzählungen hier niemals der Schüler seinen Meister übertroffen.",ep:1,g:12,l:45,wd:true,fm:true,w:10,an:14,e:[2,4,1,1,25,25,false,false],c:"CS>100",p:4500};
I.u[929] = {n:"Kristallit",t:50,d:"Dieser magische Stein mit dem seltsamen Namen sollte nicht in fremde Hände gelangen, da er Schmuckstücken und Waffen große Macht verleiht.",ep:22,g:705,l:120,wd:true,fm:true,w:20,p:500};
I.u[930] = {n:"Schatzkarte des Schattenbergmannes",t:24,d:"Diese Karte weist den Weg zur versteckten Schatztruhe der Schattenbergleute: \n\"Die Schatztruhe befindet sich auf einer Insel. Hinter einer Gießerei versteckt, befindet sich ihr einziger Zugang.\"",ep:1,g:6,l:1,wd:true,fm:true,w:0,p:1};
I.u[931] = {n:"Schatzkarte des Schattenbäckers",t:24,d:"Diese Karte weist den Weg zur versteckten Schatztruhe der Schattenbäcker: \n\"Die Schatztruhe befindet sich auf einer Insel im Süden Amaknas. Der versteckte Zugang zur Insel befindet sich hinter den Felsen zwischen zwei kleinen Weihern.\"",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[932] = {n:"Klein \"Rot-Cape-Schön\"",t:17,d:"Dieser Umhang erhöht die Lebenspunkte seines Trägers.",ep:1,g:13,l:8,wd:true,fm:true,w:5,p:400};
I.u[933] = {n:"\"Rot-Cape-Schön\"",t:17,d:"Dieser Umhang erhöht die Lebenspunkte seines Trägers.",ep:1,g:13,l:13,wd:true,fm:true,w:5,p:650};
I.u[934] = {n:"Groß \"Rot-Cape-Schön\"",t:17,d:"Dieser Umhang erhöht die Lebenspunkte seines Trägers.",ep:1,g:13,l:16,wd:true,fm:true,w:5,p:900};
I.u[935] = {n:"Tels kleiner Blaumann",t:17,d:"Dieser Umhang erhöht das Glück seines Trägers.",ep:1,g:18,l:1,wd:true,fm:true,w:5,p:560};
I.u[936] = {n:"Tels Blaumann",t:17,d:"Dieser Umhang erhöht das Glück seines Trägers.",ep:1,g:18,l:3,wd:true,fm:true,w:5,p:1020};
I.u[937] = {n:"Tels großer Blaumann",t:17,d:"Dieser Umhang erhöht das Glück seines Trägers.",ep:1,g:18,l:6,wd:true,fm:true,w:5,p:1560};
I.u[938] = {n:"Schatzkarte des Schattenschmiedes",t:24,d:"Diese Karte weist den Weg zur versteckten Schatztruhe der Schattenschmiede: \n-- noch zu erstellen --",ep:1,g:9,l:1,wd:true,fm:true,w:0,p:1};
I.u[939] = {n:"Bwork Schatzkarte",t:24,d:"Diese Karte weist den Weg zur versteckten Schatztruhe der Bworks: \n\"Der Zugang zur Schatztruhe befindet sich in einer Sackgasse im Süd-Osten des Schattenwaldes. Aber es ist gar nicht leicht an den Bworks vorbeizukommen, die ihn bewachen.\"",ep:3,g:7,l:1,wd:true,fm:true,w:0,p:1};
I.u[940] = {n:"Poupsi",t:16,d:"Poupsi beschützt den Träger vor körperlichem Schaden.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[941] = {n:"Witots Stirnband",t:16,d:"Dieses schöne Stirnband erhöht die Weisheit seines Trägers.",ep:1,g:22,l:1,wd:true,fm:true,w:1,p:100};
I.u[942] = {n:"Lizzy",t:16,d:"Lizzy beschützt den Träger vor magischem Schaden.",ep:4,g:23,l:1,wd:true,fm:true,w:1,p:150};
I.u[943] = {n:"Kleines Band der Vitalität",t:16,d:"Dieses Stirnband erhöht die Vitalität seines Trägers.",ep:1,g:20,l:1,wd:true,fm:true,w:1,p:1500};
I.u[944] = {n:"Band der Vitalität",t:16,d:"Dieses Stirnband erhöht die Vitalität seines Trägers.",ep:1,g:20,l:1,wd:true,fm:true,w:2,p:3000};
I.u[945] = {n:"Uhms geringer Hang zur Dunkelheit",t:17,d:"Dieser Umhang erhöht die Weisheit seines Trägers.",ep:1,g:15,l:8,wd:true,fm:true,w:5,p:375};
I.u[946] = {n:"Uhms Hang zur Dunkelheit",t:17,d:"Dieser Umhang erhöht die Weisheit seines Trägers.",ep:1,g:15,l:12,wd:true,fm:true,w:5,p:600};
I.u[947] = {n:"Uhms starker Hang zur Dunkelheit",t:17,d:"Dieser Umhang erhöht die Weisheit seines Trägers.",ep:1,g:15,l:19,wd:true,fm:true,w:5,p:1200};
I.u[948] = {n:"Asta-Umhang",t:17,d:"Solchermaßen gewappnet könnt ihr glatt durch den ganzen Wald stolzieren, ohne erkannt zu werden. Doch seht euch vor! Es kann schnell passieren, dass den Astaknyden bei eurem Anblick der Saft in die Krone schießt.",ep:1,g:16,l:10,wd:true,fm:true,w:5,p:10000};
I.u[949] = {n:"Großes Band der Vitalität",t:16,d:"Dieses Stirnband erhöht die Vitalität seines Trägers.",ep:1,g:20,l:3,wd:true,fm:true,w:2,p:4500};
I.u[951] = {n:"Nadel und Faden",t:20,d:"Nadel und Faden, das verbindet man doch gleich noch mit welchem Handwerk? Ach ja, mit dem eines tapferen Schneiderleins.",ep:2,g:4,l:1,wd:true,fm:true,w:1,an:4,e:[1,4,1,1,100,100,false,false],p:100};
I.u[952] = {n:"Umhang des tollwütigen WuWulfs",t:17,d:"Dieser Umhang wurde aus dem Fell und diversen anderen organischen Teilen von tollwütigen WuWulfs angefertigt... darum kann man von ihm durchaus behaupten, er würde im wahrsten Sinne des Wortes eine Aura der Macht verbreiten.",ep:1,g:3,l:33,wd:true,fm:true,w:5,p:3075};
I.u[953] = {n:"Umhang des irren Tofu",t:17,d:"Dieser mit Tofu-Federn besetzte Umhang erlaubt es seinem Träger, sehr schnell zu rennen und sehr leicht aus Gerangeln mit Angreifern zu entkommen. Jedoch sollte man damit nicht erwarten, einen heldenhaften Eindruck zu hinterlassen...",ep:1,g:19,l:36,wd:true,fm:true,w:10,p:3075};
I.u[954] = {n:"Samttuchai",t:17,d:"Das Samttuchai ist ein legendärer Umhang, der von den besten Schneidern ausschließlich für eine Gruppe von Kriegern angefertigt wird, die einen eigenen Kampfstil entwickelt haben und nur den Nahkampf für ehrenvoll halten.",ep:7,g:2,l:22,wd:true,fm:true,w:10,p:1500};
I.u[955] = {n:"Cape Hillar",t:17,d:"Hillar Cape ist besonders bei Frisören besonders beliebt, da sie sich und ihre Kunden gern darin einrollen. Dadurch sollen angeblich die Haare widerstandsfähiger und kräftiger werden.",ep:8,g:5,l:34,wd:true,fm:true,w:10,p:3275};
I.u[956] = {n:"Launenmantel",t:17,d:"Dieser Mantel erhöht die Reichweite seines Trägers, wodurch selbst weit entfernte Ziele durch seine Zauber erfasst, oder die naiven Anfänger unter den Abenteurer gehörig beeindruckt werden können.",ep:8,g:7,l:33,wd:true,fm:true,w:10,p:3000};
I.u[957] = {n:"Fresssacktuch",t:17,d:"Das Fresssacktuch erhöht den durch seinen Träger angerichteten Schaden und seine Vitalität. Dummerweise sondert es einen strengen Geruch ab. Daher könnte es durchaus vorkommen, dass ein Fresssack euch mit einem seiner Artgenossen verwechselt.",ep:5,g:12,l:23,wd:true,fm:true,w:15,p:1575};
I.u[958] = {n:"Dofustator",t:17,d:"Dieses Gewand gehört zu den Mächtigsten der ganzen Welt. Es verstärkt merklich die Kräfte seines Trägers. Ist es nicht gerade voll im Trend, als Tourist durch die Schlachtfelder zu stolzieren?",ep:1,g:8,l:6,wd:true,fm:true,w:15,p:200000};
I.u[959] = {n:"Schatzkarte Nr. 5",t:24,d:"-- noch zu erstellen --",ep:1,g:10,l:1,wd:true,fm:true,w:0,p:1};
I.u[960] = {n:"Wabbit-Trank",t:24,d:"Dieser Trank ist das einzig bekannte Mittel gegen die Myxomawose. Ein Schluck dieses Gebräues ermöglicht es euch bereits, die Insel der Wabbit zu betreten, ohne um euer Leben fürchten zu müssen.",ep:5,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[961] = {n:"Wabbit-Schlüssel",t:24,d:"Dies ist einer der drei Schlüssel, die man braucht, um das Schloss der Wabbits zu betreten.",ep:8,g:3,l:1,wd:true,fm:true,w:0,p:1};
I.u[962] = {n:"Wabbit-Schlüssel",t:24,d:"Dies ist einer der drei Schlüssel, die man braucht, um das Schloss der Wabbits zu betreten.",ep:8,g:4,l:1,wd:true,fm:true,w:0,p:1};
I.u[963] = {n:"Wabbit-Schlüssel",t:24,d:"Dies ist einer der drei Schlüssel, die man braucht, um das Schloss der Wabbits zu betreten.",ep:8,g:5,l:1,wd:true,fm:true,w:0,p:1};
I.u[965] = {n:"Dubbelstein",t:50,d:"Dieser Stein kommt aus den Dubbel-Landen. Für gewisse Einwohner Amaknas besitzt er einen großen Wert.",ep:2,g:663,l:41,wd:true,fm:true,w:15,p:10000};
I.u[966] = {n:"Handbuch der Schneiderei",t:25,d:"(Doppelklick, um den Schneiderberuf zu lernen) \nIn diesem Handbuch stehen alle Tipps und Tricks des Handwerkes. Auf den ersten Seiten gibt es sogar einige Schnittmuster für alle, die sich so etwas nicht selbst ausdenken können oder wollen.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[967] = {n:"Schillernder Umhang",t:17,d:"Dieser wunderschöne Umhang erhöht die AP, Vitalität und Weisheit seines Trägers. Ein Feuerwerk der Sinne eben!",ep:13,g:78,l:55,wd:true,fm:true,w:20,p:200000};
I.u[968] = {n:"Funkelnder Gürtel",t:10,d:"Dieser wunderschöne Gürtel erhöht die AP seines Trägers, sowie dessen Vitalität und Weisheit.",ep:1,g:10,l:30,wd:true,fm:true,w:200,p:200000};
I.u[969] = {n:"Krone des Wa Wabbits",t:16,d:"Diese wunderschöne Krone gehörte einst dem berühmt-berüchtigten Wa Wabbit.",ep:8,g:21,l:30,wd:true,fm:true,w:30,s:40,p:3000};
I.u[970] = {n:"Wa Wabbit-Stecken",t:4,d:"Dieser Stecken gehörte einst dem berüchtigten Wa Wabbit.",ep:8,g:21,l:25,wd:true,fm:true,w:20,an:12,tw:true,e:[5,5,1,1,30,20,false,false],s:40,p:2500};
I.u[971] = {n:"Umhang des Wa Wabbit",t:17,d:"Dieses königliche Gewand hat einmal der berühmte Wa Wabbit besessen. Vollgesogen mit seinem Schweiß und anderen Absonderungen wird es euch beim Tragen immer an ihn erinnern... Wie schön!",ep:8,g:21,l:30,wd:true,fm:true,w:25,s:40,p:2525};
I.u[972] = {n:"Cawwot-Dofus",t:23,d:"Der Cawwot-Dofus erhöht die Weisheit seines Trägers.",ep:1,g:6,l:6,wd:true,fm:true,w:5,p:500000};
I.u[973] = {n:"Klauenbein einer Akaknelle",t:24,d:"Diese Endstück des Beines einer Araknelle ist sehr fein gebaut und haarig. Erfahrene Alchimisten können aus der daraus extrahierten Flüssigkeit sehr wirksame Tränke herstellen.",ep:2,g:11,l:1,wd:true,fm:true,w:0,p:1};
I.u[974] = {n:"Kopf des Bauerns in Not",t:24,d:"Es kam wie es kommen musste, der Bauer in Not verlor letzten Endes seinen Kopf.",ep:1,g:12,l:1,wd:true,fm:true,w:0,p:1};
I.u[975] = {n:"Beißzahn des gefangenen Vampirs",t:24,d:"Dieser spitze Zahn stammt von einem Vampir. Damit könnt ihr vor euren Freunden glänzen, die euch garantiert für einen erfahrenen Vampirjäger halten werden, wenn ihr den Zahn an einer Kette um den Hals tragt oder im Inventar mit euch führt.",ep:1,g:13,l:1,wd:true,fm:true,w:0,p:1};
I.u[976] = {n:"Küwbiskopf",t:16,d:"Ein Küwbiskopf hat die eigentümliche Eigenschaft, magische Partikel zu zerstreuen und abzulenken. Daher ist er auch ein guter magischer Isolator. Vielleicht tragen deswegen manche Krieger dieses Gemüse auf ihrem Kopf mit sich herum, wer weiß.",ep:4,g:24,l:20,wd:true,fm:true,w:10,p:500};
I.u[989] = {n:"Zitronen-Shigekax",t:42,d:"Diese noch immer von Hand hergestellten Zitronenbonbons schmecken auch heute noch genauso gut wie früher.",ep:1,g:23,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[990] = {n:"Erdbeer-Shigekax",t:42,d:"Diese noch immer von Hand hergestellten Erdbeerbonbons schmecken auch heute noch genauso gut wie früher.",ep:13,g:25,l:1,wd:true,fm:true,w:1,u:true,p:140};
I.u[991] = {n:"Minz-Shigekax",t:42,d:"Diese noch immer von Hand hergestellten Minzbonbons schmecken auch heute noch genauso gut wie früher.",ep:2,g:24,l:1,wd:true,fm:true,w:1,u:true,p:400};
I.u[992] = {n:"Kirsch-Shigekax",t:42,d:"Diese noch immer von Hand hergestellten Kirschbonbons schmecken auch heute noch genauso gut wie früher.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[993] = {n:"Grüngli",t:42,d:"Vor diesem Bonbon aus reinem Minzgeleeextrakt schrecken mit Sicherheit selbst Vegetarier zurück, doch zählt es dennoch völlig zu Recht zu den kulinarischen Spezialitäten Amaknas.",ep:5,g:21,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[994] = {n:"Rotagli",t:42,d:"Vor diesem Bonbon aus reinem Erdbeergeleeextrakt schrecken mit Sicherheit selbst Vegetarier zurück, doch zählt es dennoch völlig zu Recht zu den kulinarischen Spezialitäten Amaknas.",ep:5,g:20,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[995] = {n:"Blaugli",t:42,d:"Vor diesem Bonbon aus reinem Blaubeergeleeextrakt schrecken mit Sicherheit selbst Vegetarier zurück, doch zählt es dennoch völlig zu Recht zu den kulinarischen Spezialitäten Amaknas.",ep:5,g:22,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[996] = {n:"Multigli",t:42,d:"Das Multigli wurde aus dem Handel zurückgezogen, da es angeblich für das Verschwinden zahlreicher Kinder verantwortlich sein soll. Es heißt, derjenige, der ein Multigli lutscht, würde seinen schlimmsten Alpträumen begegnen.",ep:5,g:26,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[997] = {n:"Kokokosnuss",t:46,d:"Diese Nuss ist so rund wie eine Kanonenkugel. Darüber hinaus besitzt sie praktischerweise 3 kleine Löcher, so dass man sie leicht greifen und weit fortwerfen kann.",ep:12,g:159,l:42,wd:true,fm:true,w:2,p:1};
I.u[998] = {n:"Niedlicher Schlüpfer des Piratenkapitäns",t:15,d:"Dieser Schlüpfer des Piratenkapitäns beweist einmal mehr, dass Lachen manchmal ungesund sein kann. Ein echter Glücksbringer, fragt sich nur für wen.",ep:12,g:163,l:82,wd:true,fm:true,w:2,p:1};
I.u[999] = {n:"Ekliges Segeltuch",t:55,d:"Auch wenn es klebrig und übelriechend ist, so handelt es sich dennoch um ein Segeltuch guter Qualität. Schade nur, dass es in der Mitte ein großes Loch hat.",ep:12,g:164,l:1,wd:true,fm:true,w:5,p:1};
I.u[1000] = {n:"Leeres Fass",t:15,d:"Dieses große Fass ist bereits seit langem geleert worden, doch lässt sich immernoch bestimmen, was es einmal alles enthalten hat: Rum, Kamas und betrunkene Piraten. Alles mögliche eben, aber niemals Wasser.",ep:12,g:165,l:1,wd:true,fm:true,w:5,p:1};
I.u[1001] = {n:"Brett aus Kokokoholz",t:95,d:"Sind dies zukünftige Teile eines Schiffes? Oder des Parkettbodens eines Hauses? In jedem Fall handelt es sich im jetzigen Zustand bloß um ein gewöhnliches Holzbrett.",ep:12,g:166,l:42,wd:true,fm:true,w:10,p:10};
I.u[1002] = {n:"Kokokostamm",t:38,d:"Wie alle Stämme ist der Stamm einer Kokokospalme gerade und sehr stabil, auch wenn er etwas schmaler als der Durchschnitt ist.",ep:12,g:167,l:42,wd:true,fm:true,w:1,p:1};
I.u[1003] = {n:"Balken aus Kokokoholz",t:38,d:"Diesen stabilen Balken aus Kokokoholz sollte man besser nicht ins Auge bekommen. Das könnte nämlich sonst ins Auge gehen.",ep:12,g:168,l:42,wd:true,fm:true,w:1,p:1};
I.u[1004] = {n:"Unabdingbares Seil",t:15,d:"Alle Abenteurer wissen, dass man ein solches Seil immer dabeihaben sollte. Warum in aller Welt nimmt dann niemals jemand eines mit?!?",ep:12,g:170,l:1,wd:true,fm:true,w:1,p:1};
I.u[1005] = {n:"Quittung für ein Floß",t:24,d:"Diese Quittung wurde von Kib Roche höchstpersönlich unterzeichnet. Darauf steht, dass euer Floß bald fertiggestellt sein wird.",ep:1,g:176,l:1,wd:true,fm:true,w:0,p:1};
I.u[1006] = {n:"Piratenmütze",t:24,d:"Diese imposante Mütze mit dem Pelzbesatz und dem Totenkopfzeichen auf der Vorderseite ist der Klassiker unter den Kaptitänsmützen.",ep:12,g:14,l:1,wd:true,fm:true,w:0,p:1};
I.u[1007] = {n:"Hakenhand",t:24,d:"Diese praktische Prothese ersetzt vorteilhaft die fehlende Hand von Piraten, die Glück im Unglück hatten. Die Hakenhand ist nicht nur vielseitig einsetzbar, sondern sieht mit der neongelben, im Dunkeln leuchtenden Farbe auch noch absolut stylisch aus.",ep:12,g:15,l:1,wd:true,fm:true,w:0,p:1};
I.u[1008] = {n:"Heruntergeklappte Kinnlade",t:24,d:"Diese schicke Kieferkette ist wohl die Frucht des Wutausbruches eines Kapitäns, der möglicherweise etwas empfindlich auf den Lachanfall eines unvorsichtigen Matrosen beim Anblick des Schlüpfers seines Chefs reagiert haben wird.",ep:12,g:16,l:1,wd:true,fm:true,w:0,p:1};
I.u[1009] = {n:"Piratenschädel",t:24,d:"Dieser Schädel mit dem roten Kopftuch beweist einmal mehr, dass ein Pirat selbst dann noch seine Kahlköpfigkeit verbergen kann, wenn er tot ist.",ep:12,g:17,l:1,wd:true,fm:true,w:0,p:1};
I.u[1010] = {n:"Grüner Schildkrötenpanzer",t:24,d:"Dies ist der Panzer einer verrückten Schildkröte, die sich für einen Ninja hielt.",ep:12,g:18,l:1,wd:true,fm:true,w:0,p:1};
I.u[1011] = {n:"Gelber Schildkrötenpanzer",t:24,d:"Dies ist der Panzer einer verrückten Schildkröte, die vermutlich zuviele schädliche Substanzen eingenommen hat.",ep:12,g:19,l:1,wd:true,fm:true,w:0,p:1};
I.u[1012] = {n:"Roter Schildkrötenpanzer",t:24,d:"Dies ist der Panzer einer verrückten Schildkröte, die wohl zuviel Tomaten und Käse auf Toast gegessen hat.",ep:12,g:20,l:1,wd:true,fm:true,w:0,p:1};
I.u[1013] = {n:"Blauer Schildkrötenpanzer",t:24,d:"Dies ist der Panzer einer verrückten Schildkröte, die Zowwo, den Fuchs in der eiernden Maske, imitieren wollte.",ep:12,g:21,l:1,wd:true,fm:true,w:0,p:1};
I.u[1014] = {n:"Grüne Maske",t:24,d:"Dies ist die Maske des lachenden Kanniballs. Sie ist dem Grünzeug gewidmet, welches so hervorragend das Fleisch begleitet.",ep:12,g:22,l:1,wd:true,fm:true,w:0,p:1};
I.u[1015] = {n:"Gelbe Maske",t:24,d:"Dies ist die Maske des weinenden Kanniballs. Sie ist den Blitzen gewidmet, deren Macht gerade das junge Frischfleisch so erschreckt.",ep:12,g:23,l:1,wd:true,fm:true,w:0,p:1};
I.u[1016] = {n:"Rote Maske",t:24,d:"Dies ist die Maske des wütenden Kanniballs. Sie ist dem Feuer gewidmet, welches das Braten des Fleisches ermöglicht.",ep:12,g:24,l:1,wd:true,fm:true,w:0,p:1};
I.u[1017] = {n:"Blaue Maske",t:24,d:"Dies ist die Maske des überraschten Kanniballs. Sie ist dem Wasser gewidmet, welches zwischen zwei Fleischhäppchen den Durst stillt.",ep:12,g:25,l:1,wd:true,fm:true,w:0,p:1};
I.u[1018] = {n:"Gleister",t:15,d:"Aus diesem kleinen Topf mit dem wohlriechenden rosa Gelee sollte unter keinen Umständen genascht werden. Denn sonst kann der Übeltäter wahrscheinlich sein Lebtag lang nicht mehr reden, so gut wirkt dieser klebrige Stoff.",ep:12,g:171,l:1,wd:true,fm:true,w:1,p:1};
I.u[1019] = {n:"Fliegerhelm",t:16,d:"Mit diesem Fliegerhelm auf dem Kopf seht ihr wirklich einzigartig aus... auf halbem Wege zwischen \"einfach nur lächerlich\" und \"zum Totlachen\".",ep:1,g:25,l:20,wd:true,fm:true,w:10,p:200};
I.u[1020] = {n:"Zerbrochener Fliegerhelm",t:15,d:"Dieser Hut hat euch das Leben gerettet, doch seins dabei verloren.",ep:2,g:173,l:1,wd:true,fm:true,w:5,p:1};
I.u[1021] = {n:"Hölzerne Flügel",t:17,d:"All diejenigen, die schon immer davon geträumt haben wie ein Kwack durch die Lüfte zu segeln – hört endlich auf zu träumen! Denn diese lächerlichen Holzflügel machen aus euch nur eine Gefahr für die Allgemeinheit sowie euch zum Gespött derselben.",ep:1,g:22,l:20,wd:true,fm:true,w:20,p:1200};
I.u[1022] = {n:"Zerschmetterte Flügel",t:104,d:"Diese Flügel erinnern euch stets daran, dass ihr euch besser noch einmal hättet hinlegen sollen, anstatt Unsinn anzustellen.",ep:2,g:174,l:1,wd:true,fm:true,w:10,p:1};
I.u[1023] = {n:"Buddel voll Rum",t:15,d:"Auf dem Etikett steht \"Rum, 10 Jahre.\" Doch wie will man das jetzt noch nachprüfen? Darunter steht noch, dass man ihn nicht trinken soll, wenn man noch plant zu reisen. Ha, wer würde denn so blöd sein, nachdem er eine ganze Buddel voller Rum gefunden hat?",ep:12,g:177,l:1,wd:true,fm:true,w:2,p:1};
I.u[1026] = {n:"Kleines Stek-Messer",t:5,d:"Der verrückte Erfinder Stek Dardar soll diese seltsamen und äußerst gefährlichen Messer bestellt haben. Niemand wußte wozu, bis er eines Tages seinem Gott einen riesigen Haufen blutigen Fleisches opferte.",ep:1,g:13,l:32,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>32&CS>10",p:3000};
I.u[1027] = {n:"Stek-Messer",t:5,d:"Der verrückte Erfinder Stek Dardar soll diese seltsamen und äußerst gefährlichen Messer bestellt haben. Niemand wußte wozu, bis er eines Tages seinem Gott einen riesigen Haufen blutigen Fleisches opferte.",ep:1,g:13,l:35,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>35&CS>12",p:3400};
I.u[1028] = {n:"Großes Stek-Messer",t:5,d:"Der verrückte Erfinder Stek Dardar soll diese seltsamen und äußerst gefährlichen Messer bestellt haben. Niemand wußte wozu, bis er eines Tages seinem Gott einen riesigen Haufen blutigen Fleisches opferte.",ep:1,g:13,l:38,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>38&CS>14",p:3800};
I.u[1029] = {n:"Breites Stek-Messer",t:5,d:"Der verrückte Erfinder Stek Dardar soll diese seltsamen und äußerst gefährlichen Messer bestellt haben. Niemand wußte wozu, bis er eines Tages seinem Gott einen riesigen Haufen blutigen Fleisches opferte.",ep:1,g:13,l:41,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>41&CS>16",p:4000};
I.u[1030] = {n:"Dreißigschwänzige Katzendolche",t:5,d:"Dieses Paar Dolche ist in Wirklichkeit ein magisches Spielzeug, welches ursprünglich für junge Ecaflips gedacht war. Nachdem jedoch einmal der Sohn eines Sram-Anhängers mitspielte, wurden die dreißigschwänzigen Katzendolche allerdings schnell wieder verboten.",ep:14,g:20,l:25,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,50,false,false],c:"CA>40&CS>20&CV>20",p:1800};
I.u[1031] = {n:"Grausame Dolche von Elorie Entuwan",t:5,d:"Diese fein gearbeiteten Dolche sollen einmal der grausamsten Sram von ganz Amakna gehört haben. Jedenfalls einer der Grausamsten... Naja, ein wenig grausamer als alle anderen oder zumindest mindestens genauso grausam wie sie, was bereits nicht schlecht ist.",ep:1,g:7,l:40,wd:true,fm:true,w:1,an:13,e:[12,3,1,1,30,50,false,false],c:"CA>40",p:4000};
