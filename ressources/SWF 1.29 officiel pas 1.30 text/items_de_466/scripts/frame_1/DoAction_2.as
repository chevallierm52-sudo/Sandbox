I.u[417] = {n:"Boo-Schlamm",t:15,d:"Boo-Schlamm ist sehr aggressiv. Er besteht aus einer Vielzahl von Schlammpartikeln großer Schlammigkeit. Kaum trocken zu kriegen. Man wird seiner meist erst nach einer großen Schlammschlacht habhaft. Ein wahres Schlammassel eben...",ep:2,g:116,l:17,wd:true,fm:true,w:1,p:1};
I.u[418] = {n:"Barthaare eines Grand Pa-Wabbit",t:54,d:"Der Grand Pa-Wabbit hat einen fülligen Rauschebart, der allerdings sehr schlecht riecht. Denn so, wie er täglich sabbernd vor der Grand Ma-Wabbit steht, ist es auch kein Wunder, dass sich seine Barthaare mit seinem angeblich magischem, aber ohne Zweifel schlecht riechenden Sabber vollgesogen haben.",ep:8,g:114,l:39,wd:true,fm:true,w:1,p:100};
I.u[419] = {n:"Ohr des Grand Pa-Wabbits",t:106,d:"Die Ohren des Grand Pa-Wabbit sind spitz und rund, aber auch dicht von schwarz-weißen Haaren bewachsen, was ihnen einen coolen Zebra-Look verleiht. Ohne Frage ein Prachtstück, vor allem, weil es überhaupt nicht riecht.",ep:8,g:115,l:39,wd:true,fm:true,w:1,p:1};
I.u[420] = {n:"Leinenschnur",t:15,d:"Eine Leinenschnur ist sehr reißfest. Darum eignet sich Leinen auch gut für feine Stickereien. Außerdem kann man damit seine Freunde fesseln, um ihnen klar zu machen, wer der Chef in der Gilde ist.",ep:1,g:118,l:1,wd:true,fm:true,w:1,p:10};
I.u[421] = {n:"Flachsblüte",t:35,d:"Flachsblüten sind entweder weiß oder blau, je nachdem, zu welcher Jahreszeit die Pflanze gesät wurde. Als Tee zubereitet, ist es ein wirksames Beruhigungsmittel.",ep:1,g:117,l:1,wd:true,fm:true,w:1,p:0};
I.u[422] = {n:"Flachs-Samen",t:58,d:"Diese klitzekleinen Samen enthalten viele gute Dinge. Kwackjäger wissen, wie versessen ihre Beute darauf ist und verwenden diese glänzenden Samen gern als Köder.",ep:1,g:119,l:1,wd:true,fm:true,w:2,p:1};
I.u[423] = {n:"Flachs",t:34,d:"An Flachs ist nicht außergewöhnliches, mit Ausnahme der Eigenschaft, dass sich die Pflanze bis zu 7 Mal wiederaufrichten kann, nachdem sie durch Stürme umgeknickt wurde. Kein Wunder, dass die Fasern so biegsam sind...",ep:1,g:122,l:40,wd:true,fm:true,w:2,p:0};
I.u[424] = {n:"Leinenfasern",t:55,d:"Dies ist die beste Faser für alle Arten von Stoffen. Sie ist zwar selten und teuer, doch so hochwertig, dass es sich kein Schneider leisten kann, ausschließlich andere Fasern zu verwenden.",ep:13,g:120,l:46,wd:true,fm:true,w:1,p:1};
I.u[425] = {n:"Hanf",t:34,d:"Hanf findet Verwendung für die Erforschung halluzinogener Substanzen, aber gleichfalls auch von Webereien, die aus den Fasern herrliche Produkte spinnen können.",ep:1,g:121,l:70,wd:true,fm:true,w:2,p:0};
I.u[426] = {n:"Hanffaser",t:55,d:"Diese Faser sieht zwar nicht sehr schön aus, doch ist sie sehr reißfest. Zudem lässt sie sich zur Not immer vielseitig verwenden, wenn man nichts anderes mehr mit ihr anzufangen weiß.",ep:13,g:123,l:46,wd:true,fm:true,w:1,p:1};
I.u[427] = {n:"Hanfsamen",t:58,d:"Hanfsamen werden gern verwendet, um Tabiherden zur Brunftzeit zu zähmen. Nach nur einigen Samen werden sie wieder sanft wie Lämmer.",ep:1,g:157,l:10,wd:true,fm:true,w:1,p:10};
I.u[428] = {n:"Hanfblüten",t:35,d:"Aus diesen Blüten lassen sich Tränke mit unvorhersehbarer Wirkung herstellen. Die Auswirkungen reichen von der vollständigen Lähmung bis hin zur Immunität gegen Wabbitgasangriffe.",ep:1,g:156,l:10,wd:true,fm:true,w:1,p:0};
I.u[429] = {n:"Bwork Bogenschützen-Pfeilspitze",t:15,d:"Diese verrostete Pfeilspitze besteht aus einem sehr seltenen Metall, welches man ausschließlich in Form dieser Pfeilspitzen findet.",ep:4,g:125,l:24,wd:true,fm:true,w:1,p:1};
I.u[430] = {n:"Unsichtbarer Knochen des Unsichtbaren Chafers",t:47,d:"Dieser Knochen ist völlig unsichtbar, ein Zeichen der magischen Kräfte, die ihm innewohnen. Sicherlich lässt er sich zu einem leckeren magischen Trank verarbeiten.",ep:1,g:126,l:23,wd:true,fm:true,w:1,p:20};
I.u[431] = {n:"Krachlergestein",t:51,d:"Dieses seltsame Gesteinsstück scheint beinahe lebendig zu sein. Es bezieht seine Kraft aus den Edelsteinen in seinem Inneren. Das macht es nahezu unzerstörbar, außer für Krachler selbst. Drum gibt es kein besseres Material für die Herstellung von dicken Hammern.",ep:2,g:127,l:31,wd:true,fm:true,w:5,p:1};
I.u[432] = {n:"Rippchen",t:47,d:"Rippchen schmecken hervorragend. Einfach grillen und schon hat man ein reichhaltiges Mahl. Das ist besonders dann sehr praktisch, wenn es nichts anderes zu essen gibt.",ep:3,g:158,l:33,wd:true,fm:true,w:1,p:100};
I.u[433] = {n:"Schienbeinknochen eines Chafer-Bogenschützen",t:47,d:"Welch seltsamer Knochen. Er lässt sich leicht frittieren und verbreitet einen leckeren Currygeschmack dabei. Ideal für skrupellose Chefköche, die sparen müssen.",ep:1,g:101,l:34,wd:true,fm:true,w:1,p:100};
I.u[434] = {n:"Astaknydenrinde",t:96,d:"Dieses Stück Rinde ist rau, von tiefen Rinnen durchzogen, mit kleinen Unebenheiten übersäht und riecht angenehm. Alles in allem ähnelt es also ein wenig den Füßen eines Enutrofs.",ep:1,g:103,l:32,wd:true,fm:true,w:1,p:1};
I.u[435] = {n:"Astaknydenwurzel",t:98,d:"Dieses Stück Wurzel hat bereits viel erlebt bei den Wanderungen des Astaknyden durch die dunklen Wälder. Doch erklärt dies immer noch nicht, wo die gespeicherte Magie herkommt.",ep:1,g:102,l:32,wd:true,fm:true,w:1,p:1};
I.u[436] = {n:"Stock aus Astaknydenwurzeln",t:4,d:"Dieser Stock, der aus einer dicken Astaknydenwurzel herausgearbeitet wurde, ist sehr effektiv im Nahkampf. Allerdings sollte man dabei immer aufpassen, dass er nicht nass wird, da er sich sonst wieder im Boden verwurzelt und den Träger angreift.",ep:1,g:1,l:30,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,20,50,false,false],c:"CI>30&CC>5",p:2650};
I.u[437] = {n:"Astaknydenknospe",t:108,d:"Während der Pubertät wachsen Astaknyden häßliche Knospen, die mit vitaminreichem Harzsaft gefüllt sind. Später einmal entstehen daraus neue Triebe, die irgendwann wiederum einmal Knospen bekommen werden.",ep:1,g:104,l:32,wd:true,fm:true,w:1,p:1};
I.u[438] = {n:"WuWulf-Schwanz",t:65,d:"Der WuWulf-Schwanz ähnelt einem großen, moosbewachsenen Stück Holz. Doch sollte man ihn als Holzfäller besser nicht damit verwechseln...",ep:1,g:105,l:70,wd:true,fm:true,w:1,p:50};
I.u[439] = {n:"WuWulf-Fangzahn",t:47,d:"Dieser scharfe Fangzahn ist ein guter Glücksbringer. Leider bringt er auch einen fauligen Geruch mit sich...",ep:1,g:106,l:70,wd:true,fm:true,w:1,p:1};
I.u[440] = {n:"WuWulf-Kralle",t:15,d:"Aus dieser dreckigen Kralle lassen sich bösartige Waffen herstellen.",ep:1,g:107,l:70,wd:true,fm:true,w:1,p:1};
I.u[441] = {n:"Kupfer",t:39,d:"Kupfer ist ein ideales Metall für die Herstellung billiger Waffen, die dennoch etwas hermachen. Dahingehend wirkt es beinahe wie Gold, hat aber nicht dessen gute Eigenschaften.",ep:1,g:108,l:10,wd:true,fm:true,w:5,p:0};
I.u[442] = {n:"Bronze",t:39,d:"Dieses Metall wird oftmals für dekorative Arbeiten verwendet. Beispielsweise, um kostengünstig neu geschmiedete Waffen zu verzieren.",ep:1,g:109,l:20,wd:true,fm:true,w:5,p:0};
I.u[443] = {n:"Kobalt",t:39,d:"Der Name \"Kobalt\" bedeutet in Alt-Sadida \"teuflisches Kupfer\". Darum wird niemand überrascht sein, dass es besonders für die Herstellung leichter, aber absolut tödlicher Waffen verwendet wird.",ep:1,g:77,l:30,wd:true,fm:true,w:5,p:0};
I.u[444] = {n:"Zinn",t:39,d:"Zinn ist ein weiches und schweres Metall. Ein wenig wie der Wo Wabbit, aber noch schlimmer.",ep:1,g:78,l:50,wd:true,fm:true,w:5,p:0};
I.u[445] = {n:"Mangan",t:39,d:"Im Gegensatz zu dem, was alle Abenteurer glauben, dient dieses Metall nicht dazu, Regenrinnen herzustellen, sondern gefährlich Waffen, wie zum Beispiel die berühmte Klinge von Manganese, die bereits mehr als einen Tofu im Rahmen des alljährlichen Boulgour-Festes betäubt hat.",ep:1,g:397,l:40,wd:true,fm:true,w:5,p:0};
I.u[446] = {n:"Bauxit",t:39,d:"Dieses Metall wird für seinen silbrigen Schimmer und die gute Schärfbarkeit beim erfolgreichen Wetzen der Klinge hoch geschätzt.",ep:1,g:76,l:70,wd:true,fm:true,w:5,p:0};
I.u[447] = {n:"Kohle",t:39,d:"Kohle besitzt zwar keine magischen Eigenschaften, auch wenn dies überraschen mag, doch ist dieses Erz in der Lage, Blitze anzuziehen, sie zu speichern und in den unpassendsten Momenten wieder entweichen zu lassen.",ep:5,g:75,l:1,wd:true,fm:true,w:5,p:0};
I.u[448] = {n:"Feuerstein",t:51,d:"Dieses Gestein ist äußerst scharf. Tatsächlich soll es bereits mehr als einem unvorsichtigem Maulwurf die Kehle durchgeschnitten haben.",ep:1,g:74,l:22,wd:true,fm:true,w:5,p:1};
I.u[449] = {n:"Ebenholz",t:38,d:"Dieses Holz verdankt seinen Namen einem Mißverständnis. Vor langer Zeit gab es eine Familie von Holzfällern, die tief im Wald versteckt einen kleinen Hain mit unvergleichlich hochwertigem Holz entdeckt hatten. Um Neider abzuschrecken, versteckten sie die gefällten Holzscheite immer tief in ihrem Brennholzstapel, der immer größer und größer wurde, bis das Geheimnis eines Tages ans Licht kam. Ihr Ausspruch:\"Is\' all eh B\'ennholz\" war so oft von Gästen gehört worden, dass es später zum Running Gag wurde und im Laufe der Zeit den Namen \"Ebenholz\" prägt.",ep:7,g:73,l:70,wd:true,fm:true,w:5,p:0};
I.u[450] = {n:"Granitgestein",t:51,d:"Dieses Gestein ist derart schwer und nahezu für nichts zu gebrauchen, außer im Rahmen der Waffenschmiede. Allerdings soll man daraus ebenfalls Edelsteine herausschlagen können, heißt es.",ep:1,g:1,l:30,wd:true,fm:true,w:20,p:1};
I.u[454] = {n:"Holzfälleraxt",t:19,d:"Diese Axt ist unverzichtbar für jeden Holzfäller, der seinen Beruf ausüben will. Doch im Notfall kann sie auch durchaus dazu dienen, ein paar aufgetauchte Monster wieder loszuwerden.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:150};
I.u[455] = {n:"Hammer der Morgenröte",t:7,d:"Dieser lächerliche kleine Hammer diente dem Bauern Zokrim dazu, die Zaunpfähle für seine Weiden bei Einsetzen der Morgenröte in den Boden zu schlagen. Warum er dies immer nur bei Einsetzen der Morgenröte zu tun pflegte, weiß niemand, aber der Legende nach hatte er einen sehr guten Grund dafür.",ep:1,g:2,l:26,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CS>10&CI>16",p:2000};
I.u[456] = {n:"Eichentod",t:19,d:"Mit dieser Axt lassen sich leicht Bäume fällen, sogar die Dicksten ohne große Mühe. Doch wird sie vor allem für ihr großes Gewicht geschätzt, welches es erlaubt, einen Bwork in drei Teile zu schlagen, ehe dieser es überhaupt mitbekommt. Man muss es jetzt nur noch schaffen, diese Waffe hoch zu bekommen.",ep:7,g:2,l:33,wd:true,fm:true,w:50,an:17,e:[5,4,1,1,40,40,false,false],c:"CS>66&CA>10",p:3150};
I.u[458] = {n:"Chafer-Amulett",t:1,d:"Der Chafer ist ein sehr feinfühliges und vornehmes Wesen, weshalb er immer ein Amulett mit den Schädeln seiner im Kampf gefallenen Cousins bei sich trägt. Seltsam ist nur, dass niemand jemals von diesen Cousins des Chafers gehört hat.",ep:1,g:3,l:19,wd:true,fm:true,w:4,p:1200};
I.u[459] = {n:"Brett aus Eschenholz",t:95,d:"Bastler können aus diesem Brett wunderbare Dinge erschaffen, wie einen hölzernen Sarg zum Beispiel.",ep:1,g:93,l:1,wd:true,fm:true,w:10,p:10};
I.u[460] = {n:"Eichenholz",t:38,d:"Dieses Holz hervorragender Qualität ist so strapazierfähig, dass man daraus beinahe alles problemlos fertigen kann. Stecken, Häuser, Schiffe und aus den besten sooogaaaar Bierfässer (Hicks!).",ep:1,g:92,l:30,wd:true,fm:true,w:5,p:0};
I.u[461] = {n:"Eibenholz",t:38,d:"Dieses besonders biegsame Holz kann man kaum durchbrechen. Daher wird es gern für den Bogenbau verwendet. Leider ist es recht schwierig, noch welches zu finden, da viele Bauern Amaknas die Gewohnheit haben, die jungen Triebe abzuschneiden, weil ihre Fresssäcke davon krank werden.",ep:1,g:94,l:50,wd:true,fm:true,w:5,p:0};
I.u[462] = {n:"Bogen aus Astaknydenwurzeln",t:2,d:"Da das Holz eines Astaknyden selbst abgeschnitten noch lebendig ist, ist es nicht einfach, diesen Bogen zu gebrauchen. Doch gibt es nichts besseres um einen Astaknyden zu verspotten, als ihn mit einem Bogen zu töten, der aus den Wurzeln der eigenen Brüder gemacht wurde.",ep:1,g:1,l:28,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,30,50,false,true],c:"CS>10&CA>28",p:2250};
I.u[463] = {n:"Bernstein",t:50,d:"Dieser schöne Bernstein besteht aus versteinertem Astaknydenharz. Manchmal findet man kleine Moskitos darin, die bereits seit Ewigkeiten im Harz gefangen sind, was seinen Wert nur erhöht. Und diese kleinen Biester haben es auch einfach nicht anders verdient.",ep:1,g:96,l:32,wd:true,fm:true,w:4,p:20};
I.u[464] = {n:"Astaknydenbernstein",t:50,d:"Dieser schöne Bernstein besteht aus versteinertem Astaknydenharz. Manchmal findet man kleine Arachneen darin, die bereits seit Ewigkeiten im Harz ihres Beschwörers gefangen sind. Doch diese kleinen Biester haben es einfach auch nicht anders verdient.",ep:1,g:97,l:32,wd:true,fm:true,w:5,p:40};
I.u[465] = {n:"Geschliffener Kristall",t:50,d:"Ein geschliffener Kristall ist ein wunderschöner klarer Edelstein. Leider geht er auch sehr leicht zu Bruch. Wie man sieht, ist selbst bei Edelsteinen nicht immer alles vollkommen.",ep:1,g:98,l:50,wd:true,fm:true,w:20,p:5000};
I.u[466] = {n:"Geschliffener Saphir",t:50,d:"Dieser wunderschöne blaue Edelstein eignet sich gut für die Herstellung magischer Waffen. Vielleicht liegt das daran, dass gewisse Spielentwickler mit zu wenig Phantasie gern die Farbe \"blau\" nehmen, um Mana zu symbolisieren?",ep:1,g:99,l:50,wd:true,fm:true,w:20,p:5000};
I.u[467] = {n:"Geschliffener Rubin",t:50,d:"Dieser wertvolle Edelstein leuchtet nach dem Schleifen in roten Farbtönen noch schöner als die Federn eines Flammen-Kwacks. Dabei ist er noch viel kälter als die Federn eines Eis-Kwacks.",ep:1,g:100,l:50,wd:true,fm:true,w:20,p:5000};
I.u[468] = {n:"Amaknabrot",t:33,d:"Dieses kleine, frisch aus dem Ofen kommende Brot mit dem weichen Inneren und der goldenen Kruste gibt im Kampf verlorene LP zurück. Es ist sehr beliebt, da es normalerweise auch recht günstig ist.",ep:1,g:13,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[469] = {n:"Stab aus Astaknydenwurzeln",t:3,d:"Die Macht dieses Stabes beruht auf den magischen Eigenschaften der noch lebendigen Astaknydenwurzeln. Darum solltet ihr immer auf der Hut sein vor üblen Überraschungen. Der Stab kann sich nämlich manchmal auch gegen den Träger wenden.",ep:1,g:3,l:33,wd:true,fm:true,w:20,an:11,e:[5,4,2,2,50,40,false,true],c:"CI>33&CW>10",p:3100};
I.u[470] = {n:"Ulmenholz",t:38,d:"Früher war Ulmenholz alltäglich. Doch heutzutage ist es äußerst selten, da Ulmen vor Jahrhunderten durch den großen Grafiozz (einen gewaltigen Zauberspruch des mächtigen Bwork Magus der dunklen Höhlen) nahezu alle entwurzelt wurden.",ep:3,g:140,l:90,wd:true,fm:true,w:5,p:0};
I.u[471] = {n:"Ahornholz",t:38,d:"Die Ahornblätter mussten einst wenig einfallsreichen Leuten als Flagge herhalten. Doch kann man aus ihnen leckeren Sirup machen, um Crêpes zu verfeinern. Was das Holz angeht, so rätseln die Holzfäller immer noch, wozu es gut sein könnte.",ep:1,g:153,l:40,wd:true,fm:true,w:5,p:0};
I.u[472] = {n:"Hainbuchenholz",t:38,d:"Das Hainbuchenholz verdankt seinen Namen den Sadidas, die sich ausschließlich unter Hainbuchen fortzupflanzen pflegten, und dies ziemlich hanebüchen. Um dies mehr oder minder geheimzuhalten, hieß es zur Paarungszeit unter den Sadidas immer nur \"Komm, lass uns hanebüchen\", was ganz einfach bedeutete \"Komm, geh\'n wir zu den Hainbuchen\". Die Gründe hierfür sind ein großes Geheimnis. Einzig im uralten Grimoire des Bwork Magus soll es noch einen versteckten Hinweis darauf geben.",ep:1,g:138,l:80,wd:true,fm:true,w:5,p:0};
I.u[473] = {n:"Kastanienholz",t:38,d:"Der Geruch von Kastanienholz vertreibt Mücken, sagt man. Mit Ausnahme derjenigen, die den Geruch von Kastanien mögen oder ihren Geruchssinn verloren haben. Also mit Ausnahme so gut wie aller Mücken, weshalb an diesem Gerücht auch nichts Wahres dran ist.",ep:1,g:86,l:10,wd:true,fm:true,w:5,p:0};
I.u[474] = {n:"Vogelkirschholz",t:38,d:"Dieses Holz wird von Skulpteuren sehr geliebt. Dank seiner kompakten Textur, seiner schönen Maserung und dem rot-braunen Ton, den es mit der Zeit erhält, lassen sich daraus wahre Meisterwerke fertigen.",ep:1,g:139,l:60,wd:true,fm:true,w:5,p:0};
I.u[476] = {n:"Walnussholz",t:38,d:"Walnussholz wird sehr gern für die Fertigung von Möbeln verwendet. Man könnte es auch für den Schiffsbau nutzen, doch weigern sich aus unerfindlichen Gründen manche Zimmermänner, dieses Holz einzusetzen.",ep:1,g:95,l:20,wd:true,fm:true,w:5,p:0};
I.u[477] = {n:"Schweinedrachenblut",t:15,d:"Diese Phiole enthält das Blut, welches Schweinedrachen die gewaltigen teuflischen Kräfte verleiht. Nur in Maßen verwenden oder gut kochen lassen, wenn ihr wieder einmal schwarze Schweinedrachenblutwurst herstellen wollt.",ep:2,g:544,l:70,wd:true,fm:true,w:10,p:100};
I.u[478] = {n:"Hainbuchenbestutzer",t:19,d:"Der Ursprung des Namens dieser Axt ist auf die Holzfällerin Woodee Woodschrecker zurückzuführen, die ihren ganzen Charme dafür aufwandte, die Aufmerksamkeit der anderen Holzfäller zu erregen, um so die Position der letzten Hainbuchen geheimzuhalten, deren Existenz sie schützen wollte.",ep:7,g:3,l:47,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,40,40,false,false],c:"CW>20&CI>20&CC>20",p:5900};
I.u[479] = {n:"Elfenbein",t:47,d:"Elfenbein wird von Sammlern auf Grund seiner legendären Reinheit und von Schmieden als Beimischung zur Herstellung noch tödlicherer Waffen gesucht. Doch nur deshalb gleich eine ganze Küste Amaknas danach zu benennen, geht doch ein wenig zu weit!",ep:1,g:88,l:40,wd:true,fm:true,w:10,p:100};
I.u[480] = {n:"Seltsames Erz",t:39,d:"Dieses seltsame Erz stammt aus einem rätselhaften, geheimen Bergwerk. Im Gegensatz zu all den anderen seltsamen Gegenständen in Amakna ist es allerdings überhaupt nicht magisch.",ep:1,g:90,l:24,wd:true,fm:true,w:5,p:100};
I.u[481] = {n:"Schweinedrachenschädel",t:47,d:"Trotz des geringen Inhaltes ist dieser Schädel ein tolles Studienobjekt. Seine Ähnlichkeit mit Iop-Schädeln hat bereits vielen Medizinstudenten dabei geholfen, die mangelnde Intelligenz von gewissen Iops eingehend zu erforschen.",ep:2,g:91,l:70,wd:true,fm:true,w:50,p:100};
I.u[482] = {n:"Baggers Schaufel",t:8,d:"Ein Enutrof, der wohl in der Taverne ein wenig über seinen Durst getrunken hatte, stellte eines Tages fest, dass sich diese ursprünglich zum Ausheben unterirdischer Gänge konzipierte Schaufel auch hervorragend dazu eignet, die dicken Schädel von Gegnern zu bearbeiten.",ep:1,g:8,l:27,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>7&CC>20",p:2200};
I.u[483] = {n:"Große Baggers Schaufel",t:8,d:"Ein Enutrof, der wohl in der Taverne ein wenig über seinen Durst getrunken hatte, stellte eines Tages fest, dass sich diese ursprünglich zum Ausheben unterirdischer Gänge konzipierte Schaufel auch hervorragend dazu eignet, die dicken Schädel von Gegnern zu bearbeiten.",ep:1,g:8,l:29,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>9&CC>20",p:2500};
I.u[484] = {n:"Mächtige Baggers Schaufel",t:8,d:"Ein Enutrof, der wohl in der Taverne ein wenig über seinen Durst getrunken hatte, stellte eines Tages fest, dass sich diese ursprünglich zum Ausheben unterirdischer Gänge konzipierte Schaufel auch hervorragend dazu eignet, die dicken Schädel von Gegnern zu bearbeiten.",ep:1,g:8,l:31,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>11&CC>20",p:2800};
I.u[485] = {n:"Lederschlüpfer des Chafer-Lanzenträgers",t:56,d:"Wenn es Winter wird, geht ein Chafer-Lanzenträger niemals ohne seinen Lederschlüpfer aus dem Haus. Denn dieser erfüllt gleich mehrere Zwecke: einerseits hält er die Gelenke warm und zum anderen lenkt er die Gegner ab.",ep:1,g:152,l:44,wd:true,fm:true,w:10,p:100};
I.u[486] = {n:"Keiler-Leder",t:56,d:"Dieses sehr strapazierfähige Leder besitzt leider den Nachteil, einen strengen Geruch nach brünftigem Keilermännchen abzusondern. Daher wird es gerne von den örtlichen Bauern eingesetzt, um weibliche Wildschweinsäue zu fangen, die zu idiotisch sind, um solch hinterhältige Taktiken zu durchschauen.",ep:1,g:16,l:14,wd:true,fm:true,w:10,p:1};
I.u[487] = {n:"Schweinedrachen-Leder",t:56,d:"Da sich der Schweinedrachen für einen echten Drachen hält, pflegt er sich beim Feuerspeien immer gehörig den Wanst zu verbrennen. Das ist auch der Grund, warum dieses Leder stets etwas verbrannt riecht.",ep:2,g:142,l:70,wd:true,fm:true,w:10,p:6000};
I.u[489] = {n:"Lupe",t:20,d:"Dank dieser Lupe könnt ihr die Innenausstattung von Räumen untersuchen, um Spuren von Schätzen zu entdecken.",ep:1,g:3,l:1,wd:true,fm:true,w:10,an:3,e:[1,6,1,1,100,10,false,false],p:10};
I.u[490] = {n:"Phiole",t:20,d:"Diese Art von Phiole nutzt jeder Alchimist, der etwas auf sich hält, um wieder einmal die besten Tränke von ganz Amakna darin einzufüllen.",ep:1,g:2,l:1,wd:true,fm:true,w:3,an:4,e:[1,6,1,1,200,2,false,false],p:10};
I.u[491] = {n:"Einfassmesser",t:5,d:"Mit einem solchen Messer kann ein Juwelier Schmuckstücke bearbeiten.",ep:1,g:16,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[492] = {n:"Nudelholz",t:20,d:"Dieses Werkzeug ist absolut notwendig, wenn ihr das Handwerk eines Bäckers oder Konditors ausüben wollt.",ep:1,g:1,l:1,wd:true,fm:true,w:8,an:4,tw:true,e:[50,6,1,1,500,10,false,false],p:10};
I.u[493] = {n:"Hammer des Hammerschmiedes",t:7,d:"Dieses Werkzeug wird bei der Herstellung von Hämmern benötigt.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[494] = {n:"Hammer des Schwertschmiedes",t:7,d:"Dieses Werkzeug wird bei der Herstellung von Schwertern benötigt.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[495] = {n:"Hammer des Dolchschmiedes",t:7,d:"Dieses Werkzeug wird bei der Herstellung von Dolchen benötigt.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[496] = {n:"Hammer des Schaufelschmiedes",t:7,d:"Dieses Werkzeug wird bei der Herstellung von Schaufeln benötigt.",ep:1,g:2,l:1,wd:true,fm:true,w:15,an:15,e:[5,4,1,1,50,50,false,false],p:150};
I.u[497] = {n:"Spitzhacke des Bergmanns",t:21,d:"Dieses Werkzeug ist zum Abbau von Erz einfach unentbehrlich.",ep:1,g:1,l:1,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[498] = {n:"Schnitzmesser für Stecken",t:5,d:"Ein solches Messer wird zum Schnitzen von Stecken benötigt.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[499] = {n:"Schnitzmesser für Stäbe",t:5,d:"Ein solches Messer wird zum Schnitzen von Stäben benötigt.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[500] = {n:"Schnitzmesser für Bögen",t:5,d:"Ein solches Messer wird zum Schnitzen von Bögen benötigt.",ep:1,g:17,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[501] = {n:"Modifizierter Astaknydensaft",t:15,d:"Dieses sirupartige Harz wurde einmal versuchsweise von einem namhaften Alchimisten verwendet, um abgetrennten Astaknydenwurzeln wieder neues Leben einzuflößen. Ein Fehlschlag. Doch sollte es ausschließlich von erfahrenen Alchimisten gehandhabt werden.",ep:2,g:162,l:30,wd:true,fm:true,w:2,p:50};
I.u[502] = {n:"Spaltaxt der Eiben und Elben",t:19,d:"Diese Axt ist eine der wenigen, die in der Lage sind, auch verzauberte Bäume zu fällen. Das bedeutet, dass sie alles zerschneidet, was magisch ist – ganz gleich, ob lebendig oder nicht.",ep:1,g:4,l:17,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,50,false,false],c:"CS>10&CI>35",p:950};
I.u[515] = {n:"Boulgourde der Lichtungen",t:19,d:"Diese Axt gehörte einmal dem berühmten Holzfäller Bruce Boulgour, der Kassiopoe Benn, die Tochter eines anderen großen Holzfällers, geheiratet hatte. Mit dieser Waffe pflegte er sich des Nachts zu verteidigen, wenn er loszog, um ganze Wälder niederzumähen.",ep:7,g:5,l:62,wd:true,fm:true,w:60,an:17,tw:true,e:[15,6,1,1,50,40,false,false],c:"CI>124&CC>30&CV>10",p:10100};
I.u[519] = {n:"Wunderpulver",t:48,d:"Dieses Wunderpulver wurde aus Flachssamen und Brot gewonnen. Doch erklärt diese noch lange nicht seine magische Wirkung.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[520] = {n:"Mohnbrot",t:33,d:"Die Herstellung dieses Brotes ist heikel, da Bäcker, die beim Backen dieser Brote zu nah am Ofen stehen, manchmal seltsame Symptome zeigen. Es wurden bereits welche gesehen, die dann splitternackt tanzend um ihre Bäckerei herumgehüpft sind...",ep:1,g:10,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[521] = {n:"Sesambrot",t:33,d:"Die Mutigsten unter den Kwacks verkleiden sich manchmal als Amaknaische Bäcker, um Sesamkörner zu stehlen. Doch dieses Versteckspiel funktioniert bei niemanden, außer vielleicht bei Iop-Bäckern.",ep:1,g:11,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[522] = {n:"Leinsamenbrot",t:33,d:"Dieses Brot ist reich an Proteinen, doch arm im Geschmack. Leider kommt niemand darum herum, schwere Entscheidungen im Leben zu treffen, wie \"Essen oder nicht essen?\"",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[524] = {n:"Haselnussbrot",t:33,d:"Dieses irgendwie nussig schmeckende Brot enthält garantiert keine Farbstoffe oder Konservierungsmittel, was man von den königlichen Gelees nicht behaupten kann.",ep:1,g:12,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[526] = {n:"Mehrkornbrot",t:33,d:"Dieses Brot besteht aus einer Vielzahl von Getreidesorten und enthält genügend Proteine, um selbst einen Chafer wieder zum Leben zu erwecken.",ep:1,g:6,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[527] = {n:"Walnussbrot",t:33,d:"Dieses Brot wird mit Walnussbaumholz gebacken und die Walnüsse werden erst einmal angeröstet, bevor sie in den Teig gebettet werden. Dies garantiert eine 100%ige Nussigkeit.",ep:4,g:8,l:40,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[528] = {n:"Vollkornbrot",t:33,d:"Dieses Brot ist mit Vollkorn angereichert. Daher ist es oft das tägliche Brot der anspruchsvollen, hart arbeitenden Handwerksmeister.",ep:1,g:7,l:20,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[529] = {n:"Gerstenmehl",t:52,d:"Diese Mehl erhält man, wenn in der Mühle Gerstenkörner zermahlen werden. Es verleiht dem Brot unverwechselbare Leichtigkeit, die nur noch übertroffen werden kann, wenn man beim Backen des Brotes dunkle Zaubermächte heraufbeschwört.",ep:1,g:256,l:1,wd:true,fm:true,w:2,p:0};
I.u[530] = {n:"Roggenmehl",t:52,d:"Dieses Mehl hat alle guten Eigenschaften des Roggens geerbt. Der Legende nach soll Roggen, der bei Sonnenaufgang keimt, niemals völlig ausreifen. Darum zeugen abergläubige Bauern ihre Kinder auch bei Sonnenaufgang in der Hoffnung, dass sie niemals altern...",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[531] = {n:"Hafermehl",t:52,d:"Dieses Mehl geht beim Backen nicht auf. Darum ergibt es sehr dichte und nahrhafte Brote. Sehr praktisch, wenn man Monster füttern muss oder will.",ep:1,g:250,l:1,wd:true,fm:true,w:2,p:0};
I.u[532] = {n:"Roggen",t:34,d:"Dieses dunkle Getreide wächst und gedeiht selbst unter schlechten Bedingungen. Es ist eine der wenigen Getreidesorten, die sogar lange Dürreperioden überleben kann.",ep:1,g:82,l:50,wd:true,fm:true,w:2,p:0};
I.u[533] = {n:"Hafer",t:34,d:"Diese Getreidesorte wird gern dazu benutzt, junge Tabis zu füttern, die sie mit ihren noch nicht ausgewachsenen Zähnen noch nicht wiederkäuen können. Allerdings muss die Menge an Hafer sorgfältig kontrolliert werden, da Hafer bei Tabis mit empfindlichen Mägen schwere Blähungen verursachen kann.",ep:1,g:154,l:20,wd:true,fm:true,w:2,p:0};
I.u[534] = {n:"Malzmehl",t:52,d:"Dieses weißliche Mehl erhält man durch das Mahlen von gekeimten Gerstenkörnern. Es verleiht dem Brot einen leicht säuerlichen und im besten Fall einen leichten Biernachgeschmack. Ideal für die langsame Entwöhnung von Alkoholikern.",ep:1,g:255,l:1,wd:true,fm:true,w:2,p:0};
I.u[535] = {n:"Hopfenmehl",t:52,d:"Dieses Mehl verleiht dem Brot einen delikaten Biergeschmack, ohne dass man dafür Bier in den Brotteig schütten müßte. Manchmal ist die Natur eben doch zu etwas gut.",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[536] = {n:"Haferflockenbrot",t:33,d:"Dieses sehr leichte Brot ist ideal für alle, die von Mutter Natur mit einem ganz kleinen Magen gestraft wurden.",ep:1,g:5,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[537] = {n:"Kartoffeln",t:68,d:"Wenn ihr als Abenteurer über ein solches Gemüse stolpert, dann liegt es entweder daran, dass ihr gerade ein Kartoffelfeld überquert, oder dass ihr euch in Einzelhaft im Gefängnis befindet.",ep:1,g:135,l:1,wd:true,fm:true,w:20,p:10};
I.u[538] = {n:"Geschälte Kartoffeln",t:68,d:"Diese geschälte Kartoffel hat zwar ihre Haut verloren, ist allerdings trotzdem noch genießbar.",ep:1,g:136,l:1,wd:true,fm:true,w:20,p:10};
I.u[539] = {n:"Roggenbrot",t:33,d:"Dieses Brot wurde aus Roggenmehl gebacken. Dadurch erhält das Innere die charakteristische, leicht bräunliche Färbung und das Brot den leicht süßlichen Geschmack.",ep:1,g:9,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[543] = {n:"Diamant",t:51,d:"Korrekt geschliffen und poliert ergibt dieser Stein einen wunderschönen Diamanten.",ep:1,g:144,l:30,wd:true,fm:true,w:20,p:15};
I.u[544] = {n:"Smaragd",t:51,d:"Korrekt geschliffen und poliert ergibt dieser Stein einen wunderschönen Smaragd.",ep:1,g:145,l:30,wd:true,fm:true,w:20,p:15};
I.u[545] = {n:"Kristall",t:51,d:"Korrekt geschliffen und poliert ergibt dieser Stein einen wunderschönen Kristall.",ep:1,g:141,l:30,wd:true,fm:true,w:20,p:15};
I.u[546] = {n:"Saphir",t:51,d:"Korrekt geschliffen und poliert ergibt dieser Stein einen wunderschönen Saphir.",ep:1,g:151,l:30,wd:true,fm:true,w:20,p:15};
I.u[547] = {n:"Rubin",t:51,d:"Korrekt geschliffen und poliert ergibt dieser Stein einen wunderschönen Rubin.",ep:1,g:150,l:30,wd:true,fm:true,w:20,p:15};
I.u[548] = {n:"Rückruftrank",t:12,d:"Dieser Trank bringt einen Abenteurer an den letzten Ort zurück, den er gespeichert hat.",ep:1,g:17,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[577] = {n:"Bauernsense",t:22,d:"Diese rostige und stumpfe Sense ist nicht gerade eine wirkungsvolle Waffe. Andererseits ist sie ein ideales Werkzeug zum Mähen ganzer Felder.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:150};
I.u[578] = {n:"Wetzstein",t:51,d:"Jetzt braucht ihr nicht mehr herumzuwetzen. Nutzt einfach diesen Stein dafür.",ep:2,g:127,l:1,wd:true,fm:true,w:20,p:1};
I.u[579] = {n:"Ledermesser",t:5,d:"Ein solches Messer wird zum Zuschneiden von Schuhen und Gürteln benötigt.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,4,1,1,50,50,false,false],p:150};
I.u[580] = {n:"Zetermaid-Trank",t:12,d:"Dieser Trank gibt dem Anwender eine kleine Menge an Energie zurück.",ep:1,g:18,l:10,wd:true,fm:true,w:1,u:true,p:20};
I.u[582] = {n:"Weißmehl",t:52,d:"Für dieses Mehl benötigt man eine ganze Reihe verschiedener Getreidesorten. Jedoch wird es für seine hervorragende Qualität zum Brotbacken sehr geschätzt, auch wenn Bäckerlehrlinge es gern mit gewöhnlichem Weizenmehl verwechseln.",ep:1,g:7,l:1,wd:true,fm:true,w:2,p:0};
I.u[583] = {n:"Kussmehl",t:52,d:"Dieses halbweiße Mehl wurde nach der Lieblingsbeschäftigung seines Erfinders benannt, einer jungen Bäuerin, die es genoß, mit mehlverschmierten Wangen Küsse zu verteilen.",ep:1,g:7,l:20,wd:true,fm:true,w:2,p:0};
I.u[586] = {n:"Bauernmehl",t:52,d:"Es war zu dem Zeitpunkt, an dem Shika Ingalsse die Frau von Bruce Boulgour mit Mehlsackschlägen von ihren Broten vertrieb, dass ihr das Rezept zu diesem hervorragenden Mehl einfiel. Wie man sieht, sind Frauenkämpfe manchmal mehr als bloße Zerstreuung für die Massen.",ep:1,g:258,l:30,wd:true,fm:true,w:2,p:0};
I.u[587] = {n:"Vollmehl",t:52,d:"Dieses Mehl besteht aus einer Vielzahl von Getreidesorten. Darum steckt darin eine vollständige Mahlzeit, weshalb man es auch für Vollkornbrote benutzt.",ep:1,g:259,l:40,wd:true,fm:true,w:2,p:0};
I.u[592] = {n:"Ivan Haus-Sehne",t:2,d:"Dieser Bogen gehörte Ivan Hau, einem kampferprobten Crâ, der bereits mehr als einen entlaufenen Tofu niedergestreckt hat. Dieser Bogen hat die Besonderheit, den Gegner durch besondere Trickschüsse zu überraschen, die ihn erst perplex machen und dann sterbend zu Boden fallen lassen.",ep:7,g:1,l:36,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,7,15,50,false,true],c:"CS>30&CA>36",p:3600};
I.u[593] = {n:"Freyliche Orchidee",t:35,d:"Diese Blüte ist sehr selten und unglaublich schön, doch leider kaum mehr zu finden, denn viele Krötenarten pflegen mit diesen Orchideen ihren Nachwuchs zu füttern...",ep:1,g:192,l:40,wd:true,fm:true,w:1,p:0};
I.u[594] = {n:"Edelweiss",t:35,d:"Diese Blüte ist sehr selten und unglaublich schön, doch leider kaum mehr zu finden, denn ihre Magie wäre sogar in der Lage, Tote ins Leben zurückzubringen.",ep:1,g:191,l:50,wd:true,fm:true,w:1,p:0};
I.u[595] = {n:"Hobel des Schreiners",t:20,d:"Mit diesem Hobel können die Schreiner Baumstämme bearbeiten, um daraus Bretter oder Balken zu machen. Ein faszinierendes Handwerk für alle, die Holzhäuser lieben.",ep:1,g:19,l:1,wd:false,fm:true,w:1,e:[1,4,1,1,100,100,false,false],p:10};
I.u[596] = {n:"Kurze Angel",t:20,d:"Diese kurze Angel ist einfach ideal, um kleine Fische aus kleinen Teichen zu angeln.",ep:1,g:8,l:1,wd:true,fm:true,w:1,an:18,e:[1,4,1,1,100,100,false,false],p:200};
I.u[597] = {n:"Fangnetz",t:99,d:"Dieses sehr widerstandsfähige Netz ermöglicht es, selbst das Wildeste aller Reittiere einzufangen, vorausgesetzt man konnte es vorher ein wenig hypnotisieren oder ablenken.",ep:20,g:1,l:1,wd:true,fm:true,w:1,an:0,p:10};
I.u[598] = {n:"Greu-Vette",t:41,d:"Greu-Vetten werden für ihre rosa Farbe und ihren feinen Geschmack sehr geschätzt. Umgekehrt hasst man sie aber auch für ihren legendären schlechten Charakter und ihre schmierigen Antennen.",ep:1,g:292,l:1,wd:true,fm:true,w:1,p:10};
I.u[600] = {n:"Krakamor",t:41,d:"Krakamors sind große Romantiker. Ihre kleinen Tofu-Augen sehen zwar niedlich aus, doch irrt euch da mal nicht. Diese Wesen haben es faustdick hinter den Ohren. Außerdem sind sie auch sehr aggressiv zu Fremden.",ep:2,g:309,l:20,wd:true,fm:true,w:1,p:10};
I.u[602] = {n:"Sichel-und-Hammerhai",t:41,d:"Dieser rote Hai (von der Gesinnung her) ist ein echter Kämpfer für die gerechte Sache. \"Einer für alle und alle für Einen\", auf die Herde, euh... Horde kommt es an. Für Individualisten gibt es keinen Platz in der Gruppe, ausgenommen ihren Chef, den Hai Starkhainovitsch, der von der ganzen Horde als Idol und Vorbild verehrt wird.",ep:2,g:322,l:80,wd:true,fm:true,w:2,p:1};
I.u[603] = {n:"Kätzchenfisch",t:41,d:"Dieser Fisch hat die Eigenheit, Barthaare zu tragen und unter Wasser zu schnurren, was alle fliegenden Fische der Umgebung in Angst und Schrecken zu versetzen pflegt.",ep:1,g:277,l:1,wd:true,fm:true,w:1,p:50};
I.u[607] = {n:"Schlammige Forelle",t:41,d:"Die schlammige Forelle ist ein entfernter Artverwandter vom aggressiven Somoon, den man auf der Moon-Insel findet. Wer hätte das gedacht?",ep:1,g:395,l:1,wd:true,fm:true,w:1,p:50};
I.u[610] = {n:"Krebshalskette",t:1,d:"Dieses weißliche Amulett wurde aus Krebsschalen gefertigt, was es zwar sehr zerbrechlich, aber auch originell erscheinen lässt.",ep:1,g:30,l:24,wd:true,fm:true,w:2,p:1800};
I.u[616] = {n:"Halskette des Seebären",t:1,d:"Dieser Halskette aus großen Fischschuppen sagt man nach, dass sie den Träger selbst bei stürmischen Seegang vor Unheil bewahren soll.",ep:1,g:29,l:22,wd:true,fm:true,w:2,p:2000};
I.u[617] = {n:"Piratenamulett",t:1,d:"Diese furchterregende Amulett hat bereits mehr als einen Seemann beeindruckt. Schon das bloße Tragen verbreitet Angst und Schrecken.",ep:1,g:20,l:41,wd:true,fm:true,w:2,p:4500};
I.u[619] = {n:"Stecken der Fresssackhirten",t:4,d:"Mit diesem Stecken konnte der Fresssackhirten Farle Ingalsse Tofus beschwören, die seine Herden bewachten. Im Laufe der Zeit stellte sich heraus, dass dieser Stecken gleichfalls eine hervorragende Waffe im Kampf abgibt.",ep:7,g:6,l:85,wd:true,fm:true,w:20,tw:true,e:[10,3,1,1,30,100,false,false],c:"CI>60&CW>20&CA>40",p:10000};
I.u[620] = {n:"Krakamorzersäbel",t:6,d:"Mit diesem Säbel konnte der berühmte Seemann Mobbly Dickmann die Tentakel des für das Ersticken betrunkener Seebären berüchtigten Riesenkrakamors von Moons Insel in Scheiben tranchieren.",ep:1,g:8,l:61,wd:true,fm:true,w:50,an:14,e:[10,7,1,1,50,50,false,false],c:"CV>60&CW>60",p:9900};
I.u[629] = {n:"Spitzhut",t:16,d:"Dieser wunderschöne Hut wird euch sicherlich wieder eine Auszeichnung zum bestverkleidetsten Abenteurer auf dem jährlichen Kindermaskenball bescheren. Einfach stylisch!",ep:5,g:1,l:21,wd:true,fm:true,w:5,p:1400};
I.u[638] = {n:"Amulett des Somoon-Fischers",t:1,d:"Einen Somoon zu fischen ist kaum machbar, doch mit diesem Amulett ist für den Träger nichts mehr unmöglich.",ep:12,g:24,l:35,wd:true,fm:true,w:5,p:2500};
I.u[639] = {n:"Amulett des Abgrunds",t:1,d:"Dieses Amulett wurde im auf Grund gelaufenen Wrack des bekannten Krakamor-Fischers, Moby Drifftick, gefunden, der in einem großen Umkreis für seine lausigen Witze in der Piratenbar bekannt war.",ep:14,g:22,l:47,wd:true,fm:true,w:5,p:6000};
I.u[640] = {n:"Küstenbogen",t:2,d:"Dieser Bogen wurde für Fischer entwickelt, welche die Küste von herumlungerndem Ungeziefer befreien wollten, ohne dafür von ihrem Sitz aufstehen zu müssen. Und dies auch noch durch das Fenster ihrer Lieblingskneipe hindurch. Wahnsinn!",ep:14,g:38,l:46,wd:true,fm:true,w:10,an:10,tw:true,e:[10,4,2,10,30,45,false,true],c:"CA>46",p:5600};
I.u[641] = {n:"Urwolle",t:15,d:"Diese Wolle ist weich wie das Haarkleid eines jungen Ecaflippchen, weiß wie ein Frühlingswölkchen, aber auch zerbrechlich wie eine Tofufeder.",ep:1,g:657,l:6,wd:true,fm:true,w:1,p:500};
I.u[642] = {n:"Seidenraupenkokon",t:15,d:"Dieser enorme Kokon kann ausgerollt werden, bis nur noch ein gewaltiger, schillernder Seidenfaden übrigbleibt. Der Abenteurer Harry Hane benutzte einst diesen Trick, um aus dem Labyrinth des Dark Vlads zu entkommen.",ep:1,g:489,l:6,wd:true,fm:true,w:1,p:100};
I.u[643] = {n:"Seidenfaden",t:15,d:"Dieser Faden ist unvergleichlich fein und dehnbar. Darum ist er bei den Chafern bei Weitem das beliebteste Material für die Herstellung kampftauglicher Unterwäsche.",ep:1,g:486,l:5,wd:true,fm:true,w:1,p:100};
I.u[646] = {n:"Black Tiwabbit-Haare",t:54,d:"Diese schwarzen Haare haben den großen Vorteil, dass man den Dreck darin nicht sieht, was sicher viele Helden erfreuen wird. Doch Vorsicht: bei starkem und ätzenden Schweiß verfärben sich diese Haare gern weißlich.",ep:8,g:195,l:11,wd:true,fm:true,w:1,p:50};
I.u[648] = {n:"Wabbit-Haare",t:54,d:"Dieses Haar wird von erfahrenen Schneidern nicht so gern verwendet, obwohl es aufgrund seines Zitronellol-Geruchs den Vorteil hat, Moskitos zu vertreiben.",ep:8,g:196,l:18,wd:true,fm:true,w:1,p:1};
I.u[649] = {n:"Wo Wabbit-Haare",t:54,d:"Diese Haare sind dermaßen fettig, dass sie völlig wasserabweisend wirken.",ep:8,g:197,l:39,wd:true,fm:true,w:1,p:40};
I.u[650] = {n:"Grand Pa-Wabbit-Haare",t:54,d:"Dieses schlecht riechende Haar wird nur ungern von Schneidern verwendet, da es ganz zottelig wirkt, wenn es mit Kawottensaft in Kontakt gerät.",ep:8,g:198,l:39,wd:true,fm:true,w:1,p:50};
I.u[651] = {n:"WuWulfpelz",t:55,d:"Dieser Pelz aus WuWulfhaar ist sehr selten. Doch dafür ist er sehr strapazierfähig und widersteht sowohl magischen, als auch physikalischen Angriffen.",ep:1,g:199,l:70,wd:true,fm:true,w:1,p:100};
I.u[652] = {n:"Keilerpelz",t:55,d:"Dieser Keilerpelz ist rau und übelriechend, doch auch sehr strapazierfähig. Er widersteht fast allen physikalischen Angriffen.",ep:1,g:220,l:13,wd:true,fm:true,w:1,p:50};
I.u[653] = {n:"Prespik-Pelz",t:55,d:"Unter seinen Stacheln besitzt der Prespik einen weichen, roten Pelz, der einen strengen Geruch verbreitet, wenn er nass wird. Da es in Amakna niemals regnet, gibt es natürlich auch keine Gefahr, doch vermeidet dennoch, euch eine Badehose daraus schneidern zu lassen.",ep:1,g:661,l:17,wd:true,fm:true,w:1,p:100};
I.u[654] = {n:"Wabbitpelz",t:55,d:"Dieser Pelz aus Barthaaren des Grand Pa-Wabbits ist zwar sehr dicht, aber leider auch ziemlich kratzig, ein wenig wie eine dicke Raupe mit giftigen Haaren.",ep:8,g:15,l:18,wd:true,fm:true,w:1,p:100};
I.u[657] = {n:"Stecken der Tofuhirten",t:4,d:"Mit diesem Stecken kann die Tofuhirtin Shika Ingalsse Tofus beschwören, welche die Herden bewachen. Im Laufe der Zeit stellte sich heraus, dass dieser Stecken gleichfalls eine hervorragende Waffe im Kampf abgibt.",ep:7,g:6,l:56,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>40&CW>10&CS>30",p:5600};
I.u[658] = {n:"Stecken der Tabihirten",t:4,d:"Mit diesem Stecken kann die Tabihirtin Gramine Ingalsse Tofus beschwören, welche die Herden bewachen. Im Laufe der Zeit stellte sich heraus, dass dieser Stecken gleichfalls eine hervorragende Waffe im Kampf abgibt.",ep:7,g:6,l:34,wd:true,fm:true,w:10,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>20&CW>5",p:3400};
I.u[666] = {n:"Püree Pikfeyl",t:15,d:"Es hat sich auf Frigost eingebürgert, diese kulinarische Katastrophe zu servieren, sobald ein dummer Fehler mit maximalen Auswirkungen auftritt. Warum auch immer...",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:0};
I.u[673] = {n:"Kastanienfresser",t:19,d:"Diese Axt ist in keinster Weise außergewöhnlich, außer dass ihr Schaft aus Kastanienholz besteht, welches für sein geringes Gewicht sehr geschätzt wird. Dadurch liegt diese Axt so leicht in der Hand wie die Feder eines jungen Schattentofus.",ep:1,g:6,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>8&CA>3",p:400};
I.u[674] = {n:"Spalter der Vogelkirschen",t:19,d:"\"Diese Axt hat alles, was eine gute Axt haben muss\", lobte sie einmal der bekannte Holzfäller Bruce Boulgour. In der Tat. Sie lässt sich leicht und kontrolliert durch die Luft schwingen und der Griff aus echtem Vogelkirschenholz absorbiert die auftretenden Vibrationen beim Spalten massiver Baumstämme oder dicker Bworkschädel.",ep:1,g:7,l:32,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>40",p:2900};
I.u[675] = {n:"Walnussknacker",t:19,d:"Die gewöhnlich erscheinende Axt ist sehr wirkungsvoll. Mit diesem Werkzeug gewann Bruce Boulgour nämlich einst den Wettkampf im Bworkzwergspalten. Das nur als kleine Erinnerung an die Wirksamkeit dieser Axt.",ep:1,g:8,l:21,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CV>30",p:1350};
I.u[676] = {n:"Ahornesser",t:19,d:"Diese Axt hat den großen Vorteil, nicht zu rosten. Das vermeidet sicherlich unliebsame Überraschungen bei allen Naschkatzen unter den Holzfällern, die gern am Ende ihres anstrengenden Tagewerkes den süßen Ahornsirup von den Axtblättern ablecken.",ep:1,g:10,l:25,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CA>30",p:1850};
I.u[677] = {n:"Piratenumhang",t:17,d:"Dieser Umhang gehörte einst einem alten Piraten namens Zokrim. Er soll nicht nur ein schräger Vogel, sondern vor allem ein ganz schöner Pechvogel gewesen sein...",ep:1,g:11,l:1,wd:true,fm:true,w:10,p:1};
I.u[678] = {n:"Elfenbeinfarbige Schriftrolle",t:13,d:"(Doppelklick, um Erfahrungspunkte zu erhalten.) \nDiese Schriftrolle gibt dem Leser Erfahrungspunkte, ohne dass dieser irgendein Risiko dafür eingehen muss.",ep:1,g:3,l:25,wd:true,fm:true,w:1,u:true,p:1};
I.u[679] = {n:"Weiße Schriftrolle",t:13,d:"(Doppelklick, um Erfahrungspunkte zu erhalten.) \nDiese Schriftrolle gibt dem Leser Erfahrungspunkte, ohne dass dieser irgendein Risiko dafür eingehen muss.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[680] = {n:"Goldene Schriftrolle",t:13,d:"(Doppelklick um Erfahrungspunkte zu erhalten) \nDiese Schriftrolle gibt dem Leser Erfahrungspunkte, ohne dass dieser irgendein Risiko dafür eingehen muss.",ep:1,g:3,l:50,wd:true,fm:true,w:1,u:true,p:1};
I.u[683] = {n:"Kleine Schriftrolle der Stärke",t:76,d:"(Doppelklick, um Punkte für Stärke zu erhalten.) \nDiese Schriftrolle erhöht die Stärke des Lesers, ohne dass dieser irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Stärke weniger als 25 Punkte beträgt.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<25",u:true,p:1000};
I.u[684] = {n:"Zauberschriftrolle",t:76,d:"(Doppelklick um Punkte für Zaubersprüche zu erhalten) \nDiese Schriftrolle gibt dem Leser Punkte für Zaubersprüche, ohne dass dieser irgendein Risiko dafür eingehen muss.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:15000};
I.u[686] = {n:"Kleine Schriftrolle der Intelligenz",t:76,d:"(Doppelklick um Punkte für Intelligenz zu erhalten) \nDiese Schriftrolle erhöht die Intelligenz des Lesers, ohne dass dieser irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Intelligenz weniger als 25 Punkte beträgt.",ep:2,g:23,l:1,wd:true,fm:true,w:1,c:"Ci<25",u:true,p:1000};
I.u[690] = {n:"Flachsmehl",t:52,d:"Dieses Mehl ist eigenartig. Es stammt nämlich nicht von einem echten Getreide, was wohl auch erklärt, dass es keiner anderen Mehlsorte ähnelt.",ep:1,g:254,l:1,wd:true,fm:true,w:2,p:0};
I.u[692] = {n:"Stärkendes Brot",t:33,d:"Dieses Brot besteht aus Leinsamen, weshalb es recht fettig ist und ein bräunliches Inneres besitzt. Es steckt voller gesättigter Fettsäuren, schmeckt aber einfach nur widerlich.",ep:1,g:12,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[694] = {n:"Purpur-Dofus",t:23,d:"Dieses Ei wurde vom Feuerdrachen Ignemikhal gelegt. Das Mindeste, was man von ihm behaupten kann, ist, dass es mächtig nach Schwefel stinkt. Aber das ist auch bloß das Mindeste...",ep:1,g:1,l:6,wd:true,fm:true,w:5,p:500000};
I.u[695] = {n:"Schriftrolle des Holzfällers",t:13,d:"(Doppelklick, um Erfahrungspunkte in diesem Beruf zu erhalten)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[696] = {n:"Grobianium",t:16,d:"Das Grobianium macht zwar den Anschein, die letzten 10 Modewechsel übersprungen zu haben, aber dafür ist es sehr wirkungsvoll im Kampf... für einen simplen Strohhut jedenfalls.",ep:1,g:2,l:20,wd:true,fm:true,w:4,p:1300};
I.u[697] = {n:"Makroute",t:16,d:"Der Makroute ist ein sehr anhänglicher Hund... So anhänglich, dass er denjenigen, welchen er als sein neues Herrchen auserkoren hat, nie wieder verlässt... Inzwischen dürfte er dieserart wohl an die 30 Millionen Herrchen gefunden haben.",ep:2,g:3,l:6,wd:true,fm:true,w:6,p:30000};
I.u[698] = {n:"Sprehs schöner Hut",t:16,d:"Sprehs Hut enthält mächtige Magie. Lebendig und doch unsterblich hat er daher bereits die größten Magier aller Zeiten kennengelernt, wie beispielsweise Meinerve Mons Goanidgähr, Rumpelmore von der Alm und den berühmten haarigen Zocker.",ep:1,g:4,l:33,wd:true,fm:true,w:6,p:3000};
I.u[699] = {n:"Troma",t:16,d:"Der Troma ist genauso zwielichtig und furchterregt wie ein Krallkopf mit Tschwantzfehdern. (Alle, die nicht wissen, was ein Krallkopf mit Tschwantzfehdern ist, können dies im großen Buch des Tschuftmann Gurus nachlesen.)",ep:1,g:5,l:22,wd:true,fm:true,w:10,p:1525};
I.u[700] = {n:"Pandawa",t:16,d:"Ah, der Pandawa! Hat er nicht ein ziemlich aufgedunsenes Gesicht? Wie sein Freund Makroute verbringt er am Liebsten einen Großteil seiner Zeit auf dem Kopf seines Herrchens. Wenn er einmal eine bequeme Stellung gefunden hat, bleibt er dort. Nahrung und alles Weitere bezieht er dann von seinem Träger. Sehr praktisch.",ep:2,g:6,l:6,wd:true,fm:true,w:10,c:"PG!10",p:12000};
I.u[701] = {n:"Oiram",t:16,d:"Der Oiram hat bereits viele Anhänger auf allen Teilen der Welt gefunden, da er einfach klasse aussieht...Bevor er in eure Hände kam, wurde er lange Zeit von einem durchgeknallten Klempner getragen, der es liebte, damit durch die Gegend zu rennen und zu hüpfen.",ep:1,g:7,l:22,wd:true,fm:true,w:12,c:"PG!10",p:1525};
I.u[702] = {n:"Kritter",t:16,d:"Dieser Dämonenschädel, der aus den unterschiedlichsten Knöchelchen zusammengefügt wurde, wird seinen  Träger mit Anmut und Eleganz verleihen... Eure Freundinnen werden vor Neid platzen.",ep:1,g:8,l:30,wd:true,fm:true,w:9,c:"PG!10",p:2600};
I.u[703] = {n:"Dora",t:16,d:"Dieser Hut ist nichts anderes als ein umgedrehter, magischer Früchtekorb. Damit werdet ihr bestimmt eure gesamte Umgebung beeindrucken können, vor allem, wenn es sich dabei um junge Bwork Magus-Lehrlinge handelt.",ep:2,g:9,l:36,wd:true,fm:true,w:20,p:3550};
I.u[704] = {n:"Dantgoule",t:16,d:"Mit diesem Hut aus miteinander verknoteten Chafer-Lederunterhosen seid ihr der neue Star... Zumindest bei den weiblichen Bwork Magi mit ihren roten Bärten und ihrer überwältigenden Weiblichkeit...",ep:2,g:10,l:36,wd:true,fm:true,w:10,p:3550};
I.u[705] = {n:"Tromatisierende Maske",t:16,d:"Wenn ihr auf der Suche nach extremen Erfahrungen seid, wird euch diese tromatisierende Gesichtsmaske den echten Kick geben. Aber keine Sorge, es ist gar nicht so schlimm, wie es aussieht. Das Innere ist gepolstert und sogar mit einem Strohhalm und Cocktails versehen.",ep:12,g:11,l:47,wd:true,fm:true,w:10,p:6000};
I.u[706] = {n:"O\'Bouls Kristallkugelhut",t:16,d:"Hugne, der Gedächtnislose, besaß einst eine wunderschöne Kristallkugel, die er von seinem Großvater geerbt hatte. Da er sie zur Erinnerung stets bei sich tragen wollte, befestigte er sie an der Spitze seines Hutes, auf dass sie ihn immer begleiten würde... Doch dann vergaß er sie und starb an Erschöpfung beim Versuch, sie wiederzufinden.",ep:4,g:12,l:24,wd:true,fm:true,w:12,s:38,p:1775};
I.u[707] = {n:"MinotoHorno",t:16,d:"Dieser Hut aus Minotororhörnern ist sehr praktisch, um Gegnern vorzutäuschen, man sei ein gefährlicher Minotoror. Doch leider funktioniert diese List nur bei geistig etwas beschränkten Gegnern. Bei Iops und Tofus sollte das demnach gut klappen.",ep:2,g:13,l:33,wd:true,fm:true,w:10,s:54,p:3000};
I.u[708] = {n:"Houde",t:16,d:"Dieser Hut aus der Haut magischer grüner Larven wird seinem Träger stets munter und fidel aussehen lassen, wenn auch gleichzeitig ziemlich albern. Man kann eben nicht alles haben im Leben. Der Träger dieses Hutes ist übrigens ein sehr gutes Beispiel hierfür.",ep:1,g:14,l:30,wd:true,fm:true,w:8,p:2525};
I.u[709] = {n:"Lorko Kasko",t:16,d:"Dieser Helm aus verzauberter Baumrinde gehörte einst Lorko, einem berühmten Holzfäller, der es sogar wagte, den gefürchteten Holzfäller Bruce Boulgour zu einem Ulmen-Entwurzelungsduell mit bloßen Händen bei der Lichtung von Liroye Merlin herauszufordern.",ep:9,g:15,l:37,wd:true,fm:true,w:9,c:"PG!10",p:3825};
I.u[710] = {n:"Korko Klako",t:16,d:"Do Korko Klako is o Huto und o sehr bo. So genioso, so tollo, so praktiko, doso och die bosten oller Sadidos do Korko Klako ofsetzoen wolln.",ep:1,g:16,l:17,wd:true,fm:true,w:9,c:"PG=10",p:1000};
I.u[711] = {n:"Jouiks Krempe",t:16,d:"Diese hübsche Ledermaske gehörte einst Jouik Krampe, dem Cousin von Zeurg. Beide pflegten stets in hautenger Lederkleidung herumzulaufen. In etwa so wie der Chafer-Offizier, nur ein kleines bisschen weniger pervers.",ep:8,g:17,l:26,wd:true,fm:true,w:15,c:"PG=10",p:2025};
I.u[712] = {n:"Gulliver",t:16,d:"Dieser Hut aus zusammengenähten Ohren ist so originell, dass ihr damit nur einzigartig aussehen könnt. Man erzählt, dass ihn einst Rakmar Bilgout getragen haben soll, um die Königin der Fresssäcke damit zu verführen. Sobald er sein Ziel erreicht hatte, soll er ihr die Kehle durchgeschnitten haben.",ep:13,g:18,l:33,wd:true,fm:true,w:10,p:3075};
I.u[713] = {n:"Schriftrolle des Schwertschmiedes",t:13,d:"(Doppelklick, um Erfahrungspunkte zu erhalten)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[714] = {n:"Schriftrolle des Dolchschmiedes",t:13,d:"(Doppelklick, um Erfahrungspunkte in diesem Beruf zu erhalten)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
