I.u[818] = {n:"Felsenschlüssel von Ded Aléïcar",t:12,d:"Dieser kleine Felsbrocken ist der Schlüssel zur Grotte von Ded Aléïcar. Doch die will erst noch gefunden werden.",ep:4,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[819] = {n:"Heiliges Schwert",t:6,d:"Dies ist ein heiliges Schwert, das jungen Kriegern im Laufe ihrer Ausbildung gegeben wird.",ep:1,g:1,l:15,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>30&CV>3",p:800};
I.u[820] = {n:"Großes heiliges Schwert",t:6,d:"Dies ist ein heiliges Schwert, das jungen Kriegern im Laufe ihrer Ausbildung gegeben wird.",ep:1,g:1,l:16,wd:true,fm:true,w:30,an:14,e:[5,4,1,1,50,50,false,false],c:"CS>32&CV>4",p:900};
