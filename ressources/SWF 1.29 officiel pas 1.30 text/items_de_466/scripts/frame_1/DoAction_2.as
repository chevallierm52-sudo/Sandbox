I.u[716] = {n:"Schriftrolle des Steckenschnitzers",t:13,d:"(Doppelklick, um Erfahrungspunkte in diesem Beruf zu erhalten)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
