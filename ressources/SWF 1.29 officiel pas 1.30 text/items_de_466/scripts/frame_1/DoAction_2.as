I.u[896] = {n:"Mächtige Sylvandolche",t:5,d:"Einst waren diese Dolche speziell dazu geschaffen worden, Wurzeln und junge Triebe zu stutzen, doch dann bemerkte man, dass sie auch als nahezu tödliche Waffe taugen...",ep:1,g:6,l:27,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>27&CI>5",p:2200};
I.u[897] = {n:"Scharfe Minidolche",t:5,d:"Diese gewöhnlich erscheinenden Dolche sind extrem scharf. Sie sind leicht zu verstecken, weshalb sie auch eine bevorzugte Waffe für Meuchelmörder sind.",ep:7,g:10,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30&CW>5",p:2600};
