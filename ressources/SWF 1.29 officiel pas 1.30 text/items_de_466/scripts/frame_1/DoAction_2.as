I.u[718] = {n:"Zauberschriftrolle \"Flammiche\"",t:75,d:"(Doppelklick, um den Elementarzauber \"Flammiche\" zu lernen)",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[719] = {n:"Zauberschriftrolle \"Befreiung\"",t:75,d:"(Doppelklick, um den Elementarzauber \"Befreiung\" zu lernen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[720] = {n:"Zauberschriftrolle \"Blitzschlag\"",t:75,d:"(Doppelklick, um den Elementarzauber \"Blitzschlag\" zu lernen)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[721] = {n:"Zauberschriftrolle \"Arachnee beschwören\"",t:75,d:"(Doppelklick, um den Beschwörungszauber \"Arachnee beschwören\" zu lernen)",ep:16,g:3,l:1,wd:true,fm:true,w:1,u:true,p:10000};
I.u[724] = {n:"Meister des Steckens",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit dem Stecken erheblich mehr Schaden anrichten.",ep:1,g:2,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[725] = {n:"Meister des Schwertes",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit dem Schwert erheblich mehr Schaden anrichten.",ep:3,g:1,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[726] = {n:"Meister des Bogens",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit dem Bogen erheblich mehr Schaden anrichten.",ep:4,g:3,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[727] = {n:"Meister des Hammers",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit dem Hammer erheblich mehr Schaden anrichten.",ep:1,g:4,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[728] = {n:"Meister des Stabes",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit dem Stab erheblich mehr Schaden anrichten.",ep:1,g:5,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[729] = {n:"Meister des Dolches",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit dem Dolch erheblich mehr Schaden anrichten.",ep:2,g:6,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[730] = {n:"Meister der Schaufel",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit der Schaufel erheblich mehr Schaden anrichten.",ep:7,g:7,l:20,wd:true,fm:true,w:1,u:true,p:10000};
I.u[731] = {n:"Spezialzauberschriftrolle \"Bröckll\"",t:75,d:"(Doppelklick, um den Zauberspruch zu lernen)  \nNur Iops können den Spezialzauber \"Bröckll\" lernen.",ep:2,g:4,l:1,wd:true,fm:true,w:1,c:"PG=8",u:true,p:10000};
I.u[732] = {n:"Silimelles Ehering",t:9,d:"Dieser wunderschöne Ehering wurde der Bierbrauerin Silimelle während eines feucht-fröhlichen Gelages in der Taverne gestohlen. Das kommt davon, wenn man sich Unbekannten gegenüber spendabel zeigt...",ep:1,g:30,l:26,wd:true,fm:true,w:1,p:2000};
I.u[733] = {n:"Stiefel von Ragalde",t:11,d:"Ragalde gehörte mit zu den tollkühnsten Iops, falls man bei Iops diesen Begriff überhaupt benutzen kann. Mit diesen Stiefeln hat er eine große Anzahl von Kreaturen aller Art niedergestreckt, die sich bei ihm unbeliebt gemacht hatten.",ep:1,g:7,l:49,wd:true,fm:true,w:1,p:5000};
I.u[734] = {n:"Sicherheitsgürtel",t:10,d:"Dieser Gürtel erlaubt es, den Wächtern des Schlosses von Amakna alle Unruhestifter bei Unruhen oder Volksfesten direkt in Gewahrsam zu nehmen. Wie praktisch, nicht wahr?",ep:1,g:7,l:17,wd:true,fm:true,w:10,p:1000};
I.u[737] = {n:"Smaragd-Dofus",t:23,d:"Dieser Dofus ist noch grüner als ein kranker Tofu. Das Ei wurde von Aerafal, dem Luftdrachen gelegt. Doch damit es so grün wurde, muss dieser ganz schön Luftkrank gewesen sein... Der Gipfel der Seltsamkeit, nicht wahr?",ep:1,g:2,l:6,wd:true,fm:true,w:5,p:500000};
I.u[739] = {n:"Türkis-Dofus",t:23,d:"Dieser Dofus wurde von Aguabrial, dem Wasserdrachen gelegt. Wahnsinn, was ein Drache mit Wasser alles anstellen kann...",ep:1,g:3,l:6,wd:true,fm:true,w:5,p:500000};
I.u[742] = {n:"Gehörnter Stecken",t:4,d:"\"Alles wird vorübergehen... Es wird alles mal vorübergehen\", schrien voller Angst \"Die Rot Behosten\", eine berühmt-berüchtigte Gruppe fahrender, mit dem gehörnten Stecken bewaffneter Sänger. Damit versuchten sie sich Mut zu machen, bevor sie vom gigantischen Ei eines Riesentofus zermalmt wurden.",ep:1,g:1,l:29,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,200,false,false],c:"CC>20&CI>30",p:2350};
I.u[743] = {n:"Goldgelbe Brioche",t:33,d:"Das Rezept dieser Brioche hat Xaver, der Bäcker höchstpersönlich ausgearbeitet, als er sich einmal das Ziel in den Kopf gesetzt hatte, eine Brioche zu backen, die sowohl leichtverdaulich, als auch lecker im Geschmack sein sollte. Ohne jeden Zweifel: beides ist hierbei der Fall.",ep:1,g:8,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[744] = {n:"Bowissen-Umhang",t:17,d:"Dieser Umhang verhält sich wie sein Träger: er ist absolut einzigartig und wird häufig völlig unterschätzt.  \nEr besteht aus vielen zusammengenähten Häuten grüner Larven, was ihm einen pelzigen Eindruck verleiht, der den Umhang so richtig sympathisch macht.",ep:1,g:1,l:20,wd:true,fm:true,w:10,p:1275};
I.u[745] = {n:"Goldbarren",t:40,d:"Dieser Goldbarren wurde erzeugt, indem Rohgold geschmolzen und in Barrenform gepresst wurde.",ep:1,g:241,l:10,wd:true,fm:true,w:1,p:0};
I.u[746] = {n:"Ebonit",t:40,d:"Mit dieser seltenen Legierung lassen sich einige sehr seltene und besonders tödliche Gegenstände herstellen. Denn Ebonit ist ein Metall welches beim Rosten ein sehr wirksames Gift erzeugt.",ep:1,g:658,l:20,wd:true,fm:true,w:20,p:0};
I.u[747] = {n:"Aluminit",t:40,d:"Diese Legierung ist beeindruckend leicht. Demzufolge ist sie ideal für die Fertigung kleiner Dolche und Kurzschwerter.",ep:1,g:660,l:10,wd:true,fm:true,w:10,p:0};
I.u[748] = {n:"Magnesit",t:40,d:"Dieser einzigartigen Legierung schreibt man beinahe magische Kräfte zu. Nachts leuchtet sie im Dunkeln und vibriert. Ein hervorragendes Mittel, einem gutgläubigem Bwork weiszumachen, ihr hättet magische Kräfte.",ep:1,g:659,l:30,wd:true,fm:true,w:30,p:0};
I.u[749] = {n:"Backelitit",t:40,d:"Diese Legierung ist zwar recht spröde, doch korrekt geschärft, wird sie so scharf wie die Klinge eines Chafers.",ep:1,g:487,l:40,wd:true,fm:true,w:40,p:0};
I.u[750] = {n:"Kwuarz",t:40,d:"Diese seltsame Legierung ist in der Lage, eine beängstigende Energiemenge zu speichern. Leider wird sie unter bestimmten Voraussetzungen auch sehr instabil. Dennoch können die Meisterschmiede nie genug von dem Zeug kriegen, da sie damit die berühmtesten aller Waffen herstellen können.",ep:1,g:664,l:60,wd:true,fm:true,w:60,p:0};
I.u[752] = {n:"Vampirblut",t:15,d:"Dieses Blut ist hochmagisch, was es zu einem unverzichtbaren Bestandteil bei der Zubereitung der magischen, schwarzen Blutwurst macht. Die Nebenwirkungen derselben sind allerdings noch unerforscht.",ep:2,g:89,l:15,wd:true,fm:true,w:1,p:100};
I.u[754] = {n:"Vampirumhang",t:17,d:"Dieser blutrote Umhang wurde jahrelang in Blut getaucht. Darum ist er auch so begehrt im Rahmen des HelloTeeny - Festes.",ep:7,g:17,l:29,wd:true,fm:true,w:13,p:2500};
I.u[756] = {n:"Enger Lederschlüpfer des Vampirs",t:56,d:"Um sich vor kritischen Treffern in kritischen Trefferzonen zu beschützen, tragen Vampire gern diesen engen Lederschlüpfer, wenn sie auf die Jagd gehen. Zudem schützt er besagte kritische Zonen auch noch vor kritischem Sonnenbrand. Extrem vielseitig!",ep:3,g:622,l:15,wd:true,fm:true,w:1,p:100};
I.u[757] = {n:"Blaubeergelee",t:110,d:"Dieses Gelee ist besonders klebrig, fast so sehr wie ein tollwütiges Blockpüppchen. Seltsamerweise klebt es mit am Besten an Tofufedern. Vielleicht könnte dies ja nützlich sein...",ep:5,g:42,l:3,wd:true,fm:true,w:1,p:1};
I.u[758] = {n:"Umhang des Rächers",t:17,d:"Dieser Umhang kann nur von wirklich reinen Wesen getragen werden, die sich der Wahrheit und Gerechtigkeit verschworen haben und zu den Rächern Amaknas wurden. Also so gut wie von niemandem...",ep:1,g:2,l:30,wd:true,fm:true,w:10,c:"Ps=1&Pa>20",p:2550};
I.u[759] = {n:"Chogrelotischer Heenchenumhang",t:17,d:"Dieser fein gearbeitete Umhang wurde aus den Federn des letzten Heenchens von Amakna gefertigt. Eine echte Seltenheit also, die von vielen Sammlern heiß begeht wird.",ep:8,g:3,l:33,wd:true,fm:true,w:4,p:5000};
I.u[760] = {n:"Curryloses Currybrot",t:33,d:"Dies ist ein Prototyp von Kwaker Vans. Der Geschmack und die Wirksamkeit dieses Brotes sorgen beide immer aufs Neue für Überraschungen. Leider lässt sich Gleiches nicht für den strengen Geruch behaupten. Der bleibt immer konstant dabei.",ep:2,g:12,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[761] = {n:"Maushaare",t:54,d:"Diese Haare sind sehr fein und weich, weshalb sie zum Füttern von Mänteln sehr geschätzt werden. Pelzmäntel mit Maushaarinnenfutter sind gerade der letzte Schrei in der gehobenen Gesellschaft Amaknas.",ep:1,g:549,l:1,wd:true,fm:true,w:1,p:1};
I.u[764] = {n:"Zwergeulenamulett",t:1,d:"Dieses kleine Amulett wird alle Möchtegernabenteurer glücklich machen.",ep:1,g:1,l:1,wd:true,fm:true,w:2,p:50};
I.u[765] = {n:"Sense von Farle Ingalsse",t:22,d:"Diese Sense hat Farle Ingalsse höchstpersönlich benutzt. Ursprünglich für das Mähen jeglicher Art von Getreide konzipiert, kann man mit ihr gleichzeitig alle Arten von Monstern ummähen, die sich in den Getreidefeldern versteckt halten.",ep:3,g:1,l:13,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,50,false,false],c:"CC>10",p:650};
I.u[766] = {n:"Elnags Collier",t:1,d:"Dieses Amulett verwandelt die Lebenskraft seines Trägers in Schlagkraft und erhöht so den angerichteten Schaden.",ep:1,g:34,l:1,wd:true,fm:true,w:1,p:20};
I.u[767] = {n:"Royal Gantie",t:9,d:"Trotz dieses pompösen Namens macht einen dieser Ring bloß ein wenig stärker und ein wenig dümmer.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[768] = {n:"Camasserfüllt",t:9,d:"Dieser Ring beeinflußt stark euer Schicksal. Er macht euch widerstandsfähiger, bringt euch aber ebenfalls Unglück. Im Klartext: er erhöht eure Chancen, länger zu leben, verringert jedoch gleichzeitig eure die Chancen, glücklich zu sein.",ep:1,g:33,l:1,wd:true,fm:true,w:1,p:100};
I.u[769] = {n:"Einekeineux",t:11,d:"Diese Stiefel bringen Glück. Dummerweise senken sie auch eure Fähigkeit, Schläge im Kampf einzustecken.",ep:1,g:5,l:2,wd:true,fm:true,w:1,p:200};
I.u[770] = {n:"Fecaflip",t:11,d:"Dieses wunderschöne Paar Schuhe verwandelt einen Teil eurer Stärke in Intelligenz.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[771] = {n:"Eschenzerbrecher",t:19,d:"Diese Axt ist ja an für sich nichts besonderes, doch wird sie von angehenden Holzhackern gern verwendet, da sie sehr einfach zu gebrauchen ist.",ep:1,g:9,l:8,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,45,45,false,false],c:"CS>10&CC>10",p:400};
I.u[772] = {n:"Mantel \"Undegen\"",t:17,d:"Mit diesem legendären Mantel wird man so gut wie unbesiegbar, wenn man ihn mit der legendärsten Waffe aller Fechtmeister, dem Dart Tagnan des Muskeltieres, und der berühmten Baronen-Kugel des Mönches von Hausen kombiniert.",ep:7,g:4,l:22,wd:true,fm:true,w:10,p:1500};
I.u[773] = {n:"Cape \"El Lini\"",t:17,d:"Dieser Umhang kommt aus dem fernen Land Pastatalieni, einem seltsamen Ort, wo man mit den Händen spricht. Das erklärt auch zu einem Großteil, warum er einem soviel Bewegungsfreiheit erlaubt. Zudem ist er auch noch überraschend leicht.",ep:1,g:5,l:14,wd:true,fm:true,w:1,p:775};
I.u[774] = {n:"Cape Ulais",t:17,d:"Dieser vom Mont Agues stammende Mantel führte letztendlich dazu, dass der frühere Besitzer vergiftet wurde und verstarb. Dabei soll der Mantel doch eigentlich die Lebenskraft seines Trägers stärken. Seltsam.",ep:1,g:7,l:14,wd:true,fm:true,w:3,p:775};
I.u[775] = {n:"Mantel e Patie",t:17,d:"Dieser auf magische Art und Weise mit großer Sorgfalt gewobene Mantel gibt dem Träger die Fähigkeit, selbst die kleinsten Schwachstellen des Gegners aufzudecken und seine zerstörerischen Schläge genau dorthin zu plazieren.",ep:5,g:9,l:17,wd:true,fm:true,w:10,p:1000};
I.u[776] = {n:"Cape Selcorp",t:17,d:"Dieser Umhang gehörte einst einer gewissen Mulba, die damit beschwerliche Gegenstände transportierte, die im Rahmen ihrer Suche nach den Sieben Kristalldoubeln überirdischen Ursprunges anfielen. Man sagt außerdem, dass dieser Umhang auch erheblich die Stärke seines Trägers erhöhen soll.",ep:5,g:8,l:14,wd:true,fm:true,w:3,p:775};
I.u[777] = {n:"Hahn Rei\'-Umhang",t:17,d:"Morgenappell auf der Hühnerfarm: \"All\' inn\' Rei\' \"! Da sich der alte Hahn auch nach 20 \"Rei\' \"-Rufen nicht blicken ließ, sollte er gerupft werden. Doch er entging der Strafe, da er nach 3 Tagen Hetzjagd tot umfiel. \"...Rei\' \"schrie der Besitzer.",ep:5,g:10,l:44,wd:true,fm:true,w:10,p:5275};
I.u[778] = {n:"Moriartantelli",t:17,d:"Dieser echte Mantel des Grauens ist das Beweisstück für eure Angehörigkeit zu der Bande des diabolischen und genialen Professors M. Man sagt, allein sein ständiges Pech wäre seiner unglaublichen Intelligenz ebenbürtig. Dieser Mantel kann nur von den bösesten aller Bösewichte getragen werden.",ep:2,g:11,l:6,wd:true,fm:true,w:1,c:"Ps=2&Pa>30",p:20000};
I.u[779] = {n:"Mah\'Jik Mahn\'Tel",t:17,d:"Dieser gewöhnlich erscheinende Mantel ist keineswegs gewöhnlich. Denn er kann seinen Träger vor den Augen all derer verstecken, die ihn gerade nicht ansehen. Wahrlich beeindruckend!",ep:8,g:12,l:34,wd:true,fm:true,w:15,p:3300};
I.u[781] = {n:"Cape von Itou Lascione",t:17,d:"Dieser wunderschöne Umhang wurde speziell für den großen Strategen General Itou Lascione angefertigt. Doch kaum zog er seinen Umhang an, schon gab er seine Pläne zur Beherrschung des Universums auf und begann seine neue Laufbahn als Gärtner. Seltsam, nicht wahr?",ep:8,g:7,l:21,wd:true,fm:true,w:10,p:1400};
I.u[782] = {n:"Agrid",t:19,d:"Diese Axt ist recht außergewöhnlich. Sie diente zwar ursprünglich dazu, jungen Holzhackern das Handwerk beizubringen, doch wenn sie korrekt gehandhabt wird, kann sie sogar junge, unerfahrene Astaknyden in zwei Teile spalten. Das ist doch ziemlich bemerkenswert, nicht wahr?",ep:1,g:11,l:27,wd:true,fm:true,w:20,an:17,e:[5,4,1,1,45,45,false,false],c:"CW>15",p:2200};
I.u[783] = {n:"Holzfälleramulett",t:1,d:"Dieses Amulett besteht einzig und allein aus seltenen Edelhölzern und wird besonders von Holzfällern sehr geschätzt. Diese messen ihm allerdings oftmals mehr Kräfte bei, als es in Wirklichkeit hat.",ep:1,g:9,l:22,wd:true,fm:true,w:2,p:1500};
I.u[784] = {n:"Stiefel des geprügelten Katers",t:11,d:"Der \"geprügelte Kater\" ist der Spitzname, der einem berühmten Ecaflip gegeben wurde. Kein anderer Ecaflip war dickköpfiger als er. Allein schieres Glück rettete ihm bei mehr als einem Kampf das Leben, welches er aufgrund eines bedenklichen Mangels an Intelligenz zu verlieren drohte.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[785] = {n:"Festungsring",t:9,d:"Dieser Ring, der über viele Generationen hinweg von Enutrof-Großväterchen zu Enutrof-Väterchen weitergegeben wurde, erhöht die Stärke seines Trägers beträchtlich. Dieses Examplar hier ist bloß eine billige Kopie des Originals, doch wird es den Sammler dennoch zufrieden stellen, egal ob Enutrof oder nicht.",ep:1,g:29,l:11,wd:true,fm:true,w:1,p:525};
I.u[786] = {n:"Anhänger der mickrigen Eule",t:1,d:"Dieser Anhänger, der durch Zufall bei einem falschen Handgriff des Juweliers entstanden ist, erhöht die Intelligenz seines Trägers. Allerdings verursacht er ebenfalls dröhnende Kopfschmerzen, die seine körperliche Verfassung verschlechtern.",ep:1,g:1,l:2,wd:true,fm:true,w:1,p:200};
I.u[787] = {n:"Ano Rexik Ring",t:9,d:"Dieser seltsame kleine Ring besitzt die Fähigkeit, die Flinkheit seines Trägers zu hören, doch scheint er auch gleichzeitig Unglück anzuziehen.",ep:1,g:31,l:1,wd:true,fm:true,w:1,p:100};
I.u[789] = {n:"Kobeer-Gürtel",t:10,d:"Dieser Gürtel ist besonders bei der Jugend von Amakna sehr beliebt. Das liegt am hervorragenden Werbespruches des Sadida-Schusters bei dessen Verkauf: \"Das Leben ist so kurz, bleibt hart am Ball\". Inwieweit dies inspirieren soll, ist allerdings fraglich.",ep:2,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[790] = {n:"Cape der Guten Hoffnung",t:17,d:"Die magische Kraft dieses Mantels wurde lange Zeit hinweg zu Unrecht überbewertet, was zum Verschwinden von so manch einem Abenteurer geführt hat, unter anderem auch des berühmt-berüchtigten Minnesänger O\'Heins.",ep:8,g:5,l:30,wd:true,fm:true,w:8,p:2525};
I.u[791] = {n:"Astaknydis Vivitus",t:4,d:"Dieser Stab besteht aus lebendigen Astaknydenwurzeln. Vorsicht, diese haben die ärgerliche Angewohnheit, sich manchmal gegen ihren Träger zu wenden. Doch wenn sie sich mal dazu entscheiden, dasselbe Ziel wie der Träger anzugreifen, kann dieser Stecken sehr effektiv sein.",ep:2,g:1,l:34,wd:true,fm:true,w:10,an:12,e:[5,2,1,1,50,30,false,false],c:"CC>30&CI>34&CW>15",p:3400};
I.u[792] = {n:"Astaknydensaft",t:15,d:"Dieser sirupartige Pflanzensaft hat überhaupt keinen praktischen Nutzen, es sei denn, ihr seid bereit, so lange zu warten, bis er zu Bernstein versteinert. Gerüchteweise soll ein gewitztes Enutröffchen einen Weg gefunden haben, diesen Prozess erheblich zu beschleunigen.",ep:1,g:162,l:45,wd:true,fm:true,w:2,p:50};
I.u[793] = {n:"Biokatalysatrank",t:12,d:"Dieser Trank beschleunigt gewisse biologische und chemische Prozesse, wie beispielsweise die Bildung von Niederschlägen oder die Gärung. Er lässt sich wie eine Art ultramächtiges Backtriebmittel einsetzen, schmeckt aber noch lange nicht so schlecht wie diese.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[795] = {n:"Schriftrolle der Stärke",t:76,d:"(Doppelklick, um Punkte für Stärke zu erhalten.) \nDiese Schriftrolle erhöht die Stärke des Lesers, ohne dass er irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Stärke weniger als 50 Punkte beträgt.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<50",u:true,p:2500};
I.u[796] = {n:"Große Schriftrolle der Stärke",t:76,d:"(Doppelklick, um Punkte für Stärke zu erhalten.) \nDiese Schriftrolle erhöht die Stärke des Lesers, ohne dass er irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Stärke weniger als 80 Punkte beträgt.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<80",u:true,p:5000};
I.u[797] = {n:"Mächtige Schriftrolle der Stärke",t:76,d:"(Doppelklick, um Punkte für Stärke zu erhalten) \nDiese Schriftrolle erhöht die Stärke des Lesers, ohne dass dieser irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Stärke weniger als 100 Punkte beträgt.",ep:1,g:21,l:1,wd:true,fm:true,w:1,c:"Cs<100",u:true,p:8000};
I.u[798] = {n:"Kleine Schriftrolle der Flinkheit",t:76,d:"(Doppelklick, um Punkte für Flinkheit zu erhalten.) \nDiese Schriftrolle erhöht die Flinkheit des Lesers, ohne dass dieser irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Flinkheit weniger als 25 Punkte beträgt.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<25",u:true,p:1000};
I.u[799] = {n:"Schriftrolle der Flinkheit",t:76,d:"(Doppelklick, um Punkte für Flinkheit zu erhalten.) \nDiese Schriftrolle erhöht die Flinkheit des Lesers, ohne dass er irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Flinkheit weniger als 50 Punkte beträgt.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<50",u:true,p:2500};
I.u[800] = {n:"Große Schriftrolle der Flinkheit",t:76,d:"(Doppelklick, um Punkte für Flinkheit zu erhalten.) \nDiese Schriftrolle erhöht die Flinkheit des Lesers, ohne dass dieser irgendein Risiko dafür eingehen muss. Doch Vorsicht: sie lässt sich nur dann anwenden, wenn der Grundwert in Flinkheit weniger als 80 Punkte beträgt.",ep:1,g:20,l:1,wd:true,fm:true,w:1,c:"Ca<80",u:true,p:5000};
