I.u[822] = {n:"Schwert des Ritters",t:6,d:"Das Schwert des Ritters ist stabil und wirksam. Darum fügt es euren Gegnern auch großen Schaden zu.",ep:7,g:9,l:23,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>46",p:1600};
I.u[823] = {n:"Schwert des starken Ritters",t:6,d:"Das Schwert des starken Ritters ist stabil und wirksam. Darum fügt es euren Gegnern auch großen Schaden zu.",ep:7,g:9,l:24,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>48",p:1800};
I.u[824] = {n:"Schwert des mächtigen Ritters",t:6,d:"Das Schwert des mächtigen Ritters ist stabil und wirksam. Darum fügt es euren Gegnern auch großen Schaden zu.",ep:7,g:9,l:26,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>52",p:2000};
I.u[825] = {n:"Bworkling",t:6,d:"Diese grobe Klinge ist bei den dümmsten aller Bworks, die noch nicht mal Funktionsweise eines Bogens oder eines Stockes verstehen, sehr beliebt. Doch einige von ihnen verwechseln dennoch hin und wieder das Heft mit der Klinge, was meist starke Lachanfälle ihrer Gegner zur Folge hat.",ep:1,g:13,l:23,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>46&CA>8",p:1600};
I.u[826] = {n:"Groß-Bworkling",t:6,d:"Diese grobe Klinge ist bei den dümmsten aller Bworks, die noch nicht mal Funktionsweise eines Bogens oder eines Stockes verstehen, sehr beliebt. Doch einige von ihnen verwechseln dennoch hin und wieder das Heft mit der Klinge, was meist starke Lachanfälle ihrer Gegner zur Folge hat.",ep:1,g:13,l:24,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>48&CA>14",p:1800};
I.u[827] = {n:"Bworkling der Macht",t:6,d:"Diese grobe Klinge ist bei den dümmsten aller Bworks, die noch nicht mal Funktionsweise eines Bogens oder eines Stockes verstehen, sehr beliebt. Doch einige von ihnen verwechseln dennoch hin und wieder das Heft mit der Klinge, was meist starke Lachanfälle ihrer Gegner zur Folge hat.",ep:1,g:13,l:26,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>52&CA>16",p:2000};
I.u[828] = {n:"Pfeifender Bogen",t:2,d:"Dieser Bogen verschießt so schnelle Pfeile, dass man sie bereits von Weitem anfliegen hört. Denkt also immer daran, einen Schalldämpfer zu verwenden, wenn ihr unbemerkt bleiben möchtet.",ep:1,g:15,l:11,wd:true,fm:true,w:10,an:10,tw:true,e:[5,3,2,6,30,40,false,true],c:"CA>11&CS>5",p:550};
I.u[829] = {n:"Bogen Ghang",t:2,d:"Aufgrund der geringen Reichweite ist dieser Bogen nicht sehr wirkungsvoll. Dennoch kann man mit ihm die Gegner genügend schwächen, bevor man ihnen mit einer anderen Waffe oder mit Magie den Gnadenstoß verpasst.",ep:1,g:1,l:8,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,30,50,false,true],c:"CA>8",p:400};
I.u[830] = {n:"Intelligenzstäbchen",t:3,d:"Dieser Stab erhöht die Intelligenz seines Trägers.",ep:7,g:1,l:24,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>24",p:1700};
I.u[831] = {n:"Großes Intelligenzstäbchen",t:3,d:"Dieser Stab erhöht die Intelligenz seines Trägers.",ep:7,g:1,l:27,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>27",p:2100};
I.u[832] = {n:"Mächtiges Intelligenzstäbchen",t:3,d:"Dieser Stab erhöht die Intelligenz seines Trägers.",ep:7,g:1,l:29,wd:true,fm:true,w:10,an:11,e:[5,3,2,2,50,20,false,true],c:"CI>29",p:2500};
I.u[833] = {n:"Weisheitsstäbchen",t:3,d:"Dieser Stab erhöht die Weisheit seines Trägers.",ep:1,g:4,l:23,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>23&CW>7",p:1600};
I.u[834] = {n:"Großes Weisheitsstäbchen",t:3,d:"Dieser Stab erhöht die Weisheit seines Trägers.",ep:1,g:4,l:25,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>25&CW>9",p:1900};
I.u[835] = {n:"Mächtiges Weisheitsstäbchen",t:3,d:"Dieser Stab erhöht die Weisheit seines Trägers.",ep:1,g:4,l:27,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>27&CW>11",p:2200};
I.u[836] = {n:"Astakning",t:9,d:"Dieser Ring, der aus Astaknydenrinde gefertigt wurde, besitzt große Kräfte und legt damit dem Träger auch große Verantwortung auf. Doch trotz seines großen Wertes gibt es Gerüchte, die besagen, er sei verflucht.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:100};
I.u[837] = {n:"Kluhschuh",t:11,d:"Diese Stiefel erhöhen beachtlich die Stärke seines Trägers, doch verdummt dieser im Laufe der Zeit dabei auch ein wenig. Bei regelmäßiger, langjähriger Verwendung endet er dann letzten Endes als Iop.",ep:1,g:3,l:8,wd:true,fm:true,w:1,p:400};
I.u[838] = {n:"Oni-Blut",t:15,d:"Oni-Blut wird besonders von erfahrenen Alchimisten sehr gern verwendet, um bestimmten Waffen furchterregende Eigenschaften zu verleihen.",ep:4,g:662,l:75,wd:true,fm:true,w:1,p:100};
I.u[840] = {n:"Minotoror-Haare",t:54,d:"Diese Haare riechen sehr streng, doch sind sie widerstandsfähig wie keine anderen. Einen Minotoror-Pelz zu tragen, wird euch bei allen anderen Abenteurern Respekt verschaffen und Fliegen von weither anziehen.",ep:2,g:201,l:125,wd:true,fm:true,w:1,p:100};
I.u[841] = {n:"Ring der Genugtuung",t:9,d:"Dieser Ring erhöht die AP seines Trägers im Austausch gegen seine Stärke und Intelligenz.",ep:1,g:12,l:8,wd:true,fm:true,w:1,p:10};
I.u[842] = {n:"Goldene Dracheischale",t:111,d:"Diese Schale ist so gut wie unzerbrechlich. Doch nachdem sie von Generationen von Juwelieren auf Hochglanz poliert wurde, ist es nun möglich, ihre magischen Kräfte zu nutzen, um daraus extrem mächtige Amulette zu fertigen.",ep:11,g:202,l:64,wd:true,fm:true,w:5,p:1};
I.u[843] = {n:"Schwarze Dracheischale",t:111,d:"Diese Schale ist so gut wie unzerbrechlich. Doch nachdem sie von Generationen von Juwelieren auf Hochglanz poliert wurde, ist es nun möglich, ihre magischen Kräfte zu nutzen, um daraus extrem mächtige Amulette zu fertigen.",ep:11,g:203,l:64,wd:true,fm:true,w:5,p:150};
I.u[844] = {n:"Ei eines Saphir-Dracheis",t:105,d:"Aus diesem Ei wird einmal ein hübsches kleines Baby-Drachei schlüpfen, sollte es von einem Saphir-Dracheiweibchen ausgebrütet werden. In der Zwischenzeit solltet ihr jedoch vermeiden, es zu warm zu halten. Man weiß nie, was dabei herauskommt.",ep:11,g:204,l:74,wd:true,fm:true,w:20,p:100};
I.u[845] = {n:"Ei eines goldenen Dracheis",t:105,d:"Aus diesem Ei wird einmal ein hübsches kleines Baby-Drachei schlüpfen, sollte es von einem goldenen Dracheiweibchen ausgebrütet werden. In der Zwischenzeit solltet ihr jedoch vermeiden, es zu warm zu halten. Man weiß nie, was dabei herauskommt.",ep:11,g:205,l:74,wd:true,fm:true,w:20,p:100};
I.u[846] = {n:"Ei eines schwarzen Dracheis",t:105,d:"Aus diesem Ei wird einmal ein hübsches kleines Baby-Drachei schlüpfen, sollte es von einem schwarzen Dracheiweibchen ausgebrütet werden. In der Zwischenzeit solltet ihr jedoch vermeiden, es zu warm zu halten. Man weiß nie, was dabei herauskommt.",ep:11,g:206,l:74,wd:true,fm:true,w:20,p:100};
I.u[847] = {n:"Ei eines weißen Dracheis",t:105,d:"Aus diesem Ei wird einmal ein hübsches kleines Baby-Drachei schlüpfen, sollte es von einem weißen Dracheiweibchen ausgebrütet werden. In der Zwischenzeit solltet ihr jedoch vermeiden, es zu warm zu halten. Man weiß nie, was dabei herauskommt.",ep:10,g:38,l:74,wd:true,fm:true,w:1,p:100};
I.u[848] = {n:"Uralter Drachei-Knochen",t:47,d:"Dieser alte Knochen ist hochgradig magisch. Korrekt verwendet, lassen sich aus ihm extrem mächtige Gegenstände herstellen.",ep:11,g:15,l:70,wd:true,fm:true,w:20,p:100};
I.u[849] = {n:"Stärkitätmich Ring",t:9,d:"Dieser kleine Ring erhöht die Stärke seines Trägers.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[850] = {n:"Flinkitäglich Ring",t:9,d:"Seltsamerweise stürzen sich die Sammler Amaknas auf diesen Ring, obwohl er keinen Pfifferling wert ist.",ep:1,g:1,l:1,wd:true,fm:true,w:1,p:50};
I.u[851] = {n:"Vitalitätich Ring",t:9,d:"Dieser kleine Ring erhöht die Lebenskraft seines Trägers.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[852] = {n:"Intellimagich Ring",t:9,d:"Dieser kleine Ring erhöht die Intelligenz seines Trägers.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[853] = {n:"Glücksikläglich Ring",t:9,d:"Dieser kleine Ring erhöht das Glück seines Trägers.",ep:1,g:42,l:1,wd:true,fm:true,w:1,p:50};
I.u[854] = {n:"Zwergbärenamulett",t:1,d:"Dieses kleine Amulett erhöht die Stärke seines Trägers.",ep:1,g:5,l:1,wd:true,fm:true,w:1,p:50};
I.u[856] = {n:"Fröschli",t:1,d:"Dieses kleine Amulett erhöht die Flinkheit seines Trägers.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:50};
I.u[859] = {n:"Gürtel der Flinkheit",t:10,d:"Dieser ärmlich aussehende Gürtel erhöht geringfügig die Flinkheit seines Trägers. Aber immerhin besser als nichts, oder?",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:50};
I.u[860] = {n:"Gürtel des Glücks",t:10,d:"Dieser ärmlich aussehende Gürtel erhöht geringfügig das Glück seines Trägers. Aber immerhin besser als nichts, oder?",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:50};
I.u[861] = {n:"Kleine feste Stiefel",t:11,d:"Diese Stiefel geben ihrem Träger einen starken und sicheren Halt auf Schritt und Tritt, jedoch auf Kosten der Flinkheit. Dadurch wird er in jedem Fall weniger flink als ein Tofu, doch ob es ihn auch weniger dumm als einen solchen macht, bleibt noch zu klären.",ep:1,g:3,l:2,wd:true,fm:true,w:1,p:200};
I.u[862] = {n:"Intelligente Sandalen",t:11,d:"Diese Stiefel erhöhen die Intelligenz ihres Trägers und verleihen ihm dabei auch noch einen modischen Touch. Das Kirschbaumholz der Sohlen passt sich einfach nur wunderbar dem Schuhbett an.",ep:1,g:4,l:8,wd:true,fm:true,w:1,p:400};
I.u[863] = {n:"Flinke Stiefel",t:11,d:"Diese Stiefel erhöhen die Flinkheit ihres Trägers. Da kann man ihn doch glatt mit einem Tofu verwechseln, vor allem wenn er sich mal wieder durch seine eigene Dummheit vor allen anderen lächerlich gemacht hat.",ep:1,g:5,l:8,wd:true,fm:true,w:1,p:400};
I.u[864] = {n:"Glückliche Stiefel",t:11,d:"Diese Stiefel erhöhen das Glück ihres Trägers. Dadurch wird dieser leichter an seltene Gegenstände herankommen, wie zum Beispiel Fresssackspeichel.",ep:1,g:1,l:8,wd:true,fm:true,w:1,p:100};
I.u[867] = {n:"Dragolyra",t:1,d:"Dieses herrliche Amulett wurde aus den Überresten von Dracheiern handgefertigt und verfügt über eine solch eindrucksvolle Macht, dass der größte Teil der alltäglichen Gegner lieber den Rückzug antritt.",ep:11,g:9,l:32,wd:true,fm:true,w:2,p:4700};
I.u[878] = {n:"Schriftrolle des Bäckers",t:13,d:"(Zum Benutzen Doppelklicken) \nMit dieser Schriftrolle erhaltet ihr Erfahrungspunkte im Beruf als Bäcker.",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[879] = {n:"Schriftrolle des Schusters",t:13,d:"(Doppelklick, um Erfahrungspunkte in diesem Beruf zu erhalten)",ep:1,g:3,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[880] = {n:"Königliche Fresssackwolle",t:57,d:"Diese Wolle ist einfach königlich! Warm, weich und leicht und so herrlich wollig! Doch ruft sie in seltenen Fällen auch Hautausschläge hervor. Beim Alter des königlichen Fresssacks ist dies aber auch kein Wunder.",ep:1,g:207,l:35,wd:true,fm:true,w:1,p:4000};
I.u[881] = {n:"Weiße Fresssäckchenwolle",t:57,d:"Diese Wolle ist extrem weich, da sie aus dem Flaum eines Fresssäckchens stammt. Doch Vorsicht: an ihr haftet noch der typische Geruch, weshalb es gut vorkommen kann, dass sich kleine Fresssäckchen auf offener Straße an euch reiben und eure Kleider ablecken.",ep:1,g:208,l:2,wd:true,fm:true,w:1,p:1};
I.u[882] = {n:"Fresssack-Anführer-Wolle",t:57,d:"Diese Wolle riecht sehr streng. Aber da sie einst einem großen Fresssack-Anführer gehört hatte, behalten sie viele Abenteurer aus sentimentalen Gründen.",ep:1,g:209,l:19,wd:true,fm:true,w:1,p:1};
I.u[883] = {n:"Weißes Fresssäckchen-Leder",t:56,d:"Dieses glatte und weiche Leder ist hervorragend für die Herstellung von Lederunterwäsche geeignet. Die Lederschlüpfer der Chafer sind hierfür gute Beispiele.",ep:1,g:534,l:2,wd:true,fm:true,w:1,p:1};
I.u[884] = {n:"Schwarzes Fresssäckchen-Leder",t:56,d:"Dieses glänzende Leder wird von allen Schuhmachern und Schneidern sehr geschätzt, um daraus kleine Stiefel oder Hüte herzustellen.",ep:1,g:16,l:2,wd:true,fm:true,w:1,p:1};
I.u[885] = {n:"Schwarze Fresssäckchenwolle",t:57,d:"Diese raue Wolle wird nicht mehr oft von Schneidern eingesetzt, doch dafür benutzen sie viele Enutrofs, um ihre beginnende Glatze zu verbergen.",ep:1,g:210,l:2,wd:true,fm:true,w:1,p:1};
I.u[886] = {n:"Königliches Fresssack-Leder",t:56,d:"Dieses Leder ist schlichtweg königlich! Es besitzt eine außergewöhliche Geschmeidigkeit. Die vielen Vertiefungen sind ein deutliches Zeichen für die Langlebigkeit des königlichen Fresssacks. In ganz Amakna lässt sich kein besseres Leder finden.",ep:1,g:535,l:35,wd:true,fm:true,w:1,p:4000};
I.u[887] = {n:"Fresssack-Anführer-Leder",t:56,d:"\"Dieses Leder hat bereits alle Kriege mitgemacht – das härtet ab wie nichts!\" So sprach der Söldner mit einer Lederrüstung aus Fresssack-Anführer-Leder, kurz bevor der Wind drehte und er an dem furchtbaren Geruch seiner Rüstung erstickte.",ep:1,g:534,l:19,wd:true,fm:true,w:1,p:1};
I.u[888] = {n:"Große nachdenkliche Stiefel",t:11,d:"Diese Stiefel nehmen ihrem Träger einige geistige Arbeit ab, weshalb sie ein Muss für jeden Iop sind.",ep:1,g:6,l:26,wd:true,fm:true,w:15,p:1950};
I.u[889] = {n:"Mächtige nachdenkliche Stiefel",t:11,d:"Diese Stiefel nehmen ihrem Träger einige geistige Arbeit ab, weshalb sie ein Muss für jeden Iop sind.",ep:1,g:6,l:27,wd:true,fm:true,w:15,p:2200};
I.u[890] = {n:"Stiefel des Fresssacks",t:11,d:"Diese Stiefel bestehen ganz aus Fresssackleder. Dank des Geruches, der ihnen entströmt, können sich Fresssackzüchter auch leichter den Fresssäcken nähern, um sie zu töten.",ep:1,g:3,l:1,wd:true,fm:true,w:3,p:150};
I.u[891] = {n:"Stiefel des großen Fresssacks",t:11,d:"Diese Stiefel bestehen ganz aus Fresssackleder. Dank des Geruches, der ihnen entströmt, können sich Fresssackzüchter auch leichter den Fresssäcken nähern, um sie zu töten.",ep:1,g:3,l:2,wd:true,fm:true,w:4,p:200};
I.u[892] = {n:"Stiefel des mächtigen Fresssacks",t:11,d:"Diese Stiefel bestehen ganz aus Fresssackleder. Dank des Geruches, der ihnen entströmt, können sich Fresssackzüchter auch leichter den Fresssäcken nähern, um sie zu töten.",ep:1,g:3,l:4,wd:true,fm:true,w:5,p:250};
I.u[893] = {n:"Kleine Sylvandolche",t:5,d:"Einst waren diese Dolche speziell dazu geschaffen worden, Wurzeln und junge Triebe zu stutzen, doch dann bemerkte man, dass sie auch als nahezu tödliche Waffe taugen...",ep:1,g:6,l:20,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>20&CI>5",p:1300};
