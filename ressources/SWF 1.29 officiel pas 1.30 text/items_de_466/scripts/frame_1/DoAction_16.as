I.u[7733] = {n:"Streichler mit grünen Piepmatzfedern",t:93,d:"Diese phantastische Maschine streichelt alle Reittiere, die sich ihr nähern;\r\n            immer nur mit dem Strich, wohlgemerkt. Das senkt ihre Agressivität und macht sie ruhiger.",ep:1,g:33,l:1,wd:true,fm:true,w:10,ut:true,p:1};
