I.u[7507] = {n:"Trank des Vergessens: \"Schuhmagier\"",t:44,d:"Dieser Trank lässt euch den Beruf des Schuhmagiers vergessen.",ep:2,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7508] = {n:"Signier-Rune",t:50,d:"Diese Rune erlaubt es bekannten Handwerksmeistern, ihre Werke zu signieren. \n(Einsatz: Bei der Herstellung zusammen mit den anderen Zutaten verwenden).",ep:18,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[7509] = {n:"Teil des Schlüssels zum Dungeon der Schweine",t:84,d:"Wenn euch dieser Schweinerüssel nichts sagt, dann versucht erst gar nicht, das Rätsel zu lösen. Denn sonst riskiert ihr die letzte Tracht Prügel eures Lebens, vor allem dann, wenn ihr euch ablenken lasst.",ep:13,g:1,l:1,wd:true,fm:true,w:1,p:100};
I.u[7510] = {n:"Teil des Schlüssels zum Schweinedungeon",t:84,d:"Dieses Schlüsselteil gehört vielleicht zu einem Schlüssel zur Schatztruhe eurer Träume. Vielleicht ist es aber auch der Schlüssel zu eurem Sarg. Nix Genaues weiß man nicht.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:100};
I.u[7511] = {n:"Schlüssel zum Dungeon der Schweine",t:84,d:"Wenn ihr meint, dies sei der Schlüssel zum Herzen einer schönen Schweinedame, dann habt ihr euch geschnitten. Dies ist nur der Schlüssel zum Unterschlupf des Schweinedrachens. Doch ist er nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:100};
I.u[7513] = {n:"Klötzi",t:11,d:"\"Klötzi\" war der Spitzname eines ärmlichen Enutrof-Schuhmachers, der sogar noch kleiner als der Durchschnitts-Xelor war. Man munkelt, er habe sich diese Schuhe maßgeschneidert, um seine Liebste – eine beinlose Eniripsa – im Stehen küssen zu können, was ihm auch mit Klotz am Bein leider nicht gelang.",ep:20,g:67,l:122,wd:true,fm:true,w:10,p:37800};
I.u[7514] = {n:"Flips Slippers",t:11,d:"Flip war alt geworden, doch ging er immer noch gern in der Nähe des Hafenbeckens von Sufokia angeln. In seiner Jugend hatte er keine Probleme gehabt, einen Ball auf seiner Nase zu balancieren oder seine berühmten FlipFlacks zu schlagen, und das mit einer für andere unerreichbaren Geschmeidigkeit.",ep:20,g:70,l:123,wd:true,fm:true,w:10,p:37850};
I.u[7515] = {n:"Cape \"Dein Futur\"",t:17,d:"Dieser Umhang entstammt nicht eurem Universum, passt aber dennoch hervorragend zu euren Kniestrümpfen aus Fresssackwolle.",ep:20,g:92,l:148,wd:true,fm:true,w:10,p:47925};
I.u[7516] = {n:"Hut von Bimd\'Oul",t:16,d:"Ein alter, von Jahrzehnten des Unglücks gezeichneter Enutrof fand eines Tages diesen Hut in den Tiefen einer Nische in den Höhlen von Bimd\'Oul. Ein wenig später ging dieser Enutrof freiwillig ins Exil und versuchte, weit entfernt von den Ewigen Landen Amaknas der wachsenden Langeweile zu entgehen und ein neues Leben anzufangen.",ep:20,g:121,l:110,wd:true,fm:true,w:10,p:31675};
I.u[7517] = {n:"Ripaten-Bier",t:37,d:"Dieses Bier ist so sauer, dass der Holzkrug, in dem es ausgeschenkt wird, die Lebenserwartung eines Moskitos hat.",ep:7,g:4,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7518] = {n:"Phantöffelchen",t:18,d:"Diese überraschende Kreatur entstammt direkt aus dem Jenseits und ist nicht bereit, dorthin zurückzukehren, es sei denn, ihr würdet sie betrüblicherweise dorthin begleiten.",ep:3,g:13,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7519] = {n:"Rosa Dragooner",t:18,d:"Dieser kleine Drache hat eine Haut, so rosa wie die Pobacken eines weiblichen Bworks. Eine gute Art, gefahrlos schlüpfrige Fantasien in euch zu erwecken oder an schöne Erinnerungen zu erinnern. Zum Glück ist dieser Drache nicht nur Vehikel eurer Fantasien, sondern in erster Linie eine mächtige und weise Kreatur. Doch Vorsicht: Seiner Gefräßigkeit kommt nur die Perversität eines Chafers bei Vollmond annähernd gleich, und er ernährt sich ausschließlich von anderen Vertrauten.",ep:3,g:14,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7520] = {n:"Croum",t:18,d:"Dieser Zinnsoldat im Ruhestand ist ein Wesen aus lebendig gewordenem Metall. Croum wird euch an jeden Ort hin folgen und sein Leben dafür geben, euch zu beschützen, wenn ihr ihm regelmäßig etwas zu essen gebt. Doch erwartet nicht, dass er an eurer Stelle Schläge einsteckt, dazu sind schließlich die Abenteurer-Anfänger in Astrub da.",ep:3,g:15,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7521] = {n:"Phantöffelchen-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also, verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, Nahrung sowie Eniripsa-Pulver für seine Pflege.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7522] = {n:"Minimino",t:18,d:"Dieses gezähmte und dressierte Minotororbaby kann ohne Gefahr gestreichelt werden. Doch Vorsicht: Manchmal kommt die Natur doch noch zu ihrem Recht und der zerstörerische Instinkt dieser Kreatur kommt zum Vorschein – meistens genau dann, wenn ihr auf ihn gezählt habt. Um böse Überraschungen zu vermeiden, solltet ihr ihn wie eines eurer eigenen Kinder großziehen, d.h. mit Stockschlägen.",ep:3,g:21,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7523] = {n:"Rote Maunzmiez",t:18,d:"Diese niedliche, rothaarige Kreatur schafft es tatsächlich, alle Kater der Umgebung um den Verstand zu bringen, selbst die Eingebildetsten.  \n(DIESER LEGENDÄRE VERTRAUTE BRAUCHT NIEMALS GEFÜTTERT ZU WERDEN!)",ep:1,g:40,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7524] = {n:"Getigerte Maunzmiez",t:18,d:"Diese seltsame Kreatur ist das Produkt einer Kreuzung aus einer weißen Maunzmiez und einer schwarzen Maunzmiez. Sie ernährt sich nur von Fisch.",ep:3,g:41,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7525] = {n:"Rosa Dragooner-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, Nahrung sowie Eniripsa-Pulver für seine Pflege.",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7526] = {n:"Geschenkpaket: Croum",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, Nahrung sowie Eniripsa-Pulver für seine Pflege. (WARNHINWEIS: Dieses Paket enthält sehr schwere Gegenstände! Ihr lauft daher Gefahr, überladen zu sein, wenn ihr es öffnet. Entledigt euch daher vorher all eurer schweren Gegenstände oder lasst euch von einem befreundetem Charakter helfen.)",ep:1,g:42,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
