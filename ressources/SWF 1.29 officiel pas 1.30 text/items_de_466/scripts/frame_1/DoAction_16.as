I.u[7379] = {n:"Pelz des Pandikaze-Geistes",t:55,d:"Dieses Pelzstück ist trotz der furchtbaren Schläge, die ihr dem Pandikaze-Geist im Kampf zugefügt habt, noch nahezu unversehrt geblieben.",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7380] = {n:"Pelz des Maho Feuerfux-Geistes",t:55,d:"Hier handelt es sich um einen magischen Pelz mit roten Haaren voller übermächtiger Magie. Mehr gibt es dazu nicht zu sagen.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7381] = {n:"Pelz des Soryo Feuerfux-Geistes",t:55,d:"Dieser kleine Pelz ist perfekt dazu geeignet, im Winter Löcher in Wänden und Türen zu stopfen.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7382] = {n:"Pelz des Leopardo-Geistes",t:55,d:"Fühlt sich dieser Pelz nicht so sanft wie die Musik des Leopardo-Geistes an? Er wird euch sicher noch gute Dienste leisten. Bloß wozu – das ist hier die Frage...",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7383] = {n:"Pelz des Yokai Feuerfux-Geistes",t:55,d:"Dieser Pelz stammt direkt von den empfindlichsten Teilen eines Yokai Feuerfux-Geistes. Gleichzeitig leider auch von den Übelriechendsten. Viele Abenteurer denken, es handele sich dabei um seine Barthaare, doch sie irren sich.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7384] = {n:"Pelz des Pandel-Geistes",t:55,d:"Im Gegensatz zu dem, was man so denken mag, ist dieser Pelz nicht essbar. Abenteurer, die dies versuchten, wurden in einen Tanukouï San-Geist verwandelt. Für manche sogar ein Glücksgriff...",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7385] = {n:"Pelz des Tanukouï San-Geistes",t:55,d:"Dieser Pelz stammt direkt aus der Achselhöhle des Tanukouï San-Geistes. Er vereinigt daher große Weichheit mit großem Gestank, der dem charakteristischem Geruch verwesenden Rablingfleisches ähnelt.",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7386] = {n:"Hoden des Tanukouï San",t:15,d:"Diese gewaltigen Hoden sind in ein außergewöhnlich warmes und weiches Futteral eingebettet, das magische Angriffe abwehrt. Auch etwaige Fusstritte mit den Getas des Tanukouï San können ihnen nichts anhaben. Also, gut aufheben!",ep:1,g:2,l:120,wd:true,fm:true,w:200,p:10};
I.u[7387] = {n:"Der Söldnerclan",t:25,d:"Alles, ja wirklich alles, was es über Söldner zu erfahren gibt! Geschrieben vom Gründer und Großmeister des Söldnerclans.",ep:1,g:19,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7388] = {n:"Trank des Vergessens: \"Meister der Axt\"",t:45,d:"Dieser Trank lässt euch vergessen, dass ihr die Axt gemeistert habt.",ep:3,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7389] = {n:"Trank des Vergessens: \"Raserei\"",t:43,d:"Dieser Trank lässt euch einen Grad des Sacrieur-Zauberspruches \"Raserei\" vergessen.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7390] = {n:"Trank des Vergessens: \"Fliegendes Schwert\"",t:43,d:"Dieser Trank lässt euch einen Grad des Sacrieur-Zauberspruches \"Fliegendes Schwert\" vergessen.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7391] = {n:"Trank des Vergessens: \"Gerinnung\"",t:43,d:"Dieser Trank lässt euch einen Grad des Sacrieur-Zauberspruches \"Gerinnung\" vergessen.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7392] = {n:"Trank des Vergessens: \"Blutiger Wahnsinn\"",t:43,d:"Dieser Trank lässt euch einen Grad des Sacrieur-Zauberspruches \"Blutiger Wahnsinn\" vergessen.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7393] = {n:"Pelz des Pandora-Geistes",t:55,d:"Dieser Pelz hat sich mit dem Schweiß der Pandora vollgesogen, was ihm eine nicht unerhebliche Wertsteigerung verleiht.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7394] = {n:"Trank des Vergessens: \"Felienchen\"",t:43,d:"Dieser Trank lässt euch einen Grad des Spezialzaubers \"Felienchen\" vergessen.",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7395] = {n:"Trank des Vergessens: \"Seelenraub\"",t:43,d:"Dieser Trank lässt euch einen Grad des Spezialzaubers \"Seelenraub\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[7396] = {n:"Wohlstand",t:29,d:"Dieser Segen verleiht euch in euren nächsten Kämpfen Resistenz gegen Wasserschaden.",ep:18,g:10,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7397] = {n:"Scharfsinn",t:29,d:"Dieser Segen verleiht euch in euren nächsten Kämpfen Resistenz gegen Feuerschaden.",ep:18,g:9,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7398] = {n:"Elastizität",t:29,d:"Dieser Segen verleiht euch in euren nächsten Kämpfen Resistenz gegen Luftschaden.",ep:18,g:8,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7399] = {n:"Unerbittlichkeit",t:29,d:"Dieser Segen verleiht euch in euren nächsten Kämpfen Resistenz gegen Erdschaden.",ep:18,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[7400] = {n:"Schriftrolle des Findens",t:87,d:"Diese Schriftrolle erlaubt es euch, das Ziel eurer Jagd zu lokalisieren.",ep:1,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:1};
I.u[7401] = {n:"Blanko-Schriftrolle",t:87,d:"Diese Schriftrolle erlaubt es euch, ein Ziel zu \"markieren\", um es später zu jagen.",ep:16,g:1,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,ut:true,p:100};
I.u[7402] = {n:"Bündel von zehn Blanko-Schriftrollen",t:87,d:"Dieses Bündel erlaubt es euch, <b>EINE einzelne Zielperson</b> zu \"markieren\", um sie mehrfach später zu jagen.",ep:16,g:3,l:10,wd:false,fm:true,w:10,c:"Ps!0&PP>0",u:true,ut:true,p:500};
I.u[7403] = {n:"Knochen des Leopardo-Geistes",t:47,d:"Dieser kleine, aber spitze Knochen wurden einst von den Brigandinern als Nasendekoration benutzt. Eine elegante Art, auch eine Hakennase gut zur Geltung zu bringen.",ep:19,g:3,l:100,wd:true,fm:true,w:1,p:10};
I.u[7404] = {n:"Knochen eines Maho Feuerfux-Geistes",t:47,d:"Dieser Knochen ist noch von mächtiger Magie erfüllt, die man grob als \"mechanisch\" beschreiben könnte. Darum solltet ihr euch nicht wundern, wenn er sich eines Tages aufmachen sollte, die Überreste seines Besitzers zu finden.",ep:19,g:8,l:100,wd:true,fm:true,w:1,p:10};
I.u[7405] = {n:"Knochen des Pandikaze-Geistes",t:47,d:"Dieser Knochen ist das Einzige, was vom Pandikaze-Geist noch übriggeblieben ist, nachdem ihr über ihn hergefallen seid. Doch habt ihr kein Glück. Er besitzt keinerlei Magie...",ep:19,g:4,l:100,wd:true,fm:true,w:1,p:10};
I.u[7406] = {n:"Knochen des Geistes der Pandora",t:47,d:"Dieser Knochen ist nicht der Büchse der Pandora entwichen, doch könnte man dies beinahe glauben.",ep:19,g:5,l:100,wd:true,fm:true,w:1,p:10};
I.u[7407] = {n:"Knochen des Pandel-Geistes",t:47,d:"Dieser handgeschnitzte Knochen könnte problemlos als Zeiger einer gewaltigen Uhr verwendet werden, so vielseitig einsetzbar ist er!",ep:19,g:6,l:100,wd:true,fm:true,w:1,p:10};
I.u[7408] = {n:"Knochen des Soryo-Feuerfux-Geistes",t:47,d:"Als sich der Soryo Feuerfux zum ersten Mal einen Knochen brach, beschloss er, sich am erstbesten Wesen zu rächen, das ihm über den Weg liefe. Euch! Doch ist er offenbar an den Falschen geraten.",ep:19,g:7,l:100,wd:true,fm:true,w:1,p:10};
I.u[7410] = {n:"Knochen des Geistes von Tanukouï San",t:47,d:"Weil sie das große Gewicht der enormen Hoden des Tanukouï San zu tragen haben, gehören diese Knochen zu den Widerstandsfähigsten in ganz Amakna.",ep:19,g:1,l:100,wd:true,fm:true,w:1,p:10};
I.u[7411] = {n:"Knochen des Yokai Feuerfux-Geistes",t:47,d:"Dieser Knochen lässt sich wunderbar als Keule verwenden, wenn euch die Lust überkommt, ein paar Schädel von Mitstreitern zu zerschmettern oder Enutrofs in den Boden zu stampfen. Doch jetzt, da er sich in euren Händen befindet, ändert sich ja vielleicht sein Schicksal.",ep:19,g:2,l:100,wd:true,fm:true,w:1,p:10};
I.u[7412] = {n:"Bündel von hundert Blanko-Schriftrollen",t:87,d:"Dieses Bündel erlaubt es euch, <b>EINE einzelne Zielperson</b> zu \"markieren\", um sie mehrfach später zu jagen.",ep:16,g:3,l:10,wd:false,fm:true,w:100,c:"Ps!0&PP>0",u:true,ut:true,p:3500};
I.u[7413] = {n:"Schriftrolle: \"Zeigen\"",t:25,d:"(Doppelklick, um das Emoticon zu lernen.) \nDiese Schriftrolle ermöglicht es euch, \"Zeigen\" zu lernen – sei es um jemandem dem Weg zu weisen oder öffentlich Betrüger anzuprangern.",ep:18,g:9,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7414] = {n:"Kleine weiße Maunzmiez",t:18,d:"Dieses kleine Fellknäuel faucht, kratzt und beißt selbst die Hand, die Futter bringt. Das macht es zu einer gefährlichen, aber auch gleichzeitig unwiderstehlichen kleinen Kreatur. Ähnlichkeiten mit gewissen Wesen weiblichen Geschlechts sind wohl nicht zufällig. Doch Vorsicht: diese sehr wählerische Maunzmiez frisst nur frisches Fleisch von soeben erlegten Kreaturen.",ep:3,g:9,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7415] = {n:"Kleiner schwarzer Schnuffwuff",t:18,d:"Diese seltsame kleine Kreatur ernährt sich ausschließlich von frisch geangelten Fischen. Doch keine Sorge, seine gutmütige treudoofe Anwesenheit ist die beste Entschädigung für seinen Atem nach verwesendem Fisch.",ep:3,g:10,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7417] = {n:"Tierheimzertifikat: Peki Peki",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Peki Peki, den ihr im Tierheim abgegeben habt.",ep:3,g:26,l:1,wd:false,fm:true,w:1,p:100};
I.u[7418] = {n:"Tierheimzertifikat: Kleine weiße Maunzmiez",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über die kleine weiße Maunzmiez, die ihr im Tierheim abgegeben habt.",ep:3,g:27,l:1,wd:false,fm:true,w:1,p:100};
I.u[7419] = {n:"Tierheimzertifikat: Kleiner, schwarzer SchnuffWuff",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den kleinen, schwarzen SchnuffWuff, den ihr im Tierheim abgegeben habt.",ep:3,g:28,l:1,wd:false,fm:true,w:1,p:100};
I.u[7420] = {n:"Tierheimzertifikat: Nomoon",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Nomoon, den ihr im Tierheim abgegeben habt.",ep:3,g:35,l:1,wd:false,fm:true,w:1,p:100};
I.u[7421] = {n:"Trank des Vergessens: \"Schildschmied\"",t:44,d:"Dieser Trank lässt euch den Beruf des Schildschmiedes vergessen.",ep:18,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[7422] = {n:"Maskananas",t:16,d:"Diese Maske mit dem Aussehen einer exotischen Frucht ist ein echtes Sammlerobjekt. Sie hat keinerlei Funktion, außer – den Worten des Erfinders nach – ihren Träger exotisch und appetitlich erscheinen zu lassen.",ep:1,g:117,l:1,wd:true,fm:true,w:1,s:74,p:10};
I.u[7423] = {n:"Ei der goldenen Larve",t:12,d:"So seltsam, wie das klingen mag, ist es nun wissenschaftlich erwiesen: Die Eier der goldenen Larve werden gar nicht von den goldenen Larven ausgebrütet, sondern von den gemeinen Larven, seien sie nun grün, orange oder blau. Die Natur steckt definitiv noch voller Geheimnisse!",ep:1,g:715,l:10,wd:true,fm:true,w:1,u:true,p:1};
I.u[7425] = {n:"Kleine goldene Larve",t:32,d:"Diese Larve ist soeben aus einem Ei geschlüpft. Da ihr das erste Wesen wart, welches sie erblickte, betrachtet sie euch nun als Mutter Larve.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
