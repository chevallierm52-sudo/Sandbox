I.u[7350] = {n:"Aermyne \'Braco\' Scalptaras",t:32,d:"Aermyne \'Braco\' Scalptaras befindet sich nun in eurem sicheren Gewahrsam. Jetzt müsst ihr ihn nur noch zum Gefängnis eskortieren und dort abliefern.",ep:1,g:16,l:1,wd:false,fm:true,w:1,m:true,p:1};
