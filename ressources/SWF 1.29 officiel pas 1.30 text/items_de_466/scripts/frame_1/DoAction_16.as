I.u[7267] = {n:"Bulbusch-Blatt",t:36,d:"Diese Blätter findet man nur an einem einzigen Ort – nämlich auf dem Kopf des Bulbuschs. Versucht es also gar nicht erst, sie auf dem eurem anzupflanzen, sie würden nämlich eingehen, bevor ihr zweimal blinzeln könnt.",ep:18,g:55,l:42,wd:true,fm:true,w:2,p:10};
I.u[7268] = {n:"Bulbambus-Sprossen",t:36,d:"Diese Sprossen findet man nur an einem einzigen Ort – nämlich auf dem Kopf des Bulbambus. Untersucht darum gar nicht erst den euren, es befindet sich nichts Schmackhaftes darauf.",ep:18,g:56,l:67,wd:true,fm:true,w:2,p:10};
I.u[7269] = {n:"Magische Bulbigrinde",t:96,d:"Diese magische Rinde ist mindestens so widerstandsfähig wie der Schild von Captain Amakna, wenn auch vielleicht nicht ganz so schön.",ep:18,g:105,l:150,wd:true,fm:true,w:2,p:10};
I.u[7270] = {n:"Magische Bulbiflorarinde",t:96,d:"Diese Rinde ist derart zerbrechlich, dass man sie als Spitzenbesatz für gewagte Unterwäsche verwenden könnte.",ep:18,g:106,l:26,wd:true,fm:true,w:2,p:10};
I.u[7271] = {n:"Magische Bulbuschrinde",t:96,d:"Diese schuppige Rinde ist perfekt für Antirutsch-Schuhsohlen geeignet.",ep:18,g:107,l:42,wd:true,fm:true,w:2,p:10};
I.u[7272] = {n:"Magische Bulbambusrinde",t:96,d:"Diese glatte Rinde ist ideal für die Herstellung von Parkettböden und Tanzflächen.",ep:18,g:108,l:67,wd:true,fm:true,w:2,p:10};
I.u[7273] = {n:"Ringelschnatterhaut",t:59,d:"Die Ringelschnatterhaut gleitet einem förmlich zwischen den Fingern hindurch. Doch solltet ihr daraus besser keine Schuhe fertigen, denn ihr würdet sie nie wieder ausziehen wollen.",ep:18,g:41,l:67,wd:true,fm:true,w:2,p:10};
I.u[7274] = {n:"Ringelschnatterfangzahn",t:47,d:"Dieser Zahn gleicht keinem anderen. Er stinkt noch schlimmer, als wenn der ganze üble Geruch der Ringelschnatter darin gespeichert worden wäre.",ep:18,g:16,l:67,wd:true,fm:true,w:2,p:100};
I.u[7275] = {n:"Kitsou Nae-Haare",t:54,d:"Diese Haare sind weich wie die Kruppe eines weiblichen Trools. Das könnte glatt vergessene Kindheitserinnerungen in euch erwecken.",ep:16,g:560,l:29,wd:true,fm:true,w:1,p:10};
I.u[7276] = {n:"Kitsou Nufeu-Haare",t:54,d:"Diese Haare sind weich wie die Kruppe eines weiblichen Trools. Das könnte glatt vergessene Kindheitserinnerungen in euch erwecken.",ep:18,g:557,l:111,wd:true,fm:true,w:1,p:10};
I.u[7277] = {n:"Kitsou Nere-Haare",t:54,d:"Diese Haare sind weich wie die Kruppe eines weiblichen Trools. Das könnte glatt vergessene Kindheitserinnerungen in euch erwecken.",ep:16,g:558,l:80,wd:true,fm:true,w:1,p:10};
I.u[7278] = {n:"Kitsou Nakwa-Haare",t:54,d:"Diese Haare sind weich wie die Kruppe eines weiblichen Trools. Das könnte glatt vergessene Kindheitserinnerungen in euch erwecken.",ep:1,g:559,l:60,wd:true,fm:true,w:1,p:10};
I.u[7279] = {n:"Kitsou Nae-Fell",t:59,d:"Dieses Fell ist von hervorragender Qualität. In mehrere Streifen geschnitten, kann man daraus eine tolle Peitsche herstellen. Das perfekte Geschenk für gestresste Eltern.",ep:18,g:46,l:19,wd:true,fm:true,w:2,p:10};
I.u[7280] = {n:"Kitsou Nufeu-Fell",t:59,d:"Dieses Fell ist von hervorragender Qualität. In mehrere Streifen geschnitten, kann man daraus eine tolle Peitsche herstellen. Das perfekte Geschenk für gestresste Eltern.",ep:18,g:44,l:111,wd:true,fm:true,w:2,p:10};
I.u[7281] = {n:"Kitsou Nere-Fell",t:59,d:"Dieses Fell ist von hervorragender Qualität. In mehrere Streifen geschnitten, kann man daraus eine tolle Peitsche herstellen. Das perfekte Geschenk für gestresste Eltern.",ep:18,g:45,l:80,wd:true,fm:true,w:2,p:10};
I.u[7282] = {n:"Kitsou Nakwa-Fell",t:59,d:"Dieses Fell ist von hervorragender Qualität. In mehrere Streifen geschnitten, kann man daraus eine tolle Peitsche herstellen. Das perfekte Geschenk für gestresste Eltern.",ep:1,g:43,l:60,wd:true,fm:true,w:2,p:10};
I.u[7283] = {n:"Tanukouï San-Haut",t:59,d:"Die ausgebreitete Haut von Tanukouï San gibt eine ausgezeichnete Geldbörse für eure Kamas ab.",ep:1,g:2,l:85,wd:true,fm:true,w:2,p:100};
I.u[7284] = {n:"Tanukouï San-Haare",t:54,d:"Die Haare von Tanukouï San riechen nicht allzu gut. Aber das ist auch vollkommen egal, schließlich sind es die Haare von Tanukouï San.",ep:1,g:3,l:85,wd:true,fm:true,w:2,p:100};
I.u[7285] = {n:"Araknawa-Klaue",t:103,d:"Diese kleine Klaue wird noch lange Zeit vor sich hin zucken. Diskret in die Unterhose eurer Gegner plaziert, ist sie eine ideale Ablenkung, die euch sicher den Sieg eintragen wird.",ep:18,g:716,l:43,wd:true,fm:true,w:2,p:100};
I.u[7286] = {n:"Bimbambusholz",t:38,d:"Bimbambusholz ist beinahe genauso wertvoll wie das viel gepriesene Kuhklebkussholz, obwohl es sehr viel verbreiteter ist, als jenes. Das muss man nicht verstehen, oder?",ep:18,g:675,l:47,wd:true,fm:true,w:2,p:100};
I.u[7287] = {n:"Bimbambus-Blatt",t:36,d:"Bimbambusblätter sind breit und haarig. Also ein wenig wie Bwork-Weibchen, allerdings nicht so aggressiv.",ep:18,g:69,l:47,wd:true,fm:true,w:2,p:1};
I.u[7288] = {n:"Blatt des heiligen Bimbambus",t:36,d:"Dieses große Blatt ist dermaßen hart und schwer, dass es euch zerquetschen könnte. Jetzt wisst ihr auch, warum man im Herbst besser nicht unter Heiligen Bimbambussen schlafen sollte.",ep:18,g:68,l:120,wd:true,fm:true,w:2,p:100};
I.u[7289] = {n:"Heiliges Bimbambusholz",t:38,d:"Dieses Holz hier sollte niemals in die falschen Hände geraten, doch niemand weiß genau warum.",ep:18,g:674,l:120,wd:true,fm:true,w:10,p:100};
I.u[7290] = {n:"Magische Bimbambus-Wurzel",t:98,d:"Diese Wurzel erlaubt es dem Bimbambus, Magie aus dem Boden zu speichern, bevor er sie im Kampf auf seine Gegner schleudert.",ep:18,g:100,l:20,wd:true,fm:true,w:2,p:10};
I.u[7291] = {n:"Magische Wurzel des heiligen Bimbambus",t:98,d:"Diese Wurzel erlaubt es dem heiligen Bimbambus, Magie aus dem Boden zu speichern, bevor er sie im Kampf auf seine Gegner schleudert.",ep:18,g:99,l:87,wd:true,fm:true,w:2,p:100};
I.u[7292] = {n:"Maho Feuerfux-Haare",t:54,d:"Diese Haare stammen vom gefährlichen Maho Feuerfux. Diese Kreatur sieht zwar ganz niedlich aus, doch besitzt sie in Wirklichkeit furchtbare magische Kräfte.",ep:18,g:202,l:150,wd:true,fm:true,w:2,p:1};
I.u[7293] = {n:"Soryo Feuerfux-Haare",t:54,d:"Diese Haare stammen von einer kleinen, rothaarigen und bösartigen Kreatur, wie so viele andere.",ep:18,g:203,l:130,wd:true,fm:true,w:10,p:1};
I.u[7294] = {n:"Yokai Feuerfux-Haare",t:54,d:"Diese dichten und übelriechenden Haare wurden mit roher Gewalt einer schaurigen, rothaarigen Kreatur ausgerissen.",ep:18,g:204,l:110,wd:true,fm:true,w:10,p:10};
I.u[7295] = {n:"Pandora-Haare",t:54,d:"Aus diesen mysterösen Haaren lässt sich sicherlich ein Umhang oder eine magische Mütze mit überraschenden Eigenschaften schneidern.",ep:18,g:2,l:200,wd:true,fm:true,w:10,p:200};
I.u[7297] = {n:"Pandel-Haare",t:54,d:"Diese magischen Haare sind so mächtig, dass sie sogar ein kaputtes Uhrwerk wieder in Bewegung setzen könnten.",ep:18,g:206,l:150,wd:true,fm:true,w:1,p:1};
I.u[7298] = {n:"Maho Feuerfux-Haut",t:59,d:"Diese glatte, feine Haut bietet einen hervorragenden Schutz gegen die unterschiedlichsten magischen Attacken des Maho Feuerfuxes. Mehr noch: sie gestattet es, die Angriffe des Maho Feuerfuxes gegen diesen selbst zurückzuwenden.",ep:18,g:42,l:150,wd:true,fm:true,w:1,p:100};
I.u[7299] = {n:"Soryo Feuerfux-Haut",t:59,d:"Diese Haut diente einst zur Anfertigung von Unterwäsche für Kinder mit empfindlicher Haut. Schlüpfer aus Soryo Feuerfux-Haut wurden selbst von den Nachkommen des Chafer-Offiziers für gut geheißen.",ep:18,g:38,l:130,wd:true,fm:true,w:1,p:100};
I.u[7300] = {n:"Yokai Feuerfux-Haut",t:59,d:"Diese dicke Haut gibt einen hervorragenden Schutz gegen Bambusschläge ab.",ep:18,g:37,l:110,wd:true,fm:true,w:1,p:100};
I.u[7301] = {n:"Leopardo-Haut",t:59,d:"Diese Haut wurde einst von Pandawas verwendet, um daraus sehr leichte, \"minimalistische\" Unterwäsche anzufertigen.",ep:18,g:36,l:40,wd:true,fm:true,w:1,p:10};
I.u[7302] = {n:"Pandora-Haut",t:59,d:"Die Haut von Pandora wird euch sicherlich viele Überraschungen bereiten, falls ihr Schuhmacher seid.",ep:18,g:1,l:200,wd:true,fm:true,w:10,p:100};
I.u[7303] = {n:"Pandel-Haut",t:59,d:"Diese raue Haut wechselt je nach Uhrzeit die Farbe.",ep:18,g:39,l:100,wd:true,fm:true,w:1,p:10};
I.u[7304] = {n:"Maho Feuerfux-Pelz",t:55,d:"Hierbei handelt es sich um einen magischen Pelz mit roten Haaren voller übermächtiger Magie. Mehr gibt es dazu nicht zu sagen.",ep:18,g:11,l:150,wd:true,fm:true,w:1,p:100};
I.u[7305] = {n:"Soryo Feuerfux-Pelz",t:55,d:"Dieser kleine Pelz ist perfekt dazu geeignet, im Winter Löcher in Wänden und Türen zu stopfen.",ep:18,g:10,l:130,wd:true,fm:true,w:1,p:10};
I.u[7306] = {n:"Yokai Feuerfux-Pelz",t:55,d:"Dieser Pelz stammt direkt von den empfindlichsten Teilen eines Yokai Feuerfuxes. Gleichzeitig leider auch von den Übelriechendsten. Viele Abenteurer denken, es handele sich dabei um seine Barthaare, doch sie irren sich.",ep:18,g:9,l:110,wd:true,fm:true,w:1,p:10};
I.u[7307] = {n:"Pandora-Pelz",t:55,d:"Dieser Pelz ist beinahe genauso selten wie etwas Positives aus der Büchse der Pandora.",ep:18,g:125,l:200,wd:true,fm:true,w:10,p:10};
I.u[7308] = {n:"Pandel-Pelz",t:55,d:"Im Gegensatz zu allem, was man denken mag, ist dieser Pelz nicht essbar. Abenteurer, die dies versucht haben, wurden in einen Tanukouï San-Geist verwandelt. Für manche allerdings ein Glücksgriff...",ep:18,g:12,l:100,wd:true,fm:true,w:1,p:10};
I.u[7309] = {n:"Schlüssel zum Dungeon der Pandikaze",t:84,d:"Dieser Schlüssel öffnet euch die Türen zum Dungeon der Pandikaze. Doch ist er nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:13,g:229,l:1,wd:true,fm:true,w:1,p:100};
I.u[7310] = {n:"Schlüssel zur Bulbi-Höhle",t:84,d:"Dieser Schlüssel öffnet euch die Türen zur Bulbi-Höhle. Doch ist er nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:1,g:230,l:1,wd:true,fm:true,w:1,p:100};
I.u[7311] = {n:"Schlüssel zum Dungeon der Kitsoune",t:84,d:"Dieser Schlüssel öffnet euch die Türen zum Dungeon der Kitsoune. Doch ist er nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:1,g:231,l:1,wd:true,fm:true,w:1,p:100};
I.u[7312] = {n:"Schlüssel zum Dungeon der Feuerfuxe",t:84,d:"Dieser Schlüssel öffnet euch die Türen zum Dungeon der Feuerfuxe. Doch ist er nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:2,g:232,l:1,wd:true,fm:true,w:1,p:100};
I.u[7313] = {n:"Regeln der Pandawashu-Kunst",t:25,d:"Ein Buch mit Regeln, die jeder, der die Pandawushu-Kampfarten ausübt, aus dem FF beherrschen muss...",ep:18,g:19,l:1,wd:true,fm:true,w:2,u:true,p:1};
