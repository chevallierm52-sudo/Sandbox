I.u[7703] = {n:"Kleiner böser Rabling",t:18,d:"Dieses dunkle Federvieh ist bekannt dafür, sich auf Friedhöfen herumzutreiben und Abenteurer mit weißer Haut zu jagen. Seinen Schnabel pflegt er an frisch aus dem Grab geplünderten Knochen zu wetzen.",ep:3,g:18,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:8,p:1};
I.u[7704] = {n:"Wuseliges Eichhörnchen",t:18,d:"Dieses Eichhörnchen wird ein diabolisches Vergnügen daran finden, euch auf die Nüsse zu gehen, was allerdings ganz praktisch sein kann, wenn auch äußerst schmerzhaft. Dieser Vertraute isst nur Samenkörner.",ep:3,g:16,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7705] = {n:"Leopardo",t:18,d:"Diese hübsche Kreatur ist ein entfernter Verwandter der auf der Wabbit-Insel lebenden Lenalds. Doch sie ist viel mutiger undisziplinierter als jene. Der Leopardo wird euch bei allen Kämpfen sicher gut unterstützen können. Doch nehmt euch in Acht: Diese Kreatur kann sehr nachtragend sein, wenn sie denkt, dass ihr euch nicht genug um sie kümmert. Angemerkt sein, dass sie ausschließlich Fleisch frisst.",ep:3,g:27,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7706] = {n:"Bilby",t:18,d:"Bilby, oder Bilbiblabalou, ist ein kleines, abenteuerlustiges Gelee. Es ist ganz besonders auf Vald fixiert und besitzt bemerkenswerte Fähigkeiten (in Anbetracht seiner geringen Größe jedenfalls).",ep:3,g:43,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7707] = {n:"Frischling",t:18,d:"Dieser kleine Frischling besitzt einen besonders großen Rüssel, mit dem er selbst die dicksten Eicheln aufzustöbern vermag. Kein Wunder, dass er euch gleich gefunden hat.",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7708] = {n:"Blauer Piepmatz",t:18,d:"Dieser kleine Piepmatz ist nicht wie alle anderen Piepmatze. Man braucht sich ja bloß mal seine Farbe anzusehen! Jedoch teilt er mit denen, mit denen er sonst nichts teilt, die Vorliebe für das Anpicken von Hinterteilen anderer Wesen. Man sagt, es gäbe Leute,  die so etwas mögen...",ep:1,g:19,l:1,wd:true,fm:true,w:10,p:1};
