I.u[7497] = {n:"Trank der Massenbefreiung",t:14,d:"Dieser Trank erlaubt es euch, die Seelen aller eurer Feinde auf der Karte zu befreien und sie zurück auf den Friedhof zu schicken, ohne dass sie die Gelegenheit hätten, vorher wiedererweckt zu werden.",ep:0,g:59,l:1,wd:false,fm:true,w:1,c:"Pg>23,4",u:true,p:10};
