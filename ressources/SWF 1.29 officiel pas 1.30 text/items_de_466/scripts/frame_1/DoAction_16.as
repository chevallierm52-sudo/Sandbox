I.u[7683] = {n:"Futterstelle aus Urholz",t:93,d:"Diese Futterstelle enthält leckere Nahrung, speziell für Reittiere. Das wird mit Sicherheit eine willkommene Abwechslung sein, nach all den Süßigkeiten mit denen es bisher gefüttert wurde. An der Futterstelle gewinnt ein Reittier wieder ein wenig Energie zurück, wenn es schwächeln sollte.",ep:2,g:92,l:1,wd:true,fm:true,w:10,ut:true,p:1};
