I.u[7634] = {n:"Klassischer Dracopo",t:93,d:"Dieses lederbezogene, mechanische Dracotruterhinterteil wird selbst die hochnäsigsten aller männlichen Reittiere zufrieden stellen. Außerdem erweckt es auch die mütterlichen Instinkte der Weibchen. Unbestätigten Gerüchten zufolge scheinen diese Maschinen sogar bei Iops zu funktionieren.",ep:1,g:3,l:1,wd:true,fm:true,w:10,ut:true,p:1};
