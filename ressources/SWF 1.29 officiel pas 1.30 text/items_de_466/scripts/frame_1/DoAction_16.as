I.u[7552] = {n:"Truterumhang",t:17,d:"Wenn sich ein Krieger und ein Dracotruter treffen, dann können seltsame Dinge geschehen. Dieser Umhang hier ist das beste Beispiel dafür. Er besteht aus einem gewöhnlichen Tuch, auf welches die Flügel und der Schwanz eines Dracotruters genäht wurden, welcher sich anläßlich des Treffens mit dem berühmten Wilddiebischen Kreuzbuben freiwillig geopfert hatte. Oh\'Nein soll daraus anschließend sogar ein Lied komponiert haben.",ep:2,g:90,l:50,wd:true,fm:true,w:5,s:42,p:25000};
I.u[7553] = {n:"Truterkappe",t:16,d:"Wenn ihr schon immer mal wie ein Dracotruter aussehen wolltet, so ist dies endlich eure Chance. Jedoch solltet ihr vermeiden, zur Weihnachtszeit damit in den Straßen Amaknas herumzulaufen, da ihr andernfalls gesundheitliche Probleme bekommt.",ep:2,g:118,l:50,wd:true,fm:true,w:10,s:42,p:15000};
I.u[7554] = {n:"Trutertreter",t:11,d:"Eure Freundinnen werden euch sicherlich um diese stylischen Stiefel beneiden. Doch solltet ihr deren Namen nicht allzu wörtlich nehmen, denn Dragotruten zu treten, ist grundsätzlich eine ganz schlechte Idee. Sie werden euch auf Schritt und Tritt verfolgen, und wenn sie euch erst einmal gekrallt haben, dann werdet ihr sicherlich ziemlich betreten aus der Wäsche schauen.",ep:2,g:65,l:50,wd:true,fm:true,w:3,s:42,p:5000};
I.u[7555] = {n:"Trutering",t:9,d:"Mit diesem Ring am Finger werden eure Freundinnen sicher voller Neid sagen: \"Sie sieht wirklich aus wie ein Truter\".",ep:2,g:97,l:50,wd:true,fm:true,w:1,s:42,p:1000};
I.u[7556] = {n:"Truter-Geschenkpaket",t:89,d:"Dieses Geschenkpaket enthält einen Teil eines berühmten Verkleidungssets. Eure Dracotruterfreunde werden vor Neid platzen, wenn sie es sehen!",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7557] = {n:"Schlüssel zum Dungeon der Astaknyden",t:84,d:"Dieses Schlüssel aus echter Astaknydenrinde sieht so aus, als könne er gleich Wurzeln schlagen, sobald er an einem warmen und feuchten Ort abgelegt wird – beispielsweise in einer Bwork-Unterhose.",ep:1,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[7558] = {n:"Bworkies banale Behaarung",t:24,d:"Diese Haar bleiben sicherlich nur für kurze Zeit in eurem Rucksack... Jedenfalls ist euch dies zu wünschen.",ep:14,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[7559] = {n:"Goldogur",t:10,d:"Man munkelt, der erste Besitzer dieses Prachtstückes hätte nach der ersten Anprobe nicht mehr aufhören können, Luftsprünge zu machen und Pirouetten zu drehen. Das zeigt, dass man schon wirklich ein wenig verrückt sein muss, um ein derartiges Teil zu tragen.",ep:22,g:85,l:164,wd:true,fm:true,w:0,p:48200};
I.u[7560] = {n:"Re Per Wa Rune",t:78,d:"Diese Rune erlaubt es euch, Wasser-Schaden zu absorbieren.",ep:1,g:31,l:10,wd:true,fm:true,w:1,p:10};
