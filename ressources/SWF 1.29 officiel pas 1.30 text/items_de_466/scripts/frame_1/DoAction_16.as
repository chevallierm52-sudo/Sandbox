I.u[7326] = {n:"Perzeptauren-Trank des Vergessens: Pods",t:86,d:"Dieser vom Gildenobersten verabreichte Trank senkt die zulässige Zahl an Pods für Perzeptauren.",ep:5,g:1,l:6,wd:true,fm:false,w:5,c:"Pz=0",u:true,p:100};
I.u[7327] = {n:"Perzeptauren-Trank des Vergessens: Anzahl der Perzeptauren",t:86,d:"Dieser vom Gildenobersten verabreichte Trank senkt die maximale Anzahl an Perzeptauren um eins.",ep:5,g:1,l:6,wd:true,fm:false,w:5,c:"Pz=0",u:true,p:100};
