I.u[7356] = {n:"VerBwackWandlung",t:31,d:"Das Wasser der verfluchten Quelle des ertrunkenen Bwacks hat euch vorübergehend in einen Bwack verwandelt. Bei der geringsten Berührung werdet ihr wieder in eure ursprüngliche Form zurückverwandelt.",ep:18,g:22,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[7357] = {n:"Frischlinglische Verwandlung",t:31,d:"Das Wasser der verfluchten Quelle des ertrunkenen Frischlings hat euch vorübergehend in einen Frischling verwandelt. Bei der geringsten Berührung werdet ihr wieder in eure ursprüngliche Form zurückverwandelt.",ep:18,g:20,l:1,wd:false,fm:false,w:0,m:true,p:1};
