I.u[7329] = {n:"Perzeptauren-Trank des Vergessens: Weisheit",t:86,d:"Dieser vom Gildenobersten verabreichte Trank senkt die Weisheit der Perzeptauren.",ep:5,g:1,l:6,wd:true,fm:false,w:5,c:"Pz=0",u:true,p:100};
I.u[7330] = {n:"Lexikon der Alchemie, Band G: Perzeptauren",t:25,d:"Dieses Lexikon enthält alle Alchemierezepturen, die für Perzeptauren verwendbar sind.",ep:2,g:2,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[7331] = {n:"Enormer Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer die Chance, selbst die widerborstigsten Seelen einzufangen.",ep:16,g:14,l:1,wd:false,fm:true,w:1,tw:true,p:10000};
I.u[7332] = {n:"Kleiner glücklicher Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer eine gute Chance, nicht allzu mächtige Seelen einzufangen.",ep:5,g:3,l:1,wd:false,fm:true,w:1,tw:true,p:3750};
I.u[7333] = {n:"Mittelgroßer glücklicher Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer eine gute Chance, relativ erhabene Seelen einzufangen.",ep:5,g:4,l:1,wd:false,fm:true,w:1,tw:true,p:7500};
I.u[7334] = {n:"Großer glücklicher Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer eine gute Chance, auch noch überaus scheue Seelen einzufangen.",ep:16,g:5,l:1,wd:false,fm:true,w:1,tw:true,p:10500};
I.u[7335] = {n:"Enorm glücklicher Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer eine gute Chance, selbst die widerborstigsten Seelen einzufangen.",ep:16,g:6,l:1,wd:false,fm:true,w:1,tw:true,p:15000};
I.u[7336] = {n:"Mega-Seelenstein des Hasardeurs",t:83,d:"Diese Rune gibt ihrem Besitzer eine geringe Chance, selbst die Mächtigsten aller Seelen einzufangen.",ep:16,g:11,l:1,wd:false,fm:true,w:1,tw:true,p:12500};
I.u[7337] = {n:"Mega-Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer eine Chance, selbst die Mächtigsten aller Seelen einzufangen.",ep:16,g:15,l:1,wd:false,fm:true,w:1,tw:true,p:25000};
I.u[7338] = {n:"Glücklicher Mega-Seelenstein",t:83,d:"Diese Rune gibt ihrem Besitzer eine gute Chance, selbst die Mächtigsten aller Seelen einzufangen.",ep:16,g:7,l:1,wd:false,fm:true,w:1,tw:true,p:37500};
I.u[7339] = {n:"Kitsou-Kappe",t:16,d:"Dieser ausgehöhlte Kopf eines Kitsous kann nur von Abenteurern getragen werden, die völlig ihren Geruchsinn verloren haben. Niemand fragt sich zweimal warum.",ep:18,g:97,l:61,wd:true,fm:true,w:10,s:41,p:9875};
I.u[7340] = {n:"Kitsou-Umhang",t:17,d:"Dieser Umhang lässt sich mit einfachsten Mitteln waschen - selbst ein Bach reicht dazu aus. Allerdings besteht das Risiko, dass er ab dem dritten Waschgang seine schöne Farbe verliert.",ep:18,g:84,l:62,wd:true,fm:true,w:10,s:41,p:10225};
I.u[7341] = {n:"Kitsou-Ring",t:9,d:"Dieser kleine Ring beschützt seinen Träger vor den ständigen, lästigen, kleinen Alltagssorgen.",ep:1,g:93,l:55,wd:true,fm:true,w:10,s:41,p:8125};
I.u[7342] = {n:"Kitsou-Amulett",t:1,d:"Das Kitsou-Amulett wird mit Sicherheit die Aufmerksamkeit auf euer Doppelkinn lenken.",ep:18,g:91,l:26,wd:true,fm:true,w:10,s:41,p:2000};
I.u[7343] = {n:"Leopardo-Haare",t:54,d:"Diese Haare sind keineswegs wie alle anderen, auch wenn alles dies zu glauben scheinen.",ep:18,g:205,l:50,wd:true,fm:true,w:5,p:1};
I.u[7344] = {n:"Aerdala-Dojo-Siegerurkunde",t:24,d:"Auf diesem Zettel steht das offizielle Datum, an dem ihr zuletzt im Dojo einen Sieg errungen habt.",ep:1,g:251,l:0,wd:false,fm:true,w:0,p:1};
