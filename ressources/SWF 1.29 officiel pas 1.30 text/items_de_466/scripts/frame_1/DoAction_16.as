I.u[7495] = {n:"Ledermesser des Schuhmagiers",t:5,d:"Mit diesem Ledermesser könnt ihr euer Leder noch besser zerschneiden und besser Felle gerben. Damit ist es das ideale Werkzeug, um alte Schuhe und Gürtel zu erneuern.",ep:2,g:53,l:1,wd:true,fm:true,w:15,an:13,e:[5,6,1,1,40,40,false,false],c:"PJ=62",p:1000};
