I.u[7650] = {n:"Hammer des Bastlers",t:7,d:"Mit diesem Hammer kann ein Bastler eine Vielzahl von Gegenständen erschaffen oder Arbeiten verrichten.",ep:7,g:2,l:1,wd:true,fm:true,w:10,an:15,e:[5,6,1,1,50,50,false,false],p:100};
I.u[7651] = {n:"Nebelhorn",t:94,d:"Dieses Nebelhorn ruft euer Reittier zu Hilfe, wenn ihr in Not seid.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[7652] = {n:"Trank der Erinnerung",t:12,d:"Dieser Trank nimmt einen mikroskopischen Teil der Essenz eines Wesens auf und markiert damit einen Gegenstand oder ein Gebiet. Dies ist sehr praktisch, um eine unauslöschliche Erinnerung daran zu bewahren.",ep:18,g:2,l:1,wd:true,fm:true,w:1,p:1};
