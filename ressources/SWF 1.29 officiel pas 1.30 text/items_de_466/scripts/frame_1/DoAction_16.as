I.u[7367] = {n:"Engel & Dämonen",t:25,d:"Nach dem Landen eines Bestsellers, hochgelobt von einer Vielzahl von Lesern, gibt es nun einen zweiten Teil zu den metaphysischen Thesen von Acidrik Magenspalter.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[7368] = {n:"Stärnbchen",t:3,d:"Der Schöpfer dieses Stabes erschuf ihn, um damit Sternschnuppen vom Himmel zu holen, da sie ihn am Schlafen hinderten. Wenn man der Legende Glauben schenken darf, so wollte er ihn nach einer durchzechten Nacht in der Taverne ausprobieren, wobei er dummerweise den Mond statt eine Sternschnuppe erwischte. Die Macht des Stabes soll ausgereicht haben, um den Mond in zwei Hälften zu spalten, wobei eine Hälfte in den Schlamm des Assel-Meeres fiel, um Moons Insel zu bilden. Doch ist das wohl nur eine frei erfundene Tavernengeschichte.",ep:19,g:55,l:126,wd:true,fm:true,w:15,an:11,e:[5,4,2,4,50,50,false,true],c:"CS>100&CV>150&CI>300",p:39355};
I.u[7369] = {n:"Bimbambus-Bernstein",t:50,d:"Dieses Stück Bernstein hängt meistens ganz oben an der Krone des Bimbambus. Es dient ihm als Schmuck sowie auch dazu, mehr Schaden anzurichten, wenn er beschließt, nach euch zu schlagen. Eine erfinderische Kreatur!",ep:18,g:2,l:40,wd:true,fm:true,w:2,p:100};
I.u[7370] = {n:"Heiliger Bimbambus-Bernstein",t:50,d:"Dieser Bernstein ist der einzige Besitz des heiligen Bimbambus, den er darum auch eifersüchtig gegen alle Eindringlinge verteidigt. Darum ist er auch so ausgemergelt und bösartig...",ep:18,g:1,l:120,wd:true,fm:true,w:2,p:100};
I.u[7371] = {n:"\"Die Zeit der Dofus\" – Wiedergefundene Fragmente IV",t:25,d:"Band IV der Fragmente von der Geschichte der Welt, gefunden und überabeitet von Acidrik Magenspalter.",ep:18,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
