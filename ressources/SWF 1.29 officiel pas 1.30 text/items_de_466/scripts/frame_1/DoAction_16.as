I.u[7625] = {n:"Klassischer Prügler",t:93,d:"Dieses mechanische Gerät teilt euren Reittieren die Schläge aus, die sie schon lange verdient haben. Diese Art Maschine wurde früher üblicherweise in Schulen eingesetzt, beispielsweise, um jungen Iops beizubringen, bis 5 zu zählen.",ep:1,g:5,l:1,wd:true,fm:true,w:10,ut:true,p:1};
