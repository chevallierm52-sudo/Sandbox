I.u[7502] = {n:"Trank des Sammelns",t:12,d:"Dieser Trank ermöglicht die Festlegung eines Sammelpunktes. Das kann beispielsweise nützlich sein, wenn ihr zusammen mit anderen Abenteurern gleicher Gesinnung den Angriff oder die Verteidigung eines Dorfes organisieren wollt. Zusätzlich speichert dieser magische Trank die letzte Position der Charaktere vor Aufsuchen des Sammelpunktes, was es diesen später ermöglicht, schnell wieder dorthin zurückzukehren.",ep:0,g:21,l:1,wd:false,fm:true,w:1,p:1};
I.u[7505] = {n:"Trank des Vergessens: \"Kleidsamagier\"",t:44,d:"Dieser Trank lässt euch den Beruf des Kleidsamagiers vergessen.",ep:9,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
