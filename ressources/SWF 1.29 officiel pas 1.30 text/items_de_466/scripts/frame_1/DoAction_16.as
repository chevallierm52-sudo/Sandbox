I.u[7673] = {n:"Tränke aus Urholz",t:93,d:"An dieser Tränke kann eurer künftiges Reittier seinen Durst stillen oder in den heißen Sommermonaten herumplanschen. Mit Wasser und/oder magischen Tränken gefüllt, wird sie sicherlich ihren Teil zum gesunden Wachstum eures Reittieres beitragen.",ep:3,g:88,l:1,wd:true,fm:true,w:10,ut:true,p:1};
