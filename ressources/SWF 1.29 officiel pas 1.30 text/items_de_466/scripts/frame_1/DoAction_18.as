I.u[8348] = {n:"Schwarze Dracossschale",t:111,d:"Mit dieser Dracossschale könnt ihr leicht eure wertvollsten Teile bedecken.",ep:11,g:738,l:50,wd:true,fm:true,w:1,p:10};
I.u[8349] = {n:"Saphir-Dracossschale",t:111,d:"Mit dieser Dracossschale könnt ihr leicht eure wertvollsten Teile bedecken.",ep:11,g:739,l:50,wd:true,fm:true,w:1,p:10};
