I.u[8351] = {n:"Goldene Dracossschale",t:111,d:"Mit dieser Dracossschale könnt ihr leicht eure wertvollsten Teile bedecken.",ep:11,g:741,l:50,wd:true,fm:true,w:1,p:10};
I.u[8352] = {n:"Schwarze Dracossschuppe",t:59,d:"Aus dieser hübschen Dracossschuppe lassen sich bestimmt schöne Stiefel herstellen, oder sogar ein Set neuer Kampf-Unterwäsche.",ep:11,g:606,l:50,wd:true,fm:true,w:1,p:10};
I.u[8353] = {n:"Saphir-Dracossschuppe",t:59,d:"Aus dieser hübschen Dracossschuppe lassen sich bestimmt schöne Stiefel herstellen, oder sogar ein Set neuer Kampf-Unterwäsche.",ep:11,g:608,l:50,wd:true,fm:true,w:1,p:10};
I.u[8354] = {n:"Weiße Dracossschuppe",t:59,d:"Aus dieser hübschen Dracossschuppe lassen sich bestimmt schöne Stiefel herstellen, oder sogar ein Set neuer Kampf-Unterwäsche.",ep:11,g:607,l:50,wd:true,fm:true,w:1,p:10};
I.u[8355] = {n:"Goldene Dracossschuppe",t:59,d:"Aus dieser hübschen Dracossschuppe lassen sich bestimmt schöne Stiefel herstellen, oder sogar ein Set neuer Kampf-Unterwäsche.",ep:11,g:605,l:50,wd:true,fm:true,w:1,p:10};
I.u[8356] = {n:"Draconixa-Haut",t:59,d:"Diese glatte und mit Abenteurerblut parfürmierte Haut ist das Geheimnis, welches Draconixen so unwiderstehlich macht. Sie eignet sich hervorragend für Schuhwerk oder Gürtel und hat zudem noch den Vorteil, dass sie leicht bei jeder Temperatur in der Waschmaschine gewaschen werden kann.",ep:11,g:609,l:70,wd:true,fm:true,w:1,p:1};
I.u[8357] = {n:"Draconixa-Horn",t:47,d:"Die Draconixa besitzt an der Rückseite des Kopfes zwei kleine Hörner. Die sind dazu da, die Wellen der Verliebtheit der anderen Dracheier in der Brunftzeit aufzufangen, die, noch einmal zur Erinnerung, bei den Dracheiern nie endet.",ep:11,g:649,l:70,wd:true,fm:true,w:1,p:10};
I.u[8358] = {n:"Draconixa-Schützer",t:111,d:"Wenn die Spannung steigt und droht, sich in einem gewaltigen Liebesgewitter zu entladen, kann sich die Draconixa mit diesen Dracheischützern vor eigenen Liebestorheiten bewahren. Die Schützer sollen übrigens auch bei männlichen Exemplaren helfen, wenn sie unterhalb des Gürtels getragen werden.",ep:11,g:742,l:70,wd:true,fm:true,w:1,p:10};
I.u[8359] = {n:"Flügel eines fliegenden Dracheis",t:104,d:"Selbst beschädigt, zerfetzt und angesengt wie es ist, kann man mit desem Flügel immer noch frei wie ein unschuldiges Moskitokind über dem Abgrund schweben.",ep:11,g:743,l:80,wd:true,fm:true,w:1,p:10};
I.u[8360] = {n:"Haut eines fliegenden Dracheis",t:59,d:"Diese dunkle Haut ist mit einer Vielzahl kleiner Schuppen übersät, die den Luftwiderstand des fliegenden Dracheis senken sollen. In Wirklichkeit dienen sie jedoch nur dazu, Unwissende damit zu beeindrucken.",ep:11,g:610,l:70,wd:true,fm:true,w:1,p:10};
I.u[8361] = {n:"Horn eines fliegenden Dracheis",t:47,d:"Dieses Horn fungiert als Visier, um das Ziel anzufliegen. Das ist sehr praktisch, wenn das fliegende Drachei wieder einmal zu viel getrunken hat.",ep:11,g:650,l:70,wd:true,fm:true,w:1,p:10};
I.u[8362] = {n:"Haut eines Dracheikriegers",t:59,d:"Die Haut eines Dracheikriegers ist nicht nur dafür bekannt, selbst den harten Schlägen der Klinge des Kriegers widerstehen zu können, sondern auch nach mehrjährigem Kochen sehr schmackhaft zu sein.",ep:11,g:611,l:80,wd:true,fm:true,w:1,p:10};
I.u[8363] = {n:"Horn eines Drachei-Kriegers",t:47,d:"Ein echter Drachei-Krieger verfügt über drei verschiedene Hörner. Zwei hinter dem Kopf, und eines auf der Spitze der Schnauze. So kann das Opfer mit 2 Hörnern festgehalten werden, während der Krieger es mit dem dritten Horn aufspießt. Manchmal dreht er jedoch auch den Spieß herum und macht es umgekehrt.",ep:11,g:651,l:80,wd:true,fm:true,w:1,p:10};
I.u[8364] = {n:"Lederriemen eines Drachei-Kriegers",t:15,d:"Dieser Lederriemen ermöglichte es dem Drachei-Krieger, seine Schulterpolster zu befestigen. Euch hingegen wird er helfen, eure Hosen zu tragen.",ep:11,g:744,l:80,wd:true,fm:true,w:1,p:10};
I.u[8365] = {n:"Geborstenes Crocabulia-Horn",t:47,d:"Crocabulia hat einst in einem furchtbaren Kampf das eigene Horn zerborsten. Doch hat sich der Einsatz gelohnt. Dabei hat sie nämlich das Ei beschützen können, aus dem 15 Jahre später der furchtbare Crocoburio geschlüpft ist.",ep:11,g:652,l:400,wd:true,fm:true,w:1,p:10};
I.u[8366] = {n:"Kleiner, roter Kapaunumhang",t:17,d:"Dieser Umhang gehörte einst einem berühmten Kapaun, einem alten Geflügel mit langen Federn, welches gern vor dem Zaap von Bonta vor einem Publikum aus naivem Junggeflügel und unreifen gackernden Hennen hin- und herstolzierte.",ep:22,g:121,l:171,wd:true,fm:true,w:10,p:49200};
I.u[8367] = {n:"Crocabulia-Haut",t:59,d:"Diese rote Haut wird es euch vielleicht erlauben, das Mäntelchen zu eurem kleinen roten Käppchen zu schneidern, vorausgesetzt euch stören ie Kommentare eurer Verbündeten nicht.",ep:11,g:612,l:400,wd:true,fm:true,w:1,p:10};
I.u[8368] = {n:"Crocabulia-Zahn",t:47,d:"Dieser enorme Zahn wurde in Extremis herausgebrochen, bevor Crocabulia das Maul für immer schloss.",ep:11,g:653,l:400,wd:true,fm:true,w:1,p:10};
I.u[8369] = {n:"Schalenfragment von Terrassikolossokal, dem Krieger",t:111,d:"Dieses Schalenfragment wird euch sehr nützlich dabei sein, einen Schlüssel zum Heiligtum der Dracheier anzufertigen.",ep:10,g:750,l:80,wd:true,fm:true,w:1,p:10};
I.u[8370] = {n:"Schalenfragment von Ignirakronator, dem Krieger",t:111,d:"Dieses Schalenfragment wird euch sehr nützlich dabei sein, einen Schlüssel zum Heiligtum der Dracheier anzufertigen.",ep:10,g:749,l:80,wd:true,fm:true,w:1,p:10};
I.u[8371] = {n:"Schalenfragment von Aerodinamiguir, dem Krieger",t:111,d:"Dieses Schalenfragment wird euch sehr nützlich dabei sein, einen Schlüssel zum Heiligtum der Dracheier anzufertigen.",ep:10,g:748,l:80,wd:true,fm:true,w:1,p:10};
I.u[8372] = {n:"Schalenfragment von Aquabradabraqualak, dem Krieger",t:111,d:"Dieses Schalenfragment wird euch sehr nützlich dabei sein, einen Schlüssel zum Heiligtum der Dracheier anzufertigen.",ep:10,g:747,l:80,wd:true,fm:true,w:1,p:10};
I.u[8373] = {n:"Stein von Ignifollirunklator, dem Ausgehungerten",t:51,d:"Wenn dieser Stein mit den drei restlichen Steinen in Kontakt gebracht wird, müsste er eine magische Schockwelle ausstoßen, die in der Lage sein dürfte, selbst eine magisch versiegelte Tür zu öffnen.",ep:10,g:463,l:100,wd:true,fm:true,w:1,p:10};
I.u[8374] = {n:"Stein von Aquatiriliralak, dem Gnadenlosen",t:51,d:"Wenn dieser Stein mit den drei restlichen Steinen in Kontakt gebracht wird, müsste er eine magische Schockwelle ausstoßen, die in der Lage sein dürfte, selbst eine magisch versiegelte Tür zu öffnen.",ep:10,g:460,l:100,wd:true,fm:true,w:1,p:10};
I.u[8375] = {n:"Stein von Terranowakrobakal, dem Hinterhältigen",t:51,d:"Wenn dieser Stein mit den drei restlichen Steinen in Kontakt gebracht wird, müsste er eine magische Schockwelle ausstoßen, die in der Lage sein dürfte, selbst eine magisch versiegelte Tür zu öffnen.",ep:10,g:461,l:100,wd:true,fm:true,w:1,p:10};
I.u[8376] = {n:"Stein von Aerotrubaduir, dem Bösartigen",t:51,d:"Wenn dieser Stein mit den drei restlichen Steinen in Kontakt gebracht wird, müsste er eine magische Schockwelle ausstoßen, die in der Lage sein dürfte, selbst eine magisch versiegelte Tür zu öffnen.",ep:10,g:462,l:100,wd:true,fm:true,w:1,p:10};
I.u[8377] = {n:"Bastler-Rune",t:88,d:"Dieser magische Stein erlaubt es den Bastlern, potentiellen Kunden ihre Position auf der Karte anzeigen zu lassen.",ep:18,g:12,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8378] = {n:"Magisches Fragment",t:88,d:"Dieses magische Fragment enthält einen Bruchteil der ehemals im Gegenstand enthaltenen Magie. Mit ein wenig Glück lassen sich daraus sicherlich interessante Runen gewinnen.",ep:1,g:44,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8379] = {n:"Vie-Rune",t:78,d:"Diese kleine Rune erfüllt Gegenstände mit großer Gesundheit.",ep:1,g:59,l:20,wd:true,fm:true,w:1,p:10};
I.u[8380] = {n:"Peki Peki-Fell",t:55,d:"Dieses Fell bedeckte das haarige Hinterteil des Peki Peki, bevor ihr diesen ein wenig zu fest gegen den Strich gestreichelt habt.",ep:18,g:721,l:400,wd:true,fm:true,w:10,p:100};
I.u[8381] = {n:"Magischer Peki Peki-Schwanz",t:65,d:"Dieser Schwanz ist hochmagisch. Selbst jetzt, da ihr ihn abgeschnitten, getrocknet und ausgestopft habt, ist er noch am Zucken. Irgendetwas muss doch mit ihm anzufangen sein als ein bloßes Ausstellen auf dem Regal!",ep:18,g:751,l:400,wd:true,fm:true,w:10,p:100};
I.u[8383] = {n:"Moon-Haut",t:59,d:"Ohne seine weiche, schöne Haut hielt es der arme kleine Moon nicht mehr aus und floh laut heulend in die Tiefen des Dschungels. So ähnlich pflegtet ihr jedenfalls euren Kindern vorm Zubettgehen die Geschichte zu erzählen...",ep:12,g:613,l:200,wd:true,fm:true,w:1,p:10};
I.u[8384] = {n:"Magisches Moon-Fell",t:55,d:"Auch wenn es euch schwer fällt, dies zuzugeben: dieses magische Fell ist hochmagisch. Nur weil ihr nicht in der Lage seid, dies selbst heraus zu finden, bedeutet dies noch lange nicht, dass es nicht magisch sein kann. Für einmal solltet ihr auf die Stimme der Vernunft hören und es einfach so akzeptieren.",ep:12,g:722,l:200,wd:true,fm:true,w:1,p:100};
I.u[8385] = {n:"Haut der Shin-Larve",t:59,d:"Die Haut der Shin-Larve ist noch glibbriger und klebriger als ihr erwartet hättet. Fast so sehr wie die der letzten Prinzessin, die ihr vor kurzem gerettet habt.",ep:5,g:614,l:100,wd:true,fm:true,w:1,p:10};
I.u[8386] = {n:"Zahn der Shin-Larve",t:47,d:"Niemand hätte gedacht, dass die Shin-Larve Zähne im Mund hätte. Vielleicht, weil es in Wirklichkeit nur ein einziger Zahn war?",ep:5,g:654,l:100,wd:true,fm:true,w:1,p:10};
I.u[8387] = {n:"Vibrierende Feder des Königlichen Tofu",t:53,d:"Noch königlicher als der Königliche Tofu, und noch vibrierender als die Feder eines Kirbull-Vibrators aus dem Bergwerk von Kruup, ist diese Feder ideal, um ein beliebiges Ziel an einem beliebigen Ort zu kitzeln. (Hinweis: diese Feder ist selbstreinigend und benötigt keine Wartung!)",ep:3,g:645,l:200,wd:true,fm:true,w:1,p:10};
I.u[8388] = {n:"Bworkette-Haut",t:59,d:"Als Dank für eure Gnade hat die Bworkette zugestimmt, euch ein Stück ihrer Haut zu überlassen. Sie ist also nicht mit heiler Haut davon gekommen. Doch rachsüchtig, wie sie ist, hat sie ihrem großen Bruder, dem Bworker Bescheid gesagt, der euch nun sucht, um euch zu zermalmen...",ep:4,g:615,l:100,wd:true,fm:true,w:1,p:10};
I.u[8389] = {n:"Bworkette-Haar",t:54,d:"Die Bworkette hat ganz glatte Haut, außer unter den Achseln.",ep:4,g:665,l:100,wd:true,fm:true,w:1,p:10};
I.u[8390] = {n:"Farles Schweinehaut",t:59,d:"Farle war der größte Schweinezüchter des Landes. Ja, sogar der Urheber der größten Schweinereien, wie einige böse Zungen sagen, die eifersüchtig auf Shika sind. Eines jedoch ist sicher: dass Farle sehrwohl der Erschaffer der Farles Schweine ist und sie nach seinem Ebenbild geschaffen hat",ep:15,g:616,l:50,wd:true,fm:true,w:1,p:10};
I.u[8391] = {n:"O\'Rgan Spendha-Haut",t:59,d:"Trotz seines schlechten Charakters war O\'Rgan Spendha diesmal sehr großzügig. Er hat euch sogar seine letzte Haut gegeben, bevor er sich schweiniosisch grunzend aus dem Staub gemacht hat.",ep:15,g:617,l:60,wd:true,fm:true,w:1,p:10};
I.u[8392] = {n:"B\'hlut Spendha-Haut",t:59,d:"Um eine solch sanfte Haut zu erhalten, habt ihr B\'hlut Spendha womöglich mit einer Käsereibe bearbeiten müssen. Das wird er euch sicherlich nicht so schnell verzeihen. Rechnet also nicht damit, dass er euch freundlich den Weg weist, wenn ihr euch mal wieder in seinem Labyrinth verlaufen habt.",ep:15,g:618,l:60,wd:true,fm:true,w:1,p:10};
I.u[8393] = {n:"Schweinedrachen-Haar",t:54,d:"Trotz langer Suche gelingt es euch nicht, am Körper des Schweinedrachens die Stelle ausfindig zu machen, an der dieses Haar wuchs. Die Anatomie der Schweinedrachen scheint ein echtes Wunder der Natur zu sein!",ep:2,g:666,l:100,wd:true,fm:true,w:1,p:10};
I.u[8394] = {n:"Mega-Stein des legendären Mega-Krachlers",t:51,d:"Dieser gewaltige Stein ähnelt einem Mega-Krachler-Stein. Doch der Schein täuscht. Dieser Stein hier ist noch viel gewaltiger!",ep:5,g:464,l:100,wd:true,fm:true,w:1,p:10};
I.u[8396] = {n:"Mojo des WuWulfs",t:15,d:"Diese kleine Phiole enthält die gesamte Manneskraft des WuWulfs. Vorsicht: sie ist ungenießbar!",ep:1,g:752,l:1,wd:true,fm:true,w:1,p:1};
I.u[8397] = {n:"Wa Wabbit-Haar",t:54,d:"Der Wa Wabbit ist normalerweise immer sehr geizig und wenig spendabel, wenn es um seine Haut und Haare geht. Doch ausnahmsweise hat er euch einen kleinen Teil seines Körpers überlassen. Welch rührende Geste!",ep:2,g:667,l:100,wd:true,fm:true,w:1,p:10};
I.u[8398] = {n:"Wa Wabbit-Fell",t:55,d:"Niemand weiß genau, woher der Wa Wabbit dieses Fell her hat. Andererseits hat auch noch niemand genauer nachgeforscht. Daher wird wohl dieses Fell noch lange Zeit eines der größten Geheimnisse Amaknas bleiben.",ep:2,g:723,l:100,wd:true,fm:true,w:1,p:10};
I.u[8399] = {n:"Meister Pandoars Haar",t:54,d:"Ein Mal mehr wollte Meister Pandoar angeben, doch habt ihr ihm eine gute Abreibung verpasst. Er hätte besser in seiner Boxx bleiben sollen.",ep:18,g:668,l:100,wd:true,fm:true,w:1,p:10};
I.u[8400] = {n:"Meister Pandoars Fell",t:55,d:"Dieses Fell, welches mal seinen Nacken, mal sein Hinterteil bedeckte, hat den Meister Pandoar bereits mehr als einmal gerettet. Doch nicht dieses Mal.",ep:18,g:724,l:100,wd:true,fm:true,w:1,p:10};
I.u[8401] = {n:"Meister Pandoars Haut",t:59,d:"Gegerbt von Wind und Wetter der Insel Pandala und von magischen Angriffen gezeichnet, befindet sich die Haut von Meister Pandoar ist in sehr schlechtem Zustand. Dennoch hängt ihr an ihr. Womöglich, um sie als Andenken an den guten alten Meister aufzubewahren, der euch bei mehreren Gelegenheiten beinahe ohne Gnade das Leben genommen hätte?",ep:18,g:619,l:100,wd:true,fm:true,w:1,p:10};
I.u[8402] = {n:"Stein des Kuhlosses",t:51,d:"Der Kuhloss mag zwar freigiebig sein, doch hat er euch dieses große Steinherz nicht freudigen Herzens überreicht. Kein Wunder, wenn man bedenkt, was ihr wohl damit anfangen werdet.",ep:20,g:465,l:100,wd:true,fm:true,w:10,p:10};
I.u[8403] = {n:"Zopf des Kuhlosses",t:15,d:"Dieser gewaltige Zopf wurde vom Kuhloss höchstpersönlich vor vielen Jahrhunderten geknüpft. Mit der Zeit wurde er so hart wie Stein, und das, obwohl aus ihm eine Moskito anlockende, ölige Flüssigkeit hervorquillt. Man kann wirklich sagen, dass dieser Zopf dem Kuhloss vortrefflich stand und sein ganzer Stolz war! Und ihr Bösewicht, habt ihm den einfach so abgeschnitten!",ep:20,g:753,l:100,wd:true,fm:true,w:10,p:10};
I.u[8404] = {n:"Skeunk-Haut",t:59,d:"Dieses Stück Haut scheint von der Ferse des Skeunks zu stammen, was vielleicht seine gelbliche Färbung erklärt. Nun, selbst wenn ihr nicht in der Lage sein solltet, moderne Klamotten daraus zu schneidern, so habt ihr immer noch die Möglichkeit, euren Kreationen einen \"Retro\"-Look zu verleihen, der dann mit Sicherheit irgendwann aufgegriffen wird.",ep:20,g:620,l:400,wd:true,fm:true,w:1,p:100};
I.u[8405] = {n:"Skeunk-Haar",t:54,d:"Wer außer euch hätte gewusst, dass sich Skeunk bereits seit frühester Kindheit am ganzen Körper epilierte?",ep:20,g:669,l:400,wd:true,fm:true,w:10,p:100};
I.u[8406] = {n:"Minotot-Wolle",t:57,d:"Diese Wolle hat die Eigenheit, sehr fein und reißfest zu sein. So verfilzen die Haare des Minotots nicht, selbst wenn es diesem egal wäre. Vielleicht solltet ihr euch diese Wolle implantieren lassen und eine wunderschöne braune Brustbehaarung tragen? Ein Traum!",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8407] = {n:"Minotot-Leder",t:56,d:"Dieses Leder, welches nur geringfügig seltener als Fresssack-Leder ist, eignet sich hervorragend für feine Stiche, wie sie für beispielsweise für Ledermasken nötig sind.",ep:21,g:658,l:100,wd:true,fm:true,w:1,p:10};
I.u[8408] = {n:"Minotot-Huf",t:47,d:"Dieser Huf hat bereits zahlreiche Abenteurerleichen weggescharrt, aber auch so manchen Kuhfladen, der sich im Labyrinth des Minotorors verirrt hatte. Zur Verteidigung des Minotots sollte man anmerken, dass beide manchmal zum Verwechseln ähnlich aussehen.",ep:21,g:754,l:400,wd:true,fm:true,w:10,p:100};
I.u[8409] = {n:"Minotot-Horn",t:47,d:"Dieses Horn ähnelt von Weitem einem gewaltigen, hochmagischen Fresssack-Horn. Überraschenderweise erkennt man jedoch von Nahem, dass es sich doch um das Horn eines Minotots handelt.",ep:21,g:655,l:400,wd:true,fm:true,w:1,p:10};
I.u[8410] = {n:"Minotot-Schienbeinknochen",t:47,d:"Dieser große Knochen hat seit vielen Jahrhunderten das gewaltige Übergewicht des Minotots ausgehalten. Ein wahre Heldentat für einen Knochen.",ep:21,g:656,l:400,wd:true,fm:true,w:10,p:100};
I.u[8411] = {n:"Muminotoror-Amulett",t:1,d:"Dieses verfluchte Amulett, welches mit Muminotoror-Bandagen umwickelt wurde, wird es euch vielleicht sogar ermöglichen, den Fluch des Labyrinths des Minotorors abzuwehren. Andererseits könnte es sich dabei auch bloß um ein Gimmick für Touristen handeln.",ep:0,g:114,l:111,wd:false,fm:true,w:5,s:59,p:31300};
I.u[8412] = {n:"Muminotoror-Ring",t:9,d:"Dieser aus ineinandergewickelten Muminotoror-Bandagen bestehende Ring stinkt, ist häßlich und ungemütlich. Jedoch gibt er notfalls einen ausgezeichneten Verband ab, wenn ihr euch wieder einmal den Finger in einer der Türen des Labyrinths des Minotorors gequetscht habt.",ep:0,g:119,l:111,wd:false,fm:true,w:10,s:59,p:31525};
I.u[8413] = {n:"Muminotoror-Hammer",t:7,d:"Der Steinblock am Ende dieses Hammers wurde mit Muminotororbandagen umwickelt, um die Flüssigkeiten der Schläge einsteckenden Kreaturen besser aufzusaugen. Vielleicht auch nur, damit ihnen die Schläge weniger weh tun, und der Kampf länger andauert.",ep:0,g:60,l:112,wd:false,fm:true,w:10,an:15,tw:true,e:[5,4,1,1,50,50,false,false],c:"CC>100&CI>200&CW>150",s:59,p:100};
I.u[8414] = {n:"Drachei-Dolche",t:5,d:"Diese Dolche sind ideal zum Köpfen von gekochten Dracheiern. Sie sind gleichfalls sehr leicht, was praktisch werden könnte, wenn die Dracheier bemerken, dass wieder mal einer der Ihnen geköpft wurde...",ep:20,g:58,l:128,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CS>150&CI>150&CA>100",p:39854};
I.u[8415] = {n:"Muminotoror-Stiefel",t:11,d:"Diese mit Muminotoror-Bandagen gefütterten und verzierten Stiefel sind sehr warm und bequem. Dazu geben sie auch noch ein wertvolles Souvenir ab.",ep:0,g:92,l:110,wd:false,fm:true,w:10,s:59,p:31255};
I.u[8416] = {n:"Muminotoror-Umhang",t:17,d:"Dieser Umhang aus ineinander verflochtenen Muminotoror-Bandagen verleiht euch das Aussehen einer frisch einem Grabe entstiegenen Mumie. Gut genug, damit eure Feinde vor Neid erblassen.",ep:0,g:122,l:111,wd:false,fm:true,w:10,s:59,p:31780};
I.u[8417] = {n:"Kuchenschaufel",t:8,d:"Diese Schaufel wurde einst einem jungen Enutrof für das Spielen im Sandkasten geschenkt. Kurz vor seinem Tode verwendete er sie immer noch, so sehr liebte er sie.",ep:20,g:43,l:131,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,30,false,true],c:"CC>250&CA>100",p:42514};
I.u[8418] = {n:"Muminotoror-Gürtel",t:10,d:"Diese große und breite Bandage des Muminotorors besitzt einen erheblichen Mehrwert, auch wenn niemand versteht, warum. Drum werdet ihr sie leicht zu einem guten Preis verkaufen können. Außerdem wird der auf ihr liegende Fluch schnell die Schenkel des Käufers verdorren lassen, was zum Weiterverkauf einfach unglaublich praktisch ist.",ep:0,g:108,l:112,wd:false,fm:true,w:10,s:59,p:32255};
I.u[8419] = {n:"Moh-Schaufel",t:8,d:"Mit dieser Schaufel soll einst Kaptitän Machab den berüchtigten weißen Krakamor Groby Dick erschlagen haben.",ep:20,g:42,l:115,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>200",p:33653};
I.u[8420] = {n:"Drachei-Schaufel",t:8,d:"Dracheier lieben es, lange Stollen zu graben, doch nutzen sie dafür keine Schaufeln, wie findige Enutrofs eines Tages festgestellt haben. Lange hat die Enutrof-Gemeinschaft nach der Moral hinter der Geschichte gesucht, um von ihnen zu lernen. Sie kamen zu folgendem Schluss: \"Manchmal ist es unwichtig zu wissen, woher die Schaufel kommt, Hauptsache, man kann damit kräftig zuschlagen.\"",ep:20,g:45,l:127,wd:true,fm:true,w:20,an:16,tw:true,e:[10,4,1,1,40,40,false,true],c:"CC>200&CS>100",p:42154};
I.u[8421] = {n:"Tierheimzertifikat: Kleiner böser Rabling",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den kleinen bösen Rabling, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8424] = {n:"Entschädigungsgeschenk für Züchter",t:89,d:"Dieses Geschenkpaket für Züchter enthält alles, was das Züchterherz begehrt, um die Koppel mit ausgezeichneten Aufzuchtgegenständen zu füllen. Doch Vorsicht: die hier enthaltenen Gegenstände wiegen einiges! Ihr riskiert, nach dem Öffnen überladen zu sein!",ep:1,g:32,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8425] = {n:"Geldbörse mit 10.000 Kamas",t:100,d:"Diese Geldbörse ist sehr schwer. Darin muss sich ja ein wahres Vermögen befinden!",ep:1,g:56,l:1,wd:true,fm:true,w:10,u:true,p:100000};
I.u[8428] = {n:"Nebelhafter Unsichtbarkeitstrank",t:12,d:"Dieser Trank ermöglicht es, spurlos im Nebel zu verschwinden, um an der zuletzt gespeicherten Position wieder aufzutauchen.",ep:0,g:26,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,ut:true,p:1};
I.u[8430] = {n:"Gelber, magischer Ballon",t:94,d:"Im Gegensatz zu den ganzen Fälschungen, die man auf dem Jahrmarkt des Trools finden kann, ist dieser Ballon hier ideal, um mit Eleganz und Leichtigkeit durch die Lüfte davonzufliegen. Er wurde ja schließlich nach einer Rezeptur des großen Magus Ko Met auf traditionelle Weise mit echten Tofuhaaren von Hand angefertigt.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8431] = {n:"Wirbelnde Rauchbombe",t:12,d:"Diese Rauchbombe wird einen umherwirbelnden Schutzschirm aus Rauch bilden, der all eure Handlungen vor den Augen Unbefugter verbergen wird. Und zwar mit Stil!",ep:0,g:29,l:1,wd:true,fm:true,w:1,c:"(PX=3)|(PX=4)",u:true,p:1};
I.u[8435] = {n:"Roter, magischer Ballon",t:94,d:"Im Gegensatz zu den ganzen Fälschungen, die man auf dem Jahrmarkt des Trools finden kann, ist dieser Ballon hier ideal, um mit Eleganz und Leichtigkeit durch die Lüfte davonzufliegen. Er wurde schließlich nach einer Rezeptur des großen Magus Ko Met auf traditionelle Weise mit echten Erdbeergeleestückchen von Hand angefertigt.",ep:1,g:5,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8436] = {n:"Schlüssel zum Weich-Eich-Dungeon",t:84,d:"Dieser Schlüssel wird euch den Zugang zu den intimsten Bereichen der Anatomie von Weich-Eich gewähren. Selbst wenn ihr keine Ahnung habt, wo ihr hinlauft, wird euch diese Reise durch neue Welten sicherlich nicht kalt lassen.",ep:1,g:236,l:1,wd:true,fm:true,w:1,p:100};
I.u[8437] = {n:"Schlüssel zum versandeten Dungeon",t:84,d:"Dieser Schlüssel wurde aus Muschelschalen und diversem angespülten Zeug aus dem Meer hergestellt. Womöglich könnt ihr mit ihm einen Luxusstrand an der Küste des Assel-Meeres betreten, von dem es heißt, dort sei der weißeste Sand von ganz Amakna zu finden.",ep:1,g:237,l:1,wd:true,fm:true,w:1,p:100};
I.u[8438] = {n:"Schlüssel zum Rattendungeon von Brâkmar",t:84,d:"Dieser Schlüssel gewährt euch Zutritt zum Rattendungeon von Brâkmar. Dabei braucht ihr euch noch nicht einmal zu verkleiden, selbst wenn ihr nicht aus Brâkmar stammt.",ep:1,g:238,l:1,wd:true,fm:true,w:1,p:100};
I.u[8439] = {n:"Schlüssel zum Rattendungeon von Bonta",t:84,d:"Dieser Schlüssel gewährt euch Zutritt zum Rattendungeon von Bonta. Dabei braucht ihr euch noch nicht einmal zu verkleiden, selbst wenn ihr nicht aus Bonta stammt.",ep:1,g:239,l:1,wd:true,fm:true,w:1,p:100};
I.u[8441] = {n:"Heilibillyschein",t:16,d:"Bill wollte einst einen Heiligenschein haben. Er schrie so lange und so laut, dass ihm der Wunsch gewährt wurde. Ein richtiger kleiner Teufel.",ep:22,g:159,l:100,wd:true,fm:true,w:1,p:25540};
I.u[8442] = {n:"Schwarze Rattenmaske",t:16,d:"Diese Maske trug Bruce Boulgour, als er das Territorium der Kanalkratten infiltrierte, um eine alte Ulme mit den Wurzeln voran zu fällen. Jedoch war er dann schließlich doch gezwungen, sämtliche Ratten der Umgebung zu massakrieren, weil er mit seinen dicken Holzschuhen nicht allzu subtil vorgehen konnte.",ep:2,g:158,l:102,wd:true,fm:true,w:1,s:68,p:17222};
I.u[8443] = {n:"Schwarzer Rattenumhang",t:17,d:"Dieser Umhang kann aus Haaren jeder Art gefertigt werden, vorausgesetzt, sie sind dreckig. Die Haare werden ineinander verzwirnt und dann mit verschiedenen Sekreten übergossen. Der Geruch ist einfach unverwechselbar.",ep:13,g:123,l:105,wd:true,fm:true,w:5,s:68,p:18356};
I.u[8444] = {n:"Schwarze Rattendolche",t:5,d:"Mit diesen schartigen und gleichzeitig sehr scharfen Dolchen könnt ihr mühelos große Fleischstücke aus euren Feinden herausschneiden. So wissen diese gleich, was ihr von ihnen haltet. Bloß schade, dass diese Dolche nicht auch rostig, rotglühend und vergiftet sein können.",ep:8,g:59,l:108,wd:true,fm:true,w:5,an:13,tw:true,e:[10,3,1,1,30,50,false,false],c:"CA>250&CW>100&CV>300",s:68,p:19358};
I.u[8445] = {n:"Schwarzes Rattenhalsband",t:1,d:"Der frühere Rattenbesitzer dieses Halsbandes hatte geplant, Clanchef zu werden. Doch leider wurde er vorher von einem tollwütigen Lenald gefressen.",ep:18,g:115,l:103,wd:true,fm:true,w:5,s:68,p:17650};
I.u[8446] = {n:"Schwarze Rattenstiefel",t:11,d:"Warnung: besser erst die Schuhe überprüfen! Nicht selten steckt darin noch ein Rest der Füße des Vorbesitzers.",ep:13,g:93,l:101,wd:true,fm:true,w:10,s:68,p:18700};
I.u[8447] = {n:"Schwarzer Rattengürtel",t:10,d:"Im Gegensatz zu ihrem weißen Cousin aus Bonta, zieht es die schwarze Ratte vor, unauffällig zu bleiben. Darum trägt sie nur einen schmalen, schwarzen Fellgürtel. Andererseits liebt diese Ratte auch jede Form von Waffen, weshalb sie stets mit einem lärmenden Arsenal davon ausgestattet ist.",ep:13,g:109,l:101,wd:true,fm:true,w:5,s:68,p:18934};
I.u[8448] = {n:"Schwarzer Rattenring",t:9,d:"Dreht diesen Ring nach rechts, wenn ihr die Hand eines Gegners schütteln müsst. Dreht ihn nach links, wenn es die Hand eines Freundes ist. Doch in allen Fällen solltet ihr es tunlichst unterlassen, mit dem Ring am Finger zu applaudieren.",ep:20,g:120,l:98,wd:true,fm:true,w:5,s:68,p:16980};
I.u[8449] = {n:"Verwandlung des Astaknyden-Dungeons",t:27,d:"Ein Astaknyde hat euch gebissen. Ein seltsamer Fluch ereilt euch nun.",ep:9,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8450] = {n:"Weißes Rattenschwert",t:6,d:"Diese Waffe ist das Symbol der weißen Ratten. Sie steht in dem Ruf, Freund wie Feind gleichermaßen problemlos durchbohren zu können.",ep:16,g:71,l:109,wd:true,fm:true,w:10,an:14,tw:true,e:[5,5,1,1,40,50,false,false],c:"CA>150&CS>100",s:67,p:17542};
I.u[8451] = {n:"Weißer Rattenhut",t:16,d:"Mit diesem Hut ähnelt eine weiße Ratte auf ein Haar einer weißen Ratte von Bonta. Ohne diesen Hut nur einer weißen Ratte von Bonta ohne Hut.",ep:13,g:160,l:105,wd:true,fm:true,w:10,s:67,p:18451};
I.u[8452] = {n:"Weißer Rattenumhang",t:17,d:"Dieser Umhang ist das Symbol, welches eine weiße Ratte als weiße Ratte der Kanalisation von Bonta ausweist. Sie erhält sie nur nach einer langen, schwierigen und gefährlichen Prüfung, und trägt sie darum stolz bis zum Tode, in der Regel also nie sehr lange.",ep:14,g:124,l:102,wd:true,fm:true,w:5,s:67,p:17025};
I.u[8453] = {n:"Weißes Rattenhalsband",t:1,d:"Wenn ihr dieses Halsband um den Kopf tragt, so soll es euch vor den toxischen Dämpfen aus der Kanalisation beschützen können. Wird es hingegen als Gürtel getragen, so kann es eure Verbündeten vor euren eigenen toxischen Dämpfen schützen. Die Wahl sollte also leicht fallen.",ep:18,g:116,l:103,wd:true,fm:true,w:5,s:67,p:18900};
I.u[8454] = {n:"Weißer Rattenpanzerhandschuh",t:9,d:"Diesen Panzerhandschuh trug einst Mariena, die Köchin aus dem Palast von Bonta. Sie nutzte sie gerne, um widerborstige Fresssäcke damit zu erschlagen, und packte damit weglaufendes Gemüse, wenn diese aus der Salatschüssel sprangen oder Gäste, die nicht aufessen wollten. Die Handschuhe tragen also noch ihre Handschrift.",ep:18,g:121,l:101,wd:true,fm:true,w:5,s:67,p:17150};
I.u[8455] = {n:"Weißer Rattengürtel",t:10,d:"Im Gegensatz zu den Aussagen ihrer schwarzen Cousins aus Brâkmar, können weiße Ratten durchaus sehr diskret sein. Die metallischen Spangen dieses Gürtels sind darum mit Teer bestrichen und machen kein Geräusch, es sei denn der Träger stürzt unkontrolliert zu Boden. Dies passiert allerdings öfter als es scheint, da der Gürtel allein mehrere Tonnen wiegt.",ep:16,g:110,l:102,wd:true,fm:true,w:150,s:67,p:18850};
I.u[8456] = {n:"Weiße Rattenstiefel",t:11,d:"Mit diesen Stiefeln an den Füßen kann euch nichts mehr aus dem Gleichgewicht bringen. Selbst bei starken Windböen bewegt ihr euch keinen Zentimeter mehr vom Fleck.",ep:3,g:94,l:99,wd:true,fm:true,w:10,s:67,p:17650};
I.u[8457] = {n:"Zeremonienmaske des Rattenmeisters",t:16,d:"Diese Maske hat nichts, aber auch gar nichts mit dem Dora zu tun...  auch wenn es so aussieht. Also, beklagt euch nicht über einen Mangel an Kreativität seitens ihrer  Erschaffer! Seid lieber froh, dass sie hübsch anzusehen ist.",ep:13,g:173,l:133,wd:true,fm:true,w:10,s:64,p:43300};
I.u[8458] = {n:"Zeremonienumhang des Rattenmeisters",t:17,d:"Dieser farbige Umhang macht euch zu einem leichten Ziel. Darum haben nur flinke und erfahrene Abenteurer längere Zeit einen solchen Umhang tragen können.",ep:14,g:125,l:130,wd:true,fm:true,w:10,s:64,p:42030};
I.u[8459] = {n:"Zeremonienhalskette des Rattenmeisters",t:1,d:"Um Diebstähle zu verhindern, wird diese Halskette dem zukünftigen Rattenmeister bereits bei der Geburt über den Kopf gezogen. Im erwachsenen Alter gibt es somit keinen Weg mehr, ihm diese Halskette zu stehlen. Für diese hier wurde der Kopf des vergangenen Rattenmeisters abgeschlagen.",ep:18,g:117,l:134,wd:true,fm:true,w:5,s:64,p:45842};
I.u[8460] = {n:"Zeremonienring des Rattenmeisters",t:9,d:"Dieser Ring wurde einst erschaffen, als der unglückliche Zeremonienmeister von damals nur noch einen Finger besaß. Die folgenden Meister hingegen besaßen ihre Finger in voller Zahl.",ep:20,g:122,l:131,wd:true,fm:true,w:5,s:64,p:42542};
I.u[8461] = {n:"Zeremoniengürtel des Rattenmeisters",t:10,d:"Das Motiv auf diesem Gürtel erweckt den Eindruck, ihr hättet Feuer unter den von ihr bedeckten Bereichen. Die optische Täuschung ist sogar derart gelungen, dass viele Träger daran glauben und schmerzhaft japsend durch die Gegend springen. Das ist ganz im Sinne des Rituals zu welchem dieser Gürtel getragen wird.",ep:16,g:111,l:133,wd:true,fm:true,w:10,s:64,p:43358};
I.u[8462] = {n:"Zeremonienstiefel des Rattenmeisters",t:11,d:"Der erste Rattenmeister verstarb, als er aus Versehen in eine kochende Lavapfütze trat. Seitdem tragen alle Rattenmeister diese Schuhe, um ihm Respekt zu zollen. Ein kleines Wort der Warnung: die Schuhe sind nicht feuerfest!",ep:13,g:95,l:134,wd:true,fm:true,w:10,s:64,p:43541};
I.u[8463] = {n:"Ur-Astakappa",t:16,d:"Diese Kappa wurde speziell für Jizeh angefertigt, um dessen Dickkopf mit einem Dünnbretthut zu schmücken. Er ließ ihn fertigen, nachdem er den Ur-Astaknyden besiegt hatte, indem er dessen Nüsse zwischen seinen Backen zermalmte, auch wenn er sich dessen weniger rühmt.",ep:9,g:174,l:114,wd:true,fm:true,w:10,s:65,p:33150};
I.u[8464] = {n:"Ur-Astarind",t:17,d:"Der Ur-Astaknyde liebt Sonnenbäder im Sommer. Da ist es bloß dumm, dass sein an düsteres Waldklima gewohntes Holz dies nicht gut verträgt. Aus den abgefallenen Rindenstücken wurde dieser Umhang gefertigt.",ep:18,g:126,l:114,wd:true,fm:true,w:5,s:65,p:33524};
I.u[8465] = {n:"Ur-Torque",t:1,d:"Um den Hals getragen, bringt diese Torque euren Bart so richtig zur Geltung. Wenn ihr jetzt noch keinen Bart besitzen solltet, so habt ihr Pech gehabt.",ep:20,g:118,l:110,wd:true,fm:true,w:10,s:65,p:31542};
I.u[8466] = {n:"Ur-Ring",t:9,d:"Spät abends, nach viel Alkoholgenuss, mag es scheinen, als würde euch der kleine im Stein eingefangene Moskito lüstern zuzwinkern. Doch solltet ihr das besser nicht euren Freunden erzählen. Er tut nämlich nur so.",ep:9,g:123,l:113,wd:true,fm:true,w:5,s:65,p:33241};
I.u[8467] = {n:"Ur-Schienbeinschoner",t:11,d:"Mit diesen Schienbeinschonern aus Massivgold brauchen eure Beine keine Waffe mehr zu fürchten. Allerdings sind sie nicht kompatibel zu Stiefeln. Ihr mögt sie zwar tragen, um euch bei einem Fressballspiel zu schützen, doch könnt ihr dann leider keine unauffälligen Tritte mit euren spitzen Stiefeln austeilen.",ep:20,g:96,l:110,wd:false,fm:true,w:10,s:65,p:31524};
I.u[8468] = {n:"Ur-Astaschurz",t:10,d:"Diesem Gürtel wird nachgesagt, er würde seinem Träger die Ur-Kraft verleihen. Doch scheint die Wirkung abgelaufen zu sein.",ep:9,g:112,l:111,wd:true,fm:true,w:10,s:65,p:32101};
I.u[8469] = {n:"Weich-Eich-Talisman",t:1,d:"Dieses Holzstück stammt direkt aus Weich-Eichs Herzen. Darum steckt in ihm gewaltige Macht, beispielsweise die, Weich-Eich in unheimliche Wut zu versetzen.",ep:20,g:119,l:138,wd:true,fm:true,w:10,s:66,p:44521};
I.u[8470] = {n:"Weich-Eich-Ring",t:9,d:"Dieser Ring ist nichts anderes als ein Ausscheidungsprodukt Weich-Eichs. Es besteht zwar aus Holz, doch sein Geruch ist genauso.",ep:9,g:124,l:139,wd:true,fm:true,w:5,s:66,p:43014};
I.u[8471] = {n:"Weich-Eich-Sonntagsschlappen",t:11,d:"Am Sonntag pflegt Weich-Eich immer ein Mittagsschläfchen zu halten. Wenn er dann aufwacht, liebt er es, einen jungen Trunknyden an seiner Seite zu sehen, der ihm seine Sonntagsschlappen bringt, ohne dass er etwas sagen muss. Da er dummerweise keine Füße hat, sind die Schlappen noch ganz neu.",ep:20,g:97,l:136,wd:true,fm:true,w:5,s:66,p:43521};
I.u[8472] = {n:"Abgenutzter Weich-Eich-Umhang",t:17,d:"Vor mehr als 200 Jahren verfing sich ein gewöhnliches Stück Tuch in einem der Äste Weich-Eichs. Die neuen Triebe, welche einfach drumherum und durch es hindurch wuchsen, bedachten es mit ihrer Magie. Nun formt das Stück Stoff eine Einheit mit den Ästen des Baumes, was es unpraktisch und leicht entflammbar, jedoch auch unglaublich mächtig werden ließ.",ep:18,g:127,l:142,wd:true,fm:true,w:10,s:66,p:44578};
I.u[8473] = {n:"Weich-Eich-Herbststring",t:10,d:"Im Herbst legt Weich-Eich gewöhnlich diesen String an, um seine wertvollen Eicheln zu bedecken. Im Sommer hingegen hängen diese frei.",ep:9,g:113,l:141,wd:true,fm:true,w:10,s:66,p:44514};
I.u[8474] = {n:"Weich-Eich-Hut",t:16,d:"Egal, wie herum ihr diesen Hut aufgesetzt habt, man wird den Eindruck nicht los, er säße nicht gerade.",ep:9,g:166,l:145,wd:true,fm:true,w:10,s:66,p:45241};
I.u[8476] = {n:"Erster Schlüssel zum Sphincter-Dungeon",t:24,d:"Dieser Schlüssel allein wird noch nicht ausreichen, um die Tür zum Sphincter-Dungeon zu öffnen. Ihr braucht noch den anderen dazu.",ep:1,g:502,l:1,wd:false,fm:true,w:0,p:100};
I.u[8477] = {n:"Zweiter Schlüssel zum Sphincter-Dungeon",t:24,d:"Dieser Schlüssel allein wird noch nicht ausreichen, um die Tür zum Sphincter-Dungeon zu öffnen. Ihr braucht noch den anderen dazu.",ep:1,g:503,l:1,wd:false,fm:true,w:0,p:100};
I.u[8478] = {n:"Stiefelleckertrank",t:12,d:"Dieser illegale und von Groß und Klein gefürchtete Trank zwingt alle, die davon auch nur einen einzigen Schluck trinken dazu, die Stiefel ihres Nächsten zu lecken. Es heißt sogar, es soll noch eine andere Version dieses Trankes geben, doch führte diese zu einem noch schlimmeren Mundgeruch und ist daher nicht mehr zu finden.",ep:0,g:36,l:1,wd:false,fm:true,w:0,p:10};
I.u[8480] = {n:"Stiefelleckertrank",t:24,d:"Dieser illegale und von Groß und Klein gefürchtete Trank zwingt alle, die davon auch nur einen einzigen Schluck trinken dazu, die Stiefel ihres Nächsten zu lecken. Es heißt sogar, es soll noch eine andere Version dieses Trankes geben, doch führte diese zu einem noch schlimmeren Mundgeruch und ist daher nicht mehr zu finden.",ep:2,g:32,l:1,wd:true,fm:true,w:0,p:10};
I.u[8481] = {n:"Kanalkrattenhaar",t:54,d:"Diese Haare sind dreckig und übelriechend. Kein Wunder, sie haben ja auch viele Jahre am unsaubersten Ort der Gegend verbracht. Dennoch glänzen sie noch.",ep:2,g:670,l:42,wd:true,fm:true,w:1,p:10};
I.u[8482] = {n:"Kanalkrattenhaut",t:59,d:"Diese Haut ist von einer Vielzahl Schrammen und Striemen übersät. Ein Zeichen der schlimmen Kindheit, die diese Kanalkratte verbringen musste. Hättet ihr nicht ein wenig Erbarmen ihr gegenüber zeigen können?",ep:2,g:621,l:42,wd:true,fm:true,w:1,p:10};
I.u[8483] = {n:"Tschamanen-Kanalkrattenhaut",t:59,d:"Wenn diese Haut erst einmal geschrubbt wurde, kann sie als Bettvorleger oder Fußabtreter dienen. Praktisch, nicht?",ep:2,g:622,l:40,wd:true,fm:true,w:1,p:10};
I.u[8484] = {n:"Tschamanen-Kanalkrattenhaar",t:54,d:"Dieses Haar, welches früher für falsche Schnurrbärte genutzt wurde, eignet sich hervorragend als Ersatz für Achselhaare.",ep:2,g:671,l:40,wd:true,fm:true,w:1,p:10};
I.u[8485] = {n:"Schwarzes Rattenfell",t:55,d:"Wenn es um einen Holzstiel gewickelt wird, kann euch dieses Rattenfell gute Dienste als Wischmob leisten, oder aber auch, um euch am verlängerten Rücken zu kratzen. Es ist also für jeden Geschmack etwas dabei",ep:2,g:725,l:100,wd:true,fm:true,w:1,p:10};
I.u[8486] = {n:"Weißes Rattenfell",t:55,d:"Dieses Fell ist mindestens so fettig wie ein in Blobfett getunktes Wabbithaar. Es wird euch hervorragend vor Kälte schützen, insbesondere, wenn es in Flammen steht.",ep:2,g:726,l:100,wd:true,fm:true,w:1,p:10};
I.u[8487] = {n:"Sphincter Cells Fell",t:55,d:"Dieses Fell scheint mit einer seltsamen, chemischen Substanz bedeckt zu sein. Aufgrund potentiell gefährlicher Nebenwirkungen derselben sollte man das Fell nicht zu lange in den Händen halten. Wer weiß, was sonst so alles geschehen kann.",ep:2,g:727,l:200,wd:true,fm:true,w:10,p:100};
I.u[8488] = {n:"Ellenbogenbein der schwarzen Ratte",t:47,d:"Dieser Rattenknochen kann geleert, durchbohrt und zurechtgeschnitzt werden. Ideal für alle, die Freude an einem Musikinstrument oder einem Blasrohr haben.",ep:2,g:658,l:100,wd:true,fm:true,w:10,p:10};
I.u[8489] = {n:"Weißer Rattenzahn",t:47,d:"In Wirklichkeit handelt es sich bei diesem Gegenstand um einen bösartigen, hohlen Fangzahn, durch welchen die weiße Ratte eine Vielzahl von Krankheitskeimen direkt in die Blutbahn des Opfers einspritzte. Eine gute Methode, um selbst Gegner umzubringen, die ihr entkommen konnten. Dieser Ratte sind definitiv alle Mittel Recht, um von ihren Untergebenen gefürchtet zu werden.",ep:2,g:659,l:100,wd:true,fm:true,w:10,p:10};
I.u[8490] = {n:"Sphincter Cells Schienbeinknochen",t:47,d:"Sphincter verstand keinen Spaß, was Knochen anging. Er pflegte allen Witzbolden die Knochen entzwei, entdrei, entviert oder gar entfünft zu brechen.",ep:2,g:657,l:200,wd:true,fm:true,w:10,p:10};
I.u[8491] = {n:"Schwarze Rattenhaut",t:59,d:"Die schwarze Ratte war aufgrund ihres schlimmen Mundgeruches sehr gefürchtet, wie auch für die raue Haut ihres Hinterns. Letztere mag ja sehr praktisch sein, um auf der Klo-Schüssel nicht auszurutschen. Doch leider pflegte die schwarze Ratte niemals Toiletten zu benutzen, da sie ja in der Kanalisation lebte.",ep:2,g:623,l:100,wd:true,fm:true,w:1,p:10};
I.u[8492] = {n:"Weiße Rattenhaut",t:59,d:"Die weiße Ratte empfand ein perverses Vergnügen dabei, laut in der Kanalisation herumzustöhnen, bis ihr jemand zu Hilfe eilte. Anschließend nutzte sie die Naivität und Dummheit ihrer Opfer aus, um ihnen bei lebendigem Leib die Haut von den Knochen zu schälen und die fleischlichen Überrestes des Opfers zu kochen.",ep:2,g:624,l:100,wd:true,fm:true,w:1,p:10};
I.u[8493] = {n:"Sphincter Cells Haut",t:59,d:"Wer hätte gedacht, dass ihr eines Tages einmal die Haut des berüchtigten Sphincters in den Händen halten würdet? Mit Sicherheit jedenfalls nicht Sphincter selbst. Seine Selbstüberschätzung hat ihn zu Fall gebracht.",ep:2,g:625,l:200,wd:true,fm:true,w:10,p:100};
I.u[8494] = {n:"Ur-Astaknydenrinde",t:96,d:"Diese Rinde ließ sich leicht vom Ur-Astaknyden ablösen. Ihr brauchtet also noch nicht einmal die Zähne zu Hilfe zu nehmen.",ep:9,g:667,l:200,wd:true,fm:true,w:10,p:10};
I.u[8495] = {n:"Ur-Astaknydenknospe",t:108,d:"Diese getrocknete Knospe wurde einst von einer ausgehungerten Kreatur leergetrunken. Wenn ihr sie in Wasser taucht, wird sie wieder ihre ursprüngliche Form annehmen und sich aufblähen, um dann schnell zu verfaulen.",ep:9,g:755,l:200,wd:true,fm:true,w:1,p:10};
I.u[8496] = {n:"Ur-Astaknydenwurzel",t:98,d:"Sogar jetzt noch, wo sie ihrem ursprünglichen Besitzer brutalst herausgerissen wurde, vermag es diese Wurzel, euch den Hintern zu versohlen und euch zu Fall zu bringen. Oh wie nachtragend!",ep:9,g:668,l:200,wd:true,fm:true,w:1,p:10};
I.u[8497] = {n:"Das große Buch des Filtounga-Rezepts",t:24,d:"Dieses Buch enthält alle Geheimnisse rund um das Filtounga-Rezept, das mythenhafte Hauptgericht von Mouss Bouff.",ep:16,g:95,l:1,wd:true,fm:true,w:0,u:true,p:10};
I.u[8498] = {n:"Kanigrou-Fleisch",t:63,d:"Dieses Fleisch ist mindestens so zart wie ein Boo-Schädel.",ep:13,g:375,l:80,wd:true,fm:true,w:1,p:1};
I.u[8499] = {n:"Koalak-Fleisch",t:63,d:"Koalak-Fleisch ist in der Regel recht zäh. Doch lässt es sich leicht weich klopfen, zum Beispiel, indem man einen Stock aus Kalyptus-Holz zu Hilfe nimmt. So etwas soll auch bekanntlich bei unartigen Kindern helfen.",ep:20,g:376,l:60,wd:true,fm:true,w:1,p:1};
I.u[8500] = {n:"Crocodyll-Fleisch",t:63,d:"Dieses fade Fleisch hat viele Jahre lang im Schlamm gelegen, bevor es begann, zu verfaulen und Geschmack zu entwickeln.",ep:4,g:377,l:70,wd:true,fm:true,w:1,p:1};
I.u[8501] = {n:"Konserviertes Kanigrou-Fleisch",t:64,d:"Dieses Fleischstück kann mehrere Tage lang aufbewahrt werden, bevor man es zu einem leckeren Gericht zubereitet.",ep:13,g:387,l:80,wd:true,fm:true,w:1,p:10};
I.u[8502] = {n:"Konserviertes Koalak-Fleisch",t:64,d:"Dieses Fleischstück kann mehrere Tage lang aufbewahrt werden, bevor man es zu einem leckeren Gericht zubereitet.",ep:20,g:388,l:120,wd:true,fm:true,w:1,p:10};
I.u[8503] = {n:"Konserviertes Crocodyll-Fleisch",t:64,d:"Dieses Fleischstück kann mehrere Tage lang aufbewahrt werden, bevor man es zu einem leckeren Gericht zubereitet.",ep:4,g:389,l:70,wd:true,fm:true,w:1,p:10};
I.u[8504] = {n:"Kanigrou-Rippchen",t:69,d:"Egal ob warm oder kalt gegessen, diese Rippchen sind einfach köstlich und sehr sättigend.",ep:13,g:132,l:80,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8505] = {n:"Koalak-Filet",t:69,d:"Dieses Fleischstück kann selbst bodenlose Mägen füllen.",ep:20,g:133,l:120,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8506] = {n:"Crocodyll-Rippchen",t:69,d:"Dieses große, rohe Stück Fleisch ist ohne Zweifel sehr schwer verdaulich. Aber die Gier gewinnt immer die Überhand beim Ringen mit dem Verstand...",ep:4,g:134,l:70,wd:false,fm:true,w:1,u:true,ut:true,p:10};
I.u[8507] = {n:"Filtounga-Hauptgericht",t:69,d:"Filtounga ist ein einzigartiges Hauptgericht. Dank der Zutaten ist der Geschmack... unverwechselbar. Lauwarm servieren!",ep:1,g:136,l:100,wd:true,fm:true,w:1,c:"Cv<100",u:true,ut:true,p:1};
I.u[8508] = {n:"Die Hauptspeise: Filtounga",t:24,d:"Diese leckere Mahlzeit ist für die Hexe Bel Nechuk bestimmt.",ep:1,g:120,l:1,wd:true,fm:true,w:0,p:1};
I.u[8509] = {n:"Die Rezeptur des Bwork-Bieres",t:25,d:"Der große Magus BworknRoll enthüllt hierin das heilige Rezept des Bwork-Bieres. Nicht ein Geheimnis lässt er darin aus! Er geht sogar so weit zu beschreiben, auf welche Weise man es am Besten genießt. Das wird das Verhalten so mancher Biertrinker revolutionieren!",ep:1,g:130,l:10,wd:false,fm:true,w:5,u:true,p:500};
I.u[8511] = {n:"Übermächtige Armbrust der Dunkelheit",t:102,d:"...",ep:0,g:0,l:1,wd:false,fm:true,w:0,an:10,tw:true,e:[20,7,4,12,50,30,true,true],p:1};
I.u[8513] = {n:"BworknRolls Skalpell",t:5,d:"Das Skalpell des BworknRolls ist ideal, um bestimmte \"Teile\" einer Kreatur zu \"ernten\", denn es garantiert die Unversehrtheit der abgeschnittenen Körperteile. Es sollte stets am Ende eines Kampfes eingesetzt werden.",ep:1,g:60,l:40,wd:true,fm:true,w:10,an:13,e:[10,4,1,1,30,50,false,false],c:"Qa=166",p:100};
I.u[8514] = {n:"Vampirhirn",t:15,d:"Dieses mit weißen Blutkörperchen überflutete Hirn saugt ständig alle verfügbaren roten Blutkörperchen auf. Daher haben Vampire auch ihren blassen Teint. Bei Iops ist es genau umgekehrt. Da all ihr Blut in die Füße fließt, können sie zwar hervorragend durch die Gegend springen, aber dafür nicht denken.",ep:3,g:492,l:20,wd:true,fm:true,w:2,u:true,p:10};
I.u[8515] = {n:"Trool-Knochen",t:47,d:"Wenn man erst einmal das Gewicht und die Stabilität eines Trool-Knochens mit eigenen Augen gesehen hat, wird man sicherlich besser einschätzen könnten, warum Troolschläge so weh tun.",ep:4,g:640,l:5,wd:true,fm:true,w:50,p:50};
I.u[8516] = {n:"Bworkettes Herz",t:15,d:"Die herzlose Bworkette warf einst ihren Sohn Krazybwork in genau den Abgrund, welcher von BworknRoll verflucht ward, nachdem sie ihm ihre Liebe versagt hatte. Die Bworkette lebt nun einsam in einer Höhle vor sich hin und frisst jeden Tag ihr eigenes Herz auf, welches dann über Nacht wieder nachwächst.",ep:4,g:518,l:33,wd:true,fm:true,w:33,p:33};
I.u[8517] = {n:"Miese Muschel",t:15,d:"Diese miese kleine Muschel ist sehr nützlich für einsame Bworks, wenn sie fernab von ihren Kameraden auf Jagd ausziehen.",ep:3,g:756,l:1,wd:true,fm:true,w:3,p:21};
I.u[8518] = {n:"Miese Muscheln mit Fritten",t:69,d:"In den Tiefen des Assel-Meeres leben die miesen Muscheln. Tagelang pflücken sie Plankton, welches sie in ihrem Muschelkörper reifen lassen, bis es eine Frittenform angenommen hat. Dann lassen sie sich auf den Strand treiben, spucken ihre Fritte aus und brutzeln sie und sich unter der Sonne goldbraun.",ep:3,g:135,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:30};
I.u[8519] = {n:"Troolrolle",t:69,d:"Diese traditionsreiche, mit Troolköttelchen gefüllte Kuchenrolle wurde nach einem alten Bworkrezept gebacken. Nur ein Bwork, der mit bloßen Händen einen Trool besiegt hat, darf davon essen.",ep:1,g:136,l:5,wd:true,fm:true,w:20,u:true,p:200};
I.u[8520] = {n:"Glibbroll",t:60,d:"Dank dieser dicken, glibberigen Fettschicht kann man selbst in uralten Kesseln leckere Gerichte kochen, ohne dass diese anbrieten. Gewisse Osamodas-Anhänger nutzen sie manchmal auch, um Tofus an Orte zu bringen, welche die strikte Moral eines Iops gehörig ablehnen würde.",ep:1,g:1,l:1,wd:true,fm:true,w:10,p:10};
I.u[8521] = {n:"Rotcapechen",t:17,d:"Das Rotcapechen ist das Lieblingsartefakt von Möchtegernhelden. Wenn sie es erst einmal angelegt haben, halten sie sich für die Inkarnation von Supermann oder einen übermächtigen Magus. Jedenfalls so lange, bis sie einem Minotoror über den Weg laufen...",ep:1,g:128,l:9,wd:false,fm:true,w:1,p:200};
I.u[8522] = {n:"Magische Zauberschleuder",t:74,d:"Dieses seltsame Ding enthält eine schier unerschöpfliche Quelle magischer Energie, die leider auch sehr instabil ist. Niemand kann sagen, wann die Quelle wieder versiegt, doch ist es in jedem Fall dringend angeraten, sie schnell zu verwenden.",ep:1,g:31,l:1,wd:false,fm:true,w:0,ut:true,p:1};
I.u[8523] = {n:"Artefakt der Ounchkins",t:24,d:"Diesem heiligen Familienartefakt entströmt ein gewaltiger Fluss der Macht. Obwohl es von Generation zu Generation innerhalb der Familie weitergegeben wurde, hat es im Laufe der Zeit nichts von seiner Magie eingebüßt. Vielleicht stand es ja sogar irgendwann im Kontakt mit einem Dofus... Wer weiß?",ep:1,g:714,l:200,wd:true,fm:true,w:0,p:1};
I.u[8524] = {n:"Ping Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:45,l:1,wd:true,fm:true,w:1,p:1};
I.u[8525] = {n:"Piepmatz-Ei",t:69,d:"Piepmatz-Eier sind ein echtes Festessen für Leckermäuler. Allerdings schlüpfen die Mätze recht schnell, wenn sie in der Nähe einer Wärmequelle sind. Darum solltet ihr es vermeiden, diese Eier längere Zeit in der Hosentasche oder im Mund zu lassen, wenn ihr nicht einen ausgehungerten Minipiepmatz in der Hand haben wollt, der euch für seine Mami hält.",ep:4,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[8526] = {n:"Tierheimzertifikat: Blutrünstiger Koalak",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Blutrünstigen Koalak, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8527] = {n:"Gobtreter",t:11,d:"Diese Stiefel aus Goblinhaut wurden von Planbworksek hergestellt, um Sturmangriffe (bevorzugt im ungeschützten Rücken der Gegner) zu erleichtern. Diese Schuhe haben außerdem bereits schon mehr als nur einen Bwork aus einer Notlage gerettet.",ep:4,g:98,l:14,wd:true,fm:true,w:20,p:400};
I.u[8528] = {n:"Das Crêpes-Rezept",t:25,d:"Dank Pol Bokuz wird euch endlich der Crêpe-Teig gelingen, der eure Enkelkinder ernährt und erfreut. Das Geheimnis bei diesem hervorragenden und schlaffördernden Rezept: Wunderpulver natürlich!",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:0};
I.u[8529] = {n:"Zaap-Hammer",t:24,d:"Nichts geht über einen guten Hammer, um einen durcheinander geratenen Zaap zu reparieren!",ep:1,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[8530] = {n:"Sibirischer Filz",t:16,d:"Achtung! Dieser Filzhut ist ein teures Importprodukt! Er hält eure Ohren gut warm und absorbiert euren alkoholgeschwängerten Atem. Was will man mehr?",ep:22,g:167,l:151,wd:true,fm:true,w:10,p:46280};
I.u[8531] = {n:"Hasimir-Helm",t:16,d:"Wer außer euch würde es wagen, einen derart lächerlichen Hut zu tragen? Niemand!",ep:1,g:168,l:33,wd:true,fm:true,w:6,p:3000};
I.u[8532] = {n:"Hasimir-Umhang",t:17,d:"Mit diesem Umhang über den Schultern werdet ihr allen aufgeblasenen Laffen mal so richtig eure kalte Schulter zeigen können.",ep:1,g:129,l:14,wd:true,fm:true,w:1,p:775};
I.u[8533] = {n:"Flud",t:16,d:"Flud ist nicht wirklich ein Hut, sondern vielmehr eine Art Parasit, der am Kopf von überkommunikativen, überlauten oder aggressiven Abenteurern wächst. Das abstoßende Äußere des Parasiten treibt alle anderen Personen in die Flucht, was fatalerweise den Träger desselben meist dazu bringt, noch lauter und eindringlicher zu schreien, um sich Gehör zu verschaffen.",ep:1,g:169,l:1,wd:true,fm:true,w:1,s:69,p:100};
I.u[8534] = {n:"Cape S\'lokk",t:17,d:"Dieser flauschige Umhang absorbiert alle Geräusche der Umgebung und zwingt den Träger dazu, ständig zu brüllen.",ep:1,g:130,l:1,wd:true,fm:true,w:10,s:69,p:100};
I.u[8535] = {n:"Ainmischa",t:11,d:"Diese Getas sind leicht. Sogar so leicht, dass sie ihren Träger dazu zwingen durch die Gegend zu rennen und überall hin zu hüpfen, wenn ein Kampf beginnt. Erfahrene Abenteurer hassen dieses Schuhwerk, da es jedem dahergelaufenen Jungspunt eine Zeitlang ermöglichte, uneingeladen an ihren Kämpfen teilzunehmen.",ep:1,g:99,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8536] = {n:"Spammettchen",t:10,d:"Dieser Gürtel trägt sich so eng, dass der Träger oftmals anfängt zu stottern, zu zittern und Dummheiten zu machen.",ep:1,g:114,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8537] = {n:"Plusains",t:9,d:"Dieser kleine Ring hat keinerlei Funktion, außer die Aufmerksamkeit anderer auf die Tatsache zu lenken, dass ihr existiert.",ep:1,g:125,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8538] = {n:"Äs Ähm Ässe",t:1,d:"Nach mehreren Tagen und Nächten harter Arbeit, ist es dem besten Juwelier von Astrub endlich gelungen, sein Werk fertigzustellen. In frühester Kindheit von Bworks enführt,  hatte er einen schweren Sprachfehler davongetragen. Kein Wunder, dass ihn niemand verstand, als er mitten auf dem Marktplatz proklamierte: \"M1 Rign is goil! Vk:bilisch\"",ep:1,g:120,l:1,wd:true,fm:true,w:1,s:69,p:1};
I.u[8539] = {n:"Axt des Holzfällerlehrlings",t:19,d:"Auch wenn ihr im Umgang mit einer Axt nicht geschult seid, werdet ihr nicht in Gefahr kommen, euch mit diesem Exemplar zu schneiden, da die Klinge völlig stumpf ist. Aber wenn ihr fest und lang genug damit zuschlagt, wird es euch sicherlich doch noch gelingen, Bäume damit zu fällen.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,40,40,false,false],p:0};
I.u[8540] = {n:"Sense des Bauernlehrlings",t:22,d:"Diese Sense ist nicht gerade die Top-Qualität, aber einer geschenkten Sense schaut man auch nicht auf die Klinge. Zum Mähen von ein wenig Weizen wird sie ausreichen und viel mehr ist ja auch gar nicht nötig.",ep:1,g:1,l:1,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,50,50,false,false],p:1};
I.u[8541] = {n:"Angel des Fischerlehrlings",t:20,d:"Naja, diese Angel hat schon bereits bessere Zeiten hinter sich. Die Schnur ist teilweise eingerissen und der Köder löst sich manchmal ab. Also ist sie ideal für Gründlinge.",ep:1,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,1,100,100,false,false],p:1};
I.u[8542] = {n:"Handschuhe des Alchimistenlehrlings",t:20,d:"Diese Handschuhe sind wirklich nicht gerade die Top-Qualität. Sie besitzen kaum Löcher und der Schweißgeruch des Vorbesitzers ist nur mit Mühe und Not auszumachen. Zudem sind die Finger zu kurz, die Handhabung unbequem. Also kein Zweifel, die Handschuhe hier taugen nicht zu viel, außer vielleicht zum Rupfen mancher Kräuter.",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:1};
I.u[8543] = {n:"Incarnam-Limonade",t:79,d:"Diese göttliche Limonade ist eine Mischung aus Wasser, Blubberblasen und Tier-Extrakten. Es belebt die jungen Seelen, die frisch in Incarnam beginnen. Für andere hingegen ist es nur gut genug, um Rülpswettbewerbe durchzuführen.",ep:1,g:4,l:1,wd:true,fm:true,w:1,c:"PL<16",u:true,ut:true,p:1};
I.u[8544] = {n:"Tierheimzertifikat: Ping",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den kleinen Ping, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8545] = {n:"Schlüssel des Incarnam-Dungeons",t:84,d:"Dieser Schlüssel wird euch Zutritt zum Dungeon von Incarnam gewähren, in welchem der fürchterliche WullyWuStruppi hausen soll.",ep:1,g:19,l:1,wd:true,fm:true,w:1,p:10};
I.u[8546] = {n:"WullyWuWulf-Haut",t:59,d:"Kleine Löckchen verleihen dieser glatten Haut ihr wunderschönes Aussehen. Nun, sicherlich ist sie ein begehrtes Tauschobjekt. Für irgendjemanden jedenfalls. Möglicherweise auf Incarnam. Vielleicht. Bloß wer...?",ep:1,g:3,l:1,wd:true,fm:true,w:10,p:1};
I.u[8547] = {n:"ixigihik trinsfirmikzik",t:31,d:"vixflirtik hixiknik mimipfmik nik gitik sik",ep:1,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8548] = {n:"Wabbit-Vewwandlung",t:31,d:"Vewfluchte Kawotten sind schlecht füw die Gesundheit.",ep:8,g:19,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[8557] = {n:"Batofu-Feder",t:53,d:"Diese Feder stinkt, aber ist hochmagisch. Warum muss nur alles Hochmagische so übel riechen?",ep:3,g:120,l:20,wd:true,fm:true,w:1,p:10};
I.u[8558] = {n:"Hasimir-Hut",t:16,d:"Wenn ihr einen netten Plausch mit Wabbits halten wollt, dann kommt dieser Helm genau richtig. Wenn ihr hingegen jemanden bezirzen möchtet, solltet ihr diesen Hut lieber euren Konkurrenten überstülpen...",ep:1,g:170,l:6,wd:true,fm:true,w:10,p:12000};
I.u[8559] = {n:"HmmMmmMmmm",t:16,d:"Hmmmmm mm mmmmmm mmmmm, mmm mmm mm mmmmmm mmmmm mmmmmmm mmmmmm mmm mmmm\'m mmmmm mmmm mmmmmmm.",ep:2,g:171,l:42,wd:true,fm:true,w:1,p:420};
I.u[8561] = {n:"Pandawa-Baby",t:18,d:"Dieses liebliche Pandawa-Baby wird euch überall hin folgen, um die Welt mit seinen großen, runden Kulleraugen zu entdecken und zu erforschen. Dieser zahme Zeitgenosse frisst nur Reis.",ep:3,g:42,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8563] = {n:"Juppi Gobsassa",t:32,d:"Juppi muss zu seinem Magie-Lehrer.",ep:1,g:18,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[8564] = {n:"Tierheimzertifikat: Pandawa-Baby",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über das Pandawa-Baby, das ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8565] = {n:"Pandawa Baby Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[8566] = {n:"Ping-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8567] = {n:"Pandawa-Baby-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:20,g:3,l:1,wd:false,fm:true,w:1,m:true,p:1};
I.u[8568] = {n:"Pandawa-Baby-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für die Aufzucht, Futter, und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8569] = {n:"Doro l\'Blak",t:16,d:"Dieser Hut gehört einst einer kleinen Xelorina, die ein diebisches Vergnügen dabei empfand, den Lauf der Zeit zu ändern. Der Legende nach gelang es ihr sogar, den Einwohnern Amaknas mehrere Tage zu stehlen. Um nicht den Zorn der Amaknianer auf sich zu ziehen, verteilte sie daraufhin freigiebig eine große Menge Süßigkeiten.",ep:22,g:172,l:129,wd:true,fm:true,w:10,p:42512};
I.u[8570] = {n:"Haar einer Bonta-Ratte",t:54,d:"Dieses Haar gehörte einer Kanalkratte von Bonta. Was leicht nachgewiesen kann, denn nur diese Ratten haben Haare, die zur Farbe ihrer Stadtmauer passen.",ep:2,g:672,l:40,wd:true,fm:true,w:1,p:10};
I.u[8571] = {n:"Haar einer Brâk-Ratte",t:54,d:"Dieses Haar gehörte einer Kanalkratte von Brâkmar. Was leicht nachgewiesen kann, denn nur diese Ratten haben Haare, die zur Farbe ihrer Stadtmauer passen.",ep:2,g:673,l:40,wd:true,fm:true,w:1,p:10};
I.u[8572] = {n:"Trank des Vergessens: \"Reittiere zähmen\"",t:43,d:"Dieser Trank lässt euch einen Grad des Zauberspruches \"Reittiere zähmen\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8573] = {n:"Trank des Vergessens: \"Bösartiger Boomerang\"",t:43,d:"Dieser Trank lässt euch einen Grad des Zauberspruches \"Bösartiger Boomerang\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[8574] = {n:"Vinegrett-Dofus",t:23,d:"Mit oder ohne Speck: der Vinegrette-Dofus schmückt jeden Teller.",ep:0,g:13,l:1,wd:false,fm:true,w:1,p:1};
I.u[8575] = {n:"Ramboton",t:4,d:"Ein berühmter Feca-Krieger, der sich allein durch den ganzen Dschungel von Pandala hindurchgekämpft hatte, pflegte zu sagen: \"Willst du den Krieg gewinnen, so musst du zum Krieg werden!\"",ep:1,g:71,l:200,wd:false,fm:true,w:20,an:12,tw:true,e:[7,3,1,2,42,42,false,true],c:"PN~xxramboplxx",p:100000};
I.u[8576] = {n:"Empfehlungsschreiben von Yse Vewybad",t:24,d:"Dieses Empfehlungsschreiben habt ihr von Yse Vewybad für eure geleisteten Dienste erhalten.",ep:2,g:26,l:20,wd:false,fm:true,w:0,p:1};
I.u[8588] = {n:"Halsabschneider-Abzeichen",t:24,d:"Dieses Abzeichen, das ihr von einem Halsabschneider bekommen habt, ist vielleicht der Schlüssel zu deren Unterschlupf.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[8590] = {n:"Vertrag zwischen Vil Smiss und Yse Vewybad",t:24,d:"Dieser Vertrag beweist den Verrat von Yse Vewybad. Nun müsst ihr ihn nur noch zu einer dafür verantwortlichen Person bringen.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[8593] = {n:"Wabbit-Vewwandlungstwank",t:27,d:"Dieser Trank wurde euch von Salg Zengaer übergeben. Er wird es euch erlauben, euch in einen Wabbit zu verwandeln, um euch als Werber für Allisteria auszugeben.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8594] = {n:"Wabbit-Vewwandlungstwank",t:27,d:"Dieser Trank wurde euch von Salg Zengaer übergeben. Er wird es euch erlauben, euch in einen Wabbit zu verwandeln, um euch als Werber für Allisteria auszugeben.",ep:2,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8595] = {n:"Fettes Tofu-Ei",t:24,d:"Dieses Ei enthält einen fetten Tofu. Vielleicht einen zukünftigen Besieger des Wa-Pwinzes?",ep:1,g:122,l:1,wd:true,fm:false,w:0,p:1};
I.u[8596] = {n:"Purpur-Klaue",t:6,d:"Die Purpur-Klaue verdankt ihren Namen dem Bwork-Blut, in das sie über viele Jahrzehnte hinweg freiwillig oder unfreiwillig getaucht wurde. Vorher war sie schlicht und einfach nur violett.",ep:22,g:72,l:145,wd:true,fm:true,w:15,an:14,tw:true,e:[8,6,1,1,45,100,false,false],c:"CS>350&CV>400",p:52000};
I.u[8597] = {n:"Stopf-Trank",t:24,d:"Mit Hilfe dieses Trankes wird Vil Smiss den fetten Tofu mästen, den ihr ihm gebracht habt.",ep:3,g:2,l:1,wd:true,fm:true,w:0,p:1};
I.u[8598] = {n:"Schweizer Dolch",t:5,d:"Der Schweizer Dolch jodelt, wenn man ihn durch die Lüfte schwingt. Außerdem ist seine Klinge ideal, um den Widerstand der gegnerischen Eingeweide gegen das Tageslicht zu brechen. Nur essen kann man ihn leider nicht. Schade eigentlich.",ep:22,g:61,l:67,wd:true,fm:true,w:10,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CA>100",p:10654};
I.u[8599] = {n:"Krallette",t:5,d:"Die Krallette ist das Werk eines manisch auf die Maniküre fixierten Ecaflippchens, welches ausgesprochen pikiert auf die Einführung langer Schwerter reagierte, zumal deren Griffe zu keinem Zeitpunkt mit ihrem Nagellack harmonierten. So sind sie nun mal, die Ecaflippchen.",ep:22,g:62,l:69,wd:true,fm:true,w:10,an:13,e:[15,3,1,1,30,30,false,true],c:"CA>100&CS>100",p:11254};
I.u[8600] = {n:"Die Unlust, Treppen zu steigen",t:30,d:"Vom vielen Herumschreien seid ihr nun völlig außer Atem und daher nicht in der Lage, so viele Stufe hochzusteigen, bevor ihr nicht mindestens weitere 6 Minuten Ruhe gehabt habt...",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8603] = {n:"Livree der Lakaien des Wa-Pwinzes",t:24,d:"Hiermit kann der Lakai des Wa-Pwinzes ganz nach der neuesten Mode eingekleidet werden.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8604] = {n:"Schnallauffall-Schwert",t:6,d:"Mit dem Schnallauffall-Schwert werdet ihr eure Gegner in jeder Notlage im Handumdrehen niederstrecken. Notfalls könnt ihr es auch als Gürtelschnalle verwenden.",ep:22,g:73,l:100,wd:true,fm:true,w:10,an:14,e:[15,8,1,1,40,50,false,false],c:"CS>250&CI<1",p:25654};
I.u[8605] = {n:"Gnadenspender",t:6,d:"Der Gnadenspender sollte gut geschmiert werden, damit er besser ins Futteral gleitet. Er ist leider nicht abwaschbar, und so sei denn auch darauf hingewiesen, dass er lediglich zur einmaligen Verwendung geeignet ist. Denkt daran: er dient vor allem eurem Schutz!",ep:22,g:74,l:73,wd:true,fm:true,w:15,an:14,e:[5,5,1,1,40,50,false,true],c:"CS>80&CI>80&CA>80",p:14000};
I.u[8606] = {n:"Brautkleid",t:24,d:"Dieses Brautkleid wurde sorgsam in ein schönes Paket zusammengelegt. Nun müsst ihr es nur noch zum Intendanten San Lavalss bringen.",ep:2,g:715,l:1,wd:true,fm:true,w:0,p:1};
I.u[8607] = {n:"Stagelnock",t:4,d:"Der Stagelnock besticht durch seine schlichte Eleganz und seine dezidierte Funktionalität. Die ideale Waffe für alle, die ihrem Gegner gerne mal die Pickel nach innen drücken wollen.",ep:22,g:72,l:107,wd:true,fm:true,w:15,an:12,tw:true,e:[7,4,1,1,30,50,false,true],c:"CA>150&CI>150",p:29856};
I.u[8608] = {n:"Klopps Stock",t:4,d:"Es geht das Gerücht, ein Sadida namens Klopp hätte mit diesem Stock seine Familie vor einer Herde wütender Fresssäcke retten wollen. Im Gemenge war es ihm allerdings nicht mehr möglich, mit seinem Stock die richtigen Unterscheidungen zu treffen.",ep:22,g:73,l:85,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,35,40,false,true],c:"CW>150&CV>200",p:20000};
I.u[8609] = {n:"Bogen der Geisha",t:2,d:"Dieser Bogen ist federleicht, elegant geschwungen und riecht gut. Doch kann er auch sehr mörderisch sein, wenn man mit ihm umzugehen weiß.",ep:22,g:56,l:81,wd:true,fm:true,w:15,an:10,tw:true,e:[5,4,3,7,30,50,false,true],c:"CA>200",p:16900};
I.u[8610] = {n:"Monnesond & Ernest-Bogen",t:2,d:"Der Monnesond & Ernest-Bogen neigt dazu, die Erde umkreisen zu wollen. Haltet ihn also besser gut fest!",ep:22,g:57,l:79,wd:true,fm:true,w:10,an:10,tw:true,e:[7,5,4,7,30,50,false,true],c:"CI>150&CC>150",p:15320};
I.u[8611] = {n:"Bastab Café",t:3,d:"Dieser Stab gehörte einst dem berühmten Gringooh, dem nachgesagt wird, ausgezeichneten Kaffee zubereitet zu haben. Allerdings rückte er sein Rezept bis zum Tode nicht heraus.",ep:22,g:61,l:72,wd:true,fm:true,w:15,an:11,e:[5,3,2,4,15,50,false,true],c:"CI>100&CC>100",p:16500};
I.u[8612] = {n:"Ill-Yeah-Richter-Stab",t:3,d:"Mit dem Ill-Yeah-Richter-Stab könnt ihr den Musikgeschmack eurer Feinde testen. Wer durchfällt, hat eben Pech gehabt. Spot on für euch!",ep:22,g:62,l:79,wd:true,fm:true,w:10,an:11,tw:true,e:[10,4,2,5,40,50,false,true],c:"CA>150",p:18000};
I.u[8613] = {n:"Spatzack",t:8,d:"Zum Graben ist der Spatzack weniger geeignet, es sei denn, ihr konzentriert euch auf den Schädel eures Gegners.",ep:22,g:46,l:70,wd:true,fm:true,w:10,an:16,tw:true,e:[5,4,1,1,30,50,false,false],c:"CC>100",p:13540};
I.u[8614] = {n:"RIP-Schipp",t:8,d:"Eine herrliche Erfindung, die RIP-Schipp. Man kann sie sowohl zum Grabausschaufeln als auch als Grabkreuz verwenden. Dies jedoch nur 1 Mal.",ep:22,g:47,l:66,wd:true,fm:true,w:1,an:16,tw:true,e:[5,4,1,1,20,30,false,false],c:"CI>100&CC>50",p:1};
I.u[8615] = {n:"Weichklopfer",t:7,d:"Wenn du erstmal einen Weichklopfer hast, fangen alle Schädel an, wie Koteletts auszusehen.",ep:22,g:61,l:83,wd:true,fm:true,w:10,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100&CV>100",p:17560};
I.u[8616] = {n:"Tommys Klopfer",t:7,d:"Tommys Klopfer stammt aus der Zeit von König Stephanus, welcher mit ihm dereinst Millionen von Menschen in Angst und Schrecken versetzte.",ep:22,g:62,l:178,wd:true,fm:true,w:10,an:15,tw:true,e:[5,5,1,1,40,50,false,true],c:"CI>350&CW>180",p:10000};
I.u[8617] = {n:"Schopens Haueraxt",t:19,d:"Schopen war ein etwas kauziger Philosoph, der es nie versäumte, die liebestollen Amaknianer auf den Boden der Realität zurückzuholen. Hierfür prägte er die weisen Worte: Wenn du zum Weibe gehst, vergiss die Haueraxt nicht!",ep:22,g:45,l:62,wd:true,fm:true,w:10,an:17,e:[5,4,1,1,20,30,false,false],c:"CV>150",p:10200};
I.u[8618] = {n:"Neckischer Nackenspalter",t:19,d:"Der neckische Nackenspalter wurde speziell für das Spalten von neckischen Bworknacken entworfen. Ferner findet er auch an astrubianischen Nacken Gefallen, was auf irgendeinen neckischen Zusammenhang schließen lässt. Nur auf welchen?",ep:22,g:46,l:80,wd:true,fm:true,w:10,an:17,tw:true,e:[10,4,1,1,50,50,false,true],c:"CC>120&CA>60",p:16700};
I.u[8619] = {n:"Dula-Berst-Michan-Helm",t:16,d:"Dieser Helm ist der ganze Stolz der Iops. Wenn er ihnen nicht immerzu die Sicht versperrte und die Ohren verstopfte... Aber dennoch - er ist die ideale Ausrüstung für alle, die nicht lange herumreden wollen, damit sie sich so richtig prügeln können.",ep:22,g:175,l:40,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8621] = {n:"Verfluchte Kawotte",t:94,d:"Diese appetitliche Kawotte sieht auf den ewsten Blick ganz gewöhnlich aus, jedoch wiecht sie föwmlich nach bösawtigen Vewzaubewungen. Wewdet ihw dew Vewsuchung widewstehen können hineinzubeißen?",ep:8,g:6,l:21,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[8624] = {n:"Blauer magischer Ballon",t:94,d:"Im Gegensatz zu den ganzen Fälschungen, die man auf dem Jahrmarkt des Trools finden kann, ist dieser Ballon hier ideal, um mit Eleganz und Leichtigkeit durch die Lüfte davonzufliegen. Er wurde ja schließlich nach einer Rezeptur des großen Magus Ko Met auf traditionelle Weise von Hand von einem Trool aufgeblasen.",ep:1,g:7,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8625] = {n:"Grüner magischer Ballon",t:94,d:"Dieser grüne, magische Ballon entsteht, wenn eine grüne Larve einen Luitschi-Pilz frisst. Die abgesprungenen Augen werden von Bworks als Appetithäppchen zum Apéritif sehr geschätzt.  Außerdem hat dieser Ballon auch den großen Magus Ko Met zu vielerlei Rezepturen inspiriert.",ep:1,g:8,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8626] = {n:"vixflirtik hixiknik",t:94,d:"tik gitik Ixilik iksitik nirmilik ibik stiknik vik finkstik zibirikmiktik kinnik dik widikstihik tik virsikchinik diknik mimipfmik?",ep:6,g:9,l:21,wd:false,fm:true,w:1,u:true,ut:true,p:100};
I.u[8627] = {n:"Sarr Ys\' Flöte",t:3,d:"Sarr Ys war ein Troubadour, der mit seinen bezaubernden Melodien noch lange in Erinnerung der Bevölkerung Amaknas bleiben wird. Leider kam dieser brilliante Künstler kürzlich nach einem ausschweifenden Trinkgelage bei einem tragischen Qwark-Quak-Unfall ums Leben.",ep:1,g:63,l:1,wd:false,fm:true,w:10,an:11,e:[10,6,2,3,100,30,false,true],p:1};
I.u[8628] = {n:"Nur-Mut-Hut",t:16,d:"Dieser Hut verleiht euch die Sicherheit, die ihr braucht, um all das in Angriff zu nehmen, wovon ihr immer schon geträumt habt. Mit dieser Ausstrahlung werdet ihr in den Augen eurer Feinde hundertprozentig fürchtenswert erscheinen. Vergesst aber nicht, in von Zeit zu Zeit abzunehmen, denn sonst lauft ihr Gefahr, euch permanent zu verausgaben!",ep:22,g:185,l:40,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8629] = {n:"Alles-wird-gut-Hut",t:16,d:"Angesichts dieser absolut untypischen Kopfbedeckung verstummen die meisten Münder in stummem Wahnsinn.",ep:22,g:179,l:40,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8630] = {n:"Schlafspitz",t:16,d:"Der Schlafspitz ähnelt ein wenig dem Sulik und dem Piruk, hat aber ansonsten nichts mit diesen gemein. Im Gegenteil: er ist so komfortabel, dass ihn die Xélors selbst im Bett aufbehalten.",ep:22,g:177,l:40,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8631] = {n:"Magiesterhut",t:16,d:"Wer sich schon immer gefragt hat, warum die Eniripsa im Notfall stets ein Heilmittel parat haben, der erhält jetzt die Antwort auf den Kopf zugesagt. Im Saum dieses Respekt einflößenden Hutes findet sich die Liste der im Ernstfall anzuwendenden Heilmittel eingenäht. Ein Fall von wissenschaftlicher Magie, sozusagen. Hut ab!",ep:22,g:184,l:40,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8632] = {n:"Barettich",t:16,d:"Wer hier die Farbe rot oder weiß erwartet hat, der wird enttäuscht. Außerdem gleicht dieses Kleidungsstück eher einer Maske als einer Kopfbedeckung. Warum müssen die Leute derart zum Narren gehalten werden? Ganz einfach: damit sie was zum Reden haben!",ep:22,g:178,l:40,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8633] = {n:"Döhna-Kebkapp",t:16,d:"Die Döhna-Kebkapp ist die Antwort der Sacrieurs auf die Frage, wie das Problem des kleinen Imbiss\' zwischendurch zu lösen sei. Ganz einfach: Gegner in Scheiben schneiden, aufspießen und Kopf ins Feuer halten. Dabei kommen auch die Sacrieurs schmerztechnisch voll und ganz auf ihre Kosten.",ep:22,g:180,l:40,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8634] = {n:"Horn-Helm",t:16,d:"Diesen Helm könnt ihr entweder tragen oder aber zum Einlagern von Fresssackfutter verwenden.",ep:22,g:181,l:40,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8635] = {n:"Dikthutor",t:16,d:"Dieser Hut diktiert seinem Träger alle möglichen Versprechen, welche jener niemals in der Lage sein wird, einzulösen. Ungeklärt ist, ob er dabei auf das Gedächtnis- oder das Sprachzentrum des Gehirns einwirkt... Wer seinem Träger begegnet, sollte also besser alle Fremdworte und Schachtelsätze ausblenden und sich lediglich auf den übermittelten Grundwortschatz konzentrieren.",ep:22,g:176,l:40,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8636] = {n:"Robbins Hut",t:16,d:"Robbin, ein berühmter Crâ, benutzte diesen Hut, um sich unbemerkt durch die Wälder zu schleichen und Reisende zu überfallen - all dies einer guten Sache wegen: seiner eigenen!",ep:22,g:186,l:40,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8637] = {n:"Nasführer",t:16,d:"Mit dem Nasführer erhöht sich das Glück der Fécas und ihrer Verbündeten. Wenn ihr also einem Féca folgt, der euch naseweis mit der Nase voraus an der Nase eurer Gegner herum führt, dann könnt ihr sicher sein, dass ER einen Nasführer trägt, und dass IHR mit heiler Nase davon kommt.",ep:22,g:182,l:40,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8638] = {n:"Bedeckel",t:16,d:"Nicht nur auf dem Haupt, sondern auch in der Küche ist der Bedeckel ein unabdingliches Utensil. In letztgenannter wird er hauptsächlich für die Zubereitung von Schmorgerichten verwendet, welche bekanntermaßen einige Zeit in Anspruch nimmt. Nun versteht ihr schon viel besser, warum die Handgelenke der Enutrofs einem Paket Muskelfleisch gleichen.",ep:22,g:183,l:40,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8639] = {n:"Ballisti-Cape",t:17,d:"Wenn dieser Überzieher im Winde flattert, verleiht er euch eine Aura der Unantastbarkeit, vor allem, wenn ihr mit dem Rücken zu eurem Gegner steht. So manch einer wird vermuten, er sei mit einem Metallkreuz verstärkt, das euch vor hinterhältigen Projektilen schützt.",ep:22,g:131,l:80,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8640] = {n:"Cape Cash",t:17,d:"Aus weichem, doch festem Stoff gearbeitet, verleiht dieses Cape den Ecaflips das Gefühl, dass sie immer und überall das Ass ausspielen können.",ep:22,g:133,l:80,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8641] = {n:"Meuchelmäntelchen",t:17,d:"Dieses Mäntelchen ist so leicht und fein, dass es nicht mal knistert, wenn sich die Srams ihren Opfern nähern.",ep:22,g:140,l:80,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8642] = {n:"Mantel der Diskretion",t:17,d:"Die dunkle Farbe dieses Mantels passt gut zu jeder anderen Kleidung. Da er sehr weit geschnitten ist, hat er außerdem den Vorteil, euch von Kopf bis Fuß zu verhüllen, sodass ihr weder auffallt noch ein Sterbenswörtchen eurem Munde entwischt.",ep:22,g:141,l:80,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8643] = {n:"Karitas\' Stola",t:17,d:"Diese wunderbar weiche und wärmende Stola habt ihr Karita zu verdanken. Keiner weiß, woher sie kam, wie lange sie blieb und wohin sie verschwand. Tatsache ist, dass sie euch diesen Umhang hinterlassen hat, der seinen Träger von der Gicht und diversen Sehnenentzündungen bewahrt - zum Neid aller Pandawas, die sich tagtäglich mit der Last ihrer Freunde und Feinde abplagen müssen.",ep:22,g:134,l:80,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8644] = {n:"Speckiger Mantel",t:17,d:"Der speckige Mantel kaschiert die Speckpölsterchen der Sadidas. Er wird mit zwei Hantelknöpfen am Unterkleid befestigt, damit der Eindruck entsteht, es handele sich bei den überschüssigen Pfunden um Muskelpakete.",ep:22,g:139,l:80,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8645] = {n:"Unabdingling",t:17,d:"Da seine Einsatzmöglichkeiten nahezu unbegrenzt sind, gehört das Unabdingling zur Grundaustattung der Sacrieurs. Es dient als Verband für offene Wunden, als Wischmopp nach Blutbädern, als Fußabtreter, als Zeltdach, und manchmal auch als Umhang.",ep:22,g:138,l:80,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8646] = {n:"Häme-Umhang",t:17,d:"Die Osamodas tragen diesen Umhang, wenn sie ganz besonders kampfeslustig aufgelegt sind. Damit können sie ihre Gesichtsmuskeln entspannen und sich voll und ganz darauf konzentrieren, ihre Gegner zu Fall zu bringen, denn ihr hämisches Grinsen ist bereits auf diesem Umhang aufgenäht.",ep:22,g:137,l:80,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8647] = {n:"Capeoeira",t:17,d:"Außer als Schlechtwetterschutz dient dieses Cape den Pandawas zur choreographischen Ausschmückung ihrer Tänze. In letztgenanntem Fall wird es einfach auf den Boden gelegt und es gilt die Regel, dass bestraft wird, wer mit seinem Fuß den Boden außerhalb des Stoffes berührt. Wer dies nicht schafft, muss 3 Tage lang im Regen stehen.",ep:22,g:142,l:80,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8648] = {n:"Ahulcos Cape",t:17,d:"Ahulco war nicht wie andere Crâs... Er hatte enorme Orientierungsschwierigkeiten und fand sich sogar in seinem eigenen Bett nicht zurecht. Dem lag offensichtlich eine funktionale Hirnstörung zu Grunde, denn nach eingehender Befragung fand man heraus, dass ihm alle Räume wie ein von der untergehenden Sonne beschienener, weiter Strand mit Kokospalmen erschienen...",ep:22,g:132,l:80,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8649] = {n:"Umbangkok",t:17,d:"Weite Reisen, ferne Länder... Exotische Düfte... Sonne, Strand und Meer... Der Umbangkok schickt euch auf imaginäre Reisen, was ungemein praktisch ist, insbesondere an grauen, regnerischen Tagen.",ep:22,g:136,l:80,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8650] = {n:"Harnumdrang",t:17,d:"Die Enutrofs leben in einem derartigen unterirdischen Chaos, dass sie auf diverse Orientierungsmittel angewiesen sind. Zu diesen gehört der Harnumdrang, auf welchem die Position der öffentlichen Toiletten des Untergrunds verzeichnet ist.",ep:22,g:135,l:80,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8651] = {n:"Blurt-Gurt",t:10,d:"Dieser prächtige Gurt ist eine wahre Zierde für jeden Iop. Manch einer behauptet, sein Herzstück ließe sich als Waffe einsetzen, falls das Schwert außer Reichweite gerät. Dies ist allerdings eine Legende, denn nur Srams sind clever genug, mit solchen Tricks zu arbeiten.",ep:22,g:116,l:130,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8652] = {n:"66er",t:10,d:"Dienst ist Dienst, und Schnaps ist Schnaps, und Schnaps ist 66. Und wer nicht sticht, der rächt sich! \n(Kartensprüche der Ecaflips, Band 29)",ep:22,g:117,l:130,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8653] = {n:"Klackerdieklacker-Gurt",t:10,d:"Der Ton macht den Namen, so der Erfinder dieses Gegenstandes. Dank der aneinander schlagenden Schmuckknochen kommt kein Sram ungehört an seinen Opfern vorbei. Daher auch die von dieser Klasse geprägte Warnung an die kleinen Sram-Nachkömmlinge: \"Der Klackerdieklacker-Gurt in den Ohren der Opfer surrt.\"",ep:22,g:118,l:130,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8654] = {n:"Uhr-Guhrt",t:10,d:"Bei länger währenden Kämpfen sorgt der Uhr-Guhrt dafür, dass die Xélors nicht in Trägheit verfallen. Also legt den Guhrt besser ab, bevor ihr euch Zeit für ein Nickerchen gönnt.",ep:22,g:119,l:130,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8655] = {n:"Erster-Holon-Gürtel",t:10,d:"Der Erste-Holon-Gürtel ist der Erste und Einzige seiner Art. Er transportiert jede Art von Heilmittel für jede Art von Krankheit – von Aberglaube bis Zipperlein. Er ist das Ganze, das Teil wiederum eines anderen Ganzen ist, nämlich des Eniripsa.",ep:22,g:120,l:130,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8656] = {n:"Düpier-Gürtel",t:10,d:"Dieser Gürtel wird mit dem Püppchen nach hinten zeigend angelegt. Eine wunderbare Taktik, eure Gegner zu düpieren!",ep:22,g:121,l:130,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8657] = {n:"Krawattschurz",t:10,d:"Der Krawattschurz sieht schlicht und harmlos aus. Hinter dem Binder befindet sich allerdings ein mörderisches Folterinstrument, das jeder peinlichen Befragung ein schnelles Ende setzt.",ep:22,g:122,l:130,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8658] = {n:"Tswangs Gürtel",t:10,d:"Die Osamodas profitieren von der Weisheit Tswangs, eines weit gereisten chinesischen Mönches, der sich vor 11.111 Jahren nach Astrub begab, um die amaknischen Götter zu studieren. Er hinterließ den impulsiven Osamodas diesen Gürtel mit den Worten: \"Bevor der Zorn deine Sinne betäubt und deine Augen sich in den Gewässern der blutgetränkten Apokalypse spiegeln, berühre die Laschen von Tswangs Gürtel.\"",ep:22,g:123,l:130,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8659] = {n:"Gravitas-Gurt",t:10,d:"Dieser Gurt hilft den Pandawas, sich im Rausch gerade zu halten. Er gehört damit sozusagen zur Grundausstattung dieser Klasse. Dass die Pandawas in trunkenem Zustand oft von einer unerklärlichen Erdenschwere befallen werden, führen sie gerne auf die Kraft zurück, die diesem Gurt seinen Namen verliehen hat – auch wenn ein jeder weiß, dass selbige eher damit beschäftigt ist, gewisse Wissenschaftler mit Äpfeln zu erschlagen.",ep:22,g:124,l:130,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8660] = {n:"Dart-Gurt",t:10,d:"Dieser Gurt dient nicht nur dazu, zu weite Kleider zu bündeln, sondern ist auch ein echter Blickfang. Nicht zuletzt erfüllt er eine nützliche didaktische Funktion als Zielscheibe: junge Crâs, die gerade mit den Grundlagen der Kampfkunst vertraut gemacht werden, lernen so, ihre Pfeile nicht unterhalb der Gürtellinie zu verteilen.",ep:22,g:125,l:130,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8661] = {n:"Pro Viant Amin-Gürtel",t:10,d:"Die Fécas gehören seit jeher zu den umsichtigsten Bewohnern der amaknischen Lande. So nimmt es nicht Wunder, dass ihre Gurtsäckchen mit wasserlöslichen Krachlklotz-Krumen gefüllt sind. Damit diese Pro Viant Amin-Bomben unterwegs niemandem in die Hände, geschweige denn auf die Füße fallen, sind sie fest am gleichnamigen Gürtel festgezurrt.",ep:22,g:126,l:130,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8662] = {n:"Leitgurt",t:10,d:"Immer mehr männliche Enutrofs verlassen sich auf diesen Gurt, an dem eine magische Karte befestigt ist, die gewisse peinliche Unfälle kaschiert und außerdem den Standort diverser öffentlicher Toiletten verzeichnet.",ep:22,g:127,l:130,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8663] = {n:"Imafrohs Drauflos-Stiefel",t:11,d:"Mit diesen Stiefeln heizen die Iops ihren Gegnern auf dem Kampffeld tüchtig ein. Dabei sorgen sie auch noch für jede Menge Gelächter. Das stört sie  nicht besonders, da sie eh daran gewöhnt sind, nicht Ernst genommen zu werden.",ep:22,g:100,l:100,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8664] = {n:"Haarige Mukuboots",t:11,d:"Sadidas sind nie einsam, weil sie stets ihre Puppen als Begleiter beschwören können. Doch auch ihr braucht die Einsamkeit nicht mehr zu fürchten, dank dieser Schuhe. Sie sind zwar manchmal eine haarige Angelegenheit, doch fühlen sie sich gut an den Füßen an, auch wenn man sich mit ihnen so lächerlich fühlt, dass man am Liebsten vor Scham in Grund und Boden versinken will.",ep:22,g:105,l:100,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8665] = {n:"Botoxiner",t:11,d:"Die Botoxiner sind mit einem speziellen Wirkstoff imprägniert, der sich über einen längeren Zeitraum hinweg über die Haut bis zu den Nervenzellen ausbreitet und dort eine Muskellähmung auslöst. Dadurch erscheint so manche Sram-Dame jünger als sie ist. Bei den Herren der Sram-Schöpfung versagt der Wirkstoff allerdings gänzlich.",ep:22,g:102,l:100,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8666] = {n:"Icellis Botten",t:11,d:"Icelli war ein berühmter Maler florentinischen Ursprungs, der sich aus Liebe zu den rundlichen Fresssäcken (oder waren es die rundlichen Sadida-Damen?) in Astrub niederließ. Diese Liebe zu runden Formen hat offensichtlich auch seine Schuhe imprägniert, welche es Icelli früher gestatteten, schneller zu malen. Wer sie jetzt trägt, beginnt unter kreisrunden Wahrnehmungsstörungen zu leiden...",ep:22,g:103,l:100,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8667] = {n:"Bakterientreter",t:11,d:"Mit diesen Tretern seid ihr immer auf der richtigen Seite, ganz gleich, wohin euch eure Wege führen, denn sie schützen euch vor schädlichen Bodenmikroorganismen. Manch Neider zieht sie allerdings durch den Schlamm mit der Behauptung sie sähen aus wie Hauspantoffeln.",ep:22,g:104,l:100,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8668] = {n:"Biotreter",t:11,d:"Als Pflanzenliebhaber achten die Sadidas stark darauf, wo sie ihre Füße hinsetzen. Mit diesen Tretern ist es ihnen sogar möglich, seltene Gewächse zu orten und zu verschonen. Dies gilt jedoch nicht für Fresssackexkremente...",ep:22,g:101,l:100,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8669] = {n:"Fakirinas",t:11,d:"Im Gegensatz zu anderen Charakterklassen haben die Sacrieurs eine Schwäche dafür, mit einem Nagel im Fuß herumzulaufen. Sie erleiden eben gerne Schmerzen, weil sie sich dadurch lebendig und wütend genug fühlen, um auf ihre Feinde loszugehen. Das Ganze hat den positiven Nebeneffekt, dass ihnen die von ihren Schuhen hinterlassene Blutspur dabei hilft, sich in der Gegend zurechtzufinden. Mit Schuhen von eher mittelmäßiger Qualität würde ein Sacrieur wohl niemals überleben.",ep:22,g:106,l:100,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8670] = {n:"Sieben-Meilen-Pantoffeln",t:11,d:"Mit den Sieben-Meilen-Pantoffeln durchwandern die Osamodas ganz Amakna. Davon abgesehen, macht dieses Schuhwerk nicht viel her. Möglicherweise könnte man es als Tofu-Nest oder als Feldblumenvase verwenden, aber so richtig überzeugend ist das nicht. Es sind eben ganz einfach ein paar Pantoffeln.",ep:22,g:107,l:100,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8671] = {n:"Reliquie des Mächtigen Korallators",t:24,d:"Diese beeindruckende Reliquie wird euch möglicherweise all eure Sorgen vergessen lassen.",ep:22,g:152,l:1,wd:true,fm:true,w:0,p:1};
I.u[8672] = {n:"Reliquie von Gurrlo, dem Fürchterlichen",t:24,d:"Diese beeindruckende Reliquie wird euch möglicherweise all eure Sorgen vergessen lassen.",ep:22,g:153,l:31,wd:true,fm:true,w:0,p:1};
I.u[8673] = {n:"Reliquie des Groß-Shilfs",t:24,d:"Diese beeindruckende Reliquie wird euch möglicherweise all eure Sorgen vergessen lassen.",ep:22,g:154,l:61,wd:true,fm:true,w:0,p:1};
I.u[8674] = {n:"Tynril-Reliquie",t:24,d:"Diese schöne Tynril-Reliquie wird euch all eure Sorgen vergessen lassen.",ep:22,g:155,l:101,wd:true,fm:true,w:0,p:1};
I.u[8675] = {n:"Kimbo-Reliquie",t:24,d:"Diese Reliquie gehört nun euch! Doch ist sie möglicherweise nicht ganz eure Kragenweite.",ep:22,g:156,l:141,wd:true,fm:true,w:0,p:1};
I.u[8676] = {n:"Boah-Schwert",t:6,d:"Vlad hatte sich in dieses wunderschöne Schwert verliebt. Darum nahm er an allen Dragokartrennen statt, nur um sich dieses Schmuckstück kaufen zu können. Dummerweise hat er erst zu spät verstanden, dass in diesem Schwert ein furchtbarer Fluch lauert...",ep:1,g:75,l:95,wd:true,fm:true,w:1,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8677] = {n:"Surr",t:18,d:"Dieser süße Hase war einst der Lieblingsvertraute von Meister Bläck Jäck. Trotz seines harmlosen Aussehens soll er sehr kampfkräftig sein. Er frisst ausschließlich Kawotten und Pflanzen.",ep:3,g:44,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8678] = {n:"Flieghut von Sichthofen-Geschenk",t:16,d:"Fliegtgut von Sichthofen war einst ein talentierter Eiskunstläufer, doch dann traf er auf jemanden, der sein Leben veränderte: er wurde zum besten Dracokartrennenfahrer aller Zeiten. So kann\'s gehen!",ep:1,g:187,l:36,wd:true,fm:true,w:20,p:3550};
I.u[8679] = {n:"Surr-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:46,l:1,wd:true,fm:true,w:1,p:1};
I.u[8680] = {n:"Schlüpfrige Fischschuppe",t:59,d:"Diese schlüpfrige Fischschuppe erlaubte es ihrem vormaligen Besitzer stets den Ködern und Netzen der Angler zu entkommen. Jedoch war sie nicht schlüpfrig genug, um dem Holzspeer eines kleinen Kindes abgleiten zu lassen.",ep:1,g:626,l:10,wd:true,fm:true,w:1,p:1};
I.u[8681] = {n:"Rolf Mops\' Haut",t:59,d:"Die große Schwäche der Rolf Möpse ist ihre Liebe zu ausgedehnten Bädern, sei es in Wasser, Wein oder gar Essig. Zudem genießt er es, sich um Zwiebeln und Gurken herumzuwickeln. Andere Wesen, andere Sitten...",ep:1,g:627,l:40,wd:true,fm:true,w:1,p:1};
I.u[8682] = {n:"Mopps\' schwammige Haut",t:59,d:"Diese Haut lässt sich von beiden Seiten verwenden. Eine Seite ist sanft und ermöglicht es empfindliche Oberflächen damit zu waschen, während die andere sehr rau ist, um mit dieser den Rest des Körpers abzuschrubben.",ep:1,g:628,l:10,wd:true,fm:true,w:1,p:1};
I.u[8683] = {n:"Ping-Geschenk",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich genug Nahrung und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8684] = {n:"Tierheimzertifikat: Surr",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über Surr, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8685] = {n:"Tierheimzertifikat: Bilby",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über Bilby, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[8686] = {n:"Surr-Geschenk",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich genug Nahrung und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8687] = {n:"Bilby-Geschenk",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich genug Nahrung und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8688] = {n:"Surr-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8691] = {n:"Pandawushu-Stirnband",t:24,d:"Ihr habt dieses schönes Stirnband einem Pandawushu-Schüler als Symbol eures Sieges abgenommen.",ep:2,g:253,l:1,wd:true,fm:true,w:0,p:1};
I.u[8692] = {n:"Rezeptur für einen Verwandlungstrank",t:24,d:"Diese Notizensammlung enthält die Theorien verschiedener Alchimisten über eine potentielle Wabbit-Verwandlung. Daran sieht man einmal mehr, dass manche Personen wirklich zu viel Zeit haben...",ep:2,g:95,l:1,wd:true,fm:true,w:0,p:1};
I.u[8693] = {n:"Felidan",t:18,d:"Dank dieses Vertrauten wird euch jeder Angehörige des anderen Geschlechts schöne Augen machen. Ein Ratschlag: vermeidet es, dies auf euch zu beziehen. Dieser Erfolg ist nämlich ausschließlich auf euren Vertrauten zurückzuführen, dessen großen Kulleraugen niemand widerstehen kann. Er ernährt sich übrigens ausschließlich von Fisch.",ep:3,g:45,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8694] = {n:"Kandierte Schilischoten",t:42,d:"Diese kandierten Schilischoten sind umhüllt von übermächtigem geschmolzenen Bonbon. Das explosive Gemisch aus Süßigkeit und Schärfe ermöglichte es dem Dracotruter Blonder Blitz, eines der berühmtesten Dracotruterrennen in der Geschichte zu gewinnen.",ep:1,g:111,l:1,wd:true,fm:true,w:1,c:"PO!1723",u:true,p:1};
I.u[8695] = {n:"Unbe-Schwert",t:6,d:"Wie bereits der alte Unbe sagte: \"Nicht auf die Größe kommt es an, sondern darauf, wie man es handhabt!\"",ep:22,g:76,l:177,wd:true,fm:true,w:10,an:14,e:[5,3,1,1,50,50,false,false],c:"CM>5",p:50050};
I.u[8696] = {n:"",t:23,d:"",ep:0,g:14,l:1,wd:false,fm:true,w:1,p:1};
I.u[8697] = {n:"",t:23,d:"",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[8698] = {n:"",t:23,d:"",ep:0,g:16,l:1,wd:false,fm:true,w:1,p:1};
I.u[8699] = {n:"Tynril-Hut",t:16,d:"Mit dem Tynril-Hut seht ihr aus, als stünden euch die Haare zu Berge, selbst wenn ihr nicht zu den Rastas gehört. Doch einen Vorteil hat er, dieser Hut: Bei hoher Luftfeuchte kringeln sich seine Späne, sodass ihr immer wisst, wie es um die Wetterlage beschaffen ist. Allerdings solltet ihr euch nicht allzu sehr den Flammen nähern, es sei denn ihr brennt tatsächlich darauf, wie eine lebende Fackel durch Amakna zu wandeln.",ep:22,g:188,l:164,wd:true,fm:true,w:10,p:51250};
I.u[8700] = {n:"Smaragd-Schale",t:16,d:"Diese Kopfbedeckung scheint ein authentischer Teil eines geborstenen Smaragd-Dofus zu sein. Der Dofus war jedoch noch nicht vollkommen ausgeleert. Ein natürliches Ei-Shampoo soll aber gesund sein, sagt man.",ep:1,g:189,l:21,wd:true,fm:true,w:5,p:1400};
I.u[8701] = {n:"Choh-Schwert",t:6,d:"Dieses schmucke Schwert gehörte einst einem berüchtigten Gauner, der den Ruf hatte, jedes Mal geschnappt zu werden, wenn er ein Verbrechen beging.",ep:0,g:77,l:95,wd:false,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[8702] = {n:"",t:4,d:"",ep:0,g:74,l:1,wd:false,fm:true,w:1,an:12,tw:true,e:[0,0,1,1,0,0,false,false],p:1};
I.u[8703] = {n:"",t:5,d:"",ep:0,g:63,l:1,wd:false,fm:true,w:1,an:13,e:[1,0,1,1,1,1,false,false],p:1};
I.u[8704] = {n:"Narrmützl",t:16,d:"Ob Ja-Sager oder Nein-Sager, mit dem Narrmützl spielt ihr zu jeder Musik. Ein Narr, wer Böses dabei denkt!",ep:22,g:190,l:160,wd:true,fm:true,w:10,p:47625};
I.u[8706] = {n:"Felidan-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:48,l:1,wd:true,fm:true,w:1,p:1};
I.u[8707] = {n:"Tierheimzertifikat: Felidan",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über Felidan, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8708] = {n:"Tierheimzertifikat: Krötschild",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über Krötschild, den ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:true,fm:true,w:1,p:100};
I.u[8709] = {n:"Felidan-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8711] = {n:"Felidan-Geschenk",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für die Aufzucht und Eniripsa-Pulver, um ihn zu pflegen.",ep:1,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[8712] = {n:"Stück Goldemort",t:110,d:"Bravo! Ihr habt dem Kadaver von Goldemort eine kleines Stückchen Substanz entnommen für eure Sammlung. Die Geier sind stolz auf euch.",ep:1,g:490,l:1,wd:true,fm:true,w:1,p:1};
I.u[8713] = {n:"Spagettas",t:11,d:"In manchen Gegenden ist es üblich, den Kampf zu eröffnen, indem man seinen Gegnern die Spagettas vor die Füße wirft. In anderen Gegenden wiederum ist es üblich, seinen Feinden einen Handschuh ins Gesicht zu werfen, um seine Verachtung zu bezeugen. Wozu das alles gut sein soll...! Der Brauch mit den Spagettas hat allerdings den Vorteil, dass der Gegner gleich zu Kampfbeginn seinen Geruchssinn einbüßt.",ep:22,g:108,l:100,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8714] = {n:"Spannring",t:9,d:"Dieser Ring ist ein Geschenk der Göttin Crâ an ihre Anhänger und erinnert selbige daran, dass nur ein gespannter Bogen den Pfeil ins Ziel bringt.",ep:22,g:126,l:150,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8715] = {n:"Würfelring",t:9,d:"Die Spielsucht der Ecaflips ist legendär. Jeder Vorwand ist ihnen Recht, ihr Gegenüber zum Spiel zu verleiten, wie man an diesem Ring wohl sieht. Sein Aufsatz ist außerdem leicht abnehmbar und kann als Ersatzwürfel eingesetzt werden.",ep:22,g:127,l:150,wd:true,fm:false,w:1,s:88,p:10000};
I.u[8716] = {n:"Blutrüns Tigerring",t:9,d:"Bei den Osamoda-Damen ist dieses Schmuckstück ausgesprochen beliebt, denn es unterstreicht ihren wildkatzenhaften Charakter. Doch auch wenn es sein mag, dass sie sich wie blutrünstige Tigerinnen verhalten, wenn sie in die Nähe von Monstern geraten, so sind sie doch ausgesprochen sanft und anschmiegsam in Gegenwart all ihrer Liebsten.",ep:22,g:128,l:150,wd:true,fm:false,w:1,s:84,p:10000};
I.u[8717] = {n:"Wessen-Ring",t:9,d:"Böse Zungen behaupten, dieser Ring gehöre zu den nutzlosesten Gegenständen in ganz Amakna. Denn wer würde sich schon gerne das kostbare Samtwams zerreißen, wenn der Schnupfen droht und ein Griff in die Tasche unabdinglich wird? Weniger böse Zungen sprechen ihm einen gewissen Nützlichkeitsgrad zu, denn immerhin bleiben kleine Hautfetzen des Gegners in seinem Geweihaufsatz hängen. Doch eines beschäftigt beide Fronten gleichermaßen, und dieses Eine ist die Frage: Wessen Ring ist dies bloß?",ep:22,g:129,l:150,wd:true,fm:false,w:1,s:81,p:10000};
I.u[8718] = {n:"Erinner-Ring",t:9,d:"Die kleinen Schilde des Memo-Rings sind ideale Festplatten für die Ablage von Notizen jeder Art. Bei den Féca-Kindern ist dieses Schmuckstück auch als Eselsbrücken-Ring bekannt. Daher auch das typische Féca-Sprichwort: \"Über diese Brücke gehe ich nicht!\"",ep:22,g:130,l:150,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8719] = {n:"Konservato-Ring",t:9,d:"Dieser Ring ist genau das Richtige für nostalgisch veranlagte Enutrofs, die ab und zu eine Prise Vergangenheitsduft genießen wollen. Einfach die Schaufel abziehen und die Nase in die Nut halten. Die Frage ist nur: Wie kommt der Duft in die Nut hinein?",ep:22,g:131,l:150,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8720] = {n:"Deko Dia-Ring",t:9,d:"Dieser Ring wurde den Eniripsa einst von ihrer Göttin überbracht, damit sie fürderhin alle für ihre Klasse in Gefahrensituationen relevanten Botschaften dekodieren. Seither wird er von Generation zu Generation weitergegeben. Fällt er in die Hände eines Nicht-Eniripsa, so dient er mit hoher Wahrscheinlichkeit jedoch eher der Dekoration.",ep:22,g:132,l:150,wd:true,fm:false,w:1,s:83,p:10000};
I.u[8721] = {n:"Bierlein-öffne-Dich",t:9,d:"Dies Schmuckstück ist gar eine Zier \nVor allem nach dem 3. Bier.  \nEin Pandawa stets wohlgemut  \nEs gern sich an den Finger tut.  \nOh Bier  \nTu du \nDich öffnen \nMir! \n(Bierlein-öffne-Dich, Hauptgesang)",ep:22,g:133,l:150,wd:true,fm:false,w:1,s:92,p:10000};
I.u[8722] = {n:"Hallow-Reeng",t:9,d:"Dieses Schmuckstück wurde den Sram-Kindern traditionellerweise anlässlich von Kinderfeiern übergeben, als Anerkennung für ihre gemein(sam)e Heimtücke. Bei anderen Klassen ist der Hallow-Reeng weniger beliebt, da er die Kinder zu sehr aufregt und alle anfangen, nach Bombons zu schreien.",ep:22,g:134,l:150,wd:true,fm:false,w:1,s:89,p:10000};
I.u[8723] = {n:"Subma-Ring",t:9,d:"Der Subma-Ring ist der einzige Ring, der auch unter Wasser stets genau die Uhrzeit anzeigt. Ausgehend von seiner Zeichenvorlage wurden bereits mehrere Versuche unternommen, den Gegenstand im Großformat zu reproduzieren. Dieses Vorhaben scheiterte jedoch auf Grund der Patentansprüche eines gewissen Dr. Niemand.",ep:22,g:135,l:150,wd:true,fm:false,w:1,s:86,p:10000};
I.u[8724] = {n:"Haar-Harr-Ring",t:9,d:"Entgegen aller durch böse Zungen ausgestreuten Gerüchte haben die Sadidas keine Haare an den Fingern. Wirklich nicht! Ihr männlicher Charme rührt einzig und allein von diesem herrlichen Juwel her, dessen Auswüchse nicht gestutzt werden dürfen, denn andernfalls verlöre sich diese betörende, wenn auch recht lächerliche Aura der Männlichkeit.",ep:22,g:136,l:150,wd:true,fm:false,w:1,s:90,p:10000};
I.u[8725] = {n:"SOS-Ring (So-oder-So)",t:9,d:"Wer einen Nicht-Sacrieur mit diesem Ring erwischt, sollte ihn sofort in die Notaufnahme bringen.",ep:22,g:137,l:150,wd:true,fm:false,w:1,s:87,p:10000};
I.u[8726] = {n:"Geiger-Derwisch-Schuhe",t:11,d:"In der Nähe von Edelsteinadern sind diese Schuhe nicht zu bremsen und machen ihrem Namen alle Ehre. Daher ist es nicht verwunderlich, dass die Enutrofs doch weitestgehend isoliert ihrer Arbeit nachgehen, denn im historischen Gedächtnis dieser Klasse ist das im Jahre 619 nach Enutrof durch die Schall- und Trittwellen dieses Schuhwerks ausgelöste, katastrophale Geiger-Derwisch-Beben noch ausreichend gut verankert.",ep:22,g:109,l:100,wd:true,fm:false,w:1,s:85,p:10000};
I.u[8727] = {n:"Kneif-Stiefel",t:11,d:"Die Fécas beschwören diese Stiefel, sobald es eng für sie wird und sie sich aus dem Staub bzw. über alle Berge machen müssen. Tatsächlich funktioniert dieses Schuhwerk genauso effizient wie ein Allradantrieb auf schwierigem Gelände. Allerdings hat es einen Nachteil: es gestattet nicht nur zu kneifen, sondern kneift auch noch selbst.",ep:22,g:110,l:100,wd:true,fm:false,w:1,s:91,p:10000};
I.u[8728] = {n:"Karottenbotten",t:11,d:"Es ist kaum zu glauben, aber diese Botten bestehen aus mumifizierten Karotten! Deren Stiele winden sich elegant um den einstigen Fruchtkörper und können jederzeit als Sehnen für die Bögen der Crâ verwendet werden.",ep:22,g:111,l:100,wd:true,fm:false,w:1,s:82,p:10000};
I.u[8729] = {n:"Korallenstäbchen",t:51,d:"Diese Stäbchen blättern bei trockenem Klima von den Korallatoren ab. Sie sind so hübsch anzusehen, dass sich selbst die besonnenen kleinen Xelorinas dazu hinreißen lassen, sie zu Freundschaftsbändchen zu verarbeiten.",ep:22,g:2,l:40,wd:true,fm:true,w:10,p:1};
I.u[8730] = {n:"Steißbein des Korallators",t:47,d:"Dieser strategisch günstig platzierte Knochen gestattete es dem Korallator, jederorts eine bequeme Position einzunehmen. Nun, da der Korallator nicht mehr unter den Lebenden weilt, ist es an euch, ihm einen Nutzen zuzuweisen.",ep:16,g:12,l:40,wd:true,fm:true,w:1,p:1};
I.u[8731] = {n:"Mächtige Koralle",t:51,d:"Die Mächtige Koralle unterscheidet sich von einem Korallenstäbchen vor allem hinsichtlich ihrer Größe und ihres Nutzens. Nicht einmal ein Amalgam aus verschiedenen Korallenstäbchen erreicht auch nur annähernd Wert und Güte einer einzigen Mächtigen Koralle!",ep:22,g:9,l:150,wd:true,fm:true,w:10,p:1};
I.u[8732] = {n:"Blaukoralle",t:51,d:"Die bemerkenswerte Farbe dieser Koralle lässt auf die guten Ernährungsgewohnheiten der Krustoralle schließen.  Eine kräftige Färbung in schillernem Blau und ein stabiles Skelett sind der Lohn dafür.",ep:16,g:3,l:40,wd:true,fm:true,w:10,p:1};
I.u[8733] = {n:"Grünkoralle",t:51,d:"Die bemerkenswerte Farbe dieser Koralle lässt auf die guten Ernährungsgewohnheiten der Krustoralle schließen. Passt nur auf, dass sie euch nicht mit einem Salat verwechselt! Solch ein bedauerlicher Fehler ist ja schnell passiert!",ep:16,g:4,l:40,wd:true,fm:true,w:10,p:1};
I.u[8734] = {n:"Braunkoralle",t:51,d:"Die bemerkenswerte Farbe dieser Koralle lässt auf die Ernährungsgewohnheiten der Krustoralle schließen. Eine Kreatur mehr, für die Obst und Gemüse reine Fremdwörter sind.",ep:16,g:5,l:40,wd:true,fm:true,w:10,p:1};
I.u[8735] = {n:"Fahlkoralle",t:51,d:"Die bemerkenswerte Farbe dieser Koralle lässt auf die Ernährungsgewohnheiten der Krustoralle schließen. Eine Kreatur mehr, für die Obst und Gemüse reine Fremdwörter sind.",ep:16,g:6,l:40,wd:true,fm:true,w:10,p:1};
I.u[8736] = {n:"Herz des geschliffenen Krachlers",t:51,d:"Das Einzige, was das Herz des Krachlers vom Herzen des geschliffenen Krachlers unterscheidet, ist das feine Splittern, das ihr zu hören bekommt, wenn ihr es mit euren groben Füßen tretet.",ep:16,g:7,l:80,wd:true,fm:true,w:1,p:1};
I.u[8737] = {n:"Kling-Kugel des geschliffenen Krachlklotzes",t:51,d:"Diese Kling-Kugel verlangt nach ihrem Gegenstück, der Klang-Kugel. Allerdings weiß niemand so recht, ob diese auch wirklich existiert...",ep:16,g:8,l:80,wd:true,fm:true,w:1,p:1};
I.u[8738] = {n:"Sacrum Corallatorum",t:47,d:"Hier nun ein weiteres Stück aus dem Knochenbestand der Korallatoren. Dieses Exemplar stammt vom Groß-Korallator. Ratet mal, aus welcher Körperregion...",ep:22,g:11,l:150,wd:true,fm:true,w:1,p:1};
I.u[8739] = {n:"Oberarmknochen des Sparo",t:47,d:"Er sieht aus wie ein Oberarmknochen, und er verhält sich wie ein Oberarmknochen. Doch ist es wirklich einer? Tja... Wer kennt schon die Anatomie dieses von Schwertern durchbohrten Fässermannes...?",ep:22,g:18,l:80,wd:true,fm:true,w:1,p:1};
I.u[8740] = {n:"Flipps Zahnstumpf",t:47,d:"Dieser Stumpf lässt auf Flipps Mundhygiene schließen... Warum musstet ihr ihn auch aufheben?",ep:22,g:19,l:80,wd:true,fm:true,w:1,p:1};
I.u[8741] = {n:"Kido-Schnabel",t:47,d:"Kido-Schnäbel sind sehr weich, weswegen sie von Otomaïs Schülern oft als Pfeilspitzen für das Übungstraining mit dem Bogen verwendet wurden.",ep:16,g:22,l:80,wd:true,fm:true,w:1,p:1};
I.u[8744] = {n:"Krustorallenschere",t:47,d:"Das ideale Werkzeug zum Knacken von traumatisierten Kokokosnüssen.",ep:22,g:17,l:40,wd:true,fm:true,w:1,p:1};
I.u[8745] = {n:"Blaublütenblatt",t:35,d:"Dem Blaublütenblatt ist seine Herkunft eindeutig anzusehen... Otomaïs Schüler sollten wirklich etwas weniger mit Spirituosen herumexperimentieren.",ep:22,g:3,l:40,wd:true,fm:true,w:1,p:1};
I.u[8746] = {n:"Grünblütenblatt",t:35,d:"Dem Grünblütenblatt ist seine Herkunft eindeutig anzusehen... Otomaïs Schüler sind eben doch noch ziemlich grün hinter den Ohren...",ep:22,g:5,l:40,wd:true,fm:true,w:1,p:1};
