I.u[8246] = {n:"Hut des grünen Piepmatzes",t:16,d:"Mit diesem Hut auf dem Kopf werdet ihr zwar lächerlich, aber auch gleichzeitig unwiderstehlich aussehen. Tja, eine wahrhaft schwierige Wahl...",ep:1,g:140,l:1,wd:true,fm:true,w:1,s:71,p:1};
I.u[8247] = {n:"Hut des gelben Piepmatzes",t:16,d:"Mit diesem Hut auf dem Kopf werdet ihr zwar lächerlich, aber auch gleichzeitig unwiderstehlich aussehen. Tja, eine wahrhaft schwierige Wahl...",ep:1,g:141,l:1,wd:false,fm:true,w:1,s:72,p:1};
I.u[8248] = {n:"Hut des rosafarbenen Piepmatzes",t:16,d:"Mit diesem Hut auf dem Kopf werdet ihr zwar lächerlich, aber auch gleichzeitig unwiderstehlich aussehen. Tja, eine wahrhaft schwierige Wahl...",ep:1,g:142,l:1,wd:true,fm:true,w:1,s:70,p:1};
I.u[8249] = {n:"Trinker-Feder",t:53,d:"Diese abgenutzte Feder hat eine große Menge hochprozentigen Alkohols aufgesogen, weshalb sie leicht entflammbar ist.",ep:13,g:2,l:1,wd:true,fm:true,w:1,p:1};
I.u[8250] = {n:"Rafux-Haar",t:54,d:"Der Rafux verkleidet sich gern als Rabling. Niemand weiß genau wieso, doch hat fast jeder eine eigene Meinung zu diesem Thema.",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:1};
I.u[8251] = {n:"Peki Peki-Haar",t:54,d:"Wer hätte gedacht, dass ihr eines Tages einmal die Haut des berüchtigten Peki Peki in den Händen halten würdet? Niemand, außer vielleicht Oma Trantschie mit ihrer krankhaften Liebe zu ausgestopften Peki Pekis.",ep:18,g:6,l:1,wd:true,fm:true,w:1,p:1};
I.u[8252] = {n:"Feder des gezähmten Rablings",t:53,d:"Diese fettige Feder gehörte einmal einem gezähmten Rabling, der die meiste Zeit seines Lebens eingesperrt in einem Käfig verbracht hat und dort gemästet wurde.",ep:13,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[8253] = {n:"Schwammulett",t:1,d:"Dieses Amulett wird oftmals mit einem der Spielzeuge verwechselt, die in Überraschungseiern zu finden sind. Dabei gewinnt man es doch am Schießstand, wie jeder weiß...",ep:1,g:106,l:11,wd:true,fm:true,w:2,s:63,p:525};
I.u[8254] = {n:"Schwammring",t:9,d:"Als Ehering verwendet, gelingt es diesem Meisterstück, die Brücke zu schlagen zwischen den beiden wichtigsten Botschaften im Eheleben: \"Ich liebe dich\" und \"Kümmer du dich um den Abwasch\". Welch Zeitersparnis!",ep:1,g:112,l:10,wd:true,fm:true,w:2,s:63,p:500};
I.u[8255] = {n:"Schwammaufel",t:8,d:"Diese Waffe ist extrem wirkungsvoll gegen Erdschollen und hat bereits mehr als nur einen angehenden Abenteurer begleitet. Wenn sie nass wird, weicht sie auf, bis man sie aufrollen kann. Doch dafür sollte man besser zu zweit sein.",ep:1,g:44,l:10,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,true],s:63,p:500};
I.u[8256] = {n:"Schwammokassins",t:11,d:"Mit diesen Stiefeln an den Füßen könnte ein Eniripsa glatt über das Wasser wandeln. Wahre Aussage, da Eniripsas ja Flügel besitzen, doch verblüfft es immer wieder alle Zuhörer. Andere Klassen könnten diese Stiefel dazu nutzen, sich während des Laufens an den Füßen zu kratzen oder schlicht und einfach mal, jene sauber zu machen.",ep:1,g:84,l:11,wd:true,fm:true,w:5,s:63,p:525};
I.u[8257] = {n:"Schwammgürtel",t:10,d:"Dieser Gürtel erlaubte es Vald, ohne Sorge im Weiher zu baden. Wie die meisten Iops hat er schließlich noch nicht schwimmen gelernt.",ep:1,g:102,l:10,wd:true,fm:true,w:5,s:63,p:500};
I.u[8258] = {n:"Schwammantel",t:17,d:"Dieser Mantel ist ideal, um sich inmitten der natürlichen Umgebung zu tarnen. Aber auch nur, wenn niemand da ist, der euch sehen will.",ep:1,g:109,l:10,wd:true,fm:true,w:1,s:63,p:505};
I.u[8259] = {n:"Schwammützel",t:16,d:"Auf einem kleinen Beizettel am Rand der Mütze steht geschrieben: \"Schenkt diese Mütze eurem Mann, stülpt sie ihm über den Dickschädel, schiebt ihn mit den Füßen voran durch die Küche, und schon ist der Boden wieder blitzblank!\" Ein originelles Vorgehen, um die Arbeitsteilung im Haushalt zu erleichtern.",ep:1,g:143,l:11,wd:true,fm:true,w:10,s:63,p:525};
I.u[8260] = {n:"Kalyptus-Stirnband",t:16,d:"Mit diesem Stirnband auf dem Kopf sehen Iops noch verführerischer aus, als jemals zuvor.",ep:20,g:124,l:133,wd:true,fm:true,w:10,p:43500};
I.u[8262] = {n:"MuWulf-Amulett",t:1,d:"Das MuWulf-Amulett enthält eine seltsame Substanz aus den Eingeweiden des MuWulfs. Einige behaupten, dabei handele es sich um die Essenz des Monsters, andere hingegen glauben, dieser habe nur einen etwas zu alten Kirbull verspeist.",ep:20,g:107,l:143,wd:true,fm:true,w:1,s:55,p:44850};
I.u[8263] = {n:"MuWulfs-Ring",t:9,d:"Achtung! Dieser Ring wird eurem Finger einen extrem üblen Geruch bescheren! Doch da es heißt, ein übler Geruch könne einen anderen überdecken, wäre dies vielleicht für euren Finger und eure Umgebung gar keine so schlechte Sache...",ep:20,g:113,l:126,wd:true,fm:true,w:10,s:55,p:40190};
I.u[8264] = {n:"MuWulf-Stiefel",t:11,d:"In diesen Stiefeln steckt immer noch der fürchterliche Appetit des MuWulfes... Also fürchtet um eure Füße! Wenn diese nämlich wieder einmal nach dem gefürchteten Stinkus Casei riechen, könnte es sein, dass sie die Stiefel auffressen.",ep:18,g:85,l:131,wd:true,fm:true,w:20,s:55,p:42840};
I.u[8265] = {n:"MuWulf-Mantel",t:17,d:"Ein MuWulf hat einen wunderschönen, langen Schwanz, der bis zum Boden reicht. Und nun haben ihm eifersüchtige Abenteurer diesen abgenommen. Schade eigentlich.",ep:20,g:110,l:139,wd:true,fm:true,w:10,s:55,p:44500};
I.u[8266] = {n:"MuWulf-Gürtel",t:10,d:"Auf diesem farbigen Gürtel prangt ein wunderschönes, violett gefärbtes Haarbüschel. Ihr könnt den Gürtel natürlich aber auch anders herum tragen, um euch als Wabbit zu verkleiden.",ep:20,g:103,l:125,wd:true,fm:true,w:1,s:55,p:1};
I.u[8267] = {n:"MuWulf-Hut",t:16,d:"Beim Ausweiden des MuWulfs haben die Jäger schnell festgestellt, dass dieser nur ein einziges großes Horn besitzt, welches aus dem Schädel hervorwächst. Doch die Iops stört das überhaupt nicht, und so tragen sie ihn denn auch mit großem Eifer und großer Freude.",ep:4,g:144,l:141,wd:true,fm:true,w:10,s:55,p:44600};
I.u[8268] = {n:"Minotoror-Amulett",t:1,d:"Dieses Amulett beschützte den Minotoror magisch vor Läusen, Flöhen und Zecken. Offensicht genau das, was ihr braucht!",ep:18,g:112,l:111,wd:true,fm:true,w:1,s:54,p:31260};
I.u[8269] = {n:"Minotororing",t:9,d:"Im Gegensatz zu dem, was manche Abenteurer glauben, wurde dieser Ring niemals vom Minotoror getragen. Wie sollte er ihn auch über seine Hufe ziehen können?",ep:21,g:117,l:105,wd:true,fm:true,w:1,s:54,p:28010};
I.u[8270] = {n:"Minotot-Armband",t:9,d:"Dieses Armband schützt hervorragend den Arm eines Eniripsas. Allerdings verdreifacht es auch dessen Gewicht.",ep:21,g:116,l:151,wd:true,fm:true,w:10,s:57,p:45425};
I.u[8271] = {n:"Ring des Schweinedrachens",t:9,d:"Mit diesem Ring aus Leder und Elfenbein werdet ihr eure Freunde mal so richtig gut stimulieren können.",ep:18,g:115,l:108,wd:true,fm:true,w:1,s:58,p:29600};
I.u[8272] = {n:"Halskette des Minotots",t:1,d:"Diese Halskette ermöglichte es dem Minotot, seinen Hals zu schützen und diesen vor allen anderen zu verstecken, vor allem, wenn er mal wieder SOOOO einen Hals hatte...",ep:21,g:111,l:158,wd:true,fm:true,w:20,s:57,p:47800};
I.u[8273] = {n:"Amulett des Schweinedrachen",t:1,d:"Dieses Amulett besitzt einen kleinen Zusatzring für eine Leine, wenn dem Schweinedrachen wieder mal der Sinn nach einer kleinen Nachtwanderung steht.",ep:21,g:110,l:100,wd:true,fm:true,w:1,s:58,p:25470};
I.u[8274] = {n:"Axt des Minotorors",t:19,d:"Mit dieser Axt wurde bereits der Kopf eines der gefährlichsten Minotorors von ganz Amakna abgehauen. Doch das Unglaublichste an dieser Geschichte ist die Tatsache, dass sie euch völlig kalt zu lassen scheint.",ep:21,g:44,l:109,wd:true,fm:true,w:10,an:17,tw:true,e:[5,5,1,1,40,50,false,true],s:54,p:30110};
I.u[8275] = {n:"Szepter des Minotots",t:4,d:"Dieses Szepter mit dem edelsteinverzierten Schlangenkopf schlägt nicht nur junge, abergläubische Abenteurer in die Flucht, nein, es dient ebenso dazu, diesen den Hintern zu versohlen!",ep:21,g:67,l:151,wd:true,fm:true,w:50,an:12,tw:true,e:[5,4,1,1,40,50,false,false],s:57,p:46200};
I.u[8276] = {n:"Minotoror-Stiefel",t:11,d:"Diese furchtbaren Stiefel aus Minotoror-Fell und -leder sind mit Sicherheit viel zu schwer, als dass ihr mit ihnen den legendären Wettlauf um die Bucht von Amakna gewinnen könntet. Andererseits könnt ihr beim Start mit ihnen prima die Zehen der Kontrahenten zermalmen.",ep:21,g:89,l:113,wd:true,fm:true,w:40,s:54,p:32290};
I.u[8277] = {n:"Minotot-Sandalen",t:11,d:"Mit diesen unglaublichen Sandalen könnt ihr es euch sogar erlauben, die gefährlichsten Gewässer zu betreten, ohne euch die Füße schmutzig zu machen. Doch Vorsicht: sie können Emaille-Badewannen beschädigen.",ep:21,g:88,l:163,wd:true,fm:true,w:20,s:57,p:48400};
I.u[8278] = {n:"Schweinedrachen-Pantoffeln",t:11,d:"Ein gutes Paar Pantoffeln unter den Füßen, und schon fühlt man sich wie ein echter Held. So richtig heldenhaft, mächtig und leistungsstark. Leider sind es dennoch bloß Pantoffeln.",ep:20,g:87,l:93,wd:true,fm:true,w:5,s:58,p:22800};
I.u[8279] = {n:"Minotoror-Umhang",t:17,d:"Nehmt einen Minotoror, fesselt ihn an einen Baum, nehmt einen Riesenhobel und schält ihm (in einem einzigen Durchgang) den Rücken ab. Schon haltet ihr einen frischen, neuen Minotoror-Umhang in den Händen.",ep:21,g:117,l:109,wd:true,fm:true,w:10,s:54,p:30500};
I.u[8280] = {n:"Minotot-Umhang",t:17,d:"Dieser Umhang ist genau das Richtige, um auszugehen oder jemanden beim Maskenball des Chafer-Offiziers zu verführen.",ep:21,g:116,l:156,wd:true,fm:true,w:40,s:57,p:48850};
I.u[8281] = {n:"Schweinedrachen-Umhang",t:17,d:"Dieser Umhang wird euch zwar noch nicht zu einem süßen, kleinen Ferkelchen machen, doch reicht er eventuell aus, einen Abend lang eine hübsche, betrunkene Lady zu Schweinereien verführen zu können.",ep:20,g:118,l:103,wd:true,fm:true,w:10,s:58,p:27500};
I.u[8282] = {n:"Minotoror-Gürtel",t:10,d:"Dieser Gürtel ist dermaßen biegsam, dass er sogar als Peitsche verwendbar ist. Kein Wunder, dass ihn der Minotoror immer dabei hatte. Dank seiner herrscht bald wieder Zucht und Ordnung in den Ewigen Landen Amaknas.",ep:21,g:106,l:111,wd:true,fm:true,w:1,s:54,p:1};
I.u[8283] = {n:"Minotot-Gürtel",t:10,d:"Dieser starre Gürtel war der Einzige, der stabil genug war, den enormen Wanst des Minotots zurückzuhalten, damit dieser nicht beim leisesten Windhauch nach vorne überkippte.",ep:21,g:105,l:149,wd:true,fm:true,w:30,s:57,p:49950};
I.u[8284] = {n:"Minotot-Hut",t:16,d:"Dieser Hut wurde von Generation zu Generation in der Familie des Minotots weitergegeben. Das erklärt auch sein zerlumptes Aussehen und seinen modrigen Geruch.",ep:21,g:151,l:157,wd:true,fm:true,w:20,s:57,p:47652};
I.u[8285] = {n:"Schweinedrachen-Hut",t:16,d:"Mit diesem gewaltigen Schädel auf dem Kopf seht ihr aus wie ein Langhaar-Gripskopf, doch ohne Haare. Das wird eurer Fan-Gemeinde sicher die Sprache verschlagen",ep:20,g:150,l:98,wd:true,fm:true,w:10,s:58,p:24500};
I.u[8286] = {n:"Drachei-Umhang",t:17,d:"Der Legende nach wird euch dieser schuppenübersäte Umhang vor Blitzen, Bohnen und bissigen Bauernweibern beschützen können.",ep:11,g:115,l:127,wd:true,fm:true,w:10,s:56,p:41000};
I.u[8287] = {n:"Drachei-Helm",t:16,d:"Dieser furchterregende und übertrieben große Helm könnte glatt einen jungen Möchtegern-Abenteurer wie euch in eine furchterregende Kampfmaschine verwandeln. An eine Wand genagelt, gibt er allerdings auch eine gute Hutablage ab.",ep:11,g:149,l:128,wd:true,fm:true,w:10,s:56,p:41500};
I.u[8288] = {n:"Drachei-Gürtel",t:10,d:"Böse Zungen mit übler Phantasie behaupten, dieser Gürtel könne auch als Prothese eingesetzt werden. Doch versteht niemand genau, was damit gemeint ist. Es handelt sich ja schließlich bloß um einen einfachen Drachei-Gürtel!",ep:20,g:104,l:124,wd:true,fm:true,w:1,s:56,p:1};
I.u[8289] = {n:"Drachei-Ring",t:9,d:"Dieser Ring wurde direkt aus der gewaltigen Eischale eines Dracheis herausgearbeitet. Er wird einen kleinen, aber dafür hochwichtigen Teil eurer Finger beschützen können.",ep:20,g:114,l:128,wd:true,fm:true,w:10,s:56,p:41468};
I.u[8290] = {n:"Drachei-Amulett",t:1,d:"Mit diesem aus Dracheischuppen gefertigten Amulett könnt ihr euren Adamsapfel oder aber eure Mandeln vor feindlichen Schlägen beschützen. Das kann durchaus einen großen Unterschied im Kampf ausmachen.",ep:11,g:108,l:124,wd:true,fm:true,w:1,s:56,p:38930};
I.u[8291] = {n:"Drachei-Stiefel",t:11,d:"Fresssäcke beim Fressball treten oder eure Feinde piesacken? Mit diesen Stiefeln kein Problem!",ep:20,g:86,l:129,wd:true,fm:true,w:20,s:56,p:41500};
I.u[8292] = {n:"Drachei-Schwert",t:6,d:"Diese Klinge ist so scharf wie eine Rasierklinge und bleibt es auch! Da stellt sich doch die Frage, was in aller Welt die Dracheier mit ihr anfangen...",ep:11,g:68,l:127,wd:true,fm:true,w:30,an:14,e:[8,5,1,1,40,50,false,true],c:"CS>200&CA>200",p:41025};
I.u[8293] = {n:"Drachei-Axt",t:19,d:"Diese Axt zerteilt Butter genauso leicht, wie Schädel. Oder war es umgekehrt?",ep:20,g:43,l:126,wd:true,fm:true,w:20,an:17,tw:true,e:[5,4,1,1,40,50,false,false],c:"CC>180&CW>80",p:40854};
I.u[8294] = {n:"Drachei-Hammer",t:7,d:"Schwerer als der ausgehöhlte Schädel des haarigen Zockers, aber zerbrechlicher als der Schienbeinknochen des Kirbulls – also alles in allem immer noch ein ausgezeichneter Hammer!",ep:20,g:59,l:123,wd:true,fm:true,w:30,an:15,e:[10,5,1,1,45,50,false,true],c:"CI>200&CC>100",p:38542};
I.u[8295] = {n:"Drachei-Bogen",t:2,d:"Dieser Bogen ist so mächtig, dass man sogar faule Dracheier über die Stadtmauern von Brâkmar hinwegschießen kann. Eigentlich eine Verschwendung!",ep:20,g:55,l:122,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,8,40,50,false,true],c:"CS>300&CV>250",p:38015};
I.u[8296] = {n:"Drachei-Stab",t:3,d:"Dieser Stab scheint sehr wirkungsvoll zu sein, wenn er als Knüppel verwendet wird. Oder auch als Fliegenklatsche.",ep:21,g:60,l:124,wd:true,fm:true,w:10,an:11,e:[5,3,2,5,30,30,false,true],c:"CI>100&CA>200",p:37884};
I.u[8297] = {n:"Drachei-Stecken",t:4,d:"Dieser Stecken besitzt an seinem äußeren Ende eine dicke Spitze, von der sich niemand erklären kann, wie sie dorthin geraten ist. Anderseits kennen aufgeklärte Abenteurer bereits deren Einsatzort...",ep:20,g:66,l:124,wd:true,fm:true,w:30,an:12,tw:true,e:[5,5,1,1,30,50,false,true],c:"CS>300&CA>150&CV>300",p:39800};
I.u[8298] = {n:"Shikas Ähren",t:1,d:"Shika half Farle immer bei der Ernte, indem sie die magischen Ähren aufsammelte, die unter seiner Sense zu Boden fielen. Im Laufe der vielen Ernten gewöhnte sie sich an, diese an einer Kette aufgereiht um den Hals zu tragen. Auch ohne Wurzeln und Stengel sind die magischen Ähren in der Lage, weiter zu reifen, und zwar besonders zu dieser Jahreszeit.",ep:18,g:113,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8299] = {n:"Shikas magisches Armband",t:9,d:"Dieses Armband bedeckte Shikas Arme und schützte sie vor Sonnenbrand und Rablingsbissen. Dank des über die Jahre aufgesaugten Schweißes glänzt das Armband noch feucht im Sonnenlicht.",ep:21,g:118,l:80,wd:true,fm:true,w:5,s:53,p:16500};
I.u[8300] = {n:"Shikas Stecken",t:4,d:"Dieser handgeschnitzte Stecken ermöglichte es Shika, die höchsten Heuballen von ganz Amakna aufzuschichten. Der Legende nach sollen diese sogar so hoch gewesen sein, dass sich die Seeleute ihrer als Navigationspunkte bedienten, um zu herauszufinden, wie weit sie noch von der Küste entfernt sind.",ep:20,g:69,l:80,wd:true,fm:true,w:10,an:12,e:[10,5,1,1,45,45,false,false],s:53,p:16500};
I.u[8301] = {n:"Shikas Holzschuhe",t:11,d:"Diese Holzschuhe wurden von Shika modifiziert, damit sie beim Säen in den Ebenen von Snossios niemals die Pflanzen herunterdrücken. Später fügte Shika dann noch hohe Absätze hinzu, um morgens auf dem Acker herumrennen zu können, ohne den Dreck oder den Morgentau fürchten zu müssen und ihre empfindlichen Knöchel zu verstauchen.",ep:21,g:91,l:80,wd:true,fm:true,w:10,s:53,p:16600};
I.u[8302] = {n:"Shikas Umhang",t:17,d:"Getrocknete magische Getreideähren wurden auf die gesamte Oberfläche dieses Umhangs genäht. Nun wohnt diesem eine dermaßen starke Magie inne, dass Shika damit selbst bei starken Gewittern Blitze ablenken kann.",ep:20,g:120,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8303] = {n:"Shikas Gürtel",t:10,d:"Dieser Ledergürtel schützte immer Shikas Beine, wenn sie rennend durch die Weizenfelder pflügte, um einen entlaufenen Fresssack zur Herde zurückzutreiben. Im Laufe der Zeit haben sich darin die Pollen der magischen Getreidesorten festgesetzt, so dass der Gürtel nach und nach sogar begann, schwach zu leuchten. Praktisch für Farle, der dadurch bei der Ernte im Mondschein die Beine seiner Frau von den Getreideähren unterscheiden konnte.",ep:21,g:107,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8304] = {n:"Shikappe",t:16,d:"Diese Kappe ist mit einer Vielzahl an Getreideähren bedeckt, was Shika stets ein neckisches Aussehen verlieh, wenn sie damit frühmorgens loszog, um die Felder umzugraben.",ep:20,g:156,l:80,wd:true,fm:true,w:10,s:53,p:16500};
I.u[8305] = {n:"Muminotoror-Artefakt",t:24,d:"Dieses eigenartige Artefakt wird benötigt, um dem Minotoror gegenübertreten zu können.",ep:21,g:119,l:1,wd:false,fm:true,w:0,p:1};
I.u[8306] = {n:"Minoknasto-Artefakt",t:24,d:"Dieses eigenartige Artefakt wird benötigt, um dem Minotoror gegenübertreten zu können.",ep:21,g:120,l:1,wd:false,fm:true,w:0,p:1};
I.u[8307] = {n:"Schlüssel zum Saal des Minotots",t:84,d:"Dieser aus verschiedenen Rohstoffen konstruierte Schlüssel wird es euch ermöglichen, dem unglaublichen Minotot zu begegnen. Eine Begegnung, die euch prägen wird, vor allem, wenn der Minotot einen seiner Hufabdrücke in eurem Hinterteil hinterlässt.",ep:13,g:15,l:1,wd:true,fm:true,w:1,p:10};
I.u[8308] = {n:"Scaratos-Panzer",t:107,d:"Aus diesem glänzenden kleinen Panzer kann man günstig hübsche Schmuckstücke fertigen und sie später als angebliche Reliquien, die Fliegen unsichtbar machen können, zu einem hohen Preis an naive Astrubianer verkaufen.",ep:21,g:735,l:1,wd:true,fm:true,w:1,p:10};
I.u[8309] = {n:"Federboahfeder",t:53,d:"Diese Feder ist vom Staub eines magischen Steines bedeckt. Das erklärt wohl auch, warum eine Federboahfeder schwerer wiegt, als drei Einheiten Tofufedern. Alles eine Frage der Logik.",ep:21,g:4,l:1,wd:true,fm:true,w:10,p:1};
I.u[8310] = {n:"Geleewürfelgelee",t:110,d:"Dieser Pott mit Gelee enthält eine abstoßend riechende und fürchterlich schmeckende Substanz. Und doch hegt ihr – wie viele – den geheimen Wunsch, euch damit einzureiben. Aber gut, es gibt schlimmere Verhaltensstörungen im Leben...",ep:21,g:736,l:1,wd:true,fm:true,w:1,p:1};
I.u[8311] = {n:"Bumino-Haar",t:54,d:"Dieses Haar ist mit einer Art Patina überzogen, die in der Sonne glänzt und aus reinstem Fett besteht. Herrlich!",ep:21,g:9,l:1,wd:true,fm:true,w:1,p:1};
I.u[8312] = {n:"Minoskito-Haut",t:59,d:"Diese abgenutzte Haut ist dank Meersalz und feinem Sand so glatt gewetzt worden, wie ein alter Schuh, der von Meersalz und feinem Sand glatt gewetzt wurde.",ep:21,g:604,l:1,wd:true,fm:true,w:1,p:1};
I.u[8313] = {n:"Minotoror-Schienbeinknochen",t:47,d:"Dieser Knochen ist stabil genug, um als Träger beim Hausbau zu dienen. Möglicherweise könnte man damit auch das Haus des Nachbarn zerschlagen. Doch welcher normale Mensch würde so etwas tun?",ep:2,g:644,l:1,wd:true,fm:true,w:1,p:1};
I.u[8314] = {n:"Kramelehon-Haut",t:59,d:"Diese geschwärzte Haut schützt empfindliche Haut sehr effektiv vor den Strahlen der Sonne. Doch damit das hin haut, muss die Haut auf der bloßen Haut getragen werden.",ep:21,g:603,l:1,wd:true,fm:true,w:1,p:1};
I.u[8315] = {n:"Mandrinchen-Haut",t:59,d:"Diese fleckige Haut soll dem Ruf nach ein potentes Gift enthalten, das jeden, der sie berührt, in ein ausgetrocknetes Karambol verwandelt. Beängstigend, aber dennoch ist die Versuchung groß...",ep:21,g:602,l:1,wd:true,fm:true,w:1,p:1};
I.u[8316] = {n:"Minifux: Tipps für die Aufzucht",t:25,d:"Dieses Buch wurde von Oshimo Li\'kross Babine geschrieben und erklärt eingehend die Aufzucht eines Minifuxes.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8317] = {n:"El Scarador: Tipps für die Aufzucht",t:25,d:"Dieses Buch wurde von Oshimo Li\'kross Babine geschrieben und erklärt eingehend die Aufzucht El Scaradors.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8318] = {n:"Astaknydasta: Tipps für die Aufzucht",t:25,d:"Dieses Buch wurde von Oshimo Li\'kross Babine geschrieben und erklärt eingehend die Aufzucht eines Astaknydastas.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8319] = {n:"Fresskügelchen: Tipps für die Aufzucht",t:25,d:"Dieses Buch wurde von Oshimo Li\'kross Babine geschrieben und erklärt eingehend die Aufzucht eines Fresskügelchens.",ep:3,g:10,l:1,wd:false,fm:true,w:1,u:true,p:20};
I.u[8320] = {n:"Schlüssel zum Unterschlupf des Schweinedrachens",t:84,d:"Nachdem ihr eine halbe Ewigkeit im Dungeon des Schweinedrachens herumgeirrt seid, habt ihr schließlich festgestellt, dass ihr vergessen habt, den Schlüssel zum Unterschlupf des Schweinedrachens einzustecken. Glücklicherweise haben eure Schweinios-Freunde immer einen Zweitschlüssel dabei!",ep:15,g:16,l:1,wd:true,fm:true,w:1,p:100};
I.u[8321] = {n:"Minoknasto-Haar",t:54,d:"Gebt es endlich auf, diese Haare sind nicht essbar!",ep:21,g:664,l:100,wd:true,fm:true,w:1,p:10};
I.u[8322] = {n:"Muminotoror-Haar",t:54,d:"Unter all diesen Bandagen verbirgt der Muminotoror einen weichen Flaum, der selbst die Süßeste aller Prinzessinnen neidisch machen würde.",ep:21,g:663,l:100,wd:true,fm:true,w:1,p:10};
I.u[8323] = {n:"Minoknasto-Leder",t:56,d:"Na? Wird euch dieses krumpelige und raue Stück Leder an die Backen eurer Liebsten erinnern?",ep:21,g:657,l:100,wd:true,fm:true,w:1,p:10};
I.u[8324] = {n:"Muminotoror-Leder",t:56,d:"Der Muminotoror hatte schon seit frühester Kindheit eine sehr empfindliche Haut, weshalb er sich immer in Bandagen hüllen musste. Böse Zungen munkeln sogar, er tue dies, um andere furchtbare Dinge zu kaschieren.",ep:21,g:656,l:100,wd:true,fm:true,w:1,p:10};
I.u[8325] = {n:"Muminotoror-Hut",t:16,d:"Wenn ihr euer Gesicht vor dem Zahn der Zeit bewahren wollt, gibt es nichts Besseres als diesen Hut. Doch Vorsicht: er hilft leider nicht vor Gedächtnisverlust.",ep:0,g:157,l:110,wd:false,fm:true,w:10,s:59,p:100};
I.u[8326] = {n:"Muminotoror-Bandage",t:15,d:"Um Hörner und Füße gewickelt, haben diese Bandagen im Laufe der vielen Jahre die Magie und den schlechten Geruch des Muminotorors aufgesogen. Damit finden sie nun sicherlich ihren Platz in der Sammlung jedes Archäologen.",ep:21,g:734,l:100,wd:true,fm:true,w:1,p:10};
I.u[8327] = {n:"Minoknasto-Horn",t:47,d:"Dieses große Horn ist zwar völlig unnütz, aber dennoch eindrucksvoll. Ein wenig, wie eine Armee voller Flöhe.",ep:21,g:643,l:100,wd:true,fm:true,w:1,p:10};
I.u[8328] = {n:"Muminotoror-Horn",t:47,d:"Eingerollt in magische Bandagen, wird dieses Horn mit Sicherheit sehr viel wert sein, von Sammlern gepriesen werden, sehr schlecht riechen und vielleicht gar verflucht sein. Fast wie ein Mumie, eben.",ep:21,g:642,l:100,wd:true,fm:true,w:1,p:10};
I.u[8329] = {n:"Lichens Schlüssel",t:84,d:"...",ep:1,g:0,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8330] = {n:"Helm eines fliegenden Dracheis",t:16,d:"Durch diesen kleinen Helm geschützt, konnten sich die fliegenden Dracheier ohne Furcht vor Beulen am Schädel auf ihre Feinde stürzen. Nachdem diese Art von Helm lange Jahre hindurch erfolgreich auf großen Baustellen Amaknas getragen wurde, hat er nun wieder einen Anstieg der Verkaufszahlen verursacht, nachdem seine Wirksamkeit bei der Verteidigung gegen die WuWulf-Invasion aus dem Kruupgebirge bewiesen werden konnte. Wie? Eine völlig unlogische Geschichte? Ja, durchaus, aber wen kümmert das?",ep:13,g:152,l:72,wd:true,fm:true,w:10,p:16000};
I.u[8331] = {n:"Draconixa-Helm",t:16,d:"Mit diesem Helm auf dem Kopf könnt ihr nicht nur Travestie-Shows gewinnen, sondern auch jeden dahergelaufenen Astrubianer um ein wenig Geld erleichtern, indem ihr ihm um Mitternacht für nur 100 Kamas eine wunderbare Liebesnacht hinter der Ulme versprecht.",ep:18,g:153,l:95,wd:true,fm:true,w:10,p:23000};
I.u[8333] = {n:"Mantel des Weißnachtsmannes",t:17,d:"Dieser seltsame Mantel tauchte plötzlich in der kalten Jahreszeit auf. Mit seiner Hilfe haben sich schon viele Betrüger als großzügige alte Männer mit weißem Rauschebart ausgegeben.",ep:1,g:119,l:19,wd:true,fm:true,w:10,p:1205};
I.u[8334] = {n:"Hut des Weißnachtsmannes",t:16,d:"Mit Hilfe dieses Hutes könnt ihr leicht all die Narben auf eurem Schädel verstecken. Vielleicht bringt ihr damit ja am Ende sogar noch Kinder zum Lachen, wer weiß?",ep:1,g:155,l:22,wd:true,fm:true,w:10,p:1478};
I.u[8335] = {n:"Winziges Weißnachtsgeschenk",t:89,d:"Das Ankama-Team wünscht euch ein frohes Fest! Möge euch dieses Geschenk noch viel Freude bereiten!",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8336] = {n:"Kleines Weißnachtsgeschenk",t:89,d:"Das Ankama-Team wünscht euch ein frohes Fest! Möge euch dieses Geschenk noch viel Freude bereiten!",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8337] = {n:"Weißnachtsgeschenk",t:89,d:"Das Ankama-Team wünscht euch ein frohes Fest! Möge euch dieses Geschenk noch viel Freude bereiten!",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8338] = {n:"Weißnachtsschwert",t:6,d:"Dieses seltsame Schwert wird euch nicht unbesiegbar machen, aber zum Erledigen von Schneebällen sollte es ausreichen.",ep:1,g:69,l:1,wd:false,fm:true,w:1,an:14,e:[1,1,1,1,2,2,false,true],p:1};
I.u[8339] = {n:"Großes Weißnachtsgeschenk",t:89,d:"Das Ankama-Team wünscht euch ein frohes Fest! Möge euch dieses Geschenk noch viel Freude bereiten!",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8340] = {n:"Gewaltiges Weißnachtsgeschenk",t:89,d:"Das Ankama-Team wünscht euch ein frohes Fest! Möge euch dieses Geschenk noch viel Freude bereiten!",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8341] = {n:"Ananas-Stiefel",t:11,d:"Diese Stiefel verbreiten einen starken Geruch nach vergorenem Ananassaft in löchrigem, alten Socken. Damit werdet ihr wenigstens sicher sein, dass euch niemand auffordern wird, sie jemals auszuziehen.",ep:1,g:90,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8342] = {n:"Schlüssel zum Heiligtum der Dracheier",t:84,d:"Dieser mit Dracheischalen besetzte Schlüssel gewährt euch Zugang zum Heiligtum der fürchterlichen Dracheier, welches nicht gerade für seine Gastfreundlichkeit berühmt ist.",ep:10,g:18,l:1,wd:true,fm:true,w:1,p:100};
I.u[8343] = {n:"Schlüssel zum Dungeon der Dracheier",t:84,d:"Ihr dachtet, endlich ans Ziel eurer Mühen gekommen zu sein, doch müsst ihr nun feststellen, dass ihr damit völlig daneben lagt. Dieser Schlüssel bringt euch ausschließlich eurem sicheren Tode näher...",ep:10,g:17,l:1,wd:true,fm:true,w:1,p:100};
I.u[8344] = {n:"Schwarzes Dracosshorn",t:47,d:"Mit diesem Horn – zwar etwas stumpfer als ein Xelorzeiger, doch dafür sehr viel stabiler –, könnt ihr endlich eure Treter in Piekser verwandeln.",ep:11,g:648,l:50,wd:true,fm:true,w:1,p:10};
I.u[8345] = {n:"Saphir-Dracosshorn",t:47,d:"Mit diesem Horn – zwar etwas stumpfer als ein Xelorzeiger, doch dafür sehr viel stabiler –, könnt ihr endlich eure Treter in Piekser verwandeln.",ep:11,g:647,l:50,wd:true,fm:true,w:1,p:10};
