I.u[2018] = {n:"Goldener Weizen",t:34,d:"Diese Weizenähre birgt mächtige magische Kräfte.",ep:1,g:474,l:1,wd:true,fm:true,w:2,p:0};
I.u[2019] = {n:"Magisches Weizenmehl",t:52,d:"Diese Mehl wurde aus einer goldenen Weizenähre gewonnen. Wahrlich beeindruckend!",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[2020] = {n:"Goldenes Brot",t:33,d:"Dieses Brot wurde mit magischem Weizenmehl gebacken. Daher findet es reißenden Absatz.",ep:1,g:69,l:10,wd:true,fm:true,w:2,c:"Cv<10",u:true,ut:true,p:1};
I.u[2021] = {n:"Leuchtender Hopfen",t:34,d:"Dieser Hopfen straht eine schwach leuchtende Aura aus, als Zeichen der Magie, die Mutter Erde ihm verliehen hat.",ep:1,g:475,l:30,wd:true,fm:true,w:2,p:0};
I.u[2022] = {n:"Magisches Hopfenmehl",t:52,d:"Dieses Mehl wurde aus glänzendem Hopfen gewonnen. Ohne Zweifel: in ihm schlummern magische Kräfte.",ep:1,g:253,l:1,wd:true,fm:true,w:2,p:0};
I.u[2023] = {n:"Magisches Hopfenbrot",t:33,d:"Dieses",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[2024] = {n:"Briochette",t:33,d:"Diese kleine Brioche wurde mit Hopfenmehl gebacken. Das erklärt auch den fühlbaren Energiegewinn beim Verspeisen.",ep:1,g:8,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2025] = {n:"Magische Briochette",t:33,d:"Diese kleine Brioche wurde mit Hopfenmehl gebacken. Das erklärt auch den fühlbaren Energiegewinn beim Verspeisen.",ep:1,g:8,l:20,wd:true,fm:true,w:1,c:"Cv<20",u:true,p:1};
I.u[2026] = {n:"Sturmflachs",t:34,d:"Dieser Sturmflachs hat bereits die schlimmsten Unwetter mitgemacht und sich danach schon über 7 Mal wieder aufgerichtet, was kein anderes Getreide geschafft hätte. Nachdem er nun über 148 Jahre hinweg den Morgentau der weiten Ährenfelder von Pathi aufgesaugt hat, wird er irgendwann in naher Zukunft endlich verarbeitet werden können. Mit ein wenig Glück...",ep:1,g:476,l:40,wd:true,fm:true,w:1,p:0};
I.u[2027] = {n:"Magisches Flachsmehl",t:52,d:"Dieses Mehl wurde aus Sturmflachs gewonnen. Es besitzt daher wertvolle magische Eigenschaften.",ep:1,g:254,l:1,wd:true,fm:true,w:1,p:0};
I.u[2028] = {n:"Magisch stärkendes Brot",t:33,d:"Dieses Brot wurde aus dem Mehl von Sturmflachs gefertigt, daher ist es nicht so fett und hat gleichzeitig einen hervorragenden Geschmack.",ep:1,g:12,l:1,wd:true,fm:true,w:1,c:"Cv<30",u:true,ut:true,p:1};
I.u[2029] = {n:"Widerstandsfähiger Roggen",t:34,d:"Dieses dunkle Getreide wächst und gedeiht selbst unter den furchtbarsten Bedingungen.",ep:1,g:477,l:50,wd:true,fm:true,w:2,p:0};
I.u[2030] = {n:"Magisches Roggenmehl",t:52,d:"Dieses Mehl hat alle guten Eigenschaften des widerstandsfähigen Roggens geerbt. Darum hat es auch bei maßlosem Verzehr eine starke abführende Wirkung.",ep:1,g:257,l:1,wd:true,fm:true,w:2,p:0};
I.u[2031] = {n:"Brot aus widerstandsfähigem Roggen",t:33,d:"Dieses Brot wurde aus widerstandsfähigem Roggenmehl gebacken. Daher schmeckt es zwar nicht besonders, ist jedoch gesund wie nichts anderes!",ep:1,g:9,l:10,wd:true,fm:true,w:1,c:"Cv<40",u:true,ut:true,p:1};
I.u[2032] = {n:"Zuckergerste",t:34,d:"Diese seltene Ähre hat während der Keimung süßen Regen abbekommen, wodurch sie unschätzbare magische Eigenschaften besitzt.",ep:1,g:477,l:10,wd:true,fm:true,w:2,p:0};
I.u[2033] = {n:"Süßgerstenmehl",t:52,d:"Dieses Mehl wurde aus Zuckergerste gewonnen. Dadurch wird das Brot so leicht, dass man am liebsten mit der nächsten Windbö davonfliegen möchte. Allerdings ist dies noch lange kein Grund, hemmungslos alle Vorräte aufzuessen.",ep:1,g:256,l:1,wd:true,fm:true,w:1,p:0};
I.u[2034] = {n:"Gerstige Zuckerstange",t:42,d:"Die Gerstige Zuckerstange ist eine Süßigkeit mit einem unverwechselbaren Geschmack. Ihr Fertigung ist ziemlich aufwändig, da der Gerstenzucker erst einmal aus der Zuckergerste herausgeprügelt werden muss.",ep:1,g:128,l:1,wd:true,fm:true,w:1,c:"Cv<50",u:true,p:50000};
I.u[2035] = {n:"Euphorisierender Hanf",t:34,d:"Diese Hanfähre scheint mächtige geistverändernde Wirkungen hervorzurufen. Erfahrene Spezialisten könnten diese Eigenschaft durchaus für einen guten Zweck nutzen.",ep:1,g:478,l:70,wd:true,fm:true,w:1,p:0};
I.u[2036] = {n:"Goldener Hafer",t:34,d:"Wenn man diese Ähren betrachtet, hat man den Eindruck, sie würden goldene Tränen weinen. Doch liegt dies an den magischen Kräften, die sie während ihres Wachstums angereichert haben.",ep:1,g:551,l:20,wd:true,fm:true,w:2,p:0};
I.u[2037] = {n:"Goldenes Hafermehl",t:52,d:"Dieses Mehl wurde aus goldenem Haferähren gewonnen. Daher auch sein goldener Farbton und die großen magischen Kräfte. Doch dies allein wird euch noch lange nicht zu einem magischen Bäcker machen.",ep:1,g:250,l:1,wd:true,fm:true,w:1,p:0};
I.u[2038] = {n:"Brot mit goldenen Haferflocken",t:33,d:"Dieses Brot ist einfach perfekt.",ep:1,g:5,l:10,wd:true,fm:true,w:2,c:"Cv<70",u:true,ut:true,p:1};
I.u[2039] = {n:"Jägertestmarke",t:24,d:"Ihr habt versucht, den Test abzulegen, um ein echter Jäger zu werden.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2040] = {n:"Tsogs geheimes Schatzkästchen",t:24,d:"In einer kleinen Truhe habt ihr Tsogs geheimes Schatzkästchen entdeckt. Seltsam, dass diese Kiste genauso unbeschreiblich und eigenartig riecht, wie Tsog selbst, nicht wahr?",ep:2,g:56,l:1,wd:true,fm:true,w:0,p:1};
I.u[2041] = {n:"Übelriechende Fresssackkeule",t:24,d:"Diese Keule riecht nach Fäulnis und Tod. Und das liegt nicht unbedingt am vorzeitigen Ableben des Besitzers.",ep:1,g:64,l:20,wd:true,fm:true,w:0,p:1};
I.u[2042] = {n:"Knochen von Mak Gahan",t:24,d:"Diesen Knochen habt ihr als Andenken mitgenommen, nachdem ihr den Körper vom Chafer Mak Gahan in alle vier Himmelrichtungen zerlegt habt.",ep:1,g:57,l:1,wd:true,fm:true,w:0,p:1};
I.u[2043] = {n:"Dahingekritzelter Meuchelmördername",t:24,d:"Auf diesem alten, übelriechenden, verwitterten Stück Papier steht der Name des Meuchelmörders, welcher den Inhaber des Gasthauses \"Zur Brennenden Katze\" ermordet hat.",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2044] = {n:"Bier aus der \"Brennenden Katze\"",t:37,d:"Dieses Bier hier schmeckt definitiv nach Katzenpisse... Doch leider noch nicht streng genug, denn sonst fände es keinerlei Anklang...",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:6};
I.u[2045] = {n:"Kastenzettel",t:24,d:"Dieser Zettel beweist, dass ihr einen Kasten zurückgebracht habt.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2046] = {n:"Schlüssel von Brâkmar",t:24,d:"Dieser Schlüssel wurde aus noch unerfindlichen Gründen von einem Eichhörnchen gestohlen.",ep:2,g:61,l:1,wd:true,fm:true,w:0,p:1};
I.u[2047] = {n:"Liste der Milizionäre in der Pause",t:24,d:"Diese Liste wurde euch vom Milizonär in der Taverne gegeben. Es stehen folgende Namen darauf: \nBrank Thoof, Haco Norss, Jack Rottance, Kad Maxy.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2048] = {n:"Liste der Milizionäre in der Pause",t:24,d:"Diese Liste wurde euch vom Milizionäre in der Taverne gegeben. Es stehen folgende Namen darauf: \nBrank Thoof, Haco Norss, Jack Rottance, Kad Maxy.",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2049] = {n:"Geständnis des Kriegers Xale DuGros",t:24,d:"Xale DuGros hat zugegeben, nicht in die Taverne zu gehen. Allerdings macht er regelmäßig eine Pause.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2050] = {n:"Geständnis des Kriegers Nager Nacmeil",t:24,d:"Nager Nacmeil hat zugegeben, nicht in die Taverne zu gehen. Allerdings macht er regelmäßig eine Pause.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2051] = {n:"Geständnis von Bishom Pot",t:24,d:"Bishom Pot hat alles gestanden. Sein Verhalten ist absolut unentschuldbar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2052] = {n:"Signierter und datierter Freistellungsschein",t:24,d:"Dieses Dokument beweist, dass ihr einen Tag frei habt.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2053] = {n:"Abzeichen des Milizionärs Allen Tokar",t:24,d:"Dies ist das Abzeichen des Milizionärs Allen Tokar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2054] = {n:"Abzeichen des Milizionärs Biztek Aput",t:24,d:"Dies ist das Abzeichen des Milizionärs Biztek Aput.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2055] = {n:"Abzeichen des Milizionärs Bill Indebar",t:24,d:"Dies ist das Abzeichen des Milizionärs Bill Indebar.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2056] = {n:"Rabling-Auge",t:109,d:"Ein Rabling-Auge kann hin und wieder nützlich sein. Gebt nur Acht, dass euch nicht sein böser Blick trifft.",ep:1,g:326,l:20,wd:true,fm:true,w:1,p:100};
I.u[2058] = {n:"Herz von Brandon",t:15,d:"Dieses menschliche Herz stammt höchstwahrscheinlich vom berühmten Lhi, dem Rablingsforscher.",ep:1,g:328,l:20,wd:true,fm:true,w:5,p:500};
I.u[2059] = {n:"Toter Rabling",t:15,d:"Ihr hattet vollkommen Recht, ihn aufzuheben. Euer Gegner ist unversehrt. Zwar tot, aber noch völlig unversehrt.",ep:1,g:329,l:20,wd:true,fm:true,w:10,p:100};
I.u[2060] = {n:"Rabling-Kralle",t:103,d:"Nicht nötig, dafür die ganze Klaue abzutrennen. Vor allem, weil Rablingsklauen im Gegensatz zu Wabbitpfoten nicht nur kein Glück, sondern gar Unglück bringen.",ep:1,g:330,l:20,wd:true,fm:true,w:1,p:10};
I.u[2061] = {n:"Rablingsumhang",t:17,d:"Dieser Umhang, der auf den ersten Blick nicht sehr ansprechend aussieht, ist im Kampf sehr hilfreich. Immer vorausgesetzt, man kann sich an den strengen Geruch nach verwesendem Rabling gewöhnen.",ep:1,g:15,l:45,wd:true,fm:true,w:5,p:5600};
I.u[2062] = {n:"Tarnung",t:31,d:"Mit dieser Tarnung seid ihr in eurer Umgebung nicht mehr auszumachen. Ihr werdet erst wieder sichtbar, wenn ihr einem Kampf beitretet.",ep:1,g:1,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2063] = {n:"Flattrige Stiefel",t:11,d:"Diese Stiefel wurden aus vielen Rablingskadavern gefertigt, weshalb ihr Träger stets ein Gefühl der Leichtigkeit und Losgelöstheit verspürt, wenn er sie an den Füßen hat. Ein wenig wie nach dem Verzehr von gerösteten Röhrlingsmeistern.",ep:1,g:17,l:41,wd:true,fm:true,w:15,p:4500};
I.u[2064] = {n:"Schriftrolle der Tarnung",t:14,d:"Diese Schriftrolle erlaubt es dem Anwender, sich wie ein Chamäleon der Farbe der Umgebung anzupassen. Doch sollte er dabei schnelle Bewegungen und verdächtige Geräusche besser unterlassen, wenn er nicht entdeckt werden möchte...",ep:16,g:1,l:10,wd:true,fm:true,w:1,c:"Pg=10&PM=B",u:true,p:250};
I.u[2065] = {n:"Helm des Elitechafers",t:24,d:"Der Helm des Elitechafers ist beschädigt, kann aber dennoch genutzt werden, seine Angehörigkeit zur Elite der Chafer kenntlich zu machen.",ep:2,g:59,l:1,wd:false,fm:true,w:0,p:1};
I.u[2066] = {n:"Stecken des Kanigrous",t:4,d:"Dieser Stecken ist der Versuch eines Stockschnitzers, die Waffe eines Kanigrous zu imitieren. Das Ergebnis ist immer für einige Überraschungen gut, doch nicht immer ausschließlich gute.",ep:13,g:22,l:54,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,30,50,false,false],c:"CS>50&CA>40&CC>30",p:5400};
I.u[2067] = {n:"Trank des Vergessens: \"Flammiche\"",t:43,d:"Dieser Trank lässt euch einen Grad des Elementarzaubers \"Flammiche\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2068] = {n:"Trank des Vergessens: \"Kawotte\"",t:43,d:"Dieser Trank lässt euch einen Grad des Elementarzaubers \"Kawotte\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2069] = {n:"Trank des Vergessens: \"Moons Hammer\"",t:43,d:"Dieser Trank lässt euch einen Grad des Elementarzaubers \"Moons Hammer\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2070] = {n:"Shako",t:16,d:"Dieser Knochenschädel befand sich über lange Zeit in einer Kanigroutasche. Obwohl er nun benutzt und zerkratzt aussieht, hat er dennoch all seine schönen Eigenschaften behalten.",ep:9,g:58,l:34,wd:true,fm:true,w:15,p:3200};
I.u[2071] = {n:"Trank des Vergessens: \"Befreiung\"",t:43,d:"Dieser Trank lässt euch einen Grad des Elementarzaubers \"Befreiung\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2072] = {n:"Trank des Vergessens: \"Blitzschlag\"",t:43,d:"Dieser Trank lässt euch einen Grad des Elementarzaubers \"Blitzschlag\" vergessen.",ep:5,g:36,l:1,wd:true,fm:true,w:1,u:true,p:1000};
I.u[2073] = {n:"Trank des Vergessens: \"Bröckll\"",t:43,d:"Dieser Trank lässt euch einen Grad des Spezialzaubers \"Bröckll\" vergessen.",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[2074] = {n:"Feuer-Bwack",t:18,d:"Dieser süsse kleine Bwack wird später irgendwann einmal zu einem furchtbaren Kwack werden. Doch bis dahin könnt ihr ihn getrost bei euch behalten.",ep:1,g:3,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:2,p:1};
I.u[2075] = {n:"Wasser-Bwack",t:18,d:"Dieser süsse kleine Bwack wird später irgendwann einmal zu einem furchtbaren Kwack werden. Doch bis dahin könnt ihr ihn getrost bei euch behalten.",ep:1,g:2,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:13,p:1};
I.u[2076] = {n:"Luft-Bwack",t:18,d:"Dieser süsse kleine Bwack wird später irgendwann einmal zu einem furchtbaren Kwack werden. Doch bis dahin könnt ihr ihn getrost bei euch behalten.",ep:1,g:4,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:15,p:1};
I.u[2077] = {n:"Erd-Bwack",t:18,d:"Dieser süsse kleine Bwack wird später irgendwann einmal zu einem furchtbaren Kwack werden. Doch bis dahin könnt ihr ihn getrost bei euch behalten.",ep:1,g:5,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:14,p:1};
I.u[2078] = {n:"Testament von Ixa Mustam",t:24,d:"Das Testament des Vaters von Oto Mustam ist in Alt-Brâk geschrieben. Schade für euch, dass ihr bloß ein einziges Wort in dieser wundervollen Sprache beherrscht, nämlich: \"Guo\'rhalys!\"",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2079] = {n:"74er Omnischlundeau, Spätlese",t:24,d:"Es heißt, es würde über 20 Jahre lang dauern, einen Wein aus Omnischlundsaft zu destillieren, damit er nicht mehr toxisch wirke...",ep:2,g:62,l:1,wd:true,fm:true,w:1,p:1};
I.u[2080] = {n:"Omnischlundsaft",t:24,d:"Omnischlundsaft ist mindestens genauso toxisch wie Skorpiutgift. Aber wird er korrekt destilliert, so entsteht daraus ein Wein unbeschreiblichen Geschmackes. Leider gibt es nur sehr wenige Wesen, die diese Kunst beherrschen. Und die meisten von ihnen sind Piraten...",ep:2,g:63,l:1,wd:true,fm:true,w:1,p:1};
I.u[2081] = {n:"Bericht von Finch Aticus",t:24,d:"Der Bericht des Spiones Finch Aticus enthält die komplette Liste der Truppenstärken und Waffengattungen der Verteidiger von Bonta.",ep:2,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[2082] = {n:"Frischling",t:32,d:"Wenn ein kleiner Frischling seine Eltern vor seinen eigenen Augen sterben sieht, dann wird deren Mörder für ihn zu seiner Ersatztmutter.",ep:13,g:1,l:1,wd:true,fm:true,w:0,m:true,p:10};
I.u[2083] = {n:"Oto Mustams Brief",t:24,d:"Dies ist ein Brief eures Meisters an Vil Smiss. Er wurde mit Absicht in einem unbekannten Dialekt verfasst, um zu vermeiden, dass neugierige Menschen wie ihr ein Auge auf seinen Inhalt werfen.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2084] = {n:"Vil Smisses Antwort",t:24,d:"Dies ist die Antwort von Vil Smiss auf den Brief von Oto Mustam. Sie ist völlig unverständlich für die meisten Normalsterblichen. So auch für euch...",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2085] = {n:"Bier aus der Kneipe \"Zum Knüppel\"",t:37,d:"Dieses Bier schmeckt nicht nur bloß nach Wasser, sondern ist auch noch sündhaft teuer. Also hat es durchaus etwas mit manchen \"feinen Damen\" gemein.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2086] = {n:"\"Alakarte\"-Bier",t:37,d:"Dieses mit Kirsch-Blobs aromatisierte Bier wird von manchen auch Manoca genannt.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,p:3};
I.u[2087] = {n:"\"Bagrutt\"-Bier",t:37,d:"Dieses Bier macht euch gleich nach der Einnahme schon viel mutiger und stärker... Doch Vorsicht: der Absturz danach ist umso härter, vor allem da die Wirkung schon nach kurzer Zeit wieder verfliegt.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:5};
I.u[2088] = {n:"Bier aus dem \"Hohlzkrug\"",t:37,d:"Dieses Bier unterscheidet sich nur wenig von anderen, jedoch ist das Maß hervorragend geschnitzt. Somit hat das Behältnis einen größeren Wert als sein Inhalt. Eine Eigenschaft, die es mit Iopschädeln und der Boulevardpresse gemein hat.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2089] = {n:"Bier aus dem \"G\'smörtnbröd\"",t:37,d:"Dieses Bier wird heiß ausgeschenkt, so dass es im Sommer kaum trinkbar ist. Allerdings verbreitet es einen leckeren Geruch nach frisch gebackenem Brot, weshalb es des Öfteren als ideale Flüssignahrung für\'s Frühstück herhalten muss.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[2090] = {n:"Bier aus dem \"Eisenbeiß\"",t:37,d:"Dieses Bier hat einen bitteren, metallischen Nachgeschmack. Der ist zwar sehr unangenehm, jedoch wirkt das Bier dafür revitalisierend. Darin ähnelt es glatt den Küssen der Mumie Nova.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:7};
I.u[2091] = {n:"\"Die Bwackaufzucht leicht gemacht\" – Ein Ratgeber",t:25,d:"In diesem praktischen Ratgeber steht beschrieben, wie man am besten einen Bwack aufzieht.",ep:3,g:4,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2092] = {n:"\"Auf 4 Pfoten durchs Leben\" – Ein Ratgeber",t:25,d:"In diesem praktischen Ratgeber steht beschrieben, wie man am besten eine Maunzmiez aufzieht.",ep:3,g:3,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2093] = {n:"\"Nicht ohne meinen Wabbit\" – Ein Ratgeber",t:25,d:"In diesem praktischen Ratgeber steht beschrieben, wie man am besten einen Wabbit aufzieht.",ep:3,g:5,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[2094] = {n:"Schatten-Makroute",t:16,d:"Der Schatten-Makroute ist ein Hut, der aus einem zerfetzten Makroute entstand, wobei dieser von Hand und ohne Narkose wieder zusammengenäht wurde. Daher hört er auch nur auf sein Herrchen und liebt es, Unbekannte zu beißen.",ep:14,g:33,l:50,wd:true,fm:true,w:5,p:6600};
I.u[2095] = {n:"Där Bär",t:16,d:"Där Bär ist eine Kopfbedeckung, die aus dem Kopf eines erlegten Bären angefertigt wurde. Der Schneider, der dieses Prachtstück geschaffen hat, muss ein wahrer Meister seiner Zunft gewesen sein. Denn er hat nicht nur den seidigen Glanz des schwarzen Bärenfelles, sondern auch noch den ungläubigen und unwilligen Ausdruck des Bären beim Erlegtwerden bewahrt. Einfach großartig!",ep:14,g:34,l:35,wd:true,fm:true,w:5,p:10000};
I.u[2096] = {n:"Braves Dora des Schattens",t:16,d:"Brave, der Geist, verstand es als erstes, die seltenen Dunkelweiden für andere Zwecke als zur Nahrungszubereitung zu benutzen.",ep:14,g:35,l:37,wd:true,fm:true,w:5,p:3800};
I.u[2097] = {n:"Champo",t:16,d:"Dieser Pilzhut stammt von einem der verblichenen großen Fungi-Meister Amaknas. Tapfer und allseits respektiert, endete Li Ling, der Röhrling, als Füllung eines Tofu-Eier-Omeletts. Die Welt ist grausam und ungerecht...",ep:1,g:36,l:43,wd:true,fm:true,w:25,p:5000};
I.u[2098] = {n:"Tierheimszertifikat: Erdbwack",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Erdbwack, den ihr im Tierheim abgegeben habt.",ep:3,g:21,l:1,wd:false,fm:true,w:1,p:100};
I.u[2099] = {n:"Tierheimszertifikat: Feuerbwack",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Feuerbwack, den ihr im Tierheim abgegeben habt.",ep:3,g:23,l:1,wd:false,fm:true,w:1,p:100};
I.u[2100] = {n:"Tierheimszertifikat: Wasserbwack",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Wassererbwack, den ihr im Tierheim abgegeben habt.",ep:3,g:22,l:1,wd:false,fm:true,w:1,p:100};
I.u[2101] = {n:"Tierheimszertifikat: Luftbwack",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Luftbwack, den ihr im Tierheim abgegeben habt.",ep:3,g:20,l:1,wd:false,fm:true,w:1,p:100};
I.u[2102] = {n:"Tierheimszertifikat: Wabbit",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Wabbit, den ihr im Tierheim abgegeben habt.",ep:3,g:25,l:1,wd:false,fm:true,w:1,p:100};
I.u[2103] = {n:"Formular von Welloy Cab",t:24,d:"Dieses von Wellow Cab pfotschriftlich ausgefüllte Formular wird alle Sammler von sinnfreien Zahlen und leeren Phrasen beglücken.",ep:1,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2104] = {n:"Verhärlm",t:16,d:"Dieser gefährlich aussehende Helm wurde aus Ouginakkörperteilen und sonstigem Unrat zusammengewürfelt. Nachdem er dann noch längere Zeit über von Gourlo, dem Schrecklichen, getragen wurde, bot er ein jämmerliches Bild der Verzweiflung.",ep:14,g:37,l:48,wd:true,fm:true,w:30,p:6000};
I.u[2105] = {n:"Blanko-Formular",t:24,d:"Diese Blanko-Formular ist ein Ausbund an Inhaltslosigkeit, der nur darauf wartet, von Welloy Cab ausgefüllt zu werden.",ep:1,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2106] = {n:"Liste der Köder für die Angler",t:24,d:"Ihr sollt diese Köder so schnell wie möglich besorgen.",ep:1,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2107] = {n:"Spezialköder",t:24,d:"Diese Dose mit Spezialködern sieht aus wie eine gewöhnliche Dose Shobäh.",ep:1,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[2108] = {n:"Tabachs Abzeichen",t:24,d:"Dies ist das Abzeichen von Tabach, dem Amtschreiber des Ordens der Tapferen Herzen.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2109] = {n:"Abzeichen von Yba Uhl",t:24,d:"Dies ist das Abzeichen von Yba Uhl, der Amtsschreiberin des Ordens des Rettenden Geistes.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2110] = {n:"Abzeichen von Aidurraff",t:24,d:"Dies ist das Abzeichen von Aidurraff, der Amtsschreiberin des Ordens des Allsehenden Auges.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2111] = {n:"Die Seele des Fischers",t:25,d:"Dieses Buch enthält alle Tipps und Tricks, die man braucht, um ein guter Fischer zu werden.",ep:2,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2112] = {n:"Die Seele des Jägers",t:25,d:"Dieses Buch enthält alle Tipps und Tricks, die man braucht, um ein guter Jäger zu werden.",ep:3,g:1,l:1,wd:true,fm:true,w:1,u:true,p:250};
I.u[2114] = {n:"Unbekanntes Nahrungsmittel",t:15,d:"Dieses Nahrungsmittel ist absolut unbekannt.",ep:1,g:0,l:1,wd:true,fm:true,w:10,p:1};
I.u[2116] = {n:"Rezept zur Herstellung von Nocabregor",t:24,d:"Um Nocabregor herzustellen, werden 3 Prisen Wunderpulver und 1 Löffel voll Elbogs Schmieröl benötigt. Allerdings ist einzig ein Feuerwerker oder ein Zauberer in der Lage, diese Rezeptur anzuwenden, denn hierzu braucht es einen Feuerstein.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2117] = {n:"Zahn des tollwütigen Blutwolfes",t:24,d:"Dieser Zahn wurde tollkühn einem wütenden Wolf abgenommen.",ep:2,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2118] = {n:"Brâkmantel",t:17,d:"Mit diesem Mantel könnt ihr unentdeckt über jeden Friedhof wandern oder euch in eine Chafine verwandeln, wenn euch wieder ein Impuls nach extremen Perversitäten überkommt.",ep:1,g:20,l:1,wd:true,fm:true,w:7,c:"Ps=2",p:800};
I.u[2119] = {n:"Bonta-Umhang",t:17,d:"Dieser Umhang verleiht euch Flüüügel. Der Rauch beim Verbrennen könnte euch sogar noch länger im Schwebezustand dahingleiten lassen.",ep:5,g:34,l:1,wd:true,fm:true,w:3,c:"Ps=1",p:800};
I.u[2120] = {n:"Letzer Wille von Ixa Mustam",t:24,d:"\"Mein Testament befindet sich am Leuchtturm Amaknas. Nimm eine kleine hölzerne Schaufel, um es auszugraben. Und gib meinem Sohn noch eine Ohrfeige von mir!\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2121] = {n:"Tsogs letzter Wille",t:24,d:"\"Unter Weinfässern in einem Tunnel im Osten von Sufokia habe ich eine Schatzkiste versteckt. Ich empfehle Dir, eine kleine hölzerne Schaufel zu benutzen, um sie auszugraben.\"",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2122] = {n:"Einladungsschreiben zur Zeremonie",t:24,d:"Dieser Brief ist versiegelt. Es wäre unhöflich, das Siegel aufzubrechen und ihn zu lesen.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2123] = {n:"Rezeptur zur Herstellung von Sonacixem",t:24,d:"Diese Rezeptur ermöglicht euch die Herstellung von Sonacixem, welches ein hochwirksames magisches Gift zu sein scheint.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2124] = {n:"Ausgefülltes Untersuchungsformular",t:24,d:"Dieses Untersuchungsformular des Typs Nr. 243a wurde von Leonzi Trool ausgefüllt. Dem ersten Anschein nach ist er nicht...",ep:2,g:74,l:1,wd:true,fm:true,w:0,p:1};
I.u[2127] = {n:"Zeurks Brief",t:24,d:"In diesem Brief steht das genaue Ritual zu einem mächtigen Zauberspruch beschrieben, welcher die vollständige Vernichtung der Hohlbainiden zur Folge hätte.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2128] = {n:"Hellsehen",t:31,d:"Ihr könnt hellsehen. Dieser Zustand bleibt solange wirksam, bis ihr wieder einem Kampf beitretet.",ep:6,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2129] = {n:"Büschel von Dike Taraks Haar",t:24,d:"Der schlechte Zustand von Dike Taraks Haar beweist, wie sehr ihr den armen Jungen misshandelt habt.",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2130] = {n:"Oberst Lyeno",t:32,d:"Bringt Oberst Lyeno zu einem Magier in Bonta, um ihn von der mächtigen Verzauberung Weich-Eichs zu erlösen.",ep:9,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2131] = {n:"Steuerliches Dekret Nr. 51-11b",t:24,d:"Dieses unverschämte Dekret verdonnert alle Besitzer oder Verkäufer von alkoholhaltigen Getränken dazu, der Miliz eine Steuer zu entrichten. Und zwar unter dem Vorwand einer Zwangspause.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2132] = {n:"Nibb Tchel\'Schoso",t:32,d:"Befreit Nibb Tchel\'Schoso aus dem Gefängnis von Brâkmar und bringt ihn zu Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2133] = {n:"Scheck der Taverne \"Zur Brennenden Katze\"",t:24,d:"Dieser Scheck deckt die durch die neue Tavernensteuer von Oto Mustam geforderte Summe.",ep:2,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2134] = {n:"Nibb Tug\'tschin",t:32,d:"Befreit Nibb Tug\'tschin aus dem Gefängnis von Bonta und bringt ihn zu Oto Mustam.",ep:16,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2135] = {n:"Scheck der Taverne des \"Betrunkenen Bworks\"",t:24,d:"Dieser Scheck deckt die durch die neue Tavernensteuer von Oto Mustam geforderte Summe.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2136] = {n:"Scheck des Gasthauses \"Bei Djaul\"",t:24,d:"Dieser Scheck deckt die durch die neue Tavernensteuer von Oto Mustam geforderte Summe.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2137] = {n:"Scheck der Taverne \"GothGrotte Nr.13\"",t:24,d:"Dieser Scheck deckt die durch die neue Tavernensteuer von Oto Mustam geforderte Summe.",ep:2,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2138] = {n:"Scheck der Taverne \"Zur Goldenen Larve\"",t:24,d:"Dieser Scheck deckt die durch die neue Tavernensteuer von Oto Mustam geforderte Summe.",ep:2,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[2139] = {n:"Danathors Liste",t:24,d:"- 3 Stücke Apfel Blob \n- 1 Schale \n- 2 Kirschen",ep:2,g:58,l:1,wd:true,fm:true,w:0,p:1};
I.u[2140] = {n:"Briefumschlag",t:24,d:"...",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2141] = {n:"Lunge der Ebenen",t:24,d:"An dieser Halskette hängt ein gewaltiger grüner Diamant, welcher dermaßen hell strahlt, dass sich automatisch die Blicke aller Wesen in der Umgebung auf ihn richten und nicht mehr auf den Träger... Das kann in manchen Situationen sehr praktisch sein.",ep:1,g:66,l:1,wd:true,fm:true,w:0,p:1};
I.u[2143] = {n:"Söldner-Schlüssel",t:15,d:"Dieser Schlüssel verschafft euch Zutritt zu den Söldnern.",ep:1,g:404,l:1,wd:true,fm:true,w:0,p:1};
I.u[2144] = {n:"Gewöhnlicher Pilzhut",t:24,d:"Dieser gewöhnliche Pilzhut ist zwar nicht gerade gut gearbeitet, aber er reicht aus, um sich vor der Sonne zu schützen.",ep:2,g:68,l:1,wd:false,fm:true,w:0,p:1};
I.u[2145] = {n:"Brosche von Sbab",t:24,d:"Diese kleine Brosche wurde euch von Sbab gegeben, und zwar als Anerkennung eures ehrenvollen Verhaltens als Dämon.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2146] = {n:"Geständnis von Oni Tnec",t:24,d:"Dies ist das Geständnis von Oni Tnec, in dem er genau beschreibt, auf welch furchtbare Art und Weise er Rimaraf ermordet hat.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2147] = {n:"Skorpiutgift mit Rechnung",t:24,d:"Dies ist Skorpiutgift mit einer Rechnung auf dem Namen Oni Tnec.",ep:2,g:39,l:1,wd:true,fm:true,w:0,p:1};
I.u[2148] = {n:"Vernehmungsbericht",t:24,d:"Dieser Bericht zählt all die groben Fehler auf, die Oni Tnec begangen hat und die schließlich zu seiner Verhaftung geführt haben.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2149] = {n:"Abzeichen von Oni Tnec",t:24,d:"Das Abzeichen von Oni Tnec wurde an Rimarafs Wohnsitz sichergestellt.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2150] = {n:"Skorpiutkörner",t:58,d:"Diese Körner wurden aus Skorpiutgift hergestellt. Bereits ein einziges ist absolut tödlich. Zwei zu verschlucken, ist demnach doppelt so tödlich.",ep:14,g:405,l:36,wd:true,fm:true,w:1,p:1};
I.u[2151] = {n:"Vergifteter Blobkuchen",t:33,d:"Dieser Kuchen schmeckt hervorragend. Wären nur nicht einige Skorpiutkörner darin enthalten...",ep:3,g:406,l:30,wd:true,fm:true,w:5,p:1};
I.u[2152] = {n:"Oberst Lyeno",t:32,d:"Bringt Oberst Lyeno zu Amayiro.",ep:16,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2153] = {n:"Lyenos Abzeichen",t:24,d:"Dies ist das Abzeichen von Lyeno, das ihr in der Nähe des Gefängnisses gefunden habt, in welchem er festgehalten wurde.",ep:2,g:49,l:1,wd:true,fm:true,w:0,p:1};
I.u[2154] = {n:"Ring von Sendar",t:9,d:"Dieser Ring wurde von Silaisie getragen.",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2155] = {n:"Jiva Medaillon",t:1,d:"Dieses Amulett wurde von Silaisie getragen.",ep:1,g:19,l:1,wd:false,fm:true,w:1,c:"PN~Silaisie",p:1};
I.u[2156] = {n:"Schwert der Gerechtigkeit",t:6,d:"Dieses Schwert verbreitet die Stimme der Wahrheit. Und die will bekanntlich keiner hören...",ep:1,g:16,l:1,wd:false,fm:true,w:1,an:14,e:[30,5,1,1,30,50,false,false],c:"PN~Silaisie",p:1};
I.u[2157] = {n:"Clint Easthut",t:16,d:"Das Modell \"Clint\" ist ein Hut ganz schlicht und ohne Schnickschnack. Aber hochgradig schattenwerfend und imposant. Ein Qualitätsmerkmal.",ep:1,g:38,l:50,wd:true,fm:true,w:10,c:"Ps=3",p:1};
I.u[2158] = {n:"Oto Mustams Brief an Sbab",t:24,d:"Alleiniges Ziel dieses Brief voller Ironie ist es, Sbab zu schmähen und wütend zu machen.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2159] = {n:"Schriftrolle des Mutes",t:14,d:"Diese Schriftrolle erhöht eure Stärke und Tapferkeit. Das kann mitunter ziemlich nützlich sein, wenn beispielsweise ein tollwütiger Kanigrou auf euch zugestürmt kommt.",ep:1,g:2,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2160] = {n:"Schriftrolle der Entmutigung",t:14,d:"Diese Schriftrolle senkt die Stärke und Tapferkeit eines bestimmten Zieles. Das kann mitunter ziemlich nützlich sein, wenn beispielsweise ein tollwütiger Kanigrou auf euren Todfeind zugestürmt kommt.",ep:1,g:4,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2161] = {n:"Schriftrolle der Gelenkigkeit",t:14,d:"Diese Schriftrolle verbessert eure Flinkheit. Das kann mitunter ziemlich nützlich sein, wenn euch beispielsweise das Vorbeihuschen an einem MuWulf zum spontanen und dringlichem Bedürfnis wird.",ep:1,g:6,l:1,wd:true,fm:true,w:1,ut:true,p:200};
I.u[2162] = {n:"Schriftrolle der Steifheit",t:14,d:"Diese Schriftrolle senkt die Flinkheit eines bestimmten Zieles. Das kann mitunter ziemlich nützlich sein, wenn beispielsweise das Vorbeihuschen an einem MuWulf zum spontanen und dringlichem Bedürfnis eures Todfeindes wird und ihr etwas dagegen habt.",ep:16,g:5,l:1,wd:true,fm:true,w:1,ut:true,p:300};
I.u[2163] = {n:"Waffenruhe",t:31,d:"Euch wird niemand angreifen, bis ihr wieder einem Kampf beitretet.",ep:1,g:3,l:1,wd:true,fm:true,w:0,m:true,c:"Ps=0",p:1};
I.u[2164] = {n:"Lavaprobe",t:24,d:"Diese Lavaprobe wurde östlich der Mine gefunden.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2165] = {n:"Lavaprobe",t:24,d:"Diese Lavaprobe wurde westlich der Mine gefunden.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2166] = {n:"Lavaprobe",t:24,d:"Diese Lavaprobe wurde direkt vor der Mine gefunden.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2167] = {n:"Lavaprobe",t:24,d:"Diese Lavaprobe wurde südlich der Mine gefunden.",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[2168] = {n:"Einleitung des Berichtes",t:24,d:"In der Einleitung dieses Berichtes wird beschrieben, dass es beängstigende Änderungen der Konsistenz der Magmaströme von Brâkmar gibt.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2169] = {n:"Raaga",t:32,d:"Geleitet Raaga zu einer vulkanisch aktiven Höhle.",ep:14,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2170] = {n:"Söldnerschwert",t:6,d:"Dieses lange Schwert ist schwer und sehr unhandlich, aber es zerschneidet alles, was ihm in die Quere kommt – ein wenig so, wie es ein langes, schweres und sehr unhandliches Schwert tun würde.",ep:1,g:25,l:1,wd:true,fm:true,w:1,an:14,tw:true,e:[30,5,1,1,25,50,false,false],p:1};
I.u[2171] = {n:"Raagas Bericht",t:24,d:"Dieser Bericht beschreibt ausführlich die spontane, unvorhersehbare vulkanische Aktivität in Brâkmar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2172] = {n:"Liste der zu entnehmenden Proben",t:24,d:"Raaga hat euch genau angewiesen, an welchen Stellen gute Lavaproben entnehmen werden können:\nBleibt bei der Suche innerhalb eines Umkreises von 5 Meilen. Sucht nach kleinen Anhöhen.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2173] = {n:"\"Die geheimnisvolle Sprache der Eichhörnchen\"",t:25,d:"Dieses Lexikon lehrt euch die geheimnisvolle Sprache der Eichhörnchen. Naja, versucht es zumindest. Gebt nicht dem Lexikon die Schuld, sollte es für euch ein Buch mit sieben Siegeln bleiben.",ep:2,g:6,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[2174] = {n:"Passierschein für den Vernehmungsbereich",t:24,d:"Dieses Stück Papier lässt euch durch die Kontrollen durch, so dass ihr euch im Bereichs der Vernehmungsräume des Gefängnisses frei bewegen könnt.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2175] = {n:"Ermahnung des Intendanten",t:24,d:"Dies schriftliche Ermahnung wurde von Danathor geschrieben, um euch daran zu erinnern, in Zukunft seine Nachhut besser zu sichern.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2176] = {n:"Rimarafs Adresse",t:24,d:"Rimaraf wohnt in einem kleinen, roten Ziegelsteinhaus des Schlachtviertels, in der Schnitterstraße 13.",ep:2,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[2177] = {n:"Danathors Brosche",t:24,d:"Diese kleine Brosche wurde euch von Danathor höchstpersönlich überreicht.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2178] = {n:"Untersuchungsformular Nr.36",t:80,d:"Dieses Formular ermöglicht die Identifizierung etwaiger Verdächtigter, die Straftaten begangen haben. \n(Doppelklicken und dann jemanden anklicken, um das Formular anzuwenden.)",ep:16,g:6,l:1,wd:true,fm:true,w:1,c:"PO!2181&PO!2177&Ps=1&Pa=27",ut:true,p:100};
I.u[2179] = {n:"Dracotruterzahn",t:47,d:"Dieser Zahn ist sehr scharf. Er wäre eine gefährliche Waffe in der Hand eines jeden. Bloß gut, dass Dracotruter ihn nur zum Zerbeißen von Schalat einsetzen.",ep:2,g:419,l:20,wd:true,fm:true,w:2,p:1};
I.u[2180] = {n:"Vernehmungsbericht",t:24,d:"Diese Person scheint ein perfektes Alibi zu haben...",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2181] = {n:"Vernehmungsbericht",t:24,d:"Diese Person ist verdächtig. Ihr Alibi ist nämlich nicht haltbar.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2182] = {n:"Visitenkarte des Fahnders",t:24,d:"Ein Fahnder von der Miliz, der mit der Aufklärung der Ermordung Rimarafs betreut ist, überwacht euch, da er euch verdächtigt. Er hat euch seine Visitenkarte dagelassen...",ep:2,g:71,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2183] = {n:"Trank des Vergessens: \"Fischer\"",t:44,d:"Dieser Trank lässt euch den Beruf des Fischers vergessen.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2184] = {n:"Trank des Vergessens: \"Fischhändler\"",t:44,d:"Dieser Trank lässt euch den Beruf des Fischhändlers vergessen.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2185] = {n:"Trank des Vergessens: \"Jäger\"",t:44,d:"Dieser Trank lässt euch den Beruf des Jäger vergessen.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2186] = {n:"Trank des Vergessens: \"Metzger\"",t:44,d:"Dieser Trank lässt euch den Beruf des Metzgers vergessen.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[2187] = {n:"Dichs Sportfischlein",t:41,d:"Dieses Fischlein ist das Produkt der Kreuzung einer Vielzahl von Fischsorten und kann nur im Schwimmbädli von Sufokia geangelt werden.",ep:7,g:400,l:1,wd:true,fm:true,w:20,p:1};
I.u[2188] = {n:"Dichs Fischlein-Angel",t:20,d:"Nur diese Art von Angel kann die kleinen Fischlein aus dem Schwimmbädli von Sufokia fangen.",ep:7,g:8,l:1,wd:true,fm:true,w:2,an:18,e:[1,5,1,5,10,10,false,true],p:50};
I.u[2189] = {n:"Zertifikat für die richtige Stimmabgabe",t:24,d:"Dieses kleine Stück Papier mit der Unterschrift von Satirev Refibrom höchstpersönlich beweist, dass ihr bei einer Urteilsfindung mitgewirkt... und dabei die richtige Stimme abgegeben habt.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2190] = {n:"Untersuchungsformular Nr. 33",t:80,d:"Diese Art Formular wird gewöhnlich gebraucht, um Verdächtige zu identifizieren, die Straftaftaten begangen haben. Jetzt müßt ihr es nur noch ausfüllen, um ein gefälschtes Verhör von \"Oni Tnec\" zu produzieren. \n(Doppelklick und dann auf euch selbst anwenden, um es auszufüllen.)",ep:16,g:6,l:1,wd:true,fm:false,w:1,c:"PO=2177&Ps=1&Pa=27",u:true,p:100};
I.u[2191] = {n:"Zertifikat für die falsche Stimmabgabe",t:24,d:"Dieses kleine Stück Papier mit der Unterschrift von Satirev Refibrom höchstpersönlich beweist, dass ihr bei einer Urteilsfindung mitgewirkt... und dabei die falsche Stimme abgegeben habt.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[2192] = {n:"Gestohlene Dokumente",t:24,d:"Diese streng geheimen Dokumente wurden mit einer Glyphe des Todes versiegelt. Natürlich könntet ihr diese jetzt aufbrechen, doch dann kämt ihr nicht mehr dazu, die Dokumente zu lesen.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2193] = {n:"Büschel von Pujas Haar",t:24,d:"Um dieses Haarbüschel zu erhalten, musstet ihr den Sohn von Oto Mustam erst einmal so richtig verdreschen. Meine Güte, was wird der euch jetzt hassen...",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2194] = {n:"Merkzettel",t:24,d:"10 Astaknydenrinden mitbringen.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2195] = {n:"Zahn",t:24,d:"Dieser Zahn gehört wahrscheinlich euch. Ja, sogar ganz sicher! Er fehlt euch, seitdem Oto Mustam euch eine tüchtige Abreibung gegeben hat. Vielleicht wäre es besser, wenn ihr etwas damit warten würdet, bevor ihr ihn noch einmal ansprecht. So beruhigt er sich vielleicht ein wenig.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[2196] = {n:"Erkenntnis",t:29,d:"Dieser Segen verleiht euch Intelligenz in den nächsten Kämpfen.",ep:18,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2197] = {n:"Scheidung-Entscheidung",t:14,d:"Diese Ringe ermöglichen es, den heiligen Bund der Ehe wiederaufzulösen.",ep:1,g:13,l:1,wd:true,fm:true,w:0,ut:true,p:1};
I.u[2198] = {n:"Schriftrolle der Erkenntnis",t:14,d:"Diese Schriftrolle erhöht eure Intelligenz. Vielleicht hilft euch das, beim nächsten Mal die Ruhe zu bewahren, wenn ihr es mal wieder mit Bworks zu tun habt.",ep:1,g:7,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2199] = {n:"Schriftrolle der Dummheit",t:14,d:"Diese Schriftrolle senkt die Intelligenz eines Zieles. Vielleicht hilft euch das ja, wenn es  eurem Todfeind das nächstes Mal schwer fällt, die Ruhe zu bewahren, wenn er mal wieder mit zwei Bworks zu tun hat.",ep:1,g:8,l:1,wd:true,fm:true,w:1,ut:true,p:1};
I.u[2200] = {n:"Warnung von Satirev Refibrom",t:24,d:"Der oberste Richter von Brâkmar will euch nicht mehr sehen. Es scheint kein Platz mehr in seinem Herzen für euch übrig zu sein... – wenn er denn ein solches hätte.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2201] = {n:"Ausgeglichenheit",t:29,d:"Dieser Segen verleiht euch Weisheit in den nächsten Kämpfen.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2202] = {n:"Senilität",t:30,d:"Dieser Fluch raubt euch Weisheit im nächsten Kampf.",ep:1,g:4,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2203] = {n:"Schriftrolle der Ausgeglichenheit",t:14,d:"Diese Schriftrolle erhöht eure Weisheit. Vielleicht hilft euch das dabei, bald den Dark Vlad im Duell stellen zu können.",ep:1,g:9,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2204] = {n:"Schriftrolle der Senilität",t:14,d:"Diese Schriftrolle senkt die Weisheit eines Zieles. Vielleicht hilft euch das dabei, wenn euer Todfeind glaubt, bald den Dark Vlad im Duell stellen zu können.",ep:1,g:10,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2205] = {n:"Befehlsänderung",t:24,d:"Dieses Papier zeigt an, dass ihr bereits einmal Befehlsänderung durchgeführt habt.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[2206] = {n:"Glücksfall",t:29,d:"Dieser Segen verleiht euch Glück in den nächsten Kämpfen.",ep:18,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2207] = {n:"Gefängnisurkunde",t:24,d:"Auf dieser Urkunde sind alle Straftaten, für die ihr hinter Gitter kamt, mit Datum aufgelistet.",ep:2,g:73,l:1,wd:true,fm:true,w:0,p:1};
I.u[2208] = {n:"Pech",t:30,d:"Dieser Fluch raubt euch Chancen im nächsten Kampf.",ep:1,g:5,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2209] = {n:"Schriftrolle des Glücks",t:14,d:"Diese Schriftrolle erhöht euer Glück. Vielleicht hilft euch das dabei, schneller den Tofu im Heuhaufen zu finden.",ep:1,g:11,l:1,wd:true,fm:true,w:2,ut:true,p:250};
I.u[2210] = {n:"Schriftrolle des Pechs",t:14,d:"Diese Schriftrolle senkt das Glück eines Zieles. Vielleicht hilft euch das dabei, euren Todfeind davon abzuhalten, sein Glück zu machen.",ep:1,g:12,l:1,wd:true,fm:true,w:2,ut:true,p:500};
I.u[2211] = {n:"Iop-Kostüm",t:14,d:"Mit dieser Verkleidung werdet ihr der absolute Star aller Gesellschaftsabende sein. Der einzige Nachteil ist, dass man euch ständig nachsagen wird, ihr wärt gescheit wie ein Iop. Was auch immer das heißen mag...",ep:1,g:14,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2212] = {n:"Xelor-Kostüm",t:14,d:"Mit diesem Hut und gewissen anderen Verkleidungsstücken ist die Ähnlichkeit vollkommen. Ihr seid ein waschechter Xelor, kein Zweifel möglich.",ep:1,g:15,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2213] = {n:"Sadida-Kostüm",t:14,d:"Es braucht nur sehr wenig, wie ein Sadida auszusehen. Einmal zerschlagen frisch vom Bett aufstehen, den Blick ins Leere fahren und den Kopf zwischen den Beinen verknoten. Die Wirkung lässt nicht auf sich warten.",ep:1,g:16,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2214] = {n:"Iop-Look",t:31,d:"Jeder hält euch jetzt für einen Iop, bis ihr einem Kampf beitretet.",ep:1,g:4,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2215] = {n:"Xelor-Look",t:31,d:"Jeder hält euch jetzt für einen Xelor, bis ihr einem Kampf beitretet.",ep:1,g:5,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2216] = {n:"Sadidas Look",t:31,d:"Jeder hält euch jetzt für einen Sadidas, bis ihr einem Kampf beitretet.",ep:1,g:6,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2217] = {n:"Feca-Kostüm",t:14,d:"Dieser Pelzhut stammt geradewegs aus einem alten Speicher. Das sieht man ihm auch an, dank seines klassischen \"Retro\"-Looks. Wahnsinn, wie sehr ihr damit einem Feca gleicht!",ep:1,g:17,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2218] = {n:"Feca-Look",t:31,d:"Jeder hält euch für einen Feca, bis ihr einem Kampf beitretet.",ep:1,g:7,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2219] = {n:"Eniripsa-Kostüm",t:14,d:"Eniripsaflügel befähigen euch nicht zum Fliegen! Macht daher in diesem Aufzug besser keine Luftsprünge vor euren Kameraden, sonst werdet ihr auch noch ausgelacht bei einer Bruchlandung.",ep:1,g:18,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2220] = {n:"Eniripsa-Look",t:31,d:"Jeder hält euch jetzt für einen Eniripsa, bis ihr einem Kampf beitretet.",ep:1,g:8,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2221] = {n:"Enutrof-Kostüm",t:14,d:"Dieser falsche Bart lässt euch wie ein Enutrof aussehen, verleiht euch jedoch auch dessen charakteristischen schlechten Mundgeruch.",ep:1,g:19,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:100};
I.u[2222] = {n:"Enutrof-Look",t:31,d:"Jeder hält euch jetzt für einen Enutrof, bis ihr einem Kampf beitretet.",ep:1,g:9,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2223] = {n:"Sacrieur-Kostüm",t:14,d:"Ein wenig Tofublut, eine falsche Narbe. Dazu noch den typisch psychopathischen Piratenblick aufsetzen, und fertig ist die Verkleidung. Nun könnt ihr selbst an den geheimsten Sacrieur-Treffen teilnehmen, ohne aufzufallen!",ep:1,g:20,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2224] = {n:"Sacrieur-Look",t:31,d:"Jeder hält euch jetzt für einen Sacrieur, bis ihr einem Kampf beitretet.",ep:1,g:10,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2225] = {n:"Sram-Kostüm",t:14,d:"Eine Totenmaske, eine Kapuze über den Kopf, und schon ist die Illusion perfekt. In diesem Aufzug werdet ihr aussehen wie eine verruchte Gestalt, die frisch aus den Tiefen des Friedhofes auferstanden ist: ein Sram eben!",ep:1,g:21,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2226] = {n:"Sram-Look",t:31,d:"Jeder hält euch jetzt für einen Sram, bis ihr einem Kampf beitretet.",ep:1,g:11,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2227] = {n:"Osamodas-Kostüm",t:14,d:"Dieser gegabelte Schwanz und die Hörner werden sicher den geheimen Modegeschmack so manch eines Abenteurers treffen. Probiert es doch einfach einmal an, dann werdet ihr sehen, dass euch dieses Kostüm wie angegossen passt. Damit werdet ihr sogar an den streng geheimen \"Wie-Aie-Pi\"-Treffen der Osamodasanbeter teilnehmen können.",ep:1,g:22,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2228] = {n:"Osamodas-Look",t:31,d:"Jeder hält euch jetzt für einen Osamodas, bis ihr einem Kampf beitretet.",ep:1,g:12,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2229] = {n:"Ecaflip-Kostüm",t:14,d:"Dieses Kostüm besteht aus kuscheligen Ohren aus echtem Wabbitfell, einem getigerten Schwanz und einer Schachtel hungriger Flöhe. Es besteht keine Zweifel daran: spätestens wenn ihr diese heimtückischen Biester an eure Nachbarn weitergegeben habt, wird euch jeder abkaufen, dass ihr ein waschechter Ecaflip seid.",ep:1,g:23,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2230] = {n:"Ecaflip-Look",t:31,d:"Jeder hält euch jetzt für einen Ecaflip, bis ihr einem Kampf beitretet.",ep:1,g:13,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2231] = {n:"Crâ-Kostüm",t:14,d:"Eine Crâ geht nie ohne Köcher aus dem Hause, wie jeder weiß. Also ist es auch kein Wunder, dass euch alle anderen mit diesem Köcher für einen Crâ halten. Es geht doch einfach nichts darüber, die ob ihres Scharfsinnes eingebildeten Bogenschützen so einfach zu täuschen.",ep:1,g:24,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2232] = {n:"Crâ-Look",t:31,d:"Jeder hält euch jetzt für einen Crâ, bis ihr einem Kampf beitretet.",ep:1,g:14,l:1,wd:true,fm:false,w:0,m:true,p:1};
I.u[2233] = {n:"Beißgürtelchen",t:10,d:"Diesen Gürtel bastelten die jungen Füchse Xif und Ixof aus den Zähnen, die bei den Kämpfen auf den Wabbitschlachtfeldern auf den Boden gefallen waren. Seit dieser Zeit ist dieses Basteln bei vielen Abenteurern zur Gewohnheit geworden.",ep:8,g:20,l:28,wd:true,fm:true,w:20,c:"CS<40&CI>80",p:2400};
I.u[2234] = {n:"Bonta-Look",t:31,d:"Jeder hält euch jetzt für einen Bonta, bis ihr einem Kampf beitretet.",ep:1,g:15,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2235] = {n:"Brâkmar-Look",t:31,d:"Jeder hält euch jetzt für einen Brâk, bis ihr einem Kampf beitretet.",ep:1,g:16,l:1,wd:true,fm:true,w:0,m:true,u:true,p:1};
I.u[2236] = {n:"Bonta-Kostüm",t:14,d:"In dieser Verkleidung werden euch sicher alle Reisenden grüßen und manche nach dem Weg befragen.",ep:1,g:25,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2237] = {n:"Brâkmar-Kostüm",t:14,d:"So gekleidet werdet ihr Angst und Schrecken verbreiten.",ep:1,g:26,l:1,wd:true,fm:true,w:10,c:"Pg=10",u:true,p:1};
I.u[2239] = {n:"Eniripsa-Pulver",t:48,d:"Dieses Pulver wird in mühevoller Feinarbeit aus den Flügeln von Eniripsas gewonnen. Es scheint sogar Vertraute heilen zu können",ep:3,g:260,l:1,wd:true,fm:true,w:1,p:1000};
I.u[2240] = {n:"Kleines rotes Feenwerk",t:74,d:"Ideal, um kleine Hochzeitsfeiern zu bereichern, oder für die große Feier der Lederschlüpfer des Chafer-Offiziers.",ep:16,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:350};
I.u[2241] = {n:"Königliches Minzgelee",t:110,d:"Das königliche Gelee hat bereits mehr als einen Abenteurer in den finanziellen Ruin getrieben. Vorsicht, dass es euch nicht auch so ergeht! Denn wenn man einmal auf den Geschmack gekommen ist, mag man es nicht mehr missen.",ep:7,g:408,l:100,wd:true,fm:true,w:1,p:100};
I.u[2242] = {n:"Königliches Erdbeergelee",t:110,d:"Dieses Konzentrat aus königlichem Erdbeergelee kann sogar einen pazifistischen Tabi in eine blutrünstige Mordmaschine verwandeln. Darum solltet ihr es bei einem Empfang besser nicht zum Aperitif servieren.",ep:7,g:409,l:150,wd:true,fm:true,w:1,p:100};
I.u[2245] = {n:"Skorpiutschere",t:47,d:"Einst wurde diese Schere gern verwendet, um sich damit am verlängerten Rücken zu kratzen. Praktischerweise diente sie auch manchmal als Mantelaufhänger an der Wand. Heute wird sie gerne genutzt, um sie in den verlängerten Rücken von Gegnern zu schlagen, was allerdings viel schmerzhafter ist.",ep:14,g:411,l:36,wd:true,fm:true,w:1,p:1};
I.u[2246] = {n:"Zerbrochene Krone des Königlichen Tofus",t:15,d:"Diese Krone wurde bei den aufgetretenen mächtigen magischen Kräfte zerbrochen, oder aber beim letzten Kopfstoß, den euch der Royal Tofu verabreichte, bevor er starb.",ep:3,g:412,l:100,wd:true,fm:true,w:10,p:250};
I.u[2247] = {n:"Feder des Königlichen Tofus",t:53,d:"Nur ein Iop könnte übersehen, dass dies eine Feder des Königlichen Tofus ist. Sie ist eindeutig dicker als andere Tofu-Federn!",ep:3,g:413,l:100,wd:true,fm:true,w:11,p:250};
I.u[2248] = {n:"Ouginak-Haare",t:54,d:"Dieses Haar hält warm. Der Beweis: eure Hand ist schon schweißnass. Es sei denn, dies liegt an eurer Furcht vor den Repressalien des nächsten Ouginaks, der euch mit diesen Haaren in der Tasche entdeckt.",ep:14,g:414,l:51,wd:true,fm:true,w:1,p:1};
I.u[2249] = {n:"Trunknydenblatt",t:36,d:"Dieses Blatt gibt dem Trunknyden seine große Kampfkraft. Doch wer Nutzen daraus ziehen will, muss es auch richtig verwenden. Spinat daraus zu machen, scheint manchmal zum Ziel zu führen. Für einige jedenfalls...",ep:2,g:415,l:35,wd:true,fm:true,w:1,p:1};
I.u[2250] = {n:"Trunknydenholz",t:38,d:"Dieser dicke Ast klingt hohl. Das ist auch kein Wunder, denn das grüne Harz, welches daraus hervorquillt, ist bereits ein deutliches Indiz dafür, dass es sich in Wahrheit um die Nase des Trunknyden handeln muss.",ep:9,g:416,l:35,wd:true,fm:true,w:1,p:100};
I.u[2251] = {n:"Megastein des Krachlers",t:51,d:"Wenn euch ein Mega-Krachler Steine in den Weg legt, dann kracht es aber gewaltig!",ep:5,g:417,l:45,wd:true,fm:true,w:15,p:150};
I.u[2252] = {n:"Goldzahn des Krachlers",t:47,d:"Nachdem ihr dem armen Krachler seinen letzten noch verbliebenen Zahn herausgebrochen habt, weil es ein Goldzahn war, könnt ihr nun mit einem Liedchen auf den Lippen eure Reise fortsetzen. Schade, dass es nur einer war!",ep:5,g:418,l:31,wd:true,fm:true,w:5,p:1};
I.u[2253] = {n:"Omnischlund-Blüte",t:35,d:"Diese Blüte beschleunigt alle Funktionen des Verdauungsapparates. Darum wird sie gerne nach einem Besuch beim Lieblingskoch empfohlen.",ep:12,g:420,l:42,wd:true,fm:true,w:1,p:100};
I.u[2254] = {n:"Heckenschützerblatt",t:36,d:"Heckenschützerblätter haben einen charakteristischen Geschmack, nach einer Mischung aus Nüssen und frischem Schalat. Doch der Nachgeschmack ist hinterhältig... zu spät!",ep:2,g:421,l:22,wd:true,fm:true,w:1,p:1};
I.u[2255] = {n:"Spionagebericht",t:24,d:"Derzeit wenig Aktivität. Stopp. Söldner der Miliz bestürzt über Ermordung eines der Ihren. Stopp. Wespennest. Stopp. Hinweise, dass der Mörder ein Bonta. Stopp und Ende.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2256] = {n:"Überreste einer Kellerratte",t:24,d:"Von dieser Ratte bleibt nicht mehr viel übrig. Eine weniger, die den Eingang der Kanalisation unsicher macht.",ep:2,g:121,l:1,wd:true,fm:true,w:0,p:1};
I.u[2257] = {n:"Mauerstück der Kanalwand",t:24,d:"Dieses Mauerstück der Kanalwand wurde im Magen eines Dingsbums wiedergefunden.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2259] = {n:"Zahn eines Klepprippraubritters",t:47,d:"In den Händen haltet ihr gerade das älteste Spielzeug von ganz Amakna. Die Regeln sind denkbar einfach: Werft einen Zahn in die Luft und fangt ihn mit der selben Hand wieder auf, während ihr einen zweiten Zahn vom Boden aufhebt.",ep:4,g:13,l:16,wd:true,fm:true,w:1,p:20};
I.u[2260] = {n:"Visitenkarte eines Brâks",t:24,d:"Irgendjemand hat diese Visitenkarte unbemerkt in euren Rucksack geschmuggelt. Aller Wahrscheinlichkeit nach ein Brâk... Darauf steht, dass die wahren Krieger von euren Meuchelmörderkünsten stark beeindruckt sind und euch daher anbieten, in Zukunft verrückte Abenteuer auf brâkmarischer Seite zu erleben.",ep:2,g:72,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2261] = {n:"Schnüffelgeist",t:30,d:"Ein Schnüffelgeist verfolgt euch. Er ernährt sich von eurem Körpergeruch und eurer Vitalität.",ep:1,g:7,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2262] = {n:"Beschreibung des Meuchelmörders",t:24,d:"Ihr habt einen nach frischem Blut riechenden Bonta ausfindig gemacht. Alle Informationen, die ihr über diese Person gesammelt habt, stehen nun auf diesem Zettel.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO=2177",p:1};
I.u[2263] = {n:"Bluts Wünschelrute",t:80,d:"Dieser Stecken wird von einem Schnüffelgeist bewohnt. Wenn man diesen Geist frei lässt, wird er geradewegs auf den nächsten Gegenstand zusausen, an dem ein von ihm heißgeliebter Geruch haftet. Anschließend wird er eine Zeitlang dort bleiben und die Umgebung heimsuchen, bevor er wieder im Land der Geister verschwindet.",ep:16,g:25,l:1,wd:true,fm:true,w:10,ut:true,p:1};
I.u[2264] = {n:"Goblinhaut",t:59,d:"Ein Goblin ist eine hinterhältige und schadenfreudige Kreatur. Doch hört all dies plötzlich auf, wenn ihr seine Haut habt. Passt nur auf, nicht zu sehr in seine Haut zu schlüpfen.",ep:4,g:422,l:16,wd:true,fm:true,w:1,p:1};
I.u[2265] = {n:"Beschreibung eines Bontas",t:24,d:"Ihr habt zwar einen Schnüffelgeist entfesselt, jedoch hat dieser das falsche Ziel im Visier gehabt. Ihr habt einige Informationen über die Person auf dieses Stück Papier gekritzelt, um euch später noch daran zu erinnern.",ep:2,g:55,l:1,wd:true,fm:true,w:0,c:"PO!2177",p:1};
I.u[2266] = {n:"Ferkelchen-Milch",t:15,d:"Diese Ferkelchen-Milch stammt wohl von einem Ferkelchen. Wann weiß ja nie, was die anderen denken. Falls ihr gemeint habt, sie käme von einem Tofu, so seid belehrt, dass das nicht wahr ist.",ep:1,g:423,l:18,wd:true,fm:true,w:1,p:1};
I.u[2267] = {n:"Dracomilch",t:15,d:"Diese Dracomilch ist etwas ganz besonderes. Niemand hat jemals einen Schweinedrachen gesehen, der sich freiwillig hätte melken lassen! Daher kann man sich leicht ausmalen, dass es mindestens 7 starke Kämpfer brauchte, ihn festzuhalten, während ein 8. das Melken übernahm.",ep:2,g:424,l:70,wd:true,fm:true,w:2,p:1};
I.u[2268] = {n:"Bwork Bogenschützen-Skalp",t:15,d:"Dieser Skalp könnte glatt eine neue Mode bei den Enutrofs lancieren: den falschen Skalp. Ein bisschen Flohpulver und einmal gut durchkämmen und schon kann man am Schönheitswettbewerb für Mister Universum oder Miss Enutrof teilnehmen!",ep:4,g:425,l:24,wd:true,fm:true,w:1,p:1};
I.u[2269] = {n:"Auge einer blauen Larve",t:24,d:"Dieses Auge einer blauen Larve ist völlig intakt vor eure Füße gerollt. Gut zubereitet, ist Larvenaugenbrei zum Frühstück ein wahrer Festschmaus. Dieses Larvenauge hier wird Oto beweisen, dass ihr tatsächlich eine blaue Larve getötet habt.",ep:1,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2270] = {n:"Larveneiertraube",t:24,d:"Diese Larveneiertraube ähnelt zwar Weintrauben, doch sollte man vorsichtshalber besser nichts davon essen.",ep:1,g:83,l:1,wd:true,fm:true,w:0,p:1};
I.u[2271] = {n:"Violettes Bwork-Leder",t:56,d:"Auch jetzt kursieren noch viele Gerüchte über dieses seltsame Bworkfabrikat. Manche Abenteurer behaupten, die violette Färbung stamme von den Goblins, doch konnte niemand je herausfinden, von welcher Kreatur das Leder selbst stammt. Seltsam.",ep:4,g:426,l:31,wd:true,fm:true,w:1,p:1};
I.u[2272] = {n:"Goldene Larve",t:32,d:"Diese Larve ist soeben aus einem Ei geschlüpft. Da ihr das erste Wesen wart, welches sie erblickte, betrachtet sie euch nun als Mutter Larve.",ep:1,g:5,l:1,wd:true,fm:true,w:10,m:true,p:1};
I.u[2273] = {n:"Purpurgewebe",t:55,d:"Dieses sanfte und glatte Gewebe wurde aus reinstem Purpurstoff gemacht. Auf einem kleinen Schildchen im Inneren steht geschrieben: \"Made in Thai-Waren\".",ep:2,g:427,l:23,wd:true,fm:true,w:1,p:1};
I.u[2274] = {n:"Kerze des Schattenbergmannes",t:15,d:"Nehmt zum Beispiel einen Enutrof in einem Bergwerkstollen. Ohne Licht, sieht man ihn nicht. Beim Schattenbergmann verhält es sich ähnlich, da ihr ihm ja schließlich seine Kerze weggenommen habt.",ep:1,g:428,l:24,wd:true,fm:true,w:10,p:10000};
I.u[2275] = {n:"Lausiges Schweinepriester-Leder",t:56,d:"Der Lausige Schweinepriester wäre beinahe ausgestorben. Tapferen Naturschützer gelang es, Keiler mit Ferkelchen zu kreuzen, um die Ebenen von Cania wieder neu mit dieser Spezies zu bevölkern. Doch seitdem sind diese Kreaturen mit Allem unzufrieden und hören nicht auf sich zu beschweren. Welch schweiniger Charakter!",ep:2,g:429,l:40,wd:true,fm:true,w:10,p:1};
I.u[2277] = {n:"Leichentuch",t:55,d:"Um glaubhafter zu erscheinen, wickeln sich Geister gern in solche Leichentücher ein, um dahergelaufene Abenteurer in Angst und Schrecken zu versetzen.",ep:14,g:430,l:65,wd:true,fm:true,w:1,p:1000};
I.u[2278] = {n:"Unsichtbares Gewebe",t:55,d:"Dieses seltene Gewebe wurde früher gern von Happy Tripper verwendet, um Maulwürfe zu fangen. Doch nahm ihm der charismatische Chafer-Offizier das unsichtbare Gewebe ab, bevor er unter noch nicht geklärten Umständen plötzlich verschwand.",ep:1,g:431,l:23,wd:true,fm:true,w:1,p:1};
I.u[2279] = {n:"Spitzer Zahn",t:47,d:"Dieser Zahn gehörte zweifelsfrei einmal einem Schlängelchen. Das sieht man sofort, weil die leicht gebogene Spitze vorn so unglaublich spitz ist.",ep:3,g:432,l:15,wd:true,fm:true,w:1,p:1};
I.u[2280] = {n:"Vampirstrohhalm",t:15,d:"Unterschätzt niemals einen Vampir. Bloß mit diesem Strohhalm in der Hand könnte er euch bis auf die Knochen aussaugen.",ep:3,g:433,l:22,wd:true,fm:true,w:1,p:1};
I.u[2281] = {n:"Blutiges Gewebe",t:55,d:"Dieses Gewebe sieht beinahe lebendig aus. Vampire benutzen es gern auf Maskenbällen, um die Mode der letzten Jahrhunderte vorzuführen.",ep:3,g:434,l:15,wd:true,fm:true,w:1,p:1};
I.u[2282] = {n:"Büschel weißer Haare",t:15,d:"Dies ist der Beweis, dass sich Monster doch mehr Sorgen machen, als man denkt.",ep:1,g:435,l:24,wd:true,fm:true,w:1,p:1};
I.u[2283] = {n:"Auge eines Kwoans",t:109,d:"Dieses Auge besitzt hypnotisierende Eigenschaften, weshalb man besser ständig ein Auge darauf haben sollte. Obwohl... vielleicht besser doch nicht ...wuff, wau, wau, wuff.",ep:3,g:436,l:8,wd:true,fm:true,w:1,p:1};
I.u[2284] = {n:"Notiz von Larry Stotales",t:24,d:"Der Eingang zur sagenumwobenen Grotte der goldenen Larven befindet sich im Osten Amaknas. Die in der kleinen goldenen Larve schlummernden Kräfte werden es euch gestatten, die Höhle zu betreten. Aber Achtung: sobald sie Schaden erleidet, wirft sie sich sofort in die Arme ihres Vaters.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2285] = {n:"Schattengewebe",t:55,d:"Schattengewebe wurde lange Zeit heiß diskutiert. Denn anfassen wollte sie niemand, da sie beim bloßen Berühren Hautausschlag und Krankheiten verbreiten. Eines Tages fand man die Erklärung dafür heraus, als jemand beobachtete, dass sie von Dämonen als Taschentücher gebraucht wurden.",ep:3,g:437,l:50,wd:true,fm:true,w:1,p:1};
I.u[2286] = {n:"Bandagen",t:15,d:"Diese Bandagen sind revolutionär: dreifache Dicke, Fliedergeruch, extreme Resistenz. Ein echtes Qualitätsprodukt.",ep:2,g:438,l:51,wd:true,fm:true,w:1,p:1};
I.u[2287] = {n:"Schwarzes Leder",t:56,d:"Dieses Leder wurde bereits bearbeitet. Es ist nun zwar nicht mehr auszumachen, von welcher Kreatur dieses Leder einmal stammte, jedoch lässt sich eindeutig bestimmen, dass die Färbung durch einen Spezialfarbstoff erzeugt wurde.",ep:1,g:439,l:74,wd:true,fm:true,w:1,p:1};
I.u[2288] = {n:"Wabbitpfote",t:103,d:"Viele Touristen besuchen die Insel der Wabbits nur, um sich eine Wabbitpfote zu nehmen, da diese Glück bringen soll. Leider trifft dies überhaupt nicht zu... Doch sagt das nicht weiter, die gesamte dort ansässige Tourismusbranche würde sonst zusammenbrechen.",ep:8,g:440,l:18,wd:true,fm:true,w:1,p:1};
I.u[2290] = {n:"Weißer Scarablatt-Panzer",t:107,d:"Man braucht nicht viel, um sich einen wunderschönen neuen Lampenschirm zu basteln. Doch wird es sicherlich noch irgendeine andere Einsatzmöglichkeit für diesen schicken Panzer geben. Wer weiß?",ep:3,g:441,l:32,wd:true,fm:true,w:1,p:1};
I.u[2291] = {n:"Blauer Scarablatt-Panzer",t:107,d:"Man braucht nicht viel, um sich einen wunderschönen neuen Lampenschirm zu basteln. Doch wird es sicherlich noch irgendeine andere Einsatzmöglichkeit für diesen schicken Panzer geben. Wer weiß?",ep:3,g:442,l:32,wd:true,fm:true,w:1,p:1};
I.u[2292] = {n:"Roter Scarablatt-Panzer",t:107,d:"Man braucht nicht viel, um sich einen wunderschönen neuen Lampenschirm zu basteln. Doch wird es sicherlich noch irgendeine andere Einsatzmöglichkeit für diesen schicken Panzer geben. Wer weiß?",ep:3,g:443,l:32,wd:true,fm:true,w:1,p:1};
I.u[2293] = {n:"Grüner Scarablatt-Panzer",t:107,d:"Man braucht nicht viel, um sich einen wunderschönen neuen Lampenschirm zu basteln. Doch wird es sicherlich noch irgendeine andere Einsatzmöglichkeit für diesen schicken Panzer geben. Wer weiß?",ep:3,g:444,l:32,wd:true,fm:true,w:1,p:1};
I.u[2294] = {n:"Scarablatt-Innereien",t:15,d:"Bei oberflächlicher Betrachtung sehen diese Innereien nicht gerade appetitlich aus. Doch mit feinen Gewürzen, wie z.b. ein wenig Wildminze, bringen sie selbst den verwöhntesten Chafer-Feinschmecker in höchste Verzückungen und Zuckungen.",ep:3,g:445,l:32,wd:true,fm:true,w:1,p:1};
I.u[2295] = {n:"Fragment der Reptilklinge",t:15,d:"Mit diesem Fragment der Reptilklinge an der Wand könnt ihr damit prahlen, ein Crocodyll bezwungen zu haben, gleich dem exzentrischen Mick J., dem Crocodyll-Dandy.",ep:4,g:446,l:69,wd:true,fm:true,w:10,p:1};
I.u[2296] = {n:"Reptilhafter Schild",t:15,d:"Wozu könnte bloß dieser wunderschöne, Edelstein verzierte Schild dienen? Bis ihr eine Antwort auf diese Frage findet, könnt ihr ihn ja als Unterlage zum Servieren von Tee benutzen.",ep:4,g:447,l:69,wd:true,fm:true,w:15,p:1};
I.u[2297] = {n:"Armbrustbolzen",t:15,d:"Dieser Bolzen könnte als Rohmaterial für eine kurze, aber scharfe Waffe dienen. Alternativ auch als Zahnstocher, ganz wie es euch beliebt.",ep:1,g:125,l:34,wd:true,fm:true,w:1,p:1};
I.u[2299] = {n:"Dark Vlads Schulterpolster",t:15,d:"Dieses Schulterpolster hat bereits mehr als eine Schlacht erlebt. Auch wenn es nicht sehr stabil aussieht, solltet ihr dennoch vermeiden, den Dark Vlad auf die durch es geschützte Schulter zu schlagen, wenn ihr an eurer Waffe hängt.",ep:2,g:449,l:120,wd:true,fm:true,w:5,p:80};
I.u[2300] = {n:"Knochenfragment",t:47,d:"Dieses Knochenfragment ist entweder der Überrest eines Chaferskeletts aus dem Neolithikum, oder der eines MuWulf-Mahls. Doch könnte es auch weder das Eine, noch das Andere sein.",ep:9,g:450,l:43,wd:true,fm:true,w:1,p:1};
I.u[2301] = {n:"Kolerat-Schnurrbart",t:15,d:"Mit diesem Schnurrbart könnt ihr euch prima verkleiden. Zum Beispiel in einen großen Künstler Brâkmars, wie beispielsweise die Gebrüder Salv und Ador Bali.",ep:2,g:451,l:9,wd:true,fm:true,w:1,p:1};
I.u[2302] = {n:"Krebszunge",t:15,d:"Die führenden Denker von Amkana fragen sich immer noch, wozu man diese Krebszunge wohl einsetzen könnte. Wenn sie die Antwort wüssten, wären sie sicherlich schockiert.",ep:1,g:452,l:4,wd:true,fm:true,w:1,p:1};
I.u[2303] = {n:"Leerer Krebspanzer",t:107,d:"Einmal fachkundig geleert, kann man diesen Krebspanzer mit den unterschiedlichsten Füllungen versehen. Allerdings sollte man immer bedenken, dass alles, was man in den Panzer stopft, für immer und ewig nach Krebs riechen wird.",ep:1,g:453,l:4,wd:true,fm:true,w:2,p:1};
I.u[2304] = {n:"Fragment eines rundgeschliffenen Steines",t:51,d:"Dieses Fragment stammt aus der linken Pobacke eines Krachlers der Ebenen. Es gibt nichts besseres, um kleine Arachneen zu zermalmen. Außer vielleicht den früheren Besitzer dieses Fragments.",ep:5,g:454,l:45,wd:true,fm:true,w:5,p:1};
I.u[2305] = {n:"Fragment eines spitzen Steines",t:51,d:"Dieses Fragment stammt aus dem rechten Schulterblatt eines Krachlers der Ebenen. Es sei denn, es handelt sich um ein Rippenstück. Auf jeden Fall sollte man dieses Steinfragment besser nicht grob fahrlässig irgendwohin positionieren.",ep:5,g:455,l:45,wd:true,fm:true,w:5,p:1};
I.u[2306] = {n:"Krachlerherz",t:51,d:"Herz aus Stein, siehst Du nicht die Liebe, die ich Dir entgegenbring? Doch lässt du mich fallen, so will ich nicht eher ruhen, bis du zerspringst!",ep:5,g:456,l:45,wd:true,fm:true,w:5,p:1};
I.u[2307] = {n:"Schild des Chafer Lanzenträgers",t:24,d:"...",ep:2,g:75,l:1,wd:true,fm:true,w:0,p:1};
I.u[2308] = {n:"Brâkmar-Abzeichen",t:24,d:"Dieses Abzeichen dient dazu, Kämpfer der Brâkmarianer unter den Toten eines Schlachtfeldes zu identifizieren. Allerdings gibt es derzeit auch in Bonta den Trend, solche Abzeichen zu sammeln.",ep:2,g:76,l:1,wd:true,fm:true,w:0,p:1};
I.u[2309] = {n:"Rote Kerze",t:24,d:"Eine eigenartige rote Kerze...",ep:1,g:77,l:1,wd:true,fm:true,w:0,p:1};
I.u[2310] = {n:"Grüne Kerze",t:24,d:"...",ep:2,g:78,l:1,wd:true,fm:true,w:0,p:1};
I.u[2311] = {n:"Blaue Kerze",t:24,d:"...",ep:2,g:79,l:1,wd:true,fm:true,w:0,p:1};
I.u[2312] = {n:"Blutspulver",t:24,d:"...",ep:2,g:80,l:1,wd:true,fm:true,w:0,p:1};
I.u[2313] = {n:"Wasseratmungsgerät",t:24,d:"...",ep:2,g:81,l:1,wd:true,fm:true,w:0,p:1};
I.u[2314] = {n:"Phiole von Jiva",t:24,d:"...",ep:2,g:82,l:1,wd:true,fm:true,w:0,p:1};
I.u[2315] = {n:"Blutwolfhaare",t:54,d:"Brijiht Barklo hatte einst ein Verbot durchgebracht, junge Blutwölfe zu jagen. Doch seitdem sie wieder auf Moon im Exil ist, geht die Jagd ungehemmt weiter, und die Schneider bereichern sich weiter am Verkauf wertvoller Pelzmäntel.",ep:1,g:196,l:19,wd:true,fm:true,w:1,p:1};
I.u[2316] = {n:"Gelber Fangzahn",t:47,d:"Die gelben Fangzähne des Blutwolfes sind ein Zeichen für dessen schlechte Mundhygiene. Kein Wunder, dass er Angst und Schrecken verbreitet.",ep:1,g:458,l:19,wd:true,fm:true,w:1,p:1};
I.u[2317] = {n:"Wolfsohren",t:106,d:"Wenn man sich diese Ohren genauer ansieht, so kann man sich durchaus fragen, wie in aller Welt ein Blutwolf damit noch irgendetwas hören kann, mit all dem Dreck und den Viechern, die darin herumkrabbeln.",ep:1,g:459,l:19,wd:true,fm:true,w:1,p:1};
I.u[2318] = {n:"Bärentatze",t:103,d:"Manche Goblinstämme tragen solche Bärentatzen als Amulett um den Hals. Warum weiß niemand genau. Wohl aufgrund eines uralten, längstvergessenen Aberglaubens.",ep:1,g:460,l:12,wd:true,fm:true,w:1,p:1};
I.u[2320] = {n:"Gerissene Ouginak-Kette",t:15,d:"Wie bei jedem Ouginak enthält diese Halskette alle notwendigen Informationen über das Monster. Auf diesem hier steht zu lesen: \"Ich habe mich verlaufen. Meine Hütte befindet sich neben der Straße durch die Sidimotelande. Bitte bringt mich zu meinem brâkmarischen Herrschen zurück, der euch für eure Mühen sicher gern ein paar Ohrfeigen geben wird.\"",ep:14,g:462,l:51,wd:true,fm:true,w:5,p:1};
I.u[2321] = {n:"Ouginak-Lefzen",t:15,d:"Irgendwie werdet ihr den Eindruck nicht los, dass die Lefzen des Ouginaks gar nicht mehr aufhören, Speichelfäden zu ziehen. Diese Viecher sind für ihren unendlichen Appetit berühmt-berüchtigt!",ep:14,g:463,l:51,wd:true,fm:true,w:1,p:1};
I.u[2322] = {n:"Rattenfangzähne",t:47,d:"Auf den ersten Blick scheint es sich hier bloß um ausgefallene Milchzähnchen zu handeln... Doch sind es in Wahrheit die abgenutzten, übelriechenden und geschärften Fangzähne eine Ratte. Sie dienen den Enutrofs manchmal als Zahnersatz, wenn sie zu geizig sind, sich Goldzähne zu leisten.",ep:1,g:464,l:50,wd:true,fm:true,w:1,p:1};
I.u[2323] = {n:"Wirbelsäule",t:47,d:"Diese Wirbelsäule ist in sehr gutem Zustand. Doch ist das noch lange kein Grund, euch den Rücken kaputtzumachen!",ep:1,g:465,l:34,wd:true,fm:true,w:2,p:1};
I.u[2324] = {n:"Wassermelone",t:46,d:"...",ep:1,g:466,l:1,wd:true,fm:true,w:2,p:1};
I.u[2325] = {n:"Banane",t:46,d:"Einst schrieb Geror Lendorman zu Ehren dieser Frucht eine ganze Ode. Der Titel lautet: \"Die Banane der glücklichen Menschen\".",ep:1,g:467,l:1,wd:true,fm:true,w:1,p:1};
I.u[2326] = {n:"Orange",t:46,d:"...",ep:1,g:468,l:1,wd:true,fm:true,w:1,p:1};
I.u[2327] = {n:"Apfel",t:46,d:"...",ep:1,g:469,l:1,wd:true,fm:true,w:1,p:1};
I.u[2328] = {n:"Kleine goldene Perle",t:15,d:"Diese kleine goldene Perle ist ein Geschenk der kleinen goldenen Larve, die euch begleitet hat. Sie besitzt daher einen großen Liebhaberwert. So glatt und glänzend wie sie ist, wäre sie das ideale Geschenk für jedes weibliche Wesen.",ep:5,g:483,l:1,wd:true,fm:true,w:1,p:1};
I.u[2329] = {n:"Birne",t:46,d:"...",ep:1,g:470,l:1,wd:true,fm:true,w:1,p:1};
I.u[2330] = {n:"Explosive Kapsel",t:15,d:"Diese Kapsel enthält magische Zitrusfrüchte. Darum sollte man sie erst schütteln, wenn man nicht möchte, dass das gesamte Fruchtfleisch am Boden kleben bleibt.",ep:4,g:711,l:23,wd:true,fm:true,w:1,p:1};
I.u[2331] = {n:"Aubergine",t:46,d:"Dieses Gemüse ist nicht sehr nahrhaft. Daher wird es meist noch von Gewürzen begleitet. Doch trotz seines schlechten Rufes sollen Auberginen sehr gut für die Gesundheit sein. Außer für Bworks, doch weiß niemand warum...",ep:1,g:472,l:1,wd:true,fm:true,w:1,p:10};
I.u[2332] = {n:"Trostbonbon",t:42,d:"Dank dieses Trostbonbons könnt ihr eure Tränen zurückhalten.",ep:13,g:135,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2333] = {n:"Übermächtiges rotes Bonbon",t:42,d:"Dieses Bonbon wird eure Aufmerksamkeit im Kampf stärken, da es einen wirklich furchtbaren Geschmack besitzt und so klebrig ist, dass man es nicht mehr los wird, bevor es sich aufgelöst hat. (Doppelklick, um es zu verwenden.) Es verleiht dem Anwender +20 in Weisheit und +10 in Filzen für die Dauer der nächsten 30 Kämpfe.",ep:1,g:136,l:1,wd:true,fm:false,w:1,c:"PO!1723",u:true,p:1};
I.u[2336] = {n:"Chafer-Schädel",t:47,d:"Dieser Schädel wird nie wieder klappern... Obwohl, wer weiß das schon mit Bestimmtheit?",ep:1,g:480,l:16,wd:true,fm:true,w:1,p:1};
I.u[2337] = {n:"Magisches Buch",t:25,d:"Dieses Buch scheint magisch zu sein. Seltsam.",ep:1,g:7,l:1,wd:true,fm:true,w:1,p:50};
I.u[2338] = {n:"Altes Buch",t:25,d:"...",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[2339] = {n:"Liste der Standardausrüstung",t:24,d:"Ein gewöhnlicher Krieger, der etwas auf sich hält, sollte weder Lumpen tragen, noch zu farbenfrohe Kleidung. Eine gute Auswahl wäre demnach:\n- ein Caméering am Mittelfinger\n- ein Band und ein Gürtel der Vitalität\n- Kluhschuhe\n- ein Brâkmantel.",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[2340] = {n:"Unterhose des Milizionärs",t:24,d:"Dies ist tatsächlich die Unterhose eines Milizionärs. Ihr müsst wirklich ein ganz schön verdorbener Fetischist sein, um so etwas zu besitzen. Oder jemand hat euch einen Streich gespielt.",ep:2,g:84,l:1,wd:true,fm:true,w:0,p:1};
I.u[2341] = {n:"Mech Riorraws Bogen",t:2,d:"Dieser Bogen wurde von Mech Riorraw erbaut. Er ist solcherart austariert, dass man damit über den Lavafluss hinwegschießen und Ziele hoch oben auf den Zinnen der Mauern von Brâkmar treffen kann, nicht mehr und nicht weniger.",ep:16,g:8,l:10,wd:true,fm:true,w:100,an:10,tw:true,e:[0,6,20,21,0,30,false,true],c:"Ps=1",p:0};
I.u[2342] = {n:"Ring der Loyalität",t:24,d:"Dieser Doppelring wurde euch von Domen höchstpersönlich als Anerkennung für eure Loyalität überreicht. Doch würde die Rückgabe dieses Ringes bedeuten, dass ihr für die ultimative Zerstörung von Allem seid. Damit könnte man euch tatsächlich sogar zu den Anhängern von Djaul zählen.",ep:2,g:86,l:1,wd:true,fm:true,w:0,p:1};
I.u[2343] = {n:"Djauls Armband",t:24,d:"Dieses Armband wurde euch von Djaul gegeben. Die Tatsache, dass ihr es tragt, spricht dafür, dass ihr seinen Worten und Taten zustimmt.",ep:2,g:85,l:1,wd:true,fm:true,w:0,p:1};
I.u[2344] = {n:"Brief für Oto",t:24,d:"Dieser Brief für Oto wurde euch von Domen mitgegeben.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2345] = {n:"Schildkrötenauge",t:24,d:"Diese neunmalkluge Schildkröte wird nun nicht mehr den Dicken Molly machen.",ep:2,g:70,l:1,wd:true,fm:true,w:0,p:1};
I.u[2346] = {n:"Halsabschneider-Kostüm",t:14,d:"Nein, dies ist nicht das berühmt-berüchtigte Kostüm von Dracovampi, der fliegenden Fledermaus. Dies ist die Bekleidung eines der Bewohner des Friedhofes, eines Halsabschneiders von zwielichtigem Ruf.",ep:1,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[2347] = {n:"Missionsbericht",t:24,d:"Dieser Missionsbericht beschreibt peinlich genau, wie der Angriff auf Brâkmar über die Ostmauer verlaufen ist.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2348] = {n:"Halsabschneider Look",t:31,d:"Jeder hält euch für einen Halsabschneider. Dies bleibt solange wirksam, bis ihr einem Kampf beitretet.",ep:1,g:17,l:1,wd:true,fm:false,w:0,m:true,u:true,p:1};
I.u[2349] = {n:"Brief für Oto",t:24,d:"Dieser Brief für Oto wurde euch von Domen mitgegeben. Doch habt ihr vergessen, ihn auszuhändigen.",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2350] = {n:"Büschel Haare",t:24,d:"Es scheint, als habe dieses Büschel Haare einem eurer Gegner gehört.",ep:2,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[2351] = {n:"Brot des \"G\'smörtnbröd\"",t:33,d:"In diesem Brot steckt sowohl flüssige, als auch feste Nahrung. Und selbst in getrocknetem Zustand füllt es einen Bierkrug vollständig aus.",ep:16,g:13,l:1,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[2352] = {n:"Brief von Danathor",t:24,d:"\"Ich muss mit Dir reden. Komm allein, sobald Du etwas Zeit hast. Bis bald, mein junger Freund.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2353] = {n:"Brief von Larry Poller",t:24,d:"\"Hallo, mein Name ist Larry Poller. Wir sind uns bei der Befreiung von Oberst Lyeno begegnet. Ich hätte da noch eine kleine Aufgabe für euch... Kommt doch einfach vorbei, sobald ihr einen Augenblick Zeit habt. Bis bald.\"",ep:2,g:65,l:1,wd:true,fm:true,w:0,p:1};
I.u[2354] = {n:"Schildkrötenhirn",t:24,d:"Dieses Schildkrötenhirn lässt sich zu einem Festmahl verarbeiten, wenn es richtig zubereitet wird.",ep:2,g:89,l:1,wd:true,fm:true,w:0,p:1};
I.u[2355] = {n:"Onipulver",t:24,d:"Dieses blaue Pulver ist ein extrem mächtiger magischer Katalysator.",ep:2,g:88,l:1,wd:true,fm:true,w:0,p:1};
I.u[2356] = {n:"Wunder",t:31,d:"Ihr habt nun wunderliche Kräfte. Jedenfalls solange, bis ihr wieder einem Kampf beitretet.",ep:13,g:19,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2357] = {n:"Oliviolettaholz",t:38,d:"Dieses Holz ist scheinbar in der Lage, allen Temperaturen zu trotzen. Also versucht besser erst gar nicht, ein Feuer damit anzufachen, sonst erfriert ihr vorher noch.",ep:14,g:481,l:50,wd:true,fm:true,w:5,p:0};
I.u[2358] = {n:"Bombussholz",t:38,d:"Dieses Holz gehört zu den weichesten Hölzern überhaupt. Deshalb lässt es sich ganz nach Belieben formen und ist kinderleicht zu bearbeiten.",ep:13,g:482,l:50,wd:true,fm:true,w:5,p:0};
I.u[2359] = {n:"Brosche von Heticili Ufot",t:24,d:"Diese kleine Brosche wurde euch von Heticili Ufot überreicht.",ep:2,g:69,l:1,wd:true,fm:true,w:0,p:1};
I.u[2360] = {n:"Eigentumsurkunde",t:24,d:"Diese Urkunde bestätigt, dass das Haus Heticili Ufot gehört.",ep:2,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[2361] = {n:"Bogen von Mulic Bere",t:2,d:"Dieser Bogen ist eine Erfindung des genialen Erfinders Mulic Beres. Seine maximale Reichweite ist einfach nur unglaublich. Das Problem dabei ist nur, dass die minimale Reichweite beinahe genauso weit ist.",ep:16,g:10,l:10,wd:true,fm:false,w:100,an:10,tw:true,e:[0,6,17,23,0,30,false,true],p:0};
I.u[2362] = {n:"Wahrsagung von Paro Cabanne",t:24,d:"Dies ist die Wahrsagung von Paro Cabanne über die nächsten Wahlen.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[2365] = {n:"Blatt der Hestia-Ranke",t:36,d:"Dieses Rankenblatt sieht zwar gewöhnlich aus, doch ist es absolut unverzichtbar bei manchen seltsamen Rezepturen.",ep:16,g:415,l:1,wd:true,fm:true,w:1,p:1};
I.u[2366] = {n:"Krakamorangel",t:20,d:"Diese Angel besteht ganz aus Metall und Diamant. Nur so ist sie in der Lage, das Gewicht der schweren Krakamors auszuhalten. Zusätzlich ist sie noch mit dem Geruch einer Krakamora impregniert worden, was die Chance, dieses Monster aus dem Wasser zu holen, beträchtlich erhöht.",ep:1,g:8,l:1,wd:false,fm:true,w:10,an:18,e:[2,6,1,9,30,30,false,false],p:1};
I.u[2367] = {n:"Gürtel von Tausendundeiner Schlacht",t:10,d:"Dieser schicke Gürtel ist wunderbar für große Maskenbälle geeignet, obwohl man ihm nachsagt, bereits bei mehr als 1.000 Kämpfen dabei gewesen zu sein. Oder ging es dabei um Gelage und das Schlachten von Geflügel? So genau weiß dies niemand mehr. Doch eines ist klar: in beiden Fällen waren wertvolle Edelsteine mit im Spiel.",ep:8,g:21,l:37,wd:true,fm:true,w:20,c:"CW>49&Ps=1",p:3700};
I.u[2368] = {n:"Ramum, die Ewige",t:10,d:"Ramum war eine Kindheitsgefährtin von Nova, doch sie haben sich wieder aus den Augen verloren, als Ramum beschloss, ihren Schönheitsschlaf zu halten. Da Schönheit nicht ewig währt, sie aber schon, könnte dies lange Zeit in Anspruch nehmen...",ep:2,g:22,l:37,wd:true,fm:true,w:50,c:"CW>49&Ps=2",p:1000};
I.u[2369] = {n:"Mächtig funkelnder Gürtel",t:10,d:"Dieser wunderschöne Gürtel entstand nach einer verrückten Wette. Es wurde gewettet, dass sich einer der besten und mächtigsten Gürtel von ganz Amakna noch weiter verbessern ließe, nämlich der Funkelnde Gürtel. Pakape Prométhé nahm die Wette an und gewann. Dies ist das Ergebnis.",ep:2,g:26,l:80,wd:true,fm:true,w:150,p:300000};
I.u[2370] = {n:"Vegagürtel",t:10,d:"Dieses unglaublich leichte Ausrüstungsstück wird eine kleine Prise Finesse in diese grobe Welt voller brünftiger Bworks tragen.",ep:2,g:23,l:41,wd:true,fm:true,w:5,c:"CA>50",p:4575};
I.u[2371] = {n:"Pauls Vermöbelgürtel",t:10,d:"Dieser Gürtel ist besonders in klammen, kalten Nächten von Vorteil. Außerdem braucht ihr euch nicht mehr darum zu sorgen, dass euch jemand vermöbeln könnte, da ihr mit Pauls Gürtel davor gut geschützt seid. Ein wahres Multitalent eben.",ep:13,g:24,l:27,wd:true,fm:true,w:30,p:2775};
I.u[2372] = {n:"Lymphs Stiefel am Tisch",t:11,d:"Diese Stiefel geben einem den Eindruck, als liefe man durch frisches Gras. Daher sind sie ideal für alle, deren Fussgeruch mehr an einen kranken Bwork, als an ein Minzgelee erinnert. Daher darf man sie selbst am Tisch anbehalten. Ausnahmsweise.",ep:5,g:18,l:39,wd:true,fm:true,w:5,c:"CC>50",p:4100};
I.u[2373] = {n:"Moon-Boots",t:11,d:"Moons Haar, welches notwendigerweise zur Konfektion dieser Stiefel erforderlich ist, gehört wohl zu den Materialien, die am besten von allen die Füße wärmen. Zudem wird euch dadurch bei der Erinnerung an Moon sicher ganz warm ums Herz.",ep:14,g:19,l:62,wd:true,fm:true,w:30,p:10000};
I.u[2374] = {n:"Hains Siedlerstiefel",t:11,d:"Hain lebte zurückgezogen in einer kleinen Hütte tief im Wald der Astaknyden. Er hasste Besuch und sah jede andere Kreatur als Störenfried an, wobei er ihnen die genaue Größe seiner Stiefel aus der Nähe zu zeigen pflegte.",ep:4,g:20,l:38,wd:true,fm:true,w:40,p:4000};
I.u[2375] = {n:"HNO-Stiefel",t:11,d:"Dank dieser Stiefel werden all eure versteckten und verstopften Sinne wieder geschärft. Mit ihnen werdet ihr hören können, wie der Wind die Segel eines Schiffes auf den Weiten des Assel-Meeres füllt. Auch der faulige Geruch, der den Stiefeln des Bwork-Chefs entströmt, wird euch nicht entgehen.",ep:13,g:21,l:77,wd:true,fm:true,w:40,p:15500};
I.u[2376] = {n:"Blutaxt des Grauens",t:19,d:"Diese Axt ist die einzige, die den furchtbaren Kräften des \"Kaerliers\" standhalten kann, und daher auch die einzige, mit der er sich schneiden lässt.",ep:1,g:18,l:1,wd:true,fm:true,w:10,e:[5,6,1,1,45,45,false,false],c:"PJ>2,79",p:1};
I.u[2378] = {n:"Felsnasenblut",t:51,d:"Dieses flammend rot gefärbte Gestein ermöglicht die Herstellung sehr machtvoller Tränke.",ep:16,g:459,l:1,wd:true,fm:true,w:0,p:1};
I.u[2379] = {n:"Holz des Kaerliers",t:38,d:"Dieses Holz stammt vom ultraseltenen Kaerlier. Seine Eigenschaften sind eher... seltsam.",ep:14,g:140,l:40,wd:true,fm:true,w:5,p:20};
I.u[2380] = {n:"Schlämmmäntelchen",t:17,d:"Dieser seltsame Mantel wurde aus Schlammresten von Blubbis gefertigt. Bisher ist noch niemand dahintergekommen, weshalb er stehenbleibt, wenn man ihn auszieht.",ep:13,g:35,l:41,wd:true,fm:true,w:10,p:4500};
I.u[2381] = {n:"Schwebemantel",t:17,d:"Dieser Mantel wurde aus einem Gimpel herausgeschnitten, der ehemals auf der obersten Zinne der höchsten Burg von Amakna flatterte. Das ist sicher auch der Grund dafür, warum dem Mantel ein himmlisch feiner Geruch nach offenem Himmel anhaftet.",ep:5,g:36,l:61,wd:true,fm:true,w:10,c:"CI>90",p:9500};
I.u[2382] = {n:"Uhms Hang und Fuß",t:17,d:"Uhm war ein tollkühner Ecaflip, der sich rühmte, immer auf seinen Pfoten zu landen, egal aus welcher Höhe er auch fallen möge. Doch eines Tages fiel er einem hungrigen Trool vor die Füße, was diesem sehr gefiel. Am Ende des auffallend kurzen und einseitigen Gemetzels vervielfältigten sich seine Körperteile in bedenklichem Maße. Man begrub ihn überall dort, wo man seine Überreste fand. Also ein wenig überall verstreut. Vielseitig bis in den Tod.",ep:14,g:37,l:36,wd:true,fm:true,w:10,p:6500};
I.u[2383] = {n:"Mantel des Blutes",t:17,d:"Dieser aus reinem Blutgewebe gewobene Mantel fühlt sich seltsam an. So als wäre die rötliche Färbung im Laufe der Zeit geronnen.",ep:7,g:38,l:50,wd:true,fm:true,w:10,c:"CS>90",p:6000};
I.u[2384] = {n:"Tierische Stiefel",t:11,d:"Man könnte beinahe behaupten, diese Stiefel hätten einen gewissen... tja... bestialischen Look. Darum solltet ihr nicht überrascht sein, wenn sich ein WuWulf in euch und eure Stiefel verliebt! Möglicherweise gehört dies zu den schlimmsten Erfahrungen, die man überhaupt machen kann.",ep:14,g:22,l:94,wd:true,fm:true,w:40,p:23000};
I.u[2385] = {n:"Grasena",t:17,d:"Grasena ist nicht nur ideal für euren Garten, sondern kann notfalls auch noch als Fußabtreter vorm Eingang des Hauses dienen. Dieser von Sadidas für Sadidas angefertigte Umhang wird niemandem auch nur ein Haar krümmen und euch haarklein alles Unerklärliche erklären. Zudem werdet ihr damit anderen Sadidas bis aufs Haar gleichen.",ep:12,g:39,l:88,wd:true,fm:true,w:10,p:20000};
I.u[2386] = {n:"Lumpenhülle",t:17,d:"Dieser seltsame Umhang bezieht all seine Kraft aus seinem heruntergekommenen Aussehen. Drum behaltet für ihn folgenden Merkspruch immer im Hinterkopf: \"Je schmutziger, desto nützlicher!\"",ep:13,g:40,l:53,wd:true,fm:true,w:10,p:7000};
I.u[2387] = {n:"Umhaarang",t:17,d:"Zugegeben, dieser Mantel riecht sehr streng. Geht man der Sache näher nach, so stellt man fest, dass der schlimme Geruch wohl von der Mischung aus vielerlei Monsterhaaren haariger Monster stammt. Ein echtes Potpourri eben.",ep:14,g:41,l:63,wd:true,fm:true,w:10,c:"CW>30&CV>50",p:10500};
I.u[2388] = {n:"Amulett des Krallenrätsels",t:1,d:"Eines Tages zerschlug ein Ecaflip namens Dodge eine steinerne Schatzkarte in tausend Teile. Anschließend puzzelte er. Als er dachte, die ursprüngliche Karte wiederhergestellt zu haben, fertigte er daraus dieses mysteriöse Amulett an. Niemand weiß hingegen, was aus dem Schatz wurde.",ep:14,g:36,l:44,wd:true,fm:true,w:5,p:4000};
I.u[2389] = {n:"Amulett von Badoul",t:1,d:"Dodge liebte es, alles zu zerstören, was in seinen Augen wertvoll erschien. Seiner Ansicht nach war dies der Beweis für seine Existenz. Jedem das seine...",ep:14,g:37,l:32,wd:true,fm:true,w:5,p:3200};
I.u[2390] = {n:"Glückskugel",t:1,d:"Dieses Medaillon ist so gut wie vollkommen. Es erhöht beträchtlich die Weisheit seines Trägers. Das ist sehr nützlich, um bei euren Freunden weise zu erscheinen, oder so zu tun, als wärt ihr ein Musterschüler.",ep:5,g:38,l:49,wd:true,fm:true,w:1,p:6400};
I.u[2391] = {n:"Glückskügelchen",t:1,d:"Eine alte Redensart von Sufokia besagt: Eines guten Tages die Glückskugel, an besseren Tagen die Glückskügelchen. Daran lässt sich empirisch einmal mehr feststellen: je älter die Redensart, desto lächerlicher und unzutreffender ist sie zwangsläufig.",ep:5,g:39,l:98,wd:true,fm:true,w:1,p:24400};
I.u[2392] = {n:"Modifizierte Dracoleier",t:1,d:"Dank der vielfältigen Talente der Handwerksmeister von Amakna zeichnet sich die modifizierte Dracoleier durch ihre Vollkommenheit aus.",ep:11,g:25,l:42,wd:true,fm:true,w:1,p:5000};
I.u[2393] = {n:"Omelett-Amulett",t:1,d:"Der Osamodas Ohnei wollte unbedingt vor den Augen der Mitglieder seiner Gilde groß dastehen, was ihn dazu bewog, ein revolutionäres Amulett anzufertigen. Die Idee kam ihm, während er seinen Freunden ein Frühstück zubereitete. Seltsam, nicht war?",ep:1,g:40,l:17,wd:true,fm:true,w:10,p:1000};
I.u[2394] = {n:"Knospenkettchen",t:1,d:"Vollgetankt mit Sonnenstrahlen, erwärmt das Knospenkettchen das Herz seines Trägers und vermittelt ihm ein Gefühl von Erdverbundenheit und Naturliebe. Es ist derart angenehm und leicht zu tragen, dass man mitunter glatt vergisst, es zum Schlafen abzulegen.",ep:9,g:41,l:32,wd:true,fm:true,w:1,p:3000};
I.u[2395] = {n:"Lard Fous Halstuch",t:1,d:"Lard Fou war ein kleiner, bösartiger Dämon, der es liebte, sich vor andere Personen hinzupflanzen und sich dann nicht mehr zu bewegen. Er ist sehr magie-resistent, was zu dieser Zeit großen Respekt gebot. Seit dieser Zeit hat sich Lard Fou irgendwo verkrochen und wartet.",ep:8,g:42,l:42,wd:true,fm:true,w:15,p:5000};
I.u[2396] = {n:"Lams Pione",t:1,d:"Sylveline gehörte nie zu den gescheitesten. Ihre Mutter, Lam, schenkte ihr eines Tages diese Pione und sagte: \"Hier. Wenigstens Du sollst eine Leuchte werden!\" Sie war ja selbst auch keine. Mit diesem Geistesblitz erleuchtete sie ihre Tochter und beschien ihr den Weg in ein neues Leben.",ep:7,g:43,l:15,wd:true,fm:true,w:5,p:1500};
I.u[2397] = {n:"Das Bibbelaw",t:1,d:"Law Bibbe war ein alter Mann, der es liebte, irgendwelche Gegenstände zu seltsamen Objekten zusammenzufügen. Eines Tages erschuf er also dieses seltsam geformte Medaillon. Als er es sich anlegte, verspürte er ein merkwürdiges Kribbeln im ganzen Körper. Ein sehr seltsames Gefühl war das...",ep:13,g:44,l:30,wd:true,fm:true,w:10,p:3000};
I.u[2398] = {n:"Das Auge des Kanigrous",t:1,d:"Dieses Auge wurde Melyonen vom berüchtigten Kanigrou Rook Y Balboua geschenkt, und zwar als Dankeschön dafür, dass sie ihm seine jetzige Frau Ar d\'rieeeeeeeeeneuh vorgestellt hatte.",ep:13,g:45,l:52,wd:true,fm:true,w:1,p:7000};
I.u[2399] = {n:"Weichkalbband",t:1,d:"Jozebo Vez war ein Kalbszüchter, also von entfernten Verwandten der Fresssäcke. Innerhalb seiner Herde gab es nun einige Tiere mit einem viel weicheren Fell als die anderen. Diese ließen sich zu einem viel höheren Preis verkaufen, weshalb er sie mit diesem Halsband markierte.",ep:13,g:46,l:15,wd:true,fm:true,w:1,p:1};
I.u[2400] = {n:"Dunkle tierische Stiefel",t:11,d:"Man könnte beinahe behaupten, diese Stiefel hätten eine gewisse... dunkle Seite. Darum solltet ihr nicht überrascht sein, wenn sich ein Vampir in euch und eure Stiefel verliebt! Möglicherweise ist dies eine der schlimmsten Erfahrungen, die man überhaupt machen kann.",ep:14,g:23,l:122,wd:true,fm:true,w:35,p:38000};
I.u[2401] = {n:"Karte von Kwelsh",t:15,d:"Diese Karte hat irgendetwas mit Meister Kwelsh zu tun. Das ist alles, was ihr darüber wissen müsst.",ep:16,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[2402] = {n:"Schwert von Sériane-Kerm",t:6,d:"Dieses Schwert verliehen zu bekommen, ist eine besondere Auszeichnung für die erfolgreichsten Söldner von Seriane-Kerm. Allerdings ist es ziemlich scharf.",ep:1,g:25,l:30,wd:false,fm:true,w:20,an:14,tw:true,e:[10,4,1,1,40,40,false,false],c:"Ps=3",p:1};
I.u[2403] = {n:"Isedi",t:10,d:"In vergangenen Zeiten wurde dieser Gürtel gern getragen. Doch heutzutage weiß niemand genau, was ihn von anderen Gürteln unterscheiden soll. Viele wollen das Geheimnis mit eigenen Augen gesehen haben, aber niemand redet gern darüber. Also solltet ihr immer die Augen offen halten, wenn ihr den Gürtel tragt. Denn es haben bereits viele andere ein Auge auf ihn geworfen.",ep:13,g:25,l:49,wd:true,fm:true,w:10,p:6100};
I.u[2404] = {n:"Gürtel der Gürtelratte",t:10,d:"Die Gürtelratte war trotz ihres Namens eine gewöhnlichliche Kanalratte, die diesen Gürtel um die Hüfte geschnallt trug, um ihre Knutschflecke besser verbergen zu können.",ep:2,g:27,l:55,wd:true,fm:true,w:10,p:8100};
I.u[2409] = {n:"Flammen-Kwackapp",t:16,d:"Die Flammen-Kwackapp gibt euch wirklich das bärenstarke Erscheinungsbild eines erfolgreichen Weiberheldes. Also braucht ihr die Weiber nur noch festzuhalten, wenn sie sich nicht mehr auf den Beinen halten können vor Lachen, wenn ihr mit ihr auftaucht. Seid ihr nun ein Held, der hält, was er verspricht oder nicht?",ep:13,g:39,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2410] = {n:"Astakappa",t:16,d:"Diese stylische Kopfbedeckung schützt euch wirksam vor Dünnbrettbohrern und Wurmlöchern, immer vorausgesetzt, ihr schafft es, trotz eurer Dickköpfigkeit den Hohlraum mit Inhalt auszufüllen.",ep:1,g:40,l:45,wd:true,fm:true,w:50,s:3,p:5500};
I.u[2411] = {n:"Fresssackkapp",t:16,d:"Dieser tolle Hut erhöht die Stärke und Intelligenz seines Träger, vorausgesetzt, dieser kann sich an den strengen Geruch gewöhnen.",ep:1,g:41,l:10,wd:true,fm:true,w:15,s:1,p:2050};
I.u[2412] = {n:"Flammen-Kwape",t:17,d:"Dieser flammende und schillernde Umhang ist zwar wunderschön anzusehen, verleiht euch aber dennoch keine Superkräfte. Da hilft es auch nichts, ein großes \"M\" darauf zu sticken. Auch nicht, wenn ihr fest daran glaubt. Punkt. Basta. Schluss mit der Diskussion. Dieses Cape verleiht  k e i n e  Superkräfte, und Garantien gibt es auch keine.",ep:8,g:42,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2413] = {n:"Astacapa",t:17,d:"Solchermaßen gewappnet, könnt ihr glatt durch den ganzen Wald stolzieren, ohne erkannt zu werden. Doch seht euch vor! Es kann schnell passieren, dass den Astaknyden bei eurem Anblick der Saft in die Krone schießt.",ep:1,g:43,l:45,wd:true,fm:true,w:17,s:3,p:5500};
I.u[2414] = {n:"Fresssacksack",t:17,d:"Dieses sackförmige Gewand hat alles, was man sich nur wünschen kann: es ist behaglich, widerstandsfähig, schön gefärbt und höchst selten... nur der Geruch ist eine Zumutung für jede Nasenhöhle.",ep:1,g:44,l:10,wd:true,fm:true,w:30,s:1,p:2780};
I.u[2415] = {n:"Flammen-Kwacklinge",t:6,d:"Die Flammen-Kwacklinge ist eine wirklich stylische Waffe. Wenn der Gegner nicht gleich vor Angst und Schrecken bibbert, so wird sie ihn trotzdem gehörig beeindrucken, während ihr ihn dann mit einem alten, aber gemeinen Trick völlig überrumpeln könnt.",ep:5,g:52,l:41,wd:true,fm:true,w:5,an:14,e:[5,5,1,1,50,50,false,false],c:"CI>50&CV>50",s:2,p:4600};
I.u[2416] = {n:"Hammer des Fresssacks",t:7,d:"Im Benutzerhandbuch dieses Hammers steht, dass er eine kolossale Energiemenge freisetzt, wenn er korrekt eingesetzt wird. Schon wieder eines dieser Osamodas-Handbücher, die in Sadida übersetzt wurden...",ep:1,g:23,l:10,wd:true,fm:true,w:25,an:15,e:[5,5,1,1,40,40,false,true],s:1,p:845};
I.u[2417] = {n:"Astecken",t:4,d:"Dieser Stecken hat die berücktigte Aggressivität alter Astaknyden beibehalten, ohne dass ihm ihr charakteristisch modriger Geruch anhaftet. Einfach ideal!",ep:1,g:23,l:45,wd:true,fm:true,w:10,an:12,tw:true,e:[3,4,1,1,30,50,false,false],s:3,p:5500};
I.u[2418] = {n:"Flammen-Kwackband",t:9,d:"Anhand dieses Bandes kann euer Herr euch immer wiederfinden, solltet ihr mal verloren gehen.",ep:5,g:43,l:42,wd:true,fm:true,w:2,s:2,p:4900};
I.u[2419] = {n:"Ring von Buhz Leichtfrier",t:9,d:"Dieser Ring gehörte dem berühmten Buhz Leichtfrier, dem Retter der Neuzeit, welcher den Kultsatz prägte: \"Bis zum Eni der Unenuigkeit und darosamodas hiniop.\"",ep:1,g:44,l:10,wd:true,fm:true,w:10,s:1,p:775};
I.u[2420] = {n:"Astaband",t:9,d:"Äste von Astaknyden zu verarbeiten ist nicht leicht. Aber mit viel Ausdauer erhält man am Ende ein Armband, das gleichzeitig nüchtern, elegant und raffiniert ist. Also so ziemlich genau das Gegenteil eines Sadidas in einer Taverne.",ep:1,g:45,l:40,wd:true,fm:true,w:10,s:3,p:4500};
I.u[2421] = {n:"Feurige Kwacklauen",t:11,d:"Mit diese Sporen an den Füßen werdet ihr von nun an wie auf Eiern gehen müssen, damit sie euch nicht ungesehen von einem Sram mit schlechten Absichten gestohlen werden.",ep:5,g:25,l:40,wd:true,fm:true,w:5,s:2,p:4400};
I.u[2422] = {n:"Fressstiefel",t:11,d:"Diese Stiefel sind bequem wie nichts anderes. Das Innere scheint aus einer Doppellage Fresssackwolle zu bestehen, doch kann man auch noch eine warme Flüssigkeit zwischen den Zehen rinnen fühlen. Ist das wohl eher Fresssackspeichel oder -blut? Egal.",ep:1,g:26,l:10,wd:true,fm:true,w:15,s:1,p:1700};
I.u[2423] = {n:"Astaboots",t:11,d:"Die Wirkung dieser Stiefel könnt ihr sehr gut simulieren anhand eines Besuchs in eurer Lieblingskneipe. Dort einfach so viel trinken, wie es geht, dann noch ein wenig mehr und am nächsten Morgen habt ihr Beine, die sich so schwer und leblos anfühlen, wie nach längerem Tragen der Astaboots. Toll, was?",ep:1,g:27,l:45,wd:true,fm:true,w:20,s:3,p:4500};
I.u[2424] = {n:"Feuriges Amukwack",t:1,d:"Mit all diesen roten Federn um den Hals, werdet ihr Aldo Rado ähneln, dem großen Sacrieur-Abenteurer auf der Suche nach einer goldenen Stadt.",ep:5,g:47,l:42,wd:true,fm:true,w:3,s:2,p:4900};
I.u[2425] = {n:"Amulett des Fresssacks",t:1,d:"Das wohlgeformte Horn eines Fresssacks verleiht euch Ruhe und Weisheit. Analog dazu wird euch auch ein wohlgeformter Fresssackanhänger Ruhe und Weisheit verleihen. Oder das Gegenteil. Oder etwas ganz anderes. Oder aber vielleicht auch gar nichts.",ep:1,g:48,l:3,wd:true,fm:true,w:10,s:1,p:550};
I.u[2426] = {n:"Arach-Amuleth",t:1,d:"Diese kleine Arachnee ist der lebende Beweis, dass man ein Tierchen nicht aufspießen muss, um aus ihm ein Amulett zu machen. Sie wird euch lustig am unteren Bereich des Halsansatzes kitzeln oder euch gar irgendwann einmal Babyamulethe, euh...-arachneen zur Welt bringen.",ep:1,g:49,l:20,wd:true,fm:true,w:10,s:3,p:1300};
I.u[2427] = {n:"Flammen-Kwackürtel",t:10,d:"Um wie ein Flammen-Kwack in der Balzzeit herumzustolzieren, gibt es nichts besseres als diesen Gürtel. Vorausgesetzt man trägt nichts anderes.",ep:12,g:28,l:41,wd:true,fm:true,w:5,s:2,p:4600};
I.u[2428] = {n:"Gürtel des Fresssacks",t:10,d:"Dieser aus Wolle handgefertigte, praktische Gürtel ist sehr leicht für seine Größe. Außerdem sieht seine Wolle stets wie neu aus. Beides soll einer Legende nach daher kommen, dass Hunderte neugeborener weißer Fresssäckchen ihr Leben, ihr Blut und ihre Wolle für ihn lassen mußten.",ep:1,g:29,l:20,wd:true,fm:true,w:10,s:1,p:1253};
I.u[2429] = {n:"Astaschurz",t:10,d:"Dieser hölzerne Lendenschurz wird euch Sicherheit und Komfort bieten. Einmal pro Jahr wird allerdings eine leichte Anti-Arachneenbehandlung empfohlen. Vergleichbar einer Anti-Parasitenbehandlung bei einem Sadida, doch mit 3x weniger Mittelchen.",ep:1,g:30,l:45,wd:true,fm:true,w:25,s:3,p:4500};
I.u[2430] = {n:"Blaubeergelee-Klecks",t:24,d:"Ihr habt euch in Gegenwart dieses armen Blaubeergelees wie ein grober Brutalo verhalten. Wer weiß, vielleicht werdet ihr diese Untat eines Tages büßen müssen.",ep:7,g:91,l:1,wd:true,fm:true,w:0,p:1};
I.u[2431] = {n:"Zitronengelee-Klecks",t:24,d:"Ihr habt euch in Gegenwart dieses armen Zitronengelees wie ein grober Brutalo verhalten. Wer weiß, vielleicht wird euch eines Tages jemand genauso platt schlagen wie ihr das Gelee.",ep:7,g:90,l:1,wd:true,fm:true,w:0,p:1};
I.u[2432] = {n:"Erdbeergelee-Klecks",t:24,d:"Ihr habt euch in Gegenwart dieses armen Erdbeergelees wie ein grober Brutalo verhalten. Wer weiß, vielleicht werdet ihr eines Tages genauso einen unförmigen Fleck in der Landschaft bilden wie das Gelee jetzt.",ep:7,g:92,l:1,wd:true,fm:true,w:0,p:1};
I.u[2433] = {n:"Minzgelee-Klecks",t:24,d:"Ihr habt euch in Gegenwart dieses armen Minzgelees wie ein grober Brutalo verhalten. Wer weiß, vielleicht bleiben eines Tages von euch genauso wenig Reste über wie von diesem Gelee.",ep:7,g:93,l:1,wd:true,fm:true,w:0,p:1};
I.u[2435] = {n:"Enis Keys",t:11,d:"Dieses seltsame Paar handgefertigter Schuhe war für einen später berühmt gewordenen Eniripsa der Schlüssel zum Gewinnen des großen Marathons von Amakna. Mit ihnen überquerte er vor den Augen der völlig verblüfften Ecaflips das Asselmeer. Ein Eni, der übers Wasser laufen kann, wow, genial! Manchmal braucht es nur einen kleinen Trick, um den Hauptgewinn zu ergattern.",ep:5,g:29,l:45,wd:true,fm:true,w:5,p:4800};
I.u[2436] = {n:"Zitronengelee",t:110,d:"Dieser Topf Zitronengelee sieht eigenartig aus. Laut Elrik Ola kommt dieses Gelee aus seiner Heimat. Genauer gesagt, vom anderen Ende des Weltalls, also nicht gerade von nebenan.",ep:7,g:490,l:45,wd:true,fm:true,w:1,p:1};
I.u[2437] = {n:"Königliches Zitronengelee",t:110,d:"Laut gewisser Gerüchte soll Zitronengelee noch besser schmecken als andere Geleesorten. Vielleicht weil der starke Zitronengeschmack den Geschmack des Gelees übertüncht?",ep:7,g:491,l:200,wd:true,fm:true,w:1,p:100};
I.u[2438] = {n:"Königliche Fresssackkapp",t:16,d:"Die königliche Fresssackkapp wird immer modern bleiben, ganz gleich wohin der Trend geht. Sie ist nämlich nicht nur hochelegant, sondern beschert ihrem Träger auch noch Stärke und Intelligenz. Wahrlich königlich!",ep:1,g:42,l:50,wd:true,fm:true,w:45,s:4,p:100};
I.u[2440] = {n:"Schwert des königlichen Fresssacks",t:6,d:"Dieses Schwert weiß nicht, auf welchem Huf es tanzen soll... Darum fügt es Gegnern einfach Schaden von jedem Element zu.",ep:1,g:30,l:70,wd:true,fm:true,w:65,an:14,e:[4,4,1,1,30,50,false,false],s:4,p:30000};
I.u[2441] = {n:"Königlicher Fresssackring",t:9,d:"Dieser Ring erhöht die Lebenspunkte seines Trägers, so wie der weibliche Geruch der Konkubine des königlichen Fresssacks ihren Liebreiz erhöht.",ep:1,g:46,l:30,wd:true,fm:true,w:5,s:4,p:100};
I.u[2442] = {n:"Königliche Fressstiefel",t:11,d:"Sie glänzen golden und sie strahlen große Macht aus – alles an diesen Stiefel ist einfach nur \"königlich\".",ep:1,g:30,l:50,wd:true,fm:true,w:50,s:4,p:6600};
I.u[2443] = {n:"Amulett des königlichen Fresssacks",t:1,d:"Dieses Amulett erhöht die Stärke und Intelligenz seines Trägers.",ep:1,g:50,l:50,wd:true,fm:true,w:10,s:4,p:5000};
I.u[2444] = {n:"Gürtel des königlichen Fresssacks",t:10,d:"Dieser wunderschöne Gürtel erhöht die Vitalität seines Trägers in beträchtlichem Maße und hilft ihm beim Verstauen seiner Ausrüstung. Er ist so sanft, dass man damit sogar seine Liebste fesseln kann, wenn sie sich einmal weigert, zu Hause zu bleiben, während man auf die Jagd geht.",ep:1,g:31,l:52,wd:true,fm:true,w:10,s:4,p:7000};
I.u[2445] = {n:"Königlicher Fresssacksack",t:17,d:"Dieses königlich sackförmige Gewand ist nicht nur extrem stylisch, sondern macht seinen Träger auch noch extrem stark!",ep:1,g:46,l:50,wd:true,fm:true,w:60,s:4,p:50000};
I.u[2446] = {n:"Gelacape",t:17,d:"Wie kann dieser Umhang ohne Gewebe und Felle so lange halten? Diese Frage beschäftigt schon seit langer Zeit die Denker von Amakna – eine kleine, unwichtige Minderheit, die heute nicht mehr ein Dutzend Personen umfassen mag.",ep:7,g:47,l:60,wd:true,fm:true,w:10,s:6,p:1000};
I.u[2447] = {n:"Gelohaube",t:16,d:"Mit dieser Haube auf dem Kopf könnt ihr sicher sein, dass eure Freunde in Zukunft immer davon träumen werden, in eure Nähe zu kommen. Dieses Kleidungsstück hätte sogar den Chafer-Offizier in seinen aktivsten Zeiten zufriedengestellt. Und das will etwas heißen.",ep:5,g:43,l:60,wd:true,fm:true,w:23,s:6,p:9500};
I.u[2448] = {n:"Fresssackhirn",t:15,d:"Kein Zweifel möglich, dies ist eindeutig ein Fresssackhirn. Gut zubereitet, ist es ein wahrer Gaumenschmaus, der besonders bei jungen Iop-Kindern, die einmal groß und stark werden möchten, großen Anklang findet. Es soll auch intelligent machen, doch würden die Iop-Kinder nichts mehr davon essen, wenn sie das wüßten.",ep:1,g:492,l:9,wd:true,fm:true,w:1,p:1};
I.u[2449] = {n:"Armee von Flöhen",t:15,d:"Laut gewisser Jäger kann eine Armee ausgehungerter Flöhe in einer Nacht einen ganzen Fresssack auffressen. Ja, schlimmer noch: sie könnten glatt einem Sadida die Haare vom Körper knabbern.",ep:1,g:493,l:9,wd:true,fm:true,w:1,p:1};
I.u[2451] = {n:"Fresssackhuf",t:47,d:"Früher einmal wurden Fresssackhufe als Untertassen verwendet. Doch schufen findige Eniripsa-Alchimisten eine neue Mode, indem sie daraus Trinkschalen machten. So erhalten die morgentlichen Cornflakes noch mehr Geschmack.",ep:1,g:495,l:9,wd:true,fm:true,w:1,p:1};
I.u[2453] = {n:"Fresssackauge",t:109,d:"Früher einmal wurde aus Fresssackaugen eine hervorragende Suppe gemacht. Sie war so lecker, dass man sie aus den Rezeptbüchern entfernen mußte, weil viele Jäger nur noch die Augen sammelten und die noch dampfenden Fresssackkadaver einfach wilden Tieren überließen.",ep:1,g:497,l:9,wd:true,fm:true,w:1,p:1};
I.u[2454] = {n:"Fresssackmagen",t:15,d:"Dieser Magen verfügt über eine großartige Dehnbarkeit. Allerdings solltet ihr euch nicht wundern, in seinem Inneren Kleeblattbrei zu finden, da dies eine der Lieblingsspeisen von Fresssäcken ist.",ep:1,g:498,l:9,wd:true,fm:true,w:1,p:1};
