I.u[1976] = {n:"Gesäuberte Ur-Forelle",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:399,l:1,wd:true,fm:true,w:1,p:1};
I.u[1977] = {n:"Gewürze",t:15,d:"Diese getrockneten Gewürze geben euren Speisen das gewisse Etwas.",ep:1,g:378,l:1,wd:true,fm:true,w:1,p:10};
I.u[1978] = {n:"Prise Pfeffer",t:15,d:"Dieses Gewürz bringt ein wenig Feuer in eure Gerichte.",ep:1,g:381,l:1,wd:true,fm:true,w:1,p:5};
I.u[1980] = {n:"Steifheit",t:30,d:"Dieser Fluch raubt euch Flinkheit im nächsten Kampf.",ep:1,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
