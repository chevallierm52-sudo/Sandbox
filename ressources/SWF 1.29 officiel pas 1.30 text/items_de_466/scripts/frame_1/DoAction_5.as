I.u[1983] = {n:"Gelee-Gelatine",t:15,d:"Diese Gelatine stammt direkt aus dem Herzen eines Gelees. Ein gutes und noch dazu schmackhaftes Mittel für die Nahrungskonservierung.",ep:1,g:379,l:20,wd:true,fm:true,w:1,p:5};
