I.u[1985] = {n:"Astaknydenharz",t:15,d:"Dieses kleine Harzstück wurde von fachkundigem Personal nach einer längerem Operation dem noch zuckenden Astaknyden extrahiert. Doch taugt es lediglich dazu, die von ihm bedeckten Gegenständed vor der Luft zu schützen.",ep:1,g:382,l:50,wd:true,fm:true,w:1,p:10};
I.u[1986] = {n:"Prise Zeitpulver",t:48,d:"Nur dieses geheimnisumwobene Zeitpulver, welches in den Manufakturen der Xelor hergestellt wird, ist in der Lage, den Zerfall von Gegenständen und Lebewesen zu verlangsamen. Darum wird es gern eingesetzt, um Lebensmittel zu konservieren oder die Falten von Enutrofs zu kurieren.",ep:1,g:2,l:1,wd:true,fm:true,w:1,p:2};
