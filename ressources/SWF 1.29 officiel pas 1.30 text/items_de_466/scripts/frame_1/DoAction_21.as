I.u[10155] = {n:"Yagulett",t:1,d:"Diese Amulett schützt euch vor zufälligen Enthauptungen und haarsträubenden Abstempelungen.",ep:0,g:147,l:43,wd:true,fm:true,w:10,s:134,p:5030};
I.u[10156] = {n:"Yagoffel",t:11,d:"Diese Pantoffeln sind bequemer, als gewöhnliche Pantoffeln aber ihr wisst nicht, warum. Vielleicht liegt es anden Tausenden von massierenden Staubmilben...",ep:0,g:140,l:41,wd:true,fm:true,w:10,s:134,p:4575};
I.u[10157] = {n:"Yagurt",t:10,d:"Dieser Gürtel wurde aus Leinenfädenresten hergestellt. Damit kann man Müllsäcke zusammen binden.",ep:0,g:157,l:43,wd:true,fm:true,w:10,s:134,p:5025};
I.u[10158] = {n:"Trophäenschild des Dark Vlads",t:82,d:"Haltet diesen Schild stolz ins Licht, damit jeder ihn sehen kann. Denn wenn ihr umkommt, wird dies die letzte Erinnerung an eure großen Heldentaten bleiben.",ep:0,g:43,l:1,wd:true,fm:true,w:1,p:1};
