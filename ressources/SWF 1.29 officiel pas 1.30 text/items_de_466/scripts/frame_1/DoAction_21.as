I.u[10168] = {n:"Chisp-Boots",t:11,d:"Ponch pflegte jeden Morgen diese Stiefel zu pflegen, bevor er auf seinen Dracotruter aufsprang, wieder einmal die Witwen und Waisen zu retten. Vor allem die Witwen, schließlich war Ponch ein ziemlicher Charmeur.",ep:0,g:141,l:42,wd:true,fm:true,w:10,s:138,p:4850};
I.u[10169] = {n:"Chisp-Schild",t:82,d:"Ponch liebte es, mit diesem Schild am Arm auf seinem Dracotruter über das Land zu flitzen. Immer im Dienste der Sicherheit, versteht sich.",ep:0,g:41,l:1,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10170] = {n:"Chisp-Hut",t:16,d:"Dieser Helm bewahrt seinen Träger vor gefährlichen Dracotruterstürzen und verleiht ihnen einen erfrischend idiotischen Gesichtsausdruck.",ep:0,g:246,l:40,wd:true,fm:true,w:10,s:138,p:4400};
I.u[10171] = {n:"Chisp-Fäustlinge",t:9,d:"Diese Fäustlinge aus schwarzem Leder sind wie dazu geschaffen, schmerzhafte Ohrfeigen zu verpassen.",ep:0,g:173,l:44,wd:true,fm:true,w:10,s:138,p:4800};
I.u[10172] = {n:"Schnamulett",t:1,d:"Dieses Amulett kann eine tollwütige Horror-Schneckse mindestens zwei bis drei Tage lang ernähren. Genug Zeit zum Weglaufen, also!",ep:0,g:148,l:42,wd:true,fm:true,w:10,s:137,p:4900};
I.u[10173] = {n:"Schniefel",t:11,d:"Die Sohle dieser Stiefel ist mit einem klebrigen Schleim vollgekleistert, während sich im inneren ein glitschiger Schleim befindet. Oder war es umgekehrt?",ep:0,g:142,l:39,wd:true,fm:true,w:10,s:137,p:4105};
I.u[10174] = {n:"Schnumhang",t:17,d:"Ein glibbriger Schleim bedeckt die Oberfläche dieses Umhangs. Drum macht folgendes: nehmt Anlauf, legt euch auf den Rücken und rutscht bis zu eurem Ziel.",ep:0,g:169,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10175] = {n:"Schmaske",t:16,d:"Diese schleimige Schmaske wird eure Haare viele Jahre lang mit Haargel versorgen, ob ihr möchtet, oder nicht. Gebt nur acht, dass andere Abenteurer euch damit nicht mit einer Eniripsa im Larvenset verwechseln.",ep:0,g:247,l:42,wd:true,fm:true,w:10,s:137,p:4800};
I.u[10177] = {n:"Dunkle Schattenastaknydenrinde",t:24,d:"Noch dunkler als die Schattenastaknydenrinde, stammt der Glanz dieser Rinde aus den wenig angenehmen Substanzen, die vom Organismus der Schattenastaknyde ausgeschieden werden. Eben diese Substanzen verleihen ihr ihre geheimnisvollen Kräfte.",ep:0,g:231,l:1,wd:false,fm:true,w:0,p:1};
I.u[10178] = {n:"Geschnitzte dunkle Rinde",t:24,d:"Damit die geschnitzte Dunkle Rinde nicht beschädigt wird, habt ihr sie in diese Schachtel gelegt.",ep:0,g:56,l:1,wd:false,fm:true,w:0,p:1};
I.u[10179] = {n:"Mark-und-Beingraf zu Vamps enganliegender Lederslip",t:24,d:"Um sich vor kritischen Treffern an kritischen Stellen zu schützen, benutzt Mark-und-Beingraf zu Vamps bei der Jagd seinen enganliegenden Lederslip. Dieser Slip schützt seine kritischen Stellen auch vor Sonnenbrand.",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10180] = {n:"Das Esteban",t:1,d:"Dieses schöne Medaillon soll der Schlüssel zu einer geheimnisvollen, verschollenen Stadt sein.",ep:0,g:149,l:42,wd:true,fm:true,w:10,s:136,p:4800};
I.u[10181] = {n:"Sonnenring",t:9,d:"Dieser Ring wurde in einer geheimnisvollen Stadt gefunden, deren Geheimnis niemand vermutete, bevor der Ring gefunden wurde.",ep:0,g:174,l:41,wd:true,fm:true,w:10,s:136,p:4600};
I.u[10182] = {n:"Sonnenschild",t:82,d:"Dieser Schild speichert einfallende Sonnenstrahlen und wirft sie bei Bedarf direkt in die Augen eurer Gegner zurück. Wenn ihr also Gegner nicht mit eurer Intelligenz blenden könnt, dann jetzt dank eures Schildes wenigstens mit Lichtstrahlen.",ep:0,g:42,l:1,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10183] = {n:"Sonnenmaske",t:16,d:"Diese Maske fängt auftreffende Sonnenstrahlen ein und konzentriert sie auf euer Gesicht. Dadurch könnt ihr das ganze Jahr über mit sonngebräunter Haut herumlaufen, selbst wenn ihr im hohen Norden Amaknas wohnt.",ep:0,g:248,l:42,wd:true,fm:true,w:10,s:136,p:4750};
I.u[10184] = {n:"Nokes Mono-Maske",t:16,d:"Noke liebte es einst, sich im Wald zu verstecken und mit dieser Maske Wanderer zu erschrecken. Doch das ist schon lange her. Er starb an einem Herzinfarkt beim Anblick seines Spiegelbildes in einer Wasserpfütze.",ep:0,g:249,l:42,wd:true,fm:true,w:10,s:135,p:4700};
I.u[10185] = {n:"Nokes Mono-Wolfumhang",t:17,d:"Noke träumte davon, ein großer, böser Wolf zu sein. Doch selbst mit diesem Umhang auf den Schultern, ähnelte er höchstens einem kleinen, bösen Wolf.",ep:0,g:170,l:41,wd:true,fm:true,w:10,s:135,p:4600};
I.u[10186] = {n:"Nokes Mono-Halskette",t:1,d:"Diese Halskette aus geschliffenen Keilerhauern sieht so fürchterlich aus und stinkt so bestialisch, dass selbst Keiler davor Reißaus nehmen! Und das will schon etwas heißen.",ep:0,g:150,l:41,wd:true,fm:true,w:10,s:135,p:4525};
I.u[10187] = {n:"Nokes Mono-Dolche",t:5,d:"Mit diesen Dolchen wurde einst ein kriegerischer Riesenkeiler ausgeweidet, der davon träumte, ein Hirsch zu sein.",ep:0,g:76,l:41,wd:true,fm:true,w:10,an:13,tw:true,e:[12,3,1,1,30,45,false,false],c:"CS>50&CW>50&CV>80",s:135,p:4000};
I.u[10188] = {n:"Morgentau-Maske",t:16,d:"Diese Maske macht aus euch dank seiner einzigartigen Übersetzungsvorrichtung einen ausgezeichneten Protokollier-Wobot. So entgehen euch keine Kohl-Diskussionen mehr oder anderes Dummgeschwätz. Kann auch als schalldichter Helm benutzt werden.",ep:0,g:250,l:43,wd:true,fm:true,w:10,s:133,p:5075};
I.u[10189] = {n:"Oxano",t:9,d:"Dieser Ring gehörte einst einem Holzschuhmacher, der unter dem Spitznamen \"Welpen\" bekannt war, den er sich herumbummelnd nach einer langen Reise gemacht hat. Seine Freunde nannten ihn den \"Welpenbummler\".",ep:0,g:175,l:37,wd:true,fm:true,w:10,s:133,p:3875};
I.u[10190] = {n:"Morgentau-Stiefelchen",t:11,d:"Wenn ihr Kohl anpflanzen wollt, so wie es bei uns üblich ist, dann denkt daran, diese Stiefelchen zu tragen. Die sind nämlich eigens dazu entworfen worden, den Kohl nicht zu zertreten. Ist zum Tanzen mit eurem Partner aber nicht geeignet, gilt nur für Kohl, nicht für Füße.",ep:0,g:143,l:38,wd:true,fm:true,w:10,s:133,p:3925};
I.u[10191] = {n:"Oxolatur",t:10,d:"Dieser Gürtel hält euren Blähbauch nach einer Portion Kohl in Zaum.",ep:0,g:158,l:37,wd:true,fm:true,w:10,s:133,p:373};
