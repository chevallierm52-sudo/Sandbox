I.u[9785] = {n:"Shushu von Rushu",t:18,d:"Dieser geringe Dämon wird euch auf all euren Pilgerreisen treu zur Seite stehen, sei es vom Astrub-Zaap zum Friedhof oder vom Friedhof zum Astrub-Zaap. Diese Kreatur wird von einem furchtbaren Hass auf Morphs angetrieben. Gerüchten nach soll dieser aus um ein düsteres Kapitel der Familiengeschichte stammen... mit jedem besiegten Morph wird sich der Shushu von Rushu weiterentwickeln.",ep:0,g:52,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9786] = {n:"Shushu von Rushu - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:49,l:1,wd:true,fm:true,w:1,p:1};
