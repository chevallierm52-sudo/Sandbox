I.u[9916] = {n:"Spezialzauberschriftrolle \"Seelenlasso\"",t:75,d:"Diese Schriftrolle ermöglicht das Erlernen des Zauberspruches Seelenlasso. Jedoch ist der Zauber nur Anhängern Osamodas zugänglich.",ep:1,g:6,l:1,wd:true,fm:true,w:1,c:"PG=2",u:true,p:10000};
I.u[9917] = {n:"Kopfgeldgesuch",t:24,d:"Diese Schriftrolle enthält den Namen eures Zieles",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9919] = {n:"Mento-Ring",t:9,d:"Gibt dem Träger das Aussehen einer Eule.",ep:0,g:7,l:1,wd:false,fm:false,w:0,p:0};
I.u[9920] = {n:"Kopfgeldprämie",t:24,d:"Diese Schriftrolle bestätigt, dass euer Ziel erfolgreich eliminiert wurde",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9921] = {n:"Teckton-Ihks Armband",t:9,d:"Dieses Armband verfügt über hohe Leuchtkraft. Aber nur nachts, in dunklen Tavernen!",ep:0,g:168,l:45,wd:true,fm:true,w:10,s:132,p:5525};
I.u[9922] = {n:"Teckton-Ihks Gürtel",t:10,d:"Dieser Gürtel verfügt über einen überaus starken Magneten, durch den der Gürtel zusammengehalten wird. Also besser keine bleierne Unterwäsche tragen...",ep:0,g:154,l:38,wd:true,fm:true,w:10,s:132,p:4050};
I.u[9923] = {n:"Teckton-Ihks Schuhe",t:11,d:"Wenn ihr hübsche Muskeln zu zeigen habt, und gern tanzt wie ein Roboter, dann sind das genau die Richtigen Schuhe für euch. Doch Vorsicht, Schnürsenkel gibt es nur gegen Aufpreis!",ep:0,g:135,l:40,wd:true,fm:true,w:10,s:132,p:4300};
I.u[9924] = {n:"Blitzhörner",t:16,d:"Einer alten Legende nach sollen sich diese natürlichen Blitzableiter bei Gewittern magisch aufladen, um anschließend große Blitze auf Gegner oder zufällige Passanten in der Nähe zu schleudern. Es ist jedoch keine Legende, dass man mit diesen Hörnern ziemlich bescheuert aussieht.",ep:0,g:239,l:42,wd:true,fm:true,w:10,s:139,p:4825};
I.u[9925] = {n:"Faustesblitz",t:9,d:"Einen Ring kann man dies hier wohl schwerlich nennen. Eher einen Handschuh oder Fäustling. Doch eines ist sicher: die Redewendung \'ein kräftiger Händedruck\' bekommt hiermit eine ganz neue Bedeutung!",ep:0,g:169,l:44,wd:true,fm:true,w:10,s:139,p:4400};
I.u[9926] = {n:"Spacige Hellebarde",t:19,d:"Mit dieser spacigen Hellebarde könnt ihr zwei Köpfe auf einmal abtrennen. Das heißt, ihr könntet gleichzeitig ein Achtel aller Köpfe der sechszehnköpfigen Hydra vor euch abhacken. Doch da sie nachwachsen, solltet ihr lieber fliehen...",ep:0,g:57,l:39,wd:true,fm:true,w:10,an:17,e:[3,5,1,1,20,50,false,false],c:"CC>60&CV>50&CW>30",s:139,p:3900};
I.u[9927] = {n:"Goldoboots",t:11,d:"Mit diesen Stiefeln an den Füßen verdreifacht sich eure Wahrscheinlichkeit, anfliegende Kometen zu orten, oder von plötzlich erscheinenden Kampf-Wobots in die Mangel genommen zu werden.",ep:0,g:136,l:42,wd:true,fm:true,w:10,s:139,p:4805};
I.u[9928] = {n:"Volle Nellson Stiefel",t:11,d:"Ihr werdet mindestens 12 Stunden damit beschäftigt sein, die Schnürsenkel dieser Stiefel zu binden und 16 Stunden, um sie wieder aufzumachen. Wenn ihr die Stiefel also täglich an- und wieder ablegen möchtet, dann seid ihr jeden Tag 4 Stunden zu spät. Es sei denn, ihr würdet an einem Tag bereits einen Vorsprung gewinnen, um die anderen Tage zu kompensieren.",ep:0,g:137,l:42,wd:true,fm:true,w:10,s:131,p:4750};
I.u[9929] = {n:"Voller Nellson Gürtel",t:10,d:"Die Achillesferse mancher Kämpfer befindet sich nicht immer am Fuß, sondern bei manchen in Höhe des Bauchnabels. Mit diesem Gürtel könnt ihr eure Schwachstelle jetzt noch besser schützen.",ep:0,g:155,l:41,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9930] = {n:"Volle Nellson Maske",t:16,d:"Mit dieser Maske wird man euch von Weitem für eine mutierte, radioaktive Riesenlarve halten, von Nahem hingegen für einen mächtigen Kämpfer. Bleibt also besser stets im Nahkampf!",ep:0,g:240,l:38,wd:true,fm:true,w:10,s:131,p:4000};
I.u[9931] = {n:"Teckton-Ihks Perücke",t:16,d:"Diese Perücke lässt euren Schwanenhals noch länger erscheinen und eure Haare wirken echt stylisch!",ep:0,g:241,l:39,wd:true,fm:true,w:10,s:132,p:4255};
I.u[9932] = {n:"Achselhaare des Bagrutt-Wirts",t:24,d:"Dieses schmierige Haarbüschel wurde aus den Achselhöhlen des Wirtes der Bagrutt-Taverne herausgerissen. Der Geruch macht euch wahnsinnig und ihr rennt und springt und grunzt! Noch so eine versteckte Macke.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[9933] = {n:"Voller Nellson Umhang",t:17,d:"Die Bitoufhaare am oberen Rand des Umhangs sind dazu da euren Nacken zu schützen. Das werden euch eure Halswirbel sicher zu danken wissen...",ep:0,g:167,l:42,wd:true,fm:true,w:10,s:131,p:4825};
I.u[9934] = {n:"Schlüssel zur Koppel",t:24,d:"Hier sieht man einmal mehr, dass Goblins erfahrene Bastler sind! Selbst aus den einfachsten Materialien können sie tolle Sachen machen, wie man hier sehen kann. Für jeden wäre dies bloß ein x-beliebiger Knochen. Aber nicht für die Goblins. Für sie ist es ein Schlüssel zur Koppel!",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9935] = {n:"Kletterseil",t:15,d:"Dieses stabile Seil wird von Amateur-Bergsteigern sehr geschätzt. Man kann damit auf Berge hinauf und auch wieder herunterklettern. Doch lässt sich damit noch viel mehr machen. Einer alten Sitte in Amakna zufolge lässt sich auch sehr gut eine Schlinge in das Seil knoten, durch welche man den Kopf des Chefs des Dorfes stecken kann, um diesen klarzumachen, dass seine Entscheidungen nicht einstimmig angenommen wurden...",ep:0,g:170,l:1,wd:false,fm:true,w:5,p:1};
I.u[9936] = {n:"Darth Weydahelm",t:16,d:"Dieser Helm ist einfach perfekt, wenn ihr trotz eures engelhaften Lächelns und eures pickelverzierten Gesichts einen auf ganz schrecklich böse machen möchtet!",ep:0,g:242,l:37,wd:true,fm:true,w:10,s:117,p:3825};
I.u[9937] = {n:"Chaphut",t:16,d:"Diesen Hut gibt es zusammen mit einem falschen Schnurrbart. Ein solcher nicht nachwachsender Schnurrbart ist sehr praktisch. So könnt ihr euch den Besuch des Barbiers ersparen.",ep:0,g:243,l:37,wd:true,fm:true,w:10,s:116,p:3700};
I.u[9938] = {n:"Leuchteschwert",t:6,d:"Die Klinge dieser Waffe wurde 18 Monate lang in konzentriertem Glühwürmchenextrakt eingelegt. Das Ergebnis seht ihr hier: es leuchtet im Dunkeln!",ep:0,g:91,l:38,wd:true,fm:true,w:10,an:14,tw:true,e:[5,4,1,1,50,50,false,false],c:"CV>30&CS>20&CW>20",s:117,p:3800};
I.u[9939] = {n:"Chapstock",t:4,d:"Diese biegsame Bambusstock gehörte einst einem berüchtigten Vagabunden mit guten Manieren.",ep:0,g:88,l:37,wd:true,fm:true,w:10,an:12,e:[5,3,1,1,40,50,false,false],c:"CC>25",s:116,p:3700};
I.u[9940] = {n:"Unbearbeitetes Perlmutt",t:51,d:"Richtig poliert wird hieraus wunderschönes Perlmutt.",ep:0,g:10,l:20,wd:true,fm:true,w:1,p:10};
I.u[9941] = {n:"Perlmutt",t:50,d:"Bis zur Entdeckung der Insel Otomaïs und von Krustorallen war Perlmutt gänzlich unbekannt. Bei Juwelieren und Alchemisten sehr beliebt, auch wenn die Rezepturen in denen Perlmutt als Zutat vorkommt, streng geheim gehalten werden.",ep:0,g:4,l:50,wd:true,fm:true,w:10,p:5000};
I.u[9942] = {n:"Todesring",t:9,d:"Die Konstruktion dieses Ringes, dem man auch öfter unter dem Handelsnamen \"Der Schwarze Ring\" begegnet, scheint noch nicht abgeschlossen zu sein. Aber was macht das schon, wo seine Macht bereits ausreicht, um einen Mond zu zerstören?",ep:0,g:170,l:36,wd:true,fm:true,w:10,s:117,p:3600};
I.u[9943] = {n:"Charliefel",t:11,d:"Diese wunderschönen Schuhe sind überzogen mit einer Lackschicht aus... was auch immer dies für ein Lack gewesen sein mag, glänzen tut er, bis die Augen tränen!",ep:0,g:138,l:43,wd:true,fm:true,w:10,s:116,p:4975};
I.u[9944] = {n:"Chaplivatte",t:1,d:"Mit seiner doppelten Funktion als Krawatte und Amulett zugleich können euch eure Liebsten nach Belieben an der kurzen Leine führen. Und euch würde dies auch noch gefallen...",ep:0,g:145,l:43,wd:true,fm:true,w:10,s:116,p:5000};
I.u[9945] = {n:"Rucksack von Blubba dem Propheten",t:81,d:"Blubba war schon seit jeher ein Prophet, nämlich der Überbringer einer schlimmen Nachricht, die so alt war, dass er sie am Ende selbst vergaß. Darum beschloss er auch Kopfgeldjäger zu werden und sein Leben spektakulär im Magen einer großen Sandkreatur zu beenden.",ep:0,g:33,l:38,wd:true,fm:true,w:10,s:117,p:4050};
I.u[9946] = {n:"Kristall des Kain Dharyn",t:24,d:"Kain Dharyn war ein in ganz Amakna berühmter Schatzjäger. Unter seinen Entdeckungen befanden sich unter anderem kostbare Kristalle sie überraschende Eigenschaften verliehen, wie z.B. die Fähigkeit ohne Hände rückwärts zu schielen. Kain hielt den Ort des Kristallvorkommens verborgen und noch heute sind zahlreiche Enutrofs auf seiner Suche.",ep:0,g:744,l:1,wd:false,fm:true,w:0,p:1};
I.u[9947] = {n:"Verzauberter Kristall des Kain Dharyn",t:24,d:"Dieser verzauberte Kristall des Kain Dharyn vervielfacht die Gier jener, die ihn ansehen.",ep:0,g:717,l:1,wd:false,fm:true,w:0,p:1};
I.u[9948] = {n:"Schienbein des Anführers der Diebe",t:24,d:"Mit einem Schienbein weniger, läuft es sich für den Anführer der Diebe nicht so gut. Das geschieht ihm ganz recht.",ep:0,g:57,l:1,wd:false,fm:true,w:0,p:1};
I.u[9949] = {n:"Kart Ben-Teig",t:110,d:"Dieser Teig wurde von Kart Ben dem Geologen und Spezialisten auf dem Gebiet der Monsunregen erfunden, als er frühzeitig einer Arthrose im Rücken erlag. Dieser Teig hatte die Eigenschaft, bei Kontakt mit organischen Substanzen sofort hart zu werden, was Kart Ben dazu verhalf, sich aufrecht zu halten. Erst nach seinem Tod, wurde der Teig vor allem von den Enutrofs zweckentfremdet. Der einzige Nachteil ist der Geruch, was den Atem einiger  Enutröffchen erklärt.",ep:0,g:42,l:1,wd:false,fm:true,w:1,p:1};
I.u[9950] = {n:"Unreiner blauer Sudelstein",t:51,d:"Richtig poliert, enthüllt dieser Stein sein ganzes Potential.",ep:0,g:151,l:1,wd:false,fm:true,w:5,p:1};
I.u[9951] = {n:"Unreiner gelber Sudelstein",t:51,d:"Richtig poliert, enthüllt dieser Stein sein ganzes Potential.",ep:0,g:145,l:1,wd:false,fm:true,w:5,p:1};
I.u[9952] = {n:"Grüner unreiner Sudelstein",t:51,d:"Richtig poliert, enthüllt dieser Stein sein ganzes Potential.",ep:0,g:76,l:1,wd:false,fm:true,w:5,p:1};
I.u[9953] = {n:"Blauer Sudelstein",t:50,d:"Dieser Stein vermag eine Seele mühelos zu besudeln, was ganz praktisch sein kann, wenn man Tofus in Schattentofus verwandeln möchte. Mit anderen Sudelsteinen kombiniert, verleiht sie sogar absolute Kontrolle über besudelte Seelen.",ep:0,g:460,l:50,wd:false,fm:true,w:10,p:100};
I.u[9954] = {n:"Gelber Sudelstein",t:50,d:"Dieser Stein vermag eine Seele mühelos zu besudeln, was ganz praktisch sein kann, wenn man Tofus in Schattentofus verwandeln möchte. Mit anderen Sudelsteinen kombiniert, verleiht sie sogar absolute Kontrolle über besudelte Seelen.",ep:0,g:463,l:50,wd:false,fm:true,w:10,p:100};
I.u[9955] = {n:"Grüner Sudelstein",t:50,d:"Dieser Stein vermag eine Seele mühelos zu besudeln, was ganz praktisch sein kann, wenn man Tofus in Schattentofus verwandeln möchte. Mit anderen Sudelsteinen kombiniert, verleiht sie sogar absolute Kontrolle über besudelte Seelen.",ep:0,g:461,l:50,wd:false,fm:true,w:10,p:100};
I.u[9956] = {n:"Stein der Besudelten Seelen",t:24,d:"Dieser Stein stammt aus dem Brunnen der Besudelten Seelen. Mit ihm kann man die Seelen von Monstern kontrollieren, die in seinem Inneren eingeschlossen sind.",ep:0,g:462,l:1,wd:false,fm:true,w:0,p:1};
I.u[9957] = {n:"",t:114,d:"",ep:0,g:6,l:40,wd:false,fm:false,w:15,an:14,tw:true,e:[3,5,1,1,45,90,false,true],p:1};
I.u[9958] = {n:"Kiste mit Bonta Ausrüstung",t:24,d:"Dieses Kiste beinhaltet das Kit für den perfekten kleinen Milizionär. Wenn der Inhalt von der gleichen Qualität ist wie der Behälter, dann sollte es keinen wundern, dass die Miliz von Bonta in weniger als einem Tag besiegt wird.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9959] = {n:"Gutachten",t:24,d:"Ihr habt es euch schon gedacht und dieses Gutachten bestätigt es: die Ausrüstungen der Bonta-Milizionäre sind von schlechter Qualität. Diese Nachricht dürfte Oto Mustam freuen.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9960] = {n:"Schlüssel zur Lagerhalle",t:24,d:"Dieser Behälter enthält den gesamten Mageninhalt von Schluckspecht. Irgendwo dort drin befinden sich also auch die Schlüssel zur Lagerhalle. Was tut man nicht alles, um seinen Auftrag zu erfüllen...",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9961] = {n:"Martellhammer",t:7,d:"Dieser Hammer von nur minderwertiger Qualität wurde zum Hereinlegen von Schmieden entworfen, um diese glauben zu lassen, sie hätten da ein ausgezeichnetes Stück Wertarbeit in den Händen. Es wird stark davon abgeraten, diesen Hammer zu benutzen, selbst wenn man nichts damit machen will.",ep:0,g:2,l:1,wd:true,fm:false,w:5,an:15,e:[5,4,1,1,60,20,false,false],p:10};
I.u[9962] = {n:"Kiste mit Erzen",t:24,d:"Ihr habt diese Kiste mit Erzen gestohlen, damit Matra Tse keine neuen Ausrüstungen für die Bonta-Milizionäre schmieden kann.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9963] = {n:"Schmiedehammer",t:24,d:"Ihr habt diesen Hammer von Matra Tse entwendet und ihn durch einen Martellhammer ersetzt. Matra Tse ist dermaßen unfähig, dass er den Unterschied kaum bemerken dürfte.",ep:0,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9964] = {n:"Kramelehon-Dracotruter - Geschenk",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell!",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9965] = {n:"Methode zur Hundeaufzucht",t:24,d:"Diese Methode, die vom berühmten Maunzmiezbändiger Riyou Tchevlakouk entwickelt wurde, erklärt, wie man einen Blutwolf bezähmt und ihn zum besten Freund des Menschen macht.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9966] = {n:"Beute vom Warentransport",t:24,d:"Diese Beute habt ihr beim Angriff auf einen Warentransport aus Bonta ergattert. Trampl im Milizgebäude von Brâkmar wird euch für eure Mühe belohnen. Mit ein wenig Glück lässt er euch vielleicht sogar in einem Stück weggehen.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9967] = {n:"Wie man Omniberg zubereitet",t:24,d:"Laura Soho, die Kellnerin der Taverne in Amakna, hat euch auf diesem Stück Papier aufgeschrieben, wie man mit Hilfe eines Alchemisten eine gute Flasche Omniberg zubereitet.\nDazu braucht ihr:\n- 5 Phiolen Pandaberg\n- 1 Omni-Rum\n- 10 Schalatblätter",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9968] = {n:"Flasche Omniberg",t:79,d:"Dieses übermächtige Alkoholgemisch reißt einem die Zunge heraus, zerraspelt den Gaumen, verbrennt die Speiseröhre und lässt den Magen explodieren, bevor das Gehirn zu Kochen beginnt. Ein Getränk nur für waschechte Pandawas! Ganz klein steht unten auf der Flasche: Alkoholmissbrauch gefährdet die Gesundheit, nur in Massen zu genießen, außer es handelt sich um ein Trankopfer für die Göttin.",ep:0,g:177,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[9969] = {n:"Vergifteter Fischschalat",t:15,d:"Wie das Sprichwort sagt: Ein Geruch kommt selten allein. Der Duft, der von diesem Fischschalat ausgeht, überdeckt ein starkes Gift, das man sobald man es verschluckt hat, gleich wieder hochwürgt. Genau das Richtige um langweilige Hochzeitsfeiern zu beleben oder seinem Lieblingsgildenmeister einen Streich zu spielen.",ep:0,g:80,l:1,wd:false,fm:true,w:1,p:1};
I.u[9970] = {n:"Fischschalat-Rezept",t:24,d:"Grobinson Grubolé hat das Rezept für Fischschalat in den Sand am Strand geschrieben und ihr habt es auf ein Stück Papier übertragen. \n- Einen Fischer (nach Geschmack, muss aber nicht sein) \n- 2 Seebarsche \n- 3 Krebsstäbchen*** \n- 2 Zitronen\n- 4 Schalatblätter\n- 1 Vergifteter Blobkuchen (als persönliche Note)",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9971] = {n:"Mulic Beres Schlüssel",t:24,d:"Diese Schlüssel gehören Mulic Bere. Sie dienen zum Öffnen seiner Spezialschmiede, in der man, unter anderem, ungewöhnliche Gegenstände für gewöhnliche Leute, wie ihr es seid, herstellen kann.",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9972] = {n:"Schmiedehammer für Kratzer",t:7,d:"Dieser Schmiedehammer wurde zu einem ganz bestimmten Zweck hergestellt, was seine Verwendung für andere Aufgaben schwierig macht. Nur eine verzweifelte Person oder ein Außenseiter würde ihn zum Schmieden von Waffen benutzen.",ep:0,g:2,l:1,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,50,false,false],c:"PJ>20,49",p:150};
I.u[9973] = {n:"Endstück des Kratzers",t:15,d:"Dieses Kratzer-Endstück besitzt mehrere Scharniere, um seine Anwendung zu erleichtern. Die zahlreichen Dornen bestätigen die Redewendung aus Amakna: \"Ich bin dir ein Dorn im Auge.\"",ep:0,g:716,l:1,wd:false,fm:true,w:1,p:1};
I.u[9974] = {n:"Handschnitzer",t:5,d:"Wenn ihr diesen Schnitzer im Kampf verwendet, wird das ins Auge gehen und ihr könnt dabei den Kopf verlieren, bevor ihr auch nur eure Beine in die Hand nehmen könnt.",ep:0,g:17,l:1,wd:true,fm:true,w:5,e:[5,4,1,1,50,50,false,false],c:"PJ>19,49",p:150};
I.u[9975] = {n:"Handgriff des Kratzers",t:15,d:"Alleine ist euch der Handgriff zu nichts nutze. Man kann einen Kratzer an seinem Ende befestigen, aber das würde euch auch nicht weiterhelfen. Nur ein krankes Hirn wird wissen, wozu es gut ist.",ep:0,g:52,l:1,wd:false,fm:true,w:5,p:1};
I.u[9976] = {n:"Unfertiger Rückenkratzer",t:15,d:"Dieser Rückenkratzer ist fast perfekt. Fast, aber nicht ganz. Nur ein Schmied von großem Talent kann ihn fertigstellen. Dummerweise kennt ihr keinen.",ep:0,g:52,l:1,wd:false,fm:true,w:10,p:1};
I.u[9977] = {n:"Spentox Rückenkratzer",t:24,d:"Dieser mit Dornen gespickte Rückenkratzer ist so gestaltet, dass er die Form des Körpers annimmt und so selbst bis dahin nur schwer zugängliche Bereiche erreicht.",ep:0,g:745,l:1,wd:false,fm:true,w:0,p:1};
I.u[9978] = {n:"Floharmee der Keiler der Ebenen",t:24,d:"Grösser als Fresssackflöhe, können Flöhe von Keilern der Ebenen das Hundertfache an Eigengewicht in Blut absorbieren. Das lässt Vampire und selbst Dark Vlad vor Neid erblassen.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9979] = {n:"Zaubertrank für Langlebigkeit",t:12,d:"Der Alchemist Nileza braute diesen Trank in der Hoffnung, mit ihm unsterblich zu werden.\nLeider starb er, bevor er ihn benutzen konnte;\r\n            er hatte den Trank mit vergiftetem Einohrblut verwechselt.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[9980] = {n:"Greu-fettgericht",t:49,d:"Dieses Gericht veranschaulicht den Lieblingsausspruch des Ritters Kacador: \"Fett ist Leben\".",ep:0,g:82,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9981] = {n:"Sägemehl",t:52,d:"Dieses Mehl wurde von Xaver, dem Bäcker benutzt, um Brote herzustellen, die jedes Mal bei den Begräbnissen des Minnesängers Oh\'Nein serviert wurde.",ep:0,g:7,l:1,wd:false,fm:true,w:1,p:1};
I.u[9982] = {n:"Ritterschlagssalat",t:69,d:"Der Name dieses Salats ist eine Hommage an den Tag seiner Zubereitung, denn er wurde da zum ersten Mal zur Ritterschlagszeremonie des Ritters Kacador serviert. Wie alles Essen, das für den Ritter bestimmt ist, ist dieser Salat für Vegetarier nicht geeignet.",ep:0,g:129,l:1,wd:false,fm:true,w:5,u:true,ut:true,p:1};
I.u[9983] = {n:"Popelbrot",t:33,d:"Dieses Brot, das bei den Begräbnissen des berühmten Minnesängers Oh\'Nein serviert wurde, hat einen so ekelhaften Geschmack und Geruch, dass er Tote auferwecken und Lebende in die ewigen Jagdgründe schicken könnte. Dies würde die zahlreichen Comebacks ins Leben des Minnesängers Oh\'Nein erklären.",ep:0,g:13,l:1,wd:false,fm:true,w:2,u:true,ut:true,p:1};
I.u[9984] = {n:"Liste mit Zutaten von einst",t:24,d:"Hier ist die Liste von Oto Mustam:\n- 1 Popelbrot\n- 1 Ritterschlagssalat\n- 1 Greu-fettgericht\n- 1 Zaubertrank für Langlebigkeit",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9985] = {n:"Rezept für Popelbrot",t:24,d:"- 2 Sägemehl\n- 5 Wasser\n- 2 Bäckerhefe",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9986] = {n:"Rezeptur für Sägemehl",t:24,d:"- 1 Spezialmehl von Xaver, dem Bäcker \n - 1 Eniripsa Pulver \n - 4 Zwiebeln",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9987] = {n:"Rezept für Ritterschlagssalat",t:24,d:"- 5 Monsterschnauzsalat***\n- 20 Blobpollen\n- 10 Astaknydenknospen",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9988] = {n:"Rezept für das Greu-fettgericht",t:24,d:"- 10 Greu-Vetten*** im Teigmantel  \n- 5 Zitronen \n- 10 Schalatblätter",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9989] = {n:"Rezeptur für den Zaubertrank für Langlebigkeit",t:24,d:"- 2 Einohrsblut\n- 10 Biokatalysatränke\n- 2 Tränke der Erinnerung",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9990] = {n:"Cheekahs Broche",t:24,d:"Diese Broche habt ihr von Cheekah als Dank erhalten, nachdem ihr seinen Warentransport tapfer verteidigt habt. Die Broche ist gleichfalls ein Pfand für sein Versprechen, euch nach seiner Rückkehr nach Bonta noch einmal persönlich zu danken.",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9993] = {n:"Sa Biene",t:32,d:"Ihr seid damit beauftragt worden, Sa Biene zum Milizgebäude von Brâkmar zu eskortieren.",ep:0,g:25,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9995] = {n:"Söldner-Schriftrolle des Findens",t:87,d:"Diese Schriftrolle erlaubt es euch, das Ziel eurer Jagd zu lokalisieren.",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps=3",u:true,p:1};
I.u[9996] = {n:"Bündel von hundert Söldner-Schriftrollen",t:87,d:"Dieses Bündel erlaubt es euch, <b>EINE einzelne Zielperson</b> zu \"markieren\", damit Söldner sie später mehrfach jagen können.",ep:0,g:3,l:10,wd:false,fm:true,w:100,ut:true,p:3500};
I.u[9997] = {n:"Schlüssel zum Unterschlupf der Räuber",t:24,d:"Dies ist der Schlüssel zum Unterschlupf der Räuber. Cette clef permet d\'ouvrir la porte du repaire des bandits. Dank Grimpill wisst ihr, dass die Tür gleich nach Eintritt durch einen Mechanismus sofort wieder verschlossen wird. Darum besitzt jede Person mit Zutritt zum Räuberunterschlupf einen eigenen Schlüssel.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9999] = {n:"Kopie des Schlüssels zum Unterschlupf der Räuber",t:84,d:"Diese Kopie des Schlüssels zum Unterschlupf der Räuber sieht so aus, als könnte sie jederzeit entzwei brechen. Und nach Murphys Gesetz genau in dem Moment, wo sie eingesetzt wird. Heutzutage erhält man auch keine Qualität mehr bei seinen Fälschungen!",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10000] = {n:"Grimpills Achselhaare",t:24,d:"Sobald ihr dieses Büschel Haare in den Händen haltet, habt ihr den Eindruck, dass sich da was bewegt. Und wenn ihr näher hinseht, dann merkt ihr, dass es keine Haar sind, sondern eine Handvoll Flöhe und Riesenzecken. Kurz gesagt, ihr haltet ein echtes Ökosystem in euren Händen.",ep:0,g:30,l:1,wd:false,fm:true,w:0,p:1};
I.u[10001] = {n:"Bündel von zehn Söldner-Schriftrollen",t:87,d:"Dieses Bündel erlaubt es euch, <b>EINE einzelne Zielperson</b> zu \"markieren\", damit Söldner sie später mehrfach jagen können.",ep:0,g:3,l:10,wd:false,fm:true,w:10,ut:true,p:500};
I.u[10002] = {n:"Söldner-Schriftrolle",t:87,d:"Diese Schriftrolle erlaubt es euch, <b>EINE einzelne Zielperson</b> zu \"markieren\", damit Söldner sie später jagen können.",ep:0,g:1,l:10,wd:false,fm:false,w:1,ut:true,p:100};
I.u[10003] = {n:"Wabbelesch Bischmalz ",t:110,d:"Die Rezeptur für diese künstliche Gelatine ist nur Liroye Merlin bekannt. Aber es heißt, dass das Bischmalz fest wird, wenn es mit nassem Rasen in Kontakt tritt und anschließend die Form des Gegenstandes annimmt, der vorhin hineingetaucht wurde. Darum ist die Gelatine ideal zum Herstellen von Gussformen.",ep:0,g:47,l:1,wd:false,fm:true,w:0,p:1};
I.u[10004] = {n:"Die Kunst das Wabbelesch Bischmalz richtig zu verwenden",t:24,d:"Dieses Schriftstück von Liroye Merlin erläutert Tausende von Anwendungsbeispiele für das Wabbelesch Bischmalz. Der interessanteste Teil ist mit Abstand folgender: Wie kann man günstig Schlüssel herstellen? Man vermischt miteinander: \n- 1 Wabbelesch Bischmalz\n- 1 Einheit Wuchernde Gräser\n- 1 Backelitit",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10005] = {n:"Geheime Dokumente",t:24,d:"Eine Liste mit geheimen Dokumenten von Bonta. Da kann man sich wirklich die Frage stellen, wie es passieren kann, dass sich solche Dokumente im Unterschlupf der Räuber wiederfinden...",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10006] = {n:"Verdächtiger Bericht",t:24,d:"Dieser Bericht lässt euch in sehr verdächtigem Licht erscheinen. Eure Loyalität zu Bonta wird angezweifelt und ihr habt Anteil an zahlreichen unsauberen Geschäften. Nur ein Experte könnte entscheiden, ob es sich um ein authentisches Dokument handelt oder nicht.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10007] = {n:"Phiole mit Brâk-Gift",t:24,d:"Diese Phiole mit Brâk-Gift nach hauseigenem Rezept trägt die Aufschrift:\"An einem warmen Ort aufbewahren und nach Öffnen langsam einnehmen\". Weiter unten folgt noch das Kleingedruckte:\"Nicht schlucken, außer ihr seid Bonta oder das Opfer\". Offensichtlich sind die Brâks nicht zu Späßen aufgelegt, wenn es um ihr Gift geht.",ep:0,g:39,l:1,wd:false,fm:true,w:0,p:1};
I.u[10008] = {n:"Kundenregister",t:24,d:"Dieses Register enthält eine Liste aller Kunden, die in den letzten zwei Wochen Bestellungen in der Werkstatt der Alchimisten aufgegeben haben. Das Problem ist nur, dass alles in Brâksprache geschrieben ist und ihr kein Wort davon versteht.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10009] = {n:"Xephirex",t:32,d:"Ihr müsst nun den Verräter Xephirex zu Amayiro bringen. Dort wird er dann für seine Sünden geradestehen müssen.",ep:0,g:24,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10010] = {n:"Schlüssel zum Spielsaal",t:24,d:"Dieser Schlüssel verschafft Zugang zum Spielsaal des  Gasthauses \"Zur Brennenden Katze\".",ep:0,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[10011] = {n:"Trapes Herz",t:24,d:"Dies ist das noch schlagende Herz von Trape. Dass euch kein einziger Sram Anhänger Widerstand geleistet hat, als ihr ihn umgebracht habt, wundert euch zwar immer noch, aber nach längerer Überlegung kommt ihr zum Schluss, dass es ohnehin aufs Gleiche hinausgelaufen wäre. Und so bringt ihr eurem heißgeliebtem Chef dieses Herz.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10012] = {n:"Trapes Herz",t:24,d:"Dies ist das noch schlagende Herz von Trape. Dass euch kein einziger Sram Anhänger Widerstand geleistet hat, als ihr ihn umgebracht habt, wundert euch zwar immer noch, aber nach längerer Überlegung kommt ihr zum Schluss, dass es ohnehin aufs Gleiche hinausgelaufen wäre. Und so bringt ihr eurem heißgeliebtem Chef dieses Herz.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10013] = {n:"Trapes Herz",t:24,d:"Dies ist das noch schlagende Herz von Trape. Dass euch kein einziger Sram Anhänger Widerstand geleistet hat, als ihr ihn umgebracht habt, wundert euch zwar immer noch, aber nach längerer Überlegung kommt ihr zum Schluss, dass es ohnehin aufs Gleiche hinausgelaufen wäre. Und so bringt ihr eurem heißgeliebtem Chef dieses Herz.",ep:0,g:518,l:1,wd:false,fm:true,w:0,p:1};
I.u[10014] = {n:"Trapes Scheck",t:24,d:"Dieser für Oto Mustam bestimmte Scheck wurde von Trape vorbereitet. Schade, dass es sich nicht um klingende Kamas handelt, sonst hättet ihr euch diskret bedienen können.",ep:0,g:54,l:1,wd:false,fm:true,w:0,p:1};
I.u[10015] = {n:"Oto Mustams Einkaufsliste",t:24,d:"Ihr seid beim Böswilligkeitstest kläglich gescheitert und Oto Mustam will es euch heimzahlen, indem ihr folgende Gegenstände finden sollt: \n- 1 Sack mit Bronze\n- 1 Sack mit Malz\n- 1 Sack Hanfblüten",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10016] = {n:"Metaxt",t:24,d:"Diese schlichte Axt scheint einer anderen Epoche anzugehören. Die Qualität ist so mittelmäßig, dass man damit kaum einen Trunknyden zerhacken kann.",ep:0,g:746,l:1,wd:false,fm:true,w:0,p:1};
I.u[10017] = {n:"Naras Katana",t:24,d:"Dieses Katana wurde von Nara geschmiedet, als er auf die Probe gestellt wurde. Es ist der Metaxt des Matra Tse haushoch überlegen!",ep:0,g:53,l:1,wd:false,fm:true,w:0,p:1};
I.u[10018] = {n:"Bauanleitung für Wäscheklammern",t:15,d:"Diese Anleitung ist so klar und deutlich, dass vielleicht sogar ein Iopkind es begreifen könnte. Naja, vielleicht. Denn ein Iop ist und bleibt ein Iop. Ein Bastler könnte anhand dieser Anleitung allerlei Gegenstände herstellen und wenn es sich dabei um einen Iop handelt, geschieht eventuell ein Wunder. \nIhr benötigt dazu die hiesige Anleitung, 10 Bretter aus Kalyptusholz und 10 Aluminite.",ep:0,g:767,l:1,wd:false,fm:true,w:1,p:1};
I.u[10019] = {n:"Eimer mit Wäscheklammern",t:15,d:"Dieser Eimer enthält so viele Wäscheklammern, dass man mit ihnen die Unterhosen der ganzen Garnison von Amakna auf den Stadtmauern aufhängen könnte. Man kann sie auch dazu benutzen, um Häute und Felle frisch erlegter Monster (oder der Erzfeinde) zum Trocknen aufzuhängen.",ep:0,g:768,l:1,wd:false,fm:true,w:10,p:1};
I.u[10020] = {n:"Zerschlissenes Püppchen",t:24,d:"Kaum zu glauben, dass dieses heruntergekommene und stinkende Püppchen einst ein mächtiger Bwork Magus war. Aber dann fällt euch ein, dass alle Bwork Magi heruntergekommen sind und stinken. Es ist also alles in bester Ordnung.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10021] = {n:"Zusammengeflicktes Püppchen",t:24,d:"Ob diese Puppe nun besser aussah, bevor Maskara sie zusammengeflickt hat oder danach, ist schwer zu sagen. Doch eines ist sicher. Nur ein Gott könnte eine Puppe schöner machen, als das Original. Kein Wunder, warum sich der Bwork Magus in einer Höhle eingesperrt hatte und stets schlecht gelaunt war.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10022] = {n:"Verzaubertes Püppchen",t:24,d:"Wie bezaubernd, dieses verzauberte Püppchen vom Zauberer höchstpersönlich zu erhalten, der es in den verzauberten Seen verzaubert hatte. Wäre er noch am Leben, hätte es euch der Minnesänger O\'Heins singend überreicht.",ep:0,g:747,l:1,wd:false,fm:true,w:0,p:1};
I.u[10023] = {n:"Patrouillenregister",t:24,d:"Es wird die Strecke beschrieben, die von den Brâk-Patrouillen zurückgelegt wird. Wer hier einen Hinterhalt plant, hat nun freie Auswahl.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10024] = {n:"Alter Bwork Grimoire",t:24,d:"Dies ist ein alter Grimoire eines Bwork Magus der dunklen Höhlen, was bedeutet, dass die Bilder die dort enthalten sind für einen modernen Bwork Magus der dunklen Höhlen nur schwer verständlich ist und für einen gewöhnlichen Bwork Magus nahezu unmöglich. Bleibt nur zu hoffen, dass Danathor hierfür einen Nutzen findet. Wär doch schade, wenn ihr euch die Mühe umsonst gemacht hättet, oder?",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10025] = {n:"Omniberg-Fieber",t:30,d:"Man hat\'s euch gesagt: Omniberg-Missbrauch gefährdet die Gesundheit.",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10026] = {n:"Fischschalat-Rezept",t:24,d:"Grobinson Grubolé hat das Rezept für Fischschalat in den Sand am Strand geschrieben und ihr habt es auf ein Stück Papier übertragen. - Einen Fischer (je nach Geschmack, muss aber nicht sein) - 2 Seebarsche - 3 Krebsstäbchen*** - 2 Zitronen - 4 Schalatblätter - 2 Grünglis (als persönliche Note)",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10028] = {n:"Rezeptur für Flickenstoff",t:24,d:"Diese Rezeptur wurde vom Schneider Tosh entwickelt, um magische Kleider zusammenzuflicken. Erfahrene Schneider können sich dieser Rezeptur bedienen, um einen Stoff herzustellen, der Wind und Wetter trotzt. \n- 5 Bwork Magus-Barthaare \n- 5 Black Tiwabbit-Haare \n- 3 Barthaare eines Grand Pa-Wabbit \n- 3 WullyWuWulf-Haare \n- 1 Seidenfaden",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10029] = {n:"Rezeptur für Blutorange-Färbemittel",t:24,d:"Diese Rezeptur wurde vom berühmten Alchemisten Salg Zengaer entwickelt aber wurde noch nie ausprobiert, weil Salg Zengaer die Rezeptur bei seinem Freund Tosh vergessen hat, der es euch großzügig erweise geschenkt hat.\n- 1 Magisches rotes Färbemittel\n- 1 Magisches orangefarbenes Färbemittel\n- 10 Einheiten Fresssackblut\n- 5 Glänzende Sardinen",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10030] = {n:"Flickenstoff",t:55,d:"Dieser synthetische Stoff wurde vom Schneider Tosh erfunden und gestattet das Flicken von magischen Kleidern ohne ihre Kräfte zu mindern. Verständlich, warum er bei erfahrenen Schneidern so beliebt ist.",ep:0,g:434,l:1,wd:false,fm:true,w:1,p:1};
I.u[10031] = {n:"Blutorange-Färbemittel",t:70,d:"Dieses Magische Färbemittel wurde von Salg Zengaer erfunden und ist extrem aggressiv, als ob es von einer Macht dazu gedrängt wird, Böses zu tun. Es stellt sich also die Frage, warum es so böse ist.",ep:0,g:63,l:1,wd:false,fm:true,w:1,p:1};
I.u[10032] = {n:"Flicken-Bandana",t:24,d:"Dieser Bandana befindet sich weitaus besserem Zustand als er gefunden wurde. Er riecht weniger nach Kawotte und mehr nach Fisch, Tökredilsch wird sich freuen, ihn in so gutem Zustand wieder zu bekommen.",ep:0,g:749,l:1,wd:false,fm:true,w:0,p:1};
I.u[10033] = {n:"Missionsbefehl",t:24,d:"Dieser von Gerti Gertisorf unterschriebene Missionsbefehl besagt den Brâks, dass sie all ihre Dokumente Miss H. N. Delung geben sollen, die vor dem Ordensturm von Brâkmar Wache schiebt.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10034] = {n:"Liste von Magus X",t:24,d:"Dies ist die Liste an Gegenständen, die für das Ritual der Offenbarung benötigt werden:\n- 5 Elementartränke: Nieselregen\n- 10 Einheiten Wasser\n- 10 Pandürbis-Samen\n- 4 Einheiten Wunderpulver\n- 2 Einheiten Hainbuchenholz\n- 4 Elementartränke: Windhauch\n- 2 Vertrauenspersonen dabei haben\n- KEINEN Schwefel dabei haben",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10035] = {n:"Ergebnis der Offenbarung",t:24,d:"Magus X hat auf dieser Schriftrolle das Ergebnis des Rituals der Offenbarung niedergeschrieben. Um das Horn des Ih-Fritts zu benutzen, muss man nur seine Hand hinein tauchen und schon hat man frittierte Kartoffelstäbchen.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10036] = {n:"Spielkrallen-Feenwerk",t:74,d:"Als Mylaise im Höllehmturm lebte, wo oft Langeweile aufkam, befahl sie einem Handwerksmeister aufwendiges Feenwerk zu ihrer Unterhaltung herzustellen. Er kam ihrer Bitte so begeistert nach, dass sie auch heute noch hin und wieder einige verteilen kann, wenn sie gut aufgelegt ist.",ep:0,g:30,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10038] = {n:"Rezeptur für einen Behälter",t:24,d:"Der alte Bergmann Ra Gut hat euch die Rezeptur für den Korruptit-Behälter auf diesem alten Stück Papier hingekritzelt. Es riecht nach Schweiß und Schwefel.\n- 2 Ulmenholz\n- 3 Geschliffenes Krachlklotzherz\n- 2 Korallenbeutel (kann man in den Eingeweiden eines Mufahfah finden)\n- 1 Holzfäller, der erfahren genug ist, um die Herstellung nicht zu vermasseln.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10039] = {n:"Geschliffenes Krachlklotzherz",t:51,d:"Dieses Herz aus polierten Stein sieht dem Herzen des Geschliffenen Krachlers zum Verwechseln ähnlich, ist aber kleiner. Sein Gewicht steht im umgekehrten Verhältnis zu seiner Größe, Zeichen des in ihm eingeschlossenen mächtigen Zaubers oder ist einfach nur ein Irrtum.",ep:0,g:7,l:1,wd:false,fm:true,w:20,p:1};
I.u[10040] = {n:"Korallenbeutel",t:15,d:"Dieser Beutel ist sein Gewicht in Korallen wert. Man kann sich zu recht fragen, wie er in die Eingeweide eines räudigen Mufahfah gelangt ist.",ep:0,g:54,l:1,wd:false,fm:true,w:250,p:1};
I.u[10041] = {n:"Korruptit-Behälter",t:15,d:"Dieser Behälter dient zum Konservieren und Transportieren von Korruptit. Wenn man kein Korruptit besitzt, kann man immer noch was anderes darin transportieren.",ep:0,g:56,l:1,wd:false,fm:true,w:50,p:1};
I.u[10042] = {n:"Raue Zunge - Feenwerk",t:74,d:"Als Mylaise im Höllehmturm lebte, wo oft Langeweile aufkam, befahl sie einem Handwerksmeister aufwendiges Feenwerk zu ihrer Unterhaltung herzustellen. Er kam ihrer Bitte so begeistert nach, dass sie auch heute noch hin und wieder einige verteilen kann, wenn sie gut aufgelegt ist.",ep:0,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[10043] = {n:"Ein Hauch von Schönheit\' - Lotion",t:30,d:"Eine sehr mächtige Schönheitslotion gab euch dieses Aussehen... perfekt um große Katerchen zum dahinschmelzen zu bringen! Miauuuh!",ep:0,g:2,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10044] = {n:"Mylaises Schönheitslotion",t:12,d:"Mylaise trägt diese Lotion jeden Morgen auf ihren Körper auf, um jung und schön auszusehen... probiert es nur selbst einmal aus - sie wirkt wirklich!\nAllerdings reicht bei euch eine kleine Kampfhandlung bereits aus, um wieder alt und hässlich auszusehen... eine Lotion macht eben noch lange keine Liebespriesterin aus!",ep:0,g:40,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10045] = {n:"Rezeptur für die Selbstgemachte Knute",t:24,d:"Diese improvisierte Rezeptur erklärt, wie man eine Knute herstellt, eine seltsame Waffe für Kreaturen mit seltsamen Gebräuchen. Es werden folgende Zutaten dafür benötigt:\n- 5 Ouginak-Ketten\n- 5 Ebonit\n- 50 Tofuschnäbel\n- 5 Gleister\n- 5 Bretter aus Kastanienholz",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10046] = {n:"Selbstgemachte Knute",t:24,d:"Der Bastler hat diese Kiste aus übriggebliebenen Brettern aus Kastanienholz gezimmert, um die Knute vor Unwetter zu schützen, jedenfalls behauptet er das. Es sieht eher so aus, als ob er unschuldige Augen vor dem Anblick schützen möchte.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10047] = {n:"Rezeptur zur Herstellung eines Talismans des bösen Blicks",t:24,d:"Um einen Talisman des bösen Blicks herzustellen, benötigt ihr die Hilfe eines (lebenden) Juweliers und folgende Zutaten:\n- 5 Rippchen\n- 1 WuWulf-Auge\n- 10 Leinenschnüre",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10048] = {n:"Zutaten für die Aerol-Lotion",t:24,d:"Hier die Liste mit den Zutaten für die Herstellung der Aerol-Lotion:\n- 5 Elementartränke: Windhauch\n- 2 Trunknydenholz\n- 2 WuWulf-Haare\n- 20 Einheiten Wunderpulver \n- 10 Einheiten Zeitpulver\n- 2 Blaubeergelee\n- 3 Biokatalysatränke\n- 4 grüne Larvenhäute\n-  2 Personen deines Vertrauens (oder auch nicht)\n- KEINEN Tabaksbeutel voller Schwefel",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10049] = {n:"Talisman des bösen Blicks",t:1,d:"Dieser Talisman scheint euch nicht aus den Augen zu lassen, was ihn ziemlich beunruhigend macht und in euch eine ausgeprägte Paranoia hervorruft.",ep:0,g:45,l:1,wd:false,fm:true,w:5,p:1000};
I.u[10050] = {n:"Tekelests Fluch",t:30,d:"Dieser Fluch macht euch für die Raserei der Elemente empfindlicher. Es sieht so aus, als ob der Talisman gegen den Bösen Blick seine Aufgabe nicht erfüllt hätte. Ihr müsst sofort mit Divad Dleifrepok sprechen.",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10051] = {n:"Lavageist",t:32,d:"Ihr habt diesen Geist dazu gezwungen, euch bis zu Mulic Beres Schmiede zu folgen. Ihr beeilt euch besser, denn es sieht ganz so aus, als ob er schon angefangen habe zu erkalten.",ep:0,g:17,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10052] = {n:"Trank des Vergessens: \'Seelenlasso\'",t:43,d:"Dieser Trank lässt euch einen Grad des Spezialzaubers \"Seelenlasso\" vergessen.",ep:0,g:31,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[10053] = {n:"",t:9,d:"",ep:0,g:172,l:50,wd:false,fm:true,w:1,p:1};
I.u[10054] = {n:"Vampyring",t:9,d:"Dieser Ring hat drei lange Jahre hindurch in Fleddermausguano gelegen. Aber er ist nach wie vor magisch!",ep:0,g:171,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4703};
I.u[10055] = {n:"Vampyr-Amulett",t:1,d:"Dieses Amulett soll eventuellen blutsaugenden Vampyren, die euch in den Hals beißen wollen, signalisieren, dass dies unnötig ist, da ihr selbst bereits ein Vampyr seid.",ep:0,g:146,l:45,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:5500};
I.u[10056] = {n:"Vampyr-Gürtel",t:10,d:"Auf dem Werbeslogan steht: \"Und außerdem leuchtet er nachts!\" Wie, außerdem? Außerdem zu was?!?",ep:0,g:156,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4805};
I.u[10057] = {n:"Jagdrune",t:78,d:"\"Also, ein schlechter Jäger, der hat einen Bogen...und der sieht, wie sich was bewegt und schiesst! Ein guter Jäger, der hat auch einen Bogen, er sieht, wie sich was bewegt und schiesst, aber naja...ist ein guter Jäger...\" Dank dieser Rune könnt ihr dies mit egal welcher Waffe überprüfen.",ep:0,g:60,l:10,wd:false,fm:true,w:1,p:10};
I.u[10058] = {n:"Vampyr-Umhang",t:17,d:"Bram hatte Recht: man sollte sich immer vor Kreaturen mit langen Zähnen hüten. Besonders, wenn diese auch noch einen Vampyr-Umhang tragen...",ep:0,g:168,l:41,wd:true,fm:true,w:5,c:"PO!10119",s:130,p:4550};
I.u[10059] = {n:"Schattenhainbuchenholz",t:38,d:"Das Holz der Schattenhainbuche ist mit dem Holz der Hainbuche identisch, bloß kommt noch ein mieser Charakter hinzu. Es kann zum Schmieden unheilvoller Waffen verwendet werden...wie zum Beispiel einem Schwert.",ep:0,g:138,l:1,wd:false,fm:true,w:5,p:1};
I.u[10060] = {n:"Schwertgriff aus Schattenhainbuchholz",t:15,d:"Dieser Schwertgriff wurde aus Schattenhainbuchholz geschnitzt. Alleine ist sie zu nichts nutze, aber mit der passenden Klinge wird aus ihr eine unheilvolles Schwert.",ep:0,g:97,l:1,wd:false,fm:true,w:1,p:1};
I.u[10061] = {n:"Vampyr-Stiefel",t:11,d:"Es heißt, dass einst Elizabeth Batterrory diese Stiefel getragen haben soll. Sie war eben beinreich.",ep:0,g:139,l:41,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4550};
I.u[10062] = {n:"Marks Knochen",t:47,d:"Dieser Knochen sieht dem eines Chafers zum Verwechseln ähnlich, aber dem ist nicht so. Der Knochen gehörte dem berühmten Abenteurer Mark, an dessen Heldentaten sich niemand erinnert und an dessen Geschmack sich der MuWulf auch nicht mehr entsinnen kann.",ep:0,g:15,l:1,wd:false,fm:true,w:5,p:1};
I.u[10063] = {n:"Ein Hauch von Schönheit\' - Lotion",t:31,d:"Eine sehr mächtige Schönheitslotion gab euch dieses Aussehen... perfekt um große Katerchen zum dahinschmelzen zu bringen! Miauuuh!",ep:0,g:13,l:1,wd:false,fm:false,w:0,m:true,p:1};
I.u[10064] = {n:"Magisches finsteres Färbemittel",t:70,d:"Dieses äußerst seltene, magische Färbemittel wird hauptsächlich bei Exorzismen und Ritualen schwarzer Magie benutzt. Der Geruch der von ihm ausgeht ist schlimmer, als der von Troolfürzen nach ausgedehntem Osamodasverzehr.",ep:0,g:67,l:1,wd:false,fm:true,w:0,p:1};
I.u[10065] = {n:"Aerol-Lotion",t:24,d:"Diese Lotion wurde vor langer, langer Zeit vom Enutrof-Alchemisten Aerol erfunden, der ein Mittel gegen Haarausfall finden wollte. Dummerweise schützte sie ihn nicht vor Steinschlag und er starb bei einer Partie Krachlerkegeln plattgedrückt von einem Felsen.",ep:0,g:752,l:1,wd:false,fm:true,w:0,p:1};
I.u[10066] = {n:"Alptraumhafter Weihrauch",t:24,d:"Dieser magische Weihrauch wurde aus den Alpträumen der vom Orden des Kranken Geistes gefolterten Gefangenen gewonnen. Ihr Preis ist genauso krank wie jene, die ihn hergestellt haben.",ep:0,g:37,l:1,wd:false,fm:true,w:0,p:1};
I.u[10067] = {n:"Werkstattschlüssel von Sotzio Paht",t:84,d:"Dieser Schlüssel verschafft euch Zutritt zur Werkstatt des großen Schmiedmagiers Sotzio Paht, in den Kellergeschossen von Brâkmar. Weil er nicht so oft gestört werden will, hat er den Schlüssel verzaubert, damit er sich nach Benutzung in Luft auflöst.",ep:0,g:61,l:1,wd:false,fm:true,w:1,p:1};
I.u[10068] = {n:"Unheilvolles Schwert",t:24,d:"Dieses Schwert strahlt eine spürbar unheilvolle Aura aus. Denkt nicht einmal im Traum dran, es zu entwenden, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und das wollt ihr ganz bestimmt NICHT.",ep:0,g:725,l:1,wd:false,fm:true,w:0,p:1};
I.u[10069] = {n:"Fass KO-Met",t:24,d:"Dieses Fass enthält einen sehr starken Alkohol der mit Ringelschnattergift und MuWulf-Ohrenschmalz destilliert wurde. Davon zu trinken und sei es nur ein kleines Schlückchen, ruft schwere Gerhirnschäden hervor. Daher ist er auch so bei den Iops beliebt, die davon ohne Probleme trinken können.",ep:0,g:165,l:1,wd:false,fm:true,w:0,p:1};
I.u[10070] = {n:"Bombusfass",t:15,d:"Dieses Bombusfass ist von Ebonit umreift. Diese Legierung verwandelt sich mit der Zeit in Gift, aber das Bombusfass wird vor allem zur Fermentierung und Konservierung von Alkohol verwendet und gibt ihm ein ganz besonderes Aroma mit ebenso besonderen Nebenwirkungen.",ep:0,g:165,l:1,wd:false,fm:true,w:5,p:1};
I.u[10071] = {n:"Zugangsplan zu Pol Bokuzens Keller",t:24,d:"Dieser Plan zeigt euch, wie ihr euch Zutritt zu Pol Bokuzens Keller südlich des Zaap im Dorf Amakna verschaffen könnt. Um den Eingang freizuräumen bedarf es zwei Personen: eine Person, die mit Kuch Henwegs Schaufel ausgestattet ist und einen Bergmann mit seiner Spitzhacke, der imstande ist, Silber abzubauen. Außerdem braucht ihr ein Bombusfass zum Befördern von KO-Met;\r\n            die Bastler wissen, wie man sie zusammenbaut.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10072] = {n:"Bürzelfeder",t:24,d:"Diese mit Alkoholdämpfen durchtränkte Feder wurde einem Verirrten Saufuhu gewaltsam vom Bürzel gerissen. Jetzt weiß er, dass Alkohol der Gesundheit schadet.",ep:0,g:754,l:1,wd:false,fm:true,w:0,p:1};
I.u[10073] = {n:"Schild von HispaÑia",t:82,d:"Der mythische Dal-Uk-Wet, Vereiniger der Königreiche von HispaÑia, besaß einen magischen Schild. Sein Urgroßenkel Sir-Dal, ließ einige Kopien davon anfertigen, um die besten Krieger von HispaÑia zu belohnen. Dieser Schild ist einer der seltenen Kopien.",ep:0,g:40,l:1,wd:false,fm:true,w:1,p:1};
I.u[10074] = {n:"Brief des Anführers der Diebe",t:24,d:"Beim Kampf gegen die Diebe bei Milone gefunden: Milone Corichel hat vor kurzem ein Juwel von grossem Wert erschaffen. Entwendet das Juwel, koste es, was es wolle. Zum Glück hat Milone den Dieben eine Fälschung mitgegeben, was wir aber nicht euch zu verdanken haben.\nAuf der Rückseite befindet sich der Sitz ihres Schlupfwinkels aufgezeichnet. Eine Revanche ist angesagt, aber ihr geht besser mit Begleitung hin.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10075] = {n:"Ungeniessbarer Brei",t:24,d:"Dieser ungeniessbare Brei ist wie durch Zauberei in eurer Tasche erschienen.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[10076] = {n:"Einzigartiger Schild von HispaÑia",t:82,d:"Der mythische Dal-Uk-Wet, Vereiniger der Königreiche von HispaÑia, konzentrierte all seine Macht in seinem Schild, zum großen Missfallen seiner Gegner. Jahre später, ließ sein Urgroßenkel Sir-Dal einige Kopien davon anfertigen, um die besten Krieger von HispaÑia zu belohnen, aber dieser hier ist das Original, der Einzige, der Mächtigste von allen!",ep:0,g:40,l:1,wd:false,fm:true,w:30,c:"PP>9",p:63200};
I.u[10077] = {n:"Terra Cogita",t:32,d:"Ihr müsst Terra Cogita zu mehreren Orten eskortieren, bevor ihr ihn schließlich zu Hannes Schnalltgetin bringen könnt.",ep:0,g:22,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10078] = {n:"Eni Hoob",t:32,d:"Eskortiert und beschützt Eni Hoob. Seit er in eurer Begleitung ist, scheint sich das Schicksal gegen euch verschworen zu haben.",ep:0,g:13,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10079] = {n:"Bibberbrot",t:33,d:"Von den Iops heiß begehrt, macht dieses Brot tollkühn und mutig zugleich, was schon den vorzeitigen Tod zahlreicher Abenteurer hervorgerufen hat. Xaver, der Bäcker hat die Herstellung an dem Tag eingestellt, als er zusehen musste, wie eine ganze Truppe von Troubadouren eine Gruppe tollwütiger WuWülfe angriff.",ep:0,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[10080] = {n:"Nachricht der Renegaten",t:24,d:"Diese Nachricht handelt von einem Renegatentreffen in der Nähe des Scarablatt-Dungeons. Vielleicht solltet ihr dort als nächstes hingehen, um mehr darüber zu erfahren.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10081] = {n:"Nachricht des Renegaten-Anführers",t:24,d:"Der Renegaten-Anführer befiehlt in dieser Nachricht, sich mit ihm südlich des Territoriums der Banditen zu treffen. Für euch ist das die ideale Gelegenheit, diesen Verräter auszuschalten.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10082] = {n:"Moritov-Cocktail",t:24,d:"Was erhält man, wenn man ein Fahlblütenblatt zerdrückt? Einen alkoholisierten Nektar, der Grundlage zahlreicher Cocktails ist, an denen sich die Anhänger Otomaïs auf Sommerfesten laben. Dieser explosive Cocktail wird euren Partys Feuer unterm Hintern machen und das nicht nur im übertragenen Sinne.",ep:0,g:762,l:1,wd:false,fm:true,w:0,p:1};
I.u[10083] = {n:"Fischschalat",t:49,d:"Wie das Sprichwort sagt: Ein Geruch kommt selten allein. Der Duft, der von diesem Fischschalat ausgeht, überdeckt einen Geruch von ungewaschenen Füssen. Ist also mit Vorsicht zu genießen und das Küssen danach kann man getrost vergessen.",ep:0,g:80,l:1,wd:false,fm:true,w:3,u:true,ut:true,p:1};
I.u[10084] = {n:"Appell-Trillerpfeife",t:24,d:"Diese Trillerpfeife wurde nach den Hundezuchtmethoden von Riyou Tchevlakouk entworfen und gestattet es, gezähmte Blutwölfe zu rufen. Allerdings könnt ihr damit nicht als Herrchen eines Blutwolfs durchgehen, der euch nicht gehört. Funktioniert auch mit wilden Blutwölfen.",ep:0,g:755,l:1,wd:false,fm:true,w:0,p:1};
I.u[10085] = {n:"Exekutionsbefehl",t:87,d:"Dieser Befehl ist klar und deutlich formuliert. Findet das Ziel und erledigt es. Perfekt geeignet für verwirrte Abenteurer",ep:0,g:2,l:10,wd:false,fm:true,w:1,c:"Ps!0&PP>0",u:true,p:0};
I.u[10086] = {n:"Eckzahn des Räubers der Ebenen",t:24,d:"Der Kampf gegen die Räuber der Ebenen war derart heftig, dass einer von ihnen einen Eckzahn verlor. Hier ist er!",ep:0,g:13,l:1,wd:false,fm:true,w:0,p:1};
I.u[10087] = {n:"Xarthans Verabredung",t:24,d:"Dieses Papier wurde von einem Brâk verfasst und darauf ist ein Treffen mit Xarthan im Turm von Bonta vereinbart, das nach seiner nächsten Versammlung stattfinden soll. Vielleicht ist das Treffen schon im Gange?",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[10088] = {n:"Gebrauchtes Taschentuch",t:24,d:"Das gebrauchte Taschentuch habt ihr nach eurem Kampf gegen Xephirex aufgelesen. Ein nettes Erinnerungsstück und überaus praktisch obendrein, sollte einmal eure Nase laufen oder euer Ecaflip eine Katzenhaarallergie erleiden.",ep:0,g:756,l:1,wd:false,fm:true,w:0,p:1};
I.u[10089] = {n:"Warenkiste",t:24,d:"Xephirex hat euch gebeten, diese Kiste mit Waren dem Berater Boyowa, bei Grandapan, als Zeichen seines guten Willens zu übergeben. Ihr kennt seinen Inhalt nicht, aber es handelt sich sicher um wertvolle Dinge.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10090] = {n:"Liste mit Naras Möbelstücken",t:24,d:"Nara hat euch eine Liste angefertigt mit den Dingen, die er zum Einrichten seiner neuen Schmiedewerkstatt benötigt: 20 Einheiten Eichenholz, 1 Tabaksbeutel voller Schwefel, 30 Einheiten Eisen, 1 Kwuarz, 5 Backelitit und 10 Leder von Keilern der Ebenen.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10091] = {n:"Notizen über Erazals Fluch",t:24,d:"Erazals Fluch erklärt, wie man einen Seele gegen ihren Willen auferweckt. Dazu braucht man: 1x Phönixblut, 5 Wunderpulver und ein Lears Amulett, das ihr auf den Kadavern von Astaknyden und Schattenastaknyden finden könnt.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10092] = {n:"Annulierungsbefehl",t:24,d:"Dieser nur ein paar Stunden alte Brief beinhaltet, dass der Angriff auf Bonta abgeblasen wurde, da ihre Milizionäre verbesserte Ausrüstungen erhalten haben und der Verräter Xephirex gefasst wurde.",ep:0,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[10102] = {n:"Vampyrmaske",t:16,d:"Diese Maske schützt euch vor morgendlichen Sonnenstrahlen, wenn nicht sogar noch vor Anderem!",ep:0,g:244,l:42,wd:true,fm:true,w:10,c:"PO!10119",s:130,p:4725};
I.u[10103] = {n:"Brief an Fidji Merlin",t:24,d:"Tück\'n\'Stück hat euch dieses Schreiben für Fidji Merlin anvertraut. Offenbar werdet ihr die Anweisungen der Bastlerin von Brâkmar befolgen müssen.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[10104] = {n:"Modifizierte Futterstelle",t:24,d:"Diese Futterstelle wurde sabotiert, indem Augerginen hineingeschmuggelt und darin versteckt wurden. Man sollte besser nicht auf dem Rücken eines Dracotruters durch Brâkmar reisen, der aus dieser Futterstelle genascht hat. Es könnte sich sonst um ein einmaliges und hochexplosives Erlebnis handeln...",ep:0,g:759,l:1,wd:false,fm:true,w:0,p:1};
I.u[10105] = {n:"Mit Haaren bedecktes Bein",t:24,d:"Dieses mit Arachneen- und Maunzmiezhaaren bedeckte Arachneenbein ist bei einer Konfrontation mit Heimgeh Dammvert eine schreckliche Waffe.",ep:0,g:11,l:1,wd:false,fm:true,w:0,p:1};
I.u[10106] = {n:"Vampyrella",t:18,d:"Diese furchtbare Kreatur empfindet ein unheiliges Vergnügen dabei, das Blut eurer Verbündeten auszusaugen, oder gar euer Eigenes. Darum sollte man sie stets beschäftigen, am Besten durch das Bekämpfen von Skeletten. Kreaturen zu Staub zerfallen zu sehen, ist nämlich ihr liebstes Hobby...",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10107] = {n:"Fleddermaus",t:18,d:"Dieser Vertraute hatte nicht nur eine schwere Kindheit, sondern bekam auch noch einen idiotischen Namen verpasst. Kein Wunder, dass er völlig verrückt geworden ist. Er ist nun völlig besessen von der Idee, Groß- und Kleinmorphs in den Staub fallen zu sehen, damit er ihre sterblichen Hüllen verspotten kann.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10108] = {n:"Vampyrella-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:53,l:1,wd:true,fm:true,w:1,p:1};
I.u[10109] = {n:"Fleddermaus-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:54,l:1,wd:true,fm:true,w:1,p:1};
I.u[10118] = {n:"Frisch gezähmter Blutwolf",t:32,d:"Dieser Blutwolf wurde nach allen Künsten der Hundezuchtmethode bezähmt, die vom berühmten Maunzmiezbändiger Riyou Tchevlakouk entwickelt wurde.",ep:0,g:23,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10119] = {n:"Ghulifiziert",t:30,d:"Ihr fühlt euch irgendwie...anders!",ep:0,g:1,l:1,wd:false,fm:true,w:0,m:true,c:"POX10055&POX10054&POX10056&POX10061&POX10058&POX10102",p:0};
I.u[10120] = {n:"Beschreibung eines Unbekannten",t:24,d:"Gnil Schirf hat euch die Beschreibung eines Unbekannten aufgeschrieben, der sich mit Sulsch Tim Sliglu Terpeh unterhalten hat. Seltsamerweise stimmt sie nicht mit der mündlichen Beschreibung überein, die er euch gegeben hat. Irgendwas stimmt da nicht.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10121] = {n:"Kleiner Stein",t:51,d:"Dieser kleine Stein ist dazu da, die Magie der Fliesen zu aktivieren, um die Essenz des Wassers zu erreichen. Die Verwendung ist denkbar einfach. Es genügt, den kleinen Stein auf eine Fliese zu legen und schon wirkt die Magie. Kurz: selbst ein Iop wäre dazu wohl in der Lage, vorausgesetzt er erblickt nicht gerade einen Feind, auf den er den Stein werfen könnte.",ep:0,g:267,l:1,wd:false,fm:true,w:1,p:1};
I.u[10122] = {n:"Norbs Liste",t:24,d:"Norb hat euch eine Liste mit Ressourcen gemacht, die Nara benötigt. Aufgeführt sind: 2 Backelitit, 10 Einheiten Mangan, 20 Einheiten Bauxit, 15 Einheiten Dolomit und 20 Einheiten Olivioletta-Holz.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10124] = {n:"Gaunzmiez",t:32,d:"Bringt diese Maunzmiez zu Riyou Tchevlakouk, dem Maunzmiezbezähmer. Aber gebt drauf acht, den Blick dieser schrecklichen Kreatur nicht zu kreuzen, sonst erliegt ihr ihrem Charme und werdet so albern wie eine Eniripsa.",ep:0,g:6,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10125] = {n:"Bogen des Banditen-Bogenschützen",t:2,d:"Dieser Bogen gehörte früher einem alten Banditen-Bogenschützen, der ihn dazu benutzte, Feinde aus großer Entfernung niederzustrecken, um sich die Hände nicht schmutzig zu machen. Diese Waffe steckt so voller Magie, dass sie euch in einen Banditen-Bogenschützen verwandelt, sobald ihr sie in den Händen haltet.",ep:0,g:67,l:30,wd:true,fm:false,w:10,an:10,tw:true,e:[2,6,3,5,40,40,false,true],p:3000};
I.u[10126] = {n:"Schwert des Banditen-Haudegens",t:6,d:"Dieses Schwert gehörte früher einem alten Banditen-Haudegen, der es hasste, Gegnern nachzulaufen. Darum schnitt er jedem gleich beide Beine ab und stellte dann seine Fragen. Diese Waffe steckt so voller Magie, dass sie euch in einen Banditen-Haudegen verwandelt, sobald ihr sie in den Händen haltet.",ep:0,g:92,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,40,40,false,false],p:3000};
I.u[10127] = {n:"Stock des Banditen-Glücksritters",t:4,d:"Dieser Stock gehörte früher einem alten Banditen-Glücksritter, der ständig betrunken war. Er pflegte sich daher auf diesen Stock abzustützen, während er seinen Opfern die Taschen leerte. Diese Waffe steckt so voller Magie, dass sie euch in einen Banditen-Glücksritter verwandelt, sobald ihr sie in den Händen haltet.",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:12,e:[5,6,1,1,40,40,false,false],p:3000};
I.u[10128] = {n:"Schlüssel der Schmuggler",t:24,d:"Diesen Schlüssel habt ihr auf den zerfetzten Überbleibseln einer von Zuckungen geschüttelten Leiche gefunden. Das hat euch nicht mehr ausgemacht, als den Schlüssel von einem Tresen zu nehmen. Naja, die Leiche mit dem Schlüssel befand sich auf einem Tresen.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[10129] = {n:"Kiste mit kostbaren Erzen",t:24,d:"Diese Kiste ist mit kostbaren Erzen gefüllt, die für die Herstellung von Miliz-Ausrüstungen von Bonta bestimmt sind. Domen hat euch darum gebeten, die Kiste zu Kazzy Domo zu bringen, der weiß, was damit zu tun ist.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10131] = {n:"Geschenk: Vampyrella",t:89,d:"Wenn ihr dieses Geschenkpaket schüttelt, könnt ihr hören, dass sich etwas darin bewegt. Es klingt nach einer Kreatur, die bereit ist, euch sofort um den Hals zu fallen... Öffnet schnell das Paket und nehmt euren Vertrauten in Empfang.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10132] = {n:"Geschenk: Fleddermaus",t:89,d:"Wenn ihr dieses Geschenkpaket schüttelt, könnt ihr hören, dass sich etwas darin bewegt. Es klingt nach einer Kreatur, die bereit ist, euch sofort um den Hals zu fallen... Öffnet schnell das Paket und nehmt euren Vertrauten in Empfang.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10133] = {n:"Stab des Banditen-Zauberers",t:3,d:"Dieser Stab gehörte früher einem alten Banditen-Zauberer, der ihn dazu benutzte, haufenweise Feinde in Aschehaufen zu verwandeln. Diese Waffe steckt so voller Magie, dass sie euch in einen Banditen-Zauberer verwandelt, sobald ihr sie in den Händen haltet.",ep:0,g:72,l:30,wd:true,fm:false,w:10,an:11,tw:true,e:[2,5,2,4,40,40,false,true],p:3000};
I.u[10134] = {n:"Tierheimzertifikat: Vampyrella",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10135] = {n:"Tierheimzertifikat: Fleddermaus",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10136] = {n:"Schlüssel zum Scheinversteck",t:24,d:"Dieser Schlüssel dient dazu, das Scheinversteck der Partisanen von Djaul und Hécate zu öffnen, das sich in der Nähe vom Gasthaus \"Bei Djaul\" befindet.",ep:0,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[10137] = {n:"Kiste mit Gift",t:24,d:"Diese Kiste mit Gift stammt aus den Reserven Brâkmars, was an sich schon seine Wirksamkeit garantiert. Sie enthält genug Gift, um eine ganze Floharmee auszulöschen, behandelt sie also mit Vorsicht.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10138] = {n:"Slip aus Soryo Feuerfux-Haut",t:24,d:"Die Wirksamkeit von Slips aus Soryo Feuerfux-Haut wird von den Nachfahren des Chafer-Offizieres garantiert. Normalerweise wird es von Babys mit empfindlicher Haut getragen, aber kommt auch beim der großen Feier der Lederschlüpfer des Chafer-Offizieres zum Tragen.",ep:0,g:621,l:1,wd:false,fm:true,w:0,p:1};
I.u[10139] = {n:"Kiste mit Schwertern",t:24,d:"Diese Kiste enthält zahlreiche Schwerter, die für die Mitglieder des Ordens des Blutenden Herzens oder des Ordens des Kranken Geistes bestimmt sind, je nachdem, wer sie zuerst in die Hände kriegt.",ep:0,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[10140] = {n:"Geschenk: Vampyring",t:89,d:"Beim Schütteln dieses Geschenkpaketes könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
