I.u[9808] = {n:"Shushu von Rushu - Geschenk",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für die Aufzucht und Eniripsa-Pulver, um ihn zu pflegen.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9809] = {n:"Shushu von Rushu Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9810] = {n:"Tierheimzertifikat: Shushu von Rushu",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[9811] = {n:"Neutralitätsbestätigung",t:24,d:"Diese Bestätigung hat euch Morry Gähn von der Miliz des Schlosses von Amakna gegeben. Sie ist Voraussetzung, um wieder neutral zu werden.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9812] = {n:"Deserteur-Bestätigung",t:24,d:"Diese Bestätigung hat euch Morry Gähn gegeben. Sie bestätigt, dass ihr eure Gesinnung verlassen habt und ist Voraussetzung, um wieder neutral zu werden.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9813] = {n:"Bogen Oh\'Sseh\' - Geschenk",t:89,d:"Beim Schütteln dieses Geschenkpaketes könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
