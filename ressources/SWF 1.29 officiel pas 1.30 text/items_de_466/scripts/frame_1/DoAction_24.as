I.u[11131] = {n:"Seltsames Ding",t:24,d:"Wie dumm kann man bloß sein, um die Funktionsweise dieses Gegenstandes nicht sofort zu erfassen?!?",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11132] = {n:"Löffel",t:24,d:"Nun, wo er den Löffel abgeben musste wird der arme Bär wohl mit den Fingern essen müssen. Das ist allein eure Schuld!",ep:0,g:824,l:1,wd:false,fm:true,w:0,p:1};
I.u[11133] = {n:"Vibrierende Ping-Feder",t:94,d:"Nicht nur der Royal-Tofu besitzt eine vibrierende Feder, auch manche Pings haben eine solche. Sie ist hochmagisch, aber niemand hat bisher herausgefunden, wozu sie wohl dienen mag...",ep:0,g:20,l:50,wd:false,fm:false,w:1,c:"Qc=555&Qa!555",u:true,p:500};
I.u[11134] = {n:"Apewicubus",t:94,d:"Ein Gegenstand ist in diesem Eiswürfel aus dem zugefrorenen See eingeschlossen. Um herauszufinden, um was es sich handelt gibt es zwei Möglichkeiten: einfach abwarten, bis das Eis abtaut oder es so zu machen, wie es ein zappeliger, unartiger Lausbub tun würde - einfach draufhauen!",ep:0,g:21,l:50,wd:false,fm:true,w:1,u:true,p:500};
I.u[11135] = {n:"Schwanz eines Legendären Fressmuts",t:65,d:"Der Schwanz eines Legendären Fressmuts ist nicht ganz so legendär wie der Fressmut selbst. Er ist eher klein und versteckt unter dem dichten Fell. Doch das hat euch nicht davon abgehalten ihn zu suchen und auszureißen!",ep:0,g:752,l:118,wd:false,fm:true,w:10,p:1};
I.u[11136] = {n:"Wolle des Legendären Fressmuts",t:57,d:"Dreckig, aber legendär! Das erinnert euch an jemanden...",ep:0,g:212,l:118,wd:false,fm:true,w:10,p:1};
I.u[11137] = {n:"Kümmerliche Überreste einer Zekahl-Ratte",t:24,d:"Was? Das ist alles, was von der Zekahl-Ratte noch übrig ist? Subtilität ist wirklich nicht eure Stärke...",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11138] = {n:"",t:24,d:"",ep:0,g:828,l:1,wd:false,fm:true,w:0,p:1};
I.u[11139] = {n:"Einkorn-Samenkorn",t:24,d:"Dies ist eine Urform des Weizens, der in Amakna angebaut wird. Man könnte glatt meinen, auf der Insel Frigost sei die Zeit angehalten worden...",ep:0,g:829,l:1,wd:false,fm:true,w:0,p:1};
I.u[11140] = {n:"2-Nim-Samen",t:24,d:"Einst war es ein Garant für gute Qualität und familienfreundlichen Nährstoffzusatz. Doch auch Beispiel einer dummen Wette. Der ehemalige Bürgermeister von Frigost hatte nämlich mit deinem Ecaflip gewettet, dass er in der Lage sei, nach einer der Delikatessen aus 2-Nim-Samen aufzuhören. Er hat die Wette verloren und damit seinen Reichtum und sein Amt! Wie schade!",ep:0,g:830,l:1,wd:false,fm:true,w:0,p:1};
I.u[11141] = {n:"",t:24,d:"",ep:0,g:831,l:1,wd:false,fm:true,w:0,p:1};
I.u[11142] = {n:"Linsenkorn",t:24,d:"Durch Anbringen von körnigen Linsen, wird euer Augenlicht entgegen der landläufigen Meinung auch nicht besser. Dafür werdet ihr noch lächerlicher aussehen, als ihr es jetzt schon tut.",ep:0,g:832,l:1,wd:false,fm:true,w:0,p:1};
I.u[11143] = {n:"Salzkörnchen",t:24,d:"Eines der Salzkörnchen, mit denen der besiegte Körper des Sparos direkt im Fass eingelegt wurde. Das kommt eben davon, dass dieser überall seinen Senf hinzugeben musste!",ep:0,g:833,l:1,wd:false,fm:true,w:0,p:1};
I.u[11144] = {n:"T-Grana-Samen",t:24,d:"Den Stengel abbrechen, zwei Sekunden abwarten und weit wegwerfen. Das bekommen junge Frigostianer bereits von klein auf beigebracht. Niemand weiß warum...",ep:0,g:834,l:1,wd:false,fm:true,w:0,p:1};
I.u[11145] = {n:"G-Walt-Samen",t:24,d:"Diese Samen nutzen gerne unzivilisierte Frigostianer aus niederen Verhältnissen, um Abenteurer zu aggressen. Wie ist bloß so etwas möglich? Niemand weiß es genau, aber es gibt eben Dinge, die man besser nicht genauer hinterfragt!",ep:0,g:835,l:1,wd:false,fm:true,w:0,p:1};
