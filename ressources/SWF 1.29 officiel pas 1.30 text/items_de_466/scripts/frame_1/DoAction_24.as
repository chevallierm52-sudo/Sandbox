I.u[11157] = {n:"Schlingfass-Tulpe",t:24,d:"Zu Brei zerstampft oder gekocht eignet sich diese Tulpe besonders zur raschen Gewichtsabnahme. Der Nachteil ist allerdings, dass meist eure Kamabörse meist ebenfalls rasch an Gewicht abnimmt.",ep:0,g:842,l:1,wd:false,fm:true,w:0,p:1};
