I.u[11149] = {n:"Sternchenkorn",t:24,d:"Wenn auch ihr wie ein Sternchen im Sternchenhimmel \"Scho-Bizz\" aufleuchten möchtet, dann ist das Sternchenkorn genau das richtige für euch. Doch Vorsicht, die Wirkung ist extrem vergänglich.",ep:0,g:839,l:1,wd:false,fm:true,w:0,p:1};
