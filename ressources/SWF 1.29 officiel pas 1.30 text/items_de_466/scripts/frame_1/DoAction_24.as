I.u[11190] = {n:"Geschenk: YeCh\'Ti-Amulett",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11191] = {n:"Stiefel des Dungeon-Säuberers",t:11,d:"Die Sohle dieser Stiefel ist zwar schon sehr abgenutzt, dafür sind sie auch sehr bequem. Sie haben schon die schlimmsten Dungeons durchquert und die bösartigsten Monster in Grund und Boden gestampft!",ep:0,g:162,l:73,wd:true,fm:true,w:10,an:0,p:13700};
I.u[11192] = {n:"Geschenk: Dungeonsäuberer",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt. Achtung, das Geschenk kann nur in DOFUS 2.0 verwendet werden.",ep:0,g:42,l:1,wd:false,fm:true,w:1,c:"Sc=997",u:true,p:1};
I.u[11193] = {n:"Brett aus Zitterpappelholz",t:95,d:"Aus diesem Brett können Bastlern alle möglichen Dinge erschaffen – wie einen hölzernen Sarg, zum Beispiel.",ep:0,g:23,l:100,wd:false,fm:true,w:10,p:10};
I.u[11194] = {n:"Frostizz-Mehl",t:52,d:"Dieses Mehl löst sich wunderbar in MiMilch und gibt dieser einen besonderen Schokoladengeschmack. Die geleenachtischliebenden Bewohner einer verschollenen Insel pflegten es jedoch in Wasser aufzulösen.",ep:0,g:260,l:100,wd:false,fm:true,w:1,p:1};
I.u[11195] = {n:"Schmubfem",t:30,d:"Ihr solltet zu einem Arzt gehen, bevor sich euer Zustand noch weiter verschlimmert.",ep:0,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11196] = {n:"Eiskama",t:24,d:"Da den Frigostianern das Metall knapp wurde, entschieden sie sich dazu, Kamas aus Eis herzustellen. Diese Währung hat jedoch außerhalb der Insel nicht den geringsten Wert!",ep:0,g:825,l:1,wd:false,fm:true,w:0,p:1};
I.u[11197] = {n:"Die Zinuzitiz",t:30,d:"Die Impfkampagne gegen diese Krankheit hat dem Stillen Örtchen bereits mehr als 2 Milliarden Kamas gekostet, ohne bisher nennenswerten Erfolg zu zeigen. Man könnte fast meinen, Frigostianer würden ihre Kamas gern aus dem Fenster hinauswerfen.",ep:0,g:7,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[11198] = {n:"Impfstoff gegen Schmubfem",t:24,d:"Dieser Impfstoff ist sehr wirkungsvoll gegen Schmubfem, aber leider hält seine Wirkung nicht sehr lange an. Deswegen muss die Impfung jede Woche erneuert werden.",ep:0,g:31,l:1,wd:false,fm:true,w:0,p:1};
I.u[11199] = {n:"Frostizz-Samen",t:58,d:"Diese sich kalt anfühlenden Samen riechen stark nach Kakao.",ep:0,g:0,l:100,wd:false,fm:true,w:1,p:1};
I.u[11200] = {n:"Geschenk: Schild von HispaÑia",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[11201] = {n:"Fressmut-Blutprobe",t:24,d:"Diese Blutsprobe wurde einem Fressmut abgenommen, der mit Schmubfem infiziert ist.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11202] = {n:"Isotonisches Meerwasser",t:24,d:"Günther Pesser braucht dieses Wasser für seine Forschungen zur Entwicklung eines Impfstoffes gegen Schmubfem.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[11203] = {n:"Beifuß",t:24,d:"Dieses Kraut wird von Alchimisten, von Eniripsas und ganz besonders von Eniripsa-Alchimisten geschätzt. Es existiert davon noch eine nahe Verwandte, deren Extrakt ganz besonders von Matrosen, von Enutrofs und von Enutrof-Matrosen geschätzt wird.",ep:0,g:103,l:1,wd:false,fm:true,w:0,p:1};
I.u[11204] = {n:"Das Biest - Blutsprobe",t:24,d:"Mit viel Mühe konntet ihr der Zielkreatur diese Blutsprobe abnehmen. Die Frage ist nur, ob der Nutzen proportional zum Aufwand sein wird.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11205] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 01 Uhr und 04 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11206] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 04 Uhr und 07 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11207] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 07 Uhr und 10 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11208] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 10 Uhr und 13 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11209] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 13 Uhr und 16 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11210] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 16 Uhr und 19 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11211] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 19 Uhr und 22 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11212] = {n:"Ausgemachter Termin",t:24,d:"Ihr habt mit Käpt\'n Schluck einen Termin zwischen 22 Uhr und 01 Uhr ausgemacht.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[11213] = {n:"Fressmut-Flöhe",t:24,d:"Diese Flöhe sind noch schwerer zu erwischen, als ein tollwütiger Peki mit brennendem Schwanz und noch aggressiver als eine Horde astrubianischer Bettelmönche. Das macht sie zu einer echten Plage für jede arme Kreatur, die ihnen als Wirt dient.",ep:0,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[11214] = {n:"Blut eines parasitenbefallenen Fressmuts",t:24,d:"Diese Blutsprobe wurde einem parasitenbefallenem Fressmut abgenommen.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11215] = {n:"Blut eines parasitenbefallenen Fressmut-Anführers",t:24,d:"Diese Blutsprobe wurde einem parasitenbefallenem Fressmut-Anführer abgenommen.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11216] = {n:"Blut eines parasitenbefallenen Legendären Fressmuts",t:24,d:"Diese Blutsprobe wurde einem parasitenbefallenem Legendären Fressmut abgenommen.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11217] = {n:"Blut eines parasitenbefallenen Fressmütchens",t:24,d:"Diese Blutsprobe wurde einem parasitenbefallenem Fressmütchen abgenommen.",ep:0,g:102,l:1,wd:false,fm:true,w:0,p:1};
I.u[11218] = {n:"Brief für Otomaï",t:24,d:"Wogew, dew Einsiedlew hat euch gebeten, diesen Brief Otomaï zu geben. Darin befinden sich mehrere Abhandlungen über Flöhe, die als Parasiten Wabbits, aber auch Fressmuts befallen können.",ep:0,g:65,l:1,wd:false,fm:true,w:0,p:1};
I.u[11219] = {n:"Schwanz des Königlichen Fressmuts",t:65,d:"Im Sommer kann der königliche Fressmut mit dem Schwanz lästige Fliegen verjagen. Den Rest des Jahres über kommt der Schwanz jedoch kaum zur Anwendung. Darum vergisst der königliche Fressmut manchmal, dass er einen Schwanz hat.",ep:0,g:755,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11221] = {n:"Wolle des Königlichen Fressmuts",t:57,d:"Niemand kann genau sagen, wann die Fressmuts auf Frigost gelandet sind. Doch eines ist sicher. Es muss lange her sein, da Unterwäsche aus Fressmut-Wolle bereits viele Generationen lang von Frigostianern weitergegeben wurde.",ep:0,g:213,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11222] = {n:"Schnabel eines Ti-Pings",t:47,d:"Was ist lang und hart und riecht nach Fisch?... Richtig, ein Ti-Ping-Schnabel!",ep:0,g:662,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11223] = {n:"Feder eines Ti-Pings",t:53,d:"Früher besuchten Ti-Pings die Insel Frigost nur im Winter. Doch jetzt, wo die Insel völlig zugeeist ist, bleiben sie das gesamte Jahr über da. Die Versorgung mit Ti-Ping-Federn wäre damit also gesichert!",ep:0,g:646,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11224] = {n:"Schwabbelping-Flügel",t:104,d:"Frigostianer fragen sich regelmäßig, wozu diese lächerlichen Flügelchen wohl dienen könnten. Denn ein Schwabbelping kann nicht im Traum daran denken, mit ihnen abheben zu können.",ep:0,g:216,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11225] = {n:"Schwabbelping-Haut",t:59,d:"Was ist extrem fettig, glänzt im Sonnenlicht und wird nie gewaschen? Nein, es handelt sich nicht um eure Perücke, sondern um ein Stück Schwabbelping-Haut!",ep:0,g:49,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11226] = {n:"Öl von Mama Ping",t:60,d:"Dieses Öl ist ein Extrakt aus einer Mama Ping. Um jemals wieder ruhig schlafen zu können, hat euer Unterbewusstsein beschlossen, selektiv jegliche Erinnerung an die Extraktionsmethode aus eurem Gedächtnis zu verbannen.",ep:0,g:72,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11227] = {n:"Mama Ping - Daunen",t:54,d:"Alle Einwohner Frigosts stopfen ihre Unterwäsche mit Mama Ping - Daunen aus. Die vorgegebene Begründung dafür wäre aus Schutz vor der Kälte. Doch nur junge Iops glauben diese faule Ausrede!",ep:0,g:675,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11228] = {n:"Riesengräte des Ping Schamanen",t:47,d:"Auf Frigost gibt es noch zahlreiche unbeantwortete Fragen und noch mehr ungefragte Antworten. Vielleicht werdet ihr daher zu den glücklichen Menschen gehören, die nie erfahren werden, wo der Ping Schamane diese Riesengräte her hat!",ep:0,g:663,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11229] = {n:"Barthaare eines Ping Schamanen",t:54,d:"Grundsätzlich stinken Barthaare eines Ping Schamanen immer nach verwesendem Fisch. Dazu gesellt noch die persönliche Note des jeweiligen Schamanen hinzu. Mutige Abenteurer unter den Frigostianern nutzen diesen Geruchscocktail gern als Anti-Fressmut-Mittel.",ep:0,g:674,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11230] = {n:"Schwanz eines Ping-Fus",t:65,d:"Unterschätzt niemals die Kräfte eines Ping-Fus. Selbst mit seinem Stummelschwänzchen kann dieser töten!",ep:0,g:753,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11231] = {n:"Ohr des Ping-Fus",t:106,d:"Da die Ohren meist durch den Fisch verdeckt werden, ist das Gehör massiv unterentwickelt. Die einzige Ausnahme sind die Lockrufe eines willigen Ping-Fu Weibchens. Ihr könnt euch also ruhig ungestraft über Ping-Fus Witze reißen, so lange ihr nicht, wie ein Ping-Fu Weibchen klingt. Keine leichte Aufgabe!",ep:0,g:625,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11232] = {n:"Feder des King Pings",t:53,d:"Der King Ping wird von den Frigostianern hoch verehrt. Schließlich braucht man Viecher mit wohl klingenden Namen, die gute Jagdtrophäen abgeben.",ep:0,g:647,l:145,wd:false,fm:true,w:10,an:0,p:10};
I.u[11233] = {n:"King Ping - Ei",t:105,d:"Dieses riesige Ei muss irgendwann einmal irgendwo herausgekommen sein...vermutlich half dabei ein guter Ping!",ep:0,g:643,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11234] = {n:"Ried Riechhart",t:32,d:"Die Überlebenden aus dem Wald der verlorenen Kiefern müssen nun zu Chef Sietas gebracht werden.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11235] = {n:"Sioux Stürm",t:32,d:"Die Überlebenden aus dem Wald der verlorenen Kiefern müssen nun zu Chef Sietas gebracht werden.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11236] = {n:"Jo-Nie Stürm",t:32,d:"Die Überlebenden aus dem Wald der verlorenen Kiefern müssen nun zu Chef Sietas gebracht werden.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11237] = {n:"Grim Bäng",t:32,d:"Die Überlebenden aus dem Wald der verlorenen Kiefern müssen nun zu Chef Sietas gebracht werden.",ep:0,g:0,l:1,wd:false,fm:false,w:0,an:0,m:true,p:1};
I.u[11238] = {n:"Skratsmut-Schwanz",t:65,d:"Der Schwanz des Skratsmuts hilft diesem beim Balancieren auf Eicheln das Gleichgewicht zu bewahren. Diese Kreatur scheint gegen Lächerlichkeit immun zu sein...",ep:0,g:754,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11239] = {n:"Skratsmut-Eichel",t:58,d:"Ein gewöhnlicher Skratsmut verbringt im Durchschnitt die ersten drei Lebensjahre mit der Suche nach der perfekten Eichel. Den Rest seines Lebens verbringt es damit, sich zu erinnern, wo es die perfekte Eichel vergraben hat!",ep:0,g:68,l:115,wd:false,fm:true,w:10,an:0,p:10};
I.u[11240] = {n:"Smilomut-Zahn",t:47,d:"Seriöse wissenschaftliche Studien haben ergeben, dass Smilomut-Zähne statistisch gesehen die Primärquelle aller Gesäßperforationen bei Frigostianern darstellen.",ep:0,g:664,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11241] = {n:"Smilomut-Haar",t:54,d:"Smilomut-Haar diente einst dazu, warme Daunendecken herzustellen. Manche Frigostianer sind ja so skrupellos. Jedes Mittel ist ihnen recht, um eine Entschuldigung für ihren geliebten Raubtieratem beim Aufwachen zu finden.",ep:0,g:676,l:120,wd:false,fm:true,w:10,an:0,p:10};
I.u[11242] = {n:"Keisler-Hauer",t:47,d:"Sie verströmen einen leichten Geruch nach Unterwäsche. Es scheint jedoch die von jemand anderem sein!",ep:0,g:665,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11243] = {n:"Keisler-Leder",t:56,d:"Dieses Leder umschmiegt die schönen Kurven des Keislers und unterstreicht dessen grazile Silhouette.",ep:0,g:16,l:125,wd:false,fm:true,w:10,an:0,p:10};
I.u[11244] = {n:"Gérards Nachricht",t:24,d:"Hab ne Albino Ping Mama gesichtet und bin ihr zum Unterschlupf gefolgt. Jackpot! Hunderte von Ping Mamas mit Nachwuchs! Das kann ich mir nicht entgehen lassen. Werd alles abknallen, was nicht bei drei verschwunden ist. Fleischversorgung für nächste Jahrzehnte ist gesichert!\nGérard",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[11245] = {n:"Familienjuwelen von Gérard",t:24,d:"Im Gegensatz zu denen des MuWulfs, haben diese Familienjuwelen weder einen Wert, noch einen Nutzen.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11246] = {n:"Scheeles Frigsus-Auge",t:109,d:"Bevor dieser Frigsus in die Ewigen Jagdgründe einging,  genauer gesagt, kurz, bevor er einging, hat euch der Frigsus noch einen bitterbösen Blick zugeworfen. So böse, dass euch fast das Blut in den Adern gefroren wäre. Als wäre es nicht bereits kalt genug auf Frigost...",ep:0,g:591,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11247] = {n:"Durchstochenes Frigsus-Ohr",t:106,d:"Frigsus-Ohren sind immer durchstochen. Liegt es an einer Leidenschaft für Ohrringe oder liegt es am schlechten Einfluss der Lieder Oh\'Neins, die manchmal vom Kontinent herüberschallen?",ep:0,g:626,l:130,wd:false,fm:true,w:10,an:0,p:10};
I.u[11248] = {n:"Kaniglu-Ohr",t:106,d:"Dieses Ohr erinnert euch an ein Lied der jungen Frigostianer: \"Kaniglu Gluck Gluck... Omnischlund Schling Schund... Rumtata Rumtata Tätärä!\". Eine große dichterische Leistung und kurz genug, um selbst von Iops gesungen zu werden.",ep:0,g:627,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11249] = {n:"Kaniglu-Pelz",t:55,d:"Dieser Pelz erinnert euch an den Text eines Volkliedes, das jeder Frigostianer auswendig kennt: \"Kaniglu look look... Äh\"... Wie ging das Lied nochmal weiter?",ep:0,g:730,l:135,wd:false,fm:true,w:10,an:0,p:10};
I.u[11250] = {n:"Haar einer Maunzwildmiez",t:54,d:"Als sie noch lebten, pflegten die politischen Gegner dem Meister Burgherr zu versichern, dass sie ausschließlich Unterwäsche aus Maunzwildmiez-Haaren trugen.",ep:0,g:677,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11251] = {n:"Sternum einer Maunzwildmiez",t:47,d:"Mehr als einer hat sich bereits gefragt, was man wohl mit dem Sternum einer Maunzwildmiez anfangen könnte. Eine ausgestopfte Maunzwildmiez vielleicht?",ep:0,g:666,l:85,wd:false,fm:true,w:10,an:0,p:10};
I.u[11252] = {n:"Pfote einer Zefatz-Ratte",t:103,d:"Junge Schüler auf Frigost pflegen ein Spiel namens \"Maunzfatz\" zu spielen. Die Regeln sind einfach. Mit der Pfote einer Zefatz-Ratte werden Spuren im Schnee hinterlassen. Eine Maunzwildmiez wird diesen folgen, um schließlich in einem Hinterhalt zu landen. Die Miez wird gefangen, geschert und aus den Haaren werden Handschuhe gefertigt. Die Kreativität von Kindern ist wahrhaftig nicht zu unterschätzen!",ep:0,g:36,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11253] = {n:"Pelz der Zefatz-Ratte",t:55,d:"Vor der Vereisung von Frigost wurden die Zefatz-Ratten gern ihres Pelzes wegen gejagt. Kleider daraus wurden dann in Amakna unter dem Label: \"exotische Kitsou-Pelzmäntel\" vertrieben.",ep:0,g:731,l:95,wd:false,fm:true,w:10,an:0,p:10};
I.u[11254] = {n:"Zange eines Krebab-Tai",t:47,d:"Krebab-Tais werden von den Fischern von Frigost aus zwei verschiedenen Gründen gejagt. Zum einen, weil sie penetrant schlechte Laune verbreiten. Zum anderen, weil sie gern aus Spaß an der Freude mit ihren Zangen die Netze der Fischer abschneiden. Die Fischer wiederum machen sich mit Freude einen Spaß daraus, den Krebabs die Zangen abzuschneiden.",ep:0,g:668,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11255] = {n:"Auge eines Krebab-Tai",t:109,d:"Dieses Auge schwimmt in einer milchigen Flüssigkeit, die gern bei echter Hausmacher-Kost Anwendung findet und zwar als Essigersatz. Natürlich muss man entsprechend viel Zeit zur Fermentierung einrechnen.",ep:0,g:592,l:65,wd:false,fm:true,w:10,an:0,p:10};
I.u[11256] = {n:"Frostikan-Schnabel",t:47,d:"Der Frostikan ist eine dumme, schlecht erzogene Kreatur, dessen Guano die Hälfte des Hafens von Frigost bedeckt. Außerdem neigt sie dazu, die geangelten Fische der Fischer zu stehlen. Aber gut abgerichtet kann dieser Vogel die Reichtümer abgelenkter Touristen in seinem Schnabel verstecken.",ep:0,g:667,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11257] = {n:"Frostikan-Feder",t:53,d:"Diese Federn werden gern von Schülern auf Frigost für Schreibübungen verwendet. Frostikan-Mütter bringen daher ihrem Nachwuchs als Erstes bei, dass sie beim Vorbeiflug an Schulen immer so schnell wie möglich fliegen müssen.",ep:0,g:648,l:75,wd:false,fm:true,w:10,an:0,p:10};
I.u[11258] = {n:"Quittung vom Chef Sietas",t:24,d:"Auf dieser Quittung ist das Empfangsdatum der Kiefernstämme aufgeführt. Wenn ihr sie",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[11259] = {n:"Kiefernstämme",t:24,d:"Chef Sietas benötigt diese Stämme, um das Heizsystem anzufeuern.",ep:0,g:0,l:1,wd:false,fm:true,w:0,p:1};
I.u[11260] = {n:"Ping-Fett",t:24,d:"Dieses vielschichtige und fischige Fett ist ein ausgezeichneter Brennstoff mit langer... sehr sehr langer Brenndauer. Das ist auch der Grund, warum die Pings niemals kalt haben!",ep:0,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[11261] = {n:"Damars Materialliste",t:24,d:"Auf dieser Liste sind die Materialien aufgelistet, die von den Fischern des Zugefrorenen Sees für die Reparatur benötigt werden.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[11262] = {n:"Damars Ehering",t:24,d:"Ehering, den Damar vor dreißig Jahren Vali Dummidatt versprochen hatte.",ep:0,g:27,l:1,wd:false,fm:true,w:0,p:1};
