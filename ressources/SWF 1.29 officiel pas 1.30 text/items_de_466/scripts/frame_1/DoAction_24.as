I.u[11182] = {n:"Perrücke des Königlichen Fressmuts",t:24,d:"Eines ist sicher: ohne die Perücke wird der Königliche Fressmut ganz schön an Autorität einbüßen!",ep:0,g:826,l:1,wd:false,fm:true,w:0,p:1};
