I.u[11174] = {n:"Schlüssel zum Fressmut-Dungeon",t:84,d:"Dieser Schlüssel ermöglicht den Eintritt ins Fressmut-Dungeon. Nur Mut!",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:1};
I.u[11175] = {n:"Ping\'den-Schlüssel",t:84,d:"Dieser Schlüssel mit hohem Quecksilbergehalt schwimmt auf dem Wasser und sogar in Vinaigrette! Alternativ kann man damit auch den Ping-Dungeon aufschließen, ja!",ep:0,g:255,l:1,wd:false,fm:true,w:1,p:1};
