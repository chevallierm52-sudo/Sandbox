I.u[2998] = {n:"Minotororwolle",t:57,d:"Diese großartige Wolle hat schon viel erlebt, wie einen Zusammenstoß mit dem Dark Vlad zum Beispiel. Glücklicherweise schützt sie sich und ihren Besitzer selbst vor den heimtückischsten Schlägen.",ep:2,g:654,l:125,wd:true,fm:true,w:30,p:12500};
I.u[2999] = {n:"Minotoror-Leder",t:56,d:"Dieses Leder ist mindestens so stabil, wie die Befestigungsanlagen von Brâkmar. Es hat bisher noch gänzlich unerforschte Eigenschaften, die es erlauben, das Leder leicht bearbeiten zu können, um daraus extrem mächtige und schöne Gegenstände herzustellen.",ep:2,g:655,l:125,wd:true,fm:true,w:30,p:12500};
I.u[3000] = {n:"Zerstörter Bworkhelm",t:15,d:"In jedem Bworkdorf sind es die Bwork Magi, welche sich um die Schmiede kümmern. Da dies ein gefährliches Handwerk ist, erhalten alle Schmiede schon ab der frühesten Kindheit einen Helm, um sich vor Hammerschlägen und Stürzen zu schützen.",ep:4,g:646,l:43,wd:true,fm:true,w:10,p:1};
I.u[3001] = {n:"Bwork-Schulterpolster",t:15,d:"Dieses Schulterpolster ist besonders wichtig für die körperliche Ertüchtigung. Wobei man im Falle der Bworks eher von Training sprechen sollte.",ep:4,g:647,l:43,wd:true,fm:true,w:10,p:1};
I.u[3002] = {n:"Löcheriger Bwork-Stiefel",t:15,d:"Dieser Stiefel ist in diesem Zustand unbenutzbar. Doch braucht man ihn nur von einem erfahrenen Schuhmacher flicken zu lassen, dann ist er wieder wie neu. Bis dahin stößt der schlimme Geruch aufdringliche Liebhaber ab.",ep:4,g:648,l:43,wd:true,fm:true,w:10,p:1};
