I.u[2455] = {n:"Fresssackblut",t:15,d:"Ein wahrer Fresssackjäger geht niemals ohne Fresssackblut auf die Jagd. Denn es zieht besonders gut die dicken Fresssäcke an. Leider auch Fliegen...",ep:1,g:499,l:9,wd:true,fm:true,w:1,p:1};
I.u[2460] = {n:"Fresssäckchen-Auge",t:109,d:"Nicht, dass euch das Fresssäckchen jetzt im Auge behielte, doch werdet ihr den Eindruck nicht los, als würde es euch den Verlust desselben vorwerfen.",ep:1,g:500,l:2,wd:true,fm:true,w:1,p:1};
I.u[2462] = {n:"Hirn eines Fresssack-Anführers",t:15,d:"Seitdem ihr diesem Fresssack-Anführer sein Gehirn entnommen habt, hat er gewisse Koordinierungsprobleme...",ep:1,g:501,l:19,wd:true,fm:true,w:1,p:1};
I.u[2463] = {n:"Zahn des Fresssack-Anführers",t:47,d:"Den Zahn eines Fresssack-Anführers zu ziehen, ist keine leichte Aufgabe, wie alle wissen, die es bereits einmal versucht haben. Allerdings macht es nichts, wenn er dabei zerbricht. Es heißt sogar, dass beschädigte Zähne wertvoller seien, was auf Marktausgleichsmechanismen zurückzuführen ist, was auch immer dieses Wort bedeuten mag...",ep:1,g:502,l:19,wd:true,fm:true,w:1,p:1};
I.u[2464] = {n:"Schwanz des Fresssack-Anführers",t:65,d:"Bleibt gut versteckt im dichten Unterholz liegen und beobachtet. Mit etwas Glück könnt ihr dann einen Fresssack-Anführer glücklich mit dem Schwänzchen wedeln sehen. Doch geschieht das nur einmal pro Jahr und zwar in der Paarungszeit.",ep:1,g:503,l:19,wd:true,fm:true,w:1,p:1};
I.u[2465] = {n:"Fresssack-Anführer-Horn",t:47,d:"Da er wesentlich ruppiger als seine Artgenossen ist, fällt es dem Fresssack-Anführer auch leichter, Srams und andere Abenteurer aufzuspießen. Darum findet man oftmals an der Spitze der Hörner kleine Stofffetzen befestigt. Offensichtlich eine Trophäensammlung.",ep:1,g:504,l:19,wd:true,fm:true,w:1,p:1};
I.u[2466] = {n:"Fresssack-Anführer-Zunge",t:15,d:"Für eine Fresssack-Anführer-Zunge gilt: je älter, desto widerlicher. Ihr Aussehen ähnelt immer mehr einer ausgedörrten Larve, während sich der Geruch dem eines halbverwesten Trools annähert. Dieses Exemplar hier muss schon ganz besonders alt gewesen sein.",ep:1,g:505,l:19,wd:true,fm:true,w:1,p:1};
I.u[2467] = {n:"Huf eines Fresssack-Anführers",t:47,d:"Laut der Schuhmacher gehören Hufe dieser Art zu den Haltbarsten und gleichzeitig auch Formbarsten in ganz Amakna. Wenn man jetzt nur wüßte, was sie unter \"formbar\" verstehen!",ep:1,g:538,l:18,wd:true,fm:true,w:1,p:1};
I.u[2468] = {n:"Magen eines Fresssack-Anführers",t:15,d:"Im Inneren dieses Magens wartet eine echte Überraschung auf euch. Ein Puzzle! Kleiner Finger eines Enutrofs, Nase eines Osamodas, Haarbüschel eines Sadidas. Aus all diesen Teilen könnte man einen Helden basteln!",ep:1,g:506,l:19,wd:true,fm:true,w:1,p:1};
I.u[2469] = {n:"Gelano",t:9,d:"Kein Nägelkauen mehr mit diesem Ring. Einfach stattdessen die Finger lecken!",ep:7,g:47,l:60,wd:true,fm:true,w:5,s:6,p:10000};
I.u[2470] = {n:"Geloboots",t:11,d:"Diese Stiefel sind sehr bequem. Zudem sind sie besonders im Sommer sehr praktisch, da ihnen ein Geruch nach Walderdbeeren entströmt, der problemlos selbst den üblen Fußgeruch eines alten Sadida mit haarigen Zehen überdecken kann.",ep:5,g:31,l:60,wd:true,fm:true,w:50,s:6,p:1000};
I.u[2471] = {n:"Gelogürtelo",t:10,d:"Das Schwerste an diesem Gürtel ist, den Heißhunger auf Süßkram zu unterdrücken, um ihn nicht gleich an Ort und Stelle aufzuessen.",ep:7,g:32,l:60,wd:true,fm:true,w:15,s:6,p:1000};
I.u[2472] = {n:"Gelamu",t:1,d:"Dieses Amulett verrät eure Vorliebe für Gelee-Orgien. Es gibt sicherlich bessere Wege, sich innerhalb der Gesellschaft ins Rampenlicht zu stellen, doch wenigstens steht ihr zu eurer Schwäche.",ep:5,g:51,l:60,wd:true,fm:true,w:4,s:6,p:1000};
I.u[2473] = {n:"Umhang des Abenteurers",t:17,d:"Dieser klassische Umhang ist zwar noch keine große Klasse, doch wird er sicherlich kleine Abenteurer mit großer Freude erfüllen.",ep:1,g:48,l:1,wd:true,fm:true,w:7,s:5,p:100};
I.u[2474] = {n:"Hut des Abenteurers",t:16,d:"Eines kann er gut, dieser Hut, nämlich hübsche Mädchen in die Flucht schlagen. Doch ansonsten ist er leider nicht sehr nützlich.",ep:1,g:44,l:1,wd:true,fm:true,w:12,s:5,p:100};
I.u[2475] = {n:"Ring des Abenteurers",t:9,d:"Dieser niedliche Ring ist besonders für Anfänger gut geeignet und wird mit Sicherheit alle kleinen Kinder oder Ecaflips sehr erfreuen.",ep:1,g:48,l:1,wd:true,fm:true,w:5,s:5,p:10};
I.u[2476] = {n:"Stiefel des Abenteurers",t:11,d:"Diese Stiefel einfacher Machart sind haltbar und schützen ihren Träger vor den Gefahren des Abenteureralltages. Daher sind sie besonders für junge Krieger gut geeignet, die sich auf den beschwerlichen Weg des Abenteurerlebens begeben haben.",ep:1,g:32,l:1,wd:true,fm:true,w:15,s:5,p:10};
I.u[2477] = {n:"Gürtel des Abenteurers",t:10,d:"Ein kleiner Gürtel für kleine angehende Abenteurer. Klein, aber fein!",ep:1,g:33,l:1,wd:true,fm:true,w:6,s:5,p:10};
I.u[2478] = {n:"Amulett des Abenteurers",t:1,d:"Nicht sehr stylisch, nicht sehr mächtig, aber ganz nett, wenn man das vollständige Set dazu besitzt.",ep:1,g:52,l:1,wd:true,fm:true,w:2,s:5,p:10};
I.u[2479] = {n:"Lausiger Schweinepriester-Kamm",t:15,d:"Dieser Kamm ist ein Zeichen der Reife bei den lausigen Schweinepriestern. Darum sieht man manchmal junge Eniripsas, die sich erwachsen geben wollen damit durch die Straßen der Städte stolzieren. Doch niemals wagen sie sich damit in den felsigen Teil der Ebenen von Cania. Seltsam.",ep:13,g:507,l:18,wd:true,fm:true,w:1,p:1};
I.u[2480] = {n:"Lederschlüpfer des Lausigen Schweinepriesters",t:56,d:"\"Ein Schweinepriester ohne Lederschlüpfer ist ein toter Schweinepriester\", so lautet der Lieblingsspruch der Dame Arskuss, einer voyeuristisch und sadistisch veranlagten Feca-Anhängerin. Ihr Lieblingszeitvertreib soll darin bestanden haben, ihre \"Freunde\" zu zwingen, die erwähnten gebrauchten Lederschlüpfer der Schweinepriester über ihren Kopf zu stülpen.",ep:13,g:508,l:18,wd:true,fm:true,w:1,p:1};
I.u[2481] = {n:"Lausiger Schweinepriester-Rüssel",t:15,d:"Dieser Rüssel ist nicht nur rosa wie die Backen eines Osamodas-Säuglings, sondern lässt sich auch zu einer schmackhaften Speise verarbeiten. Alternativ könnt ihr daraus auch eine hübsche Rüsselhalskette anfertigen, vorausgesetzt, ihr seid mutig genug, die amüsierten Blicke der Nachbarn auszuhalten.",ep:13,g:509,l:18,wd:true,fm:true,w:1,p:1};
I.u[2482] = {n:"Lausiger Schweinepriester-Treter",t:15,d:"Es wurde einmal ein ähnlicher Schuh auf den Treppenstufen des Königsschlosses gefunden. Wie die Gerüchte sagen, soll dieser Schuh bei der überstürzten Flucht einer Lausigen Schweinepriesterin verloren worden sein.",ep:13,g:510,l:18,wd:true,fm:true,w:2,p:1};
I.u[2483] = {n:"Lausiges Schweinepriestergebiss",t:47,d:"Einige Lausige Schweinepriester kommen ohne Gebiss auf die Welt. Andere hingegen sind mit einem vollen Gebiss ausgestattet. Manchmal kommt es auch vor, dass welche eines morgens mit einem Gebiss im Mund aufwachen, ohne zu wissen, wie sie dazu kamen.",ep:13,g:511,l:30,wd:true,fm:true,w:1,p:1};
I.u[2484] = {n:"Zerborstener Dreizack",t:15,d:"Dies ist ein kleines Andenken an euren Lausigen Schweinepriester-Freund. Doch mit seinem lausigen Charakter ist es gut möglich, dass er euch quer durchs Land verfolgt, nur weil ihr angeblich seinen Dreizack zerbrochen hättet.",ep:13,g:512,l:18,wd:true,fm:true,w:2,p:1};
I.u[2485] = {n:"Vegakapp",t:16,d:"Der derzeitige Hit im Nordosten Amaknas.",ep:1,g:45,l:40,wd:true,fm:true,w:25,s:10,p:4500};
I.u[2486] = {n:"Lausiges Schweinepriesterohr",t:106,d:"Dieses Ohr ist ein gutes Mittel, um sich Respekt zu verschaffen. Diese Trophäe ist der Beweis, dass ihr die Lausigen Schweinepriester nach Belieben an der Nase herumführen könnt. Doch Vorsicht, andere Schweinepriester finden das sicher nicht so lustig.",ep:13,g:513,l:18,wd:true,fm:true,w:1,p:1};
I.u[2487] = {n:"Skorpiut-Panzer",t:107,d:"Skorpiut-Panzer sind einfach ideal für die Anfertigung schwerer Rüstungen. Dennoch wurden diese Kreaturen eines Tages aus Brâkmar herausgetrieben, weil sie aufgrund ihrer unkontrollierbaren Vermehrung zu einer Plage wurden. Selbst Gelees können sich nicht so schnell vermehren!",ep:14,g:514,l:36,wd:true,fm:true,w:1,p:1};
I.u[2488] = {n:"Skorpiut-Innereien",t:15,d:"Bei oberflächlichem Betrachten sehen diese Innereien nicht gerade appetitlich aus. Nun, ihr habt Recht. Skorpiut-Innereien schmecken absolut scheußlich, selbst wenn sie mit Liebe zubereitet wurden.",ep:14,g:445,l:36,wd:true,fm:true,w:1,p:1};
I.u[2489] = {n:"Super-Vega-Mantelblatt",t:17,d:"Mit diesem hocheleganten Mantel werdet ihr in Zukunft aufpassen müssen, kein Blatt vor den Mund zu bekommen.",ep:1,g:49,l:58,wd:true,fm:true,w:15,s:10,p:1000};
I.u[2490] = {n:"Skorpiut-Klaue",t:103,d:"Nur wenige Eingeweihte wissen, wie man eine Skorpiut-Klaue in solch gutem Zustand erhält. Hoffen wir einmal, dass ihr sie auch mit guten Absichten erworben habt, und nicht bloß, um damit Schlösser zu knacken.",ep:14,g:515,l:36,wd:true,fm:true,w:1,p:1};
I.u[2491] = {n:"Ouginak-Auge",t:109,d:"Es ist befremdlich, aber wahr. Dieses Ouginak-Auge reflektiert nicht den Betrachter. Stattdessen erblickt man sein Dubbel. Sehr merkwürdig.",ep:14,g:516,l:51,wd:true,fm:true,w:1,p:1};
I.u[2492] = {n:"Ouginak-Kette",t:15,d:"Diese dicke Hundekette habt ihr von einem Ouginak. Bevor sie zerbrach, diente sie höchstwahrscheinlich dazu, den Ouginak irgendwo anzuketten.",ep:14,g:517,l:51,wd:true,fm:true,w:2,p:1};
I.u[2493] = {n:"Ouginak-Herz",t:15,d:"Dieses Herz wird euch treu begleiten. Solange ihr es nicht verkauft, tauscht oder verschenkt, wird es euch stets in der Tiefe eures Rucksacks begleiten. Welch herzensrührende Treue!",ep:14,g:518,l:51,wd:true,fm:true,w:1,p:1};
I.u[2494] = {n:"Schwertknauf",t:15,d:"Sicherlich konnte nur ein übermächtiger Schlag dieses gefürchtete Schwert zerbrechen. In der Tat hat jeder Abenteurer, der das Schwert des Ouginaks in der Hand hält, das Bedürfnis, vor Freude loszuheulen. Wa-hooooooo!",ep:14,g:519,l:51,wd:true,fm:true,w:2,p:1};
I.u[2495] = {n:"Kolerat-Auge",t:109,d:"Dieses Auge leuchtet im Dunkeln, wenn es erst einmal von seinem Besitzer getrennt ist. So kann er es besser wiederfinden.",ep:2,g:520,l:9,wd:true,fm:true,w:1,p:1};
I.u[2496] = {n:"Kolerat",t:65,d:"Wenn er in feine Scheiben geschnitten wird, hat der Schwanz eines Kolerats einen leckeren Wurstgeschmack. Doch verschwindet dieser, sobald die Stücke zu groß werden. Sehr seltsam!",ep:2,g:521,l:9,wd:true,fm:true,w:1,p:1};
I.u[2497] = {n:"Kolerat-Ohr",t:106,d:"Haltet es ganz nah ans Ohr. Dann könnt ihr das Meer hören, heißt es.",ep:2,g:522,l:9,wd:true,fm:true,w:1,p:1};
I.u[2498] = {n:"Vegamu",t:1,d:"Das Vegamu hat die manchmal störende Angewohnheit, Moskitos anzuziehen, die es von weitem für eine Artgenossin halten. Da ist die Enttäuschung groß, wenn sie schließlich auf den Träger des Amulettes stoßen.",ep:1,g:53,l:40,wd:true,fm:true,w:20,s:10,p:1000};
I.u[2499] = {n:"Kolerat-Schnauze",t:15,d:"Kolerats haben einen außerordentlich guten Geruchssinn. Sie sind zwar den Ouginaks bei Weitem unterlegen, doch riechen sie diese schon auf 300 Meter Entfernung. Sehr praktisch, um ihnen zu entkommen.",ep:2,g:523,l:9,wd:true,fm:true,w:1,p:1};
I.u[2500] = {n:"Toter Kolerat",t:15,d:"Ihr hattet vollkommen Recht, ihn aufzuheben. Euer Gegner ist unversehrt. Zwar tot, aber noch völlig unversehrt.",ep:2,g:524,l:9,wd:true,fm:true,w:10,p:1};
I.u[2501] = {n:"Blutwolfschwanz",t:65,d:"Der Gott Osamodas kriegt jedes Mal die Krise, wenn man sich an seinen wilden Raubtieren vergreift. \"Sind sie so niedlich\", pflegt er dann zu rufen. Da sieht man, dass er noch nie eine ihrer Reviermarkierungen über sich ergehen lassen musste.",ep:1,g:525,l:19,wd:true,fm:true,w:1,p:1};
I.u[2502] = {n:"Blutwolfpfötchen",t:103,d:"Diese Pfötchen werden von allen Gastronomen aus der Region sehr geschätzt. Außerdem sollen sie magische Kräfte besitzen, die ihrem Besitzer Glück bringen. Nicht schlecht!",ep:1,g:526,l:19,wd:true,fm:true,w:1,p:1};
I.u[2503] = {n:"Blutwolfpelz",t:55,d:"Mit diesem Pelz seid ihr genauso gut herausgeputzt, wie ein Blutwolf. Falls es schon immer euer Traum gewesen sein sollte, mit einem Pelz auf dem Kopf katzengleich durch die Gegend zu schleichen, völlig lautlos und tödlich... so muss man sagen, dass ihr ganz schön seltsame Träume habt!",ep:1,g:200,l:19,wd:true,fm:true,w:1,p:1};
I.u[2504] = {n:"Blutwolfzunge",t:15,d:"Diese Zunge muss bereits an vielen heruntergekommenen Orten herumgehangen haben, bevor sie in eure Tasche kam.",ep:1,g:527,l:19,wd:true,fm:true,w:1,p:1};
I.u[2505] = {n:"Hundeknochen",t:15,d:"Um einen Blutwolf zu bändigen, gibt es nichts besseres als Hundeknochen. Ein Blutwolf liebt diese Dinger einfach. Er wird es euch gegenüber natürlich nicht zugeben wollen, doch habt ihr in ihm jetzt einen Freund fürs Leben gewonnen.",ep:1,g:528,l:19,wd:true,fm:true,w:1,p:1};
I.u[2506] = {n:"Schelle",t:15,d:"Mit seiner Schelle am Schwanzende lässt sich ein Schlängelchen bereits schon auf  Kilometern Entfernung hören. Glücklicherweise, möchte man sagen, da man es aufgrund seiner guten Tarnung bereits auf zwei Metern Entfernung nicht mehr ausmachen kann.",ep:13,g:529,l:10,wd:true,fm:true,w:1,p:1};
I.u[2507] = {n:"Gespaltene Zunge",t:15,d:"Mit dieser Zunge könnt ihr wunderbar eure Freunde auspeitschen. Osamodas und Sacrieurs wird dies eine Freude sein.",ep:13,g:530,l:10,wd:true,fm:true,w:1,p:1};
I.u[2508] = {n:"Schlängelchengift",t:15,d:"Dieses äußerst wirksame Gift könnte selbst eine Armee tollwütiger Fresssäcke besiegen. Darum ist es auch kein Wunder, dass man es auch früher zu genau diesem Zweck verwendet hat.",ep:13,g:531,l:10,wd:true,fm:true,w:1,p:1};
I.u[2509] = {n:"Schlängelchenzahn",t:47,d:"Dieser Zahn gehörte zweifelsfrei einmal einem Schlängelchen. Das sieht man sofort, weil die leicht gebogene Spitze vorn so unglaublich spitz ist.",ep:13,g:432,l:10,wd:true,fm:true,w:1,p:1};
I.u[2510] = {n:"Keiler der Ebenen-Magen",t:15,d:"Dieser Magen kann manchmal furchterregende Dinge enthalten. Ein Iopine wäre sicher begeistert von der Möglichkeit, all ihre Schwerter darin zu verstauen.",ep:13,g:532,l:44,wd:true,fm:true,w:1,p:1};
I.u[2511] = {n:"Keiler der Ebenen-Leder",t:56,d:"Keiler der Ebenen-Leder hat viele gute Eigenschaften. Jedoch pflegten die Schuhmacher  zu zögern, wenn es darum geht, es zu verwenden. Der Grund: es stinkt nicht. Daher glaubten viele Kunden, es handele sich dabei bloß um ein billiges Lederimitat und wollten ihre Produkte nicht kaufen.",ep:2,g:410,l:44,wd:true,fm:true,w:10,p:1};
I.u[2512] = {n:"Keiler der Ebenen-Schwanz",t:65,d:"Viele Wilderer von Brâkmar sammeln diese haarigen Trophäen. Auch wenn bis heute ihr genauer Verwendungszweck unbekannt bleibt.",ep:13,g:536,l:44,wd:true,fm:true,w:1,p:1};
I.u[2513] = {n:"Keiler der Ebenen-Pelz",t:55,d:"Im Gegensatz zum Leder geht vom Pelz eines Keilers der Ebenen ein strenger Geruch aus, mit dem man selbst verstopfte Nasen wieder freibekommt. Man sagt ihm nach, man könne damit selbst Sadidas im Winterschlaf wieder aufwecken.",ep:13,g:537,l:44,wd:true,fm:true,w:1,p:1};
I.u[2514] = {n:"Keiler der Ebenen-Huf",t:47,d:"Im Allgemeinen sind die Hufe dieses Keilers von Lehm und Erde bedeckt. Doch manchmal findet man auch kleine zertretene Biblobs aller Farben darunter. Wie auch ihr selbst scheinen Keiler der Ebenen Biblobs nicht zu mögen.",ep:13,g:539,l:44,wd:true,fm:true,w:1,p:1};
I.u[2515] = {n:"Keiler der Ebenen-Rüssel",t:15,d:"Auf dem ersten Blick wirkt dieser Rüssel hier nicht gerade sehr frisch. Dennoch gehört er  zu den frischesten und zartesten aller Schweinerüssel.",ep:13,g:540,l:44,wd:true,fm:true,w:1,p:1};
I.u[2516] = {n:"Keiler der Ebenen-Hauer",t:47,d:"Diese Hauer werden euch immer an den verhassten Keiler der Ebenen erinnern. Doch muss man feststellen, dass sie genauso abgenutzt sind, wie die Schneidezähne eines Wabbits, der viele Kawotten genagt hat.",ep:13,g:541,l:44,wd:true,fm:true,w:1,p:1};
I.u[2517] = {n:"Mega-Umhang",t:17,d:"Dieser Umhang gehörte einem berühmten Helden, der dafür bekannt war, den furchtbaren Dr. Wily besiegt zu haben, welcher mit seinen beschworenen Wesen die Welt der Zwölf erobern wollte. Dr. Wily starb im Kampf, bevor noch irgendeines seiner beschworenen Wesen etwas tun konnte.",ep:1,g:50,l:45,wd:true,fm:true,w:2,s:76,p:5500};
I.u[2518] = {n:"Viewtifuler Mantel",t:17,d:"Silvia von Jodaw hat diesen mächtigen Mantel mit eigener Hand aus einem Bündel alter Gardinen geschneidert. Glücklicherweise merkt man ihm das kaum an, so sehr ähnelt er nun einem in Schweiniosblut ausgewrungenem Wischmob.",ep:1,g:51,l:45,wd:true,fm:true,w:2,s:75,p:5500};
I.u[2519] = {n:"Megahelm",t:16,d:"Um selbst extremste Situationen zu meistern, um in der Gesellschaft eurer Freunde zu glänzen, kurz, um ein wahrer Held zu sein, ist dieser schicke Helm hier genau das Richtige.",ep:1,g:46,l:44,wd:true,fm:true,w:2,s:76,p:5200};
I.u[2520] = {n:"Viewtifuler Helm",t:16,d:"Dieser Helm gehörte einst dem guten alten Jojo, einem Helden aus längst vergangenen Zeiten. Obwohl er für viele Heldentaten berühmt war, ist unverständlich, wie sehr er immer noch von Fans idealisiert wird.",ep:1,g:47,l:44,wd:true,fm:true,w:2,s:75,p:5200};
I.u[2521] = {n:"Megastiefel",t:11,d:"Roll, die freundliche Schwester des Besitzers dieser Stiefel, war Spezialistin in astraler Ausstopftechnik. Was ist nun der Unterschied zwischen normaler und astraler Ausstopftechnik? Nun, bei der astralen Ausstopftechnik werden Kreaturen astral ausgestopft natürlich! Warum ist das bloß so schwer zu begreifen?",ep:1,g:33,l:43,wd:true,fm:true,w:2,s:76,p:5000};
I.u[2522] = {n:"Viewtifule Stiefel",t:11,d:"Dank dieser Stiefel konnte der berühmte-berüchtigte Jojo die Power seiner Rundumkicks erhöhen. Ein Wunder, dass sie immer noch weiß sind...",ep:1,g:34,l:43,wd:true,fm:true,w:2,s:75,p:5000};
I.u[2523] = {n:"Megagürtel",t:10,d:"Dieser Gürtel wurde speziell dafür entwickelt, die Hüften des Träger zu schützen. Er wird euch also zu nichts Nutze sein.",ep:1,g:34,l:45,wd:true,fm:true,w:2,s:76,p:5600};
I.u[2524] = {n:"Viewtifuler Gürtel",t:10,d:"Es heißt, dieser Gürtel sei von Käpft\'n Bluh persönlich angefertigt worden. Kaum zu glauben! Dennoch habt ihr nicht einmal gestutzt!",ep:1,g:35,l:46,wd:true,fm:true,w:2,s:75,p:5600};
I.u[2525] = {n:"Meister Rabs Herz",t:15,d:"Ohne Herz wird seinem hübschen Vogelgezwitscher sicherlich etwas fehlen.",ep:13,g:328,l:160,wd:true,fm:true,w:1,p:1};
I.u[2526] = {n:"Meister Rabs Sichel",t:15,d:"Diese Sichel diente ursprünglich dazu, Iops niederzumähen. Doch stellte Meister Rab schnell fest, dass sie so scharf ist, dass man mit ihr auch jederzeit alles und jeden erwischen kann.",ep:1,g:557,l:160,wd:true,fm:true,w:10,p:1};
I.u[2527] = {n:"Stinkus Casei",t:15,d:"Der Meister steckt wirklich voller Überraschungen. In seiner Tasche fandet ihr einen Stinkus Casei, die Königin aller Käsesorten. Er war bereits angebrochen, ein Indiz für den feinen Geschmack Meister Rabs. Doch angesichts der Gestankswolke dieses überreifen Käsestückes, ist es wohl besser, wenn ihr ihn nicht allzu lange bei euch aufbewahrt.",ep:13,g:558,l:160,wd:true,fm:true,w:1,p:1};
I.u[2528] = {n:"Kanigrou-Kralle",t:47,d:"Man muss sowohl stark, als auch schnell sein, um eine Kanigrou-Kralle zu ergattern. Stark, um sie abzutrennen und schnell, um der tödlichen Ohrfeige auszuweichen, die zwangsläufig danach kommt.",ep:13,g:559,l:70,wd:true,fm:true,w:1,p:1};
I.u[2529] = {n:"Tinktur aus flüssigem Metall",t:26,d:"Diese Tinktur vermag einer geschmiedeten ätherischen Waffe einen kleinen Teil Stofflichkeit zurückzugeben.",ep:1,g:13,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2530] = {n:"Caraboots",t:11,d:"Diese zwar ein wenig schweren, aber todschicken Stiefel werden euch zur Königin der Nacht machen.",ep:12,g:35,l:60,wd:true,fm:true,w:50,s:9,p:1000};
I.u[2531] = {n:"Carachoud",t:16,d:"Gleich euch hat eine Schildkröte einen wirklich sehr sehr kleinen Kopf. Das trifft sich gut, denn dieser Hut ist speziell für einen solchen konzipiert worden.",ep:12,g:48,l:60,wd:true,fm:true,w:24,s:9,p:10000};
I.u[2532] = {n:"Caramantel",t:17,d:"Ein praktischer und widerstandsfähiger Umhang ist das. Er wird euch bestimmt nicht über Nacht zu einer Berühmtheit machen, doch da ihr das ja vorher auch nicht wart, wo ist das Problem?",ep:12,g:52,l:60,wd:true,fm:true,w:15,s:9,p:10000};
I.u[2534] = {n:"Eis-Kwape",t:17,d:"Dieser Umhang ist einfach ideal, sich damit abzukühlen, wenn die Sonne wieder einmal auf Moons Insel niederbrennt oder das heiße Blut eurer unternehmungslustigen und selbstmörderischen Freunde am Überkochen ist. Sei es, sein Mütchen zu kühlen oder einen kühlen Kopf zu bewahren, dieser Umhang wird allen Ansprüchen des modernen Abenteurers gerecht.",ep:8,g:53,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2535] = {n:"Eis-Kwackapp",t:16,d:"Die Eis-Kwackapp wird euch immer mit neuen, frische Ideen versorgen, selbst wenn euch letztere gerade am Ausgehen sind. Leider ist sie nicht mächtig genug, um bei Iops zu wirken.",ep:13,g:49,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2537] = {n:"Eis-Kwackürtel",t:10,d:"Dieser Gürtel ist nicht nur ideal, um eure Hüften zu festigen, nein, er wird sogar auch alles andere festigen und kühl bewahren, was unterhalb der Gürtellinie liegt. Ist das nicht toll?",ep:12,g:36,l:41,wd:true,fm:true,w:5,s:13,p:4600};
I.u[2538] = {n:"Tinktur aus flüssigem Schwermetall",t:26,d:"Diese Tinktur vermag einer geschmiedeten ätherischen Waffe einen Teil Stofflichkeit zurückzugeben.",ep:1,g:14,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2539] = {n:"Extrakt aus Holzspänen",t:26,d:"Diese Tinktur vermag einer geschnitzten ätherischen Waffe einen Teil Stofflichkeit zurückzugeben.",ep:1,g:16,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2540] = {n:"Extrakt aus kräftigen Holzspänen",t:26,d:"Diese Tinktur vermag einer geschnitzten ätherischen Waffe einen Teil Stofflichkeit zurückzugeben.",ep:1,g:17,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2541] = {n:"Tinktur aus flüssigem Edelmetall",t:26,d:"Diese Tinktur vermag einer geschmiedeten ätherischen Waffe einen großen Teil Stofflichkeit zurückzugeben.",ep:2,g:15,l:1,wd:true,fm:true,w:1,c:"Pj=17|Pj=31|Pj=14|Pj=11|Pj=20",p:10};
I.u[2542] = {n:"Heimtrank",t:12,d:"Dieser Trank bringt einen Abenteurer jederzeit blitzschnell wieder zu seinem Zuhause zurück.",ep:1,g:142,l:1,wd:true,fm:true,w:2,u:true,p:100};
I.u[2543] = {n:"Extrakt aus seltenen Holzspänen",t:26,d:"Diese Tinktur vermag einer geschnitzten ätherischen Waffe einen großen Teil Stofflichkeit zurückzugeben.",ep:9,g:18,l:1,wd:true,fm:true,w:1,c:"Pj=13|Pj=19|Pj=18",p:10};
I.u[2544] = {n:"Rabkling",t:6,d:"So furchtbar scharf und unglaublich stylisch ist diese Klinge, dass sie viele Neider finden wird... wenn ihr oft in Rablingskreisen verkehrt.",ep:1,g:32,l:45,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,20,50,false,false],s:8,p:4500};
I.u[2545] = {n:"Rabühstiefel",t:11,d:"Diese Stiefel verleihen dem Träger ein einzigartiges Gefühl von Leichtigkeit, allerdings auch ein völlig bescheuertes Aussehen.",ep:1,g:37,l:45,wd:true,fm:true,w:1,s:8,p:1000};
I.u[2546] = {n:"Rabling-Helm",t:16,d:"Dank dieses hübschen Helmes werdet ihr fast so stylisch aussehen, wie der berüchtigte Meister Rab.",ep:1,g:50,l:45,wd:true,fm:true,w:23,s:8,p:1000};
I.u[2547] = {n:"Rabacapa Maesteri",t:17,d:"Die besten Schneider Amaknas haben sich nach dem Dahinscheiden Meister Rabs zusammengeschlossen, um aus seinen Überresten einen prächtigen Umhang zu schaffen. Das ist ihnen definitiv gelungen. Mit diesem Umhang ist jedem sofort klar – der Meister, das seid ihr!",ep:13,g:56,l:127,wd:true,fm:true,w:30,p:41000};
I.u[2549] = {n:"Kanigrou-Dose",t:15,d:"Diese Dose enthält Kanigroustücke, die frisch geschnitten da hineingepresst wurden. Solch eine Kanigrou-Dose ist leicht zu transportieren und auch noch lecker. Der beste Freund des Menschen.",ep:13,g:560,l:70,wd:true,fm:true,w:1,p:1};
I.u[2550] = {n:"Kanigrou-Pelz",t:55,d:"Aus diesem Pelz könnte man eine tolle Perücke anfertigen. Damit wird man euch bereits von Weitem bemerken! Von sehr Weitem bereits und auf jeden Fall.",ep:13,g:561,l:70,wd:true,fm:true,w:1,p:1};
I.u[2551] = {n:"Kanigrou-Ohr",t:106,d:"Die Lieblingsmahlzeit aller Ouginaks ist: Kanigrou-Ohr in eigenem Saft. Doch das Standardrezept sieht Wildminze und ein paar knusprige Nägel für einen stärkeren Geschmack vor.",ep:13,g:562,l:70,wd:true,fm:true,w:1,p:1};
I.u[2552] = {n:"Kanigrou-Auge",t:109,d:"Das Kanigrou-Auge wurde zu einem echten Modeschlager. Fast jeder Abenteurer rennt nun mit solch einem Auge um den Hals herum.",ep:13,g:563,l:70,wd:true,fm:true,w:1,p:1};
I.u[2553] = {n:"DAU-GAU-Kugel",t:15,d:"Dies ist eine richtige DAU-GAU-Kugel! Wenn man diese Kugel auf sich zukommen sieht, sollte man schleunigst Reißaus nehmen, sonst könnte es zu spät sein. Schwere Kopfschmerzen über eine große Zeitspanne wären die Folgen. Außerdem sind DAU-GAU-Kugeln sehr schwer, und daher auch sehr schwer wieder loszuwerden...",ep:1,g:564,l:40,wd:true,fm:true,w:500,p:1};
I.u[2554] = {n:"Lausiges Schweinepriesterkotelett",t:47,d:"Lausige Schweinepriesterkoteletts haben einen charakteristischen Geschmack. Manche essen sie lieber mit Sauce, andere roh. Lausige Schweinepriester hingegen ziehen euch als Kotelett vor. Jeder hat eben seinen eigenen Geschmack.",ep:13,g:159,l:40,wd:true,fm:true,w:1,p:1};
I.u[2555] = {n:"Ledersattel",t:56,d:"Man könnte glatt meinen, Lausige Schweinepriester seien Weicheier, denn sie pflegen einen überaus weichen und konfortablen Sattel zu benutzen. Wenn man diesen ein wenig bearbeitet, könnte man glatt hervorragende Pantoffeln daraus fertigen.",ep:13,g:565,l:40,wd:true,fm:true,w:5,p:1};
I.u[2556] = {n:"Blobpollen",t:15,d:"Dies ist der Ursprung aller gutartigen Allergien in der ganzen Welt. Einziges Problem dabei ist bloß, dass gutartige Allergien leicht zu bösartigen Allergien werden können. Also lauft daher nicht mit diesen Pollen in der Tasche herum, wenn ihr es irgendwie vermeiden könnt.",ep:5,g:566,l:34,wd:true,fm:true,w:1,p:1};
I.u[2557] = {n:"Blobblütenblatt",t:35,d:"So seltsam, wie dies auch scheinen mag. Blobblütenblätter sind weder gekocht noch roh genießbar. Wer hätte das gedacht?",ep:5,g:567,l:34,wd:true,fm:true,w:1,p:1};
I.u[2558] = {n:"Toter Blob",t:15,d:"Ihr hattet vollkommen Recht, ihn aufzuheben. Euer Gegner ist unversehrt. Zwar tot, aber noch völlig unversehrt.",ep:5,g:568,l:34,wd:true,fm:true,w:10,p:1};
I.u[2559] = {n:"Troolmähne",t:15,d:"Eine Mähne wie diese sieht man nicht alle Tage. Nur die reichesten aller Enutrofs können es sich leisten, sich daraus eine Perücke machen zu lassen.",ep:4,g:569,l:115,wd:true,fm:true,w:1,p:1};
I.u[2560] = {n:"Schulterpolster des Trools",t:15,d:"Es ist ratsam, das Schulterpolster des Trools lieber in diesem Zustand zu begutachten, als direkt an der Schulter des Trools. Womöglich macht dieser sonst noch eine Modenschau.",ep:4,g:570,l:115,wd:true,fm:true,w:5,p:1};
I.u[2561] = {n:"Troolischer Armreif der Stärke",t:15,d:"Als bräuchte ein Trool noch einen Armreif der Stärke... Diese fürchterliche Kampfmaschine trägt jedoch einen an jedem Arm. Vielleicht als Glücksbringer?",ep:4,g:571,l:115,wd:true,fm:true,w:5,p:1};
I.u[2562] = {n:"Schlüpfer des Trools",t:56,d:"Wenn man sich den heruntergekommenen Zustand dieses Schlüpfers einmal ansieht, so weiß man, dass sich Trools auch wirklich überall hinsetzen. Auf den ersten Blick lässt sich daher auch das Alter seines Besitzers abschätzen...",ep:4,g:572,l:115,wd:true,fm:true,w:1,p:1};
I.u[2563] = {n:"Trunknydenholzkeil",t:38,d:"Für den Trunknyden dient dieser Keil als Fuß. Während der Fuß auch gleichzeitig als Keil dient. Darum sucht der arme Trunknyde auch stets nach einen Keil für seinen Fuß.",ep:9,g:573,l:35,wd:true,fm:true,w:2,p:1};
I.u[2564] = {n:"Trunknydenbrauen",t:38,d:"Wollt ihr wissen, wie ein Trunknyd zufällige Besucher zu vertreiben pflegt? Ganz einfach: mit dem, was ihr da gerade in den Händen haltet. Mit seinen dicken, hölzernen Augenbrauen!",ep:9,g:574,l:35,wd:true,fm:true,w:2,p:1};
I.u[2565] = {n:"Trunknyden-Scheibe",t:15,d:"Von diesem Trunknyden kann man sich eine Scheibe abschneiden, habt ihr euch gedacht. Und das prompt auch getan.",ep:9,g:575,l:35,wd:true,fm:true,w:2,p:1};
I.u[2566] = {n:"Magische Trunknyden-Scheibe",t:15,d:"Diese Scheibe unterscheidet sich von allen anderen Scheiben des Trunknyden. Im Moment, wo ihr sie abschneiden wolltet, gab es ein helles Aufblitzen und im nächsten Moment lag sie als bereits fertig geschnitten auf dem noch qualmenden Boden.",ep:9,g:576,l:35,wd:true,fm:true,w:2,p:1};
I.u[2567] = {n:"Vorschau",t:29,d:"Dieser Segen erlaubt es euch, in den nächsten Kämpfen schneller zu reagieren.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2568] = {n:"Untermenschliche Reflexe",t:30,d:"Dieser Fluch stürzt euch in einen semi-komatösen Zustand, wodurch eure Reflexe im nächsten Kampf stark verringert werden.",ep:1,g:6,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[2569] = {n:"Schriftrolle der Übermenschlichen Reflexe",t:14,d:"Im nächsten Kampf, an dem er teilnimmt, wird der Anwender dieser Schriftrolle an Flinkheit gewinnen.",ep:1,g:28,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2570] = {n:"Schriftrolle der Untermenschlichen Reflexe",t:14,d:"Im nächsten Kampf, an dem er teilnimmt, wird der Anwender dieser Schriftrolle ein wenig unbeweglich erscheinen.",ep:1,g:29,l:1,wd:true,fm:true,w:1,ut:true,p:250};
I.u[2571] = {n:"Prespik-Pfote",t:103,d:"Wie schafft es ein Prespik, mit nur 2 Klauen derart schnell zu sein? Habt ihr euch diese Frage nicht auch schon gestellt? Es wird wohl für immer ein Geheimnis bleiben.",ep:1,g:577,l:18,wd:true,fm:true,w:1,p:1};
I.u[2572] = {n:"Prespik-Magen",t:15,d:"\"Wenn man immer wieder das Gleiche isst, ähnelt man irgendwann dem, was man isst\". Diese berühmten Satz prägte der Koch von Bonta. Das erklärt auch, warum ein Prespikmagen innen grün ist.",ep:1,g:578,l:18,wd:true,fm:true,w:1,p:1};
I.u[2573] = {n:"Prespik-Schwanz",t:65,d:"Ein Prespik setzt nur sehr selten seinen Schwanz ein. Ein Glück, denn die Kraft die er damit entwickeln kann, ist beträchtlich. Manche Holzhacker wollen schon mit eigenen Augen beobachtet haben, wie Prespiks ganze Holzstämme mit ihrem Schwanz mitgeschleift haben.",ep:1,g:579,l:18,wd:true,fm:true,w:1,p:1};
I.u[2574] = {n:"Prespik-Mähne",t:15,d:"Es gibt nicht Besseres für geheime \"Wie-Aie-Pi\"-Treffen der Osamodasanbeter. Tragt diese Mähne und jeder wird euch für ein beschworenes Wesen halten!",ep:1,g:580,l:18,wd:true,fm:true,w:1,p:1};
I.u[2575] = {n:"WuWulf-Skalp",t:15,d:"Bei eurem Erscheinen hatte der WuWulf sicherlich die gleiche Absicht wie ihr. Nämlich euch mehr oder weniger diplomatisch euren Skalp zu entfernen. Ihr wart einfach schneller.",ep:1,g:581,l:70,wd:true,fm:true,w:1,p:1};
I.u[2576] = {n:"WullyWuWulf-Skalp",t:15,d:"Bei eurem Erscheinen hatte der WullyWuWulf sicherlich die gleiche Absicht wie ihr. Nämlich euch mehr oder weniger zartfühlend euren Skalp zu entfernen. Nun steht er da und schaut dumm aus der Wäsche.",ep:1,g:582,l:22,wd:true,fm:true,w:1,p:1};
I.u[2577] = {n:"MuWulf-Skalp",t:15,d:"Bei eurem Erscheinen hatte der MuWulf sicherlich die gleiche Absicht wie ihr. Nämlich euch mehr oder weniger taktvoll euren Skalp zu entfernen. Nun wird er es sein, der sich bei Regen einen Gehirnschnupfen einfängt.",ep:2,g:583,l:198,wd:true,fm:true,w:1,p:1};
I.u[2578] = {n:"WuWulf-Auge",t:109,d:"Selbst mit abgetrenntem Auge bleibt der Blick des WuWulfs auf euch fixiert. Man könnte glatt meinen, er habe ein Auge auf euch geworfen.",ep:1,g:584,l:70,wd:true,fm:true,w:1,p:1};
I.u[2579] = {n:"WullyWuWulf-Auge",t:109,d:"Selbst mit abgetrenntem Auge bleibt der Blick des WullyWuWulfs auf euch fixiert. Man könnte glatt meinen, er würde euch zuzwinkern. Dieses Vieh ist irgendwie nicht totzubekommen.",ep:1,g:585,l:22,wd:true,fm:true,w:1,p:1};
I.u[2580] = {n:"MuWulf-Auge",t:109,d:"Selbst mit abgetrenntem Auge bleibt der Blick des MuWulfs auf euch fixiert. Man könnte glatt meinen, er ziehe die Augenbrauen hoch, wenn ihr mit dem Finger darauf deutet.",ep:2,g:586,l:198,wd:true,fm:true,w:1,p:1};
I.u[2581] = {n:"MuWulf-Zähne",t:47,d:"In der Familie der Wulfs ist es definitiv der MuWulf, der die größten Zahne besitzt. So kann er euch noch eine Weile festklammern und ansabbern, bevor er euch auffrisst.",ep:2,g:587,l:198,wd:true,fm:true,w:1,p:1};
I.u[2582] = {n:"MuWulf-Hoden",t:15,d:"Da die Preise der WuWulf-Hoden bereits skandalös in die Höhe geschossen sind, wisst ihr, dass diese MuWulf-Hoden hier in eurer Hand ihr Gewicht in Gold wert sein müssen.",ep:2,g:588,l:198,wd:true,fm:true,w:20,p:1};
I.u[2583] = {n:"Krebsauge",t:109,d:"Süßwassermatrosen mögen diese leckeren Krebsaugen, da man sie auch auf dem Festland fangen kann.",ep:1,g:589,l:4,wd:true,fm:true,w:1,p:1};
I.u[2584] = {n:"Boos Schlammhand",t:15,d:"Diese Schlammhand von Boo ist extrem schlammig. Man sieht gar nicht, ob unter dem ganzen Schlamm überhaupt noch eine Hand steckt.",ep:2,g:590,l:19,wd:true,fm:true,w:1,p:1};
I.u[2585] = {n:"Lehmherz eines Boos",t:15,d:"Mit seinem Herz aus Lehm ist es für Biologen gar nicht leicht, einem Boo einen Platz in der Nahrungskette zuzuweisen. Er wird wohl ganz am Ende stehen.",ep:2,g:591,l:19,wd:true,fm:true,w:1,p:1};
I.u[2586] = {n:"Flügel eines wilden, roten Dracotruters",t:104,d:"Dieser Flügel riecht nach Schwefel. Doch laut erfahrenen Züchtern ist dies das beste Stück für ein Barbecue. Einfach mit scharfen Gewürzen bestreuen und schon stört der Schwefelgeruch auch nicht mehr.",ep:2,g:592,l:29,wd:true,fm:true,w:1,p:1};
I.u[2587] = {n:"Handbeil des Holzfällers",t:19,d:"Dieses Handbeil ist für den Holzhacker unabdinglich. Nicht, dass es sonderlich nützlich wäre – es lässt sich ja nicht einmal ein Baum damit fällen. Allerdings wirkt bereits sein bloßes Vorhandensein beruhigend.",ep:1,g:6,l:3,wd:true,fm:true,w:10,an:17,e:[5,5,1,1,30,30,false,false],c:"CV>2",p:20};
I.u[2588] = {n:"Dracotruterflügel",t:104,d:"Es ist definitiv wahr, dass das Fleisch gezähmter Dracotruter deutlich besser schmeckt, als das der Wilden. Es ist süßlicher und hat nicht diesen widerlichen Schwefelabgang.",ep:2,g:593,l:29,wd:true,fm:true,w:1,p:1};
I.u[2589] = {n:"Hevlalavs Handaxt",t:19,d:"Mit dieser kleinen Axt lassen sich zwar keine Bäume fällen, jedoch kann man sich gut mit ihr gegen kleine Monster verteidigen. Allerdings sollte man das nicht versuchen, wenn es sich beim kleinen Monster um einen Minotoror handelt.",ep:1,g:7,l:6,wd:true,fm:true,w:10,an:17,e:[10,4,1,1,40,40,false,false],p:60};
I.u[2590] = {n:"Vôr\'Oms Axt",t:19,d:"Diese Axt wurde von einem angehenden Bwork-Schmied hergestellt. Sie ist gut ausgewogen und liegt prima in der Hand. Damit hat dieser Bwork DIE Axt für junge Abenteurer erschaffen.",ep:1,g:13,l:12,wd:true,fm:true,w:15,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>10",p:120};
I.u[2591] = {n:"Schwanz eines wilden, roten Dracotruters",t:65,d:"Was man mit diesem Schwanz macht? Ganz einfach, man legt ihn auf einen runden Felsen und drehe ihn darauf. Man gehe dorthin, wo die Schwanzspitze hinzeigt, bis man einen neuen runden Felsen findet. Auf diese Art und Weise finden sich Sadidas bereits seit Jahrtausenden in den Ewigen Landen zurecht.",ep:2,g:594,l:27,wd:true,fm:true,w:1,p:1};
I.u[2592] = {n:"Bombusschnitter",t:19,d:"Das geringe Gewicht und die gute Griffigkeit dieser Axt vereinfachen spürbar das sichere und problemlose Fällen von Bombussen.",ep:13,g:15,l:39,wd:true,fm:true,w:1,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>20&CW>20",p:390};
I.u[2593] = {n:"Oliviolettas Beschneider",t:19,d:"Diese aus Oliviolettaholz bestehende Axt ist bestens dazu geeignet, den violetten Wellen der Oliviolettas zu widerstehen. Es zeigt sich hier wieder einmal, dass man Feuer mit Feuer bekämpfen muss.",ep:14,g:14,l:42,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>60",p:420};
I.u[2594] = {n:"Dracotruterschwanz",t:65,d:"Seltsamerweise besitzt ein Dracotruterschwanz überhaupt keine magischen Eigenschaften. Dennoch wächst er im Gegensatz zum Crocodyllschwanz sehr schnell wieder nach. Einer Legende nach soll es auch manchmal vorkommen, dass aus dem Schwanz ein vollständiger Dracotruter erwächst. Betrachtet euch hiermit als gewarnt.",ep:2,g:595,l:17,wd:true,fm:true,w:1,p:1};
I.u[2595] = {n:"Steinaxt",t:19,d:"Diese sehr... primitive Axt... ist sehr effektiv, um Dinge zu schlagen, so lange es sich dabei nicht um Holz handelt.",ep:5,g:2,l:51,wd:true,fm:true,w:20,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>50&CV>60",p:510};
I.u[2596] = {n:"Dracotrutermilch",t:15,d:"Züchter schätzen die Tatsache, dass Dracotruter auch Milch geben. Einziger Makel ist dabei, dass diese Milch absolut scheußlich schmeckt. Darum werden damit bloß die kleinen Dracotrüterchen gefüttert, bis sie entwöhnt sind.",ep:2,g:424,l:29,wd:true,fm:true,w:1,p:1};
I.u[2597] = {n:"Breschenschläger",t:19,d:"Diese langstielige Axt findet selbst die kleinsten Zwischenräume im Stamm von Bäumen, um diese dann mit einem Schlag in zwei Teile zu spalten. Dies ist auch sehr praktisch im Kampf. Egal ob Baum oder nicht Baum - eine Bresche kann man immer gebrauchen.",ep:14,g:16,l:54,wd:true,fm:true,w:20,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>70",p:540};
I.u[2598] = {n:"Hornplatten eines wilden, roten Dracotruters",t:47,d:"Diese Hornplatten sind ein knöcherner Auswuchs, der eigentlich zu nichts Nutze ist. Darum konnte man sich lange Jahre lang ihren hohen Abnutzungsgrad nicht erklären. Doch seitdem Biologen Dracotruter dabei beobachtet haben, wie sie sich an Trools rieben, ist dieses Phänomen besser verstanden.",ep:2,g:596,l:29,wd:true,fm:true,w:1,p:1};
I.u[2599] = {n:"Dracotruterschuppe",t:47,d:"Diese auf dem Rücken eines Dracotruters gelegene Schuppe kommt wie gerufen, wenn ihr mal wieder mitten bei einem Ausritt das dringende Bedürfnis verspürt, euch zu kratzen.",ep:2,g:597,l:29,wd:true,fm:true,w:1,p:1};
I.u[2600] = {n:"Rauschende Bartabaxt",t:19,d:"Diese gewaltige Axt verursacht ein lautes Geräusch, wenn sie auf ein Ziel niederfährt. Das hat meist zur Folge, dass die danach einsetzende Stille umso erschreckender wirkt.",ep:14,g:17,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CS>30&CV>30&CA>30",p:660};
I.u[2601] = {n:"Darssons Axt",t:19,d:"Darsson war ein tapferer Enutrof-Streiter, der allerdings zwei linke Hände hatte. So ließ er ständig seine Schaufel im Kampf fallen. Eines Tages kam er auf die Idee, eine Ersatz-Axt an seinem Gürtel zu befestigen. Diese hat ihm oftmals das Leben gerettet, jedenfalls solange, bis er eines Tages auch sie im Kampf fallen ließ...",ep:14,g:18,l:57,wd:true,fm:true,w:15,an:17,e:[12,4,1,1,30,30,false,false],c:"CC>20&CA>20&CV>20",p:570};
I.u[2602] = {n:"Klebabbblütenblatt",t:35,d:"Ein Klebabbblütenblatt ist nicht größer als ein Krebsauge. Es besteht üblicherweise aus mehreren klebrigen Bläschen, die sich schwammig anfühlen. Man verwendet es gern, um nach einem harten Winter die Löcher in den Dächern abzudichten.",ep:12,g:598,l:12,wd:true,fm:true,w:1,p:1};
I.u[2603] = {n:"Größter gemeinster Arme-Teiler",t:19,d:"Diese Axt ist sehr praktisch, um widerspenstige Teile von Bäumen abzuschneiden. Besonders die kleinen Geschwülste des Stammes lassen sich leicht entfernen, wenn man einen vollkommen glatten und runden Baumstamm erhalten will.",ep:13,g:2,l:66,wd:true,fm:true,w:22,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CS>30",p:660};
I.u[2604] = {n:"Bart-Axt des Milizionärs",t:19,d:"Diese Bart-Axt wird hauptsächlich von den Milizverbänden Amaknas eingesetzt. Ihre Länge und Wirksamkeit soll vermutlich Schwächen in anderen Bereichen kompensieren.",ep:13,g:3,l:78,wd:true,fm:true,w:30,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>30&CS>30&CW>30&CC>5",p:780};
I.u[2605] = {n:"Klebabbhaut",t:59,d:"Wundert euch nicht, wenn man euch zeigt, dass Klebabbhaut klebt. Mit ihr kann man selbst Dinge an die Decke kleben. Kein Wunder, dass dieses Zeug patentiert wurde. Von einem Bauern namens Uh Hu.",ep:12,g:599,l:12,wd:true,fm:true,w:1,p:1};
I.u[2606] = {n:"Axt des Erfinders",t:19,d:"Viele Inschriften mit dem gesammelten Grundwissen, das ein jeder Amaknianer haben sollte, wurden in diese Axt eingeritzt. Der Erfinder Hansi Klaus Pedi wollte nämlich allen Schlägertypen mit seiner Axt ein wenig Kultur einbläuen... Leider verlorene Liebesmüh. Einer von ihnen schlug ihm irgendwann mit ihr den Schädel ein. Das war nicht ganz im Sinne des Erfinders.",ep:4,g:4,l:81,wd:true,fm:true,w:30,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>50&CA>50&CI>50",p:810};
I.u[2607] = {n:"Totes Klebabb",t:15,d:"Ihr hattet vollkommen Recht, ihn aufzuheben. Euer Gegner ist unversehrt. Zwar tot, aber noch völlig unversehrt.",ep:12,g:600,l:14,wd:true,fm:true,w:10,p:1};
I.u[2608] = {n:"Grob-Axt der Straßenjungen",t:19,d:"Diese Axt pflegt öfters um die Welt zu reisen, wobei sie meist ganz unten anfängt. Das liegt wohl daran, dass sie tief im Süden Amaknas von einer kleinen, aber dafür sehr erfolgreichen Gruppe von Schatzsuchern geschmiedet wird.",ep:18,g:1,l:84,wd:true,fm:true,w:18,an:17,e:[10,4,1,1,40,40,false,false],c:"CV>100&CS>50",p:840};
I.u[2609] = {n:"Leerer grüner Schildkrötenpanzer",t:107,d:"Wo steckt bloß der Eigentümer dieses Panzers? Er ist wohl aus, ein paar Einkäufe machen.",ep:7,g:601,l:24,wd:true,fm:true,w:2,p:1};
I.u[2610] = {n:"Leerer roter Schildkrötenpanzer",t:107,d:"Wo steckt bloß der Eigentümer dieses Panzers? Er ist wohl schon ausgezogen.",ep:7,g:602,l:24,wd:true,fm:true,w:2,p:1};
I.u[2611] = {n:"Leerer gelber Schildkrötenpanzer",t:107,d:"Wo steckt bloß der Eigentümer dieses Panzers? Vielleicht macht er gerade ein Nickerchen da drinnen.",ep:7,g:603,l:24,wd:true,fm:true,w:2,p:1};
I.u[2612] = {n:"Großfisch-Kuse",t:19,d:"Diese langstielige Axt wird gerne von erfahrenen Seeleuten genutzt, um gewaltige Fische zu bekämpfen, die ihr Schiff angreifen. Da kann man sich bestimmt leicht vorstellen, was diese Axt für Schaden bei kleineren Monstern anrichten wird...",ep:14,g:4,l:87,wd:true,fm:true,w:32,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>50&CA>50",p:870};
I.u[2613] = {n:"Leerer blauer Schildkrötenpanzer",t:107,d:"Wo steckt bloß der Eigentümer dieses Panzers? Er wird wohl gerade unter der Dusche sein.",ep:7,g:604,l:24,wd:true,fm:true,w:2,p:1};
I.u[2614] = {n:"Axt von Prinzessin Denhals",t:19,d:"Prinzessin Denhals war eine bildhübsche junge Prinzessin, die Frische und Liebreiz ausstrahlte. Daher kam man aus dem Staunen nicht mehr heraus, als sie bei einem Bworkangriff auf ihre Heimatstadt ihre Axt zog und ganz allein die Hälfte der gegnerischen Armee damit niedermetzelte.",ep:18,g:5,l:90,wd:true,fm:true,w:28,an:17,tw:true,e:[10,4,1,1,40,40,false,false],c:"CV>150&CW>50&CS>250",p:900};
I.u[2615] = {n:"Lookabeer Axt",t:19,d:"Diese Axt ist dafür bekannt, sehr schnell und radikal jegliche Streitereien zwischen betrunkenen Enutrofs zu beenden.",ep:18,g:8,l:96,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,40,false,false],c:"CV>120",p:960};
I.u[2616] = {n:"Hallenbade des Blutes",t:19,d:"Diese Axt erhielt ihren Namen aufgrund ihrer Wirksamkeit im Laufe eines brutalen Einweihungstestes: ein Mythophobiker wurde zusammen mit dieser großen Axt in eine Halle voller Barden gesteckt.",ep:14,g:7,l:99,wd:true,fm:true,w:40,an:17,e:[15,5,1,1,40,40,false,false],c:"CV>100&CS>100",p:990};
I.u[2617] = {n:"Kokosnoss-Scheibe",t:15,d:"Ha! Endlich etwas, was euch an einen echten Urlaub erinnert! Man kann nicht gerade sagen, der Reiseagentur sei dank!",ep:12,g:605,l:14,wd:true,fm:true,w:1,p:1};
I.u[2618] = {n:"Kokos-Strohhalm",t:15,d:"Es gibt nichts Besseres für das genüßliche Schlürfen von Cocktails, als einen gefärbten Kokos-Strohhalm. Jetzt braucht man nur noch eine Kokosnoss mit Loch drin.",ep:12,g:433,l:14,wd:true,fm:true,w:1,p:1};
I.u[2619] = {n:"Kokosmilch",t:15,d:"Welch tolle Idee! Nun gibt es Kokosmilch auch in Flaschen. So kann man sie zu jeder Zeit und an jedem beliebigen Ort in Ruhe trinken.",ep:12,g:423,l:14,wd:true,fm:true,w:1,p:1};
I.u[2620] = {n:"Qualitäts-Rum",t:15,d:"Dieser Rum stammt aus einem renommierten Keller. Es kann natürlich auch sein, dass er seit mehreren Generationen in einer Jackentasche geschlummert hat.",ep:12,g:177,l:94,wd:true,fm:true,w:1,p:1};
I.u[2621] = {n:"Bart von Le Tschuck",t:15,d:"Nun haltet ihr den Bart von Le Tschuck in den Händen. Doch beim Abschneiden sind auch die Zähne herausgefallen. Bei Zombies ist es auch so, dass sie ständig Teile verlieren.",ep:12,g:606,l:94,wd:true,fm:true,w:1,p:1};
I.u[2622] = {n:"Le Tschucks Gürtelschnalle",t:15,d:"7 Generationen von erfolgreichen Piratenkapitänen trugen diese Gürtelschnalle schon mit Stolz, bevor sie in eure Hände fiel. Und nun?",ep:12,g:607,l:94,wd:true,fm:true,w:2,p:1};
I.u[2623] = {n:"Skelett-Bwack",t:15,d:"Züchter gingen bisher immer davon aus, das Bwacks am Ende ihres Lebens einfach weit davonfliegen. Doch dieses Exemplar scheint eine Ausnahme zu sein.",ep:12,g:608,l:94,wd:true,fm:true,w:1,p:1};
I.u[2624] = {n:"Kokokoblatt",t:36,d:"Selbst erfahrene Jäger wollen um jeden Preis viele Kokokosblätter sammeln, um dann niemals wieder die Füße auf diese verfluchte Insel setzen zu müssen. Warum auch nicht?",ep:12,g:609,l:42,wd:true,fm:true,w:1,p:1};
I.u[2625] = {n:"Thomas kaniballische Wuddupuppe",t:15,d:"Eine seltsame Kraft geht von dieser Puppe aus. Als würde sie jemanden rufen.",ep:12,g:610,l:51,wd:true,fm:true,w:2,p:1};
I.u[2626] = {n:"Jaffs kaniballische Wuddupuppe",t:15,d:"Eine seltsame Kraft geht von dieser Puppe aus. Als würde sie jemanden rufen.",ep:12,g:611,l:51,wd:true,fm:true,w:2,p:1};
I.u[2627] = {n:"Sarbaks kaniballische Wuddupuppe",t:15,d:"Eine seltsame Kraft geht von dieser Puppe aus. Als würde sie jemanden rufen.",ep:12,g:612,l:51,wd:true,fm:true,w:2,p:1};
I.u[2628] = {n:"Archibalds kaniballische Wuddupuppe",t:15,d:"Eine seltsame Kraft geht von dieser Puppe aus. Als würde sie jemanden rufen.",ep:12,g:613,l:51,wd:true,fm:true,w:2,p:1};
I.u[2629] = {n:"Caramantellus Minotoris",t:17,d:"Dieser fürstliche Mantel bietet seinem Träger einen unglaublich guten Schutz. Genau dieses Modell bescherte der berühmten Schneiderin dieses Meisterwerkes großen Ruhm, bevor sie im Ansturm der Massen unterging und nie wieder gesehen ward.",ep:13,g:55,l:121,wd:true,fm:true,w:10,p:38500};
I.u[2630] = {n:"Omnischlundtopf",t:15,d:"Ohne Übertreibung kann man sagen, dass ein Omnischlund nicht gerade sehr freigiebig ist. Doch dieser Topf ist randvoll gefüllt. Ihr seid ein echter Glückspilz. Jetzt muss nur noch ein passender Verwendungszweck dafür gefunden werden.",ep:12,g:614,l:44,wd:true,fm:true,w:1,p:1};
I.u[2631] = {n:"Omnischlund-Magen",t:15,d:"Dieser Magen ist noch dehnbarer, als ihr euch vorstellen könnt. Er lässt sich ganz nach Bedarf ausstülpen, so dass selbst ihr ganz hineinpassen würdet. Ein tolles Versteck, also.",ep:12,g:615,l:44,wd:true,fm:true,w:1,p:1};
I.u[2632] = {n:"Omni-Rum",t:15,d:"Diese Buddel Rum wurde im Inneren eines Omnischlunds zurückgelassen. Welch eine Verschwendung. Jedoch scheint er dort noch an Aroma dazugewonnen zu haben. Wenn das die Winzer wüssten...",ep:12,g:177,l:44,wd:true,fm:true,w:1,p:1};
I.u[2633] = {n:"Heimtückischer Rum",t:15,d:"Vorsicht Falle! Der Heckenschützer ist dermaßen heimtückisch, dass er eine leere Flasche Rum mit... ja, es ist wirklich wahr! Mit echten Rum gefüllt hat! Doch gibt es da noch einen unverwechselbaren Geruch: getrockneten Klebabb.",ep:12,g:177,l:24,wd:true,fm:true,w:1,p:1};
I.u[2634] = {n:"Gebrochene Lanze",t:15,d:"Ohne seine Lanze wird der Heckenschützer sein Maul bestimmt nicht mehr so weit aufreißen. Bloß was wollt ihr jetzt mit diesem Schrott anfangen?",ep:12,g:616,l:24,wd:true,fm:true,w:2,p:1};
I.u[2635] = {n:"Gaitzbrötchen",t:33,d:"Das Rezept dieses Brotes wurde von Darniell Garniell entwickelt, einem Rivalen von Xaver, dem Bäcker. Sein Name war derart blödsinnig, dass sich seine Kunden ständig über ihn lustig machten. Er rächte sich dann, indem er den Teig mit seinen ungewaschenen Füßen knetete.",ep:1,g:13,l:80,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2636] = {n:"Beflügelndes Brot",t:33,d:"Dieses Brot enthält scheinbar leckeres Geflügelfleisch. Doch Vorsicht: das ist bloß eine Täuschung. In Wirklichkeit handelt es sich um Tofufleisch, wie man eindeutig am Geruch feststellen kann.",ep:1,g:13,l:100,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[2637] = {n:"Die Klaue",t:6,d:"Diese gekrümmte Klinge aus Knochen, Horn und Knorpel ist so scharf wie die Kralle eines Ecaflips. Nun, ein wenig größer vielleicht. Und sauberer.",ep:13,g:33,l:35,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,30,50,false,false],c:"CV>10&CS>10&CA>10",p:3500};
I.u[2638] = {n:"Die geschärfte Klaue",t:6,d:"Aus 100% natürlichen Rohstoffen gemacht, liegt dieser Krummsäbel wie eine sechste Kralle in der Hand eines Ecaflips. Doch Vorsicht: passt gut auf, dass ihr euch nicht an eurem Schnäuzchen kratzt.",ep:14,g:34,l:68,wd:true,fm:true,w:12,an:14,e:[12,4,1,1,30,50,false,false],c:"CV>30&CA>30&CS>30",p:6800};
I.u[2639] = {n:"Falsche Klaue von Ceangal",t:6,d:"Eine Ecaflip-Schmiedin kam auf die Idee diesen Krummsäbel zu schmieden, nachdem sie mehrfach dabei versagt hatte, die alte und mächtige Zaubertechnik mit dem selben Namen zu meistern. Sie sagte sich wohl, dass ihr die falsche Klaue wenigstens nicht durch die Lappen gehen würde.",ep:14,g:35,l:95,wd:true,fm:true,w:10,an:14,tw:true,e:[10,4,1,1,40,50,false,false],c:"CV>50&CA>50&CS>50",p:9500};
I.u[2640] = {n:"Fleischsteckender Fressen",t:4,d:"Dieser wunderlich geschnitzte Stecken stammt ganz klar nicht aus der Gegend. Er stinkt vielmehr nach dem fauligen Geruch der dunklen und feuchten Orte im tiefsten Brâkmar.",ep:1,g:24,l:30,wd:true,fm:true,w:56,an:12,e:[3,5,1,1,20,50,false,false],s:7,p:1000};
I.u[2641] = {n:"Toady",t:16,d:"Dieser rot-weiß und vor allem absolut stylische Hut wird immer zu eurem Wohlbehagen in allen gesellschaftlichen Belängen beitragen, selbst bei lästigen Staatsempfängen.",ep:1,g:51,l:30,wd:true,fm:true,w:10,s:7,p:2700};
I.u[2642] = {n:"Ripps Kiefer",t:47,d:"Ripp ist ja bereits spindeldürr. Wenn man ihm jetzt auch noch seinen Kiefer entfernt, so wird er wohl so ungefährlich, wie eine Armee voller Flöhe im Winterschlaf.",ep:3,g:617,l:33,wd:true,fm:true,w:1,p:1};
I.u[2643] = {n:"Schweinedrachen-Hauer",t:47,d:"Diese Hauer gehörten einst dem berühmtesten Raubtier Amaknas, welches hoch oben im Gebirge lebte: dem Schweinedrachen. Viele Jäger wären bereit, ihr Leben zu geben, um diese Hauer zu besitzen, sagt man. Eine günstige Gelegenheit, für wenig Geld eine große Familie zu erwerben!",ep:2,g:618,l:70,wd:true,fm:true,w:1,p:1};
I.u[2644] = {n:"Schweinedrachen-Schwanz",t:65,d:"Welch ein Genuss solch ein Schweinedrachenschwanz doch ist. In einer Pfanne mit etwas Sesamöl angebraten und mit einer leckeren Sauce versehen, ist dies ein Essen, welches eure Gäste so schnell nicht mehr vergessen werden.",ep:2,g:619,l:70,wd:true,fm:true,w:1,p:1};
I.u[2645] = {n:"Schweinedrachen-Rüssel",t:15,d:"Angesichts dieses Rüssels ist klar, warum der Schweinedrachen euren Schlag gar nicht kommen sah. Tja, Pech für ihn!",ep:2,g:620,l:70,wd:true,fm:true,w:1,p:1};
I.u[2646] = {n:"Lederschlüpfer des Ferkelchens",t:56,d:"Dieser weite Lederschlüpfer ist eine Freude für ein jedes Ferkelchen. Die Nähte sind elastisch und doch extrem haltbar. Ideal für eine noch größere Beweglichkeit im Nahkampf! Die Tradition sieht vor, dass dieser Schlüpfer niemals gewaschen wird, da er sonst alle ihm innewohnenden, bisher unbekannten und doch gefürchteten Eigenschaften verlieren würde.",ep:1,g:621,l:20,wd:true,fm:true,w:1,p:1};
I.u[2647] = {n:"Ohr eines Ferkelchens",t:106,d:"Ferkelchen werden meist nicht wegen ihrer schönen Ohren, sondern eher wegen ihrer Hauer gejagt. Doch da dieses Exemplar hier seine Hauer bereits verloren hatte...",ep:1,g:623,l:20,wd:true,fm:true,w:1,p:1};
I.u[2648] = {n:"Kwack-Krallen",t:15,d:"Kwacks sind keine Aasfresser. Dennoch besitzen sie seltsame Ablagerungen unter ihren Krallen... Man sollte sie wohl besser nicht zu genau untersuchen.",ep:1,g:624,l:30,wd:true,fm:true,w:1,p:1};
I.u[2649] = {n:"Wurmus Terribilis",t:15,d:"Dieser Wurm gehört zu den Lieblingsspeisen der wilden Kwacks. Das Seltsame ist, dass dieses Exemplar noch lebt, obwohl es aus dem Magen eines Kwacks kommt.",ep:5,g:625,l:30,wd:true,fm:true,w:1,p:1};
I.u[2650] = {n:"Wurmus Aquaticus",t:15,d:"Dieser Wurm gehört zu den Lieblingsspeisen der wilden Kwacks. Das Seltsame ist, dass dieses Exemplar noch lebt, obwohl es aus dem Magen eines Kwacks kommt.",ep:1,g:626,l:30,wd:true,fm:true,w:1,p:1};
I.u[2651] = {n:"Wurmus Feurikuss",t:15,d:"Dieser Wurm gehört zu den Lieblingsspeisen der wilden Kwacks. Das Seltsame ist, dass dieses Exemplar noch lebt, obwohl es aus dem Magen eines Kwacks kommt.",ep:5,g:627,l:30,wd:true,fm:true,w:1,p:1};
I.u[2652] = {n:"Wurmus Luftikus",t:15,d:"Dieser Wurm gehört zu den Lieblingsspeisen der wilden Kwacks. Das Seltsame ist, dass dieses Exemplar noch lebt, obwohl es aus dem Magen eines Kwacks kommt.",ep:5,g:628,l:30,wd:true,fm:true,w:1,p:1};
I.u[2653] = {n:"Tote Arachnea Majora",t:15,d:"Ihr hattet vollkommen Recht, sie aufzuheben. Eure Gegnerin ist unversehrt. Zwar tot, aber noch völlig unversehrt.",ep:1,g:629,l:43,wd:true,fm:true,w:10,p:1};
I.u[2654] = {n:"Eier einer Arachnea Majora",t:105,d:"Das Problem mit Arachneen ist ihre rasante Vermehrungsrate. Es braucht nur wenige heiße Sommertage, damit gleich mehrere Generationen in Folge schlüpfen. Darum gilt: im Sommer Füße weg vom Wald der Astaknyden!",ep:1,g:630,l:43,wd:true,fm:true,w:1,p:1};
I.u[2655] = {n:"Rabschürzling",t:10,d:"Dieser Gürtel wurde aus den Überresten Meister Rabs gefertigt, die sorgsam wieder vernäht wurden. Damit werdet ihr mit Sicherheit eine Respektsperson. Le Tschuck persönlich hat euch zu diesem Anlaß seine Gürtelschnalle geliehen.",ep:13,g:56,l:120,wd:true,fm:true,w:10,p:36938};
I.u[2656] = {n:"Unzerreißbarer Faden",t:15,d:"Wenn Schuhmacher und Schneider wüssten, dass es unzerreißbare Fäden gibt, dann gäbe es bereits die Woche des unzerreißbaren Fadens, das Fest des unzerreißbaren Fadens und den Feiertag des unzerreißbaren Fadens!",ep:1,g:631,l:43,wd:true,fm:true,w:1,p:1};
I.u[2659] = {n:"Blütenblatt einer wilden Sonnenblume",t:35,d:"Diese Blüte bewegt sich. Ja, sie richtet sich tatsächlich nach der Sonne. Probiert es einfach aus. Legt sie morgens in eure rechte Hosentasche und ihr werdet sie abends in der Linken wiederfinden.",ep:1,g:632,l:12,wd:true,fm:true,w:1,p:1};
I.u[2661] = {n:"Wildes Sonnenblumenblatt",t:36,d:"Dieser Teil der wilden Sonnenblume ist nicht nur ein Blatt der Pflanze, sondern auch gleichzeitig seine Fußsohle. Wundert euch also nicht über den strengen Käsefußgeruch.",ep:1,g:633,l:12,wd:true,fm:true,w:1,p:1};
I.u[2662] = {n:"Dämonenrosenspeichel",t:15,d:"Die Dämonenrose hat die schlechte Angewohnheit, alles und jeden in ihrer Reichweite mit ihrem Speichel vollzusabbern. Doch soll dies angeblich ein Zeichen von Zuneigung sein. Darum ein Rat: wenn sie sich euch voll zuneigt, dann springt besser schnell aus dem Weg.",ep:1,g:634,l:8,wd:true,fm:true,w:1,p:1};
I.u[2663] = {n:"Dünger",t:15,d:"Jede hübsche Pflanze braucht Dünger. Nur manche Enutröffchen hohen Alters können darauf verzichten.",ep:1,g:635,l:8,wd:true,fm:true,w:1,p:1};
I.u[2664] = {n:"Crocodyll-Knochen",t:47,d:"Dieser grünliche Knochen ist seltsam. Das ist das Mindeste, was man darüber sagen kann. Außerdem stammt er wohl von der Pfote eines Crocodylls. Dieses muss wahre Tränen vergossen haben, als es den Verlust bemerkte!",ep:4,g:636,l:36,wd:true,fm:true,w:2,p:100};
I.u[2665] = {n:"Wuchernde Gräser",t:36,d:"Diese Art von Gräsern findet man oft auf Fresssack-Koppeln. Sein Name kommt daher, dass es von Zeit zu Zeit beschließt, wild zu wuchern und manchmal über diesen Weg sogar die Koppel verlässt, um wo anders weiterzuwachsen.",ep:1,g:637,l:9,wd:true,fm:true,w:1,p:1};
I.u[2666] = {n:"Minotororhuf",t:47,d:"Dieser Huf hat sicherlich bereits mehr als einen Abenteurer erschlagen. Doch nun wird der Minotoror hoffentlich weniger den großen Macker spielen, so auf einem Huf herumtänzelnd. Wobei... Einarmige Banditen sind auch gefürchteter als welche mit zwei Armen!",ep:2,g:800,l:125,wd:true,fm:true,w:1,p:1};
I.u[2667] = {n:"Minotoror-Schwanz",t:65,d:"Es ist ein wahres Wunder, den Schwanz eines Minotorors zu sehen, ohne dass der restliche Minotoror dranhängt. Der Ärmste... Sicherlich sucht er den Schwanz nun überall. Es sei denn er hat den Verlust noch gar nicht bemerkt, was natürlich auch möglich wäre.",ep:2,g:640,l:125,wd:true,fm:true,w:1,p:1};
I.u[2669] = {n:"Fledermaus",t:15,d:"Manchmal verwandeln sich Vampire in Fledermäuse, um besser entkommen zu können. Meist lassen sie vorher noch eine Art dämonisches Gelächter hören. \"Muaharharhar!\" Allein damit können sie ganze Armeen in die Flucht schlagen... von Flöhen.",ep:3,g:641,l:21,wd:true,fm:true,w:1,p:1};
I.u[2673] = {n:"Verfaultes Ei",t:105,d:"Eine Schande ist das! Wie kann man nur ein solch heruntergekommenes Tofu-Ei bebrüten. Man muss wirklich völlig verdorben sein, um so etwas zu tun.",ep:1,g:642,l:3,wd:true,fm:true,w:1,p:1};
I.u[2674] = {n:"Kürbisschen",t:46,d:"Dieses Kürbisschen ist genau richtig. Lecker im Geschmack und nicht zu groß, so dass sie sich nicht in einen Küwbis verwandeln wird.",ep:4,g:643,l:15,wd:true,fm:true,w:1,p:1};
I.u[2675] = {n:"Schattentofu-Feder",t:53,d:"Der Schattentofu hat kaum noch Federn. Daher riskiert er es, sich eine gepflegte Erkältung einzufangen. Also, wundert euch nicht, wenn ihr ihn nachts husten hört.",ep:1,g:644,l:3,wd:true,fm:true,w:1,p:1};
I.u[2676] = {n:"Totes Eynaug",t:15,d:"Ihr hattet vollkommen Recht, ihn aufzuheben. Euer Gegner ist unversehrt. Zwar tot, aber noch völlig unversehrt.",ep:4,g:645,l:274,wd:true,fm:true,w:10,p:1};
I.u[2677] = {n:"Tschuckschürz",t:10,d:"Dieser Gürtel wurde aus den mächtigsten Teilen von Le Tschuck gebastelt, allem voran aus seinem Schlüpfer. Es gibt nichts Wirksameres, um unter den weiblichen Freibeutern für etwas Aufregung zu sorgen.",ep:12,g:41,l:98,wd:true,fm:true,w:10,p:25000};
I.u[2678] = {n:"Kokoketter Gürtel",t:10,d:"Dieser Gürtel ähnelt mehr einem Lendenschurz, als einem herkömmlichen Gürtel. Einfach perfekt, wenn ihr euch hinter den Kokokos von Moons Insel verstecken wollt, oder euch heimlich an eine solche heranzumachen gedenkt.",ep:12,g:40,l:42,wd:true,fm:true,w:10,p:4800};
I.u[2681] = {n:"Gürtel der gelben Schildkröte",t:10,d:"Dieser kleine Gürtel ist einfach ideal, um eure wichtigsten Körperteile vor kritischen Treffern zu schützen. Achtet allerdings vor dem Anprobieren immer darauf, dass der Schuster auch wirklich den Vorbesitzer dieses Panzers entfernt hat.",ep:7,g:43,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2683] = {n:"Gürtel der blauen Schildkröte",t:10,d:"Dieser kleine Gürtel ist einfach ideal, um eure wichtigsten Körperteile vor kritischen Treffern zu schützen. Achtet allerdings vor dem Anprobieren immer darauf, dass der Schuster auch wirklich den Vorbesitzer dieses Panzers entfernt hat.",ep:7,g:44,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2685] = {n:"Gürtel der grünen Schildkröte",t:10,d:"Dieser kleine Gürtel ist einfach ideal, um eure wichtigsten Körperteile vor kritischen Treffern zu schützen. Achtet allerdings vor dem Anprobieren immer darauf, dass der Schuster auch wirklich den Vorbesitzer dieses Panzers entfernt hat.",ep:7,g:42,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2687] = {n:"Gürtel der roten Schildkröte",t:10,d:"Dieser kleine Gürtel ist einfach ideal, um eure wichtigsten Körperteile vor kritischen Treffern zu schützen. Achtet allerdings vor dem Anprobieren immer darauf, dass der Schuster auch wirklich den Vorbesitzer dieses Panzers entfernt hat.",ep:7,g:45,l:60,wd:true,fm:true,w:10,p:10000};
I.u[2688] = {n:"Kleblingsgürtel",t:10,d:"Man kann wirklich sagen: wer diesen Gürtel erst einmal anprobiert hat, der gibt ihn nie wieder her. Das ist dann nämlich auch gar nicht mehr möglich. Somit ist der Gürtel ein Segen für alle zerstreuten Professoren und Lieblingsopfer von Taschendieben.",ep:12,g:46,l:50,wd:true,fm:true,w:10,p:6600};
I.u[2689] = {n:"Lendenschurz \"Bannisierung, grün\"",t:10,d:"Der Schuster, der diesen Gürtel aus den Resten von Dracotrutern angefertigt hat, dürfte keinerlei Phantasie gehabt haben was die Namensgebung angeht.",ep:2,g:47,l:29,wd:true,fm:true,w:10,p:2400};
I.u[2710] = {n:"Lendenschurz \"Bannisierung, wild\"",t:10,d:"Diese verbesserte und vor allem stahlverstärkte Version des klassischen Lendenschurzes \"Bannisierung, grün\" wurde speziell für die Jagd nach äußerst scheuen und wilden Dragetrutern in schlecht zugänglichen Gebieten entworfen.",ep:2,g:48,l:32,wd:true,fm:true,w:10,p:3000};
