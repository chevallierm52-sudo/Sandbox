I.u[2803] = {n:"Taschenkrebs-Gürtel",t:10,d:"Dieser seltsame Gürtel besteht vollständig aus den Zangen und Panzern von Krebsen. Das sieht zwar toll aus und macht ihn sehr kleidsam, jedoch lässt sich der charakteristische Geruch selbst mit der mächtigsten Magie nicht ganz vertreiben. Also nicht wundern, wenn Freund und Feind lieber auf Abstand bleiben.",ep:1,g:49,l:8,wd:true,fm:true,w:2,p:400};
I.u[2804] = {n:"WuWulfs-Gürtel",t:10,d:"Der berüchtigte WuWulf hat seine wertvollsten Organe für diesen mächtigen Gürtel gespendet, der trotz seines heruntergekommenen Aussehens noch genug Magie ausstrahlt, um den perversesten aller Chafer zu beleben.",ep:2,g:50,l:81,wd:true,fm:true,w:10,p:16800};
I.u[2805] = {n:"Magische WuWulf-Hoden",t:15,d:"Niemand weiß genau, wann und wo es geschah, doch wurden eines Tages diese Hoden von dunkler Schattenmagie erfüllt.",ep:1,g:650,l:80,wd:true,fm:true,w:20,p:1000};
I.u[2806] = {n:"Magische MuWulf-Hoden",t:15,d:"Diesen mächtigen Hoden wohnen magische Kräfte inne. Niemand hat bisher herausgefunden, wozu sie genau dienten. Doch ist es manchmal auch besser, nicht alles zu wissen.",ep:2,g:651,l:198,wd:true,fm:true,w:10,p:2000};
I.u[2807] = {n:"MuWu-Gürtel",t:10,d:"Der Schuster Bowisse hat diesen Gürtel höchstpersönlich angefertigt und anschließend seinem Freund Bruce Boulgour geschenkt, als es diesem gelang, mit bloßen Händen Weich-Eich zu entwurzeln.",ep:2,g:51,l:129,wd:true,fm:true,w:20,p:50000};
I.u[2808] = {n:"Schweinischer Drachengürtel",t:10,d:"Dieser Gürtel wird euch einfach unwiderstehlich machen. Bowisse empfiehlt allerdings allen seinen Trägern, mit diesem Gürtel niemals echten Schweinedrachen zu nahe zu kommen, da dies einige ihrer urigsten Instinkte auslösen könnte.",ep:2,g:52,l:77,wd:true,fm:true,w:20,s:58,p:16000};
I.u[2809] = {n:"Chafer-Gürtel",t:10,d:"Hinter diesem groteskem Namen verbirgt sich eine wunderschöne Kreation des Schusters Bowisse. Eines Tages sammelte dieser nämlich bei seinem täglichen Spaziergang im Skelett-Dungeon die Reste seiner Gegner ein und erschuf daraus dieses Prachtstück.",ep:3,g:53,l:49,wd:true,fm:true,w:10,p:6500};
I.u[2810] = {n:"Gürtel von Evis Sohn",t:10,d:"Dieser wunderschöne rötliche Gürtel soll euch angeblich magisch helfen, euch besser zu konzentrieren und schneller zu lernen. Das macht ihn zum Traum aller Faulpelze Amaknas.",ep:1,g:54,l:26,wd:true,fm:true,w:6,p:2000};
I.u[2811] = {n:"Ouginakischer Gürtel",t:10,d:"Dieser Gürtel ist speziell für ganz wagemutige Abenteurer angefertigt worden. Denn damit soll man sich angeblich gefahrlos den Ouginaks nähern können. Doch wurde das bisher noch nie nachgewiesen.",ep:14,g:55,l:65,wd:true,fm:true,w:10,p:11000};
