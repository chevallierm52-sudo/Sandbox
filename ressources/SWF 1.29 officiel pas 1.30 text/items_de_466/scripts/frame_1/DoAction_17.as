I.u[8243] = {n:"Hut des roten Piepmatzes",t:16,d:"Mit diesem Hut auf dem Kopf werdet ihr zwar lächerlich, aber auch gleichzeitig unwiderstehlich aussehen. Tja, eine wahrhaft schwierige Wahl...",ep:1,g:137,l:1,wd:true,fm:true,w:1,s:60,p:1};
