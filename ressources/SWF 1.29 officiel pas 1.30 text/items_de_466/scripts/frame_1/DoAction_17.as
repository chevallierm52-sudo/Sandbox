I.u[7753] = {n:"Das Staöfchen",t:3,d:"Dieser Stab soll direkt aus den heißesten Tiefen der Erde hervorgekommen sein. Daher Vorsicht an alle, die ihn einsetzen wollen. Ohne entsprechenden Schutz riskiert ihr einen schmerzhaften Rückschlag!",ep:1,g:131,l:229,wd:false,fm:true,w:15,an:11,e:[10,2,5,5,20,60,false,false],c:"CI>1000&CA>250",p:57000};
I.u[7754] = {n:"Ocker-Dofus",t:23,d:"Dieser Dofus besitzt in konzentrierter Form all die Kräfte von Terrakourial, dem Erddrachen. Er sollte also nicht in fremde Hände fallen. Auf fremde Füße besser auch nicht.",ep:1,g:12,l:6,wd:true,fm:true,w:10,p:50000};
