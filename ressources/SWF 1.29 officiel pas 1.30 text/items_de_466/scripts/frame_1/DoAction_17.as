I.u[8245] = {n:"Violetter Piepmatz-Hut",t:16,d:"Mit diesem kleinen Hütchen auf dem Kopf seid ihr zwar lächerlich, aber gleichzeitig auch faszinierend, weil seltsam. Welche Seite sich da wohl durchsetzen wird?",ep:1,g:139,l:1,wd:true,fm:true,w:1,s:62,p:1};
