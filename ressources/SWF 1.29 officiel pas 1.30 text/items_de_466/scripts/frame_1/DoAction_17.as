I.u[8237] = {n:"Gürtel des roten Piepmatzes",t:10,d:"Dieser kleine Gürtel wird eure Hüften beim nächsten Kampf mit Sicherheit voll zur Geltung bringen. Später kann er dann auch dazu dienen, eure Eingeweide festzuhalten, wenn euch ein aggressiver Keiler der Ebenen den Bauch aufgeschlitzt haben sollte.",ep:1,g:96,l:1,wd:true,fm:true,w:1,s:60,p:1};
