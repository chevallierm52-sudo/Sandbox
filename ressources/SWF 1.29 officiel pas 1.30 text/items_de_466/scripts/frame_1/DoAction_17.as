I.u[7744] = {n:"Streichler mit spitzen Kwackfedern",t:93,d:"Diese phantastische Maschine streichelt alle Reittiere, die sich ihr nähern;\r\n            immer nur mit dem Strich, wohlgemerkt. Das senkt ihre Agressivität und macht sie ruhiger.",ep:5,g:44,l:1,wd:true,fm:true,w:10,ut:true,p:1};
