I.u[8050] = {n:"Haut eines unreifen Koalaks",t:59,d:"Der kleine unreife Koalak war nicht damit einverstanden, euch seine Haut zu überlassen. Doch störte euch das herzlich wenig, da ihr viel grausamer und auch viel stärker seid als er...",ep:20,g:3,l:1,wd:true,fm:true,w:1,p:10};
I.u[8052] = {n:"Meister Koalak-Haut",t:59,d:"Diese alte, mitgenommene Haut bedeckte einst das Hinterteil von Meister Koalak. Auf ihr prangen immer noch ein paar rote Striemen und Spuren – ein Zeichen dafür, dass der alte Meister immer noch ein wildes Leben führte.",ep:20,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[8053] = {n:"Koalakreiter-Fell",t:59,d:"Dieses eingerissene, abgewetzte Fell hat sich bei den vielen Ausritten der vergangenen Jahre ziemlich stark abgenutzt. Ein Qualitätsmerkmal!",ep:20,g:6,l:1,wd:true,fm:true,w:1,p:10};
I.u[8054] = {n:"Dracoalak-Fell",t:59,d:"Dieses Fell erinnert euch an den Geruch der Stallanlagen im Schloss von Amakna. Daneben ist es auch sehr praktisch, um empfindliche Abenteurer in Angst und Schrecken zu versetzen und sie dann diskret beiseite zu schaffen, wenn sie euch wieder einmal unbedingt auf Schritt und Tritt bis in die dunkelsten Dungeons hinein verfolgen.",ep:20,g:7,l:1,wd:true,fm:true,w:1,p:10};
I.u[8055] = {n:"Knochen einer Koalak-Mama",t:47,d:"Eine Koalak-Mama besitzt extrem stabile Knochen. Das ist auch nötig, damit sie ihrem eigenen Gewicht standhalten kann. Doch sollte man ihr besser nicht ins Gesicht sagen, dass sie einen schweren Knochenbau hat...",ep:20,g:638,l:1,wd:true,fm:true,w:1,p:10};
I.u[8056] = {n:"Wilder Koalak-Schienbeinknochen",t:47,d:"Dieser Knochen lässt sich leicht zurechtschnitzen, zum Beispiel zu einem Dolch. Oder einem Furunkelaufstecher.",ep:20,g:639,l:1,wd:true,fm:true,w:1,p:10};
I.u[8057] = {n:"Schienbein des Koalak-Totengräbers",t:47,d:"Dieser praktische Knochen ließe sich notfalls auch als Schaufel einsetzen, um Kadaver auszugraben und auszurauben, wenn ihr eure Ferien mal wieder in der Nähe eines Friedhofes verbringt. Alternativ funktioniert er aber auch als Schienbein eines Koalak-Totengräbers.",ep:20,g:640,l:1,wd:true,fm:true,w:1,p:10};
I.u[8058] = {n:"Ellenbogen der Koalak-Mumie",t:47,d:"Dieser Knochen hat bis heute seine Schönheit bewahrt, nicht zuletzt dank der vielen Bandagenlagen, die ihn selbst vor den mächtigsten magischen Angriffen bewahren. Ein Geschenk der Koalak-Mumie.",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8059] = {n:"Haare eines Kirsch-Koalaks",t:54,d:"Diese Haare sind von Blob-Pollen übersäht, was ihnen zwar einen süßlichen Geschmack, aber dafür auch einen schrecklichen Geruch verleiht.",ep:20,g:660,l:1,wd:true,fm:true,w:1,p:10};
I.u[8060] = {n:"Haare eines Kokos-Koalaks",t:54,d:"Diese Haare sind von Blob-Pollen übersäht, was ihnen zwar einen süßlichen Geschmack, aber dafür auch einen schrecklichen Geruch verleiht.",ep:20,g:662,l:1,wd:true,fm:true,w:1,p:10};
I.u[8061] = {n:"Haare eines Apfel-Koalaks",t:54,d:"Diese Haare sind von Blob-Pollen übersäht, was ihnen zwach einen süßlichen Geschmack, aber dafür auch einen schrecklichen Geruch verleiht.",ep:20,g:661,l:1,wd:true,fm:true,w:1,p:10};
I.u[8062] = {n:"Haare eines Indigo-Koalaks",t:54,d:"Diese Haare sind von Blob-Pollen übersäht, was ihnen zwach einen süßlichen Geschmack, aber dafür auch einen schrecklichen Geruch verleiht.",ep:20,g:659,l:1,wd:true,fm:true,w:1,p:10};
I.u[8063] = {n:"Blutrünstiger Koalak-Schwanz",t:65,d:"Dieser lächerliche kleine Schwanz hätte auch an eurem Körper dran sein können. Also, lacht besser nicht über andere, und schätzt euch glücklich, dass dem nicht so ist.",ep:20,g:641,l:1,wd:true,fm:true,w:1,p:10};
I.u[8064] = {n:"Blutrünstiger Koalak-Boomerang",t:15,d:"Dieses seltsam geformte Stück Holz saust gerne lange durch die Luft. Manchmal durchpflügt es dabei auch die Reihen der Gegner. Doch kehrt es immer zurück zum Werfer. Nur nicht immer in dessen Hand...",ep:20,g:721,l:1,wd:true,fm:true,w:1,p:10};
I.u[8065] = {n:"Barthaare eines braunen Warkos",t:54,d:"Diese Haare sind von Nesselkapselzellen übersäht, wodurch selbst der leichteste Kuss des braunen Warkos einem Angiff mit einer Massenvernichtungswaffe gleichkommt.",ep:20,g:657,l:1,wd:true,fm:true,w:1,p:10};
I.u[8066] = {n:"Barthaare eines violetten Workos",t:54,d:"Diese Barthaare enthalten Nesselkapselzellen, was aus ihnen eine tödliche Waffe macht. Sehr viel tödlicher als euer fauliger Bwork-Atem, übrigens.",ep:20,g:658,l:1,wd:true,fm:true,w:1,p:10};
I.u[8067] = {n:"Stiefel des Champion",t:11,d:"Manche Abenteurer behaupten, ein Champion könne in diesen Stiefeln über sämtliche Falle laufen, ohne sie auszulösen. Doch Vorsicht: dieses Gerücht könnte auch eine Falle sein.",ep:1,g:72,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8068] = {n:"Mantel des Champion",t:17,d:"Dieser schöne Mantel mit intergrierten Schulterpolstern lässt euch wie ein echter Champion aussehen.",ep:1,g:96,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8069] = {n:"Hut des Champion",t:16,d:"Dieser imposante Hut bringt euren Dickkopf so richtig gut zur Geltung.",ep:1,g:127,l:1,wd:false,fm:true,w:100,s:45,p:10};
I.u[8070] = {n:"Gürtel des Champion",t:10,d:"Mit diesem Gürtel um die Hüften könnt ihr alles verstecken, was an euch versteckt werden sollte.",ep:1,g:88,l:1,wd:false,fm:true,w:10,s:45,p:10};
I.u[8071] = {n:"Mini-Champion",t:18,d:"Diese kleine Kreatur folgt nur wahren Champions. Daher kann es gut sein, dass sie euch ein paar Tage lang folgt und dann feststellt, dass ihr nur ein Hochstapler seid. Danach ist es an euch, diesem Vertrauten zu folgen.",ep:1,g:32,l:1,wd:false,fm:true,w:10,c:"PZ=1",s:45,p:1};
I.u[8072] = {n:"Kalyptus-Dofus",t:23,d:"Niemand weiß, welcher Drache diesen Dofus hervorgebracht hat. Es heißt jedoch, er habe kurz vorher eine gewaltige Menge Kalyptusblätter gegessen und sei nach der Eiablage an den fürchterlichen Blähungen elendig krepiert.",ep:1,g:10,l:6,wd:false,fm:true,w:1,p:500000};
I.u[8073] = {n:"Schlüssel zum Unterschlupf des Skeunks",t:84,d:"Dieser Schlüssel wurde euch von Rigoulak im Austausch gegen das Kuhloss-Set gegeben. Mit seiner Hilfe könnt ihr nun den Unterschlupf des Skeunks betreten.",ep:13,g:11,l:1,wd:true,fm:true,w:1,p:100};
I.u[8075] = {n:"Dok Alako-Boomerang",t:15,d:"Dieses seltsam geformte Stück Holz saust gern lange durch die Luft. Manchmal durchpflügt es dabei auch die Reihen der Gegner. Doch kehrt es immer zurück zum Werfer. Nur nicht immer in dessen Hand...",ep:20,g:722,l:1,wd:true,fm:true,w:1,p:10};
I.u[8076] = {n:"Koalak Meister-Boomerang",t:15,d:"Dieses seltsam geformte Stück Holz saust gern lange durch die Luft. Manchmal durchpflügt es dabei auch die Reihen der Gegner. Doch kehrt es immer zurück zum Werfer. Nur nicht immer in dessen Hand...",ep:20,g:723,l:1,wd:true,fm:true,w:1,p:10};
I.u[8077] = {n:"Brauner Warko-Boomerang",t:15,d:"Dieses seltsam geformte Stück Holz saust gern lange durch die Luft. Manchmal durchpflügt es dabei auch die Reihen der Gegner. Doch kehrt es immer zurück zum Werfer. Nur nicht immer in dessen Hand...",ep:20,g:724,l:1,wd:true,fm:true,w:1,p:10};
I.u[8078] = {n:"Brett aus Kalyptusholz",t:95,d:"Aus diesem Brett können Bastlern alle möglichen Dinge erschaffen – wie einen hölzernen Sarg, zum Beispiel.",ep:20,g:22,l:70,wd:true,fm:true,w:10,p:10};
I.u[8079] = {n:"Kleine weiße Maunzmiez-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt. Nur so ist es euch möglich, das Heiligtum der Vertrauten zu betreten.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8080] = {n:"Kleine schwarze SchnuffWuff-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt. Nur so ist es euch möglich, das Heiligtum der Vertrauten zu betreten.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8081] = {n:"Sack voller Hainbuchenholz",t:100,d:"Dieser gewaltige Sack enthält eine große Menge Hainbuchenholz.",ep:1,g:55,l:1,wd:true,fm:true,w:250,u:true,p:100};
I.u[8082] = {n:"Sensalak-Pelz",t:55,d:"An diesem Pelz haftet noch der Gestank des Todes. Ihr allerdings riecht halbverwest. Ein wichtiger Unterschied.",ep:20,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8083] = {n:"Fischeralak-Knochen",t:47,d:"Dieser Knochen ist aufgebaut wie ein Schwamm, weshalb er auch auf dem Wasser schwimmt. Das ist praktisch, sollte der Fischeralak einmal ins Wasser fallen, oder einen großen Fang hochziehen müssen.",ep:20,g:10,l:1,wd:true,fm:true,w:1,p:100};
I.u[8084] = {n:"Piralak-Haut",t:59,d:"Diese Haut voller Schrammen und Schnitte wurde im Laufe der Jahre hart wie Stein, ohne jedoch an Geschmeidigkeit einzubüßen. Das macht sie zum idealen Material für Geißeln oder Sandalen für Leute mit schlechtem Mode-Geschmack.",ep:20,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[8085] = {n:"Haare eines Koalak-Försters",t:54,d:"Diese Haare sind mit Kalyptus-Harz übersäht, was ihnen zwar einen wunderschönen Glanz, aber dafür auch einen schrecklichen Geruch verleiht.",ep:20,g:4,l:1,wd:true,fm:true,w:1,p:100};
I.u[8086] = {n:"Zerfetzter Dracoalakhut",t:15,d:"Dieser seltsame Hut verbarg einst die beginnende Glatze des Dracoalaks. Bald wird er auch die eure kaschieren.",ep:20,g:725,l:1,wd:true,fm:true,w:1,p:100};
I.u[8087] = {n:"Meister der Axt",t:73,d:"(Doppelklick, um diesen Zauberspruch zu lernen.) \nBei Anwendung dieses Spruches werdet ihr beim Kampf mit der Axt erheblich mehr Schaden anrichten.",ep:20,g:8,l:20,wd:false,fm:true,w:1,u:true,p:10000};
I.u[8088] = {n:"Gyver-Stab",t:3,d:"Dieser Stab, der aus allerlei alten Überresten aus dem Speicher der Großmutter angefertigt wurde, enthält große Macht. Es heißt, er könne sogar selbsttätig seinen Meister beschützen und die Gegner angreifen.",ep:20,g:56,l:128,wd:true,fm:true,w:10,an:11,e:[5,5,2,5,40,50,false,true],c:"CI>250",p:41257};
I.u[8089] = {n:"Stoi-Stab",t:3,d:"Stoi war der Name eines Papageis, der stets alles wiederholte, was man ihm sagte. Es heißt, dieser Stab sei aus seinem Schnabel geschnitzt worden!",ep:20,g:57,l:138,wd:true,fm:true,w:20,an:11,tw:true,e:[5,4,3,4,40,50,false,true],c:"CI>150&CA>100&CC>100&CS>100",p:44125};
I.u[8090] = {n:"Stecken der Karibuik",t:4,d:"Nicht zu verwechseln mit den Piraten der Karibuik! Die haben nun wirklich überhaupt nichts damit zu tun.",ep:20,g:64,l:114,wd:true,fm:true,w:10,an:12,tw:true,e:[5,5,1,1,35,50,false,true],c:"CI>200&CA>150",p:33520};
I.u[8091] = {n:"Tua Kwän-Stock",t:4,d:"Dieser Stecken kommt aus dem hohen Norden. Er ist knochig, verdreht, hat einige Macken und hört sich eigenartig an, doch ist er trotzdem sehr beliebt.",ep:20,g:65,l:134,wd:true,fm:true,w:20,an:12,tw:true,e:[20,4,1,1,150,150,false,true],c:"CS>150&CA>150&CI>150",p:43550};
I.u[8092] = {n:"Dolche des Prutalos",t:5,d:"Der Prutalo vertrieb sich seine Zeit mit netten Beschäftigungen, wie zum Beispiel Mädchen an den Haaren zu ziehen oder dem Aufschlitzen von Mitmenschen. Ein Gentleman muss ja auch was im Club zu erzählen haben.",ep:20,g:56,l:135,wd:true,fm:true,w:20,an:13,tw:true,e:[10,3,1,1,30,50,false,true],c:"CS>250&CA>100",p:43510};
I.u[8093] = {n:"Dolche Guevara",t:5,d:"Diese Dolche werden euch noch lange nicht zu einem Helden machen. Doch wenn ihr sie in eurer Unterkleidung aufbewahrt, so können sie euch zu immerhin wie eine Heldin aussehen lassen.",ep:0,g:64,l:58,wd:true,fm:true,w:1,e:[-1,-1,1,1,-1,-1,false,false],p:4253};
I.u[8094] = {n:"Schwert Ödlich",t:6,d:"Ein altes Iop-Sprichwort besagt: Ist der Gegner tot, freut sich das Schwert.",ep:20,g:66,l:169,wd:true,fm:true,w:30,an:14,e:[10,5,1,1,50,50,false,true],c:"CS>450&CV>450",p:49010};
I.u[8095] = {n:"Ayassalama-Säbel",t:6,d:"Dieser Säbel wurde unter rein ästhetischen Aspekten gefertigt, denn er sollte lediglich einen höchst wertvollen Kamin schmücken. Allerdings kam sein früherer Besitzer anlässlich eines Einbruchs auf seinem Anwesen auf den Dreh, ihn zur Verteidigung einzusetzen. Manchen Leuten ist auch gar nichts heilig....",ep:20,g:67,l:143,wd:true,fm:true,w:20,an:14,e:[15,4,1,1,80,50,false,true],c:"CI>300&CS>130&(PG=6|PG=8|PG=11)",p:44587};
I.u[8096] = {n:"Toms Mahok-Hammer",t:7,d:"Der frühere Besitzer pflegte mit den WuWulfs zu tanzen, bis diese ihn schließlich auffraßen.",ep:20,g:56,l:140,wd:true,fm:true,w:20,an:15,e:[5,5,1,1,30,45,false,true],c:"CI>250&CC>250",p:44541};
I.u[8097] = {n:"Liebestöter",t:7,d:"Dieser Hammer lässt einen das Leben wie durch eine rosarote Brille sehen, kurz bevor er einem den Schädel einschlägt.",ep:20,g:57,l:129,wd:true,fm:true,w:30,an:15,e:[5,4,1,1,40,15,false,true],c:"CS>250&CI>150",p:42658};
I.u[8098] = {n:"Errs Klinge",t:19,d:"Diese Axt mit ungewöhnlicher Form verfügt über eine vibrierende Klinge, mit der man seine Gegner musikalisch erledigen kann.",ep:0,g:38,l:1,wd:false,fm:true,w:1,an:17,e:[10,4,1,1,50,50,false,true],p:1};
I.u[8099] = {n:"Axt im Walde",t:19,d:"Angeblich soll diese Waffe in einer Quelle elementarer Blitzstrahlen abgeschreckt und anschließend mit Sternenstaub bestäubt und gehärtet worden sein. Welch ein Unsinn!",ep:20,g:39,l:116,wd:true,fm:true,w:10,an:17,tw:true,e:[7,5,1,1,35,50,false,false],c:"CA>120&CV>150",p:34562};
I.u[8100] = {n:"Ohrop-Axt",t:19,d:"Diese Axt ist bereits ziemlich durchlöchert, wodurch sie merkwürdige Pfeiftöne von sich gibt, sobald sie durch die Luft geschwungen wird. Was allerdings den Vorteil hat, dass man sich die Schreie der Opfer nicht allzu sehr zu Herzen nimmt.",ep:20,g:40,l:112,wd:true,fm:true,w:15,an:17,e:[5,4,1,1,40,50,false,false],c:"CS>150&CW>150",p:30300};
I.u[8101] = {n:"Tischocken-Axt",t:19,d:"Diese Axt hat Bruce Boulgour geschmiedet, als er sich am Backgewerbe versuchen wollte, um seinem Freund Xaver, dem Bäcker eine Freude zu machen. Es sollte eigentlich eine Kuchenschaufel werden...",ep:20,g:41,l:128,wd:true,fm:true,w:1,an:17,e:[5,4,1,1,20,30,false,false],c:"CI>230&CA>60&CV>250",p:444};
I.u[8102] = {n:"Legendäres Mega-Krachlergestein",t:51,d:"Dieser Gesteinsbrocken könnte glatt das Herz des legendären Mega-Krachlers sein. Doch eins ist gewiss, nämlich dass dieser Krachler niemals schweren Herzens war. Entsprechend leicht ist er auch. Ideal für Abenteurer, die gerade auf Diät sind.",ep:5,g:457,l:120,wd:true,fm:true,w:50,p:100};
I.u[8103] = {n:"Bogen der Gespinndichkeit",t:2,d:"Dieser Bogen ist in Wirklichkeit das fossilgewordene Haar eines Sadidas im Tiefschlaf, in welches sich eine Horde Arachneen eingesponnen hat.",ep:20,g:53,l:121,wd:true,fm:true,w:20,an:10,tw:true,e:[5,5,2,6,30,50,false,true],c:"CS>100&CA>100&CI>100&CC>100&CV>200",p:34857};
I.u[8104] = {n:"Chtelion-Bogen",t:2,d:"Dieser Bogen ist häßlich, unmodern und macht den Schützen dumm, doch kann man damit Pfeile verschießen. Das ist doch schon mal etwas.",ep:20,g:54,l:129,wd:true,fm:true,w:20,an:10,tw:true,e:[7,4,2,6,35,40,false,true],c:"CI>300&CV>300&CA>100",p:42510};
I.u[8106] = {n:"Trank des Vergessens: \"Bastler\"",t:44,d:"Dieser Trank lässt euch den Beruf des Bastlers vergessen.",ep:7,g:2,l:1,wd:false,fm:true,w:1,c:"Pz=0",u:true,p:10};
I.u[8107] = {n:"Ehrenbuch der Barden",t:25,d:"Dieses Buch wurde Nolliuos, dem Sieger des Bardenwettbewerbes im Jahre 636, in einer feierlichen Zeremonie für seine Verdienste überreicht. Seine Worte und Werke wurden ganz nach dem üblichen Brauch niedergeschrieben. Hujikan, Doux-Leurre und Madahine, die ebenfalls auf der Bestenliste rangierten, bekamen anschließend ebenfalls einen Eintrag im Buch. Langes Leben ihnen und ihrer Feder!",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8108] = {n:"Tofu-Amulett",t:1,d:"Leicht wie eine Feder ist dieses Amulett. Es lässt sich um den Hals oder auch als Stirnband tragen. Für alle Abenteurer mit ausgefallenem Modebewusstsein.",ep:3,g:95,l:22,wd:true,fm:true,w:5,s:50,p:1525};
I.u[8109] = {n:"Tofu-Ring",t:9,d:"Dieser kleine Ring ist derart lächerlich, dass er schon wieder nützlich ist. Denn eure Gegner werden stets Mitleid mit euch haben, was manchmal sehr praktisch sein kann. Sie werden euch beispielsweise immer den Gnadenstoß verpassen, anstatt euch noch lange leiden zu lassen.",ep:3,g:100,l:21,wd:true,fm:true,w:5,s:50,p:1350};
I.u[8110] = {n:"Tofu-Stab",t:3,d:"Im Gegensatz zu dem, was manche Abenteurer glauben, wird dieser Stab nicht  v o n  Tofus verwendet (dafür sind sie viel zu dumm), sondern  g e g e n  Tofus. Die Federn, die ihn schmücken, imitieren das Balzverhalten paarungswilliger Tofus, wodurch sich selbige leichter fangen lassen. Wie weit werden mörderische Jäger denn noch gehen, um ihre primitiven Gelüste auszuleben?",ep:3,g:58,l:25,wd:true,fm:true,w:10,an:11,e:[5,6,2,2,50,50,false,false],s:50,p:100};
I.u[8111] = {n:"Tofu-Pantoffeln",t:11,d:"Diese leichten, elastischen Pantoffeln bleiben im Winter warm und im Sommer kühl. Ihr einziger Nachteil: sie lassen sich nicht in der Maschine waschen. Schade.",ep:3,g:73,l:23,wd:true,fm:true,w:10,s:50,p:1575};
I.u[8112] = {n:"Tofu-Umhang",t:17,d:"Dieser seltsame Umhang scheint in zwei Teile geschnitten worden zu sein. Doch warum sollte jemand so etwas tun? Niemand weiß darauf eine Antwort, auch wenn jeder eine Meinung dazu hat.",ep:3,g:97,l:26,wd:true,fm:true,w:10,s:50,p:2000};
I.u[8113] = {n:"Tofu-Gürtel",t:10,d:"Dieser Gürtel ist nicht nur ideal, um Tofus zu erwürgen, sondern auch für Jäger, die mit ihm Abenteurer von ihrem Jagdrevier vertreiben möchten. Mit Jägern ist eben nicht zu spaßen, vor allem mitten in der ganzjährigen Jagdsaison.",ep:3,g:89,l:22,wd:true,fm:true,w:5,s:50,p:1553};
I.u[8114] = {n:"Helmofu",t:16,d:"Dieser Bauhelm ist der letzte Schrei und somit unumgänglich für jeden Abenteurer, der mit dem Trend geht. Sonst noch etwas?",ep:3,g:128,l:23,wd:true,fm:true,w:5,s:50,p:1575};
I.u[8116] = {n:"Mütze des goldenen Scarabiestes",t:16,d:"Diese Mütze ist perfekt, um eure Pickel zu verbergen, oder aber euer hübsches Engelsgesicht.",ep:6,g:129,l:58,wd:true,fm:true,w:10,s:51,p:8900};
I.u[8117] = {n:"Umhang des goldenen Scarabiestes",t:17,d:"Noch goldener als ein klassischer Scarablatt-Umhang und weniger dunkel als ein schwarzer Scara-Mantel, ist dieser Umhang einfach ideal, um eure Unförmigkeit zu verbergen. Darum hütete ihn das goldene Scarabiest auch wie seinen Augapfel, da es außer ziemlich golden nämlich auch ziemlich buckelig war. Heutzutage hingegen wird der Umhang meist tiefer getragen, um unförmige Hinterteile zu verbergen. Kein Wunder, dass er so populär wurde.",ep:6,g:98,l:58,wd:true,fm:true,w:10,s:51,p:8980};
I.u[8118] = {n:"Stab des goldenen Scarabiestes",t:3,d:"Dieser magische Stab ist perfekt dazu geeignet, alte Möbel oder alte Abenteurer abzustauben.",ep:6,g:59,l:59,wd:true,fm:true,w:10,an:11,e:[10,4,2,4,30,60,false,false],s:51,p:9300};
I.u[8119] = {n:"Gürtel des goldenen Scarabiestes",t:10,d:"Wenn ihr gerne nackt an den Stränden von Moon spazieren geht, dann ist dieser Gürtel genau das Richtige für euch. Dabei braucht ihr dann auch nicht einmal ein Feigenblatt zu tragen.",ep:6,g:90,l:51,wd:true,fm:true,w:10,s:51,p:6825};
I.u[8120] = {n:"Amulett des goldenen Scarabiestes",t:1,d:"Auf einer behaarten Brust macht sich dieses Amulett am Besten. Warum, weiß niemand, aber es ist so.",ep:6,g:96,l:45,wd:true,fm:true,w:5,s:51,p:5375};
I.u[8121] = {n:"Ring des goldenen Scarabiestes",t:9,d:"Das Scarabiest ist eine seltsame Kreatur. Da alle anderen Scarablätter es für häßlich halten, wird es von allen gemieden. Kein Wunder, dass diese Kreatur später so biestig wurde!",ep:6,g:101,l:43,wd:true,fm:true,w:5,s:51,p:5000};
I.u[8122] = {n:"Stiefel des goldenen Scarabiestes",t:11,d:"Mit diesen gebogenen Stiefeln an den Füßen kann man selbst die steilsten Berghänge ohne Seil erklimmen. Bauern können damit ihre Felder ohne Pflug bestellen. Ausgesprochen praktisch!",ep:6,g:74,l:54,wd:true,fm:true,w:10,s:51,p:7725};
I.u[8123] = {n:"Bauernamulett",t:1,d:"Dieses Amulett ist mit wildem Sonnenblumenöl eingerieben und mit frischen Kräutern gespickt. Ein perfekter Köder für die gefährlichen Wiederkäuer, denen ihr nachstellt, wie beispielsweise Fresssäcke oder böse Schwiegermütter.",ep:1,g:97,l:20,wd:true,fm:true,w:5,s:47,p:1255};
I.u[8124] = {n:"Bermudagürtel des Bauern",t:10,d:"Dieser Gürtel ist wahrlich außergewöhnlich, da eine Bermuda aus Leinen daran befestigt ist. Das macht ihn zum idealen Gürtel für alle, die schnell aus ihren Kleidern schupfen wollen, um gleich an Ort und Stelle aktiv zu werden. Aber Achtung: aus hygienischen Gründen ist dieser Gürtel im städtischen Schwimmbad verboten!",ep:1,g:91,l:20,wd:true,fm:true,w:10,s:47,p:1300};
I.u[8125] = {n:"Bauernkappe",t:16,d:"Es gibt nichts Besseres für die Feldarbeit unter sengender Sonne als ein Grobianium. Doch wenn ihr arm seid, hilft auch eine Bauernkappe.",ep:1,g:130,l:19,wd:true,fm:true,w:10,s:47,p:1200};
I.u[8126] = {n:"Mottenzerfressene Bauernfäustlinge",t:9,d:"Diese Handschuhe sind wahre Prachtexemplare. Man munkelt, sie seien mit Diamantenstaub besprenkelt worden, was sie extrem widerstandsfähig macht. Darum besitzen sie auch eine raue und eine weiche Seite, je nachdem ob ihr gerade das Hinterteil eines Fresssackes oder das eurer Frau reiben möchtet. Praktisch, nicht wahr?",ep:1,g:102,l:12,wd:true,fm:true,w:5,s:47,p:600};
I.u[8127] = {n:"Abgenutzte Bauernsense",t:22,d:"Diese robuste, aber bereits stark abgenutzte Sense ist schartig und stumpf. Doch immer noch sehr praktisch, um die Haut oberflächlich aufzuschürfen. Ideal für alle, die endlich etwas gegen die Warzen ihrer Gegner unternehmen wollen.",ep:1,g:2,l:17,wd:true,fm:true,w:1,an:17,e:[5,3,1,1,50,50,false,false],s:47,p:950};
I.u[8128] = {n:"Bauernstiefel",t:11,d:"Diese Stiefel sind mit Stroh ausgefüllt, welches den Schweiß aufsaugt. Ferner sind sie ideal, um seltene toxische Pilze zum Nulltarif anzubauen. Dank ihrer besonders weichen Sohle wird das Tragen dieser Stiefel auch von der allgemeinen Fressball-Liga empfohlen.",ep:1,g:75,l:18,wd:true,fm:true,w:5,s:47,p:1100};
I.u[8129] = {n:"WuWulf-Amulett",t:1,d:"Dieses aus WuWulf-Knochen, -zähnen und -klauen angefertigte Amulett enthält große Macht. Aber auch einen großen Gestank. Wenn sich alle anderen über euren schlechten Atem beklagen, dann solltet ihr euch also nicht wundern.",ep:1,g:98,l:57,wd:true,fm:true,w:10,s:32,p:8550};
I.u[8130] = {n:"WuWulf-Axt",t:19,d:"Diese furchterregende Axt hat bereits mehr als einen Abenteurer in die ewigen Abenteuergründe gejagt. Und das, obwohl sie derart schlecht schneidet, dass es manchmal mehr als 10 Anläufe braucht, um einen Hals zu durchtrennen.",ep:1,g:42,l:55,wd:true,fm:true,w:10,an:17,tw:true,e:[5,6,1,1,50,50,false,false],s:32,p:8125};
I.u[8131] = {n:"Bauernsack",t:81,d:"Dieser Sack, der gerade bei Schülern hoch im Kurs steht, ist ideal, um darin Tier- und Pflanzenmehl zu transportieren. Wenn ihr ihn öffnet, entfaltet und entlang der Nähte auftrennt, wird er euch außerdem gute Dienste als Kleid leisten, es sei denn ihr schämt euch für eure haarigen Beine.",ep:1,g:3,l:19,wd:true,fm:true,w:1,s:47,p:1153};
I.u[8132] = {n:"Schwarzer Scara-Gürtel",t:10,d:"Diesem Gürtel fehlt jegliche Originalität. Dafür passt er allerdings gut zu eurer Frisur.",ep:6,g:93,l:43,wd:true,fm:true,w:10,s:49,p:4955};
I.u[8133] = {n:"Schwarze Scara-Mütze",t:16,d:"Die perfekte Mütze für alle, die einen schwarzen Humor haben.",ep:6,g:132,l:53,wd:true,fm:true,w:10,s:49,p:7350};
I.u[8134] = {n:"Schwarzer Scara-Umhang",t:17,d:"Wenn ihr nicht die Mittel habt, euch eine Rabacapa Maesteri zu leisten, aber dennoch gern ganz in schwarz gekleidet sein möchtet, um Arachneen zu erschrecken, dann ist dieser Umhang genau das Richtige für euch.",ep:6,g:100,l:53,wd:true,fm:true,w:10,s:49,p:7575};
I.u[8135] = {n:"Schlüssel zum Dungeon der Bworks",t:84,d:"Dieser wunderschöne Schlüssel ermöglicht euch, ins Dungeon der Bworks einzudringen, aber was das herauskommen angeht...",ep:1,g:234,l:1,wd:true,fm:true,w:1,p:100};
I.u[8136] = {n:"Schwarzer Scara-Ring",t:9,d:"Dieser magische Ring lässt sich bequem an der großen Zehe tragen. Das ist ideal, um Warzen und eingewachsene Zehennägel zu verstecken.",ep:6,g:104,l:48,wd:true,fm:true,w:10,s:49,p:6200};
I.u[8137] = {n:"Innereien des goldenen Scarabiestes",t:15,d:"Diese Innereien sind für die vielen Verdauungsstörungen des goldenen Scarabiestes verantwortlich. Darum dürft ihr sie nun ohne jede Reue braten.",ep:6,g:726,l:70,wd:true,fm:true,w:5,p:100};
I.u[8138] = {n:"Panzer eines schwarzen Scarablattes",t:107,d:"Umgedreht gibt dieser Panzer einen hervorragenden Aschenbecher ab.",ep:6,g:727,l:40,wd:true,fm:true,w:5,p:100};
I.u[8139] = {n:"Schlüssel zum Dungeon der Scarablätter",t:84,d:"Dieser wunderschöne goldene Schlüssel gewährt euch Zutritt zum Dungeon der Scarablätter. Glaubt ihr etwa wirklich, bereits alles gesehen zu haben?",ep:1,g:233,l:1,wd:true,fm:true,w:1,p:100};
I.u[8140] = {n:"Antennen eines schwarzen Scarablattes",t:15,d:"Das arme schwarze Scarablatt hat nie herausgefunden, wozu seine Antennen gut sind. Manchmal ist die Natur wirklich gemein!",ep:6,g:728,l:40,wd:true,fm:true,w:1,p:100};
I.u[8141] = {n:"Flügel eines schwarzen Scarablattes",t:104,d:"Im Gegensatz zu dem, was manche Abenteurer glauben, sind die Flügel von schwarzen Scarablättern nicht schwarz, sondern weiß. Wieder so ein Mysterium der Natur...",ep:6,g:729,l:40,wd:true,fm:true,w:1,p:100};
I.u[8142] = {n:"Geheimschlüssel zum königlichen Tofustall",t:84,d:"Dieser Schlüssel gibt euch Zutritt zum königlichen Tofustall, wo euch eine gute Abreibung erwartet.",ep:3,g:12,l:1,wd:true,fm:true,w:1,p:1};
I.u[8143] = {n:"Schlüssel der Felder",t:84,d:"Dieser Schlüssel dient nicht dazu, euch den Dungeon der Felder zu öffnen, sondern vielmehr dazu, Abenteurer darin einzusperren.",ep:1,g:13,l:1,wd:true,fm:true,w:1,p:100};
I.u[8144] = {n:"Mojo des MuWulfs",t:15,d:"Diese kleine Phiole enthält die Essenz der Männlichkeit des MuWulfs. Vorsicht, sie ist absolut ungenießbar!",ep:2,g:730,l:1,wd:true,fm:true,w:1,p:1};
I.u[8145] = {n:"Bwork-Bier",t:37,d:"Bwork-Bier verpaßt einem Feca bereits auf 12 Schritte Entfernung und einem Sadida auf 15 Fuß Abstand einen Rausch. Es lässt sich beim besten Willen nicht feststellen, ob das Bier so heißt, weil es von Bworks oder aus Bworks hergestellt wurde. Vielleicht beides...?",ep:1,g:1,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[8146] = {n:"Stiefel des legendären Mega-Krachlers",t:11,d:"Wenn ihr beim Tanzen gern die Zehen eurer Partner zerquetscht, dann sind diese Stiefel für euch wie geschaffen!",ep:5,g:77,l:86,wd:true,fm:true,w:10,s:52,p:19150};
I.u[8147] = {n:"Helm des legendären Mega-Krachlers",t:16,d:"Dieser verbesserte Version des Krachlerhelmes wird euch vor Steinschlägen bewahren, aber nicht vor Schicksalsschlägen. Also seht euch vor!",ep:5,g:133,l:80,wd:true,fm:true,w:10,s:52,p:16530};
I.u[8148] = {n:"Hammer des Legendären Mega-Krachlers",t:7,d:"Dieser riesige Hammer ist nichts anderes als das Schwert eines Krachlers, welches mit legendärem Mega-Krachlergestein verstärkt wurde. Dieser geheimnisvolle Gegenstand wird sicherlich eure Gegner völlig überraschen, kurz bevor sie von ihm zermalmt werden.",ep:5,g:58,l:81,wd:true,fm:true,w:10,an:15,e:[7,5,1,1,40,50,false,false],c:"CA>100&CI>50",s:52,p:16850};
I.u[8149] = {n:"Ring des Legendären Mega-Krachlers",t:9,d:"Dieser mit Edelsteinen eingefasste Felsbrocken ist einfach ideal, um den Schläfen oder der Stirn eurer Gegner damit ein bleibendes Andenken zu verpassen.",ep:18,g:105,l:80,wd:true,fm:true,w:10,s:52,p:16775};
I.u[8150] = {n:"Amulett des Legendären Mega-Krachlers",t:1,d:"Dieses auf den ersten Blick gewöhnlich erscheinende Amulett enthält ein großes Geheimnis. Nämlich das Geheimnis um alle Geheimnisse, die sich in seinem Inneren befinden.",ep:5,g:99,l:84,wd:true,fm:true,w:10,s:52,p:18350};
I.u[8151] = {n:"Fresskügelchen",t:18,d:"Dieses kleine Monster wird euch auf Schritt und Tritt folgen und dabei die Reste seiner Artgenossen, der Fresssäcke, verspeisen. Mal beängstigend, mal lustig, wird es euer Leben aufheitern, bevor es euch vielleicht eines Tages selbst verspeist.",ep:3,g:35,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8152] = {n:"Gürtel des Legendären Mega-Krachlers",t:10,d:"Der Legendäre Mega-Krachler trägt diesen Gürtel um seinen großen Zeh. Das heißt, ihr könnt ihn also möglicherweise sogar als Gürtel verwenden! Glück gehabt.",ep:5,g:94,l:80,wd:true,fm:true,w:10,s:52,p:16506};
I.u[8153] = {n:"Astaknydasta",t:18,d:"Wie ihr auch, konnte dieser kleine Astaknyd den Anblick seiner Familie nicht mehr ertragen und beschloss, ein Rebell zu werden. Also schloss er sich euch an und zählt nun die Mitglieder seiner Familie, die eurer Klinge zum Opfer fallen.",ep:3,g:34,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8154] = {n:"El Scarador",t:18,d:"Dieser liebenswürdige kleine Käfer aus dem Süden ist nicht zu unterschätzen. Da er in frühester Jugend von seinen Freunden gehänselt wurde, strebt er nun nach Rache und wird nicht eher ruhen, bis alle Scarablätter für diese Schmach von euch ausgelöscht wurden.",ep:3,g:36,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8155] = {n:"Minifux",t:18,d:"Diese hübsche Kreatur ist ein entfernter Verwandter der Lenalds, die auf der Wabbit-Insel leben. Doch sie ist viel mutiger  und gleichzeitig auch viel undisziplinierter als diese. Der Minifux wird euch bei all euren Kämpfen sicher gut unterstützen können. Doch das oberste Ziel dieses tückischen Wesens ist und bleibt es, alle Artverwandten auszurotten.",ep:3,g:37,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8156] = {n:"Schlüssel zum Dungeon der Canidae",t:84,d:"Dieser Schlüssel ermöglicht euch den Zutritt zum Dungeon der Canidae, wo ihr euch mit Freude und Vergnügen zerfleischen lassen könnt.",ep:1,g:235,l:1,wd:true,fm:true,w:1,p:1};
I.u[8157] = {n:"Magisches Blütenblatt",t:35,d:"Wie alle magischen Gegenstände auch, ist dieses Blütenblatt sehr beeindruckend. Es strahlt eine Aura der Macht aus, die sich direkt proportional zur Naivität des Betrachters verhält.",ep:1,g:2,l:20,wd:true,fm:true,w:1,p:100};
I.u[8158] = {n:"Fettige Tofurby-Feder",t:53,d:"Der Tofurby wälzt sich gerne in Fett, damit seine Federn nicht austrocknen und ausfallen. Diese Technik gibt es schon seit Urzeiten. Selbst Enutrofs kennen und nutzen sie schon, um ihre Haare nach der Pubertät vor dem Ausfallen zu bewahren.",ep:3,g:1,l:50,wd:true,fm:true,w:1,p:10};
I.u[8159] = {n:"Panzer des goldenen Scarabiestes",t:107,d:"Als Kopfbedeckung getragen, wird euch dieser Panzer vor Wind und Wetter sowie vor gefährlichen Guanoniederschlägen zu schützen wissen.",ep:6,g:731,l:70,wd:true,fm:true,w:5,p:100};
I.u[8160] = {n:"Antennen des goldenen Scarabiestes",t:15,d:"Wenn ihr Korgamon, dem Schrecken der Karpaten ähneln wollt, dann steckt euch diese Antennen in die Nase und singt lautstark Wanderlieder, während ihr mit eurem Hintern wackelt.",ep:6,g:732,l:70,wd:true,fm:true,w:1,p:100};
I.u[8161] = {n:"Flügel des goldenen Scarabiestes",t:104,d:"Wenn ihr schon immer davon geträumt habt, wie ein fetter Piepmatz durch die Lüfte zu flattern, dann befestigt diese Flügel einfach am Körper und springt vom höchsten Turm von Brâkmar. Mit etwas Glück gleicht ihr danach einem zerschmetterten Rabling und habt den Brâkmarmilizen einen großen Heiterkeitsanfall beschert, sowie den Rablingen ein Festmahl.",ep:6,g:733,l:70,wd:true,fm:true,w:1,p:100};
I.u[8162] = {n:"Küwbiskopf",t:16,d:"Mit diesem Küwbiskopf auf dem Schädel seht ihr noch bescheuerter aus als sonst. Doch erinnert euch an den furchtbaren Fluch von Höll\'O\'Fen! Wollt ihr wirklich als stupide Kreatur enden? Nur dieser Küwbiskopf kann euch vor diesem Schicksal bewahren.",ep:1,g:134,l:1,wd:true,fm:true,w:1,p:1};
I.u[8163] = {n:"Kabuto",t:16,d:"Dieser Helm wurde einst von den Ordnungskräften der beiden größten Städte getragen. Doch heute dient er vielmehr dazu, allzu neugierige Bürger davon abzuschrecken, zu viel über diejenigen zu erfahren, welche die Geschicke der Stadt in den Händen halten.",ep:20,g:135,l:101,wd:true,fm:true,w:10,p:26000};
I.u[8164] = {n:"Fresskügelchen-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, sowie Eniripsa-Pulver für seine Pflege.",ep:1,g:2,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8165] = {n:"Astaknydasta-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, sowie Eniripsa-Pulver für seine Pflege.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8166] = {n:"El Scarador-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, sowie Eniripsa-Pulver für seine Pflege.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8167] = {n:"Minifux-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, sowie Eniripsa-Pulver für seine Pflege.",ep:1,g:2,l:1,wd:false,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[8168] = {n:"Höll O\'Feen-Geschenk",t:89,d:"Höll O\'Feen war mit Abstand der größte Produzent von Küwbissen weit und breit. Dazu war er Lehrling eines mächtigen Bwork Magus. Um den jährlichen Wettbewerb um die dicksten Küwbisse gewinnen zu können, bat er seinen Lehrmeister um Hilfe, der sofort den neuesten seiner Zaubersprüche an ihnen ausprobierte, welcher prompt fehlschlug. Seitdem verwandeln sich jedes Jahr zur selben Zeit all diejenigen, welche von den magischen Küwbissen gekostet haben, mehrere Tage lang in seltsame unförmige Kreaturen. Dieser Fluch scheint zudem auch noch ansteckend zu sein. Als Gegenmaßnahme begannen die Einwohner Amaknas, mehrere Tage lang mit ausgehöhlten Küwbissen auf den Köpfen herumzulaufen, um den Fluch abzuwehren. Und was das Überraschendste daran ist: es scheint sogar zu wirken!",ep:1,g:1,l:1,wd:false,fm:true,w:1,p:1};
I.u[8169] = {n:"Höll\'O\'Feen-Fresssack-Verwandlung",t:27,d:"Ihr wurdet in einen Höll\'O\'Feen-Fresssack verwandelt. Um diese Verwandlung wieder rückgängig zu machen, müsst ihr einen Abenteurer besiegen.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8170] = {n:"Höll\'O\'Feen-Tofu",t:27,d:"Ihr wurdet in einen Höll\'O\'Feen-Tofu verwandelt. Um diese Verwandlung wieder rückgängig zu machen, müsst ihr einen Abenteurer besiegen.",ep:1,g:4,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8171] = {n:"Astaknydasta-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:34,l:1,wd:true,fm:true,w:1,p:1};
I.u[8172] = {n:"Fresskügelchen-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[8173] = {n:"El Scarador-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:36,l:1,wd:true,fm:true,w:1,p:1};
I.u[8174] = {n:"Minifux-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben...oder aber ihn feige ein für alle Male fallen zu lassen.",ep:3,g:37,l:1,wd:true,fm:true,w:1,p:1};
I.u[8175] = {n:"Tierheimzertifikat: Astaknydasta",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über Astaknydasta, den ihr im Tierheim abgegeben habt.",ep:3,g:36,l:1,wd:false,fm:true,w:1,p:100};
I.u[8176] = {n:"Tierheimzertifikat: Fresskügelchen",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über das Fresskügelchen, das ihr im Tierheim abgegeben habt.",ep:3,g:37,l:1,wd:false,fm:true,w:1,p:100};
I.u[8178] = {n:"Tierheimzertifikat: El Scarador",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über El Scarador, den ihr im Tierheim abgegeben habt.",ep:3,g:38,l:1,wd:false,fm:true,w:1,p:100};
I.u[8179] = {n:"Tierheimzertifikat: Minifux",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Minifux, den ihr im Tierheim abgegeben habt.",ep:3,g:39,l:1,wd:false,fm:true,w:1,p:100};
I.u[8180] = {n:"Tierheimzertifikat: Bworky",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Bworky, den ihr im Tierheim abgegeben habt.",ep:3,g:40,l:1,wd:false,fm:true,w:1,p:100};
I.u[8181] = {n:"Krachlcoatlus des legendären Megakrachlers",t:17,d:"Dieser dicke Umhang aus massivem Gestein wird aus euch einen massigen Brutalo mit einem Herzen aus Stein machen. Dann lasst die Gegner mal kommen!",ep:5,g:101,l:84,wd:true,fm:true,w:10,s:52,p:18200};
I.u[8184] = {n:"Minifux-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt. Nur so ist es euch möglich, das Heiligtum der Vertrauten zu betreten.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8185] = {n:"El Scarador-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt. Nur so ist es euch möglich, das Heiligtum der Vertrauten zu betreten.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
