I.u[7999] = {n:"Umhängananas",t:17,d:"Gewisse Abenteurer behaupten, dieser Mantel sei so schuppig wie die Haut eines Crocodylls, während andere meinen, er sei noch rauer als der Hintern eines weiblichen Bworks. Wie auch immer: Lernt aus ihren Fehlern und zieht diesen Mantel richtig herum an! Zeigt euren Gegnern, dass es weh tut, sich mit euch anzulegen!",ep:1,g:94,l:1,wd:true,fm:true,w:10,s:74,p:100};
I.u[8000] = {n:"Bworky",t:18,d:"Diese kleine Kreatur ist ein Bwork, der mehrere Jahrzehnte lang in einem kleinen Trinkgefäß gefangen war. Darum nahm sein Körper auch dessen Form an. Seine gute Laune und sein legendärer Humor machen ihn zum idealen Begleiter für die aussichtslose Eroberung von Dungeons oder für einen Auftritt auf verhexten Jahrmärkten. Doch Vorsicht: er trinkt gerne einen Apéritif und verträgt nur Nüsse, auch wenn er nichts dagegen hat, von Zeit zu Zeit ein paar Eicheln zu verschlingen.",ep:3,g:31,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8001] = {n:"Bandagen eines Koalak-Kriegers",t:15,d:"Diese Bandagen sind normalerweise um die Arme des Koalak-Kriegers gewickelt. Sie erlauben es ihm, sich die Nase zu schneuzen, ohne ein Taschentuch zu benutzen. Nach Benutzung werden die Bandagen dann an die Decke gehängt, als Fliegenfalle.",ep:20,g:719,l:70,wd:true,fm:true,w:5,p:100};
I.u[8002] = {n:"Dok Alako-Pelz",t:55,d:"Dieser Pelz steckt voller alter, mächtiger, aber auch unberechenbarer Magie. Wieder eine Gemeinsamkeit mit eurer Liebsten.",ep:20,g:720,l:40,wd:true,fm:true,w:5,p:1};
I.u[8003] = {n:"Koalak-Amulett",t:1,d:"Dieses Amulett ähnelt keinem anderen Amulett. Das liegt daran, dass kein anderes Amulett diesem Amulett ähnelt.",ep:20,g:94,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8004] = {n:"Koalak-Ring",t:9,d:"Dieser wunderschöne Ring wird nur von den mutigsten aller Koalaks getragen. Denn nur diese wagen es manchmal, junge Abenteurer vor der Bank von Astrub zu berauben.",ep:20,g:99,l:53,wd:true,fm:true,w:10,s:46,p:7375};
I.u[8005] = {n:"Koalak-Bogen",t:2,d:"Dieser mächtige Bogen stiehlt Gegnern ihr Leben. Manchmal stiehlt er sogar dem Leben seine Gegner. Ganz schön beeindruckend!",ep:20,g:52,l:61,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,4,50,50,false,true],s:46,p:9775};
I.u[8006] = {n:"Koalak-Stiefel",t:11,d:"Diese Stiefel sind in Wirklichkeit nichts anderes als Koalak-Pfoten, die dem früheren Besitzer grausam abgeschlagen, ausgehöhlt und mit Koalak-Pelz ausgefüttert wurden. Diese furchterregenden und gleichzeitig bezaubernden Stiefel werden sicher ganz Astrub in Aufruhr versetzen.",ep:20,g:71,l:60,wd:true,fm:true,w:10,s:46,p:9600};
I.u[8007] = {n:"Koalak-Umhang",t:17,d:"Dieser Umhang wird euch vor den meisten Attacken beschützen, doch nicht vor eurer eigenen Lächerlichkeit.",ep:20,g:95,l:61,wd:true,fm:true,w:10,s:46,p:9675};
I.u[8008] = {n:"Gürtel des Koalak",t:10,d:"...",ep:20,g:87,l:60,wd:true,fm:true,w:10,s:46,p:9508};
I.u[8009] = {n:"Maske des Koalak",t:16,d:"Diese Maske mit den riesigen Koalak-Ohren ist in der Lage selbst die geringsten Geräusche hörbar zu machen. Doch Vorsicht: wenn ihr Freunde habt, die zu Panikwellen neigen, so kann euch das Trommelfell dabei platzen.",ep:20,g:125,l:60,wd:true,fm:true,w:10,s:46,p:9425};
I.u[8010] = {n:"Demontierschlüssel",t:93,d:"Mit diesem Schlüssel lassen sich in einer Koppel installierte Aufzuchteinrichtungen leicht wieder abbauen.",ep:1,g:96,l:1,wd:false,fm:true,w:10,ut:true,p:1};
I.u[8011] = {n:"Propheten, Kulte und Glaubensrichtungen",t:25,d:"Eine Sammlung guter Geschichten über diverse Kulte, um die überzeugten Mystiker zu erfreuen.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[8012] = {n:"Pulver der Wiedererweckung",t:48,d:"Dieses Pulver kann die Geister von Vertrauten zurück ins Leben rufen, vorausgesetzt ihr wisst, wie man sie damit füttern kann.",ep:20,g:51,l:1,wd:true,fm:true,w:1,p:100};
I.u[8013] = {n:"Maunzmiez-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt. Nur so ist es euch möglich, das Heiligtum der Vertrauten zu betreten.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8016] = {n:"Blutrünstiger Koalak-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:43,l:1,wd:true,fm:true,w:1,p:1};
I.u[8017] = {n:"Mini Bwork-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:31,l:1,wd:true,fm:true,w:1,p:1};
I.u[8020] = {n:"Krötschild-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:2,g:42,l:1,wd:true,fm:true,w:1,p:1};
