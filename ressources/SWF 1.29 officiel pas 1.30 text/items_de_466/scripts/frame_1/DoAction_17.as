I.u[7804] = {n:"Energie-Bonbon",t:42,d:"Dieses Bonbon gibt eine große Menge an Energie zurück, beispielsweise nach einer schweren Anstrengung.",ep:1,g:137,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7805] = {n:"Dracotruter: Tipps für die Aufzucht",t:25,d:"Dieses Buch erläutert genau das Vorgehen beim Einfangen, Züchten und Zureiten von Dracotrutern. Es wurde von Oshar Marif höchstpersönlich geschrieben – ein sicheres Indiz für ein qualitativ hochwertiges Produkt.",ep:16,g:19,l:1,wd:false,fm:true,w:1,u:true,p:500};
I.u[7806] = {n:"Reittierzertifikat",t:97,d:"Dieses Zertifikat erlaubt es euch, euer Reittier in einem Stall abzuholen. \nDoch Vorsicht: es ist nur 20 Tage gültig. Wenn diese Zeit abgelaufen ist, dann wird euer Reittier wieder in die freie Wildbahn entlassen und ist damit für euch verloren. Denkt daran, euer Reittier in einem eigenen Stall abzustellen, wenn ihr vorhabt, längere Zeit abwesend zu sein.",ep:1,g:1,l:60,wd:false,fm:true,w:1,c:"PL>59",p:1};
