I.u[7879] = {n:"Hyrkuls Advent",t:25,d:"Bei den kolossalen, unmoralischen, wenig banalen Annalen von Domen kann es einem schon kalt den Rücken hinunterlaufen. Daher sollte man nur die maximale empfohlene Tagesdosis davon einnehmen. Risiken und Nebenwirkungen: kalter Schweiß und nächtliche Inkontinenz.",ep:16,g:19,l:1,wd:true,fm:true,w:1,u:true,p:10};
I.u[7880] = {n:"Fresscool-Amulett",t:1,d:"Diese Art von Amulett wurde einst von einem Bund von Abenteurern getragen, welche statt der ewigen Schlachten lieber Worte der Liebe verbreiten wollten. Naja, jedem wie\'s beliebt.",ep:20,g:93,l:20,wd:true,fm:true,w:5,s:43,p:1300};
I.u[7881] = {n:"Fresscool-Ring",t:9,d:"Diese Ring wird es euch erlauben, noch fester zuzuschlagen, wenn ihr euren Kindern eine wohlverdiente Trach Prügel verabreicht.",ep:20,g:98,l:38,wd:true,fm:true,w:5,s:43,p:4000};
I.u[7882] = {n:"Fresscool-Hammer",t:7,d:"Dieser Hammer ist ideal, um einen bleibenden Abdruck eurer pazifistischen Ader auf dem Schädel eurer Gegner zurückzulassen.",ep:20,g:54,l:41,wd:true,fm:true,w:10,an:15,e:[5,5,1,1,40,40,false,false],s:43,p:4520};
I.u[7883] = {n:"Fresscool-Stiefel",t:11,d:"Diese mit Fresscool-Wolle überzogenen Stiefel sind einfach genial! Trotz ihres leichten Gewichts halten sie eure Füße in den kalten Jahreszeiten gut warm. Und wenn es warm wird, sind sie auch noch luftdurchlässig. Selbst die hochnäsigsten aller Abenteurer können kein Argument gegen sie finden.",ep:20,g:66,l:38,wd:true,fm:true,w:15,s:43,p:3925};
I.u[7884] = {n:"Fresscool-Mantel",t:17,d:"Dieser Mantel ist genau das Richtige für euch, wenn ihr das Leben stets von der positiven Seite nehmt. Tatsächlich ist er so dick und so bequem, dass er notfalls sogar als Feldbett dienen kann. Zudem vertreibt der daraus entströmende Eukalyptusqualm alle Insekten und andere unerwünschte Tierchen.",ep:20,g:93,l:55,wd:true,fm:true,w:15,s:43,p:8030};
I.u[7885] = {n:"Fresscool-Gürtel",t:10,d:"Mit diesem Gürtel um die Lenden ist es euch sicher ein Leichtes, euch als Pazifisten auszugeben, um eure Feinde dann mit einem Schwertstich in den Rücken umso besser zu überraschen.",ep:20,g:84,l:37,wd:true,fm:true,w:10,s:43,p:3800};
I.u[7886] = {n:"Fresscool-Hut",t:16,d:"Mit diesem Hut auf dem Kopf werdet ihr sicherlich nicht viel schlauer als vorher wirken, das ist wohl klar. Aber dafür sehr viel \"cooler\", und darauf kommt es schließlich an im Leben.",ep:20,g:119,l:47,wd:true,fm:true,w:15,s:43,p:6000};
I.u[7887] = {n:"Kopftuch des Kuhlosses",t:16,d:"Dieses Kopftuch gehörte einst dem berühmten Kuhloss, der für seine Empfindlichkeit und seinen legendären Humor bekannt geworden ist.",ep:20,g:122,l:82,wd:true,fm:true,w:10,s:44,p:18375};
I.u[7888] = {n:"Sack des Kuhlosses",t:81,d:"Dieser Sack dient dem Kuhloss als Aufbewahrungsort für seine Kalyptus-Blätter oder aber dazu, aufmüpfige Koalaks zum Schweigen zu bringen...",ep:20,g:2,l:69,wd:false,fm:true,w:10,s:44,p:12278};
I.u[7889] = {n:"Stiefel des Kuhlosses",t:11,d:"Diese Stiefel gehörten einst dem großen Kuhloss. Wer das nicht gleich sieht, wird es sicherlich bald fühlen. Diese Stiefel sind derart bequem, dass sie euch beinahe vergessen lassen, wie armselig euer kleines Leben doch ist.",ep:20,g:69,l:73,wd:true,fm:true,w:10,s:44,p:13775};
I.u[7890] = {n:"Stock des Kuhlosses",t:4,d:"Dieser Stecken ist in Wirklichkeit nichts anderes, als der ausgehölte Knochen eines der Vorfahren des Kuhlosses. Nun ist er vielseitig einsetzbar, sei es als Kalyptuspfeife oder als Hirtenstock. Der Fortschritt ist eben nicht aufzuhalten.",ep:20,g:62,l:75,wd:true,fm:true,w:10,an:12,tw:true,e:[10,4,1,1,20,50,false,false],s:44,p:14675};
I.u[7891] = {n:"Mini Wa",t:18,d:"Dieser kleine Wabbit ist in Wirklichkeit ein verheimlichter Sohn des berühmt-berüchtigten Wa Wabbits. Vielleicht wird er ja eines Tages auf den Thron steigen?",ep:3,g:28,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7892] = {n:"Willy Wirrwolf",t:18,d:"Willy Wirrwolf ist wirklich ein bösartiges Wesen. Das liegt an seiner schwierigen Kindheit. Daher rächt er sich nun, indem er alle Teddybären auffrisst, die seinen Weg kreuzen.",ep:3,g:29,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[7893] = {n:"Mini Wa-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:18,l:1,wd:true,fm:true,w:1,p:1};
I.u[7894] = {n:"Willy Wirrwolf-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:3,g:17,l:1,wd:true,fm:true,w:1,p:1};
I.u[7895] = {n:"Tierheimzertifikat: Mini Wa",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Mini Wa, den ihr im Tierheim abgegeben habt.",ep:3,g:34,l:1,wd:false,fm:true,w:1,p:100};
I.u[7896] = {n:"Tierheimzertifikat: Willy Wirrwolf",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über Willy Wirrwolf, den ihr im Tierheim abgegeben habt.",ep:3,g:29,l:1,wd:false,fm:true,w:1,p:100};
I.u[7897] = {n:"Mini Wa-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, Nahrung sowie Eniripsa-Pulver für seine Pflege. (WARNHINWEIS: Dieses Paket enthält sehr schwere Gegenstände! Ihr lauft daher Gefahr, überladen zu sein, wenn ihr es öffnet. Entledigt euch daher besser vorher all eurer schweren Gegenstände oder lasst euch von einem befreundetem Charakter helfen.)",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7898] = {n:"Willy Wirrwolf-Geschenkpaket",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, Nahrung sowie Eniripsa-Pulver für seine Pflege. (WARNHINWEIS: Dieses Paket enthält sehr schwere Gegenstände! Ihr lauft daher Gefahr, überladen zu sein, wenn ihr es öffnet. Entledigt euch daher besser vorher all eurer schweren Gegenstände oder lasst euch von einem befreundetem Charakter helfen.)",ep:1,g:42,l:1,wd:true,fm:true,w:1,c:"PZ=1",u:true,p:1};
I.u[7899] = {n:"Der Mini Wa: Tipps für die Aufzucht",t:25,d:"Dieses Buch wurde von Oshimo Li\'kross Babine geschrieben und erklärt eingehend die Aufzucht eines Mini Was.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7900] = {n:"Willy Wirrwolf: Tipps für die Aufzucht",t:25,d:"Dieses Buch wurde von Oshimo Li\'kross Babine geschrieben und erklärt eingehend die Aufzucht von Willy Wirrwolf.",ep:1,g:10,l:1,wd:true,fm:true,w:1,u:true,p:200};
I.u[7902] = {n:"Gürtel der goldenen Lady",t:10,d:"Eine alte Geschichte aus dem berühmten Zauberbuch \"Die Frau - Weisheiten und Wahrheiten\" besagt, dass dieser Gürtel aus massivem Gold einmal der goldenen Lady gehört haben soll, die mehr an Reichtum als an Macht interessiert war. In der unzensierten Version dieses Buches steht, sie habe eine ausgesprochene Vorliebe für dreckige Witze und Späße gehabt. Somit unterschied sie sich also kaum von anderen Frauen...",ep:2,g:86,l:71,wd:true,fm:true,w:5,p:13300};
I.u[7903] = {n:"Kalyptusblatt",t:36,d:"Vorsichtig in die Nase geschoben, sollen diese Blätter die Atemwege wieder befreien. Laut einiger Stammesmitglieder soll diese Technik auch mit anderen Körperöffnungen funktionieren.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7904] = {n:"Kalyptusblüte",t:35,d:"Wenn sie verbrannt wird, entwickelt diese Pflanze einen dichten Rauch mit halluzinogener Wirkung. Wird sie gekaut, so macht sie impotent. Als Tee eingenommen, wirkt sie wie ein starkes Abführmittel. Darum ist es am Allerbesten, ganz die Finger davon zu lassen.",ep:14,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7905] = {n:"Fresscool-Wolle",t:57,d:"Diese Wolle sieht der eines Fresssacks zum Verwechseln ähnlich und dennoch ist sie ganz ganz anders. Sie stinkt nämlich nicht richtig.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7906] = {n:"Fresscool-Horn",t:47,d:"Einer alten Legende nach soll das Pulver aus diesen Hörnern eine aphrodisierende Wirkung haben. Doch soll es dummerweise manchmal auch schlimme Nebenwirkungen zeitigen. Ein Grund mehr, es auszuprobieren.",ep:20,g:9,l:1,wd:true,fm:true,w:1,p:10};
I.u[7907] = {n:"Fresscool-Leder",t:56,d:"Aus diesem vielfarbenen Leder kann man vielfarbene Unterwäsche aus vielfarbenem Leder herstellen. Da könnte glatt der blasierteste aller Chafer vor Neid erblassen.",ep:20,g:1,l:1,wd:true,fm:true,w:1,p:10};
I.u[7908] = {n:"Schlüssel zum Dungeon des Kuhlosses",t:84,d:"Dieser Knochenschlüssel gestattet euch den Eintritt in den Kuhloss-Dungeon, selbst wenn ihr nicht zu den geladenen Gästen gehört.",ep:13,g:5,l:1,wd:true,fm:true,w:1,p:10};
I.u[7911] = {n:"Blutrünstiger Koalak",t:18,d:"Dieser kleine Koalak verbirgt nur einfach gut seine Heimtücke. Versucht nicht, ihn zu reizen, indem ihr ihm beispielsweise am Schwanz zieht oder ihm die Schnauze reibt, sonst bekommt ihr gleich seinen Boomerang zu spüren.",ep:3,g:30,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:46,p:1};
I.u[7913] = {n:"Animagi (MJ)",t:9,d:"Dieser seltsame Gegenstand, der in Vergessenheit geraten ist, gehörte einst einem Erzmagier. Man sagt, damit hätte er sogar mit manchen Tieren reden können.",ep:1,g:22,l:1,wd:false,fm:true,w:1,p:1};
I.u[7917] = {n:"Entschädigungsgeschenkpaket",t:89,d:"Als Entschuldigung für die in der letzten Zeit aufgetretenen Probleme erhaltet ihr von Ankama dieses Geschenkpaket. Es enthält:\n- 5 Entschädigungsbonbons der Weisen\n- 5 Entschädigungsbonbons der Glücklichen\n-10 Energie-Entschädigungsbonbons\n-10 Einheiten Eniripsa-Pulver.",ep:1,g:32,l:1,wd:true,fm:true,w:1,c:"PO!7801&PO!7800",u:true,p:1};
I.u[7918] = {n:"Schlüssel zum Dungeon der Tofus",t:84,d:"Mit diesem aus einer Tofufeder hergestellten Schlüssel könnt ihr das Innere mancher Schlösser so lange kitzeln, bis sie vor Lachen aufspringen... oder einfach die Tür zu Farle Ingalsse Tofustall öffnen.",ep:1,g:6,l:1,wd:true,fm:true,w:1,p:100};
I.u[7919] = {n:"Jetons des Spielleiters",t:15,d:"Dieser schöne Jeton lässt sich sicher auf dem Jahrmarkt des Trools gegen schöne Geschenke eintauschen.",ep:1,g:737,l:1,wd:true,fm:true,w:1,p:100};
I.u[7920] = {n:"Turnierstab (SL)",t:3,d:"Dieser gewöhnlich aussehende Stab erlaubt es den Spielleitern, Abenteurer in die für Kämpfe reservierte Zone zu teleportieren.",ep:1,g:8,l:1,wd:false,fm:true,w:1,e:[5,6,1,1,50,50,false,false],u:true,p:100};
I.u[7921] = {n:"Krone des Königlichen Tofus",t:16,d:"Diese Krone ist sehr schwer zu erlangen, und sie rinnt einem im wahrsten Sinne des Wortes zwischen den Fingern hindurch. Das ist der beste Beweis dafür, dass es sich auch wirklich um die Krone des Königlichen Tofus handelt. Andererseits scheint sie nicht so recht auf euren kleinen Kopf passen zu wollen. Wie wird das dann wohl mit dem Kopf eines Iops aussehen?",ep:13,g:154,l:128,wd:true,fm:true,w:10,p:42625};
I.u[7922] = {n:"Sacrieur-Dubbelteddy",t:61,d:"Dieser Teddy ist perfekt für junge Sacrieurs. Der schwammartige Stoff kann ihr Blut aufsaugen und lässt sich bei jeder Temperatur in der Waschmaschine reinigen.",ep:0,g:1,l:1,wd:true,fm:true,w:10,p:1};
I.u[7923] = {n:"Pandawa-Dubbelteddy",t:61,d:"Dieser Teddy stinkt nach Alkohol und nassem Pandawa-Haar. Ganz wie Mama. Wie schön!",ep:1,g:2,l:1,wd:true,fm:true,w:10,p:1};
I.u[7924] = {n:"Schlüssel zum Labyrinth des Minotorors",t:84,d:"Dieser wunderschöne Schlüssel ermöglicht euch, ins Labyrinth des Minotorors einzudringen. Aber was das Herauskommen angeht...",ep:13,g:7,l:1,wd:true,fm:true,w:1,p:100};
I.u[7925] = {n:"Kalyptusholz",t:38,d:"Aus diesem wohlriechenden Holz könnt ihr Häuser bauen, die selbst dann noch wohlig riechen, wenn ihre Bewohner es nicht tun. Bedauerlicherweise ist es nicht zur Unterwäschekonstruktion geeignet. Schade eigentlich.",ep:20,g:1,l:50,wd:true,fm:true,w:2,p:0};
I.u[7926] = {n:"Schlüssel zum Dungeon von Meister Rab",t:84,d:"Dieser Schlüssel erlaubt es euch, Meister Rab in Fleisch und Blut zu begegnen. Er wird euch sicherlich ein wenig Wasser und Käse anbieten.",ep:1,g:8,l:1,wd:true,fm:true,w:1,p:100};
I.u[7927] = {n:"Schlüssel zum Dungeon der Krachler",t:84,d:"Obschon etwas ramponiert, ist dieser Schlüssel unzerstörbar. Offensichtlich hat er bereits viele Türen geöffnet. Außerdem sagt man, er sei aus den Intimteilen eines Krachlers gefertigt. Wahrlich erschreckend!",ep:1,g:9,l:1,wd:true,fm:true,w:1,p:100};
I.u[7929] = {n:"Handbuch des Söldners von Astrub",t:25,d:"Das Handbuch des Söldners von Astrub wurde vom berühmten Igor Ant, dem Söldnerchef, geschrieben. Es ist die ideale Nachtlektüre all derer, die für Recht und Ordnung eintreten... oder sie mißbrauchen möchten.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:5};
I.u[7930] = {n:"Freunde finden und behalten",t:25,d:"Ratschläge und Tipps, um gute und treue Freunde zu finden. Geschrieben von Acidrik Magenspalter.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[7931] = {n:"\"Die Zeit der Drachen\" – Wiedergefundene Fragmente III",t:25,d:"Band III der Fragmente von der Geschichte der Welt, gefunden und überabeitet von Acidrik Magenspalter.",ep:1,g:19,l:1,wd:false,fm:true,w:1,u:true,p:50};
I.u[7932] = {n:"Schriftrolle der Miss Astrub",t:25,d:"Die dralle, kurvenreiche Miss Astrub des Jahres zeigt alle Facetten ihrer Verführungskünste, mit deren Hilfe sie vorher bereits die Jury bezirzt hat.",ep:1,g:9,l:1,wd:false,fm:true,w:1,u:true,p:100};
I.u[7934] = {n:"\"Wie finde ich meinen Weg\" – Ein Ratgeber",t:25,d:"Arpagnagrobis schrieb einst dieses Werk für all die jungen Abenteurer, die noch unerfahren in der Benutzung von Kompass und Zaap sind.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[7935] = {n:"Saphirbrosche",t:24,d:"Dieses Schmuckstück hat sich vor vielen Monaten einmal in eurem dichten Haar verfangen, ohne dass ihr es bemerkt hättet, bis es euch schließlich vor die Füße fiel. Eine darin eingravierte Inschrift besagt, diese Brosche könne als Schlüssel dienen, wenn sie mit anderen Broschen vereint würde. Wieder so eine dämliche Anpreisung, um wertlosen Modeschmuck loszuwerden?",ep:20,g:109,l:1,wd:true,fm:true,w:0,p:100};
I.u[7936] = {n:"Smaragdbrosche",t:24,d:"Dieses Schmuckstück hat sich vor vielen Monaten einmal in eurem dichten Haar verfangen, ohne dass ihr es bemerkt hättet, bis es euch schließlich vor die Füße fiel. Eine darin eingravierte Inschrift besagt, diese Brosche könne als Schlüssel dienen, wenn sie mit anderen Broschen vereint würde. Wieder so eine dämliche Anpreisung, um wertlosen Modeschmuck loszuwerden?",ep:20,g:110,l:1,wd:false,fm:true,w:0,p:100};
