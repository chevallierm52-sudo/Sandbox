I.u[7799] = {n:"Grillerpfeife",t:94,d:"Das funktioniert immer gut: bei einer Rast mitten in der Natur braucht ihr nur die Grillerpfeife zu zücken, kräftig hineinzublasen und schon kommt euer Reittier in vollem Galopp angerannt, schneller als ein ausgehungerter Wabbit, der eine Kawotte entdeckt.",ep:20,g:1,l:60,wd:true,fm:true,w:1,u:true,p:1000};
I.u[7800] = {n:"Entschädigungsbonbon der Weisen",t:28,d:"Dieses Bonbon erhöht eure Weisheit um 100 Punkte für die Dauer von 30 Kämpfen.",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7801] = {n:"Entschädigungsbonbon der Glücklichen",t:28,d:"Dieses Bonbon erhöht euren Filzwert um 100 Punkte für die Dauer von 30 Kämpfen.",ep:1,g:1,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[7802] = {n:"Bonbon der Weisen",t:42,d:"Dieses Bonbon erhöht eure Weisheit um 100 Punkte für die Dauer von 30 Kämpfen. \n(Warnung: Es sollte immer nur ein Bonbon eingenommen werden. Bei gleichzeitiger Einnahme mehrerer Bonbons wird sich ihre Wirkung nicht addieren.)",ep:1,g:136,l:1,wd:false,fm:true,w:1,c:"PO!7800",u:true,p:1};
