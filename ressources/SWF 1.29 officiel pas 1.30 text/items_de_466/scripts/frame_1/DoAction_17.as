I.u[8225] = {n:"Sandalen des roten Piepmatzes",t:11,d:"Diese Schuhe sind perfekt dazu geeignet, kleine, kriechende Kreaturen zu zertreten, die zwischen den Grashalmen herumkriechen. Aber passt auf, dass ihr nicht versehentlich Xelors oder Eniripsas mit ihnen erwischt.",ep:1,g:78,l:1,wd:true,fm:true,w:1,s:60,p:1};
