I.u[7939] = {n:"Handbuch des perfekten Rekruten von Brâkmar",t:25,d:"Dieses Buch beschreibt das harmonische, aber doch vielseitige und hochinteressante Leben eines jungen Rekruten von Brâkmar. Es wurde vom Drillmeister von Brâkmar, Oto Mustam, höchstpersönlich geschrieben.",ep:1,g:10,l:1,wd:false,fm:true,w:1,u:true,p:1};
