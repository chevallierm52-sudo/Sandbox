I.u[8188] = {n:"Bworky-Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt. Nur so ist es euch möglich, das Heiligtum der Vertrauten zu betreten.",ep:20,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[8211] = {n:"Ping",t:18,d:"Offensichtlich ist diese Kreatur entweder aus einem Zoo oder einer entfernten Insel entlaufen. Sie ist dafür bekannt, den im Kampf angerichteten Schaden ihres Trägers zu erhöhen. Ihre Besonderheit (die sie mit manchen Herrchen teilt) ist ihr nach verwesendem Fisch stinkender Atem. Drum ist es angeraten, ihr das Maul zu stopfen, doch müsst ihr das Material hierfür separat erwerben. Vorsicht, diese kleine Kreatur ist sehr eigen, sie frisst nur Fisch!",ep:3,g:38,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[8213] = {n:"Amulett des roten Piepmatzes",t:1,d:"Dieses Amulett scheint aus einem kleinen getrockneten Piepmatzkopf zu bestehen. Heutzutage gibt es wohl keine Grenze mehr, wie weit manche für gutes Aussehen zu gehen bereit sind.",ep:1,g:100,l:1,wd:true,fm:true,w:1,s:60,p:1};
