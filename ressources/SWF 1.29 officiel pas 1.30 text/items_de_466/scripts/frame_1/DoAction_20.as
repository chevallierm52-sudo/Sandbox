I.u[9366] = {n:"Tütüll",t:10,d:"Dieser rosa Tütüll ist einfach ein Traum! Gewebt aus feinster Urwolle und Schwammgespinst von Mopp passt er hervorragend zum Jahresabschlussfest der jüngsten Familiensprössin.",ep:22,g:148,l:49,wd:true,fm:true,w:5,p:300};
