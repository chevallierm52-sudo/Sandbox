I.u[9718] = {n:"Ultra-perfekter Seelenstein",t:83,d:"Dieser einzigartige Stein wurde speziell für eine Aufgabe geschaffen: das Einfangen der Seele des Krakamors. Das erklärt das seltsame Aussehen und auch den strengen Geruch...",ep:0,g:24,l:1,wd:false,fm:true,w:1,tw:true,c:"Qa=439",p:0};
