I.u[9548] = {n:"Wolken-Peiniger",t:114,d:"Diese furchtbare magische Waffe wurde vom berühmten Bastler Issering hergestellt. Sie kanalisiert die magischen Kräfte des Benutzers zu gebündelten Entladungen großer Macht im Rahmen neuer Zauberkräfte. Zudem verändert sie dessen Aussehen. Mit der Zeit wird der Peiniger schließlich zum einzigen Freund seines Besitzers, es sei denn dieser findet rechtzeitig die Kraft in sich, den Gegenstand wieder abzulegen.",ep:0,g:5,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
I.u[9549] = {n:"Hosenträgershorts des Paten",t:10,d:"Der Werbeslogan des Schneiders dieses Prunkstücks war: \"Selbst mitten in Äktschn, bietet die Hosenträger Atträktschn\". Das hat gewirkt! Man muss dazusagen, dass der Mann vor seiner Karriere als Schneider im ganzen Land für seine Dichter-Künste gefürchtet war.",ep:0,g:152,l:48,wd:true,fm:true,w:10,s:126,p:6175};
I.u[9550] = {n:"Standort des Lagers",t:24,d:"Merlaun hat euch den genauen Ort genannt, an welchem der Milizionär den Transgenesis-Zauber wirken wird. Nun solltet ihr euch wirklich beeilen, sonst ist es zu spät!",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9551] = {n:"Präpariertes Skorpiutkorn",t:24,d:"Diese Skorpiutkörner wurden präpariert, aber man merkt den Unterschied nicht. Das echte Problem ist, dass man den Unterschied zwischen diesen Körnen und Mohnsamen ganz klar sehen kann. Nur ein Idiot könnte davon täuschen lassen.",ep:0,g:405,l:1,wd:false,fm:true,w:0,p:1};
I.u[9552] = {n:"Geschenk: Schatten-Peiniger",t:89,d:"Beim Schütteln dieses Geschenkpaketes könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
