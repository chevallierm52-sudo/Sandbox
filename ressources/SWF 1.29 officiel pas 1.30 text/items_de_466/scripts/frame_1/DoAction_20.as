I.u[9652] = {n:"Papayo-Stirnband",t:16,d:"Es gibt kein besseres Stirnband, um eure Stirn zu kühlen, oder euch zum \"Papayo-Stil\" zu bekennen!",ep:0,g:236,l:48,wd:true,fm:true,w:10,s:129,p:6175};
I.u[9653] = {n:"Flügelmütze",t:16,d:"Die Flügel die auf diese Mütze genäht sind, schützen eure Öhrchen vor Beleidigungen, aber nur vor denen, die ihr selber ausstoßt.",ep:0,g:237,l:42,wd:true,fm:true,w:10,s:140,p:4825};
I.u[9654] = {n:"Papayo-Umhang",t:17,d:"Dieser Umhang wird die prallen Rundungen eures Hinterteils positiv hervorheben. Oder waren es die eures Buckels?",ep:0,g:165,l:48,wd:true,fm:true,w:10,s:129,p:6105};
I.u[9655] = {n:"Papayo-Sandalen",t:11,d:"Die Sohle dieser Sandalen wurde verstärkt, um auch gewichtigeren Papayos einen sicheren Tritt zu gewährleisten.",ep:0,g:132,l:49,wd:true,fm:true,w:10,s:129,p:6475};
I.u[9656] = {n:"Slumpenstiefel",t:11,d:"Mit den Rädern auf diesen Stiefeln könnt ihr mühelos die Treppenstufen hinunterkommen, aber erhöht dabei die Chance, euch die Knochen zu brechen. Es ist eure Wahl.",ep:0,g:133,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9657] = {n:"Pups-Stecken",t:4,d:"Wer hat es gewagt, diesen Stecken mit einem derart lächerlichen Namen auszustatten? Das weiß Niemand. Ihr hingegen, müsst ihn so nennen und wie ein Depp dastehen, wenn man euch nach seinem Namen fragt.",ep:0,g:82,l:42,wd:true,fm:true,w:10,an:12,e:[1,3,1,1,10,40,false,false],c:"CV>60&CW>30",s:140,p:4200};
I.u[9658] = {n:"Papayo-Amulett",t:1,d:"Bei diesem Amulett handelt es sich in Wirklichkeit um einen Blumenkranz, der um einen Faden herumgeflochten wurde. Von ihm geht ein magischer Geruch aus, der garantiert alle Fliegen und Mücken vertreibt.",ep:0,g:144,l:47,wd:true,fm:true,w:10,s:129,p:6000};
I.u[9659] = {n:"Slump-Kette",t:1,d:"Erala hat dieses Amulett seine ganze Kindheit über getragen. Keiner weiß so genau, was in ihm eingeschlossen ist.",ep:0,g:143,l:43,wd:true,fm:true,w:10,s:140,p:5025};
I.u[9660] = {n:"Slait-Umhang",t:17,d:"Zwei buschige Schwänze auf einmal! Da ist wohl ein Traum wahr geworden!",ep:0,g:166,l:47,wd:true,fm:true,w:10,s:128,p:5825};
I.u[9661] = {n:"Angora Maunzmiez - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[9662] = {n:"Slait-Ring",t:9,d:"Es heisst, dass Abenteurer aus bisher noch nicht geklärten Gründen diese Ringe sammeln sollen. Seltsam, diese Abenteurer.",ep:0,g:167,l:43,wd:true,fm:true,w:10,s:128,p:5100};
I.u[9663] = {n:"Slait-Ohren",t:16,d:"Diese fellüberwachsenen Ohren sind aerodynamischer, als sie auf dem ersten Blick erscheinen...",ep:0,g:238,l:49,wd:true,fm:true,w:10,s:128,p:6375};
