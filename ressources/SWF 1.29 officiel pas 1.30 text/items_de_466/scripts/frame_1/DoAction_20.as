I.u[9557] = {n:"Schlüssel zur Truhe",t:24,d:"Dieser Schlüssel öffnet die Truhe, die (jedenfalls behauptet das Terra Tibya) die Sumens-Statuen enthält.",ep:1,g:3,l:1,wd:false,fm:true,w:0,p:1};
I.u[9558] = {n:"Enttarnungstrank",t:14,d:"Mit diesem Trank könnt ihr alle unsichtbaren Charaktere in eurer Umgebung sichtbar machen.",ep:0,g:73,l:1,wd:false,fm:true,w:1,c:"Pg>23,3",u:true,p:1};
I.u[9559] = {n:"Kleine Notiz aus Bonta",t:24,d:"Auf diesem Zettel steht: Dämlicher Brâk, du bist nicht nur dumm und hässlich, sondern auch langsam und du stinkst. Selbst eine Bwork-Mama würde dich nicht als Schosstier haben wollen. Ich rate dir also, in deine stinkende Stadt zurückzukehren oder wenn du verrückt genug bist, dir die Statue aus dem Bonta-Turm zu holen.\nUnterzeichnet: ein schlauer Bonta.",ep:3,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9562] = {n:"Seltsamer Gegenstand",t:24,d:"Dieser seltsame Gegenstand ist wirklich sehr seltsam. Aber noch seltsamer ist das Gefühl, das ihr habt, es könne euch Zugang zu einem noch seltsameren Ort ganz in der Nähe verschaffen. Seltsam, nicht?",ep:0,g:69,l:1,wd:false,fm:true,w:0,p:1};
I.u[9563] = {n:"Haarbüschel eines Brâkmarsianers",t:24,d:"Dieses Haarbüschel wurde einer unbekannten Kreatur herausgerissen, die die Abzeichen von Brâkmar trug. Jetzt habt ihr den Beweis, dass es \"sie\" gibt.",ep:0,g:29,l:1,wd:false,fm:true,w:0,p:1};
I.u[9564] = {n:"Abzeichen eines Psychopathen",t:24,d:"Ihr habt dieses Abzeichen dem noch warmen Körper eines Brâk-Psychopathen abgenommen. Schämt ihr euch nicht, Tote zu bestehlen?",ep:0,g:76,l:1,wd:false,fm:true,w:0,p:1};
I.u[9565] = {n:"Abzeichen eines Mörders",t:24,d:"Ihr habt dieses Abzeichen dem noch warmen Körper eines Bonta-Mörders abgenommen. Schämt ihr euch nicht, Tote zu bestehlen?",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9566] = {n:"Schutz-Schild",t:82,d:"Gladis Ney war ein verarmter, heruntergekommener Schildschmied, bis ihm eines Nachts die Inspiration zu diesem Meisterwerk kam. Danach verkauften sich seine Schilde wie warme Semmeln.  \nVielleicht trug aber auch dazu bei, dass dieser angeblich \"hochmagische\" Schild ist ein zuverlässiger Schutz gegen scharfkantige, fliegende Kristallsplitter sein sollte. Beispielsweise gegen solche wie sie entstehen, wenn ein Kristall-Komet in großer Höhe vom Explosivpfeil einer Bogenschützen-Göttin getroffen wird. \nOb da etwas dran ist, weiss niemand, aber man geht schließlich immer besser auf Nummer sicher...",ep:0,g:34,l:1,wd:false,fm:true,w:1,p:5000};
I.u[9567] = {n:"Black Wab - Maske",t:16,d:"Diese Maske ist das perfekte Mittel, um euren langgehegten Traum des nächtlichen maskierten Rächers über den Dächern von Astrub endlich mal ganz offen ausleben zu können.",ep:0,g:235,l:49,wd:true,fm:true,w:10,s:127,p:6325};
I.u[9569] = {n:"Black Wab - Umhang",t:17,d:"Der kleine Bommel am Ende des Mantels ist als Staubfänger unübertroffen. Da er so klein ist, passt er sogar unter sonst unerreichbare Möbestücke. Doch vergesst ja nicht, den Bommel abzunehmen, bevor ihr euch auf einen längeren Spaziergang durch die Felder begebt!",ep:0,g:164,l:46,wd:true,fm:true,w:10,s:127,p:5600};
I.u[9570] = {n:"Sesanabolikum-Korn",t:58,d:"Dieses magietechnisch veränderte Korn vermehrt die Muskelmasse auf spektakuläre Art und Weise. Im Gegenzug verringert es auf ebenso spektakuläre Art und Weise die Gehirnmasse. Kein Wunder, dass es bei der Ernährung junger Iops eine große Rolle spielt.",ep:0,g:3,l:1,wd:false,fm:true,w:1,p:1};
I.u[9571] = {n:"Weichselcremetorte",t:15,d:"Diese Torte mit roten Früchten und Kirschmarmelade lässt einem das Wasser im Mund zusammenlaufen. Ansonsten nutzt sie zu nichts anderem.",ep:0,g:145,l:1,wd:false,fm:true,w:1,p:1};
I.u[9572] = {n:"Ein Geschenk für Frau Gertisorf",t:24,d:"Dieses Geschenk ist für Gerti Gertisorfs Mutter bestimmt. Es sieht so aus, als ob da ein kleines Vermögen drin wäre, das eure Ausrüstungskosten für Jahre im voraus decken könnte. Zu dumm, dass ihr nicht lange genug am Leben bleiben würdet, wolltet ihr auf die Idee kommen, es zu stehlen.",ep:0,g:742,l:1,wd:false,fm:true,w:0,p:1};
I.u[9573] = {n:"Rezeptur für das Sesanabolikum-Korn",t:24,d:"Diese Rezeptur ist nur einer Handvoll Alchemisten auf der ganzen Welt bekannt. Merlaun hat sich dennoch erboten, euch das Geheimnis zu verraten, da er es satt hat, ständig von euch gestört zu werden. \n7 Sesamkörner \n5 Pilzlinge \n1 Nichsotolla Hecht \nDamit die Zubereitung eines Nichsotolla-Hechts gelingt, braucht ihr einen Fischhändler, der euch 2 ausgenommene Hechte mit 7 Skorpiutkörnern, 2 Mojos des WuWulfs, 1 Konserviertes Crocodyll-Fleisch und 2 Kitsous Eingeweide zusammenmischt.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9574] = {n:"Rezeptur für Weichselcremetorte",t:24,d:"Der Bäcker Kelog Korflex ist für diese originelle Rezeptur verantwortlich. Da er gerne Leute beglückt, hat er euch das Geheimnis verraten. Aber Vorsicht! Die Weichselcremetorte fängt nach einer Stunde an zu schmelzen.  \n2 Biokatalysatränke\n5 Kirsch-Blob-Stücke\n3 Kirschen\n4 Erdbeergelee\n1 Walnuss-Öl\n2 Einheiten Kidoblut",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[9575] = {n:"Black Wab - Gürtel",t:10,d:"Je nachdem, ob ihr euch hinter ihm verstecken wollt, oder mit ihm glänzen möchtet, kann dieser praktische Gürtel links- oder rechts herum getragen werden.",ep:0,g:153,l:46,wd:true,fm:true,w:10,s:127,p:5600};
I.u[9576] = {n:"Black Wab - Stiefel",t:11,d:"Diese Stiefel aus dem Leder eines echten Black Wabbit - Hinterteils werden euch stets ein warmes Gefühl dabei geben, wenn ihr Monstern damit in den Allerwertesten tretet. Hach, ist das Abenteurerleben schön!",ep:0,g:131,l:47,wd:true,fm:true,w:10,s:127,p:5850};
I.u[9577] = {n:"Fluch von Hassang Trapick",t:30,d:"Da wird man glatt grün vor Neid!",ep:0,g:5,l:1,wd:false,fm:true,w:0,m:true,p:1};
