I.u[9706] = {n:"Schwert Foh\'hl\'",t:6,d:"Bei dieser Waffe handelt es sich um eine Shushette. Sie ist in der Lage, Seelenfragmente der Shushus von Rushu einzufangen, die von Monstern aufgenommen wurden. Diese können dann direkt auf der Waffe aufgebracht werden, um sie noch mächtiger zu machen.",ep:0,g:89,l:30,wd:true,fm:false,w:10,an:14,tw:true,e:[5,5,1,1,35,60,false,false],c:"CA>30&CV>30",p:300};
