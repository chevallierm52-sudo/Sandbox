I.u[9594] = {n:"Fresskügelchen des Paten",t:18,d:"Dieses Fresskügelchen ist nichts anderes, als ein hundgewöhnliches verkleidetes Fresskügelchen, welches sein Herrchen imitiert. Wie jedes Fresskügelchen wird es diesem ein Vergnügen sein, die Seelen seiner Artgenossen zu verspeisen.",ep:0,g:46,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[9595] = {n:"Fresskügelchen des Paten - Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für allemal fallen zu lassen.",ep:0,g:35,l:1,wd:true,fm:true,w:1,p:1};
I.u[9596] = {n:"Geschenk: Fresskügelchen des Paten",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als sei etwas Lebendiges darin. Also verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für die Aufzucht und Eniripsa-Pulver, um ihn zu pflegen.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[9597] = {n:"Fresskügelchen des Paten - Vergeistung",t:27,d:"Ihr wurdet in einen Geist verwandelt, um ins Innere des Heiligtums der Vertrauten gelangen zu können.",ep:0,g:3,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9598] = {n:"Tierheimszertifikat: Fresskügelchen des Paten",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
