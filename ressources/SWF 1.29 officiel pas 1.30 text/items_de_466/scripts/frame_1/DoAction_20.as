I.u[9222] = {n:"Durchdrungene unvollständige Klinge (Stufe 2)",t:24,d:"Oto hat euch diese eindrucksvoll aussehende Klinge ausgeliehen, damit es durch Lagrens Geschicklichkeit mit mehr Macht durchtränkt wird. Denkt nicht einmal im Traum dran, es zu stehlen, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und DAS wollt ihr ganz bestimmt NICHT.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9223] = {n:"Durchdrungene unvollständige Klinge (Stufe 3)",t:24,d:"Oto hat euch diese eindrucksvoll aussehende Klinge ausgeliehen, damit es durch Lagrens Geschicklichkeit mit mehr Macht durchtränkt wird. Denkt nicht einmal im Traum dran, es zu stehlen, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und DAS wollt ihr ganz bestimmt NICHT.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9224] = {n:"Durchdrungene unvollständige Klinge (Stufe 4)",t:24,d:"Oto hat euch diese eindrucksvoll aussehende Klinge ausgeliehen, damit es durch Lagrens Geschicklichkeit mit mehr Macht durchtränkt wird. Denkt nicht einmal im Traum dran, es zu stehlen, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und DAS wollt ihr ganz bestimmt NICHT.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9225] = {n:"Durchdrungene unvollständige Klinge (Stufe 5)",t:24,d:"Oto hat euch diese eindrucksvoll aussehende Klinge ausgeliehen, damit es durch Lagrens Geschicklichkeit mit mehr Macht durchtränkt wird. Denkt nicht einmal im Traum dran, es zu stehlen, denn es ist nicht nur nicht fertig, sondern es würde vor allem Otos Zorn auf euch ziehen und DAS wollt ihr ganz bestimmt NICHT.",ep:16,g:124,l:1,wd:false,fm:true,w:0,p:1};
I.u[9226] = {n:"Alptraum-Essenz",t:24,d:"Mit dieser Essenz imprägniert ihr Otos Schwert mit Macht.",ep:16,g:501,l:1,wd:false,fm:true,w:0,p:1};
I.u[9227] = {n:"Onivins Liste potentieller Ehekandidatinnen",t:24,d:"Diese Liste habt ihr von Satirev Onivin erhalten, damit ihr bei den folgenden Frauen von Astrub ein gutes Wort für ihn einlegen könnt: Nepra Lido, Enileda, Gwenolaz Barnumuze, Maskara, Kwuarzuah.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9228] = {n:"Brihannas Zeugenaussage",t:24,d:"Auf diesem Blatt Papier steht Brihannas Zeugenaussage.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9229] = {n:"Brihannas zwielichtige Zeugenaussage",t:24,d:"Auf diesem Blatt Papier steht Brihannas zwielichtige Zeugenaussage.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9231] = {n:"Moderwasser",t:24,d:"Man könnte glauben, dass dieser Eimer als Nachttopf eines Chef-Crocodylls gedient hat, aber dem ist nicht so. Das Moderwasser darin ist noch ekliger als Wasser aus den Bodenlosen Sümpfen. Naja, über den Inhalt des Eimers lässt sich noch spekulieren...",ep:6,g:46,l:1,wd:false,fm:true,w:0,p:1};
I.u[9232] = {n:"Gereinigtes Moderwasser",t:24,d:"Auch wenn ihr wisst, dass dieses Moderwasser gereinigt wurde, könnt ihr keinen Unterschied erkennen. Aus der Nähe riecht es sogar noch übler als vorher, was aber normal ist, schließlich seid ihr mit der Nase näher dran.",ep:16,g:46,l:1,wd:false,fm:true,w:0,p:1};
I.u[9233] = {n:"Lebending: Umhang",t:113,d:"Dieser polymorphe Gegenstand geht eine Symbiose mit anderen unbelebten Gegenständen ein, bevor ihm diese schließlich als Nahrung dienen. (Diesen lebendigen Umhang müsst ihr also mit anderen Umhängen füttern. Dabei könnt ihr ihm alle zwölf Stunden neue Nahrung geben.)",ep:1,g:149,l:1,wd:true,fm:false,w:1,p:1};
I.u[9234] = {n:"Lebending: Hut",t:113,d:"Dieser polymorphe Gegenstand geht eine Symbiose mit anderen unbelebten Gegenständen ein, bevor ihm diese schließlich als Nahrung dienen. (Diesen lebendigen Hut müsst ihr also mit anderen Hüten füttern. Dabei könnt ihr ihm alle zwölf Stunden neue Nahrung geben.)",ep:1,g:211,l:1,wd:true,fm:false,w:1,p:1};
I.u[9235] = {n:"Fragwürdige Version von Tim",t:24,d:"Dieser Brief besagt, dass ihr Sulsch Tim Sliglu Terpehs Version für unglaubwürdig haltet.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9236] = {n:"Glaubwürdige Version von Tim",t:24,d:"Dieser Brief besagt, dass ihr Sulsch Tim Sliglu Terpehs Version für glaubwürdig haltet.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9237] = {n:"Brihannas glaubwürdige Zeugenaussage",t:24,d:"Dieser Brief besagt, dass ihr Brihannas Zeugenaussage glaubwürdig findet, es sei denn es liegt nur daran, dass ihr ihre Pseudomusik toll findet.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9238] = {n:"Brihannas fragwürdige Zeugenaussage",t:24,d:"Dieser Brief besagt, dass ihr Brihannas Zeugenaussage fragwürdig findet, es sei denn es liegt nur daran, dass ihr nicht mögt, wie sie redet... oder singt.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9239] = {n:"Glaubwürdiger Gnireh",t:24,d:"In diesem Brief steht, dass ihr glaubt, dass Gnireh mit der Angelegenheit nichts zu tun hat. Nach Fisch zu müffeln hat also auch sein Gutes.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9240] = {n:"Gnireh als Komplize",t:24,d:"In diesem Brief steht, dass ihr glaubt, dass Gnireh tatsächlich das geheime Dokument in Sulsch Tim Sliglu Terpeh Tasche hineingeschoben hat oder aber es handelt sich um einen Racheakt wegen des schrecklichen Geruchs, der ihn umgibt.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9241] = {n:"Meinung zu Ungunsten von Sulsch Tim Sliglu Terpeh",t:24,d:"Dieser Brief ist eurer Meinung nach ein Hinweis darauf, dass sich Sulsch Tim Sliglu Terpeh des Verrats schuldig gemacht hat.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9242] = {n:"Meinung zu Gunsten von Sulsch Tim Sliglu Terpeh",t:24,d:"Dieser Brief ist eurer Meinung nach ein Hinweis darauf, dass Sulsch Tim Sliglu Terpeh unschuldig ist.",ep:16,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[9243] = {n:"Schuldiger Tim",t:24,d:"Dieser Brief besagt, dass ihr Sulsch Tim Sliglu Terpeh für schuldig befindet. Danathor ist mit eurer Entscheidung zufrieden.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9244] = {n:"Unschuldiger Tim",t:24,d:"Dieser Brief besagt, dass ihr Sulsch Tim Sliglu Terpeh für unschuldig befindet. Amayiro ist mit eurer Entscheidung zufrieden.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9245] = {n:"Eingestelltes Verfahren",t:24,d:"Dieser Brief zeigt an, dass ihr während Sulsch Tim Sliglu Terpehs Prozess nicht sehr überzeugend gewesen seid und somit das Verfahren eingestellt wurde. Erwartet bloß keinen Dank von Danathor oder Amayiro.",ep:16,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9247] = {n:"Schlüssel zum Pilz-Dungeon",t:84,d:"Dieser Schlüssel eröffnet euch den gefährlichen Pilz-Dungeon.",ep:13,g:247,l:1,wd:true,fm:true,w:1,p:1};
I.u[9248] = {n:"Schlüssel zum Blob-Dungeon",t:84,d:"Dieser Schlüssel ermöglicht euch den Zutritt zum Blob-Dungeon.",ep:5,g:248,l:1,wd:true,fm:true,w:1,p:1};
I.u[9249] = {n:"Teils des Kirschblob-Schlüssels",t:84,d:"Wenn ihr die übrigen Schlüsselteile findet, werdet ihr vielleicht Gelegenheit haben, einen Multiblob herauszufordern!",ep:5,g:250,l:1,wd:true,fm:true,w:1,p:1};
I.u[9250] = {n:"Teils des Apfelblob-Schlüssels",t:84,d:"Wenn ihr die übrigen Schlüsselteile findet, werdet ihr vielleicht Gelegenheit haben, einen Multiblob herauszufordern!",ep:5,g:251,l:1,wd:true,fm:true,w:1,p:1};
I.u[9251] = {n:"Teils des Kokosblob-Schlüssels",t:84,d:"Wenn ihr die übrigen Schlüsselteile findet, werdet ihr vielleicht Gelegenheit haben, einen Multiblob herauszufordern!",ep:5,g:252,l:1,wd:true,fm:true,w:1,p:1};
I.u[9252] = {n:"Teils des Indigoblob-Schlüssels",t:84,d:"Wenn ihr die übrigen Schlüsselteile findet, werdet ihr vielleicht Gelegenheit haben, einen Multiblob herauszufordern!",ep:5,g:249,l:1,wd:true,fm:true,w:1,p:1};
I.u[9253] = {n:"Tollwutstrank",t:24,d:"Domen hat vergessen, das Schild von diesem Trank zu entfernen. Sein Name verheißt nichts Gutes.",ep:16,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9254] = {n:"Schlüssel zum Unterschlupf des Multiblobs",t:84,d:"Mit diesem Schlüssel erhaltet ihr die Gelegenheit, einen Multiblob herauszufordern!",ep:5,g:253,l:1,wd:true,fm:true,w:1,p:1};
I.u[9255] = {n:"Lebending: Amulett",t:113,d:"Dieser polymorphe Gegenstand geht eine Symbiose mit anderen unbelebten Gegenständen ein, bevor ihm diese schließlich als Nahrung dienen. (Dieses lebendige Amulett müsst ihr also mit anderen Amuletten füttern. Dabei könnt ihr ihm alle zwölf Stunden neue Nahrung geben.)",ep:1,g:139,l:1,wd:true,fm:false,w:1,p:1};
I.u[9256] = {n:"Lebending: Ring",t:113,d:"Dieser polymorphe Gegenstand geht eine Symbiose mit anderen unbelebten Gegenständen ein, bevor ihm diese schließlich als Nahrung dienen. (Diesen lebendigen Ring müsst ihr also mit anderen Ringen füttern. Dabei könnt ihr ihm alle zwölf Stunden neue Nahrung geben.)",ep:1,g:161,l:1,wd:true,fm:false,w:1,p:1};
I.u[9257] = {n:"Schlafmittel",t:24,d:"Dieser Trank hat eine ganz besondere Eigenschaft: sobald er mit einem Lebensmittel in Verbindung kommt und man von diesem Lebensmittel isst, fällt man sofort in einen tiefen Schlaf. Jede Ähnlichkeit mit einem euch bereits bekanntem Trank ist rein zufällig.",ep:16,g:500,l:1,wd:false,fm:true,w:0,p:1};
I.u[9258] = {n:"Drohung des Wächters",t:24,d:"In diesem Brief erklärt der Gefängniswärter von Astrub  Zlepluaf, dass die Wächter Fangzähne haben und sie ihm diese in den Hals schlagen werden, wenn er sich nicht mit der Suppe beeilt.",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9259] = {n:"Zlepluafs Brief",t:24,d:"In diesem Brief erklärt Zlepluaf dem Gastwirt von Astrub, dass er krank ist und er euch an seiner Stelle schickt.",ep:1,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9260] = {n:"Abendsüppchen",t:24,d:"Diese Suppe ist für die Wachen des Gefängnis von Astrub bestimmt. Es ist Zeit, die Suppe noch etwas nachzuwürzen.",ep:1,g:728,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[9261] = {n:"Schlafsüppchen",t:24,d:"Ihr habt das Schlafmittel in die Suppe gegeben. Die Wachen werden tief und fest schlafen.",ep:1,g:728,l:1,wd:false,fm:true,w:0,p:1};
I.u[9262] = {n:"Gefängnisschlüssel von Astrub",t:24,d:"Dieser Schlüssel öffnet die Gefängniszelle  von Astrub.",ep:1,g:790,l:1,wd:false,fm:true,w:0,p:1};
I.u[9263] = {n:"Mykoknyden-Rinde",t:96,d:"Der Mykoknyde ist das traurige Ergebnis einer außer Kontrolle geratenen Astaknyden-Mykose. Diese Rinde solltet ihr also mit äußerster Vorsicht behandeln, insbesondere, wenn ihr euch durch die Wälder bewegt.",ep:23,g:109,l:113,wd:true,fm:true,w:1,p:10};
I.u[9264] = {n:"Briango Brularte",t:32,d:"Ihr müsst Briango Brulartes Waffen wiederbeschaffen und ihn anschließend bis zu Oto Mustam eskortieren.",ep:1,g:28,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9265] = {n:"Miteter",t:24,d:"Das sind die Miteter, die man manchmal auf Krachlerköpfen mit mangelnder Hygiene finden kann.",ep:5,g:727,l:1,wd:false,fm:true,w:0,p:1};
I.u[9266] = {n:"Königliches Geleefett",t:24,d:"Dieses Fett wurde von einem Königlichen Gelee gewonnen. Es handelt sich hierbei um eine unerlässliche Zutat für die Zusammenstellung eines Lähmungstranks.",ep:7,g:32,l:1,wd:false,fm:true,w:0,p:1};
I.u[9267] = {n:"Fungeten-Trompete",t:15,d:"Die Fungeten-Trompete ist nicht nur kulinarisch, sondern auch musikalisch ein Genuss. Leider hat sie sich weder in dem einen, noch in dem anderen Sinn in der Welt der Zwölf durchgesetzt.",ep:23,g:764,l:125,wd:true,fm:true,w:1,p:10};
I.u[9268] = {n:"Lichthammer ohne Geist",t:24,d:"Dieser Lichthammer scheint den Geist verloren zu haben, der ihm seine Macht verliehen hat. Deshalb sieht er recht unscheinbar aus.",ep:3,g:8,l:1,wd:false,fm:true,w:0,p:1};
I.u[9269] = {n:"Pilzkröt-Zunge",t:15,d:"Der Pilzkröt ist ein Pflanzenfresser. Das erklärt auch, warum er mit einer solchen Zunge ausgestattet ist.",ep:23,g:765,l:134,wd:true,fm:true,w:1,p:1};
I.u[9270] = {n:"Ersatzpuppe",t:24,d:"Eine Puppe die von Maskaras geschickten Händen angefertigt wurde, um die dem Lichtgeist verlorengegangene Puppe zu ersetzen.",ep:1,g:680,l:1,wd:false,fm:true,w:0,p:1};
I.u[9271] = {n:"Maskaras Versprechen",t:24,d:"Dieser schlichte Ring symbolisiert Maskaras Versprechen, mit euch Puppenstube zu spielen (und vor allem euer Püppchen zu sein) wenn sie kann. Damit ist dies also eines der kostbarsten Güter auf der Welt.",ep:1,g:730,l:1,wd:false,fm:true,w:0,p:1};
I.u[9272] = {n:"Kiste aus Bonta",t:24,d:"Ihr habt es gewagt, diese Kiste in eurem eigenen Ordensturm zu stehlen, um sie den Halsabschneidern zu übergeben, ohne zu wissen, was drin ist. Mit dieser Handlungsweise missbraucht ihr das Vertrauen, das der Ordensmeister in euch hegt.",ep:1,g:44,l:1,wd:false,fm:true,w:0,p:1};
I.u[9273] = {n:"",t:24,d:"",ep:2,g:55,l:1,wd:false,fm:true,w:0,p:1};
