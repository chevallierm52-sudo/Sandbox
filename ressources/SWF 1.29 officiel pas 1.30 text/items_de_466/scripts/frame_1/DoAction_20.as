I.u[9379] = {n:"Valenteeni-Schokolade",t:42,d:"Üblicherweise schenkt man dieses kleine Paket der Person, die man am Liebsten mag. Wenn es sich bei manchen Abenteurern dabei um sie selbst handelt, dürfen sie die Schokolade auch persönlich aufessen.",ep:1,g:3,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9380] = {n:"Einherz-Feenwerk",t:74,d:"Dieses originelle Feenwerk ermöglicht es euch, etwas mehr Liebe in diese harte und brutale Welt zu bringen. (Oder war es etwas mehr Härte in die Welt der Liebe?)",ep:1,g:32,l:1,wd:false,fm:true,w:1,ut:true,p:1};
I.u[9381] = {n:"Omniblob-Blume",t:35,d:"Der Omniblob ist dermaßen gefräßig, dass er sogar seine eigenen Blumen verschlingen würde. Allerdings findet er doch immer noch irgendeinen unvorsichtigen Abenteurer, der sich in seine Nähe wagt.",ep:5,g:7,l:50,wd:true,fm:true,w:1,p:1};
I.u[9382] = {n:"Bloblingsblume",t:35,d:"Dieses Blümchen wurde von einem Blobling abgerissen. Besser ist das wohl, wenn man bedenkt, dass dieser damit reichlich lächerlich aussah...",ep:5,g:8,l:40,wd:true,fm:true,w:1,p:1};
I.u[9383] = {n:"Trunkniblob-Wurzel",t:98,d:"Die überlangen Wurzeln des Trunkniblobs graben sich tief in den Boden, immer auf der Suche nach von Abenteurern vergrabenen Schätzen.",ep:5,g:1,l:40,wd:true,fm:true,w:1,p:1};
I.u[9384] = {n:"Blume des Königlichen Kirschblobs",t:35,d:"Wäre diese Blume nicht königlichen Ursprungs, so würdet ihr sie mit Sicherheit geradewegs auf den Kompost werfen.",ep:5,g:12,l:100,wd:true,fm:true,w:1,p:1};
I.u[9385] = {n:"Blume des Königlichen Kokosblobs",t:35,d:"Wäre diese Blume nicht königlichen Ursprungs, so würdet ihr sie mit Sicherheit geradewegs auf den Kompost werfen.",ep:5,g:9,l:100,wd:true,fm:true,w:1,p:1};
I.u[9386] = {n:"Blume des Königlichen Indigoblobs",t:35,d:"Wäre diese Blume nicht königlichen Ursprungs, so würdet ihr sie mit Sicherheit geradewegs auf den Kompost werfen.",ep:5,g:11,l:100,wd:true,fm:true,w:1,p:1};
I.u[9387] = {n:"Blume des Königlichen Apfelblobs",t:35,d:"Wäre diese Blume nicht königlichen Ursprungs, so würdet ihr sie mit Sicherheit geradewegs auf den Kompost werfen.",ep:5,g:10,l:100,wd:true,fm:true,w:1,p:1};
I.u[9388] = {n:"Blatt des Königlichen Blobs",t:36,d:"Getrocknet, gerollt und durch die Lungen inhaliert können die Blätter des Königlichen Multiblobs Halluzinationen und Anfälle von Paranoia auslösen. Mit zunehmendem Konsum legen sich diese Erscheinungen jedoch wieder.",ep:5,g:13,l:100,wd:true,fm:true,w:1,p:1};
I.u[9389] = {n:"Blatt des Königlichen Multiblobs",t:36,d:"Die Blätter des Königlichen Multiblobs ernähren sich von der Gehirnmasse, der sie entwachsen. Sie sind eben nicht allzu anspruchsvoll.",ep:5,g:14,l:150,wd:true,fm:true,w:1,p:1};
I.u[9391] = {n:"Blume des Königlichen Multiblobs",t:35,d:"Diese Blume befand sich lange Zeit im Gehirnkasten des Königlichen Multiblobs, wo sie dazu diente, dessen Gedächtnislücken zu stopfen.",ep:5,g:13,l:150,wd:true,fm:true,w:1,p:1};
I.u[9394] = {n:"Bloblingshütchen",t:16,d:"Dieses Hütchen ist die ideale Tarnung für alle, die gerne im Unterholz unterwegs sind. Sogar sein Geruch ist auf dieses Biotop abgestimmt.",ep:22,g:222,l:152,wd:true,fm:true,w:15,p:45782};
I.u[9395] = {n:"Königliche Bloprone",t:16,d:"Diese Kopfbedeckung schmückte lange Zeit das Haupt von Kuri, der Liebespriesterin, bis sie sie aus Gründen des guten Geschmacks ablegte.",ep:22,g:223,l:161,wd:true,fm:true,w:10,p:47750};
I.u[9396] = {n:"Zewouan-Ring",t:9,d:"Der Zewouan-Ring, in der alten Sprache der Lenalds auch als \"Zewouan-Ling\" bekannt, soll von Zauwon, einem finsteren Wabbit, in einem unter Feuer-Pandala gelegenen Vulkan geschmiedet worden sein...",ep:1,g:7,l:1,wd:false,fm:true,w:1,c:"PX=3|PX=5",p:1};
I.u[9398] = {n:"",t:24,d:"",ep:2,g:27,l:1,wd:false,fm:true,w:0,p:1};
I.u[9399] = {n:"",t:24,d:"",ep:16,g:61,l:1,wd:false,fm:true,w:0,p:1};
I.u[9400] = {n:"",t:24,d:"",ep:16,g:6,l:1,wd:false,fm:true,w:0,p:1};
I.u[9401] = {n:"Bworker-Haut",t:59,d:"Diese Haut hat sich durch alle gewonnenen und verlorenen Schlachten hinweg schadlos gehalten, und sämtlichen Unwettern getrotzt. Sie kann eben nicht aus ihrer Haut heraus.",ep:14,g:9,l:400,wd:true,fm:true,w:10,p:1};
I.u[9402] = {n:"Biefel",t:11,d:"Dank der kleinen Flügelchen am Ende dieser Pantoffeln werden eure Füße aktiv gekühlt und bleiben stehts luftig frisch. Allerdings werdet ihr mit ihnen leider an den Fressball-Meisterschaften nicht mehr zugelassen werden. Schade.",ep:1,g:128,l:34,wd:true,fm:true,w:5,s:112,p:3200};
I.u[9403] = {n:"Piekshammer",t:7,d:"Die kleinen Flügelchen machen diese Waffe leichter, so dass ihr sie schneller schwingen könnt. Manchmal, ganz selten, fliegt sie auch des nachts allein davon und macht sich einen Spaß daraus, euch mit einem kräftigem Schlag aus dem Tiefschlaf zu reißen.",ep:1,g:68,l:27,wd:true,fm:true,w:12,an:15,e:[10,4,1,1,45,50,false,false],c:"CI>17&CC>5",s:112,p:2100};
I.u[9404] = {n:"Bzzz-Cape",t:17,d:"Der Stachel am Ende des Umhangs hat zwar den Nachteil, dass ihr euch nirgends mehr hinsetzen könnt, jedoch wird auch niemand mehr versuchen, euch den Hintern zu versohlen!",ep:1,g:155,l:33,wd:true,fm:true,w:5,s:112,p:3000};
I.u[9405] = {n:"Sombieno",t:16,d:"Passt auf, wo ihr diesen Hut tragt, sonst droht die Fliegenklatsche...",ep:1,g:224,l:37,wd:true,fm:true,w:9,s:112,p:3825};
I.u[9406] = {n:"Piggeldis Lauscherlis",t:16,d:"Mit dieser Kopfbedeckung aus frisch verarbeitetem Material werdet ihr schnell Freunde unter den Schweinepriestern gewinnen. Das kann euch nur zugute kommen, denn in den Weiten der amaknischen Lande werdet ihr ganz sicher auch einmal auf Gesellschaft angewiesen sein.",ep:1,g:225,l:36,wd:true,fm:true,w:2,s:113,p:3600};
I.u[9407] = {n:"Schlingelwutz-Cape",t:17,d:"Es soll Leute geben, die den Namen dieses Umhangs vehement gegen jene verteidigen, die da behaupten, er sei falsch geschrieben. Wie dem auch sei - fest steht, dass dieser Umhang keineswegs dazu geeignet ist, irgendwelche Flaschen zu öffnen, noch sich in andere Dinge hineinzubohren.",ep:1,g:156,l:37,wd:true,fm:true,w:3,s:113,p:3800};
I.u[9408] = {n:"Schink\'n\'Ring",t:9,d:"Mit diesem Ring am Finger ähnelt ihr einem kleinen Schweinio. Passt also auf, dass ihr nicht die falschen Freunde anzieht!",ep:1,g:162,l:40,wd:true,fm:true,w:3,s:113,p:500};
I.u[9409] = {n:"Speckgürtel",t:10,d:"Vorsicht vor Neidern, denn dieser Ringelschwanz ist einfach unwiderstehlich!",ep:1,g:149,l:39,wd:true,fm:true,w:1,s:113,p:4225};
I.u[9410] = {n:"Ostwald-Hut",t:16,d:"Der Ostwaldhut mag zwar weniger modern sein als der Clint Easthut, doch dafür unterstreicht er noch besser eure Eitelkeit.",ep:1,g:226,l:40,wd:true,fm:true,w:25,s:114,p:1000};
I.u[9411] = {n:"Ostwald-Mantel",t:17,d:"Dieser Mantel wird euch sicher vor Sonnenbrand schützen. Doch Vorsicht wegen der Länge. Nicht bei allen Abenteurern reicht er bis zum Boden...",ep:1,g:157,l:36,wd:true,fm:true,w:10,s:114,p:6500};
I.u[9412] = {n:"Ostwald-Gürtel",t:10,d:"Die Schleuder dient nur rein dekorativen Zwecken. Aber vielleicht reicht das ja, solltest du auf deinem Weg einer Bande von Wegelagerern begegnen.",ep:1,g:150,l:32,wd:true,fm:true,w:10,s:114,p:3000};
I.u[9413] = {n:"Ostwald-Stiefel",t:11,d:"Dank der Sporen an diesen Stiefeln könnt ihr euren Dracotruter zu größerer Eile antreiben, oder aber ihm aus Versehen bei vollem Galopp den Todesstoß versetzen...",ep:1,g:129,l:30,wd:true,fm:true,w:10,s:114,p:2700};
I.u[9414] = {n:"Zitrynder",t:16,d:"Diese ausgehöhlte Riesenzitrone lässt sich problemlos über den Kopf stülpen. Die Kerne brauchen dann nur noch ein Plätzchen in eurem Schädel. Kein Problem, also!",ep:1,g:227,l:30,wd:true,fm:true,w:9,s:115,p:2600};
I.u[9415] = {n:"Zitrantel",t:17,d:"Dieser Mantel wurde aus verschiedenen Rindenstücken von Zitrusfrüchten hergestellt. Darum hält er stets frisch und kühlt, bloß im Dunkeln leuchten tut er noch nicht.",ep:1,g:158,l:30,wd:true,fm:true,w:8,s:115,p:2525};
I.u[9416] = {n:"Zitring",t:9,d:"Sollte euch euer Mineralwässerchen ein mal zu fade erscheinen, braucht ihr lediglich diesen Ring hineinzuhalten und euren Finger etwas zu schütteln. Damit erhaltet ihr ein wunderbares Erfrischungsgetränk mit dem Geschmack sonniger Zitronen, und ggf. Blutorangen. (Letzteres, falls euch der Finger dabei abfällt. Aber gut, man kann eben nicht alles haben.)",ep:1,g:163,l:20,wd:true,fm:true,w:4,s:115,p:1300};
I.u[9417] = {n:"Schlürfstock",t:4,d:"Der Schlürfstock ist genau das Richtige für alle, die auf ihre Gegner einschlagen und gleichzeitig ihre Blutreserven aufstocken wollen.",ep:1,g:81,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",s:115,p:2900};
I.u[9418] = {n:"Kristallmütze",t:16,d:"Der Nächste, der versucht, euch unfreiwillig den Kopf zu frisieren, wird sich wohl einen Zinken aus seinem Kamm brechen.",ep:1,g:228,l:22,wd:false,fm:true,w:12,s:125,p:1525};
I.u[9451] = {n:"Kristallmantel",t:17,d:"Dieses beeindruckende Stück Kristall lässt sich überraschend bequem als Mantel tragen. Es macht euch vielleicht nicht stärker, aber dafür kann es wohl passieren, dass Monster, die euch fressen wollen, elend an diesem Mantel ersticken.",ep:1,g:159,l:21,wd:false,fm:true,w:10,s:125,p:1400};
I.u[9452] = {n:"Kristallring",t:9,d:"Noch nie habt ihr so strahlend und begehrenswert ausgesehen, wie mit diesem Ring am Finger.",ep:1,g:164,l:30,wd:false,fm:true,w:4,s:125,p:2600};
I.u[9453] = {n:"Kristallgürtel",t:10,d:"Wenn ihr diesen Gürtel um die Hüften tragt, so wird es aus Angst um seine Finger niemand mehr wagen, euch zu nahe zu kommen.",ep:1,g:151,l:48,wd:false,fm:true,w:30,s:125,p:6075};
I.u[9454] = {n:"Pom-Pompösamulett",t:1,d:"Sowohl den Jüngsten, als auch den Ältesten wird dieses Amulett als Sabberlätzchen gute Dienste leisten.",ep:1,g:140,l:27,wd:false,fm:true,w:5,s:124,p:2200};
I.u[9455] = {n:"Pom-Pompöser Ring des Pösen",t:9,d:"Dieser Ring sieht selbst dann gut aus, wenn er am großen Zeh getragen wird. Das könnte von Vorteil sein, weil er nämlich ganz pöse stinkt...",ep:1,g:165,l:30,wd:false,fm:true,w:4,s:124,p:2600};
I.u[9456] = {n:"Pom-Pompöser Umhang",t:17,d:"Dieser Umhang ist einfach unfehlbar, um die Aufmerksamkeit der Allgemeinheit auf die Wohlgeformtheit eures Hinterteils zu lenken.",ep:1,g:160,l:33,wd:false,fm:true,w:5,s:124,p:3075};
I.u[9457] = {n:"Pom-Pompöser Hut",t:16,d:"Dieser Hut verströmt einen derart starken Dämonenrosengeruch, dass selbst die Flöhe auf eurem Kopf und in euren Ohren Reißaus nehmen müssen.",ep:1,g:229,l:33,wd:false,fm:true,w:5,s:124,p:3000};
I.u[9458] = {n:"",t:24,d:"",ep:16,g:3,l:1,wd:false,fm:true,w:0,p:1};
I.u[9459] = {n:"Weißnachtsmann-Wunschzettel",t:24,d:"Ihr habt es verpasst, dem Weißnachtsmann einen Wunschzettel zu schreiben. Hier habt ihr nun eine Vorlage. Ihr solltet dankbar dafür sein!",ep:1,g:41,l:1,wd:false,fm:true,w:0,p:0};
I.u[9460] = {n:"Pi-Säckchen-Zäpfchen",t:24,d:"Ihr seid wahrlich Ungeheuer! Aus diesem Zäpfchen wird nun niemals mehr ein Pi-Säckchen werden! Schämt euch!",ep:1,g:123,l:1,wd:false,fm:true,w:0,p:0};
I.u[9461] = {n:"Kimbo-Perrücke",t:16,d:"Diese Perrücke fristete lange Zeit ihr Dasein unter dem Kopfkissen des Kimbo, wo er sie schamhaft versteckte. Sie ist aus dem Haar eines jungen Knaben gefertigt, der den Kimbo einst mit seinem entrückten Lächeln bezauberte. Möglicherweise ist sie an ein paar Stellen noch etwas zerknautscht, aber das werdet ihr schon in den Griff bekommen.",ep:22,g:230,l:196,wd:true,fm:true,w:10,p:60000};
I.u[9462] = {n:"",t:24,d:"",ep:5,g:807,l:1,wd:false,fm:true,w:0,p:1};
I.u[9463] = {n:"Pom-Pompöses Amulett",t:1,d:"Die Pompompösität dieses Amuletts beeindruckt die gesamte amaknische Moskitopopulation, die sich angesichts seiner Aura entsprechend demütig fernhält. (Möglicherweise liegt dieses für Moskito untypische Verhalten allerdings auch am Geruch, welcher von ihm ausströmt...)",ep:23,g:141,l:189,wd:true,fm:true,w:10,s:107,p:58000};
I.u[9464] = {n:"Krakamulett",t:1,d:"Ein Furcht erregendes Stück, dieses Amulett. In früheren Zeiten, als es noch lebendig war, wollte es die Welt erobern. Jetzt ist es an eurem Hals gelandet, das arme Ding...",ep:22,g:142,l:194,wd:true,fm:true,w:30,s:97,p:58411};
I.u[9465] = {n:"",t:76,d:"",ep:0,g:20,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9466] = {n:"",t:24,d:"",ep:14,g:737,l:1,wd:false,fm:true,w:0,p:1};
I.u[9467] = {n:"",t:24,d:"",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9468] = {n:"Seltsame Schaufel",t:8,d:"Die Seltsame Schaufel hat die Angewohnheit, euch eure Lebenskraft und eure Jugend zu rauben, euch eure wertvollen Körpersäfte zu verunreinigen und eure leckeren Troolrollen vom Teller zu stibitzen.",ep:22,g:51,l:191,wd:true,fm:true,w:10,an:16,e:[5,4,1,1,35,50,false,false],c:"CC>450",p:58401};
I.u[9469] = {n:"Erregender Degen",t:6,d:"Der erregende Degen erregt vor allem Eines: eine heftige Mykose, sobald er die Eingeweide eurer Gegner erreicht.",ep:23,g:85,l:184,wd:true,fm:true,w:10,an:14,e:[10,4,1,1,50,50,false,false],c:"CC>300&CA>300",p:58456};
I.u[9471] = {n:"Valenteeni-Hut",t:16,d:"Valenteenis, Valenteenas, hört, hört! Dieser elegante und biedere Hut ist das perfekte Signal für euch, die ihr auf der Suche nach den Freuden der Liebe seid. Denn er kann ausschließlich von unvermählten Abenteurerinnen und Abenteurern getragen werden. Drum wisst ihr immer, wem ihr euer Herz öffnen könnt, ohne den herben Schmerz der Aussichtslosigkeit fürchten zu müssen.",ep:1,g:231,l:1,wd:false,fm:true,w:1,c:"PR=0",p:1};
I.u[9472] = {n:"Passionsfrucht-Shigekax",t:42,d:"Dieses süße und cremige Bonbon wird für seine aphrodisierende Wirkung geschätzt und ist somit das ideale Geschenk für den oder die Liebste(n).",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,ut:true,p:1};
I.u[9473] = {n:"Herzchenballon",t:94,d:"Beschreibung",ep:0,g:14,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9474] = {n:"Erhabener Seelenstein des Hasardeurs",t:83,d:"Diese Rune gibt euch eine geringe Chance, schier unglaublich mächtige Seelen einzufangen...",ep:0,g:17,l:1,wd:false,fm:true,w:1,tw:true,p:23000};
I.u[9475] = {n:"Erhabener Seelenstein",t:83,d:"Diese Rune gibt euch eine Chance, schier unglaublich mächtige Seelen einzufangen...",ep:0,g:16,l:1,wd:false,fm:true,w:1,tw:true,p:50000};
I.u[9476] = {n:"Erhabener glücklicher Seelenstein",t:83,d:"Diese Rune gibt euch eine gute Chance, schier unglaublich mächtige Seelen einzufangen...",ep:0,g:18,l:1,wd:false,fm:true,w:1,tw:true,p:75000};
I.u[9477] = {n:"",t:14,d:"",ep:0,g:6,l:10,wd:false,fm:true,w:1,c:"Ps=1|Ps=2|Ps=3",u:true,p:1};
I.u[9478] = {n:"",t:14,d:"",ep:0,g:1,l:10,wd:false,fm:true,w:1,c:"PX=4|PX=5",u:true,p:1};
I.u[9479] = {n:"Posh-Mütze",t:16,d:"Jetzt heißt es nur noch, den Nagel auf den Kopf treffen...",ep:1,g:232,l:45,wd:true,fm:true,w:23,s:123,p:1000};
I.u[9480] = {n:"Posh-Mantel",t:17,d:"Mit diesem hübschen Fadenkreuz auf eurem Umhang haben Crâ-Bogenschützen keine Entschuldigung mehr, wenn sie an euch vorbeischießen!",ep:1,g:161,l:33,wd:true,fm:true,w:10,s:123,p:3000};
I.u[9481] = {n:"Posh-Schild",t:82,d:"Der Nagel in diesem Schild kann auch als Nahkampfwaffe eingesetzt werden, wenn es wieder einmal darum geht, aufgeblasenen Gegner den Wind aus den Segeln zu nehmen.",ep:1,g:36,l:1,wd:true,fm:true,w:1,s:123,p:1};
I.u[9482] = {n:"Zika-Schild",t:82,d:"Wenn ihr befürchten müsst, eure Freunde durch euer monströses Aussehen zu ängstigen, dann kommt dieser Schild gerade wie gerufen, um euch hinter ihm zu verstecken.",ep:1,g:37,l:1,wd:true,fm:true,w:1,s:122,p:1};
I.u[9483] = {n:"Schild Wondaroll",t:82,d:"Dieser Schild ist der ganze Stolz der jungen Iops, welche von ihren Schulmeistern erhaltene Belohnungsbildchen aneinander reihen, um ihre Freunde damit zu beeindrucken.",ep:1,g:38,l:1,wd:true,fm:true,w:1,p:1};
I.u[9484] = {n:"Geschiegerter Tilt",t:82,d:"Dieser Schild schützt den Träger zwar nicht sehr wirkungsvoll vor Schlägen, aber davor sehr gut vor Gespenstern.",ep:1,g:39,l:1,wd:true,fm:true,w:1,p:1};
I.u[9485] = {n:"Zikadumhang",t:17,d:"Die 3 Kugeln, welche diesen Umhang schmücken sind mit extra schweren Gewichten ausgestattet. Jetzt müsstet ihr nur noch kreiseln können, wie ein Derwisch, dann könntet ihr eure Gegner nach allen Regeln der Kunst aus dem Weg räumen.",ep:1,g:162,l:30,wd:true,fm:true,w:10,s:122,p:2500};
I.u[9486] = {n:"Zikadohut",t:16,d:"Egal, ob mit oder ohne diesen Hut - ihr werdet immer wie ein Narr dastehen. Doch mit dem Zikadohut habt ihr wenigstens eine Ausrede zur Hand.",ep:1,g:233,l:33,wd:true,fm:true,w:10,s:122,p:3075};
I.u[9487] = {n:"Zertifikat über den Gesinnungswechsel",t:24,d:"Dieses Zertifikat hat euch Morry Gähn gegeben. Es enthält eure persönlichen Daten und bescheinigt euren Gesinnungswechsel.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9488] = {n:"Register von Bonta",t:24,d:"Dieses Register wird von Morry Gähn geführt und enthält zahlreiche Dokumente. Darunter auch eines, welches erklärt, wie man Bonta wird. Dieses Formular müsst ihr ausfüllen.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9489] = {n:"Register von Brâkmar",t:24,d:"Dieses Register wird von Morry Gähn geführt und enthält zahlreiche Dokumente. Darunter auch eines, welches erklärt, wie man Brâk wird. Dieses Formular müsst ihr ausfüllen.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9490] = {n:"Ordenszertifikat Nr. 5",t:24,d:"Dieses Zertifikat bescheinigt, dass ihr einem Orden angehört. Um diesen zu wechseln, müsst ihr nach Erhaltsdatum des Zertifikats sieben Tage warten. Ihr könnt natürlich euer Fähnchen nach dem Wind drehen, aber wir wollen\'s doch nicht übertreiben.",ep:16,g:33,l:1,wd:false,fm:true,w:0,p:1};
I.u[9491] = {n:"Fluch: Rosarotundzuckersüß",t:30,d:"Nun seht ihr die Welt wie durch eine rosarote Brille. Alles ist gut, bloß euch ist übel.",ep:1,g:2,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[9492] = {n:"Geschenk: Biefeln",t:89,d:"Wenn ihr dieses Geschenkpaket schüttelt, könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
