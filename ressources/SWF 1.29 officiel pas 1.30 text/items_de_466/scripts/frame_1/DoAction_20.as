I.u[9523] = {n:"Super Söldnermissions-Belohnung",t:14,d:"Diese super Schriftrolle dokumentiert, dass ihr eine tolle Belohnung für euer Engagement im Laufe vieler Missionen bei den Söldnern verdient habt.",ep:0,g:6,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[9524] = {n:"Geschenk: Geschiegerter Tilt",t:89,d:"Wenn ihr dieses Geschenkpaket schüttelt, könnt ihr hören, dass sich etwas darin bewegt. Vielleicht haben sich ja dieses eine Mal die Götter keinen schlechten Scherz mit euch erlaubt?",ep:1,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9525] = {n:"Geschenkpaket: Valenteeni-Tag",t:89,d:"Dieses Geschenkpaket enthält ein Erste-Hilfe-Kit für Wagnisse im Namen der Liebe.",ep:1,g:4,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[9526] = {n:"Merkzettel über Drohungen",t:24,d:"Ihr habt euch notiert, dass ihr Astrubianer nicht bedrohen dürft, wenn sich Sicherheitssöldner in der Nähe befinden.",ep:0,g:50,l:1,wd:false,fm:true,w:0,p:1};
I.u[9527] = {n:"Pulver von eingewachsenen Zehennägel",t:24,d:"Pulver von eingewachsenen Zehennägel, die einst von Enutrof-Füssen stammten. Auch nach so langer Zeit bleibt der Käsefußgeruch präsent. So wie\'s aussieht, wurdet ihr kräftig über\'s Ohr gehauen.",ep:1,g:37,l:1,wd:false,fm:true,w:0,p:1};
I.u[9528] = {n:"Lears Amulett",t:24,d:"Dieses mächtige Amulett gehörte einst dem verschollenen Ok-Kultisten Lear. Ihm wird nachgesagt, er könne Verbindung mit Kreaturen aus anderen Dimensionen aufnehmen und die Seelen von Inkarnationen klonen. Zudem soll er sogar die Kunst der Selbst-Wiedererweckung beherrschen, was praktisch sein kann, wenn mal kein Priester in der Nähe ist.",ep:9,g:48,l:1,wd:false,fm:true,w:0,p:1};
I.u[9529] = {n:"Trank der erzwungenen Wiedererweckung",t:24,d:"Es kann manchmal vorkommen, dass eine Seele nicht auferstehen kann oder will. Zu diesem Zweck wird dann dieser Trank eingesetzt. Dadurch wird die Seele wieder in den ursprünglichen Körper hineingezwungen, ob sie will oder nicht.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9530] = {n:"Verzauberte Dichs-Fischlein Angelrute",t:24,d:"Mit ein wenig Glück werdet ihr mit dieser Angelrute eine Brabbelzunge von einem Dichs-Fischlein erhalten.",ep:0,g:739,l:1,wd:false,fm:true,w:0,p:1};
I.u[9531] = {n:"Brabbelzunge",t:24,d:"Dieses seltsame Organ findet manchmal bei der Brabbelzungenmethode Anwendung.\nDiese heimtückische Methode besteht darin, jemandem dazu zu bringen, eine Brabbelzunge zu schlucken, wonach das Opfer anfängt, zu reden und dabei wild in alle Richtungen gestikuliert und herumzuckt, was es sehr ermüdet.\nInteressant ist die Nebenwirkung, sobald das Opfer müde wird: Es hält die erste Person, die ins Blickfeld kommt für den allerbesten Freund oder Freundin und brabbelt so schön einfacher irgendwelche Informationen aus.",ep:1,g:740,l:1,wd:false,fm:true,w:0,p:1};
I.u[9532] = {n:"Sumens-Statue",t:24,d:"Es ist eine der Statuen, die Maimane Sumens geschenkt hat und die Gut und Böse der Menschheit symbolisieren. Sie verdankt ihr Aussehen einer Verzauberung Sumens, der sie vor allen gierigen Händen schützen wollte.\nEs stellen sich jedoch zwei Fragen: Repräsentiert diese Statue das Gute oder das Böse? Und vor Allem: warum dieses alberne äußere Erscheinungsbild?",ep:14,g:738,l:1,wd:false,fm:true,w:0,p:1};
I.u[9533] = {n:"Verführerischer Seelenstein",t:24,d:"Vom Meister des Ordens des Eitrigen Auges höchstpersönlich verzaubert, hat dieser Seelenstein die Fähigkeit andere Seelen zu verführen, die sich dann leichter auf freiwilliger Basis einfangen lassen.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9534] = {n:"Seelenstein von Terra Tibya",t:24,d:"Dieser Seelenstein enthält die Seele des Enutrofs Terra Tibya. Ihr solltet euch gut um ihn kümmern, ansonsten endet ihr selbst noch im Inneren des Steins.",ep:2,g:732,l:1,wd:false,fm:true,w:0,p:1};
I.u[9535] = {n:"Trank der Transgenese",t:24,d:"Richtig angewendet vermag dieser Trank das Wachstum von Getreide enorm zu beschleunigen, durch Veränderung der Genstruktur. Gerüchteweise sollen seltsame Nebenwirkungen daraus resultieren, aber pssst! Die Verbraucher sind noch nicht reif für diese Art von Informationen. Für das Gelingen müssen zwei Bauern und zwei Alchimisten zusammenarbeiten.",ep:0,g:2,l:1,wd:false,fm:true,w:0,p:1};
I.u[9536] = {n:"Schriftrolle der Transgenese",t:24,d:"Diese Schriftrolle aktiviert die Wirkung des Tranks der Transgenese auf dem Getreide, genauer gesagt, Hafer.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[9537] = {n:"Surazals Segen",t:24,d:"Dieses Buch enthält nicht nur verrückte Geschichten über wandelnde Tote, sondern beschreibt das Ritual, mit dem man eine Seele dazu zwingen kann, in seinen Körper zurückzukehren.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[9538] = {n:"Trank der Erinnerung: Gedächtnisaktivierung",t:24,d:"Mit diesem Trank kann man sich eine Erinnerung wachrufen, die das Gedächtnis dummerweise vergessen hat.",ep:0,g:82,l:1,wd:false,fm:true,w:0,p:1};
I.u[9539] = {n:"Abzeichen des Anführers der Renegaten",t:24,d:"Ihr habt dieses Abzeichen von einem Bonta-Renegaten, der es nicht verdiente.",ep:0,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[9540] = {n:"Patentierter Umhang des Paten",t:17,d:"Dieser patentierte Umhang  wird euch mit Sicherheit einmal den Hals retten, wenn nicht sogar ein tiefer gelegenes Körperteil...",ep:0,g:163,l:48,wd:true,fm:true,w:10,s:126,p:6200};
I.u[9541] = {n:"Borsalino des Paten",t:16,d:"Dieser originelle Hut verleiht euch die nötige Selbstsicherheit für eure Rolle als Paten. Darum solltet ihr ihn besser zu jeder Tages- und Nachtzeit auf dem Kopf tragen!",ep:0,g:234,l:43,wd:true,fm:true,w:10,s:126,p:5100};
I.u[9542] = {n:"Lackschuhe des Paten",t:11,d:"Diese Schuhe glänzen, was das Zeug hält! Und das selbst dann, wenn die Schuhe bereits völlig abgenutzt sind. Toll, um Gegner zu blenden, bevor sie die Schuhe per Tritt an den Schädel gedonnert bekommen!",ep:0,g:130,l:40,wd:true,fm:true,w:10,s:126,p:4450};
I.u[9543] = {n:"Protzring des Paten",t:9,d:"Dieser schwere Goldring verleiht euren Ohrfeigen gleich viel mehr Gewicht und euren Streicheleinheiten mehr Stil.",ep:0,g:166,l:40,wd:true,fm:true,w:10,s:126,p:0};
I.u[9544] = {n:"Schatten-Peiniger",t:114,d:"Diese furchtbare magische Waffe wurde vom berühmten Bastler Issering hergestellt. Sie kanalisiert die magischen Kräfte des Benutzers zu gebündelten Entladungen großer Macht im Rahmen neuer Zauberkräfte. Zudem verändert sie dessen Aussehen. Mit der Zeit wird der Peiniger schließlich zum einzigen Freund seines Besitzers, es sei denn dieser findet rechtzeitig die Kraft in sich, den Gegenstand wieder abzulegen.",ep:0,g:1,l:30,wd:true,fm:false,w:10,an:1,e:[5,6,2,4,50,50,false,false],p:1};
