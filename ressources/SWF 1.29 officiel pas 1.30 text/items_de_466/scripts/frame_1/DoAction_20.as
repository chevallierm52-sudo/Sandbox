I.u[9667] = {n:"Slait-Stiefel",t:11,d:"Dank dieser Stiefel kann der berüchtige Slait auch über Parkett rennen, ohne es mit seinen Krallen zu beschädigen. Wie praktisch!",ep:0,g:134,l:43,wd:true,fm:true,w:10,s:128,p:5050};
