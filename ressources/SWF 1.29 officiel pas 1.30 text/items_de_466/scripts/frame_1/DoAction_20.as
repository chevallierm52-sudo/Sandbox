I.u[9277] = {n:"Schamorchel-Auge",t:109,d:"Der Schamorchel hat die störende Angewohnheit, sich mit seinem Stab über die Wimpern zu streichen. Dabei verliert er meist ein Auge. Schlimmer ist es natürlich, wenn es ihn am Hals juckt.",ep:23,g:587,l:152,wd:true,fm:true,w:1,p:1};
I.u[9278] = {n:"Bipilz-Lamelle",t:15,d:"Der Bipilz hat 2 Beine, 2 Arme, und 2 Köpfe. Das heißt, er ist gleich doppelt so dumm wie andere Gattungsgenossen...",ep:23,g:766,l:144,wd:true,fm:true,w:1,p:1};
I.u[9279] = {n:"Hieblingsgeifer",t:15,d:"Er ist etwas klebrig, aber dennoch faszinierend vielseitig zu verwenden. Man kann mit ihm sowohl Waffen ölen, als auch Gladiatorenrücken entzücken.",ep:23,g:45,l:149,wd:true,fm:true,w:1,p:1};
I.u[9280] = {n:"Stinkelingstachel",t:15,d:"Zwar trägt der Stinkeling lediglich 4 Stacheln auf seinem Haupt, doch sind diese ziemlich kräftig.",ep:23,g:40,l:900,wd:true,fm:true,w:1,p:1};
I.u[9281] = {n:"Stinkelings Hutstück",t:15,d:"Dies ist ein Stück vom Hut des Stinkelings. Möge es euch viel Freude bereiten!",ep:23,g:41,l:900,wd:true,fm:true,w:1,p:1};
