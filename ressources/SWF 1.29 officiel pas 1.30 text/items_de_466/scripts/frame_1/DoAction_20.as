I.u[9701] = {n:"Halluzinogener Pilz",t:24,d:"Dieser von den geschickten und erfahrenen Händen des Maiar Thirithis manipulierte Pilz enthält ein starkes Halluzinogen, das die Vision der Welt völlig verändert, wenn ihr es einnehmt. Daher mit Vorsicht zu genießen.",ep:0,g:743,l:1,wd:false,fm:true,w:0,p:1};
