I.u[9697] = {n:"Rezeptur für eine Creme zur spontanen Regenerierung",t:24,d:"Ihr habt diese Rezeptur von Elya Wood gestohlen, schämt ihr euch nicht? Anscheinend nein. Dumm gelaufen für euch, dass sie in einer euch unbekannten Sprache geschrieben ist, sowas Blödes aber auch. Es gibt also doch noch Gerechtigkeit auf diese Welt.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:0};
