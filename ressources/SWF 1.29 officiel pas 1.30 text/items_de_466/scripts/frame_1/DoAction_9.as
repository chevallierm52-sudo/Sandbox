I.u[4381] = {n:"Amulett Argie",t:1,d:"Dieses seltsame Amulett erlaubt es dem Träger, selbst mitten im Kampf ein erholsames Schläfchen zu machen. So wie ein Feca es beispielweise im Kampf gegen einen Krachler machen würde.",ep:14,g:54,l:82,wd:true,fm:true,w:10,p:17200};
I.u[4382] = {n:"Eispick",t:6,d:"Dieses Kurzschwert mit der kalten und spitzen Klinge weckt die innersten Instinkte bei seinem Träger. Binnen kürzester Zeit wird damit jede Bewegung, so alltäglich sie auch sein mag, als heimtückiger Tiefschlag von hinten ausgeführt. Ihr solltet wirklich mal ein wenig Willenskraft einsetzen, um dieser Klinge wenigstens ein wenig zu widerstehen.",ep:13,g:14,l:85,wd:true,fm:true,w:1,an:14,e:[10,4,1,1,30,50,false,false],c:"CS>80",p:1};
