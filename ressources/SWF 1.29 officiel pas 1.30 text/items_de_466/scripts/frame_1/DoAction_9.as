I.u[4241] = {n:"Die Rosarote Klaue",t:6,d:"Dieser unüblich gefärbte Krummsäbel dient dazu, den Gegner weichzuklopfen, bevor man daran ging, selbiges mit seinem Fleische vorzunehmen. Genau so, wie es ein junges Ecaflippchen machen würde. Die perfekte Färbung dieses Säbels wird dadurch erhalten, dass die Klinge seit vielen Jahrhunderten in die Innereien der besiegten Gegner getaucht wird.",ep:14,g:41,l:100,wd:true,fm:true,w:20,an:14,tw:true,e:[10,5,1,1,50,40,false,false],c:"CS>150",p:10000};
I.u[4242] = {n:"Klingenfächer",t:6,d:"Ursprünglich war dieser Fächer nur ein nützliches Hilfsmittel, um sich Luft zuzufächeln. Dazu wurde er einfach stetig auf und ab bewegt. Nachdem jedoch dabei einige Köpfe zu Boden gerollt waren, wurde entschieden, in Zukunft kein Metall mehr für diese Art von Gegenstand zu benutzen.",ep:12,g:24,l:75,wd:true,fm:true,w:20,an:14,tw:true,e:[5,5,1,1,40,40,false,false],c:"CW>40&CV>40",p:7500};
