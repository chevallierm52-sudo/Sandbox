I.u[3203] = {n:"Tribal-Armband",t:9,d:"Die Herkunft dieses Armbandes ist sehr vage. Man geht davon aus, dass es von einem sehr gefürchteten, herbivoren und Farn rupfenden Sadidas-Kaniball-Stamm der schlimmsten Sorte abstammt. Aber vielleicht ist das auch nur eine frei erfundene Geschichte, um kleine Sadidas zu erschrecken.",ep:11,g:49,l:51,wd:true,fm:true,w:5,p:7000};
I.u[3204] = {n:"Bonta-Gürtel",t:10,d:"Dieser Gürtel ist gegenwärtig sehr in Mode in den Straßen von Bonta. Die Verzierung an der Schnalle trägt den Stempel eines bekannten Schustergeheimbundes.",ep:3,g:37,l:53,wd:true,fm:true,w:10,c:"Ps=1",p:7400};
I.u[3205] = {n:"Brâkschurz",t:10,d:"Dieser Gürtel ist gegenwärtig sehr in Mode in den Abwasserkanälen von Brâkmar. Wer wie ein harter Bursche erscheinen will, wird nichts Besseres finden. Wer allerdings ein harter Bursche sein will, sollte sich nach etwas Besserem umschauen.",ep:13,g:38,l:53,wd:true,fm:true,w:10,c:"Ps=2",p:7500};
I.u[3206] = {n:"Xerbo",t:10,d:"Dieser wunderschöne Gegenstand wurde den fingerfertigsten Kriegern verliehen. Er trägt sich auf der bloßen Haut und nur im Winter.",ep:13,g:39,l:67,wd:true,fm:true,w:7,p:13000};
I.u[3207] = {n:"Stiefel der Genugtuung",t:11,d:"Diese Stiefel sind so bequem und so leicht, dass man gar nicht genug tun kann, um sie zu bekommen. Einzig eure Gegner könnten unzufrieden sein, wenn ihr ihnen die Sohlen eurer Stiefel eingehend zu begutachten gebt. Aber selbst das ist noch nicht gesagt.",ep:1,g:38,l:17,wd:true,fm:true,w:10,p:950};
I.u[3208] = {n:"Schlüpfer des Bwork-Bogenschützen",t:56,d:"Bwork-Schützen haben die lästige Angewohnheit, ihren Schlüpfer zum Verstauen ihrer Pfeile zu verwenden. Vielleicht denken viele deshalb, dass die Pfeile vergiftet seien. Gut möglich.",ep:1,g:649,l:23,wd:true,fm:true,w:1,p:1};
I.u[3209] = {n:"Bwork Magus-Skalp",t:15,d:"Schon in jungen Jahren versuchen Enutrofs einen Bwork Magus-Skalp zu erjagen, um ihre beginnende Glatze zu verdecken. Damit sehen sie zwar noch seltsamer aus als sonst, doch verdeckt der Bworkgestank wenigstens ihren Alkoholatem.",ep:4,g:653,l:23,wd:true,fm:true,w:1,p:1};
