I.u[3356] = {n:"Die Schaufel des Dudes",t:8,d:"Es gibt nichts Kurzweiligeres, als mit dieser goldenen Schaufel Maulwurfshügel aufzugraben, um zu entspannen. Ist es euch egal, dass sich alle Welt über euren Stil und Geschmack lustig macht? Ist es euch egal, dass ihr völlig planlos durchs Leben geht? Dann ist die Schaufel des Dudes genau das Richtige für euch!",ep:13,g:27,l:52,wd:true,fm:true,w:10,an:16,e:[5,5,1,1,50,50,false,false],c:"CC>60&CV>40",p:7500};
I.u[3357] = {n:"Fingerklopfer",t:7,d:"Wenn in Amakna junge Schüler nicht brav waren oder nicht lernen wollen, dann schlägt man ihnen mit diesem Hammer auf die Finger. Dieses Gerät hier hat hauptsächlich Iop-Finger auf dem Gewissen.",ep:2,g:29,l:49,wd:true,fm:true,w:20,an:15,e:[5,5,1,1,50,50,false,false],c:"CS>30&CI>30",p:6300};
