I.u[10518] = {n:"Rezeptur fürs Kletterseil",t:24,d:"Ein Bastler kann aus folgenden Ressourcen ein Kletterseil basteln: 30 Einheiten Hanf, 5 Seidenfäden und 1 unzerreißbaren Faden.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10519] = {n:"Rezeptur für Unreine Sudelsteine",t:24,d:"Ein Alchemist kann aus folgenden Zutaten verschiedenfarbige Unreine Sudelsteine herstellen: \nBlau: 2 Blaubeergelee, 1 Zetermaid-Trank. \nGelb: 2 Zitronengelee, 1 Zetermaid-Trank. \nGrün: 2 Minzgelee, 1 Zetermaid-Trank.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10520] = {n:"Rezeptur für Sudelsteine",t:24,d:"Ein Bergmann kann mit folgenden Zutaten verschiedenfarbige Sudelsteine herstellen: \nBlau: 10 blaue Unreine Sudelsteine, 10 Einheiten Wasser. \nGelb: 10 gelbe Unreine Sudelsteine, 10 Einheiten Wasser. \nGrün: 10 grüne Unreine Sudelsteine, 10 Einheiten Wasser.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10521] = {n:"Rezeptur zur Herstellung des magischen finsteren Färbemittels",t:24,d:"Ein Alchemist kann mit folgenden Zutaten ein magisches finsteres Färbemittel zusammenbrauen: 1 Magisches dunkles Färbemittel, 1 Schattenastaknydenrinde, 1 Schattenastaknydenwurzel, 1 Knospe eines Schattenastaknyden und 1 Marks Knochen",ep:0,g:74,l:1,wd:false,fm:true,w:0,p:1};
I.u[10522] = {n:"Rezeptur für ein Bombusfass",t:24,d:"Ein Bastler kann dieses Fass mit 4 Brettern aus Bombussholz und 3 Ebonit bauen.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
