I.u[10657] = {n:"Ogrinenjäger",t:18,d:"Dieser seltsame Vertraute ist eine Kreuzung der besten Trüffelsucher in ganz Amakna. Mit seinem enormen Rüssel spürt er Ogrinen auf, auch wenn diese unter Wasser versteckt sind. Otomaï hat mehrere Jahre dazu gebraucht, um diese Kreatur zu züchten. Man erzählt sich, er benutze ihn um einen seiner Fehler auszubügeln, um etwas wiederzufinden, das ihm abhanden gekommen oder weggelaufen ist. So genau weiss das Keiner... Die Suche nach Ogrinen bedarf eines so physiologisch komplexen  und energieraubenden Prozesses, dass diese Kreatur sich zum Wachsen von Monsterseelen ernähren muss. Sie wurde auf den Stränden der Insel Otomaï aufgezogen und verschlingt nur Seelen der Geschöpfe, die dort leben.",ep:0,g:56,l:1,wd:true,fm:true,w:10,p:1};
I.u[10658] = {n:"Ogrinenjäger-Geist",t:90,d:"Dieser Geist hat noch nicht vollständig die Welt der Lebenden verlassen. Also liegt es nun an euch ihn wiederzubeleben... oder aber ihn feige ein für alle Male fallen zu lassen.",ep:0,g:56,l:1,wd:true,fm:true,w:1,p:1};
I.u[10659] = {n:"Ei des Ogrinenjägers",t:72,d:"Dieses merkwürdige Ei enthält eine kleine magische Kreatur. Darum sollte es warm aufbewahrt werden. Wer weiß, was daraus entschlüpfen wird...",ep:0,g:206,l:1,wd:false,fm:true,w:0,u:true,p:1};
I.u[10660] = {n:"Geschenkpaket: Ei des Ogrinenjägers",t:89,d:"Wenn ihr dieses Geschenk kräftig schüttelt, werdet ihr merken, dass es nicht leer ist. Vielleicht haben sich die Götter dieses eine Mal keinen Scherz mit euch erlaubt.",ep:0,g:42,l:1,wd:false,fm:true,w:1,u:true,p:1};
I.u[10661] = {n:"Tierheimzertifikat: Ogrinenjäger",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[10662] = {n:"Pa Pro-Rune",t:78,d:"Diese Rune erlaubt es euch, leichter seltene Gegenstände zu finden.",ep:0,g:36,l:20,wd:true,fm:true,w:1,p:10};
I.u[10663] = {n:"Maultasche mit Fresssackgehacktem",t:33,d:"Man muss schon einen soliden Magen haben, um diese Maultasche runter zu schlucken. Das verwendete Fresssackfleisch ist nicht immer vom Frischsten und verleiht dem Ganzen einen Geschmack wie Austern mit Schokolade. Eine echte Delikatesse für Bworks.",ep:0,g:71,l:20,wd:true,fm:true,w:1,c:"Sc=1",u:true,ut:true,p:1};
I.u[10664] = {n:"Astakeichel",t:94,d:"Man muss nur leicht dran reiben und schon kommt der in der Eichel gefangene Astaknyde herausgeschossen.",ep:0,g:15,l:1,wd:true,fm:true,w:0,c:"Sc=2&(PB=4|PB=22|PB=33|PB=169|PB=170|PB=486|PB=168)",u:true,p:0};
I.u[10665] = {n:"Jorbaks Truhe",t:94,d:"Jorbak hat sein ganzes Vermögen verloren. Was mag nur in dieser seltsamen Truhe stecken? Wenn ihr\'s wissen wollt, macht sie auf.",ep:0,g:16,l:1,wd:true,fm:true,w:1,u:true,p:0};
I.u[10667] = {n:"Jorbaks Fußabdruck",t:24,d:"Ihr habt es geschafft, euch zu merken, wann der Geist Jorbaks sichtbar sein wird. Kein Grund zur Überstürzung.",ep:0,g:251,l:1,wd:true,fm:true,w:0,p:0};
I.u[10668] = {n:"Jorbak im Glück",t:28,d:"Für einige Zeit werdet ihr von Jorbaks Glück profitieren.",ep:0,g:16,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10669] = {n:"Muffelkrötentrank",t:12,d:"Das geschieht euch recht, einfach drauflos zu trinken!",ep:0,g:18,l:1,wd:true,fm:true,w:1,c:"Sc=4",u:true,p:0};
I.u[10670] = {n:"Parziweichs Schriftrolle",t:94,d:"Die Anweisungen auf dieser Schriftrolle sind so einfach nachzuvollziehen wie ein Wabbit-Kochrezept und verraten ein bezauberndes Geheimnis.",ep:0,g:17,l:1,wd:true,fm:true,w:1,c:"Sc=5",u:true,p:0};
I.u[10673] = {n:"MmmMmmMmmm-Trank",t:12,d:"HmmMmmMmmm",ep:0,g:191,l:1,wd:true,fm:false,w:1,c:"Sc=7",u:true,ut:true,p:1};
