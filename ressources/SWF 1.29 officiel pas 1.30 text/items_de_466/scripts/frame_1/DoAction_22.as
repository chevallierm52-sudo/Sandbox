I.u[10544] = {n:"Gelutine",t:18,d:"Diese Kreatur von einem anderen Stern wurde von seinem früheren Herrchen so abgerichtet, dass es nur Monster der Blob-Familie auffrisst. Das erklärt vielleicht seine überraschende Erscheinung oder seinen Blob-Atem.",ep:0,g:55,l:1,wd:true,fm:true,w:10,p:1};
I.u[10552] = {n:"Yagonnett",t:16,d:"Diese seltsame Kopfbedeckung wird eure Ohren vor plötzlichen Kälteeinbrüchen und vor schlechten Witzen eurer Freunde schützen.",ep:0,g:245,l:41,wd:true,fm:true,w:10,s:134,p:4525};
I.u[10553] = {n:"Tolot-Helm",t:16,d:"Nur ein Fressballer kann auf die bescheuerte Idee kommen, sich als Tofu zu verkleiden, um Gegenspieler zu erschrecken. Vielleicht war es aber auch nur ein schlecht getarnter Versuch, Aufmerksamkeit zu erheischen.",ep:0,g:252,l:41,wd:false,fm:true,w:10,s:142,p:4550};
I.u[10554] = {n:"Rota Ikuzim-Helm",t:16,d:"Mit den im Helm integrierten Augengläser seht ihr rot, wann immer ihr wollt. Allerdings auch, wenn ihr nicht wollt...",ep:0,g:253,l:41,wd:false,fm:true,w:10,s:143,p:4550};
I.u[10555] = {n:"FC Humpelstilz-Schild",t:82,d:"Dieser imposante Schild hat bei zahlreichen Fressballspielen überall Spuren und Kratzer davongetragen. Dieser Veteran unter den Schilden wird euch demnach bei Fressballspielen eine gute Hilfe sein, zu echten Kämpfen taugt er jedoch nicht mehr.",ep:0,g:54,l:1,wd:false,fm:true,w:10,c:"PP>0",s:142,p:1};
I.u[10556] = {n:"Arsenal Roter Fresssack-Schild",t:82,d:"Dieser imposante Schild bekräftigt das Überlegenheitsgefühl der Jugend von heute. Viel heiße Luft und nichts dahinter. Darum wird er euch bei einem echten Kampf nicht von Nutzen sein, es sei denn jemand würde euch mit einem Fressball beschießen.",ep:0,g:53,l:1,wd:false,fm:true,w:10,c:"PP>0",s:143,p:1};
I.u[10557] = {n:"FC Humpelstilz-Lederhandschuh",t:9,d:"Diesem Lederhandschuh sieht man jahrelangen Missbrauch durch das Auffangen runder Bälle oder anderer wollbedeckter kugelrunder Dinge an.",ep:0,g:176,l:43,wd:true,fm:true,w:10,s:142,p:4500};
I.u[10558] = {n:"Arsenal Roter Fresssack-Lederhandschuh",t:9,d:"Mit diesem tollen Lederhandschuh könnt ihr gleich einem verrückten Hund dem Bällchen nachrennen und euch wie einen wahrer Fressballspieler aufführen, ohne euch dafür schämen zu müssen.",ep:0,g:177,l:43,wd:true,fm:true,w:10,s:143,p:4500};
I.u[10559] = {n:"Tolot-Gürtel",t:10,d:"Der Gürtel ist so konzipiert, dass er die Hauptwucht beim stürmischen Aufprall muskelbepackter Fressballspieler auffängt. Doch lässt er sich auch gut als Rettungsring verwenden, sollte mal ein Bad genommen werden. Wer käme nur auf einen so abwegigen Gedanken?",ep:0,g:159,l:41,wd:false,fm:true,w:10,s:142,p:4600};
I.u[10560] = {n:"Mounu-Gürtel",t:10,d:"Dieser Gürtel beweist einmal mehr, dass Fressball und Fairplay nicht immer einher gehen. Darum schützt dieser Gürtel vor tief ausgeführten Tiefschlägen. Das macht ihn auch ideal für das Training des jungen Sramnachwuchses...",ep:0,g:160,l:41,wd:false,fm:true,w:10,s:143,p:4600};
I.u[10561] = {n:"FC Humpelstilz-Stiefel",t:11,d:"Diese Stiefel haben bereits einiges erlebt, das merkt man sofort. Mit ihnen könnt ihr euch als echten Fressballer feiern lassen und so tun, als könntet ihr auf eine lange Karriere zurückblicken.",ep:0,g:144,l:42,wd:false,fm:true,w:10,s:142,p:4825};
I.u[10562] = {n:"Arsenal Roter Fresssack-Stiefel",t:11,d:"Diese modernen Stiefel haben schon mal als einen fressballfanatischen jungen Abenteurer begeistert. Zudem erleichtern sie das Hinfallen. Ideal für den Amateursport, wo eine der ersten Übungen darin besteht, spektakulär zu Boden zu stürzen und es so aussehen zu lassen, als wäre man gefoult worden.",ep:0,g:145,l:42,wd:false,fm:true,w:10,s:143,p:4825};
I.u[10563] = {n:"Magische Kristallkugel",t:50,d:"Diese Kugel ermöglicht die Neuverteilung der Attributspunkte. Nur die Klassenmeister in den jeweiligen Klassentempeln wissen, wie die Kugel einzusetzen ist.",ep:0,g:460,l:1,wd:true,fm:true,w:100,p:1000};
I.u[10564] = {n:"Magisches Kristallkugelpaket",t:89,d:"Dieses Paket enthält eine sorgfältig eingewickelte Kristallkugel.",ep:0,g:42,l:1,wd:true,fm:true,w:0,u:true,p:1};
