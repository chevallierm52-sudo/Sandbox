I.u[10196] = {n:"Standort der Ecaflip-Fliese",t:24,d:"Griesgrahm zufolge befindet sich die Ecaflip-Fliese in der Mitte der Minotoror-Insel.\nNur ein Ecaflip, der mit Ecaflips Glück und einer Münze des Schatzes von Badoul ausgestattet ist, kann die Höhle öffnen, indem er sich auf die Fliese stellt.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10197] = {n:"Standort der Xélor-Fliese",t:24,d:"Kwuarzuahr hat die Xélor-Fliese irgendwo im Dorf Feudala abgelegt.\nNur ein Xelor, der mit Xélors Vergangenheit und einer Prise Zeitpulver ausgestattet ist, kann die Höhle öffnen, indem er sich auf die Fliese stellt.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10198] = {n:"Standort der Enutrof-Fliese",t:24,d:"Annapelles Worten zufolge hat ihr Mann Slah Zieg die Enutrof-Fliese nordöstlich ihres Hauses vergraben und zwar zu Füssen einer Dracotruter-Statue.\nNur ein Enutrof der mit Enutrofs Erinnering und einem Goldzahn des Krachlers ausgestattet ist, kann die Höhle öffnen, indem er sich auf die Fliese stellt.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10199] = {n:"Notizen über Nosilla Budois\' Vision",t:24,d:"Der Lichtgeist Nosilla Budois hat angeblich den Wald von Amakna und die Berge durch- und überquert, um sich auf dem Friedhof der Verdammten niederzulassen. Gorilla sprach ebenso von einer Stadt, in der sich ein Alchemistenhaus befindet, vor der eine Eniripsa steht und einer Sadida-Puppenmacherin. Ihr habt euch ihre Beschreibungen aufgeschrieben.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10200] = {n:"Lichtgeist",t:32,d:"Dieser Lichtgeist leuchtet nicht sehr hell. Es sieht so aus, als wäre durch das Herausreißen aus dem Hammer sein Glanz abgestumpft. Ihr beeilt euch besser und bringt ihn schnell zu Tück\'n\'Stück.",ep:0,g:26,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10201] = {n:"Keiler der Ebenen",t:32,d:"Es scheint so, als ob dieser Keiler der Ebenen entweder zu fett oder krank oder beides zu sein scheint. Wie dem auch sei, er will euch partout nicht folgen und ihr müsst ihn mit Gewalt hinter euch herziehen, was euch erheblich verlangsamt. Außerdem scheint er euch bei geringstem Anlass verlassen zu wollen.",ep:0,g:27,l:1,wd:false,fm:true,w:0,m:true,p:1};
I.u[10202] = {n:"Gestohlenes Zeitfragment",t:24,d:"Dieses Zeitfragment wurde von den Stundenglasdämonen aus Xélors Uhrwerk gestohlen. Es ist besser, man gibt nicht damit an, einen solchen Gegenstand zu besitzen, es sei denn man will sich den Zorn der Götter auf sich ziehen.",ep:0,g:801,l:1,wd:false,fm:true,w:0,p:1};
I.u[10203] = {n:"Zerissener Auftrag für eine Mission",t:24,d:"Auf diesem zerrissenen Stück Papier steht der letzte Satz eines Auftrags für eine Mission: \"...und bringt ihn zum Verhören in den Kerker von Brâkmar.\" \nDas wurde anscheinend vor Kurzem verloren.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10204] = {n:"Liste für Dardondakals Unterschlupf",t:24,d:"Um Zugang zum Unterschlupf Dardondakals zu bekommen, das im Wald von Cania versteckt liegt, benötigt ihr: \n10 Weiße Dracheischalen,  5 Eier eines weißen Dracheis und 1 Haut eines Dracheikriegers.",ep:0,g:55,l:1,wd:false,fm:true,w:0,p:1};
I.u[10205] = {n:"Psychin",t:24,d:"Wer hätte gedacht, dass ein Psychin das einst einem Drachen gehörte, ein so gewöhnliches Aussehen haben könnte? Ihr vielleicht?",ep:0,g:46,l:1,wd:false,fm:true,w:0,p:1};
I.u[10206] = {n:"Heiliges Wasser",t:24,d:"Dieses Wasser stammt aus einer unterirdischen Quelle von Akwadala. Die Alkoholdämpfe die sie ständig ausströmt bestätigen ihre sakrale Natur.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[10207] = {n:"Schlüsselbund",t:24,d:"Die Magie dieses Schlüsselbundes erschöpft sich rasch und lädt sich erst nach einer Woche wieder auf aber mit ihr könnt ihr alle Dungeon-Schlösser bezwingen.",ep:0,g:774,l:1,wd:false,fm:true,w:0,p:0};
I.u[10208] = {n:"Pandawa Elixir",t:12,d:"Ein kräftiger Schluck und schon werdet ihr in euren Klassentempel teleportiert. Bekannte Nebenwirkungen: Bauchweh, Schwiegermutter zu Besuch, Haarausfall, Mundgeruch, lose Schnürsenkel, ständig rote Ampel.",ep:0,g:153,l:1,wd:true,fm:true,w:1,c:"PG=12",u:true,p:0};
