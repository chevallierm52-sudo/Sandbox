I.u[10271] = {n:"Sag Fnesens Liste",t:24,d:"Sag Fnes hat euch die nötigen Ressourcen genannt, damit euch ein Schneider eine Sag-Maske machen kann. Ihr braucht:\n6 Unsichtbares Gewebe, 2 Rutil, 20 Hanffasern, 1 Kokosschale des Bitoufs der Ebenen, 50 schwarze Fresssäckchen-Leder.",ep:0,g:41,l:1,wd:false,fm:true,w:0,p:1};
I.u[10272] = {n:"Sags Maske",t:15,d:"Sag war ein einfallsreicher Enutrof, dem nichts unmöglich schien. Diese von ihm erfundene Maske gestattete es ihm, in der verschmutzten Luft in den tiefsten Minen Brâkmars zu überleben. Allerdings hatte er dabei vergessen, dass diese Maske nicht vor Vulkanausbrüchen schützt.",ep:0,g:772,l:1,wd:false,fm:true,w:1,p:1};
I.u[10274] = {n:"Sacrieurs Tränen",t:24,d:"Dieses Wasser stammt aus einem Becken, das aus den Tränen der Göttin Sacrieur entstanden ist. Von seinem Ursprung mal abgesehen, unterschiedet es sich bis auf seinen leichten Salzgeschmack nicht von gewöhnlichem Wasser.",ep:0,g:764,l:1,wd:false,fm:true,w:0,p:1};
I.u[10275] = {n:"Pivipiepen",t:24,d:"Hinter diesem Namen verbergen sich harte Kämpfe. Während zahlreicher Schlachten angeshüft, kann man diese Münzen bei den Sackers in der Miliz der zwei rivalisierenden Städte eintauschen.",ep:0,g:766,l:1,wd:true,fm:true,w:0,p:0};
I.u[10276] = {n:"Passierschein für die Insel Eiland Där",t:15,d:"Mit diesem Passierschein könnt ihr einmal auf die Insel Eiland Där hin-und zurück. Er ist aber nur bei Mos Konaut in der Bucht von Cania gültig.",ep:0,g:770,l:1,wd:false,fm:true,w:1,p:1};
I.u[10277] = {n:"Danathors Anweisungen",t:24,d:"Dies sind die Anweisungen Danathors zum Schmieden einer Schimmernden Morgendämmerung.\nDie Passierscheine für Eiland Där bei Mos Konaut in der Bucht von Cania benutzen.\nEinen Eiskristall zum Herstellen eines Gefriertranks besorgen und es mit einem Psychin in einer Höhle benutzen, um einen Erinnerungssplitter herzustellen.\nSich ins Innere der Insel begeben um die Schimmernde Morgendämmerung zu schmieden. \nHelfen muss ein Mitglied aus dem Orden des Rettenden Geistes (mit Titel Adept der Schriften oder höher), ein Xélor der den Zauberspruch \"Uhrwerk\" und ein Sacrieur der den Zauberspruch \"Fliegendes Schwert\" beherrscht.\nFolgende Handwerksmeister werden benötigt (eine Person kann mehrere Berufe ansammeln): Juwelier und Schmuckmagier, Steckenschnitzer und Schnitzmagier für Stecken, Dolchschmied und Schmiedmagier für Dolche, Alchemist.\n5 Diamanten, 1 Geschliffener Kristall, 1 Perlmutt,  1 Elementartrank: Tsunami benutzen.\nDanathor die \"Schimmernde Morgendämmerung\" bringen.",ep:0,g:26,l:1,wd:false,fm:true,w:0,p:1};
I.u[10278] = {n:"Geistreiche Gemme des Crocabulia",t:85,d:"Als Sieger-Trophäe beim Duell gewonnen, ist in dieser Gemme die Seele eines Monsters eingeschlossen. An einem dunklen und trockenen Ort aufbewahren. Vor Gebrauch schütteln.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
I.u[10279] = {n:"Eiskristall",t:15,d:"Dieser Kristall besteht aus hochdichtem Eis und Schleim und darf nicht zu starken Temperaturen ausgesetzt werden, sonst schmilzt es und besudelt euer Inventar.",ep:0,g:98,l:1,wd:false,fm:true,w:1,p:1};
I.u[10280] = {n:"Gefriertrank",t:12,d:"Mit diesem Trank könnt ihr sofort jede Flüssigkeit zum Gefrieren bringen. Diese Tränke sind sehr rar,denn die für die Herstellung nötigen Zutaten sind nur schwierig zu bekommen.",ep:0,g:82,l:1,wd:false,fm:true,w:1,p:1};
I.u[10281] = {n:"Erinnerungssplitter",t:24,d:"Wenn man euch eines Tages erzählt hätte, dass man eine Erinnerung in tausend Stücke zersplittern kann, um daraus eine Waffe zu schmieden, dann hättet ihr es nicht geglaubt. Und wenn ihr diese Geschichte erzählen würdet, würde man euch auch nicht glauben.",ep:0,g:802,l:1,wd:false,fm:true,w:0,p:1};
I.u[10283] = {n:"Schimmernde Morgendämmerung",t:24,d:"Der Zauber der von dieser Waffe ausgeht ist so mächtig, dass ihr sie in der Luft vibrieren spüren könnt. Wenn Jiva keine so wilde Kriegerin wäre, könnte man meinen, dass dieser Gegenstand für andere Zwecke bestimmt sei... aber das sind Gedanken, für die man euch steinigen könnte, sollten diese je Danathor zu Ohren kommen.",ep:0,g:803,l:1,wd:false,fm:true,w:0,p:1};
I.u[10284] = {n:"Kitsous Eingeweide",t:15,d:"Naja, auf dem ersten Blick sehen diese Eingeweide nicht gerade appetitlich aus. Und wenn ihr näher hinschaut, sogar noch weniger.",ep:0,g:445,l:50,wd:false,fm:true,w:1,p:1};
I.u[10285] = {n:"Nichsotolla-Hecht",t:49,d:"Ah, der Nichsotolla-Hecht! Den mag aber niemand essen, denn jeder weiß, dass der Geschmack gar nicht so...toll ist.",ep:0,g:132,l:1,wd:false,fm:true,w:1,p:140};
I.u[10287] = {n:"Magische Formel der vier Banditenbrüder",t:24,d:"Diese magische Formel wurde von dem berüchtigten Banditenquartett Bendiga, Ronkarly, Branum und Kroone erfunden. Nichts ist besser, um einen Gegner oder einen leichtgläubigen Fan in Sekundenschnelle um seine Börse zu bringen. Sobald die Formal ausgesprochen wird, erfasst die Wirkung die ganze Welt der Zwölf und hält kurze Zeit an, bevor sie wieder verfliegt...",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:0};
I.u[10288] = {n:"Amaryllis",t:24,d:"Eine Blume, die nett anzusehen und zu berühren ist. Kein Wunder, dass die Brâks diese Art fast bis zum Aussterben Zertreten haben.",ep:0,g:192,l:1,wd:false,fm:true,w:0,p:1};
