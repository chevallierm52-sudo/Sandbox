I.u[10516] = {n:"Flünkchen-Vergeistung",t:27,d:"Das kommt davon, wenn man mit dem Feuer spielt. Naja, es ist vielleicht gar nicht so schlimm, fragt den Magus X um Rat.",ep:0,g:3,l:1,wd:true,fm:true,w:0,m:true,p:1};
