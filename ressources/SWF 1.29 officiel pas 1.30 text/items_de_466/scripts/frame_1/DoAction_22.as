I.u[10597] = {n:"Gelutine-Geist",t:90,d:"Diese Gelutine hat noch nicht die Welt der Lebenden verlassen, es liegt nur an euch, einen Weg zum Wiederbeleben zu finden oder sie ein für alle Male feige im Stich zu lassen.",ep:0,g:55,l:1,wd:true,fm:true,w:1,p:1};
I.u[10598] = {n:"Geschenk: Gelutine",t:89,d:"Wenn man sein Ohr an das Geschenkpaket hält oder dieses heftig schüttelt, so kann man manchmal seltsame Geräusche vernehmen, so als befände sich etwas Lebendiges darin. Also, verliert keine Zeit und öffnet es schnell, um euren großartigen Vertrauten in Empfang zu nehmen, einschließlich einer Anleitung für seine Aufzucht, Nahrung, sowie Eniripsa-Pulver für seine Pflege.",ep:0,g:42,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[10599] = {n:"Tierheimzertifikat: Gelutine",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über den Vertrauten, den ihr im Tierheim abgegeben habt.",ep:0,g:24,l:1,wd:false,fm:true,w:1,p:100};
