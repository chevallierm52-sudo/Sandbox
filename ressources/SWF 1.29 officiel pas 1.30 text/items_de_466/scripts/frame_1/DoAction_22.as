I.u[10314] = {n:"Kidoblut",t:15,d:"So rot wie sein Gefieder, ist Kidoblut in der zeitgenössischen Kochkunst eines der heiß begehrtesten Zutaten. Das Fehlen magischer Kräfte hingegen macht aus ihm einen denkbar schlechten Ersatz für Vampirblut in der Rezeptur für magische Blutwurst",ep:0,g:89,l:1,wd:false,fm:true,w:1,p:1};
I.u[10315] = {n:"Mondsteinsplitter",t:24,d:"Den Legenden nach badete die Göttin Pandawa sich in Vollmondnächten nackt in den Quellen von Akwadala. Der Mond konnte sich der Schönheit dieses Anblicks nicht entziehen und zersprang vor Entzücken, wobei Dutzende von Gesteinssplittern im Gebiet von Pandala verstreut wurden.",ep:0,g:767,l:1,wd:false,fm:true,w:0,p:1};
I.u[10316] = {n:"Rezeptur für Unsichtbares Öl",t:24,d:"Diese Rezeptur veranschaulicht, wie man aus  6 Unsichtbaren Knochen des Unsichtbaren Chafers, 2  Unsichtbares Gewebe, 1 Enttarnungstrank und 1 Trank der Stillen Camouflage unsichtbares Öl herstellt. Ihr müsst die Handlung \"Mahlen\" auswählen.",ep:0,g:176,l:1,wd:false,fm:true,w:0,p:1};
I.u[10317] = {n:"Unsichtbares Öl",t:60,d:"Beim Unsichtbaren Öl handelt es sich um ein magisches Öl von extremer Macht, denn die Flecken, die dieses Öl verursacht, sind nicht sichtbar und somit das Glück der Wäscherinnen und junger wilder Iops.",ep:0,g:0,l:1,wd:false,fm:true,w:1,p:100};
I.u[10318] = {n:"Gefälschte Sumens-Statue",t:24,d:"Diese Statue sieht der echten Sumens-Statue zum Verwechseln ähnlich, es sei denn, es handelt sich hier um das Original. Es ist besser, ihr behaltet eure Zweifel für euch und erzählt nichts davon euren Vorgesetzten.",ep:0,g:738,l:1,wd:false,fm:true,w:0,p:1};
I.u[10319] = {n:"WuWulfblut",t:24,d:"Bei so einer Riesenbestie könnte man glauben, dass WuWulfblut eine besonderen Aspekt haben müsste, aber dem ist nicht so. Naja, außer, dass es grün ist.",ep:0,g:32,l:1,wd:false,fm:true,w:0,p:1};
