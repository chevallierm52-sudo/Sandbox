I.u[10606] = {n:"Geistreiche Gemme der Weissen Ratte",t:85,d:"Als Sieger-Trophäe bei einem Duell gewonnen, ist in dieser Gemme die Seele eines Monsters eingeschlossen. An einem dunklen und trockenen Ort aufbewahren. Vor Gebrauch schütteln.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
