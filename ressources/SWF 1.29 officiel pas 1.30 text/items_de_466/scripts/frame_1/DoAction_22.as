I.u[10220] = {n:"Gebrauchsanweisung für die Elektroschockschaufel",t:24,d:"Diese Buch, das in 198 Sprachen und Dialekte übersetzt wurde, erklärt wie und in welchen Fällen die Elektroschockschaufel zum Einsatz kommt. Die für die Bworks und Iops bestimmten Seiten sind übrigens reich bebildert.",ep:0,g:95,l:1,wd:false,fm:true,w:0,p:1};
I.u[10221] = {n:"Verwandeltes Wasser",t:15,d:"Bei diesem Wasser, das von Eli Bell umgewandelt worden ist, handelt es sich um eine ausgewogene Mischung von Heiligem Wasser und Mondwasser. Das Ergebnis ist ganz einfach...überraschend.",ep:0,g:769,l:1,wd:false,fm:true,w:1,p:1};
I.u[10223] = {n:"Elektroschockschaufel",t:8,d:"Diese Schaufel ist hauptsächlich zu medizinischen Zwecken bestimmt, auch wenn sie, was höchst kontrovers diskutiert wird, vom Enutrof Resat schon als Selbstverteidigungswaffe eingesetzt wurde.",ep:0,g:10,l:40,wd:false,fm:true,w:25,an:16,tw:true,e:[15,4,1,1,50,50,false,false],p:1000};
I.u[10224] = {n:"Verlorener Gedanke",t:24,d:"Diese Puppe umschließt einen von Solar Verlorenen Gedanken aus dem bald ein wunderschöner, goldener Denkerling schlüpfen wird, vorausgesetzt sie wird nicht vorher zerstört oder verkauft.",ep:0,g:765,l:1,wd:false,fm:true,w:0,p:1};
I.u[10227] = {n:"Geistreiche Gemme von Spongemob Schwammtopf",t:85,d:"Als Sieges-Trophäe beim Duell gewonnen, ist in dieser Gemme die Seele eines Monsters eingeschlossen. An einem dunklen und trockenen Ort aufbewahren. Vor Gebrauch schütteln.",ep:0,g:2,l:1,wd:true,fm:true,w:1,u:true,p:0};
