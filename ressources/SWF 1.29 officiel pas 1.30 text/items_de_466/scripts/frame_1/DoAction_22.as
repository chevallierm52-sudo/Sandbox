I.u[10301] = {n:"Haarbüschel des abscheulichen Sept-Schrecks der Meere",t:24,d:"Dieses nervige Haarbüschel könnte der Grund für die schlechte Laune des abscheulichen Sept-Schrecks der Meere sein. Naja, seit ihr es ihm herausgerissen habt, ist er ziemlich sauer.",ep:0,g:771,l:1,wd:false,fm:true,w:0,p:1};
