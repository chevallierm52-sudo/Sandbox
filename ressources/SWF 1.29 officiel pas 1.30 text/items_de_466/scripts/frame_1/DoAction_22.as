I.u[10417] = {n:"Seelenstein mit Dungeonmonster",t:85,d:"Dieser Seelenstein enthält die Seelen eines oder mehrerer Dungeonmonster, die nur darauf warten, wieder unter die Lebenden zurückzukehren, um sich an euch zu rächen. Allerdings lässt sich der Seelenstein nur in speziellen Arenen einsetzen, welch sich in den großen Städten befinden.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
I.u[10418] = {n:"Seelenstein mit Namensmonster",t:85,d:"Dieser Seelenstein enthält die Seelen eines oder mehrerer Namensmonster, die nur darauf warten, wieder unter die Lebenden zurückzukehren, um sich an euch zu rächen. Allerdings lässt sich der Seelenstein nur in speziellen Arenen einsetzen, welch sich in den großen Städten befinden.",ep:0,g:1,l:1,wd:false,fm:true,w:1,u:true,p:10};
