I.u[1568] = {n:"Schlüssel zum Dungeon der Fresssäcke",t:84,d:"Dieser Schlüssel gestattet euch den Eintritt in den Dungeon der Fresssäcke. Doch ist diese Schlüsselrolle nur von kurzer Dauer, da er durch die Benutzung zerstört wird.",ep:1,g:226,l:9,wd:true,fm:true,w:2,p:100};
