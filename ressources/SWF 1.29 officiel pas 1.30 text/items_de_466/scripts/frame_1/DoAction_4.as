I.u[1486] = {n:"Medaille Holy",t:1,d:"Holy war eine Anhängerin von Iop, die den Schwur abgelegt hat, das Böse mitsamt der Wurzel herauszureißen, wo auch immer es sich versteckt haben mag. Ihre vollkommene Selbstbeherrschung und gefährliche Ruhe konnte einzig dadurch gebrochen werden, dass man sie mit einer gewissen Oly verglich.",ep:1,g:23,l:31,wd:true,fm:true,w:3,p:2800};
I.u[1487] = {n:"Adelus",t:10,d:"Dieser tolle Gürtel kleidet ihn nicht nur elegant, er massiert auch noch seinen Träger. Der glückliche Besitzer leidet dadurch viel weniger unter Stress und kann so besser nachdenken.",ep:1,g:12,l:48,wd:true,fm:true,w:30,p:6075};
I.u[1488] = {n:"Plimclik",t:1,d:"Unter diesem seltsamen Namen versteckt sich ein ebenso seltsamer Gegenstand, der irgendwie aus den vorhergehenden Amuletten hervorgegangen ist. Über die genauen Umstände seiner Entdeckung ist nichts bekannt.",ep:11,g:123,l:130,wd:true,fm:true,w:24,p:1000};
I.u[1489] = {n:"Die Brosche Hète",t:1,d:"Hète war einer der größten Krieger ganz Amaknas. Der Legende nach zog er all seine Weisheit aus dieser Brosche, die er immer bei sich trug.",ep:11,g:15,l:28,wd:true,fm:true,w:1,p:2300};
I.u[1490] = {n:"Das Gelitzder Gogolkettchen",t:1,d:"Der Erschaffer, ein gewisser Ken Aton, war für seine seltsamen Gewohnheiten bekannt. Er verbrachte ganze Tage damit, Minotorors zu jagen, um daraus für sich selbst diverse eine Oberkörperbekleidungen herzustellen.",ep:1,g:12,l:13,wd:true,fm:true,w:2,p:650};
I.u[1491] = {n:"Kette des Lichas",t:1,d:"Der Licha ist eine dreckige Kreatur, die dafür bekannt ist, sich bei Gruppen aus tapferen Streitern einzuschmuggeln, um sich einen Teil der Beute anzueignen. Eines Tages flog er damit auf und ist seitdem auf der Flucht.",ep:13,g:12,l:45,wd:true,fm:true,w:2,p:5400};
I.u[1492] = {n:"Tass\' Mäntelchen",t:17,d:"Dieser berüchtigte Umhang wurde von der Großmutter von Tasselhoff höchstpersönlich gestrickt. Sie wußte damals natürlich noch nicht, dass dieser all seine perversen Gelüste und Phantasien damit ausleben würde... Und sie sollte es auch niemals erfahren.",ep:0,g:23,l:30,wd:true,fm:true,w:11,p:800};
I.u[1493] = {n:"Sacrieurs Wunde",t:9,d:"Man sagt, dieser Ring sei aus einer der vielen Wunden eines Sacrieurs herausgewachsen.",ep:1,g:13,l:15,wd:true,fm:true,w:2,p:800};
I.u[1494] = {n:"Markiering",t:9,d:"Die ursprüngliche Funktion dieses Ringes war es, den Osamodas das Erkennen ihres Tofus beim Kampfe zu erleichtern.",ep:1,g:14,l:15,wd:true,fm:true,w:4,p:800};
I.u[1495] = {n:"Ano Dhyn Ring",t:9,d:"Dieser kleine Ring, der nicht nach viel aussieht, wurde von Degun hergestellt. Degun ist übrigens besser bekannt für seine plötzlichen Jähzornanfälle und seine starke Abneigung gegen den Licha, als für seine Handwerkskünste.",ep:1,g:37,l:36,wd:true,fm:true,w:3,p:3575};
I.u[1496] = {n:"Ecaflips Glück",t:9,d:"Dieser Ring wurde angefertigt, um seinem Träger Glück bein Kartenspiel zu bringen.",ep:1,g:32,l:20,wd:true,fm:true,w:4,p:1300};
I.u[1497] = {n:"Xélors Vergangenheit",t:9,d:"Dieser Ring entstand während einer Xelor-Zeitreise.",ep:1,g:16,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1498] = {n:"Enutrofs Erinnering",t:9,d:"Diese Ringe wurden in den Tränen eines Enutrofs abgeschreckt, der seine Schaufel verloren hatte. Das gibt einen Eindruck von der tiefen Verzweiflung dieses armen Menschen.",ep:1,g:15,l:30,wd:true,fm:true,w:4,p:2600};
I.u[1499] = {n:"Das Enutrofion",t:9,d:"Dieser Ring ist nur für Enutrofs bestimmt. Ihr Gott hat ihn mit einem Zauber versehen, damit er einzig von seinen Anhänger getragen werden kann. Er wird Enutrofs viel Glück bringen und sie neue Schätze entdecken lassen.",ep:1,g:39,l:59,wd:true,fm:true,w:1,c:"PG=3",p:10000};
I.u[1500] = {n:"Der Teppich",t:17,d:"Dieser tolle Umhang wurde von Hand aus verschiedenen Naturfasern gewoben, was ihn zu einem Unikat macht, sei es durch die satten Farben oder die lebendigen Schattierungen.",ep:8,g:8,l:43,wd:true,fm:true,w:16,p:5000};
I.u[1501] = {n:"Trauring",t:9,d:"Dieser Trauring wird das Bündnis mit dem Wesen eurer Träume besiegeln... Also: Schluss mit den kleinen Schäferstündchen hinter den Büschen! Dieses Mal geht es ums Ganze, was ihr mit diesem Ring auch Jedermann zeigen könnt.",ep:2,g:27,l:1,wd:true,fm:true,w:10,p:1};
I.u[1503] = {n:"Stab des Irrlichts",t:3,d:"Es heißt, dass es zur Herstellung dieses schaurigen Gegenstandes nötig sei, das Holz des Stabes in einen frischen Kadaver einzuführen, welcher dann anschließend beerdigt werden muss. Doch wagte es bisher noch niemand, diese Rezeptur auszuprobieren.",ep:3,g:14,l:20,wd:true,fm:true,w:15,an:11,e:[5,3,2,3,30,50,false,true],c:"CI>30",p:1000};
I.u[1504] = {n:"Dolch O\'Bert",t:5,d:"O\'Bert Rotkehl war im ganzen Umkreis für seinen schrecklichen Gesang berühmt und gefürchtet. Eines Tages, als er wieder einmal aus voller Lautstärke seinen Gesang in die schutzlosen Wälder und Wiesen hinaus kra kehlte, wurde ihm selbige von einem Unbekannten durchgeschnitten. Daher auch sein Spitzname. Der für den Mord verwendete Dolch wurde schnell wiedergefunden, doch niemand machte sich die Mühe den Schuldigen ausfindig zu machen. O\'Bert sang einfach zu schauderhaft.",ep:1,g:1,l:30,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1505] = {n:"Flöte",t:20,d:"Diese seltene Holzflöte aus Astaknydenholz wird Kummer und Sorgen zerstreuen und eure Freunde erfreuen.",ep:1,g:6,l:1,wd:true,fm:true,w:1,an:4,e:[0,5,1,1,0,0,false,false],p:50000};
I.u[1506] = {n:"Seltsames Zeichen",t:15,d:"Diese Spielkarte enthält... irgendetwas. Man weiß zwar nicht genau was, doch ist es sicherlich sehr wichtig!",ep:1,g:224,l:1,wd:true,fm:true,w:10,p:1};
I.u[1507] = {n:"Gutschein über 1000 KeK",t:15,d:"Auf dieses Stück Papier ist ein kleiner Slogan gekritzelt worden: \"Bravo! Dieser KeK-Gutschein beweist die Außergewöhnlichkeit Deines Charakters. Komm zu uns, um ihn einzulösen. Wir warten auf Dich!\" Unten stehen noch zwei Zahlen geschrieben: \"-1, 2\". Seltsam.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1508] = {n:"Gutschein über 2000 KeK",t:15,d:"Auf dieses Stück Papier ist ein kleiner Slogan gekritzelt worden: \"Bravo! Dieser KeK-Gutschein beweist die Außergewöhnlichkeit Deines Charakters. Komm zu uns, um ihn einzulösen. Wir warten auf Dich!\" Unten stehen noch zwei Zahlen geschrieben: \"-1, 2\". Seltsam.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1509] = {n:"Gutschein über 5000 KeK",t:15,d:"Auf dieses Stück Papier ist ein kleiner Slogan gekritzelt worden: \"Bravo! Dieser KeK-Gutschein beweist die Außergewöhnlichkeit Deines Charakters. Komm zu uns, um ihn einzulösen. Wir warten auf Dich!\" Unten stehen noch zwei Zahlen geschrieben: \"-1, 2\". Seltsam.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1510] = {n:"Gutschein über 10000 KeK",t:15,d:"Auf dieses Stück Papier ist ein kleiner Slogan gekritzelt worden: \"Bravo! Dieser KeK-Gutschein beweist die Außergewöhnlichkeit Deines Charakters. Komm zu uns, um ihn einzulösen. Wir warten auf Dich!\" Unten stehen noch zwei Zahlen geschrieben: \"-1, 2\". Seltsam.",ep:1,g:225,l:1,wd:true,fm:true,w:10,p:1};
I.u[1511] = {n:"Neunschwanz",t:6,d:"Der Legende nach soll Ecaflip im Laufe der epischen Schlacht, die ihm den Rang eines Gottes bescherte, eine Waffe verwendet haben, die aus seinen eigenen Schwänzen bestand. Nämlich einen für jedes Leben, das er besaß.",ep:13,g:19,l:80,wd:true,fm:true,w:20,an:14,e:[9,9,1,1,20,20,false,false],c:"CS>99&CA>99&CV>99",p:20000};
I.u[1512] = {n:"Die Legenden des Crocoburio",t:25,d:"Dieses Buch erzählt die Geschichte des berühmt-berüchtigten Crocoburio.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
I.u[1514] = {n:"Trank des Vergessens: \"Nachwirkung\"",t:43,d:"Dieser Trank lässt euch einen Grad des Ecaflip-Zauberspruches \"Nachwirkung\" vergessen.",ep:2,g:27,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1515] = {n:"Feuer-Bwack Ei",t:72,d:"Dieses Ei, welches von einem Flammen-Kwack gelegt wurde, ist kurz vor dem Aufplatzen... Doch zum Glück greifen die selbst kurz nach der Geburt bereits sehr aggressiven Bwacks niemals ihre Eltern an.",ep:1,g:59,l:1,wd:true,fm:true,w:1,u:true,p:100};
