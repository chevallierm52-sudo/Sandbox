I.u[1640] = {n:"Der kleine Cutter",t:6,d:"Diese Klinge ist hervorragend dazu geeignet, die anderen lieben Leutchen in der Umgebung zu bedrohen: sie ist handlich, wendig und vor allem extrem scharf. Aus diesem Grunde wurde sie vor langer Zeit aus dem Handel gezogen. Aber sie wird heutzutage zur reinen Bwork-Abwehr toleriert.",ep:14,g:23,l:46,wd:true,fm:true,w:12,an:14,e:[5,5,1,1,30,50,false,false],p:5000};
