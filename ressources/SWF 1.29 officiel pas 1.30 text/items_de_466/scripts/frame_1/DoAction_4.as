I.u[1572] = {n:"Magische Objekte erschaffen für Dummies",t:25,d:"Dieses Buch enthält eine Sammlung von Rezepten und Ratschlägen für angehende Thaumaturgen, die Gegenstände verzaubern wollen. Absolut empfehlenswert!",ep:9,g:19,l:1,wd:true,fm:true,w:1,u:true,p:100};
I.u[1573] = {n:"Transportrune",t:12,d:"(Diesem Gegenstand scheint keinerlei Magie innezuwohnen...)",ep:1,g:14,l:1,wd:true,fm:true,w:1,p:1};
I.u[1574] = {n:"Yench-Schnitter",t:6,d:"Dieses Schwert gehörte einst dem inzwischen verstorbenen Kih Besans, den man überall nur den Yench-Schnitter nannte. Dies war nämlich seine Lieblingsbeschäftigung. Da sieht man es wieder: manche Leute kann ein Nichts erfreuen.",ep:2,g:21,l:60,wd:true,fm:true,w:15,an:14,tw:true,e:[10,5,1,1,40,40,false,false],p:6000};
I.u[1575] = {n:"Gildalogem",t:50,d:"Diese extrem seltene Gemme, die ihr tief in den Innereien eines erlegten Monsters gefunden habt, ermöglicht es euch, eure eigene Gilde zu gründen.",ep:5,g:229,l:1,wd:true,fm:true,w:5,p:1000};
