I.u[1652] = {n:"Klaue einer Arachnea Majora",t:103,d:"Diese vielgegliederte Klaue ist lang, dünn und sehr behaart. Sie wurde früher gern dazu verwendet, um Besen oder exotische Perrücken herzustellen.",ep:1,g:246,l:39,wd:true,fm:true,w:1,p:1};
I.u[1653] = {n:"Don Rouanns Frömmigkeit",t:24,d:"Dieser Ring ist das äußere Zeichen eurer Suche nach Don Rouanns Geheimnis. Ihr habt bereits die Tapferkeit gemeistert.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1654] = {n:"Don Rouanns Frömmigkeit",t:24,d:"Dieser Ring ist das äußere Zeichen eurer Suche nach Don Rouanns Geheimnis. Ihr habt bereits die Tapferkeit und Kommunikation gemeistert. Nun braucht ihr nur noch etwas Geduld.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1655] = {n:"Don Rouanns Frömmigkeit",t:24,d:"Dieser Ring ist das äußere Zeichen eurer Suche nach Don Rouanns Geheimnis.",ep:2,g:27,l:1,wd:true,fm:true,w:0,p:1};
I.u[1656] = {n:"Magier-Fecalisator",t:9,d:"Dieser Ring beschützt seinen Träger vor magischen Angriffen und dadurch auch gleichzeitig vor all diesen kleinen Monstern, die ihre verborgene magischen Künste dazu mißbrauchen, sich wichtig zu machen und euch auf die Nerven zu gehen.",ep:1,g:40,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1657] = {n:"Krieger-Fecalisator",t:9,d:"Dieser Ring beschützt seinen Träger vor körperlichen Angriffen und dadurch auch gleichzeitig vor all diesen kleinen Monstern, die ihre verborgene körperliche Stärke dazu mißbrauchen, um euch zu überraschen.",ep:1,g:41,l:26,wd:true,fm:true,w:2,p:2000};
I.u[1660] = {n:"Schattensastaknyden-Bernstein",t:50,d:"Dieses wunderschöne Stück Bernstein hält im Inneren eine bösartige Kreatur gefangen. Damit ähnelt es einem Sarkophag, der es dem Schattenastaknyden erlaubt, Souvenirs von allen beschworenen Kreaturen zu sammeln, wenn diese auf dem Schlachtfeld umkommen.",ep:9,g:638,l:78,wd:true,fm:true,w:2,p:6000};
I.u[1661] = {n:"Moskito-Bernisteinmedaillon",t:1,d:"Einen in Bernstein eingefangenen Moskito um den Hals zu tragen, ist eine gute Art, den Gegnern zu zeigen, dass man ein gefährlicher Jäger ist... von Moskitos wenigstens. Was euch außerhalb der Wiege Amaknas ziemlich lächerlich macht.",ep:1,g:17,l:40,wd:true,fm:true,w:5,p:4400};
I.u[1662] = {n:"Arachneen-Bernisteinmedaillon",t:1,d:"Eine in Bernstein eingefangenen Arachnee um den Hals zu tragen, während man gerade eine ihrer Schwestern bekämpft, kann diese ganz schön aus der Fassung bringen. Armes Tierchen! Man nennt dies die Ironie des Schicksals.",ep:1,g:18,l:34,wd:true,fm:true,w:5,p:3225};
I.u[1663] = {n:"Schuppen eines Crocodylls",t:59,d:"Diese Schuppen eines Crocodylls sind für jeden angehenden Jäger eine Trophäe, die sich sehen lassen kann. Und wenn ihr sie den Trunkenbolden in der Taverne präsentiert, habt ihr gute Chancen, sie so sehr zu beeindrucken, dass sie euch eine Runde ausgeben.",ep:4,g:233,l:36,wd:true,fm:true,w:5,p:50};
I.u[1664] = {n:"Crocodyll-Zahn",t:47,d:"Wenn ihr einem Crocodyll auf den Zahn fühlen wollt, dann solttet ihr im diesen einfach ausreißen. Soweit die Weisheit eines erfolgreichen Zahnarztes.",ep:4,g:234,l:36,wd:true,fm:true,w:1,p:50};
I.u[1665] = {n:"Stiefel des Lehrlings",t:11,d:"Diese seltsamen Stiefel gibt man gern den jungen Lehrlingen, die geistig ein wenig hinterherhinken. Das erlaubt es ihnen, den geistigen Abstand zu den anderen etwas zu verringern. Grundsätzlich sind sie allerdings auch für jeden Iop geeignet.",ep:4,g:68,l:50,wd:true,fm:true,w:10,p:6675};
I.u[1666] = {n:"Stiefel des Beschwörlehrlings",t:11,d:"Diese Stiefel wurden speziell für all diejenigen entwickelt, die in Kämpfen gerne ihren Kreaturen die ganze Arbeit überlassen.",ep:12,g:14,l:51,wd:true,fm:true,w:10,p:7000};
I.u[1667] = {n:"Ruf des Gürthulhu",t:10,d:"Dieser Gürtel wurde von einem alten ex-Hippie Schuhmacher angefertigt, dessen Spitzname \"Kraft der Liebe\" lautet. Er war zwar viel weniger bekannt als der berüchtigte Bowisse, aber trotz seines Alters immer noch sehr kreativ!",ep:8,g:13,l:50,wd:true,fm:true,w:10,p:6700};
I.u[1668] = {n:"Gürtel des zitternden Dickmanns",t:10,d:"Der zitternde Dickmann hasste es, so genannt zu werden und entschloss sich daher, lieber seine Gegner zum Zittern zu bringen. Aus diesem Grunde bestellte er bei Bowisse diesen Gürtel, passend zur Haarfarbe. Doch seitdem zitterte der Dickmann nicht nur stärker denn je, sondern versprühte auch noch seinen Charme in alle Richtungen.",ep:4,g:14,l:55,wd:true,fm:true,w:8,p:8000};
I.u[1669] = {n:"Aereignisgürtel",t:10,d:"Dieser Gürtel wurde für die bekannteste Crâ von Amakna angefertigt, die es genoß, ihre ohnehin schon spärliche Freizeit durch das Organisieren vieler Feste und außergewöhnlicher Events auszufüllen. Sie nutzte auch noch die kleinste Zeitspanne, um das Volk zu erfreuen, wie beispielsweise die Zeit zwischen zwei Bügelstreichen der Lederunterhose des Chafer-Offizieres.",ep:8,g:15,l:84,wd:true,fm:true,w:10,p:18300};
I.u[1670] = {n:"Angespitzte Wind-Kwack-Feder",t:53,d:"Manchmal wächst einem Wind-Kwack eine Feder, die sich von allen anderen durch ihre schöne Form und spitze Spitze unterscheidet. Üblicherweise ist sie hochgradig magisch. Ein perfektes Accessoire, um sich als Indianerchef zu verkleiden.",ep:5,g:393,l:24,wd:true,fm:true,w:10,p:100};
I.u[1671] = {n:"Magischer Hafer",t:34,d:"Diese magische Haferähre wurde von einem ärmlichen Bauern geerntet, der kurz zuvor unabsichtlich von einem Bwork Magus-Lehrling verzaubert worden war, als dieser sein Zauberbuch falsch herum in der Hand hielt.",ep:1,g:550,l:20,wd:true,fm:true,w:10,p:0};
I.u[1672] = {n:"Darits Haare",t:54,d:"Diese Haare sind die einzigen Überreste von Darit, einem draufgängerischen Magierlehrling, der vergessen hatte zu überprüfen, ob der Prespik \"Zauber zurückwerfen\" gewirkt hatte, bevor er ihn mit einem Donnerblitz angriff.",ep:1,g:555,l:18,wd:true,fm:true,w:1,p:100};
I.u[1673] = {n:"Magische Arachneenklaue",t:103,d:"Diese Arachneenklaue ist einzigartig. Sie zuckt von ganz allein und scheint noch voller Leben zu stecken, obwohl sie brutal von ihrer Besitzerin getrennt wurde. Nun scheint ein zweiter Frühling als großer Modedesigner für diese Klaue zu beginnen!",ep:1,g:392,l:2,wd:true,fm:true,w:10,p:100};
I.u[1674] = {n:"Luitschi-Pilz",t:15,d:"Dieser Held wurde einst von Weich-Eich verwandelt, doch schlug seine Magie wohl fehl. Darum nahm er letztlich die Gestalt eines Pilzes an. Weil die anderen Pilze nun ein wenig geistig zurückgeblieben sind, verehren sie ihn als Gott und verteidigen ihn mit ihrem Leben.",ep:1,g:390,l:46,wd:true,fm:true,w:10,p:100};
I.u[1675] = {n:"Überraschender Knochen des Chafer-Infanteristen",t:47,d:"Dieser magische Knochen erlaubt es den Chafer-Infanteristen, Überraschungsangriffe zu starten, wie zum Beispiel das Ausziehen und Über-den-Kopf-Ziehen ihres Schlüpfers ohne den Einsatz der Hände. Wahre Chafer erkennt man daran, dass sie dies selbst mitten im Kampfgetümmel schaffen, ohne getroffen zu werden.",ep:3,g:15,l:35,wd:true,fm:true,w:1,p:100};
I.u[1676] = {n:"Verzauberte Weide",t:15,d:"Aus diesem verzauberten Weidenstück könnte man einen wunderschönen Obstkorb flechten – eine Einheit aus Eleganz und Funktionalität. Ganz das Gegenteil des alten Lichas.",ep:2,g:123,l:69,wd:true,fm:true,w:10,p:100};
I.u[1677] = {n:"Dantgoulischer Trank",t:12,d:"Dieser magische Trank ist als einziger stark genug, ineinander verknotete Lederschlüpfer des Chafer-Offiziers zu verzaubern. Das spricht Bände über die magische Macht, die diesem Trank innewohnt.",ep:2,g:139,l:50,wd:true,fm:true,w:10,p:1000};
I.u[1678] = {n:"Traumatisierte Kokosnuss",t:46,d:"Diese Kokokosnuss wurde in ihrer Kindheit traumatisiert. Darum hat sie im Laufe der Jahre einen unvorstellbaren Hass aufgestaut, was ihr eine große Macht verleiht.",ep:12,g:552,l:42,wd:true,fm:true,w:2,p:100};
I.u[1679] = {n:"O\'Bouls Kristallstein",t:50,d:"Mit ein wenig Geduld und Fleiß wird aus diesem eckigen Kristallstein eine glattpolierte, runde Kristallkugel, die sich hervorragend als Quaste eines magischen Hutes eignet. Dank dieser Form kann sie sich auch noch durch die feinsten Ritzen und Spalten hindurchschlängeln.",ep:4,g:240,l:16,wd:true,fm:true,w:10,p:100};
I.u[1680] = {n:"Verbranntes Minotoror-Horn",t:47,d:"Dieses Minotoror-Horn wurde wie durch mächtige Magie verbrannt. Leider scheint es, wie so viele Dinge im Leben, paarweise benötigt zu werden.",ep:2,g:245,l:125,wd:true,fm:true,w:10,p:100};
I.u[1681] = {n:"Magische grüne Larvenhaut",t:59,d:"Hinter dem Anschein, ein bloßer grüner Breifleck zu sein, verbirgt sich ein mächtiges Artefakt. Um den Hals getragen soll es soviel Glück bringen, dass ihr noch glücklicher werdet als der glücklichste Chafer.",ep:1,g:391,l:7,wd:true,fm:true,w:10,p:100};
I.u[1682] = {n:"Rinde von Liroye Merlin",t:96,d:"Diese Stück verzauberte Baumrinde stammt von der verzauberten Lichtung von Liroye Merlin. Es muss sich gelöst haben, als der gefürchtete Holzfäller Bruce Boulgour seine Boulgourde zerschmetterte, als er versuchte einen verzauberten Baum zu fällen.",ep:9,g:542,l:78,wd:true,fm:true,w:1,p:100};
I.u[1683] = {n:"Heller Kartoffelsack",t:15,d:"Dieser magische Sack gehörte einmal einem Halsabschneider, der darin gewaltige Mengen an geschälten Kartoffeln transportierte, um sie den Gefangenen teuer zu verkaufen. Als er starb, wurde dieser Sack einem Ritual gleich von Generation zu Generation weitergegeben.",ep:1,g:243,l:12,wd:true,fm:true,w:10,p:100};
I.u[1684] = {n:"Dunkler Kartoffelsack",t:15,d:"Dieser Sack unterscheidet sich nur geringfügig von anderen Kartoffelsäcken, außer dass er als Kind einmal in eine Lache Schattenastaknydenharz gefallen ist, was ihm besondere Eigenschaften verliehen hat.",ep:1,g:244,l:12,wd:true,fm:true,w:10,p:100};
I.u[1685] = {n:"Feder des letzten Heenchen",t:53,d:"Vorsicht: dies ist eine Schwanzfeder des letzten Heenchens von Amakna! Diese Feder ist ein tolles Geschenk für befreundete Schneider oder für fanatische Heenchen-Fans, deren Zahl in letzter Zeit rasant ansteigt.",ep:3,g:247,l:32,wd:true,fm:true,w:1,p:100};
I.u[1686] = {n:"Magisches rotes Färbemittel",t:70,d:"Dieses magische Färbemittel verleiht Haaren und Fellen nach dem Auftragen einen wunderschönen roten Farbton. Desweiteren scheint es auch noch bestimmte andere magische Wirkungen zu verursachen.",ep:7,g:63,l:10,wd:true,fm:true,w:1,p:500};
I.u[1687] = {n:"Magisches grünliches Färbemittel",t:70,d:"Dieses magische Färbemittel verleiht Haaren und Fellen nach dem Auftragen einen wunderschönen grünen Farbton. Desweiteren scheint es auch noch bestimmte andere magische Wirkungen zu verursachen.",ep:1,g:64,l:10,wd:true,fm:true,w:1,p:500};
I.u[1688] = {n:"Magisches bläuliches Färbemittel",t:70,d:"Dieses magische Färbemittel verleiht Haaren und Fellen nach dem Auftragen einen wunderschönen blauen Farbton. Desweiteren scheint es auch noch bestimmte andere magische Wirkungen zu verursachen.",ep:5,g:65,l:10,wd:true,fm:true,w:1,p:500};
I.u[1689] = {n:"Magisches orangefarbes Färbemittel",t:70,d:"Dieses magische Färbemittel verleiht Haaren und Fellen nach dem Auftragen einen wunderschönen orangefarbenen Farbton. Desweiteren scheint es auch noch bestimmte andere magische Wirkungen zu verursachen.",ep:1,g:66,l:10,wd:true,fm:true,w:1,p:500};
I.u[1690] = {n:"WullyWuWulf-Haare",t:54,d:"Diese Haare ähneln denen eines WuWulfs, doch sind sie kürzer, brüchiger und ein wenig weicher. Leider ist der Geruch der Gleiche.",ep:1,g:554,l:22,wd:true,fm:true,w:1,p:1};
I.u[1691] = {n:"MuWulf-Haare",t:54,d:"Selten sind die Abenteurer, die diese Haare am lebenden Objekt berühren konnten. Doch bloß, weil ihr diese abgetrennten Haare in der Hand haltet, seid ihr noch lange kein Held!",ep:2,g:553,l:198,wd:true,fm:true,w:10,p:200};
I.u[1692] = {n:"Magisches dunkles Färbemittel",t:70,d:"Dieses magische Färbemittel verleiht Haaren und Fellen nach dem Auftragen einen wunderschönen, tiefschwarzen Farbton. Desweiteren scheint es auch noch bestimmte andere magische Wirkungen zu verursachen.",ep:1,g:67,l:10,wd:true,fm:true,w:1,p:500};
I.u[1693] = {n:"Umhang von Jules Yanos",t:17,d:"Jules Yanos, der berühmte Schneider war in erster Linie dafür bekannt, dass er seine Frau gegen einen magischen Fingerhut ausgetauscht hat. Demnach gibt es also doch noch Männer, die etwas Geschäftssinn besitzen!",ep:8,g:8,l:54,wd:true,fm:true,w:1,p:7800};
I.u[1694] = {n:"Wolle des wütenden Trools",t:57,d:"Diese Stück Wolle stammt vom gefährlichsten Trool von ganz Amakna. Dieser wurde von einem skrupellosen Schneiderlein in einen Bettvorleger verwandelt, dem man sogar nachsagt, seine Frau gegen einen magischen Fingerhut eingetauscht zu haben. Höchst mysteriös...",ep:4,g:27,l:115,wd:true,fm:true,w:10,p:1};
I.u[1695] = {n:"Umhang von Elya Wood",t:17,d:"Man sagt, der Chafer-Offizier habe einst versucht, diesen Umhang von seinem rechtschaffenen Besitzer zu stehlen, um seine lederne Unterkleidung dadurch zu ersetzen. Doch passte er ihm nicht in dem Kram, da er seiner Meinung seine perversen Gelüste und seine Arglist nicht ausreichend unterstrich.",ep:8,g:9,l:80,wd:true,fm:true,w:10,s:39,p:16500};
I.u[1696] = {n:"MuWulf-Pelz",t:55,d:"Schneider haben schon seit langer Zeit einen Weg gefunden, Pelzkleidung für Kunden attraktiv zu machen. Nämlich mit dem Spruch: \"Je schlimmer sie riecht, desto mächtiger ist sie.\" Dieses Exemplar hier stinkt schlimmer als das gebrauchte Fußbadwasser eines Enutrof, in dem ein Chafer seinen Schlüpfer gewaschen hätte. Demnach muss es sehr, sehr mächtig sein.",ep:2,g:14,l:198,wd:true,fm:true,w:20,p:300};
I.u[1697] = {n:"Kleiner Rucksack aus Fresssackwolle",t:81,d:"Dieser kleine Rucksack wird aus euch sicherlich keine Berühmtheit machen, doch werdet ihr in ihm eure persönlichen Utensilien leicht verstauen können.",ep:1,g:25,l:1,wd:true,fm:true,w:5,p:100};
I.u[1698] = {n:"Rucksack des kleinen Ernters",t:81,d:"Dieser Rucksack wurde speziell dazu entwickelt, eure geernteten oder gesammelten Ressourcen aufzunehmen. Nur echte Rohstoffsammler werden diesen Rucksack tragen können (Stufe >20 im Beruf erforderlich).",ep:1,g:26,l:5,wd:true,fm:true,w:5,c:"PJ>2,20|PJ>24,20|PJ>36,20|PJ>28,20|PJ>26,20|PJ>41,20",p:2000};
I.u[1699] = {n:"Rucksack des jungen Abenteurers",t:81,d:"Dieser Rucksack ist besonders für diejenigen geeignet, die nicht allzuweit von zuhause weggehen und dabei unwichtige Sachen mitnehmen wollen, wie zum Beispiel Eschenholzbretter.",ep:1,g:27,l:10,wd:true,fm:true,w:5,p:3000};
I.u[1700] = {n:"Geschwindel der Gürtlichkeit",t:10,d:"Dieser hochgradig aerodynamische Gürtel wurde von Tengra Reufrus höchstpersönlich angefertigt. Er wird euch flink wie die Luft und frei wie einen Tofu machen. Oder war es umgekehrt?",ep:4,g:17,l:27,wd:true,fm:true,w:15,p:2000};
I.u[1701] = {n:"Gürtel der vielen Taschen",t:10,d:"Dieser Gürtel besitzt viele Taschen, die es dem Träger erlauben, einen erheblichen Teil ihres Inventars darin aufzubewahren.",ep:1,g:16,l:20,wd:true,fm:true,w:10,p:1300};
I.u[1702] = {n:"Rucksack des Ernters",t:81,d:"Dieser Rucksack wurde speziell dazu entwickelt, eure geernteten oder gesammelten Ressourcen aufzunehmen. Nur echte Rohstoffsammler werden diesen Rucksack tragen können (Stufe >40 im Beruf erforderlich).",ep:8,g:28,l:15,wd:true,fm:true,w:10,c:"PJ>2,40|PJ>24,40|PJ>36,40|PJ>28,40|PJ>26,40|PJ>41,40",p:3000};
I.u[1703] = {n:"Rucksack des großen Ernters",t:81,d:"Dieser Rucksack wurde speziell dazu entwickelt, eure geernteten oder gesammelten Ressourcen aufzunehmen. Nur echte Rohstoffsammler werden diesen Rucksack tragen können (Stufe >60 im Beruf erforderlich).",ep:8,g:29,l:20,wd:true,fm:true,w:10,c:"PJ>2,60|PJ>24,60|PJ>36,60|PJ>28,60|PJ>26,60|PJ>41,60",p:2000};
I.u[1704] = {n:"Rucksack des Stacka Novista",t:81,d:"Der Legende nach soll es einen berühmten Bergmann gegeben haben, der in der Lage war, ohne Unterlaß in allen 4 Minen gleichzeitig Erz abzubauen. Dies ist doch sicher wieder einmal eine Legende, die von der \"Sichel-Hammer\"-Gilde erfunden wurde, um die Bergmänner zur Arbeit anzutreiben.",ep:8,g:30,l:20,wd:true,fm:true,w:10,c:"PJ>2,90|PJ>24,90|PJ>36,90|PJ>28,90|PJ>26,90|PJ>41,90",p:10000};
I.u[1705] = {n:"Rucksack des Abenteurers",t:81,d:"Dieser Rucksack ist einfach ideal dafür, all eure Tränke und Brote aufzunehmen, wenn ihr für mehrere Monate auf Abenteuer auszieht – in das Labyrinth zum Beispiel.",ep:8,g:31,l:40,wd:true,fm:true,w:4,p:4000};
I.u[1707] = {n:"Rucksack des erfahrenen Abenteurers",t:81,d:"Dieser Rucksack ist einfach ideal dafür, all eure Tränke und Brote aufzunehmen, wenn ihr zu neuen, immer exotischeren Zielen aufbrecht, wie beispielsweise auf Moons Insel.",ep:13,g:32,l:60,wd:true,fm:true,w:5,p:6000};
I.u[1709] = {n:"Knöchelchen",t:47,d:"\"Schau mal, was ich hier habe! Ein kleines Knöchelchen für Mamas kleinen Liebling!\". So lauteten die letzten Worte einer uralten Enutrof-Dame, die einen tollwütigen MuWulf mit ihrem Haustier verwechselte.",ep:1,g:15,l:1,wd:true,fm:true,w:2,p:1};
I.u[1710] = {n:"Mondsichel",t:1,d:"Die Herkunft dieses Amuletts, welches einen zunehmenden Viertelmond darstellt, ist völlig unbekannt... jedenfalls den meisten. Wer weiß, welche Geheimnisse diesem Stück Geschmeide innewohnen...",ep:1,g:19,l:1,wd:false,fm:true,w:10,p:1000};
I.u[1711] = {n:"SchnuffWuff",t:18,d:"Mit diesem kleinen Hund macht selbst das tägliche Gassi-Gehen wieder Spaß. Doch außer seinen gewohnten wildwachsenden Wurzeln sollte man ihm nichts zu fressen geben, sonst riskiert man, dabei seine Hand zu verlieren.(DIESER VERTRAUTE MAG ÜBERHAUPT KEINE RESSOURCEN!)",ep:1,g:6,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1712] = {n:"Bauermaid-Trank",t:12,d:"Dieser Trank gibt dem Anwender einige Punkte an Energie zurück.",ep:1,g:140,l:20,wd:true,fm:true,w:1,u:true,p:50};
I.u[1713] = {n:"Bettnull-Trank",t:12,d:"Dieser Trank gibt dem Anwender einige Punkte an Energie zurück.",ep:1,g:141,l:40,wd:true,fm:true,w:1,u:true,p:100};
I.u[1715] = {n:"Das Weissnachtsgeschenk",t:25,d:"Dieses Buch ist ein absolut lesenswerter Klassiker. Nicht umsonst der Bestseller im Winter 634.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1716] = {n:"Eine himmlische Familie",t:25,d:"Dieses Buch wurde hochgelobt. Nicht umsonst der zweitbeste Verkaufsschlager im Winter 634.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1717] = {n:"Erste Weissnacht",t:25,d:"Der Außenseiter des Jahres 635 ist es wirklich wert, dass man sich näher mit ihm beschäftigt.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:50};
I.u[1718] = {n:"Kraft des Crocoburio",t:9,d:"Dieses Ringpaar wurde einst durch den schwarzen Odem von Grougalorasalar verzaubert, weshalb ihm unglaubliche Macht innewohnt, die heute jedoch leider stark zurückgegangen ist. Diese Reliquie war dem Crocoburio bestimmt, der als einziger im Stande war, diese Ringe zu tragen, ohne von ihnen beherrscht zu werden.",ep:4,g:38,l:40,wd:true,fm:true,w:2,c:"CS>59",p:4000};
I.u[1719] = {n:"Geist des Crocoburio",t:11,d:"Dieses Paar Schuhe gehörte einst dem Crocoburio. Die wenigen Charaktere, die im Stande sind, diese Schuhe anzuziehen, werden sofort von raffinierten, aber gleichzeitig auch diabolischen Plänen und Gedanken heimgesucht. Dieser Fluch soll – so will es die Legende – von den Tausenden von Schädeln herkommen, die durch diese Stiefel bereits zermalmt wurden.",ep:4,g:12,l:42,wd:true,fm:true,w:10,c:"CI>49",p:5000};
I.u[1720] = {n:"Macht des Crocoburio",t:10,d:"Grougalorasalar pflegte einzelne Knochenstücke von jedem stärkeren Gegner aufzubewahren, den er besiegt hatte. Seine Liebe für den Crocoburio brachte ihn dazu, aus diesen Fragmenten den vorliegenden mächtigen Gürtel anzufertigen.",ep:4,g:18,l:34,wd:true,fm:true,w:15,c:"CV>119",p:3000};
I.u[1721] = {n:"Trank des Vergessens: \"Uhrwerk\"",t:43,d:"Dieser Tränk lässt euch einen Grad des Xelor-Zauberspruches \"Uhrwerk\" vergessen.",ep:2,g:37,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1722] = {n:"Astaknydale Verwandlung",t:27,d:"Der Fluch von Weich-Eich hat euch in einen Astaknyden verwandelt. \nUm den Zauber zu lösen, müßt ihr einen Abenteurer besiegen, der sich in den Wald der Astaknyden verlaufen hat.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1723] = {n:"Übermächtiges rotes Bonbon",t:28,d:"Dieses Bonbon stärkt euch für eine gewisse Dauer.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1724] = {n:"Tapferkeit",t:29,d:"Dieser Segen verleiht euch Stärke in den nächsten Kämpfen.",ep:18,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1725] = {n:"Entmutigung",t:30,d:"Dieser Fluch raubt euch Kraft im nächsten Kampf.",ep:1,g:1,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1726] = {n:"Büschel von Tarches Haar",t:24,d:"Dieses Haarbüschel beweist euren Sieg über Tarche. Welch eine Heldentat!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1727] = {n:"Drohbrief",t:24,d:"Dies ist ein Drohbrief der an die Dame von Claudjean gerichtet ist.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1728] = {n:"Maunzmiez",t:18,d:"Damen jeder Klasse werden beim Anblick dieses verschmitzten und kuscheligen, kleinen Fellknäuels weich.  \nAus diesem Grunde sollte man dieses Tier keinesfalls unterschätzen.",ep:1,g:1,l:1,wd:true,fm:true,w:10,c:"PZ=1",p:1};
I.u[1729] = {n:"O\' Mer-Ring",t:9,d:"Dieser Ring gehörte einst Mer, dem größten Faulpelz und Nichtsnutz von ganz Amakna. Er betrieb eine Götzenanbetung von Donutts und Rippchen.",ep:7,g:28,l:25,wd:true,fm:true,w:25,c:"CI<100&CC<100",p:1900};
I.u[1730] = {n:"Prise Salz",t:48,d:"Eine Prise Salz ist das beste Mittel, um schmackhafte Gerichte noch schmackhafter zu machen.",ep:1,g:261,l:1,wd:true,fm:true,w:1,p:1};
I.u[1731] = {n:"Topf mit schmackhafter Sauce",t:15,d:"Diese Sauce enthälte alle wesentlichen Aromen für ein herrlich würziges Mahl.",ep:1,g:262,l:1,wd:true,fm:true,w:1,p:4};
I.u[1732] = {n:"Frühstücksschale",t:15,d:"Es gibt nichts Praktischeres, um seine Suppe auszutrinken, ohne sie auslöffeln zu müssen.",ep:16,g:263,l:1,wd:true,fm:true,w:1,p:6};
I.u[1733] = {n:"Eintopf",t:15,d:"Einer für alle, und alle für einen - dieser Topf gleicht keinem! Das Fleisch, so zart und weich, ist hier in seinem Reich, dem Gemüse gleich. Lang lebe mein Eintopf! (Auszug aus der Hymne für Metzger, Opus 4)",ep:16,g:264,l:1,wd:true,fm:true,w:1,p:6};
I.u[1734] = {n:"Kirsche",t:46,d:"Diese Frucht ähnelt stark einem Paar dicker Kugeln.",ep:1,g:265,l:1,wd:true,fm:true,w:1,p:1};
I.u[1735] = {n:"Tierheimszertifikat: Maunzmiez",t:77,d:"Dieses Zertifikat enthält alle notwendigen Informationen über die Maunzmiez, die ihr im Tierheim abgegeben habt.",ep:3,g:24,l:1,wd:false,fm:true,w:1,p:100};
I.u[1736] = {n:"Zitrone",t:46,d:"Der Saft dieser Frucht hilft wie kein anderer, den Geruch nach verfaulendem Fleisch zu überdecken. Darum ist er auch immer dabei, wenn es Fischgerichte gibt, damit die  Illusion von Frische verbreitet wird.",ep:1,g:266,l:1,wd:true,fm:true,w:1,p:2};
I.u[1737] = {n:"Feldbrot",t:33,d:"Dieses Brot liegt sowohl schwer im Magen, als auch im Rucksack, doch muss man zugeben, dass es genau den rustikalen Geschmack hat, den man von Brot schlechthin erwartet.",ep:1,g:68,l:40,wd:true,fm:true,w:3,u:true,ut:true,p:1};
I.u[1738] = {n:"Stadtbrot",t:33,d:"Allein bei seinem bloßen Geruch bekommt man bereits Lust hineinzubeißen. Allerdings vergeht das nach mehreren Bissen schnell wieder, da dieses Brot sehr sättigend ist.",ep:1,g:69,l:10,wd:true,fm:true,w:2,u:true,ut:true,p:1};
I.u[1739] = {n:"Glühstäbchen",t:3,d:"Die Spitze dieses Stabs ist brennend heiß. Aber noch rätselhafter ist der Aschegeruch, der die Vermutung nahelegt, dass sein Holz einen Waldbrand überlebt hat.",ep:13,g:24,l:80,wd:true,fm:true,w:1,an:11,e:[5,4,2,3,40,50,false,true],c:"CI>60&CV>40",p:1};
I.u[1740] = {n:"Crocoburiose Verwandlung",t:27,d:"Das Crocobur enthält die Essenz des Crocoburio und kann seinem Meister nur gestohlen werden, indem man ihn tötet.",ep:4,g:2,l:1,wd:true,fm:true,w:0,m:true,p:1};
I.u[1741] = {n:"Phönix-Blut",t:14,d:"Das Blut des Phönix hat die Eigenschaft, Geister wiederzubeleben und gibt ein wenig Energie zurück.",ep:18,g:3,l:10,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:1000};
I.u[1742] = {n:"Phönix-Blut (Auslese)",t:14,d:"Das Blut des Phönix hat die Eigenschaft, Geister wiederzubeleben und gibt ein wenig Energie zurück.",ep:18,g:3,l:50,wd:true,fm:true,w:1,c:"Pg=23",ut:true,p:2500};
I.u[1744] = {n:"Schönes Büschel von Tarches Haar",t:24,d:"Dieses Haarbüschel beweist euren Sieg über Tarche. Einfach schön!",ep:1,g:30,l:1,wd:true,fm:true,w:0,p:1};
I.u[1745] = {n:"Tierarztspritze",t:24,d:"Spitzes Ende, Reservoir, furchterregendes Aussehen... Keine Zweifel möglich, dies ist eine Spritze. Seid gewarnt!",ep:1,g:31,l:1,wd:true,fm:true,w:0,p:1};
I.u[1746] = {n:"Blut des Wabbit GM",t:24,d:"Wer würde jemals auf die Idee kommen mit einer Spritze in der Hand auf die Insel der Wabbits zu reisen, um einer genetisch modifizierten Kreatur Blut abzunehmen? Keiner außer euch selbst, natürlich.",ep:8,g:32,l:1,wd:true,fm:true,w:0,p:1};
I.u[1747] = {n:"Analyse der Blutprobe des Wabbit GM",t:24,d:"Die Analyse lässt nur einen einzigen Schluss zu: das Blut wurde tatsächlich aus dem Hinterteil eines Wabbit GM entnommen. Nach langen und schwierigen Experimenten fanden die Alchimisten schließlich heraus, in welche Pobacke dabei gestochen wurde. Mit 90%iger Fehlertoleranz war es die Rechte.",ep:5,g:33,l:1,wd:true,fm:true,w:0,p:1};
I.u[1748] = {n:"Wabbit",t:18,d:"Dieser kleine Wabbit ist ganz zahm. Daher wird er euch nicht beißen. Doch das gilt nicht für die anderen...",ep:8,g:7,l:1,wd:true,fm:true,w:10,c:"PZ=1",s:11,p:1};
I.u[1749] = {n:"Jeton für den Jahrmarkt des Trools",t:15,d:"Diesen Jeton habt ihr von Leonzi Trool erworben, der damit seinen Traum voranbringen will, eines Tages in der Ebene von Cania einen Ort der Freude und des Spaßes zu schaffen, der für alle Kreaturen offen ist.",ep:13,g:737,l:1,wd:true,fm:true,w:1,p:1};
I.u[1750] = {n:"Stäbchenfisch",t:41,d:"Ein Stäbchenfisch ist dafür bekannt extrem kleinkariert zu sein. Kein Wunder, seine längliche Form beschränkt seine geistige Größe, weshalb er auch so leicht zu angeln ist.",ep:2,g:269,l:1,wd:true,fm:true,w:3,p:10};
I.u[1751] = {n:"Gesäuberter Stäbchenfisch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:270,l:1,wd:true,fm:true,w:2,p:1};
I.u[1752] = {n:"Gebratener Stäbchenfisch **",t:49,d:"Dieses leckere Stück Fisch enthält das Beste aus vielen erwachsenen Stäbchenfischen. Der Geschmack mundet selbst Kindern, doch ist der Nährwert nicht besonders hoch.",ep:2,g:71,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:60};
I.u[1753] = {n:"Gebratener Stäbchenfisch ***",t:49,d:"Dieses leckere Stück Fisch enthält das Beste aus vielen erwachsenen Stäbchenfischen. Der Geschmack mundet selbst Kindern, doch ist der Nährwert nicht besonders hoch.",ep:2,g:72,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1754] = {n:"Käpt\'n Igluglus-Fisch",t:41,d:"Diese seltene Art von Stäbchenfisch lebt in den eiskalten Gewässern des hohen Nordens, daher der Name. Weil er sich von polarem Plankton zu ernähren pflegt, ist sein Fleisch auch besonders reich an wertvollen Ballaststoffen.",ep:1,g:271,l:1,wd:true,fm:true,w:3,p:100};
I.u[1755] = {n:"Gesäuberter Käpt\'n Igluglus-Fisch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:272,l:1,wd:true,fm:true,w:2,p:100};
I.u[1756] = {n:"Gebratener Stäbchenfisch ****",t:49,d:"Dieser gebratene Käpt\'n Igluglus-Fisch ist nicht nur lecker, sondern besitzt zudem auch noch einen hohen Nährwert.",ep:1,g:73,l:1,wd:true,fm:true,w:1,c:"Ci<10",u:true,ut:true,p:10000};
I.u[1757] = {n:"Suriminikrebs",t:41,d:"Dieser besondere Krebs wird seiner Fülle an schmackhaftem Fleisch wegen sehr geschätzt. Zudem ist er der einzige Krebs, den man angeln kann. Er besitzt nämlich den Instinkt, die Angelschnur mit seinen Scheren zertrennen zu wollen, obwohl diese viel zu stumpf dafür sind.",ep:2,g:273,l:1,wd:true,fm:true,w:3,p:1};
I.u[1758] = {n:"Gesäuberter Suriminikrebs",t:62,d:"Dieser Krebs kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:274,l:1,wd:true,fm:true,w:2,p:1};
I.u[1759] = {n:"Exotischer Suriminikrebs",t:41,d:"Dieser seltene Verwandte des Suriminikrebses ist viel intelligenter als dieser. Doch manchmal, nach einer durchzechten Nacht zum Beispiel, lässt er seinen niederen Instinkten freien Lauf. Dann habt ihr eine Chance ihn zu fangen!",ep:1,g:275,l:1,wd:true,fm:true,w:3,p:20};
I.u[1760] = {n:"Gesäuberter exotischer Suriminikrebs",t:62,d:"Dieser Krebs kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:276,l:1,wd:true,fm:true,w:2,p:20};
I.u[1761] = {n:"Gesäuberter Kätzchenfisch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:278,l:1,wd:true,fm:true,w:1,p:1};
I.u[1762] = {n:"Tigerfisch",t:41,d:"Dieser Fisch ähnelt einem Kätzchenfisch, doch handelt es sich hier um die ausgewachsene Vollversion.",ep:1,g:279,l:1,wd:true,fm:true,w:3,p:30};
I.u[1763] = {n:"Gesäuberter Tigerfisch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:280,l:1,wd:true,fm:true,w:2,p:30};
I.u[1764] = {n:"Krebsstäbchen **",t:49,d:"Lässt sich überall genüßlich mit den Händen essen. Doch wehe, wenn man zuviel auf einmal davon verspachtelt hat!",ep:2,g:74,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:30};
I.u[1765] = {n:"Krebsstäbchen ***",t:49,d:"Diese Stäbchen sollte man langsam essen, sehr langsam sogar, und mit ein wenig Sauce für den Geschmack.",ep:2,g:75,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:60};
I.u[1766] = {n:"Krebsstäbchen ****",t:49,d:"Dieses Krebsstäbchen wurde aus dem Fleisch von exotischen Suriminikrebsen gefertigt. Daher schmeckt es einfach nur furchtbar. Dafür ist es allerdings unglaublich sättigend.",ep:1,g:76,l:1,wd:true,fm:true,w:1,c:"Ci<30",u:true,ut:true,p:30000};
I.u[1767] = {n:"Geräucherter Kätzchenfisch **",t:49,d:"Dieser mit Sorgfalt geräucherte Kätzchenfisch gibt eine tolle Mahlzeit ab. Doch Vorsicht: der Räuchergeruch sitzt noch wochenlang in eurer Kleidung fest.",ep:1,g:78,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:60};
I.u[1768] = {n:"Geräucherter Kätzchenfisch ***",t:49,d:"Dieser mit Sorgfalt geräucherte Kätzchenfisch gibt eine tolle Mahlzeit ab. Doch Vorsicht: der Räuchergeruch sitzt noch wochenlang in eurer Kleidung fest.",ep:1,g:79,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:90};
I.u[1769] = {n:"Geräucherter Tigerfisch ****",t:49,d:"Dieser Tigerfisch wird selbst die anspruchsvollsten Gourmets zufriedenstellen. Sein Fleisch ist etwas fester als das des geräucherten Katzenhais und vor allem sehr viel feiner!",ep:1,g:77,l:1,wd:true,fm:true,w:1,c:"Cw<40",u:true,ut:true,p:40000};
I.u[1770] = {n:"Kokos-Blob-Stück",t:15,d:"Dieses Blob-Stück riecht extrem stark nach Kokos. Wie kann ein einfaches Stück Monsterüberrest so stark nach Kokos riechen?",ep:5,g:281,l:34,wd:true,fm:true,w:1,p:1};
I.u[1771] = {n:"Ki-Maus",t:15,d:"Eine kleine grüne Ki-Maus, die durch die Prärie flitzt... (nicht zu verwechseln mit einer Mi-Maus!) Versucht erst  gar nicht, sie am Schwanz zu packen;\r\n            ihr schafft es ja doch nicht!",ep:13,g:282,l:1,wd:true,fm:true,w:2,p:1};
I.u[1772] = {n:"Kokos-Blob-Blüte",t:35,d:"Sagt es durch die Blume oder schweigt für immer!",ep:2,g:283,l:34,wd:true,fm:true,w:2,p:1};
I.u[1773] = {n:"Apfel-Blob-Stück",t:15,d:"Stück für Stück verschwinden die Stücke im Mund.",ep:5,g:284,l:34,wd:true,fm:true,w:1,p:1};
I.u[1774] = {n:"Apfel-Blob-Blüte",t:35,d:"Sagt es durch die Blume oder schweigt für immer!",ep:5,g:285,l:34,wd:true,fm:true,w:1,p:1};
I.u[1775] = {n:"Kirsch-Blob-Stück",t:15,d:"Stück für Stück verschwinden die Stücke im Mund.",ep:5,g:286,l:34,wd:true,fm:true,w:1,p:1};
I.u[1776] = {n:"Kirsch-Blob-Blüte",t:35,d:"Sagt es durch die Blume oder schweigt für immer!",ep:5,g:287,l:34,wd:true,fm:true,w:1,p:1};
I.u[1777] = {n:"Indigo-Blob-Stück",t:15,d:"Stück für Stück verschwinden die Stücke im Mund.",ep:5,g:288,l:34,wd:true,fm:true,w:1,p:1};
I.u[1778] = {n:"Indigo-Blob-Blüte",t:35,d:"Sagt es durch die Blume oder schweigt für immer!",ep:5,g:289,l:34,wd:true,fm:true,w:1,p:1};
I.u[1779] = {n:"Seebarsch",t:41,d:"Dieser Barsch lebt gern in großen Seen und Flüssen, die vom Schmelzwasser großer Gletscher gespeist werden. Seine Größe und Frische macht ihn darum zu einem beliebten Fang für Angler.",ep:2,g:290,l:40,wd:true,fm:true,w:3,p:1};
I.u[1780] = {n:"Gesäuberter Seebarsch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:291,l:40,wd:true,fm:true,w:2,p:1};
I.u[1781] = {n:"Gesäuberte Greu-Vette",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:293,l:1,wd:true,fm:true,w:1,p:1};
I.u[1782] = {n:"Gründling",t:41,d:"Dieser kleine, flinke Süßwasserfisch wird gern von Kinden und Amateur-Fischern geangelt, weil er an alles anbeißt, was sich bewegt. Einziger Nachteil: er macht nicht satt.",ep:1,g:294,l:1,wd:true,fm:true,w:3,p:1};
I.u[1783] = {n:"Gesäuberter Gründling",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:295,l:1,wd:true,fm:true,w:2,p:1};
I.u[1784] = {n:"Blaurochen",t:41,d:"Der Blaurochen ist der Herrscher über den Meeresgrund. Meist gräbt er sich in den sandigen Boden ein und lauert auf Beute. Doch in seltenen Fälle schwimmt er zur Meeresoberfläche und schnappt nach eurem Köder. Und das ist auch gut so.",ep:2,g:296,l:50,wd:true,fm:true,w:3,p:1};
I.u[1785] = {n:"Gesäuberter Blaurochen",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:297,l:50,wd:true,fm:true,w:2,p:1};
I.u[1786] = {n:"Horror-Greu-Vette",t:41,d:"Diese mutierte Greu-Vette hat die Fähigkeit, fürchterliche Geräusche zu produzieren, indem sie ihren Körper bewegt. Gut, dass diese Art nur sehr selten vorkommt.",ep:1,g:298,l:1,wd:true,fm:true,w:3,p:100};
I.u[1787] = {n:"Gesäuberte Horror-Greu-Vette",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:299,l:1,wd:true,fm:true,w:2,p:100};
I.u[1788] = {n:"Farle-Rochen",t:41,d:"Diese seltene Rochenart wurde erstmalig von Farle Ingalsse während eines seiner großen Abenteuer gefangen und identifiziert. Er fand heraus, dass diese überraschende Art alle anderen Fische mit seinem mächtigen Schrei entzaubern und in die Flucht schlagen kann.",ep:1,g:300,l:50,wd:true,fm:true,w:3,p:20};
I.u[1789] = {n:"Gesäuberter Farle-Rochen",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:301,l:50,wd:true,fm:true,w:2,p:20};
I.u[1790] = {n:"Imeer-Gründling",t:41,d:"Diese seltene Gründlingssorte stammt aus dem tiefsten Imeer südlich von Moons Insel. Obwohl diese Fische in den heißen Strömungen zu Hause sind, durchqueren sie 1x jährlich Tausende von Kilometern zum Laichen.",ep:1,g:302,l:1,wd:true,fm:true,w:3,p:1};
I.u[1791] = {n:"Gesäuberter Imeer-Gründling",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:321,l:1,wd:true,fm:true,w:2,p:1};
I.u[1792] = {n:"Wunder-Barsch",t:41,d:"Dieser Artverwandte des Seebarsches ist heutzutage vom Aussterben bedroht! Das liegt am dummen Aberglauben, sein Verzehr könne wahre Wunder vollbringen. Doch dem ist leider nicht so.",ep:1,g:303,l:70,wd:true,fm:true,w:3,p:30};
I.u[1793] = {n:"Gesäuberter Wunder-Barsch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:304,l:40,wd:true,fm:true,w:2,p:30};
I.u[1794] = {n:"Karpf\'Ediem",t:41,d:"Dieser Fisch gehört zu den Weisensten unter allen Süßwasserfischen. Er wird niemals an einer Angel anbeißen, es sei denn, er will nicht mehr länger leben.",ep:2,g:305,l:40,wd:true,fm:true,w:3,p:1};
I.u[1795] = {n:"Gesäuberter Karpf\'Ediem",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:306,l:10,wd:true,fm:true,w:2,p:1};
I.u[1796] = {n:"Sandkärpfchen",t:41,d:"Dieser kleine Karpfen besitzt die gleiche Farbe wie der Sand am Strand. Eine Entwicklung der Natur, die es ihm erlaubt, sich in der Umgebung zu tarnen. Dumm nur, dass es am Grunde der Seen meist keinen Sand gibt...",ep:1,g:307,l:40,wd:true,fm:true,w:3,p:1};
I.u[1797] = {n:"Gesäubertes Sandkärpfchen",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:308,l:10,wd:true,fm:true,w:2,p:1};
I.u[1798] = {n:"Gesäuberter Krakamor",t:62,d:"Dieser Krakamor kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:310,l:20,wd:true,fm:true,w:1,p:1};
I.u[1799] = {n:"Krakamor-Einzelgänger",t:41,d:"Dieser Krakamor wählt eine einzige Gefährtin für sein ganzes Leben. Das ist unglaublich selten, wenn man die Sitten und Gebräuche der Krakamors betrachtet.",ep:1,g:311,l:20,wd:true,fm:true,w:3,p:30};
I.u[1800] = {n:"Gesäuberter Krakamor-Einzelgänger",t:62,d:"Dieser einzigartige Krakamor kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:312,l:20,wd:true,fm:true,w:2,p:30};
I.u[1801] = {n:"Flussbarsch",t:41,d:"Unter seiner idiotischen und trägen Fassade versteckt sich der cleverste und schnellste Fisch ganz Amaknas. Dennoch lohnt es sich, ihn zu angeln, da er auch gleichzeitig einer der wohlschmeckensten Fische der Ewigen Lande ist.",ep:3,g:313,l:70,wd:true,fm:true,w:3,p:1};
I.u[1802] = {n:"Gesäuberter Flußbarsch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:3,g:314,l:70,wd:true,fm:true,w:2,p:1};
I.u[1803] = {n:"Katzenbarsch",t:41,d:"Das Aussehen hat dieser Fisch vom Vater geerbt, die Wildheit von der Mutter. Er gehört zu den Fischen, die am schwersten zu fangen sind, und wird von Anglern gefürchtet. Gleichzeitig ist der Katzenbarsch auch einer der seltensten Fische, da die Paarung eines Kätzchenfisches mit einem Flussbarsch nur ganz selten vorkommt.",ep:1,g:315,l:70,wd:true,fm:true,w:3,p:50};
I.u[1804] = {n:"Gesäuberter Katzenbarsch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:316,l:70,wd:true,fm:true,w:2,p:50};
I.u[1805] = {n:"Glänzende Sardine",t:41,d:"Diesen Fisch sieht man schon von Weitem. Darum ist er auch ideal für angehende Fischer!",ep:2,g:317,l:20,wd:true,fm:true,w:3,p:1};
I.u[1806] = {n:"Gesäuberte glänzende Sardine",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:318,l:50,wd:true,fm:true,w:2,p:1};
I.u[1807] = {n:"Schattensardine",t:41,d:"Im Gegensatz zur glänzenden Sardine ist diese Sardinenart nahezu unsichtbar in trüben Gewässern, was den Anreiz, sie zu angeln noch erhöht.",ep:1,g:319,l:20,wd:true,fm:true,w:3,p:1};
I.u[1808] = {n:"Gesäuberte Schattensardine",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:320,l:50,wd:true,fm:true,w:2,p:1};
I.u[1809] = {n:"Gegrillter Seebarsch **",t:49,d:"Dieser Fisch ist zwar nicht besonders schmackhaft, doch kann man ihn gut essen, wenn er so appetitsanregend auf seinem Salatbett liegt. Außerdem füllt er gut den Magen.",ep:2,g:98,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:180};
I.u[1810] = {n:"Gegrillter Seebarsch ***",t:49,d:"Dieser Fisch ist zwar nicht besonders schmackhaft, doch kann man ihn gut essen, wenn er so appetitsanregend auf seinem Salatbett liegt. Außerdem füllt er gut den Magen.",ep:2,g:80,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:320};
I.u[1811] = {n:"Greu-Vette im Teigmantel **",t:49,d:"Wer wird nicht schwach beim Anblick einer knackigen Greu-Vette im Teigmantel? Da ist es schwer, mit Naschen aufzuhören, will man am Ende nicht so aussehen wie Otofu!",ep:1,g:81,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:20};
I.u[1812] = {n:"Greu-Vette im Teigmantel ***",t:49,d:"Wer wird nicht schwach beim Anblick einer knackigen Greu-Vette im Teigmantel? Da ist es schwer, mit Naschen aufzuhören, will man am Ende nicht so aussehen wie Otofu!",ep:1,g:82,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:30};
I.u[1813] = {n:"Gründling in Scheiben **",t:49,d:"Diese mit Zwiebeln überzogenen Gründlingsscheiben sind ein wahrer Genuß, wäre da nur nicht der schlechte Geruch, der sich einige Stunden nach dem Verzehr bemerkbar macht.",ep:1,g:83,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:20};
I.u[1814] = {n:"Gründling in Scheiben ***",t:49,d:"Diese mit Zwiebeln überzogenen Gründlingsscheiben sind ein wahrer Genuß, wäre da nur nicht der schlechte Geruch, der sich einige Stunden nach dem Verzehr bemerkbar macht.",ep:1,g:84,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:30};
I.u[1815] = {n:"Rochenflossen **",t:49,d:"Mit brauner Bworkbutter überbacken, entfaltet diese Rochenflosse erst so richtig ihren vollen Geschmack. Ihr werdet sehen: dieser Fisch verleiht euch Flügel...",ep:2,g:85,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:180};
I.u[1816] = {n:"Rochenflossen ***",t:49,d:"Mit brauner Bworkbutter überbacken, entfaltet diese Rochenflosse erst so richtig ihren vollen Geschmack. Ihr werdet sehen: dieser Fisch verleiht euch Flügel...",ep:2,g:86,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:340};
I.u[1817] = {n:"Gedünsteter Karpf\'Ediem ****",t:49,d:"Dieser Fisch wird nur gedämpft, um seinen feinen natürlichen Geschmack nicht zu verändern. Denn er ist so unglaublich lecker, dass es einen umhaut.",ep:1,g:87,l:1,wd:true,fm:true,w:1,c:"Cw<60",u:true,ut:true,p:60000};
I.u[1818] = {n:"Gedünsteter Karpf\'Ediem **",t:49,d:"Dieser Fisch wird nur gedämpft, um seinen feinen natürlichen Geschmack nicht zu verändern. Der leckere Geschmack lässt den täglichen Stress von euch abfallen und euch eure Sorgen für einen Moment vergessen.",ep:2,g:88,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:130};
I.u[1819] = {n:"Gedünsteter Karpf\'Ediem ***",t:49,d:"Dieser Fisch wird nur gedämpft, um seinen feinen natürlichen Geschmack nicht zu verändern. Der leckere Geschmack lässt den täglichen Stress von euch abfallen und euch eure Sorgen für einen Moment vergessen.",ep:2,g:89,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:200};
I.u[1820] = {n:"Gegrillter Krakamor **",t:49,d:"Ein gegrillter Krakamor entwickelt einen strengen Geruch. Doch wenn dieser verwunden werden kann, so erwartet den Gaumen ein echter Leckerbissen. Dazu ein kleiner Ratschlag am Rande: aufgespießt auf einem kleinen Stocher lässt er sich viel praktischer essen.",ep:2,g:90,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:130};
I.u[1821] = {n:"Gegrillter Krakamor ***",t:49,d:"Ein gegrillter Krakamor entwickelt einen strengen Geruch. Doch wenn dieser verwunden werden kann, so erwartet den Gaumen ein echter Leckerbissen. Dazu ein kleiner Ratschlag am Rande: aufgespießt auf einem kleinen Stocher lässt er sich viel praktischer essen.",ep:2,g:91,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:200};
I.u[1822] = {n:"Gebratener Flussbarsch",t:49,d:"Nach vielen Sprüngen im Wasser, und einem letzten verpatztem Sprung an Land, kann dieser Fisch jetzt genüßlich verspeist werden.",ep:3,g:93,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:300};
I.u[1823] = {n:"Gebratener Flussbarsch ***",t:49,d:"Nach vielen Sprüngen im Wasser, und einem letzten gelungenem Sprung an Land, kann dieser Fisch jetzt genüßlich verspeist werden.",ep:3,g:94,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:400};
I.u[1824] = {n:"Gebratener Flussbarsch ****",t:49,d:"Nach vielen Sprüngen im Wasser, und zwei letzten gelungenen Sprüngen an Land, kann dieser Fisch jetzt genüßlich verspeist werden.",ep:1,g:92,l:1,wd:true,fm:true,w:1,c:"Cw<100",u:true,ut:true,p:100000};
I.u[1825] = {n:"Ölsardine **",t:49,d:"Diese erst gekochte, dann in Öl getränkte Sardine ist zwar nicht sehr sättigend, aber als kleines Appetithäppchen ist sie wunderbar geeignet.",ep:2,g:96,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:80};
I.u[1826] = {n:"Ölsardine ***",t:49,d:"Diese erst gekochte, dann in Öl getränkte Sardine ist zwar nicht sehr sättigend, aber als kleines Appetithäppchen ist sie wunderbar geeignet.",ep:2,g:97,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:140};
I.u[1827] = {n:"Ölsardine ****",t:49,d:"Diese erst gekochte, dann in Öl getränkte Sardine ist zwar nicht sehr sättigend, aber als kleines Appetithäppchen ist sie wunderbar geeignet.",ep:1,g:95,l:1,wd:true,fm:true,w:1,c:"Ci<40",u:true,ut:true,p:40000};
I.u[1828] = {n:"Gegrillter Seebarsch ****",t:49,d:"Dieser Fisch ist besonders schmackhaft, wenn er so appetitanregend auf seinem Salatbett liegt. Außerdem füllt er gut den Magen.",ep:2,g:99,l:1,wd:true,fm:true,w:1,c:"Cw<70",u:true,ut:true,p:50000};
I.u[1829] = {n:"Greu-Vette im Teigmantel ****",t:49,d:"Wer wird nicht schwach beim Anblick einer knackigen Greu-Vette im Teigmantel? Da ist es schwer, mit Naschen aufzuhören. Dieser Leckerbissen wurde aus einer Horror-Greu-Vette hergestellt, die noch mehr Kalorien enthält als die normalen. Egal! Guten Appetit!",ep:1,g:100,l:1,wd:true,fm:true,w:1,c:"Ci<10",u:true,ut:true,p:10000};
I.u[1830] = {n:"Gründling in Scheiben ****",t:49,d:"Diese mit Zwiebeln überzogenen Imeer-Gründlingsscheiben sind ein wahrer Genuß. Bei dieser Gründlingsart gibt es auch keinen schlechten Geruch als Nebenwirkung. Im Gegenteil, die Luft wird sogar noch gut mit Sauerstoff versorgt!",ep:1,g:101,l:1,wd:true,fm:true,w:1,c:"Cw<10",u:true,ut:true,p:10000};
I.u[1831] = {n:"Rochenflossen ****",t:49,d:"Meisterhaft mit brauner Bworkbutter überbacken, entfaltet diese Farle-Rochenflosse erst so richtig ihren vollen Geschmack. Ihr werdet sehen: dieser Fisch verleiht euch Flügel...",ep:1,g:102,l:1,wd:true,fm:true,w:1,c:"Ci<70",u:true,ut:true,p:70000};
I.u[1832] = {n:"Flambierte Forelle **",t:49,d:"Dank des uralten, exotischen Kochrezeptes der Lenalds wird dieser hervorragend schmeckende Fisch die Flamme in euch wieder neu entfachen. Man müßte das Rezept nur noch beherrschen, was bei euch offensichtlich nicht der Fall ist.",ep:1,g:108,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:30};
I.u[1833] = {n:"Flambierte Forelle ***",t:49,d:"Dank des uralten, exotischen Kochrezeptes der Lenalds wird dieser hervorragend schmeckende Fisch die Flamme in euch wieder neu entfachen. Man müßte das Rezept nur noch beherrschen, was bei euch offensichtlich nicht der Fall ist.",ep:1,g:107,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:60};
I.u[1834] = {n:"Flambierte Forelle ****",t:49,d:"Dank des uralten, exotischen Kochrezeptes der Lenalds wird dieser hervorragend schmeckende Fisch die Flamme in euch wieder neu entfachen. Man müßte das Rezept nur noch beherrschen, was bei euch offensichtlich nicht der Fall ist.",ep:1,g:109,l:1,wd:true,fm:true,w:1,c:"Cw<20",u:true,ut:true,p:20000};
I.u[1835] = {n:"Gefüllter Hecht **",t:49,d:"Ach ja, ein gefüllter Hecht. Jeder isst ihn gern, doch niemand weiß, was alles in ihm steckt. Wenn sie nur wüßten... Würden sie ihn wohl trotzdem essen?",ep:2,g:132,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:80};
I.u[1836] = {n:"Gefüllter Hecht ***",t:49,d:"Ach ja, ein gefüllter Hecht. Jeder isst ihn gern, doch niemand weiß, was alles in ihm steckt. Wenn sie nur wüßten... Würden sie ihn wohl trotzdem essen!",ep:2,g:133,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:140};
I.u[1837] = {n:"Gefüllter Hecht ****",t:49,d:"Ach ja, ein gefüllter Hecht. Jeder isst ihn gern, doch niemand weiß, was alles in ihm steckt. Nicht alles wissen zu wollen ist definitiv ein Zeichen von Weisheit!",ep:1,g:134,l:1,wd:true,fm:true,w:1,c:"Cw<40",u:true,ut:true,p:40000};
I.u[1838] = {n:"Haifischfilet, scharf gewürzt **",t:49,d:"Dieser Hai hätte sicherlich nicht die Güte gehabt, euch erst noch vor dem Essen mit Gewürzen zu bestreuen.",ep:2,g:103,l:1,wd:true,fm:true,w:3,u:true,ut:true,p:300};
I.u[1839] = {n:"Haifischfilet, scharf gewürzt ***",t:49,d:"Dieser Hai hätte sicherlich nicht die Güte gehabt, euch erst noch vor dem Essen mit vielerlei Gewürzen zu bestreuen.",ep:2,g:104,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:400};
I.u[1840] = {n:"Haifischfilet, scharf gewürzt ****",t:49,d:"Dieser Hai hätte sicherlich nicht die Güte gehabt, euch erst noch vor dem Essen mit magischen Gewürzen zu bestreuen.",ep:1,g:105,l:1,wd:true,fm:true,w:1,c:"Ci<100",u:true,ut:true,p:100000};
I.u[1844] = {n:"Forelle",t:41,d:"Forellen sind relativ leicht zu fangen. Erfahrene Angler nutzen meist gleich 3 Angeln parallel, um sie zu fischen. Denn zudem schmecken diese Fische auch einfach gut.",ep:1,g:394,l:1,wd:true,fm:true,w:3,p:0};
I.u[1845] = {n:"Gesäuberte Forelle",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:396,l:1,wd:true,fm:true,w:2,p:1};
I.u[1846] = {n:"Ur-Forelle",t:41,d:"Dies ist eine der ältesten Forellen ganz Amaknas. Falls sie, wie man sagt, mit dem Alter weiser geworden ist, dann muss sie nun zu den weisesten Wesen der ewigen Lande gehören... Doch daran bestehen noch berechtigte Zweifel.",ep:1,g:398,l:1,wd:true,fm:true,w:3,p:1};
I.u[1847] = {n:"Hecht",t:41,d:"Dieser große Süßwasserfisch ist der beste Barbecue-Freund des Fischers.",ep:2,g:400,l:10,wd:true,fm:true,w:3,p:1};
I.u[1848] = {n:"Gesäuberter Hecht",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:401,l:10,wd:true,fm:true,w:2,p:1};
I.u[1849] = {n:"Tolla-Hecht",t:41,d:"Diese neue Hechtart wurde von den Wissenschaftlern Tolla und Hecht nach vielen experimentellen Kreuzungen entwickelt. Sie besitzt magische Eigenschaften, dank deren einigen Exemplaren dieser seltenen Art bei einem Streit zwischen den Wissenschaftlern die Flucht gelang.",ep:1,g:402,l:10,wd:true,fm:true,w:3,p:1};
I.u[1851] = {n:"Gesäuberter Tolla-Hecht",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:403,l:10,wd:true,fm:true,w:2,p:1};
I.u[1852] = {n:"Gesäuberter Sichel-und-Hammerhai",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:2,g:323,l:80,wd:true,fm:true,w:2,p:1};
I.u[1853] = {n:"Raufkauschhai",t:41,d:"Dieser Verwandte des Sichel-und-Hammerhais ist noch sehr viel wilder und chaotischer als dieser. Darum ist es der Traum eines jeden Fischers, sich mit einem solchen Fang einen Namen zu machen. Immer vorausgesetzt, dass er hinterher noch am Leben ist.",ep:1,g:324,l:80,wd:true,fm:true,w:4,p:1};
I.u[1854] = {n:"Gesäuberter Raufkauschhai",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden.",ep:1,g:325,l:80,wd:true,fm:true,w:3,p:1};
I.u[1855] = {n:"Zackenbarsch",t:41,d:"Diese faule Fisch schläft die ganze Zeit über. Darum ist er auch so schwer zu fangen.",ep:1,g:0,l:1,wd:true,fm:true,w:2,p:1};
I.u[1856] = {n:"Gesäuberter Zackenbarsch",t:62,d:"Dieser Fisch kann nun als Zutat für leckere Gerichte verwendet werden",ep:1,g:0,l:1,wd:true,fm:true,w:2,p:1};
I.u[1859] = {n:"Gegrillter Krakamor ****",t:49,d:"Ein feiner Duft entströmt diesem gegrillten Krakamor. Wer ihn isst, wird noch lange an diesen Gaumenschmaus zurückdenken.",ep:1,g:91,l:1,wd:true,fm:true,w:1,c:"Ci<50",u:true,ut:true,p:50000};
I.u[1860] = {n:"Harpunenangel",t:20,d:"Diese äußerst widerstandsfähige Angel besitzt einen Köder in Form einer Harpunenspitze, die speziell für die Haifischerei entwickelt wurde.",ep:1,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1861] = {n:"Barschstabangel",t:20,d:"Diese Angel wurde speziell dafür konzipiert, die flinken Barsche zu fangen.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,8,100,100,false,false],c:"PJ>36,99",p:20000};
I.u[1862] = {n:"Liebesstab",t:20,d:"Dem Holz dieser Angel entströmt ein süsslicher Geruch, der auch ihre Schnur und ihren Köder durchtränkt. Er ähnelt den Lockstoffen, die eine Krakamora ausstößt, um Krakamors anzulocken.",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1863] = {n:"Chôs Angel",t:20,d:"Chô war der beste Koch der Tafelrunde. Er beherrschte insbesondere die Fähigkeit, frische Gerichte direkt vor den Kunden zuzubereiten. Diese Angel hier erlaubte ihm beispielsweise das Fangen der Fische für seine Spezialität direkt im Gasofen: \"Gas-Barsch Chô\".",ep:2,g:8,l:1,wd:true,fm:true,w:5,an:18,e:[1,6,1,6,100,100,false,false],c:"PJ>36,59",p:10000};
I.u[1864] = {n:"Strickangel",t:20,d:"Die Schnur dieser Angel besteht ganz aus Wolle und der Köder hat die Form eines Wollknäuels. Dem können nur ganz wenige Kätzchenfische widerstehen.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1865] = {n:"KonKubussische Angel",t:20,d:"Diese Angel wurde speziell an die außergewöhnliche Morphologie der Folienfische angepasst.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,6,1,4,100,100,false,false],c:"PJ>36,29",p:5000};
I.u[1866] = {n:"Standardangel",t:20,d:"Diese weit verbreitete und überall gebräuchliche Angel wird es jungen Anglern ermöglichen, überall zu angeln. Immer vorausgesetzt, dass sie die dafür nötige Geduld aufbringen.",ep:2,g:8,l:1,wd:true,fm:true,w:3,an:18,e:[1,4,1,3,100,100,false,false],c:"PJ>36,9",p:1000};
I.u[1867] = {n:"Große Angel",t:20,d:"Diese Angel ist ausschließlich professionellen Fischern vorbehalten. Sie erlaubt es, den Köder sehr weit auszuwerfen. Dennoch muss man sie perfekt beherrschen, um  mit ihr Fänge machen zu können.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,5,100,100,false,false],c:"PJ>36,39",p:2000};
I.u[1868] = {n:"Teleskopangel",t:20,d:"Diese Angel kann eine wahrlich erschreckende Länge erreichen. Nur echte Meister des Angelns wissen ihr volles Potential zu nutzen.",ep:2,g:8,l:1,wd:true,fm:true,w:4,an:18,e:[1,4,1,7,100,100,false,false],c:"PJ>36,69",p:4000};
I.u[1869] = {n:"Zahnentferner",t:24,d:"Dieser Zahnentferner wird hauptsächlich für Fresssäcke eingesetzt, allerdings hindert euch nichts daran, dieses Gerät zu verwenden, um eure Karies damit zu behandeln, falls euch der Sinn danach steht.",ep:2,g:34,l:1,wd:true,fm:true,w:0,p:1};
I.u[1870] = {n:"Fresssackzahn",t:24,d:"Dieser Fresssackzahn sieht einem menschlichen Zahn zum Verwechseln ähnlich.",ep:1,g:35,l:1,wd:true,fm:true,w:0,p:1};
I.u[1871] = {n:"Halskette",t:24,d:"Diese ist die verlorene Halskette der Tochter des Bürgermeisters. Leider ist sie in einem sehr schlechten Zustand, da sie ein Verdauungsschläfchen im Magen eines Rablings hinter sich hat.",ep:2,g:36,l:1,wd:true,fm:true,w:0,p:1};
I.u[1872] = {n:"Schießpulver",t:24,d:"Dies ist Schießpulver. Ein kleines Schild zeigt die korrekte Benutzung in einfachen Worten an: \nPulver + Flamme = Explosion!",ep:2,g:37,l:1,wd:true,fm:true,w:0,p:1};
I.u[1873] = {n:"Steinblock",t:24,d:"Dieser Steinblock aus Teilen eines Krachlers der Ebenen ähnelt jenen Steinblöcken, aus denen die Stadtmauern von Bonta gebaut wurden. Zufall?",ep:2,g:38,l:1,wd:true,fm:true,w:0,p:1};
I.u[1874] = {n:"Skorpiutgift",t:24,d:"Dieses Skorpiutgift sollte besser nicht in die Hände von Dritten gelangen.",ep:2,g:39,l:1,wd:true,fm:true,w:2,p:1};
I.u[1875] = {n:"Sense von Meister Rab",t:24,d:"Warum diese Sense zum Abtrennen von Weizenähren verwenden, wenn man mit ihr auch Granit zerteilen kann?",ep:2,g:40,l:1,wd:true,fm:true,w:0,p:1};
I.u[1876] = {n:"Untersuchungsformular",t:24,d:"Dieses Untersuchungsformular konform zur Neuregelung nach dem Brâkmar-Gerichtsbeschluss Nr. 243a erlaubt die genaue Identifizierung der Teilnahme oder nicht Teilnahme an...",ep:2,g:41,l:1,wd:true,fm:true,w:0,p:1};
I.u[1877] = {n:"Löcheriger Hood",t:24,d:"Der Vorbesitzer dieses Hutes scheint einige Schläge eingesteckt zu haben. Das kommt eben davon, wenn man sich gegen die Autorität Bontas auflehnt.",ep:1,g:42,l:1,wd:true,fm:true,w:0,p:1};
I.u[1878] = {n:"Spezialkarte",t:24,d:"Diese Spielkarte mit dem seltsamen Aussehen ist noch so gut wie neu! Perfekt erhalten wie sie ist, könnte man glatt vermuten, sie sei ein Sammlerstück.",ep:2,g:43,l:1,wd:true,fm:true,w:0,p:1};
I.u[1879] = {n:"Kiste mit Stichwaffen",t:24,d:"Ein Kiste mit Stichwaffen, die mit stumpfen Gegenständen jedlicher Art gefüllt ist. Seltsam.",ep:2,g:44,l:1,wd:true,fm:true,w:500,p:1};
I.u[1880] = {n:"Dose Shobäh",t:24,d:"Lecker! Shobäh! Das wird euren Kanigrou glücklich machen.",ep:2,g:45,l:1,wd:true,fm:true,w:0,p:1};
I.u[1881] = {n:"Schlamm",t:24,d:"So, das wäre vollbracht.",ep:2,g:46,l:1,wd:true,fm:true,w:2,p:1};
I.u[1882] = {n:"Zerstampfte Blobblüten",t:24,d:"Welch ein böser Blobblütenbrei!",ep:2,g:47,l:1,wd:true,fm:true,w:0,p:1};
I.u[1883] = {n:"Restaurierte Halskette",t:24,d:"Nun ist die Halskette, die der Tochter des Bürgermeisters verloren gegangen war, wieder so gut wie neu.",ep:2,g:48,l:1,wd:true,fm:true,w:0,p:1};
I.u[1889] = {n:"Rabling-Feder",t:53,d:"Während Rabling-Federn früher gern als Schreibfedern verwendet wurden, werden sie heute eher in der Bekleidungsindustrie verwendet. Denn die Rablinge von heute sind nicht mehr das, was sie einmal waren. Sie bieten nicht mehr jedem Erstbesten ihre Federn dar, sondern verteidigen sie mit Krallen und Schnabel. Tja, die Zeiten ändern sich eben.",ep:1,g:327,l:20,wd:true,fm:true,w:1,p:1};
I.u[1890] = {n:"Kanigrou-Haare",t:54,d:"Kanigrouhaare reflektieren Sonnenlicht auf eine seltsame Art und Weise, fast so, als würden sie erst einen Großteil des einfallenden Lichts absorbieren, um die unverdaulichen Reste dann wieder auszustrahlen.",ep:13,g:359,l:70,wd:true,fm:true,w:1,p:1};
I.u[1891] = {n:"Schlängelchenhaut",t:59,d:"Habt ihr nicht auch schon immer von einer kleinen Handtasche aus Schlängelchenhaut geträumt? Nicht? Recht habt ihr, denn sie hält nicht, was sie verspricht.",ep:2,g:361,l:10,wd:true,fm:true,w:1,p:1};
I.u[1892] = {n:"Feder von Meister Rab",t:53,d:"\"Von Panik erfüllt, spreizte Meister Rab weit seine Flügel und ließ eine wunderschöne Feder fallen.\" In euren Träumen vielleicht läuft dies manchmal so ab, aber in Wirklichkeit sieht die Sache anders aus...",ep:13,g:362,l:160,wd:true,fm:true,w:1,p:1};
I.u[1893] = {n:"Skorpiutschwanz",t:65,d:"Dies ist eine tolle Trophäe. Schade nur, dass eine übelriechende Flüssigkeit daraus ausläuft.",ep:14,g:363,l:36,wd:true,fm:true,w:1,p:1};
I.u[1894] = {n:"Haare des Keilers der Ebenen",t:54,d:"Diese Haare sind einfach nur abstoßend. Doch wenn man sie unter einem Mikroskop beobachtet, sieht man, dass sie von einem ganzen Mikrokosmos bewohnt sind. Welch ein Glück ihr doch habt!",ep:13,g:364,l:44,wd:true,fm:true,w:1,p:1};
I.u[1895] = {n:"Feubuk Bier",t:37,d:"Dieses starke Bier mit hohem Alkoholgehalt wird euch wieder ein wenig Leben einhauchen.",ep:16,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:4};
I.u[1896] = {n:"Vogelfleisch",t:63,d:"Dieser Vogelschlegel beweist, dass die Jäger von Zeit zu Zeit auch mit Zartgefühl vorgehen können.",ep:1,g:348,l:1,wd:true,fm:true,w:2,p:1};
I.u[1897] = {n:"Vogelfleisch **",t:63,d:"Mini-Kwackschlegel für maximalen Geschmack.",ep:1,g:349,l:40,wd:true,fm:true,w:2,p:1};
I.u[1898] = {n:"Larvenfleisch",t:63,d:"Dieser gelbliche, stinkende Haufen ist alles, was in der Larve steckt. Kein Wunder, dass diese Biester eine so widerstandsfähige Haut haben.",ep:1,g:354,l:1,wd:true,fm:true,w:2,p:1};
I.u[1899] = {n:"Larvenfleisch **",t:63,d:"Dieser gelbliche, stinkende Haufen ist alles, was in der Larve steckt. Kein Wunder, dass diese Biester eine so widerstandsfähige Haut haben.",ep:1,g:354,l:9,wd:true,fm:true,w:2,p:1};
I.u[1900] = {n:"Larvenfleisch ***",t:63,d:"Dieser gelbliche, stinkende Haufen ist alles, was in der Larve steckt. Kein Wunder, dass diese Biester eine so widerstandsfähige Haut haben.",ep:1,g:354,l:10,wd:true,fm:true,w:2,p:1};
I.u[1901] = {n:"Wabbitkeule ****",t:63,d:"Diese Keule ist vollkommen. Man kann bei ihrem Anblick nur weit die Augen aufreißen, und kurz danach den Mund.",ep:2,g:368,l:80,wd:true,fm:true,w:2,p:1};
I.u[1902] = {n:"Wabbitkeule",t:63,d:"Diese Wabbitkeule scheint mit Kawotten angemacht worden zu sein. Ideal für einen Eintopf.",ep:8,g:365,l:20,wd:true,fm:true,w:2,p:1};
I.u[1903] = {n:"Wabbitkeule **",t:63,d:"Ideal für die rustikale Küche.",ep:8,g:366,l:40,wd:true,fm:true,w:2,p:1};
I.u[1904] = {n:"Weiße Dracheischale",t:16,d:"Dies ist die gepolsterte Schale eines Dracheis. Sie ist ideal, euch gegen die Blitzstrahlen von betrunkenen Bwork Magi zu schützen. Einziger Nachteil: damit seht ihr immer aus wie frisch aus einem Ei geschlüpft.",ep:11,g:28,l:39,wd:true,fm:true,w:50,p:4200};
I.u[1905] = {n:"Wabbitkeule ***",t:63,d:"Diese ist eine fette Keule, welche die meisten aller Mägen stopfen sollte.",ep:8,g:367,l:60,wd:true,fm:true,w:2,p:1};
I.u[1907] = {n:"Hasenohren",t:16,d:"Diese Ohren werden euer fröhliches Lächeln unterstreichen und euch mit einem ständigen Fluss an Gerüchten über eure Person eindecken.",ep:1,g:30,l:30,wd:true,fm:true,w:9,p:2600};
I.u[1908] = {n:"Chafer-Helm",t:16,d:"Selbst Spartagfuss, der Schnitter, hatte nicht das Glück, diesen Helm zu tragen, welcher dank der edlen Edelsteinen und qualitativ hochwertigen Verarbeitung sehr widerstandsfähig ist. Ihr seid doch ein echter Glückspilz!",ep:13,g:31,l:50,wd:true,fm:true,w:18,p:6500};
I.u[1910] = {n:"Ouginakmantel",t:17,d:"Dieser Mantel stammt von einem Ouginak. Man kann daher noch den schwachen Geruch seiner feuchten, warmen Schnauze wahrnehmen, welcher ein wenig dem der Zitzen eines brünftigen Fresssackweibchens ähnelt.",ep:14,g:33,l:50,wd:true,fm:true,w:10,p:6650};
I.u[1911] = {n:"Fresssackkeule",t:63,d:"Diese kleine Keule eines Fresssäckchens ist leider ziemlich klein, doch dafür groß im Geruch. Glücklicherweise soll dieser beim Braten verschwinden, sagt man.",ep:1,g:334,l:10,wd:true,fm:true,w:2,p:1};
I.u[1912] = {n:"Fresssackkeule **",t:63,d:"Diese Keule stinkt nach Tod und Verderben. Das kommt aber nicht vom verfrühten Ableben des Vorbesitzers.",ep:1,g:335,l:20,wd:true,fm:true,w:2,p:1};
I.u[1913] = {n:"Fresssackkeule ***",t:63,d:"Diese Keule stammt von einem alten Fresssack-Anführer. Steinhart wie sie ist, wäre sie ein mächtiger Totschläger, wäre da nur nicht ihr fürchterlicher Geruch. Doch nahrhaft ist sie, wie keine andere!",ep:1,g:336,l:40,wd:true,fm:true,w:2,p:1};
I.u[1914] = {n:"Fresssack-Keule ****",t:63,d:"Zart und doch saftig, nicht zu fett und nicht zu trocken ist diese Fresssackkeule. Und je abgehangener, desto schmackhafter ist sie.",ep:1,g:337,l:50,wd:true,fm:true,w:2,p:1};
I.u[1915] = {n:"Insektenfleisch",t:63,d:"Man sollte den Nährwert dieses glibbrigen, übelriechenden Stück Fleisches nicht unterschätzen.",ep:1,g:370,l:1,wd:true,fm:true,w:2,p:1};
I.u[1916] = {n:"Insektenfleisch **",t:63,d:"Dieses Fleisch ähnelt dem von Insekten, doch ist 10x mehr dran. Gut, dass einige Abenteurer so etwas mögen.",ep:3,g:370,l:50,wd:true,fm:true,w:4,p:1};
I.u[1917] = {n:"Schweinebraten",t:63,d:"Dieses Stück wildes Schweinefleisch ist noch nicht ganz gezähmt. Es blutet noch vor sich hin, gleich einem letzten Aufbäumen seiner Kräfte, bevor es in die Pfanne kommt.",ep:1,g:331,l:30,wd:true,fm:true,w:3,p:1};
I.u[1918] = {n:"Schweinebraten **",t:63,d:"Noch dicker für noch längere Freude! So sprach der glückliche Jäger, bevor er das Tier für seine Freunde in Scheiben schnitt.",ep:13,g:331,l:50,wd:true,fm:true,w:3,p:1};
I.u[1919] = {n:"Schweinebraten ****",t:63,d:"Dieses Stück Schweinedrachenfleisch ist so zart und butterweich, dass man daraus sogar ein königliches Kissen anfertigen könnte. Doch wird es meist lieber gegessen.",ep:2,g:331,l:80,wd:true,fm:true,w:4,p:1};
I.u[1920] = {n:"Milizabzeichen",t:24,d:"Dieses Abzeichen dient dazu, Angehörige der Miliz unter den Toten eines Schlachtfeldes zu identifizieren. Allerdings gibt es derzeit auch in Brâkmar den Trend, solche Abzeichen zu sammeln.",ep:2,g:49,l:1,wd:false,fm:true,w:0,p:1};
I.u[1921] = {n:"Schweinebraten ***",t:63,d:"Saftig, wie dieses Fleischstück ist, muss das dazugehörige Schwein ganz schön fit geblieben sein.",ep:1,g:331,l:60,wd:true,fm:true,w:3,p:1};
I.u[1922] = {n:"Dracofleisch",t:63,d:"Dieses seltene Fleisch guter Qualität hat die Eigenschaft, die Hitze des Backofens noch viele Stunden lang zu speichern, was ziemlich praktisch ist, wenn man auf Reisen geht.",ep:2,g:371,l:40,wd:true,fm:true,w:2,p:1};
I.u[1923] = {n:"Dracofleisch **",t:63,d:"Dieses Dracofleisch besitzt nicht nur gute thermische Eigenschaften, sondern schmeckt auch noch gut. Ein wenig wie geräucherter Schinken, um genau zu sein.",ep:2,g:371,l:60,wd:true,fm:true,w:2,p:1};
I.u[1924] = {n:"Dracofleisch ***",t:63,d:"Das Fleisch von Dracheiern ist zwar ein wenig zäh, aber dafür auch viel nahrhafter als gewöhnliches Dracofleisch. Einige behaupten sogar, es habe magische Kräfte.",ep:11,g:371,l:70,wd:true,fm:true,w:2,p:1};
I.u[1925] = {n:"Freistellung für 24 Stunden",t:24,d:"Dieses Schreiben der Miliz bestätigt, dass ihr 24 Stunden lang freigestellt seid.",ep:2,g:50,l:1,wd:true,fm:true,w:0,p:1};
I.u[1926] = {n:"Dracofleisch ****",t:63,d:"Diese Fleischstück kommt aus dem Drachenteil eines Schweinedrachens. Es ist ein wahres Geschenk des Himmels, was ja auch kein Wunder ist, da ein Schweinedrachen schließlich fliegen kann.",ep:2,g:371,l:80,wd:true,fm:true,w:2,p:1};
I.u[1927] = {n:"Monsterschnauze",t:63,d:"Diese WullyWuWulf-Schnauze mit den knackigen Lefzen ist ideal als Beilage zum Salat.",ep:1,g:372,l:30,wd:true,fm:true,w:1,p:1};
I.u[1928] = {n:"Hauer des aggressiven Keilers",t:24,d:"Es war sicherlich einiges an Geschicklichkeit notwendig, um einem Keiler der Ebenen diesen Hauer abzunehmen.",ep:2,g:51,l:1,wd:true,fm:true,w:0,p:1};
I.u[1929] = {n:"Monsterschnauze **",t:63,d:"Von dieser leckeren Monsterschnauze kann man essen, bis man träge wird. Denn man wird den Geschmack nie leid.",ep:1,g:373,l:50,wd:true,fm:true,w:2,p:1};
I.u[1930] = {n:"Monsterschnauze ***",t:63,d:"Dieses Fleischstück schmeckt einfach vorzüglich. Doch Vorsicht: nicht zuviel davon zu essen! Nicht ohne Grund hat ein MuWulf solch einen schlimmen Mundgeruch.",ep:2,g:374,l:70,wd:true,fm:true,w:2,p:1};
I.u[1931] = {n:"Schartiges Katana",t:24,d:"Dies ist die Waffe von Amayiro. Sie liegt hervorragend in der Hand, scheint allerdings an manchen Stellen ein wenig rissig zu sein.",ep:2,g:52,l:1,wd:true,fm:true,w:0,p:1};
I.u[1932] = {n:"Instandgesetztes Katana",t:24,d:"Das ehemals schartige Katana ist nun wieder wie neu und bereit, alles und jeden zu zerschneiden. Amayiro wird sicherlich nicht enttäuscht sein.",ep:2,g:53,l:1,wd:true,fm:true,w:0,p:1};
I.u[1933] = {n:"Vogelfleisch ****",t:63,d:"Dieses kleine Stück Rablingfleisch steckt voller mächtiger Magie, die höchstwahrscheinlich vom berühmt-berüchtigten Meister Rab höchstpersönlich stammt.",ep:13,g:350,l:30,wd:true,fm:true,w:2,p:1};
I.u[1934] = {n:"Jagdmesser",t:20,d:"Dieses Messer ist ein typisches Erkennungsmerkmal von Jägern. Je größer, schärfer und glänzender, desto begehrter ist es. Seltsame Kriterien...",ep:1,g:14,l:1,wd:true,fm:true,w:2,an:13,e:[10,3,1,1,25,30,false,false],c:"PJ>41,0",p:1};
I.u[1935] = {n:"Schuldschein über 100.000 Kama",t:24,d:"\"Wer seine Schulden stets begleicht, großen Reichtum wohl erreicht\", heißt es. Das ist ja schön und gut, doch sind 100.000 Kama eine gewaltige Summe. Es wäre besser, Schulden dieser Größenordnung in Zukunft zu vermeiden. Euer Geldbeutel wird es euch danken.",ep:1,g:54,l:1,wd:true,fm:true,w:0,p:1};
I.u[1936] = {n:"Jagdbeil",t:20,d:"Dieses schwere Beil ist sehr wirkungsvoll, wenn es darum geht, schnell und präzise jedes beliebige Körperteil von noch lebendigen Tieren abzutrennen.",ep:1,g:15,l:1,wd:true,fm:true,w:5,an:17,e:[10,4,1,1,30,40,false,false],c:"PJ>41,9",p:1000};
I.u[1937] = {n:"Spionagebericht",t:24,d:"Dieser handschriftliche Bericht von Bishom Pot enthält sicherliche viele Informationen über die täglichen Handlungen und Taten der Einwohner Brâkmars.",ep:2,g:55,l:1,wd:true,fm:true,w:0,p:1};
I.u[1938] = {n:"Jagdklinge",t:20,d:"Diese Klinge wurde speziell für die Jagd entwickelt. Sie ist zwar ein wenig gewöhnungsbedürftig in der Handhabung, jedoch kann sie einem geschickten Jäger gute Dienste leisten.",ep:3,g:16,l:1,wd:true,fm:true,w:2,an:14,e:[5,4,1,1,40,40,false,false],c:"PJ>41,29",p:5000};
I.u[1939] = {n:"Jagdlanze",t:20,d:"Diese Lanze lässt sich wunderbar gegen Monstergruppen einsetzen. Allerdings wird ein gewisses Talent benötigt, um sie geschickt einsetzen zu können.",ep:3,g:17,l:1,wd:true,fm:true,w:2,an:12,e:[7,5,1,1,30,50,false,false],c:"PJ>41,49",p:10000};
I.u[1940] = {n:"Jagdhammer",t:20,d:"Dieser Hammer ist ein außergewöhnliches Stück. Er ist so gebaut, dass er sein Ziel eher betäubt, als zerschmettert. Dies ist gerade für die Jagd sehr praktisch, jedoch nicht unbedingt fürs Überleben.",ep:1,g:18,l:1,wd:true,fm:true,w:2,an:15,e:[5,6,1,1,50,50,false,false],c:"PJ>41,69",p:20000};
I.u[1941] = {n:"Jagende Schaufel",t:20,d:"Diese Schaufel ist besonders gut dafür geeignet, Monster niederzuschlagen, ohne sie dabei zu beschädigen. Aber Achtung: nur für erfahrene Jäger geeignet.",ep:3,g:9,l:1,wd:true,fm:true,w:2,an:16,e:[7,4,1,1,30,50,false,false],c:"PJ>41,29",p:5000};
I.u[1942] = {n:"Jagdbogen",t:20,d:"Der Jagdbogen wird als die zuverlässigte Waffe eines Jägers überhaupt angesehen. Denn mit ihm kann man ein Maximum an Schaden anrichten, und das bei einem Minimum an sichtbaren Spuren.",ep:3,g:10,l:1,wd:true,fm:true,w:2,an:10,tw:true,e:[7,5,1,6,35,40,false,false],c:"PJ>41,29",p:5000};
I.u[1943] = {n:"Jagdstäbchen",t:20,d:"Dieser Stab verbrennt das anvisiert Ziel, verdirbt aber dabei nicht das Fleisch. Im Gegenteil, er konserviert es und brät es schon einmal an. Einfach unabdinglich für jeden Jäger.",ep:3,g:11,l:1,wd:true,fm:true,w:2,an:11,e:[5,3,2,4,30,50,false,false],c:"PJ>41,29",p:5000};
I.u[1944] = {n:"Kugelspucker",t:20,d:"Diese alte, aber immer noch wirksame Waffe verschießt eine kleine Kugel aus Kupfer auf das anvisierte Ziel. Extrem wirksam, wäre da nicht der Krach. Daher wird sich diese Waffe wohl auch in keinem anderen Handwerk durchsetzen.",ep:1,g:21,l:1,wd:false,fm:true,w:2,an:10,e:[5,3,1,10,40,40,false,false],c:"PJ>41,99",p:50000};
I.u[1945] = {n:"Hackebeil des Metzgers",t:20,d:"Dieses enorme Beil tranchiert jede Art von Fleisch, mit oder ohne Knochen.",ep:1,g:12,l:1,wd:true,fm:true,w:2,an:14,e:[10,4,1,1,25,50,false,false],p:200};
I.u[1946] = {n:"Hackebeil des Fischhändlers",t:20,d:"Dieses enorme Beil tranchiert jede Art von Fisch, mit oder ohne Gräten.",ep:1,g:13,l:1,wd:true,fm:true,w:2,an:14,e:[10,4,1,1,25,50,false,false],p:200};
I.u[1947] = {n:"Nuggets",t:69,d:"Diese kleinen, gesottenen Vogelstückchen sind ein wahrer Gaumenschmaus, aber auch ein Grauen für jeden Magen.",ep:1,g:115,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:30};
I.u[1948] = {n:"Nuggets **",t:69,d:"Diese kleinen, gesottenen Vogelstückchen sind ein wahrer Gaumenschmaus, aber auch ein Grauen für jeden Magen.",ep:1,g:116,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:140};
I.u[1949] = {n:"Larve in Salzlake",t:69,d:"Rezept: Ca. 1 min. in kochendem Wasser ziehen lassen, damit das glibbrige Larvenfleisch fest wird. Mit etwas Salz bestreuen und schon ist der kleine Appetithappen fertig. Ideal für Picknicks!",ep:1,g:112,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[1950] = {n:"Larve in Salzlake **",t:69,d:"Rezept: Ca. 1 min. in kochendem Wasser ziehen lassen, damit das glibbrige Larvenfleisch fest wird. Mit etwas Salz bestreuen und schon ist der kleine Appetithappen fertig. Ideal für Picknicks!",ep:1,g:113,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:50};
I.u[1951] = {n:"Larve in Salzlake ***",t:69,d:"Rezept: Ca. 1 min. in kochendem Wasser ziehen lassen, damit das glibbrige Larvenfleisch fest wird. Mit etwas Salz bestreuen und schon ist der kleine Appetithappen fertig. Ideal für Picknicks!",ep:1,g:114,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:70};
I.u[1952] = {n:"Insektenfleischklöße",t:69,d:"Wie der Name schon sagt, handelt es sich hier um Fleischklöße. Ja, von echten Insekten. Wer sich dazu durchringt, sie zu probieren, wird sehen, dass sie besser schmecken als sie aussehen.",ep:1,g:110,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:40};
