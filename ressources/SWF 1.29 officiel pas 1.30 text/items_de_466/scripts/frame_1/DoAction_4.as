I.u[1624] = {n:"Stiefel des Nexus",t:11,d:"Diese Stiefel gehörten Nexus, dem größten Ritter, der er jemals erstarrte.",ep:3,g:16,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1625] = {n:"Die Legende des Schnappers",t:25,d:"Dieses Buch erzählt die Geschichte des letzten menschlichen Wesens, welches dem Schnapper begegnete.",ep:2,g:19,l:1,wd:true,fm:true,w:1,u:true,p:150};
