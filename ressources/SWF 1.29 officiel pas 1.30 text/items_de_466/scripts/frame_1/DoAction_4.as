I.u[1543] = {n:"Fragment des Crocobur-Sockels",t:24,d:"Dieses Fragment stammt aus dem Sockel in dem Crocobur, das berüchtigte Schwert des Crocoburios, viele Jahrhunderte lang steckte. So ist es auch kein Wunder, dass das Schwert nach und nach einen Teil seiner magischen Macht an das Gestein abgegeben hat und dieses Fragment nun seinerseits hoch magisch ist.",ep:1,g:28,l:1,wd:true,fm:true,w:0,p:1};
