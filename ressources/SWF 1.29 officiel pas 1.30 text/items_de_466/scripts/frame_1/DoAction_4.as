I.u[1566] = {n:"Urkunde von Hel Münster",t:24,d:"Diese Urkunde beweist, dass Hel Münster von nun an euer Mentor ist. Und dass ihr ihn daher mit \"Meister Hel Münster\" anzusprechen habt.",ep:9,g:26,l:1,wd:true,fm:true,w:0,p:1};
