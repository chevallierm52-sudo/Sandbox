I.u[1557] = {n:"Ga Pa-Rune",t:78,d:"Diese Rune ist derart mächtig, dass sie von den Göttern verboten werden sollte. Sie hat die Macht, eine Waffe so leicht und effektiv zu machen, dass man sie führen und gleichzeitig genüßlich Kaffee trinken kann.",ep:1,g:55,l:50,wd:true,fm:true,w:1,p:10};
I.u[1558] = {n:"Ga Pme Rune",t:78,d:"Diese Rune ist derart mächtig, dass sie von den Göttern verboten werden sollte. Sie hat die Macht, eine Waffe so schnell verstaubar und zückbar zu machen, dass man in der nächsten Sekunde nach ihrer Verwendung bereits in der Taverne sein kann.",ep:1,g:56,l:50,wd:true,fm:true,w:1,p:10};
I.u[1559] = {n:"Holzring von Weich-Eich",t:9,d:"Dieser Ring wurde aus einem Auswuchs von Weich-Eich geschaffen, der während eines Sturmes abgerissen wurde. Nun gehört er euch, doch solltet ihr immer vermeiden, ihn in die Nähe seines rechtmäßigen Besitzers zu bringen, da es sonst passieren kann, dass er sich gegen euch wendet.",ep:9,g:11,l:46,wd:true,fm:true,w:3,p:7775};
