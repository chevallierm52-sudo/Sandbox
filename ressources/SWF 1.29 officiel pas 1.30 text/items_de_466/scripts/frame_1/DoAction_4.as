I.u[1613] = {n:"Schuppen des Chef Crocodylls",t:59,d:"Aus diesen Schuppenresten lassen sich sicherlich schöne Stiefel erschaffen.",ep:4,g:547,l:69,wd:true,fm:true,w:5,p:100};
I.u[1614] = {n:"Zähne des Chef Crocodylls",t:47,d:"Aus diesen Zähnen, die mit viel Mühe dem Crocodyll entrissen wurden, muss sich doch irgendetwas machen lassen...!",ep:4,g:548,l:69,wd:true,fm:true,w:1,p:100};
I.u[1619] = {n:"Astamu",t:1,d:"Das Astamu ist ein äußerst elegantes Amulett. Solltet ihr vorhaben, es anzulegen, so raten wir euch, dazu völlig unbekleidet herumzulaufen, damit es so richtig zur Geltung kommt. Ihr werdet sehen: keine Frau kann da noch widerstehen.",ep:9,g:16,l:46,wd:true,fm:true,w:2,p:5700};
I.u[1620] = {n:"Astabog",t:2,d:"Dieser Bogen scheint so richtig lebendig zu sein. Beinahe erwartet man, dass er die Pfeile von allein losschießen wird, ganz wie ein Großer. Das könnte ihm zum idealen Bogen für Abenteurer mit zwei linken Händen machen, wenn man dazu nicht die Pfeile noch in die richtige Richtung einlegen müsste...",ep:9,g:24,l:39,wd:true,fm:true,w:10,an:10,tw:true,e:[5,4,2,5,50,30,false,true],p:4200};
I.u[1621] = {n:"Stiefel der Meisterschaft",t:11,d:"Die Stiefel der Meisterschaft erhöhen die Flinkheit und Intelligenz, verringern allerdings die Stärke und das Glück ihres Trägers. Der Name mag allerdings ein wenig mißverständlich sein, da diese Stiefel nicht für euch die Gegner meistern werden – dies müßt ihr schon selbst erledigen.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
I.u[1622] = {n:"Stiefel der Macht",t:11,d:"Die Stiefel der Macht erhöhen die Flinkheit und Intelligenz, verringern allerdings die Stärke und das Glück ihres Trägers. Der Name mag allerdings ein wenig mißverständlich sein, da diese Stiefel nicht für euch die Gegner meistern werden – dies müßt ihr schon selbst erledigen.",ep:4,g:14,l:22,wd:true,fm:true,w:5,p:1500};
