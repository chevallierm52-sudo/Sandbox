I.u[1635] = {n:"Schriftrolle: \"Panikwelle\"",t:25,d:"(Doppelklick, um dieses Emoticon zu lernen) \nDiese Schriftrolle lehrt euch, bei einer aufkommenden Panikwelle eure Angst im wahrsten Sinne des Wortes \"in Luft aufzulösen\". Doch Vorsicht, auf die Dauer könnte dies mit negativen Nebenwirkungen verbunden sein, die eurer Gesundheit und der eurer Freunde schaden könnten.",ep:4,g:9,l:1,wd:true,fm:true,w:1,u:true,p:1};
I.u[1636] = {n:"Kleiner Abendstern",t:6,d:"Die Erschafferin dieses Schwertes mit einem gewissen Charme wollte dessen inhärente Aura der Schönheit mit einem würzig-spitzigen Charakter zu einem neuen Ganzen verschmelzen. Das Ergebnis sagt definitiv mehr als tausend Worte.",ep:1,g:22,l:40,wd:true,fm:true,w:10,an:14,e:[5,4,1,1,40,40,false,false],c:"CA>35&CV>35&CS>11",p:4000};
