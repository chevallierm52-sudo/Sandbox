I.u[264] = {n:"Kleiner nerviger Bogen",t:2,d:"Dieser Bogen mag zwar sehr einfach gehalten sein, doch ist er trotzdem sehr nützlich.",ep:1,g:3,l:14,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>14&CS>4",p:750};
I.u[265] = {n:"Nerviger Bogen",t:2,d:"Dieser Bogen mag zwar sehr einfach gehalten sein, doch ist er trotzdem sehr nützlich.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>16&CS>6",p:900};
I.u[266] = {n:"Großer nerviger Bogen",t:2,d:"Dieser Bogen mag zwar sehr einfach gehalten sein, doch ist er trotzdem sehr nützlich.",ep:1,g:3,l:18,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>18&CS>8",p:1050};
I.u[267] = {n:"Mächtiger nerviger Bogen",t:2,d:"Dieser Bogen mag zwar sehr einfach gehalten sein, doch ist er trotzdem sehr nützlich.",ep:1,g:3,l:19,wd:true,fm:true,w:25,an:10,tw:true,e:[10,4,2,6,30,50,false,true],c:"CA>19&CS>9",p:1200};
I.u[270] = {n:"Xaveur",t:2,d:"Der Xaveur ist ein sehr wirkungsvoller Bogen. Er gehört einst Xaver, dem Bäcker. Dieser pflegte immer an alle Monstern in der Umgebung seiner Bäckerei Brote zu vergeben, bevor er die nächste Fuhre in den Ofen schub.",ep:7,g:5,l:60,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,9,30,100,false,true],c:"CA>60&CV>15",p:9050};
I.u[271] = {n:"Chafer-Hammer",t:7,d:"Diese schöne und faszinierende Waffe erlaubt epische Schlachten im Nahkampf, wie ein echter Chafer sie führen würde.",ep:1,g:9,l:21,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,40,30,false,false],c:"CS>10&CI>11",p:1350};
I.u[272] = {n:"Nomoon",t:2,d:"Dieser Bogen hat sogar genug Zugkraft, um Pfeile bis auf den Mond zu schießen.",ep:7,g:9,l:28,wd:true,fm:true,w:18,an:10,tw:true,e:[10,5,2,12,30,50,false,true],c:"CA>28&CV>5",p:2350};
I.u[273] = {n:"Yamatos Sehne",t:2,d:"Yamatos Sehne hat bereits mehr als ein Monsterherz zum Vibrieren gebracht. Mit dieser feinen Waffe lässt sich ein Pfeil selbst in die verborgensten Stellen plazieren.",ep:7,g:10,l:33,wd:true,fm:true,w:18,an:10,tw:true,e:[10,4,2,7,30,50,false,false],c:"CA>33&CS>10",p:3000};
I.u[274] = {n:"Stück des Klauenpuzzles",t:51,d:"Diese ist ein sehr seltenes Puzzlestück zum berühmten Schatz von Dodge, einem der berühmtesten Ecaflipkrieger von ganz Amakna.",ep:1,g:267,l:12,wd:true,fm:true,w:1,p:100};
I.u[276] = {n:"Münze des Schatzes von Badoul",t:15,d:"Diese Münze ist ein seltenes Stück vom Schatz von Badoul, welchen Dodge, einer der berühmtesten Ecaflipkrieger von ganz Amakna, irgendwo versteckt hat.",ep:1,g:268,l:12,wd:true,fm:true,w:1,p:100};
I.u[278] = {n:"Felsenring",t:9,d:"In diesen Ring ist ein sehr seltener geschliffener Stein eingelegt. Der Felsenring trägt seinen Namen aufgrund der vielen unterschiedlichen Gesteine und Metalle, die zu seiner Anfertigung nötig sind.",ep:1,g:4,l:15,wd:true,fm:true,w:4,p:800};
I.u[279] = {n:"Die Träne des Fresssacks",t:1,d:"Laut Bericht eines bekannten Abenteurers enthält dieses Amulett eine Fresssackträne, deren Geruch und Eigenschaften abgekochtem Fresssackleder ähnelt.",ep:1,g:7,l:2,wd:true,fm:true,w:5,p:200};
I.u[280] = {n:"Regenbogenhalskette",t:1,d:"Diese Halskette ist von Sammlern heiß begehrt und bringt bestimmt viel Geld ein.",ep:1,g:11,l:6,wd:true,fm:true,w:6,p:300};
I.u[281] = {n:"Apfel",t:42,d:"Dieser Apfel gibt einige verlorene Lebenspunkte zurück. Und auf dem Kopf eines Freundes gibt er ein tolles Ziel für Bogenschützen ab.",ep:1,g:1,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:1};
I.u[282] = {n:"Verbesserter Pflegebalsam",t:12,d:"Dieser Balsam gibt einige verlorene Lebenspunkte zurück. Allerdings nur, wenn ihr nicht bereits volle LP habt.",ep:1,g:39,l:20,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[283] = {n:"Pflegebalsam",t:12,d:"Dieser Balsam gibt einige verlorene Lebenspunkte zurück.",ep:1,g:3,l:10,wd:true,fm:true,w:1,u:true,ut:true,p:10};
I.u[284] = {n:"Salz",t:48,d:"Salz ist ein Mineral. Einmal zerstampft und gemahlen, wird es eurem Brot Geschmack verleihen.",ep:2,g:260,l:1,wd:true,fm:true,w:1,p:10};
I.u[285] = {n:"Weizenmehl",t:52,d:"Dieses Mehl erhält man beim Mahlen von Weizenkörnern. Damit kann man fast alles machen: Brote, Pfannkuchen, Waffeln, Kuchen und Mehlschlachten.",ep:1,g:251,l:1,wd:true,fm:true,w:2,p:0};
I.u[286] = {n:"Bäckerhefe",t:48,d:"Dies ist eine unverzichtbare Zutat für gutschmeckendes Brot.",ep:1,g:137,l:1,wd:true,fm:true,w:1,p:1};
I.u[287] = {n:"Handvoll Sesamkörner",t:58,d:"Diese proteinreichen Körner verbessern jedes Brot. Leider ist der Anbau von Sesam unter den Klimabedingungen in Amakna sehr schwierig, weshalb diese Körner selten und wertvoll sind.",ep:1,g:3,l:1,wd:true,fm:true,w:1,p:1};
I.u[288] = {n:"Handvoll wilde Sonnenblumenkerne",t:58,d:"Diese proteinreichen Kerne geben jedem Brot einen ganz eigenen Geschmack. Leider besteht die einzige bekannte Art, Sonnenblumenkerne zu ernten, darin, sie direkt von wilden Sonnenblumen zu pflücken, was nicht ganz ungefährlich ist.",ep:1,g:6,l:12,wd:true,fm:true,w:1,p:10};
I.u[289] = {n:"Weizen",t:34,d:"Weizen ist bereits seit Urzeiten ein wesentlicher Bestandteil der Ernährung der Einwohner Amaknas und der Tofus.",ep:1,g:9,l:1,wd:true,fm:true,w:2,p:0};
I.u[290] = {n:"Pilz",t:15,d:"Ob mit oder ohne Sahnesauce, dieser Pilz schmeckt einfach vorzüglich. Der einfachste Weg sich einen Vorrat anzulegen, ist ein paar Pilzlinge zu jagen.",ep:1,g:1,l:5,wd:true,fm:true,w:1,p:10};
I.u[291] = {n:"WuWulf-Haar",t:54,d:"Diese Haare unterscheiden sich von allen anderen Haaren. Sie besitzen besondere Eigenschaften, weshalb sie von Alchimisten sehr geschätzt werden.",ep:1,g:8,l:70,wd:true,fm:true,w:1,p:1};
I.u[292] = {n:"WuWulf-Hoden",t:15,d:"Diese gewaltigen Hoden sind in ein außergewöhnlich warmes und weiches Futteral eingebettet. Es ist nahezu unmöglich, sie nach einem blutigen Kampf gegen einen WuWulf in unversehrtem Zustand vorzufinden, was wohl ihren horrenden Preis erklärt.",ep:1,g:10,l:70,wd:true,fm:true,w:20,p:50};
I.u[293] = {n:"Schaufel des kleinen Krachlers",t:8,d:"Das einzige, was genauso hart ist wie ein Krachler, ist ein Krachler. Genau aus diesem Grund wurde diese speziell für die Krachler-Jagd entwickelte Schaufel aus Krachlergestein hergestellt.",ep:1,g:7,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1200};
I.u[294] = {n:"Schaufel des Krachlers",t:8,d:"Das einzige, was genauso hart ist wie ein Krachler, ist ein Krachler. Genau aus diesem Grund wurde diese speziell für die Krachler-Jagd entwickelte Schaufel aus Krachlergestein hergestellt.",ep:1,g:7,l:23,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>8&CC>15",p:1600};
I.u[295] = {n:"Schaufel des großen Krachlers",t:8,d:"Das einzige, was genauso hart ist wie ein Krachler, ist ein Krachler. Genau aus diesem Grund wurde diese speziell für die Krachler-Jagd entwickelte Schaufel aus Krachlergestein hergestellt.",ep:1,g:7,l:26,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>11&CC>15",p:2000};
I.u[296] = {n:"Schaufel des gewaltigen Krachlers",t:8,d:"Das einzige, was genauso hart ist wie ein Krachler, ist ein Krachler. Genau aus diesem Grund wurde diese speziell für die Krachler-Jagd entwickelte Schaufel aus Krachlergestein hergestellt.",ep:1,g:7,l:29,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>14&CC>15",p:2400};
I.u[297] = {n:"Stiefel des jungen Fresssackes",t:11,d:"Diese Stiefel bestehen ganz aus Fresssackleder. Dank des Geruchs, der ihnen entströmt, ist es den Fresssackzüchtern auch ein Leichtes, sich den Fresssäcken zu nähern, um sie zu töten.",ep:1,g:3,l:1,wd:true,fm:true,w:2,p:100};
I.u[298] = {n:"Tofulytische Sandalen",t:11,d:"Diese Sandalen bestehen aus zermahlenen Tofu-Federn und die Sohle aus unabnutzbaren Tofuschnäbeln. Allerdings kann es aus noch ungeklärter Ursache manchmal vorkommen, dass ihr Träger mitunter ein wenig schwach im Kopf wird... wie ein Tofu eben.",ep:1,g:4,l:1,wd:true,fm:true,w:7,p:100};
I.u[299] = {n:"Feiht-Schuhe",t:11,d:"Die beste Verteidigung ist immer noch der Angriff! Diese Schuhe werden es euch ermöglichen, ganze Gruppen von Aggressoren ohne Probleme aus dem Weg zu treten.",ep:1,g:8,l:24,wd:true,fm:true,w:30,p:1800};
I.u[300] = {n:"Handvoll Mohnkörner",t:58,d:"Diese Samen verleihen dem Brot eine halluzinogene Wirkung, welche gerade von Abenteurern sehr geschätzt wird, die sich von einem schweren Kampf erholen möchten.",ep:1,g:11,l:5,wd:true,fm:true,w:1,p:1};
I.u[301] = {n:"Tofufeder",t:53,d:"Tofufedern werden oft von Schneidern zum Ausstopfen verwendet. Doch vergesst nicht: ein Kilo Tofufedern wiegt genausoviel wie ein Kilo Blei!",ep:1,g:14,l:4,wd:true,fm:true,w:1,p:10};
I.u[302] = {n:"Küwbis",t:68,d:"Küwbisse wachsen auf den Feldern. Sie sind zwar nur unwesendlich größer als WuWulf-Hoden, doch dafür schmecken sie besser.",ep:4,g:12,l:15,wd:true,fm:true,w:5,p:10};
I.u[303] = {n:"Eschenholz",t:38,d:"Eschenholz steht zwar nicht gerade für gute Qualität, doch dafür findet man es in Hülle und Fülle. Außerdem wächst es schnell wieder nach. Man darf es nur nicht in der Nähe von Feuer aufbewahren, da es sehr leicht brennt.",ep:1,g:17,l:1,wd:true,fm:true,w:5,p:0};
I.u[304] = {n:"Fresssack-Leder",t:56,d:"Dieses ausgesprochen strapazierfähige Leder ist der wichtigste Rohstoff der Gerber, die daraus Stiefel, Gürtel und sogar Peitschenschnüre anfertigen. Der einzige Nachteil daran ist der strenge Geruch nach saurem Schweiß brünftiger Fresssackmännchen. Nicht gerade förderlich, um neue Bekanntschaften zu schließen.",ep:1,g:16,l:9,wd:true,fm:true,w:2,p:1};
I.u[305] = {n:"Wabbitzahn",t:47,d:"Obwohl diese Zähne nach langen Jahren des Kawottenknabberns völlig abgenutzt sind, lassen sich daraus gute Tränke herstellen, da sie die vitaminreiche Wirkung der Kawotten aufgesogen haben.",ep:8,g:13,l:20,wd:true,fm:true,w:1,p:1};
I.u[306] = {n:"Teuflische Löwenzahnblüte",t:35,d:"Richtig zubereitet – nämlich erst gut durchgekocht, dann getrocknet – verlieren diese Blüten ihre toxische Wirkung und können zu einem schmackhaften Tee verarbeitet werden. Oftmals erfreuen sich aber auch romantische Jugendliche bei ihrer ersten großen Liebe daran. Wer hat noch nie die Samen einer solchen Blüte fortgeblasen, auf dass diese sich gleich dem Morgentau sanft über den Hals der Angebetenen legen? Vielleicht ein paar Iops, die dazu neigen, die Samen einzuatmen, anstatt sie fortzublasen und dann unter qualvollen Zuckungen jämmerlich an ihnen ersticken.",ep:1,g:18,l:5,wd:true,fm:true,w:1,p:10};
I.u[307] = {n:"Moskitoflügel",t:104,d:"Diese zierlichen Flügel haben die Eigenheit, das Denkvermögen aller Wesen zu verbessern, die es wagen, auf ihnen herumzukauen. Denn der Geschmack ähnelt dem verfaulter Kwackeier. Aus diesem Grunde werden sie meist ausschließlich zur Zubereitung von Weisheitstränken verwendet.",ep:1,g:19,l:2,wd:true,fm:true,w:1,p:1};
I.u[308] = {n:"Weiße Dracheischale",t:111,d:"Diese Schale ist so gut wie unzerbrechlich. Doch nachdem sie von Generationen von Juwelieren auf Hochglanz poliert wurde, ist es nun möglich, ihre magischen Kräfte zu nutzen, um daraus extrem mächtige Amulette zu fertigen.",ep:11,g:21,l:64,wd:true,fm:true,w:5,p:1};
I.u[309] = {n:"Dämonenrosenblütenblatt",t:35,d:"Diesen Blütenblättern sagt man eine starke aphrodisierende Wirkung nach. Darum ist dies das ideale Geschenk, um euren langjährigen Schwarm zu erobern. Doch vermeidet besser, daraus einen Tee zu kochen, er hätte nämlich genau die umgekehrte Wirkung.",ep:1,g:20,l:6,wd:true,fm:true,w:1,p:10};
I.u[310] = {n:"Chafer-Knochen",t:47,d:"Dieser Knochen ist nahezu unzerstörbar. Doch weicht er beim Kontakt mit Wasser sofort auf, was seinen Einsatz für Alchimisten erheblich vereinfacht.",ep:1,g:15,l:34,wd:true,fm:true,w:5,p:1};
I.u[311] = {n:"Wasser",t:15,d:"Wasser ist ein wesentlicher Bestandteil von ganz vielen Dingen und Lebewesen. Grundsätzlich gilt: je trüber es ist, desto mehr Geschmack hat das Bier danach.",ep:1,g:26,l:1,wd:true,fm:true,w:1,p:1};
I.u[312] = {n:"Eisen",t:39,d:"Eisen ist sehr nützlich für viele Berufe. Schmiede machen daraus Waffen, Dörfler nutzen es zum Bügeln, und Diebe zum Aufbrechen von Türen und Schatztruhen.",ep:1,g:24,l:1,wd:true,fm:true,w:5,p:0};
I.u[313] = {n:"Gold",t:39,d:"Gold ist ein seltenes und wertvolles Edelmetall. Dank seiner Eigenschaften ist es ideal für jede Art von Verzierung geeignet, wie man sie auf besonders mächtigen Gegenständen findet.",ep:1,g:22,l:80,wd:true,fm:true,w:5,p:0};
I.u[314] = {n:"Tabiwolle",t:57,d:"Tabiwolle ist nicht gerade die weicheste Wolle, doch lassen sich daraus schöne Kleider schneidern. Nur zur Herstellung von Unterwäsche eignet sie aufgrund ihrer bräunlichen Farbe und des kratzenden Stoffes wirklich nicht.",ep:0,g:655,l:1,wd:true,fm:true,w:1,p:50};
I.u[315] = {n:"Geschliffener Diamant",t:50,d:"Alle Juweliere Amaknas sind erpicht darauf, diese Edelsteine in ihre Finger zu bekommen, die ihre Fähigkeiten bis an die Grenze strapazieren. Abenteurer müssen dafür in die tiefsten und gefährlichsten Minen einfahren. Nur gut, daß Diamanten unvergänglich sind.",ep:1,g:25,l:50,wd:true,fm:true,w:10,p:5000};
I.u[316] = {n:"Geschliffener Smaragd",t:50,d:"Dank der intensiven grünen Farbe kann dieser wertvolle Edelstein selbst den dümmsten Thunfisch in eine hübsche Prinzessin verwandeln, und das ohne jede okkulte Magie!",ep:1,g:23,l:50,wd:true,fm:true,w:10,p:5000};
I.u[317] = {n:"Kleiner Tabistock",t:4,d:"Dieser Stock diente ursprünglich den Hirten Amaknas dazu, ihre Tabiherde zu dirigieren. Er ist nämlich so leicht, dass der Träger jedem entlaufenen Tabi nachrennen kann, ohne jemals müde zu werden.",ep:7,g:6,l:30,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:2650};
I.u[318] = {n:"Tabistock",t:4,d:"Dieser Stock diente ursprünglich den Hirten Amaknas dazu, ihre Tabiherde zu dirigieren. Er ist nämlich so leicht, dass der Träger jedem entlaufenen Tabi nachrennen kann, ohne jemals müde zu werden.",ep:7,g:6,l:34,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>20",p:3200};
I.u[319] = {n:"Großer Tabistock",t:4,d:"Dieser Stock diente ursprünglich den Hirten Amaknas dazu, ihre Tabiherde zu dirigieren. Er ist nämlich so leicht, dass der Träger jedem entlaufenen Tabi nachrennen kann, ohne jemals müde zu werden.",ep:7,g:6,l:37,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>25",p:3750};
I.u[320] = {n:"Mächtiger Tabistock",t:4,d:"Dieser Stock diente ursprünglich den Hirten Amaknas dazu, ihre Tabiherde zu dirigieren. Er ist nämlich so leicht, dass der Träger jedem entlaufenen Tabi nachrennen kann, ohne jemals müde zu werden.",ep:7,g:6,l:40,wd:true,fm:true,w:1,an:12,e:[5,3,1,1,40,50,false,false],c:"CA>30",p:4300};
I.u[323] = {n:"Amulett von Kam Assutra",t:1,d:"Dieses Amulett verleiht dem Träger außergewöhnliche Fähigkeiten. Er wird förmlich spüren können, wie eine mysteriöse Aura seinen Körper umhüllt, welche alle Grenzen seiner physischen Kräfte sprengt.",ep:1,g:4,l:43,wd:true,fm:true,w:5,p:5000};
I.u[324] = {n:"Kroketthalskett",t:1,d:"Dieses Amulett färbt sich rosa, wenn der Träger guter Laune ist. Man sagt ihm ebenfalls nach, die Chancen für das Finden guter Gegenstände zu erhöhen.",ep:1,g:7,l:6,wd:true,fm:true,w:5,p:300};
I.u[325] = {n:"SRAMulett",t:1,d:"Dieses Amulett enthält kleine Schädelchen, die von einem der größten Sram-Juweliere aus Knochen herausgearbeitet wurden. Es erlaubt dem Träger, leichter aus einer gefährlichen Lage zu entkommen.",ep:1,g:3,l:2,wd:true,fm:true,w:5,p:200};
I.u[326] = {n:"VanDenFrogg-Halskette",t:1,d:"Diese Halskette stammt aus dem Norden Amaknas und erleichtert dem Träger das Beschwören von Kreaturen.",ep:1,g:2,l:33,wd:true,fm:true,w:4,p:3000};
I.u[327] = {n:"Schwert des Raubritters von Kleppripp",t:6,d:"Diese Klinge wurde ursprünglich für die Raubritter von Kleppripp geschmiedet. Obwohl es sich herausstellte, dass sie viel zu schwer für diese schwachen Goblinoiden war, kann ein normaler Abenteurer mit ihr sehr schnell zuschlagen, da dieses Schwert sehr leicht in der Hand liegt.",ep:1,g:3,l:16,wd:true,fm:true,w:25,an:14,e:[5,5,1,1,50,20,false,false],c:"CS>32",p:900};
I.u[328] = {n:"Schnipp-Schnapp",t:6,d:"Dieses Schwert mit doppelter Klinge diente ursprünglich dazu, Äste von Bäumen abzuschneiden, um sich einen Weg durch den Dschungel zu bahnen. Allerdings stellten die Holzfäller sehr schnell fest, dass sie der ideale Begleiter war, um mit jeglicher Art von Bedrohung auf dem Weg fertigzuwerden.",ep:1,g:4,l:18,wd:true,fm:true,w:28,an:14,e:[6,5,1,1,20,60,false,false],c:"CS>36",p:1050};
I.u[329] = {n:"Der Triumph-Bogen",t:2,d:"Wie der Name besagt, lässt sich mit diesem Bogen leicht jeder Kampf gewinnen. Ein bekannter und phantasieloser Crâ-Architekt hat später diesen Namen übernommen, um ihn einer seiner Bauten zu verleihen.",ep:7,g:11,l:30,wd:true,fm:true,w:15,an:10,tw:true,e:[10,4,2,10,30,50,false,true],c:"CA>30&CC>5&CS>10",p:1950};
I.u[331] = {n:"Regen-Bogen",t:2,d:"Dies ist einer der meistgesuchtesten Bögen ganz Amaknas. Der Legende nach soll man nämlich an der Stelle, wo der Pfeil landet, einen Schatz finden können. Seltsamerweise scheint dies nur dann zu funktionieren, wenn Regen und Sonnenstrahlen das Ganze bescheinen.",ep:7,g:16,l:22,wd:true,fm:true,w:19,an:10,tw:true,e:[10,5,2,11,30,50,false,true],c:"CA>22&CC>15",p:1500};
I.u[332] = {n:"Jeannes Bogen",t:2,d:"Jeanne war ein wenig verrückt. Sie hörte ständig in Ihrem Kopf Tabis rülpsen. Um zu verhindern, dass sie sich mit ihrem Bogen selbst verletzt, wurde er ihr abgenommen und man beschloß, sie anläßlich der Einweihung der Taverne lebendig zu verbrennen, um die Atmosphäre etwas zu aufzulockern.",ep:7,g:15,l:30,wd:true,fm:true,w:23,an:10,tw:true,e:[10,4,2,9,30,50,false,true],c:"CS>10&CA>30",p:2550};
I.u[333] = {n:"Brotstock",t:3,d:"Dieses einfache Stockbrot wurde zu einer gefürchteten Waffe, nachdem es Xaver der Bäcker während des Monsterfütterns zum Warmhalten in den tiefsten Punkt seines Ofens geschoben hatte und erst 234 Jahre später aus Zufall dort wiederfand.",ep:3,g:9,l:50,wd:true,fm:true,w:1,an:11,e:[5,3,3,5,50,50,false,true],c:"CW>40&CI>100",p:6650};
I.u[334] = {n:"Liriels Stab",t:3,d:"Dieser Stab gehörte einer Eniripsa namens Liriel, die nach einer Überdosis Erdbeeren in furchtbarer Agonie das Leben aushauchte. Beim Ausfallen ihrer Flügel stieß sie einen schrecklichen Schmerzenschrei aus, der einem durch Mark und Bein ging. Nun ist dieser angeblich verfluchte Stab bei Sammlern heiß begehrt.",ep:7,g:5,l:20,wd:true,fm:true,w:13,an:11,e:[5,5,2,3,50,50,false,true],c:"CI>40",p:1300};
I.u[335] = {n:"Stecken des Bwork Magus",t:4,d:"Ohne ihren Stecken sind Bwork Magi genauso ungefährlich, wie Tofus ohne ihre Küsse. Damit sollte ja klar sein, dass in diesem Stecken große Macht drin steckt.",ep:7,g:1,l:58,wd:true,fm:true,w:28,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>58&CA>20",p:8900};
I.u[336] = {n:"Stock des Wabbitopas",t:4,d:"Dieser Stock hat die Fähigkeit, Kawotten schweben zu lassen. Da fragt man sich doch, was in aller Welt das bringen soll...",ep:8,g:1,l:32,wd:true,fm:true,w:1,an:12,e:[5,2,1,1,30,50,false,false],c:"CI>32&CA>10",p:2900};
I.u[337] = {n:"Bogen des Bwork-Bogenschützen",t:2,d:"Dieser Bogen ist sehr einfach zu gebrauchen. Er wurde schließlich auch bei der Entwicklung an die Intelligenz des Bwork-Bogenschützen angepasst, weshalb er beinahe schon von einem Tofu gehandhabt werden kann. Im Gegenzug braucht man allerdings die Stärke eines Krachlers, um ihn zu spannen.",ep:7,g:4,l:20,wd:true,fm:true,w:20,an:10,tw:true,e:[10,5,2,7,30,50,false,true],c:"CS>20&CA>20",p:1300};
I.u[338] = {n:"Klein Bworkling",t:6,d:"Diese grobe Klinge ist sehr beliebt bei den dümmsten aller Bworks, die die Funktionsweise eines Bogens oder eines Stockes nicht verstehen. Doch einige von ihnen verwechseln dennoch hin und wieder das Heft mit der Klinge, was meist starke Lachanfälle ihrer Gegner zur Folge hat.",ep:1,g:13,l:21,wd:true,fm:true,w:30,an:14,e:[5,5,1,1,50,30,false,false],c:"CS>42",p:1400};
I.u[339] = {n:"Schwert des Chafers",t:6,d:"Dieses Schwert benutzte Buh Tscher, der Metzger, um damit Knochen zu spalten. Doch dem Chafer gelang es einst, ihm dieses Werkzeug zu rauben. In seinen Händen stellt das Schwert nun eine äußerst gefährliche Waffe dar, auf deren Konto schon mehrere Dutzend Totalamputationen gehen.",ep:1,g:5,l:27,wd:true,fm:true,w:20,an:14,e:[20,6,1,1,15,60,false,false],c:"CS>54&CC>10",p:2100};
I.u[340] = {n:"Leurnetten",t:5,d:"Diese Dolche geben ihrem Träger die Macht, alles und nichts von jedermann zu stehlen, genauer: irgendwas von irgendwem. Oder war es umgekehrt? Wir werden es wohl nie erfahren...",ep:1,g:9,l:12,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>12",p:600};
I.u[341] = {n:"Verrückte Schwesterdolche",t:5,d:"Diese legendären Dolche sind ein echtes Sammlerstück für jeden Sram, der etwas auf sich hält. Sie werden von manchen sogar so sehr veehrt, dass sie gar nicht versuchen, diese Dolche zu stehlen. Das will etwas heißen!",ep:7,g:10,l:46,wd:true,fm:true,w:10,an:13,e:[10,2,1,1,30,50,false,false],c:"CA>46",p:5600};
I.u[342] = {n:"Preslufts Hammer",t:7,d:"Dieser eigentümliche Hammer wurde ganz aus Kwack-Schnäbeln gebaut, was auch erklärt, warum es so sehr sticht, wenn man Schläge damit abbekommt.",ep:5,g:12,l:18,wd:true,fm:true,w:1,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>12&CS>6",p:1100};
I.u[345] = {n:"Kleine Baggers Schaufel",t:8,d:"Ein Enutrof, der wohl in der Taverne ein wenig über seinen Durst getrunken hatte, stellte eines Tages fest, dass sich diese ursprünglich zum Ausheben unterirdischer Gänge konzipierte Schaufel auch hervorragend dazu eignet, die dicken Schädel von Gegnern zu bearbeiten.",ep:1,g:8,l:25,wd:true,fm:true,w:40,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>5&CC>20",p:1900};
I.u[346] = {n:"Regen-Ringe",t:9,d:"Wenn man gewissen Geschichten Glauben schenken darf, sollen diese Ringe den Träger vor Unwettern schützen. Jedoch konnte dies bisher noch nicht nachgewiesen werden, da es in Amakna niemals regnet.",ep:1,g:34,l:17,wd:true,fm:true,w:4,p:1000};
I.u[347] = {n:"Goldenes Rhizom",t:8,d:"Diese Gartenschaufel ist besonders tauglich, wenn es darum geht, Rhizome, wie sie bei vielen Unkräutern vorkommen, abzutrennen. Allerdings ist sie gleichfalls hervorragend dazu geeignet, alles andere von allem anderen abzutrennen.",ep:1,g:10,l:40,wd:true,fm:true,w:30,an:16,e:[10,4,1,1,50,50,false,false],c:"CS>10&CC>30",p:4400};
I.u[348] = {n:"Speedies \"Nächster Gang, gebt alles\"-Stiefel",t:11,d:"Diese Stiefel gehörten einst einem Koch, der ständig alle Angestellten in der Gegend herumscheuchte... \"Nächster Gang, gebt alles!\", weil er ein schauderhaftes Organisationstalent hatte. Man hörte ihn immer bereits von Weitem krakelen: \"Y\'arriva,y\'arriva, es kommt gleich!\"",ep:2,g:5,l:53,wd:true,fm:true,w:20,p:6700};
I.u[350] = {n:"Silber",t:39,d:"Silber ist ein glänzendes Metall, welches besonders von Juwelieren sehr geschätzt wird. Doch entgegen der allgemeinen Meinung, zeigt es keine Wirkung bei Vampiren.",ep:1,g:28,l:60,wd:true,fm:true,w:5,p:0};
I.u[351] = {n:"Bier von Amakna",t:37,d:"Dieses Bier wird eure LP aufstocken. Diese Eigenschaft  hat gar einmal einen großen Dichter Amaknas zu folgender Ode an das Bier bewegt: \"Rinnt das Bier durch den Mund, geht\'s im ganzen Körper rund. Rinnt das Bier in den Magen, wirkt\'s dort erfrischend und labend. Rinnt das Bier in den Darm, wird der Körper wohlig warm. Rinnt das Bier schließlich raus, dann ein Neues du dir kauf!\" Das kann doch nur ein Iop gewesen sein!",ep:2,g:4,l:1,wd:true,fm:true,w:1,u:true,ut:true,p:2};
I.u[352] = {n:"Kleines heiliges Schwert",t:6,d:"Ein heiliges Schwert, das jungen Kriegern im Laufe ihrer Ausbildung gegeben wird.",ep:1,g:1,l:13,wd:true,fm:true,w:30,e:[5,4,1,1,50,50,false,false],c:"CS>26&CV>5",p:700};
I.u[353] = {n:"Schwert des kleinen Ritters",t:6,d:"Das Schwert des kleinen Ritters ist stabil und wirksam. Darum kann es euren Gegnern auch großen Schaden zuzufügen.",ep:7,g:9,l:21,wd:true,fm:true,w:30,an:14,e:[4,5,1,1,30,30,false,false],c:"CS>42",p:1400};
I.u[354] = {n:"Nüs Schwert",t:6,d:"Diese Schwertart wurde speziell für die Leibgarde eines reichen und berüchtigten Händlers angefertigt. Sie sollte zwar mehr zur Abschreckung dienen als zum echten Kampf, doch war sie dennoch gut geeignet, etwaige Diebe oder manchmal auch ehrliche Kunden niederzustrecken, was auf Dauer allerdings recht anstrengend ist.",ep:1,g:11,l:25,wd:true,fm:true,w:20,e:[12,4,1,1,30,60,false,false],c:"CS>50&CW>5",p:1850};
I.u[355] = {n:"Ring der Tüchtigkeit",t:9,d:"Dieser Ring bringt seinem Träger Stärke und Mut.",ep:1,g:7,l:12,wd:true,fm:true,w:4,p:600};
I.u[356] = {n:"Gürtel der Haltbarkeit",t:10,d:"Dieser Gürtel erhöht die Ausdauer im Kampf seines Trägers und damit meist auch seine Lebensdauer.",ep:1,g:3,l:27,wd:true,fm:true,w:16,p:2200};
I.u[357] = {n:"Schwanzus Longus",t:6,d:"Dieses Schwert symbolisiert das Körperteil, auf das Ecaflips am stolzesten sind. Warum dürfte nun klar sein.",ep:1,g:18,l:13,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>26&CA>10",p:650};
I.u[358] = {n:"Höllenschwanz",t:6,d:"Der Höllenschwanz macht einem das Leben zur Hölle... und mit ihm könnt ihr Freund wie Feind in den Wahnsinn treiben. Mitunter lässt sich damit auch leicht Freund zu Feind machen, das Umgekehrte ist alledings scheinbar noch nicht vorgekommen.",ep:1,g:18,l:21,wd:true,fm:true,w:20,an:14,e:[20,4,1,1,15,15,false,false],c:"CS>42&CA>10",p:1400};
I.u[359] = {n:"Der Ecalisator",t:9,d:"Vor langer, langer Zeit wurde Isidor dieser Ring vom König Alister Snoc verliehen, der die unvergleichliche Flinkheit dieses Ecaflips erkannt hatte.",ep:1,g:35,l:29,wd:true,fm:true,w:3,p:2400};
I.u[360] = {n:"Tiwabbit-Ohren",t:106,d:"Diese kleinen, braunen Ohren riechen seltsamerweise nach WuWulf, wenn sie gekocht werden. Doch mit einer Füllung aus königlichem Gelee werden sie überall hoch gepriesen.",ep:8,g:30,l:11,wd:true,fm:true,w:1,p:10};
I.u[361] = {n:"Kawotte",t:68,d:"Das ist das einzige Nahrungsmittel des Tiwabbit Ischungrig. Kein Wunder, dass er derart zurückgeblieben ist.",ep:2,g:31,l:20,wd:true,fm:true,w:1,p:2};
I.u[362] = {n:"Blaue Larvenhaut",t:59,d:"Diese extrem glatte Haut ist eine sehr gute Zutat für viele magische Tränke.",ep:1,g:32,l:2,wd:true,fm:true,w:1,p:2};
I.u[363] = {n:"Orangefarbene Larvenhaut",t:59,d:"Diese extrem glatte Haut ist eine sehr gute Zutat für viele magische Tränke.",ep:1,g:33,l:9,wd:true,fm:true,w:1,p:2};
I.u[364] = {n:"Grüne Larvenhaut",t:59,d:"Diese extrem glatte Haut ist eine sehr gute Zutat für viele magische Tränke.",ep:1,g:34,l:7,wd:true,fm:true,w:1,p:100};
I.u[365] = {n:"Arachneenklaue",t:103,d:"Diese Klaue ist feingliedrig und haarig. Sie wird von Alchimisten für ihre euphorisierende Wirkung gepriesen. Wer weiß, wo die Arachneenklauenpulver überall hineinmischen.",ep:1,g:35,l:2,wd:true,fm:true,w:1,p:10};
I.u[366] = {n:"Tofuschnabel",t:47,d:"Dieser lächerlich aussehende Tofuschnabel ist überraschend scharf. Bogenschützen verwenden Tofuschnäbel seit vielen Jahren bereits als Pfeilspitzen.",ep:1,g:37,l:4,wd:true,fm:true,w:1,p:2};
I.u[367] = {n:"Tofu-Ei",t:105,d:"Dieses Ei hat die seltene Eigenschaft, nach faulen Eiern zu riechen, obwohl es gar nicht faul ist. Jetzt stellt euch einmal vor, wie es wohl stinken muss, wenn es wirklich einmal faul werden sollte. An manche Dinge sollte man selbst in seinen kühnsten Träumen nicht denken.",ep:1,g:38,l:4,wd:true,fm:true,w:1,p:1};
I.u[368] = {n:"Erdbeergelee",t:110,d:"Dieses wohlschmeckende Erdbeergelee hat bereits mehr als einen zügellosen Abenteurer krank gemacht. Wie heißt es so schön: \"All Ding ist Gift, nur auf die Dosis kommt es an.\" Beim Erdbeergelee sollte auf jeden Fall eine Überdosis vermieden werden.",ep:5,g:40,l:28,wd:true,fm:true,w:1,p:100};
I.u[369] = {n:"Minzgelee",t:110,d:"Dieses wohlschmeckende Minzgelee hat bereits mehr als einen zügellosen Abenteurer krank gemacht. Es hat allerdings eine wohltuende Wirkung auf den Rest eurer Gruppe, solltet ihr an schlechtem Atem leiden.",ep:5,g:41,l:10,wd:true,fm:true,w:1,p:100};
I.u[370] = {n:"Königliches Blaubeergelee",t:110,d:"Dieses wohlschmeckende Blaubeergelee ist das Verdauungsendprodukt eines reichhaltigen Honigmahls und dessen Gärung im Magen eines königlichen Gelees. Im Rohzustand ist es zwar ungenießbar, aber zu Pralinen verarbeitet ein wahres Wundermittel.",ep:7,g:407,l:50,wd:true,fm:true,w:1,p:100};
I.u[371] = {n:"Moskitobraue",t:15,d:"Moskitos besitzen lange und zierliche Brauen, die ihnen erst den charakteristischen unwiderstehlich Blick eines großen Frauenverstehers verleihen. Darum sind ihre Brauen wohl auch von Tränen durchtränkt, denen man magische Eigenschaften nachsagt.",ep:1,g:44,l:1,wd:true,fm:true,w:1,p:1};
I.u[372] = {n:"Stirnband des Black Tiwabbits",t:15,d:"Allein dieses Stirnband verleiht dem Black Tiwabbit sein furchteinflößendes, kriegerisches Aussehen. Es heißt, diese Tradition käme vom sagenhaften Wambo Wabbit.",ep:8,g:29,l:11,wd:true,fm:true,w:1,p:2};
I.u[373] = {n:"Teuflischer Löwenzahnstengel",t:36,d:"Dieser Stengel ist so biegsam wie eine Weidenrute. Das macht ihn zum idealen Material zur Herstellung von Peischen und Geißeln, die heutzutage bei der modernen Kindererziehung nicht mehr wegzudenken sind.",ep:1,g:45,l:6,wd:true,fm:true,w:1,p:10};
I.u[374] = {n:"Teuflische Löwenzahnzunge",t:36,d:"Die grüne Färbung dieser Zunge kommt von den Minzgelee-Exzessen dieses Löwenzahns. Er kann einfach nicht genug davon bekommen.",ep:1,g:555,l:5,wd:true,fm:true,w:1,p:2};
I.u[375] = {n:"Zahn eines Schattentofus",t:47,d:"Der Schattentofu hat einst seinen lächerlichen kleinen Tofuschnabel gegen lächerlich große Zähne eingetauscht. Schwer zu sagen, was gefährlicher ist. Doch lächerlich sind beide.",ep:1,g:47,l:3,wd:true,fm:true,w:1,p:1};
I.u[376] = {n:"Schattentofu-Flügel",t:104,d:"Dieser lächerliche kleine Flügel dient auch dem Schattentofu kaum zu etwas Nützlichem, außer vielleicht Luft aufzuwirbeln, um Moskitos zu ärgern.",ep:1,g:48,l:3,wd:true,fm:true,w:1,p:1};
I.u[377] = {n:"Pilzlingsdornen",t:15,d:"Diese giftigen Dornen schützen den Pilzling vor Nahkampfangriffen. Leider verhindern sie auch, dass er seiner Liebsten näherkommen kann, ohne sie zu töten. Das ist wohl der Grund, warum Pilzlinge Sporen entwickelt haben, um sich zu vermehren.",ep:1,g:49,l:5,wd:true,fm:true,w:1,p:1};
I.u[378] = {n:"Pilzlingsporen",t:15,d:"Diese Sporen ermöglichen es dem Pilzling, seine Nachkommen überall hin zu verbreiten. Doch geschieht dies nicht gleichmäßig. Denn Pilzlingsporen werden besonders von schlechtriechenden Abenteurerfüßen und dem Geruch der Stiefel des Bowissen angelockt.",ep:1,g:50,l:5,wd:true,fm:true,w:1,p:1};
I.u[379] = {n:"Krebsschere",t:47,d:"Die übertrieben große Krebsschere ist innen hohl, doch trotzdem kaum aufzubrechen. Krebse können damit das andere Geschlecht beeindrucken und sich als King feiern lassen.",ep:1,g:51,l:4,wd:true,fm:true,w:1,p:1};
I.u[380] = {n:"Wildminzenblätter",t:36,d:"Dies ist das Hauptnahrungsmittel von Minzgelees. Drum nehmt euch in Acht. Aber: wenn ihr Wildminzengeruch riecht, bedeutet dies noch lange nicht, dass auch ein Minzgelee in der Nähe ist.",ep:1,g:52,l:30,wd:true,fm:true,w:1,p:0};
I.u[381] = {n:"Erdbeere",t:46,d:"Dies ist das Hauptnahrungsmittel von Erdbeergelees. Drum nehmt euch in Acht. Wenn ihr Erdbeergeruch riecht, befindet ihr euch bereits mitten in ihrem Jagdgebiet.",ep:7,g:53,l:28,wd:true,fm:true,w:1,p:1};
I.u[382] = {n:"Kralle eines Raubritters von Kleppripp",t:47,d:"Diese dreckige und abgenutze Kralle war bereits überall und nirgendwo, unter anderem auch an den verruchtesten Orten. Darum solltet ihr sie nicht mehr an den verruchtesten Orten aufbewahren, damit sie sich nicht weiter abnutzt.",ep:3,g:54,l:16,wd:true,fm:true,w:1,p:1};
I.u[383] = {n:"Fresssackhorn",t:47,d:"Fresssackhörner fühlen sich weich und glatt an wie Leder. Aus noch unbekannten Gründen werden sie ganz besonders von Osamodas geschätzt.",ep:1,g:55,l:9,wd:true,fm:true,w:1,p:1};
I.u[384] = {n:"Fresssackwolle",t:57,d:"Diese dichte Wolle riecht nach ungewaschenem Bwork. Doch hält sie gut warm und kratzt nicht, weshalb sie selbst von empfindlichen Eniripas zum Füttern der Unterwäsche getragen wird.",ep:1,g:56,l:9,wd:true,fm:true,w:1,p:1};
I.u[385] = {n:"Fresssackspeichel",t:15,d:"Dieser eitrige Speichel stinkt furchtbar. Das liegt daran, dass der Fresssack stets mit der Zunge über die Wolle zu streichen pflegt, um diese sauber zu halten. Kommt jetzt der Gestank der Wolle vom Speichel oder der Gestank des Speichels von der Wolle? Dinge, die man besser nicht allzugenau erforschen sollte.",ep:1,g:57,l:9,wd:true,fm:true,w:1,p:1};
I.u[386] = {n:"Keiler-Rüssel",t:15,d:"Dieser Rüssel ist das perfekte Werkzeug, um dicke Eicheln unter dem Unterholz aufzustöbern. Doch im Gegensatz zum Rüssel des Schweinedrachens ist er aufgrund seines furchtbaren Gestankes absolut ungenießbar.",ep:1,g:58,l:14,wd:true,fm:true,w:1,p:1};
I.u[387] = {n:"Keiler-Hauer",t:47,d:"Mit diesem Hauer verteidigt sich der Keiler. Außerdem reinigt er damit seinen Trüffelsuchrüssel. Vergesst also nicht, ihn unter fließendem Wasser abzuspülen, bevor ihr ihn zu Pulver verarbeitet.",ep:1,g:59,l:14,wd:true,fm:true,w:1,p:1};
I.u[388] = {n:"Keiler-Haare",t:54,d:"Diese besonders strapazierfähigen Haare werden gern für Pinsel oder Besen verarbeitet. Doch manche Wesen reagieren auf sie allergisch, weshalb sich niemand kräftig daran reiben sollte.",ep:1,g:60,l:14,wd:true,fm:true,w:1,p:1};
I.u[389] = {n:"Wildes Sonnenblumenöl",t:60,d:"Dieses Öl wird von allen Ärzten für Diabetiker empfohlen, da es die wichtigsten natürlichen Fette enthält, ohne dabei sehr fetthaltig zu sein. Der Gehalt an pullyungesättigten Flirtsäuren ist nämlich höher als der an mollygesättigten Flirtsäuren, was für einen aktiven Glühvitaminhaushalt spricht.",ep:1,g:61,l:12,wd:true,fm:true,w:1,p:100};
I.u[390] = {n:"Walnuss-Öl",t:60,d:"Dieses Öl mit seinem fruchtigem Aroma wird gern genommen, um bestimmten Kuchen den gewissen Kick zu verleihen. Doch sollte man die Flasche schnell aufbrauchen, da sich das Öl nach dem Öffnen nicht mehr lange hält.",ep:4,g:62,l:32,wd:true,fm:true,w:1,p:100};
I.u[391] = {n:"Cashew-Nuss",t:58,d:"Aus dieser Cashew-Nuss lässt sich auch ein Öl pressen, wenn sie noch grün gepflückt wurde. Einmal getrocknet, kann man aus ihr auch Spielzeug für etwas geistig minderbemittelte Iopkinder herstellen.",ep:4,g:63,l:32,wd:true,fm:true,w:1,p:10};
I.u[392] = {n:"Pekan-Nuss",t:58,d:"Aus dieser Pekan-Nuss lässt sich auch ein Öl pressen, doch ist es besser sie einfach so zu essen, da das Öl eine stark abführende Wirkung hat.",ep:4,g:64,l:32,wd:true,fm:true,w:1,p:10};
I.u[393] = {n:"Eichel",t:58,d:"Keiler lieben diese Eicheln. Fragt sich nur warum.",ep:1,g:65,l:14,wd:true,fm:true,w:1,p:10};
I.u[394] = {n:"Haselnuss",t:58,d:"Diese kleine Haselnuss schmeckt besonders gut, wenn man sie mit einer Tafel Schokolade zusammen isst.",ep:1,g:66,l:14,wd:true,fm:true,w:1,p:1};
I.u[395] = {n:"5-blättriges Kleeblatt",t:36,d:"Dieses Kleeblatt ist ein unverzichtbarer Bestandteil bei der Ernährung von Tabis. Züchter müssen allerdings trotzdem Acht geben, nicht zu viel davon zu verfüttern, da sie schwere Blähungen bei den Tabis verursachen können.",ep:1,g:67,l:20,wd:true,fm:true,w:1,p:0};
I.u[396] = {n:"Palmöl",t:60,d:"Dieses Öl mit dem leichten Aroma ist für alle Gerichte geeignet, vom Frittieren bis hin zur Herstellung einer Vinaigrette-Sauce zum Schalat.",ep:3,g:68,l:32,wd:true,fm:true,w:1,p:100};
I.u[397] = {n:"Elbogs Schmieröl",t:60,d:"Dieses seltene Öl ist ein echtes Wunderelixier. Es ist so schmierfähig, dass sich damit eingeölte Maschinen niemals abnutzen. Man erhält es durch das Vermischen verschiedener anderer Öle.",ep:4,g:69,l:32,wd:true,fm:true,w:1,p:100};
I.u[398] = {n:"Palmfrucht",t:46,d:"Diese seltsame Frucht ergibt einmal ausgepresst ein hervorragendes Öl. Leider ist die Schale der Frucht kaum zu knacken, da sie so hart ist, wie die Sohle der Schuhe des Bowissen.",ep:3,g:81,l:32,wd:true,fm:true,w:1,p:10};
I.u[399] = {n:"Sesamöl",t:60,d:"Dieses Öl aus gepressten Sesamkörnern sticht durch seinen reichen Nussgeschmack mit einem leichten Nachgeschmack nach gebrannten Kastanien hervor. Nur schade, dass sich der Geruch eher dem eines angeschmorten Fresssackes als dem eines Minzgelees ähnelt.",ep:1,g:71,l:1,wd:true,fm:true,w:1,p:100};
I.u[400] = {n:"Gerste",t:34,d:"Gerste wird zum Bierbrauen, aber auch für die Viehzucht verwendet, und manchmal auch für die Aufzucht biertrinkenden Viehs.",ep:1,g:82,l:10,wd:true,fm:true,w:2,p:0};
I.u[401] = {n:"Hopfen",t:34,d:"Die Blüte der weiblichen Hopfenpflanze enthält alle wichtigsten Grundstoffe für das Brauen eines guten Bieres, insbesondere Stärke und natürliche Fette. \"Das erinnert mich total an meinen Biologieunterricht, bloß dass ich niemals einen Unterricht genossen habe.\" So lauten die zugegebenermaßen übertrieben romantischen Worte von Gabriela Neiht beim Anhören dieser Beschreibung.",ep:1,g:80,l:30,wd:true,fm:true,w:2,p:0};
I.u[405] = {n:"Malz",t:34,d:"So nennt man Gerste nach dem Keimen. Dieses für gutes Bier unverzichtbare Getreide ist allerdings ein wenig tückisch und tendiert dazu, beim Keimvorgang das Bier zu absorbieren. Ein wenig so wie der Tot nach einem harten Arbeitstag reiner Tofujagd.",ep:1,g:83,l:60,wd:true,fm:true,w:2,p:0};
I.u[406] = {n:"Wo Wabbit-Magen",t:15,d:"Dieser Magen hat die Fähigkeit, sich extrem weit zu dehnen, was die Verdauung des Wo Wabbits erheblich verbessert. Besonders wenn dieser wieder einmal zuviele vergorenen Kawotten gegessen hat.",ep:8,g:146,l:39,wd:true,fm:true,w:1,p:10};
I.u[407] = {n:"Prespikstachel",t:47,d:"Es gibt nichts Besseres für die Herstellung neuer Pfeilspitzen oder auch als Zahnstocher.",ep:1,g:134,l:18,wd:true,fm:true,w:1,p:50};
I.u[408] = {n:"Gebiss eines Elite-Chafers",t:47,d:"Der Elite-Chafer hat seine Zähne aufgrund des hohen Alkoholkonsums bereits verloren. Darum trägt er nun ein Gebiss. Aus reinem Gold, weil dieses Metall als Einziges auf längere Zeit seinen schlimmen Mundgeruch aushält.",ep:9,g:129,l:43,wd:true,fm:true,w:1,p:50};
I.u[409] = {n:"Bwork Magus-Barthaare",t:54,d:"Diese roten Haare stinken, wenn sie nass werden. Warum weiß niemand so genau, doch wissen alte Bwork Magi, aus ihnen mächtige Magie zu extrahieren. Das könnte einige Alchimisten sehr interessieren.",ep:4,g:131,l:23,wd:true,fm:true,w:1,p:20};
I.u[410] = {n:"Grimoire des Bwork Magus",t:25,d:"Dieses alte Zauberbuch ist ein wahres Sammlerstück. Denn daraus zieht der Bwork Magus seine Inspiration und große Zaubermacht. Jede einzelne Seite verbirgt zahlreiche Geheimnisse über die genaue Anatomie einzelner Wesen Amaknas.",ep:4,g:130,l:1,wd:true,fm:true,w:1,p:100};
I.u[411] = {n:"Schnabel des Eis-Kwacks",t:47,d:"Dieser außerordentlich harte Schnabel erlaubt es dem Eis-Kwack, Löcher ins Eis zu schlagen, wenn ihm danach ist, Löcher ins Eis zu schlagen. Eis-Kwacks sind wahrlich seltsame Wesen.",ep:1,g:133,l:24,wd:true,fm:true,w:1,p:20};
I.u[412] = {n:"Schnabel des Flammen-Kwacks",t:47,d:"Diese außerordentlich harte Schnabel erlaubt es dem Flammen-Kwack, Flammen auszuschlagen, wenn ihm danach ist, Flammen auszuschlagen. Flammen-Kwacks sind wahrlich seltsame Wesen.",ep:5,g:132,l:24,wd:true,fm:true,w:1,p:20};
I.u[413] = {n:"Schnabel des Wind-Kwacks",t:47,d:"Diese außerordentlich harte Schnabel erlaubt es dem Wind-Kwack, Windströmungen zu zerschlagen, wenn ihm danach ist, Windströmungen zu zerschlagen. Wind-Kwacks sind wahrlich seltsame Wesen.",ep:5,g:110,l:24,wd:true,fm:true,w:1,p:20};
I.u[414] = {n:"Eis-Kwack-Feder",t:53,d:"Dieses Feder besitzt die Eigenschaft, dem Frost widerstehen zu können. Genau aus diesem Grund wird man niemals einen vereisten Eis-Kwack sehen.",ep:1,g:112,l:24,wd:true,fm:true,w:1,p:20};
I.u[415] = {n:"Flammen-Kwack-Feder",t:53,d:"Dieses Feder besitzt die Eigenschaft, Flammen widerstehen zu können. Genau aus diesem Grund wird man niemals einen flammbierten Flammen-Kwack sehen.",ep:5,g:111,l:24,wd:true,fm:true,w:1,p:20};
I.u[416] = {n:"Wind-Kwack-Feder",t:53,d:"Dieses Feder besitzt die Eigenschaft, Windböen widerstehen zu können. Genau aus diesem Grund kann ein Wind-Kwack die unterschiedlichsten Winde einstecken, ohne daß seine Laune darunter leiden würde.",ep:5,g:113,l:24,wd:true,fm:true,w:1,p:20};
