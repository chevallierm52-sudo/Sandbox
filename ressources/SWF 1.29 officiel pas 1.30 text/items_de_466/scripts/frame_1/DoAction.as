I.u[218] = {n:"Basher",t:5,d:"Basher sind fürchterliche Waffen, gut geeignet für jeden Meuchelmörder. Ihr Träger wird mit ihnen manch einem blutrünstigen Kämpfer mindestens ebenbürtig sein.",ep:7,g:5,l:29,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>40",p:2500};
I.u[219] = {n:"Blessurdolche",t:5,d:"Die Blessurdolche gehörten einst dem berüchtigten Dunkelhand-Oger, der umkam, als er einen Bimd Oul-Paladin angriff. Man munkelt, sein Blut würde nun diese bösartigen Dolche beleben, doch konnte das bis heute noch niemand beweisen.",ep:7,g:55,l:64,wd:true,fm:true,w:15,an:13,tw:true,e:[17,3,1,1,30,100,false,false],c:"CA>64&CV>10&CC>10",p:10900};
I.u[220] = {n:"Chakra Style",t:5,d:"Chakra Style sind zwei Schwesterdolche, die einst einer berüchtigten Diebin Amaknas gehörten. Sie war so gut, dass sie es sogar schaffte, die Schlösser der Türen zum Tempel Osaroths zu knacken und einige der wertvollsten Reliquien von dort mitgehen zu lassen!",ep:7,g:8,l:73,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>73&CC>15",p:13900};
