I.u[233] = {n:"Kaiser",t:7,d:"Kaiser ist der Name des Schweinedrachens, welcher einst das Dorf Bounkaïda dem Erdboden gleichmachte. Nachdem ihn die Milizen endlich überwältigt hatten, nutzten viele Schmiede Teile des Drachens, um daraus Waffen zu machen. U.a. entstand dabei dieser Hammer.",ep:2,g:10,l:82,wd:true,fm:true,w:20,an:15,e:[20,4,1,1,30,200,false,false],c:"CS>80&CI>80&CA>50",s:58,p:10000};
I.u[234] = {n:"Ragnarok",t:7,d:"Ragnarok ist ein wirklich sehr mächtiger Hammer, der in der Lage ist Unwetter auszulösen... oder vor Wut blitzende Augen bei euren Verbündeten, falls diese versehentlich von ihm getroffen wurden.",ep:7,g:55,l:66,wd:true,fm:true,w:60,an:15,e:[10,4,1,1,45,100,false,false],c:"CS>40&CI>40&CW>10",p:11400};
I.u[235] = {n:"Cerberus",t:7,d:"Dieser Hammer hat einst dem Wächter zum Tor der Hölle gehört. Er verhinderte damit, dass die Lebenden dort hineingehen, die Toten herauskommen und sich die lebenden Toten überhaupt vom Fleck bewegen.",ep:1,g:7,l:16,wd:true,fm:true,w:35,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>15&CS>15",p:900};
I.u[236] = {n:"Barabas",t:7,d:"Barabas ist wirklich furchterregend: er ermöglicht es dem Träger, sich leichtfüßig zu bewegen und ist sehr wirkungsvoll im Nahkampf.",ep:1,g:11,l:23,wd:true,fm:true,w:40,an:15,e:[5,4,1,1,45,45,false,false],c:"CI>13&CS>10",p:1600};
I.u[237] = {n:"Sargass",t:7,d:"Sargass befand sich einst in den Händen eines Kindes mit furchterregenden Kräften. Allerdings weiß niemand, wer diese Waffe nun besitzt, seitdem das Kind sie bei einem Abenteurer gegen einen Sack Murmeln eingetauscht hat.",ep:1,g:8,l:27,wd:true,fm:true,w:12,an:15,e:[10,4,1,1,45,50,false,false],c:"CI>17&CC>5",p:2100};
I.u[238] = {n:"Kleine Kehrschaufel",t:8,d:"Eine gut ausgewogene Schaufel, die besonders für Anfänger gut geeignet ist.",ep:1,g:4,l:13,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>3&CC>10",p:700};
I.u[239] = {n:"Kehrschaufel",t:8,d:"Eine gut ausgewogene Schaufel, die besonders für Anfänger gut geeignet ist.",ep:1,g:4,l:15,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>10",p:800};
