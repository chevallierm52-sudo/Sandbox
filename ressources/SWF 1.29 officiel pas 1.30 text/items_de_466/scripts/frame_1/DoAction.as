I.u[174] = {n:"Kleines Weisheitsstäbchen",t:3,d:"Dieser Stab erhöht die Weisheit seines Trägers.",ep:1,g:4,l:20,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,50,30,false,true],c:"CI>20&CW>5",p:1300};
I.u[180] = {n:"Stab des Limbos",t:3,d:"Dieser Stab stammt aus dem tiefsten Limbo von Syrastass. Der Legende nach kann er auf bloßen Wunsch seines Trägers ganze Felder von Osterglocken zum Erblühen bringen.",ep:9,g:7,l:105,wd:true,fm:true,w:30,an:11,e:[10,4,2,4,30,30,false,true],c:"CI>200&CW>100",p:28400};
I.u[181] = {n:"Himmlischer Stab",t:3,d:"Dieser Stab wurde von Helle aus den obersten Himmelsphären gesegnet. Er verleiht daher seinem Träger Flinkheit und Vitalität im Kampf.",ep:7,g:6,l:52,wd:true,fm:true,w:25,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>104&CV>20&CA>10",p:7150};
I.u[182] = {n:"Kleiner Laubstock",t:4,d:"Dieser schön zurechtgeschnitzte Stock ist besonders für Anfänger gut geeignet.",ep:1,g:2,l:13,wd:true,fm:true,w:16,an:12,e:[5,4,1,1,50,50,false,false],c:"CI>13",p:700};
