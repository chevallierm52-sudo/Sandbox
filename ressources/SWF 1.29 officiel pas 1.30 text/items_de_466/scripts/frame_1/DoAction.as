I.u[156] = {n:"Gürtel der Macht",t:10,d:"Dieser Gürtel erhöht erheblich die Kampfkraft seines Trägers. Leider wirkt sich sein hohes Gewicht dabei ein wenig negativ auf dessen Flinkheit aus. Aber wer will schon vor dem Gegner weglaufen?",ep:1,g:19,l:31,wd:true,fm:true,w:20,p:3000};
I.u[157] = {n:"Das Geschnapsel",t:1,d:"Das Geschnapsel wurde aus einem Stück Mondstein gefertigt, welches über 5.000 Jahre in einem Fass Schnaps verbracht hatte. Da ist fast vorprogrammiert, dass dies dem Amulett große Macht verleiht.",ep:2,g:7,l:17,wd:true,fm:true,w:5,p:1000};
I.u[158] = {n:"Die Goldene Zukunft",t:1,d:"Die goldene Zukunft erhöht erheblich die Flinkheit und Vitalität ihres Trägers.",ep:1,g:9,l:12,wd:true,fm:true,w:5,p:600};
I.u[159] = {n:"Die Himmlische Brosche",t:1,d:"Man sagt, diese Brosche sei vom berühmten Schmied Bulgur höchstpersönlich gefertigt worden, dem man nachsagt, sogar die mächtigen Waffen der Götter zu schmieden.",ep:1,g:8,l:40,wd:true,fm:true,w:5,p:2900};
I.u[160] = {n:"Sternpudding",t:1,d:"Dieser seltene Gegenstand wurde aus dem Gemisch von Sternenstaub aus der Milchstraße und Himmelseiern gefertigt. Daher immer kühl aufbewahren!",ep:7,g:10,l:62,wd:true,fm:true,w:5,p:10000};
I.u[161] = {n:"Die Berühmtheit",t:1,d:"Dieses mächtige Amulett wird mit Sicherheit den Träger zu einer Berühmt-Berüchtigtheit machen.",ep:1,g:9,l:27,wd:true,fm:true,w:5,p:2200};
