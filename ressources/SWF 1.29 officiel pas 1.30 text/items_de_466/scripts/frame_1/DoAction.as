I.u[65] = {n:"Goultard",t:6,d:"Da es gleich nach dem Schmieden im Blut eines Schweinedrachens abgeschreckt wurde, hat das Goultard einen eigentümlichen Geruch an sich. Riecht es nach Drachendung? Nach Schweineurin? Schwer zu sagen. Hat sich jedoch der Träger erst einmal an den Gestank gewöhnt, kann er sich mit diesem mächtigen Schwert mit den besten aller Kämpfer messen.",ep:2,g:17,l:40,wd:true,fm:true,w:50,an:14,e:[15,5,1,1,40,50,false,false],c:"CS>80&CV>40&CA>40",p:4400};
