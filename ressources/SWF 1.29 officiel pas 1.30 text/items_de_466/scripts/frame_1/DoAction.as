I.u[127] = {n:"Bowissen-Stiefel",t:11,d:"Diese außergewöhnlichen Stiefel erhöhen eure Bewegungsrate im Kampf. Doch hütet euch vor dem furchtbaren Gestank, den sie absondern. Sie haben nämlich einst dem berüchtigten Bowissen gehört.",ep:2,g:2,l:50,wd:true,fm:true,w:13,p:5000};
