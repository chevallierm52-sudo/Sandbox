I.u[250] = {n:"Ares",t:8,d:"Ares mit seinem seltsamen Aussehen auf halbem Wege zwischen einer Axt und einer Schaufel war eine der sieben Waffen, die der Dämon Kajlir zum Besiegen der \"Bruderschaft der Purpur-Dofus sammelnden Enutrofs\" verwendet hat.",ep:9,g:9,l:72,wd:true,fm:true,w:50,an:16,e:[10,4,1,1,50,50,false,false],c:"CC>200",p:14000};
I.u[251] = {n:"Graubart",t:8,d:"Graubart war die Lieblingswaffe des Dämonenzwerges (oder Zwergdämonen?), der viele Dorfbewohner terrorisierte, weil er ohne auch nur \"Vorsicht\" zu rufen ihre Dörfer angriff, und zwar völlig ohne Rücksicht, so dass sie danach die Nachsicht hatten.",ep:1,g:11,l:20,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,50,50,false,false],c:"CS>5&CC>15",p:1250};
I.u[252] = {n:"Kleiner Vitalgürtel",t:10,d:"Dieser Gürtel erhöht die Lebenskraft seines Trägers und garantiert so eine geringfügig längere Haltbarkeit im Kampf.",ep:1,g:9,l:1,wd:true,fm:true,w:6,p:100};
