I.u[188] = {n:"Gehstock des Einsiedlerkrebses",t:4,d:"Dieser Stab erhöht die Weisheit seines Trägers. Risiken und Nebenwirkungen: Kann zu einer Hypertrophie führen, daher nur in Maßen verwenden.",ep:1,g:3,l:14,wd:true,fm:true,w:25,an:12,e:[5,3,1,1,50,50,false,false],c:"CI>14",p:750};
I.u[194] = {n:"Spiritueller Stock",t:4,d:"Dieser Stock erhöht nicht nur die Vitalität seines Trägers, er kann notfalls sogar gegessen werden.",ep:1,g:8,l:16,wd:true,fm:true,w:16,an:12,e:[3,3,1,1,50,50,false,false],c:"CI>16",p:900};
I.u[200] = {n:"Gott-Stock",t:4,d:"Der Gott-Stock ist eine extrem mächtige Waffe. Selbst wenn ihr gerade mal eine kleine Schwäche verspürt, dann wird seine große Macht euch immernoch den Besten der Besten mindestens ebenbürtig sein lassen.",ep:3,g:7,l:67,wd:true,fm:true,w:23,an:12,e:[10,3,1,1,30,30,false,false],c:"CI>60&CV>10&CW>10",p:11650};
I.u[201] = {n:"Hook",t:4,d:"Hook wurde bei einer Leiche gefunden, die direkt neben den Überresten eines gewaltigen, halb-verwesten Crocodylls lag.",ep:7,g:4,l:55,wd:true,fm:true,w:20,an:12,e:[5,3,1,1,30,50,false,false],c:"CI>30&CC>10&CS>10",p:8050};
I.u[202] = {n:"Razielle",t:6,d:"Dieses Schwert wurde durch die Tränen des Engels Raziel geweiht. Es ist einfach nur himmlisch zerstörerisch und seine Macht reicht aus, um auch die mächtigsten aller Gegner mühelos besiegen zu können.",ep:1,g:16,l:52,wd:true,fm:true,w:50,an:14,e:[15,5,1,1,40,50,false,false],c:"CS>104&CV>52&CA>20",p:7100};
I.u[203] = {n:"Tots Gürtel",t:10,d:"Wenn ihr diesen großartigen Gürtel um die Taille tragt, so bedeutet dies, das ihr ein echtes Glückskind seid. Dieser Gürtel gehörte nämlich einst einem berühmten-berüchtigten haarigen Riesen, dem stärksten Helden und unwiderstehlichstem Frauenhelden aller Zeiten.",ep:1,g:10,l:33,wd:true,fm:true,w:15,p:3200};
I.u[204] = {n:"Kryst O\'Boul",t:4,d:"Dieser lebende Stecken hängt immer an den düsterlichsten Orten von ganz Amakna herum. Alle 300 Jahre ändert er Ort und Besitzer, wobei er es vorzieht, immer möglichst dunkle und übelriechende Tunnel und Gänge zu nehmen.",ep:7,g:63,l:59,wd:true,fm:true,w:23,an:12,tw:true,e:[5,3,1,1,30,50,false,false],c:"CI>59&CA>5",s:38,p:9050};
I.u[205] = {n:"Kleine eiserne Dolche",t:5,d:"Diese liebevoll geschmiedeten Dolche sind besonders für Anfänger sehr gut geeignet.",ep:1,g:3,l:10,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>10",p:500};
