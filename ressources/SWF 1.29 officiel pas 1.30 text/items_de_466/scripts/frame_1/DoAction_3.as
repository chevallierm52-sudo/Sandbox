I.u[1117] = {n:"Kleine Archeobogie",t:2,d:"Der Bauplan dieses uralten Bogens wurde in den Tiefen der Ruinen von Din von einem Abenteurer gefunden, der wegen seiner Peitsche gefürchtet war. Es ist allerdings nicht bekannt, ob die Gerüchte wahr sind, er habe sein altes, krachmachendes Lederding gegen diesen wunderschönen, biologisch abbaubaren Bogen eingetauscht.",ep:1,g:20,l:18,wd:true,fm:true,w:17,an:10,tw:true,e:[10,6,2,8,30,50,false,true],c:"CI>20&CA>15",p:4000};
