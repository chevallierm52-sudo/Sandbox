I.u[1068] = {n:"Atmos kleiner Sphärenzerschlager",t:7,d:"Dieser Streithammer ist besonders für die Zerschlagung von Sphären geeignet. Als zusätzlicher Effekt wird der Träger auch sehr wetterfühlig. Doch seinen Schöpfer konnte diese Eigenschaft nicht schützen;\r\n            er wurde von einem Blitz erschlagen. Erst sehr viel später fand man heraus, dass der Hammer Schläge jeder Art und insbesondere Blitzschläge anzuziehen scheint.",ep:2,g:14,l:34,wd:true,fm:true,w:40,an:15,e:[7,4,1,1,50,50,false,false],c:"CI>10&CS>10",p:14000};
