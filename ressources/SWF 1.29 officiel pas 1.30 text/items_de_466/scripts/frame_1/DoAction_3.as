I.u[1403] = {n:"Ottos Witzhammer",t:7,d:"Dieser Hammer gehörte früher Otto, einem jungen Osamodas, der den lieben langen Tag lang nur Witze erzählte. Sein Hammer ist genau wie er. Er erhöht nicht gerade die Intelligenz seiner Umgebung, doch kann er tierisch entspannend auf sie wirken.",ep:1,g:3,l:23,wd:true,fm:true,w:20,an:15,e:[4,4,1,1,30,30,false,true],c:"CA>20",p:1700};
I.u[1404] = {n:"Tonhammeri Minotororo",t:7,d:"Mögt ihr Tiere? Zum Beispiel Minotorors? Tonhammeri auch. Er hat ihnen sogar sein Leben gewidmet. Dieser Hammer erzählt ein wenig seine traurige Geschichte. Beispielsweise, wie er in Gemeinschaft mit seinen Tieren lebte und mit ihnen auf die Jagd ging, genauso flink, wie ein humpelnder Fresssack auf 2 Hufen. Einfach rührend!",ep:5,g:15,l:35,wd:true,fm:true,w:35,an:15,e:[6,4,1,1,30,30,false,true],c:"CI>80&CW>30",p:3400};
I.u[1405] = {n:"Feenwasser",t:12,d:"Dieser Trank hat dieselbe heilsame Wirkung wie das Blut der Eniripsa. Das ist toll, denn endlich braucht man die armen Eniripsas nicht mehr ausbluten zu lassen, um die heilsame Wirkung zu entfalten.",ep:3,g:41,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
I.u[1406] = {n:"Einohrblut",t:12,d:"Dieser Trank hat dieselbe heilsame Wirkung wie das Blut der Einohrer, außer, dass er keine Unsterblichkeit verleiht. Um es mit den Worten eines berühmten Eniripsa-Heilers auszudrücken: \"Trinkt, und ihr werdet von allen Gebrechen geheilt!\"",ep:3,g:40,l:60,wd:true,fm:true,w:1,u:true,ut:true,p:100};
