I.u[1129] = {n:"Saphir-Dracheischale",t:111,d:"Diese Schale ist so gut wie unzerbrechlich. Doch nachdem sie von Generationen von Juwelieren auf Hochglanz poliert wurde, ist es nun möglich, ihre magischen Kräfte zu nutzen, um extrem mächtige Amulette zu fertigen.",ep:11,g:211,l:64,wd:true,fm:true,w:5,p:1};
