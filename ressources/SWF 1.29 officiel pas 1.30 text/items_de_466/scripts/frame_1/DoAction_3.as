I.u[1101] = {n:"Kleiner Stab für gewisse Stunden",t:3,d:"Der Eniripsa Mie Däpan fertigte eine ganze Reihe dieser spitzen Stäbe an, um gegen Diebstähle vorzugehen. Theroretisch sollen die Stäbe die Macht haben, in der Zeit zurückzureisen, um Überfälle zu verhindern. Doch in der Praxis landeten sie alle im Auge eines mächtigen und mächtig darüber erbosten Dämonen.",ep:4,g:17,l:15,wd:true,fm:true,w:10,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>25&CS>1",p:1500};
