I.u[1393] = {n:"Hammetronom",t:7,d:"Dieser Hammer wurde aus Teilen eines Uhrwerkes gebaut. Nämlich des Uhrwerkes, das vom Crocodyll verschlungen wurde, welches auch gleichfalls die Hand von Käpt\'n Gurk verspeist hatte. Während man das Uhrwerk heil wiedergefunden hatt, weiß niemand genau, was aus der Hand des Kapitäns geworden ist.",ep:5,g:21,l:54,wd:true,fm:true,w:20,an:15,e:[8,6,1,1,40,40,false,true],c:"CI>62&CW>22",p:9700};
