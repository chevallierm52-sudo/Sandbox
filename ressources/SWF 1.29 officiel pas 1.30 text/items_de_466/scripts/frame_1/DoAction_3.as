I.u[1141] = {n:"Erd-Kwack Feder",t:53,d:"Diese Feder besitzt die Eigenschaft, Steinschlägen zu widerstehen. Genau aus diesem Grund wird man niemals einen beerdigten Erd-Kwack sehen.",ep:5,g:223,l:24,wd:true,fm:true,w:1,p:20};
I.u[1142] = {n:"Schnabel des Stein-Kwacks",t:47,d:"Diese außerordentlich harte Schnabel erlaubt es dem Stein-Kwack, Steine zu zerschlagen, wenn ihm danach ist, Steine zu zerschlagen. Stein-Kwacks sind wahrlich seltsame Wesen.",ep:5,g:222,l:24,wd:true,fm:true,w:1,p:20};
I.u[1143] = {n:"Kleiner Stab der Beherrschung",t:3,d:"Man sagt, dieser Stab habe die Macht, andere zu beherrschen. Laut Anleitung soll man ihn heftig vor dem Gesicht der Zielperson hin- und herschütteln. Aber mit dem Stab auf sie eindreschen, funktioniert meist genauso gut.",ep:4,g:21,l:56,wd:true,fm:true,w:15,an:11,e:[5,4,2,4,50,50,false,true],c:"CI>80",p:20000};
