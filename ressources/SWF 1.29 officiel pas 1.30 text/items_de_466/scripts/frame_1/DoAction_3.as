I.u[1032] = {n:"Unta deMers kleine Klinge",t:5,d:"Dieser Dolch wurde einst vom geheimen Orden Unta deMer gebraucht. Man sagt, dieser Orden habe beabsichtigt, Amakna ins Chaos zu stürzen. Doch seit dem Zeitpunkt, an dem angeblich Teile Sufokias untergingen, ward keiner mehr von ihnen gesehen.",ep:1,g:14,l:44,wd:true,fm:true,w:10,an:13,e:[13,3,1,1,30,50,false,false],c:"CA>44&CC>5",p:5000};
