I.u[1121] = {n:"Trüber Kristallbogen",t:2,d:"Nehmen Sie einen alten, gebrauchten Bogen, streuen Sie etwas Wunderpulver darauf und bittet einen Drachen, seinen Odem darauf zu hauchen. Sie erhalten dann einen verzauberten Bogen. Doch dieses märchenhafte Rezept funktioniert leider nicht wirklich... Drachen zielen nämlich immer daneben.",ep:10,g:18,l:38,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"CI>35&CA>10",p:3500};
