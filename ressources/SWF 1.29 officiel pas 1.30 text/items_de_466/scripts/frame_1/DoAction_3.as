I.u[1105] = {n:"Kleiner Kirchenstab",t:3,d:"Dieser schwere Stab hat bereits mehr als nur einen Sünderschädel zertrümmert. Es waren nämlich Iop-Priester, die sich seiner bedienten, um auf radikale und endgültige Weise Reuigen die Absolution zu erteilen.",ep:2,g:16,l:36,wd:true,fm:true,w:1,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>36&CS>25",p:5000};
