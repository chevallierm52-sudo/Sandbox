I.u[1426] = {n:"Kuch Henwegs Schaufel",t:8,d:"Kuch Henweg, der Erschaffer dieser Schaufel, war ein typischer Iop. Jahrelang suchte er nach einem Schreiber, der ihm seinen Namen auf die Schaufel ritzen würde. Doch kam es nie dazu, weil er stets alle Schreiber während seiner unkontrollierbaren Jähzornattacken mit seiner Schaufel henwegzuschaufeln pflegte...",ep:3,g:8,l:24,wd:true,fm:true,w:24,an:16,e:[5,5,1,1,50,50,false,true],p:1800};
I.u[1427] = {n:"Zebubs Schaufel",t:8,d:"Diese Schaufel wird von den kannibällischen Priestern der Moon-Insel ausschließlich dazu genutzt, Zebub zu beschwören, eine Gottheit mit dem Kopf einer Kuh. Wozu das? Wer weiß... Achtung: nur Charaktere böser Gesinnung können diese Waffe führen!",ep:1,g:40,l:55,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,50,20,false,true],c:"Ps=2&CC>50",p:8000};
I.u[1428] = {n:"Immergrün",t:36,d:"Diese seltsame kleine Pflanze gedeiht am besten in Wüstengegenden, wo sie einen feinen Currygeruch in der Luft verbreitet. Sie scheint auch den Wechsel der Jahreszeiten problemlos zu verkraften. Wenn man das bloß auch von manchen Frauen behaupten könnte...",ep:2,g:54,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1429] = {n:"Deils feine Schippe",t:8,d:"Deils Schippe ist so kunstvoll gefertigt und wunderschön anzusehen, dass alle Frauen bei ihrem Anblick schwach werden. Allerdings sollte man niemals vergessen, dass es sich dabei um eine blanke, scharfe Waffe handelt. Oder mit den Worten Deils ausgedrückt: \" Sie ist so scharf, sie ist so schick, sie ist so hip, meine Schipp\'! \"",ep:1,g:19,l:30,wd:true,fm:true,w:15,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>10&CI>10",p:1500};
I.u[1430] = {n:"Deils Schippe",t:8,d:"Deils Schippe ist so kunstvoll gefertigt und wunderschön anzusehen, dass alle Frauen bei ihrem Anblick schwach werden. Allerdings sollte man niemals vergessen, dass es sich dabei um eine blanke, scharfe Waffe handelt. Oder mit den Worten Deils ausgedrückt: \" Sie ist so scharf, sie ist so schick, sie ist so hip, meine Schipp\'! \"",ep:1,g:19,l:45,wd:true,fm:true,w:23,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>15&CI>15",p:2300};
I.u[1431] = {n:"Deils schöne Schippe",t:8,d:"Deils Schippe ist so kunstvoll gefertigt und wunderschön anzusehen, dass alle Frauen bei ihrem Anblick schwach werden. Allerdings sollte man niemals vergessen, dass es sich dabei um eine blanke, scharfe Waffe handelt. Oder mit den Worten Deils ausgedrückt: \" Sie ist so scharf, sie ist so schick, sie ist so hip, meine Schipp\'! \"",ep:1,g:19,l:60,wd:true,fm:true,w:30,an:16,e:[5,6,1,1,40,40,false,true],c:"CC>25&CI>25",p:3000};
I.u[1432] = {n:"Fels Gartenschau",t:8,d:"Fel, ein alter Enutrof-Gärtner, pflegte überall im Übermaß Blumen zu pflanzen und jedem damit auf die Nerven zu gehen. Daher bekam alles, was er je anrührte, den Spitznamen \"Fels Gartenschau\". Seine Waffe ist kein bisschen besser: sie ist zwar mächtig, doch tut sie alles im Überfluß und steigert nicht gerade die Intelligenz ihres Trägers.",ep:1,g:17,l:21,wd:true,fm:true,w:21,an:16,e:[2,4,1,1,50,50,false,true],c:"CC>27&CW<100&CS>10",p:2100};
I.u[1433] = {n:"Hins RichterSchaufel",t:8,d:"Hin war ein exzentrischer Enutrof-Richter, der statt eines Hammers immer seine Schaufel verwendete, um Urteilssprüche zu verkünden. Da er auch gleichfalls unerkannterweise der Henker des Ortes war, konnte er mit ihr auch gleich das Urteil vollstrecken. Praktisch, nicht wahr?",ep:7,g:4,l:60,wd:true,fm:true,w:30,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>60&CS>30&CA>10",p:6500};
I.u[1434] = {n:"Trank des Vergessens: \"Uhrwerk\"",t:43,d:"Dieser Trank lässt euch einen Grad des Xelor-Zauberspruches \"Uhrwerk\" vergessen.",ep:1,g:37,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1435] = {n:"Lockruf der Schwere",t:8,d:"Diese extrem schwere Schaufel ist besonders für fe... ähm... starke Abenteurer geeignet.",ep:9,g:11,l:80,wd:true,fm:true,w:150,an:16,e:[10,6,1,1,50,50,false,true],c:"CS>100",p:40000};
I.u[1436] = {n:"Schippe Hansi",t:8,d:"Hansi war der Name des kleinen Affen, der den erfahrenen Kämpfer Chourros treu begleitete. Dieser war so daran gewöhnt, sich mit dem kleinen Affen zu unterhalten, dass er nach dessen Versterben kurzerhand seine Schaufel nach ihm benannte und die gewohnten Unterhaltungen ohne Unterbrechung weiterführte.",ep:7,g:8,l:50,wd:true,fm:true,w:50,an:16,e:[10,5,1,1,50,50,false,true],c:"CC>30&CA>10",p:7800};
I.u[1437] = {n:"Trank des Vergessens: \"Kräftige Bestrafung\"",t:43,d:"Dieser Trank lässt euch einen Grad des Sacrieur-Zauberspruches \"Kräftige Bestrafung\" vergessen.",ep:2,g:35,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1438] = {n:"Glückspickel",t:21,d:"Dieser Pickel wird von vielen Bergarbeiter-Clans als mächtiger Glücksbringer angesehen.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,4,1,1,50,50,false,true],c:"CC>30",p:2500};
I.u[1439] = {n:"Unglückspickel",t:21,d:"Dieser Pickel neigt dazu, Murphys Auge auf den Träger zu werfen. Allerdings würde, so sagt man, gar nicht viel fehlen, damit diesem der ganz große Wurf gelänge.",ep:1,g:1,l:25,wd:false,fm:true,w:20,an:17,e:[4,6,1,1,50,10,false,true],p:250};
