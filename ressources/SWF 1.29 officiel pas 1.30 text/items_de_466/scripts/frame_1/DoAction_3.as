I.u[1040] = {n:"Blutklingen von Ortimus Contrari",t:5,d:"Ortimus Contrari ist selbst unter Meuchelmördern eine Legende. Denn Insider wissen, dass er seine Aufträge stets auf eine Art und Weise erledigt, die sich grundlegend von den traditionellen Methoden unterscheidet. Mehr solltet ihr zu eurer eigenen Sicherheit darüber jedoch nicht wissen, da ihr sonst sofort sterben müsstet!",ep:9,g:19,l:80,wd:true,fm:true,w:15,an:13,e:[15,3,1,1,20,50,false,false],c:"CA>79&CS>40",p:10000};
I.u[1041] = {n:"Geborstenes Schwert des Unglücksritters",t:5,d:"Dieses Schwert wurde dem jungen Iop Blackcat zu seinem Ritterschlag verliehen. Leider stürzte dieser gleich bei seiner ersten Mission als Ritter und zerschmetterte sein Schwert. Er hatte nämlich einen Krachler für einen harmlosen Stein gehalten.",ep:1,g:43,l:35,wd:true,fm:true,w:20,an:13,e:[5,5,1,1,30,50,false,false],c:"CS>20",p:3000};
I.u[1042] = {n:"Süße dornengespickte rosa Schaufel",t:8,d:"Diese Schaufel besteht aus einem sehr seltenem Dornenholz. Einer Legende nach soll jede junge Frau beim bloßen Berühren dieser Schaufel in einen ewig andauernden Schlaf fallen. Was hingegen nicht in der Legende erwähnt wird, ist das *gähn*... jeder andere auch *gähn*... bei *gähn*... längerem Kontakt... zzzzZZZzzz.",ep:1,g:20,l:34,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CS>4&CC>26",p:3200};
