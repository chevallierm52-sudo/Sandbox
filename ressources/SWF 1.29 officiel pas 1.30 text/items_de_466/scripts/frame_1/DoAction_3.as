I.u[1383] = {n:"Schildzu Krötzschlag",t:7,d:"Dieser Hammer ging über viele Jahrezehnte durch die Hände Dutzender Schmiede, die jeweils ein wenig daran weitergearbeitet haben. Das Endergebnis kann sich wirklich sehen lassen, doch hat der Hammer leider von den vielen Erschaffern auch deren Vorstellungen einer kurzen Zeitdauer geerbt.",ep:1,g:5,l:55,wd:true,fm:true,w:20,an:15,tw:true,e:[8,4,1,1,50,50,false,false],p:8000};
