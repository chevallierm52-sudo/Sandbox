I.u[1084] = {n:"Tors Hammer",t:7,d:"Dieser gewaltige Hammer wird euch helfen, alle Menschen, die denken, dass Stärke über Verstand siegt, eines Besseren zu belehren! (Hier das Kleingedruckte: Allerdings gilt dies nur für diejenigen, die schwächer sind als ihr. Stärkere haben bekanntlich IMMER Recht...)",ep:9,g:20,l:81,wd:true,fm:true,w:60,an:15,e:[10,4,1,1,40,50,false,false],c:"CI>100",p:15000};
I.u[1085] = {n:"Falistos Hammer",t:7,d:"Die Falistos sind außergewöhnliche Schmiede (die Qualität ihrer Hämmer ist dafür Beweis genug). Es handelt sich um ehemals dämonische Anhänger Xélors, die ihren Gott verlassen haben. Diese Tat hatte jedoch schwere Folgen: nämlich ihre ständige höllische Verspätung!",ep:9,g:19,l:79,wd:true,fm:true,w:70,an:15,tw:true,e:[15,7,1,1,50,25,false,false],c:"CS>79",p:10000};
I.u[1086] = {n:"Schwarze Farbe",t:15,d:"Dieser Eimer mit schwarzer Farbe ist sehr nützlich, um etwas schwarz anzumalen. Sei es euer Haus, euren Haustofu, eure Freunde oder gar euch selbst, wenn euch danach ist.",ep:12,g:175,l:1,wd:true,fm:true,w:2,p:1};
I.u[1087] = {n:"Ring der Geistesstärke",t:9,d:"Dieser Ring erhöht geringfügig die Intelligenz seines Trägers.",ep:1,g:36,l:14,wd:true,fm:true,w:2,p:775};
I.u[1088] = {n:"Kanniballische Maske",t:16,d:"Diese Maske ist eine exakte, nur leicht vergrößerte Imitation der Masken, die stolz von den wichtigen Kannibällen getragen werden.",ep:12,g:26,l:40,wd:true,fm:true,w:10,p:5000};
I.u[1089] = {n:"Ticket zur Moon-Insel",t:15,d:"Ziel: Paradiesinsel \nPreis: 1.000 Kamas \nGültigkeit: 1 einfache Hinfahrt",ep:2,g:172,l:1,wd:true,fm:true,w:1,p:1};
I.u[1090] = {n:"Astrohaube",t:16,d:"Die Astrohaube ist die perfekte Haube für euren Astralkörper.",ep:1,g:27,l:20,wd:true,fm:true,w:4,p:1300};
