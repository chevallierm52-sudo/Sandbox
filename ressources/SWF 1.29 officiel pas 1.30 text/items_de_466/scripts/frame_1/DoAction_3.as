I.u[1059] = {n:"Grabund Schaufel",t:8,d:"Diese Schaufel ist der Liebling aller Gärtner und Bauern. Sie ist beispielsweise hervorragend dazu geeignet Kartoffeln auszugraben. Doch nichts hindert euch daran, damit beispielsweise auch Radieschen auszugraben und sie euren Gegner stolz mit der Wurzel voran zu präsentieren.",ep:1,g:17,l:15,wd:true,fm:true,w:35,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>15",p:750};
I.u[1060] = {n:"Kleiner Dualstreitkolben",t:7,d:"Dies ist wieder einmal eine dieser hervorragend gearbeiteten Dualwaffen. Dieser Streitkolben mit dem perfekten Luftwiderstandsfaktor pflügt doppelt so schnell wie andere durch die Luft – und zerschmettert daher doppelt so schnell die Schädel der Gegner. Das sind mindestens zwei gute Gründe, diese Waffe zu besitzen.",ep:1,g:16,l:18,wd:true,fm:true,w:40,an:15,e:[10,5,1,1,60,40,false,false],c:"CS>18&CI>2",p:3000};
