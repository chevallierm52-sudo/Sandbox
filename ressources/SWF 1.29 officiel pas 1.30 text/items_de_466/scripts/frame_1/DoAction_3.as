I.u[1459] = {n:"Längliches Reagenzglas",t:71,d:"Dieses Reagenzglas wurde so gebaut, dass man es mit nur einer Hand entkorken kann.",ep:1,g:55,l:1,wd:true,fm:true,w:1,p:5};
I.u[1460] = {n:"Große Phiole",t:71,d:"Diese Phiole wurde absichtlich so geformt, dass man sie entkorken kann, ohne seine Hände zu benutzen.",ep:3,g:56,l:1,wd:true,fm:true,w:1,p:10};
I.u[1461] = {n:"Ätzendes Gift",t:15,d:"Dieses Gift, welches aus Arachneeklauen gewonnen wurde, wird euch völlig kopflos machen. Im übertragenen Sinne, wie auch wörtlich, da nach längerem Wahnsinn der Schädel irgendwann durch Einfluss des Giftes zerspringt.",ep:1,g:189,l:20,wd:true,fm:true,w:1,p:100};
I.u[1462] = {n:"Vampirflüssigkeit",t:15,d:"Diese Flüssigkeit ist eine Mischung aus verschiedenen Blutsorten, die sich in einem Wesen befanden, welches die dumme Angewohnheit hatte, gleich allem und jedem um den Hals zu fallen.",ep:2,g:188,l:30,wd:true,fm:true,w:1,p:100};
I.u[1463] = {n:"Elementarphiole",t:71,d:"Diese Phiole ist einfach ideal, um darin die alchimistische Essenz der Elemente einzufangen.",ep:1,g:57,l:1,wd:true,fm:true,w:1,p:50};
I.u[1464] = {n:"Blaue Scarablatt-Antennen",t:15,d:"Niemand weiß genau, wozu die Antennen von Scarablättern dienen. Das einzige, was man herausfinden konnte ist, dass sie schlecht riechen.",ep:3,g:216,l:32,wd:true,fm:true,w:1,p:100};
I.u[1465] = {n:"Rote Scarablatt-Antennen",t:15,d:"Niemand weiß genau, wozu die Antennen von Scarablättern dienen. Das einzige, was man herausfinden konnte ist, dass sie schlecht riechen.",ep:3,g:217,l:32,wd:true,fm:true,w:1,p:1};
I.u[1466] = {n:"Grüne Scarablatt-Antennen",t:15,d:"Niemand weiß genau, wozu die Antennen von Scarablättern dienen. Das einzige, was man herausfinden konnte ist, dass sie schlecht riechen.",ep:3,g:218,l:32,wd:true,fm:true,w:1,p:100};
I.u[1467] = {n:"Weiße Scarablatt-Antennen",t:15,d:"Niemand weiß genau, wozu die Antennen von Scarablättern dienen. Das einzige, was man herausfinden konnte ist, dass sie schlecht riechen.",ep:3,g:219,l:32,wd:true,fm:true,w:1,p:100};
I.u[1468] = {n:"Glasbehälter",t:71,d:"Dieser Glasbehälter ist multifunktional. Man kann in mit Tränken füllen oder gar Fische ertränken.",ep:1,g:58,l:1,wd:true,fm:true,w:1,p:100};
I.u[1469] = {n:"Empfehlungsschreiben",t:24,d:"Diese Schriftrolle wurde euch von Salg Zengaer mitgegeben. Er empfiehlt euch wärmstens für ein Studium der hohen Kunst der Alchemie.",ep:1,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1470] = {n:"Empfehlungsschreiben mit Notiz",t:24,d:"Diese Schriftrolle wurde euch von Salg Zengaer mitgegeben. Er empfiehlt euch wärmstens für ein Studium der hohen Kunst der Alchemie. Darunter wurde von Heinz Zilp noch eine kurze Notiz hinzugefügt.",ep:2,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1471] = {n:"Empfehlungsschreiben mit Notiz und Blume",t:24,d:"Diese Schriftrolle wurde euch von Salg Zengaer mitgegeben. Er empfiehlt euch wärmstens für ein Studium der hohen Kunst der Alchemie. Darunter wurde von Heinz Zilp noch eine kurze Notiz hinzugefügt. Die daran befestigte Blume zeigt, dass ihr die erste Lektion bereits gemeistert habt.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1472] = {n:"Antrag für einen Prüfungstermin",t:24,d:"Diese Schriftrolle bestätigt, dass ihr die Ausbildung zum Alchimisten gemeistert habt und daher bereit seid, die Prüfung abzulegen.",ep:3,g:26,l:1,wd:true,fm:true,w:0,p:1};
I.u[1473] = {n:"Grüne Hände",t:20,d:"Mit den grünen Händen wird euch kein Pflänzchen oder Kräutlein kaputtgehen. Damit solltet ihr also kein Unkraut jäten!",ep:1,g:5,l:1,wd:true,fm:true,w:5,e:[5,3,1,1,30,50,false,true],p:100};
I.u[1474] = {n:"Xelor-Amulett",t:1,d:"Dieses überaus mächtige Amulett ist das Ergebnis der langen Arbeit eines sehr alten Xelor-Anhängers zur Meisterung der Zeit.",ep:1,g:28,l:52,wd:true,fm:true,w:10,p:7300};
I.u[1475] = {n:"Das zöne Zwert von Zulie",t:6,d:"Das zöne Zwert von Zulie wurde vom berühmten Waffenschmied Dave-LoL kurz vor seinem Tode geschmiedet, der es Zulie, der zönsten Iopine des Reiches vermachte. Man sagt, die Schönheit dieses Schwertes könne sich nur mit der Schönheit seines Trägers messen... Und wenn sie nicht gestorben sind, dann zönen sie noch heute.",ep:4,g:15,l:60,wd:true,fm:true,w:30,an:14,e:[10,4,1,1,30,50,false,false],c:"CS>100&CV>50",p:3000};
I.u[1476] = {n:"Amulett des Krachlers",t:1,d:"Dieses mächtige Amulett enthält das gesamte Leben eines Krachlers, mitsamt aller Gegenstände, die dieser ins Herz geschlossen hatte, bevor er unter den brutalen Schlägen gieriger Abenteurer nach langem Leiden sein Leben aushauchte.",ep:2,g:25,l:47,wd:true,fm:true,w:5,p:5800};
I.u[1477] = {n:"Glücksbringer von Mulette",t:1,d:"Mulette ist ein kleines Ecaflippchen, das iin ihrem Leben noch niemals eine Glückssträhne hatte, bis sie eines Tages dieses Amulett von ihrer Großmutter bekam.",ep:1,g:26,l:44,wd:true,fm:true,w:5,p:5000};
I.u[1478] = {n:"Harmonie",t:1,d:"Dieser Anhänger ermöglicht es seinem Träger, in Frieden und Harmonie mit der Umgebung zu leben.",ep:1,g:122,l:47,wd:true,fm:true,w:1,p:6000};
I.u[1479] = {n:"Hautscheputt",t:7,d:"Dieser legendäre Hammer ging  in Amakna bereits durch viele Hände. Er gehörte einst Hautscheputt, der nie auch nur eine Sekunde zögerte, seine Gegner damit zu Klump zu schlagen.",ep:13,g:6,l:46,wd:true,fm:true,w:20,an:15,e:[5,4,1,1,50,30,false,false],c:"CI>50&CV>30",p:5600};
I.u[1480] = {n:"Einvernehmen",t:1,d:"Dieser Anhänger ermöglicht es seinem Träger, in Frieden und Harmonie mit der Umgebung zu leben.",ep:1,g:121,l:38,wd:true,fm:true,w:1,p:4000};
I.u[1481] = {n:"Eintracht",t:1,d:"Dieser Anhänger ermöglicht es seinem Träger, in Frieden und Harmonie mit der Umgebung zu leben.",ep:1,g:11,l:26,wd:true,fm:true,w:1,p:2000};
I.u[1482] = {n:"Emblem der Blässe",t:1,d:"Dieses Amulett ist sehr nützlich, doch erscheint sein Träger damit noch weißer als ein Fresssack.",ep:1,g:32,l:41,wd:true,fm:true,w:2,p:4500};
I.u[1483] = {n:"Kabbal",t:1,d:"Ein mysteriöses Symbol eines mysteriösen Geheimbundes. Ihr habt nichts gehört und der Bund existiert auch nicht. Ihr habt diese Beschreibung auch niemals gelesen. Sie zerstört sich selbsttätig in 5...4...3...2...1.",ep:11,g:13,l:29,wd:true,fm:true,w:2,p:2500};
I.u[1484] = {n:"Modifiziertes Amulett Itby",t:1,d:"Eine ausgezeichnete Arbeit des Goldschmied-Lehrlings Polma Kartnez, der man nachsagt, sie sei sogar besser als das Original.",ep:1,g:31,l:17,wd:true,fm:true,w:5,p:1000};
I.u[1485] = {n:"Reignett",t:1,d:"Dieses Amulett ist eine verbesserte Version der Goldenen Zukunft. Seltsamerweise haben beide überhaupt nichts gemein, außer ihres lächerlichen Aussehens.",ep:1,g:27,l:22,wd:true,fm:true,w:5,c:"CC>10",p:1500};
