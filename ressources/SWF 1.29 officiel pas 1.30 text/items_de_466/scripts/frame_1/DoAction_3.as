I.u[1399] = {n:"Elnags Schlägel",t:7,d:"Wie auch das Amulett des gleichen Namens wandelt Elnags Schlägel eure Lebensenergie direkt in magische Energie um. Nur in Maßen zu verwenden!",ep:1,g:12,l:15,wd:true,fm:true,w:15,an:15,e:[5,5,1,1,40,40,false,true],p:1500};
