I.u[1054] = {n:"Kill-Schrills Schaufelkelle",t:8,d:"Ursprünglich diente diese Kreuzung aus Schaufel und Maurerkelle als praktisches Multifunktionswerkzeug beim Bau von neuen Gebäuden. Doch dies änderte sich schnell, als sie Kill-Schrill in die Hände fiel. Dank ihrer geringen Größe und hervorrangenden Handlichkeit ist es eine perfekte und sehr überraschende Mordwaffe. Zumindest für einen ständig zugesoffenen Enutrof mit Nervenzuckungen.",ep:13,g:15,l:53,wd:true,fm:true,w:20,an:16,e:[5,3,1,1,40,40,false,false],c:"CC>47",p:5000};
I.u[1055] = {n:"Kleine Schaufel von Kuhdungluh",t:8,d:"Die Einwohner der Insel Kuhdungluh pflegen schon seit langer Zeit das Handwerk, diese häßlichen Schaufeln aus Schnicks und Schnacks (besonders aus Schnacks) herzustellen. Sie taugen absolut nicht zum Graben, sollen aber angeblich lebensnotwendig auf dieser Insel sein. Vermutlich wieder einmal nur, um Geistern und unartigen Kindern Angst einzujagen.",ep:8,g:19,l:25,wd:true,fm:true,w:30,an:16,e:[5,4,1,1,40,40,false,false],c:"CC>22&CI>3",p:1500};
