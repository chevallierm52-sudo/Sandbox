I.u[1036] = {n:"Kleiner hinterhältiger Dolch",t:5,d:"Dieser Sramdolch besitzt bereits ein schurkenhaftes Aussehen. Sogar dermaßen beschurkt, dass man sich die berechtigte Frage stellen kann, ob es sich dabei überhaupt noch um einen Dolch handelt. Bis man die Antwort gefunden hat, ist es jedoch oft schon zu spät.",ep:7,g:11,l:53,wd:true,fm:true,w:1,e:[14,3,1,1,30,50,false,false],c:"CA>53&CS>18",p:7000};
