I.u[1323] = {n:"Trank des Vergessens: \"Meister des Bogens\"",t:43,d:"Dieser Trank lässt euch einen Grad des Crâ-Zauberspruches \"Meister des Bogens\" vergessen.",ep:2,g:34,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
I.u[1324] = {n:"Katzenkraut",t:36,d:"Bei dieser Pflanze läuft jedem Ecaflip das Wasser im Mund zusammen.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1325] = {n:"Nussschale",t:46,d:"Diese Nussschale ist von Natur aus extrem hart. Sie wird allen äußeren Gewalten zu trotzen wissen. Damit ist sie ein Symbol für die Ideologie der Fecas.",ep:2,g:52,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1326] = {n:"Blutiger Feuerstein",t:51,d:"Dieser scharfkantige Gesteinssplitter wurde anscheinend bereits gegen etwas oder jemanden eingesetzt. Sein gefährliches Aussehen macht ihn zum perfekten Symbol für die Philosphie der Iops.",ep:2,g:47,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1327] = {n:"Geschnitzter Knochen",t:47,d:"Dieser tote Gegenstand ist furchterregend, wenn er richtig bearbeitet wird. Genau wie ein Sram.",ep:2,g:48,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1328] = {n:"Mysteriöser Kama",t:15,d:"Auf dieser Kama-Münze prangt das Bild eines Tofus mit einer seltsamen Kopfbedeckung auf dem Schädel.",ep:1,g:182,l:1,wd:true,fm:true,w:10,p:1};
I.u[1329] = {n:"Elastisches Holz",t:38,d:"Dieser große Ast mit seiner gebogenen Form und dem elastischen Zurückschnellen lässt sofort an Crâs denken. Ob er wohl als Wanderstock taugt?",ep:2,g:49,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1330] = {n:"Das Amulett Itby",t:1,d:"Diese originelle Schöpfung des Goldschmiedes John Les Nonnes gehört heute zu den absoluten Schmuckklassikern.",ep:1,g:31,l:10,wd:true,fm:true,w:5,p:500};
I.u[1331] = {n:"Medaille Oly",t:1,d:"Olivia, von allen nur Oli genannt, war eine Anhängerin von Iop, deren einziges echtes Talent das Kochen war. Man munkelt, Iop höchstpersönlich habe ihr diese Medaille zugesteckt, um ihre Schwäche im Kampf auszugleichen. Denn nur Streiter reinen Herzens können diese Medaille tragen.",ep:7,g:23,l:51,wd:true,fm:true,w:10,c:"Ps=1&Pa>10",p:7000};
I.u[1332] = {n:"Altes 4-blättriges Kleeblatt",t:36,d:"4-blättrige Kleeblätter sind noch viel seltener als 5-blättrige. Wenn ihr eins finden solltet, so ist es ratsam, es zwischen zwei Zauberschriftrollen trocknen zu lassen.",ep:2,g:50,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1333] = {n:"Elementartrank: Fünkchen",t:26,d:"Dieser wärmende Trank wird dank der seiner schwachen Feuermagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:3,g:1,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1334] = {n:"Tabaksbeutel voller Schwefel",t:48,d:"Dieser kleine Beutel voller Schwefel verbreitet einen unerträglichen Gestank... welcher direkt an die Osamodas denken lässt.",ep:2,g:51,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1335] = {n:"Elementartrank: Nieselregen",t:26,d:"Dieser rieselnde Trank wird dank der darin innewohnenden schwachen Wassermagie gern eingesetzt, um alle möglichen Gegenstände ein wenig zu verzaubern.",ep:3,g:2,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1336] = {n:"Brennnesseln",t:36,d:"Kurz nachdem ihr diese Pflanze über eure Haut streicht, werdet ihr wissen, was Leiden bedeutet.",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1337] = {n:"Elementartrank: Windhauch",t:26,d:"Dieser Hauchtrank wird dank seiner schwachen Luftmagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:3,g:3,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1338] = {n:"Elementartrank: Erschütterung",t:26,d:"Dieser vibrierende Trank wird dank seiner schwachen Erdmagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:3,g:4,l:1,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:250};
I.u[1339] = {n:"Glockenblume",t:35,d:"Die Blüten der Glockenblume sind klein, niedlich und sehr zerbrechlich. Man sagt ihnen nach, sie würden beruhigend wirken und könnten gewisse Krankheiten heilen. Sie wurden sicher von einer seltsamen Gottheit erschaffen, die gern eine Pflanze nach dem Bild der Eniripsas schaffen wollte.",ep:2,g:46,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1340] = {n:"Elementartrank: Steinschlag",t:26,d:"Dieser grollende Trank wird dank seiner Erdmagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:9,g:4,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1341] = {n:"Elementartrank: Wolkenbruch",t:26,d:"Dieser plätschernde Trank wird dank seiner Wassermagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:9,g:2,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1342] = {n:"Elementartrank: Windbö",t:26,d:"Dieser pfeifende Trank wird dank seiner Luftmagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:9,g:3,l:25,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1343] = {n:"Elementartrank: Flammenlohe",t:26,d:"Dieser prasselnde Trank wird dank seiner Feuermagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:9,g:1,l:25,wd:true,fm:true,w:1,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:500};
I.u[1344] = {n:"Eisenkraut",t:36,d:"Diese spezielle Pflanze schickt alles und jeden in einen tiefen Schlaf. Das Lieblingskraut der Sadidas eben...",ep:2,g:53,l:1,wd:true,fm:true,w:1,p:5000};
I.u[1345] = {n:"Elementartrank: Flächenbrand",t:26,d:"Dieser tobende Trank wird dank seiner mächtigen Feuermagie gern eingesetzt, um alle möglichen Gegenstände mächtig zu verzaubern.",ep:4,g:1,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1346] = {n:"Elementartrank: Tsunami",t:26,d:"Dieser überflutende Trank wird dank der darin innewohnenden mächtigen Wassermagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:4,g:2,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1347] = {n:"Elementartrank: Hurrikan",t:26,d:"Dieser wirbelnde Trank wird dank seiner mächtigen Luftmagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:4,g:3,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1348] = {n:"Elementartrank: Erdbeben",t:26,d:"Dieser dröhnende Trank wird dank seiner starken Erdmagie gern eingesetzt, um alle möglichen Gegenstände zu verzaubern.",ep:4,g:4,l:50,wd:true,fm:true,w:6,c:"Pj=48|Pj=49|Pj=50|Pj=46|Pj=44|Pj=45|Pj=43|Pj=47",p:800};
I.u[1350] = {n:"Alkobog-Lich",t:2,d:"Diesen Bogen hat ein Erz-Magier erbaut, der sich nie von seinem Flachmann trennen konnte. Um das Problem in den Griff zu bekommen, erfand er diesen mit mächtiger Wassermagie verzauberten Bogen.",ep:3,g:4,l:15,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,3,6,30,50,false,true],p:250};
I.u[1351] = {n:"Bogen des Bösen Klicks",t:2,d:"\"Knapp vorbei ist auch daneben\", so sagt das Sprichwort. Weise Krieger meiden diesen Bogen. Es heißt nämlich, er gäbe einem den Bösen Klick beim Schießen.",ep:1,g:51,l:30,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,6,10,10,false,true],c:"CC>30",p:1600};
I.u[1352] = {n:"Boos Bogen",t:2,d:"Dieser Bogen bezieht seine Stärke aus Erde und Wasser. Unheil all jenen, die auf Feuer und Luft schwören!",ep:2,g:6,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],p:5000};
I.u[1353] = {n:"PolyPfeil-Bogen",t:2,d:"Dieser Bogen, dessen Rollen alle poliert wurden, war vor langer, langer Zeit das Symbol des Kampfes zwischen Gut und Böse. Selbst heute noch glimmt in ihm die Flamme der früheren Rächer des Unheils.",ep:12,g:10,l:41,wd:true,fm:true,w:10,an:10,tw:true,e:[10,5,2,8,30,50,false,true],c:"Ps=1&Pa>10&CI>30&CW>30",p:200};
I.u[1354] = {n:"Hicks Bogen",t:2,d:"Hick war ein verwunschener Crâ. Er konnte machen, was er wollte – er wurde seinen Schluckauf nicht mehr los. Eines Tages tauschte er seinen Feuerbogen gegen ein Schwert. Unbegreiflicherweise verschwand das ihn plagende Übel am gleichen Tag.",ep:13,g:11,l:50,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,6,40,40,false,true],p:1000};
I.u[1355] = {n:"Hidsad-Bogen",t:2,d:"Der Mann, der diesen Bogen erschaffen hat – ein gewisser Mark Hidsad – hat niemals richtig gelernt, damit umzugehen. Die meiste Zeit verletzte er seine Gegner genauso schwer wie sich selbst.",ep:14,g:12,l:40,wd:true,fm:true,w:10,an:10,tw:true,e:[5,5,2,7,30,50,false,true],p:4000};
I.u[1356] = {n:"1/2-Stäbchenbaguette",t:3,d:"Die Bäckerin Rika Zarouil war dafür bekannt, die kleinste Eniripsa im Umkreis zu sein. Ihr Brot wurde in einem Stöfchen gebacken, und in den Kampf zog sie mit ihrem berühmten, halben Stäbchenbaguette.",ep:1,g:13,l:11,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,30,50,false,true],p:1000};
I.u[1357] = {n:"Stolche",t:3,d:"Ein spaßhafter Stabschnitzer versuchte einst, seine geschnitzten Stäbe als Dolche zu verkaufen. Doch die List zeigte keinerlei Erfolg. Trotzdem sind die Stolche eine elegante und wirkungsvolle Waffe.",ep:7,g:17,l:35,wd:true,fm:true,w:10,an:11,e:[5,4,2,2,40,40,false,true],c:"CI>25",p:3500};
I.u[1359] = {n:"Ast \"Geh Auf\'m Weg\"",t:3,d:"Die Geschichte dieses Stabes liegt im Dunkeln. Doch hat dieser zumeist \"AGAW\" genannte Stab seinem Träger mehr als nur einmal geholfen, die am wenigsten verstopften Wege Amaknas zu finden. Das kann sehr nützlich sein, besonders wenn im Reich des königlichen Fresssacks mal wieder hohes Verkehrsaufkommen herrscht.",ep:9,g:12,l:59,wd:true,fm:true,w:10,an:11,e:[7,3,2,3,30,50,false,true],c:"CI>70&CS>30",p:5000};
I.u[1360] = {n:"Hyldegarde",t:3,d:"Dieser Stab wurde vor vielen Jahren in den Flammen der Schmiede von Mo\'Der geschmiedet. Daher ist es auch stark angeraten, immer einen Eimer Wasser in der Nähe zu haben, um notfalls sein inneres Feuer wieder löschen zu können.",ep:13,g:8,l:48,wd:true,fm:true,w:10,an:11,e:[5,4,2,4,50,50,false,true],p:4800};
I.u[1361] = {n:"Stab der Sylvan",t:3,d:"Der Stab der Sylvan besitzt die sonderbare Macht, seinem Träger eine hervorragende Sehschärfe zu bescheren. Jetzt fehlt nur noch genügend Flinkheit, um sich rechtzeitig aus dem Staub zu machen.",ep:1,g:15,l:43,wd:true,fm:true,w:10,an:11,e:[4,5,2,2,40,40,false,true],c:"CA>80",p:4000};
I.u[1362] = {n:"Vampirpflock",t:3,d:"Der Vampirpflock ist der Stab eines alten Vampirs, der sich vor langer Zeit aus dem Gesellschaftsleben und Metzgerdasein zurückgezogen hat. Dieses seltsame Stück Holz hat jedoch einen Teil der Fähigkeiten des alten Vampirs konserviert.",ep:7,g:14,l:65,wd:true,fm:true,w:10,an:11,e:[5,6,2,3,50,20,false,true],c:"CA>30&CW<60",p:4000};
I.u[1363] = {n:"Opiskrkrücks Stock",t:4,d:"Neben seinem unerträglichen Namen besitzt dieser Stock noch viele andere Eigenschaften, um seinen Träger vor Wut schier zum Platzen zu bringen.",ep:1,g:5,l:40,wd:true,fm:true,w:10,an:12,e:[5,5,1,1,5,5,false,true],c:"CI<100",p:5000};
I.u[1364] = {n:"VergissmeinStocknicht",t:4,d:"Dieser Stock lässt einen Sorgen und Kummer vergessen. Leider geht dabei mit der Zeit auch ein Großteil des Gedächtnisses verloren, während gleichzeitig die Konzentrationsfähigkeit nachlässt. Daher ist er ausschließlich den Weisen vorbehalten...",ep:13,g:11,l:30,wd:true,fm:true,w:15,an:12,e:[5,3,1,1,50,50,false,true],c:"CW>50",p:3000};
I.u[1365] = {n:"Woods Stock",t:4,d:"Wood war ungeschlagen im Umgang mit seinem Stock. Wenn er mal loslegte, dann war die Atmosphäre um ihn herum wie elektrisch aufgeladen, das rhythmischen Trommeln seiner Schläge dröhnte durch die Luft, und Gegner in seiner Umgebung wurden wie von Geisterhand umhergewirbelt.",ep:1,g:68,l:20,wd:true,fm:true,w:15,an:12,e:[8,5,1,1,50,40,false,true],p:2000};
I.u[1366] = {n:"Hirtenstock für Fresssäcke",t:4,d:"Ein solcher Hirtenstock wird üblicherweise von den Bwork-Fresssackhirten für den Almabtrieb verwendet. Bworks lieben es nämlich, Fresssäcke in feine Scheibchen geschnitten als Vorspeise zu genießen (in nicht wenigen Fällen wird dann der Hirte selbst als Hauptgericht serviert).",ep:9,g:9,l:12,wd:true,fm:true,w:10,an:12,e:[5,4,1,1,50,50,false,true],p:1200};
I.u[1367] = {n:"Dinas Mythosstock",t:4,d:"Dieser Stock gehörte einst der hübschen Dina. Mit ihren üppigen Kurven und ihrem hoch-explosiven Charakter schuf sie einen echten Mythos um sich und den sie überallhin begleitenden Stock herum. Sie war aber auch eine echte Granate, heißt es.",ep:13,g:6,l:40,wd:true,fm:true,w:15,an:12,e:[5,5,1,1,30,50,false,true],c:"CI>50&CA>40",p:4000};
I.u[1368] = {n:"112xSpritzstock",t:4,d:"Die sagenumwobenen \"112er\" waren nichts anderes als eine mutige Brandbekämpfungstruppe in Amakna, die unter anderem sogar gefährliche Drachennestlingsfeuer löschen konnten. Anscheinend hat dieser Stock einmal einem von ihnen gehört. Zu seinem Einsatz braucht man viel Mut und Stärke.",ep:1,g:18,l:29,wd:true,fm:true,w:15,an:12,e:[5,4,1,1,40,50,false,true],c:"CC>10",p:2500};
I.u[1369] = {n:"Uneros Tischmesser",t:5,d:"Diese Messer sollten anfangs in einem bekannten Luxusrestaurant eingesetzt werden. Doch bei ihrem eher... seltsamen... Aussehen, hat es der Restaurantbesitzer letzten Endes doch vorgezogen, sie an einen fahrenden Messerwerfer zu verkaufen.",ep:1,g:13,l:33,wd:true,fm:true,w:10,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>55&CC>5",p:3000};
I.u[1370] = {n:"Ergot Mina",t:5,d:"Das Heft dieser Waffe fühlt sich stets fettig und glitschig an, doch vom Aussehen her ist sie einfach unübertroffen.",ep:1,g:14,l:20,wd:true,fm:true,w:10,an:13,e:[8,3,1,1,50,50,false,true],p:2000};
I.u[1371] = {n:"Öhls Messer",t:5,d:"Öhl war ein alter Fresssackhirte im Norden Amaknas, der eines Tages inmitten eines noch dampfenden Fresssack-Dunghaufens ein Paar stark verschmutzter Dolche fand. Eine Warnung an jeden der sie nun trägt: ihr Griff ist sehr rutschig, darum kann es leicht vorkommen, dass sie einem aus der Hand gleiten.",ep:1,g:10,l:40,wd:true,fm:true,w:20,an:13,e:[10,3,1,1,30,50,false,true],c:"CA>40",p:4000};
I.u[1372] = {n:"Dolche von Abdul Abhau",t:5,d:"Niemand kennt das Ende von Abdul Abhau O\'da Abu Putt, einem alten Einsiedler-Sram, der schon immer ein wenig an Verfolgungswahn litt. Er erwartete stets, durch ein Mitglied seiner eigenen Familie erdolcht zu werden, daher vermied er jeden Kontakt mit der Außenwelt. Nach seinem Tod fand man seine Lieblingsdolche neben seiner Leiche liegen und nur die Flinksten konnten sich noch einen von ihnen schnappen.",ep:9,g:19,l:44,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>60",p:5300};
I.u[1373] = {n:"Höllisches Rasiermesser",t:5,d:"Krys Rasni war ein alter Enutrof-Anhänger mit dichtem Bart, wie jeder wahre Enutrof, der etwas auf sich hält. Drum zog er es vor, die Rasierklingen, die ihm seine Frau Bartbara Rasni zu schenken pflegte, ausschließlich im Kampf zu gebrauchen.",ep:1,g:17,l:30,wd:true,fm:true,w:15,an:13,e:[10,3,1,1,30,50,false,false],c:"CA>30",p:3000};
I.u[1374] = {n:"Tints Killerdolch",t:5,d:"Vor langer, langer Zeit verwendete ein bekannter Schreiber Amaknas einen Dolch namens \"Tint\". Normalerweise benutzte er ihn, um Steinplatten zu gravieren. Darum war sein Dolch besonders widerstandsfähig gebaut, und bei einem Angriff erledigte er problemslos drei gefährliche Räuber. Gerührt ritzte er für die Nachwelt \"Mit Tint killte er\" in den Dolch hinein und setzte seinen Namen dahinter.",ep:1,g:12,l:30,wd:true,fm:true,w:13,an:13,e:[10,3,1,1,30,50,false,false],c:"CS>50",p:3000};
I.u[1375] = {n:"Bodi Beilders Axt",t:19,d:"Bodi Beilder war ein junger Iop, der dafür berühmt war, gewaltige Gewichte hochstemmen zu können. Unglücklicherweise für ihn gehörte Intelligenz nicht zu seinen Stärken, wie es bei den meisten muskulösen Iops der Fall ist.",ep:1,g:14,l:15,wd:true,fm:true,w:25,an:17,e:[10,5,1,1,50,50,false,true],c:"CS>70&CI<10",p:800};
I.u[1376] = {n:"Axt Oni",t:19,d:"Diese recht schwere Axt ist ideal, um Trolle zu bekämpfen. Denn die magischen Runen auf ihren Blättern verbrennen diese Gegner gleich an Ort und Stelle.",ep:7,g:15,l:35,wd:true,fm:true,w:23,an:17,e:[10,5,1,1,40,50,false,true],c:"CS>50",p:3000};
I.u[1377] = {n:"Schraxtfur",t:19,d:"Schraxtfur war der Name, den ein junger Priester seiner mächtigen Axt gegeben hatte. Er zögerte nicht, mit seiner mächtigen Axt alle Andersgläubigen niederzustrecken, woraufhin er jedes Mal einen Strich auf das Blatt malte. Wozu dies genau dienen soll, hat jedoch noch keiner herausgefunden...",ep:1,g:16,l:22,wd:true,fm:true,w:22,an:17,e:[10,5,1,1,50,50,false,true],c:"CW>30",p:2200};
I.u[1378] = {n:"Ramms Steinaxt",t:19,d:"Ramms schwere Steinaxt besteht trotz ihres verwirrenden Namen aus reinem Metall. Sie hat die Eigenschaft, beim Aufschlag auf das Ziel oder auf andere Waffen einen unangenehm lauten, schrillen Ton von sich zu geben.",ep:1,g:17,l:28,wd:true,fm:true,w:22,an:17,e:[8,5,1,1,40,40,false,true],c:"CA>30",p:2300};
I.u[1379] = {n:"Skrunchhhhhhh",t:7,d:"Wenn man den Mythen Glauben schenken darf, soll der Name dieses Hammers dem Geräusch nachempfunden sein, das er beim Einschlagen gegnerischer Schädel verursacht. Leider ist gerade kein Gegner da, um diese Theorie zu verifizieren.",ep:7,g:9,l:35,wd:true,fm:true,w:35,an:15,e:[8,5,1,1,30,40,false,true],c:"CS>50&CA>20",p:35000};
I.u[1380] = {n:"Trank des Vergessens: \"Wort der Heilung\"",t:43,d:"Dieser Trank lässt euch einen Grad des Eniripsa-Zauberspruches \"Wort der Heilung\" vergessen.",ep:2,g:36,l:1,wd:true,fm:true,w:1,c:"Pz=0",u:true,p:1000};
