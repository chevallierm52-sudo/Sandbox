I.u[1147] = {n:"Wahrer Magischeinstecken",t:4,d:"Dieser Stock ist ein genaues Duplikat eines legendären Artefaktes, nur etwas weniger mächtig. Doch da er hervorragend dazu geeignet ist, bei einem kurzen Schlag auf dem Boden waberndes Licht zu produzieren (Oh!), und immer bereit ist, ein wenig eure Stimme zu verändern (Wah!), wird er anderen etwas vorgaukeln, das gar nicht stimmt: nämlich dass ihr ein großer Magier seid.",ep:1,g:16,l:35,wd:true,fm:true,w:15,an:12,e:[7,4,1,1,50,50,false,true],c:"CI>45",p:7000};
I.u[1148] = {n:"Kleiner Aknefer Stecken",t:4,d:"Eine Vielzahl jugendlicher Fécas besitzt irgendwo einen solchen Stecken. Das kann man schon beinahe nicht mehr eine neue Modeerscheinung nennen, das ist bereits wie eine Art zwanghaftes Ritual geworden. Jemand sollte ihnen wirklich mal sagen, dass sie damit einfach nur lächerlich aussehen.",ep:5,g:19,l:24,wd:true,fm:true,w:30,an:12,e:[5,4,1,1,30,50,false,true],c:"CS>25&CA>5",p:5000};
