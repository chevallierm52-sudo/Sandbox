I.u[1131] = {n:"Imposanter Kirchenstab",t:3,d:"Dieser schwere Stab hat bereits mehr als nur einen Sünderschädel zertrümmert. Es waren nämlich Iop-Priester, die sich seiner bedienten, um auf radikale und endgültige Weise Reuigen die Absolution zu erteilen.",ep:2,g:16,l:52,wd:true,fm:true,w:30,an:11,e:[10,3,2,3,30,50,false,true],c:"CI>51&CS>25",p:7000};
I.u[1132] = {n:"Ni\'Ninnin Stab",t:3,d:"Dieses wahre Kunstwerk symbolisiert die Verbindung von Reinheit... und Dummheit. Übrigens scheint der Schöpfer dieses Stabes beides in hohem Maße besessen zu haben, denn er verlieh diesem Gegenstand enorme magische Kräfte.",ep:3,g:18,l:50,wd:true,fm:true,w:5,an:11,e:[10,4,2,4,50,30,false,true],c:"CI>99&CW>20",p:7000};
I.u[1133] = {n:"Kleine Einwegrute",t:3,d:"Die Emanzipation der Eniripsa-Hausfrauen unter 50 begann dank dieses Stabes. Gleichzeitig wirksam gegen Staub und gegen Monster. Praktisch, nicht wahr?",ep:1,g:20,l:30,wd:true,fm:true,w:10,an:11,e:[7,4,2,2,50,50,false,true],c:"CI>50",p:5000};
