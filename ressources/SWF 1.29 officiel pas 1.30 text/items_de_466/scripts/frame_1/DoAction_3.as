I.u[1046] = {n:"Kleine Mischmaschaufel",t:8,d:"Die Mischmaschschaufel ist DIE Lösung für all eure kleinen Gärtnereiproblemchen. Mit ihr könnt ihr sämtliche Radieschen aus dem Garten ausbuddeln und stolz euren Gegnern zeigen, mit der Wurzel voraus!",ep:1,g:18,l:38,wd:true,fm:true,w:40,an:16,e:[7,4,1,1,30,50,false,false],c:"CS>10&CC>28",p:4000};
