I.u[1113] = {n:"\"I Kea nit gern\"-Bogen, Sonderangebot",t:2,d:"Dieses Sondermodell eines Bogens, welches es nur im hohen Norden Amaknas zu kaufen gibt, ist spottbillig. Allerdings muss man es auch selbst zusammenbauen, so dass das Endergebnis stark von der Kompetenz des Bastlers abhängt.",ep:2,g:21,l:35,wd:true,fm:true,w:15,an:10,tw:true,e:[12,4,2,7,50,50,false,true],c:"CA>40&CS>2&CI>2",p:3400};
