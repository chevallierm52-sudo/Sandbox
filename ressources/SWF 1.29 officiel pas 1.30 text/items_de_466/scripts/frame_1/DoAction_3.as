I.u[1455] = {n:"Flügel eines blauen Scarablattes",t:104,d:"Diese Scarablatt-Flügel haben magische Eigenschaften. Man kann aus ihnen Tränke elementaren Wassers herstellen.",ep:3,g:212,l:32,wd:true,fm:true,w:2,p:100};
I.u[1456] = {n:"Flügel eines weißen Scarablattes",t:104,d:"Diese Scarablatt-Flügel haben magische Eigenschaften. Man kann aus ihnen Tränke elementaren Wassers herstellen.",ep:3,g:213,l:32,wd:true,fm:true,w:2,p:100};
