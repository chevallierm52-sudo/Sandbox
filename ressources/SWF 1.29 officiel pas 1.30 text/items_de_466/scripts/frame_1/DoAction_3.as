I.u[1137] = {n:"Unauffälliger Houvrett-Stab",t:3,d:"Houvrette entwickelte diesen \"Stab\", um damit ihren Ehemann, einen Enutrof, von seiner Lieblingskneipe wieder nach Hause zu bringen. Daher zeigt der Stab auch schon starke Gebrauchsspuren. Man munkelt, er habe zudem wieder viel Schwung in ihre Beziehung gebracht, doch niemand weiß genaueres dazu.",ep:7,g:19,l:40,wd:true,fm:true,w:12,an:11,e:[5,3,2,2,50,50,false,true],c:"CW>10&CI>45",p:4000};
