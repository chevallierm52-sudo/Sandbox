System.security.allowDomain(_parent._url);
VERSION = 83;
SIM = new Object();
SIM[24] = {m:"Un giorno sono caduto nella tazza del cesso del re Allister. Che bello!",s:-1,l:1,p:1};
SIM[25] = {m:"Ho fame, dammi da mangiare o divoro gli oggetti del tuo inventario.",s:3,l:1,p:1};
SIM[26] = {m:"Dammi subito da mangiare, sennò mi strafogo con i tuoi kama.",s:3,l:1,p:1};
SIM[27] = {m:"Dai, fagli ingoiare la polvere, sembra talmente scarso.",s:-1,l:1,p:1};
SIM[28] = {m:"Ma chi è questo buffone chi ci aggredisce?",s:-1,l:1,p:1};
SIM[29] = {m:"Penso che questo odioso personaggio abbia avuto quello che si meritava.",s:-1,l:1,p:1};
SIM[30] = {m:"Non posso credere che tu sia tanto scarso da farti battere da un nano del genere.",s:-1,l:1,p:1};
SIM[31] = {m:"Finalmente un colpo critico, cominciavo a perdere la pazienza...",s:-1,l:1,p:1};
SIM[32] = {m:"Ma perché fai sempre più fiaschi critici che colpi critici?",s:-1,l:1,p:1};
SIM[33] = {m:"Per una volta che non hai fatto un fiasco critico...",s:-1,l:1,p:1};
SIM[34] = {m:"E\' di nuovo grazie a me se hai vinto l\'ennesimo combattimento .",s:-1,l:1,p:1};
SIM[35] = {m:"La prossima volta cerca di non fare altre fesserie, sono un po\' stanco di essere in coppia con un perdente come te.",s:-1,l:1,p:1};
SIM[36] = {m:"Guarda un po\' questo principiante che arriva... dovresti aggredirlo, sarebbe una vittoria facile.",s:-1,l:1,p:1};
SIM[37] = {m:"Guarda chi è appena arrivato... Credo che sia veramente arrivato il momento di andarsene.",s:-1,l:1,p:1};
SIM[38] = {m:"Se solo tu potessi lanciare dei colpi critici spesso come lui!",s:-1,l:1,p:1};
SIM[39] = {m:"Ma è uno sfigato! Spiegami come fai per scegliere così i tuoi amici?",s:-1,l:1,p:1};
SIM[40] = {m:"Torni a quest\'ora? Allora non conto niente per te?",s:3,l:1,p:0.1};
SIM[41] = {m:"Credo che tu abbia appena ucciso uno dei nostri alleati. Sei ancora in tempo per andarti a far curare...",s:-1,l:1,p:1};
SIM[42] = {m:"Un giorno t\'insegnerò a scegliere bene gli amici.",s:-1,l:1,p:1};
SIM[43] = {m:"Dai, non fare il tirchio, dammi quello che hai appena recuperato, non tenere sempre tutto per te!",s:-1,l:1,p:1};
SIM[44] = {m:"Non mi sembra di essere mai stato in coppia con un avventuriero così stupido.",s:-1,l:1,p:1};
SIM[45] = {m:"Dai, dammelo...",s:-1,l:1,p:1};
SIM[46] = {m:"Ancora un fiasco... Haha.",s:1,l:1,p:1};
SIM[47] = {m:"Ho già ascoltato una canzone di Claudius Baglionus. Sono rimasto sordo per 12 anni.",s:-1,l:1,p:0.2};
SIM[48] = {m:"Conosci la storia del Kirbul che dava zuccate?",s:2,l:1,p:0.1};
SIM[49] = {m:"Un giorno sposerò un Dora Bora.",s:-1,l:1,p:0.1};
SIM[50] = {m:"È a questo punto che il cattivo arriva e dice: \"Ehi tu, buffone, non sono io il cattivo, sei tu\". Io ero piegato in due dal ridere.",s:2,l:1,p:0.1};
SIM[51] = {m:"Si dice che Allister avesse una chiappa più grande dell\'altra. Non penso sia vero, ogni volta che si sedeva su di me, destra o sinistra, io soffrivo allo stesso modo.",s:-1,l:1,p:0.5};
SIM[52] = {m:"Lichen è veramente un tipo come si deve.",s:-1,l:1,p:0.01};
SIM[53] = {m:"Ho avuto un\'infanzia difficile, stavo con un principiante di Astrub che vendeva all\'asta allo Zaap. Sono diventato sordo.",s:-1,l:1,p:0.1};
SIM[54] = {m:"Mi ricordi un mostro ma non so più quale. Potrebbe essere mia suocera...",s:-1,l:1,p:0.1};
SIM[55] = {m:"Il problema di Astrub, è che non brucia mai.",s:-1,l:1,p:0.1};
SIM[57] = {m:"Ho già visto un Feca fare altro che non fosse lanciare le sue armature e lanciarsi a testa bassa in un combattimento. Ma era in un sogno.",s:-1,l:1,p:0.1};
SIM[58] = {m:"Ho già incontrato uno Yop che sapesse contare. Ma quel giorno ero ubriaco.",s:-1,l:1,p:0.1};
SIM[59] = {m:"Ho fame!",s:-1,l:1,p:1};
SIM[62] = {m:"Ho mangiato abbastanza da resistere parecchi mesi.",s:-1,l:1,p:1};
SIM[63] = {m:"Ho mangiato talmente tanto che rischio di vomitare nel tuo inventario.",s:-1,l:1,p:1};
SIM[64] = {m:"Ti avrei aiutato volentieri, ma ho mangiato troppo. La prossima volta forse.",s:-1,l:1,p:1};
SIM[65] = {m:"Ancora da mangiare... Abbi pietà di me!",s:-1,l:1,p:1};
SIM[66] = {m:"Se tu non mi avessi fatto mangiare così tanto, avrei potuto salvarti la vita.",s:-1,l:1,p:1};
SIM[67] = {m:"Ok va bene, hai appena vinto, sei contento, ma non è una ragione sufficiente per continuare a rimpinzarmi di oggetti!",s:-1,l:1,p:1};
SIM[68] = {m:"I devs vinceranno!",s:-1,l:10,p:0.01};
SIM[70] = {m:"Si dice che le invocazioni rubino le risorse vinte alla fine del combattimento. Falso, sono io che le rubo!",s:-1,l:3,p:1};
SIM[71] = {m:"Alcuni avventurieri dicono che parlare vicino alle zone di pesca faccia scappare i pesci...",s:-1,l:5,p:1};
SIM[72] = {m:"Credo ancora al Minotobul di Nawal e tu?",s:-1,l:1,p:1};
SIM[73] = {m:"Ah, forse quello riuscirà a sbarazzarmi di te.",s:-1,l:1,p:1};
SIM[74] = {m:"Se continui a farti uccidere da tutto ciò che si muove, me ne vado!",s:3,l:1,p:1};
SIM[75] = {m:"Un traditore! Ecco cosa ci voleva per un po\' d\'azione!",s:-1,l:1,p:1};
SIM[76] = {m:"Potresti ottenere un colpo critico con il \"Nutrimento degli oggetti\", per favore?",s:-1,l:1,p:1};
SIM[77] = {m:"Meglio così, tanto non serviva a niente.",s:1,l:5,p:1};
SIM[78] = {m:"Se qualcuno mi cerca, sono nel tuo zaino a riposare.",s:-1,l:10,p:1};
SIM[79] = {m:"Spero che faccia proprio male.",s:1,l:5,p:1};
SIM[80] = {m:"Oh oh, aspetta, aspetta, faccio una foto!",s:2,l:10,p:0.5};
SIM[81] = {m:"Forse dovrei andare con il tuo nemico...",s:-1,l:5,p:1};
SIM[82] = {m:"Credo che sia l\'ora di andare a mangiare.",s:-1,l:1,p:1};
SIM[83] = {m:"Dai, sono sicuro che puoi fare di meglio!",s:-1,l:15,p:1};
SIM[84] = {m:"Ho fatto un giro allo zaap di Astrub tempo fa. Doveva esserci una gara a chi urlava più forte.",s:-1,l:15,p:0.5};
SIM[85] = {m:"Un giorno ho incontrato un animale che si chiama bradipo. Mi ha fatto pensare subito a un Sadida.",s:-1,l:8,p:1};
SIM[86] = {m:"L\'altwa volta un Wabbit mi ha mowsicato. Cwedo mi abbia attaccato una gwave malattia.",s:-1,l:12,p:0.5};
SIM[87] = {m:"Prima dell\'invenzione degli Zaapi, gli abitanti di Bonta e di Brakmar passavano tanto tempo a cercare la strada quanto un Sadida ne passava a dormire.",s:-1,l:16,p:1};
SIM[88] = {m:"Già qui? Mi hai portato da mangiare?",s:-1,l:7,p:1};
SIM[89] = {m:"Dovresti scegliere meglio i tuoi amici. Ma d\'altronde, io avrei dovuto scegliere meglio il mio proprietario.",s:-1,l:14,p:1};
SIM[90] = {m:"Quand\'è che mangiamo?",s:-1,l:1,p:1};
SIM[91] = {m:"L\'ultimo che non mi dava da mangiare è morto in circostanze sospette e misteriose.",s:-1,l:17,p:1};
SIM[92] = {m:"Attaccalo, attaccalo, non vale niente quello!",s:-1,l:3,p:1};
SIM[93] = {m:"Ok, cerco qualcuno di competente per farti fare un oggetto.",s:-1,l:9,p:1};
SIM[94] = {m:"Il prossimo?",s:-1,l:6,p:1};
SIM[95] = {m:"Ho già incontrato un drago. Non ci ho pensato due volte a mordergli la coda.",s:-1,l:18,p:1};
SIM[96] = {m:"Ah, forse riuscirò a mangiare qualcosa...",s:-1,l:12,p:1};
SIM[97] = {m:"Che peeeccatooo... c\'eri quaaasiii... Ma come, pensi che stia recitando?",s:-1,l:9,p:1};
SIM[98] = {m:"Il bagno. Dov\'è il bagno?",s:-1,l:7,p:1};
SIM[99] = {m:"Per molto tempo mi sono chiesto se fossero più stupidi i Goblin o i Bwork. Ma dopo anni d\'intensa riflessione, penso che siano tutt\'e due fuori concorso.",s:-1,l:11,p:1};
SIM[100] = {m:"Perché tutti si accaniscono contro questi sfortunati Blop?",s:-1,l:9,p:1};
SIM[101] = {m:"Ma cosa c\'é nascosto nella torre di Gisgul?",s:-1,l:4,p:0.25};
SIM[102] = {m:"Com\'è carino... fa venire fame.",s:-1,l:4,p:1};
SIM[103] = {m:"Non contare sul mio aiuto, almeno fin quando continuerai a lasciarmi morire di fame.",s:-1,l:1,p:1};
SIM[104] = {m:"Dammi da mangiare i suoi oggetti!",s:-1,l:1,p:1};
SIM[105] = {m:"Mi sorprendi ogni giorno di più.",s:-1,l:8,p:1};
SIM[106] = {m:"Spero che tu non mi voglia dare da mangiare i suoi oggetti...",s:-1,l:1,p:1};
SIM[107] = {m:"Non c\'è niente per me nel mucchio?",s:-1,l:1,p:1};
SIM[108] = {m:"Certo, certo... ma non basta fare qualche buona mossa ogni tanto per essere un buon proprietario.",s:-1,l:1,p:1};
SIM[109] = {m:"Non c\'è bisogno che tu vada così di corsa, se hai altre cose da fare, falle e ripassa più tardi.",s:-1,l:5,p:1};
SIM[110] = {m:"Ah, un miserabile nemico! Concialo per le feste e dammi da mangiare i suoi oggetti!",s:-1,l:1,p:1};
SIM[111] = {m:"Apparentemente il tuo nemico è bravo come te.",s:2,l:5,p:1};
SIM[112] = {m:"Non hai bisogno di me per questo qua, e comunque mi fa male il cuore.",s:-1,l:1,p:1};
SIM[113] = {m:"Bof, è un colpo di fortuna.",s:-1,l:5,p:1};
SIM[114] = {m:"Un corno! Non ti ho mica chiesto di darmi ancora da mangiare.",s:-1,l:1,p:1};
SIM[115] = {m:"Peccato che non ci sia un punteggio sotto zero, ti calzerebbe a pennello.",s:1,l:1,p:1};
SIM[116] = {m:"Hai visto che ore sono? Potresti avvisare quando stai via così tanto.",s:-1,l:6,p:0.5};
SIM[117] = {m:"Addosso al nemico e nessuna pietà!",s:-1,l:5,p:1};
SIM[118] = {m:"Hai ragione, bisogna difendere il tuo territorio.",s:-1,l:7,p:0.5};
SIM[119] = {m:"La miglior difesa è l\'attacco.",s:-1,l:8,p:0.5};
SIM[120] = {m:"In combattimento tutto è lecito, tranne il disonore.",s:-1,l:11,p:0.5};
SIM[121] = {m:"La lotta è come il salame. Da consumare senza moderazione.",s:-1,l:1,p:1};
SIM[122] = {m:"Non ho neanche un po\' di paura.",s:1,l:15,p:0.3};
SIM[123] = {m:"Aiuto! Aiuto! Vogliono rubarmi al mio proprietario!",s:-1,l:6,p:0.7};
SIM[124] = {m:"Credo che questa persona ti odi.",s:-1,l:3,p:0.6};
SIM[125] = {m:"Senza offesa, ma il tuo alleato è più bravo di te.",s:-1,l:4,p:0.5};
SIM[126] = {m:"Un Pìu non avrebbe fatto meglio.",s:-1,l:2,p:1};
SIM[127] = {m:"Guarda come ha fatto il tuo alleato e prendi esempio.",s:-1,l:9,p:0.5};
SIM[128] = {m:"Ah no, non bluffava mica.",s:-1,l:6,p:0.5};
SIM[129] = {m:"Ahi, deve far male!",s:-1,l:5,p:1};
SIM[130] = {m:"È bravino, mica come certi altri...",s:-1,l:10,p:0.2};
SIM[131] = {m:"Wow, devo ammettere che con questa mossa mi hai veramento stupito.",s:-1,l:12,p:1};
SIM[132] = {m:"Non ti avrei mai creduto capace di una tale impresa.",s:-1,l:13,p:0.7};
SIM[133] = {m:"Bel colpo, bravo.",s:-1,l:2,p:1};
SIM[134] = {m:"Datemi una B, una R, una A, una V, una O. BRAVO!",s:-1,l:16,p:0.2};
SIM[135] = {m:"Se solo succedesse più spesso...",s:-1,l:8,p:0.1};
SIM[136] = {m:"Ma non è possibile! Chi è quest\'idiota?",s:3,l:5,p:0.8};
SIM[137] = {m:"Dobbiamo veramente sopportare questo sfigato?",s:3,l:10,p:0.8};
SIM[138] = {m:"Un Pìu sarebbe più efficace.",s:-1,l:2,p:1};
SIM[139] = {m:"Uuuuu! Che idiota!",s:2,l:3,p:1};
SIM[140] = {m:"Chi è questo pagliaccio? L\'hai assunto tu?",s:-1,l:11,p:0.5};
SIM[141] = {m:"La prossima volta scegli un alleato più competente.",s:-1,l:7,p:1};
SIM[142] = {m:"Un colpo critico, non è scontato...",s:-1,l:6,p:0.5};
SIM[143] = {m:"Credi che sappia giocare?",s:-1,l:12,p:1};
SIM[144] = {m:"Io dico che sta bluffando.",s:-1,l:6,p:0.5};
SIM[145] = {m:"Dopo questo, non venire a vantarti di averlo vinto.",s:-1,l:8,p:0.8};
SIM[146] = {m:"Scusa, ma cosa cercava di fare?",s:2,l:10,p:0.6};
SIM[147] = {m:"Vai, così! Sì, No! Attento! Bé ecco, se mi avessi ascoltato non sarebbe successo.",s:-1,l:4,p:1};
SIM[148] = {m:"Questo non va bene.",s:-1,l:3,p:0.7};
SIM[149] = {m:"Allora è questo che chiamano fiasco critico...",s:-1,l:14,p:0.2};
SIM[150] = {m:"Essere scarsi non è una fatalità. Tranquillo, puoi migliorare.",s:-1,l:13,p:0.1};
SIM[151] = {m:"Dovrò insegnarti ad usare tutt\'e dieci le dita.",s:-1,l:8,p:0.5};
SIM[152] = {m:"Assassino! Come hai potuto uccidere a sangue freddo un altro oggetto davanti ai miei occhi?",s:3,l:11,p:0.2};
SIM[153] = {m:"Per fortuna non sei stato tu a fabbricarmi.",s:-1,l:5,p:1};
SIM[154] = {m:"Smettila, ti fai male per niente.",s:-1,l:7,p:0.8};
SIM[155] = {m:"Come pretendi di diventare ricco se rompi il materiale?",s:-1,l:9,p:1};
SIM[156] = {m:"Pazienza, avrai più fortuna la prossima volta.",s:-1,l:13,p:0.5};
SIM[157] = {m:"L\'artigianato non è proprio per te.",s:1,l:15,p:0.5};
SIM[158] = {m:"Non vorrei rovinarti la giornata, ma i PNG sono meglio di te.",s:-1,l:17,p:0.2};
SIM[159] = {m:"È il principio della ricchezza, continua così.",s:-1,l:9,p:1};
SIM[160] = {m:"Wow! Puoi farne uno per me? Dai, per favore?",s:-1,l:8,p:0.5};
SIM[161] = {m:"Ecco un oggetto che non dovrai comprare al mercatino.",s:-1,l:10,p:0.5};
SIM[162] = {m:"Un\'altra?",s:-1,l:6,p:1};
SIM[163] = {m:"La prossima volta prova con: \"Sono venuto in pace.\"",s:-1,l:5,p:0.5};
SIM[164] = {m:"Credo che sia l\'ora di andara a dormire.",s:-1,l:2,p:1};
SIM[165] = {m:"Non dimenticare di recuperare energia, non ho assolutamente voglia di essere trasformato in un fantasma.",s:-1,l:8,p:1};
SIM[166] = {m:"In quale momento il combattimento é diventato a nostro sfavore?",s:-1,l:7,p:0.5};
SIM[167] = {m:"Abbiamo perso! L\'abbiamo presa nel... ahem, insomma abbiamo perso.",s:-1,l:15,p:0.2};
SIM[168] = {m:"Se tu mi avessi nutrito meglio, non sarebbe mai accaduto.",s:-1,l:10,p:0.8};
SIM[169] = {m:"Arruolati, dicevano...",s:-1,l:12,p:0.8};
SIM[170] = {m:"Ecco cosa capita quando si fanno gli idioti.",s:1,l:11,p:0.5};
SIM[171] = {m:"Sei scarso, è così. Non ci puoi fare niente.",s:-1,l:16,p:0.1};
SIM[172] = {m:"Abbiamo vinto! Che passeggiata!",s:2,l:15,p:0.2};
SIM[173] = {m:"Niente da dire, siamo stati bravissimi.",s:-1,l:10,p:0.5};
SIM[174] = {m:"Ancora qualche combattimento come questo e entrerai nella leggenda.",s:-1,l:20,p:0.1};
SIM[175] = {m:"La prossima volta lasciagli una possibilità, giusto per divertirci un po\'.",s:-1,l:5,p:0.5};
SIM[176] = {m:"Non mi stupirebbe se ti avessero incrociato con un forziere animato.",s:-1,l:11,p:0.2};
SIM[178] = {m:"Per questo colpo ti ha aiutato Anutrof in persona.",s:-1,l:4,p:1};
SIM[179] = {m:"Fai comunella con il dio Anutrof?",s:-1,l:14,p:0.1};
SIM[180] = {m:"Con tutto quello che hai appena guadagnato, non avrai più nessuna scusa per non nutrirmi.",s:-1,l:7,p:1};
SIM[181] = {m:"Te lo giuro, non c\'entro niente. È stato il mio proprietario.",s:-1,l:10,p:0.6};
SIM[182] = {m:"Hai mirato male, questo è nostro alleato. Anzi, era...",s:-1,l:6,p:1};
SIM[183] = {m:"Spiacente, il mio proprietario ha del guano di Tofu negli occhi.",s:-1,l:12,p:0.5};
SIM[184] = {m:"La prossima volta che si appiccica così, mandalo via!",s:-1,l:3,p:1};
SIM[185] = {m:"Ancora una mossa del genere e ti denuncio alle autorità.",s:3,l:16,p:0.2};
SIM[186] = {m:"La domanda sorge spontanea: ma la persona che ti ha ucciso, non era per caso nostra alleata?",s:-1,l:13,p:0.5};
SIM[187] = {m:"Guarda il lato positivo: servirai da concime.",s:1,l:9,p:0.5};
SIM[188] = {m:"Per un momento ho pensato che ce l\'avresti fatta.",s:-1,l:6,p:0.5};
SIM[189] = {m:"Sei sicuro che stai bene? Sei tutto pallido.",s:-1,l:2,p:1};
SIM[190] = {m:"Non si sta poi così male per terra. Oi, mi ascolti o no? Svegliaaatii!",s:-1,l:11,p:1};
SIM[191] = {m:"Non si può dire che ti ha preso di striscio...",s:2,l:14,p:0.8};
SIM[192] = {m:"Ben ti sta! Così impari a lasciarmi morire di fame!",s:1,l:7,p:0.8};
SIM[193] = {m:"Non sono sicuro che tu sia veramente da compatire.",s:-1,l:3,p:0.4};
SIM[194] = {m:"Ben gli sta! Non doveva mettersi contro di te!",s:1,l:2,p:1};
SIM[195] = {m:"Ah, allora puoi sbagliare anche te...",s:-1,l:5,p:0.5};
SIM[196] = {m:"Non avrei voluto essere al suo posto.",s:-1,l:13,p:0.5};
SIM[197] = {m:"Almeno le sue sofferenze sono finite, non come le mie.",s:-1,l:11,p:1};
SIM[198] = {m:"Posso mangiare il suo equipaggiamento dopo?",s:-1,l:4,p:1};
SIM[199] = {m:"È fuori questione che il suo equipaggiamento tocchi le mie labbra.",s:3,l:6,p:1};
SIM[200] = {m:"La prossima volta che ti viene voglia di morire avvertimi, così cambio proprietario.",s:-1,l:5,p:1};
SIM[201] = {m:"Avrei fatto meglio a restare nel pacco regalo.",s:-1,l:10,p:0.2};
SIM[202] = {m:"Lo ammetto, ho mangiato mentre non guardavi.",s:-1,l:6,p:0.2};
SIM[203] = {m:"Di\' un po\', sei sicuro di non aver dimenticato qualcosa?",s:-1,l:9,p:1};
SIM[204] = {m:"Se tu fossi arrivato un minuto più tardi, sarei andato a cercare fortuna altrove.",s:-1,l:8,p:0.2};
SIM[205] = {m:"È questa l\'ora di arrivare?",s:3,l:4,p:1};
SIM[206] = {m:"Coccoooleee!!!",s:-1,l:6,p:1};
SIM[207] = {m:"Quanto mi sei mancato! Vieni a darmi un bacino...",s:-1,l:18,p:0.4};
SIM[208] = {m:"Che facciamo di appassionante oggi?",s:-1,l:19,p:0.8};
SIM[209] = {m:"Non dimenticare di salutare quando parti.",s:-1,l:10,p:1};
SIM[210] = {m:"Rivederti mi riempe di gioia.",s:-1,l:20,p:0.2};
SIM[211] = {m:"Oh, uno spaventoso goblin si è appena unito al combattimento!",s:-1,l:15,p:0.5};
SIM[212] = {m:"Ahahah, hai visto il livello di quello là?",s:2,l:10,p:0.5};
SIM[213] = {m:"Guarda! Un principiante, uno vero!",s:1,l:6,p:0.6};
SIM[214] = {m:"Eccone uno che non ha paura di morire.",s:-1,l:19,p:1};
SIM[215] = {m:"Cominciano a essere un po\' troppi, no?",s:-1,l:13,p:1};
SIM[216] = {m:"È il buon momento per svignarsela.",s:-1,l:8,p:0.7};
SIM[217] = {m:"Secondo me ti prendi una bella mazzata!",s:-1,l:5,p:0.6};
SIM[218] = {m:"Un giorno Fallanster ha detto: \"Fuggiamo, amici miei!\" Dovresti prenderlo come esempio.",s:-1,l:18,p:0.4};
SIM[219] = {m:"Dai, dammi un bacino, dai. Dimostrami che mi vuoi bene...",s:-1,l:16,p:0.3};
SIM[220] = {m:"Un giorno andrò a Bonta con te, tutte le notti a divertirci!",s:-1,l:8,p:0.6};
SIM[221] = {m:"Sai che c\'è? No, niente.",s:-1,l:7,p:1};
SIM[222] = {m:"La tua voce è dolce come quella di Mirlen il cantante.",s:-1,l:9,p:0.3};
SIM[223] = {m:"Guarda, ascolta come i fiori profumano.",s:-1,l:6,p:0.4};
SIM[224] = {m:"Non aver paura di ammetterlo, sono l\'amore della tua vita.",s:-1,l:10,p:0.1};
SIM[225] = {m:"L\'intendente Danathor puzza di gorgonzola. Dev\'essere per questo che non ha amici.",s:-1,l:5,p:0.2};
SIM[226] = {m:"Sai qual è la differenza tra un Sadida e Chewbecca?",s:2,l:4,p:0.3};
SIM[227] = {m:"E se andassimo a farci qualche Pappatutto per divertirci un po\'?",s:-1,l:2,p:1};
SIM[228] = {m:"Pensa se il perizoma del Buulupo fosse vivo... Brrr, solo a pensarci mi vengono i brividi.",s:-1,l:11,p:0.5};
SIM[229] = {m:"Sai cosa Allister sa sulle donne? Niente.",s:2,l:3,p:0.4};
SIM[230] = {m:"Se fossi un pareo, vorrei appartenere a un\'Aniripsa.",s:-1,l:12,p:0.2};
SIM[231] = {m:"Non è l\'ora di fare i compiti, per caso?",s:-1,l:2,p:0.7};
SIM[232] = {m:"Togliti immediatamente le dita dal naso!",s:3,l:13,p:0.4};
SIM[233] = {m:"Perché non posso essere forgimagiato? Che ingiustizia.",s:-1,l:15,p:0.3};
SIM[234] = {m:"Conosci la festa delle mutande? Di solito si cambiano lì. Ma se vuoi puoi anche farlo più spesso...",s:-1,l:6,p:0.5};
SIM[235] = {m:"È vero che le Yop sono carine, ma non come te.",s:-1,l:10,p:0.1};
SIM[236] = {m:"Sai che c\'è? Che ti voglio bene.",s:-1,l:20,p:0.1};
SIM[237] = {m:"Baci baci baci baci.",s:-1,l:5,p:1};
SIM[238] = {m:"Io e te, siamo i migliori amici del mondo.",s:-1,l:14,p:0.8};
SIM[239] = {m:"Stare con te è una figata!",s:-1,l:16,p:0.5};
SIM[240] = {m:"Lo sapevi che i Pappatutto sono tutti nudi sotto i peli? Un po\' come te d\'altronde.",s:-1,l:8,p:0.2};
SIM[241] = {m:"Per tua informazione, sappi che il Pandawa non è il We di Pandala.",s:-1,l:7,p:0.2};
SIM[242] = {m:"Sei brutto ma ti voglio bene lo stesso.",s:-1,l:8,p:0.1};
SIM[243] = {m:"Hai dei begli occhi lo sai? Ma va, sto scherzando!",s:2,l:12,p:0.6};
SIM[244] = {m:"Se mi lasci morire di fame, faccio il broncio.",s:3,l:14,p:0.8};
SIM[245] = {m:"Se tu mi nutrissi meglio, potrei tirarmela anch\'io.",s:-1,l:13,p:0.4};
SIM[246] = {m:"Nel caso non te ne fossi accorto, non sto facendo lo sciopero della fame.",s:-1,l:9,p:0.7};
SIM[247] = {m:"Sai qual è la differenza tra me e te? È che tu hai già mangiato.",s:-1,l:15,p:0.9};
SIM[248] = {m:"Se ti do un bacino, mi dai da mangiare?",s:-1,l:17,p:0.1};
SIM[249] = {m:"Puoi ordinarmi una pizza per cambiare un po\'?",s:-1,l:10,p:0.2};
SIM[250] = {m:"Oh tu, che sei il sole della mia vita... quand\'è che mangiamo?",s:-1,l:11,p:0.3};
SIM[251] = {m:"A forza di mangiare hamburger è normale che sia un po\' più rotondetto.",s:-1,l:9,p:1};
SIM[252] = {m:"Ho capito il tuo trucco. Mi metti all\'ingrasso per vendermi meglio.",s:-1,l:7,p:0.2};
SIM[253] = {m:"Farò tutto ciò che vuoi se la smetti di rimpinzarmi.",s:-1,l:12,p:1};
SIM[254] = {m:"Booorrp! Ops, scusa. A forza di mangiare troppo ho digerito male.",s:-1,l:5,p:0.5};
SIM[255] = {m:"Che differenza c\'è tra il peso di un maiale da latte e il mio? Nessuna.",s:-1,l:3,p:0.2};
SIM[256] = {m:"Non ne posso più, credo che vomiterò.",s:-1,l:2,p:1};
SIM[257] = {m:"Sono allewgico agli oggetti fabbwicati a base di cawota.",s:-1,l:11,p:0.5};
SIM[258] = {m:"Continua così e diventerò grasso come il re Allister.",s:-1,l:16,p:0.1};
SIM[259] = {m:"Non mi disturbare, sono in piena digestione.",s:-1,l:12,p:0.5};
SIM[260] = {m:"Booorrp! Scusa, mi è scappato.",s:-1,l:4,p:1};
SIM[261] = {m:"Non è possibile! Chi l\'ha fatta questa qui? In più brucia gli occhi.",s:3,l:10,p:0.2};
SIM[262] = {m:"Sono sicuro che se non avessi avuto tutti questi anelli al dito ce l\'avresti fatta.",s:-1,r:"9255",l:1,p:0.7};
SIM[263] = {m:"Dovrai vendere i tuoi anelli per rimborsare le perdite.",s:-1,r:"9255",l:10,p:0.5};
SIM[264] = {m:"Prova a metterti gli anelli agli alluci, vediamo se ti riesce meglio.",s:-1,r:"9255",l:15,p:1};
SIM[265] = {m:"Ben presto sarà il mio compleanno. Mi puoi preparare un Pizzamuleto?",s:-1,r:"9255",l:2,p:0.2};
SIM[266] = {m:"È merito mio, l\'ho colpito nell\'occhio!",s:1,r:"9255",l:14,p:0.4};
SIM[267] = {m:"Se non avessi avuto tutti quegli anelli non sarebbe accaduto.",s:-1,r:"9255",l:9,p:0.8};
SIM[268] = {m:"Non ascoltare quello che ti raccontano gli anelli, sono tutti bugiardi!",s:-1,r:"9255",l:18,p:0.7};
SIM[269] = {m:"Hai bisogno di diversi anelli. Ma io sono unico.",s:-1,r:"9255",l:19,p:0.1};
SIM[270] = {m:"Un anello non va bene. Due sono ancora peggio.",s:-1,r:"9255",l:17,p:0.3};
SIM[271] = {m:"Dovresti depositare i tuoi anelli in banca, saranno più al sicuro.",s:-1,r:"9255",l:16,p:0.4};
SIM[272] = {m:"Ho due amori nella mia vita: le collane... e te.",s:-1,r:"9255",l:20,p:0.2};
SIM[273] = {m:"Amuleto o calzoni? La decisione è stata rapida.",s:-1,r:"9255",l:4,p:0.5};
SIM[274] = {m:"Se non mi fai mangiare subito, stringo fino a soffocarti.",s:3,r:"9255",l:10,p:0.3};
SIM[275] = {m:"La caccola di naso sta alla tua bocca come l\'amuleto del Pìu sta alla mia.",s:-1,r:"9255",l:8,p:1};
SIM[276] = {m:"Se mangerò un amuleto del minatore oscuro mi trasformerò in una lucciola, vero?",s:-1,r:"9255",l:5,p:0.6};
SIM[277] = {m:"La spiga di Farle è la base di un\'alimentazione equilibrata.",s:-1,r:"9255",l:13,p:0.7};
SIM[278] = {m:"Se hai fame, mangi, vero? Ebbene, anch\'io!",s:-1,r:"9255",l:3,p:0.8};
SIM[279] = {m:"Se continui a rimpinzarmi così, finirò per assomigliare alle zinne di una sadida!",s:-1,r:"9255",l:12,p:0.2};
SIM[280] = {m:"Prenderei volentieri un Amuleto Argo per digerire meglio.",s:-1,r:"9255",l:6,p:0.5};
SIM[281] = {m:"Forse se gli dai un anello avrà pietà di te.",s:-1,r:"9255",l:7,p:0.8};
SIM[282] = {m:"Vista la sua goffaggine, potrai sbrigartela anche da solo.",s:-1,r:"9255",l:11,p:1};
SIM[283] = {m:"Buongiorno, mi porti da Moon oggi?",s:-1,r:"9255",l:15,p:0.4};
SIM[284] = {m:"Sei venuto a portarmi in viaggio culinario sull\'isola degli Wabbit?",s:-1,r:"9255",l:9,p:0.4};
SIM[285] = {m:"Se sei bravo è solo grazie alla destrezza che ti do.",s:-1,r:"9256",l:5,p:0.8};
SIM[286] = {m:"Non lo vincerai mica così questo combattimento.",s:3,r:"9256",l:18,p:1};
SIM[287] = {m:"Cosa volevi che facessi? Sono solo un anello io!",s:-1,r:"9256",l:11,p:0.6};
SIM[288] = {m:"Un anello va bene. Due sono meglio.",s:-1,r:"9256",l:4,p:0.5};
SIM[289] = {m:"Gli dei sono dodici, ma io sono l\'Unico!",s:-1,r:"9256",l:12,p:0.2};
SIM[290] = {m:"Ma guarda un po\' quest\'anello. Hai visto che mi fa l\'occhiolino?",s:-1,r:"9256",l:10,p:0.4};
SIM[291] = {m:"Se ti metti a letto con il sedere che ti prude, fammi il piacere di spostarmi prima di addormentarti.",s:-1,r:"9256",l:8,p:0.7};
SIM[292] = {m:"Non sono forse il più bel gioiello del Mondo dei Dodici?",s:-1,r:"9256",l:19,p:0.3};
SIM[293] = {m:"Hai le mani morbide, altro che il mio vecchio proprietario.",s:-1,r:"9256",l:16,p:0.2};
SIM[294] = {m:"Per me sei l\'Unico, nessuno potrà mai sostituirti.",s:-1,r:"9256",l:20,p:0.1};
SIM[295] = {m:"\"Un anello per domarli\". Qua parlano di me.",s:-1,r:"9256",l:11,p:0.5};
SIM[296] = {m:"Ene ene ene, quanto ti voglio bene!",s:-1,r:"9256",l:15,p:0.4};
SIM[297] = {m:"Ho un segreto da dirti nell\'orecchio: ti amerò alla follia per sempre. Yupi!",s:-1,r:"9256",l:15,p:0.4};
SIM[298] = {m:"Sì grattati, fai come se non ci fossi nemmeno.",s:-1,r:"9256",l:2,p:0.4};
SIM[299] = {m:"Non mi rinchiudere nel forziere di una banca. Abbi pietà!",s:-1,r:"9256",l:3,p:0.2};
SIM[300] = {m:"Mi odi così tanto che vuoi vedermi morire di fame.",s:-1,r:"9256",l:6,p:0.2};
SIM[301] = {m:"Ho fame! Dov\'è il Gelano che mi avevi promesso?",s:-1,r:"9256",l:9,p:0.5};
SIM[302] = {m:"La caccola di naso sta alla tua bocca come l\'anello del Pìu sta alla mia.",s:-1,r:"9256",l:8,p:1};
SIM[303] = {m:"Dammi da mangiare l\'anello dei guenelupi benedetti e ti coprirò di ricchezze.",s:-1,r:"9256",l:13,p:0.2};
SIM[304] = {m:"Fammi mangiare quanto vuoi, tanto non ingrasserò.",s:-1,r:"9256",l:14,p:0.8};
SIM[305] = {m:"Vuoi il mio? È più grosso.",s:3,r:"9256",l:6,p:0.5};
SIM[306] = {m:"Ecco il piano: tu li tieni e io vado a cercare aiuto.",s:-1,r:"9256",l:17,p:0.7};
SIM[307] = {m:"Spiacente, non credo di avere la forza di combattere.",s:-1,r:"9256",l:7,p:0.8};
SIM[308] = {m:"Eccoti finalmente! Credevo mi avessi dimenticato. T_T",s:-1,r:"9256",l:10,p:0.4};
SIM[309] = {m:"La prossima volta non dimenticare di spostarmi quando ti gratterai il sedere.",s:-1,r:"9256",l:1,p:1};
SIM[310] = {m:"Pestagli il piede, mordigli il braccio, schiacciagli la testa.",s:-1,r:"9233",l:4,p:0.5};
SIM[311] = {m:"Hei tu, perché attacchi il mio proprietario?",s:-1,r:"9233",l:9,p:0.3};
SIM[312] = {m:"Ecco, ora ti riconosco.",s:-1,r:"9233",l:10,p:0.8};
SIM[313] = {m:"Ben presto sarà il mio compleanno. Mi puoi preparare un Mantelcake?",s:-1,r:"9233",l:2,p:0.2};
SIM[314] = {m:"Il mio vecchio proprietario era molto più bravo. Normale, era un Etram.",s:-1,r:"9233",l:11,p:0.4};
SIM[315] = {m:"Ho fatto quel che ho potuto per proteggerti, ma non è bastato.",s:-1,r:"9233",l:13,p:0.2};
SIM[316] = {m:"Nessuno ti protegge bene come me.",s:-1,r:"9233",l:19,p:0.7};
SIM[317] = {m:"Credimi, se avessi potuto, gli avrei dato una bella lezione.",s:-1,r:"9233",l:14,p:0.5};
SIM[318] = {m:"Se non restassi sdradiato su di me sarebbe meglio.",s:3,r:"9233",l:6,p:0.8};
SIM[319] = {m:"Posso proteggerti da molte cose, ma non dalla tua stupidità.",s:-1,r:"9233",l:4,p:0.7};
SIM[320] = {m:"Ho freddo. Perché ti scaldo sempre io, e mai il contrario?",s:-1,r:"9233",l:1,p:0.4};
SIM[321] = {m:"Dovresti dipingermi di rosso e mettermi collant blu e stivali rossi, faremmo furore!",s:-1,r:"9233",l:5,p:0.2};
SIM[322] = {m:"Se sapessi tutto quello che si dice alle tue spalle, ne saresti stupito.",s:-1,r:"9233",l:7,p:0.2};
SIM[323] = {m:"Vieni a metterti al caldo vicino a me.",s:-1,r:"9233",l:12,p:0.4};
SIM[324] = {m:"Persino il re Allister in persona non possiede simili ornamenti.",s:-1,r:"9233",l:20,p:0.2};
SIM[325] = {m:"Sono il re dei re!",s:-1,r:"9233",l:15,p:0.3};
SIM[326] = {m:"Non sono un tovagliolo né uno straccio. Io sono un mantello!",s:-1,r:"9233",l:18,p:1};
SIM[327] = {m:"Perché sono sempre io a sorbirmi le tue ascelle e il tuo didietro?",s:-1,r:"9233",l:13,p:0.2};
SIM[328] = {m:"Abbi pietà, non mettermi nella biancheria sporca! Non dirò più niente sulla tua bruttezza.",s:-1,r:"9233",l:13,p:0.4};
SIM[329] = {m:"La prossima volta che avrai bisogno di andare in bagno, ricordati che sono dietro!",s:-1,r:"9233",l:7,p:1};
SIM[330] = {m:"La caccola di naso sta alla tua bocca come il mantello del Pìu sta alla mia.",s:-1,r:"9233",l:8,p:1};
SIM[331] = {m:"A forza di stare a dieta finirò per assomigliare a un mantello di poolay vibrardente.",s:-1,r:"9233",l:12,p:0.5};
SIM[332] = {m:"I gelontelli sono buoni ma si attaccano ai denti.",s:-1,r:"9233",l:9,p:0.4};
SIM[333] = {m:"Credo di aver fatto la mia scorta per l\'inverno.",s:-1,r:"9233",l:10,p:0.6};
SIM[334] = {m:"Tu prendi quello di sinistra, io mi occupo di quello di destra.",s:-1,r:"9233",l:17,p:1};
SIM[335] = {m:"Lasciami. Lasciami.",s:-1,r:"9233",l:16,p:0.8};
SIM[336] = {m:"Pfff. Questo nemico non merita neanche attenzione.",s:-1,r:"9233",l:18,p:0.5};
SIM[337] = {m:"È un uomo o una donna?... non vedo bene da qui.",s:2,r:"9233",l:13,p:0.3};
SIM[338] = {m:"All\'improvviso si sente un cattivo odore. Ah, sei arrivato?",s:-1,r:"9233",l:3,p:0.2};
SIM[339] = {m:"Ti assicuro, non è altro che un triste malinteso.",s:-1,r:"9234",l:6,p:0.4};
SIM[340] = {m:"Bene! Tanto di cappello.",s:-1,r:"9234",l:7,p:0.5};
SIM[341] = {m:"Ben presto sarà il mio compleanno. Mi puoi preparare un Caskake?",s:-1,r:"9234",l:2,p:0.2};
SIM[342] = {m:"Se tu indossassi la HmmMmmMmm avrei potuto capire, ma così... È inammissibile!",s:3,r:"9234",l:18,p:0.3};
SIM[343] = {m:"Smettila di fare lo sciocco.",s:3,r:"9234",l:11,p:0.5};
SIM[344] = {m:"Per gli dei che mazzata! Fortunatamente che ci sono ancora io qua con te.",s:-1,r:"9234",l:16,p:0.5};
SIM[345] = {m:"Quest\'individuo non meritava assolutamente di combattere al tuo fianco.",s:-1,r:"9234",l:15,p:0.3};
SIM[346] = {m:"Devo fare il morto anch\'io?",s:-1,r:"9234",l:5,p:0.4};
SIM[347] = {m:"Niente da dire, stai benissimo.",s:-1,r:"9234",l:15,p:0.8};
SIM[348] = {m:"Siccome sono vivo e abito sopra la tua testa, sono io il tuo cervello.",s:-1,r:"9234",l:16,p:0.5};
SIM[349] = {m:"Persino il re Allister in persona deve essere invidioso del fatto che ti appartengo.",s:-1,r:"9234",l:13,p:0.2};
SIM[350] = {m:"Guarda quel cappello ridicolo. Nessuna eleganza!",s:2,r:"9234",l:9,p:0.5};
SIM[351] = {m:"Da qui posso vedere cosa c\'è nelle tue orecchie... e non è tanto bello.",s:-1,r:"9234",l:6,p:0.2};
SIM[352] = {m:"Se hai tanto successo è grazie a me, non dimenticarlo.",s:-1,r:"9234",l:20,p:0.4};
SIM[353] = {m:"Se fossi stato un mantello non avrai mai più freddo, ma non sono che un umile copricapo.",s:-1,r:"9234",l:10,p:0.6};
SIM[354] = {m:"Le donne Sadida hanno belle forme, proprio come me.",s:-1,r:"9234",l:17,p:0.2};
SIM[355] = {m:"Le corna del Rushu sono miseri ornamenti paragonati a me.",s:-1,r:"9234",l:19,p:0.1};
SIM[356] = {m:"Sai perché i più grandi maghi hanno un cappello? Perché vogliono assomigliarti.",s:-1,r:"9234",l:20,p:0.1};
SIM[357] = {m:"Sai perché i più grandi maghi hanno un cappello? Perché sono più bravi di te.",s:1,r:"9234",l:14,p:0.3};
SIM[358] = {m:"Chiunque altro sarebbe felice d\'avermi al suo fianco.",s:-1,r:"9234",l:5,p:0.2};
SIM[359] = {m:"Io proteggo la tua testa dal sole, ma chi protegge me?",s:-1,r:"9234",l:10,p:0.4};
SIM[360] = {m:"La caccola di naso sta alla tua bocca come il cappello del Pìu sta alla mia.",s:-1,r:"9234",l:8,p:1};
SIM[361] = {m:"Se la tua bellezza è grande, la mia fame lo è ancora di più.",s:-1,r:"9234",l:4,p:0.6};
SIM[362] = {m:"Credi che potrei ingoiare un Dofus?",s:-1,r:"9234",l:11,p:0.3};
SIM[363] = {m:"Se mi dai un Fungocapo ti vomito addosso, stai attento.",s:-1,r:"9234",l:12,p:0.2};
SIM[364] = {m:"È un inferno di pulci qua. Se credi che le mangerò ti sbagli. Non sono così affamato.",s:-1,r:"9234",l:1,p:0.1};
SIM[365] = {m:"Ricordati di lavarti i capelli più di una volta l\'anno!",s:-1,r:"9234",l:3,p:0.2};
SIM[366] = {m:"Ecco un nemico degno d\'interesse.",s:-1,r:"9234",l:8,p:0.2};
SIM[367] = {m:"Ho creduto per un istante che fosse un nuovo nemico, invece è solo qualcuno che si è perso.",s:-1,r:"9234",l:7,p:0.3};
